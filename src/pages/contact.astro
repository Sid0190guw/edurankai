---
import BaseLayout from '@/layouts/BaseLayout.astro';
import postgres from 'postgres';

const databaseUrl = import.meta.env.DATABASE_URL || process.env.DATABASE_URL;
const sql = postgres(databaseUrl, { max: 1 });

let errorMsg = '';
let successMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const honeypot = (fd.get('website') as string || '').trim();
  const name = (fd.get('name') as string || '').trim();
  const email = (fd.get('email') as string || '').trim();
  const subject = (fd.get('subject') as string || '').trim();
  const category = (fd.get('category') as string || '').trim();
  const message = (fd.get('message') as string || '').trim();

  if (honeypot) {
    // Silent success for bots
    successMsg = 'Thanks. We will get back to you within 2 business days.';
  } else if (!email) {
    errorMsg = 'Please enter your email.';
  } else if (!message) {
    errorMsg = 'Please write a message.';
  } else if (message.length > 5000) {
    errorMsg = 'Message too long. Please keep it under 5000 characters.';
  } else if (!email.match(/^[^\s@]+@[^\s@]+\.[^\s@]+$/)) {
    errorMsg = 'Please enter a valid email address.';
  } else {
    try {
      const ipHeader = Astro.request.headers.get('x-forwarded-for') || Astro.request.headers.get('cf-connecting-ip') || '';
      const ua = Astro.request.headers.get('user-agent') || '';

      await sql`
        INSERT INTO contact_submissions (name, email, subject, category, message, ip_address, user_agent)
        VALUES (
          ${name || null},
          ${email},
          ${subject || null},
          ${category || null},
          ${message},
          ${ipHeader.substring(0, 64)},
          ${ua}
        );
      `;
      successMsg = 'Thanks. We will get back to you within 2 business days.';
    } catch (err: any) {
      errorMsg = 'Sorry, something went wrong. Please email hr@edurankai.in directly.';
    }
  }
}

await sql.end();

const CATEGORIES = [
  { value: 'hiring', label: 'Hiring / application question' },
  { value: 'partnership', label: 'Partnership / collaboration' },
  { value: 'press', label: 'Press / media' },
  { value: 'product', label: 'Product question / feedback' },
  { value: 'general', label: 'General inquiry' }
];
---
<BaseLayout title="Contact - EduRankAI" description="Get in touch with EduRankAI.">

  <section class="px-[5vw] py-10 md:py-16 max-w-2xl mx-auto">

    <div class="mb-8">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-2">CONTACT</p>
      <h1 class="font-display text-[clamp(2rem,5vw,3rem)] font-semibold text-ink leading-[1.05] tracking-tight mb-3">
        Get in <em class="italic text-burn font-medium">touch.</em>
      </h1>
      <p class="text-[0.95rem] text-ink-soft leading-relaxed">
        For hiring questions, partnerships, press, or anything else - send us a message below or email us directly. We aim to reply within 2 business days.
      </p>
    </div>

    <div class="bg-cream-2 border border-ink/10 rounded-2xl p-5 md:p-6 mb-6">
      <p class="text-[0.62rem] font-mono uppercase tracking-wider text-ink-soft font-bold mb-2">Direct email</p>
      <a href="mailto:hr@edurankai.in" class="text-burn hover:underline font-semibold text-[1.05rem]">hr@edurankai.in</a>
      <p class="text-[0.78rem] text-ink-soft mt-1.5">For applications, use our <a href="/careers" class="text-burn hover:underline">Careers page</a>. The form below is for everything else.</p>
    </div>

    {successMsg && (
      <div class="bg-leaf-bg/40 border border-leaf-border text-leaf rounded-lg p-4 mb-5 text-[0.88rem] leading-relaxed">
        {successMsg}
      </div>
    )}

    {errorMsg && (
      <div style="background:rgba(220,38,38,0.06);border:1px solid rgba(220,38,38,0.25);color:#b91c1c;font-size:0.85rem;padding:12px 14px;border-radius:8px;margin-bottom:18px;line-height:1.6;">
        {errorMsg}
      </div>
    )}

    {!successMsg && (
      <form method="POST" class="bg-white border border-ink/10 rounded-2xl p-5 md:p-6 flex flex-col gap-4">

        <div style="position:absolute;left:-9999px;">
          <label>Website (leave blank)</label>
          <input type="text" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Your name</label>
            <input type="text" name="name" placeholder="Jane Doe" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
          </div>
          <div>
            <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Email <span class="text-burn">*</span></label>
            <input type="email" name="email" required placeholder="you@example.com" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
          </div>
        </div>

        <div>
          <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">What is this about?</label>
          <select name="category" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2">
            <option value="">Choose a category...</option>
            {CATEGORIES.map((c) => (
              <option value={c.value}>{c.label}</option>
            ))}
          </select>
        </div>

        <div>
          <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Subject</label>
          <input type="text" name="subject" placeholder="One-line summary of your message" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
        </div>

        <div>
          <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Message <span class="text-burn">*</span></label>
          <textarea name="message" required rows="6" maxlength="5000" placeholder="Tell us what you would like to discuss..." class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 resize-y leading-relaxed"></textarea>
        </div>

        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3 pt-2">
          <p class="text-[0.72rem] text-ink-soft italic">We read every message. Replies within 2 business days.</p>
          <button type="submit" class="bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-6 rounded-lg text-[0.9rem] transition-all flex items-center justify-center gap-2">
            Send message
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </button>
        </div>

      </form>
    )}

    {successMsg && (
      <div class="text-center mt-4">
        <a href="/" class="text-[0.85rem] text-burn font-semibold hover:underline">Back to home -&gt;</a>
      </div>
    )}

  </section>

</BaseLayout>
