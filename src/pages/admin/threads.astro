---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

// Vis-vambhara threads
let visv: any[] = [];
try {
  visv = rows(await db.execute(sql`
    SELECT v.id, v.status, v.note AS subject,
      COALESCE(v.last_message_at, v.created_at) AS last_message_at,
      v.last_message_by, COALESCE(v.unread_admin, 0) AS unread_admin,
      v.created_at, u.email AS applicant_email, u.name AS applicant_name
    FROM visvambhara_access_requests v
    LEFT JOIN users u ON u.id = v.user_id
    ORDER BY COALESCE(v.last_message_at, v.created_at) DESC
    LIMIT 100
  `)).map((r: any) => ({
    ...r, kind: 'visvambhara_access', title: 'Vis-vambhara access',
    href: '/admin/visvambhara-access?req=' + r.id,
  }));
} catch (_) {}

// Fee waiver threads
let waivers: any[] = [];
try {
  waivers = rows(await db.execute(sql`
    SELECT w.id, w.status, w.situation_note AS subject,
      COALESCE(w.last_message_at, w.created_at) AS last_message_at,
      COALESCE(w.unread_admin, 0) AS unread_admin,
      w.created_at, u.email AS applicant_email, u.name AS applicant_name
    FROM application_fee_waivers w
    LEFT JOIN users u ON u.id = w.user_id
    ORDER BY COALESCE(w.last_message_at, w.created_at) DESC
    LIMIT 100
  `)).map((r: any) => ({
    ...r, kind: 'fee_waiver', title: 'Fee waiver',
    href: '/admin/fee-waivers?status=' + r.status + '&req=' + r.id,
  }));
} catch (_) {}

const all = [...visv, ...waivers].sort((a, b) => new Date(b.last_message_at || 0).getTime() - new Date(a.last_message_at || 0).getTime());

const url = new URL(Astro.request.url);
const filter = url.searchParams.get('kind') || 'all';
const filtered = filter === 'all' ? all : all.filter(r => r.kind === filter);
const totalUnread = all.reduce((acc, r) => acc + (r.unread_admin || 0), 0);

function fmt(d: any): string {
  try { return new Date(d).toLocaleString('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); } catch { return ''; }
}
function statusColor(s: string) {
  if (s === 'approved') return { bg: 'rgba(16,185,129,0.15)', fg: '#6ee7b7' };
  if (s === 'rejected') return { bg: 'rgba(239,68,68,0.15)', fg: '#fca5a5' };
  return { bg: 'rgba(251,191,36,0.15)', fg: '#fbbf24' };
}
---
<AdminLayout title="All threads" activeNav="">
<div style="padding-bottom:80px;">
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">Admissions &middot; Communications</p>
    <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0 0 4px;">All open threads {totalUnread > 0 && <span style="background:#FF4F00;color:#fff;font-size:11px;font-weight:700;padding:2px 8px;border-radius:100px;margin-left:8px;">{totalUnread} unread</span>}</h1>
    <p style="font-size:11.5px;color:#9aa6b6;margin:0 0 10px;">Every admin&harr;applicant conversation - Vis-vambhara access requests, fee waivers, and more.</p>
    <div style="display:flex;gap:4px;flex-wrap:wrap;">
      {[
        { k: 'all',                l: 'All',           c: all.length },
        { k: 'visvambhara_access', l: 'Vis-vambhara',  c: visv.length },
        { k: 'fee_waiver',         l: 'Fee waivers',   c: waivers.length },
      ].map((t: any) => (
        <a href={`?kind=${t.k}`} style={`text-decoration:none;font-size:12px;font-weight:600;padding:6px 12px;border-radius:6px;${filter === t.k ? 'background:#FF7040;color:#0a0a0c;' : 'background:#15151a;color:#8a8a94;'}`}>{t.l} ({t.c})</a>
      ))}
    </div>
  </div>

  <div style="padding:14px 16px;display:flex;flex-direction:column;gap:10px;">
    {filtered.length === 0 && <p style="color:#6e6e78;font-size:13px;text-align:center;padding:40px;">No threads.</p>}
    {filtered.map((r: any) => {
      const sc = statusColor(r.status);
      return (
        <a href={r.href} style="text-decoration:none;color:inherit;background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px 16px;display:flex;flex-direction:column;gap:6px;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;">
            <div style="min-width:0;flex:1;">
              <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 3px;">{r.title}</p>
              <p style="font-size:14px;font-weight:700;color:#fff;margin:0;">{r.applicant_name || r.applicant_email || 'Unknown'}</p>
              <p style="font-size:11px;color:#8a8a94;margin:2px 0 0;font-family:'Geist Mono',monospace;">{r.applicant_email}</p>
            </div>
            <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;">
              <span style={`font-size:10px;font-weight:700;padding:2px 8px;border-radius:100px;text-transform:uppercase;background:${sc.bg};color:${sc.fg};`}>{r.status}</span>
              {r.unread_admin > 0 && <span style="background:#FF4F00;color:#fff;font-size:10px;font-weight:700;padding:2px 8px;border-radius:100px;">{r.unread_admin} new</span>}
              <span style="font-size:10.5px;color:#6e6e78;">{fmt(r.last_message_at)}</span>
            </div>
          </div>
          <p style="font-size:12.5px;color:#d8d8de;margin:4px 0 0;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{(r.subject || '').toString().substring(0, 220)}</p>
        </a>
      );
    })}
  </div>
</div>
</AdminLayout>
