---
// /admin/observability — platform admin & observability (Prompt 22). STRICTLY superadmin
// (can(administer)). Consolidated cross-subsystem audit + system health + feature flags. Real data.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { consolidatedAudit, healthCheck, getFlags, isEnabled, KNOWN_FEATURES } from '@/lib/observability';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'administer', { type: 'platform' });
if (!gate.allow) return Astro.redirect('/admin');

const u = Astro.url.searchParams;
const p = Math.max(0, parseInt(u.get('p') || '0', 10) || 0);
const audit = await consolidatedAudit({ actor: u.get('actor') || '', capability: u.get('cap') || '', resource: u.get('res') || '', decision: u.get('dec') || '', from: u.get('from') || '', to: u.get('to') || '', limit: 50, offset: p * 50 });
const health = await healthCheck().catch(() => null);
const flags = await getFlags().catch(() => []);

const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const IN = 'background:#15151a;border:1px solid #26262c;color:#fff;padding:7px 9px;border-radius:6px;font-size:12px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
function fmt(d: any) { try { return new Date(d).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit', second: '2-digit' }); } catch { return '-'; } }
function pill(okv: boolean) { return okv ? '<span style="color:#6ee7b7;">OK</span>' : '<span style="color:#fca5a5;">off</span>'; }
---
<AdminLayout title="Observability" activeNav="observability">
  <div style="max-width:1120px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Superadmin</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Platform observability</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">Consolidated audit, real health, and feature flags. Superadmin only.</p>
    <div id="msg" style="display:none;margin:12px 0;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <!-- HEALTH -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;margin:16px 0;">
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Database</p><p style="font-size:20px;font-weight:800;margin:4px 0 0;" set:html={pill(!!health?.db)}></p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">AI provider</p><p style="font-size:20px;font-weight:800;margin:4px 0 0;" set:html={pill(!!health?.providers?.llm)}></p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Credential signing</p><p style="font-size:20px;font-weight:800;margin:4px 0 0;" set:html={pill(!!health?.providers?.credentialSigning)}></p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Sync queue</p><p style="font-size:20px;font-weight:800;color:#fff;margin:4px 0 0;">{health?.queues?.syncPending ?? 0}</p></div>
    </div>

    <!-- FEATURE FLAGS -->
    <div style={CARD}>
      <p style={HD}>Feature flags (disable a subsystem's routes safely)</p>
      <div style="display:flex;flex-wrap:wrap;gap:14px;">{KNOWN_FEATURES.map((k) => (
        <label style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#cfd6da;"><input type="checkbox" class="flag" data-k={k} checked={isEnabled(flags, k)} /> {k}</label>
      ))}</div>
      <p style="font-size:10.5px;color:#6e6e78;margin:8px 0 0;">Unchecking disables that subsystem's write routes immediately. Saved on change.</p>
    </div>

    <!-- CONSOLIDATED AUDIT -->
    <div style={CARD}>
      <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:10px;">
        <p style={HD + 'margin:0;'}>Consolidated audit &middot; {audit.total} rows</p>
        <form method="GET" style="display:flex;gap:5px;flex-wrap:wrap;">
          <input name="actor" value={u.get('actor') || ''} placeholder="actor" style={IN + 'width:110px;'} />
          <input name="cap" value={u.get('cap') || ''} placeholder="capability" style={IN + 'width:110px;'} />
          <input name="res" value={u.get('res') || ''} placeholder="resource" style={IN + 'width:130px;'} />
          <select name="dec" style={IN}><option value="">all</option><option value="allow" selected={u.get('dec') === 'allow'}>allow</option><option value="deny" selected={u.get('dec') === 'deny'}>deny</option></select>
          <input name="from" value={u.get('from') || ''} type="date" style={IN} /><input name="to" value={u.get('to') || ''} type="date" style={IN} />
          <button type="submit" style="background:#15151a;border:1px solid #26262c;color:#cfd6da;font-size:11px;padding:6px 11px;border-radius:6px;cursor:pointer;">Filter</button>
        </form>
      </div>
      <div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:11.5px;font-family:'Geist Mono',monospace;">
        <thead><tr style="color:#8a8a94;font-size:9px;text-transform:uppercase;text-align:left;"><th style="padding:5px 8px;">When</th><th style="padding:5px 8px;">Actor</th><th style="padding:5px 8px;">Cap</th><th style="padding:5px 8px;">Resource</th><th style="padding:5px 8px;">Decision</th></tr></thead>
        <tbody>{audit.rows.length === 0 ? <tr><td colspan="5" style="padding:14px;text-align:center;color:#6e6e78;font-family:sans-serif;">No audit rows match.</td></tr> :
          audit.rows.map((a: any) => (<tr style="border-top:1px solid #15151a;"><td style="padding:5px 8px;color:#8a8a94;white-space:nowrap;">{fmt(a.at)}</td><td style="padding:5px 8px;color:#cfd6da;">{a.user_name || (a.user_id ? String(a.user_id).slice(0, 8) : 'anon')}</td><td style="padding:5px 8px;color:#cfd6da;">{a.capability}</td><td style="padding:5px 8px;color:#8a8a94;">{a.resource}</td><td style={'padding:5px 8px;font-weight:700;color:' + (a.allow ? '#6ee7b7' : '#fca5a5')}>{a.allow ? 'ALLOW' : 'DENY'}</td></tr>))}
        </tbody>
      </table></div>
      <div style="display:flex;justify-content:space-between;margin-top:10px;font-size:11.5px;color:#8a8a94;"><span>Page {p + 1} of {Math.max(1, Math.ceil(audit.total / 50))}</span></div>
    </div>
  </div>

  <script is:inline>
    (function () {
      var msg = document.getElementById('msg');
      document.querySelectorAll('.flag').forEach(function (c) { c.addEventListener('change', function () {
        fetch('/api/admin/observability', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ key: c.getAttribute('data-k'), enabled: c.checked }) })
          .then(function (r) { return r.json(); }).then(function (j) { msg.style.display = 'block'; msg.textContent = j.ok ? ('Flag ' + c.getAttribute('data-k') + ' ' + (c.checked ? 'enabled' : 'disabled') + '.') : (j.error || 'Failed'); msg.style.background = j.ok ? 'rgba(16,185,129,0.12)' : 'rgba(239,68,68,0.12)'; msg.style.color = j.ok ? '#6ee7b7' : '#fca5a5'; });
      }); });
    })();
  </script>
</AdminLayout>
