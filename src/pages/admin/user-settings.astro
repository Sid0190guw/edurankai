---
// /admin/user-settings — read-only student-settings inspector (Prompt 14, admin surface). Gated by
// can(audit, settings). View a user's runtime-affecting settings + consent to assist support.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { can } from '@/lib/rbac';
import { getProfile } from '@/lib/student-settings';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'audit', { type: 'settings' });
if (!gate.allow) return Astro.redirect('/admin');
const rows = (r: any): any[] => (Array.isArray(r) ? r : (r?.rows || []));
const q = (Astro.url.searchParams.get('u') || '').trim();
const users = rows(await db.execute(sql`SELECT id, name, email FROM users ${q ? sql`WHERE name ILIKE ${'%' + q + '%'} OR email ILIKE ${'%' + q + '%'}` : sql``} ORDER BY name LIMIT 40`));
const sel = (Astro.url.searchParams.get('s') || '').trim();
const profile = sel ? await getProfile(sel) : null;
const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const IN = 'background:#15151a;border:1px solid #26262c;color:#fff;padding:7px 9px;border-radius:6px;font-size:12px;';
---
<AdminLayout title="User settings" activeNav="user-settings">
  <div style="max-width:900px;margin:0 auto;padding:24px;">
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0 0 4px;">Student settings</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:0 0 16px;">Read-only view of the settings that feed the runtime. Students edit their own at /aquintutor/settings.</p>
    <form method="GET" style="display:flex;gap:6px;margin-bottom:14px;"><input name="u" value={q} placeholder="search name / email" style={IN + 'width:260px;'} /><button type="submit" style="background:#15151a;border:1px solid #26262c;color:#cfd6da;font-size:11px;padding:6px 11px;border-radius:6px;cursor:pointer;">Search</button></form>
    <div style="display:grid;grid-template-columns:280px 1fr;gap:16px;" class="us-grid">
      <div style={CARD}>{users.map((u: any) => <a href={'?u=' + encodeURIComponent(q) + '&s=' + u.id} style={'display:block;text-decoration:none;padding:7px 9px;border-radius:7px;font-size:12.5px;' + (u.id === sel ? 'background:rgba(255,79,0,0.14);color:#fff;' : 'color:#cfd6da;')}>{u.name}<br/><span style="color:#8a8a94;font-size:10.5px;">{u.email}</span></a>)}</div>
      <div style={CARD}>{!profile ? <p style="color:#6e6e78;font-size:12.5px;margin:0;">Select a user.</p> :
        <pre style="font-family:'Geist Mono',monospace;font-size:12px;color:#cfd6da;white-space:pre-wrap;margin:0;">{JSON.stringify(profile, null, 2)}</pre>}</div>
    </div>
  </div>
  <style>@media (max-width:720px){ .us-grid{ grid-template-columns:1fr !important; } }</style>
</AdminLayout>
