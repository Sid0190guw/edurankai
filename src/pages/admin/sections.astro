---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

// SVG section glyphs (house rule: no emoji). Renders at 18px, stroke:currentColor.
function secIcon(name: string) {
  const P: Record<string, string> = {
    grid: '<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>',
    users: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
    book: '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
    globe: '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/>',
    mail: '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
  };
  const inner = P[name] || '<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M14 17.5a3.5 3.5 0 1 0 7 0 3.5 3.5 0 0 0-7 0"/>';
  return '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">' + inner + '</svg>';
}

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

let okMsg = '';
let errorMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  try {
    if (action === 'create_section') {
      const name = (fd.get('name') as string || '').trim();
      const slug = (fd.get('slug') as string || '').trim().toLowerCase().replace(/[^a-z0-9-]/g, '-');
      const description = (fd.get('description') as string || '').trim() || null;
      const icon = (fd.get('icon') as string || 'grid').trim();
      const color = (fd.get('color') as string || '#6e6e78').trim();
      if (!name || !slug) { errorMsg = 'Name and slug required.'; }
      else {
        await db.execute(sql`
          INSERT INTO custom_sections (name, slug, description, icon, color, created_by)
          VALUES (${name}, ${slug}, ${description}, ${icon}, ${color}, ${user.id})
        `);
        okMsg = `Section "${name}" created. It will appear in the nav.`;
      }
    } else if (action === 'toggle_section') {
      const id = fd.get('id') as string;
      const current = await db.execute(sql`SELECT is_active FROM custom_sections WHERE id = ${id} LIMIT 1`);
      const _currentRows = Array.isArray(current) ? current : (current?.rows || []);
      if (_currentRows.length > 0) {
        const isActive = (_currentRows[0] as any).is_active;
        await db.execute(sql`UPDATE custom_sections SET is_active = ${!isActive}, updated_at = NOW() WHERE id = ${id}`);
        okMsg = isActive ? 'Section hidden.' : 'Section activated.';
      }
    } else if (action === 'delete_section') {
      const id = fd.get('id') as string;
      await db.execute(sql`DELETE FROM custom_sections WHERE id = ${id}`);
      okMsg = 'Section deleted.';
    } else if (action === 'add_page') {
      const sectionId = fd.get('sectionId') as string;
      const name = (fd.get('name') as string || '').trim();
      const slug = (fd.get('slug') as string || '').trim().toLowerCase().replace(/[^a-z0-9-]/g, '-');
      const description = (fd.get('description') as string || '').trim() || null;
      const icon = (fd.get('icon') as string || 'document').trim();
      const toolType = (fd.get('toolType') as string || 'list').trim();
      if (!name || !slug || !sectionId) { errorMsg = 'Name, slug and section required.'; }
      else {
        await db.execute(sql`
          INSERT INTO custom_section_pages (section_id, name, slug, description, icon, tool_type)
          VALUES (${sectionId}, ${name}, ${slug}, ${description}, ${icon}, ${toolType})
        `);
        okMsg = `Page "${name}" added to section.`;
      }
    }
  } catch (e: any) {
    errorMsg = 'Error: ' + (e.message || 'Unknown');
  }
}

const url = new URL(Astro.request.url);
const selectedId = url.searchParams.get('section') || '';

let sections: any[] = [];
try {
  const r = await db.execute(sql`SELECT * FROM custom_sections ORDER BY sort_order, created_at`);
  sections = (Array.isArray(r) ? r : (r?.rows || [])) as any[];
} catch(e) {}

let pages: any[] = [];
if (selectedId) {
  try {
    const r = await db.execute(sql`SELECT * FROM custom_section_pages WHERE section_id = ${selectedId} ORDER BY sort_order, created_at`);
    pages = (Array.isArray(r) ? r : (r?.rows || [])) as any[];
  } catch(e) {}
}

const selectedSection = sections.find(s => s.id === selectedId);

const ICONS = ['grid','document','users','calendar','chart','shield','book','star','globe','mail','package','briefcase'];
const TOOL_TYPES = [
  { value: 'list', label: 'List / Table' },
  { value: 'kanban', label: 'Kanban Board' },
  { value: 'form', label: 'Form / Entry' },
  { value: 'gallery', label: 'Gallery' },
  { value: 'dashboard', label: 'Dashboard' },
  { value: 'content', label: 'Content Editor' },
];
---
<AdminLayout title="Custom Sections" activeNav="sections">
<div style="padding-bottom:80px;">

  <!-- Header -->
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
      <div>
        <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">Platform</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Custom Sections</h1>
      </div>
      <button onclick="document.getElementById('newSectionModal').style.display='flex'" style="background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:12px;padding:8px 14px;border-radius:8px;cursor:pointer;">+ New Section</button>
    </div>
    <p style="font-size:11px;color:#6e6e78;margin:0;">Create product sections like Sampark, Sambandh, etc. with their own tools and nav entries.</p>
  </div>

  {errorMsg && <div style="margin:10px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  <!-- Sections list -->
  <div style="padding:12px 16px;display:flex;flex-direction:column;gap:8px;">
    {sections.length === 0 && (
      <div style="text-align:center;padding:48px;color:#6e6e78;">
        <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom:8px;opacity:0.7;"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M14 17.5a3.5 3.5 0 1 0 7 0 3.5 3.5 0 0 0-7 0"/></svg>
        <p style="font-size:13px;">No custom sections yet.</p>
        <p style="font-size:12px;margin-top:4px;">Create your first section for Sampark, Sambandh, or any new product.</p>
      </div>
    )}
    {sections.map((s: any) => (
      <div style={`background:#0f0f14;border:2px solid ${selectedId === s.id ? s.color || '#FF4F00' : '#1a1a1f'};border-radius:12px;overflow:hidden;`}>
        <div style="padding:12px 14px;display:flex;align-items:center;gap:12px;">
          <div style={`width:40px;height:40px;border-radius:10px;background:${s.color}22;border:1px solid ${s.color}44;display:flex;align-items:center;justify-content:center;color:${s.color || '#FF4F00'};flex-shrink:0;`}>
            <span style="display:flex;" set:html={secIcon(s.icon)}></span>
          </div>
          <div style="flex:1;min-width:0;">
            <div style="display:flex;align-items:center;gap:8px;">
              <p style="font-size:14px;font-weight:600;color:#fff;margin:0;">{s.name}</p>
              <span style={`font-size:9px;font-weight:700;padding:1px 6px;border-radius:100px;${s.is_active ? 'background:rgba(16,185,129,0.15);color:#6ee7b7;' : 'background:#15151a;color:#6e6e78;'}`}>
                {s.is_active ? 'Active' : 'Hidden'}
              </span>
            </div>
            <p style="font-size:11px;color:#6e6e78;margin:2px 0 0;font-family:'Geist Mono',monospace;">/admin/{s.slug}</p>
            {s.description && <p style="font-size:11px;color:#8a8a94;margin:4px 0 0;">{s.description}</p>}
          </div>
        </div>
        <div style="border-top:1px solid #1a1a1f;padding:8px 14px;display:flex;gap:6px;">
          <a href={`?section=${s.id}`} style="flex:1;text-align:center;background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;text-decoration:none;font-size:12px;font-weight:500;padding:7px;border-radius:6px;">
            Manage Pages
          </a>
          <form method="POST" style="flex:1;">
            <input type="hidden" name="action" value="toggle_section" />
            <input type="hidden" name="id" value={s.id} />
            <button type="submit" style={`width:100%;font-size:12px;font-weight:500;padding:7px;border-radius:6px;border:none;cursor:pointer;${s.is_active ? 'background:rgba(251,191,36,0.1);color:#fbbf24;' : 'background:rgba(16,185,129,0.1);color:#6ee7b7;'}`}>
              {s.is_active ? 'Hide' : 'Activate'}
            </button>
          </form>
          <form method="POST" onsubmit="return confirm('Delete this section and all its pages?')">
            <input type="hidden" name="action" value="delete_section" />
            <input type="hidden" name="id" value={s.id} />
            <button type="submit" style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);color:#fca5a5;font-size:12px;font-weight:500;padding:7px 12px;border-radius:6px;cursor:pointer;">Del</button>
          </form>
        </div>
      </div>
    ))}
  </div>

  <!-- Pages for selected section -->
  {selectedSection && (
    <div style="padding:0 16px 16px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
        <p style="font-size:13px;font-weight:600;color:#fff;margin:0;">Pages in {selectedSection.name}</p>
        <button onclick="document.getElementById('newPageModal').style.display='flex'" style="background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;font-size:11px;font-weight:600;padding:6px 12px;border-radius:6px;cursor:pointer;">+ Add Page</button>
      </div>
      <div style="display:flex;flex-direction:column;gap:6px;">
        {pages.length === 0 && <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:20px;text-align:center;color:#6e6e78;font-size:12px;">No pages yet. Add pages like "Leads", "Campaigns", "Reports".</div>}
        {pages.map((p: any) => (
          <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px 14px;display:flex;align-items:center;gap:10px;">
            <div style="flex:1;min-width:0;">
              <p style="font-size:13px;font-weight:600;color:#fff;margin:0;">{p.name}</p>
              <p style="font-size:10px;color:#6e6e78;margin:2px 0 0;font-family:'Geist Mono',monospace;">{p.tool_type} - /admin/{selectedSection.slug}/{p.slug}</p>
            </div>
            <span style="font-size:10px;background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;padding:2px 8px;border-radius:6px;">{p.tool_type}</span>
          </div>
        ))}
      </div>
    </div>
  )}

</div>

<!-- New Section Modal -->
<div id="newSectionModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:100;align-items:flex-end;justify-content:center;">
  <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:16px 16px 0 0;width:100%;max-width:600px;max-height:90vh;overflow-y:auto;padding:20px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <h2 style="font-size:15px;font-weight:700;color:#fff;margin:0;">New Section</h2>
      <button onclick="document.getElementById('newSectionModal').style.display='none'" style="background:#1a1a1f;border:none;color:#8a8a94;width:30px;height:30px;border-radius:6px;font-size:18px;cursor:pointer;">&times;</button>
    </div>
    <form method="POST" style="display:flex;flex-direction:column;gap:12px;">
      <input type="hidden" name="action" value="create_section" />
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Section Name *</label>
        <input name="name" required placeholder="e.g. Sampark, Sambandh, Rankings" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
      </div>
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Slug *</label>
        <input name="slug" required placeholder="sampark" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;font-family:'Geist Mono',monospace;" />
        <p style="font-size:10px;color:#6e6e78;margin:4px 0 0;">URL: /admin/[slug] - lowercase letters, numbers, hyphens only</p>
      </div>
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Description</label>
        <input name="description" placeholder="Brief description of this section" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div>
          <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Icon</label>
          <select name="icon" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
            {ICONS.map(i => <option value={i}>{i}</option>)}
          </select>
        </div>
        <div>
          <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Color</label>
          <input name="color" type="color" value="#FF4F00" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:6px;height:42px;cursor:pointer;" />
        </div>
      </div>
      <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">Create Section</button>
    </form>
  </div>
</div>

<!-- New Page Modal -->
<div id="newPageModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:100;align-items:flex-end;justify-content:center;">
  <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:16px 16px 0 0;width:100%;max-width:600px;padding:20px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <h2 style="font-size:15px;font-weight:700;color:#fff;margin:0;">Add Page to {selectedSection?.name}</h2>
      <button onclick="document.getElementById('newPageModal').style.display='none'" style="background:#1a1a1f;border:none;color:#8a8a94;width:30px;height:30px;border-radius:6px;font-size:18px;cursor:pointer;">&times;</button>
    </div>
    <form method="POST" style="display:flex;flex-direction:column;gap:12px;">
      <input type="hidden" name="action" value="add_page" />
      <input type="hidden" name="sectionId" value={selectedId} />
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Page Name *</label>
        <input name="name" required placeholder="e.g. Leads, Campaigns, Reports" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
      </div>
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Slug *</label>
        <input name="slug" required placeholder="leads" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;font-family:'Geist Mono',monospace;" />
      </div>
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Tool Type</label>
        <select name="toolType" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
          {TOOL_TYPES.map(t => <option value={t.value}>{t.label}</option>)}
        </select>
      </div>
      <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">Add Page</button>
    </form>
  </div>
</div>

</AdminLayout>
