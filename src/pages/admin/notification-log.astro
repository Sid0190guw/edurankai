---
// /admin/notification-log — notification delivery log (Prompt 18, admin surface). Gated by can(audit).
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { deliveryLog } from '@/lib/edu-notify';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'audit', { type: 'notifications' });
if (!gate.allow) return Astro.redirect('/admin');
const log = await deliveryLog(150).catch(() => []);
function fmt(d: any) { try { return new Date(d).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); } catch { return '-'; } }
---
<AdminLayout title="Notifications log" activeNav="notification-log">
  <div style="max-width:1000px;margin:0 auto;padding:24px;">
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0 0 4px;">Notification delivery</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:0 0 16px;">In-app notifications triggered by real events; email is best-effort via the platform mail provider (env/DB). Prefs are per-user.</p>
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;">
      {log.length === 0 ? <p style="font-size:12px;color:#6e6e78;margin:0;">No notifications sent yet.</p> :
      <div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:12px;">
        <thead><tr style="color:#8a8a94;font-size:9px;text-transform:uppercase;font-family:'Geist Mono',monospace;text-align:left;"><th style="padding:5px 8px;">When</th><th style="padding:5px 8px;">User</th><th style="padding:5px 8px;">Type</th><th style="padding:5px 8px;">Title</th><th style="padding:5px 8px;">Channel</th><th style="padding:5px 8px;">Read</th></tr></thead>
        <tbody>{log.map((n: any) => (<tr style="border-top:1px solid #15151a;"><td style="padding:5px 8px;color:#8a8a94;font-family:'Geist Mono',monospace;white-space:nowrap;">{fmt(n.at)}</td><td style="padding:5px 8px;color:#cfd6da;">{n.user_name || 'user'}</td><td style="padding:5px 8px;color:#8a8a94;">{n.type}</td><td style="padding:5px 8px;color:#cfd6da;">{n.title}</td><td style="padding:5px 8px;color:#8a8a94;">{n.channel}</td><td style={'padding:5px 8px;color:' + (n.read ? '#6ee7b7' : '#c0a35e')}>{n.read ? 'yes' : 'no'}</td></tr>))}</tbody>
      </table></div>}
    </div>
  </div>
</AdminLayout>
