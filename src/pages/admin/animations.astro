---
// /admin/animations — teaching-board registry (Prompt A1a, admin surface). Shows the parametric
// template catalog + how many live instances have been fired, and lets faculty seed the template
// objects. Gated: can(create AnimationObject). The teacher board itself is /aquintutor/board.
import AdminLayout from '@/layouts/AdminLayout.astro';
import SceneGL from '@/components/SceneGL.astro';
import { can } from '@/lib/rbac';
import { TEMPLATES, templateUsage } from '@/lib/animation';
import { OBJECT_TYPES, MOTION_TYPES, BASE_TYPES, PHYSICS_TYPES, sceneService } from '@/lib/scene-spec';
import { exampleList, exampleScene, SCENE_EXAMPLE_IDS } from '@/lib/scene-examples';
import { recentCaptureDetections } from '@/lib/board-session';
import { recentHuddleFires } from '@/lib/huddle-session';
import { recentBroadcasts } from '@/lib/broadcast';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'create', { type: 'AnimationObject' });
if (!gate.allow) return Astro.redirect('/admin');
const usage = await templateUsage().catch(() => ({ templates: [], instances: 0 }));
const seededIds = new Set(usage.templates.map((t: any) => t.id));
const savedScenes = await sceneService().listScenes().catch(() => []);
const captures = await recentCaptureDetections(16).catch(() => []);
const huddleFires = await recentHuddleFires(16).catch(() => []);
const broadcasts = await recentBroadcasts(12).catch(() => []);
const sceneExamples = exampleList();
const sceneSpecs: Record<string, any> = {};
for (const id of SCENE_EXAMPLE_IDS) sceneSpecs[id] = exampleScene(id);
const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
---
<AdminLayout title="Teaching board" activeNav="animations">
  <div style="max-width:900px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Live board</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Teaching board — animation registry</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">Each template and every fired live instance is a kernel AnimationObject. Faculty drive a live board at <a href="/aquintutor/board" style="color:#9bd1ff;">/aquintutor/board</a>; students receive an adaptively-rendered view (A1b). Broadcast is a compact spec (template id + params), never video frames.</p>
    <div id="msg" style="display:none;margin:12px 0;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin:16px 0;">
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Templates</p><p style="font-size:26px;font-weight:800;color:#fff;margin:4px 0 0;">{TEMPLATES.length}</p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Seeded in kernel</p><p style="font-size:26px;font-weight:800;color:#fff;margin:4px 0 0;">{usage.templates.length}</p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Instances fired</p><p style="font-size:26px;font-weight:800;color:#fff;margin:4px 0 0;">{usage.instances}</p></div>
    </div>

    <div style={CARD}>
      <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
        <p style={HD + 'margin:0;'}>Template catalog</p>
        <button id="seed" type="button" style="background:#1c2230;color:#9bd1ff;border:1px solid #26324a;border-radius:8px;padding:8px 14px;font-size:12.5px;font-weight:600;cursor:pointer;">Seed template objects</button>
      </div>
      <table style="width:100%;border-collapse:collapse;margin-top:12px;font-size:13px;">
        <thead><tr style="text-align:left;color:#8a8a94;font-size:11px;text-transform:uppercase;">
          <th style="padding:6px 8px;font-weight:600;">Template</th><th style="padding:6px 8px;font-weight:600;">Domain</th><th style="padding:6px 8px;font-weight:600;">Parameters</th><th style="padding:6px 8px;font-weight:600;">Kernel</th>
        </tr></thead>
        <tbody>
          {TEMPLATES.map((t) => (
            <tr style="border-top:1px solid #1a1a1f;color:#d6d6de;">
              <td style="padding:8px;font-weight:600;color:#fff;">{t.name}</td>
              <td style="padding:8px;"><span style="font-family:'Geist Mono',monospace;font-size:11px;color:#8a8a94;">{t.kind}</span></td>
              <td style="padding:8px;font-family:'Geist Mono',monospace;font-size:11px;color:#9bd1ff;">{t.params.join(', ')}</td>
              <td style="padding:8px;">{seededIds.has(t.id)
                ? <span style="color:#6ee7b7;">seeded</span>
                : <span style="color:#8a8a94;">not seeded</span>}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div style={CARD}>
      <p style={HD}>Scene-spec preview — renders at each Prompt-5 tier</p>
      <p style="font-size:12px;color:#8a8a94;margin:0 0 12px;">Rich/standard = Three.js WebGL (PBR, shadows, env map, bloom on rich); lite = 2D SVG fallback of the SAME spec. Three.js is a lazy chunk fetched only for rich/standard — the lite preview never loads it.</p>
      <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-bottom:12px;">
        <select id="exSel" style="font-size:13px;padding:7px 9px;border-radius:8px;background:#15151b;color:#d6d6de;border:1px solid #26262e;">
          {sceneExamples.map((s) => <option value={s.id}>{s.title} ({s.objects})</option>)}
        </select>
        <select id="tierSel" style="font-size:13px;padding:7px 9px;border-radius:8px;background:#15151b;color:#d6d6de;border:1px solid #26262e;">
          <option value="rich">rich (WebGL + bloom)</option>
          <option value="standard">standard (WebGL)</option>
          <option value="lite">lite (2D fallback)</option>
        </select>
        <button id="renderPrev" type="button" style="background:#1c2230;color:#9bd1ff;border:1px solid #26324a;border-radius:8px;padding:7px 13px;font-size:12.5px;font-weight:600;cursor:pointer;">Render</button>
        <span id="prevMeta" style="font-family:'Geist Mono',monospace;font-size:11px;color:#8a8a94;"></span>
      </div>
      <div id="prevStage" style="background:#0e0f13;border-radius:10px;overflow:hidden;min-height:120px;"></div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
      <div style={CARD + 'margin:0;'}>
        <p style={HD}>Primitive library ({OBJECT_TYPES.length})</p>
        <p style="font-size:12px;color:#8a8a94;margin:0 0 8px;">Base ({BASE_TYPES.length})</p>
        <div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:10px;">{BASE_TYPES.map((t) => <span style="font-family:'Geist Mono',monospace;font-size:11px;color:#9bd1ff;background:#12161f;border:1px solid #22262f;border-radius:6px;padding:3px 8px;">{t}</span>)}</div>
        <p style="font-size:12px;color:#8a8a94;margin:0 0 8px;">Physics pack ({PHYSICS_TYPES.length})</p>
        <div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:10px;">{PHYSICS_TYPES.map((t) => <span style="font-family:'Geist Mono',monospace;font-size:11px;color:#ffcc88;background:#1f1810;border:1px solid #33291a;border-radius:6px;padding:3px 8px;">{t}</span>)}</div>
        <p style="font-size:12px;color:#8a8a94;margin:0 0 8px;">Motions ({MOTION_TYPES.length})</p>
        <div style="display:flex;flex-wrap:wrap;gap:5px;">{MOTION_TYPES.map((m) => <span style="font-family:'Geist Mono',monospace;font-size:11px;color:#c0c0cc;background:#141419;border:1px solid #24242c;border-radius:6px;padding:3px 8px;">{m}</span>)}</div>
      </div>
      <div style={CARD + 'margin:0;'}>
        <p style={HD}>Saved scenes ({savedScenes.length})</p>
        {savedScenes.length
          ? <div style="display:flex;flex-direction:column;gap:6px;">{savedScenes.slice(0, 20).map((s: any) => (
              <div style="display:flex;justify-content:space-between;font-size:12.5px;color:#d6d6de;border-bottom:1px solid #1a1a1f;padding-bottom:5px;">
                <span>{(s.data as any)?.title || 'Scene'}</span>
                <span style="font-family:'Geist Mono',monospace;font-size:11px;color:#8a8a94;">{(s.metadata as any)?.objectCount ?? 0} obj</span>
              </div>))}</div>
          : <p style="font-size:12.5px;color:#8a8a94;margin:0;">No scenes saved yet. Faculty save scenes from the board at /aquintutor/board.</p>}
      </div>
    </div>

    <div style={CARD + 'margin-top:16px;'}>
      <p style={HD}>Physical-board capture &amp; AI compositions ({captures.length})</p>
      <p style="font-size:12px;color:#8a8a94;margin:0 0 10px;">Recognition is best-effort and always confirmed by the teacher (never auto-penalising, never a silent guess). Corrections are tagged. Capture derives structured strokes locally — no raw video is stored or broadcast.</p>
      {captures.length
        ? <div style="display:flex;flex-direction:column;gap:6px;">{captures.map((d: any) => (
            <div style="display:flex;justify-content:space-between;gap:10px;font-size:12.5px;color:#d6d6de;border-bottom:1px solid #1a1a1f;padding-bottom:5px;">
              <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{d.source === 'physical-correction' ? '[corrected] ' : d.source === 'compose' ? '[AI compose] ' : '[board] '}{d.transcript || '(no text)'}</span>
              <span style="font-family:'Geist Mono',monospace;font-size:11px;color:#8a8a94;">{Math.round(d.confidence * 100)}% {d.fired ? '· fired' : ''}</span>
            </div>))}</div>
        : <p style="font-size:12.5px;color:#8a8a94;margin:0;">No captures yet. Faculty capture a real whiteboard at /aquintutor/board/physical.</p>}
    </div>

    <div style={CARD + 'margin-top:16px;'}>
      <p style={HD}>In-huddle animations &amp; presenter changes ({huddleFires.length})</p>
      <p style="font-size:12px;color:#8a8a94;margin:0 0 10px;">Fires + presenter grants/revokes inside live meeting rooms. The animation is broadcast as a spec over the room's data channel and rendered locally by each participant at their tier — never screen-shared as video. (Many-person video needs an SFU; see the follow-up note.)</p>
      {huddleFires.length
        ? <div style="display:flex;flex-direction:column;gap:6px;">{huddleFires.map((f: any) => (
            <div style="display:flex;justify-content:space-between;gap:10px;font-size:12.5px;color:#d6d6de;border-bottom:1px solid #1a1a1f;padding-bottom:5px;">
              <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">[{f.action}] {f.kind || ''} {f.summary || ''}</span>
              <span style="font-family:'Geist Mono',monospace;font-size:11px;color:#8a8a94;">room {String(f.room_id).slice(0, 8)}</span>
            </div>))}</div>
        : <p style="font-size:12.5px;color:#8a8a94;margin:0;">No in-huddle animations yet. Hosts drive the board in the meeting room's Board tab.</p>}
    </div>

    <div style={CARD + 'margin-top:16px;'}>
      <p style={HD}>Mass broadcasts ({broadcasts.length})</p>
      <p style="font-size:12px;color:#8a8a94;margin:0 0 10px;">One teacher to many viewers. Slides + animation specs fan out over the pull channel and render locally at each viewer's tier — viewers never publish, and video is never baked in. HD teacher video egress needs a CDN (provisioning follow-up: docs/huddle-sfu-followup.md).</p>
      {broadcasts.length
        ? <div style="display:flex;flex-direction:column;gap:6px;">{broadcasts.map((bcRow: any) => (
            <div style="display:flex;justify-content:space-between;gap:10px;font-size:12.5px;color:#d6d6de;border-bottom:1px solid #1a1a1f;padding-bottom:5px;">
              <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{bcRow.live ? '● LIVE ' : ''}{bcRow.title}{bcRow.low_bitrate ? ' · low-bitrate' : ''}</span>
              <span style="font-family:'Geist Mono',monospace;font-size:11px;color:#8a8a94;">{String(bcRow.id)}</span>
            </div>))}</div>
        : <p style="font-size:12.5px;color:#8a8a94;margin:0;">No broadcasts yet. Faculty go live at /aquintutor/broadcast.</p>}
    </div>
  </div>

  <script src="/aquin-scene-engine.js" defer></script>
  <SceneGL />
  <script is:inline define:vars={{ sceneSpecs }}>
    (function () {
      function ready(fn) { if (window.AquinScene) fn(); else setTimeout(function () { ready(fn); }, 50); }
      ready(function () {
        var stage = document.getElementById('prevStage'), meta = document.getElementById('prevMeta');
        function renderPrev() {
          var spec = sceneSpecs[document.getElementById('exSel').value], tier = document.getElementById('tierSel').value;
          if (window.AquinSceneGL && stage.__aquinGL && tier === 'lite') { window.AquinSceneGL.dispose(stage); }
          stage.innerHTML = ''; var out = window.AquinScene.render(stage, spec, tier);
          meta.textContent = tier + ' -> ' + out.renderer + ' · ' + out.nodes + ' objects' + (out.renderer === 'svg2d' ? ' (no Three.js loaded)' : '');
        }
        document.getElementById('renderPrev').addEventListener('click', renderPrev);
        renderPrev();
      });
    })();
  </script>

  <script is:inline>
    document.getElementById('seed').addEventListener('click', function () {
      var btn = this, msg = document.getElementById('msg'); btn.disabled = true; btn.textContent = 'Seeding…';
      fetch('/api/aquintutor/board', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'ensure' }) })
        .then(function (r) { return r.json(); })
        .then(function (j) {
          msg.style.display = 'block';
          if (j.ok) { msg.style.background = '#0f2a1c'; msg.style.color = '#6ee7b7'; msg.textContent = 'Seeded ' + Object.keys(j.templates || {}).length + ' template objects. Reloading…'; setTimeout(function () { location.reload(); }, 900); }
          else { msg.style.background = '#2a0f0f'; msg.style.color = '#fca5a5'; msg.textContent = j.error || 'Failed'; btn.disabled = false; btn.textContent = 'Seed template objects'; }
        })
        .catch(function () { btn.disabled = false; btn.textContent = 'Seed template objects'; });
    });
  </script>
</AdminLayout>
