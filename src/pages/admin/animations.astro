---
// /admin/animations — teaching-board registry (Prompt A1a, admin surface). Shows the parametric
// template catalog + how many live instances have been fired, and lets faculty seed the template
// objects. Gated: can(create AnimationObject). The teacher board itself is /aquintutor/board.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { TEMPLATES, templateUsage } from '@/lib/animation';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'create', { type: 'AnimationObject' });
if (!gate.allow) return Astro.redirect('/admin');
const usage = await templateUsage().catch(() => ({ templates: [], instances: 0 }));
const seededIds = new Set(usage.templates.map((t: any) => t.id));
const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
---
<AdminLayout title="Teaching board" activeNav="animations">
  <div style="max-width:900px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Live board</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Teaching board — animation registry</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">Each template and every fired live instance is a kernel AnimationObject. Faculty drive a live board at <a href="/aquintutor/board" style="color:#9bd1ff;">/aquintutor/board</a>; students receive an adaptively-rendered view (A1b). Broadcast is a compact spec (template id + params), never video frames.</p>
    <div id="msg" style="display:none;margin:12px 0;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin:16px 0;">
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Templates</p><p style="font-size:26px;font-weight:800;color:#fff;margin:4px 0 0;">{TEMPLATES.length}</p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Seeded in kernel</p><p style="font-size:26px;font-weight:800;color:#fff;margin:4px 0 0;">{usage.templates.length}</p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Instances fired</p><p style="font-size:26px;font-weight:800;color:#fff;margin:4px 0 0;">{usage.instances}</p></div>
    </div>

    <div style={CARD}>
      <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
        <p style={HD + 'margin:0;'}>Template catalog</p>
        <button id="seed" type="button" style="background:#1c2230;color:#9bd1ff;border:1px solid #26324a;border-radius:8px;padding:8px 14px;font-size:12.5px;font-weight:600;cursor:pointer;">Seed template objects</button>
      </div>
      <table style="width:100%;border-collapse:collapse;margin-top:12px;font-size:13px;">
        <thead><tr style="text-align:left;color:#8a8a94;font-size:11px;text-transform:uppercase;">
          <th style="padding:6px 8px;font-weight:600;">Template</th><th style="padding:6px 8px;font-weight:600;">Domain</th><th style="padding:6px 8px;font-weight:600;">Parameters</th><th style="padding:6px 8px;font-weight:600;">Kernel</th>
        </tr></thead>
        <tbody>
          {TEMPLATES.map((t) => (
            <tr style="border-top:1px solid #1a1a1f;color:#d6d6de;">
              <td style="padding:8px;font-weight:600;color:#fff;">{t.name}</td>
              <td style="padding:8px;"><span style="font-family:'Geist Mono',monospace;font-size:11px;color:#8a8a94;">{t.kind}</span></td>
              <td style="padding:8px;font-family:'Geist Mono',monospace;font-size:11px;color:#9bd1ff;">{t.params.join(', ')}</td>
              <td style="padding:8px;">{seededIds.has(t.id)
                ? <span style="color:#6ee7b7;">seeded</span>
                : <span style="color:#8a8a94;">not seeded</span>}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <script is:inline>
    document.getElementById('seed').addEventListener('click', function () {
      var btn = this, msg = document.getElementById('msg'); btn.disabled = true; btn.textContent = 'Seeding…';
      fetch('/api/aquintutor/board', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'ensure' }) })
        .then(function (r) { return r.json(); })
        .then(function (j) {
          msg.style.display = 'block';
          if (j.ok) { msg.style.background = '#0f2a1c'; msg.style.color = '#6ee7b7'; msg.textContent = 'Seeded ' + Object.keys(j.templates || {}).length + ' template objects. Reloading…'; setTimeout(function () { location.reload(); }, 900); }
          else { msg.style.background = '#2a0f0f'; msg.style.color = '#fca5a5'; msg.textContent = j.error || 'Failed'; btn.disabled = false; btn.textContent = 'Seed template objects'; }
        })
        .catch(function () { btn.disabled = false; btn.textContent = 'Seed template objects'; });
    });
  </script>
</AdminLayout>
