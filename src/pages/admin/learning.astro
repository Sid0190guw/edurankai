---
// /admin/learning — Educational Runtime inspector (Prompt 4, admin surface). Capability-gated
// ('audit'): a searchable, paginated list of real runtime traces (per session: estimated
// context, served variant/tier, outcome) + a selected student's mastery. Real data only.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { listTraces, countTraces, studentMastery } from '@/lib/edu-runtime';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'audit', { type: 'runtime' });
if (!gate.allow) return Astro.redirect('/admin');

const sel = (Astro.url.searchParams.get('u') || '').trim();
const p = Math.max(0, parseInt(Astro.url.searchParams.get('p') || '0', 10) || 0);
const PER = 50;
const total = await countTraces(sel || undefined).catch(() => 0);
const traces = await listTraces(PER, p * PER, sel || undefined).catch(() => []);
const mastery = sel ? await studentMastery(sel).catch(() => []) : [];

const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
const tierColor: Record<string, string> = { lite: '#8a8a94', standard: '#5ea0c0', rich: '#6ee7b7' };
const outColor: Record<string, string> = { served: '#6ee7b7', 'not-ready': '#c0a35e', denied: '#fca5a5' };
function fmt(d: any) { try { return new Date(d).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit', second: '2-digit' }); } catch { return '-'; } }
function qs(over: Record<string, any>) { const q = new URLSearchParams(); if (sel) q.set('u', sel); if (p) q.set('p', String(p)); for (const k in over) { const v = over[k]; if (v === '' || v == null) q.delete(k); else q.set(k, String(v)); } return '?' + q.toString(); }
---
<AdminLayout title="Learning runtime" activeNav="learning">
  <div style="max-width:1120px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Educational runtime</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Student progress &amp; runtime traces</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">Every started lesson runs the ordered pipeline and records a trace. Authoring: <a href="/admin/knowledge" style="color:#FF7040;">/admin/knowledge</a>.</p>

    {sel ? (
      <div style={CARD}>
        <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;">
          <p style={HD + 'margin:0;'}>Mastery for selected student</p>
          <a href={qs({ u: '' })} style="font-size:11px;color:#8a8a94;text-decoration:none;border:1px solid #26262c;padding:3px 9px;border-radius:6px;">clear filter</a>
        </div>
        {mastery.length === 0 ? <p style="font-size:12.5px;color:#6e6e78;margin:8px 0 0;">No kernel-unit mastery recorded for this student yet.</p> :
          <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:8px;">{mastery.map((m: any) => (
            <span style={'font-size:12px;border-radius:8px;padding:4px 10px;border:1px solid #26262c;color:#cfd6da;background:' + (m.state === 'mastered' || m.verified ? 'rgba(16,185,129,0.12)' : 'rgba(94,160,192,0.1)')}>{m.title || m.koId.slice(0, 8)} &middot; {m.verified ? 'verified' : m.state}</span>
          ))}</div>}
      </div>
    ) : null}

    <div style={CARD}>
      <p style={HD}>Runtime traces &middot; {total} total</p>
      {traces.length === 0 ? <p style="font-size:12.5px;color:#6e6e78;margin:0;">No traces yet. Traces are written when a student opens a lesson.</p> :
      <div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:12px;">
        <thead><tr style="color:#8a8a94;font-size:9px;text-transform:uppercase;font-family:'Geist Mono',monospace;text-align:left;"><th style="padding:5px 8px;">When</th><th style="padding:5px 8px;">Student</th><th style="padding:5px 8px;">Unit</th><th style="padding:5px 8px;">Served</th><th style="padding:5px 8px;">Outcome</th><th style="padding:5px 8px;">Pipeline</th></tr></thead>
        <tbody>
          {traces.map((t: any) => (
            <tr style="border-top:1px solid #15151a;vertical-align:top;">
              <td style="padding:6px 8px;color:#8a8a94;white-space:nowrap;font-family:'Geist Mono',monospace;">{fmt(t.at)}</td>
              <td style="padding:6px 8px;">{t.user_id ? <a href={qs({ u: t.user_id, p: '' })} style="color:#cfd6da;text-decoration:none;border-bottom:1px dotted #3a3a44;">{t.user_name || t.user_id.slice(0, 8)}</a> : <span style="color:#6e6e78;">guest</span>}</td>
              <td style="padding:6px 8px;color:#8a8a94;font-family:'Geist Mono',monospace;">{String(t.ko_id).slice(0, 8)}</td>
              <td style="padding:6px 8px;"><span style={'font-family:Geist Mono,monospace;font-size:11px;color:' + (tierColor[t.render_tier] || '#8a8a94')}>{t.render_tier}</span>{t.language && t.language !== 'en' ? <span style="color:#8a8a94;"> · {t.language}</span> : null}</td>
              <td style="padding:6px 8px;"><span style={'font-family:Geist Mono,monospace;font-size:11px;font-weight:700;color:' + (outColor[t.outcome] || '#8a8a94')}>{t.outcome}</span></td>
              <td style="padding:6px 8px;min-width:220px;">
                <details><summary style="cursor:pointer;color:#8a8a94;font-size:11px;">{(t.steps || []).length} steps</summary>
                  <ol style="margin:6px 0 0;padding-left:16px;">{(t.steps || []).map((s: any) => <li style={'font-family:Geist Mono,monospace;font-size:10.5px;color:' + (s.ok ? '#cfd6da' : '#a06060')}>{s.step}: {s.detail}</li>)}</ol>
                </details>
              </td>
            </tr>
          ))}
        </tbody>
      </table></div>}
      <div style="display:flex;justify-content:space-between;align-items:center;margin-top:10px;font-size:11.5px;color:#8a8a94;">
        <span>Page {p + 1} of {Math.max(1, Math.ceil(total / PER))}</span>
        <span style="display:flex;gap:8px;">
          {p > 0 ? <a href={qs({ p: p - 1 })} style="color:#cfd6da;border:1px solid #26262c;padding:4px 10px;border-radius:6px;text-decoration:none;">&larr; Prev</a> : null}
          {(p + 1) * PER < total ? <a href={qs({ p: p + 1 })} style="color:#cfd6da;border:1px solid #26262c;padding:4px 10px;border-radius:6px;text-decoration:none;">Next &rarr;</a> : null}
        </span>
      </div>
    </div>
  </div>
</AdminLayout>
