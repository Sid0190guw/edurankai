---
// /admin/accessibility — accessibility audit/report (Prompt AP4b). A REAL audit: computes WCAG
// contrast for the core UI color pairs and flags any that miss AA, plus states the platform-wide a11y
// guarantees (reduced-motion honored by the engine, focus/skip-link, a11y content variants). Gated.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { contrastRatio, meetsAA } from '@/lib/a11y';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'write', { type: 'content' });
if (!gate.allow) return Astro.redirect('/admin');
// core AquinTutor palette pairs (fg on bg) used across the platform
const pairs = [
  { name: 'Ink on sand (body text)', fg: '#1a1712', bg: '#fbfaf4', large: false },
  { name: 'Muted text on sand', fg: '#6b6455', bg: '#fbfaf4', large: false },
  { name: 'Rust accent on sand', fg: '#b3541e', bg: '#fbfaf4', large: false },
  { name: 'White on ink (buttons)', fg: '#fbfaf4', bg: '#1a1712', large: false },
  { name: 'Faint label on sand', fg: '#8a8378', bg: '#fbfaf4', large: true },
  { name: 'Success green on tint', fg: '#2f7d5b', bg: '#eef8f1', large: false },
  { name: 'Error red on tint', fg: '#9b2c2c', bg: '#fdecec', large: false },
];
const audited = pairs.map((p) => ({ ...p, ratio: contrastRatio(p.fg, p.bg), pass: meetsAA(p.fg, p.bg, { large: p.large }) }));
const fails = audited.filter((p) => !p.pass).length;
const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
---
<AdminLayout title="Accessibility" activeNav="accessibility">
  <div style="max-width:900px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">WCAG 2.2 AA</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Accessibility audit</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">A live contrast audit of the core palette plus the platform-wide guarantees. Students set their own preferences at <a href="/aquintutor/accessibility" style="color:#9bd1ff;">/aquintutor/accessibility</a>.</p>

    <div style={CARD}>
      <p style={HD}>Contrast (WCAG AA) — {fails === 0 ? 'all pass' : fails + ' need attention'}</p>
      <table style="width:100%;border-collapse:collapse;font-size:13px;">
        <thead><tr style="text-align:left;color:#8a8a94;font-size:11px;text-transform:uppercase;"><th style="padding:6px 8px;">Pair</th><th style="padding:6px 8px;">Ratio</th><th style="padding:6px 8px;">AA</th></tr></thead>
        <tbody>
          {audited.map((p) => (
            <tr style="border-top:1px solid #1a1a1f;color:#d6d6de;">
              <td style="padding:7px 8px;"><span style={'display:inline-block;width:12px;height:12px;border-radius:3px;margin-right:6px;vertical-align:middle;background:' + p.fg}></span><span style={'display:inline-block;width:12px;height:12px;border-radius:3px;margin-right:8px;vertical-align:middle;background:' + p.bg}></span>{p.name}{p.large ? ' (large)' : ''}</td>
              <td style="padding:7px 8px;font-family:'Geist Mono',monospace;font-size:12px;">{p.ratio}:1</td>
              <td style={'padding:7px 8px;font-weight:700;color:' + (p.pass ? '#6ee7b7' : '#fca5a5')}>{p.pass ? 'PASS' : 'FAIL'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div style={CARD}>
      <p style={HD}>Platform guarantees</p>
      <ul style="font-size:13px;color:#d6d6de;line-height:1.7;margin:0;padding-left:18px;">
        <li>Keyboard focus is always visible (<code style="color:#9bd1ff;">:focus-visible</code>); a skip-to-content link starts every page.</li>
        <li>Reduced motion (setting or OS) makes the animation engine render a <b>static keyframe</b> — no motion.</li>
        <li>High-contrast + larger-text modes apply site-wide from the student's saved preferences.</li>
        <li>Where a KnowledgeObject has an <b>accessibility variant</b> (Prompt 1/4 model), the runtime serves it.</li>
      </ul>
    </div>
  </div>
</AdminLayout>
