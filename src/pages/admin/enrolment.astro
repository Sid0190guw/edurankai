---
// /admin/enrolment — registrar enrolment console (Prompt 17, admin surface). Gated by
// can(manage, enrolment). Enrol students in courses, set stage, set course capacity/prereqs.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { STAGES } from '@/lib/rbac/roles';
import { contentService } from '@/lib/kernel-content';
import { listStudents } from '@/lib/enrolment';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'manage', { type: 'enrolment' });
if (!gate.allow) return Astro.redirect('/admin');
const students = await listStudents(100).catch(() => []);
const courses = (await contentService().listCourses().catch(() => [])).map((c: any) => ({ id: c.id, title: (c.data as any).title }));
const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const IN = 'background:#15151a;border:1px solid #26262c;color:#fff;padding:7px 9px;border-radius:6px;font-size:12px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
---
<AdminLayout title="Enrolment" activeNav="enrolment">
  <div style="max-width:1000px;margin:0 auto;padding:24px;">
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0 0 4px;">Enrolment &amp; records</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:0 0 16px;">Enrol students in courses (prerequisites + capacity enforced). Admissions: /admin/admissions.</p>
    <div id="msg" style="display:none;margin:0 0 12px;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style={CARD}>
      <p style={HD}>Enrol a student in a course</p>
      <div style="display:flex;gap:6px;flex-wrap:wrap;align-items:end;">
        <div><label style="font-size:10px;color:#8a8a94;">Student</label><br/><select id="eUser" style={IN}>{students.map((s: any) => <option value={s.user_id}>{s.name} ({s.stage})</option>)}</select></div>
        <div><label style="font-size:10px;color:#8a8a94;">Course</label><br/><select id="eCourse" style={IN}>{courses.map((c: any) => <option value={c.id}>{c.title}</option>)}</select></div>
        <button id="enrolBtn" type="button" style="background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:700;padding:8px 14px;border-radius:6px;cursor:pointer;">Enrol</button>
      </div>
    </div>

    <div style={CARD}>
      <p style={HD}>Course capacity &amp; prerequisites</p>
      <div style="display:flex;gap:6px;flex-wrap:wrap;align-items:end;">
        <div><label style="font-size:10px;color:#8a8a94;">Course</label><br/><select id="mCourse" style={IN}>{courses.map((c: any) => <option value={c.id}>{c.title}</option>)}</select></div>
        <div><label style="font-size:10px;color:#8a8a94;">Capacity (blank = uncapped)</label><br/><input id="mCap" type="number" style={IN + 'width:120px;'} /></div>
        <div style="flex:1;min-width:220px;"><label style="font-size:10px;color:#8a8a94;">Prerequisite courses</label><br/><select id="mPrereq" multiple size="3" style={IN + 'width:100%;'}>{courses.map((c: any) => <option value={c.id}>{c.title}</option>)}</select></div>
        <button id="metaBtn" type="button" style="background:#15151a;border:1px solid #26262c;color:#cfd6da;font-size:11px;padding:8px 12px;border-radius:6px;cursor:pointer;">Save</button>
      </div>
    </div>

    <div style={CARD}>
      <p style={HD}>Students ({students.length})</p>
      {students.length === 0 ? <p style="font-size:12px;color:#6e6e78;margin:0;">No students yet.</p> :
      <div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:12.5px;">
        <thead><tr style="color:#8a8a94;font-size:9px;text-transform:uppercase;font-family:'Geist Mono',monospace;text-align:left;"><th style="padding:5px 8px;">Name</th><th style="padding:5px 8px;">Stage</th><th style="padding:5px 8px;">Courses</th></tr></thead>
        <tbody>{students.map((s: any) => <tr style="border-top:1px solid #15151a;"><td style="padding:6px 8px;color:#cfd6da;">{s.name}<br/><span style="color:#6e6e78;font-size:10.5px;">{s.email}</span></td><td style="padding:6px 8px;color:#8a8a94;">{s.stage}</td><td style="padding:6px 8px;color:#cfd6da;">{s.courses}</td></tr>)}</tbody>
      </table></div>}
    </div>
  </div>

  <script is:inline>
    (function () {
      var msg = document.getElementById('msg');
      function post(body) { return fetch('/api/admin/enrolment', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }).then(function (r) { return r.json(); }); }
      function flash(t, ok) { msg.style.display = 'block'; msg.textContent = t; msg.style.background = ok ? 'rgba(16,185,129,0.12)' : 'rgba(239,68,68,0.12)'; msg.style.color = ok ? '#6ee7b7' : '#fca5a5'; }
      document.getElementById('enrolBtn').addEventListener('click', function () { post({ action: 'enrol', userId: document.getElementById('eUser').value, courseObjId: document.getElementById('eCourse').value }).then(function (j) { flash(j.ok ? 'Enrolled.' : (j.error || 'Failed'), j.ok); }); });
      document.getElementById('metaBtn').addEventListener('click', function () { var pre = Array.prototype.slice.call(document.getElementById('mPrereq').selectedOptions).map(function (o) { return o.value; }); var cap = document.getElementById('mCap').value; post({ action: 'courseMeta', courseObjId: document.getElementById('mCourse').value, capacity: cap === '' ? null : parseInt(cap, 10), prereqs: pre }).then(function (j) { flash(j.ok ? 'Saved.' : (j.error || 'Failed'), j.ok); }); });
    })();
  </script>
</AdminLayout>
