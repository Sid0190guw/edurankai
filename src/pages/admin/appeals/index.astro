---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { ensureAppealsSchema, APPEAL_KINDS } from '@/lib/application-appeals';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

await ensureAppealsSchema();

let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const appealId = (fd.get('appeal_id') as string || '').trim();
    const action = (fd.get('action') as string || '').trim();
    const note = (fd.get('decision_note') as string || '').trim().slice(0, 6000);
    if (action === 'uphold' || action === 'deny' || action === 'reviewing') {
      const status = action === 'uphold' ? 'upheld' : action === 'deny' ? 'denied' : 'reviewing';
      await db.execute(sql`
        UPDATE application_appeals SET status = ${status}, decision_note = ${note || null},
          decided_by_user_id = ${user.id}, decided_at = NOW(), updated_at = NOW()
        WHERE id = ${appealId}
      `);
      okMsg = 'Appeal ' + status + '.';
    }
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 240); }
}

function rowsOf(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

const url = new URL(Astro.request.url);
const filterStatus = url.searchParams.get('status') || '';
const all = rowsOf(await db.execute(sql`
  SELECT aa.*, u.name AS user_name, u.email AS user_email, a.role_title_snapshot
  FROM application_appeals aa
  LEFT JOIN users u ON aa.user_id = u.id
  LEFT JOIN applications a ON aa.application_id = a.id
  ${filterStatus ? sql`WHERE aa.status = ${filterStatus}` : sql``}
  ORDER BY aa.created_at DESC LIMIT 200
`));

function fmt(d: any) { try { return new Date(d).toLocaleString('en-IN', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' }); } catch { return ''; } }
---
<AdminLayout title="Application Appeals" activeNav="">
<div style="padding:14px 16px 80px;max-width:1280px;margin:0 auto;">
  <p style="font-size:10.5px;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;font-family:'Geist Mono',monospace;font-weight:700;">Recruitment ops</p>
  <h1 style="font-size:24px;color:#fff;margin:6px 0 4px;font-weight:700;">Application Appeals</h1>
  <p style="font-size:13px;color:#9aa6b6;margin:0 0 18px;">Per policy: appeals are reviewed by a senior reviewer who was not in the original decision. 10 business day SLA.</p>

  {okMsg && <div style="background:rgba(74,222,128,0.10);border:1px solid rgba(74,222,128,0.32);color:#86efac;border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;">{okMsg}</div>}
  {errMsg && <div style="background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.32);color:#fca5a5;border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;">{errMsg}</div>}

  <form method="GET" style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;">
    <select name="status" style="background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12.5px;">
      <option value="">All</option>
      <option value="open" selected={filterStatus === 'open'}>Open</option>
      <option value="reviewing" selected={filterStatus === 'reviewing'}>Reviewing</option>
      <option value="upheld" selected={filterStatus === 'upheld'}>Upheld</option>
      <option value="denied" selected={filterStatus === 'denied'}>Denied</option>
    </select>
    <button type="submit" style="background:#15151a;border:1px solid #2a2a2f;color:#FF7040;padding:9px 16px;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer;">Filter</button>
  </form>

  {all.length === 0 ? (
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:36px;text-align:center;color:#6e6e78;font-size:13px;">No appeals match.</div>
  ) : (
    <div style="display:flex;flex-direction:column;gap:8px;">
      {all.map((a: any) => {
        const kindMeta = (APPEAL_KINDS as any)[a.appeal_kind] || APPEAL_KINDS.other;
        const sc = a.status === 'upheld' ? '#86efac' : a.status === 'denied' ? '#fca5a5' : a.status === 'reviewing' ? '#fbbf24' : '#67e8f9';
        return (
          <details style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:0;">
            <summary style="padding:14px 18px;cursor:pointer;list-style:none;display:grid;grid-template-columns:1.4fr 1.2fr 1fr 100px 110px;gap:12px;align-items:center;">
              <div>
                <p style="font-size:13px;font-weight:700;color:#fff;margin:0;">{a.user_name || a.user_email}</p>
                <p style="font-size:10.5px;color:#9aa6b6;margin:2px 0 0;font-family:'Geist Mono',monospace;">{a.user_email}</p>
              </div>
              <p style="font-size:11.5px;color:#cfd6da;margin:0;">{a.role_title_snapshot || '—'}</p>
              <p style="font-size:11px;color:#67e8f9;margin:0;font-family:'Geist Mono',monospace;">{kindMeta.label}</p>
              <span style={`background:${sc}22;color:${sc};font-size:10px;font-weight:700;padding:3px 8px;border-radius:100px;text-align:center;font-family:'Geist Mono',monospace;letter-spacing:0.06em;text-transform:uppercase;`}>{a.status}</span>
              <p style="font-size:10.5px;color:#6e6e78;margin:0;font-family:'Geist Mono',monospace;">{fmt(a.created_at)}</p>
            </summary>
            <div style="padding:0 18px 18px;border-top:1px solid #1a1a1f;">
              <div style="margin:14px 0;"><p style="font-size:10.5px;color:#9aa6b6;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 6px;font-family:'Geist Mono',monospace;font-weight:700;">Grounds</p><p style="font-size:12.5px;color:#d8d8de;margin:0;line-height:1.65;white-space:pre-wrap;">{a.grounds}</p></div>
              {a.new_evidence && <div style="margin:14px 0;"><p style="font-size:10.5px;color:#9aa6b6;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 6px;font-family:'Geist Mono',monospace;font-weight:700;">New evidence</p><p style="font-size:12.5px;color:#d8d8de;margin:0;line-height:1.65;white-space:pre-wrap;">{a.new_evidence}</p></div>}
              {a.drive_url && <p style="font-size:11.5px;color:#67e8f9;margin:8px 0;font-family:'Geist Mono',monospace;"><a href={a.drive_url} target="_blank" style="color:#67e8f9;">Drive evidence ↗</a></p>}
              {a.decision_note && <div style="margin:14px 0;padding:10px 14px;background:rgba(74,222,128,0.06);border-left:3px solid #86efac;border-radius:0 6px 6px 0;"><p style="font-size:10.5px;color:#86efac;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 4px;font-family:'Geist Mono',monospace;font-weight:700;">Decision note</p><p style="font-size:12px;color:#d8d8de;margin:0;line-height:1.6;white-space:pre-wrap;">{a.decision_note}</p></div>}

              <form method="POST" style="margin-top:12px;padding-top:12px;border-top:1px solid #1a1a1f;">
                <input type="hidden" name="appeal_id" value={a.id} />
                <p style="font-size:10.5px;color:#FF7040;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;font-weight:700;margin:0 0 6px;">Decide</p>
                <textarea name="decision_note" rows="3" maxlength="6000" placeholder="Written decision note — visible to candidate" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12px;font-family:'Inter Tight',sans-serif;line-height:1.55;resize:vertical;">{a.decision_note || ''}</textarea>
                <div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap;">
                  <button type="submit" name="action" value="reviewing" style="background:#fbbf2418;border:1px solid #fbbf24;color:#fbbf24;padding:7px 14px;border-radius:5px;font-size:11px;font-weight:700;cursor:pointer;font-family:'Geist Mono',monospace;">Mark Reviewing</button>
                  <button type="submit" name="action" value="uphold" style="background:#86efac18;border:1px solid #86efac;color:#86efac;padding:7px 14px;border-radius:5px;font-size:11px;font-weight:700;cursor:pointer;font-family:'Geist Mono',monospace;">Uphold</button>
                  <button type="submit" name="action" value="deny" style="background:#fca5a518;border:1px solid #fca5a5;color:#fca5a5;padding:7px 14px;border-radius:5px;font-size:11px;font-weight:700;cursor:pointer;font-family:'Geist Mono',monospace;">Deny</button>
                </div>
              </form>
            </div>
          </details>
        );
      })}
    </div>
  )}
</div>
</AdminLayout>
