---
// /admin/schedule — faculty/registrar schedule management (Prompt 19, admin surface). Gated by
// can(write, schedule). Set deadlines that populate enrolled students' calendars; run reminders.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { contentService } from '@/lib/kernel-content';
import { courseDeadlines } from '@/lib/calendar';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'write', { type: 'schedule' });
if (!gate.allow) return Astro.redirect('/admin');
const courses = (await contentService().listCourses().catch(() => [])).map((c: any) => ({ id: c.id, title: (c.data as any).title }));
const sel = (Astro.url.searchParams.get('c') || '').trim();
const deadlines = sel ? await courseDeadlines(sel).catch(() => []) : [];
const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const IN = 'background:#15151a;border:1px solid #26262c;color:#fff;padding:7px 9px;border-radius:6px;font-size:12px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
function fmt(d: any) { try { return new Date(d).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); } catch { return '-'; } }
---
<AdminLayout title="Schedule" activeNav="schedule">
  <div style="max-width:980px;margin:0 auto;padding:24px;">
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0 0 4px;">Schedule &amp; deadlines</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:0 0 16px;">Deadlines populate enrolled students' calendars + ICS feeds. Reminders notify students 48h ahead.</p>
    <div id="msg" style="display:none;margin:0 0 12px;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style={CARD}>
      <p style={HD}>Set a deadline</p>
      <div style="display:flex;gap:6px;flex-wrap:wrap;align-items:end;">
        <div><label style="font-size:10px;color:#8a8a94;">Course</label><br/><select id="dCourse" style={IN}>{courses.map((c: any) => <option value={c.id} selected={c.id === sel}>{c.title}</option>)}</select></div>
        <div style="flex:1;min-width:180px;"><label style="font-size:10px;color:#8a8a94;">Title</label><br/><input id="dTitle" style={IN + 'width:100%;box-sizing:border-box;'} placeholder="e.g. Midterm assessment" /></div>
        <div><label style="font-size:10px;color:#8a8a94;">Kind</label><br/><select id="dKind" style={IN}><option value="assessment">assessment</option><option value="exam">exam</option><option value="lesson">lesson</option></select></div>
        <div><label style="font-size:10px;color:#8a8a94;">Due</label><br/><input id="dDue" type="datetime-local" style={IN} /></div>
        <button id="setBtn" type="button" style="background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:700;padding:8px 14px;border-radius:6px;cursor:pointer;">Add</button>
        <button id="remindBtn" type="button" style="background:#15151a;border:1px solid #26262c;color:#cfd6da;font-size:11px;padding:8px 12px;border-radius:6px;cursor:pointer;">Run reminders</button>
      </div>
    </div>

    <div style={CARD}>
      <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:10px;">
        <p style={HD + 'margin:0;'}>Deadlines</p>
        <form method="GET"><select name="c" onchange="this.form.submit()" style={IN}><option value="">— pick a course —</option>{courses.map((c: any) => <option value={c.id} selected={c.id === sel}>{c.title}</option>)}</select></form>
      </div>
      {!sel ? <p style="font-size:12px;color:#6e6e78;margin:0;">Pick a course to see its deadlines.</p> :
        deadlines.length === 0 ? <p style="font-size:12px;color:#6e6e78;margin:0;">No deadlines for this course.</p> :
        deadlines.map((d: any) => <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #15151a;font-size:12.5px;color:#cfd6da;"><span>[{d.kind}] {d.title}</span><span style="color:#8a8a94;font-family:'Geist Mono',monospace;">{fmt(d.due_at)}</span></div>)}
    </div>
  </div>

  <script is:inline>
    (function () {
      var msg = document.getElementById('msg');
      function post(body) { return fetch('/api/admin/schedule', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }).then(function (r) { return r.json(); }); }
      function flash(t, ok) { msg.style.display = 'block'; msg.textContent = t; msg.style.background = ok ? 'rgba(16,185,129,0.12)' : 'rgba(239,68,68,0.12)'; msg.style.color = ok ? '#6ee7b7' : '#fca5a5'; }
      document.getElementById('setBtn').addEventListener('click', function () { var due = document.getElementById('dDue').value; post({ action: 'setDeadline', courseObjId: document.getElementById('dCourse').value, title: document.getElementById('dTitle').value, kind: document.getElementById('dKind').value, dueAt: due }).then(function (j) { if (j.ok) { flash('Added.', true); setTimeout(function () { location.href = '?c=' + document.getElementById('dCourse').value; }, 500); } else flash(j.error || 'Failed', false); }); });
      document.getElementById('remindBtn').addEventListener('click', function () { post({ action: 'runReminders' }).then(function (j) { flash(j.ok ? ('Sent ' + j.sent + ' reminders.') : (j.error || 'Failed'), j.ok); }); });
    })();
  </script>
</AdminLayout>
