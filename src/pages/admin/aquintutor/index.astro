---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

let stats: any = {
  courses: 0, publishedCourses: 0, paidCourses: 0,
  paths: 0,
  instructors: 0,
  tests: 0, publishedTests: 0, premiumTests: 0,
  enrollments: 0,
  attempts: 0,
  paidTestAttempts: 0,
  totalRevenuePaise: 0,
};
let recentEnrollments: any[] = [];
let recentAttempts: any[] = [];
let recentPayments: any[] = [];
let premiumTests: any[] = [];

try {
  const r = await db.execute(sql`
    SELECT
      (SELECT COUNT(*) FROM training_courses)::int as courses,
      (SELECT COUNT(*) FROM training_courses WHERE is_published = true)::int as published_courses,
      (SELECT COUNT(*) FROM training_courses WHERE is_paid_course = true)::int as paid_courses,
      (SELECT COUNT(*) FROM training_paths)::int as paths,
      (SELECT COUNT(*) FROM training_instructors)::int as instructors,
      (SELECT COUNT(*) FROM tests)::int as tests,
      (SELECT COUNT(*) FROM tests WHERE is_published = true)::int as published_tests,
      (SELECT COUNT(*) FROM tests WHERE is_premium = true)::int as premium_tests,
      (SELECT COUNT(*) FROM training_enrollments)::int as enrollments,
      (SELECT COUNT(*) FROM test_attempts WHERE status IN ('submitted','auto_submitted'))::int as attempts,
      (SELECT COUNT(*) FROM payments WHERE status = 'paid')::int as paid_records,
      (SELECT COALESCE(SUM(amount_paise),0) FROM payments WHERE status = 'paid')::bigint as revenue_paise
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  const row = (rows[0] as any) || {};
  stats = {
    courses: row.courses || 0,
    publishedCourses: row.published_courses || 0,
    paidCourses: row.paid_courses || 0,
    paths: row.paths || 0,
    instructors: row.instructors || 0,
    tests: row.tests || 0,
    publishedTests: row.published_tests || 0,
    premiumTests: row.premium_tests || 0,
    enrollments: row.enrollments || 0,
    attempts: row.attempts || 0,
    paidTestAttempts: row.paid_records || 0,
    totalRevenuePaise: Number(row.revenue_paise || 0),
  };
} catch(e: any) { console.error('aquintutor hub stats failed:', e.message); }

try {
  const r = await db.execute(sql`
    SELECT e.id, e.created_at, e.progress_pct, c.title as course_title, c.slug as course_slug,
           u.name as user_name, u.email as user_email
    FROM training_enrollments e
    LEFT JOIN training_courses c ON e.course_id = c.id
    LEFT JOIN users u ON e.user_id = u.id
    ORDER BY e.created_at DESC LIMIT 10
  `);
  recentEnrollments = Array.isArray(r) ? r : (r?.rows || []);
} catch(_) {}

try {
  const r = await db.execute(sql`
    SELECT a.id, a.candidate_name, a.candidate_email, a.percentage, a.status, a.submitted_at, a.started_at,
           t.title as test_title, t.slug as test_slug
    FROM test_attempts a
    LEFT JOIN tests t ON a.test_id = t.id
    WHERE a.status IN ('submitted','auto_submitted')
    ORDER BY a.submitted_at DESC NULLS LAST LIMIT 10
  `);
  recentAttempts = Array.isArray(r) ? r : (r?.rows || []);
} catch(_) {}

try {
  const r = await db.execute(sql`
    SELECT id, order_id, amount_paise, currency, status, purpose, reference_type, email, created_at
    FROM payments
    WHERE status IN ('paid','created','signature_mismatch')
    ORDER BY created_at DESC LIMIT 10
  `);
  recentPayments = Array.isArray(r) ? r : (r?.rows || []);
} catch(_) {}

try {
  const r = await db.execute(sql`
    SELECT id, slug, title, price_inr_paise, is_published,
      (SELECT COUNT(*) FROM test_attempts WHERE test_id = tests.id AND status IN ('submitted','auto_submitted'))::int as completed_attempts,
      (SELECT COUNT(*) FROM payments WHERE reference_type = 'test' AND reference_id = tests.id AND status = 'paid')::int as paid_users
    FROM tests WHERE is_premium = true ORDER BY created_at DESC
  `);
  premiumTests = Array.isArray(r) ? r : (r?.rows || []);
} catch(_) {}

function rs(paise: number) { return 'Rs ' + Math.floor((paise || 0) / 100).toLocaleString('en-IN'); }
function ago(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins + 'm ago';
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return hrs + 'h ago';
  return Math.floor(hrs / 24) + 'd ago';
}
---
<AdminLayout title="AquinTutor LMS Overview" activeNav="aquintutor-overview">
  <div style="max-width: 1280px; margin: 0 auto; padding: 28px 24px;">

    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;flex-wrap:wrap;margin-bottom:24px;">
      <div>
        <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">AquinTutor LMS</p>
        <h1 style="font-size:26px;font-weight:800;color:#fff;margin:0 0 6px;line-height:1.15;">Virtual institution control room</h1>
        <p style="font-size:13px;color:#8a8a94;margin:0;max-width:600px;line-height:1.55;">Courses, learning paths, faculty, gamified assessments, and Razorpay revenue - all the AquinTutor surfaces in one place.</p>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <a href="/aquintutor" target="_blank" style="background:#15151a;border:1px solid #1a1a1f;color:#fff;font-size:12px;font-weight:600;padding:8px 14px;border-radius:8px;text-decoration:none;">View public site -&gt;</a>
        <a href="/admin/courses" style="background:#FF4F00;border:none;color:#fff;font-size:12px;font-weight:700;padding:8px 14px;border-radius:8px;text-decoration:none;">+ New course</a>
      </div>
    </div>

    <!-- Top KPI grid -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px;margin-bottom:24px;">
      {[
        ['Courses', stats.courses, stats.publishedCourses + ' published'],
        ['Paid courses', stats.paidCourses, ''],
        ['Learning paths', stats.paths, ''],
        ['Faculty', stats.instructors, ''],
        ['Tests', stats.tests, stats.publishedTests + ' published'],
        ['Premium tests', stats.premiumTests, ''],
        ['Enrollments', stats.enrollments, ''],
        ['Completed attempts', stats.attempts, ''],
        ['Razorpay revenue', rs(stats.totalRevenuePaise), stats.paidTestAttempts + ' paid txns'],
      ].map(([label, value, hint]) => (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px 16px;">
          <p style="font-size:10px;color:#6e6e78;text-transform:uppercase;letter-spacing:0.08em;font-family:'Geist Mono',monospace;margin:0 0 6px;">{label}</p>
          <p style="font-size:22px;font-weight:800;color:#fff;font-family:'Geist Mono',monospace;margin:0;line-height:1;">{value}</p>
          {hint && <p style="font-size:11px;color:#8a8a94;margin:4px 0 0;">{hint}</p>}
        </div>
      ))}
    </div>

    <!-- Quick links grid -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:10px;margin-bottom:28px;">
      {[
        ['/admin/courses', 'Courses', 'Create / edit / publish'],
        ['/admin/paths', 'Learning Paths', 'Course bundles + tracks'],
        ['/admin/instructors', 'Faculty', 'Instructors + bios'],
        ['/admin/tests', 'Tests & Assessments', 'Gamified assessments'],
        ['/admin/events', 'Events', 'Bootcamps + paid events'],
        ['/admin/users', 'Users', 'Learners + roles'],
      ].map(([href, title, desc]) => (
        <a href={href} style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:16px;text-decoration:none;color:#fff;transition:border-color 0.15s;display:block;">
          <p style="font-size:14px;font-weight:700;margin:0 0 4px;">{title} &rarr;</p>
          <p style="font-size:11.5px;color:#8a8a94;margin:0;">{desc}</p>
        </a>
      ))}
    </div>

    <!-- Premium tests + revenue -->
    {premiumTests.length > 0 && (
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:18px 20px;margin-bottom:24px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
          <h2 style="font-size:14px;font-weight:700;color:#fff;margin:0;">Premium tests</h2>
          <a href="/admin/tests" style="font-size:11px;color:#FF7040;text-decoration:none;font-weight:600;">All tests &rarr;</a>
        </div>
        <div style="display:flex;flex-direction:column;gap:6px;">
          {premiumTests.map((t: any) => (
            <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;background:#15151a;border:1px solid #1a1a1f;border-radius:10px;padding:10px 14px;">
              <div style="min-width:0;flex:1;">
                <p style="font-size:13px;font-weight:600;color:#fff;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{t.title}</p>
                <p style="font-size:11px;color:#8a8a94;margin:3px 0 0;font-family:'Geist Mono',monospace;">/{t.slug} &middot; {t.is_published ? 'live' : 'draft'}</p>
              </div>
              <div style="display:flex;gap:14px;flex-shrink:0;">
                <div style="text-align:right;">
                  <p style="font-size:11px;color:#6e6e78;margin:0;">Price</p>
                  <p style="font-size:13px;font-weight:700;color:#fff;font-family:'Geist Mono',monospace;margin:2px 0 0;">{rs(t.price_inr_paise)}</p>
                </div>
                <div style="text-align:right;">
                  <p style="font-size:11px;color:#6e6e78;margin:0;">Paid users</p>
                  <p style="font-size:13px;font-weight:700;color:#10b981;font-family:'Geist Mono',monospace;margin:2px 0 0;">{t.paid_users}</p>
                </div>
                <div style="text-align:right;">
                  <p style="font-size:11px;color:#6e6e78;margin:0;">Completed</p>
                  <p style="font-size:13px;font-weight:700;color:#FF7040;font-family:'Geist Mono',monospace;margin:2px 0 0;">{t.completed_attempts}</p>
                </div>
                <a href={'/aquintutor/test/' + t.slug} target="_blank" style="align-self:center;background:#FF4F00;color:#fff;font-size:11px;font-weight:700;padding:6px 12px;border-radius:6px;text-decoration:none;">View</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Recent activity grid -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:14px;">
      <!-- Enrollments -->
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;">
        <h2 style="font-size:13px;font-weight:700;color:#fff;margin:0 0 12px;">Recent enrollments</h2>
        {recentEnrollments.length === 0 && <p style="font-size:11.5px;color:#6e6e78;margin:0;">No enrollments yet.</p>}
        {recentEnrollments.map((e: any) => (
          <div style="padding:8px 0;border-bottom:1px solid #15151a;">
            <p style="font-size:12.5px;color:#fff;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{e.user_name || e.user_email || 'anonymous'} &middot; {e.course_title}</p>
            <p style="font-size:10.5px;color:#8a8a94;margin:2px 0 0;font-family:'Geist Mono',monospace;">{e.progress_pct || 0}% &middot; {ago(e.created_at)}</p>
          </div>
        ))}
      </div>

      <!-- Test attempts -->
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;">
        <h2 style="font-size:13px;font-weight:700;color:#fff;margin:0 0 12px;">Recent test attempts</h2>
        {recentAttempts.length === 0 && <p style="font-size:11.5px;color:#6e6e78;margin:0;">No attempts yet.</p>}
        {recentAttempts.map((a: any) => (
          <div style="padding:8px 0;border-bottom:1px solid #15151a;">
            <p style="font-size:12.5px;color:#fff;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{a.candidate_name || a.candidate_email || 'anonymous'} &middot; {a.test_title || '(deleted)'}</p>
            <p style="font-size:10.5px;color:#8a8a94;margin:2px 0 0;font-family:'Geist Mono',monospace;">{Math.round(a.percentage || 0)}% &middot; {ago(a.submitted_at || a.started_at)}</p>
          </div>
        ))}
      </div>

      <!-- Payments -->
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;">
        <h2 style="font-size:13px;font-weight:700;color:#fff;margin:0 0 12px;">Recent payments</h2>
        {recentPayments.length === 0 && <p style="font-size:11.5px;color:#6e6e78;margin:0;">No payment activity.</p>}
        {recentPayments.map((p: any) => (
          <div style="padding:8px 0;border-bottom:1px solid #15151a;">
            <p style="font-size:12.5px;color:#fff;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{p.email || 'anon'} &middot; {p.purpose}</p>
            <p style="font-size:10.5px;color:#8a8a94;margin:2px 0 0;font-family:'Geist Mono',monospace;">
              {rs(p.amount_paise)} &middot;
              <span style={'color:' + (p.status === 'paid' ? '#10b981' : p.status === 'created' ? '#fbbf24' : '#ef4444') + ';'}>{p.status}</span> &middot;
              {ago(p.created_at)}
            </p>
          </div>
        ))}
      </div>
    </div>

  </div>
</AdminLayout>
