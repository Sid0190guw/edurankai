---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { ensureAquintutorAuthoringSchema, listBlocks, BLOCK_KINDS } from '@/lib/aquintutor-authoring';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const { id: courseId, lid: lessonId } = Astro.params;
if (!courseId || !lessonId) return Astro.redirect('/admin/aquintutor/courses');

await ensureAquintutorAuthoringSchema();
function rowsOf(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

const lesson = rowsOf(await db.execute(sql`SELECT * FROM training_lessons WHERE id = ${lessonId} LIMIT 1`))[0] as any;
if (!lesson) return Astro.redirect('/admin/aquintutor/courses/' + courseId + '/edit');
const blocks = await listBlocks(lessonId);
const course = rowsOf(await db.execute(sql`SELECT id, title, slug FROM training_courses WHERE id = ${courseId} LIMIT 1`))[0] as any;
---
<AdminLayout title={'Lesson · ' + lesson.title} activeNav="">
<div style="padding:14px 16px 80px;max-width:1400px;margin:0 auto;">
  <a href={'/admin/aquintutor/courses/' + courseId + '/edit'} style="font-size:11.5px;color:#9aa6b6;text-decoration:none;font-family:'Geist Mono',monospace;letter-spacing:0.06em;">← {course?.title}</a>

  <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px;margin-top:14px;margin-bottom:18px;">
    <div>
      <p style="font-size:10.5px;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;font-family:'Geist Mono',monospace;font-weight:700;">Lesson editor</p>
      <h1 id="lessonTitle" style="font-size:22px;color:#fff;margin:4px 0 4px;font-weight:700;" contenteditable="true">{lesson.title}</h1>
      <p style="font-size:10.5px;color:#9aa6b6;margin:0;font-family:'Geist Mono',monospace;">{lesson.slug} · {lesson.estimated_minutes || 10} min · status: <span id="statusPill" style={`color:${lesson.status==='published'?'#86efac':lesson.status==='in_review'?'#fbbf24':'#9aa6b6'};font-weight:700;`}>{lesson.status}</span></p>
    </div>
    <div style="display:flex;gap:6px;flex-wrap:wrap;">
      <button id="saveTitleBtn" style="background:#15151a;border:1px solid #2a2a2f;color:#cfd6da;padding:7px 14px;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer;font-family:'Geist Mono',monospace;">Save title</button>
      <button id="reviewBtn" style="background:#fbbf2418;border:1px solid #fbbf24;color:#fbbf24;padding:7px 14px;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer;font-family:'Geist Mono',monospace;">Request review</button>
      <button id="publishBtn" style="background:#86efac18;border:1px solid #86efac;color:#86efac;padding:7px 14px;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer;font-family:'Geist Mono',monospace;">Publish</button>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1.4fr 1fr;gap:18px;">

    {/* LEFT: block editor */}
    <div>
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:14px;">
        <div id="blockList" style="display:flex;flex-direction:column;gap:8px;min-height:200px;"></div>

        <details style="margin-top:10px;background:#08080a;border:1px solid #1a1a1f;border-radius:8px;padding:0;">
          <summary style="cursor:pointer;padding:8px 12px;font-size:11px;color:#FF7040;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;font-family:'Geist Mono',monospace;list-style:none;">+ Add block</summary>
          <div style="padding:0 12px 12px;display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:6px;">
            {Object.entries(BLOCK_KINDS).map(([k, v]: [string, any]) => (
              <button class="addBlockBtn" data-kind={k} style="background:#0f0f14;border:1px solid #2a2a2f;color:#cfd6da;padding:8px 10px;border-radius:5px;font-size:10.5px;font-weight:700;cursor:pointer;text-align:left;font-family:'Geist Mono',monospace;letter-spacing:0.05em;text-transform:uppercase;">+ {v.label}</button>
            ))}
          </div>
        </details>
      </div>
    </div>

    {/* RIGHT: preview + meta */}
    <div>
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:14px;position:sticky;top:14px;">
        <p style="font-size:10.5px;color:#67e8f9;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 10px;font-family:'Geist Mono',monospace;font-weight:700;">Preview</p>
        <div id="preview" style="background:#FAF8F5;color:#0E0B08;padding:18px;border-radius:8px;font-family:'Inter Tight',sans-serif;line-height:1.7;font-size:14px;min-height:300px;max-height:600px;overflow-y:auto;"></div>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ lessonId, courseId, courseSlug: course?.slug, initialBlocks: blocks, blockKinds: BLOCK_KINDS, lessonTitle: lesson.title }}>
  (function () {
    var blocks = initialBlocks.slice();
    var listEl = document.getElementById('blockList');
    var previewEl = document.getElementById('preview');

    function api(method, url, body) {
      return fetch(url, { method: method, headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin', body: body ? JSON.stringify(body) : undefined }).then(function (r) { return r.json(); });
    }

    function renderBlock(b, i) {
      var wrap = document.createElement('div');
      wrap.style.cssText = 'background:#08080a;border:1px solid #1a1a1f;border-radius:8px;padding:10px;';
      wrap.setAttribute('data-id', b.id);
      wrap.innerHTML = '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">'
        + '<span style="font-family:ui-monospace,monospace;font-size:9.5px;color:#FF7040;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;">' + (i + 1) + ' · ' + (blockKinds[b.kind] ? blockKinds[b.kind].label : b.kind) + '</span>'
        + '<div style="display:flex;gap:4px;">'
        +   '<button data-act="up" style="background:transparent;border:1px solid rgba(255,255,255,0.08);color:#cfd6da;padding:3px 7px;border-radius:4px;cursor:pointer;font-size:11px;">↑</button>'
        +   '<button data-act="down" style="background:transparent;border:1px solid rgba(255,255,255,0.08);color:#cfd6da;padding:3px 7px;border-radius:4px;cursor:pointer;font-size:11px;">↓</button>'
        +   '<button data-act="del" style="background:transparent;border:1px solid rgba(239,68,68,0.3);color:#fca5a5;padding:3px 7px;border-radius:4px;cursor:pointer;font-size:11px;">×</button>'
        + '</div></div>'
        + buildEditor(b);
      wrap.querySelectorAll('[data-field]').forEach(function (inp) {
        inp.addEventListener('input', function () { applyEdit(b, inp); });
      });
      wrap.querySelector('[data-act="del"]').addEventListener('click', function () { deleteBlock(b.id); });
      wrap.querySelector('[data-act="up"]').addEventListener('click', function () { move(b.id, -1); });
      wrap.querySelector('[data-act="down"]').addEventListener('click', function () { move(b.id, 1); });
      return wrap;
    }

    function buildEditor(b) {
      var c = b.content || {};
      var base = 'background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:8px 10px;border-radius:5px;font-size:12px;width:100%;font-family:inherit;';
      switch (b.kind) {
        case 'text': return '<textarea data-field="md" rows="4" style="' + base + 'resize:vertical;" placeholder="Paragraph text (markdown supported)">' + escapeHtml(c.md || '') + '</textarea>';
        case 'heading': return '<div style="display:grid;grid-template-columns:80px 1fr;gap:6px;"><select data-field="level" style="' + base + '"><option value="1"' + (c.level===1?' selected':'') + '>H1</option><option value="2"' + (c.level===2?' selected':'') + '>H2</option><option value="3"' + (c.level===3?' selected':'') + '>H3</option></select><input data-field="text" value="' + escapeAttr(c.text || '') + '" placeholder="Heading text" style="' + base + '" /></div>';
        case 'image': return '<div style="display:grid;gap:6px;"><input data-field="url" value="' + escapeAttr(c.url || '') + '" placeholder="https://..." style="' + base + '" /><input data-field="alt" value="' + escapeAttr(c.alt || '') + '" placeholder="Alt text" style="' + base + '" /><input data-field="caption" value="' + escapeAttr(c.caption || '') + '" placeholder="Caption" style="' + base + '" /></div>';
        case 'video_embed': return '<div style="display:grid;gap:6px;"><select data-field="provider" style="' + base + '"><option value="youtube"' + (c.provider==='youtube'?' selected':'') + '>YouTube</option><option value="vimeo"' + (c.provider==='vimeo'?' selected':'') + '>Vimeo</option></select><input data-field="url" value="' + escapeAttr(c.url || '') + '" placeholder="Video URL (full)" style="' + base + '" /><input data-field="caption" value="' + escapeAttr(c.caption || '') + '" placeholder="Caption (optional)" style="' + base + '" /></div>';
        case 'callout': return '<div style="display:grid;gap:6px;"><div style="display:grid;grid-template-columns:120px 1fr;gap:6px;"><select data-field="tone" style="' + base + '"><option value="info"' + (c.tone==='info'?' selected':'') + '>Info</option><option value="warning"' + (c.tone==='warning'?' selected':'') + '>Warning</option><option value="success"' + (c.tone==='success'?' selected':'') + '>Success</option><option value="tip"' + (c.tone==='tip'?' selected':'') + '>Tip</option></select><input data-field="title" value="' + escapeAttr(c.title || '') + '" placeholder="Title" style="' + base + '" /></div><textarea data-field="body" rows="2" style="' + base + 'resize:vertical;" placeholder="Body">' + escapeHtml(c.body || '') + '</textarea></div>';
        case 'code': return '<div style="display:grid;gap:6px;"><input data-field="language" value="' + escapeAttr(c.language || 'python') + '" placeholder="Language" style="' + base + '" /><textarea data-field="code" rows="8" style="' + base + 'resize:vertical;font-family:ui-monospace,monospace;" placeholder="Paste code...">' + escapeHtml(c.code || '') + '</textarea></div>';
        case 'mcq': return '<div style="display:grid;gap:6px;"><input data-field="question" value="' + escapeAttr(c.question || '') + '" placeholder="Question" style="' + base + '" /><textarea data-field="options_text" rows="4" style="' + base + 'resize:vertical;" placeholder="One option per line">' + escapeHtml((c.options || []).join('\n')) + '</textarea><input data-field="correct" type="number" value="' + (c.correct || 0) + '" min="0" placeholder="0-based correct index" style="' + base + '" /><textarea data-field="explanation" rows="2" style="' + base + 'resize:vertical;" placeholder="Why this is right">' + escapeHtml(c.explanation || '') + '</textarea></div>';
        case 'fill_blank': return '<div style="display:grid;gap:6px;"><input data-field="prompt" value="' + escapeAttr(c.prompt || '') + '" placeholder="Question with blank" style="' + base + '" /><input data-field="answer" value="' + escapeAttr(c.answer || '') + '" placeholder="Correct answer" style="' + base + '" /></div>';
        case 'order_steps': return '<div style="display:grid;gap:6px;"><input data-field="question" value="' + escapeAttr(c.question || '') + '" placeholder="Prompt" style="' + base + '" /><textarea data-field="steps_text" rows="4" style="' + base + 'resize:vertical;" placeholder="Steps in correct order, one per line">' + escapeHtml((c.steps || []).join('\n')) + '</textarea></div>';
        case 'quote': return '<div style="display:grid;gap:6px;"><textarea data-field="text" rows="3" style="' + base + 'resize:vertical;" placeholder="Quote text">' + escapeHtml(c.text || '') + '</textarea><input data-field="attribution" value="' + escapeAttr(c.attribution || '') + '" placeholder="— Author" style="' + base + '" /></div>';
        case 'latex': return '<textarea data-field="tex" rows="3" style="' + base + 'resize:vertical;font-family:ui-monospace,monospace;" placeholder="\\sum_{i=0}^n x_i">' + escapeHtml(c.tex || '') + '</textarea>';
        case 'file_attachment': return '<div style="display:grid;gap:6px;"><input data-field="name" value="' + escapeAttr(c.name || '') + '" placeholder="File name" style="' + base + '" /><input data-field="url" value="' + escapeAttr(c.url || '') + '" placeholder="https://..." style="' + base + '" /></div>';
        case 'divider': return '<p style="color:#6e6e78;font-style:italic;font-size:11px;margin:0;">— Visual divider —</p>';
        case 'embed_lab': {
          var labs = ['pendulum','projectile','optics','circuit','logic-gates','titration','periodic','molecular','genetics','ecosystem','plot','linear-algebra','sorting','pathfinding','neural-net','fourier','animator'];
          var opts = labs.map(function (s) { return '<option value="' + s + '"' + (c.slug === s ? ' selected' : '') + '>' + s + '</option>'; }).join('');
          return '<div style="display:grid;gap:6px;"><label style="font-size:10px;color:#9aa6b6;">Embed a live virtual lab inside this lesson</label><select data-field="slug" style="' + base + '">' + opts + '</select><input data-field="height" type="number" value="' + (c.height || 620) + '" placeholder="Height px" style="' + base + '" /><input data-field="caption" value="' + escapeAttr(c.caption || '') + '" placeholder="Caption (optional)" style="' + base + '" /></div>';
        }
        case 'embed_simulator': {
          var sims = [['quantum/composer','Quantum circuit composer'],['hpc/simulator','HPC job simulator'],['labs/neural-net','Neural network playground'],['labs/circuit','Circuit builder']];
          var opts = sims.map(function (s) { return '<option value="' + s[0] + '"' + (c.target === s[0] ? ' selected' : '') + '>' + s[1] + '</option>'; }).join('');
          return '<div style="display:grid;gap:6px;"><label style="font-size:10px;color:#9aa6b6;">Embed an advanced simulator</label><select data-field="target" style="' + base + '">' + opts + '</select><input data-field="height" type="number" value="' + (c.height || 700) + '" placeholder="Height px" style="' + base + '" /><input data-field="caption" value="' + escapeAttr(c.caption || '') + '" placeholder="Caption (optional)" style="' + base + '" /></div>';
        }
        case 'embed_test': return '<div style="display:grid;gap:6px;"><label style="font-size:10px;color:#9aa6b6;">Link a proctored test / assessment</label><input data-field="slug" value="' + escapeAttr(c.slug || '') + '" placeholder="test-slug (e.g. quantum-challenge-100)" style="' + base + '" /><input data-field="label" value="' + escapeAttr(c.label || 'Take the test') + '" placeholder="Button label" style="' + base + '" /></div>';
        case 'embed_liveclass': return '<div style="display:grid;gap:6px;"><label style="font-size:10px;color:#9aa6b6;">Embed a live class / real-time teaching room</label><input data-field="roomId" value="' + escapeAttr(c.roomId || '') + '" placeholder="meet room id" style="' + base + '" /><input data-field="label" value="' + escapeAttr(c.label || 'Join the live class') + '" placeholder="Button label" style="' + base + '" /></div>';
        case 'embed_animation': return '<div style="display:grid;gap:6px;"><label style="font-size:10px;color:#9aa6b6;">Embed the animation studio</label><input data-field="height" type="number" value="' + (c.height || 640) + '" placeholder="Height px" style="' + base + '" /><input data-field="caption" value="' + escapeAttr(c.caption || '') + '" placeholder="Caption (optional)" style="' + base + '" /></div>';
        default: return '<p style="color:#fca5a5;font-size:11px;">Unknown block kind.</p>';
      }
    }

    function applyEdit(b, inp) {
      var f = inp.getAttribute('data-field');
      var v = inp.value;
      if (f === 'options_text') { b.content.options = v.split('\n').map(function(s){return s.trim();}).filter(Boolean); }
      else if (f === 'steps_text') { b.content.steps = v.split('\n').map(function(s){return s.trim();}).filter(Boolean); }
      else if (f === 'level' || f === 'correct') { b.content[f] = parseInt(v, 10) || 0; }
      else { b.content[f] = v; }
      // debounce save
      clearTimeout(b._saveTimer);
      b._saveTimer = setTimeout(function () {
        api('PATCH', '/api/aquintutor/lesson-blocks/' + b.id, { content: b.content });
      }, 350);
      renderPreview();
    }

    function renderAll() {
      listEl.innerHTML = '';
      blocks.forEach(function (b, i) { listEl.appendChild(renderBlock(b, i)); });
      renderPreview();
    }

    function renderPreview() {
      var html = '<h2 style="font-family:Cormorant Garamond,serif;font-size:24px;margin:0 0 16px;">' + escapeHtml(lessonTitle) + '</h2>';
      blocks.forEach(function (b) {
        var c = b.content || {};
        switch (b.kind) {
          case 'text': html += '<p style="margin:0 0 12px;">' + escapeHtml(c.md || '').replace(/\n/g, '<br/>') + '</p>'; break;
          case 'heading': html += '<h' + (c.level || 2) + ' style="font-family:Cormorant Garamond,serif;margin:18px 0 8px;">' + escapeHtml(c.text || '') + '</h' + (c.level || 2) + '>'; break;
          case 'image': if (c.url) html += '<figure style="margin:14px 0;"><img src="' + escapeAttr(c.url) + '" alt="' + escapeAttr(c.alt || '') + '" style="max-width:100%;border-radius:8px;" />' + (c.caption ? '<figcaption style="font-size:12px;color:#7A6F68;margin-top:6px;">' + escapeHtml(c.caption) + '</figcaption>' : '') + '</figure>'; break;
          case 'video_embed': if (c.url) html += '<div style="background:#0a0a0a;color:#fff;padding:24px;border-radius:8px;margin:14px 0;text-align:center;font-family:monospace;font-size:11px;letter-spacing:0.1em;">[ ' + (c.provider || 'video') + ' embed ]<br/><span style="font-size:10px;opacity:0.7;">' + escapeHtml(c.url) + '</span></div>'; break;
          case 'callout': html += '<div style="background:#FFF3EE;border-left:3px solid #FF4F00;padding:12px 14px;margin:14px 0;border-radius:0 6px 6px 0;"><p style="font-weight:700;margin:0 0 4px;font-size:12px;text-transform:uppercase;letter-spacing:0.08em;color:#FF4F00;">' + escapeHtml(c.title || c.tone || 'Info') + '</p><p style="margin:0;font-size:13.5px;">' + escapeHtml(c.body || '').replace(/\n/g, '<br/>') + '</p></div>'; break;
          case 'code': html += '<pre style="background:#08080a;color:#cfd6da;padding:14px;border-radius:6px;margin:14px 0;overflow-x:auto;font-family:ui-monospace,monospace;font-size:12.5px;line-height:1.55;"><code>' + escapeHtml(c.code || '') + '</code></pre>'; break;
          case 'mcq': html += '<div style="background:#FFF3EE;border:1px solid #FFD4BC;padding:14px;border-radius:8px;margin:14px 0;"><p style="font-weight:700;margin:0 0 8px;">' + escapeHtml(c.question || '') + '</p>' + (c.options || []).map(function (o, i) { return '<label style="display:block;padding:6px 0;font-size:13px;"><input type="radio" disabled' + (i === (c.correct || 0) ? ' checked' : '') + ' /> ' + escapeHtml(o) + '</label>'; }).join('') + (c.explanation ? '<p style="font-style:italic;font-size:12px;color:#7A6F68;margin:8px 0 0;">' + escapeHtml(c.explanation) + '</p>' : '') + '</div>'; break;
          case 'fill_blank': html += '<div style="background:#EBF0FF;border:1px solid #B0C4F8;padding:12px;border-radius:8px;margin:14px 0;"><p style="margin:0 0 6px;">' + escapeHtml(c.prompt || '') + '</p><input disabled placeholder="Type answer..." style="background:#fff;border:1px solid #b0c4f8;padding:6px 10px;border-radius:4px;width:200px;" /><p style="font-size:11px;color:#7A6F68;margin:6px 0 0;font-style:italic;">Answer: ' + escapeHtml(c.answer || '') + '</p></div>'; break;
          case 'order_steps': html += '<div style="background:#F2EAFF;border:1px solid #D4B5F5;padding:12px;border-radius:8px;margin:14px 0;"><p style="font-weight:700;margin:0 0 8px;">' + escapeHtml(c.question || '') + '</p><ol style="margin:0;padding-left:20px;">' + (c.steps || []).map(function (s) { return '<li>' + escapeHtml(s) + '</li>'; }).join('') + '</ol></div>'; break;
          case 'quote': html += '<blockquote style="border-left:3px solid #1A6B35;padding:8px 14px;margin:14px 0;font-style:italic;font-family:Cormorant Garamond,serif;font-size:18px;">' + escapeHtml(c.text || '') + (c.attribution ? '<footer style="font-size:13px;color:#7A6F68;font-style:normal;margin-top:6px;">— ' + escapeHtml(c.attribution) + '</footer>' : '') + '</blockquote>'; break;
          case 'latex': html += '<div style="background:#fbf5f3;border:1px solid #FFD4BC;padding:12px;border-radius:6px;margin:14px 0;font-family:ui-monospace,monospace;font-size:14px;text-align:center;">' + escapeHtml(c.tex || '') + '<p style="font-size:10px;color:#7A6F68;margin-top:4px;text-align:center;">[ rendered with KaTeX in production ]</p></div>'; break;
          case 'divider': html += '<hr style="border:none;border-top:1px solid #e5dcc6;margin:24px 0;"/>'; break;
          case 'embed_lab': html += '<div style="border:2px dashed #FF4F00;border-radius:10px;padding:18px;margin:14px 0;text-align:center;background:#FFF3EE;"><p style="font-family:ui-monospace,monospace;font-size:11px;color:#FF4F00;font-weight:700;margin:0;">LIVE LAB · /aquintutor/labs/' + escapeHtml(c.slug || 'pendulum') + '</p><p style="font-size:12px;color:#7A6F68;margin:6px 0 0;">Renders as a full interactive ' + escapeHtml(c.slug || '') + ' simulator (' + (c.height || 620) + 'px) for the learner.</p></div>'; break;
          case 'embed_simulator': html += '<div style="border:2px dashed #a78bfa;border-radius:10px;padding:18px;margin:14px 0;text-align:center;background:#F2EAFF;"><p style="font-family:ui-monospace,monospace;font-size:11px;color:#6B1FBE;font-weight:700;margin:0;">SIMULATOR · /aquintutor/' + escapeHtml(c.target || '') + '</p><p style="font-size:12px;color:#7A6F68;margin:6px 0 0;">Embedded live simulator (' + (c.height || 700) + 'px).</p></div>'; break;
          case 'embed_test': html += '<div style="border:2px dashed #1045BB;border-radius:10px;padding:18px;margin:14px 0;text-align:center;background:#EBF0FF;"><p style="font-family:ui-monospace,monospace;font-size:11px;color:#1045BB;font-weight:700;margin:0;">PROCTORED TEST · ' + escapeHtml(c.slug || '(none set)') + '</p><p style="font-size:12px;color:#7A6F68;margin:6px 0 0;">Button "' + escapeHtml(c.label || 'Take the test') + '" launches the proctored runner.</p></div>'; break;
          case 'embed_liveclass': html += '<div style="border:2px dashed #1A6B35;border-radius:10px;padding:18px;margin:14px 0;text-align:center;background:#EBF5EF;"><p style="font-family:ui-monospace,monospace;font-size:11px;color:#1A6B35;font-weight:700;margin:0;">LIVE CLASS · room ' + escapeHtml(c.roomId || '(none)') + '</p><p style="font-size:12px;color:#7A6F68;margin:6px 0 0;">Real-time teaching room joins inline.</p></div>'; break;
          case 'embed_animation': html += '<div style="border:2px dashed #fb923c;border-radius:10px;padding:18px;margin:14px 0;text-align:center;background:#FFF7ED;"><p style="font-family:ui-monospace,monospace;font-size:11px;color:#c2410c;font-weight:700;margin:0;">ANIMATION STUDIO</p><p style="font-size:12px;color:#7A6F68;margin:6px 0 0;">Embedded real-time animation generator (' + (c.height || 640) + 'px).</p></div>'; break;
          case 'file_attachment': if (c.url) html += '<a href="' + escapeAttr(c.url) + '" download style="display:inline-flex;align-items:center;gap:6px;background:#FFF3EE;color:#FF4F00;padding:10px 14px;border-radius:6px;text-decoration:none;font-weight:600;margin:14px 0;">↓ ' + escapeHtml(c.name || 'Download') + '</a>'; break;
        }
      });
      previewEl.innerHTML = html;
    }

    function escapeHtml(s) { return (s || '').toString().replace(/[<>&"]/g, function (c) { return { '<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;' }[c]; }); }
    function escapeAttr(s) { return escapeHtml(s); }

    function addBlock(kind) {
      var defaults = blockKinds[kind] ? Object.assign({}, blockKinds[kind].defaults) : {};
      api('POST', '/api/aquintutor/lesson-blocks', { lessonId: lessonId, kind: kind, content: defaults }).then(function (r) {
        if (r.ok) { blocks.push(r.block); renderAll(); }
      });
    }
    function deleteBlock(blockId) {
      api('DELETE', '/api/aquintutor/lesson-blocks/' + blockId).then(function (r) {
        blocks = blocks.filter(function (b) { return b.id !== blockId; });
        renderAll();
      });
    }
    function move(blockId, dir) {
      var idx = blocks.findIndex(function (b) { return b.id === blockId; });
      var j = idx + dir;
      if (j < 0 || j >= blocks.length) return;
      var tmp = blocks[idx]; blocks[idx] = blocks[j]; blocks[j] = tmp;
      api('POST', '/api/aquintutor/lesson-blocks/reorder', { lessonId: lessonId, ids: blocks.map(function (b) { return b.id; }) });
      renderAll();
    }

    document.querySelectorAll('.addBlockBtn').forEach(function (b) { b.addEventListener('click', function () { addBlock(b.getAttribute('data-kind')); }); });

    document.getElementById('saveTitleBtn').addEventListener('click', function () {
      var newTitle = document.getElementById('lessonTitle').textContent.trim();
      api('PATCH', '/api/aquintutor/lessons/' + lessonId + '/meta', { title: newTitle });
    });
    document.getElementById('reviewBtn').addEventListener('click', function () {
      api('POST', '/api/aquintutor/lessons/' + lessonId + '/request-review').then(function () {
        document.getElementById('statusPill').textContent = 'in_review';
        document.getElementById('statusPill').style.color = '#fbbf24';
      });
    });
    document.getElementById('publishBtn').addEventListener('click', function () {
      if (!confirm('Publish this lesson? Students will see it immediately.')) return;
      api('POST', '/api/aquintutor/lessons/' + lessonId + '/publish').then(function () {
        document.getElementById('statusPill').textContent = 'published';
        document.getElementById('statusPill').style.color = '#86efac';
      });
    });

    renderAll();
  })();
</script>
</AdminLayout>
