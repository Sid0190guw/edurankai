---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { products } from '@/lib/db/schema';
import { can } from '@/lib/auth/permissions';
import { logAudit } from '@/lib/audit';
import { asc, eq } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!can(user, 'products.view')) return Astro.redirect('/admin');
const canEdit = can(user, 'products.edit');

let errorMsg = '';
let okMsg = '';

const STATUSES = ['live', 'coming_soon', 'in_development', 'research', 'stealth'] as const;
const STATUS_LABELS: Record<string, string> = {
  live: 'Live',
  coming_soon: 'Coming Soon',
  in_development: 'In Development',
  research: 'Research',
  stealth: 'Stealth'
};

if (Astro.request.method === 'POST' && canEdit) {
  const fd = await Astro.request.formData();
  const action = fd.get('_action') as string;

  try {
    if (action === 'create' || action === 'update') {
      const id = fd.get('id') as string;
      const candidate = {
        slug: (fd.get('slug') as string || '').trim().toLowerCase(),
        name: (fd.get('name') as string || '').trim(),
        emphasisWord: (fd.get('emphasisWord') as string || '').trim() || null,
        status: fd.get('status') as any,
        shortDescription: (fd.get('shortDescription') as string || '').trim(),
        longDescription: (fd.get('longDescription') as string || '').trim() || null,
        externalUrl: (fd.get('externalUrl') as string || '').trim() || null,
        iconKey: (fd.get('iconKey') as string || '').trim() || null,
        sortOrder: parseInt((fd.get('sortOrder') as string) || '99', 10),
        isVisible: fd.get('isVisible') === 'on'
      };

      if (!candidate.slug || !candidate.name || !candidate.shortDescription || !candidate.status) {
        errorMsg = 'Slug, name, status and short description are required.';
      } else if (!candidate.slug.match(/^[a-z0-9-]+$/)) {
        errorMsg = 'Slug must be lowercase letters, digits, and hyphens only.';
      } else {
        if (action === 'create') {
          const existing = await db.select({ id: products.id }).from(products).where(eq(products.slug, candidate.slug)).limit(1);
          if (existing.length > 0) {
            errorMsg = 'Slug already exists.';
          } else {
            const inserted = await db.insert(products).values(candidate).returning({ id: products.id });
            await logAudit({ userId: user.id, action: 'product.create', entity: 'product', entityId: inserted[0].id, diff: candidate, ipAddress: Astro.clientAddress });
            okMsg = 'Product "' + candidate.name + '" created.';
          }
        } else {
          await db.update(products).set({ ...candidate, updatedAt: new Date() }).where(eq(products.id, id));
          await logAudit({ userId: user.id, action: 'product.update', entity: 'product', entityId: id, diff: candidate, ipAddress: Astro.clientAddress });
          okMsg = 'Product "' + candidate.name + '" updated.';
        }
      }
    } else if (action === 'delete') {
      const id = fd.get('id') as string;
      await db.delete(products).where(eq(products.id, id));
      await logAudit({ userId: user.id, action: 'product.delete', entity: 'product', entityId: id, diff: {}, ipAddress: Astro.clientAddress });
      okMsg = 'Product deleted.';
    } else if (action === 'toggle_visible') {
      const id = fd.get('id') as string;
      const target = await db.select().from(products).where(eq(products.id, id)).limit(1);
      if (target.length > 0) {
        await db.update(products).set({ isVisible: !target[0].isVisible, updatedAt: new Date() }).where(eq(products.id, id));
        okMsg = target[0].isVisible ? 'Hidden.' : 'Now visible.';
      }
    }
  } catch (err: any) {
    errorMsg = 'Failed: ' + (err.message || 'Unknown error');
  }
}

const url = new URL(Astro.request.url);
const editId = url.searchParams.get('edit') || '';
const allProducts = await db.select().from(products).orderBy(asc(products.sortOrder), asc(products.name));
const editing = editId ? allProducts.find(p => p.id === editId) : null;

const statusColor: Record<string, string> = {
  live: '#10b981',
  coming_soon: '#fbbf24',
  in_development: '#60a5fa',
  research: '#a78bfa',
  stealth: '#6e6e78'
};
---
<AdminLayout title="Products" activeNav="products">
  <div class="admin-page" style="max-width:1300px;">

    <div class="admin-page-header" style="margin-bottom:24px;">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">Ecosystem</div>
        <h1 class="admin-page-title">Products</h1>
        <p class="admin-page-sub">{allProducts.length} products. These appear on /ecosystem and (selected ones) on the homepage.</p>
      </div>
    </div>

    {errorMsg && <div style="background:rgba(220,38,38,0.08);border:1px solid rgba(220,38,38,0.25);color:#fca5a5;font-size:12.5px;padding:11px 14px;border-radius:7px;margin-bottom:18px;">{errorMsg}</div>}
    {okMsg && <div style="background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.25);color:#6ee7b7;font-size:12.5px;padding:11px 14px;border-radius:7px;margin-bottom:18px;">{okMsg}</div>}

    <div style="display:grid;grid-template-columns:1.5fr 1fr;gap:18px;align-items:flex-start;">

      <!-- LIST -->
      <div class="admin-card" style="padding:0;overflow:hidden;">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Product</th>
              <th>Status</th>
              <th>Visible</th>
              <th>Order</th>
              <th style="text-align:right;">Actions</th>
            </tr>
          </thead>
          <tbody>
            {allProducts.map((p) => {
              const sc = statusColor[p.status] || '#6e6e78';
              return (
                <tr style={editing && editing.id === p.id ? 'background:rgba(255,79,0,0.06);' : ''}>
                  <td>
                    <div style="font-weight:500;color:#fff;">{p.name}</div>
                    <div style="font-size:11px;color:#6e6e78;margin-top:3px;font-family:'Geist Mono',monospace;">{p.slug}</div>
                    {p.externalUrl && <div style="font-size:10.5px;color:#6e6e78;margin-top:2px;"><a href={p.externalUrl} target="_blank" style="color:#6e6e78;">{p.externalUrl} &#8599;</a></div>}
                  </td>
                  <td>
                    <span style={'display:inline-flex;align-items:center;gap:5px;font-size:11px;color:' + sc + ';font-weight:500;'}>
                      <span style={'width:6px;height:6px;border-radius:50%;background:' + sc + ';'}></span>
                      {STATUS_LABELS[p.status] || p.status}
                    </span>
                  </td>
                  <td>
                    <span style={'font-size:11px;color:' + (p.isVisible ? '#10b981' : '#6e6e78')}>
                      {p.isVisible ? 'Yes' : 'No'}
                    </span>
                  </td>
                  <td><span style="font-size:11px;color:#a0a0ab;font-family:'Geist Mono',monospace;">{p.sortOrder}</span></td>
                  <td style="text-align:right;">
                    {canEdit && (
                      <div style="display:flex;gap:5px;justify-content:flex-end;flex-wrap:wrap;">
                        <a href={'?edit=' + p.id} class="admin-btn" style="padding:4px 9px;font-size:10.5px;">Edit</a>
                        <form method="POST" style="margin:0;display:inline;">
                          <input type="hidden" name="_action" value="toggle_visible" />
                          <input type="hidden" name="id" value={p.id} />
                          <button type="submit" class="admin-btn" style="padding:4px 9px;font-size:10.5px;">{p.isVisible ? 'Hide' : 'Show'}</button>
                        </form>
                        <form method="POST" style="margin:0;display:inline;" onsubmit="return confirm('Delete this product permanently?');">
                          <input type="hidden" name="_action" value="delete" />
                          <input type="hidden" name="id" value={p.id} />
                          <button type="submit" class="admin-btn" style="padding:4px 9px;font-size:10.5px;color:#fca5a5;">Delete</button>
                        </form>
                      </div>
                    )}
                  </td>
                </tr>
              );
            })}
            {allProducts.length === 0 && <tr><td colspan="5" style="text-align:center;padding:30px;color:#6e6e78;font-size:13px;">No products yet. Create one on the right.</td></tr>}
          </tbody>
        </table>
      </div>

      <!-- FORM -->
      {canEdit && (
        <form method="POST" class="admin-card" style="display:flex;flex-direction:column;gap:12px;">
          <input type="hidden" name="_action" value={editing ? 'update' : 'create'} />
          {editing && <input type="hidden" name="id" value={editing.id} />}

          <div>
            <div class="admin-card-title" style="margin:0 0 4px;">{editing ? 'Edit: ' + editing.name : '+ New product'}</div>
            <p style="font-size:11px;color:#6e6e78;line-height:1.5;">{editing ? 'Update fields and save. Cancel to clear.' : 'Slug must be unique and URL-safe.'}</p>
          </div>

          <div>
            <label class="rolefield-label">Name *</label>
            <input name="name" required class="rolefield-input" placeholder="e.g. Sambandh" value={editing ? editing.name : ''} />
          </div>

          <div>
            <label class="rolefield-label">Emphasis word</label>
            <input name="emphasisWord" class="rolefield-input" placeholder="e.g. Sambandh" value={editing && editing.emphasisWord ? editing.emphasisWord : ''} />
            <p style="font-size:10px;color:#6e6e78;margin-top:3px;">Word to highlight in the name on the public page.</p>
          </div>

          <div>
            <label class="rolefield-label">Slug *</label>
            <input name="slug" required pattern="[a-z0-9-]+" class="rolefield-input" placeholder="e.g. sambandh" value={editing ? editing.slug : ''} />
          </div>

          <div>
            <label class="rolefield-label">Status *</label>
            <select name="status" required class="rolefield-input">
              {STATUSES.map((s) => (
                <option value={s} selected={editing && editing.status === s}>{STATUS_LABELS[s]}</option>
              ))}
            </select>
          </div>

          <div>
            <label class="rolefield-label">Short description *</label>
            <textarea name="shortDescription" required rows="3" class="rolefield-input" placeholder="One or two sentence summary.">{editing ? editing.shortDescription : ''}</textarea>
          </div>

          <div>
            <label class="rolefield-label">Long description</label>
            <textarea name="longDescription" rows="4" class="rolefield-input" placeholder="Optional, detailed description for /ecosystem/[slug]">{editing && editing.longDescription ? editing.longDescription : ''}</textarea>
          </div>

          <div>
            <label class="rolefield-label">External URL</label>
            <input name="externalUrl" type="url" class="rolefield-input" placeholder="https://..." value={editing && editing.externalUrl ? editing.externalUrl : ''} />
          </div>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            <div>
              <label class="rolefield-label">Icon key</label>
              <input name="iconKey" class="rolefield-input" placeholder="e.g. brain" value={editing && editing.iconKey ? editing.iconKey : ''} />
            </div>
            <div>
              <label class="rolefield-label">Sort order</label>
              <input type="number" name="sortOrder" class="rolefield-input" value={editing ? editing.sortOrder : 99} />
            </div>
          </div>

          <label style="display:flex;align-items:center;gap:8px;color:#d8d8de;font-size:12px;cursor:pointer;">
            <input type="checkbox" name="isVisible" style="accent-color:#FF4F00;" checked={!editing || editing.isVisible} />
            <span>Visible to public</span>
          </label>

          <div style="display:flex;gap:8px;">
            <button type="submit" class="admin-btn admin-btn-primary" style="flex:1;justify-content:center;">{editing ? 'Save changes' : 'Create product'}</button>
            {editing && <a href="/admin/products" class="admin-btn" style="display:flex;align-items:center;padding:8px 14px;">Cancel</a>}
          </div>
        </form>
      )}

    </div>
  </div>

  <style>
    .rolefield-label { display:block;font-size:10.5px;font-weight:600;color:#8a8a94;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:6px; }
    .rolefield-input { width:100%;padding:8px 11px;background:#08080a;border:1px solid #1f1f26;border-radius:6px;color:#fff;font-size:12.5px;font-family:inherit;outline:none; }
    .rolefield-input:focus { border-color:#FF4F00; }
    textarea.rolefield-input { resize:vertical;min-height:60px; }
  </style>
</AdminLayout>