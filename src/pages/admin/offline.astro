---
// /admin/offline — Offline package inspector + policy (Prompt 6, admin surface). Gated by
// can(audit, offline). Shows real compiled packages (what, size, dropped), the sync-queue depth,
// and the offline policy (max package size). Real data only.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { listPackages, queueDepth, getPolicy } from '@/lib/offline-package';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'audit', { type: 'offline' });
if (!gate.allow) return Astro.redirect('/admin');

const packages = await listPackages(50).catch(() => []);
const depth = await queueDepth().catch(() => 0);
const policy = await getPolicy().catch(() => ({ maxBytes: 8 * 1024 * 1024 }));
const canConfigure = (await can(user, 'configure', { type: 'offline' })).allow;

const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const IN = 'background:#15151a;border:1px solid #26262c;color:#fff;padding:7px 9px;border-radius:6px;font-size:12px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
const kb = (b: number) => Math.round((Number(b) || 0) / 1024);
function fmt(d: any) { try { return new Date(d).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); } catch { return '-'; } }
---
<AdminLayout title="Offline packages" activeNav="offline">
  <div style="max-width:1080px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Offline runtime</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Offline packages &amp; sync queue</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">Students download budget-planned, pre-rendered packages to learn offline; changes enqueue on reconnect for the sync engine. Sync console: <a href="/admin/sync" style="color:#FF7040;">/admin/sync</a>.</p>
    <div id="msg" style="display:none;margin:12px 0;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:16px;">
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Packages compiled</p><p style="font-size:26px;font-weight:800;color:#fff;margin:4px 0 0;">{packages.length}</p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Pending sync queue</p><p style="font-size:26px;font-weight:800;color:#fff;margin:4px 0 0;">{depth}</p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Max package size</p><p style="font-size:26px;font-weight:800;color:#fff;margin:4px 0 0;">{kb(policy.maxBytes)} KB</p></div>
    </div>

    {canConfigure ? (
      <div style={CARD}>
        <p style={HD}>Policy</p>
        <div style="display:flex;gap:8px;align-items:end;flex-wrap:wrap;">
          <div><label style="font-size:10px;color:#8a8a94;">Max package size (KB)</label><br/><input id="polKb" type="number" value={kb(policy.maxBytes)} style={IN} /></div>
          <button id="polSave" type="button" style="background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:700;padding:8px 14px;border-radius:6px;cursor:pointer;">Save policy</button>
        </div>
      </div>
    ) : null}

    <div style={CARD}>
      <p style={HD}>Compiled packages</p>
      {packages.length === 0 ? <p style="font-size:12.5px;color:#6e6e78;margin:0;">No packages compiled yet. They appear when a student taps "Download for offline".</p> :
      <div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:12px;">
        <thead><tr style="color:#8a8a94;font-size:9px;text-transform:uppercase;font-family:'Geist Mono',monospace;text-align:left;"><th style="padding:5px 8px;">When</th><th style="padding:5px 8px;">Student</th><th style="padding:5px 8px;">Tier</th><th style="padding:5px 8px;">Units</th><th style="padding:5px 8px;">Size</th><th style="padding:5px 8px;">Dropped</th></tr></thead>
        <tbody>
          {packages.map((p: any) => (
            <tr style="border-top:1px solid #15151a;">
              <td style="padding:6px 8px;color:#8a8a94;font-family:'Geist Mono',monospace;white-space:nowrap;">{fmt(p.created_at)}</td>
              <td style="padding:6px 8px;color:#cfd6da;">{p.user_name || (p.user_id ? String(p.user_id).slice(0, 8) : 'guest')}</td>
              <td style="padding:6px 8px;color:#8a8a94;font-family:'Geist Mono',monospace;">{p.tier}</td>
              <td style="padding:6px 8px;color:#cfd6da;">{p.unit_count}</td>
              <td style="padding:6px 8px;color:#cfd6da;">{kb(p.bytes)} KB</td>
              <td style={'padding:6px 8px;color:' + (p.dropped > 0 ? '#c0a35e' : '#6e6e78')}>{p.dropped}</td>
            </tr>
          ))}
        </tbody>
      </table></div>}
    </div>
  </div>

  <script is:inline>
    (function () {
      var save = document.getElementById('polSave'); if (!save) return;
      var msg = document.getElementById('msg');
      save.addEventListener('click', function () {
        var kb = parseInt(document.getElementById('polKb').value, 10) || 0;
        fetch('/api/admin/offline', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ maxBytes: kb * 1024 }) })
          .then(function (r) { return r.json(); })
          .then(function (j) { msg.style.display = 'block'; msg.textContent = j.ok ? 'Saved.' : (j.error || 'Failed'); msg.style.background = j.ok ? 'rgba(16,185,129,0.12)' : 'rgba(239,68,68,0.12)'; msg.style.color = j.ok ? '#6ee7b7' : '#fca5a5'; if (j.ok) setTimeout(function () { location.reload(); }, 500); });
      });
    })();
  </script>
</AdminLayout>
