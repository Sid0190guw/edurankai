---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { getSessionLog, summarize } from '@/lib/activity-log';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const { session } = Astro.params;
const log = session ? await getSessionLog(session) : [];
const summary = summarize(log as any);

function fmtT(ts: any, at: any) {
  try { const d = ts ? new Date(Number(ts)) : new Date(at); return d.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit', second: '2-digit' }); } catch { return ''; }
}
const sevColor: Record<string, string> = { high: '#f87171', medium: '#fbbf24', low: '#86efac', info: '#9aa6b6' };
---
<AdminLayout title={'Proctoring · ' + session} activeNav="">
<div style="padding:14px 16px 80px;max-width:1200px;margin:0 auto;">
  <a href="/admin/tests/attempts" style="font-size:11px;color:#67e8f9;text-decoration:none;font-family:'Geist Mono',monospace;letter-spacing:0.06em;">&larr; Attempts</a>
  <p style="font-size:10.5px;color:#a78bfa;letter-spacing:0.16em;text-transform:uppercase;margin:12px 0 0;font-family:'Geist Mono',monospace;font-weight:700;">Proctoring · activity log (decrypted)</p>
  <h1 style="font-size:24px;color:#fff;margin:6px 0 4px;font-weight:700;">Session {session}</h1>

  <div style="background:rgba(251,191,36,0.08);border:1px solid rgba(251,191,36,0.35);border-radius:10px;padding:11px 16px;margin:12px 0 18px;font-size:12.5px;color:#fbbf24;font-family:'Geist Mono',monospace;line-height:1.5;">
    Advisory only. These automated signals never penalise a candidate. You — a human — read the full context and decide. False positives can cause real harm.
  </div>

  {/* SUMMARY */}
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:10px;margin-bottom:14px;">
    <div style="background:#11131a;border:1px solid #2a2a35;border-radius:10px;padding:14px 16px;"><div style="font-family:'Cormorant Garamond',serif;font-size:26px;color:#fff;font-weight:600;line-height:1;">{summary.total}</div><div style="font-family:'Geist Mono',monospace;font-size:9px;letter-spacing:0.1em;text-transform:uppercase;color:#9aa6b6;margin-top:6px;font-weight:700;">Events logged</div></div>
    <div style="background:#11131a;border:1px solid #2a2a35;border-radius:10px;padding:14px 16px;"><div style="font-family:'Cormorant Garamond',serif;font-size:26px;color:#fff;font-weight:600;line-height:1;">{summary.spanMinutes}m</div><div style="font-family:'Geist Mono',monospace;font-size:9px;letter-spacing:0.1em;text-transform:uppercase;color:#9aa6b6;margin-top:6px;font-weight:700;">Duration</div></div>
    <div style="background:#11131a;border:1px solid #2a2a35;border-radius:10px;padding:14px 16px;"><div style="font-family:'Cormorant Garamond',serif;font-size:26px;color:#f87171;font-weight:600;line-height:1;">{summary.high}</div><div style="font-family:'Geist Mono',monospace;font-size:9px;letter-spacing:0.1em;text-transform:uppercase;color:#9aa6b6;margin-top:6px;font-weight:700;">High signals</div></div>
    <div style="background:#11131a;border:1px solid #2a2a35;border-radius:10px;padding:14px 16px;"><div style="font-family:'Cormorant Garamond',serif;font-size:26px;color:#fbbf24;font-weight:600;line-height:1;">{summary.medium}</div><div style="font-family:'Geist Mono',monospace;font-size:9px;letter-spacing:0.1em;text-transform:uppercase;color:#9aa6b6;margin-top:6px;font-weight:700;">Medium signals</div></div>
    <div style="background:#11131a;border:1px solid #2a2a35;border-radius:10px;padding:14px 16px;"><div style="font-family:'Cormorant Garamond',serif;font-size:26px;color:#67e8f9;font-weight:600;line-height:1;">{summary.transcriptWords}</div><div style="font-family:'Geist Mono',monospace;font-size:9px;letter-spacing:0.1em;text-transform:uppercase;color:#9aa6b6;margin-top:6px;font-weight:700;">Transcript words</div></div>
  </div>

  <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:16px 18px;margin-bottom:18px;">
    <p style="font-family:'Geist Mono',monospace;font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:#a78bfa;font-weight:700;margin:0 0 8px;">Auto summary</p>
    <p style="font-size:14.5px;color:#fff;margin:0 0 10px;font-weight:600;">{summary.verdict}</p>
    <div style="display:flex;gap:6px;flex-wrap:wrap;">
      {summary.byType.map((t) => <span style="font-family:'Geist Mono',monospace;font-size:11px;background:#1a1a25;border:1px solid #2a2a35;color:#cfd6da;padding:3px 10px;border-radius:100px;">{t.type} · {t.n}</span>)}
    </div>
  </div>

  {/* MINUTE-BY-MINUTE TIMELINE */}
  <p style="font-family:'Geist Mono',monospace;font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:#a78bfa;font-weight:700;margin:0 0 10px;">Minute-by-minute log</p>
  {log.length === 0 ? (
    <div style="padding:30px;text-align:center;color:#6b6b7a;font-family:'Geist Mono',monospace;font-size:13px;background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;">No activity recorded for this session yet.</div>
  ) : (
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
      {(log as any[]).map((e) => (
        <div style="display:grid;grid-template-columns:78px 90px 1fr;gap:12px;padding:9px 16px;border-bottom:1px solid #14141c;align-items:flex-start;">
          <span style="font-family:'Geist Mono',monospace;font-size:11px;color:#6b6b7a;">{fmtT(e.ts, e.at)}</span>
          <span style={'font-family:Geist Mono,monospace;font-size:9.5px;letter-spacing:0.06em;text-transform:uppercase;font-weight:700;color:' + (sevColor[e.severity] || '#9aa6b6') + ';'}>{e.type}</span>
          <span style="font-size:13px;color:#cfd6da;line-height:1.5;">{e.detail}</span>
        </div>
      ))}
    </div>
  )}
</div>
</AdminLayout>
