---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { isConfigured } from '@/lib/razorpay';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (!['super_admin', 'hr'].includes(user.role)) return Astro.redirect('/admin');
const ready = isConfigured();
---
<AdminLayout title="Razorpay test" activeNav="finance">
  <div class="admin-page" style="max-width:640px;">
    <div class="admin-page-header" style="margin-bottom:18px;">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">Finance</div>
        <h1 class="admin-page-title">Razorpay Rs 1 test</h1>
        <p class="admin-page-sub">Runs a real Rs 1 charge to confirm the live integration end-to-end (order -> checkout -> capture -> verify -> webhook). It shows up in the finance dashboard and your Razorpay dashboard.</p>
      </div>
    </div>

    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:18px;">
      <p style="font-size:12.5px;color:#a0a0ab;margin:0 0 14px;line-height:1.6;">
        Keys present in this environment: <strong style={ready ? 'color:#6ee7b7;' : 'color:#fca5a5;'}>{ready ? 'yes' : 'no'}</strong>.
        {!ready && ' Keys live only in Vercel production - open this page on the deployed site (edurankai.in) to test, not localhost.'}
      </p>
      <button id="payBtn" disabled={!ready} style={'background:#FF4F00;color:#fff;border:none;font-weight:700;padding:11px 20px;border-radius:8px;cursor:pointer;font-size:14px;' + (ready ? '' : 'opacity:0.5;cursor:not-allowed;')}>Pay Rs 1 (test)</button>
      <p id="result" style="margin-top:14px;font-size:13px;"></p>
    </div>
  </div>

  <script is:inline src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script is:inline>
    (function () {
      var btn = document.getElementById('payBtn');
      var out = document.getElementById('result');
      if (!btn) return;
      function say(msg, color) { out.textContent = msg; out.style.color = color || '#a0a0ab'; }
      btn.addEventListener('click', function () {
        btn.disabled = true; say('Creating order...');
        fetch('/api/payments/start-test-payment', { method: 'POST', credentials: 'same-origin' })
          .then(function (r) { return r.json(); }).then(function (d) {
            if (!d.ok) { btn.disabled = false; say(d.error || 'Failed to start.', '#fca5a5'); return; }
            if (typeof Razorpay === 'undefined') { btn.disabled = false; say('Razorpay script failed to load.', '#fca5a5'); return; }
            var rzp = new Razorpay({
              key: d.keyId, amount: d.amountPaise, currency: d.currency,
              name: 'EduRankAI', description: 'Rs 1 integration test', order_id: d.orderId,
              prefill: d.prefill || {}, theme: { color: '#FF4F00' },
              handler: function (resp) {
                say('Verifying...');
                fetch('/api/payments/verify', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ razorpay_order_id: resp.razorpay_order_id, razorpay_payment_id: resp.razorpay_payment_id, razorpay_signature: resp.razorpay_signature }) })
                  .then(function (r) { return r.json(); }).then(function (c) {
                    btn.disabled = false;
                    if (c.ok && c.status === 'paid') say('Success - Rs 1 captured + verified. Check the finance dashboard + Razorpay webhook delivery.', '#6ee7b7');
                    else say('Verify returned: ' + JSON.stringify(c), '#fbbf24');
                  }).catch(function () { btn.disabled = false; say('Verify network error.', '#fca5a5'); });
              },
              modal: { ondismiss: function () { btn.disabled = false; say('Cancelled.', '#fbbf24'); } },
            });
            rzp.open();
          }).catch(function () { btn.disabled = false; say('Network error.', '#fca5a5'); });
      });
    })();
  </script>
</AdminLayout>
