---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { listConsumers, createConsumer, deleteConsumer } from '@/lib/lti';
import { LABS } from '@/data/labs-catalog';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role !== 'super_admin') return Astro.redirect('/admin');

let okMsg = '';
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('_action');
  try {
    if (action === 'create') { const c = await createConsumer((fd.get('name') as string) || 'Institution'); okMsg = 'Created key ' + c.key; }
    else if (action === 'delete') { await deleteConsumer(fd.get('key') as string); okMsg = 'Key revoked.'; }
  } catch (e: any) { okMsg = 'Error: ' + (e?.message || 'failed'); }
}
const consumers = await listConsumers();
const launchUrl = 'https://edurankai.in/api/lti/launch';
---
<AdminLayout title="LTI integrations" activeNav="">
  <div class="admin-page" style="max-width:900px;">
    <div class="admin-page-header"><div class="admin-page-title-block">
      <div class="admin-page-eyebrow">Virtual Labs · Institutions</div>
      <h1 class="admin-page-title">LTI 1.1 integrations</h1>
      <p class="admin-page-sub">Issue a consumer key/secret to an LMS (Canvas, Moodle, Blackboard) so it can launch any lab as an external tool and receive grades back. Super-admin only.</p>
    </div></div>

    {okMsg && <div style="margin:0 0 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:16px 18px;margin-bottom:18px;font-size:13px;color:#cfd6da;line-height:1.8;">
      <div style="font-weight:700;color:#fff;margin-bottom:6px;">How an institution adds a lab</div>
      <div>1 · Launch URL: <code style="color:#86efac;">{launchUrl}</code></div>
      <div>2 · Consumer key + secret: from the table below.</div>
      <div>3 · Custom parameter: <code style="color:#86efac;">lab=&lt;slug&gt;</code> — e.g. <code style="color:#86efac;">lab=quantum-lab</code>.</div>
      <div style="color:#8a8a94;font-size:12px;margin-top:4px;">Grades post back automatically when the lab calls completion (LTI Basic Outcomes). Slugs: {LABS.slice(0,6).map((l)=>l.slug).join(', ')}…</div>
    </div>

    <form method="POST" style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;">
      <input type="hidden" name="_action" value="create" />
      <input type="text" name="name" placeholder="Institution name" style="flex:1;min-width:220px;background:#0f0f14;border:1px solid #1a1a1f;border-radius:8px;padding:9px 12px;color:#fff;font-size:13px;outline:none;" />
      <button type="submit" style="background:#FF4F00;border:none;color:#fff;font-size:13px;font-weight:600;padding:9px 18px;border-radius:8px;cursor:pointer;">Issue key + secret</button>
    </form>

    {consumers.length === 0 ? (
      <div style="text-align:center;padding:36px;color:#6e6e78;font-size:13px;">No consumer keys yet. Issue one above.</div>
    ) : (
      <div style="display:flex;flex-direction:column;gap:8px;">
        {consumers.map((c: any) => (
          <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px 14px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
            <div style="flex:1;min-width:220px;">
              <p style="font-size:14px;font-weight:600;color:#fff;margin:0;">{c.name || 'Institution'}</p>
              <p style="font-size:11.5px;color:#8a8a94;margin:3px 0 0;font-family:'Geist Mono',monospace;">key <b style="color:#86efac;">{c.consumer_key}</b> · secret <b style="color:#cfd6da;">{c.secret}</b></p>
            </div>
            <form method="POST" onsubmit="return confirm('Revoke this key? The institution will lose access.');">
              <input type="hidden" name="_action" value="delete" /><input type="hidden" name="key" value={c.consumer_key} />
              <button type="submit" style="font-size:12px;color:#fca5a5;background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);padding:7px 12px;border-radius:7px;cursor:pointer;">Revoke</button>
            </form>
          </div>
        ))}
      </div>
    )}
  </div>
</AdminLayout>
