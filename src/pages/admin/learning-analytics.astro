---
// /admin/learning-analytics — anonymized platform learning analytics (Prompt 13, admin surface).
// Gated by can(audit, analytics). Aggregates real activity only; no PII, no synthetic metrics.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { platformAnalytics } from '@/lib/analytics';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'audit', { type: 'analytics' });
if (!gate.allow) return Astro.redirect('/admin');
const a = await platformAnalytics().catch(() => null);
const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
---
<AdminLayout title="Learning analytics" activeNav="learning-analytics">
  <div style="max-width:1000px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Analytics</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Platform learning analytics</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">Anonymized aggregates from real activity (progress, assessments). No fabricated numbers; students' own analytics live at /aquintutor/analytics.</p>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin:16px 0;">
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Active learners</p><p style="font-size:26px;font-weight:800;color:#fff;margin:4px 0 0;">{a?.learners || 0}</p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Lesson completion</p><p style="font-size:26px;font-weight:800;color:#fff;margin:4px 0 0;">{a?.completion.rate || 0}%</p><p style="font-size:10.5px;color:#8a8a94;margin:2px 0 0;">{a?.completion.completed || 0}/{a?.completion.opened || 0}</p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Official attempts</p><p style="font-size:26px;font-weight:800;color:#fff;margin:4px 0 0;">{a?.official.count || 0}</p><p style="font-size:10.5px;color:#8a8a94;margin:2px 0 0;">{a?.official.avgPct || 0}% avg · {a?.official.passRate || 0}% pass</p></div>
    </div>

    <div style={CARD}>
      <p style={HD}>Per-assessment performance (official)</p>
      {!a || a.perAssessment.length === 0 ? <p style="font-size:12px;color:#6e6e78;margin:0;">No official attempts yet.</p> :
      <div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:12.5px;">
        <thead><tr style="color:#8a8a94;font-size:9px;text-transform:uppercase;font-family:'Geist Mono',monospace;text-align:left;"><th style="padding:5px 8px;">Assessment</th><th style="padding:5px 8px;">Attempts</th><th style="padding:5px 8px;">Avg %</th><th style="padding:5px 8px;">Passes</th></tr></thead>
        <tbody>{a.perAssessment.map((r: any) => (
          <tr style="border-top:1px solid #15151a;"><td style="padding:6px 8px;color:#8a8a94;font-family:'Geist Mono',monospace;">{String(r.assessment_id).slice(0, 8)}</td><td style="padding:6px 8px;color:#cfd6da;">{r.attempts}</td><td style="padding:6px 8px;color:#cfd6da;">{r.avg_pct}%</td><td style="padding:6px 8px;color:#6ee7b7;">{r.passes}</td></tr>
        ))}</tbody>
      </table></div>}
    </div>
  </div>
</AdminLayout>
