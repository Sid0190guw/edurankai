---
// /admin/hardening — production-hardening ops view (Prompt AP7b). Live queue health + recent errors
// (redacted), plus the security posture (headers, secrets, authz, index/load-test docs). Superadmin.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { queueHealth } from '@/lib/job-queue';
import { recentErrors } from '@/lib/logger';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'administer', { type: 'platform' });
if (!gate.allow) return Astro.redirect('/admin');
const health = await queueHealth().catch(() => ({ pending: 0, processing: 0, failed: 0, done: 0 }));
const errors = await recentErrors(40).catch(() => []);
const headers = ['Strict-Transport-Security', 'X-Content-Type-Options: nosniff', 'X-Frame-Options: SAMEORIGIN', 'Referrer-Policy', 'Permissions-Policy', 'admin: no-store + noindex'];
const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
---
<AdminLayout title="Hardening" activeNav="hardening">
  <div style="max-width:920px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Ops · security</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Production hardening</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;">Live reliability + the security posture. The authz + secret audits run in CI (security-audit.test.ts); this view shows the runtime signals.</p>

    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-top:16px;">
      <div style={CARD + 'margin:0;'}>
        <p style={HD}>Security posture</p>
        <ul style="font-size:13px;color:#d6d6de;line-height:1.7;margin:0;padding-left:16px;">
          <li>Secrets: <b style="color:#6ee7b7;">clean</b> — no hardcoded keys (CI-enforced; env-only).</li>
          <li>Headers: <span style="font-family:'Geist Mono',monospace;font-size:11px;color:#9bd1ff;">{headers.join(' · ')}</span></li>
          <li>Authz: sensitive endpoints guarded (CI-asserted); errors sanitized (no stack/SQL leak).</li>
          <li>Docs (repo): <span style="font-family:'Geist Mono',monospace;font-size:11px;color:#9bd1ff;">docs/db-index-review.md · docs/load-test-plan.md · docs/huddle-sfu-followup.md</span></li>
        </ul>
      </div>
      <div style={CARD + 'margin:0;'}>
        <p style={HD}>Queue health</p>
        <div style="display:flex;gap:14px;flex-wrap:wrap;font-family:'Geist Mono',monospace;font-size:13px;">
          <span style="color:#c0a35e;">pending {health.pending}</span>
          <span style="color:#9bd1ff;">processing {health.processing}</span>
          <span style="color:#fca5a5;">failed {health.failed}</span>
          <span style="color:#6ee7b7;">done {health.done}</span>
        </div>
        <p style="font-size:12px;color:#8a8a94;margin:10px 0 0;">Worker + retries at <a href="/admin/jobs" style="color:#9bd1ff;">/admin/jobs</a>.</p>
      </div>
    </div>

    <div style={CARD}>
      <p style={HD}>Recent errors (redacted, {errors.length})</p>
      {errors.length ? (
        <table style="width:100%;border-collapse:collapse;font-size:12.5px;">
          <thead><tr style="text-align:left;color:#8a8a94;font-size:11px;text-transform:uppercase;"><th style="padding:6px 8px;">When</th><th style="padding:6px 8px;">Event</th><th style="padding:6px 8px;">Message</th></tr></thead>
          <tbody>
            {errors.map((e: any) => (
              <tr style="border-top:1px solid #1a1a1f;color:#d6d6de;">
                <td style="padding:6px 8px;font-family:'Geist Mono',monospace;font-size:11px;color:#8a8a94;">{new Date(e.created_at).toLocaleString()}</td>
                <td style="padding:6px 8px;color:#fca5a5;">{e.event}</td>
                <td style="padding:6px 8px;color:#8a8a94;max-width:360px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{e.message}</td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : <p style="font-size:12.5px;color:#8a8a94;margin:0;">No errors logged — clean.</p>}
    </div>
  </div>
</AdminLayout>
