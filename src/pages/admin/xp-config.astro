---
// /admin/xp-config — gamification XP config + auditable ledger (Prompt 15, admin surface). Gated by
// can(audit, gamification); editing values needs configure. Ledger is the integrity/audit view.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { getXpConfig, DEFAULT_XP, recentLedger, weeklyLeaderboard } from '@/lib/xp-ledger';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'audit', { type: 'gamification' });
if (!gate.allow) return Astro.redirect('/admin');
const canConfigure = (await can(user, 'configure', { type: 'gamification' })).allow;
const cfg = await getXpConfig().catch(() => ({ ...DEFAULT_XP }));
const ledger = await recentLedger(50).catch(() => []);
const weekly = await weeklyLeaderboard(10).catch(() => []);
const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const IN = 'background:#15151a;border:1px solid #26262c;color:#fff;padding:7px 9px;border-radius:6px;font-size:12px;width:90px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
function fmt(d: any) { try { return new Date(d).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); } catch { return '-'; } }
---
<AdminLayout title="Gamification" activeNav="xp-config">
  <div style="max-width:1000px;margin:0 auto;padding:24px;">
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0 0 4px;">Gamification &amp; XP</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:0 0 16px;">XP comes from a real, idempotent ledger — re-doing a lesson never double-awards. Student view: /aquintutor/xp.</p>
    <div id="msg" style="display:none;margin:0 0 12px;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style={CARD}>
      <p style={HD}>XP values</p>
      <div style="display:flex;gap:14px;flex-wrap:wrap;align-items:end;">{Object.keys(DEFAULT_XP).map((k) => (
        <div><label style="font-size:10px;color:#8a8a94;">{k}</label><br/><input class="xpVal" data-k={k} type="number" value={(cfg as any)[k]} disabled={!canConfigure} style={IN} /></div>
      ))}
        {canConfigure ? <button id="saveCfg" type="button" style="background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:700;padding:8px 14px;border-radius:6px;cursor:pointer;">Save</button> : null}
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 300px;gap:16px;" class="xp-grid">
      <div style={CARD}>
        <p style={HD}>Recent XP ledger (audit)</p>
        {ledger.length === 0 ? <p style="font-size:12px;color:#6e6e78;margin:0;">No XP awarded yet.</p> :
        <div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:12px;">
          <thead><tr style="color:#8a8a94;font-size:9px;text-transform:uppercase;font-family:'Geist Mono',monospace;text-align:left;"><th style="padding:5px 8px;">When</th><th style="padding:5px 8px;">User</th><th style="padding:5px 8px;">Action</th><th style="padding:5px 8px;">XP</th></tr></thead>
          <tbody>{ledger.map((l: any) => (<tr style="border-top:1px solid #15151a;"><td style="padding:5px 8px;color:#8a8a94;font-family:'Geist Mono',monospace;white-space:nowrap;">{fmt(l.at)}</td><td style="padding:5px 8px;color:#cfd6da;">{l.user_name || String(l.user_id).slice(0, 8)}</td><td style="padding:5px 8px;color:#8a8a94;">{l.action}</td><td style="padding:5px 8px;color:#6ee7b7;">+{l.xp}</td></tr>))}</tbody>
        </table></div>}
      </div>
      <div style={CARD}>
        <p style={HD}>This week</p>
        {weekly.length === 0 ? <p style="font-size:12px;color:#6e6e78;margin:0;">No weekly XP.</p> :
          <ol style="list-style:none;margin:0;padding:0;">{weekly.map((e: any, i: number) => <li style="display:flex;justify-content:space-between;padding:4px 0;font-size:12.5px;color:#cfd6da;"><span>{i + 1}. {e.name}</span><span style="color:#FF7040;">{e.xp}</span></li>)}</ol>}
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      var b = document.getElementById('saveCfg'); if (!b) return; var msg = document.getElementById('msg');
      b.addEventListener('click', function () {
        var values = {}; document.querySelectorAll('.xpVal').forEach(function (i) { values[i.getAttribute('data-k')] = parseInt(i.value, 10) || 0; });
        fetch('/api/admin/gamification', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ values: values }) })
          .then(function (r) { return r.json(); }).then(function (j) { msg.style.display = 'block'; msg.textContent = j.ok ? 'Saved.' : (j.error || 'Failed'); msg.style.background = j.ok ? 'rgba(16,185,129,0.12)' : 'rgba(239,68,68,0.12)'; msg.style.color = j.ok ? '#6ee7b7' : '#fca5a5'; });
      });
    })();
  </script>
  <style>@media (max-width:720px){ .xp-grid{ grid-template-columns:1fr !important; } }</style>
</AdminLayout>
