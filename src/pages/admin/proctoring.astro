---
// /admin/proctoring — ATLAS proctor review console + policy (Prompt 11, admin surface). Gated by
// can(audit, proctoring) = proctor / reviewer / superadmin. Shows real per-attempt event logs and
// an ADVISORY risk summary (never an auto-penalty — a human reviews and decides). Policy toggles
// which event types are recorded.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { proctoredAttempts, eventsForSession, getEnabledTypes, EVENT_TYPES } from '@/lib/proctor';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'audit', { type: 'proctoring' });
if (!gate.allow) return Astro.redirect('/admin');
const canConfigure = (await can(user, 'configure', { type: 'proctoring' })).allow;

const attempts = await proctoredAttempts(50).catch(() => []);
const enabled = await getEnabledTypes().catch(() => [...EVENT_TYPES]);
const sel = (Astro.url.searchParams.get('s') || '').trim();
const events = sel ? await eventsForSession(sel).catch(() => []) : [];

const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
const riskC: Record<string, string> = { low: '#6ee7b7', elevated: '#c0a35e', high: '#fca5a5' };
function fmt(ms: any) { try { return new Date(Number(ms)).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', hour: '2-digit', minute: '2-digit', second: '2-digit' }); } catch { return '-'; } }
---
<AdminLayout title="Proctoring" activeNav="proctoring">
  <div style="max-width:1080px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">ATLAS proctoring</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Proctor review</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">Text signals only — no video/audio/images ever leave a student's device. Risk is <b>advisory</b>: a human reviews and decides; nothing here penalizes a candidate automatically.</p>
    <div id="msg" style="display:none;margin:12px 0;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    {canConfigure ? (
      <div style={CARD}>
        <p style={HD}>Policy — recorded event types</p>
        <div style="display:flex;flex-wrap:wrap;gap:10px;">{EVENT_TYPES.map((t) => (
          <label style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#cfd6da;"><input type="checkbox" class="polType" value={t} checked={enabled.includes(t)} /> {t}</label>
        ))}</div>
        <button id="polSave" type="button" style="background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:700;padding:8px 14px;border-radius:6px;cursor:pointer;margin-top:10px;">Save policy</button>
      </div>
    ) : null}

    <div style="display:grid;grid-template-columns:340px 1fr;gap:16px;" class="proc-grid">
      <div style={CARD}>
        <p style={HD}>Proctored attempts ({attempts.length})</p>
        {attempts.length === 0 ? <p style="font-size:12px;color:#6e6e78;margin:0;">No proctored attempts yet.</p> :
          <div style="display:flex;flex-direction:column;gap:5px;">{attempts.map((a: any) => (
            <a href={'?s=' + encodeURIComponent(a.proctor_session_id)} style={'text-decoration:none;border-radius:8px;padding:8px 10px;border:1px solid #26262c;font-size:12px;' + (a.proctor_session_id === sel ? 'background:rgba(255,79,0,0.14);' : 'background:#08080a;')}>
              <div style="display:flex;justify-content:space-between;gap:6px;"><span style="color:#cfd6da;font-weight:600;">{a.user_name || 'student'}</span><span style={'font-family:Geist Mono,monospace;font-size:10px;font-weight:700;color:' + (riskC[a.risk.level] || '#8a8a94')}>{a.risk.level}</span></div>
              <div style="color:#8a8a94;font-size:10.5px;">{a.risk.total} signals · score {a.risk.score} · {a.pct}%</div>
            </a>
          ))}</div>}
      </div>
      <div style={CARD}>
        <p style={HD}>Event log</p>
        {!sel ? <p style="font-size:12.5px;color:#6e6e78;margin:0;">Select an attempt to review its signals.</p> :
          events.length === 0 ? <p style="font-size:12.5px;color:#6e6e78;margin:0;">No events recorded for this session.</p> :
          <div style="display:flex;flex-direction:column;gap:3px;font-family:'Geist Mono',monospace;font-size:11.5px;">{events.map((e: any) => (
            <div style="display:flex;justify-content:space-between;padding:4px 8px;border-bottom:1px solid #15151a;"><span style={'color:' + (e.type === 'face_present' ? '#6ee7b7' : e.type === 'multiple_faces' || e.type === 'paste' ? '#fca5a5' : '#c0a35e')}>{e.type}</span><span style="color:#8a8a94;">{fmt(e.at)}</span></div>
          ))}</div>}
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      var save = document.getElementById('polSave'); if (!save) return; var msg = document.getElementById('msg');
      save.addEventListener('click', function () {
        var types = Array.prototype.slice.call(document.querySelectorAll('.polType:checked')).map(function (c) { return c.value; });
        fetch('/api/admin/proctoring', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'setPolicy', enabledTypes: types }) })
          .then(function (r) { return r.json(); }).then(function (j) { msg.style.display = 'block'; msg.textContent = j.ok ? 'Saved.' : (j.error || 'Failed'); msg.style.background = j.ok ? 'rgba(16,185,129,0.12)' : 'rgba(239,68,68,0.12)'; msg.style.color = j.ok ? '#6ee7b7' : '#fca5a5'; });
      });
    })();
  </script>
  <style>@media (max-width:720px){ .proc-grid{ grid-template-columns:1fr !important; } }</style>
</AdminLayout>
