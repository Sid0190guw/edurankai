---
import '@/styles/global.css';
import '@/styles/admin.css';

if (Astro.locals.user) {
  return Astro.redirect('/admin');
}

let errorMessage = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const email = (formData.get('email') as string)?.trim().toLowerCase();
  const password = formData.get('password') as string;

  if (!email || !password) {
    errorMessage = 'Email/handle and password are required.';
  } else {
    const { db } = await import('@/lib/db');
    const { users } = await import('@/lib/db/schema');
    const { verifyPassword } = await import('@/lib/auth/password');
    const { generateSessionToken, createSession } = await import('@/lib/auth/session');
    const { setSessionCookie } = await import('@/lib/auth/cookie');
    const { eq } = await import('drizzle-orm');

    const found = await db.select().from(users).where(or(eq(users.email, email), eq(users.internalHandle, email))).limit(1);
    const user = found[0];

    if (!user || !user.isActive) {
      errorMessage = 'Invalid login or password.';
    } else {
      const valid = await verifyPassword(user.passwordHash, password);
      if (!valid) {
        errorMessage = 'Invalid login or password.';
      } else if (user.role === 'applicant') {
        errorMessage = 'This account does not have admin access.';
      } else {
        const token = generateSessionToken();
        const session = await createSession(token, user.id, {
          userAgent: Astro.request.headers.get('user-agent') || undefined,
          ipAddress: Astro.clientAddress
        });
        setSessionCookie(Astro.cookies, token, session.expiresAt);
        await db.update(users)
          .set({ lastLoginAt: new Date(), updatedAt: new Date() })
          .where(eq(users.id, user.id));
        return Astro.redirect('/admin');
      }
    }
  }
}
---
<!doctype html>
<html lang="en" class="admin-html">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign in - EduRankAI Admin</title>
    <meta name="robots" content="noindex,nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="admin-body" style="display:flex;align-items:center;justify-content:center;min-height:100vh;padding:24px;">
    <div style="width:100%;max-width:380px;">
      <div style="text-align:center;margin-bottom:28px;">
        <div style="display:inline-flex;align-items:center;gap:10px;color:#fff;text-decoration:none;font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:700;">
          <span style="width:38px;height:38px;border-radius:9px;background:linear-gradient(135deg,#FF4F00,#FF7040);display:inline-flex;align-items:center;justify-content:center;font-size:20px;">E</span>
          EduRank<span style="color:#FF4F00;">AI</span>
        </div>
        <p style="font-size:12px;color:#6e6e78;margin-top:8px;letter-spacing:0.08em;text-transform:uppercase;font-family:'Geist Mono',monospace;">Admin Panel</p>
      </div>

      <div style="background:#0e0e12;border:1px solid #1a1a20;border-radius:12px;padding:28px;">
        <h1 style="font-size:18px;font-weight:600;color:#fff;margin:0 0 6px;">Sign in</h1>
        <p style="font-size:12.5px;color:#8a8a94;margin:0 0 22px;">Use your EduRankAI admin credentials.</p>

        {errorMessage && (
          <div style="background:rgba(220,38,38,0.08);border:1px solid rgba(220,38,38,0.25);color:#fca5a5;font-size:12px;padding:10px 12px;border-radius:7px;margin-bottom:16px;">
            {errorMessage}
          </div>
        )}

        <form method="POST" style="display:flex;flex-direction:column;gap:14px;">
          <div>
            <label style="display:block;font-size:10.5px;font-weight:600;color:#8a8a94;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:6px;">Email</label>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              style="width:100%;padding:9px 12px;background:#08080a;border:1px solid #1f1f26;border-radius:6px;color:#fff;font-size:13px;font-family:inherit;outline:none;"
              placeholder="you@edurankai.in"
            />
          </div>
          <div>
            <label style="display:block;font-size:10.5px;font-weight:600;color:#8a8a94;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:6px;">Password</label>
            <input
              type="password"
              name="password"
              required
              autocomplete="current-password"
              style="width:100%;padding:9px 12px;background:#08080a;border:1px solid #1f1f26;border-radius:6px;color:#fff;font-size:13px;font-family:inherit;outline:none;"
              placeholder="••••••••"
            />
          </div>
          <button
            type="submit"
            style="width:100%;padding:10px;background:#FF4F00;color:#fff;border:none;border-radius:6px;font-size:13px;font-weight:600;cursor:pointer;margin-top:4px;"
          >
            Sign in
          </button>
        </form>

        <div style="text-align:center;margin-top:18px;padding-top:18px;border-top:1px solid #15151a;">
          <a href="/" style="font-size:11.5px;color:#6e6e78;text-decoration:none;">← Back to edurankai.in</a>
        </div>
      </div>
    </div>

    <script>
      const btn = document.getElementById('admin-pw-toggle');
      const inp = document.getElementById('admin-pw-input');
      if (btn && inp) {
        btn.addEventListener('click', () => {
          const isPw = inp.type === 'password';
          inp.type = isPw ? 'text' : 'password';
          btn.textContent = isPw ? 'Hide' : 'Show';
        });
      }
    </script>
  </body>
</html>
