---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { users } from '@/lib/db/schema';
import { eq } from 'drizzle-orm';
import { verifyPassword } from '@/lib/auth/password';
import { sql } from 'drizzle-orm';
import { generateSessionToken, createSession } from '@/lib/auth/session';
import { setSessionCookie } from '@/lib/auth/cookie';

async function startSession(userId: string, req: Request, ip: string | undefined, cookies: any) {
  const token = generateSessionToken();
  const session = await createSession(token, userId, {
    userAgent: req.headers.get('user-agent') || undefined,
    ipAddress: ip,
  });
  setSessionCookie(cookies, token, session.expiresAt);
}

// Authoritative server-side face match — the browser result is never trusted.
const FACE_2FA_THRESHOLD = 0.6;
function euclid(a: number[], b: number[]): number {
  let s = 0; const n = Math.min(a.length, b.length);
  for (let i = 0; i < n; i++) { const d = (a[i] || 0) - (b[i] || 0); s += d * d; }
  return Math.sqrt(s);
}
function normDesc(d: any): number[] | null {
  if (d == null) return null;
  if (typeof d === 'string') { try { return normDesc(JSON.parse(d)); } catch { return null; } }
  if (Array.isArray(d)) return d.map(Number);
  if (typeof d === 'object') return Object.keys(d).sort((a, b) => Number(a) - Number(b)).map((k) => Number(d[k]));
  return null;
}

// Already logged in?
if (Astro.locals.user) {
  return Astro.redirect('/admin');
}

let errorMsg = '';
let requireFace = false;
let pendingUserId = '';
let pendingUserName = '';
let faceDescriptor = '';

// Check if we're in face verification phase
const pendingId = Astro.cookies.get('face_pending_user')?.value || '';

if (pendingId) {
  requireFace = true;
  pendingUserId = pendingId;
  try {
    const u = await db.select({ name: users.name }).from(users).where(eq(users.id, pendingId)).limit(1);
    pendingUserName = u[0]?.name || '';
    const fd = await db.execute(sql`SELECT face_descriptor FROM user_face_enrollments WHERE user_id = ${pendingId} AND is_active = true LIMIT 1`);
    const rows = Array.isArray(fd) ? fd : (fd?.rows || []);
    faceDescriptor = rows.length > 0 ? JSON.stringify((rows[0] as any).face_descriptor) : '';
  } catch(e) {}
}

// Authenticator (TOTP) verification phase — password OK, awaiting the code.
const tfaPendingId = Astro.cookies.get('admin_tfa_pending')?.value || '';
let requireTotp = false;
let tfaPendingName = '';
if (tfaPendingId && !pendingId) {
  requireTotp = true;
  try {
    const u = await db.select({ name: users.name }).from(users).where(eq(users.id, tfaPendingId)).limit(1);
    tfaPendingName = u[0]?.name || '';
  } catch (e) {}
}

if (Astro.request.method === 'POST') {
  const fd2 = await Astro.request.formData();
  const action = fd2.get('action') as string;

  if (action === 'password_login') {
    const email = (fd2.get('email') as string || '').trim().toLowerCase();
    const password = (fd2.get('password') as string || '').trim();

    if (!email || !password) {
      errorMsg = 'Email and password required.';
    } else {
      try {
        const found = await db.select().from(users).where(eq(users.email, email)).limit(1);
        if (!found.length || !(await verifyPassword(found[0].passwordHash || '', password))) {
          errorMsg = 'Invalid email or password.';
        } else if (!found[0].isActive) {
          errorMsg = 'Account is inactive. Contact admin.';
        } else {
          const u = found[0];
          // Any one method signs you in — passkey / authenticator / face are
          // offered as independent options; a correct password is enough here.
          // Check if face enrolled
          const faceCheck = await db.execute(sql`SELECT id FROM user_face_enrollments WHERE user_id = ${u.id} AND is_active = true LIMIT 1`);
          const faceRows = Array.isArray(faceCheck) ? faceCheck : (faceCheck?.rows || []);

          if (faceRows.length > 0 && u.role !== 'applicant') {
            // Face enrolled - redirect to face verification
            Astro.cookies.set('face_pending_user', u.id, { path: '/', httpOnly: true, maxAge: 300, sameSite: 'lax' });
            return Astro.redirect('/admin/login');
          } else {
            // No face - log in directly via proper session token
            await startSession(u.id, Astro.request, Astro.clientAddress, Astro.cookies);
            Astro.cookies.delete('face_pending_user', { path: '/' });
            return Astro.redirect('/admin');
          }
        }
      } catch(e: any) {
        errorMsg = 'Login error: ' + e.message;
      }
    }
  } else if (action === 'face_verified') {
    // The browser does a live face scan, but the AUTHORITATIVE comparison is here:
    // we re-fetch the enrolled descriptor and match it server-side. A forged POST
    // with no/!matching descriptor cannot grant an admin session.
    const userId = fd2.get('user_id') as string;
    const liveRaw = (fd2.get('live_descriptor') as string) || '';
    if (userId === pendingId) {
      try {
        const fdRow = await db.execute(sql`SELECT face_descriptor FROM user_face_enrollments WHERE user_id = ${userId} AND is_active = true LIMIT 1`);
        const fdr = Array.isArray(fdRow) ? fdRow : (fdRow?.rows || []);
        const stored = normDesc((fdr[0] as any)?.face_descriptor);
        let live: number[] | null = null;
        try { live = normDesc(JSON.parse(liveRaw)); } catch { live = null; }
        const dist = (stored && live && stored.length === 128 && live.length === 128) ? euclid(stored, live) : 99;
        const matched = dist < FACE_2FA_THRESHOLD;
        await db.execute(sql`
          INSERT INTO identity_verifications (user_id, email, claimed_name, method, face_match_distance, face_match_passed, verdict, ip_address, user_agent)
          VALUES (${userId}, ${''}, ${pendingUserName || ''}, 'face_login', ${Number.isFinite(dist) ? dist : null}, ${matched}, ${matched ? 'verified' : 'rejected'}, ${(Astro.clientAddress || '').toString().slice(0, 64) || null}, ${(Astro.request.headers.get('user-agent') || '').slice(0, 500)})
        `).catch(() => {});
        if (!matched) {
          errorMsg = 'Face not recognised (distance ' + (Number.isFinite(dist) ? dist.toFixed(3) : 'n/a') + '). Try again, or use your password.';
        } else {
          await db.execute(sql`UPDATE user_face_enrollments SET last_used_at = NOW() WHERE user_id = ${userId}`).catch(() => {});
          await startSession(userId, Astro.request, Astro.clientAddress, Astro.cookies);
          Astro.cookies.delete('face_pending_user', { path: '/' });
          return Astro.redirect('/admin');
        }
      } catch (e: any) { errorMsg = 'Login error. Please try again.'; }
    } else {
      errorMsg = 'Session mismatch. Please try again.';
      Astro.cookies.delete('face_pending_user', { path: '/' });
      requireFace = false;
    }
  } else if (action === 'tfa_verify') {
    const userId = (fd2.get('user_id') as string) || '';
    const code = ((fd2.get('code') as string) || '').trim();
    if (!userId || userId !== tfaPendingId) {
      errorMsg = 'Session expired. Please sign in again.';
      Astro.cookies.delete('admin_tfa_pending', { path: '/' });
      requireTotp = false;
    } else {
      const { verifyLoginCode } = await import('@/lib/auth/twofactor');
      const ok = await verifyLoginCode(userId, code);
      if (!ok) {
        errorMsg = 'That code is not right. Use the current code from your authenticator app, or a backup code.';
      } else {
        await startSession(userId, Astro.request, Astro.clientAddress, Astro.cookies);
        Astro.cookies.delete('admin_tfa_pending', { path: '/' });
        return Astro.redirect('/admin');
      }
    }
  } else if (action === 'cancel_tfa') {
    Astro.cookies.delete('admin_tfa_pending', { path: '/' });
    return Astro.redirect('/admin/login');
  } else if (action === 'cancel_face') {
    Astro.cookies.delete('face_pending_user', { path: '/' });
    return Astro.redirect('/admin/login');
  }
}
---
<!doctype html>
<html lang="en" style="background:#08080a;">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Admin Login - EduRankAI</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #08080a; min-height: 100vh; display: flex; align-items: center; justify-content: center; font-family: system-ui, sans-serif; padding: 16px; }
    .card { background: #0f0f14; border: 1px solid #1a1a1f; border-radius: 16px; width: 100%; max-width: 400px; padding: 32px 24px; }
    .logo { font-size: 22px; font-weight: 800; color: #fff; margin-bottom: 24px; text-align: center; }
    .logo em { font-style: normal; color: #FF4F00; }
    .label { display: block; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #6e6e78; margin-bottom: 5px; }
    .input { width: 100%; background: #15151a; border: 1px solid #1a1a1f; border-radius: 8px; padding: 11px 14px; color: #fff; font-size: 14px; outline: none; transition: border-color 0.15s; }
    .input:focus { border-color: #FF4F00; }
    .btn { width: 100%; background: #FF4F00; border: none; color: #fff; font-weight: 700; font-size: 15px; padding: 13px; border-radius: 10px; cursor: pointer; transition: opacity 0.15s; }
    .btn:hover { opacity: 0.9; }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; border-radius: 8px; padding: 10px 14px; font-size: 13px; margin-bottom: 16px; }
    .field { margin-bottom: 14px; }
    .face-oval { width: 200px; height: 240px; border: 3px solid rgba(255,79,0,0.5); border-radius: 50%; margin: 0 auto 16px; position: relative; overflow: hidden; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">EduRank<em>AI</em></div>

    {errorMsg && <div class="error">{errorMsg}</div>}

    {requireTotp ? (
      <!-- Authenticator (TOTP) code -->
      <div>
        <p style="text-align:center;font-size:13px;color:#8a8a94;margin-bottom:4px;">Welcome back,</p>
        <p style="text-align:center;font-size:16px;font-weight:600;color:#fff;margin-bottom:18px;">{tfaPendingName}</p>
        <form method="POST">
          <input type="hidden" name="action" value="tfa_verify" />
          <input type="hidden" name="user_id" value={tfaPendingId} />
          <div class="field">
            <label class="label">6-digit code from your authenticator app</label>
            <input name="code" type="text" inputmode="numeric" autocomplete="one-time-code" maxlength="12" class="input" placeholder="123456" required autofocus style="text-align:center;letter-spacing:0.18em;font-size:18px;" />
          </div>
          <button type="submit" class="btn">Verify</button>
        </form>
        <p style="text-align:center;margin-top:12px;font-size:12px;color:#6e6e78;">Lost your phone? Enter a <strong style="color:#8a8a94;">backup code</strong> instead.</p>
        <form method="POST">
          <input type="hidden" name="action" value="cancel_tfa" />
          <button type="submit" style="width:100%;background:none;border:none;color:#6e6e78;font-size:12px;cursor:pointer;padding:8px;">Use different account</button>
        </form>
      </div>
    ) : !requireFace ? (
      <!-- Password login -->
      <form method="POST">
        <input type="hidden" name="action" value="password_login" />
        <div class="field">
          <label class="label">Email</label>
          <input name="email" type="email" class="input" placeholder="you@edurankai.in" required autofocus />
        </div>
        <div class="field">
          <label class="label">Password</label>
          <input name="password" type="password" class="input" placeholder="Password" required />
        </div>
        <button type="submit" class="btn">Sign In</button>
        <p style="text-align:center;margin-top:14px;font-size:12px;">
          <a href="/forgot-password" style="color:#FF7040;text-decoration:none;font-weight:600;">Forgot password?</a>
        </p>
        <p style="text-align:center;margin-top:8px;font-size:12px;color:#6e6e78;">
          Not an admin? <a href="/portal/login" style="color:#FF7040;text-decoration:none;">Applicant portal</a>
        </p>
      </form>
      <div style="margin-top:16px;">
        <div style="display:flex;align-items:center;gap:10px;color:#4a4a52;font-size:11px;margin-bottom:12px;"><span style="flex:1;height:1px;background:#1a1a1f;"></span>OR<span style="flex:1;height:1px;background:#1a1a1f;"></span></div>
        <button type="button" id="pkLoginBtn" style="width:100%;display:flex;align-items:center;justify-content:center;gap:8px;background:#15151a;border:1px solid #2a2a31;color:#fff;font-size:13px;font-weight:700;padding:11px;border-radius:8px;cursor:pointer;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M12 11c0-1.5-1-3-3-3M5 13a7 7 0 0 1 7-7 7 7 0 0 1 7 7M8 21c-1-2-1.5-4-1.5-6M12 13v3c0 2 .5 4 1.5 6M16 14c.3 2 .8 4 1.5 5"/></svg>
          Sign in with fingerprint / passkey
        </button>
        <p id="pkLoginErr" style="color:#ff6b6b;font-size:11px;text-align:center;margin:8px 0 0;min-height:1em;"></p>
        <div style="text-align:center;margin-top:6px;">
          <button type="button" id="totpToggle" style="background:transparent;border:none;color:#FF7040;font-size:12px;font-weight:600;cursor:pointer;text-decoration:underline;">Sign in with an authenticator code</button>
        </div>
        <div id="totpBox" style="display:none;margin-top:10px;">
          <input id="totpEmail" type="email" placeholder="you@edurankai.in" class="input" style="margin-bottom:8px;" />
          <input id="totpCode" inputmode="numeric" maxlength="12" placeholder="6-digit code" class="input" style="margin-bottom:8px;text-align:center;letter-spacing:0.15em;" />
          <button type="button" id="totpBtn" class="btn" style="font-size:13px;padding:10px;">Verify code</button>
          <p id="totpErr" style="color:#ff6b6b;font-size:11px;text-align:center;margin:8px 0 0;min-height:1em;"></p>
        </div>
      </div>
    ) : (
      <!-- Face verification -->
      <div>
        <p style="text-align:center;font-size:13px;color:#8a8a94;margin-bottom:4px;">Welcome back,</p>
        <p style="text-align:center;font-size:16px;font-weight:600;color:#fff;margin-bottom:20px;">{pendingUserName}</p>

        <div style="position:relative;background:#000;border-radius:16px;overflow:hidden;margin-bottom:16px;aspect-ratio:3/4;max-width:240px;margin-left:auto;margin-right:auto;">
          <video id="videoEl" autoplay playsinline muted style="width:100%;height:100%;object-fit:cover;transform:scaleX(-1);"></video>
          <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;">
            <div style="width:140px;height:180px;border:2px solid rgba(255,79,0,0.7);border-radius:50%;"></div>
          </div>
          <div id="faceStatus" style="position:absolute;bottom:10px;left:0;right:0;text-align:center;">
            <span style="background:rgba(0,0,0,0.75);color:#fff;font-size:11px;padding:3px 10px;border-radius:100px;">Loading...</span>
          </div>
        </div>

        <div id="loadingBar" style="background:#15151a;border-radius:100px;height:3px;margin-bottom:12px;">
          <div id="loadingProg" style="background:#FF4F00;height:100%;width:0%;border-radius:100px;transition:width 0.5s;"></div>
        </div>

        <button id="verifyBtn" disabled class="btn" style="opacity:0.5;margin-bottom:10px;">Verifying face...</button>

        <form method="POST" style="display:none;" id="successForm">
          <input type="hidden" name="action" value="face_verified" />
          <input type="hidden" name="user_id" value={pendingUserId} />
          <input type="hidden" name="live_descriptor" id="liveDescriptorField" value="" />
        </form>

        <form method="POST">
          <input type="hidden" name="action" value="cancel_face" />
          <button type="submit" style="width:100%;background:none;border:none;color:#6e6e78;font-size:12px;cursor:pointer;padding:8px;">Use different account</button>
        </form>
      </div>
    )}
  </div>

  {requireFace && faceDescriptor && (
    <script is:inline src="https://cdn.jsdelivr.net/npm/@vladmandic/face-api@1.7.13/dist/face-api.min.js"></script>
    <script is:inline define:vars={{ storedDescriptor: faceDescriptor }}>
    var video = document.getElementById('videoEl');
    var verifyBtn = document.getElementById('verifyBtn');
    var statusEl = document.getElementById('faceStatus');
    var loadingProg = document.getElementById('loadingProg');
    var successForm = document.getElementById('successForm');
    var verified = false;
    var lastLiveDescriptor = null;

    function setStatus(msg, color) {
      statusEl.innerHTML = '<span style="background:rgba(0,0,0,0.75);color:' + (color||'#fff') + ';font-size:11px;padding:3px 10px;border-radius:100px;">' + msg + '</span>';
    }

    async function init() {
      setStatus('Loading face model...', '#fff');
      loadingProg.style.width = '20%';

      var MODEL_URL = 'https://cdn.jsdelivr.net/npm/@vladmandic/face-api@latest/model';
      await Promise.all([
        faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL),
        faceapi.nets.faceLandmark68TinyNet.loadFromUri(MODEL_URL),
        faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL),
      ]);
      loadingProg.style.width = '60%';

      var stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' } });
      video.srcObject = stream;
      loadingProg.style.width = '100%';

      setTimeout(function() {
        loadingProg.style.display = 'none';
        verifyBtn.disabled = false;
        verifyBtn.style.opacity = '1';
        verifyBtn.textContent = 'Verify My Face';
        verifyBtn.onclick = doVerify;
        setStatus('Position face in oval', '#10b981');
        // Auto-verify loop
        autoVerify();
      }, 300);
    }

    var attempts = 0;
    async function autoVerify() {
      if (verified) return;
      if (attempts > 20) {
        setStatus('Auto-verify failed. Click verify.', '#fbbf24');
        return;
      }
      attempts++;
      try {
        var match = await tryMatch();
        if (match) {
          onVerified();
          return;
        }
      } catch(e) {}
      setTimeout(autoVerify, 800);
    }

    async function doVerify() {
      verifyBtn.disabled = true;
      verifyBtn.textContent = 'Verifying...';
      setStatus('Scanning face...', '#fbbf24');
      try {
        var match = await tryMatch();
        if (match) { onVerified(); }
        else {
          setStatus('Face not recognized. Try again.', '#ef4444');
          verifyBtn.disabled = false;
          verifyBtn.textContent = 'Try Again';
        }
      } catch(e) {
        setStatus('Error: ' + e.message, '#ef4444');
        verifyBtn.disabled = false;
        verifyBtn.textContent = 'Try Again';
      }
    }

    async function tryMatch() {
      var det = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions())
        .withFaceLandmarks(true).withFaceDescriptor();
      if (!det) return false;
      lastLiveDescriptor = det.descriptor;
      var stored = JSON.parse(storedDescriptor);
      var storedArr = Array.isArray(stored) ? stored : Object.values(stored);
      var storedFloat = new Float32Array(storedArr);
      var dist = faceapi.euclideanDistance(det.descriptor, storedFloat);
      return dist < 0.5; // threshold ' lower = stricter
    }

    function onVerified() {
      verified = true;
      setStatus('Face verified! Logging in...', '#10b981');
      verifyBtn.textContent = 'Verified!';
      verifyBtn.style.background = '#10b981';
      setTimeout(function() {
        try {
          var f = document.getElementById('liveDescriptorField');
          if (f && lastLiveDescriptor) f.value = JSON.stringify(Array.prototype.slice.call(lastLiveDescriptor));
        } catch (e) {}
        successForm.submit();
      }, 800);
    }

    init().catch(function(e) { setStatus('Camera error: ' + e.message, '#ef4444'); });
    </script>
  )}

  <script src="/webauthn-client.js" is:inline></script>
  <script is:inline>
    (function () {
      var pk = document.getElementById('pkLoginBtn'), pkErr = document.getElementById('pkLoginErr');
      if (pk) {
        if (!window.eraPasskeySupported) pk.style.display = 'none';
        pk.addEventListener('click', async function () {
          if (pkErr) pkErr.textContent = ''; pk.disabled = true; var t = pk.innerHTML; pk.textContent = 'Follow your device prompt…';
          try { var r = await window.eraPasskeyLogin(); location.href = r.redirect || '/admin'; }
          catch (e) { if (pkErr) pkErr.textContent = (e && e.message) || 'Could not sign in with passkey.'; pk.disabled = false; pk.innerHTML = t; }
        });
      }
      var tog = document.getElementById('totpToggle'), box = document.getElementById('totpBox');
      if (tog && box) tog.addEventListener('click', function () { box.style.display = (box.style.display === 'none' || !box.style.display) ? 'block' : 'none'; });
      var tb = document.getElementById('totpBtn'), te = document.getElementById('totpErr');
      if (tb) tb.addEventListener('click', async function () {
        if (te) te.textContent = '';
        var email = (document.getElementById('totpEmail').value || '').trim();
        var code = (document.getElementById('totpCode').value || '').trim();
        if (!email || !code) { if (te) te.textContent = 'Enter your email and code.'; return; }
        tb.disabled = true;
        var rr = await fetch('/api/auth/totp-login', { method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin', body: JSON.stringify({ email: email, code: code }) });
        var d = {}; try { d = await rr.json(); } catch (_) {}
        tb.disabled = false;
        if (d.ok) location.href = d.redirect || '/admin'; else if (te) te.textContent = d.error || 'Invalid email or code.';
      });
    })();
  </script>
</body>
</html>
