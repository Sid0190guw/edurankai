---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

let okMsg = '', errMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = (fd.get('action') as string) || '';
  try {
    if (action === 'school_create') {
      const slug = (fd.get('slug') as string || '').trim().toLowerCase().replace(/[^a-z0-9-]/g, '-');
      const code = (fd.get('code') as string || '').trim().toUpperCase().slice(0, 20) || null;
      const name = (fd.get('name') as string || '').trim();
      const tagline = (fd.get('tagline') as string || '').trim() || null;
      const order = parseInt(fd.get('display_order') as string || '99') || 99;
      if (!slug || !name) errMsg = 'Slug and name required.';
      else {
        await db.execute(sql`INSERT INTO schools (slug, code, name, tagline, display_order, is_published) VALUES (${slug}, ${code}, ${name}, ${tagline}, ${order}, true)`);
        okMsg = 'School "' + name + '" created.';
      }
    } else if (action === 'school_update') {
      const id = fd.get('id') as string;
      const code = (fd.get('code') as string || '').trim().toUpperCase().slice(0, 20) || null;
      const name = (fd.get('name') as string || '').trim();
      const tagline = (fd.get('tagline') as string || '').trim() || null;
      const description = (fd.get('description') as string || '').trim() || null;
      const order = parseInt(fd.get('display_order') as string || '99') || 99;
      await db.execute(sql`UPDATE schools SET code=${code}, name=${name}, tagline=${tagline}, description=${description}, display_order=${order}, updated_at=NOW() WHERE id=${id}`);
      okMsg = 'School updated.';
    } else if (action === 'school_toggle_publish') {
      const id = fd.get('id') as string;
      await db.execute(sql`UPDATE schools SET is_published = NOT is_published, updated_at = NOW() WHERE id = ${id}`);
      okMsg = 'Toggled.';
    } else if (action === 'school_delete') {
      const id = fd.get('id') as string;
      await db.execute(sql`DELETE FROM academic_departments WHERE school_id = ${id}`);
      await db.execute(sql`DELETE FROM schools WHERE id = ${id}`);
      okMsg = 'Deleted.';
    } else if (action === 'dept_create') {
      const schoolId = fd.get('school_id') as string;
      const slug = (fd.get('slug') as string || '').trim().toLowerCase().replace(/[^a-z0-9-]/g, '-');
      const name = (fd.get('name') as string || '').trim();
      const tagline = (fd.get('tagline') as string || '').trim() || null;
      const order = parseInt(fd.get('display_order') as string || '99') || 99;
      if (!slug || !name || !schoolId) errMsg = 'Slug + name + school required.';
      else {
        await db.execute(sql`INSERT INTO academic_departments (school_id, slug, name, tagline, display_order, is_published) VALUES (${schoolId}, ${slug}, ${name}, ${tagline}, ${order}, true)`);
        okMsg = 'Department added.';
      }
    } else if (action === 'dept_delete') {
      const id = fd.get('id') as string;
      await db.execute(sql`DELETE FROM academic_departments WHERE id = ${id}`);
      okMsg = 'Department deleted.';
    } else if (action === 'dept_toggle') {
      const id = fd.get('id') as string;
      await db.execute(sql`UPDATE academic_departments SET is_published = NOT is_published WHERE id = ${id}`);
      okMsg = 'Toggled.';
    }
  } catch (e: any) {
    errMsg = 'Error: ' + (e?.message || 'Unknown');
  }
}

let schools: any[] = [];
let deptsBySchool: Record<string, any[]> = {};
let courseCountBySchool: Record<string, number> = {};
try {
  const r = await db.execute(sql`SELECT id, slug, code, name, tagline, description, display_order, is_published FROM schools ORDER BY display_order ASC, name ASC`);
  schools = Array.isArray(r) ? r : (r?.rows || []);
} catch(_) {}
try {
  const r = await db.execute(sql`SELECT id, school_id, slug, name, tagline, display_order, is_published FROM academic_departments ORDER BY school_id, display_order ASC`);
  const rows = (Array.isArray(r) ? r : (r?.rows || [])) as any[];
  for (const d of rows) (deptsBySchool[d.school_id] = deptsBySchool[d.school_id] || []).push(d);
} catch(_) {}
try {
  const r = await db.execute(sql`SELECT school_id, COUNT(*)::int as n FROM training_courses WHERE school_id IS NOT NULL GROUP BY school_id`);
  const rows = (Array.isArray(r) ? r : (r?.rows || [])) as any[];
  for (const c of rows) courseCountBySchool[c.school_id] = c.n;
} catch(_) {}
---
<AdminLayout title="Schools & Departments" activeNav="schools">
  <div style="max-width:1280px;margin:0 auto;padding:24px;color:#f4f1ea;font-family:'Space Grotesk',system-ui,sans-serif;">

    <div style="margin-bottom:18px;">
      <p style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#d97757;margin:0 0 6px;font-weight:500;">AquinTutor &middot; Institution</p>
      <h1 style="font-family:'Instrument Serif',serif;font-size:clamp(28px,3vw,40px);font-weight:400;color:#f4f1ea;margin:0;">Schools &amp; departments</h1>
      <p style="font-size:13px;color:#c8c3b8;margin:8px 0 0;max-width:720px;line-height:1.55;">CRUD for the institutional structure. Each school groups departments; departments group courses. Courses inherit the academic identity for syllabus + the AI tutor's grounding context.</p>
    </div>

    {okMsg && <div style="background:rgba(125,211,168,0.12);border:1px solid rgba(125,211,168,0.3);color:#7dd3a8;padding:10px 14px;border-radius:8px;margin-bottom:14px;font-size:13px;">{okMsg}</div>}
    {errMsg && <div style="background:rgba(224,122,108,0.12);border:1px solid rgba(224,122,108,0.3);color:#e07a6c;padding:10px 14px;border-radius:8px;margin-bottom:14px;font-size:13px;">{errMsg}</div>}

    <!-- New school -->
    <details style="background:#14181d;border:1px solid #2a3038;border-radius:14px;padding:14px 18px;margin-bottom:18px;">
      <summary style="cursor:pointer;font-size:13px;font-weight:700;color:#f4f1ea;">+ Add new school</summary>
      <form method="POST" style="margin-top:14px;display:grid;grid-template-columns:80px 1fr 1fr 1fr 80px 120px;gap:8px;align-items:end;">
        <input type="hidden" name="action" value="school_create" />
        <div><label style="font-size:10px;color:#8a8579;text-transform:uppercase;font-family:'JetBrains Mono',monospace;">Code</label><input name="code" placeholder="SCR" style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:12.5px;outline:none;margin-top:4px;" /></div>
        <div><label style="font-size:10px;color:#8a8579;text-transform:uppercase;font-family:'JetBrains Mono',monospace;">Slug</label><input name="slug" required placeholder="computing-reasoning" style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:12.5px;outline:none;margin-top:4px;" /></div>
        <div><label style="font-size:10px;color:#8a8579;text-transform:uppercase;font-family:'JetBrains Mono',monospace;">Name</label><input name="name" required placeholder="School of Computing &amp; Reasoning" style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:12.5px;outline:none;margin-top:4px;" /></div>
        <div><label style="font-size:10px;color:#8a8579;text-transform:uppercase;font-family:'JetBrains Mono',monospace;">Tagline</label><input name="tagline" placeholder="Software, AI, systems..." style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:12.5px;outline:none;margin-top:4px;" /></div>
        <div><label style="font-size:10px;color:#8a8579;text-transform:uppercase;font-family:'JetBrains Mono',monospace;">Order</label><input name="display_order" type="number" value="99" style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:12.5px;outline:none;margin-top:4px;" /></div>
        <button type="submit" class="btn-atlas" style="height:34px;">+ Add</button>
      </form>
    </details>

    {schools.length === 0 && <div style="background:#14181d;border:1px solid #2a3038;border-radius:14px;padding:30px;text-align:center;color:#8a8579;font-size:13px;">No schools yet. Create one above to start.</div>}

    {schools.map((s: any) => {
      const depts = deptsBySchool[s.id] || [];
      const courseN = courseCountBySchool[s.id] || 0;
      return (
        <div style="background:#14181d;border:1px solid #2a3038;border-radius:14px;padding:18px 22px;margin-bottom:14px;">
          <details>
            <summary style="cursor:pointer;list-style:none;display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap;">
              <div style="min-width:0;flex:1;">
                <p style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#d97757;margin:0 0 4px;font-weight:500;">{s.code || 'SCHOOL'} &middot; {String(s.display_order || 0).padStart(2, '0')}</p>
                <h2 style="font-family:'Instrument Serif',serif;font-size:22px;font-weight:400;color:#f4f1ea;margin:0;">{s.name}</h2>
                <p style="font-size:12px;color:#c8c3b8;margin:4px 0 0;">{s.tagline}</p>
                <p style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#8a8579;margin:6px 0 0;">/aquintutor/schools/{s.slug} &middot; {depts.length} departments &middot; {courseN} courses</p>
              </div>
              <div style="display:flex;gap:6px;flex-wrap:wrap;">
                <form method="POST" style="display:inline;"><input type="hidden" name="action" value="school_toggle_publish" /><input type="hidden" name="id" value={s.id} />
                  <button type="submit" style={'background:' + (s.is_published ? '#7dd3a8' : '#1c2128') + ';color:' + (s.is_published ? '#1a0f08' : '#f4f1ea') + ';border:1px solid #2a3038;font-family:JetBrains Mono,monospace;font-size:10px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:5px 12px;border-radius:6px;cursor:pointer;'}>{s.is_published ? 'Published' : 'Draft'}</button>
                </form>
                <a href={'/aquintutor/schools/' + s.slug} target="_blank" class="btn-atlas ghost" style="font-size:11px;padding:5px 10px;">View</a>
                <form method="POST" style="display:inline;" onsubmit="return confirm('Delete this school and all its departments?')"><input type="hidden" name="action" value="school_delete" /><input type="hidden" name="id" value={s.id} />
                  <button type="submit" style="background:rgba(224,122,108,0.12);color:#e07a6c;border:1px solid rgba(224,122,108,0.3);font-family:JetBrains Mono,monospace;font-size:10px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:5px 12px;border-radius:6px;cursor:pointer;">Delete</button>
                </form>
              </div>
            </summary>

            <!-- Edit form -->
            <form method="POST" style="margin-top:14px;display:grid;grid-template-columns:80px 1fr 1fr 80px;gap:8px;align-items:end;">
              <input type="hidden" name="action" value="school_update" />
              <input type="hidden" name="id" value={s.id} />
              <div><label style="font-size:10px;color:#8a8579;font-family:JetBrains Mono,monospace;">Code</label><input name="code" value={s.code || ''} style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:7px 10px;border-radius:6px;font-size:12px;margin-top:3px;" /></div>
              <div><label style="font-size:10px;color:#8a8579;font-family:JetBrains Mono,monospace;">Name</label><input name="name" value={s.name} style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:7px 10px;border-radius:6px;font-size:12px;margin-top:3px;" /></div>
              <div><label style="font-size:10px;color:#8a8579;font-family:JetBrains Mono,monospace;">Tagline</label><input name="tagline" value={s.tagline || ''} style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:7px 10px;border-radius:6px;font-size:12px;margin-top:3px;" /></div>
              <div><label style="font-size:10px;color:#8a8579;font-family:JetBrains Mono,monospace;">Order</label><input name="display_order" type="number" value={s.display_order || 99} style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:7px 10px;border-radius:6px;font-size:12px;margin-top:3px;" /></div>
              <div style="grid-column:span 4;">
                <label style="font-size:10px;color:#8a8579;font-family:JetBrains Mono,monospace;">Description (longer)</label>
                <textarea name="description" rows="2" style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:12px;margin-top:3px;resize:vertical;font-family:inherit;">{s.description || ''}</textarea>
              </div>
              <div style="grid-column:span 4;"><button type="submit" class="btn-atlas">Save school</button></div>
            </form>

            <!-- Departments -->
            <div style="margin-top:18px;border-top:1px solid #2a3038;padding-top:14px;">
              <p style="font-family:JetBrains Mono,monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;margin:0 0 10px;font-weight:600;">Departments ({depts.length})</p>
              {depts.length === 0 && <p style="font-size:12px;color:#8a8579;font-style:italic;margin:0 0 10px;">No departments yet.</p>}
              {depts.map((d: any) => (
                <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;background:#1c2128;border:1px solid #2a3038;border-radius:10px;padding:8px 12px;margin-bottom:6px;">
                  <div style="min-width:0;flex:1;">
                    <p style="font-size:13px;font-weight:600;color:#f4f1ea;margin:0;">{d.name}</p>
                    <p style="font-size:11px;color:#8a8579;margin:2px 0 0;font-family:JetBrains Mono,monospace;">/{d.slug} &middot; {d.tagline}</p>
                  </div>
                  <div style="display:flex;gap:4px;">
                    <form method="POST" style="display:inline;"><input type="hidden" name="action" value="dept_toggle" /><input type="hidden" name="id" value={d.id} />
                      <button type="submit" style={'background:' + (d.is_published ? '#7dd3a8' : '#1c2128') + ';color:' + (d.is_published ? '#1a0f08' : '#f4f1ea') + ';border:1px solid #2a3038;font-size:10px;font-weight:600;padding:3px 8px;border-radius:5px;cursor:pointer;'}>{d.is_published ? 'On' : 'Off'}</button>
                    </form>
                    <form method="POST" style="display:inline;" onsubmit="return confirm('Delete department?')"><input type="hidden" name="action" value="dept_delete" /><input type="hidden" name="id" value={d.id} />
                      <button type="submit" style="background:rgba(224,122,108,0.12);color:#e07a6c;border:1px solid rgba(224,122,108,0.3);font-size:10px;font-weight:600;padding:3px 8px;border-radius:5px;cursor:pointer;">X</button>
                    </form>
                  </div>
                </div>
              ))}

              <form method="POST" style="display:grid;grid-template-columns:1fr 1fr 1fr 80px 90px;gap:6px;margin-top:8px;align-items:end;">
                <input type="hidden" name="action" value="dept_create" />
                <input type="hidden" name="school_id" value={s.id} />
                <input name="slug" required placeholder="department-slug" style="background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:7px 10px;border-radius:6px;font-size:12px;" />
                <input name="name" required placeholder="Department name" style="background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:7px 10px;border-radius:6px;font-size:12px;" />
                <input name="tagline" placeholder="Tagline" style="background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:7px 10px;border-radius:6px;font-size:12px;" />
                <input name="display_order" type="number" value={depts.length + 1} style="background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:7px 10px;border-radius:6px;font-size:12px;" />
                <button type="submit" class="btn-atlas" style="font-size:11px;padding:7px 10px;">+ Dept</button>
              </form>
            </div>
          </details>
        </div>
      );
    })}
  </div>
</AdminLayout>
