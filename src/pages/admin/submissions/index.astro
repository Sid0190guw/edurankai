---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { listSubmissions, reviewSubmission, SUBMISSION_KIND_LABELS } from '@/lib/submissions';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

let successMsg = '', errorMsg = '';

if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const subId = (fd.get('submission_id') as string || '').trim();
    const verdict = (fd.get('verdict') as string || 'comment') as any;
    const notes = (fd.get('notes') as string || '').trim().slice(0, 5000);
    const scoreRaw = parseFloat(fd.get('score_pct') as string || '');
    const scorePct = isFinite(scoreRaw) && scoreRaw >= 0 ? scoreRaw : undefined;
    if (!subId || !notes) errorMsg = 'Submission ID + notes required.';
    else {
      await reviewSubmission({ submissionId: subId, reviewerUserId: user.id, reviewerName: user.name || user.email, verdict, notes, scorePct });
      successMsg = 'Review recorded.';
    }
  } catch (e: any) { errorMsg = String(e?.message || e).slice(0, 300); }
}

const url = new URL(Astro.request.url);
const status = url.searchParams.get('status') || '';
const kind = url.searchParams.get('kind') || '';
const q = url.searchParams.get('q') || '';
const subs = await listSubmissions({ status: status || undefined, kind: kind || undefined, q, limit: 200 });

function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' }); } catch { return ''; } }

const STATUS_OPTIONS = [
  { val: '', label: 'All statuses' },
  { val: 'submitted', label: 'Submitted (new)' },
  { val: 'under_review', label: 'Under review' },
  { val: 'approved', label: 'Approved' },
  { val: 'revisions_requested', label: 'Revisions requested' },
  { val: 'rejected', label: 'Not selected' },
];
---
<AdminLayout title="Submissions inbox" activeNav="">
<div style="padding:14px 16px 80px;max-width:1280px;margin:0 auto;">
  <p style="font-size:10.5px;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;font-family:'Geist Mono',monospace;font-weight:700;">Portal</p>
  <h1 style="font-size:24px;color:#fff;margin:6px 0 4px;font-weight:700;">Submissions inbox</h1>
  <p style="font-size:13px;color:#9aa6b6;margin:0 0 18px;">Original work submitted by applicants, Campus Ambassadors, interns and employees. Review, score, approve.</p>

  {successMsg && <div style="background:rgba(74,222,128,0.10);border:1px solid rgba(74,222,128,0.32);color:#86efac;border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;">{successMsg}</div>}
  {errorMsg && <div style="background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.32);color:#fca5a5;border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;">{errorMsg}</div>}

  <form method="GET" style="display:flex;gap:8px;margin-bottom:16px;align-items:center;flex-wrap:wrap;">
    <input name="q" value={q} type="text" placeholder="Search title, name, email..." style="flex:1;min-width:220px;background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;" />
    <select name="status" style="background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12.5px;">
      {STATUS_OPTIONS.map(o => <option value={o.val} selected={o.val === status}>{o.label}</option>)}
    </select>
    <select name="kind" style="background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12.5px;">
      <option value="">All kinds</option>
      {Object.entries(SUBMISSION_KIND_LABELS).map(([k, v]) => <option value={k} selected={k === kind}>{v.label}</option>)}
    </select>
    <button type="submit" style="background:#15151a;border:1px solid #2a2a2f;color:#FF7040;padding:9px 16px;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer;">Filter</button>
  </form>

  <p style="font-size:11.5px;color:#8a8a94;margin:0 0 12px;font-family:'Geist Mono',monospace;letter-spacing:0.06em;">{subs.length} submission(s)</p>

  {subs.length === 0 ? (
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:48px;text-align:center;color:#6e6e78;font-size:13px;">No submissions match this filter.</div>
  ) : (
    <div style="display:flex;flex-direction:column;gap:10px;">
      {subs.map((s: any) => {
        const kindMeta = SUBMISSION_KIND_LABELS[s.kind] || SUBMISSION_KIND_LABELS.other;
        return (
          <details style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:0;">
            <summary style="padding:14px 18px;cursor:pointer;list-style:none;">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap;">
                <div style="flex:1;min-width:0;">
                  <div style="display:flex;gap:8px;align-items:center;margin-bottom:4px;flex-wrap:wrap;">
                    <span style={`background:${kindMeta.accent}22;color:${kindMeta.accent};font-size:10px;font-weight:700;padding:3px 9px;border-radius:100px;font-family:'Geist Mono',monospace;letter-spacing:0.06em;text-transform:uppercase;`}>{kindMeta.label}</span>
                    <span style="background:rgba(255,255,255,0.06);color:#9aa6b6;font-size:10px;font-weight:700;padding:3px 9px;border-radius:100px;font-family:'Geist Mono',monospace;letter-spacing:0.06em;text-transform:uppercase;">{s.submitter_role.replace(/_/g,' ')}</span>
                    <span style="font-size:10.5px;color:#FF7040;font-weight:700;font-family:'Geist Mono',monospace;letter-spacing:0.06em;text-transform:uppercase;">{s.status.replace(/_/g,' ')}</span>
                  </div>
                  <h3 style="font-size:15px;color:#fff;margin:0 0 4px;font-weight:700;line-height:1.3;">{s.title}</h3>
                  <p style="font-size:11.5px;color:#9aa6b6;margin:0;font-family:'Geist Mono',monospace;">{s.submitter_name} · {s.submitter_email || '—'} · {fmt(s.submitted_at)}</p>
                </div>
                {s.score_pct != null && <p style="font-size:18px;color:#FF7040;font-weight:800;margin:0;font-family:'Geist Mono',monospace;">{Number(s.score_pct).toFixed(1)}%</p>}
              </div>
            </summary>
            <div style="padding:0 18px 18px;border-top:1px solid #1a1a1f;">
              {s.description && (
                <div style="margin:14px 0;">
                  <p style="font-size:10.5px;color:#9aa6b6;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;margin:0 0 6px;">Description</p>
                  <p style="font-size:13px;color:#d8d8de;margin:0;line-height:1.65;white-space:pre-wrap;">{s.description}</p>
                </div>
              )}
              <div style="display:flex;gap:14px;flex-wrap:wrap;margin:12px 0;">
                {s.drive_url && <a href={s.drive_url} target="_blank" style="background:#15151a;border:1px solid #2a2a2f;color:#67e8f9;padding:8px 14px;border-radius:6px;font-size:11.5px;text-decoration:none;font-family:'Geist Mono',monospace;font-weight:700;">Open Drive →</a>}
                {s.external_url && <a href={s.external_url} target="_blank" style="background:#15151a;border:1px solid #2a2a2f;color:#86efac;padding:8px 14px;border-radius:6px;font-size:11.5px;text-decoration:none;font-family:'Geist Mono',monospace;font-weight:700;">Open {s.platform} →</a>}
                {s.target_role_slug && <a href={'/admin/roles/' + s.target_role_slug} style="background:#15151a;border:1px solid #2a2a2f;color:#fbbf24;padding:8px 14px;border-radius:6px;font-size:11.5px;text-decoration:none;font-family:'Geist Mono',monospace;font-weight:700;">Role: {s.target_role_slug} →</a>}
                {s.word_count && <span style="background:#15151a;border:1px solid #2a2a2f;color:#9aa6b6;padding:8px 14px;border-radius:6px;font-size:11.5px;font-family:'Geist Mono',monospace;">{s.word_count} words</span>}
              </div>
              <form method="POST" style="margin-top:14px;padding-top:14px;border-top:1px solid #1a1a1f;display:grid;gap:10px;">
                <input type="hidden" name="submission_id" value={s.id} />
                <p style="font-size:11px;color:#FF7040;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;margin:0;">Record review</p>
                <textarea name="notes" rows="3" required maxlength="5000" placeholder="Specific written feedback on the submission..." style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;font-family:'Inter Tight',sans-serif;resize:vertical;line-height:1.55;"></textarea>
                <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
                  <select name="verdict" required style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 12px;border-radius:6px;font-size:12px;">
                    <option value="comment">Comment only</option>
                    <option value="request_revisions">Request revisions</option>
                    <option value="approve">Approve</option>
                    <option value="reject">Not selected</option>
                  </select>
                  <input name="score_pct" type="number" min="0" max="100" step="0.1" placeholder="Score % (optional)" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 12px;border-radius:6px;font-size:12px;width:160px;" />
                  <button type="submit" style="background:#FF4F00;color:#fff;border:none;padding:8px 18px;border-radius:6px;font-size:12px;font-weight:800;cursor:pointer;letter-spacing:0.04em;text-transform:uppercase;font-family:'Geist Mono',monospace;">Save review</button>
                </div>
              </form>
            </div>
          </details>
        );
      })}
    </div>
  )}
</div>
</AdminLayout>
