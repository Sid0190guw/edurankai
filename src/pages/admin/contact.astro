---
import AdminLayout from '@/layouts/AdminLayout.astro';
import postgres from 'postgres';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const databaseUrl = import.meta.env.DATABASE_URL || process.env.DATABASE_URL;
const sql = postgres(databaseUrl, { max: 1 });

let errorMsg = '';
let successMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  const id = (fd.get('id') as string || '').trim();

  try {
    if (action === 'mark_handled' && id) {
      await sql`UPDATE contact_submissions SET status = 'handled', handled_by_user_id = ${user.id}, handled_at = NOW() WHERE id = ${id};`;
      successMsg = 'Marked as handled';
    } else if (action === 'mark_new' && id) {
      await sql`UPDATE contact_submissions SET status = 'new', handled_by_user_id = NULL, handled_at = NULL WHERE id = ${id};`;
      successMsg = 'Reopened';
    } else if (action === 'delete' && id) {
      await sql`DELETE FROM contact_submissions WHERE id = ${id};`;
      successMsg = 'Deleted';
    }
  } catch (err: any) {
    errorMsg = 'Failed: ' + (err.message || 'Unknown error');
  }
}

const url = new URL(Astro.request.url);
const filter = url.searchParams.get('filter') || 'new';

let submissions: any[] = [];
if (filter === 'all') {
  submissions = await sql`SELECT * FROM contact_submissions ORDER BY created_at DESC LIMIT 200;`;
} else if (filter === 'handled') {
  submissions = await sql`SELECT * FROM contact_submissions WHERE status = 'handled' ORDER BY created_at DESC LIMIT 200;`;
} else {
  submissions = await sql`SELECT * FROM contact_submissions WHERE status = 'new' ORDER BY created_at DESC LIMIT 200;`;
}

const counts = await sql`SELECT status, COUNT(*) as c FROM contact_submissions GROUP BY status;`;
const countMap: Record<string, number> = {};
let total = 0;
counts.forEach((r: any) => { countMap[r.status] = parseInt(r.c); total += parseInt(r.c); });

await sql.end();

const CATEGORY_LABELS: Record<string, string> = {
  hiring: 'Hiring',
  partnership: 'Partnership',
  press: 'Press',
  product: 'Product',
  general: 'General'
};

function formatDateTime(d: any): string {
  if (!d) return '';
  return new Date(d).toLocaleString('en-IN', { day: 'numeric', month: 'short', year: 'numeric', hour: 'numeric', minute: '2-digit' });
}
---
<AdminLayout title="Contact Inbox" description="Review and reply to contact submissions.">

  <div class="mb-6">
    <h1 class="font-display text-[1.8rem] font-semibold text-white mb-1">Contact Inbox</h1>
    <p class="text-[0.85rem] text-white/60">{total} total submissions</p>
  </div>

  {errorMsg && <div class="bg-red-500/10 border border-red-500/30 text-red-300 rounded-lg p-3 mb-4 text-[0.85rem]">{errorMsg}</div>}
  {successMsg && <div class="bg-leaf-bg/20 border border-leaf-border/50 text-leaf rounded-lg p-3 mb-4 text-[0.85rem]">{successMsg}</div>}

  <div class="flex flex-wrap gap-2 mb-6">
    <a href="/admin/contact?filter=new" class={'inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[0.78rem] font-medium border ' + (filter === 'new' ? 'bg-burn border-burn text-white' : 'bg-white/5 border-white/10 text-white/70 hover:border-white/25')}>
      <span>New</span>
      <span class={'text-[0.72rem] font-mono ' + (filter === 'new' ? 'text-white/80' : 'text-white/40')}>{countMap['new'] || 0}</span>
    </a>
    <a href="/admin/contact?filter=handled" class={'inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[0.78rem] font-medium border ' + (filter === 'handled' ? 'bg-burn border-burn text-white' : 'bg-white/5 border-white/10 text-white/70 hover:border-white/25')}>
      <span>Handled</span>
      <span class={'text-[0.72rem] font-mono ' + (filter === 'handled' ? 'text-white/80' : 'text-white/40')}>{countMap['handled'] || 0}</span>
    </a>
    <a href="/admin/contact?filter=all" class={'inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[0.78rem] font-medium border ' + (filter === 'all' ? 'bg-burn border-burn text-white' : 'bg-white/5 border-white/10 text-white/70 hover:border-white/25')}>
      <span>All</span>
      <span class={'text-[0.72rem] font-mono ' + (filter === 'all' ? 'text-white/80' : 'text-white/40')}>{total}</span>
    </a>
  </div>

  {submissions.length === 0 ? (
    <div class="bg-white/5 border border-white/10 rounded-2xl p-10 text-center">
      <p class="text-[0.95rem] text-white/70 mb-1">No submissions in this view.</p>
    </div>
  ) : (
    <div class="flex flex-col gap-3">
      {submissions.map((s) => {
        const isHandled = s.status === 'handled';
        const subject = s.subject || (s.message ? s.message.substring(0, 60) + '...' : 'No subject');
        const catLabel = s.category ? CATEGORY_LABELS[s.category] || s.category : null;
        return (
          <div class={'border rounded-xl p-4 ' + (isHandled ? 'bg-white/3 border-white/10' : 'bg-white/5 border-white/15')}>
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2 mb-2">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1 flex-wrap">
                  <p class={'font-semibold text-[0.95rem] ' + (isHandled ? 'text-white/60' : 'text-white')}>
                    {s.name || 'Anonymous'}
                  </p>
                  <span class="text-[0.78rem] text-white/40">-</span>
                  <a href={'mailto:' + s.email + (s.subject ? '?subject=Re:%20' + encodeURIComponent(s.subject) : '')} class="text-[0.78rem] text-burn hover:underline">{s.email}</a>
                  {catLabel && <span class="text-[0.65rem] font-bold uppercase tracking-wider bg-sky-bg/20 text-sky border border-sky-border/40 px-2 py-0.5 rounded-full">{catLabel}</span>}
                  {isHandled && <span class="text-[0.65rem] font-bold uppercase tracking-wider bg-leaf-bg/20 text-leaf border border-leaf-border/40 px-2 py-0.5 rounded-full">Handled</span>}
                </div>
                <p class={'font-display text-[1rem] ' + (isHandled ? 'text-white/55' : 'text-white/90')}>{subject}</p>
              </div>
              <p class="text-[0.72rem] font-mono text-white/40 shrink-0">{formatDateTime(s.created_at)}</p>
            </div>

            <div class="bg-white/5 rounded-lg p-3 mb-3 max-h-[200px] overflow-y-auto">
              <p class="text-[0.85rem] text-white/80 whitespace-pre-wrap leading-relaxed">{s.message}</p>
            </div>

            <div class="flex flex-wrap gap-2 items-center text-[0.72rem] font-mono">
              <a href={'mailto:' + s.email + (s.subject ? '?subject=Re:%20' + encodeURIComponent(s.subject) : '')} class="text-burn hover:underline">Reply via email</a>
              <span class="text-white/20">-</span>
              {!isHandled && (
                <form method="POST" class="inline">
                  <input type="hidden" name="action" value="mark_handled" />
                  <input type="hidden" name="id" value={s.id} />
                  <button type="submit" class="text-leaf hover:underline">Mark handled</button>
                </form>
              )}
              {isHandled && (
                <form method="POST" class="inline">
                  <input type="hidden" name="action" value="mark_new" />
                  <input type="hidden" name="id" value={s.id} />
                  <button type="submit" class="text-white/60 hover:text-white">Reopen</button>
                </form>
              )}
              <span class="text-white/20">-</span>
              <form method="POST" class="inline" onsubmit="return confirm('Delete this submission permanently?');">
                <input type="hidden" name="action" value="delete" />
                <input type="hidden" name="id" value={s.id} />
                <button type="submit" class="text-red-400 hover:text-red-300">Delete</button>
              </form>
            </div>
          </div>
        );
      })}
    </div>
  )}

</AdminLayout>
