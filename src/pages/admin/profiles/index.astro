---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { listApplicantProfiles, setProfilePublic, deleteApplicantProfile, getApplicantProfile } from '@/lib/applicant-profile';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
// Full control of applicant profiles is a super-admin capability.
if (user.role !== 'super_admin') return Astro.redirect('/admin');

let okMsg = '';
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('_action');
  const targetId = fd.get('userId') as string;
  try {
    if (action === 'toggle_public' && targetId) {
      const makePublic = fd.get('makePublic') === '1';
      const p = await getApplicantProfile(targetId);
      const c = (p?.common || {}) as any;
      const name = ((c.firstName || '') + ' ' + (c.lastName || '')).trim() || 'member';
      await setProfilePublic(targetId, makePublic, name);
      okMsg = makePublic ? 'Profile published.' : 'Profile set to private.';
    } else if (action === 'delete' && targetId) {
      await deleteApplicantProfile(targetId);
      okMsg = 'Profile deleted.';
    }
  } catch (_) {}
}

const url = new URL(Astro.request.url);
const q = (url.searchParams.get('q') || '').trim();
const profiles = await listApplicantProfiles(q);
const publicCount = profiles.filter((p) => p.is_public).length;
---
<AdminLayout title="Applicant Profiles" activeNav="profiles">
  <div class="admin-page" style="max-width:1100px;">
    <div class="admin-page-header">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">People</div>
        <h1 class="admin-page-title">Applicant Profiles</h1>
        <p class="admin-page-sub">Full control over every applicant's profile — edit content, publish/unpublish, or remove. {profiles.length} profiles · {publicCount} public.</p>
      </div>
    </div>

    {okMsg && <div style="margin:0 0 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

    <form method="GET" style="display:flex;gap:8px;margin-bottom:16px;max-width:460px;">
      <input type="text" name="q" value={q} placeholder="Search name, email, headline..." style="flex:1;background:#0f0f14;border:1px solid #1a1a1f;border-radius:8px;padding:9px 12px;color:#fff;font-size:13px;outline:none;" />
      <button type="submit" style="background:#FF4F00;border:none;color:#fff;font-size:13px;font-weight:600;padding:9px 16px;border-radius:8px;cursor:pointer;">Search</button>
      {q && <a href="/admin/profiles" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;font-size:13px;text-decoration:none;padding:9px 14px;border-radius:8px;display:inline-flex;align-items:center;">Clear</a>}
    </form>

    {profiles.length === 0 ? (
      <div style="text-align:center;padding:48px;color:#6e6e78;font-size:13px;">No profiles yet. They are created as applicants fill in application step 1.</div>
    ) : (
      <div style="display:flex;flex-direction:column;gap:8px;">
        {profiles.map((p) => {
          const name = ((p.first_name || '') + ' ' + (p.last_name || '')).trim() || '(no name)';
          return (
            <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px 16px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;">
              <div style="flex:1;min-width:200px;">
                <p style="font-size:14px;font-weight:600;color:#fff;margin:0;">{name}
                  {p.is_public
                    ? <span style="font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#10b981;background:rgba(16,185,129,0.12);padding:2px 8px;border-radius:100px;margin-left:8px;">Public</span>
                    : <span style="font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#6e6e78;background:rgba(110,110,120,0.12);padding:2px 8px;border-radius:100px;margin-left:8px;">Private</span>}
                </p>
                <p style="font-size:12px;color:#8a8a94;margin:3px 0 0;">{p.email}{p.headline ? ' · ' + p.headline : ''}</p>
              </div>
              <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
                {p.is_public && p.slug && (
                  <a href={'/profile/' + p.slug} target="_blank" rel="noopener" style="font-size:12px;color:#60a5fa;text-decoration:none;padding:7px 10px;border:1px solid #1a1a1f;border-radius:7px;">View</a>
                )}
                <a href={'/admin/profiles/' + p.user_id} style="font-size:12px;color:#FF7040;text-decoration:none;padding:7px 12px;border:1px solid #1a1a1f;border-radius:7px;font-weight:600;">Edit</a>
                <form method="POST" style="display:inline;">
                  <input type="hidden" name="_action" value="toggle_public" />
                  <input type="hidden" name="userId" value={p.user_id} />
                  <input type="hidden" name="makePublic" value={p.is_public ? '0' : '1'} />
                  <button type="submit" style="font-size:12px;color:#d8d8de;background:#15151a;border:1px solid #1a1a1f;padding:7px 12px;border-radius:7px;cursor:pointer;">{p.is_public ? 'Unpublish' : 'Publish'}</button>
                </form>
                <form method="POST" style="display:inline;" onsubmit="return confirm('Delete this profile permanently?');">
                  <input type="hidden" name="_action" value="delete" />
                  <input type="hidden" name="userId" value={p.user_id} />
                  <button type="submit" style="font-size:12px;color:#fca5a5;background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);padding:7px 12px;border-radius:7px;cursor:pointer;">Delete</button>
                </form>
              </div>
            </div>
          );
        })}
      </div>
    )}
  </div>
</AdminLayout>
