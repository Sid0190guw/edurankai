---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { getApplicantProfile, updateProfile, setProfilePublic } from '@/lib/applicant-profile';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role !== 'super_admin') return Astro.redirect('/admin');

const { userId } = Astro.params;
if (!userId) return Astro.redirect('/admin/profiles');

let okMsg = '';
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('_action');
  try {
    if (action === 'toggle_public') {
      const makePublic = fd.get('makePublic') === '1';
      const p = await getApplicantProfile(userId);
      const c = (p?.common || {}) as any;
      const name = ((c.firstName || '') + ' ' + (c.lastName || '')).trim() || 'member';
      await setProfilePublic(userId, makePublic, name);
      okMsg = 'Visibility updated.';
    } else if (action === 'save') {
      const existing = await getApplicantProfile(userId);
      const prevCommon = (existing?.common || {}) as any;
      const common = {
        ...prevCommon,
        firstName: (fd.get('firstName') as string || '').trim(),
        lastName: (fd.get('lastName') as string || '').trim(),
        currentCity: (fd.get('currentCity') as string || '').trim(),
        phone: (fd.get('phone') as string || '').trim(),
        photoUrl: (fd.get('photoUrl') as string || '').trim(),
      };
      const skills = (fd.get('skills') as string || '').split(',').map((s) => s.trim()).filter(Boolean).slice(0, 40);
      const links = {
        linkedin: (fd.get('linkedin') as string || '').trim(),
        github: (fd.get('github') as string || '').trim(),
        portfolio: (fd.get('portfolio') as string || '').trim(),
        twitter: (fd.get('twitter') as string || '').trim(),
      };
      const parseJson = (v: any) => { try { const a = JSON.parse(String(v || '[]')); return Array.isArray(a) ? a.slice(0, 30) : []; } catch { return []; } };
      await updateProfile(userId, {
        headline: (fd.get('headline') as string || '').trim().slice(0, 160),
        bio: (fd.get('bio') as string || '').trim().slice(0, 4000),
        skills, links,
        experience: parseJson(fd.get('experienceJson')),
        education: parseJson(fd.get('educationJson')),
        common,
      });
      okMsg = 'Saved.';
    }
  } catch (_) { okMsg = 'Error saving.'; }
}

const profile = await getApplicantProfile(userId);
if (!profile) return Astro.redirect('/admin/profiles');
const c = (profile.common || {}) as any;
const links = (profile.links || {}) as any;
const skills: string[] = Array.isArray(profile.skills) ? profile.skills : [];
const experience: any[] = Array.isArray(profile.experience) ? profile.experience : [];
const education: any[] = Array.isArray(profile.education) ? profile.education : [];
const isPublic = !!profile.is_public;
const name = ((c.firstName || '') + ' ' + (c.lastName || '')).trim() || profile.email || 'Profile';
---
<AdminLayout title={'Edit profile - ' + name} activeNav="profiles">
  <div class="admin-page" style="max-width:820px;">
    <div class="admin-page-header">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow"><a href="/admin/profiles" style="color:#6e6e78;text-decoration:none;">← Profiles</a></div>
        <h1 class="admin-page-title">{name}</h1>
        <p class="admin-page-sub">{profile.email}</p>
      </div>
    </div>

    {okMsg && <div style="margin:0 0 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px 16px;margin-bottom:16px;display:flex;align-items:center;justify-content:space-between;gap:12px;">
      <div>
        <p style="font-size:13px;font-weight:600;color:#fff;margin:0;">Public visibility</p>
        <p style="font-size:12px;color:#8a8a94;margin:2px 0 0;">{isPublic && profile.slug ? '/profile/' + profile.slug : 'Currently private'}</p>
      </div>
      <form method="POST"><input type="hidden" name="_action" value="toggle_public" /><input type="hidden" name="makePublic" value={isPublic ? '0' : '1'} />
        <button type="submit" style={'font-size:12px;font-weight:600;padding:8px 16px;border-radius:8px;cursor:pointer;border:1px solid #1a1a1f;' + (isPublic ? 'background:#15151a;color:#fca5a5;' : 'background:#FF4F00;color:#fff;border-color:#FF4F00;')}>{isPublic ? 'Unpublish' : 'Publish'}</button>
      </form>
    </div>

    <form method="POST" id="apForm">
      <input type="hidden" name="_action" value="save" />
      <div class="ap-card">
        <p class="ap-h">Identity</p>
        <div class="ap-grid">
          <div><label class="ap-l">First name</label><input name="firstName" value={c.firstName || ''} class="ap-i" /></div>
          <div><label class="ap-l">Last name</label><input name="lastName" value={c.lastName || ''} class="ap-i" /></div>
          <div><label class="ap-l">City</label><input name="currentCity" value={c.currentCity || ''} class="ap-i" /></div>
          <div><label class="ap-l">Phone</label><input name="phone" value={c.phone || ''} class="ap-i" /></div>
          <div style="grid-column:1/-1;"><label class="ap-l">Photo URL</label><input name="photoUrl" value={c.photoUrl || ''} class="ap-i" /></div>
          <div style="grid-column:1/-1;"><label class="ap-l">Headline</label><input name="headline" value={profile.headline || ''} maxlength="160" class="ap-i" /></div>
        </div>
      </div>
      <div class="ap-card"><p class="ap-h">About</p><textarea name="bio" rows="5" maxlength="4000" class="ap-i" style="resize:vertical;">{profile.bio || ''}</textarea></div>
      <div class="ap-card">
        <p class="ap-h">Skills &amp; links</p>
        <div style="margin-bottom:10px;"><label class="ap-l">Skills (comma-separated)</label><input name="skills" value={skills.join(', ')} class="ap-i" /></div>
        <div class="ap-grid">
          <div><label class="ap-l">LinkedIn</label><input name="linkedin" value={links.linkedin || ''} class="ap-i" /></div>
          <div><label class="ap-l">GitHub</label><input name="github" value={links.github || ''} class="ap-i" /></div>
          <div><label class="ap-l">Portfolio</label><input name="portfolio" value={links.portfolio || ''} class="ap-i" /></div>
          <div><label class="ap-l">Twitter</label><input name="twitter" value={links.twitter || ''} class="ap-i" /></div>
        </div>
      </div>
      <div class="ap-card">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;"><p class="ap-h" style="margin:0;">Experience</p><button type="button" data-add="exp" style="font-size:12px;color:#FF7040;background:none;border:none;cursor:pointer;font-weight:600;">+ Add</button></div>
        <div id="expList" style="display:flex;flex-direction:column;gap:8px;"></div>
        <input type="hidden" name="experienceJson" id="experienceJson" />
      </div>
      <div class="ap-card">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;"><p class="ap-h" style="margin:0;">Education</p><button type="button" data-add="edu" style="font-size:12px;color:#FF7040;background:none;border:none;cursor:pointer;font-weight:600;">+ Add</button></div>
        <div id="eduList" style="display:flex;flex-direction:column;gap:8px;"></div>
        <input type="hidden" name="educationJson" id="educationJson" />
      </div>
      <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:700;font-size:14px;padding:13px;border-radius:10px;cursor:pointer;">Save profile</button>
    </form>
  </div>

  <style>
    .ap-card { background:#0f0f14; border:1px solid #1a1a1f; border-radius:12px; padding:16px; margin-bottom:14px; }
    .ap-h { font-size:14px; font-weight:600; color:#fff; margin:0 0 12px; }
    .ap-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
    .ap-l { display:block; font-size:10px; text-transform:uppercase; letter-spacing:0.08em; color:#8a8a94; font-weight:700; margin-bottom:4px; }
    .ap-i { width:100%; background:#08080a; border:1px solid #1a1a1f; border-radius:8px; padding:9px 11px; color:#fff; font-size:13px; outline:none; }
    .ap-i:focus { border-color:#FF4F00; }
    .ap-row input { width:100%; background:#08080a; border:1px solid #1a1a1f; border-radius:7px; padding:8px 10px; color:#fff; font-size:12.5px; outline:none; }
  </style>

  <script is:inline define:vars={{ initExp: experience, initEdu: education }}>
    (function () {
      function row(kind, item) {
        item = item || {};
        var wrap = document.createElement('div');
        wrap.className = 'ap-row';
        wrap.style.cssText = 'display:grid;grid-template-columns:1fr 1fr;gap:6px;border:1px solid #1a1a1f;border-radius:9px;padding:10px;';
        var fields = kind === 'exp'
          ? [['title','Role / title'],['org','Organisation'],['period','Period'],['detail','What you did']]
          : [['school','School'],['degree','Degree / field'],['period','Period'],['detail','Notes']];
        fields.forEach(function (f) {
          var inp = document.createElement('input');
          inp.setAttribute('data-k', f[0]); inp.placeholder = f[1]; inp.value = item[f[0]] || '';
          if (f[0] === 'detail') inp.style.gridColumn = '1/-1';
          wrap.appendChild(inp);
        });
        var del = document.createElement('button');
        del.type = 'button'; del.textContent = 'Remove';
        del.style.cssText = 'grid-column:1/-1;text-align:right;font-size:11px;color:#8a8a94;background:none;border:none;cursor:pointer;';
        del.addEventListener('click', function () { wrap.remove(); });
        wrap.appendChild(del);
        return wrap;
      }
      function mount(kind, id, init) { var l = document.getElementById(id); (init || []).forEach(function (it) { l.appendChild(row(kind, it)); }); }
      mount('exp', 'expList', initExp); mount('edu', 'eduList', initEdu);
      document.querySelectorAll('[data-add]').forEach(function (b) { b.addEventListener('click', function () { var k = b.getAttribute('data-add'); document.getElementById(k === 'exp' ? 'expList' : 'eduList').appendChild(row(k, {})); }); });
      function ser(id) { var out = []; document.querySelectorAll('#' + id + ' .ap-row').forEach(function (r) { var o = {}, any = false; r.querySelectorAll('input[data-k]').forEach(function (i) { var v = (i.value || '').trim(); o[i.getAttribute('data-k')] = v; if (v) any = true; }); if (any) out.push(o); }); return JSON.stringify(out); }
      var f = document.getElementById('apForm');
      if (f) f.addEventListener('submit', function () { document.getElementById('experienceJson').value = ser('expList'); document.getElementById('educationJson').value = ser('eduList'); });
    })();
  </script>
</AdminLayout>
