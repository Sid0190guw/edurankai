---
// /admin/vod — VOD management (Prompt AP1b, admin surface). Faculty publish/unpublish recordings and
// see the library; storage-provisioning status is shown honestly. Gated: can(write AnimationObject).
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { vodService } from '@/lib/vod';
import { storageProvisioned } from '@/lib/storage';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'write', { type: 'AnimationObject' });
if (!gate.allow) return Astro.redirect('/admin');
const list = await vodService().list(false).catch(() => []);
const provisioned = storageProvisioned();
const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
function mins(ms: number) { const s = Math.round(ms / 1000); return Math.floor(s / 60) + 'm ' + (s % 60) + 's'; }
---
<AdminLayout title="Recordings & VOD" activeNav="vod">
  <div style="max-width:900px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Recordings</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Recordings &amp; VOD</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">A recording stores the ordered animation SPEC timeline (+ optional media), so replays re-render at each viewer's tier — never a flat video. Access is gated by securityLabels.</p>
    <div id="msg" style="display:none;margin:12px 0;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style={CARD}>
      <p style={HD}>Media storage</p>
      <p style={'font-size:13px;margin:0;color:' + (provisioned ? '#6ee7b7' : '#fca5a5') + ';'}>{provisioned ? 'Object storage provisioned (Vercel Blob) — audio/video media is stored.' : 'No media store provisioned — recordings capture the SPEC timeline only (still fully replayable). Set BLOB_READ_WRITE_TOKEN to store media.'}</p>
    </div>

    <div style={CARD}>
      <p style={HD}>Recordings ({list.length})</p>
      {list.length ? (
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead><tr style="text-align:left;color:#8a8a94;font-size:11px;text-transform:uppercase;"><th style="padding:6px 8px;">Title</th><th style="padding:6px 8px;">Length</th><th style="padding:6px 8px;">Labels</th><th style="padding:6px 8px;">Status</th><th style="padding:6px 8px;"></th></tr></thead>
          <tbody>
            {list.map((v: any) => (
              <tr style="border-top:1px solid #1a1a1f;color:#d6d6de;">
                <td style="padding:8px;"><a href={'/aquintutor/vod/' + v.id} style="color:#9bd1ff;text-decoration:none;">{v.title}</a></td>
                <td style="padding:8px;font-family:'Geist Mono',monospace;font-size:11px;color:#8a8a94;">{mins(v.durationMs)}</td>
                <td style="padding:8px;font-family:'Geist Mono',monospace;font-size:11px;color:#c0a35e;">{(v.labels || []).join(', ') || 'public'}</td>
                <td style="padding:8px;">{v.published ? <span style="color:#6ee7b7;">published</span> : <span style="color:#8a8a94;">draft</span>}</td>
                <td style="padding:8px;"><button class="pubBtn" data-id={v.id} data-on={v.published ? '0' : '1'} style="background:#1c2230;color:#9bd1ff;border:1px solid #26324a;border-radius:7px;padding:5px 11px;font-size:12px;cursor:pointer;">{v.published ? 'Unpublish' : 'Publish'}</button></td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : <p style="font-size:12.5px;color:#8a8a94;margin:0;">No recordings yet. Faculty save a broadcast from /aquintutor/broadcast.</p>}
    </div>
  </div>

  <script is:inline>
    document.querySelectorAll('.pubBtn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var id = btn.getAttribute('data-id'), on = btn.getAttribute('data-on') === '1', msg = document.getElementById('msg');
        fetch('/api/aquintutor/vod', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'publish', id: id, on: on }) })
          .then(function (r) { return r.json(); }).then(function (j) { msg.style.display = 'block'; if (j.ok) { msg.style.background = '#0f2a1c'; msg.style.color = '#6ee7b7'; msg.textContent = on ? 'Published. Reloading…' : 'Unpublished. Reloading…'; setTimeout(function () { location.reload(); }, 700); } else { msg.style.background = '#2a0f0f'; msg.style.color = '#fca5a5'; msg.textContent = j.error || 'Failed'; } });
      });
    });
  </script>
</AdminLayout>
