---
// /admin/admissions — registrar admissions console (Prompt 16, admin surface). Gated by
// can(manage, admission). Queue, transcripts + interview scores, and record a decision with reasons.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { listApplications, getApplication, canDecide } from '@/lib/admissions';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'manage', { type: 'admission' });
if (!gate.allow) return Astro.redirect('/admin');
const apps = await listApplications(undefined, 100).catch(() => []);
const sel = (Astro.url.searchParams.get('a') || '').trim();
const app = sel ? await getApplication(sel).catch(() => null) : null;
const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const IN = 'background:#15151a;border:1px solid #26262c;color:#fff;padding:7px 9px;border-radius:6px;font-size:12px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
const sc: Record<string, string> = { accepted: '#6ee7b7', waitlisted: '#c0a35e', rejected: '#fca5a5', interviewed: '#5ea0c0', submitted: '#8a8a94' };
---
<AdminLayout title="Admissions" activeNav="admissions">
  <div style="max-width:1080px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Registrar</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Admissions</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">Interview scores are an aid, not the decision. Accepting an applicant makes them enrolment-eligible.</p>
    <div id="msg" style="display:none;margin:12px 0;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style="display:grid;grid-template-columns:340px 1fr;gap:16px;" class="adm-grid">
      <div style={CARD}>
        <p style={HD}>Queue ({apps.length})</p>
        {apps.length === 0 ? <p style="font-size:12px;color:#6e6e78;margin:0;">No applications yet.</p> :
          <div style="display:flex;flex-direction:column;gap:4px;">{apps.map((a: any) => (
            <a href={'?a=' + a.id} style={'text-decoration:none;border-radius:8px;padding:8px 10px;border:1px solid #26262c;font-size:12px;' + (a.id === sel ? 'background:rgba(255,79,0,0.14);' : 'background:#08080a;')}>
              <div style="display:flex;justify-content:space-between;gap:6px;"><span style="color:#cfd6da;font-weight:600;">{a.applicant || 'applicant'}</span><span style={'font-family:Geist Mono,monospace;font-size:10px;color:' + (sc[a.status] || '#8a8a94')}>{a.status}</span></div>
              <div style="color:#8a8a94;font-size:10.5px;">{a.program}{a.score != null ? ' · ' + a.score + '/100' : ''}</div>
            </a>
          ))}</div>}
      </div>

      <div style={CARD}>
        {!app ? <p style="font-size:12.5px;color:#6e6e78;margin:0;">Select an application.</p> : (
          <div>
            <h2 style="font-family:'Inter Tight',sans-serif;font-size:16px;color:#fff;margin:0 0 2px;">{app.applicant} <span style="color:#8a8a94;font-size:12px;">{app.email}</span></h2>
            <p style="font-size:12.5px;color:#8a8a94;margin:0 0 12px;">{app.program} · status <span style={'color:' + (sc[app.status] || '#8a8a94')}>{app.status}</span>{app.score != null ? ' · interview ' + app.score + '/100' : ''}</p>
            {app.profile?.background ? <div style="background:#08080a;border:1px solid #26262c;border-radius:8px;padding:10px 12px;margin-bottom:12px;font-size:12.5px;color:#cfd6da;">{app.profile.background}</div> : null}
            {(app.transcript || []).map((t: any) => (
              <div style="margin-bottom:10px;"><p style="font-size:12px;color:#8a8a94;margin:0 0 2px;">{t.q}</p><p style="font-size:12.5px;color:#cfd6da;margin:0;background:#08080a;border:1px solid #15151a;border-radius:6px;padding:7px 9px;">{t.a || '—'}</p></div>
            ))}
            {canDecide(app.status) ? (
              <div style="margin-top:14px;border-top:1px solid #15151a;padding-top:12px;">
                <p style={HD}>Record decision</p>
                <textarea id="reason" rows="2" placeholder="Reasons (shown to the applicant)" style={IN + 'width:100%;box-sizing:border-box;margin-bottom:8px;'}></textarea>
                <div style="display:flex;gap:6px;flex-wrap:wrap;">
                  <button class="dec" data-d="accepted" data-id={app.id} type="button" style="background:#0f2f22;border:1px solid #1f5f42;color:#6ee7b7;font-size:11px;font-weight:700;padding:7px 13px;border-radius:6px;cursor:pointer;">Accept</button>
                  <button class="dec" data-d="waitlisted" data-id={app.id} type="button" style="background:#2a2410;border:1px solid #5f5320;color:#c0a35e;font-size:11px;font-weight:700;padding:7px 13px;border-radius:6px;cursor:pointer;">Waitlist</button>
                  <button class="dec" data-d="rejected" data-id={app.id} type="button" style="background:#2a1414;border:1px solid #5f2f2f;color:#fca5a5;font-size:11px;font-weight:700;padding:7px 13px;border-radius:6px;cursor:pointer;">Reject</button>
                </div>
              </div>
            ) : <p style="font-size:12px;color:#8a8a94;margin-top:12px;">Decided: {app.decision_reason || '—'}</p>}
          </div>
        )}
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      var msg = document.getElementById('msg');
      document.querySelectorAll('.dec').forEach(function (b) { b.addEventListener('click', function () {
        var reason = (document.getElementById('reason') || {}).value || '';
        fetch('/api/admin/admissions', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ appId: b.getAttribute('data-id'), decision: b.getAttribute('data-d'), reason: reason }) })
          .then(function (r) { return r.json(); }).then(function (j) { msg.style.display = 'block'; msg.textContent = j.ok ? 'Decision recorded.' : (j.error || 'Failed'); msg.style.background = j.ok ? 'rgba(16,185,129,0.12)' : 'rgba(239,68,68,0.12)'; msg.style.color = j.ok ? '#6ee7b7' : '#fca5a5'; if (j.ok) setTimeout(function () { location.reload(); }, 600); });
      }); });
    })();
  </script>
  <style>@media (max-width:720px){ .adm-grid{ grid-template-columns:1fr !important; } }</style>
</AdminLayout>
