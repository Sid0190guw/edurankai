---
import AdminLayout from '@/layouts/AdminLayout.astro';
import MailClient from '@/components/MailClient.astro';
import { transportStatus } from '@/lib/mail-transport';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const transport = await transportStatus();
const isSuperAdmin = user.role === 'super_admin';
---
<AdminLayout title="Mail" activeNav="mail">
  {transport.mode === 'none' && (
    <div style="background:rgba(251,191,36,0.10);border-bottom:1px solid rgba(251,191,36,0.25);padding:8px 16px;font-size:11.5px;color:#fbbf24;display:flex;justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap;">
      <span>Internal mail works now. External send/receive is not configured yet.</span>
      {isSuperAdmin && <a href="/admin/mail/settings" style="color:#fbbf24;font-weight:700;text-decoration:underline;white-space:nowrap;">Connect your mail server &rarr;</a>}
    </div>
  )}
  {transport.mode !== 'none' && isSuperAdmin && (
    <div style="background:rgba(16,185,129,0.08);border-bottom:1px solid rgba(16,185,129,0.2);padding:7px 16px;font-size:11.5px;color:#6ee7b7;display:flex;justify-content:space-between;gap:10px;align-items:center;">
      <span>External mail via {transport.detail}.</span>
      <a href="/admin/mail/settings" style="color:#6ee7b7;text-decoration:underline;white-space:nowrap;">Mail settings &rarr;</a>
    </div>
  )}
  <MailClient user={user} basePath="/admin/mail" />
</AdminLayout>

<style is:global>
  .admin-body:has(.mailc) .admin-main, .admin-main:has(.mailc){ padding:0 !important; }
  .admin-html .mailc{ height:100dvh; }
</style>
