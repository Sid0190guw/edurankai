---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const url = new URL(Astro.request.url);
const tab = url.searchParams.get('tab') || 'compose';

// Load sent email logs if table exists
let sentEmails: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT * FROM email_logs ORDER BY created_at DESC LIMIT 50
  `);
  sentEmails = (r?.rows || []) as any[];
} catch(e) {
  // Table doesn't exist yet - that's fine
}

function timeAgo(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins + 'm ago';
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return hrs + 'h ago';
  return Math.floor(hrs / 24) + 'd ago';
}
---
<AdminLayout title="Mail" activeNav="mail">
<div style="padding-bottom:80px;">

  <!-- Header -->
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="margin-bottom:12px;">
      <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">Communication</p>
      <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Mail</h1>
    </div>
    <div style="display:flex;gap:4px;">
      {[['compose','Compose'],['sent','Sent'],['settings','SMTP Settings']].map(([t,l]) => (
        <a href={`?tab=${t}`} style={`text-decoration:none;font-size:12px;font-weight:600;padding:6px 12px;border-radius:6px;${tab === t ? 'background:#FF4F00;color:#fff;' : 'background:#15151a;color:#8a8a94;'}`}>{l}</a>
      ))}
    </div>
  </div>

  <!-- COMPOSE TAB -->
  {tab === 'compose' && (
    <div style="padding:16px;">
      <!-- SMTP warning banner -->
      <div style="background:rgba(251,191,36,0.08);border:1px solid rgba(251,191,36,0.2);border-radius:12px;padding:14px;margin-bottom:16px;">
        <div style="display:flex;align-items:flex-start;gap:10px;">
          <span style="font-size:20px;flex-shrink:0;">🔧</span>
          <div>
            <p style="font-size:13px;font-weight:600;color:#fbbf24;margin:0 0 4px;">SMTP Not Configured</p>
            <p style="font-size:12px;color:#8a8a94;margin:0 0 8px;">Mail sending requires a self-hosted SMTP server. You're building this on Ubuntu VPS with Postfix — full data sovereignty, unlimited emails.</p>
            <div style="display:flex;flex-direction:column;gap:4px;">
              <p style="font-size:11px;color:#6e6e78;margin:0;">Step 1: Get Ubuntu VPS (Hetzner CX22, ~Rs 380/mo)</p>
              <p style="font-size:11px;color:#6e6e78;margin:0;">Step 2: Install Postfix + configure for edurankai.in</p>
              <p style="font-size:11px;color:#6e6e78;margin:0;">Step 3: Add SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS to Vercel</p>
              <p style="font-size:11px;color:#6e6e78;margin:0;">Step 4: Come back here and send unlimited emails</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Compose form (disabled until SMTP ready) -->
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:16px;opacity:0.6;">
        <p style="font-size:13px;font-weight:600;color:#fff;margin:0 0 14px;">Compose Email</p>
        <div style="display:flex;flex-direction:column;gap:10px;">
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">To</label>
            <input disabled placeholder="recipient@example.com" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#6e6e78;font-size:13px;outline:none;cursor:not-allowed;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Subject</label>
            <input disabled placeholder="Email subject" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#6e6e78;font-size:13px;outline:none;cursor:not-allowed;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Message</label>
            <textarea disabled rows="6" placeholder="Type your message..." style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#6e6e78;font-size:13px;outline:none;resize:vertical;cursor:not-allowed;"></textarea>
          </div>
          <button disabled style="width:100%;background:#1a1a1f;border:none;color:#6e6e78;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:not-allowed;">
            Send Email (SMTP required)
          </button>
        </div>
      </div>

      <!-- Templates preview -->
      <div style="margin-top:16px;">
        <p style="font-size:13px;font-weight:600;color:#fff;margin:0 0 10px;">Email Templates (ready)</p>
        <div style="display:flex;flex-direction:column;gap:6px;">
          {[
            { name: 'Application Received', trigger: 'Auto: on application submit', status: 'ready' },
            { name: 'Status Update', trigger: 'Auto: on status change', status: 'ready' },
            { name: 'Offer Letter', trigger: 'Auto: when offer generated', status: 'ready' },
            { name: 'Task Assignment', trigger: 'Manual: from application detail', status: 'ready' },
            { name: 'Welcome Email', trigger: 'Auto: on portal signup', status: 'ready' },
            { name: 'Password Reset', trigger: 'Auto: on reset request', status: 'planned' },
          ].map(t => (
            <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:8px;padding:10px 14px;display:flex;align-items:center;justify-content:space-between;">
              <div>
                <p style="font-size:12px;font-weight:600;color:#fff;margin:0;">{t.name}</p>
                <p style="font-size:10px;color:#6e6e78;margin:2px 0 0;">{t.trigger}</p>
              </div>
              <span style={`font-size:9px;font-weight:700;padding:2px 8px;border-radius:100px;${t.status === 'ready' ? 'background:rgba(16,185,129,0.15);color:#6ee7b7;' : 'background:#15151a;color:#6e6e78;'}`}>
                {t.status}
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- SENT TAB -->
  {tab === 'sent' && (
    <div style="padding:12px 16px;">
      {sentEmails.length === 0 ? (
        <div style="text-align:center;padding:48px;color:#6e6e78;">
          <p style="font-size:32px;margin-bottom:8px;">📭</p>
          <p style="font-size:13px;">No emails sent yet.</p>
          <p style="font-size:12px;margin-top:4px;">Email logs will appear here once SMTP is configured.</p>
        </div>
      ) : (
        <div style="display:flex;flex-direction:column;gap:6px;">
          {sentEmails.map((e: any) => (
            <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:10px 14px;">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">
                <div style="min-width:0;">
                  <p style="font-size:13px;font-weight:600;color:#fff;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{e.subject}</p>
                  <p style="font-size:11px;color:#6e6e78;margin:2px 0 0;">To: {e.to_email}</p>
                </div>
                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:3px;flex-shrink:0;">
                  <span style={`font-size:9px;font-weight:700;padding:2px 7px;border-radius:100px;${e.status === 'sent' ? 'background:rgba(16,185,129,0.15);color:#6ee7b7;' : e.status === 'failed' ? 'background:rgba(239,68,68,0.15);color:#fca5a5;' : 'background:#15151a;color:#6e6e78;'}`}>{e.status}</span>
                  <span style="font-size:10px;color:#6e6e78;">{timeAgo(e.created_at)}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  )}

  <!-- SMTP SETTINGS TAB -->
  {tab === 'settings' && (
    <div style="padding:16px;display:flex;flex-direction:column;gap:12px;">
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:16px;">
        <p style="font-size:14px;font-weight:600;color:#fff;margin:0 0 4px;">SMTP Configuration</p>
        <p style="font-size:12px;color:#6e6e78;margin:0 0 14px;">Add these to Vercel environment variables once your VPS is ready.</p>
        <div style="display:flex;flex-direction:column;gap:8px;">
          {[
            { key: 'SMTP_HOST', example: 'mail.edurankai.in', desc: 'Your VPS hostname or IP' },
            { key: 'SMTP_PORT', example: '587', desc: 'Port 587 (TLS) or 465 (SSL)' },
            { key: 'SMTP_USER', example: 'no-reply@edurankai.in', desc: 'Sender email address' },
            { key: 'SMTP_PASS', example: '••••••••', desc: 'SMTP password (keep secret)' },
            { key: 'SMTP_FROM', example: 'EduRankAI <no-reply@edurankai.in>', desc: 'Display name + address' },
          ].map(v => (
            <div style="background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:3px;">
                <span style="font-size:11px;font-weight:700;color:#FF7040;font-family:'Geist Mono',monospace;">{v.key}</span>
                <span style="font-size:10px;color:#6e6e78;font-family:'Geist Mono',monospace;">{v.example}</span>
              </div>
              <p style="font-size:11px;color:#6e6e78;margin:0;">{v.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:16px;">
        <p style="font-size:14px;font-weight:600;color:#fff;margin:0 0 4px;">VPS Setup Guide</p>
        <p style="font-size:12px;color:#6e6e78;margin:0 0 12px;">When you get your Ubuntu VPS, run these commands:</p>
        <div style="background:#0a0a0c;border-radius:8px;padding:12px;font-family:'Geist Mono',monospace;font-size:11px;color:#6ee7b7;line-height:1.8;">
          <p style="margin:0;"># Install Postfix</p>
          <p style="margin:0;">sudo apt install postfix mailutils</p>
          <p style="margin:0;"># Configure for edurankai.in</p>
          <p style="margin:0;">sudo postconf -e 'myhostname=mail.edurankai.in'</p>
          <p style="margin:0;">sudo postconf -e 'myorigin=edurankai.in'</p>
          <p style="margin:0;"># Set SPF, DKIM, DMARC DNS records</p>
          <p style="margin:0;"># Then come back and fill in env vars above</p>
        </div>
      </div>
    </div>
  )}

</div>
</AdminLayout>
