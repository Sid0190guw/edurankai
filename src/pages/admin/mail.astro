---
import AdminLayout from '@/layouts/AdminLayout.astro';
import MailClient from '@/components/MailClient.astro';
import { transportStatus } from '@/lib/mail-transport';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const transport = transportStatus();
---
<AdminLayout title="Mail" activeNav="mail">
  {transport.mode === 'none' && (
    <div style="background:rgba(251,191,36,0.10);border-bottom:1px solid rgba(251,191,36,0.25);padding:8px 16px;font-size:11.5px;color:#fbbf24;">
      Internal mail works now. To send/receive external email, set <b>SMTP_HOST</b> (your VPS) or <b>RESEND_API_KEY</b>, and point inbound mail at <b>/api/mail/inbound</b> with <b>MAIL_INBOUND_SECRET</b>.
    </div>
  )}
  <MailClient user={user} basePath="/admin/mail" />
</AdminLayout>

<style is:global>
  .admin-body:has(.mailc) .admin-main, .admin-main:has(.mailc){ padding:0 !important; }
  .admin-html .mailc{ height:100dvh; }
</style>
