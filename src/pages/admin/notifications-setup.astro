---
// /admin/notifications-setup
// Diagnostic + setup page for browser push notifications.
// Shows: VAPID configured · permission state · subscription on file · test send.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { pushSubscriptions } from '@/lib/db/schema';
import { eq } from 'drizzle-orm';
import { randomBytes } from 'node:crypto';

const user = Astro.locals.user!;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const vapidPub = (import.meta.env.VAPID_PUBLIC_KEY || process.env.VAPID_PUBLIC_KEY || '').toString();
const vapidPriv = (import.meta.env.VAPID_PRIVATE_KEY || process.env.VAPID_PRIVATE_KEY || '').toString();
const vapidOk = !!(vapidPub && vapidPriv);

// Generate paste-ready keys for the user when missing.
// NOTE: web-push generates EC keys, not arbitrary bytes — we just suggest the
// command they should run themselves. The keys below are NOT valid VAPID keys.
const exampleSecret = randomBytes(16).toString('hex');

const mySubs = await db.select().from(pushSubscriptions).where(eq(pushSubscriptions.userId, user.id));
const totalSubs = (await db.select({ id: pushSubscriptions.id }).from(pushSubscriptions)).length;
---
<AdminLayout title="Notifications Setup" activeNav="">
<div class="admin-page" style="max-width:900px;">

  <div class="admin-page-header" style="margin-bottom:18px;">
    <div class="admin-page-title-block">
      <div class="admin-page-eyebrow">Notifications</div>
      <h1 class="admin-page-title">Browser push setup</h1>
      <p class="admin-page-sub">Make notifications work on laptop + phone. Three checks, one test button.</p>
    </div>
  </div>

  <!-- Status grid -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:10px;margin-bottom:18px;">
    <div style={`background:#0f0f14;border:1px solid ${vapidOk ? 'rgba(16,185,129,0.4)' : 'rgba(239,68,68,0.4)'};border-radius:10px;padding:12px 14px;`}>
      <p style="font-family:'Geist Mono',monospace;font-size:10px;letter-spacing:0.12em;color:#9aa6b6;margin:0 0 4px;text-transform:uppercase;font-weight:700;">Step 1 · Server</p>
      <p style={`font-size:13px;font-weight:700;color:${vapidOk ? '#6ee7b7' : '#fca5a5'};margin:0;`}>{vapidOk ? '✓ VAPID keys configured' : '✗ VAPID keys missing'}</p>
    </div>
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px 14px;">
      <p style="font-family:'Geist Mono',monospace;font-size:10px;letter-spacing:0.12em;color:#9aa6b6;margin:0 0 4px;text-transform:uppercase;font-weight:700;">Step 2 · Browser</p>
      <p style="font-size:13px;font-weight:700;margin:0;" id="permStatus">checking...</p>
    </div>
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px 14px;">
      <p style="font-family:'Geist Mono',monospace;font-size:10px;letter-spacing:0.12em;color:#9aa6b6;margin:0 0 4px;text-transform:uppercase;font-weight:700;">Step 3 · Account</p>
      <p style={`font-size:13px;font-weight:700;color:${mySubs.length > 0 ? '#6ee7b7' : '#fbbf24'};margin:0;`}>{mySubs.length > 0 ? '✓ ' + mySubs.length + ' device(s) subscribed' : '○ Not subscribed yet'}</p>
      <p style="font-size:10.5px;color:#6e6e78;margin:4px 0 0;">Server has {totalSubs} subscription(s) total across all admins.</p>
    </div>
  </div>

  {!vapidOk && (
    <div style="background:rgba(251,191,36,0.10);border:1px solid rgba(251,191,36,0.30);border-radius:10px;padding:14px 16px;margin-bottom:16px;">
      <p style="font-weight:700;color:#fbbf24;margin:0 0 8px;">Server is missing VAPID keys. Push won't work for ANY device until they're set.</p>
      <p style="font-size:12.5px;color:#d8d8de;margin:0 0 10px;line-height:1.6;">Generate keys on your laptop:</p>
      <code style="display:block;font-family:'Geist Mono',monospace;background:#08080a;border:1px solid #2a2a2f;color:#FF7040;padding:9px 12px;border-radius:7px;font-size:12px;margin-bottom:10px;">npx web-push generate-vapid-keys</code>
      <p style="font-size:12.5px;color:#d8d8de;margin:0 0 6px;line-height:1.6;">Paste the two values into Vercel → Project → Settings → Environment Variables:</p>
      <ul style="font-size:12px;color:#9aa6b6;margin:0 0 10px 18px;padding:0;line-height:1.8;">
        <li><code style="font-family:'Geist Mono',monospace;background:#08080a;padding:1px 6px;border-radius:4px;color:#FF7040;">VAPID_PUBLIC_KEY</code> = the public key (starts with B...)</li>
        <li><code style="font-family:'Geist Mono',monospace;background:#08080a;padding:1px 6px;border-radius:4px;color:#FF7040;">VAPID_PRIVATE_KEY</code> = the private key</li>
        <li><code style="font-family:'Geist Mono',monospace;background:#08080a;padding:1px 6px;border-radius:4px;color:#FF7040;">VAPID_SUBJECT</code> (optional) = mailto:hr@edurankai.in</li>
      </ul>
      <p style="font-size:11.5px;color:#6e6e78;margin:0;">Apply to Production + Preview + Development → Redeploy. Then reload this page.</p>
    </div>
  )}

  <!-- Subscribe + test actions -->
  <div class="admin-card" style="margin-bottom:16px;">
    <p style="font-size:14px;font-weight:700;color:var(--o-hi,#fff);margin:0 0 12px;">Subscribe this device + send a test push</p>
    <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
      <button type="button" id="enableBtn" style="background:#10b981;color:#fff;border:none;font-weight:700;font-size:13px;padding:10px 20px;border-radius:7px;cursor:pointer;">Enable browser notifications</button>
      <button type="button" id="testBtn" style="background:#FF4F00;color:#fff;border:none;font-weight:700;font-size:13px;padding:10px 20px;border-radius:7px;cursor:pointer;" disabled={!vapidOk}>Send test push to my devices</button>
    </div>
    <p id="actionMsg" style="font-size:12px;margin:10px 0 0;min-height:1.2em;line-height:1.5;"></p>
  </div>

  <!-- Per-device list -->
  {mySubs.length > 0 && (
    <div class="admin-card" style="margin-bottom:16px;">
      <p style="font-size:13px;font-weight:700;color:var(--o-hi,#fff);margin:0 0 10px;">Subscribed devices on this account ({mySubs.length})</p>
      <div style="display:flex;flex-direction:column;gap:5px;font-family:'Geist Mono',monospace;font-size:11.5px;">
        {mySubs.map((s: any) => (
          <div style="background:#08080a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 11px;display:flex;justify-content:space-between;gap:8px;flex-wrap:wrap;">
            <span style="color:#d8d8de;">…{(s.endpoint || '').slice(-44)}</span>
            <span style="color:#6e6e78;">last used: {s.lastUsedAt ? new Date(s.lastUsedAt).toLocaleString('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) : 'never'}</span>
          </div>
        ))}
      </div>
      <p style="font-size:11px;color:#6e6e78;margin:10px 0 0;line-height:1.5;">Each entry is one browser on one device. Dead endpoints (browser uninstalled, permission revoked) are auto-removed when push fails with 410/404.</p>
    </div>
  )}

  <!-- Troubleshooting -->
  <div class="admin-card">
    <p style="font-size:13px;font-weight:700;color:var(--o-hi,#fff);margin:0 0 10px;">Troubleshooting</p>
    <ul style="font-size:12px;color:#9aa6b6;margin:0;padding-left:18px;line-height:1.8;">
      <li>iPhone: push requires iOS 16.4+ AND adding the site to your home screen first (Safari → Share → Add to Home Screen).</li>
      <li>macOS Safari: notifications appear in Notification Center, not as floating banners by default. Adjust in System Settings → Notifications → Safari.</li>
      <li>Chrome / Edge on Windows: check Focus Assist isn't suppressing. Settings → System → Focus assist.</li>
      <li>If permission shows "denied", you'll have to manually re-allow it in the browser's site settings — we cannot re-prompt.</li>
      <li>The in-app bell (top-right of admin) is independent and always works, even when browser push is blocked.</li>
    </ul>
  </div>
</div>

<script is:inline>
  function setPerm() {
    var el = document.getElementById('permStatus'); if (!el) return;
    if (typeof Notification === 'undefined') { el.textContent = 'unsupported'; el.style.color = '#fca5a5'; return; }
    var p = Notification.permission;
    if (p === 'granted') { el.textContent = '✓ Granted'; el.style.color = '#6ee7b7'; }
    else if (p === 'denied') { el.textContent = '✗ Denied (re-allow in browser settings)'; el.style.color = '#fca5a5'; }
    else { el.textContent = '○ Not asked yet'; el.style.color = '#fbbf24'; }
  }
  setPerm();

  function setMsg(txt, color) {
    var el = document.getElementById('actionMsg'); if (!el) return;
    el.textContent = txt; el.style.color = color || '#9aa6b6';
  }

  document.getElementById('enableBtn')?.addEventListener('click', async function () {
    var btn = this; btn.disabled = true;
    setMsg('Requesting permission...');
    try {
      if (!window.EduPush) { setMsg('Push helper not loaded — hard refresh and retry.', '#fca5a5'); btn.disabled = false; return; }
      var r = await window.EduPush.subscribe();
      setPerm();
      btn.disabled = false;
      if (r.ok) {
        setMsg(r.alreadySubscribed ? '✓ Already subscribed on this device.' : '✓ Subscribed. Try the test button below.', '#6ee7b7');
        setTimeout(function () { location.reload(); }, 1500);
      } else {
        var reasonText = {
          'no-vapid': 'Server VAPID keys not configured. Set them in Vercel first (see card above).',
          'no-sw': 'Service worker did not register. Try hard refresh (Ctrl+Shift+R).',
          'NotAllowedError': 'You denied the permission prompt. Re-allow in browser settings to retry.',
        }[r.reason] || ('Failed: ' + (r.reason || r.error || 'unknown'));
        setMsg('✗ ' + reasonText, '#fca5a5');
      }
    } catch (e) { btn.disabled = false; setMsg('✗ ' + ((e && e.message) || 'error'), '#fca5a5'); }
  });

  document.getElementById('testBtn')?.addEventListener('click', function () {
    var btn = this; btn.disabled = true; setMsg('Sending test push...');
    fetch('/api/push/test', { method: 'POST', credentials: 'same-origin' })
      .then(function (r) { return r.json(); }).then(function (d) {
        btn.disabled = false;
        if (d.ok) {
          setMsg('✓ Sent to ' + d.delivered + ' / ' + d.subscriptions + ' device(s). ' + (d.hint || ''), '#6ee7b7');
        } else {
          var extra = (d.results || []).map(function (r) { return '· ' + (r.error || 'ok') + ' (' + r.endpoint + ')'; }).join('\n');
          setMsg('✗ ' + (d.error || 'failed') + (extra ? '\n' + extra : ''), '#fca5a5');
        }
      }).catch(function () { btn.disabled = false; setMsg('✗ Network error', '#fca5a5'); });
  });
</script>
</AdminLayout>
