---
// /admin/backup — backup / restore / integrity console (Prompt 23). STRICTLY superadmin
// (can(administer)). Export the kernel, run a consistency report, and restore (dry-run then apply).
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { integrityReport } from '@/lib/backup';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'administer', { type: 'platform' });
if (!gate.allow) return Astro.redirect('/admin');
const report = await integrityReport().catch(() => null);
const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
---
<AdminLayout title="Backup & integrity" activeNav="backup">
  <div style="max-width:900px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Superadmin</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Backup, restore &amp; integrity</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">Export kernel objects + relationships; restore is validated + additive (never overwrites). Students export their own data at /aquintutor/analytics.</p>
    <div id="msg" style="display:none;margin:12px 0;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin:16px 0;">
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Kernel objects</p><p style="font-size:26px;font-weight:800;color:#fff;margin:4px 0 0;">{report?.objects ?? 0}</p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Relationships</p><p style="font-size:26px;font-weight:800;color:#fff;margin:4px 0 0;">{report?.edges ?? 0}</p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Integrity</p><p style={'font-size:20px;font-weight:800;margin:4px 0 0;color:' + (report?.ok ? '#6ee7b7' : '#fca5a5')}>{report?.ok ? 'clean' : (report?.orphanEdges?.length || 0) + ' orphans'}</p></div>
    </div>

    <div style={CARD}>
      <p style={HD}>Export</p>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <a href="/api/admin/backup" style="background:#FF4F00;color:#fff;text-decoration:none;font-size:12px;font-weight:700;padding:9px 16px;border-radius:8px;">Download full kernel (JSON)</a>
        <div style="display:flex;gap:5px;"><input id="courseId" placeholder="course object id" style="background:#15151a;border:1px solid #26262c;color:#fff;padding:7px 9px;border-radius:6px;font-size:12px;width:240px;" /><a id="courseDl" href="#" style="background:#15151a;border:1px solid #26262c;color:#cfd6da;text-decoration:none;font-size:12px;padding:8px 12px;border-radius:6px;">Course subtree</a></div>
      </div>
    </div>

    <div style={CARD}>
      <p style={HD}>Restore (validated, additive)</p>
      <textarea id="pkg" rows="6" placeholder="Paste a backup JSON package here" style="width:100%;box-sizing:border-box;background:#08080a;border:1px solid #26262c;color:#cfd6da;font-family:'Geist Mono',monospace;font-size:11.5px;border-radius:8px;padding:10px;"></textarea>
      <div style="display:flex;gap:6px;margin-top:8px;">
        <button id="dryBtn" type="button" style="background:#15151a;border:1px solid #26262c;color:#cfd6da;font-size:11px;padding:8px 14px;border-radius:6px;cursor:pointer;">Dry-run</button>
        <button id="applyBtn" type="button" style="background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:700;padding:8px 14px;border-radius:6px;cursor:pointer;">Apply restore</button>
      </div>
      <pre id="planOut" style="margin:12px 0 0;font-family:'Geist Mono',monospace;font-size:11.5px;color:#8a8a94;white-space:pre-wrap;"></pre>
    </div>
  </div>

  <script is:inline>
    (function () {
      var msg = document.getElementById('msg'), out = document.getElementById('planOut');
      document.getElementById('courseId').addEventListener('input', function () { document.getElementById('courseDl').href = '/api/admin/backup?course=' + encodeURIComponent(this.value); });
      function parse() { try { return JSON.parse(document.getElementById('pkg').value); } catch (e) { msg.style.display = 'block'; msg.textContent = 'Invalid JSON.'; msg.style.background = 'rgba(239,68,68,0.12)'; msg.style.color = '#fca5a5'; return null; } }
      function post(action) { var pkg = parse(); if (!pkg) return; fetch('/api/admin/backup', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: action, package: pkg }) }).then(function (r) { return r.json(); }).then(function (j) { out.textContent = JSON.stringify(j.plan || j.applied || j, null, 2); msg.style.display = 'block'; msg.textContent = j.ok ? (action === 'apply' ? 'Restore applied.' : 'Dry-run complete.') : (j.error || 'Failed'); msg.style.background = j.ok ? 'rgba(16,185,129,0.12)' : 'rgba(239,68,68,0.12)'; msg.style.color = j.ok ? '#6ee7b7' : '#fca5a5'; }); }
      document.getElementById('dryBtn').addEventListener('click', function () { post('dryRun'); });
      document.getElementById('applyBtn').addEventListener('click', function () { if (confirm('Apply this restore? It is additive and will not overwrite existing objects.')) post('apply'); });
    })();
  </script>
</AdminLayout>
