---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

let okMsg = '', errorMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  try {
    if (action === 'resolve') {
      const id = fd.get('id') as string;
      const resolution = fd.get('resolution') as string;
      await db.execute(sql`UPDATE content_flags SET status = 'resolved', resolution = ${resolution}, resolved_by = ${user.id}, resolved_at = NOW() WHERE id = ${id}`);
      okMsg = 'Flag resolved.';
    } else if (action === 'dismiss') {
      const id = fd.get('id') as string;
      await db.execute(sql`UPDATE content_flags SET status = 'dismissed', resolved_by = ${user.id}, resolved_at = NOW() WHERE id = ${id}`);
      okMsg = 'Flag dismissed.';
    } else if (action === 'warn_user') {
      const userId = fd.get('user_id') as string;
      const message = fd.get('message') as string;
      await db.execute(sql`INSERT INTO notifications (user_id, title, body, type) VALUES (${userId}, 'Content Warning', ${message}, 'system')`);
      okMsg = 'Warning sent to user.';
    } else if (action === 'add_domain') {
      const domain = (fd.get('domain') as string || '').trim().toLowerCase();
      const reason = (fd.get('reason') as string || '').trim();
      const category = fd.get('category') as string;
      if (domain) {
        await db.execute(sql`INSERT INTO content_blocked_domains (domain, reason, category, added_by) VALUES (${domain}, ${reason||null}, ${category||null}, ${user.id}) ON CONFLICT (domain) DO NOTHING`);
        okMsg = 'Domain blocked.';
      }
    } else if (action === 'remove_domain') {
      await db.execute(sql`DELETE FROM content_blocked_domains WHERE id = ${fd.get('id') as string}`);
      okMsg = 'Domain unblocked.';
    }
  } catch(e: any) { errorMsg = e.message; }
}

const url = new URL(Astro.request.url);
const tab = url.searchParams.get('tab') || 'flags';
const filter = url.searchParams.get('filter') || 'pending';

let flags: any[] = [];
let blockedDomains: any[] = [];
let stats = { pending: 0, resolved: 0, dismissed: 0, total: 0 };

try {
  const r = await db.execute(sql`
    SELECT f.*, u1.name as reporter_name, u2.name as target_name, u2.email as target_email
    FROM content_flags f
    LEFT JOIN users u1 ON f.reporter_user_id = u1.id
    LEFT JOIN users u2 ON f.target_user_id = u2.id
    WHERE f.status = ${filter}
    ORDER BY f.created_at DESC LIMIT 50
  `);
  flags = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n, status FROM content_flags GROUP BY status`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  for (const row of rows as any[]) {
    stats[row.status as keyof typeof stats] = Number(row.n) || 0;
    stats.total += Number(row.n) || 0;
  }
} catch(e) {}

try {
  const r = await db.execute(sql`SELECT * FROM content_blocked_domains ORDER BY created_at DESC`);
  blockedDomains = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

const FLAG_COLOR: Record<string,string> = {
  nudity:'#ef4444', explicit:'#f97316', propaganda:'#a78bfa',
  hate_speech:'#ef4444', misinformation:'#fbbf24', spam:'#6b7280',
  harassment:'#f97316', violence:'#ef4444', self_harm:'#a78bfa', other:'#6b7280'
};

function timeAgo(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff/60000);
  if (mins < 60) return mins + 'm ago';
  return Math.floor(mins/60) + 'h ago';
}
---
<AdminLayout title="Content Moderation" activeNav="moderation">
<div style="padding-bottom:80px;">

  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
      <div>
        <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">Safety</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Content Moderation</h1>
      </div>
      {stats.pending > 0 && <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:100px;padding:4px 12px;"><span style="font-size:12px;font-weight:700;color:#ef4444;">{stats.pending} pending</span></div>}
    </div>
    <div style="display:flex;gap:5px;">
      {[['flags','Flags'],['domains','Blocked Domains'],['wellbeing','Wellbeing']].map(([t,l]) => (
        <a href={`?tab=${t}`} style={`text-decoration:none;font-size:12px;font-weight:600;padding:6px 12px;border-radius:6px;${tab===t?'background:#FF4F00;color:#fff;':'background:#15151a;color:#8a8a94;'}`}>{l}</a>
      ))}
    </div>
  </div>

  {errorMsg && <div style="margin:10px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  {tab === 'flags' && (
    <div style="padding:12px 16px;">
      <!-- Stats -->
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:12px;">
        {[
          { label:'Total', value:stats.total, color:'#fff' },
          { label:'Pending', value:stats.pending, color:'#ef4444' },
          { label:'Resolved', value:stats.resolved, color:'#10b981' },
          { label:'Dismissed', value:stats.dismissed, color:'#6b7280' },
        ].map(s => (
          <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:10px;text-align:center;">
            <p style={`font-size:20px;font-weight:800;color:${s.color};margin:0;font-family:'Geist Mono',monospace;`}>{s.value}</p>
            <p style="font-size:9px;color:#6e6e78;margin:3px 0 0;text-transform:uppercase;">{s.label}</p>
          </div>
        ))}
      </div>

      <!-- Filter -->
      <div style="display:flex;gap:5px;margin-bottom:12px;">
        {['pending','reviewing','resolved','dismissed'].map(f => (
          <a href={`?tab=flags&filter=${f}`} style={`text-decoration:none;font-size:11px;font-weight:600;padding:5px 10px;border-radius:100px;${filter===f?'background:#FF4F00;color:#fff;':'background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;'}`}>{f.charAt(0).toUpperCase()+f.slice(1)}</a>
        ))}
      </div>

      {flags.length === 0 && (
        <div style="text-align:center;padding:40px;background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;color:#6e6e78;">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#6e6e78" stroke-width="1.5" style="margin-bottom:12px;"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <p style="font-size:14px;font-weight:600;color:#fff;margin-bottom:4px;">No {filter} flags</p>
          <p style="font-size:12px;">Content is clean.</p>
        </div>
      )}

      <div style="display:flex;flex-direction:column;gap:8px;">
        {flags.map((f: any) => {
          const fc = (FLAG_COLOR as any)[f.flag_type] || '#6b7280';
          return (
            <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
              <div style="padding:12px 14px;">
                <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:8px;">
                  <div>
                    <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;flex-wrap:wrap;">
                      <span style={`font-size:9px;font-weight:700;padding:2px 8px;border-radius:100px;background:${fc}22;color:${fc};text-transform:uppercase;`}>{f.flag_type?.replace('_',' ')}</span>
                      <span style="font-size:9px;background:#15151a;color:#8a8a94;padding:2px 6px;border-radius:4px;">{f.flag_source}</span>
                      {f.confidence && <span style="font-size:9px;color:#6e6e78;">{Math.round(f.confidence*100)}% confidence</span>}
                    </div>
                    <p style="font-size:12px;color:#6e6e78;margin:0;font-family:'Geist Mono',monospace;">{f.entity_type} - {f.entity_id?.substring(0,12)}</p>
                  </div>
                  <span style="font-size:10px;color:#6e6e78;flex-shrink:0;">{timeAgo(f.created_at)}</span>
                </div>

                {f.content_snippet && (
                  <div style="background:#15151a;border-radius:6px;padding:8px 10px;margin-bottom:8px;border-left:3px solid #ef4444;">
                    <p style="font-size:11px;color:#8a8a94;margin:0;line-height:1.4;font-style:italic;">"{f.content_snippet.substring(0,200)}{f.content_snippet.length>200?'...':''}"</p>
                  </div>
                )}

                <div style="display:flex;align-items:center;gap:8px;font-size:11px;color:#6e6e78;flex-wrap:wrap;">
                  {f.reporter_name && <span>Reported by: <span style="color:#d8d8de;">{f.reporter_name}</span></span>}
                  {f.target_name && <span>Target: <span style="color:#fca5a5;">{f.target_name} ({f.target_email})</span></span>}
                </div>
              </div>

              {f.status === 'pending' && (
                <div style="border-top:1px solid #1a1a1f;padding:8px 14px;display:flex;gap:6px;flex-wrap:wrap;">
                  <form method="POST" style="display:flex;gap:4px;flex:1;">
                    <input type="hidden" name="action" value="resolve" />
                    <input type="hidden" name="id" value={f.id} />
                    <input name="resolution" placeholder="Resolution note..." required style="flex:1;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:6px 10px;color:#fff;font-size:11px;outline:none;" />
                    <button type="submit" style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;font-size:11px;font-weight:600;padding:6px 10px;border-radius:6px;cursor:pointer;">Resolve</button>
                  </form>
                  <form method="POST" style="display:contents;">
                    <input type="hidden" name="action" value="dismiss" />
                    <input type="hidden" name="id" value={f.id} />
                    <button type="submit" style="background:#15151a;border:1px solid #1a1a1f;color:#6e6e78;font-size:11px;padding:6px 10px;border-radius:6px;cursor:pointer;">Dismiss</button>
                  </form>
                  {f.target_user_id && (
                    <form method="POST" style="display:contents;">
                      <input type="hidden" name="action" value="warn_user" />
                      <input type="hidden" name="user_id" value={f.target_user_id} />
                      <input type="hidden" name="message" value={`Your content was flagged for ${f.flag_type?.replace('_',' ')}. Please review our community guidelines.`} />
                      <button type="submit" style="background:rgba(251,191,36,0.1);border:1px solid rgba(251,191,36,0.2);color:#fbbf24;font-size:11px;padding:6px 10px;border-radius:6px;cursor:pointer;">Warn User</button>
                    </form>
                  )}
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>
  )}

  {tab === 'domains' && (
    <div style="padding:12px 16px;">
      <!-- Add domain form -->
      <form method="POST" style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;margin-bottom:12px;display:flex;flex-direction:column;gap:10px;">
        <input type="hidden" name="action" value="add_domain" />
        <p style="font-size:12px;font-weight:600;color:#fff;margin:0;">Block a Domain</p>
        <div style="display:grid;grid-template-columns:2fr 1fr 1fr;gap:8px;">
          <input name="domain" placeholder="example.com" required style="background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:9px 12px;color:#fff;font-size:13px;outline:none;" />
          <select name="category" style="background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:9px 12px;color:#fff;font-size:12px;outline:none;">
            <option value="nudity">Nudity</option>
            <option value="hate_speech">Hate speech</option>
            <option value="propaganda">Propaganda</option>
            <option value="violence">Violence</option>
            <option value="spam">Spam</option>
            <option value="other">Other</option>
          </select>
          <button type="submit" style="background:#FF4F00;border:none;color:#fff;font-size:12px;font-weight:600;border-radius:8px;cursor:pointer;">Block</button>
        </div>
        <input name="reason" placeholder="Reason (optional)" style="background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:8px 12px;color:#fff;font-size:12px;outline:none;" />
      </form>

      <div style="display:flex;flex-direction:column;gap:6px;">
        {blockedDomains.map((d: any) => (
          <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:10px 14px;display:flex;align-items:center;gap:10px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
            <div style="flex:1;min-width:0;">
              <p style="font-size:13px;font-weight:600;color:#fff;margin:0;font-family:'Geist Mono',monospace;">{d.domain}</p>
              {d.reason && <p style="font-size:11px;color:#6e6e78;margin:2px 0 0;">{d.reason}</p>}
            </div>
            <span style="font-size:9px;background:rgba(239,68,68,0.1);color:#fca5a5;padding:2px 8px;border-radius:100px;flex-shrink:0;">{d.category}</span>
            <form method="POST" style="display:contents;">
              <input type="hidden" name="action" value="remove_domain" />
              <input type="hidden" name="id" value={d.id} />
              <button type="submit" style="background:none;border:none;color:#6e6e78;cursor:pointer;font-size:16px;padding:4px;">&times;</button>
            </form>
          </div>
        ))}
      </div>
    </div>
  )}

  {tab === 'wellbeing' && (
    <div style="padding:12px 16px;display:flex;flex-direction:column;gap:12px;">
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:16px;">
        <p style="font-size:13px;font-weight:600;color:#fff;margin:0 0 12px;">Platform Safety Features</p>
        {[
          { label: 'NSFW Image Detection', desc: 'Scan uploaded images using AI before storage. Block explicit content automatically.', status: 'active', color: '#10b981' },
          { label: 'Link Safety Check', desc: 'Warn users before navigating to blocked or unverified external domains.', status: 'active', color: '#10b981' },
          { label: 'Propaganda Filter', desc: 'Keyword-based detection for misinformation and extremist language in text submissions.', status: 'active', color: '#10b981' },
          { label: 'User Report System', desc: 'Any user can flag content. All flags go to this moderation queue.', status: 'active', color: '#10b981' },
          { label: 'Content Warnings', desc: 'Show warning overlays on sensitive topics before displaying content.', status: 'planned', color: '#fbbf24' },
          { label: 'Screen Time Limits', desc: 'Let users set daily usage limits with reminders.', status: 'planned', color: '#fbbf24' },
          { label: 'AI Chat Safety', desc: 'Filter harmful prompts in any AI-powered features.', status: 'planned', color: '#6b7280' },
        ].map(f => (
          <div style="display:flex;align-items:flex-start;gap:12px;padding:10px 0;border-bottom:1px solid #1a1a1f;">
            <div style={`width:8px;height:8px;border-radius:50%;background:${f.color};flex-shrink:0;margin-top:5px;`}></div>
            <div style="flex:1;">
              <p style="font-size:13px;font-weight:600;color:#fff;margin:0 0 2px;">{f.label}</p>
              <p style="font-size:11px;color:#6e6e78;margin:0;">{f.desc}</p>
            </div>
            <span style={`font-size:9px;font-weight:700;padding:2px 8px;border-radius:100px;flex-shrink:0;background:${f.color}22;color:${f.color};`}>{f.status.toUpperCase()}</span>
          </div>
        ))}
      </div>

      <!-- NSFW detection explanation -->
      <div style="background:#0f0f14;border:1px solid rgba(251,191,36,0.2);border-radius:12px;padding:16px;">
        <p style="font-size:13px;font-weight:600;color:#fbbf24;margin:0 0 8px;">How NSFW Detection Works</p>
        <p style="font-size:12px;color:#8a8a94;margin:0 0 10px;line-height:1.6;">When users upload images (profile photos, evidence, documents), the system runs them through a TensorFlow.js NSFW classification model before storage. Images scoring above 70% explicit are automatically rejected and flagged for review.</p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
          {[
            { label: 'Drawing/Cartoon', threshold: '< 30%', action: 'Allow' },
            { label: 'Hentai', threshold: '> 50%', action: 'Block' },
            { label: 'Neutral', threshold: '> 60%', action: 'Allow' },
            { label: 'Explicit/Porn', threshold: '> 50%', action: 'Block' },
            { label: 'Sexy', threshold: '> 70%', action: 'Flag' },
          ].map(c => (
            <div style="background:#15151a;border-radius:6px;padding:8px 10px;display:flex;justify-content:space-between;align-items:center;">
              <div>
                <p style="font-size:11px;color:#d8d8de;margin:0;">{c.label}</p>
                <p style="font-size:10px;color:#6e6e78;margin:0;">{c.threshold}</p>
              </div>
              <span style={`font-size:9px;font-weight:700;padding:1px 7px;border-radius:100px;${c.action==='Allow'?'background:rgba(16,185,129,0.15);color:#6ee7b7;':c.action==='Block'?'background:rgba(239,68,68,0.15);color:#fca5a5;':'background:rgba(251,191,36,0.15);color:#fbbf24;'}`}>{c.action}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

</div>
</AdminLayout>
