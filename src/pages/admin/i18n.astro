---
// /admin/i18n — translation-string management (Prompt AP3b). View coverage per locale, see missing
// keys, and add/edit locale strings (stored as overrides, merged at runtime). Content-translation of
// KnowledgeObjects is routed by the runtime per the existing variant model (Prompt 4). Gated: write content.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { LOCALES, STRINGS, BASE_LOCALE, coverageMerged, getStringOverrides } from '@/lib/i18n';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'write', { type: 'content' });
if (!gate.allow) return Astro.redirect('/admin');
const sel = (Astro.url.searchParams.get('locale') || 'hi');
const overrides = await getStringOverrides(sel).catch(() => ({} as Record<string, string>));
const baseKeys = Object.keys(STRINGS[BASE_LOCALE] || {});
const cov = await Promise.all(LOCALES.map(async (l) => ({ l, c: coverageMerged(l.code, await getStringOverrides(l.code).catch(() => ({}))) })));
const merged: Record<string, string> = { ...(STRINGS[sel] || {}), ...overrides };
const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
---
<AdminLayout title="Translations" activeNav="i18n">
  <div style="max-width:940px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Localization</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Translation management</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">Interface-string coverage per locale. Edits are stored as overrides and merge over the base at runtime (no code change). Untranslated strings fall back to English and are marked — never blank, never invented. Lesson content is served in the reader's language by the runtime's translation-variant model (Prompt 4).</p>
    <div id="msg" style="display:none;margin:12px 0;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style={CARD}>
      <p style={HD}>Coverage</p>
      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        {cov.map(({ l, c }) => (
          <a href={'/admin/i18n?locale=' + l.code} style={'text-decoration:none;padding:8px 14px;border-radius:10px;border:1px solid ' + (l.code === sel ? '#26324a' : '#1a1a1f') + ';background:' + (l.code === sel ? '#1c2230' : '#12121a') + ';'}>
            <div style="font-size:13px;color:#d6d6de;">{l.native} <span style="font-size:10px;color:#8a8a94;">{l.dir}</span></div>
            <div style={'font-family:Geist Mono,monospace;font-size:12px;color:' + (c.pct === 100 ? '#6ee7b7' : c.pct >= 50 ? '#c0a35e' : '#fca5a5') + ';'}>{c.pct}% · {c.c ? '' : ''}{c.translated}/{c.total}</div>
          </a>
        ))}
      </div>
    </div>

    <div style={CARD}>
      <p style={HD}>Strings — {sel}</p>
      <table style="width:100%;border-collapse:collapse;font-size:12.5px;">
        <thead><tr style="text-align:left;color:#8a8a94;font-size:11px;text-transform:uppercase;"><th style="padding:6px 8px;">Key</th><th style="padding:6px 8px;">English (base)</th><th style="padding:6px 8px;">{sel}</th><th style="padding:6px 8px;"></th></tr></thead>
        <tbody>
          {baseKeys.map((k) => (
            <tr style="border-top:1px solid #1a1a1f;color:#d6d6de;">
              <td style="padding:6px 8px;font-family:'Geist Mono',monospace;font-size:11px;color:#9bd1ff;">{k}</td>
              <td style="padding:6px 8px;color:#8a8a94;">{STRINGS[BASE_LOCALE][k]}</td>
              <td style="padding:6px 8px;">{merged[k] ? <span style="color:#d6d6de;">{merged[k]}</span> : <span style="color:#fca5a5;">(missing — falls back)</span>}</td>
              <td style="padding:6px 8px;"><input class="strIn" data-key={k} placeholder="translate…" value={overrides[k] || ''} style="width:160px;font-size:12px;padding:4px 6px;border-radius:6px;background:#15151b;color:#d6d6de;border:1px solid #26262e;" /></td>
            </tr>
          ))}
        </tbody>
      </table>
      <button id="saveAll" style="margin-top:10px;background:#1c2230;color:#9bd1ff;border:1px solid #26324a;border-radius:8px;padding:8px 14px;font-size:12.5px;cursor:pointer;">Save translations</button>
    </div>
  </div>

  <script is:inline define:vars={{ sel }}>
    document.getElementById('saveAll').addEventListener('click', function () {
      var inputs = Array.prototype.slice.call(document.querySelectorAll('.strIn')).filter(function (i) { return i.value.trim(); });
      var msg = document.getElementById('msg');
      Promise.all(inputs.map(function (i) {
        return fetch('/api/admin/i18n', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ locale: sel, key: i.getAttribute('data-key'), value: i.value.trim() }) }).then(function (r) { return r.json(); });
      })).then(function (results) {
        var okc = results.filter(function (r) { return r.ok; }).length;
        msg.style.display = 'block'; msg.style.background = '#0f2a1c'; msg.style.color = '#6ee7b7'; msg.textContent = 'Saved ' + okc + ' translations. Reloading…';
        setTimeout(function () { location.reload(); }, 800);
      });
    });
  </script>
</AdminLayout>
