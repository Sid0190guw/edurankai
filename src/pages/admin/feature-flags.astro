---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { getAllFlags, setFlag } from '@/lib/feature-flags';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role !== 'super_admin') return Astro.redirect('/admin');

let okMsg = '';
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const key = fd.get('key') as string;
  const enabled = fd.get('enabled') === '1';
  if (key) { try { await setFlag(key, enabled); okMsg = (enabled ? 'Enabled ' : 'Hidden ') + key + '.'; } catch (_) {} }
}

const flags = await getAllFlags();
const groups: Record<string, typeof flags> = {};
for (const f of flags) (groups[f.group] = groups[f.group] || []).push(f);
const srcLabel: Record<string, string> = { admin: 'set here', env: 'from env var', default: 'default' };
---
<AdminLayout title="Feature Flags" activeNav="flags">
  <div class="admin-page" style="max-width:780px;">
    <div class="admin-page-header">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">Configuration</div>
        <h1 class="admin-page-title">Feature Flags</h1>
        <p class="admin-page-sub">Turn surfaces on or off across the product. Anything off is hidden from users so it never reads as a dead end. Off by default until a feature is verified functional.</p>
      </div>
    </div>

    {okMsg && <div style="margin:0 0 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

    {Object.entries(groups).map(([group, items]) => (
      <div style="margin-bottom:18px;">
        <p style="font-size:10px;font-family:'Geist Mono',monospace;letter-spacing:0.14em;text-transform:uppercase;color:#FF7040;font-weight:700;margin:0 0 8px;">{group}</p>
        <div style="display:flex;flex-direction:column;gap:8px;">
          {items.map((f) => (
            <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px 16px;display:flex;align-items:center;justify-content:space-between;gap:14px;">
              <div style="min-width:0;">
                <p style="font-size:14px;font-weight:600;color:#fff;margin:0;">{f.label}
                  <span style={'font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;margin-left:8px;padding:2px 7px;border-radius:100px;' + (f.enabled ? 'color:#10b981;background:rgba(16,185,129,0.12);' : 'color:#6e6e78;background:rgba(110,110,120,0.12);')}>{f.enabled ? 'On' : 'Off'}</span>
                </p>
                <p style="font-size:12px;color:#8a8a94;margin:3px 0 0;">{f.desc}</p>
                <p style="font-size:10.5px;color:#5b5b63;margin:3px 0 0;font-family:'Geist Mono',monospace;">value {srcLabel[f.source]} · FEATURE_{f.env}</p>
              </div>
              <form method="POST" style="flex-shrink:0;">
                <input type="hidden" name="key" value={f.key} />
                <input type="hidden" name="enabled" value={f.enabled ? '0' : '1'} />
                <button type="submit" style={'font-size:12px;font-weight:600;padding:8px 16px;border-radius:8px;cursor:pointer;border:1px solid #1a1a1f;' + (f.enabled ? 'background:#15151a;color:#fca5a5;' : 'background:#FF4F00;color:#fff;border-color:#FF4F00;')}>{f.enabled ? 'Turn off' : 'Turn on'}</button>
              </form>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</AdminLayout>
