---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const url = new URL(Astro.request.url);
const verdictFilter = url.searchParams.get('verdict') || '';
const methodFilter = url.searchParams.get('method') || '';

let rows: any[] = [];
let stats = { verified: 0, rejected: 0, question_verified: 0, total: 0, faceEnrolled: 0 };

try {
  const r = await db.execute(sql`
    SELECT v.id, v.user_id, v.email, v.claimed_name, v.claimed_dob, v.id_card_type,
      v.face_match_distance, v.face_match_passed, v.verdict, v.reject_reason,
      v.method, v.score, v.metadata, v.ip_address, v.created_at,
      u.name as user_name, u.role as user_role
    FROM identity_verifications v LEFT JOIN users u ON v.user_id = u.id
    ${verdictFilter ? sql`WHERE v.verdict = ${verdictFilter}` : sql``}
    ${methodFilter ? (verdictFilter ? sql`AND v.method = ${methodFilter}` : sql`WHERE v.method = ${methodFilter}`) : sql``}
    ORDER BY v.created_at DESC LIMIT 200
  `);
  rows = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT
      COUNT(*) FILTER (WHERE verdict = 'verified')::int as verified,
      COUNT(*) FILTER (WHERE verdict = 'rejected')::int as rejected,
      COUNT(*) FILTER (WHERE verdict = 'question_verified')::int as question_verified,
      COUNT(*)::int as total
    FROM identity_verifications
  `);
  const r2 = Array.isArray(r) ? r : (r?.rows || []);
  Object.assign(stats, (r2[0] as any) || {});
  const f = await db.execute(sql`SELECT COUNT(*)::int as n FROM user_face_enrollments WHERE is_active = true`);
  const fRows = Array.isArray(f) ? f : (f?.rows || []);
  stats.faceEnrolled = (fRows[0] as any)?.n || 0;
} catch (_) {}

function fmtTime(d: any) {
  if (!d) return '-';
  try { return new Date(d).toLocaleString('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); } catch { return d; }
}
function fmtDob(d: any) {
  if (!d) return '-';
  try { return new Date(d).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }); } catch { return d; }
}
const verdictColor = (v: string) => v === 'verified' || v === 'question_verified' ? '#7dd3a8' : v === 'rejected' ? '#e07a6c' : '#8a8579';
---
<AdminLayout title="Identity Verifications" activeNav="identity-verifications">
  <div style="max-width:1280px;margin:0 auto;padding:24px;color:#f4f1ea;font-family:'Space Grotesk',system-ui,sans-serif;">

    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:14px;flex-wrap:wrap;margin-bottom:18px;">
      <div>
        <p style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#d97757;margin:0 0 6px;font-weight:500;">Identity &middot; Secure intake</p>
        <h1 style="font-family:'Instrument Serif',serif;font-size:clamp(28px,3vw,40px);font-weight:400;color:#f4f1ea;margin:0;">Verifications &amp; face enrollments</h1>
        <p style="font-size:13px;color:#c8c3b8;margin:8px 0 0;max-width:680px;line-height:1.55;">Every gov-ID + face match attempt and self-serve question-set recovery, with verdict + score + per-attempt detail. Click an entry to see metadata.</p>
      </div>
    </div>

    <!-- KPIs -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:10px;margin-bottom:18px;">
      {[
        ['Total attempts', stats.total, '#f4f1ea'],
        ['Verified', stats.verified, '#7dd3a8'],
        ['Question-verified', stats.question_verified, '#7dd3a8'],
        ['Rejected', stats.rejected, '#e07a6c'],
        ['Face enrolled', stats.faceEnrolled, '#7fb3ff'],
      ].map(([label, val, color]) => (
        <div style="background:#14181d;border:1px solid #2a3038;border-radius:10px;padding:12px 14px;">
          <p style="font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;margin:0 0 6px;font-weight:500;">{label}</p>
          <p style={'font-family:JetBrains Mono,monospace;font-size:22px;font-weight:600;margin:0;font-variant-numeric:tabular-nums;color:' + color + ';'}>{val}</p>
        </div>
      ))}
    </div>

    <!-- Filters -->
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px;">
      <a href="?" style={'background:' + (!verdictFilter && !methodFilter ? '#d97757' : '#14181d') + ';color:' + (!verdictFilter && !methodFilter ? '#1a0f08' : '#c8c3b8') + ';border:1px solid #2a3038;font-family:JetBrains Mono,monospace;font-size:10px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:6px 12px;border-radius:999px;text-decoration:none;'}>All</a>
      <a href="?verdict=verified" style={'background:' + (verdictFilter === 'verified' ? '#d97757' : '#14181d') + ';color:' + (verdictFilter === 'verified' ? '#1a0f08' : '#c8c3b8') + ';border:1px solid #2a3038;font-family:JetBrains Mono,monospace;font-size:10px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:6px 12px;border-radius:999px;text-decoration:none;'}>Verified</a>
      <a href="?verdict=rejected" style={'background:' + (verdictFilter === 'rejected' ? '#d97757' : '#14181d') + ';color:' + (verdictFilter === 'rejected' ? '#1a0f08' : '#c8c3b8') + ';border:1px solid #2a3038;font-family:JetBrains Mono,monospace;font-size:10px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:6px 12px;border-radius:999px;text-decoration:none;'}>Rejected</a>
      <a href="?method=id_face" style={'background:' + (methodFilter === 'id_face' ? '#d97757' : '#14181d') + ';color:' + (methodFilter === 'id_face' ? '#1a0f08' : '#c8c3b8') + ';border:1px solid #2a3038;font-family:JetBrains Mono,monospace;font-size:10px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:6px 12px;border-radius:999px;text-decoration:none;'}>ID + face</a>
      <a href="?method=question_set" style={'background:' + (methodFilter === 'question_set' ? '#d97757' : '#14181d') + ';color:' + (methodFilter === 'question_set' ? '#1a0f08' : '#c8c3b8') + ';border:1px solid #2a3038;font-family:JetBrains Mono,monospace;font-size:10px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:6px 12px;border-radius:999px;text-decoration:none;'}>Questions</a>
      <a href="?method=self_enroll" style={'background:' + (methodFilter === 'self_enroll' ? '#d97757' : '#14181d') + ';color:' + (methodFilter === 'self_enroll' ? '#1a0f08' : '#c8c3b8') + ';border:1px solid #2a3038;font-family:JetBrains Mono,monospace;font-size:10px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:6px 12px;border-radius:999px;text-decoration:none;'}>Self-enroll</a>
    </div>

    {rows.length === 0 && (
      <div style="background:#14181d;border:1px solid #2a3038;border-radius:14px;padding:30px;text-align:center;color:#8a8579;font-size:13px;">No verification attempts match this filter.</div>
    )}

    {rows.length > 0 && (
      <div style="background:#14181d;border:1px solid #2a3038;border-radius:14px;overflow:hidden;">
        <div style="display:grid;grid-template-columns:1.4fr 1.2fr 90px 100px 100px 1fr 90px;gap:10px;padding:10px 14px;background:#1c2128;border-bottom:1px solid #2a3038;font-family:JetBrains Mono,monospace;font-size:9px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;font-weight:500;">
          <div>Candidate</div><div>Email</div><div>Method</div><div>Verdict</div><div>Score / Dist.</div><div>Reason / detail</div><div>When</div>
        </div>
        {rows.map((r: any) => {
          const sev = verdictColor(r.verdict);
          const isPass = r.verdict === 'verified' || r.verdict === 'question_verified';
          return (
            <div style="display:grid;grid-template-columns:1.4fr 1.2fr 90px 100px 100px 1fr 90px;gap:10px;padding:11px 14px;border-bottom:1px solid #1c2128;align-items:center;">
              <div style="min-width:0;">
                <p style="font-size:12.5px;font-weight:600;color:#f4f1ea;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{r.claimed_name || r.user_name || '-'}</p>
                <p style="font-size:10.5px;color:#8a8579;font-family:JetBrains Mono,monospace;margin:2px 0 0;">{r.user_role || '-'} &middot; DOB {fmtDob(r.claimed_dob)}</p>
              </div>
              <p style="font-size:11.5px;color:#c8c3b8;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-family:JetBrains Mono,monospace;">{r.email || '-'}</p>
              <p style="font-size:11px;color:#7fb3ff;font-family:JetBrains Mono,monospace;letter-spacing:0.1em;text-transform:uppercase;margin:0;">{r.method || 'id_face'}</p>
              <p style="font-size:11px;margin:0;">
                <span style={'background:' + sev + '22;color:' + sev + ';border:1px solid ' + sev + '55;padding:3px 10px;border-radius:999px;font-family:JetBrains Mono,monospace;font-size:9.5px;letter-spacing:0.12em;text-transform:uppercase;font-weight:600;'}>{r.verdict || '-'}</span>
              </p>
              <p style="font-size:11.5px;color:#c8c3b8;font-family:JetBrains Mono,monospace;margin:0;font-variant-numeric:tabular-nums;">
                {r.face_match_distance != null ? 'd=' + parseFloat(r.face_match_distance).toFixed(3) : ''}
                {r.score != null ? (r.face_match_distance != null ? ' / ' : '') + 's=' + parseFloat(r.score).toFixed(2) : ''}
                {r.face_match_distance == null && r.score == null ? '-' : ''}
              </p>
              <p style="font-size:11px;color:#c8c3b8;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                {r.reject_reason || (isPass ? '' : '-')}
              </p>
              <p style="font-size:10.5px;color:#8a8579;font-family:JetBrains Mono,monospace;margin:0;">{fmtTime(r.created_at)}</p>
            </div>
          );
        })}
      </div>
    )}

    <div style="margin-top:20px;display:flex;gap:8px;flex-wrap:wrap;">
      <a href="/identity-setup" target="_blank" class="btn-atlas ghost">View public identity-setup page</a>
      <a href="/verify-by-questions" target="_blank" class="btn-atlas ghost">View public question-set recovery</a>
    </div>
  </div>
</AdminLayout>
