---
// /admin/search — search index status + reindex + query analytics (Prompt 12, admin surface).
// Gated by can(audit, search). Reindex is manage-gated (via /api/admin/search-reindex).
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { indexStatus, topQueries } from '@/lib/search-index';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'audit', { type: 'search' });
if (!gate.allow) return Astro.redirect('/admin');
const canManage = (await can(user, 'manage', { type: 'search' })).allow;

const status = await indexStatus().catch(() => ({ count: 0, lastUpdated: null }));
const queries = await topQueries(25).catch(() => []);

const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
function fmt(d: any) { try { return d ? new Date(d).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) : 'never'; } catch { return '-'; } }
---
<AdminLayout title="Search index" activeNav="search">
  <div style="max-width:1000px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Discovery</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Search index</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">Server-side index over published kernel objects. Student surface: <a href="/aquintutor/search" style="color:#FF7040;">/aquintutor/search</a>.</p>
    <div id="msg" style="display:none;margin:12px 0;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;margin-bottom:16px;">
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Indexed objects</p><p style="font-size:26px;font-weight:800;color:#fff;margin:4px 0 0;">{status.count}</p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Last reindex</p><p style="font-size:15px;font-weight:700;color:#cfd6da;margin:8px 0 0;">{fmt(status.lastUpdated)}</p></div>
      <div style={CARD + 'margin:0;display:flex;align-items:center;justify-content:center;'}>{canManage ? <button id="reindexBtn" type="button" style="background:#FF4F00;border:none;color:#fff;font-size:12px;font-weight:700;padding:10px 18px;border-radius:8px;cursor:pointer;">Reindex now</button> : <span style="font-size:11px;color:#6e6e78;">reindex needs manage</span>}</div>
    </div>

    <div style={CARD}>
      <p style={HD}>Top search queries</p>
      {queries.length === 0 ? <p style="font-size:12px;color:#6e6e78;margin:0;">No searches logged yet.</p> :
      <div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:12.5px;">
        <thead><tr style="color:#8a8a94;font-size:9px;text-transform:uppercase;font-family:'Geist Mono',monospace;text-align:left;"><th style="padding:5px 8px;">Query</th><th style="padding:5px 8px;">Searches</th><th style="padding:5px 8px;">Avg results</th><th style="padding:5px 8px;">Last</th></tr></thead>
        <tbody>{queries.map((q: any) => (
          <tr style="border-top:1px solid #15151a;"><td style="padding:6px 8px;color:#cfd6da;">{q.query}</td><td style="padding:6px 8px;color:#8a8a94;">{q.n}</td><td style={'padding:6px 8px;color:' + (q.avg_results === 0 ? '#c0a35e' : '#8a8a94')}>{q.avg_results}</td><td style="padding:6px 8px;color:#8a8a94;font-family:'Geist Mono',monospace;">{fmt(q.last_at)}</td></tr>
        ))}</tbody>
      </table></div>}
    </div>
  </div>

  <script is:inline>
    (function () {
      var btn = document.getElementById('reindexBtn'); if (!btn) return; var msg = document.getElementById('msg');
      btn.addEventListener('click', function () {
        btn.disabled = true; btn.textContent = 'Reindexing…';
        fetch('/api/admin/search-reindex', { method: 'POST' }).then(function (r) { return r.json(); }).then(function (j) {
          msg.style.display = 'block'; msg.textContent = j.ok ? ('Indexed ' + j.indexed + ' objects.') : (j.error || 'Failed'); msg.style.background = j.ok ? 'rgba(16,185,129,0.12)' : 'rgba(239,68,68,0.12)'; msg.style.color = j.ok ? '#6ee7b7' : '#fca5a5';
          if (j.ok) setTimeout(function () { location.reload(); }, 700); else { btn.disabled = false; btn.textContent = 'Reindex now'; }
        }).catch(function () { btn.disabled = false; btn.textContent = 'Reindex now'; });
      });
    })();
  </script>
</AdminLayout>
