---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { ensureCaSchema, decideAmbassador, listAmbassadors } from '@/lib/campus-ambassadors';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

await ensureCaSchema();

let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const action = (fd.get('action') as string) || '';
    const id = fd.get('id') as string;
    if (action === 'approve') {
      const stipend = parseFloat(fd.get('stipend') as string);
      const cur = (fd.get('stipend_currency') as string) || 'INR';
      await decideAmbassador({ id, status: 'approved', byUserId: user.id, stipend: isFinite(stipend) ? stipend : undefined, stipendCurrency: cur });
      okMsg = 'Ambassador approved. Their portal role has been promoted to campus_ambassador where linked.';
    } else if (action === 'reject') {
      const reason = (fd.get('reason') as string || '').slice(0, 2000);
      await decideAmbassador({ id, status: 'rejected', byUserId: user.id, reason });
      okMsg = 'Rejected.';
    } else if (action === 'revoke') {
      const reason = (fd.get('reason') as string || '').slice(0, 2000);
      await decideAmbassador({ id, status: 'revoked', byUserId: user.id, reason });
      okMsg = 'Revoked.';
    } else if (action === 'activate') {
      await decideAmbassador({ id, status: 'active', byUserId: user.id });
      okMsg = 'Activated.';
    } else if (action === 'deactivate') {
      const reason = (fd.get('reason') as string || '').slice(0, 2000);
      await decideAmbassador({ id, status: 'inactive', byUserId: user.id, reason });
      okMsg = 'Deactivated.';
    }
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 240); }
}

const url = new URL(Astro.request.url);
const filterStatus = url.searchParams.get('status') || '';
const all = await listAmbassadors(filterStatus || undefined);

const stats = {
  total: all.length,
  pending: all.filter((a: any) => a.status === 'pending').length,
  approved: all.filter((a: any) => a.status === 'approved').length,
  active: all.filter((a: any) => a.status === 'active' || a.status === 'approved').length,
  rejected: all.filter((a: any) => a.status === 'rejected').length,
  revoked: all.filter((a: any) => a.status === 'revoked' || a.status === 'inactive').length,
};

function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }); } catch { return ''; } }

const STATUS_TONE: Record<string, string> = {
  pending: '#fbbf24',
  approved: '#86efac',
  active: '#86efac',
  rejected: '#fca5a5',
  revoked: '#fca5a5',
  inactive: '#9aa6b6',
};
---
<AdminLayout title="Campus Ambassadors" activeNav="">
<div style="padding:14px 16px 80px;max-width:1280px;margin:0 auto;">
  <p style="font-size:10.5px;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;font-family:'Geist Mono',monospace;font-weight:700;">Outreach · Programme</p>
  <h1 style="font-size:24px;color:#fff;margin:6px 0 4px;font-weight:700;">Campus Ambassadors</h1>
  <p style="font-size:13px;color:#9aa6b6;margin:0 0 18px;">Applications from /careers/campus-ambassador. Approve to unlock the CAmb submission flow + promote their portal role.</p>

  {okMsg && <div style="background:rgba(74,222,128,0.10);border:1px solid rgba(74,222,128,0.32);color:#86efac;border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;">{okMsg}</div>}
  {errMsg && <div style="background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.32);color:#fca5a5;border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;">{errMsg}</div>}

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:8px;margin-bottom:18px;">
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px 14px;"><p style="font-size:10px;color:#9aa6b6;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 4px;font-family:'Geist Mono',monospace;">Total</p><p style="font-size:24px;color:#fff;margin:0;font-weight:700;">{stats.total}</p></div>
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px 14px;"><p style="font-size:10px;color:#fbbf24;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 4px;font-family:'Geist Mono',monospace;">Pending review</p><p style="font-size:24px;color:#fff;margin:0;font-weight:700;">{stats.pending}</p></div>
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px 14px;"><p style="font-size:10px;color:#86efac;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 4px;font-family:'Geist Mono',monospace;">Active ambassadors</p><p style="font-size:24px;color:#fff;margin:0;font-weight:700;">{stats.active}</p></div>
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px 14px;"><p style="font-size:10px;color:#fca5a5;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 4px;font-family:'Geist Mono',monospace;">Rejected</p><p style="font-size:24px;color:#fff;margin:0;font-weight:700;">{stats.rejected}</p></div>
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px 14px;"><p style="font-size:10px;color:#9aa6b6;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 4px;font-family:'Geist Mono',monospace;">Revoked / inactive</p><p style="font-size:24px;color:#fff;margin:0;font-weight:700;">{stats.revoked}</p></div>
  </div>

  <form method="GET" style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;">
    <select name="status" style="background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12.5px;">
      <option value="">All statuses</option>
      <option value="pending" selected={filterStatus === 'pending'}>Pending</option>
      <option value="approved" selected={filterStatus === 'approved'}>Approved</option>
      <option value="active" selected={filterStatus === 'active'}>Active</option>
      <option value="inactive" selected={filterStatus === 'inactive'}>Inactive</option>
      <option value="rejected" selected={filterStatus === 'rejected'}>Rejected</option>
      <option value="revoked" selected={filterStatus === 'revoked'}>Revoked</option>
    </select>
    <button type="submit" style="background:#15151a;border:1px solid #2a2a2f;color:#FF7040;padding:9px 16px;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer;">Filter</button>
  </form>

  {all.length === 0 ? (<div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:36px;text-align:center;color:#6e6e78;font-size:13px;">No CAmb applications match.</div>) : (
    <div style="display:flex;flex-direction:column;gap:8px;">
      {all.map((a: any) => {
        const tone = STATUS_TONE[a.status] || '#9aa6b6';
        const handles = a.social_handles || {};
        return (
          <details style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:0;">
            <summary style="cursor:pointer;padding:14px 18px;list-style:none;display:grid;grid-template-columns:1.4fr 1.2fr 1fr 110px 90px;gap:12px;align-items:center;">
              <div><p style="font-size:13.5px;color:#fff;font-weight:700;margin:0;">{a.applicant_name}</p><p style="font-size:10.5px;color:#9aa6b6;margin:2px 0 0;font-family:'Geist Mono',monospace;">{a.applicant_email}</p></div>
              <p style="font-size:11.5px;color:#cfd6da;margin:0;">{a.institution}</p>
              <p style="font-size:11px;color:#67e8f9;margin:0;font-family:'Geist Mono',monospace;">{a.course_year || '—'} · {a.country}</p>
              <span style={`background:${tone}22;color:${tone};font-size:10px;font-weight:700;padding:3px 8px;border-radius:100px;text-align:center;font-family:'Geist Mono',monospace;letter-spacing:0.06em;text-transform:uppercase;`}>{a.status}</span>
              <p style="font-size:10.5px;color:#6e6e78;margin:0;font-family:'Geist Mono',monospace;">{fmt(a.created_at)}</p>
            </summary>
            <div style="padding:0 18px 18px;border-top:1px solid #1a1a1f;">
              <div style="margin:14px 0;"><p style="font-size:10.5px;color:#FF7040;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;font-weight:700;margin:0 0 6px;">Why they want to join</p><p style="font-size:12.5px;color:#d8d8de;margin:0;line-height:1.65;white-space:pre-wrap;">{a.why_join}</p></div>
              {a.outreach_plan && <div style="margin:14px 0;"><p style="font-size:10.5px;color:#FF7040;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;font-weight:700;margin:0 0 6px;">Outreach plan (Q1)</p><p style="font-size:12.5px;color:#d8d8de;margin:0;line-height:1.65;white-space:pre-wrap;">{a.outreach_plan}</p></div>}

              <div style="display:flex;gap:14px;flex-wrap:wrap;margin:14px 0;">
                {a.applicant_phone && <p style="font-size:11.5px;color:#9aa6b6;margin:0;font-family:'Geist Mono',monospace;">📞 {a.applicant_phone}</p>}
                {handles.instagram && <a href={'https://instagram.com/' + handles.instagram.replace('@','')} target="_blank" style="font-size:11.5px;color:#67e8f9;font-family:'Geist Mono',monospace;">IG: {handles.instagram}</a>}
                {handles.linkedin && <a href={handles.linkedin} target="_blank" style="font-size:11.5px;color:#67e8f9;font-family:'Geist Mono',monospace;">LinkedIn ↗</a>}
                {handles.twitter && <a href={'https://twitter.com/' + handles.twitter.replace('@','')} target="_blank" style="font-size:11.5px;color:#67e8f9;font-family:'Geist Mono',monospace;">X: {handles.twitter}</a>}
              </div>

              {a.stipend_amount && <div style="margin:10px 0;padding:8px 14px;background:rgba(255,79,0,0.06);border-left:3px solid #FF4F00;border-radius:0 6px 6px 0;"><p style="font-size:11px;color:#FF7040;margin:0;font-family:'Geist Mono',monospace;font-weight:700;">Stipend: {a.stipend_currency} {Number(a.stipend_amount).toFixed(2)} / month</p></div>}
              {a.revocation_reason && <div style="margin:10px 0;padding:10px 14px;background:rgba(252,165,165,0.06);border-left:3px solid #fca5a5;border-radius:0 6px 6px 0;"><p style="font-size:10.5px;color:#fca5a5;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;font-weight:700;margin:0 0 4px;">Revocation reason · {fmt(a.revoked_at)}</p><p style="font-size:12px;color:#d8d8de;margin:0;line-height:1.6;">{a.revocation_reason}</p></div>}

              {a.status === 'pending' && (
                <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:14px;padding-top:14px;border-top:1px solid #1a1a1f;">
                  <form method="POST" style="display:flex;gap:6px;align-items:center;">
                    <input type="hidden" name="action" value="approve" /><input type="hidden" name="id" value={a.id} />
                    <input name="stipend" type="number" step="0.01" placeholder="Stipend" style="width:100px;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:7px 10px;border-radius:5px;font-size:11.5px;" />
                    <select name="stipend_currency" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:7px 10px;border-radius:5px;font-size:11.5px;"><option value="INR">INR</option><option value="USD">USD</option><option value="CHF">CHF</option></select>
                    <button type="submit" style="background:#86efac18;border:1px solid #86efac;color:#86efac;padding:7px 16px;border-radius:5px;font-size:11.5px;font-weight:700;cursor:pointer;font-family:'Geist Mono',monospace;">Approve</button>
                  </form>
                  <form method="POST" onsubmit="this.querySelector('[name=reason]').value = prompt('Reason for rejection (visible on record):') || ''; return !!this.querySelector('[name=reason]').value;" style="display:flex;gap:6px;align-items:center;">
                    <input type="hidden" name="action" value="reject" /><input type="hidden" name="id" value={a.id} /><input type="hidden" name="reason" />
                    <button type="submit" style="background:#fca5a518;border:1px solid #fca5a5;color:#fca5a5;padding:7px 16px;border-radius:5px;font-size:11.5px;font-weight:700;cursor:pointer;font-family:'Geist Mono',monospace;">Reject</button>
                  </form>
                </div>
              )}
              {(a.status === 'approved' || a.status === 'active') && (
                <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:14px;padding-top:14px;border-top:1px solid #1a1a1f;">
                  {a.status === 'approved' && <form method="POST"><input type="hidden" name="action" value="activate" /><input type="hidden" name="id" value={a.id} /><button type="submit" style="background:#67e8f918;border:1px solid #67e8f9;color:#67e8f9;padding:7px 16px;border-radius:5px;font-size:11.5px;font-weight:700;cursor:pointer;font-family:'Geist Mono',monospace;">Mark Active</button></form>}
                  <form method="POST" onsubmit="this.querySelector('[name=reason]').value = prompt('Reason for deactivation:') || ''; return !!this.querySelector('[name=reason]').value;"><input type="hidden" name="action" value="deactivate" /><input type="hidden" name="id" value={a.id} /><input type="hidden" name="reason" /><button type="submit" style="background:#9aa6b618;border:1px solid #9aa6b6;color:#9aa6b6;padding:7px 16px;border-radius:5px;font-size:11.5px;font-weight:700;cursor:pointer;font-family:'Geist Mono',monospace;">Deactivate</button></form>
                  <form method="POST" onsubmit="this.querySelector('[name=reason]').value = prompt('Reason for revocation (visible on record):') || ''; return !!this.querySelector('[name=reason]').value;"><input type="hidden" name="action" value="revoke" /><input type="hidden" name="id" value={a.id} /><input type="hidden" name="reason" /><button type="submit" style="background:#fca5a518;border:1px solid #fca5a5;color:#fca5a5;padding:7px 16px;border-radius:5px;font-size:11.5px;font-weight:700;cursor:pointer;font-family:'Geist Mono',monospace;">Revoke</button></form>
                </div>
              )}
            </div>
          </details>
        );
      })}
    </div>
  )}
</div>
</AdminLayout>
