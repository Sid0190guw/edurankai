---
// /admin/credential-transfer — a real, DB-backed ops tool that runs the AES-100
// Vol III P3 Ch11 (Planetary Education) engine on live records: sovereign credential
// RECOGNITION, cross-system grade/credit EQUIVALENCE, and learner MOBILITY. Not a
// demo — institutions, recognition agreements and credentials persist in Postgres
// (self-bootstrapped tables) and the engine (src/lib/credit-transfer.ts) decides
// what transfers and converts the numbers.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { addInstitution, listInstitutions, addRecognition, removeRecognition, listRecognitions, addCredential, listCredentials, listLearners, seedIfEmpty } from '@/lib/credential-store';
import { buildWorld, evaluateMobility, GRADE_SYSTEMS, CREDIT_SYSTEMS, type GradeSystem, type CreditSystem, type MobilityResult } from '@/lib/credit-transfer';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

let okMsg = '', errMsg = '';
let result: MobilityResult | null = null;
let selLearner = '', selTarget = '';

try {
  await seedIfEmpty();
  if (Astro.request.method === 'POST') {
    const fd = await Astro.request.formData();
    const action = (fd.get('action') as string) || '';
    if (action === 'add-institution') {
      const name = ((fd.get('name') as string) || '').trim();
      if (!name) throw new Error('Institution name is required.');
      await addInstitution(name, ((fd.get('country') as string) || '').trim(), (fd.get('gradeSystem') as GradeSystem) || 'gpa4', (fd.get('creditSystem') as CreditSystem) || 'us', ((fd.get('accreditation') as string) || '').trim());
      okMsg = `Institution "${name}" saved.`;
    } else if (action === 'add-recognition') {
      await addRecognition((fd.get('byInst') as string) || '', (fd.get('ofInst') as string) || '');
      okMsg = 'Recognition agreement saved.';
    } else if (action === 'remove-recognition') {
      await removeRecognition((fd.get('byInst') as string) || '', (fd.get('ofInst') as string) || '');
      okMsg = 'Recognition agreement removed.';
    } else if (action === 'add-credential') {
      const issuer = (fd.get('issuer') as string) || '', learner = ((fd.get('learner') as string) || '').trim();
      if (!issuer || !learner) throw new Error('Issuer and learner are required.');
      const gradeRaw = ((fd.get('grade') as string) || '').trim();
      await addCredential(issuer, learner, ((fd.get('type') as string) || 'course').trim(), parseFloat((fd.get('credits') as string) || '0') || 0, gradeRaw === '' ? null : parseFloat(gradeRaw));
      okMsg = `Credential recorded for ${learner}.`;
    } else if (action === 'evaluate') {
      selLearner = (fd.get('learner') as string) || '';
      selTarget = (fd.get('target') as string) || '';
    }
  }
} catch (e: any) { errMsg = String(e?.cause?.message || e?.message || e).slice(0, 260); }

const institutions = await listInstitutions();
const recognitions = await listRecognitions();
const credentials = await listCredentials();
const learners = await listLearners();
if (!selLearner && learners.length) selLearner = learners[0];
if (!selTarget && institutions.length) selTarget = institutions[0].id;

if (selLearner && selTarget) {
  result = evaluateMobility(buildWorld(institutions, recognitions, credentials), selLearner, selTarget);
}
const instName = (id: string) => institutions.find((i) => i.id === id)?.name || id;

const IN = 'width:100%;background:#15151a;border:1px solid #1a1a1f;color:#fff;padding:8px 10px;border-radius:6px;font-size:13px;margin-top:4px;';
const LB = 'font-size:10px;color:#8a8a94;text-transform:uppercase;font-family:Geist Mono,monospace;';
const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin:16px 0;';
---
<AdminLayout title="Credential Transfer" activeNav="credential-transfer">
  <div style="max-width:1040px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">AES-100 · Ch11 Planetary Education · live</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Credential recognition &amp; transfer</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">Runs the sovereign-recognition + cross-system equivalence engine on real records. An institution recognises a credential only if it chose to (an agreement, or a shared accreditation body); grades and credits are converted through a common quality / learning-hours scale. Records persist in the database.</p>

    {okMsg && <div style="background:rgba(16,185,129,0.12);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;padding:10px 14px;border-radius:8px;margin:14px 0;font-size:13px;">{okMsg}</div>}
    {errMsg && <div style="background:rgba(239,68,68,0.12);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;padding:10px 14px;border-radius:8px;margin:14px 0;font-size:13px;">{errMsg}</div>}

    <!-- ===== MOBILITY EVALUATOR (the engine, live) ===== -->
    <div style="background:#0d1117;border:1px solid #67e8f9;border-radius:14px;padding:18px;margin:16px 0;">
      <p style="font-size:11px;color:#67e8f9;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;margin:0 0 12px;font-weight:700;">Evaluate a learner's transfer</p>
      <form method="POST" style="display:grid;grid-template-columns:1fr 1fr auto;gap:10px;align-items:end;">
        <input type="hidden" name="action" value="evaluate" />
        <div><label style={LB}>Learner</label>
          <select name="learner" style={IN}>
            {learners.map((l) => <option value={l} selected={l === selLearner}>{l}</option>)}
          </select></div>
        <div><label style={LB}>Transferring to</label>
          <select name="target" style={IN}>
            {institutions.map((i) => <option value={i.id} selected={i.id === selTarget}>{i.name}</option>)}
          </select></div>
        <button type="submit" style="background:#FF4F00;color:#fff;border:none;font-size:13px;font-weight:700;padding:9px 18px;border-radius:8px;cursor:pointer;">Evaluate</button>
      </form>

      {result && (
        <div style="margin-top:16px;">
          <p style="font-size:12.5px;color:#cfd6da;margin:0 0 10px;">
            <b style="color:#fff;">{result.learner}</b> → <b style="color:#fff;">{result.to}</b> ·
            <span style="color:#6ee7b7;"> {result.transferred.length} recognised</span> ·
            <span style="color:#fca5a5;"> {result.notRecognized.length} rejected</span> ·
            <span style="color:#67e8f9;"> {result.totalCreditsTransferred} credits carried</span>
          </p>
          {result.transferred.map((t) => (
            <div style="background:#0f0f14;border:1px solid rgba(16,185,129,0.25);border-radius:10px;padding:11px 14px;margin:8px 0;">
              <div style="display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;">
                <span style="font-size:13px;color:#fff;font-weight:600;">{t.type} <span style="color:#8a8a94;font-weight:400;">· from {t.from}</span></span>
                <span style="font-size:10px;color:#6ee7b7;font-family:'Geist Mono',monospace;text-transform:uppercase;">recognised · {t.via}</span>
              </div>
              {t.converted && (
                <div style="font-size:11.5px;color:#cfd6da;font-family:'Geist Mono',monospace;margin-top:6px;">
                  grade {t.converted.fromGrade ?? '-'} ({t.converted.fromSystem}) → {t.converted.toGrade ?? '-'} ({t.converted.toSystem}) &nbsp;|&nbsp; credits {t.converted.fromCredits} → {t.converted.toCredits} {t.converted.toCreditSystem}
                </div>
              )}
            </div>
          ))}
          {result.notRecognized.map((t) => (
            <div style="background:#0f0f14;border:1px solid rgba(239,68,68,0.25);border-radius:10px;padding:11px 14px;margin:8px 0;">
              <div style="display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;">
                <span style="font-size:13px;color:#fff;font-weight:600;">{t.type} <span style="color:#8a8a94;font-weight:400;">· from {t.from}</span></span>
                <span style="font-size:10px;color:#fca5a5;font-family:'Geist Mono',monospace;text-transform:uppercase;">not recognised</span>
              </div>
              <div style="font-size:11.5px;color:#fca5a5;margin-top:6px;">{t.reason}</div>
            </div>
          ))}
          {result.transferred.length === 0 && result.notRecognized.length === 0 && <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;">This learner has no credentials on record.</p>}
        </div>
      )}
    </div>

    <!-- ===== forms: institutions / recognition / credentials ===== -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
      <details style={CARD} open>
        <summary style="cursor:pointer;font-size:13px;font-weight:700;color:#fff;">+ Add institution</summary>
        <form method="POST" style="margin-top:12px;display:grid;gap:10px;">
          <input type="hidden" name="action" value="add-institution" />
          <div><label style={LB}>Name</label><input name="name" placeholder="State University" style={IN} required /></div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <div><label style={LB}>Country</label><input name="country" placeholder="US" style={IN} /></div>
            <div><label style={LB}>Accreditation body</label><input name="accreditation" placeholder="ABET" style={IN} /></div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <div><label style={LB}>Grade system</label><select name="gradeSystem" style={IN}>{GRADE_SYSTEMS.map((g) => <option value={g}>{g}</option>)}</select></div>
            <div><label style={LB}>Credit system</label><select name="creditSystem" style={IN}>{CREDIT_SYSTEMS.map((c) => <option value={c}>{c}</option>)}</select></div>
          </div>
          <button type="submit" style="justify-self:start;background:#FF4F00;color:#fff;border:none;font-size:13px;font-weight:700;padding:9px 16px;border-radius:8px;cursor:pointer;">Save institution</button>
        </form>
      </details>

      <details style={CARD} open>
        <summary style="cursor:pointer;font-size:13px;font-weight:700;color:#fff;">+ Record a credential</summary>
        <form method="POST" style="margin-top:12px;display:grid;gap:10px;">
          <input type="hidden" name="action" value="add-credential" />
          <div><label style={LB}>Issuing institution</label><select name="issuer" style={IN}>{institutions.map((i) => <option value={i.id}>{i.name} ({i.gradeSystem}/{i.creditSystem})</option>)}</select></div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <div><label style={LB}>Learner</label><input name="learner" placeholder="learner-1" style={IN} required /></div>
            <div><label style={LB}>Course / type</label><input name="type" placeholder="Thermodynamics" style={IN} /></div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <div><label style={LB}>Credits</label><input name="credits" type="number" step="0.5" placeholder="3" style={IN} /></div>
            <div><label style={LB}>Grade (in issuer's system)</label><input name="grade" type="number" step="0.01" placeholder="3.6" style={IN} /></div>
          </div>
          <button type="submit" style="justify-self:start;background:#FF4F00;color:#fff;border:none;font-size:13px;font-weight:700;padding:9px 16px;border-radius:8px;cursor:pointer;">Record credential</button>
        </form>
      </details>
    </div>

    <details style={CARD}>
      <summary style="cursor:pointer;font-size:13px;font-weight:700;color:#fff;">+ Add recognition agreement (sovereign choice)</summary>
      <form method="POST" style="margin-top:12px;display:grid;grid-template-columns:1fr auto 1fr auto;gap:10px;align-items:end;">
        <input type="hidden" name="action" value="add-recognition" />
        <div><label style={LB}>This institution</label><select name="byInst" style={IN}>{institutions.map((i) => <option value={i.id}>{i.name}</option>)}</select></div>
        <span style="color:#8a8a94;font-size:12px;padding-bottom:9px;">recognises →</span>
        <div><label style={LB}>Credentials from</label><select name="ofInst" style={IN}>{institutions.map((i) => <option value={i.id}>{i.name}</option>)}</select></div>
        <button type="submit" style="background:#FF4F00;color:#fff;border:none;font-size:13px;font-weight:700;padding:9px 16px;border-radius:8px;cursor:pointer;">Add</button>
      </form>
      <div style="margin-top:12px;">
        {recognitions.length === 0 && <p style="font-size:12px;color:#8a8a94;margin:0;">No agreements yet. Without one, an institution only recognises its own credentials or those sharing its accreditation body.</p>}
        {recognitions.map((r) => (
          <div style="display:flex;align-items:center;gap:8px;font-size:12.5px;color:#cfd6da;padding:5px 0;">
            <span><b style="color:#fff;">{instName(r.byInst)}</b> recognises <b style="color:#fff;">{instName(r.ofInst)}</b></span>
            <form method="POST" style="display:inline;"><input type="hidden" name="action" value="remove-recognition" /><input type="hidden" name="byInst" value={r.byInst} /><input type="hidden" name="ofInst" value={r.ofInst} />
              <button type="submit" style="background:rgba(239,68,68,0.12);color:#fca5a5;border:1px solid rgba(239,68,68,0.3);font-size:10px;padding:2px 8px;border-radius:5px;cursor:pointer;">remove</button></form>
          </div>
        ))}
      </div>
    </details>

    <!-- ===== registers ===== -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:16px;">
      <div style={CARD}>
        <p style="font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;margin:0 0 10px;font-weight:700;">Institutions ({institutions.length})</p>
        {institutions.map((i) => (
          <div style="font-size:12.5px;color:#cfd6da;padding:6px 0;border-bottom:1px solid #15151a;">
            <b style="color:#fff;">{i.name}</b> <span style="color:#8a8a94;">· {i.country || '—'} · {i.gradeSystem}/{i.creditSystem}{i.accreditation ? ' · ' + i.accreditation : ''}</span>
          </div>
        ))}
      </div>
      <div style={CARD}>
        <p style="font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;margin:0 0 10px;font-weight:700;">Credentials ({credentials.length})</p>
        {credentials.slice(0, 30).map((c) => (
          <div style="font-size:12.5px;color:#cfd6da;padding:6px 0;border-bottom:1px solid #15151a;">
            <b style="color:#fff;">{c.learner}</b> · {c.type} <span style="color:#8a8a94;">· {instName(c.issuer)} · {c.credits}cr{c.grade != null ? ' · ' + c.grade : ''}</span>
          </div>
        ))}
        {credentials.length === 0 && <p style="font-size:12px;color:#8a8a94;margin:0;">No credentials yet.</p>}
      </div>
    </div>

    <p style="font-size:11px;color:#5a5a64;margin:18px 0 0;line-height:1.6;">Honest scope: the recognition policy, equivalence math and mobility logic are the real AES Ch11 engine, running on these live records. Cryptographic credential signing and inter-governmental accreditation treaties are declared substrates.</p>
  </div>
</AdminLayout>
