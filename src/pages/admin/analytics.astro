---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const url = new URL(Astro.request.url);
const range = url.searchParams.get('range') || '7d';

const days = range === '30d' ? 30 : range === '90d' ? 90 : 7;

let totalViews = 0, uniqueSessions = 0, onlineNow = 0;
let topPages: any[] = [];
let deviceStats: any[] = [];
let countryStats: any[] = [];
let dailyStats: any[] = [];
let recentViews: any[] = [];

try {
  const r = await db.execute(sql`
    SELECT
      COUNT(*)::int as total_views,
      COUNT(DISTINCT session_id)::int as unique_sessions
    FROM analytics_pageviews
    WHERE created_at >= NOW() - INTERVAL '1 day' * ${days}
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  const d = rows[0] as any;
  totalViews = Number(d?.total_views) || 0;
  uniqueSessions = Number(d?.unique_sessions) || 0;
} catch(e) {}

// Online now (last 5 min)
try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM analytics_sessions WHERE last_seen >= NOW() - INTERVAL '5 minutes'`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  onlineNow = Number((rows[0] as any)?.n) || 0;
} catch(e) {}

// Top pages
try {
  const r = await db.execute(sql`
    SELECT page, COUNT(*)::int as views, COUNT(DISTINCT session_id)::int as sessions
    FROM analytics_pageviews
    WHERE created_at >= NOW() - INTERVAL '1 day' * ${days}
    GROUP BY page ORDER BY views DESC LIMIT 10
  `);
  topPages = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

// Device breakdown
try {
  const r = await db.execute(sql`
    SELECT device_type, COUNT(*)::int as n
    FROM analytics_pageviews
    WHERE created_at >= NOW() - INTERVAL '1 day' * ${days} AND device_type IS NOT NULL
    GROUP BY device_type ORDER BY n DESC
  `);
  deviceStats = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

// Country breakdown
try {
  const r = await db.execute(sql`
    SELECT country, COUNT(*)::int as n
    FROM analytics_pageviews
    WHERE created_at >= NOW() - INTERVAL '1 day' * ${days} AND country IS NOT NULL
    GROUP BY country ORDER BY n DESC LIMIT 8
  `);
  countryStats = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

// Daily stats
try {
  const r = await db.execute(sql`
    SELECT DATE(created_at) as day, COUNT(*)::int as views, COUNT(DISTINCT session_id)::int as sessions
    FROM analytics_pageviews
    WHERE created_at >= NOW() - INTERVAL '1 day' * ${days}
    GROUP BY DATE(created_at) ORDER BY day ASC
  `);
  dailyStats = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

// Recent views
try {
  const r = await db.execute(sql`
    SELECT page, device_type, country, browser, created_at
    FROM analytics_pageviews
    ORDER BY created_at DESC LIMIT 20
  `);
  recentViews = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

function timeAgo(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff/60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins + 'm ago';
  return Math.floor(mins/60) + 'h ago';
}

const maxViews = topPages.length > 0 ? Math.max(...(topPages as any[]).map((p: any) => p.views)) : 1;
const maxDaily = dailyStats.length > 0 ? Math.max(...(dailyStats as any[]).map((d: any) => d.views)) : 1;
---
<AdminLayout title="Analytics" activeNav="analytics">
<div style="padding-bottom:80px;">

  <!-- Header -->
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
      <div>
        <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">Insights</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Analytics</h1>
      </div>
      <div style="display:flex;align-items:center;gap:6px;">
        <div style="display:flex;align-items:center;gap:5px;background:#0f0f14;border:1px solid rgba(16,185,129,0.3);border-radius:100px;padding:4px 10px;">
          <div style="width:7px;height:7px;background:#10b981;border-radius:50%;animation:pulse 2s infinite;"></div>
          <span style="font-size:11px;font-weight:600;color:#10b981;">{onlineNow} online</span>
        </div>
      </div>
    </div>
    <div style="display:flex;gap:5px;">
      {[['7d','7 days'],['30d','30 days'],['90d','90 days']].map(([v,l]) => (
        <a href={`?range=${v}`} style={`text-decoration:none;font-size:11px;font-weight:600;padding:5px 12px;border-radius:100px;${range===v?'background:#FF4F00;color:#fff;':'background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;'}`}>{l}</a>
      ))}
    </div>
  </div>

  <div style="padding:14px 16px;display:flex;flex-direction:column;gap:12px;">

    <!-- Key stats -->
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;">
      {[
        { label: 'Page Views', value: totalViews, color: '#FF7040' },
        { label: 'Sessions', value: uniqueSessions, color: '#60a5fa' },
        { label: 'Online Now', value: onlineNow, color: '#10b981' },
      ].map(s => (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px;text-align:center;">
          <p style={`font-size:24px;font-weight:800;color:${s.color};margin:0;line-height:1;font-family:'Geist Mono',monospace;`}>{s.value}</p>
          <p style="font-size:9px;color:#6e6e78;margin:4px 0 0;text-transform:uppercase;">{s.label}</p>
        </div>
      ))}
    </div>

    <!-- Daily chart -->
    {dailyStats.length > 0 && (
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;">
        <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0 0 12px;">Daily Traffic</p>
        <div style="display:flex;align-items:flex-end;gap:3px;height:80px;">
          {(dailyStats as any[]).map((d: any) => {
            const h = maxDaily > 0 ? Math.max(4, Math.round((d.views / maxDaily) * 80)) : 4;
            return (
              <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;">
                <div style={`width:100%;background:#FF4F00;border-radius:2px;height:${h}px;`} title={d.views + ' views'}></div>
              </div>
            );
          })}
        </div>
        <div style="display:flex;justify-content:space-between;margin-top:6px;">
          <span style="font-size:9px;color:#6e6e78;font-family:'Geist Mono',monospace;">{dailyStats.length > 0 ? new Date((dailyStats[0] as any).day).toLocaleDateString('en-IN',{day:'numeric',month:'short'}) : ''}</span>
          <span style="font-size:9px;color:#6e6e78;font-family:'Geist Mono',monospace;">{dailyStats.length > 0 ? new Date((dailyStats[dailyStats.length-1] as any).day).toLocaleDateString('en-IN',{day:'numeric',month:'short'}) : ''}</span>
        </div>
      </div>
    )}

    <!-- Top pages -->
    {topPages.length > 0 && (
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;">
        <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0 0 12px;">Top Pages</p>
        <div style="display:flex;flex-direction:column;gap:6px;">
          {(topPages as any[]).map((p: any) => {
            const pct = maxViews > 0 ? Math.round((p.views / maxViews) * 100) : 0;
            return (
              <div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:3px;">
                  <span style="font-size:11px;color:#d8d8de;font-family:'Geist Mono',monospace;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:60%;">{p.page || '/'}</span>
                  <span style="font-size:11px;color:#6e6e78;font-family:'Geist Mono',monospace;flex-shrink:0;">{p.views}</span>
                </div>
                <div style="background:#15151a;border-radius:100px;height:3px;">
                  <div style={`background:#FF4F00;height:100%;width:${pct}%;border-radius:100px;`}></div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )}

    <!-- Device + Country -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
      <!-- Devices -->
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:12px;">
        <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0 0 10px;">Devices</p>
        {deviceStats.length === 0 && <p style="font-size:11px;color:#6e6e78;text-align:center;padding:8px;">No data yet</p>}
        {(deviceStats as any[]).map((d: any) => {
          const icon = d.device_type === 'mobile' ? 'M' : d.device_type === 'tablet' ? 'T' : 'D';
          return (
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
              <span style="font-size:10px;font-weight:700;background:#15151a;color:#8a8a94;width:20px;height:20px;border-radius:4px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{icon}</span>
              <span style="font-size:11px;color:#d8d8de;flex:1;text-transform:capitalize;">{d.device_type}</span>
              <span style="font-size:11px;color:#FF7040;font-family:'Geist Mono',monospace;">{d.n}</span>
            </div>
          );
        })}
      </div>
      <!-- Countries -->
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:12px;">
        <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0 0 10px;">Countries</p>
        {countryStats.length === 0 && <p style="font-size:11px;color:#6e6e78;text-align:center;padding:8px;">No data yet</p>}
        {(countryStats as any[]).map((c: any) => (
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
            <span style="font-size:11px;color:#d8d8de;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{c.country || 'Unknown'}</span>
            <span style="font-size:11px;color:#60a5fa;font-family:'Geist Mono',monospace;">{c.n}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Recent views -->
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;">
      <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0 0 12px;">Recent Activity</p>
      {recentViews.length === 0 && <p style="font-size:11px;color:#6e6e78;text-align:center;padding:12px;">No page views tracked yet. Add the tracking snippet to your public pages.</p>}
      {(recentViews as any[]).map((v: any) => (
        <div style="display:flex;align-items:center;gap:10px;padding:6px 0;border-bottom:1px solid #0a0a0c;">
          <div style="flex:1;min-width:0;">
            <p style="font-size:11px;color:#d8d8de;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-family:'Geist Mono',monospace;">{v.page || '/'}</p>
            <p style="font-size:9px;color:#6e6e78;margin:1px 0 0;">{v.country || 'Unknown'} - {v.device_type || 'unknown'} - {v.browser || 'unknown'}</p>
          </div>
          <span style="font-size:10px;color:#6e6e78;flex-shrink:0;">{timeAgo(v.created_at)}</span>
        </div>
      ))}
    </div>

    <!-- Setup instructions -->
    {totalViews === 0 && (
      <div style="background:#0f0f14;border:1px solid rgba(255,79,0,0.2);border-radius:12px;padding:14px;">
        <p style="font-size:12px;font-weight:600;color:#FF7040;margin:0 0 8px;">Setup Required</p>
        <p style="font-size:11px;color:#8a8a94;margin:0 0 10px;">Add this script to your public pages to start tracking visitors:</p>
        <div style="background:#0a0a0c;border-radius:8px;padding:10px;font-family:'Geist Mono',monospace;font-size:10px;color:#6ee7b7;overflow-x:auto;">
          <p style="margin:0;">&lt;script src="/analytics.js"&gt;&lt;/script&gt;</p>
        </div>
      </div>
    )}

  </div>
</div>
</AdminLayout>
