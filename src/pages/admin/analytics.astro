---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const url = new URL(Astro.request.url);
const range = url.searchParams.get('range') || '7d';
const tab = url.searchParams.get('tab') || 'overview';
const days = range === '30d' ? 30 : range === '90d' ? 90 : 7;

let totalViews = 0, uniqueSessions = 0, onlineNow = 0, avgDuration = 0;
let topPages: any[] = [];
let deviceStats: any[] = [];
let countryStats: any[] = [];
let cityStats: any[] = [];
let sourceStats: any[] = [];
let dailyStats: any[] = [];
let recentViews: any[] = [];
let onlineSessions: any[] = [];
let loggedInVisitors: any[] = [];
let mapSessions: any[] = [];

try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as total_views, COUNT(DISTINCT session_id)::int as unique_sessions, ROUND(AVG(duration_ms)/1000)::int as avg_secs FROM analytics_pageviews WHERE created_at >= NOW() - INTERVAL '1 day' * ${days}`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  const d = rows[0] as any;
  totalViews = Number(d?.total_views)||0; uniqueSessions = Number(d?.unique_sessions)||0; avgDuration = Number(d?.avg_secs)||0;
} catch(e) {}

try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM analytics_sessions WHERE last_seen >= NOW() - INTERVAL '5 minutes'`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  onlineNow = Number((rows[0] as any)?.n)||0;
} catch(e) {}

try {
  const r = await db.execute(sql`SELECT s.*, u.name as user_name, u.email as user_email, u.role as user_role FROM analytics_sessions s LEFT JOIN users u ON s.user_id = u.id WHERE s.last_seen >= NOW() - INTERVAL '30 minutes' ORDER BY s.last_seen DESC LIMIT 20`);
  onlineSessions = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

// Sessions with precise GPS location
try {
  const r = await db.execute(sql`SELECT s.session_id, s.page, s.lat, s.lon, s.accuracy, s.address, s.suburb, s.district, s.city, s.country, s.device_type, s.last_seen, s.user_id, u.name as user_name, u.role as user_role FROM analytics_sessions s LEFT JOIN users u ON s.user_id = u.id WHERE s.lat IS NOT NULL AND s.lon IS NOT NULL ORDER BY s.last_seen DESC LIMIT 100`);
  mapSessions = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

try {
  const r = await db.execute(sql`SELECT page, COUNT(*)::int as views, COUNT(DISTINCT session_id)::int as sessions FROM analytics_pageviews WHERE created_at >= NOW() - INTERVAL '1 day' * ${days} GROUP BY page ORDER BY views DESC LIMIT 15`);
  topPages = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

try {
  const r = await db.execute(sql`SELECT device_type, COUNT(*)::int as n FROM analytics_pageviews WHERE created_at >= NOW() - INTERVAL '1 day' * ${days} AND device_type IS NOT NULL GROUP BY device_type ORDER BY n DESC`);
  deviceStats = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

try {
  const r = await db.execute(sql`SELECT country, COUNT(*)::int as n FROM analytics_pageviews WHERE created_at >= NOW() - INTERVAL '1 day' * ${days} AND country IS NOT NULL GROUP BY country ORDER BY n DESC LIMIT 10`);
  countryStats = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

try {
  const r = await db.execute(sql`SELECT city, region, country, COUNT(*)::int as n FROM analytics_pageviews WHERE created_at >= NOW() - INTERVAL '1 day' * ${days} AND city IS NOT NULL GROUP BY city, region, country ORDER BY n DESC LIMIT 10`);
  cityStats = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

try {
  const r = await db.execute(sql`SELECT referrer_source, COUNT(*)::int as n FROM analytics_pageviews WHERE created_at >= NOW() - INTERVAL '1 day' * ${days} AND referrer_source IS NOT NULL GROUP BY referrer_source ORDER BY n DESC`);
  sourceStats = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

try {
  const r = await db.execute(sql`SELECT DATE(created_at) as day, COUNT(*)::int as views, COUNT(DISTINCT session_id)::int as sessions FROM analytics_pageviews WHERE created_at >= NOW() - INTERVAL '1 day' * ${days} GROUP BY DATE(created_at) ORDER BY day ASC`);
  dailyStats = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

try {
  const r = await db.execute(sql`SELECT page, device_type, country, city, region, browser, os, referrer_source, user_name, user_role, created_at, duration_ms FROM analytics_pageviews ORDER BY created_at DESC LIMIT 30`);
  recentViews = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

try {
  const r = await db.execute(sql`SELECT DISTINCT ON (user_id) user_name, user_role, page, city, country, created_at FROM analytics_pageviews WHERE user_id IS NOT NULL AND created_at >= NOW() - INTERVAL '1 day' * ${days} ORDER BY user_id, created_at DESC`);
  loggedInVisitors = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

function timeAgo(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff/60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins + 'm ago';
  if (mins < 1440) return Math.floor(mins/60) + 'h ago';
  return Math.floor(mins/1440) + 'd ago';
}
function fmtDuration(secs: number) {
  if (!secs) return '-';
  if (secs < 60) return secs + 's';
  return Math.floor(secs/60) + 'm ' + (secs%60) + 's';
}
const maxViews = topPages.length > 0 ? Math.max(...(topPages as any[]).map((p:any)=>p.views)) : 1;
const maxDaily = dailyStats.length > 0 ? Math.max(...(dailyStats as any[]).map((d:any)=>d.views)) : 1;
const SOURCE_COLOR: Record<string,string> = { google:'#4285f4', direct:'#FF7040', internal:'#10b981', linkedin:'#0077b5', twitter:'#1da1f2', facebook:'#1877f2', external:'#a78bfa', whatsapp:'#25d366', instagram:'#e1306c' };
const ROLE_COLOR: Record<string,string> = { super_admin:'#f97316', admin:'#FF4F00', applicant:'#60a5fa', editor:'#a78bfa', marketing:'#fbbf24', hr:'#10b981' };
---
<AdminLayout title="Analytics" activeNav="analytics">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<style>
  #liveMap { height: 500px; border-radius: 12px; overflow: hidden; z-index: 1; }
  .leaflet-popup-content-wrapper { background: #0f0f14; border: 1px solid #1a1a1f; border-radius: 10px; color: #fff; }
  .leaflet-popup-tip { background: #0f0f14; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
</style>
<div style="padding-bottom:80px;">

  <!-- Header -->
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
      <div>
        <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">Insights</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Analytics</h1>
      </div>
      {onlineNow > 0 && (
        <div style="display:flex;align-items:center;gap:5px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);border-radius:100px;padding:4px 10px;">
          <div style="width:7px;height:7px;background:#10b981;border-radius:50%;animation:pulse 2s infinite;"></div>
          <span style="font-size:11px;font-weight:600;color:#10b981;">{onlineNow} online</span>
        </div>
      )}
    </div>
    <!-- Tabs -->
    <div style="display:flex;gap:5px;margin-bottom:10px;">
      {[['overview','Overview'],['map','Live Map'],['visitors','Visitors'],['pages','Pages']].map(([t,l]) => (
        <a href={`?tab=${t}&range=${range}`} style={`text-decoration:none;font-size:12px;font-weight:600;padding:6px 12px;border-radius:6px;${tab===t?'background:#FF4F00;color:#fff;':'background:#15151a;color:#8a8a94;'}`}>{l}</a>
      ))}
    </div>
    <!-- Range -->
    <div style="display:flex;gap:5px;">
      {[['7d','7d'],['30d','30d'],['90d','90d']].map(([v,l]) => (
        <a href={`?tab=${tab}&range=${v}`} style={`text-decoration:none;font-size:11px;font-weight:600;padding:4px 10px;border-radius:100px;${range===v?'background:#1a1a1f;color:#fff;border:1px solid #FF4F00;':'background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;'}`}>{l}</a>
      ))}
    </div>
  </div>

  <!-- Stats bar (always visible) -->
  <div style="padding:12px 16px 0;display:grid;grid-template-columns:repeat(4,1fr);gap:8px;">
    {[
      { label:'Views', value:totalViews, color:'#FF7040' },
      { label:'Sessions', value:uniqueSessions, color:'#60a5fa' },
      { label:'Online', value:onlineNow, color:'#10b981' },
      { label:'Avg Time', value:fmtDuration(avgDuration), color:'#a78bfa' },
    ].map(s => (
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:10px;text-align:center;">
        <p style={`font-size:18px;font-weight:800;color:${s.color};margin:0;line-height:1;font-family:'Geist Mono',monospace;`}>{s.value}</p>
        <p style="font-size:9px;color:#6e6e78;margin:3px 0 0;text-transform:uppercase;">{s.label}</p>
      </div>
    ))}
  </div>

  <div style="padding:12px 16px;display:flex;flex-direction:column;gap:12px;">

  <!-- MAP TAB -->
  {tab === 'map' && (
    <div>
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;margin-bottom:12px;">
        <div style="padding:10px 14px;border-bottom:1px solid #1a1a1f;display:flex;align-items:center;justify-content:space-between;">
          <div style="display:flex;align-items:center;gap:8px;">
            <div style="width:8px;height:8px;background:#10b981;border-radius:50%;animation:pulse 2s infinite;"></div>
            <p style="font-size:12px;font-weight:600;color:#fff;margin:0;">Live Visitor Map</p>
          </div>
          <span style="font-size:11px;color:#6e6e78;">{mapSessions.length} visitors with GPS</span>
        </div>
        {mapSessions.length === 0 ? (
          <div style="padding:48px;text-align:center;">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#6e6e78" stroke-width="1.5" style="margin-bottom:12px;"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 7.05 11.5 7.72 12.07a.5.5 0 0 0 .56 0C12.95 21.5 20 15.4 20 10a8 8 0 0 0-8-8z"/></svg>
            <p style="font-size:14px;font-weight:600;color:#fff;margin-bottom:6px;">No GPS data yet</p>
            <p style="font-size:12px;color:#6e6e78;">Visitors who allow location access will appear here with exact coordinates. The analytics.js script requests GPS permission on page load.</p>
          </div>
        ) : (
          <div id="liveMap"></div>
        )}
      </div>

      <!-- GPS sessions list -->
      {mapSessions.length > 0 && (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
          <div style="padding:10px 14px;border-bottom:1px solid #1a1a1f;">
            <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0;">Precise Locations</p>
          </div>
          {(mapSessions as any[]).map((s: any) => (
            <div style="padding:10px 14px;display:flex;align-items:flex-start;gap:10px;border-bottom:1px solid #0a0a0c;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#FF4F00" stroke="none" style="flex-shrink:0;margin-top:2px;"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 7.05 11.5 7.72 12.07a.5.5 0 0 0 .56 0C12.95 21.5 20 15.4 20 10a8 8 0 0 0-8-8z"/></svg>
              <div style="flex:1;min-width:0;">
                <p style="font-size:12px;font-weight:600;color:#fff;margin:0;">{s.user_name || 'Anonymous'}</p>
                {s.suburb && <p style="font-size:11px;color:#FF7040;margin:1px 0 0;">{s.suburb}{s.district ? ', '+s.district : ''}</p>}
                <p style="font-size:10px;color:#6e6e78;margin:1px 0 0;">{s.city || ''}{s.country ? (s.city?', ':'')+s.country : ''}</p>
                {s.address && <p style="font-size:9px;color:#6e6e78;margin:2px 0 0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{s.address.substring(0,80)}</p>}
                <p style="font-size:9px;color:#6e6e78;margin:2px 0 0;">Accuracy: ~{Math.round(s.accuracy||0)}m - {s.page}</p>
              </div>
              <div style="text-align:right;flex-shrink:0;">
                {s.user_role && <span style={`font-size:9px;font-weight:700;padding:1px 6px;border-radius:100px;background:${(ROLE_COLOR as any)[s.user_role]||'#6b7280'}22;color:${(ROLE_COLOR as any)[s.user_role]||'#6b7280'};display:block;margin-bottom:2px;`}>{s.user_role}</span>}
                <span style="font-size:9px;color:#6e6e78;">{timeAgo(s.last_seen)}</span>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  )}

  <!-- OVERVIEW TAB -->
  {tab === 'overview' && (
    <div style="display:flex;flex-direction:column;gap:12px;">

      <!-- Who is online -->
      {onlineSessions.length > 0 && (
        <div style="background:#0f0f14;border:1px solid rgba(16,185,129,0.2);border-radius:12px;overflow:hidden;">
          <div style="padding:10px 14px;border-bottom:1px solid #1a1a1f;display:flex;align-items:center;gap:8px;">
            <div style="width:8px;height:8px;background:#10b981;border-radius:50%;animation:pulse 2s infinite;flex-shrink:0;"></div>
            <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0;">Active in last 30 min</p>
          </div>
          {(onlineSessions as any[]).map((s: any) => (
            <div style="padding:8px 14px;display:flex;align-items:center;gap:10px;border-bottom:1px solid #0a0a0c;">
              <div style={`width:28px;height:28px;border-radius:50%;background:${s.user_name?'rgba(255,79,0,0.15)':'#15151a'};display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:${s.user_name?'#FF7040':'#6e6e78'};flex-shrink:0;`}>{s.user_name?s.user_name.charAt(0).toUpperCase():'?'}</div>
              <div style="flex:1;min-width:0;">
                <p style="font-size:12px;font-weight:600;color:#fff;margin:0;">{s.user_name||'Anonymous'}</p>
                <p style="font-size:10px;color:#6e6e78;margin:1px 0 0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                  {s.page} - {s.suburb ? s.suburb+', ' : ''}{s.city?s.city+', ':''}{s.country||'Unknown'}
                  {s.lat && <span style="color:#FF7040;"> (GPS)</span>}
                </p>
              </div>
              <div style="text-align:right;flex-shrink:0;">
                {s.user_role && <span style={`font-size:9px;font-weight:700;padding:1px 6px;border-radius:100px;background:${(ROLE_COLOR as any)[s.user_role]||'#6b7280'}22;color:${(ROLE_COLOR as any)[s.user_role]||'#6b7280'};display:block;margin-bottom:2px;`}>{s.user_role}</span>}
                <span style="font-size:10px;color:#6e6e78;">{timeAgo(s.last_seen)}</span>
              </div>
            </div>
          ))}
        </div>
      )}

      <!-- Daily chart -->
      {dailyStats.length > 0 && (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;">
          <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0 0 12px;">Daily Traffic</p>
          <div style="display:flex;align-items:flex-end;gap:3px;height:80px;">
            {(dailyStats as any[]).map((d: any) => {
              const h = maxDaily > 0 ? Math.max(4, Math.round((d.views/maxDaily)*80)) : 4;
              return <div style="flex:1;" title={d.views + ' views'}><div style={`width:100%;background:#FF4F00;border-radius:2px 2px 0 0;height:${h}px;`}></div></div>;
            })}
          </div>
          <div style="display:flex;justify-content:space-between;margin-top:6px;">
            <span style="font-size:9px;color:#6e6e78;">{dailyStats.length>0?new Date((dailyStats[0] as any).day).toLocaleDateString('en-IN',{day:'numeric',month:'short'}):''}</span>
            <span style="font-size:9px;color:#6e6e78;">{dailyStats.length>0?new Date((dailyStats[dailyStats.length-1] as any).day).toLocaleDateString('en-IN',{day:'numeric',month:'short'}):''}</span>
          </div>
        </div>
      )}

      <!-- Sources -->
      {sourceStats.length > 0 && (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;">
          <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0 0 12px;">Traffic Sources</p>
          {(sourceStats as any[]).map((s: any) => {
            const sc = (SOURCE_COLOR as any)[s.referrer_source]||'#6e6e78';
            const pct = totalViews>0?Math.round((s.n/totalViews)*100):0;
            return (
              <div style="margin-bottom:8px;">
                <div style="display:flex;justify-content:space-between;margin-bottom:3px;">
                  <span style={`font-size:11px;font-weight:600;color:${sc};text-transform:capitalize;`}>{s.referrer_source}</span>
                  <span style="font-size:11px;color:#6e6e78;">{s.n} ({pct}%)</span>
                </div>
                <div style="background:#15151a;border-radius:100px;height:4px;">
                  <div style={`background:${sc};height:100%;width:${pct}%;border-radius:100px;`}></div>
                </div>
              </div>
            );
          })}
        </div>
      )}

      <!-- Countries + Cities -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:12px;">
          <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0 0 10px;">Countries</p>
          {(countryStats as any[]).map((c: any) => (
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
              <span style="font-size:11px;color:#d8d8de;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{c.country}</span>
              <span style="font-size:11px;color:#FF7040;font-family:'Geist Mono',monospace;">{c.n}</span>
            </div>
          ))}
        </div>
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:12px;">
          <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0 0 10px;">Cities</p>
          {(cityStats as any[]).map((c: any) => (
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
              <div style="flex:1;min-width:0;">
                <p style="font-size:11px;color:#d8d8de;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{c.city}</p>
                <p style="font-size:9px;color:#6e6e78;margin:0;">{c.region}</p>
              </div>
              <span style="font-size:11px;color:#60a5fa;font-family:'Geist Mono',monospace;">{c.n}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Devices -->
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:12px;">
        <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0 0 10px;">Devices</p>
        <div style="display:flex;gap:8px;">
          {(deviceStats as any[]).map((d: any) => {
            const pct = totalViews>0?Math.round((d.n/totalViews)*100):0;
            const color = d.device_type==='mobile'?'#10b981':d.device_type==='tablet'?'#a78bfa':'#60a5fa';
            return (
              <div style={`flex:1;background:${color}11;border:1px solid ${color}33;border-radius:10px;padding:10px;text-align:center;`}>
                <p style={`font-size:20px;font-weight:800;color:${color};margin:0;font-family:'Geist Mono',monospace;`}>{pct}%</p>
                <p style="font-size:9px;color:#6e6e78;margin:3px 0 0;text-transform:capitalize;">{d.device_type}</p>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  )}

  <!-- VISITORS TAB -->
  {tab === 'visitors' && (
    <div style="display:flex;flex-direction:column;gap:12px;">
      {loggedInVisitors.length > 0 && (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
          <div style="padding:10px 14px;border-bottom:1px solid #1a1a1f;"><p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0;">Identified Visitors</p></div>
          {(loggedInVisitors as any[]).map((v: any) => {
            const rc = (ROLE_COLOR as any)[v.user_role]||'#6b7280';
            return (
              <div style="padding:10px 14px;display:flex;align-items:center;gap:10px;border-bottom:1px solid #0a0a0c;">
                <div style={`width:34px;height:34px;border-radius:50%;background:${rc}22;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;color:${rc};flex-shrink:0;`}>{v.user_name?.charAt(0).toUpperCase()}</div>
                <div style="flex:1;min-width:0;">
                  <p style="font-size:13px;font-weight:600;color:#fff;margin:0;">{v.user_name}</p>
                  <p style="font-size:10px;color:#6e6e78;margin:2px 0 0;">{v.city?v.city+', ':''}{v.country} - {v.page}</p>
                </div>
                <div style="text-align:right;flex-shrink:0;">
                  <span style={`font-size:9px;font-weight:700;padding:2px 8px;border-radius:100px;background:${rc}22;color:${rc};display:block;margin-bottom:3px;`}>{v.user_role}</span>
                  <span style="font-size:10px;color:#6e6e78;">{timeAgo(v.created_at)}</span>
                </div>
              </div>
            );
          })}
        </div>
      )}
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
        <div style="padding:10px 14px;border-bottom:1px solid #1a1a1f;"><p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0;">Recent Page Views</p></div>
        {(recentViews as any[]).map((v: any) => (
          <div style="padding:8px 14px;display:flex;align-items:center;gap:10px;border-bottom:1px solid #0a0a0c;">
            <div style="flex:1;min-width:0;">
              <p style="font-size:11px;color:#d8d8de;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-family:'Geist Mono',monospace;">{v.page||'/'}</p>
              <p style="font-size:9px;color:#6e6e78;margin:1px 0 0;">{v.user_name?v.user_name+' - ':''}{v.city?v.city+', ':''}{v.country||'?'} - {v.device_type} - {v.browser}{v.referrer_source&&v.referrer_source!=='direct'?' - via '+v.referrer_source:''}</p>
            </div>
            <span style="font-size:10px;color:#6e6e78;flex-shrink:0;">{timeAgo(v.created_at)}</span>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- PAGES TAB -->
  {tab === 'pages' && topPages.length > 0 && (
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;">
      <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0 0 12px;">Top Pages</p>
      {(topPages as any[]).map((p: any) => {
        const pct = maxViews>0?Math.round((p.views/maxViews)*100):0;
        return (
          <div style="margin-bottom:10px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:3px;">
              <span style="font-size:11px;color:#d8d8de;font-family:'Geist Mono',monospace;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:70%;">{p.page||'/'}</span>
              <div style="display:flex;gap:10px;flex-shrink:0;">
                <span style="font-size:10px;color:#6e6e78;">{p.sessions} sessions</span>
                <span style="font-size:11px;color:#FF7040;font-weight:600;">{p.views}</span>
              </div>
            </div>
            <div style="background:#15151a;border-radius:100px;height:3px;">
              <div style={`background:#FF4F00;height:100%;width:${pct}%;border-radius:100px;`}></div>
            </div>
          </div>
        );
      })}
    </div>
  )}

  </div>
</div>

<!-- Leaflet map script -->
{tab === 'map' && mapSessions.length > 0 && (
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script is:inline define:vars={{ mapData: mapSessions }}>
  document.addEventListener('DOMContentLoaded', function() {
    var map = L.map('liveMap', { zoomControl: true }).setView([20.5937, 78.9629], 5);

    // Dark tile layer
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
      attribution: 'Map data &copy; OpenStreetMap contributors',
      maxZoom: 19
    }).addTo(map);

    var bounds = [];

    mapData.forEach(function(s) {
      if (!s.lat || !s.lon) return;
      bounds.push([s.lat, s.lon]);

      var color = s.user_name ? '#FF4F00' : '#60a5fa';
      var isOnline = (Date.now() - new Date(s.last_seen).getTime()) < 5 * 60 * 1000;

      var marker = L.circleMarker([s.lat, s.lon], {
        radius: isOnline ? 10 : 7,
        fillColor: color,
        color: isOnline ? '#fff' : color,
        weight: isOnline ? 2 : 1,
        opacity: 1,
        fillOpacity: isOnline ? 0.95 : 0.6
      }).addTo(map);

      var popupContent = '<div style="min-width:160px;padding:4px;">'
        + '<p style="font-size:13px;font-weight:700;color:#fff;margin:0 0 4px;">' + (s.user_name || 'Anonymous visitor') + '</p>'
        + (s.user_role ? '<p style="font-size:10px;color:#FF7040;margin:0 0 4px;text-transform:uppercase;">' + s.user_role + '</p>' : '')
        + (s.suburb ? '<p style="font-size:11px;color:#6ee7b7;margin:0 0 2px;">' + s.suburb + (s.district ? ', ' + s.district : '') + '</p>' : '')
        + '<p style="font-size:11px;color:#8a8a94;margin:0 0 2px;">' + (s.city || '') + (s.country ? ', ' + s.country : '') + '</p>'
        + '<p style="font-size:10px;color:#6e6e78;margin:0 0 4px;">Accuracy: ~' + Math.round(s.accuracy || 0) + 'm</p>'
        + '<p style="font-size:11px;color:#d8d8de;margin:0 0 2px;">' + (s.page || '/') + '</p>'
        + '<p style="font-size:10px;color:' + (isOnline ? '#10b981' : '#6e6e78') + ';margin:0;">' + (isOnline ? 'Online now' : 'Last seen: ' + new Date(s.last_seen).toLocaleTimeString('en-IN')) + '</p>'
        + '</div>';

      marker.bindPopup(popupContent, { maxWidth: 220 });

      // Pulse animation for online users
      if (isOnline) {
        var pulse = L.circleMarker([s.lat, s.lon], {
          radius: 16, fillColor: color, color: color,
          weight: 1, opacity: 0.3, fillOpacity: 0.15
        }).addTo(map);
      }
    });

    if (bounds.length > 1) {
      map.fitBounds(bounds, { padding: [40, 40] });
    } else if (bounds.length === 1) {
      map.setView(bounds[0], 12);
    }

    // Auto-refresh map every 30s
    setInterval(function() { window.location.reload(); }, 30000);
  });
  </script>
)}

<!-- GPS collection on this admin page too -->
<script is:inline>
(function() {
  var sid = sessionStorage.getItem('era_session');
  if (!sid || !navigator.geolocation) return;
  navigator.geolocation.getCurrentPosition(function(pos) {
    fetch('https://nominatim.openstreetmap.org/reverse?lat='+pos.coords.latitude+'&lon='+pos.coords.longitude+'&format=json')
      .then(function(r){return r.json();})
      .then(function(geo) {
        fetch('/api/track-location', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({
            sessionId: sid,
            lat: pos.coords.latitude, lon: pos.coords.longitude,
            accuracy: pos.coords.accuracy,
            address: geo.display_name||'',
            suburb: geo.address?.suburb||geo.address?.neighbourhood||'',
            district: geo.address?.city_district||geo.address?.county||''
          })
        });
      }).catch(function(){});
  }, function(){}, {enableHighAccuracy:true, timeout:10000});
})();
</script>
</AdminLayout>
