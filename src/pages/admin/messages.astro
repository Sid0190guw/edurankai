---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { adminConversations, adminMessages, users } from '@/lib/db/schema';
import { canViewPage } from '@/lib/auth/pagePermissions';
import { eq, or, and, sql as drizzleSql, desc, ne } from 'drizzle-orm';

const currentUser = Astro.locals.user!;
if (currentUser.role === 'applicant') return Astro.redirect('/portal');

let errorMsg = '';
let okMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('_action') as string;

  try {
    if (action === 'start_conversation') {
      const recipientId = fd.get('recipientId') as string;
      const initialBody = (fd.get('body') as string || '').trim();
      if (!recipientId || !initialBody) {
        errorMsg = 'Recipient and message body required.';
      } else if (recipientId === currentUser.id) {
        errorMsg = 'You cannot message yourself.';
      } else {
        // Ensure ordering for unique pair constraint - sort by string compare
        const [userA, userB] = currentUser.id < recipientId
          ? [currentUser.id, recipientId]
          : [recipientId, currentUser.id];

        // Find existing or create
        const existing = await db.select().from(adminConversations)
          .where(and(eq(adminConversations.userAId, userA), eq(adminConversations.userBId, userB)))
          .limit(1);

        let convId = '';
        if (existing.length > 0) {
          convId = existing[0].id;
        } else {
          const created = await db.insert(adminConversations).values({
            userAId: userA, userBId: userB, lastMessageAt: new Date()
          }).returning({ id: adminConversations.id });
          convId = created[0].id;
        }

        await db.insert(adminMessages).values({
          conversationId: convId,
          senderUserId: currentUser.id,
          body: initialBody
        });

        await db.update(adminConversations).set({ lastMessageAt: new Date() }).where(eq(adminConversations.id, convId));

        return Astro.redirect('/admin/messages?c=' + convId);
      }
    }
    else if (action === 'send_message') {
      const convId = fd.get('conversationId') as string;
      const body = (fd.get('body') as string || '').trim();
      if (!convId || !body) {
        errorMsg = 'Message body required.';
      } else {
        // Validate user is in this conversation
        const conv = await db.select().from(adminConversations).where(eq(adminConversations.id, convId)).limit(1);
        if (conv.length === 0 || (conv[0].userAId !== currentUser.id && conv[0].userBId !== currentUser.id)) {
          errorMsg = 'Access denied.';
        } else {
          await db.insert(adminMessages).values({
            conversationId: convId, senderUserId: currentUser.id, body
          });
          await db.update(adminConversations).set({ lastMessageAt: new Date() }).where(eq(adminConversations.id, convId));
          return Astro.redirect('/admin/messages?c=' + convId);
        }
      }
    }
  } catch (err: any) {
    errorMsg = 'Failed: ' + (err.message || 'Unknown error');
  }
}

// Load this user's conversations
const myConvos = await db.select({
  id: adminConversations.id,
  userAId: adminConversations.userAId,
  userBId: adminConversations.userBId,
  lastMessageAt: adminConversations.lastMessageAt
}).from(adminConversations)
  .where(or(eq(adminConversations.userAId, currentUser.id), eq(adminConversations.userBId, currentUser.id)))
  .orderBy(desc(adminConversations.lastMessageAt));

// Get all admin user names for lookup
const allAdmins = await db.select({ id: users.id, name: users.name, email: users.email, role: users.role })
  .from(users).where(ne(users.role, 'applicant'));
const userMap = Object.fromEntries(allAdmins.map(u => [u.id, u]));

// Get last messages + unread counts for each convo
const convoSummaries = await Promise.all(myConvos.map(async (c) => {
  const otherId = c.userAId === currentUser.id ? c.userBId : c.userAId;
  const otherUser = userMap[otherId];
  const lastMsg = await db.select().from(adminMessages)
    .where(eq(adminMessages.conversationId, c.id))
    .orderBy(desc(adminMessages.createdAt)).limit(1);
  const unread = await db.select({ id: adminMessages.id }).from(adminMessages)
    .where(and(
      eq(adminMessages.conversationId, c.id),
      ne(adminMessages.senderUserId, currentUser.id),
      eq(adminMessages.readByRecipient, false)
    ));
  return {
    id: c.id,
    otherUser,
    lastMessage: lastMsg[0] || null,
    lastMessageAt: c.lastMessageAt,
    unreadCount: unread.length
  };
}));

// Open conversation
const url = new URL(Astro.request.url);
const openConvId = url.searchParams.get('c') || '';
let openConv: any = null;
let openMessages: any[] = [];
let otherUserInOpenConv: any = null;
if (openConvId) {
  const found = await db.select().from(adminConversations).where(eq(adminConversations.id, openConvId)).limit(1);
  if (found.length > 0 && (found[0].userAId === currentUser.id || found[0].userBId === currentUser.id)) {
    openConv = found[0];
    const otherId = openConv.userAId === currentUser.id ? openConv.userBId : openConv.userAId;
    otherUserInOpenConv = userMap[otherId];

    // Mark all incoming messages as read
    await db.update(adminMessages)
      .set({ readByRecipient: true, readAt: new Date() })
      .where(and(
        eq(adminMessages.conversationId, openConvId),
        ne(adminMessages.senderUserId, currentUser.id),
        eq(adminMessages.readByRecipient, false)
      ));

    openMessages = await db.select().from(adminMessages)
      .where(eq(adminMessages.conversationId, openConvId))
      .orderBy(adminMessages.createdAt);
  }
}

// Show new-conversation modal?
const showNew = url.searchParams.get('new') === '1';

// Recipients for new convo (everyone except me)
const recipientCandidates = allAdmins.filter(u => u.id !== currentUser.id);

function fmtTime(d: Date | string | null): string {
  if (!d) return '';
  const dt = new Date(d);
  const now = new Date();
  const sameDay = dt.toDateString() === now.toDateString();
  if (sameDay) return dt.toLocaleTimeString('en-IN', { hour: 'numeric', minute: '2-digit' });
  return dt.toLocaleDateString('en-IN', { day: 'numeric', month: 'short' });
}

function fmtTimestamp(d: Date | string): string {
  return new Date(d).toLocaleString('en-IN', { day: 'numeric', month: 'short', hour: 'numeric', minute: '2-digit' });
}

function truncate(s: string | null, max: number): string {
  if (!s) return '';
  return s.length > max ? s.substring(0, max - 1) + '…' : s;
}

function initial(name: string): string {
  return name ? name.charAt(0).toUpperCase() : '?';
}

const totalUnread = convoSummaries.reduce((sum, c) => sum + c.unreadCount, 0);
---
<AdminLayout title="Team Messages" activeNav="messages">
  <div class="admin-page" style="max-width:1400px;padding:0;">

    <div style="display:grid;grid-template-columns:340px 1fr;gap:0;height:calc(100vh - 40px);border:1px solid #1f1f26;border-radius:10px;overflow:hidden;background:#0a0a0d;">

      <!-- LEFT: Conversation list -->
      <div style="border-right:1px solid #1f1f26;display:flex;flex-direction:column;background:#0e0e12;">
        <div style="padding:14px 16px;border-bottom:1px solid #1f1f26;display:flex;justify-content:space-between;align-items:center;">
          <div>
            <h1 style="font-size:14px;font-weight:600;color:#fff;margin:0;">Team Messages</h1>
            <p style="font-size:10.5px;color:#6e6e78;margin-top:2px;">{convoSummaries.length} conversation{convoSummaries.length === 1 ? '' : 's'}{totalUnread > 0 ? ' • ' + totalUnread + ' unread' : ''}</p>
          </div>
          <a href="/admin/messages?new=1" class="admin-btn admin-btn-primary" style="padding:5px 10px;font-size:10.5px;text-decoration:none;">+ New</a>
        </div>

        <div style="flex:1;overflow-y:auto;">
          {convoSummaries.length === 0 && (
            <div style="padding:30px 20px;text-align:center;">
              <p style="font-size:12.5px;color:#6e6e78;line-height:1.7;margin-bottom:14px;">No conversations yet.<br/>Start one to message your team.</p>
              <a href="/admin/messages?new=1" class="admin-btn admin-btn-primary" style="padding:6px 12px;font-size:11px;text-decoration:none;display:inline-block;">Start a conversation</a>
            </div>
          )}

          {convoSummaries.map((c) => {
            const isOpen = openConvId === c.id;
            const lastMsgBody = c.lastMessage ? c.lastMessage.body : '(no messages yet)';
            const lastFromMe = c.lastMessage && c.lastMessage.senderUserId === currentUser.id;
            return (
              <a href={'/admin/messages?c=' + c.id} style={'display:block;padding:12px 16px;border-bottom:1px solid #15151a;text-decoration:none;color:inherit;' + (isOpen ? 'background:rgba(255,79,0,0.08);' : '')}>
                <div style="display:flex;align-items:flex-start;gap:10px;">
                  <div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#FF4F00,#FF7040);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:13px;flex-shrink:0;">
                    {c.otherUser ? initial(c.otherUser.name) : '?'}
                  </div>
                  <div style="flex:1;min-width:0;">
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:6px;margin-bottom:3px;">
                      <span style={'font-weight:' + (c.unreadCount > 0 ? '600' : '500') + ';color:#fff;font-size:12.5px;'}>{c.otherUser ? c.otherUser.name : 'Unknown'}</span>
                      <span style="font-size:9.5px;color:#6e6e78;font-family:'Geist Mono',monospace;flex-shrink:0;">{fmtTime(c.lastMessageAt)}</span>
                    </div>
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:6px;">
                      <span style={'font-size:11px;color:' + (c.unreadCount > 0 ? '#d8d8de' : '#6e6e78') + ';overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;min-width:0;'}>
                        {lastFromMe && <span style="color:#6e6e78;">You: </span>}
                        {truncate(lastMsgBody, 50)}
                      </span>
                      {c.unreadCount > 0 && (
                        <span style="background:#FF4F00;color:#fff;font-size:9.5px;font-weight:700;padding:1px 6px;border-radius:100px;flex-shrink:0;">{c.unreadCount}</span>
                      )}
                    </div>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>

      <!-- RIGHT: Open conversation OR new message -->
      <div style="display:flex;flex-direction:column;background:#0a0a0d;">

        {errorMsg && <div style="margin:14px 18px 0;background:rgba(220,38,38,0.08);border:1px solid rgba(220,38,38,0.25);color:#fca5a5;font-size:12px;padding:8px 11px;border-radius:6px;">{errorMsg}</div>}

        {showNew && (
          <div style="padding:30px 40px;max-width:600px;margin:0 auto;width:100%;">
            <h2 style="font-size:16px;font-weight:600;color:#fff;margin-bottom:18px;">Start a new conversation</h2>
            <form method="POST" style="display:flex;flex-direction:column;gap:12px;">
              <input type="hidden" name="_action" value="start_conversation" />
              <div>
                <label class="rolefield-label">Send to *</label>
                <select name="recipientId" required class="rolefield-input">
                  <option value="">Choose team member...</option>
                  {recipientCandidates.map((u) => <option value={u.id}>{u.name} ({u.role})</option>)}
                </select>
              </div>
              <div>
                <label class="rolefield-label">Message *</label>
                <textarea name="body" rows="4" required class="rolefield-input" placeholder="Hi! Just wanted to check in on..."></textarea>
              </div>
              <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:6px;">
                <a href="/admin/messages" class="admin-btn" style="padding:7px 14px;font-size:12px;display:flex;align-items:center;text-decoration:none;">Cancel</a>
                <button type="submit" class="admin-btn admin-btn-primary" style="padding:7px 14px;font-size:12px;">Send</button>
              </div>
            </form>
          </div>
        )}

        {!showNew && openConv && otherUserInOpenConv && (
          <>
            <!-- Header -->
            <div style="padding:14px 18px;border-bottom:1px solid #1f1f26;display:flex;align-items:center;gap:12px;">
              <div style="width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#FF4F00,#FF7040);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:15px;">{initial(otherUserInOpenConv.name)}</div>
              <div>
                <div style="font-size:13.5px;font-weight:600;color:#fff;">{otherUserInOpenConv.name}</div>
                <div style="font-size:10.5px;color:#6e6e78;text-transform:capitalize;">{otherUserInOpenConv.role.replaceAll('_', ' ')} • {otherUserInOpenConv.email}</div>
              </div>
            </div>

            <!-- Messages -->
            <div style="flex:1;overflow-y:auto;padding:18px;display:flex;flex-direction:column;gap:10px;" id="message-list">
              {openMessages.length === 0 && (
                <p style="text-align:center;color:#6e6e78;font-size:12.5px;padding:30px;">No messages yet. Send the first one below.</p>
              )}
              {openMessages.map((m) => {
                const fromMe = m.senderUserId === currentUser.id;
                return (
                  <div style={'display:flex;flex-direction:column;align-items:' + (fromMe ? 'flex-end' : 'flex-start') + ';'}>
                    <div style={'max-width:65%;padding:9px 13px;border-radius:14px;' + (fromMe ? 'background:#FF4F00;color:#fff;border-bottom-right-radius:4px;' : 'background:#1a1a20;color:#e8e8ee;border-bottom-left-radius:4px;') + 'font-size:13px;line-height:1.55;white-space:pre-wrap;word-wrap:break-word;'}>
                      {m.body}
                    </div>
                    <div style="font-size:9.5px;color:#6e6e78;margin-top:3px;font-family:'Geist Mono',monospace;">
                      {fmtTimestamp(m.createdAt)}
                      {fromMe && m.readByRecipient && <span style="margin-left:6px;color:#60a5fa;">read</span>}
                    </div>
                  </div>
                );
              })}
            </div>

            <!-- Send message -->
            <form method="POST" style="padding:14px 18px;border-top:1px solid #1f1f26;display:flex;gap:10px;align-items:flex-end;">
              <input type="hidden" name="_action" value="send_message" />
              <input type="hidden" name="conversationId" value={openConvId} />
              <textarea name="body" rows="1" required placeholder="Type a message..." class="rolefield-input" style="resize:none;min-height:38px;max-height:120px;flex:1;" onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();this.form.requestSubmit();}" autofocus></textarea>
              <button type="submit" class="admin-btn admin-btn-primary" style="padding:9px 16px;font-size:12px;align-self:flex-end;">Send</button>
            </form>
          </>
        )}

        {!showNew && !openConv && (
          <div style="display:flex;align-items:center;justify-content:center;flex:1;flex-direction:column;gap:8px;">
            <p style="color:#6e6e78;font-size:14px;">Pick a conversation from the left</p>
            <p style="color:#6e6e78;font-size:12px;">or <a href="/admin/messages?new=1" style="color:#FF4F00;text-decoration:underline;">start a new one</a></p>
          </div>
        )}

      </div>
    </div>

    <script is:inline>
      // Scroll messages to bottom on load
      const ml = document.getElementById('message-list');
      if (ml) ml.scrollTop = ml.scrollHeight;
    </script>
  </div>

  <style>
    .rolefield-label { display:block;font-size:10.5px;font-weight:600;color:#8a8a94;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:6px; }
    .rolefield-input { width:100%;padding:8px 11px;background:#08080a;border:1px solid #1f1f26;border-radius:6px;color:#fff;font-size:12.5px;font-family:inherit;outline:none; }
    .rolefield-input:focus { border-color:#FF4F00; }
    textarea.rolefield-input { line-height:1.55; }
  </style>
</AdminLayout>