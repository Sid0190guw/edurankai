---
// /admin/knowledge — Course + KnowledgeObject authoring (Prompt 3, admin surface).
// Gated to admin-surface roles. Adopt an existing training_courses row into the kernel as a
// CourseObject bridge, author KnowledgeObjects (body markdown, LaTeX equations, worked
// examples, security label, learning metadata), attach them to a course (ordered part_of),
// link prerequisites, and publish/archive (publish is gated to 'execute' by the API).
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { requireAdminRole } from '@/lib/rbac';
import { contentService } from '@/lib/kernel-content';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (!(await requireAdminRole(user))) return Astro.redirect('/admin');

const rows = (r: any): any[] => (Array.isArray(r) ? r : (r?.rows || []));
const svc = contentService();

let kernelCourses: any[] = [], units: any[] = [], trainingCourses: any[] = [];
try {
  kernelCourses = (await svc.listCourses()).map((c) => ({ id: c.id, title: (c.data as any).title, trainingCourseId: (c.data as any).trainingCourseId ?? null }));
  units = (await svc.listUnits()).map((u) => ({ id: u.id, title: (u.data as any).title, state: u.lifecycleState, label: (u.securityLabels || [])[0] || 'public' }));
} catch (e) { /* kernel bootstraps on first write */ }
try {
  trainingCourses = rows(await db.execute(sql`SELECT id, title, course_code, slug FROM training_courses WHERE is_published = true ORDER BY created_at DESC LIMIT 50`));
} catch (e) { /* training tables optional */ }
const bridgedIds = new Set(kernelCourses.map((c) => c.trainingCourseId).filter(Boolean));

const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const IN = 'background:#15151a;border:1px solid #26262c;color:#fff;padding:7px 9px;border-radius:6px;font-size:12px;width:100%;box-sizing:border-box;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
const stateColor: Record<string, string> = { created: '#8a8a94', validated: '#c0a35e', indexed: '#5ea0c0', published: '#6ee7b7', archived: '#a06060', updated: '#c0a35e' };
---
<AdminLayout title="Content authoring" activeNav="knowledge">
  <div style="max-width:1120px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Kernel content</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Courses &amp; knowledge units</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">Author teaching units on the kernel object model. Publishing is capability-gated (an author cannot publish; a reviewer/faculty can). Permission console: <a href="/admin/rbac" style="color:#FF7040;">/admin/rbac</a>.</p>
    <div id="msg" style="display:none;margin:12px 0;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <!-- ADOPT A COURSE INTO THE KERNEL -->
    <div style={CARD}>
      <p style={HD}>Courses in the kernel</p>
      {kernelCourses.length === 0 ? <p style="font-size:12px;color:#6e6e78;margin:0 0 10px;">No courses adopted yet. Adopt one below to attach knowledge units to it.</p> :
        <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px;">{kernelCourses.map((c) => <span style="background:#08080a;border:1px solid #26262c;border-radius:8px;padding:5px 10px;font-size:12px;color:#cfd6da;">{c.title}{c.trainingCourseId ? ' · bridged' : ''}</span>)}</div>}
      <div style="display:flex;gap:6px;flex-wrap:wrap;align-items:end;">
        <div style="flex:1;min-width:240px;"><label style="font-size:10px;color:#8a8a94;">Adopt an existing course</label>
          <select id="adoptSel" style={IN}>
            <option value="">Select a course to bridge into the kernel</option>
            {trainingCourses.filter((t) => !bridgedIds.has(t.id)).map((t) => <option value={t.id} data-title={t.title}>{t.course_code ? t.course_code + ' — ' : ''}{t.title}</option>)}
          </select>
        </div>
        <button id="adoptBtn" type="button" style="background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:700;padding:8px 14px;border-radius:6px;cursor:pointer;">Adopt into kernel</button>
      </div>
    </div>

    <!-- CREATE A KNOWLEDGE UNIT -->
    <div style={CARD}>
      <p style={HD}>New knowledge unit</p>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div style="grid-column:1/-1;"><label style="font-size:10px;color:#8a8a94;">Title *</label><input id="nTitle" style={IN} placeholder="e.g. Limits and continuity" /></div>
        <div style="grid-column:1/-1;"><label style="font-size:10px;color:#8a8a94;">Body (markdown)</label><textarea id="nBody" rows="5" style={IN + 'font-family:Geist Mono,monospace;'} placeholder="# Heading&#10;Explain with **markdown**, lists, `code`."></textarea></div>
        <div><label style="font-size:10px;color:#8a8a94;">Equations (one LaTeX per line)</label><textarea id="nEq" rows="3" style={IN + 'font-family:Geist Mono,monospace;'} placeholder="E = mc^2&#10;\frac{dy}{dx}"></textarea></div>
        <div><label style="font-size:10px;color:#8a8a94;">Worked examples (prompt :: solution per line)</label><textarea id="nEx" rows="3" style={IN + 'font-family:Geist Mono,monospace;'} placeholder="Find dy/dx of x^2 :: 2x"></textarea></div>
        <div><label style="font-size:10px;color:#8a8a94;">Security label</label><select id="nLabel" style={IN}><option value="public">public</option><option value="enrolled-only">enrolled-only</option><option value="exam-secure">exam-secure</option></select></div>
        <div style="display:flex;gap:6px;"><div style="flex:1;"><label style="font-size:10px;color:#8a8a94;">Difficulty</label><input id="nDiff" style={IN} placeholder="intro / core / advanced" /></div><div style="width:90px;"><label style="font-size:10px;color:#8a8a94;">Minutes</label><input id="nMin" type="number" style={IN} /></div></div>
        <div><label style="font-size:10px;color:#8a8a94;">Languages (comma)</label><input id="nLang" style={IN} placeholder="en, hi, mr" /></div>
        <div style="display:flex;gap:6px;"><div style="flex:1;"><label style="font-size:10px;color:#8a8a94;">Attach to course</label><select id="nCourse" style={IN}><option value="">(none yet)</option>{kernelCourses.map((c) => <option value={c.id}>{c.title}</option>)}</select></div><div style="width:80px;"><label style="font-size:10px;color:#8a8a94;">Order</label><input id="nOrder" type="number" value="1" style={IN} /></div></div>
      </div>
      <button id="createBtn" type="button" style="background:#FF4F00;border:none;color:#fff;font-size:12px;font-weight:700;padding:9px 18px;border-radius:6px;cursor:pointer;margin-top:12px;">Create unit (draft)</button>
    </div>

    <!-- UNITS -->
    <div style={CARD}>
      <p style={HD}>Knowledge units ({units.length})</p>
      {units.length === 0 ? <p style="font-size:12px;color:#6e6e78;margin:0;">No units yet. Create one above.</p> :
      <div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:12.5px;">
        <thead><tr style="color:#8a8a94;font-size:10px;text-transform:uppercase;font-family:'Geist Mono',monospace;text-align:left;"><th style="padding:6px 8px;">Unit</th><th style="padding:6px 8px;">State</th><th style="padding:6px 8px;">Label</th><th style="padding:6px 8px;min-width:320px;">Actions</th></tr></thead>
        <tbody>
          {units.map((u) => (
            <tr style="border-top:1px solid #15151a;">
              <td style="padding:8px;"><a href={'/aquintutor/lesson/' + u.id} style="color:#cfd6da;text-decoration:none;font-weight:600;">{u.title}</a></td>
              <td style="padding:8px;"><span style={'font-family:Geist Mono,monospace;font-size:11px;font-weight:700;color:' + (stateColor[u.state] || '#8a8a94')}>{u.state}</span></td>
              <td style="padding:8px;color:#8a8a94;font-family:'Geist Mono',monospace;font-size:11px;">{u.label}</td>
              <td style="padding:8px;">
                <div style="display:flex;gap:5px;flex-wrap:wrap;align-items:center;">
                  {u.state !== 'published' && u.state !== 'archived' ? <button class="pubBtn" data-id={u.id} type="button" style="background:#0f2f22;border:1px solid #1f5f42;color:#6ee7b7;font-size:11px;padding:5px 10px;border-radius:6px;cursor:pointer;">Publish</button> : null}
                  {u.state !== 'archived' ? <button class="arcBtn" data-id={u.id} type="button" style="background:#2a1414;border:1px solid #5f2f2f;color:#fca5a5;font-size:11px;padding:5px 10px;border-radius:6px;cursor:pointer;">Archive</button> : null}
                  <select class="preSel" data-id={u.id} style={IN + 'width:auto;'}><option value="">+ prerequisite</option>{units.filter((o) => o.id !== u.id).map((o) => <option value={o.id}>{o.title}</option>)}</select>
                  <button class="preBtn" data-id={u.id} type="button" style="background:#15151a;border:1px solid #26262c;color:#cfd6da;font-size:11px;padding:5px 10px;border-radius:6px;cursor:pointer;">Link</button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table></div>}
    </div>
  </div>

  <script is:inline>
    (function () {
      var msg = document.getElementById('msg');
      function flash(t, ok) { msg.style.display = 'block'; msg.textContent = t; msg.style.background = ok ? 'rgba(16,185,129,0.12)' : 'rgba(239,68,68,0.12)'; msg.style.color = ok ? '#6ee7b7' : '#fca5a5'; }
      function post(body) {
        return fetch('/api/admin/knowledge', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
          .then(function (r) { return r.json(); })
          .then(function (j) { if (j.ok) { flash('Saved.', true); setTimeout(function () { location.reload(); }, 500); } else { flash(j.error || 'Failed', false); } return j; })
          .catch(function () { flash('Network error', false); });
      }
      var adopt = document.getElementById('adoptBtn');
      adopt && adopt.addEventListener('click', function () { var s = document.getElementById('adoptSel'); var o = s.options[s.selectedIndex]; if (!s.value) return flash('Pick a course', false); post({ action: 'ensureCourse', trainingCourseId: s.value, title: o.getAttribute('data-title') }); });
      document.getElementById('createBtn').addEventListener('click', function () {
        post({ action: 'createUnit', title: document.getElementById('nTitle').value, body: document.getElementById('nBody').value, equations: document.getElementById('nEq').value, examples: document.getElementById('nEx').value, securityLabel: document.getElementById('nLabel').value, difficulty: document.getElementById('nDiff').value, estimatedMinutes: document.getElementById('nMin').value, languages: document.getElementById('nLang').value, courseObjId: document.getElementById('nCourse').value, order: document.getElementById('nOrder').value });
      });
      document.querySelectorAll('.pubBtn').forEach(function (b) { b.addEventListener('click', function () { post({ action: 'publishUnit', id: b.getAttribute('data-id') }); }); });
      document.querySelectorAll('.arcBtn').forEach(function (b) { b.addEventListener('click', function () { post({ action: 'archiveUnit', id: b.getAttribute('data-id') }); }); });
      document.querySelectorAll('.preBtn').forEach(function (b) { b.addEventListener('click', function () { var id = b.getAttribute('data-id'); var sel = document.querySelector('.preSel[data-id="' + id + '"]'); if (!sel.value) return flash('Pick a prerequisite', false); post({ action: 'addPrerequisite', unitId: id, prerequisiteUnitId: sel.value }); }); });
    })();
  </script>
</AdminLayout>
