---
// /admin/study-abroad/consultants — consultant pool management.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { ensureStudyAbroadSchema, listConsultants } from '@/lib/study-abroad';

const user = Astro.locals.user!;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

await ensureStudyAbroadSchema();
function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const action = (fd.get('_action') as string || '').trim();
    if (action === 'add') {
      const email = (fd.get('email') as string || '').trim().toLowerCase();
      const displayName = (fd.get('display_name') as string || '').trim().slice(0, 200);
      const bio = (fd.get('bio') as string || '').trim().slice(0, 4000);
      const countries = (fd.get('countries') as string || '').split(',').map(s => s.trim()).filter(Boolean);
      const specs = (fd.get('specialisations') as string || '').split(',').map(s => s.trim()).filter(Boolean);
      const langs = (fd.get('languages') as string || '').split(',').map(s => s.trim()).filter(Boolean);
      const cap = parseInt(fd.get('active_case_cap') as string || '25') || 25;
      if (!email || !displayName) { errMsg = 'Email and display name are required.'; }
      else {
        const u = rows(await db.execute(sql`SELECT id FROM users WHERE LOWER(email) = ${email} LIMIT 1`))[0] as any;
        if (!u) errMsg = 'No user with that email. The consultant must already have an EduRankAI account.';
        else {
          await db.execute(sql`
            INSERT INTO study_abroad_consultants (user_id, display_name, bio, countries, specialisations, languages, active_case_cap)
            VALUES (${u.id}, ${displayName}, ${bio || null}, ${countries}, ${specs}, ${langs}, ${cap})
            ON CONFLICT (user_id) DO UPDATE SET display_name = EXCLUDED.display_name, bio = EXCLUDED.bio, countries = EXCLUDED.countries, specialisations = EXCLUDED.specialisations, languages = EXCLUDED.languages, active_case_cap = EXCLUDED.active_case_cap, is_active = true, updated_at = NOW()
          `);
          okMsg = 'Consultant added / updated.';
        }
      }
    } else if (action === 'toggle') {
      const id = (fd.get('id') as string || '').trim();
      await db.execute(sql`UPDATE study_abroad_consultants SET is_active = NOT is_active, updated_at = NOW() WHERE id = ${id}`);
      okMsg = 'Toggled.';
    }
  } catch (e: any) { errMsg = 'Failed: ' + (e?.message || 'unknown'); }
}

const all = await listConsultants();
---
<AdminLayout title="Study Abroad Consultants" activeNav="">
<div style="padding-bottom:80px;">
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">Study Abroad</p>
    <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Consultant pool</h1>
    <p style="font-size:11.5px;color:#9aa6b6;margin:4px 0 0;">Add staff users as consultants. They appear in the assign-to dropdown on the request queue.</p>
  </div>

  {okMsg && <div style="margin:12px 16px;background:rgba(16,185,129,0.10);border:1px solid rgba(16,185,129,0.30);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}
  {errMsg && <div style="margin:12px 16px;background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.30);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errMsg}</div>}

  <div style="padding:14px 16px;display:flex;flex-direction:column;gap:14px;">
    <form method="POST" style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px 16px;">
      <p style="font-size:13px;color:#fff;font-weight:700;margin:0 0 12px;">Add a consultant</p>
      <input type="hidden" name="_action" value="add" />
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:10px;margin-bottom:10px;">
        <input name="email" type="email" required placeholder="user@edurankai.in" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 11px;border-radius:6px;font-size:12px;font-family:'Geist Mono',monospace;" />
        <input name="display_name" type="text" required placeholder="Display name (as shown to applicants)" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 11px;border-radius:6px;font-size:12px;" />
        <input name="active_case_cap" type="number" min="1" max="200" value="25" placeholder="Max active cases" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 11px;border-radius:6px;font-size:12px;" />
      </div>
      <textarea name="bio" rows="2" placeholder="Short bio shown to applicants" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 11px;border-radius:6px;font-size:12px;margin-bottom:8px;font-family:'Inter Tight',sans-serif;resize:vertical;outline:none;"></textarea>
      <input name="countries" type="text" placeholder="Countries they cover, comma-separated (UK, Germany, Canada)" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 11px;border-radius:6px;font-size:12px;margin-bottom:8px;" />
      <input name="specialisations" type="text" placeholder="Specialisations, comma-separated (MBA, STEM PhDs)" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 11px;border-radius:6px;font-size:12px;margin-bottom:8px;" />
      <input name="languages" type="text" placeholder="Languages, comma-separated (English, Hindi, German)" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 11px;border-radius:6px;font-size:12px;margin-bottom:10px;" />
      <button type="submit" style="background:#FF4F00;color:#fff;border:none;font-size:12.5px;font-weight:700;padding:9px 18px;border-radius:7px;cursor:pointer;">Add / update consultant</button>
    </form>

    {all.length === 0 ? (
      <p style="color:#6e6e78;font-size:13px;text-align:center;padding:20px;">No consultants yet.</p>
    ) : (
      <div style="display:flex;flex-direction:column;gap:8px;">
        {all.map((c: any) => (
          <div style={`background:#0f0f14;border:1px solid ${c.is_active ? '#1a1a1f' : 'rgba(115,115,115,0.4)'};border-radius:12px;padding:14px 16px;${!c.is_active ? 'opacity:0.6;' : ''}`}>
            <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;flex-wrap:wrap;">
              <div>
                <p style="font-size:14px;font-weight:700;color:#fff;margin:0;">{c.display_name} {!c.is_active && <span style="font-size:10px;color:#9aa6b6;">(inactive)</span>}</p>
                <p style="font-size:11px;color:#8a8a94;margin:3px 0 0;">{(c.active_cases || 0)} / {c.active_case_cap} active cases</p>
                {c.bio && <p style="font-size:12px;color:#d8d8de;margin:6px 0 0;line-height:1.5;">{c.bio}</p>}
                {(c.countries || []).length > 0 && <p style="font-size:11.5px;color:#9aa6b6;margin:4px 0 0;">Countries: {(c.countries || []).join(', ')}</p>}
                {(c.specialisations || []).length > 0 && <p style="font-size:11.5px;color:#9aa6b6;margin:2px 0 0;">Specialisations: {(c.specialisations || []).join(', ')}</p>}
                {(c.languages || []).length > 0 && <p style="font-size:11.5px;color:#9aa6b6;margin:2px 0 0;">Languages: {(c.languages || []).join(', ')}</p>}
              </div>
              <form method="POST" style="margin:0;">
                <input type="hidden" name="_action" value="toggle" />
                <input type="hidden" name="id" value={c.id} />
                <button type="submit" style="background:#15151a;border:1px solid #2a2a2f;color:#9aa6b6;font-size:11px;font-weight:600;padding:6px 12px;border-radius:6px;cursor:pointer;">{c.is_active ? 'Deactivate' : 'Reactivate'}</button>
              </form>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>

  <div style="padding:14px 16px;">
    <a href="/admin/study-abroad" style="font-size:12px;color:#FF7040;text-decoration:none;font-weight:600;">← Back to request queue</a>
  </div>
</div>
</AdminLayout>
