---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
function slugify(s: string) { return s.toLowerCase().replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '').slice(0, 60); }
let okMsg = '', errMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action');
  try {
    if (action === 'create') {
      const title = (fd.get('title') as string || '').trim();
      const description = (fd.get('description') as string || '').trim() || null;
      const feeChf = parseInt(fd.get('fee_chf') as string || '0') || 0;
      if (!title) errMsg = 'Title required';
      else {
        let base = slugify(title) || 'form'; let slug = base; let n = 1;
        while (rows(await db.execute(sql`SELECT id FROM forms WHERE slug = ${slug} LIMIT 1`)).length) { n++; slug = base + '-' + n; }
        const defaultFields = JSON.stringify([
          { key: 'full_name', type: 'text', label: 'Full name', required: true },
          { key: 'email', type: 'email', label: 'Email', required: true },
          { key: 'phone', type: 'phone', label: 'Phone', required: true },
        ]);
        await db.execute(sql`INSERT INTO forms (slug, title, description, fee_chf, fields, created_by) VALUES (${slug}, ${title}, ${description}, ${feeChf}, ${sql.raw("'" + defaultFields.replace(/'/g, "''") + "'::jsonb")}, ${user.id})`);
        okMsg = 'Form created: ' + slug;
      }
    } else if (action === 'delete') {
      const id = (fd.get('id') as string || '').trim();
      if (id) { await db.execute(sql`DELETE FROM forms WHERE id = ${id}`); okMsg = 'Form deleted.'; }
    }
  } catch (e: any) { errMsg = 'Failed: ' + (e?.message || 'error'); }
}

const list = rows(await db.execute(sql`SELECT f.*, (SELECT COUNT(*)::int FROM form_responses r WHERE r.form_id = f.id) AS responses FROM forms f ORDER BY f.created_at DESC LIMIT 200`));
const origin = Astro.url.origin;
---
<AdminLayout title="Forms" activeNav="forms">
  <div class="admin-page" style="max-width:1100px;">
    <div class="admin-page-header" style="margin-bottom:18px;">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">Forms</div>
        <h1 class="admin-page-title">Form builder</h1>
        <p class="admin-page-sub">Build custom forms (like Google / Zoho Forms) for event registration, surveys, or any collection. Add a fee to collect payment on submit. Share a public link; anyone can fill without an account.</p>
      </div>
    </div>
    {errMsg && <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 13px;margin-bottom:14px;font-size:12.5px;">{errMsg}</div>}
    {okMsg && <div style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 13px;margin-bottom:14px;font-size:12.5px;">{okMsg}</div>}

    <div style="display:grid;grid-template-columns:1.5fr 1fr;gap:18px;align-items:start;">
      <div style="display:flex;flex-direction:column;gap:10px;">
        {list.map((f: any) => (
          <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px 16px;">
            <div style="display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;">
              <div>
                <p style="font-size:14px;font-weight:700;color:#fff;margin:0;">{f.title} {f.is_published ? <span style="font-size:10px;color:#6ee7b7;">(live)</span> : <span style="font-size:10px;color:#fbbf24;">(draft)</span>}</p>
                <p style="font-size:11.5px;color:#8a8a94;margin:3px 0 0;">{(Array.isArray(f.fields) ? f.fields.length : 0)} fields · {f.responses} responses · {f.fee_chf > 0 ? f.fee_chf + ' CHF fee' : 'free'}</p>
              </div>
            </div>
            <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-top:10px;">
              <a href={'/admin/forms/' + f.id} style="font-size:11px;color:#FF7040;font-weight:600;text-decoration:none;">Build / responses</a>
              <span style="color:#2a2a30;">|</span>
              <input readonly value={origin + '/f/' + f.slug} onclick="this.select();document.execCommand('copy');" style="flex:1;min-width:160px;font-size:11px;font-family:monospace;background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;padding:5px 8px;border-radius:6px;" title="Click to copy public link" />
              <a href={'/f/' + f.slug} target="_blank" style="font-size:11px;color:#60a5fa;text-decoration:none;">Open</a>
              <form method="POST" style="display:inline;" onsubmit="return confirm('Delete this form and all responses?');"><input type="hidden" name="action" value="delete" /><input type="hidden" name="id" value={f.id} /><button type="submit" style="font-size:11px;color:#fca5a5;background:none;border:none;cursor:pointer;">delete</button></form>
            </div>
          </div>
        ))}
        {list.length === 0 && <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:24px;text-align:center;color:#6e6e78;font-size:13px;">No forms yet.</div>}
      </div>

      <form method="POST" style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:16px;display:flex;flex-direction:column;gap:10px;">
        <input type="hidden" name="action" value="create" />
        <p style="font-size:13px;font-weight:700;color:#fff;margin:0;">+ New form</p>
        <input name="title" required placeholder="Form title (e.g. Bootcamp Registration)" class="ff" />
        <textarea name="description" rows="2" placeholder="Short description (optional)" class="ff"></textarea>
        <label style="font-size:10px;color:#8a8a94;text-transform:uppercase;font-family:monospace;">Fee (CHF, 0 = free)<input name="fee_chf" type="number" min="0" value="0" class="ff" /></label>
        <button type="submit" class="admin-btn admin-btn-primary" style="justify-content:center;">Create &amp; build fields</button>
      </form>
    </div>
  </div>
  <style>.ff{width:100%;padding:8px 11px;background:#08080a;border:1px solid #1f1f26;border-radius:6px;color:#fff;font-size:12.5px;font-family:inherit;outline:none;}.ff:focus{border-color:#FF4F00;}</style>
</AdminLayout>
