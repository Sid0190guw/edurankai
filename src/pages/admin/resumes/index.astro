---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { listResumes, deleteResume } from '@/lib/resume';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role !== 'super_admin') return Astro.redirect('/admin');

let okMsg = '';
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  if (fd.get('_action') === 'delete' && fd.get('id')) {
    try { await deleteResume(fd.get('id') as string); okMsg = 'Resume deleted.'; } catch (_) {}
  }
}

const url = new URL(Astro.request.url);
const q = (url.searchParams.get('q') || '').trim();
const items = await listResumes(q);
const fmt = (d: any) => d ? new Date(d).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) : '-';
---
<AdminLayout title="Resume Submissions" activeNav="resumes">
  <div class="admin-page" style="max-width:1100px;">
    <div class="admin-page-header">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">Tools</div>
        <h1 class="admin-page-title">Resume Submissions</h1>
        <p class="admin-page-sub">Every resume generated with the public builder — captured for quality &amp; security. Super-admin only. {items.length} total.</p>
      </div>
    </div>

    {okMsg && <div style="margin:0 0 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

    <form method="GET" style="display:flex;gap:8px;margin-bottom:16px;max-width:460px;">
      <input type="text" name="q" value={q} placeholder="Search name, email, title..." style="flex:1;background:#0f0f14;border:1px solid #1a1a1f;border-radius:8px;padding:9px 12px;color:#fff;font-size:13px;outline:none;" />
      <button type="submit" style="background:#FF4F00;border:none;color:#fff;font-size:13px;font-weight:600;padding:9px 16px;border-radius:8px;cursor:pointer;">Search</button>
      {q && <a href="/admin/resumes" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;font-size:13px;text-decoration:none;padding:9px 14px;border-radius:8px;display:inline-flex;align-items:center;">Clear</a>}
    </form>

    {items.length === 0 ? (
      <div style="text-align:center;padding:48px;color:#6e6e78;font-size:13px;">No resume submissions yet.</div>
    ) : (
      <div style="display:flex;flex-direction:column;gap:8px;">
        {items.map((r) => (
          <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:13px 16px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;">
            <div style="flex:1;min-width:200px;">
              <p style="font-size:14px;font-weight:600;color:#fff;margin:0;">{r.full_name || '(no name)'}
                {r.user_id
                  ? <span style="font-size:9px;font-weight:700;text-transform:uppercase;color:#60a5fa;background:rgba(96,165,250,0.12);padding:2px 7px;border-radius:100px;margin-left:8px;">Account</span>
                  : <span style="font-size:9px;font-weight:700;text-transform:uppercase;color:#6e6e78;background:rgba(110,110,120,0.12);padding:2px 7px;border-radius:100px;margin-left:8px;">Guest</span>}
              </p>
              <p style="font-size:12px;color:#8a8a94;margin:3px 0 0;">{r.email || 'no email'} · {r.template || '-'}{r.level ? ' · ' + r.level : ''} · {fmt(r.created_at)}</p>
            </div>
            <div style="display:flex;gap:6px;align-items:center;">
              <a href={'/admin/resumes/' + r.id} style="font-size:12px;color:#FF7040;text-decoration:none;padding:7px 12px;border:1px solid #1a1a1f;border-radius:7px;font-weight:600;">View / edit</a>
              <form method="POST" onsubmit="return confirm('Delete this submission?');">
                <input type="hidden" name="_action" value="delete" />
                <input type="hidden" name="id" value={r.id} />
                <button type="submit" style="font-size:12px;color:#fca5a5;background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);padding:7px 12px;border-radius:7px;cursor:pointer;">Delete</button>
              </form>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</AdminLayout>
