---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { getResume, updateResume, deleteResume } from '@/lib/resume';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role !== 'super_admin') return Astro.redirect('/admin');

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/resumes');

let msg = '';
let msgOk = true;
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('_action');
  if (action === 'delete') {
    try { await deleteResume(id); return Astro.redirect('/admin/resumes'); } catch (_) {}
  } else if (action === 'save') {
    let parsed: any = null;
    try { parsed = JSON.parse((fd.get('data') as string) || '{}'); }
    catch (e: any) { msg = 'Invalid JSON: ' + (e?.message || ''); msgOk = false; }
    if (parsed) {
      try {
        await updateResume(id, {
          fullName: (fd.get('full_name') as string || '').trim(),
          email: (fd.get('email') as string || '').trim(),
          template: (fd.get('template') as string || '').trim(),
          data: parsed,
        });
        msg = 'Saved.';
      } catch (e: any) { msg = 'Save failed.'; msgOk = false; }
    }
  }
}

const r = await getResume(id);
if (!r) return Astro.redirect('/admin/resumes');
const d = (r.data || {}) as any;
const dataPretty = JSON.stringify(d, null, 2);
const fmt = (x: any) => x ? new Date(x).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' }) : '-';
const section = (label: string, items: any[], render: (e: any) => string) =>
  (Array.isArray(items) && items.length) ? { label, html: items.map(render).join('') } : null;
const blocks = [
  section('Experience', d.experience, (e) => '<b>' + (e.title || '') + '</b> ' + (e.org || '') + ' <span>' + (e.period || '') + '</span><p>' + (e.detail || '') + '</p>'),
  section('Education', d.education, (e) => '<b>' + (e.school || '') + '</b> ' + (e.degree || '') + ' <span>' + (e.period || '') + '</span>'),
  section('Projects', d.projects, (e) => '<b>' + (e.title || '') + '</b> <span>' + (e.period || '') + '</span><p>' + (e.detail || '') + '</p>'),
  section('Achievements', d.achievements, (e) => '<b>' + (e.title || '') + '</b> <span>' + (e.when || '') + '</span>'),
].filter(Boolean) as { label: string; html: string }[];
---
<AdminLayout title="Resume submission" activeNav="resumes">
  <div class="admin-page" style="max-width:880px;">
    <div class="admin-page-header">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow"><a href="/admin/resumes" style="color:#6e6e78;text-decoration:none;">← Resumes</a></div>
        <h1 class="admin-page-title">{r.full_name || '(no name)'}</h1>
        <p class="admin-page-sub">{r.email || 'no email'} · {r.template || '-'} · {r.user_id ? 'Account user' : 'Guest'} · {fmt(r.created_at)}{r.ip ? ' · ' + r.ip : ''}</p>
      </div>
    </div>

    {msg && <div style={'margin:0 0 16px;border-radius:8px;padding:10px 14px;font-size:13px;' + (msgOk ? 'background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;' : 'background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;')}>{msg}</div>}

    {blocks.length > 0 && (
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:16px;margin-bottom:16px;">
        <p style="font-size:13px;font-weight:600;color:#fff;margin:0 0 10px;">Content preview</p>
        {d.summary && <p style="font-size:12.5px;color:#c8c8d0;line-height:1.6;margin:0 0 12px;">{d.summary}</p>}
        {blocks.map((b) => (
          <div style="margin-bottom:12px;">
            <p style="font-size:10px;font-weight:800;letter-spacing:0.1em;text-transform:uppercase;color:#FF7040;margin:0 0 6px;">{b.label}</p>
            <div class="res-prev" set:html={b.html}></div>
          </div>
        ))}
      </div>
    )}

    <form method="POST">
      <input type="hidden" name="_action" value="save" />
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:16px;margin-bottom:14px;">
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;">
          <div><label class="r-l">Full name</label><input name="full_name" value={r.full_name || ''} class="r-i" /></div>
          <div><label class="r-l">Email</label><input name="email" value={r.email || ''} class="r-i" /></div>
          <div><label class="r-l">Template</label><input name="template" value={r.template || ''} class="r-i" /></div>
        </div>
        <label class="r-l" style="margin-top:12px;">Full data (JSON — full control)</label>
        <textarea name="data" rows="20" class="r-i" style="font-family:ui-monospace,monospace;font-size:12px;line-height:1.5;white-space:pre;">{dataPretty}</textarea>
      </div>
      <div style="display:flex;gap:8px;">
        <button type="submit" style="flex:1;background:#FF4F00;border:none;color:#fff;font-weight:700;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">Save changes</button>
      </div>
    </form>

    <form method="POST" onsubmit="return confirm('Delete this submission permanently?');" style="margin-top:10px;">
      <input type="hidden" name="_action" value="delete" />
      <button type="submit" style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);color:#fca5a5;font-size:13px;padding:9px 16px;border-radius:8px;cursor:pointer;">Delete submission</button>
    </form>
  </div>

  <style>
    .r-l { display:block; font-size:10px; text-transform:uppercase; letter-spacing:0.08em; color:#8a8a94; font-weight:700; margin-bottom:4px; }
    .r-i { width:100%; background:#08080a; border:1px solid #1a1a1f; border-radius:8px; padding:9px 11px; color:#fff; font-size:13px; outline:none; }
    .r-i:focus { border-color:#FF4F00; }
    .res-prev b { color:#fff; font-size:12.5px; } .res-prev span { color:#8a8a94; font-size:11.5px; } .res-prev p { color:#a8a8b0; font-size:12px; margin:2px 0 8px; }
  </style>
</AdminLayout>
