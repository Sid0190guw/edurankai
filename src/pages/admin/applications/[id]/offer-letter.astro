---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { applications, offerLetters, users } from '@/lib/db/schema';
import { generateInternalHandle } from '@/lib/auth/handle';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/applications');

let errorMsg = '';
let successMsg = '';

const found = await db.select().from(applications).where(eq(applications.id, id)).limit(1);
if (found.length === 0) return Astro.redirect('/admin/applications');
const app: any = found[0];

const existing = await db.select().from(offerLetters).where(eq(offerLetters.applicationId, id)).limit(1);
let existingOffer = existing.length > 0 ? existing[0] : null;

function genToken(): string {
  const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789abcdefghjkmnpqrstuvwxyz';
  let t = '';
  for (let i = 0; i < 32; i++) t += chars[Math.floor(Math.random() * chars.length)];
  return t;
}

function fnvHash(s: string): string {
  let h = 2166136261;
  for (let i = 0; i < s.length; i++) {
    h = h ^ s.charCodeAt(i);
    h = Math.imul(h, 16777619);
  }
  return (h >>> 0).toString(36).toUpperCase().padStart(8, '0').substring(0, 8);
}

function genPassword(): string {
  const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789';
  let p = '';
  for (let i = 0; i < 16; i++) {
    if (i > 0 && i % 4 === 0) p += '-';
    p += chars[Math.floor(Math.random() * chars.length)];
  }
  return p;
}

async function createUserAccount(email: string, fullName: string, plaintextPw: string, templateType: string): Promise<{userId: string, handle: string} | null> {
  try {
    const { hashPassword } = await import('@/lib/auth/password');
    const existing = await db.select({ id: users.id }).from(users).where(eq(users.email, email)).limit(1);
    if (existing.length > 0) {
      const hashed = await hashPassword(plaintextPw);
      await db.update(users).set({ passwordHash: hashed, updatedAt: new Date() }).where(eq(users.id, existing[0].id));
      const existingUserId = existing[0].id;
      // Get or generate handle for existing user
      const u = await db.select({ h: users.internalHandle, n: users.name }).from(users).where(eq(users.id, existingUserId)).limit(1);
      let handle = u[0]?.h || null;
      if (!handle) {
        handle = await generateInternalHandle(fullName);
        await db.update(users).set({ internalHandle: handle }).where(eq(users.id, existingUserId));
      }
      return { userId: existingUserId, handle };
    }
    let role: any = 'editor';
    if (templateType === 'leadership') role = 'super_admin';
    const hashed = await hashPassword(plaintextPw);
    const inserted = await db.insert(users).values({
      email,
      name: fullName,
      passwordHash: hashed,
      role,
      isActive: true
    }).returning({ id: users.id });
    const newUserId = inserted[0]?.id;
    if (!newUserId) return null;
    const handle = await generateInternalHandle(fullName);
    await db.update(users).set({ internalHandle: handle }).where(eq(users.id, newUserId));
    return { userId: newUserId, handle };
  } catch (e) {
    console.error('createUserAccount failed:', e);
    return null;
  }
}

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;

  try {
    if (action === 'generate') {
      const candidateName = ((fd.get('candidateName') as string) || '').trim();
      const candidateEmail = ((fd.get('candidateEmail') as string) || '').trim();
      const roleTitle = ((fd.get('roleTitle') as string) || '').trim();
      const department = ((fd.get('department') as string) || '').trim();
      const templateType = ((fd.get('templateType') as string) || 'intern').trim();
      const employmentType = ((fd.get('employmentType') as string) || '').trim();
      const workMode = ((fd.get('workMode') as string) || 'Remote').trim();
      const duration = ((fd.get('duration') as string) || '').trim();
      const hoursCommitment = ((fd.get('hoursCommitment') as string) || '').trim();
      const compensation = ((fd.get('compensation') as string) || 'Unpaid').trim();
      const reportingTo = ((fd.get('reportingTo') as string) || '').trim();
      const candidatePhone = ((fd.get('candidatePhone') as string) || '').trim();
      const candidateCity = ((fd.get('candidateCity') as string) || '').trim();
      const offerDate = ((fd.get('offerDate') as string) || '').trim();
      const joiningDate = ((fd.get('joiningDate') as string) || '').trim();
      const expiryDate = ((fd.get('expiryDate') as string) || '').trim();
      const responseDeadline = ((fd.get('responseDeadline') as string) || '').trim();
      const signatoryName = ((fd.get('signatoryName') as string) || '').trim();
      const signatoryTitle = ((fd.get('signatoryTitle') as string) || '').trim();
      const customNote = ((fd.get('customNote') as string) || '').trim();
      const refNumber = ((fd.get('refNumber') as string) || '').trim();

      if (!candidateName || !candidateEmail || !roleTitle || !signatoryName) {
        errorMsg = 'Required: candidate name, email, role, and signatory.';
      } else {
        const integrityHash = fnvHash([refNumber, candidateName, roleTitle, department, offerDate, employmentType].join('|'));
        const contentBlob = {
          candidateName, candidateEmail, candidatePhone, candidateCity,
          roleTitle, department, employmentType, workMode, duration,
          hoursCommitment, compensation, reportingTo,
          offerDate, joiningDate, expiryDate, responseDeadline,
          signatoryName, signatoryTitle, customNote, templateType
        };

        if (existingOffer) {
          await db.update(offerLetters).set({
            templateType, content: contentBlob,
            candidateName, candidateEmail, roleTitle, department,
            refNumber, integrityHash,
            offerDate: offerDate || null,
            joiningDate: joiningDate || null,
            expiryDate: expiryDate || null,
            responseDeadline: responseDeadline || null,
            updatedAt: new Date()
          }).where(eq(offerLetters.id, existingOffer.id));
          successMsg = 'Offer updated. Token: ' + existingOffer.token;
        } else {
          const token = genToken();
          const plaintextPw = genPassword();
          const accountResult = await createUserAccount(candidateEmail, candidateName, plaintextPw, templateType);
          const createdUserId = accountResult?.userId || null;
          const internalHandle = accountResult?.handle || null;

          await db.insert(offerLetters).values({
            token,
            applicationId: id,
            generatedByUserId: user.id,
            status: 'sent',
            templateType,
            content: contentBlob,
            candidateName,
            candidateEmail,
            roleTitle,
            department: department || null,
            refNumber,
            integrityHash,
            offerDate: offerDate || null,
            joiningDate: joiningDate || null,
            expiryDate: expiryDate || null,
            responseDeadline: responseDeadline || null,
            plaintextPassword: plaintextPw,
            createdUserId: createdUserId
          });
          successMsg = 'Offer created. Token: ' + token + '. Login: ' + candidateEmail + (internalHandle ? ' OR ' + internalHandle : '');
        }
      }
    } else if (action === 'withdraw' && existingOffer) {
      const reason = ((fd.get('reason') as string) || '').trim();
      await db.update(offerLetters).set({
        status: 'withdrawn',
        withdrawnAt: new Date(),
        withdrawnReason: reason || null,
        updatedAt: new Date()
      }).where(eq(offerLetters.id, existingOffer.id));
      successMsg = 'Offer withdrawn.';
    }
  } catch (err: any) {
    errorMsg = 'Failed: ' + (err.message || 'Unknown');
  }

  const refresh = await db.select().from(offerLetters).where(eq(offerLetters.applicationId, id)).limit(1);
  existingOffer = refresh.length > 0 ? refresh[0] : null;
}

const currentOffer = existingOffer;
const shortId = id.substring(0, 8).toUpperCase();
const fullName = ((app.firstName || '') + ' ' + (app.lastName || '')).trim();
const defaultRef = 'ERA-2026-' + shortId.substring(0, 6);

const fallbackDefaults = {
  candidateName: fullName,
  candidateEmail: app.email,
  candidatePhone: app.phone || '',
  candidateCity: app.city || '',
  roleTitle: app.roleTitleSnapshot || '',
  department: app.departmentSnapshot || '',
  employmentType: app.engagementType || 'Internship',
  workMode: 'Remote',
  duration: app.level === 'Intern' ? '3 Months' : '12 Months',
  hoursCommitment: app.level === 'Intern' ? '2.5 hrs/day, 5 days/week' : 'Full-time',
  compensation: (app.level === 'Intern' || app.level === 'Apprentice') ? 'Unpaid' : (app.compensation || 'To be discussed'),
  reportingTo: '',
  offerDate: new Date().toISOString().split('T')[0],
  joiningDate: '',
  expiryDate: '',
  responseDeadline: '',
  signatoryName: user.name || 'Siddharth Prasad',
  signatoryTitle: 'Founder & CEO',
  customNote: '',
  templateType: (app.level === 'Intern' || app.level === 'Apprentice') ? 'intern' : 'fulltime'
};

const defaults: any = currentOffer && currentOffer.content ? currentOffer.content : fallbackDefaults;
const refNum = (currentOffer && currentOffer.refNumber) ? currentOffer.refNumber : defaultRef;
const isWithdrawn = currentOffer && currentOffer.status === 'withdrawn';
const isSigned = currentOffer && currentOffer.status === 'signed';
---
<AdminLayout title="Offer Letter" description="Generate and manage offer letter">

  <div class="mb-4">
    <a href={'/admin/applications/' + id} class="text-[0.78rem] text-white/50 hover:text-white">&larr; Back to application</a>
  </div>

  {errorMsg && <div class="bg-red-500/10 border border-red-500/30 text-red-300 rounded-lg p-3 mb-4 text-[0.85rem]">{errorMsg}</div>}
  {successMsg && <div class="bg-leaf-bg/20 border border-leaf-border/50 text-leaf rounded-lg p-3 mb-4 text-[0.85rem]">{successMsg}</div>}

  <div class="mb-5 pb-4 border-b border-white/8">
    <p class="font-mono text-[0.7rem] text-white/40">{shortId}</p>
    <h1 class="font-display text-[1.6rem] font-semibold text-white">Offer Letter</h1>
    <p class="text-[0.85rem] text-white/60 mt-1">For <strong class="text-white">{fullName}</strong> &middot; {app.roleTitleSnapshot}</p>
  </div>

  {currentOffer && (
    <div class={'mb-5 p-4 rounded-xl border ' + (isSigned ? 'bg-leaf-bg/20 border-leaf-border/50' : isWithdrawn ? 'bg-red-500/10 border-red-500/30' : 'bg-burn-pale/20 border-burn-dim/50')}>
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
        <div>
          <p class="text-[0.62rem] font-mono uppercase tracking-wider font-bold mb-1">
            {isSigned ? 'SIGNED BY APPLICANT' : isWithdrawn ? 'WITHDRAWN' : 'SENT - AWAITING SIGNATURE'}
          </p>
          <p class="text-[0.85rem] text-white/80">Token: <span class="font-mono text-white">{currentOffer.token}</span></p>
          <p class="text-[0.78rem] text-white/60 mt-1">Ref: {currentOffer.refNumber} &middot; Hash: {currentOffer.integrityHash}</p>
        </div>
        <div class="flex flex-col gap-2 text-right">
          <a href={'/portal/offer/' + currentOffer.token} target="_blank" class="text-[0.78rem] text-burn hover:underline font-mono">Applicant link &rarr;</a>
          <a href={'/offer/verify/' + currentOffer.token} target="_blank" class="text-[0.78rem] text-sky hover:underline font-mono">Public verify &rarr;</a>
        </div>
      </div>
    </div>
  )}

  <form method="POST" class="grid grid-cols-1 lg:grid-cols-3 gap-5">
    <input type="hidden" name="action" value="generate" />

    <div class="lg:col-span-2 flex flex-col gap-4">

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Candidate</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div><label class="ofl">Name *</label><input type="text" name="candidateName" required value={defaults.candidateName} class="ofi" /></div>
          <div><label class="ofl">Email *</label><input type="email" name="candidateEmail" required value={defaults.candidateEmail} class="ofi" /></div>
          <div><label class="ofl">Phone</label><input type="text" name="candidatePhone" value={defaults.candidatePhone} class="ofi" /></div>
          <div><label class="ofl">City</label><input type="text" name="candidateCity" value={defaults.candidateCity} class="ofi" /></div>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Role &amp; Terms</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div><label class="ofl">Role *</label><input type="text" name="roleTitle" required value={defaults.roleTitle} class="ofi" /></div>
          <div><label class="ofl">Department</label><input type="text" name="department" value={defaults.department} class="ofi" /></div>
          <div><label class="ofl">Employment Type</label>
            <select name="employmentType" class="ofi">
              <option value="Internship" selected={defaults.employmentType === 'Internship'}>Internship</option>
              <option value="Apprenticeship" selected={defaults.employmentType === 'Apprenticeship'}>Apprenticeship</option>
              <option value="Full-Time" selected={defaults.employmentType === 'Full-Time'}>Full-Time</option>
              <option value="Contract" selected={defaults.employmentType === 'Contract'}>Contract</option>
              <option value="Part-Time" selected={defaults.employmentType === 'Part-Time'}>Part-Time</option>
            </select>
          </div>
          <div><label class="ofl">Work Mode</label>
            <select name="workMode" class="ofi">
              <option value="Remote" selected={defaults.workMode === 'Remote'}>Remote</option>
              <option value="Hybrid" selected={defaults.workMode === 'Hybrid'}>Hybrid</option>
              <option value="On-Site" selected={defaults.workMode === 'On-Site'}>On-Site</option>
            </select>
          </div>
          <div><label class="ofl">Duration</label><input type="text" name="duration" value={defaults.duration} class="ofi" /></div>
          <div><label class="ofl">Hours</label><input type="text" name="hoursCommitment" value={defaults.hoursCommitment} class="ofi" /></div>
          <div><label class="ofl">Compensation</label><input type="text" name="compensation" value={defaults.compensation} class="ofi" /></div>
          <div><label class="ofl">Reporting To</label><input type="text" name="reportingTo" value={defaults.reportingTo} placeholder="Head of AI / Founder" class="ofi" /></div>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Dates</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div><label class="ofl">Offer Date</label><input type="date" name="offerDate" value={defaults.offerDate} class="ofi" /></div>
          <div><label class="ofl">Joining Date</label><input type="date" name="joiningDate" value={defaults.joiningDate} class="ofi" /></div>
          <div><label class="ofl">Response Deadline</label><input type="date" name="responseDeadline" value={defaults.responseDeadline} class="ofi" /></div>
          <div><label class="ofl">Offer Expiry</label><input type="date" name="expiryDate" value={defaults.expiryDate} class="ofi" /></div>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Signatory</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div><label class="ofl">Name *</label><input type="text" name="signatoryName" required value={defaults.signatoryName} class="ofi" /></div>
          <div><label class="ofl">Title</label><input type="text" name="signatoryTitle" value={defaults.signatoryTitle} class="ofi" /></div>
          <div><label class="ofl">Ref Number</label><input type="text" name="refNumber" value={refNum} class="ofi" /></div>
          <div class="md:col-span-2"><label class="ofl">Custom Note (optional)</label><textarea name="customNote" rows="3" class="ofi resize-y">{defaults.customNote || ''}</textarea></div>
        </div>
      </div>

      <div class="flex gap-3 flex-wrap">
        <button type="submit" class="bg-burn hover:bg-burn/90 text-white font-semibold py-3 px-6 rounded-lg text-[0.95rem]">
          {currentOffer ? 'Update Offer' : 'Generate & Send Offer'}
        </button>
        <a href={'/admin/offer/blank?from=' + id} class="bg-ink hover:bg-ink/80 text-white border border-white/20 font-semibold py-3 px-6 rounded-lg text-[0.95rem] no-underline inline-flex items-center">Preview / Download PDF &rarr;</a>
      </div>
    </div>

    <div class="lg:col-span-1">
      <div class="bg-white/5 border border-white/10 rounded-xl p-5 sticky top-4">
        <h3 class="font-display text-[1rem] font-semibold text-white mb-3">How this works</h3>
        <ol class="space-y-2 text-[0.82rem] text-white/70 leading-relaxed list-decimal pl-5">
          <li>Fill in offer details on the left.</li>
          <li>Click <strong class="text-white">Generate &amp; Send Offer</strong> to create a record.</li>
          <li>System creates a secure link at <code class="text-[0.72rem] bg-white/10 px-1 rounded">/portal/offer/[token]</code></li>
          <li>Applicant reviews and signs digitally.</li>
          <li>On signing, application status auto-changes to <strong class="text-leaf">hired</strong>.</li>
          <li>Use <strong>Preview / Download PDF</strong> for a standalone PDF version.</li>
        </ol>
      </div>
    </div>
  </form>

  <style>
    .ofl { display:block;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.55);margin-bottom:6px; }
    .ofi { width:100%;padding:9px 12px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:8px;color:#fff;font-size:13px;font-family:inherit;outline:none;transition:border-color 0.15s; }
    .ofi:focus { border-color:#FF4F00; }
    textarea.ofi { resize:vertical; }
    .ofi option { background:#0a0a0c; }
  </style>
</AdminLayout>