---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
function parse(d: any): any { return typeof d === 'string' ? (() => { try { return JSON.parse(d); } catch { return {}; } })() : (d || {}); }

// COMPLETED the form, awaiting fee (application_intents).
let intents: any[] = [];
try {
  intents = rows(await db.execute(sql`
    SELECT id, role_title_snapshot, level, email, first_name, last_name, data, created_at,
           (SELECT 1 FROM payments p WHERE p.reference_id = application_intents.id AND p.status IN ('paid','captured','authorized') LIMIT 1) AS has_paid
    FROM application_intents ORDER BY created_at DESC LIMIT 500
  `));
} catch (_) {}
const intentEmails = new Set(intents.map((i: any) => (i.email || '').toLowerCase()).filter(Boolean));

// STARTED but not finished (application_drafts) - even if they only typed a name.
// Exclude anyone who already reached an intent (they're in the completed list).
let drafts: any[] = [];
try {
  drafts = rows(await db.execute(sql`
    SELECT id, email, data, step, updated_at FROM application_drafts ORDER BY updated_at DESC LIMIT 800
  `)).filter((d: any) => !intentEmails.has((d.email || '').toLowerCase()));
} catch (_) {}

function fmt(d: any) { try { return new Date(d).toLocaleString('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); } catch { return '-'; } }

// Merge all wizard steps into one flat object so we can show whatever was filled.
function flat(data: any): Record<string, any> {
  const out: Record<string, any> = {};
  const d = parse(data);
  for (const k of Object.keys(d)) {
    const v = d[k];
    if (v && typeof v === 'object' && !Array.isArray(v)) Object.assign(out, v);
    else out[k] = v;
  }
  return out;
}
function nameOf(f: any, fallbackEmail?: string) {
  const n = ((f.firstName || '') + ' ' + (f.lastName || '')).trim() || f.fullName || f.name || '';
  return n || fallbackEmail || 'Unnamed';
}
const FIELDS: { k: string; label: string }[] = [
  { k: 'phone', label: 'Phone' }, { k: 'city', label: 'City' },
  { k: 'resumeLink', label: 'Resume / portfolio' }, { k: 'linkedin', label: 'LinkedIn' },
  { k: 'education', label: 'Education' }, { k: 'fieldOfStudy', label: 'Field' },
  { k: 'institution', label: 'Institution' }, { k: 'experienceBand', label: 'Experience' },
  { k: 'whyRole', label: 'Why this role' }, { k: 'whyERA', label: 'Why EduRankAI' },
  { k: 'ambitious', label: 'Ambition' }, { k: 'availability', label: 'Availability' },
];
function val(f: any, k: string): string { const v = f && f[k]; return v == null ? '' : String(v); }

const totalStarted = drafts.length + intents.length;
---
<AdminLayout title="Everyone who started" activeNav="applications">
  <section style="max-width:1100px;margin:0 auto;padding:6px 2px 48px;">
    <p style="font-size:11px;font-family:monospace;text-transform:uppercase;letter-spacing:0.15em;color:#FF4F00;font-weight:700;margin:0 0 4px;">Applications</p>
    <h1 style="font-size:1.5rem;font-weight:600;color:#100b08;margin:0 0 4px;">Everyone who started ({totalStarted})</h1>
    <p style="font-size:0.86rem;color:#6a635c;margin:0 0 18px;">Every person who began an application - even if they only typed a name - so you can reach out and help them finish. <a href="/admin/applications" style="color:#FF4F00;text-decoration:none;">Live applications &rarr;</a></p>

    <!-- In progress / abandoned drafts -->
    <h2 style="font-size:1rem;font-weight:700;color:#100b08;margin:18px 0 8px;">In progress &middot; not yet submitted ({drafts.length})</h2>
    {drafts.length === 0 ? <p style="color:#a99e94;font-size:0.86rem;">No in-progress drafts.</p> : drafts.map((r: any) => {
      const f = flat(r.data);
      const email = r.email || f.email || '';
      const filled = FIELDS.filter((x) => val(f, x.k));
      return (
        <details style="background:#fff;border:1px solid rgba(14,11,8,0.1);border-radius:12px;margin-bottom:8px;">
          <summary style="cursor:pointer;list-style:none;padding:12px 16px;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;">
            <span>
              <strong style="font-size:0.94rem;color:#100b08;">{nameOf(f, email)}</strong>
              <span style="display:block;font-size:0.78rem;color:#a99e94;">{email}{f.phone ? ' · ' + f.phone : ''} &middot; last active {fmt(r.updated_at)}</span>
            </span>
            <span style="font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;padding:3px 10px;border-radius:100px;background:rgba(148,163,184,0.18);color:#475569;white-space:nowrap;">Step {Math.min(6, Math.max(1, parseInt(r.step) || 1))} / 6</span>
          </summary>
          <div style="padding:0 16px 14px;border-top:1px solid rgba(14,11,8,0.06);">
            {filled.length === 0 ? <p style="font-size:0.82rem;color:#a99e94;margin:12px 0 0;">Only a name/contact so far.</p> : (
              <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:10px 24px;margin-top:12px;">
                {filled.map((x) => (
                  <div>
                    <p style="font-size:0.66rem;text-transform:uppercase;letter-spacing:0.06em;color:#9a8f86;font-weight:700;margin:0 0 2px;">{x.label}</p>
                    <p style="font-size:0.84rem;color:#2b2620;margin:0;line-height:1.5;word-break:break-word;">{val(f, x.k).slice(0, 500)}</p>
                  </div>
                ))}
              </div>
            )}
          </div>
        </details>
      );
    })}

    <!-- Completed the form, awaiting fee -->
    <h2 style="font-size:1rem;font-weight:700;color:#100b08;margin:26px 0 8px;">Completed the form &middot; awaiting fee ({intents.length})</h2>
    {intents.length === 0 ? <p style="color:#a99e94;font-size:0.86rem;">None.</p> : intents.map((r: any) => {
      const f = flat(r.data);
      const filled = FIELDS.filter((x) => val(f, x.k));
      return (
        <details style="background:#fff;border:1px solid rgba(14,11,8,0.1);border-radius:12px;margin-bottom:8px;">
          <summary style="cursor:pointer;list-style:none;padding:12px 16px;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;">
            <span>
              <strong style="font-size:0.94rem;color:#100b08;">{nameOf(f, r.email) }</strong>
              <span style="color:#8a8078;font-size:0.82rem;"> &middot; {r.role_title_snapshot || 'role'}{r.level ? ' (' + r.level + ')' : ''}</span>
              <span style="display:block;font-size:0.78rem;color:#a99e94;">{r.email || f.email}{f.phone ? ' · ' + f.phone : ''} &middot; submitted {fmt(r.created_at)}</span>
            </span>
            <span style={'font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;padding:3px 10px;border-radius:100px;white-space:nowrap;' + (r.has_paid ? 'background:rgba(16,185,129,0.14);color:#047857;' : 'background:rgba(250,204,21,0.16);color:#92400e;')}>{r.has_paid ? 'paid - finalising' : 'awaiting fee'}</span>
          </summary>
          <div style="padding:0 16px 14px;border-top:1px solid rgba(14,11,8,0.06);">
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:10px 24px;margin-top:12px;">
              {filled.map((x) => (
                <div>
                  <p style="font-size:0.66rem;text-transform:uppercase;letter-spacing:0.06em;color:#9a8f86;font-weight:700;margin:0 0 2px;">{x.label}</p>
                  <p style="font-size:0.84rem;color:#2b2620;margin:0;line-height:1.5;word-break:break-word;">{val(f, x.k).slice(0, 500)}</p>
                </div>
              ))}
            </div>
          </div>
        </details>
      );
    })}
  </section>
</AdminLayout>
