---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
function parse(d: any): any { return typeof d === 'string' ? (() => { try { return JSON.parse(d); } catch { return {}; } })() : (d || {}); }

const url = new URL(Astro.request.url);
const filter = url.searchParams.get('stage') || 'all';

// EVERYONE who started = every applicant account, with how far they got.
// Most "starters" only ever created an account (name + email), so this is
// driven by the users table and enriched with draft / intent / application
// progress. This is the full 200+, not just the few who finished the form.
let starters: any[] = [];
try {
  starters = rows(await db.execute(sql`
    SELECT u.id, u.name, u.email, u.created_at,
      (SELECT COUNT(*)::int FROM applications a WHERE a.applicant_user_id = u.id) AS app_count,
      (SELECT COUNT(*)::int FROM application_intents i WHERE i.user_id = u.id) AS intent_count,
      (SELECT d.step FROM application_drafts d WHERE (d.user_id = u.id OR lower(d.email) = lower(u.email)) ORDER BY d.updated_at DESC LIMIT 1) AS draft_step,
      (SELECT d.data FROM application_drafts d WHERE (d.user_id = u.id OR lower(d.email) = lower(u.email)) ORDER BY d.updated_at DESC LIMIT 1) AS draft_data,
      (SELECT d.updated_at FROM application_drafts d WHERE (d.user_id = u.id OR lower(d.email) = lower(u.email)) ORDER BY d.updated_at DESC LIMIT 1) AS draft_at
    FROM users u
    WHERE u.role::text NOT IN ('admin','super_admin','editor','reviewer','partner','teacher','technical_moderator','institution_admin','employee','hr','finance')
    ORDER BY u.created_at DESC
    LIMIT 2000
  `));
} catch (_) {}

function stageOf(r: any): { key: string; label: string; css: string } {
  if (Number(r.app_count) > 0) return { key: 'applied', label: 'Applied', css: 'background:rgba(16,185,129,0.14);color:#047857;' };
  if (Number(r.intent_count) > 0) return { key: 'awaiting_fee', label: 'Form complete - awaiting fee', css: 'background:rgba(250,204,21,0.16);color:#92400e;' };
  if (r.draft_step) return { key: 'in_progress', label: 'In progress - step ' + Math.min(6, Math.max(1, parseInt(r.draft_step) || 1)) + '/6', css: 'background:rgba(59,130,246,0.14);color:#1d4ed8;' };
  return { key: 'signed_up', label: 'Signed up - not started form', css: 'background:rgba(148,163,184,0.18);color:#475569;' };
}

const enriched = starters.map((r: any) => ({ ...r, stage: stageOf(r) }));
const counts = {
  all: enriched.length,
  signed_up: enriched.filter((r) => r.stage.key === 'signed_up').length,
  in_progress: enriched.filter((r) => r.stage.key === 'in_progress').length,
  awaiting_fee: enriched.filter((r) => r.stage.key === 'awaiting_fee').length,
  applied: enriched.filter((r) => r.stage.key === 'applied').length,
};
const shown = filter === 'all' ? enriched : enriched.filter((r) => r.stage.key === filter);

function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: '2-digit' }); } catch { return '-'; } }
function flat(data: any): Record<string, any> {
  const out: Record<string, any> = {}; const d = parse(data);
  for (const k of Object.keys(d)) { const v = d[k]; if (v && typeof v === 'object' && !Array.isArray(v)) Object.assign(out, v); else out[k] = v; }
  return out;
}
const FIELDS: { k: string; label: string }[] = [
  { k: 'phone', label: 'Phone' }, { k: 'city', label: 'City' }, { k: 'resumeLink', label: 'Resume / portfolio' },
  { k: 'linkedin', label: 'LinkedIn' }, { k: 'education', label: 'Education' }, { k: 'fieldOfStudy', label: 'Field' },
  { k: 'institution', label: 'Institution' }, { k: 'experienceBand', label: 'Experience' },
  { k: 'whyRole', label: 'Why this role' }, { k: 'whyERA', label: 'Why EduRankAI' },
];
function val(f: any, k: string): string { const v = f && f[k]; return v == null ? '' : String(v); }
const TABS = [
  { k: 'all', label: 'All' }, { k: 'signed_up', label: 'Signed up only' }, { k: 'in_progress', label: 'In progress' },
  { k: 'awaiting_fee', label: 'Awaiting fee' }, { k: 'applied', label: 'Applied' },
];
---
<AdminLayout title="Everyone who started" activeNav="applications">
  <section style="max-width:1100px;margin:0 auto;padding:6px 2px 48px;">
    <p style="font-size:11px;font-family:monospace;text-transform:uppercase;letter-spacing:0.15em;color:#FF4F00;font-weight:700;margin:0 0 4px;">Applications</p>
    <h1 style="font-size:1.5rem;font-weight:600;color:#100b08;margin:0 0 4px;">Everyone who started ({counts.all})</h1>
    <p style="font-size:0.86rem;color:#6a635c;margin:0 0 16px;">Every applicant account and exactly how far they got - so you can reach the ones who stalled and help them finish. <a href="/admin/applications" style="color:#FF4F00;text-decoration:none;">Live applications &rarr;</a></p>

    <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:16px;">
      {TABS.map((t) => (
        <a href={'/admin/applications/intents?stage=' + t.k} style={'font-size:12.5px;font-weight:600;padding:6px 13px;border-radius:100px;text-decoration:none;' + (filter === t.k ? 'background:#FF4F00;color:#fff;' : 'background:rgba(0,0,0,0.05);color:#4a443e;')}>{t.label} ({(counts as any)[t.k]})</a>
      ))}
    </div>

    {shown.length === 0 ? <p style="color:#a99e94;font-size:0.9rem;">Nobody in this stage.</p> : shown.map((r: any) => {
      const f = flat(r.draft_data);
      const filled = FIELDS.filter((x) => val(f, x.k));
      const hasDetail = filled.length > 0;
      return (
        <details style="background:#fff;border:1px solid rgba(14,11,8,0.1);border-radius:12px;margin-bottom:8px;">
          <summary style="cursor:pointer;list-style:none;padding:12px 16px;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;">
            <span style="min-width:0;">
              <strong style="font-size:0.94rem;color:#100b08;">{r.name || f.firstName || 'Unnamed'}</strong>
              <span style="display:block;font-size:0.78rem;color:#a99e94;">{r.email}{f.phone ? ' · ' + f.phone : ''} &middot; joined {fmt(r.created_at)}{r.draft_at ? ' · last active ' + fmt(r.draft_at) : ''}</span>
            </span>
            <span style={'font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;padding:3px 10px;border-radius:100px;white-space:nowrap;' + r.stage.css}>{r.stage.label}</span>
          </summary>
          <div style="padding:0 16px 14px;border-top:1px solid rgba(14,11,8,0.06);">
            {!hasDetail ? <p style="font-size:0.82rem;color:#a99e94;margin:12px 0 0;">Account created - has not filled the form yet. Reach them at {r.email}.</p> : (
              <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:10px 24px;margin-top:12px;">
                {filled.map((x) => (
                  <div>
                    <p style="font-size:0.66rem;text-transform:uppercase;letter-spacing:0.06em;color:#9a8f86;font-weight:700;margin:0 0 2px;">{x.label}</p>
                    <p style="font-size:0.84rem;color:#2b2620;margin:0;line-height:1.5;word-break:break-word;">{val(f, x.k).slice(0, 500)}</p>
                  </div>
                ))}
              </div>
            )}
          </div>
        </details>
      );
    })}
  </section>
</AdminLayout>
