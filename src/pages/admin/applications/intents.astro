---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

// Started applications that have NOT yet materialised (applicant filled the
// form; fee not captured/recorded yet). One row stays here until payment
// clears (then it becomes a real applications row and disappears).
let intents: any[] = [];
try {
  intents = rows(await db.execute(sql`
    SELECT id, role_title_snapshot, department_snapshot, level, email, first_name, last_name,
           data, created_at,
           (SELECT 1 FROM payments p WHERE p.reference_id = application_intents.id AND p.status IN ('paid','captured','authorized') LIMIT 1) AS has_paid
    FROM application_intents
    ORDER BY created_at DESC LIMIT 300
  `));
} catch (_) {}

function fmt(d: any) { try { return new Date(d).toLocaleString('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); } catch { return '-'; } }
function nm(r: any) { return ((r.first_name || '') + ' ' + (r.last_name || '')).trim() || r.email || 'Applicant'; }

// Pull out the most useful filled fields from the data jsonb for a quick read.
const FIELDS: { k: string; label: string }[] = [
  { k: 'phone', label: 'Phone' }, { k: 'city', label: 'City' },
  { k: 'education', label: 'Education' }, { k: 'fieldOfStudy', label: 'Field' },
  { k: 'institution', label: 'Institution' }, { k: 'experienceBand', label: 'Experience' },
  { k: 'linkedin', label: 'LinkedIn' }, { k: 'portfolioUrl', label: 'Portfolio' },
  { k: 'whyRole', label: 'Why this role' }, { k: 'whyERA', label: 'Why EduRankAI' },
  { k: 'ambitious', label: 'Ambition' }, { k: 'availability', label: 'Availability' },
];
function val(d: any, k: string): string { const v = d && d[k]; return v == null ? '' : String(v); }
---
<AdminLayout title="Started applications" activeNav="applications">
  <section style="max-width:1100px;margin:0 auto;padding:6px 2px 48px;">
    <p style="font-size:11px;font-family:monospace;text-transform:uppercase;letter-spacing:0.15em;color:#FF4F00;font-weight:700;margin:0 0 4px;">Applications</p>
    <h1 style="font-size:1.5rem;font-weight:600;color:#100b08;margin:0 0 4px;">Started applications (awaiting fee)</h1>
    <p style="font-size:0.86rem;color:#6a635c;margin:0 0 18px;">Everyone who completed the form. They become live applications once the fee clears. <a href="/admin/applications" style="color:#FF4F00;text-decoration:none;">Live applications &rarr;</a> &middot; <a href="/admin/paid-stuck" style="color:#FF4F00;text-decoration:none;">Paid-but-stuck &rarr;</a></p>

    {intents.length === 0 ? (
      <p style="color:#8a8078;font-size:0.9rem;">No started applications right now.</p>
    ) : intents.map((r: any) => {
      const d = (typeof r.data === 'string' ? (() => { try { return JSON.parse(r.data); } catch { return {}; } })() : (r.data || {}));
      return (
        <details style="background:#fff;border:1px solid rgba(14,11,8,0.1);border-radius:12px;margin-bottom:10px;">
          <summary style="cursor:pointer;list-style:none;padding:14px 16px;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;">
            <span>
              <strong style="font-size:0.96rem;color:#100b08;">{nm(r)}</strong>
              <span style="color:#8a8078;font-size:0.82rem;"> &middot; {r.role_title_snapshot || 'role'}{r.level ? ' (' + r.level + ')' : ''}</span>
              <span style="display:block;font-size:0.78rem;color:#a99e94;">{r.email} &middot; started {fmt(r.created_at)}</span>
            </span>
            <span style={'font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;padding:3px 10px;border-radius:100px;' + (r.has_paid ? 'background:rgba(16,185,129,0.14);color:#047857;' : 'background:rgba(250,204,21,0.16);color:#92400e;')}>{r.has_paid ? 'paid - finalising' : 'awaiting fee'}</span>
          </summary>
          <div style="padding:0 16px 16px;border-top:1px solid rgba(14,11,8,0.06);">
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:10px 24px;margin-top:12px;">
              {FIELDS.filter((f) => val(d, f.k)).map((f) => (
                <div>
                  <p style="font-size:0.66rem;text-transform:uppercase;letter-spacing:0.06em;color:#9a8f86;font-weight:700;margin:0 0 2px;">{f.label}</p>
                  <p style="font-size:0.84rem;color:#2b2620;margin:0;line-height:1.5;word-break:break-word;">{val(d, f.k).slice(0, 600)}</p>
                </div>
              ))}
            </div>
          </div>
        </details>
      );
    })}
  </section>
</AdminLayout>
