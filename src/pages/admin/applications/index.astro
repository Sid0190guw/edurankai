---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { applications, users } from '@/lib/db/schema';
import { eq, desc, sql, and, or, ilike } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get('status') || 'all';
const search = url.searchParams.get('q') || '';

const conditions = [];
if (statusFilter !== 'all') {
  conditions.push(eq(applications.status, statusFilter as any));
}
if (search.trim()) {
  const term = '%' + search.trim() + '%';
  conditions.push(or(
    ilike(applications.firstName, term),
    ilike(applications.lastName, term),
    ilike(applications.email, term),
    ilike(applications.roleTitleSnapshot, term),
    ilike(applications.city, term)
  ));
}

const whereClause = conditions.length > 0
  ? (conditions.length === 1 ? conditions[0] : and(...conditions))
  : undefined;

const apps = whereClause
  ? await db.select().from(applications).where(whereClause).orderBy(desc(applications.createdAt)).limit(200)
  : await db.select().from(applications).orderBy(desc(applications.createdAt)).limit(200);

const counts = await db.select({
  status: applications.status,
  count: sql<number>`count(*)::int`
}).from(applications).groupBy(applications.status);

const countMap: Record<string, number> = {};
let totalCount = 0;
counts.forEach((c) => {
  countMap[c.status] = c.count;
  totalCount += c.count;
});

const STATUS_OPTIONS = [
  { value: 'all', label: 'All' },
  { value: 'submitted', label: 'Submitted' },
  { value: 'reviewing', label: 'Reviewing' },
  { value: 'task_sent', label: 'Task Sent' },
  { value: 'interview', label: 'Interview' },
  { value: 'offer', label: 'Offer' },
  { value: 'hired', label: 'Hired' },
  { value: 'rejected', label: 'Rejected' },
  { value: 'withdrawn', label: 'Withdrawn' }
];

const statusColors: Record<string, string> = {
  submitted: 'bg-sky-bg text-sky border-sky-border',
  reviewing: 'bg-burn-pale text-burn border-burn-dim',
  task_sent: 'bg-gold-bg text-gold-deep border-gold-border',
  interview: 'bg-plum-bg text-plum border-plum-border',
  offer: 'bg-leaf-bg text-leaf border-leaf-border',
  hired: 'bg-leaf-bg text-leaf border-leaf-border',
  rejected: 'bg-ink/5 text-ink-soft border-ink/15',
  withdrawn: 'bg-ink/5 text-ink-soft border-ink/15'
};
---
<AdminLayout title="Applications" description="Review and manage applicant submissions.">

  <div class="mb-6">
    <h1 class="font-display text-[1.8rem] font-semibold text-white mb-1">Applications</h1>
    <p class="text-[0.85rem] text-white/60">{totalCount} total applications</p>
  </div>

  <form method="GET" class="mb-5 flex flex-col md:flex-row gap-3">
    <input type="text" name="q" value={search} placeholder="Search by name, email, role, city..." class="flex-1 px-3.5 py-2.5 bg-white/5 border border-white/10 rounded-lg text-[0.88rem] text-white placeholder-white/40 outline-none focus:border-burn" />
    <button type="submit" class="px-5 py-2.5 bg-burn hover:bg-burn/90 text-white font-semibold text-[0.88rem] rounded-lg">Search</button>
    {(statusFilter !== 'all' || search) && <a href="/admin/applications" class="px-5 py-2.5 bg-white/5 border border-white/10 hover:border-white/20 text-white/70 text-[0.88rem] rounded-lg flex items-center">Clear</a>}
  </form>

  <div class="flex flex-wrap gap-2 mb-6">
    {STATUS_OPTIONS.map((opt) => {
      const isActive = statusFilter === opt.value;
      const count = opt.value === 'all' ? totalCount : (countMap[opt.value] || 0);
      const href = '/admin/applications?status=' + opt.value + (search ? '&q=' + encodeURIComponent(search) : '');
      return (
        <a href={href} class={'inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[0.78rem] font-medium transition-all border ' + (isActive ? 'bg-burn border-burn text-white' : 'bg-white/5 border-white/10 text-white/70 hover:border-white/25')}>
          <span>{opt.label}</span>
          <span class={'text-[0.72rem] font-mono ' + (isActive ? 'text-white/80' : 'text-white/40')}>{count}</span>
        </a>
      );
    })}
  </div>

  {apps.length === 0 ? (
    <div class="bg-white/5 border border-white/10 rounded-2xl p-10 text-center">
      <p class="text-[0.95rem] text-white/70 mb-1">No applications match.</p>
      <p class="text-[0.78rem] text-white/40">Try clearing filters or adjusting your search.</p>
    </div>
  ) : (
    <div class="flex flex-col gap-2">
      {apps.map((app) => {
        const shortId = app.id.substring(0, 8).toUpperCase();
        const createdDate = new Date(app.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
        const fullName = (app.firstName || '') + ' ' + (app.lastName || '');
        const statusClass = statusColors[app.status] || 'bg-white/10 text-white/70 border-white/15';
        return (
          <a href={'/admin/applications/' + app.id} class="bg-white/5 border border-white/10 hover:border-white/25 hover:bg-white/8 rounded-xl p-4 transition-all block">
            <div class="flex flex-col md:flex-row md:items-center gap-3">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <p class="font-mono text-[0.7rem] text-white/40">{shortId}</p>
                  <span class={'inline-block text-[0.65rem] font-bold uppercase tracking-wider border px-2 py-0.5 rounded-full ' + statusClass}>{app.status}</span>
                  {app.score !== null && app.score !== undefined && <span class="text-[0.7rem] font-mono text-white/60">Score: {app.score}</span>}
                </div>
                <p class="font-display text-[1rem] font-semibold text-white truncate">{fullName.trim() || app.email}</p>
                <div class="flex flex-wrap items-center gap-x-2 gap-y-0.5 text-[0.75rem] text-white/55 mt-0.5">
                  <span>{app.roleTitleSnapshot || 'No role'}</span>
                  <span>·</span>
                  <span>{app.departmentSnapshot || ''}</span>
                  {app.level && <span>·</span>}
                  {app.level && <span>{app.level}</span>}
                  <span>·</span>
                  <span>{app.email}</span>
                  <span>·</span>
                  <span>{app.city}</span>
                </div>
              </div>
              <div class="text-right shrink-0 md:ml-3">
                <p class="text-[0.7rem] font-mono text-white/40">{createdDate}</p>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  )}

</AdminLayout>
