---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { applications, users } from '@/lib/db/schema';
import { eq, desc, sql, and, or, ilike, inArray, gte } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

let errorMsg = '';
let okMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('_action') as string;
  try {
    if (action === 'delete_one') {
      const id = (fd.get('id') as string || '').trim();
      if (id) { await db.delete(applications).where(eq(applications.id, id)); okMsg = 'Application deleted.'; }
    } else if (action === 'bulk_delete' || action === 'bulk_archive' || action === 'bulk_status') {
      const ids = ((fd.get('selected_ids') as string) || '').split(',').map(s => s.trim()).filter(Boolean);
      if (ids.length === 0) { errorMsg = 'No applications selected.'; }
      else if (action === 'bulk_delete') {
        await db.delete(applications).where(inArray(applications.id, ids));
        okMsg = `Deleted ${ids.length} application(s).`;
      } else if (action === 'bulk_archive') {
        await db.update(applications).set({ isArchived: true }).where(inArray(applications.id, ids));
        okMsg = `Archived ${ids.length} application(s).`;
      } else if (action === 'bulk_status') {
        const newStatus = fd.get('new_status') as string;
        if (!newStatus) errorMsg = 'Pick a status.';
        else { await db.update(applications).set({ status: newStatus as any }).where(inArray(applications.id, ids)); okMsg = `Updated ${ids.length} status(es).`; }
      }
    } else if (action === 'unarchive_one') {
      const id = (fd.get('id') as string || '').trim();
      if (id) { await db.update(applications).set({ isArchived: false }).where(eq(applications.id, id)); okMsg = 'Unarchived.'; }
    }
  } catch (err: any) { errorMsg = 'Failed: ' + (err.message || 'Unknown'); }
}

const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get('status') || 'all';
const search = url.searchParams.get('q') || '';
const archivedFilter = url.searchParams.get('archived') || 'active';
const page = parseInt(url.searchParams.get('page') || '1');
const perPage = 20;

// Export CSV
const exportCsv = url.searchParams.get('export') === 'csv';
if (exportCsv) {
  const allApps = await db.select().from(applications).orderBy(desc(applications.createdAt));
  const headers = ['id','application_number','first_name','last_name','email','phone','city','role_title','status','created_at'];
  const rows = allApps.map(a => headers.map(h => {
    const key = h.replace(/_([a-z])/g, (_, c) => c.toUpperCase()) as keyof typeof a;
    const v = a[key] as any;
    if (v === null || v === undefined) return '';
    const s = String(v).replace(/"/g, '""');
    return s.includes(',') || s.includes('"') || s.includes('\n') ? `"${s}"` : s;
  }).join(','));
  const csv = headers.join(',') + '\n' + rows.join('\n');
  return new Response(csv, { headers: { 'Content-Type': 'text/csv', 'Content-Disposition': `attachment; filename="applications-${new Date().toISOString().split('T')[0]}.csv"` } });
}

const conditions: any[] = [];
if (statusFilter !== 'all') conditions.push(eq(applications.status, statusFilter as any));
if (archivedFilter === 'archived') conditions.push(eq(applications.isArchived, true));
else if (archivedFilter === 'active') conditions.push(eq(applications.isArchived, false));
if (search.trim()) {
  const term = '%' + search.trim() + '%';
  conditions.push(or(ilike(applications.firstName, term), ilike(applications.lastName, term), ilike(applications.email, term)));
}

const whereClause = conditions.length > 0 ? and(...conditions) : undefined;
const totalResult = await db.select({ n: sql<number>`count(*)::int` }).from(applications).where(whereClause);
const total = totalResult[0].n;
const totalPages = Math.ceil(total / perPage);

const apps = await db.select({
  id: applications.id, applicationNumber: applications.applicationNumber,
  firstName: applications.firstName, lastName: applications.lastName,
  email: applications.email, roleTitleSnapshot: applications.roleTitleSnapshot,
  status: applications.status, level: applications.level,
  isArchived: applications.isArchived, createdAt: applications.createdAt,
  assignedReviewerId: applications.assignedReviewerId,
}).from(applications).where(whereClause).orderBy(desc(applications.createdAt))
  .limit(perPage).offset((page - 1) * perPage);

// Status counts
const counts = await db.execute(sql`
  SELECT status, COUNT(*)::int as n FROM applications 
  WHERE is_archived = ${archivedFilter === 'archived'}
  GROUP BY status
`);
const countMap: Record<string, number> = {};
(counts.rows as any[]).forEach(r => { countMap[r.status] = r.n; });
const totalActive = Object.values(countMap).reduce((a, b) => a + b, 0);

const STATUS_COLOR: Record<string, string> = {
  submitted: '#fbbf24', reviewing: '#60a5fa', shortlisted: '#34d399',
  interview: '#a78bfa', offered: '#f97316', hired: '#10b981',
  rejected: '#f87171', withdrawn: '#6b7280',
};
const ALL_STATUSES = ['submitted','reviewing','shortlisted','interview','offered','hired','rejected','withdrawn'];
---
<AdminLayout title="Applications" activeNav="applications">
<div style="padding-bottom:80px;">

  <!-- Sticky header -->
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:12px;">
      <div>
        <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">Recruiting</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Applications</h1>
      </div>
      <div style="display:flex;gap:6px;align-items:center;">
        <a href="?export=csv" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;text-decoration:none;font-size:11px;font-weight:500;padding:6px 10px;border-radius:6px;">↓ CSV</a>
        <a href="/admin/applications/new" style="background:#FF4F00;border:none;color:#fff;font-size:12px;font-weight:600;padding:8px 14px;border-radius:8px;text-decoration:none;">+ New</a>
      </div>
    </div>

    <!-- Search -->
    <form method="GET" style="display:flex;gap:8px;margin-bottom:10px;">
      <input type="text" name="q" value={search} placeholder="Search name, email..." style="flex:1;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:8px 12px;color:#fff;font-size:13px;outline:none;min-width:0;" />
      <button type="submit" style="background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:8px 14px;color:#fff;font-size:12px;cursor:pointer;">Go</button>
    </form>

    <!-- Status pills -->
    <div style="display:flex;gap:6px;overflow-x:auto;padding-bottom:2px;">
      <a href={`?status=all&archived=${archivedFilter}`} style={`text-decoration:none;font-size:11px;font-weight:600;padding:4px 10px;border-radius:100px;white-space:nowrap;flex-shrink:0;${statusFilter === 'all' ? 'background:#FF4F00;color:#fff;' : 'background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;'}`}>
        All ({totalActive})
      </a>
      {ALL_STATUSES.filter(s => countMap[s]).map(s => (
        <a href={`?status=${s}&archived=${archivedFilter}`} style={`text-decoration:none;font-size:11px;font-weight:600;padding:4px 10px;border-radius:100px;white-space:nowrap;flex-shrink:0;${statusFilter === s ? `background:${STATUS_COLOR[s]}22;border:1px solid ${STATUS_COLOR[s]}44;color:${STATUS_COLOR[s]};` : 'background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;'}`}>
          {s} ({countMap[s] || 0})
        </a>
      ))}
    </div>
  </div>

  <!-- Messages -->
  {errorMsg && <div style="margin:10px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  <!-- Bulk actions bar -->
  <form method="POST" id="bulkForm">
    <input type="hidden" name="selected_ids" id="selected_ids" value="" />
    <div id="bulkBar" style="display:none;background:#1a1a1f;border-bottom:1px solid #1a1a1f;padding:10px 16px;position:sticky;top:108px;z-index:9;align-items:center;gap:8px;flex-wrap:wrap;">
      <span id="selectedCount" style="font-size:12px;color:#fff;font-weight:600;">0 selected</span>
      <div style="display:flex;gap:6px;flex-wrap:wrap;">
        <select name="new_status" style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:5px 8px;color:#fff;font-size:11px;outline:none;">
          <option value="">Set status...</option>
          {ALL_STATUSES.map(s => <option value={s}>{s}</option>)}
        </select>
        <button type="submit" name="_action" value="bulk_status" style="background:#15151a;border:1px solid #1a1a1f;color:#fff;font-size:11px;padding:5px 10px;border-radius:6px;cursor:pointer;">Apply</button>
        <button type="submit" name="_action" value="bulk_archive" style="background:#15151a;border:1px solid #1a1a1f;color:#fbbf24;font-size:11px;padding:5px 10px;border-radius:6px;cursor:pointer;">Archive</button>
        <button type="submit" name="_action" value="bulk_delete" onclick="return confirm('Delete selected?')" style="background:rgba(239,68,68,0.15);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;font-size:11px;padding:5px 10px;border-radius:6px;cursor:pointer;">Delete</button>
      </div>
    </div>

    <!-- Application cards -->
    <div style="padding:12px 16px;display:flex;flex-direction:column;gap:8px;">
      {apps.length === 0 && (
        <div style="text-align:center;padding:48px;color:#6e6e78;">
          <p style="font-size:32px;margin-bottom:8px;">📭</p>
          <p style="font-size:13px;">No applications match your filters</p>
        </div>
      )}
      {apps.map(a => {
        const name = ((a.firstName||'') + ' ' + (a.lastName||'')).trim() || a.email;
        const color = STATUS_COLOR[a.status || ''] || '#6e6e78';
        const date = new Date(a.createdAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
        return (
          <div style={`background:#0f0f14;border:1px solid ${a.isArchived ? '#1a1a1f' : '#1a1a1f'};border-radius:12px;overflow:hidden;${a.isArchived ? 'opacity:0.6;' : ''}`}>
            <div style="padding:12px 14px;display:flex;align-items:flex-start;gap:10px;">
              <!-- Checkbox -->
              <input type="checkbox" class="row-check" data-id={a.id} style="margin-top:3px;accent-color:#FF4F00;flex-shrink:0;width:16px;height:16px;" />
              <!-- Avatar -->
              <div style={`width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,${color}44,${color}22);border:1px solid ${color}44;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:15px;color:${color};flex-shrink:0;`}>
                {name.substring(0,1).toUpperCase()}
              </div>
              <!-- Info -->
              <div style="flex:1;min-width:0;">
                <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:6px;">
                  <div style="min-width:0;">
                    <p style="font-size:14px;font-weight:600;color:#fff;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{name}</p>
                    <p style="font-size:11px;color:#6e6e78;margin:2px 0 0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{a.roleTitleSnapshot || 'No role'}{a.level ? ` · ${a.level}` : ''}</p>
                  </div>
                  <span style={`font-size:9px;font-weight:700;padding:3px 8px;border-radius:100px;text-transform:uppercase;flex-shrink:0;background:${color}22;color:${color};border:1px solid ${color}33;`}>
                    {a.status}
                  </span>
                </div>
                <div style="display:flex;align-items:center;gap:8px;margin-top:6px;flex-wrap:wrap;">
                  <span style="font-size:10px;color:#6e6e78;font-family:'Geist Mono',monospace;">{a.applicationNumber || a.id.substring(0,8).toUpperCase()}</span>
                  <span style="font-size:10px;color:#6e6e78;">{date}</span>
                  {a.isArchived && <span style="font-size:9px;background:#15151a;color:#6e6e78;padding:1px 6px;border-radius:4px;">archived</span>}
                </div>
              </div>
            </div>
            <!-- Actions -->
            <div style="border-top:1px solid #1a1a1f;padding:8px 14px;display:flex;gap:6px;align-items:center;">
              <a href={`/admin/applications/${a.id}`} style="flex:1;text-align:center;background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;text-decoration:none;font-size:12px;font-weight:500;padding:7px;border-radius:6px;">
                View Details
              </a>
              {a.isArchived ? (
                <form method="POST" style="flex:1;">
                  <input type="hidden" name="_action" value="unarchive_one" />
                  <input type="hidden" name="id" value={a.id} />
                  <button type="submit" style="width:100%;background:#15151a;border:1px solid #1a1a1f;color:#fbbf24;font-size:12px;font-weight:500;padding:7px;border-radius:6px;cursor:pointer;">Unarchive</button>
                </form>
              ) : (
                <form method="POST" style="flex:1;" onsubmit="return confirm('Delete this application?')">
                  <input type="hidden" name="_action" value="delete_one" />
                  <input type="hidden" name="id" value={a.id} />
                  <button type="submit" style="width:100%;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);color:#fca5a5;font-size:12px;font-weight:500;padding:7px;border-radius:6px;cursor:pointer;">Delete</button>
                </form>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </form>

  <!-- Pagination -->
  {totalPages > 1 && (
    <div style="display:flex;align-items:center;justify-content:center;gap:10px;padding:16px;">
      {page > 1 && <a href={`?q=${search}&status=${statusFilter}&archived=${archivedFilter}&page=${page-1}`} style="background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;text-decoration:none;padding:8px 16px;border-radius:8px;font-size:12px;">← Prev</a>}
      <span style="font-size:12px;color:#6e6e78;">{page} / {totalPages} · {total} total</span>
      {page < totalPages && <a href={`?q=${search}&status=${statusFilter}&archived=${archivedFilter}&page=${page+1}`} style="background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;text-decoration:none;padding:8px 16px;border-radius:8px;font-size:12px;">Next →</a>}
    </div>
  )}
</div>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  const checks = Array.from(document.querySelectorAll('.row-check'));
  const idsInput = document.getElementById('selected_ids');
  const countLabel = document.getElementById('selectedCount');
  const bulkBar = document.getElementById('bulkBar');
  function update() {
    const sel = checks.filter(c => c.checked).map(c => c.getAttribute('data-id'));
    idsInput.value = sel.join(',');
    countLabel.textContent = sel.length + ' selected';
    bulkBar.style.display = sel.length > 0 ? 'flex' : 'none';
  }
  checks.forEach(c => c.addEventListener('change', update));
});
</script>
</AdminLayout>
