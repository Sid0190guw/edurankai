---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { ensureSeparationSchema, openSeparation, updateSeparation, recordExitInterview, listSeparations, SEP_KINDS, EXIT_INTERVIEW_QUESTIONS } from '@/lib/hr-separation';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

await ensureSeparationSchema();
function rowsOf(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const action = (fd.get('action') as string) || 'open';
    if (action === 'open') {
      const r = await openSeparation({
        employeeId: fd.get('employee_id') as string,
        kind: fd.get('kind') as string,
        initiatedBy: fd.get('initiated_by') as string,
        noticeDays: parseInt(fd.get('notice_days') as string, 10),
        lastWorkingDay: (fd.get('last_working_day') as string) || undefined,
        reason: (fd.get('reason') as string) || undefined,
      });
      okMsg = 'Separation opened.';
    } else if (action === 'update') {
      const id = fd.get('id') as string;
      const patch: any = {};
      ['status','kt_complete','assets_returned','access_revoked','eligibility_for_rehire','last_working_day','alumni_invited','relieving_letter_url','experience_letter_url'].forEach(k => { const v = fd.get(k); if (v !== null) patch[k] = (v === 'on') ? true : (v === 'off') ? false : v; });
      const ff = fd.get('ff_amount'); if (ff) patch.ff_amount = parseFloat(ff as string);
      await updateSeparation(id, patch); okMsg = 'Updated.';
    } else if (action === 'exit') {
      const id = fd.get('id') as string;
      const resp: any = {};
      EXIT_INTERVIEW_QUESTIONS.forEach(q => { const v = fd.get('q_' + q.key); if (v) resp[q.key] = v as string; });
      await recordExitInterview(id, resp);
      okMsg = 'Exit interview recorded.';
    }
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 240); }
}

const list = await listSeparations();
const employees = rowsOf(await db.execute(sql`SELECT id, full_name, email FROM hr_employees WHERE is_active = true ORDER BY full_name LIMIT 200`));
function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day:'2-digit', month:'short' }); } catch { return ''; } }
---
<AdminLayout title="Separations" activeNav="">
<div style="padding:14px 16px 80px;max-width:1280px;margin:0 auto;">
  <p style="font-size:10.5px;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;font-family:'Geist Mono',monospace;font-weight:700;">HR · Lifecycle · Exit</p>
  <h1 style="font-size:24px;color:#fff;margin:6px 0 4px;font-weight:700;">Separations</h1>
  <p style="font-size:13px;color:#9aa6b6;margin:0 0 18px;">Per Lifecycle Manual Part G — every separation runs through a structured flow: notice → KT → exit interview → F&amp;F → relieving + experience letters → alumni invitation.</p>

  {okMsg && <div style="background:rgba(74,222,128,0.10);border:1px solid rgba(74,222,128,0.32);color:#86efac;border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;">{okMsg}</div>}
  {errMsg && <div style="background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.32);color:#fca5a5;border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;">{errMsg}</div>}

  <details style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:0;margin-bottom:18px;">
    <summary style="cursor:pointer;padding:14px 18px;font-size:13px;color:#FF7040;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;font-family:'Geist Mono',monospace;list-style:none;">+ Open new separation</summary>
    <form method="POST" style="padding:0 18px 18px;display:grid;gap:10px;">
      <input type="hidden" name="action" value="open" />
      <select name="employee_id" required style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;">
        <option value="">— Employee *</option>
        {employees.map((e: any) => <option value={e.id}>{e.full_name} ({e.email})</option>)}
      </select>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;">
        <select name="kind" required style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;">{Object.entries(SEP_KINDS).map(([k, v]) => <option value={k}>{v.label}</option>)}</select>
        <select name="initiated_by" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;"><option value="employee">Initiated by employee</option><option value="employer">Initiated by employer</option></select>
        <input name="notice_days" type="number" placeholder="Notice days" value="30" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;" />
      </div>
      <input name="last_working_day" type="date" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;" />
      <textarea name="reason" rows="2" placeholder="Reason on record (will appear on relieving letter where applicable)" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;font-family:'Inter Tight',sans-serif;resize:vertical;"></textarea>
      <button type="submit" style="background:#FF4F00;color:#fff;border:none;padding:10px 22px;border-radius:8px;font-size:12.5px;font-weight:800;cursor:pointer;letter-spacing:0.04em;text-transform:uppercase;font-family:'Geist Mono',monospace;justify-self:start;">Open separation</button>
    </form>
  </details>

  {list.length === 0 ? (<div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:36px;text-align:center;color:#6e6e78;font-size:13px;">No separations on record.</div>) : (
    <div style="display:flex;flex-direction:column;gap:8px;">
      {list.map((s: any) => {
        const tone = s.status === 'closed' ? '#9aa6b6' : s.status === 'settlement' ? '#86efac' : s.status === 'exit_interview' ? '#67e8f9' : s.status === 'knowledge_transfer' ? '#fbbf24' : '#FF7040';
        return (
          <details style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:0;">
            <summary style="cursor:pointer;padding:14px 18px;list-style:none;display:grid;grid-template-columns:1.4fr 1.1fr 1fr 110px 90px;gap:12px;align-items:center;">
              <div><p style="font-size:13px;color:#fff;font-weight:700;margin:0;">{s.employee_name}</p><p style="font-size:10.5px;color:#9aa6b6;margin:2px 0 0;font-family:'Geist Mono',monospace;">{s.employee_email}</p></div>
              <p style="font-size:11.5px;color:#cfd6da;margin:0;">{(SEP_KINDS as any)[s.kind]?.label || s.kind}</p>
              <p style="font-size:11px;color:#9aa6b6;margin:0;font-family:'Geist Mono',monospace;">Last day: {fmt(s.last_working_day) || '—'}</p>
              <span style={`background:${tone}22;color:${tone};font-size:10px;font-weight:700;padding:3px 8px;border-radius:100px;text-align:center;font-family:'Geist Mono',monospace;letter-spacing:0.06em;text-transform:uppercase;`}>{s.status.replace(/_/g,' ')}</span>
              <p style="font-size:10.5px;color:#6e6e78;margin:0;font-family:'Geist Mono',monospace;">{fmt(s.initiated_at)}</p>
            </summary>
            <div style="padding:0 18px 18px;border-top:1px solid #1a1a1f;">
              {s.reason && <div style="margin:14px 0;"><p style="font-size:10.5px;color:#FF7040;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;font-weight:700;margin:0 0 6px;">Reason</p><p style="font-size:12.5px;color:#d8d8de;margin:0;line-height:1.65;white-space:pre-wrap;">{s.reason}</p></div>}

              <form method="POST" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:8px;margin:14px 0;">
                <input type="hidden" name="action" value="update" /><input type="hidden" name="id" value={s.id} />
                <label style="background:#08080a;border:1px solid #1a1a1f;border-radius:6px;padding:7px 10px;display:flex;justify-content:space-between;font-size:11.5px;color:#d8d8de;cursor:pointer;">KT complete<input name="kt_complete" type="checkbox" checked={s.kt_complete} /></label>
                <label style="background:#08080a;border:1px solid #1a1a1f;border-radius:6px;padding:7px 10px;display:flex;justify-content:space-between;font-size:11.5px;color:#d8d8de;cursor:pointer;">Assets returned<input name="assets_returned" type="checkbox" checked={s.assets_returned} /></label>
                <label style="background:#08080a;border:1px solid #1a1a1f;border-radius:6px;padding:7px 10px;display:flex;justify-content:space-between;font-size:11.5px;color:#d8d8de;cursor:pointer;">Access revoked<input name="access_revoked" type="checkbox" checked={s.access_revoked} /></label>
                <label style="background:#08080a;border:1px solid #1a1a1f;border-radius:6px;padding:7px 10px;display:flex;justify-content:space-between;font-size:11.5px;color:#d8d8de;cursor:pointer;">Alumni invited<input name="alumni_invited" type="checkbox" checked={s.alumni_invited} /></label>
                <select name="status" style="background:#08080a;border:1px solid #1a1a1f;color:#fff;padding:7px 10px;border-radius:6px;font-size:11.5px;"><option value="notice" selected={s.status==='notice'}>Notice</option><option value="knowledge_transfer" selected={s.status==='knowledge_transfer'}>KT</option><option value="exit_interview" selected={s.status==='exit_interview'}>Exit interview</option><option value="settlement" selected={s.status==='settlement'}>Settlement</option><option value="closed" selected={s.status==='closed'}>Closed</option></select>
                <select name="eligibility_for_rehire" style="background:#08080a;border:1px solid #1a1a1f;color:#fff;padding:7px 10px;border-radius:6px;font-size:11.5px;"><option value="">Rehire?</option><option value="yes" selected={s.eligibility_for_rehire==='yes'}>Yes</option><option value="no" selected={s.eligibility_for_rehire==='no'}>No</option><option value="with_caveats" selected={s.eligibility_for_rehire==='with_caveats'}>With caveats</option></select>
                <input name="ff_amount" type="number" step="0.01" placeholder="F&F amount" value={s.ff_amount || ''} style="background:#08080a;border:1px solid #1a1a1f;color:#fff;padding:7px 10px;border-radius:6px;font-size:11.5px;" />
                <button type="submit" style="background:#1045BB;color:#fff;border:none;padding:7px 14px;border-radius:6px;font-size:11.5px;font-weight:700;cursor:pointer;font-family:'Geist Mono',monospace;">Save</button>
              </form>

              {!s.exit_interview_at && (
                <details style="margin:14px 0;background:#08080a;border:1px solid #1a1a1f;border-radius:8px;padding:0;">
                  <summary style="cursor:pointer;padding:10px 14px;font-size:11.5px;color:#67e8f9;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;font-family:'Geist Mono',monospace;list-style:none;">Conduct exit interview →</summary>
                  <form method="POST" style="padding:0 14px 14px;display:grid;gap:8px;">
                    <input type="hidden" name="action" value="exit" /><input type="hidden" name="id" value={s.id} />
                    {EXIT_INTERVIEW_QUESTIONS.map((q) => (
                      <div><label style="font-size:10.5px;color:#67e8f9;letter-spacing:0.08em;text-transform:uppercase;font-family:'Geist Mono',monospace;font-weight:700;">{q.label}</label><textarea name={'q_' + q.key} rows="2" style="width:100%;background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:7px 10px;border-radius:5px;font-size:11.5px;font-family:'Inter Tight',sans-serif;resize:vertical;margin-top:4px;"></textarea></div>
                    ))}
                    <button type="submit" style="background:#67e8f9;color:#04161b;border:none;padding:8px 16px;border-radius:6px;font-size:11.5px;font-weight:700;cursor:pointer;font-family:'Geist Mono',monospace;justify-self:start;">Record exit interview</button>
                  </form>
                </details>
              )}
              {s.exit_interview_at && <div style="margin:10px 0;padding:10px 14px;background:rgba(103,232,249,0.06);border-left:3px solid #67e8f9;border-radius:0 6px 6px 0;"><p style="font-size:10.5px;color:#67e8f9;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;font-weight:700;margin:0;">Exit interview · {fmt(s.exit_interview_at)}</p></div>}
            </div>
          </details>
        );
      })}
    </div>
  )}
</div>
</AdminLayout>
