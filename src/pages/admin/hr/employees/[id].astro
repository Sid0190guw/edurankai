---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql as sqlExpr } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/hr/employees');

// Self-bootstrap offboarding columns (idempotent). Runs each load; UPDATE noop
// after the first time. Lets the Exit tab work without a manual migration.
try {
  await db.execute(sqlExpr`ALTER TABLE hr_employees
    ADD COLUMN IF NOT EXISTS exit_type VARCHAR(40),
    ADD COLUMN IF NOT EXISTS last_working_day DATE,
    ADD COLUMN IF NOT EXISTS notice_period_days INTEGER,
    ADD COLUMN IF NOT EXISTS notice_served_at TIMESTAMPTZ,
    ADD COLUMN IF NOT EXISTS offboarding_state JSONB DEFAULT '{}'::jsonb,
    ADD COLUMN IF NOT EXISTS relieving_letter_url TEXT`);
} catch (_) {}

let errorMsg = '';
let successMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;

  try {
    if (action === 'update_personal') {
      const fullName = (fd.get('fullName') as string || '').trim();
      const phone = (fd.get('phone') as string || '').trim();
      const personalEmail = (fd.get('personalEmail') as string || '').trim();
      const dob = (fd.get('dob') as string || '').trim();
      const gender = (fd.get('gender') as string || '').trim();
      const nationality = (fd.get('nationality') as string || '').trim();
      const bloodGroup = (fd.get('bloodGroup') as string || '').trim();
      const emergencyName = (fd.get('emergencyName') as string || '').trim();
      const emergencyPhone = (fd.get('emergencyPhone') as string || '').trim();
      const emergencyRelation = (fd.get('emergencyRelation') as string || '').trim();
      const city = (fd.get('city') as string || '').trim();
      const state = (fd.get('state') as string || '').trim();
      const country = (fd.get('country') as string || '').trim();

      await db.execute(sqlExpr`
        UPDATE hr_employees SET
          full_name = ${fullName}, phone = ${phone || null},
          personal_email = ${personalEmail || null},
          date_of_birth = ${dob || null}, gender = ${gender || null},
          nationality = ${nationality || null}, blood_group = ${bloodGroup || null},
          emergency_contact_name = ${emergencyName || null},
          emergency_contact_phone = ${emergencyPhone || null},
          emergency_contact_relation = ${emergencyRelation || null},
          city = ${city || null}, state = ${state || null}, country = ${country || null},
          updated_at = NOW()
        WHERE id = ${id}
      `);
      successMsg = 'Personal details updated.';
    } else if (action === 'update_employment') {
      const designation = (fd.get('designation') as string || '').trim();
      const employmentType = (fd.get('employmentType') as string || '').trim();
      const workMode = (fd.get('workMode') as string || '').trim();
      const joiningDate = (fd.get('joiningDate') as string || '').trim();
      const confirmationDate = (fd.get('confirmationDate') as string || '').trim();
      const probationEndDate = (fd.get('probationEndDate') as string || '').trim();
      const baseSalary = (fd.get('baseSalary') as string || '').trim();
      const currency = (fd.get('currency') as string || 'INR').trim();
      const panNumber = (fd.get('panNumber') as string || '').trim();
      const aadhaarNumber = (fd.get('aadhaarNumber') as string || '').trim();

      await db.execute(sqlExpr`
        UPDATE hr_employees SET
          designation = ${designation || null},
          employment_type = ${employmentType || null},
          work_mode = ${workMode || null},
          joining_date = ${joiningDate || null},
          confirmation_date = ${confirmationDate || null},
          probation_end_date = ${probationEndDate || null},
          base_salary = ${baseSalary ? parseFloat(baseSalary) : null},
          currency = ${currency},
          pan_number = ${panNumber || null},
          aadhaar_number = ${aadhaarNumber || null},
          updated_at = NOW()
        WHERE id = ${id}
      `);
      successMsg = 'Employment details updated.';
    } else if (action === 'update_bank') {
      const bankAccountNumber = (fd.get('bankAccountNumber') as string || '').trim();
      const bankName = (fd.get('bankName') as string || '').trim();
      const bankIfsc = (fd.get('bankIfsc') as string || '').trim();
      const bankBranch = (fd.get('bankBranch') as string || '').trim();
      const uanNumber = (fd.get('uanNumber') as string || '').trim();
      const pfNumber = (fd.get('pfNumber') as string || '').trim();
      const esicNumber = (fd.get('esicNumber') as string || '').trim();

      await db.execute(sqlExpr`
        UPDATE hr_employees SET
          bank_account_number = ${bankAccountNumber || null},
          bank_name = ${bankName || null},
          bank_ifsc = ${bankIfsc || null},
          bank_branch = ${bankBranch || null},
          uan_number = ${uanNumber || null},
          pf_number = ${pfNumber || null},
          esic_number = ${esicNumber || null},
          updated_at = NOW()
        WHERE id = ${id}
      `);
      successMsg = 'Banking & compliance details updated.';
    } else if (action === 'add_note') {
      const notes = (fd.get('notes') as string || '').trim();
      await db.execute(sqlExpr`UPDATE hr_employees SET notes = ${notes}, updated_at = NOW() WHERE id = ${id}`);
      successMsg = 'Notes saved.';
    } else if (action === 'initiate_exit') {
      const exitType = (fd.get('exitType') as string || 'resignation').trim();
      const noticeDays = parseInt((fd.get('noticePeriodDays') as string) || '0', 10) || 0;
      const lastWorkingDay = (fd.get('lastWorkingDay') as string || '').trim() || null;
      const exitReason = (fd.get('exitReason') as string || '').trim() || null;
      await db.execute(sqlExpr`
        UPDATE hr_employees SET
          exit_type = ${exitType},
          notice_period_days = ${noticeDays || null},
          last_working_day = ${lastWorkingDay},
          exit_reason = ${exitReason},
          notice_served_at = COALESCE(notice_served_at, NOW()),
          employment_status = 'notice_period',
          offboarding_state = COALESCE(offboarding_state, '{}'::jsonb),
          updated_at = NOW()
        WHERE id = ${id}
      `);
      successMsg = 'Offboarding initiated. The employee is now on notice period.';
    } else if (action === 'update_exit_checklist') {
      const state = {
        exit_interview: fd.get('exit_interview') === 'on',
        dues_cleared: fd.get('dues_cleared') === 'on',
        assets_returned: fd.get('assets_returned') === 'on',
        access_revoked: fd.get('access_revoked') === 'on',
        relieving_letter_issued: fd.get('relieving_letter_issued') === 'on',
        knowledge_handover: fd.get('knowledge_handover') === 'on',
        final_payroll: fd.get('final_payroll') === 'on',
      };
      const relievingUrl = (fd.get('relievingLetterUrl') as string || '').trim() || null;
      await db.execute(sqlExpr`
        UPDATE hr_employees SET
          offboarding_state = ${JSON.stringify(state)}::jsonb,
          relieving_letter_url = ${relievingUrl},
          updated_at = NOW()
        WHERE id = ${id}
      `);
      successMsg = 'Offboarding checklist updated.';
    } else if (action === 'mark_relieved') {
      // Final step: deactivate employee record + linked user account.
      const exitDate = (fd.get('exitDate') as string || '').trim() || null;
      const exitReason = (fd.get('exitReason') as string || '').trim() || null;
      await db.execute(sqlExpr`
        UPDATE hr_employees SET
          is_active = false,
          employment_status = 'exited',
          exit_date = ${exitDate || sqlExpr`COALESCE(last_working_day, CURRENT_DATE)`},
          exit_reason = COALESCE(${exitReason}, exit_reason),
          updated_at = NOW()
        WHERE id = ${id}
      `);
      // If linked to a user account, deactivate the login + clear face enrol
      // so a future rehire forces re-enrolment.
      await db.execute(sqlExpr`
        UPDATE users SET is_active = false, updated_at = NOW()
        WHERE id = (SELECT user_id FROM hr_employees WHERE id = ${id})
      `);
      await db.execute(sqlExpr`
        UPDATE user_face_enrollments SET is_active = false
        WHERE user_id = (SELECT user_id FROM hr_employees WHERE id = ${id})
      `).catch(() => {});
      successMsg = 'Employee relieved. Login deactivated and access revoked.';
    } else if (action === 'cancel_exit') {
      await db.execute(sqlExpr`
        UPDATE hr_employees SET
          employment_status = 'active',
          exit_type = NULL, notice_period_days = NULL, last_working_day = NULL,
          notice_served_at = NULL, exit_date = NULL, exit_reason = NULL,
          offboarding_state = '{}'::jsonb, relieving_letter_url = NULL,
          updated_at = NOW()
        WHERE id = ${id}
      `);
      successMsg = 'Exit cancelled - employee back to active status.';
    } else if (action === 'open_probation') {
      const { openProbation } = await import('@/lib/hr-lifecycle');
      const startDate = (fd.get('start_date') as string || '').trim();
      const durationMonths = parseInt((fd.get('duration_months') as string || '6'), 10);
      const noticeDays = parseInt((fd.get('notice_days') as string || '30'), 10);
      if (!startDate) { errorMsg = 'Start date is required.'; }
      else {
        const r = await openProbation({ employeeId: id, startDate, durationMonths, noticeDaysDuringProbation: noticeDays });
        successMsg = 'Probation opened. Auto-scheduled 30/60/90-day reviews. End: ' + r.scheduledEnd;
      }
    } else if (action === 'record_review') {
      const { recordReview } = await import('@/lib/hr-lifecycle');
      await recordReview({
        reviewId: fd.get('review_id') as string,
        rating: fd.get('rating') as any,
        summary: (fd.get('summary') as string || '').trim().slice(0, 4000),
        managerUserId: user.id,
      });
      successMsg = 'Review recorded.';
    } else if (action === 'confirm_employee') {
      const { confirmEmployee } = await import('@/lib/hr-lifecycle');
      await confirmEmployee({ probationId: fd.get('probation_id') as string, confirmedByUserId: user.id, letterUrl: (fd.get('letter_url') as string || '').trim() || undefined });
      successMsg = 'Employee confirmed. Written confirmation recorded.';
    } else if (action === 'extend_probation') {
      const { extendProbation } = await import('@/lib/hr-lifecycle');
      const r = await extendProbation({ probationId: fd.get('probation_id') as string, months: parseInt(fd.get('months') as string || '3', 10), reason: (fd.get('reason') as string || '').trim() });
      if (r.ok) successMsg = 'Probation extended to ' + r.newEnd;
      else errorMsg = r.error || 'Failed to extend.';
    } else if (action === 'set_goal') {
      const { setGoal } = await import('@/lib/hr-lifecycle');
      await setGoal({
        employeeId: id, kind: fd.get('kind') as any, title: (fd.get('title') as string || '').trim().slice(0, 300),
        description: (fd.get('description') as string || '').trim().slice(0, 4000),
        successMetric: (fd.get('success_metric') as string || '').trim().slice(0, 2000),
        targetDate: (fd.get('target_date') as string || '').trim() || undefined,
        weightPct: parseInt((fd.get('weight_pct') as string || '0'), 10) || undefined,
        setByUserId: user.id,
      });
      successMsg = 'Goal recorded and visible to employee.';
    } else if (action === 'close_goal') {
      const { closeGoal } = await import('@/lib/hr-lifecycle');
      await closeGoal(fd.get('goal_id') as string, fd.get('status') as any, (fd.get('notes') as string || '').trim().slice(0, 2000));
      successMsg = 'Goal closed.';
    } else if (action === 'open_pip') {
      const { openPip } = await import('@/lib/hr-lifecycle');
      const r = await openPip({
        employeeId: id, openedByUserId: user.id,
        managerUserId: (fd.get('manager_user_id') as string || '').trim() || undefined,
        durationWeeks: parseInt((fd.get('duration_weeks') as string || '2'), 10),
        reason: (fd.get('reason') as string || '').trim().slice(0, 4000),
        expectations: (fd.get('expectations') as string || '').trim().slice(0, 4000),
        consequences: (fd.get('consequences') as string || '').trim().slice(0, 2000) || undefined,
      });
      successMsg = 'PIP opened. Scheduled end: ' + r.scheduledEnd;
    } else if (action === 'log_pip_checkin') {
      const { logPipCheckin } = await import('@/lib/hr-lifecycle');
      await logPipCheckin({
        pipId: fd.get('pip_id') as string,
        weekNumber: parseInt(fd.get('week_number') as string, 10),
        progressSummary: (fd.get('progress_summary') as string || '').trim().slice(0, 4000),
        progressRating: fd.get('progress_rating') as any,
        managerUserId: user.id,
      });
      successMsg = 'Weekly check-in recorded.';
    } else if (action === 'close_pip') {
      const { closePip } = await import('@/lib/hr-lifecycle');
      await closePip({ pipId: fd.get('pip_id') as string, outcome: fd.get('outcome') as any, outcomeNotes: (fd.get('outcome_notes') as string || '').trim().slice(0, 4000) });
      successMsg = 'PIP closed.';
    } else if (action === 'raise_flag') {
      const { raiseFlag, BREACH_TYPES } = await import('@/lib/hr-flags');
      const breachType = (fd.get('breach_type') as string || '').trim() as keyof typeof BREACH_TYPES;
      const description = (fd.get('flag_description') as string || '').trim().slice(0, 4000);
      const actionTaken = (fd.get('flag_action_taken') as string || '').trim().slice(0, 2000) || undefined;
      if (!breachType || !BREACH_TYPES[breachType]) {
        errorMsg = 'Select a breach type from the list.';
      } else if (!description) {
        errorMsg = 'Description is required.';
      } else {
        const r = await raiseFlag({
          employeeId: id,
          breachType,
          description,
          actionTaken,
          flaggedByUserId: user.id,
          flaggedByName: user.name || user.email,
        });
        if (r.ok) {
          successMsg = 'Flag recorded.' + (r.autoEscalated ? ' Auto-escalated to Level 2 review (three-strike rule).' : '');
        } else {
          errorMsg = r.error || 'Could not raise flag.';
        }
      }
    } else if (action === 'reactivate') {
      await db.execute(sqlExpr`
        UPDATE hr_employees SET
          is_active = true, employment_status = 'active',
          exit_type = NULL, notice_period_days = NULL, last_working_day = NULL,
          notice_served_at = NULL, exit_date = NULL, exit_reason = NULL,
          offboarding_state = '{}'::jsonb, relieving_letter_url = NULL,
          updated_at = NOW()
        WHERE id = ${id}
      `);
      await db.execute(sqlExpr`
        UPDATE users SET is_active = true, updated_at = NOW()
        WHERE id = (SELECT user_id FROM hr_employees WHERE id = ${id})
      `);
      successMsg = 'Employee reactivated. Login restored.';
    }
  } catch (err: any) {
    errorMsg = 'Error: ' + (err.message || 'Unknown');
  }
}

const result = await db.execute(sqlExpr`SELECT * FROM hr_employees WHERE id = ${id} LIMIT 1`);
const _empRows = Array.isArray(result) ? result : (result?.rows || []);
if (_empRows.length === 0) return Astro.redirect('/admin/hr/employees');
const emp = _empRows[0] as any;

// Fetch leave balances
const leaveBalances = await db.execute(sqlExpr`
  SELECT lb.*, lt.name, lt.code, lt.is_paid
  FROM hr_leave_balances lb
  JOIN hr_leave_types lt ON lb.leave_type_id = lt.id
  WHERE lb.employee_id = ${id} AND lb.year = EXTRACT(YEAR FROM NOW())
  ORDER BY lt.name
`);
const leaveBalanceRows = (Array.isArray(leaveBalances) ? leaveBalances : leaveBalanceRows) as any[];

// Load conduct flags per Recruitment & Work Policy v2.0
const { listFlags, BREACH_TYPES } = await import('@/lib/hr-flags');
const flags = await listFlags(id);

// Load HR lifecycle state — probation, KRAs, PIPs (per HR Lifecycle Manual v1.0)
const { getActiveProbation, listProbationReviews, listGoals, listPips, listPipCheckins } = await import('@/lib/hr-lifecycle');
const activeProbation: any = await getActiveProbation(id);
const probationReviews = activeProbation ? await listProbationReviews(activeProbation.id) : [];
const goals = await listGoals(id);
const pips = await listPips(id);
const activePip = pips.find((p: any) => !p.closed_at);
const activePipCheckins = activePip ? await listPipCheckins(activePip.id) : [];
const l1count = flags.filter((f: any) => f.level === 1 && !f.is_escalation).length;
const l2count = flags.filter((f: any) => f.level === 2).length;
const l3count = flags.filter((f: any) => f.level === 3).length;
const BREACH_KEYS = Object.keys(BREACH_TYPES) as Array<keyof typeof BREACH_TYPES>;

// Fetch recent attendance
const attendance = await db.execute(sqlExpr`
  SELECT * FROM hr_attendance WHERE employee_id = ${id}
  ORDER BY date DESC LIMIT 10
`);
const attendanceRows = (Array.isArray(attendance) ? attendance : attendanceRows) as any[];

// Fetch recent leave requests
const leaveRequests = await db.execute(sqlExpr`
  SELECT lr.*, lt.name as leave_name, lt.code
  FROM hr_leave_requests lr
  JOIN hr_leave_types lt ON lr.leave_type_id = lt.id
  WHERE lr.employee_id = ${id}
  ORDER BY lr.applied_at DESC LIMIT 5
`);
const leaveRequestRows = (Array.isArray(leaveRequests) ? leaveRequests : leaveRequestRows) as any[];

// Fetch recent daily work reports
let dailyReportRows: any[] = [];
try {
  const dr = await db.execute(sqlExpr`SELECT * FROM hr_daily_reports WHERE employee_id = ${id} ORDER BY report_date DESC LIMIT 30`);
  dailyReportRows = (Array.isArray(dr) ? dr : (dr?.rows || [])) as any[];
} catch (e) {}

function formatDate(d: any) {
  if (!d) return '—';
  return new Date(d).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short', year: 'numeric' });
}

const tabs = ['Personal', 'Employment', 'Banking', 'Leave', 'Attendance', 'Notes', 'Reports', 'Exit'];

const offboardState = (emp.offboarding_state && typeof emp.offboarding_state === 'object') ? emp.offboarding_state as any : {};
const onNotice = emp.employment_status === 'notice_period';
const hasExited = !emp.is_active || emp.employment_status === 'exited';
---
<AdminLayout title={`${emp.full_name} — Employee`} activeNav="hr">
<div style="padding-bottom:80px;">

  <!-- Header -->
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <a href="/admin/hr/employees" style="display:inline-flex;align-items:center;gap:6px;color:#6e6e78;text-decoration:none;font-size:12px;margin-bottom:10px;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      All Employees
    </a>
    <div style="display:flex;align-items:center;gap:12px;">
      {/* The verified photo captured at the employee's face-2FA enrolment. */}
      {emp.photo_url
        ? <img src={emp.photo_url} alt={emp.full_name} width="44" height="44" title="Photo captured at face verification" style="width:44px;height:44px;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid #FF4F00;" />
        : <div style={`width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,${emp.employment_status === 'active' ? '#FF4F00,#FF7040' : '#2a2a32,#1a1a1f'});display:flex;align-items:center;justify-content:center;font-weight:700;font-size:18px;color:#fff;flex-shrink:0;`}>
          {emp.full_name.substring(0, 1).toUpperCase()}
        </div>}
      <div>
        <h1 style="font-size:16px;font-weight:700;color:#fff;margin:0;">{emp.full_name}</h1>
        <p style="font-size:11px;color:#6e6e78;margin:2px 0 0;">{emp.designation || 'No designation'} · <span style="font-family:'Geist Mono',monospace;">{emp.employee_code}</span></p>
      </div>
      <span style={`margin-left:auto;font-size:9px;font-weight:700;padding:3px 8px;border-radius:100px;text-transform:uppercase;${emp.employment_status === 'active' ? 'background:rgba(16,185,129,0.15);color:#6ee7b7;' : 'background:rgba(239,68,68,0.15);color:#fca5a5;'}`}>
        {emp.employment_status}
      </span>
    </div>
  </div>

  <!-- Messages -->
  {errorMsg && <div style="margin:12px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {successMsg && <div style="margin:12px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{successMsg}</div>}

  <!-- Tab Navigation -->
  <div style="overflow-x:auto;border-bottom:1px solid #1a1a1f;padding:0 16px;">
    <div style="display:flex;gap:0;min-width:max-content;" id="tabNav">
      {tabs.map((tab, i) => (
        <button data-tab={i} class="hr-tab" style={`background:none;border:none;border-bottom:2px solid ${i === 0 ? '#FF4F00' : 'transparent'};color:${i === 0 ? '#FF7040' : '#6e6e78'};font-size:12px;font-weight:600;padding:12px 14px;cursor:pointer;white-space:nowrap;transition:all 0.12s;`}>
          {tab}
        </button>
      ))}
    </div>
  </div>

  <!-- Tab Panels -->
  <div style="padding:16px;">

    <!-- PERSONAL -->
    <div id="panel-0" class="hr-panel">
      <form method="POST" style="display:flex;flex-direction:column;gap:12px;">
        <input type="hidden" name="action" value="update_personal" />
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          <div style="grid-column:1/-1;">
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Full Name *</label>
            <input type="text" name="fullName" value={emp.full_name} required style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Work Phone</label>
            <input type="tel" name="phone" value={emp.phone || ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Personal Email</label>
            <input type="email" name="personalEmail" value={emp.personal_email || ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Date of Birth</label>
            <input type="date" name="dob" value={emp.date_of_birth ? emp.date_of_birth.toString().split('T')[0] : ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Gender</label>
            <select name="gender" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
              <option value="" selected={!emp.gender}>Select</option>
              <option value="Male" selected={emp.gender === 'Male'}>Male</option>
              <option value="Female" selected={emp.gender === 'Female'}>Female</option>
              <option value="Non-binary" selected={emp.gender === 'Non-binary'}>Non-binary</option>
              <option value="Prefer not to say" selected={emp.gender === 'Prefer not to say'}>Prefer not to say</option>
            </select>
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Blood Group</label>
            <select name="bloodGroup" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
              {['', 'A+', 'A-', 'B+', 'B-', 'O+', 'O-', 'AB+', 'AB-'].map(bg => (
                <option value={bg} selected={emp.blood_group === bg}>{bg || 'Select'}</option>
              ))}
            </select>
