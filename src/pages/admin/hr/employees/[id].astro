          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Nationality</label>
            <input type="text" name="nationality" value={emp.nationality || ''} placeholder="Indian" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">City</label>
            <input type="text" name="city" value={emp.city || ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">State</label>
            <input type="text" name="state" value={emp.state || ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Country</label>
            <input type="text" name="country" value={emp.country || 'India'} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
          </div>
          <div style="grid-column:1/-1;background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px;">
            <p style="font-size:11px;font-weight:600;color:#8a8a94;margin:0 0 10px;text-transform:uppercase;letter-spacing:0.08em;">Emergency Contact</p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
              <div style="grid-column:1/-1;">
                <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Name</label>
                <input type="text" name="emergencyName" value={emp.emergency_contact_name || ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
              </div>
              <div>
                <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Phone</label>
                <input type="tel" name="emergencyPhone" value={emp.emergency_contact_phone || ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
              </div>
              <div>
                <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Relation</label>
                <input type="text" name="emergencyRelation" value={emp.emergency_contact_relation || ''} placeholder="Spouse, Parent..." style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
              </div>
            </div>
          </div>
        </div>
        <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">Save Personal Details</button>
      </form>
    </div>

    <!-- EMPLOYMENT -->
    <div id="panel-1" class="hr-panel" style="display:none;">
      <form method="POST" style="display:flex;flex-direction:column;gap:12px;">
        <input type="hidden" name="action" value="update_employment" />
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          <div style="grid-column:1/-1;">
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Designation</label>
            <input type="text" name="designation" value={emp.designation || ''} placeholder="Senior Engineer" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Employment Type</label>
            <select name="employmentType" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
              {['Full-Time','Part-Time','Contract','Internship','Freelance','Consultant','Apprenticeship','Fellowship'].map(t => (
                <option value={t} selected={emp.employment_type === t}>{t}</option>
              ))}
            </select>
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Work Mode</label>
            <select name="workMode" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
              {['Remote','Hybrid','On-Site'].map(m => (
                <option value={m} selected={emp.work_mode === m}>{m}</option>
              ))}
            </select>
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Joining Date</label>
            <input type="date" name="joiningDate" value={emp.joining_date ? emp.joining_date.toString().split('T')[0] : ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Confirmation Date</label>
            <input type="date" name="confirmationDate" value={emp.confirmation_date ? emp.confirmation_date.toString().split('T')[0] : ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Probation End Date</label>
            <input type="date" name="probationEndDate" value={emp.probation_end_date ? emp.probation_end_date.toString().split('T')[0] : ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Base Salary</label>
            <div style="display:flex;gap:6px;">
              <select name="currency" style="background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 8px;color:#fff;font-size:12px;outline:none;width:80px;">
                {['INR','USD','GBP','EUR','SGD','AED','CAD','AUD'].map(c => (
                  <option value={c} selected={emp.currency === c}>{c}</option>
                ))}
              </select>
              <input type="number" name="baseSalary" value={emp.base_salary || ''} placeholder="0 = Unpaid" style="flex:1;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
            </div>
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">PAN Number</label>
            <input type="text" name="panNumber" value={emp.pan_number || ''} placeholder="ABCDE1234F" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;font-family:'Geist Mono',monospace;" />
          </div>
          <div style="grid-column:1/-1;">
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Aadhaar Number</label>
            <input type="text" name="aadhaarNumber" value={emp.aadhaar_number || ''} placeholder="XXXX XXXX XXXX" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;font-family:'Geist Mono',monospace;" />
          </div>
        </div>
        <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">Save Employment Details</button>
      </form>
    </div>

    <!-- BANKING -->
    <div id="panel-2" class="hr-panel" style="display:none;">
      <form method="POST" style="display:flex;flex-direction:column;gap:12px;">
        <input type="hidden" name="action" value="update_bank" />
        <div style="background:rgba(255,159,0,0.08);border:1px solid rgba(255,159,0,0.2);border-radius:8px;padding:10px 12px;margin-bottom:4px;">
          <p style="font-size:12px;color:#fbbf24;margin:0;display:flex;align-items:center;gap:6px;"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>Sensitive data. Only HR admins should access this section.</p>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          <div style="grid-column:1/-1;">
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Bank Account Number</label>
            <input type="text" name="bankAccountNumber" value={emp.bank_account_number || ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;font-family:'Geist Mono',monospace;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Bank Name</label>
            <input type="text" name="bankName" value={emp.bank_name || ''} placeholder="State Bank of India" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">IFSC Code</label>
            <input type="text" name="bankIfsc" value={emp.bank_ifsc || ''} placeholder="SBIN0001234" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;font-family:'Geist Mono',monospace;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">UAN Number</label>
            <input type="text" name="uanNumber" value={emp.uan_number || ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;font-family:'Geist Mono',monospace;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">PF Number</label>
            <input type="text" name="pfNumber" value={emp.pf_number || ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;font-family:'Geist Mono',monospace;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">ESIC Number</label>
            <input type="text" name="esicNumber" value={emp.esic_number || ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;font-family:'Geist Mono',monospace;" />
          </div>
        </div>
        <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">Save Banking Details</button>
      </form>
    </div>

    <!-- PROBATION — per HR Employee Lifecycle Manual v1.0 §E -->
    <div id="panel-probation" class="hr-panel" style="margin-top:24px;">
      <p style="font-size:11px;color:#22d3ee;letter-spacing:0.12em;text-transform:uppercase;margin:0;font-weight:700;font-family:'Geist Mono',monospace;">Probation &amp; Confirmation</p>
      <p style="font-size:13px;color:#fff;margin:4px 0 12px;font-weight:600;">
        {activeProbation ? `Active · ${activeProbation.duration_months}-month term · ends ${new Date(activeProbation.extended_to_date || activeProbation.scheduled_end_date).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day:'2-digit', month:'short', year:'numeric' })}` : 'No active probation on file'}
      </p>

      {!activeProbation && (
        <form method="POST" style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:14px;margin-bottom:14px;">
          <input type="hidden" name="action" value="open_probation" />
          <p style="font-size:11.5px;color:#9aa6b6;margin:0 0 10px;font-weight:600;">Open probation period</p>
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:8px;margin-bottom:10px;">
            <input name="start_date" type="date" required value={new Date().toISOString().slice(0,10)} style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 10px;border-radius:6px;font-size:12px;" />
            <select name="duration_months" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 10px;border-radius:6px;font-size:12px;">
              <option value="3">3 months</option>
              <option value="6" selected>6 months (standard)</option>
              <option value="9">9 months</option>
              <option value="12">12 months</option>
            </select>
            <select name="notice_days" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 10px;border-radius:6px;font-size:12px;">
              <option value="7">7 days notice during probation</option>
              <option value="14">14 days notice</option>
              <option value="30" selected>30 days notice (standard)</option>
            </select>
          </div>
          <button type="submit" style="background:#22d3ee;color:#04161b;border:none;padding:8px 18px;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer;">Open probation + auto-schedule 30/60/90 reviews</button>
        </form>
      )}

      {activeProbation && (
        <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:14px;">
          {probationReviews.map((r: any) => (
            <div style={`background:#0f0f14;border:1px solid ${r.rating === 'at_risk' ? 'rgba(239,68,68,0.32)' : r.rating === 'needs_improvement' ? 'rgba(251,191,36,0.32)' : r.rating === 'exceeds' ? 'rgba(74,222,128,0.32)' : '#1a1a1f'};border-radius:8px;padding:10px 14px;`}>
              <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:6px;">
                <p style="font-size:13px;color:#fff;font-weight:700;margin:0;">Day {r.review_day} review · {new Date(r.scheduled_at).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day:'2-digit', month:'short' })}</p>
                {r.rating && <span style="background:rgba(34,211,238,0.14);color:#22d3ee;font-size:10px;font-weight:700;padding:2px 8px;border-radius:100px;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">{r.rating.replace(/_/g, ' ')}</span>}
              </div>
              {r.summary && <p style="font-size:11.5px;color:#cfd6da;line-height:1.5;margin:0 0 8px;white-space:pre-wrap;">{r.summary}</p>}
              {!r.conducted_at && (
                <form method="POST" style="display:grid;grid-template-columns:auto 1fr auto;gap:6px;margin-top:6px;">
                  <input type="hidden" name="action" value="record_review" />
                  <input type="hidden" name="review_id" value={r.id} />
                  <select name="rating" required style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:6px 8px;border-radius:5px;font-size:11px;">
                    <option value="exceeds">Exceeds</option>
                    <option value="on_track" selected>On track</option>
                    <option value="needs_improvement">Needs improvement</option>
                    <option value="at_risk">At risk</option>
                  </select>
                  <input name="summary" type="text" required maxlength="4000" placeholder="Specific written summary..." style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:6px 8px;border-radius:5px;font-size:11px;" />
                  <button type="submit" style="background:#22d3ee;color:#04161b;border:none;padding:6px 12px;border-radius:5px;font-size:11px;font-weight:700;cursor:pointer;">Record</button>
                </form>
              )}
            </div>
          ))}
        </div>
      )}

      {activeProbation && (
        <div style="display:flex;gap:6px;flex-wrap:wrap;">
          <form method="POST" onsubmit="return confirm('Issue written confirmation? This ends probation and marks the employee permanently confirmed.');" style="margin:0;">
            <input type="hidden" name="action" value="confirm_employee" />
            <input type="hidden" name="probation_id" value={activeProbation.id} />
            <button type="submit" style="background:#10b981;color:#fff;border:none;padding:8px 16px;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer;">Issue confirmation letter</button>
          </form>
          <form method="POST" onsubmit="this.querySelector('input[name=reason]').value = prompt('Reason for extension (will be on record):') || ''; if (!this.querySelector('input[name=reason]').value) return false;" style="margin:0;">
            <input type="hidden" name="action" value="extend_probation" />
            <input type="hidden" name="probation_id" value={activeProbation.id} />
            <input type="hidden" name="reason" value="" />
            <select name="months" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:7px 9px;border-radius:6px;font-size:11.5px;margin-right:4px;">
              <option value="3">Extend 3 months</option>
              <option value="2">Extend 2 months</option>
              <option value="1">Extend 1 month</option>
            </select>
            <button type="submit" style="background:#fbbf24;color:#1a1207;border:none;padding:8px 16px;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer;">Extend probation</button>
          </form>
        </div>
      )}
    </div>

    <!-- KRA + 30/60/90 PLAN — per HR Employee Lifecycle Manual v1.0 §D.8 -->
    <div id="panel-goals" class="hr-panel" style="margin-top:24px;">
      <p style="font-size:11px;color:#86efac;letter-spacing:0.12em;text-transform:uppercase;margin:0;font-weight:700;font-family:'Geist Mono',monospace;">KRAs &amp; 30-60-90 Plan</p>
      <p style="font-size:13px;color:#fff;margin:4px 0 12px;font-weight:600;">{goals.length} goal(s) on record. Written + acknowledged = manageable.</p>

      <form method="POST" style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:14px;margin-bottom:14px;">
        <input type="hidden" name="action" value="set_goal" />
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:8px;margin-bottom:8px;">
          <select name="kind" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 10px;border-radius:6px;font-size:12px;">
            <option value="kra">KRA (ongoing)</option>
            <option value="30_day">30-day</option>
            <option value="60_day">60-day</option>
            <option value="90_day">90-day</option>
            <option value="quarterly">Quarterly</option>
          </select>
          <input name="target_date" type="date" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 10px;border-radius:6px;font-size:12px;" />
          <input name="weight_pct" type="number" min="0" max="100" placeholder="Weight %" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 10px;border-radius:6px;font-size:12px;" />
        </div>
        <input name="title" type="text" required maxlength="300" placeholder="Goal title (e.g. 'Ship new ranking algorithm v2')" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 10px;border-radius:6px;font-size:12px;margin-bottom:8px;" />
        <textarea name="description" rows="2" maxlength="4000" placeholder="What needs to be done..." style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 10px;border-radius:6px;font-size:12px;font-family:'Inter Tight',sans-serif;resize:vertical;margin-bottom:8px;"></textarea>
        <input name="success_metric" type="text" maxlength="2000" placeholder="Success metric — exactly how this will be measured" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 10px;border-radius:6px;font-size:12px;margin-bottom:8px;" />
        <button type="submit" style="background:#86efac;color:#040801;border:none;padding:8px 18px;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer;">Set goal</button>
      </form>

      <div style="display:flex;flex-direction:column;gap:6px;">
        {goals.length === 0 ? (
          <div style="text-align:center;padding:16px;color:#6e6e78;font-size:12px;border:1px dashed #1a1a1f;border-radius:8px;">No goals set. The manual flags this as the highest-risk gap.</div>
        ) : goals.map((g: any) => {
          const statusColor = g.status === 'met' ? '#86efac' : g.status === 'missed' ? '#fca5a5' : g.status === 'partial' ? '#fbbf24' : '#cfd6da';
          const kindLabel = g.kind === 'kra' ? 'KRA' : g.kind.replace('_', '-').toUpperCase();
          return (
            <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:8px;padding:10px 14px;">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;flex-wrap:wrap;margin-bottom:4px;">
                <div>
                  <span style="background:rgba(134,239,172,0.12);color:#86efac;font-size:9.5px;font-weight:700;padding:2px 7px;border-radius:100px;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">{kindLabel}</span>
                  <span style="color:#fff;font-size:13px;font-weight:600;margin-left:8px;">{g.title}</span>
                </div>
                <span style={`color:${statusColor};font-size:10.5px;font-weight:700;font-family:'Geist Mono',monospace;text-transform:uppercase;letter-spacing:0.08em;`}>{g.status}</span>
              </div>
              {g.success_metric && <p style="font-size:11px;color:#cfd6da;margin:4px 0 0;line-height:1.5;"><strong style="color:#86efac;">Metric:</strong> {g.success_metric}</p>}
              {g.target_date && <p style="font-size:10.5px;color:#6e6e78;margin:3px 0 0;font-family:'Geist Mono',monospace;">Target: {new Date(g.target_date).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day:'2-digit', month:'short', year:'numeric' })} · Weight {g.weight_pct || 0}%</p>}
              {g.outcome_notes && <p style="font-size:11px;color:#9aa6b6;margin:6px 0 0;line-height:1.5;font-style:italic;">{g.outcome_notes}</p>}
              {g.status === 'open' && (
                <form method="POST" style="margin-top:6px;display:flex;gap:4px;flex-wrap:wrap;">
                  <input type="hidden" name="action" value="close_goal" />
                  <input type="hidden" name="goal_id" value={g.id} />
                  <select name="status" required style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:5px 8px;border-radius:5px;font-size:11px;">
                    <option value="met">Met</option>
                    <option value="partial">Partial</option>
                    <option value="missed">Missed</option>
                    <option value="dropped">Dropped</option>
                  </select>
                  <input name="notes" type="text" maxlength="2000" placeholder="Outcome notes (optional)" style="flex:1;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:5px 8px;border-radius:5px;font-size:11px;min-width:120px;" />
                  <button type="submit" style="background:#15151a;border:1px solid #2a2a2f;color:#cfd6da;padding:5px 12px;border-radius:5px;font-size:11px;font-weight:700;cursor:pointer;">Close</button>
                </form>
              )}
            </div>
          );
        })}
      </div>
    </div>

    <!-- PIP — per HR Employee Lifecycle Manual v1.0 §F.4 -->
    <div id="panel-pip" class="hr-panel" style="margin-top:24px;">
      <p style="font-size:11px;color:#fbbf24;letter-spacing:0.12em;text-transform:uppercase;margin:0;font-weight:700;font-family:'Geist Mono',monospace;">Performance Improvement Plans</p>
      <p style="font-size:13px;color:#fff;margin:4px 0 12px;font-weight:600;">{activePip ? `Active PIP · ends ${new Date(activePip.scheduled_end_date).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day:'2-digit', month:'short' })}` : `${pips.length} historical PIP(s)`}</p>

      {!activePip && (
        <form method="POST" style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:14px;margin-bottom:14px;">
          <input type="hidden" name="action" value="open_pip" />
          <p style="font-size:11.5px;color:#fbbf24;margin:0 0 10px;font-weight:700;display:flex;align-items:center;gap:6px;"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>Open a Performance Improvement Plan</p>
          <p style="font-size:11px;color:#9aa6b6;margin:0 0 10px;line-height:1.5;">The manual mandates a documented PIP BEFORE any performance termination. Skipping this is the #1 reason terminations fail under legal review.</p>
          <select name="duration_weeks" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 10px;border-radius:6px;font-size:12px;margin-bottom:8px;">
            <option value="2" selected>2 weeks (manual recommended)</option>
            <option value="4">4 weeks</option>
            <option value="6">6 weeks</option>
          </select>
          <textarea name="reason" rows="3" required maxlength="4000" placeholder="Specific underperformance — observable, dated, measurable. NOT 'attitude' or 'fit'." style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 10px;border-radius:6px;font-size:12px;font-family:'Inter Tight',sans-serif;resize:vertical;margin-bottom:8px;"></textarea>
          <textarea name="expectations" rows="3" required maxlength="4000" placeholder="Specific measurable improvements required by week 2 — e.g. 'Hit 95% on-time delivery on next 5 tickets'" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 10px;border-radius:6px;font-size:12px;font-family:'Inter Tight',sans-serif;resize:vertical;margin-bottom:8px;"></textarea>
          <input name="consequences" type="text" maxlength="2000" placeholder="Consequences if not met (e.g. 'Termination with 30-day notice')" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 10px;border-radius:6px;font-size:12px;margin-bottom:8px;" />
          <button type="submit" style="background:#fbbf24;color:#1a1207;border:none;padding:8px 18px;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer;">Open PIP</button>
        </form>
      )}

      {activePip && (
        <div style="background:#0f0f14;border:1px solid rgba(251,191,36,0.32);border-left:4px solid #fbbf24;border-radius:10px;padding:14px;margin-bottom:14px;">
          <p style="font-size:11px;color:#fbbf24;margin:0 0 4px;font-family:'Geist Mono',monospace;letter-spacing:0.1em;text-transform:uppercase;font-weight:700;">Active PIP · opened {new Date(activePip.opened_at).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day:'2-digit', month:'short' })}</p>
          <p style="font-size:12px;color:#cfd6da;margin:6px 0;line-height:1.55;"><strong style="color:#fbbf24;">Reason:</strong> {activePip.reason}</p>
          <p style="font-size:12px;color:#cfd6da;margin:6px 0;line-height:1.55;"><strong style="color:#fbbf24;">Expectations:</strong> {activePip.expectations}</p>
          {activePip.consequences && <p style="font-size:12px;color:#cfd6da;margin:6px 0;line-height:1.55;"><strong style="color:#fbbf24;">Consequences:</strong> {activePip.consequences}</p>}

          <p style="font-size:11px;color:#9aa6b6;margin:12px 0 6px;font-weight:700;">Weekly check-ins ({activePipCheckins.length} of {activePip.duration_weeks})</p>
          {activePipCheckins.map((c: any) => (
            <div style="background:#08080a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 12px;margin-bottom:5px;">
              <div style="display:flex;justify-content:space-between;font-size:10.5px;color:#9aa6b6;margin-bottom:3px;font-family:'Geist Mono',monospace;">
                <span>WEEK {c.week_number} · {new Date(c.check_date).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day:'2-digit', month:'short' })}</span>
                <span style={`color:${c.progress_rating === 'on_track' ? '#86efac' : c.progress_rating === 'not_met' ? '#fca5a5' : '#fbbf24'};text-transform:uppercase;letter-spacing:0.08em;`}>{c.progress_rating?.replace(/_/g,' ')}</span>
              </div>
              <p style="font-size:11.5px;color:#cfd6da;margin:0;line-height:1.5;white-space:pre-wrap;">{c.progress_summary}</p>
            </div>
          ))}

          {activePipCheckins.length < activePip.duration_weeks && (
            <form method="POST" style="background:#08080a;border:1px solid #2a2a2f;border-radius:6px;padding:8px;margin-top:8px;">
              <input type="hidden" name="action" value="log_pip_checkin" />
              <input type="hidden" name="pip_id" value={activePip.id} />
              <input type="hidden" name="week_number" value={activePipCheckins.length + 1} />
              <p style="font-size:11px;color:#fbbf24;margin:0 0 6px;font-weight:700;">Log week {activePipCheckins.length + 1} check-in</p>
              <textarea name="progress_summary" rows="2" required maxlength="4000" placeholder="Specific progress against the expectations..." style="width:100%;background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:6px 8px;border-radius:5px;font-size:11px;font-family:'Inter Tight',sans-serif;resize:vertical;margin-bottom:6px;"></textarea>
              <div style="display:flex;gap:6px;align-items:center;">
                <select name="progress_rating" required style="background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:6px 8px;border-radius:5px;font-size:11px;">
                  <option value="on_track">On track</option>
                  <option value="partial">Partial</option>
                  <option value="not_met">Not met</option>
                </select>
                <button type="submit" style="background:#fbbf24;color:#1a1207;border:none;padding:6px 14px;border-radius:5px;font-size:11px;font-weight:700;cursor:pointer;">Log check-in</button>
              </div>
            </form>
          )}

          <form method="POST" style="margin-top:10px;padding-top:10px;border-top:1px solid #1a1a1f;">
            <input type="hidden" name="action" value="close_pip" />
            <input type="hidden" name="pip_id" value={activePip.id} />
            <p style="font-size:11px;color:#9aa6b6;margin:0 0 6px;font-weight:700;">Close PIP</p>
            <div style="display:flex;gap:6px;flex-wrap:wrap;">
              <select name="outcome" required style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:6px 10px;border-radius:5px;font-size:11px;">
                <option value="met">Met expectations · retain</option>
                <option value="not_met">Not met · proceed to termination</option>
                <option value="extended">Extend PIP</option>
                <option value="early_resolution">Early resolution</option>
              </select>
              <input name="outcome_notes" type="text" required maxlength="4000" placeholder="Final outcome documentation" style="flex:1;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:6px 10px;border-radius:5px;font-size:11px;min-width:160px;" />
              <button type="submit" style="background:#15151a;border:1px solid #2a2a2f;color:#cfd6da;padding:6px 12px;border-radius:5px;font-size:11px;font-weight:700;cursor:pointer;">Close PIP</button>
            </div>
          </form>
        </div>
      )}

      {!activePip && pips.length > 0 && (
        <div style="display:flex;flex-direction:column;gap:6px;">
          {pips.map((p: any) => (
            <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:6px;padding:8px 12px;">
              <div style="display:flex;justify-content:space-between;font-size:10.5px;color:#9aa6b6;font-family:'Geist Mono',monospace;">
                <span>{new Date(p.opened_at).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day:'2-digit', month:'short', year:'numeric' })} · {p.duration_weeks}w</span>
                <span style={`text-transform:uppercase;letter-spacing:0.08em;color:${p.outcome === 'met' ? '#86efac' : p.outcome === 'not_met' ? '#fca5a5' : '#fbbf24'};`}>{p.outcome || 'closed'}</span>
              </div>
              <p style="font-size:11.5px;color:#cfd6da;margin:3px 0 0;line-height:1.5;">{p.reason}</p>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- CONDUCT FLAGS — per Recruitment & Work Policy v2.0 -->
    <div id="panel-flags" class="hr-panel" style="margin-top:24px;">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:14px;flex-wrap:wrap;">
        <div>
          <p style="font-size:11px;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;font-weight:700;font-family:'Geist Mono',monospace;">Conduct & Performance Flags</p>
          <p style="font-size:13px;color:#fff;margin:4px 0 0;font-weight:600;">{flags.length} total · L1: {l1count} · L2: {l2count} · L3: {l3count}</p>
        </div>
        {l1count > 0 && l1count % 3 === 0 && (
          <span style="background:rgba(239,68,68,0.18);color:#fca5a5;border:1px solid rgba(239,68,68,0.4);padding:5px 12px;border-radius:100px;font-size:11px;font-weight:700;">Three-strike threshold reached</span>
        )}
      </div>

      <form method="POST" style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:14px;margin-bottom:14px;">
        <input type="hidden" name="action" value="raise_flag" />
        <p style="font-size:11.5px;color:#9aa6b6;margin:0 0 10px;font-weight:600;">Raise a new flag</p>
        <div style="display:grid;grid-template-columns:1fr;gap:8px;margin-bottom:8px;">
          <select name="breach_type" required style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 10px;border-radius:6px;font-size:12px;">
            <option value="">Select breach type...</option>
            {BREACH_KEYS.map((k) => {
              const b = BREACH_TYPES[k];
              return <option value={k}>Level {b.level} — {b.label}</option>;
            })}
          </select>
          <textarea name="flag_description" required rows="3" maxlength="4000" placeholder="What happened. Specific incident, date, witnesses if any." style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 10px;border-radius:6px;font-size:12px;font-family:'Inter Tight',sans-serif;resize:vertical;"></textarea>
          <input name="flag_action_taken" type="text" maxlength="2000" placeholder="Action taken (optional — auto-fills from policy if blank)" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:8px 10px;border-radius:6px;font-size:12px;" />
        </div>
        <button type="submit" style="background:#FF4F00;color:#fff;border:none;padding:8px 18px;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer;">Record flag</button>
      </form>

      {flags.length === 0 ? (
        <div style="text-align:center;padding:24px;color:#6e6e78;font-size:12px;border:1px dashed #1a1a1f;border-radius:8px;">No flags on this employee's record.</div>
      ) : (
        <div style="display:flex;flex-direction:column;gap:6px;">
          {flags.map((f: any) => {
            const levelBg = f.level === 3 ? 'rgba(239,68,68,0.14)' : f.level === 2 ? 'rgba(251,191,36,0.14)' : 'rgba(96,165,250,0.10)';
            const levelFg = f.level === 3 ? '#fca5a5' : f.level === 2 ? '#fbbf24' : '#60a5fa';
            const levelBorder = f.level === 3 ? 'rgba(239,68,68,0.32)' : f.level === 2 ? 'rgba(251,191,36,0.32)' : 'rgba(96,165,250,0.32)';
            const spec = BREACH_TYPES[f.breach_type as keyof typeof BREACH_TYPES];
            return (
              <div style={`background:#08080a;border:1px solid ${levelBorder};border-left:4px solid ${levelFg};border-radius:8px;padding:10px 14px;`}>
                <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:10px;margin-bottom:5px;flex-wrap:wrap;">
                  <div>
                    <span style={`background:${levelBg};color:${levelFg};font-size:10px;font-weight:700;padding:2px 8px;border-radius:100px;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;`}>Level {f.level}{f.is_escalation ? ' · auto-escalation' : ''}</span>
                    <span style="color:#fff;font-size:12.5px;font-weight:600;margin-left:8px;">{spec ? spec.label : f.breach_type}</span>
                  </div>
                  <span style="color:#6e6e78;font-size:10.5px;font-family:'Geist Mono',monospace;">{new Date(f.created_at).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' })}</span>
                </div>
                <p style="color:#d8d8de;font-size:11.5px;margin:4px 0 0;line-height:1.55;white-space:pre-wrap;">{f.description}</p>
                {f.action_taken && <p style="color:#9aa6b6;font-size:11px;margin:6px 0 0;line-height:1.5;"><strong style="color:#FF7040;">Action:</strong> {f.action_taken}</p>}
                {f.flagged_by_name && <p style="color:#6e6e78;font-size:10.5px;margin:4px 0 0;">Recorded by {f.flagged_by_name}</p>}
                {f.appeal_status && <p style="color:#fbbf24;font-size:10.5px;margin:4px 0 0;">Appeal: {f.appeal_status}{f.appeal_notes ? ' — ' + f.appeal_notes : ''}</p>}
              </div>
            );
          })}
        </div>
      )}
    </div>

    <!-- LEAVE -->
    <div id="panel-3" class="hr-panel" style="display:none;">
      <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:16px;">
        {leaveBalanceRows.length === 0 ? (
          <div style="text-align:center;padding:32px;color:#6e6e78;">
            <p style="font-size:13px;">No leave balances set for {new Date().getFullYear()}</p>
            <p style="font-size:12px;margin-top:4px;">Use Leave Management to allocate leave.</p>
          </div>
        ) : leaveBalanceRows.map((lb: any) => {
          const remaining = parseFloat(lb.allocated) + parseFloat(lb.carried_forward || 0) - parseFloat(lb.used || 0);
          const pct = lb.allocated > 0 ? Math.min(100, (parseFloat(lb.used || 0) / parseFloat(lb.allocated)) * 100) : 0;
          return (
            <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px;">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
                <div>
                  <p style="font-size:13px;font-weight:600;color:#fff;margin:0;">{lb.name}</p>
                  <p style="font-size:10px;color:#6e6e78;margin:2px 0 0;font-family:'Geist Mono',monospace;">{lb.code} · {lb.is_paid ? 'Paid' : 'Unpaid'}</p>
                </div>
                <div style="text-align:right;">
                  <p style="font-size:18px;font-weight:700;color:#fff;margin:0;">{remaining}</p>
                  <p style="font-size:10px;color:#6e6e78;margin:0;">of {lb.allocated} left</p>
                </div>
              </div>
              <div style="background:#15151a;border-radius:100px;height:4px;overflow:hidden;">
                <div style={`background:#FF4F00;height:100%;width:${pct}%;border-radius:100px;transition:width 0.3s;`}></div>
              </div>
              <div style="display:flex;justify-content:space-between;margin-top:6px;">
                <span style="font-size:10px;color:#6e6e78;">Used: {lb.used || 0}</span>
                <span style="font-size:10px;color:#6e6e78;">Carried: {lb.carried_forward || 0}</span>
              </div>
            </div>
          );
        })}
      </div>

      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px;">
        <p style="font-size:12px;font-weight:600;color:#8a8a94;margin:0 0 10px;text-transform:uppercase;letter-spacing:0.08em;">Recent Leave Requests</p>
        {leaveRequestRows.length === 0 ? (
          <p style="font-size:12px;color:#6e6e78;text-align:center;padding:16px 0;">No leave requests</p>
        ) : leaveRequestRows.map((lr: any) => (
          <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid #1a1a1f;">
            <div>
              <p style="font-size:12px;font-weight:500;color:#d8d8de;margin:0;">{lr.leave_name} ({lr.code})</p>
              <p style="font-size:11px;color:#6e6e78;margin:2px 0 0;">{formatDate(lr.start_date)} → {formatDate(lr.end_date)} · {lr.days}d</p>
            </div>
            <span style={`font-size:10px;font-weight:600;padding:2px 8px;border-radius:100px;${lr.status === 'approved' ? 'background:rgba(16,185,129,0.15);color:#6ee7b7;' : lr.status === 'rejected' ? 'background:rgba(239,68,68,0.15);color:#fca5a5;' : 'background:rgba(251,191,36,0.15);color:#fbbf24;'}`}>
              {lr.status}
            </span>
          </div>
        ))}
      </div>
    </div>

    <!-- ATTENDANCE -->
    <div id="panel-4" class="hr-panel" style="display:none;">
      {attendanceRows.length === 0 ? (
        <div style="text-align:center;padding:48px 16px;color:#6e6e78;">
          <p style="font-size:13px;">No attendance records yet</p>
        </div>
      ) : (
        <div style="display:flex;flex-direction:column;gap:6px;">
          {attendanceRows.map((a: any) => (
            <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px;display:flex;align-items:center;gap:12px;">
              <div style={`width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;${a.status === 'present' ? 'background:rgba(16,185,129,0.1);color:#6ee7b7;' : a.status === 'absent' ? 'background:rgba(239,68,68,0.1);color:#fca5a5;' : 'background:rgba(251,191,36,0.1);color:#fbbf24;'}`}>
                <span style="display:flex;" set:html={a.status === 'present' ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>' : a.status === 'absent' ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' : '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>'}></span>
              </div>
              <div style="flex:1;">
                <p style="font-size:13px;font-weight:500;color:#d8d8de;margin:0;">{formatDate(a.date)}</p>
                <p style="font-size:11px;color:#6e6e78;margin:2px 0 0;">
                  {a.clock_in ? new Date(a.clock_in).toLocaleTimeString('en-IN', { timeZone: 'Asia/Kolkata',hour:'2-digit',minute:'2-digit'}) : '—'} → {a.clock_out ? new Date(a.clock_out).toLocaleTimeString('en-IN', { timeZone: 'Asia/Kolkata',hour:'2-digit',minute:'2-digit'}) : '—'}
                  {a.work_hours ? ` · ${a.work_hours}h` : ''}
                </p>
              </div>
              <span style={`font-size:10px;font-weight:600;padding:2px 8px;border-radius:100px;${a.status === 'present' ? 'background:rgba(16,185,129,0.15);color:#6ee7b7;' : a.status === 'absent' ? 'background:rgba(239,68,68,0.15);color:#fca5a5;' : 'background:rgba(251,191,36,0.15);color:#fbbf24;'}`}>
                {a.status}
              </span>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- NOTES -->
    <div id="panel-5" class="hr-panel" style="display:none;">
      <form method="POST" style="display:flex;flex-direction:column;gap:12px;">
        <input type="hidden" name="action" value="add_note" />
        <div>
          <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Internal HR Notes</label>
          <p style="font-size:11px;color:#6e6e78;margin:0 0 8px;">Not visible to the employee. For HR team use only.</p>
          <textarea name="notes" rows="8" placeholder="Performance notes, onboarding observations, disciplinary records..." style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;resize:vertical;">{emp.notes || ''}</textarea>
        </div>
        <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">Save Notes</button>
      </form>
    </div>

    <!-- EXIT / OFFBOARDING -->
    <div id="panel-7" class="hr-panel" style="display:none;">
      {hasExited && (
        <div style="background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.30);border-radius:12px;padding:14px;margin-bottom:14px;">
          <p style="font-size:13px;font-weight:700;color:#fca5a5;margin:0 0 4px;">This employee has been relieved.</p>
          <p style="font-size:12px;color:#fca5a5;margin:0;line-height:1.6;">
            Exit type: <b>{emp.exit_type || '—'}</b> · Exit date: <b>{formatDate(emp.exit_date)}</b>
          </p>
          {emp.exit_reason && <p style="font-size:12px;color:#fca5a5;margin:6px 0 0;">Reason: {emp.exit_reason}</p>}
          <form method="POST" style="margin:10px 0 0;" onsubmit="return confirm('Reactivate this employee? Their login will be restored.');">
            <input type="hidden" name="action" value="reactivate" />
            <button type="submit" style="background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:12px;padding:8px 14px;border-radius:8px;cursor:pointer;">Reactivate (rehire)</button>
          </form>
        </div>
      )}

      {!hasExited && !onNotice && (
        <form method="POST" style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;display:flex;flex-direction:column;gap:12px;">
          <input type="hidden" name="action" value="initiate_exit" />
          <div>
            <p style="font-size:14px;font-weight:700;color:#fff;margin:0 0 4px;">Initiate offboarding</p>
            <p style="font-size:11.5px;color:#6e6e78;margin:0;">This moves the employee to <b>notice period</b>, after which you can run the offboarding checklist and finally relieve them.</p>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            <div>
              <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Exit type</label>
              <select name="exitType" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
                <option value="resignation">Resignation</option>
                <option value="termination">Termination (for cause)</option>
                <option value="layoff">Layoff</option>
                <option value="end_of_contract">End of contract</option>
                <option value="retirement">Retirement</option>
                <option value="absconding">Absconding</option>
                <option value="death">Death</option>
              </select>
            </div>
            <div>
              <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Notice period (days)</label>
              <input type="number" name="noticePeriodDays" min="0" value="30" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
            </div>
            <div>
              <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Last working day</label>
              <input type="date" name="lastWorkingDay" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
            </div>
            <div style="grid-column:1/-1;">
              <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Reason / notes</label>
              <textarea name="exitReason" rows="3" placeholder="Why are they leaving? (visible to HR only)" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;resize:vertical;"></textarea>
            </div>
          </div>
          <button type="submit" style="background:#fbbf24;border:none;color:#1a1a1f;font-weight:700;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">Start offboarding (notice period)</button>
        </form>
      )}

      {onNotice && (
        <div style="display:flex;flex-direction:column;gap:14px;">
          <div style="background:rgba(251,191,36,0.10);border:1px solid rgba(251,191,36,0.28);border-radius:12px;padding:14px;">
            <p style="font-size:13px;font-weight:700;color:#fbbf24;margin:0 0 4px;">On notice period</p>
            <p style="font-size:12px;color:#fcd34d;margin:0;line-height:1.7;">
              {emp.exit_type || 'Resignation'} · Notice served {formatDate(emp.notice_served_at)} · Last day {formatDate(emp.last_working_day)}
              {emp.notice_period_days ? ` · ${emp.notice_period_days} days notice` : ''}
            </p>
            {emp.exit_reason && <p style="font-size:11.5px;color:#fcd34d;margin:6px 0 0;">Reason: {emp.exit_reason}</p>}
          </div>

          <form method="POST" style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;display:flex;flex-direction:column;gap:10px;">
            <input type="hidden" name="action" value="update_exit_checklist" />
            <p style="font-size:13px;font-weight:700;color:#fff;margin:0 0 4px;">Offboarding checklist</p>
            <p style="font-size:11.5px;color:#6e6e78;margin:0 0 6px;">Tick what's done. All recommended before clicking "Mark as relieved".</p>
            {[
              { key: 'exit_interview', label: 'Exit interview conducted' },
              { key: 'knowledge_handover', label: 'Knowledge handover documented' },
              { key: 'assets_returned', label: 'Company assets (laptop, ID card, access) returned' },
              { key: 'access_revoked', label: 'System access revoked (will auto-revoke on relieve)' },
              { key: 'dues_cleared', label: 'Dues / advances cleared' },
              { key: 'final_payroll', label: 'Final settlement & payroll processed' },
              { key: 'relieving_letter_issued', label: 'Relieving letter / experience letter issued' },
            ].map((item) => (
              <label style="display:flex;align-items:center;gap:9px;font-size:12.5px;color:#d8d8de;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:9px 12px;cursor:pointer;">
                <input type="checkbox" name={item.key} checked={!!offboardState[item.key]} />
                <span>{item.label}</span>
              </label>
            ))}
            <div>
              <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:6px 0 5px;">Relieving letter URL (Drive link)</label>
              <input type="url" name="relievingLetterUrl" value={emp.relieving_letter_url || ''} placeholder="https://drive.google.com/..." style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
            </div>
            <button type="submit" style="background:#15151a;border:1px solid #FF4F00;color:#FF7040;font-weight:600;font-size:13px;padding:10px;border-radius:10px;cursor:pointer;">Save checklist</button>
          </form>

          <form method="POST" style="background:#0f0f14;border:1px solid rgba(239,68,68,0.3);border-radius:12px;padding:14px;display:flex;flex-direction:column;gap:10px;" onsubmit="return confirm('Mark this employee as relieved? This deactivates their login and revokes face access.');">
            <input type="hidden" name="action" value="mark_relieved" />
            <p style="font-size:13px;font-weight:700;color:#fca5a5;margin:0;">Final step — mark as relieved</p>
            <p style="font-size:11.5px;color:#fcd5d5;margin:0;">Deactivates the employee record and the linked user login. Face enrolment cleared. Reversible via Reactivate.</p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
              <div>
                <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Exit date</label>
                <input type="date" name="exitDate" value={emp.last_working_day ? String(emp.last_working_day).slice(0,10) : ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
              </div>
              <div>
                <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Final reason (optional)</label>
                <input type="text" name="exitReason" placeholder="Override reason" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
              </div>
            </div>
            <button type="submit" style="background:#dc2626;border:none;color:#fff;font-weight:700;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">Mark as relieved</button>
          </form>

          <form method="POST" onsubmit="return confirm('Cancel the exit and put the employee back to active status?');">
            <input type="hidden" name="action" value="cancel_exit" />
            <button type="submit" style="width:100%;background:none;border:1px dashed #1f1f26;color:#6e6e78;font-size:12px;padding:9px;border-radius:8px;cursor:pointer;">Cancel exit (back to active)</button>
          </form>
        </div>
      )}
    </div>

    <!-- REPORTS (daily work reports submitted by the employee) -->
    <div id="panel-6" class="hr-panel" style="display:none;">
      {dailyReportRows.length === 0 ? (
        <div style="text-align:center;padding:48px 16px;color:#6e6e78;"><p style="font-size:13px;">No daily reports submitted yet.</p></div>
      ) : (
        <div style="display:flex;flex-direction:column;gap:8px;">
          {dailyReportRows.map((r: any) => (
            <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px;">
              <p style="font-size:12px;font-weight:700;color:#FF7040;margin:0 0 6px;">{formatDate(r.report_date)}</p>
              <p style="font-size:12.5px;color:#d8d8de;margin:0;white-space:pre-wrap;">{r.work_done}</p>
              {r.progress && <p style="font-size:12px;color:#a0a0ab;margin:6px 0 0;white-space:pre-wrap;"><span style="color:#6e6e78;">Progress:</span> {r.progress}</p>}
              {r.blockers && <p style="font-size:12px;color:#fca5a5;margin:6px 0 0;white-space:pre-wrap;"><span style="color:#6e6e78;">Blockers:</span> {r.blockers}</p>}
            </div>
          ))}
        </div>
      )}
    </div>

  </div>
</div>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  var panels = document.querySelectorAll('.hr-panel');
  var tabs = document.querySelectorAll('.hr-tab');
  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var idx = parseInt(tab.getAttribute('data-tab'));
      panels.forEach(function(p) { p.style.display = 'none'; });
      tabs.forEach(function(t) {
        t.style.borderBottomColor = 'transparent';
        t.style.color = '#6e6e78';
      });
      document.getElementById('panel-' + idx).style.display = 'block';
      tab.style.borderBottomColor = '#FF4F00';
      tab.style.color = '#FF7040';
    });
  });
});
</script>
</AdminLayout>
