---
// /admin/hr/onboarding — HR reviews the credentials new hires submit after accepting their offer.
// Documents are Google Drive links shared in the agreed access format; nothing is stored on our
// servers, HR opens the original. Verify or send back with a reason.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { pendingForReview, docTypeLabel, ACCESS_FORMAT, MAX_DOCS } from '@/lib/hr-onboarding';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');
const docs = await pendingForReview(150).catch(() => []);
const waiting = docs.filter((d: any) => d.status === 'submitted').length;
const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const chip = (s: string) => s === 'verified' ? { bg: '#0f2a1c', fg: '#6ee7b7', label: 'Verified' }
  : s === 'rejected' ? { bg: '#2a0f0f', fg: '#fca5a5', label: 'Sent back' }
  : { bg: '#2a1f0f', fg: '#c0a35e', label: 'Awaiting review' };
---
<AdminLayout title="Joining documents" activeNav="hr">
  <div style="max-width:960px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Onboarding</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Joining documents</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:740px;line-height:1.55;">
      Credentials submitted by new hires after accepting their offer (up to {MAX_DOCS} each). Files stay in the hire's Google Drive, shared as &ldquo;{ACCESS_FORMAT}&rdquo; &mdash; open the original to check it. Nothing is copied onto our servers.
    </p>
    <div id="msg" style="display:none;margin:12px 0;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style="display:flex;gap:12px;margin:16px 0;">
      <div style={CARD + 'margin:0;flex:1;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Awaiting review</p><p style="font-size:26px;font-weight:800;color:#c0a35e;margin:4px 0 0;">{waiting}</p></div>
      <div style={CARD + 'margin:0;flex:1;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Documents total</p><p style="font-size:26px;font-weight:800;color:#fff;margin:4px 0 0;">{docs.length}</p></div>
    </div>

    {docs.length === 0 ? (
      <div style={CARD}><p style="font-size:13px;color:#8a8a94;margin:0;">No joining documents submitted yet. New hires are prompted after they accept their offer letter.</p></div>
    ) : (
      <div style="display:flex;flex-direction:column;gap:10px;">
        {docs.map((d: any) => { const c = chip(d.status); return (
          <div style={CARD + 'margin:0;'}>
            <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap;">
              <div style="min-width:0;">
                <p style="font-size:14px;font-weight:700;color:#fff;margin:0;">{d.title || docTypeLabel(d.doc_type)}</p>
                <p style="font-size:12px;color:#8a8a94;margin:3px 0 0;">
                  {docTypeLabel(d.doc_type)} &middot; {d.user_name || 'Unknown'} <span style="color:#6e6e78;">{d.user_email || ''}</span>
                </p>
              </div>
              <span style={'font-size:11px;font-weight:700;padding:4px 11px;border-radius:100px;background:' + c.bg + ';color:' + c.fg + ';'}>{c.label}</span>
            </div>
            {d.review_note && <p style="font-size:12.5px;color:#fca5a5;margin:8px 0 0;">Sent back: {d.review_note}</p>}
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-top:12px;">
              <a href={d.drive_url} target="_blank" rel="noopener noreferrer" style="background:#1c2230;color:#9bd1ff;border:1px solid #26324a;border-radius:8px;padding:7px 13px;font-size:12.5px;font-weight:600;text-decoration:none;">Open document &rarr;</a>
              {d.status !== 'verified' && <button class="act" data-id={d.id} data-status="verified" style="background:#0f2a1c;color:#6ee7b7;border:1px solid #1a3a2a;border-radius:8px;padding:7px 13px;font-size:12.5px;font-weight:600;cursor:pointer;">Verify</button>}
              {d.status !== 'rejected' && <button class="act" data-id={d.id} data-status="rejected" data-ask="1" style="background:#2a0f0f;color:#fca5a5;border:1px solid #3a1a1a;border-radius:8px;padding:7px 13px;font-size:12.5px;font-weight:600;cursor:pointer;">Send back</button>}
            </div>
          </div>
        ); })}
      </div>
    )}
  </div>

  <script is:inline>
    document.querySelectorAll('.act').forEach(function (b) {
      b.addEventListener('click', function () {
        var msg = document.getElementById('msg');
        var status = b.getAttribute('data-status');
        var note;
        if (b.getAttribute('data-ask')) {
          note = prompt('Why is this being sent back? The hire will see this.');
          if (note === null) return;
        }
        b.disabled = true;
        fetch('/api/portal/onboarding/documents', {
          method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'review', id: Number(b.getAttribute('data-id')), status: status, note: note })
        }).then(function (r) { return r.json(); }).then(function (j) {
          msg.style.display = 'block';
          if (j.ok) { msg.style.background = '#0f2a1c'; msg.style.color = '#6ee7b7'; msg.textContent = 'Saved. Reloading…'; setTimeout(function () { location.reload(); }, 700); }
          else { msg.style.background = '#2a0f0f'; msg.style.color = '#fca5a5'; msg.textContent = j.error || 'Failed'; b.disabled = false; }
        });
      });
    });
  </script>
</AdminLayout>
