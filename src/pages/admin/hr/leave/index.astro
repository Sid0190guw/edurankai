---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { listLeave, decideLeave } from '@/lib/hr-leave';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const role = (user.role || '').toLowerCase();
if (!(role === 'super_admin' || role === 'admin' || role.indexOf('hr') >= 0)) return Astro.redirect('/admin');

let flash = '';
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  if (fd.get('action') === 'decide') {
    const r = await decideLeave(fd.get('id') as string, user, (fd.get('decision') as string) === 'approved' ? 'approved' : 'rejected', (fd.get('note') as string) || '');
    flash = r.ok ? 'Decision recorded.' : 'Error: ' + r.error;
  }
  return Astro.redirect('/admin/hr/leave?msg=' + encodeURIComponent(flash));
}

const all = await listLeave({});
const pending = all.filter((l: any) => l.status === 'pending');
const recent = all.filter((l: any) => l.status !== 'pending').slice(0, 25);
const msg = new URL(Astro.request.url).searchParams.get('msg') || '';
const fmt = (d: any) => new Date(d).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
const statusColor: Record<string, string> = { approved: '#86efac', rejected: '#fca5a5', cancelled: '#8a8a94' };
---
<AdminLayout title="Leave approvals" activeNav="">
  <div class="admin-page" style="max-width:1000px;">
    <div class="admin-page-header"><div class="admin-page-title-block">
      <div class="admin-page-eyebrow">HR Management · Time off</div>
      <h1 class="admin-page-title">Leave approvals</h1>
      <p class="admin-page-sub">Approve or reject leave requests. Reporting managers, HR heads, admins and super-admins can decide.</p>
    </div></div>
    {msg && <div style="margin:0 0 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{msg}</div>}

    <h2 style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.16em;text-transform:uppercase;color:#c2410c;font-weight:700;margin:0 0 10px;">Pending · {pending.length}</h2>
    {pending.length === 0 && <p style="color:#8a8a94;font-size:13px;margin-bottom:20px;">No leave requests waiting.</p>}
    {pending.map((l: any) => (
      <div class="lrow">
        <div style="flex:1;">
          <div style="color:#fff;font-weight:700;">{l.full_name || 'Employee'} · <span style="text-transform:capitalize;">{l.leave_type}</span> · {l.days}d</div>
          <div style="color:#8a8a94;font-size:12px;">{l.employee_code} · {fmt(l.start_date)} – {fmt(l.end_date)}{l.reason ? ' · ' + l.reason : ''}</div>
        </div>
        <form method="POST" style="display:flex;gap:6px;align-items:center;">
          <input type="hidden" name="action" value="decide"/><input type="hidden" name="id" value={l.id}/>
          <input name="note" class="lfi" placeholder="note (optional)"/>
          <button name="decision" value="approved" class="lbtn" style="background:#22c07e;">Approve</button>
          <button name="decision" value="rejected" class="lbtn" style="background:transparent;border:1px solid #444;color:#fca5a5;">Reject</button>
        </form>
      </div>
    ))}

    {recent.length > 0 && (<div>
      <h2 style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8a94;font-weight:700;margin:24px 0 10px;">Recent</h2>
      {recent.map((l: any) => (
        <div class="lrow" style="opacity:.75;">
          <div style="flex:1;"><div style="color:#cfd6da;">{l.full_name} · <span style="text-transform:capitalize;">{l.leave_type}</span> · {l.days}d</div><div style="color:#8a8a94;font-size:12px;">{fmt(l.start_date)} – {fmt(l.end_date)}{l.decided_by_role ? ' · by ' + l.decided_by_role : ''}</div></div>
          <span style={`font-family:'Geist Mono',monospace;font-size:10px;font-weight:700;text-transform:uppercase;color:${statusColor[l.status]||'#8a8a94'};`}>{l.status}</span>
        </div>
      ))}
    </div>)}
  </div>
  <style>
    .lfi{ background:#08080b;border:1px solid #262630;border-radius:7px;padding:8px 10px;color:#fff;font-size:13px;outline:none;font-family:inherit;width:150px; }
    .lbtn{ border:none;border-radius:7px;padding:8px 14px;color:#fff;font-size:12px;font-weight:700;cursor:pointer;font-family:'Geist Mono',monospace;white-space:nowrap; }
    .lrow{ display:flex;align-items:center;gap:12px;background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px 14px;margin-bottom:8px;flex-wrap:wrap; }
  </style>
</AdminLayout>
