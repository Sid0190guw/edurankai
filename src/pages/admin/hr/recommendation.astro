---
import AdminLayout from '@/layouts/AdminLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const today = new Date().toISOString().split('T')[0];

const defaults = {
  letterType: 'recommendation',
  recipientName: '',
  roleTitle: '',
  department: '',
  durationFrom: '',
  durationTo: '',
  body: '',
  addressee: '',
  signatoryName: user.name || 'Siddharth Prasad',
  signatoryTitle: 'Founder & CEO',
  refNumber: 'REC-2026-' + Math.random().toString(36).substring(2, 8).toUpperCase(),
  issueDate: today,
  customNote: ''
};
---
<AdminLayout title="Recommendation Letter" description="Generate LOR / certificate of completion / to whom it may concern.">
  <div class="mb-4">
    <a href="/admin/hr" class="text-[0.78rem] text-white/50 hover:text-white">&larr; HR Hub</a>
  </div>

  <div class="mb-5 pb-4 border-b border-white/8">
    <p class="font-mono text-[0.7rem] text-burn">DOCUMENT</p>
    <h1 class="font-display text-[1.6rem] font-semibold text-white">Recommendation / Certificate Letter</h1>
    <p class="text-[0.85rem] text-white/60 mt-1">Generate three types: LOR (Letter of Recommendation), TWMIC (To Whom It May Concern), Internship Completion Certificate.</p>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-5 gap-5">

    <div class="xl:col-span-2 flex flex-col gap-4">

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Type</h2>
        <select id="f_letterType" class="rfi">
          <option value="recommendation">Letter of Recommendation (specific addressee)</option>
          <option value="twmic">To Whom It May Concern</option>
          <option value="completion">Internship Completion Certificate</option>
        </select>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Recipient</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div class="md:col-span-2"><label class="rfl">Full Name *</label><input id="f_recipientName" type="text" class="rfi" /></div>
          <div><label class="rfl">Role Title</label><input id="f_roleTitle" type="text" class="rfi" placeholder="e.g. AI Research Intern" /></div>
          <div><label class="rfl">Department</label><input id="f_department" type="text" class="rfi" /></div>
          <div><label class="rfl">Engagement From</label><input id="f_durationFrom" type="date" class="rfi" /></div>
          <div><label class="rfl">Engagement To</label><input id="f_durationTo" type="date" class="rfi" /></div>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-5" id="recoFieldsWrap">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Addressee (LOR only)</h2>
        <div><label class="rfl">Addressee (Name + Organization)</label><textarea id="f_addressee" rows="2" class="rfi resize-y" placeholder="e.g. Admissions Committee, Stanford GSB"></textarea></div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Body</h2>
        <div><label class="rfl">Recommendation / Description *</label>
          <textarea id="f_body" rows="6" class="rfi resize-y" placeholder="Describe their contributions, character, and what you'd recommend them for..."></textarea>
        </div>
        <p class="text-[0.7rem] text-white/40 mt-2">Tip: be specific. Mention 2-3 concrete projects/outcomes.</p>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Signatory</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div><label class="rfl">Name *</label><input id="f_signatoryName" type="text" class="rfi" value={defaults.signatoryName} /></div>
          <div><label class="rfl">Title</label><input id="f_signatoryTitle" type="text" class="rfi" value={defaults.signatoryTitle} /></div>
          <div><label class="rfl">Ref Number</label><input id="f_refNumber" type="text" class="rfi" value={defaults.refNumber} /></div>
          <div><label class="rfl">Issue Date</label><input id="f_issueDate" type="date" class="rfi" value={defaults.issueDate} /></div>
        </div>
      </div>

      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        <button type="button" id="downloadBtn" class="bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.95rem]">Download PDF</button>
        <button type="button" id="printBtn" class="bg-white/10 hover:bg-white/15 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.95rem]">Print</button>
      </div>
    </div>

    <!-- LETTER PREVIEW -->
    <div class="xl:col-span-3">
      <div class="sticky top-4">
        <article id="recoLetter" style="background:#fdfcf8;color:#1a1a1f;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.25);font-family:'Inter',system-ui,sans-serif;border:1px solid rgba(0,0,0,0.06);">

          <header style="background:#fafaf6;padding:30px 36px 24px;border-bottom:3px solid #FF4F00;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:18px;flex-wrap:wrap;">
              <div>
                <p style="font-family:'Fraunces',serif;font-size:28px;font-weight:600;color:#0a0a0c;line-height:1;margin:0;">Edu<em style="color:#FF4F00;font-weight:500;">Rank</em>AI</p>
                <p style="font-size:10px;font-family:'Geist Mono',monospace;letter-spacing:0.18em;color:#FF4F00;margin:6px 0 0;font-weight:700;">BHARAT-BUILT FRONTIER AI LAB</p>
                <p style="font-size:11px;color:#6b6b76;margin:12px 0 2px;line-height:1.5;">AI Research and Technology — Guwahati, Assam, India</p>
                <p style="font-size:11px;color:#6b6b76;margin:0;line-height:1.5;">hr@edurankai.in · www.edurankai.in</p>
              </div>
              <div style="text-align:right;">
                <p style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.16em;color:#9a9aa3;margin:0;">Reference</p>
                <p id="ol_ref" style="font-family:'Geist Mono',monospace;font-size:13px;color:#1a1a1f;margin:3px 0 0;font-weight:600;">—</p>
                <p id="ol_issueDate" style="font-size:11px;color:#6b6b76;margin:5px 0 0;">—</p>
              </div>
            </div>
          </header>

          <div style="padding:30px 36px;">
            <h2 id="ol_title" style="font-family:'Fraunces',serif;font-size:22px;font-weight:600;color:#0a0a0c;margin:0 0 18px;text-align:center;">Letter of Recommendation</h2>

            <div id="ol_addresseeBlock" style="margin-bottom:16px;font-size:13px;color:#3a3a40;line-height:1.6;"></div>

            <p id="ol_subject" style="font-size:13.5px;color:#0a0a0c;font-weight:600;margin:0 0 14px;border-bottom:1px solid rgba(0,0,0,0.08);padding-bottom:8px;">Subject: —</p>

            <div id="ol_body" style="font-size:13.5px;line-height:1.85;color:#3a3a40;margin-bottom:24px;"></div>

            <!-- SIGNATURE -->
            <div style="margin-top:32px;display:flex;justify-content:space-between;align-items:flex-end;gap:14px;">
              <div>
                <p style="font-size:13px;color:#3a3a40;margin:0 0 6px;">Sincerely,</p>
                <p id="ol_sigName" style="font-family:'Fraunces',serif;font-style:italic;font-size:18px;color:#0a0a0c;margin:8px 0 4px;">—</p>
                <p id="ol_sigTitle" style="font-size:12px;color:#6b6b76;margin:0;">—</p>
                <p style="font-size:12px;font-weight:600;color:#FF4F00;margin:2px 0 0;">EduRankAI</p>
              </div>
              <div style="width:60px;height:60px;border-radius:50%;border:2px solid rgba(255,79,0,0.35);background:rgba(255,79,0,0.06);display:flex;align-items:center;justify-content:center;">
                <span style="font-size:7px;font-weight:700;color:#FF4F00;text-align:center;line-height:1.15;">EDU<br/>RANK<br/>AI</span>
              </div>
            </div>

            <div style="margin-top:24px;padding-top:14px;border-top:1px solid rgba(0,0,0,0.08);font-size:9.5px;color:#9a9aa3;font-family:'Geist Mono',monospace;text-align:center;">
              EDURANKAI.IN · BHARAT
            </div>
          </div>
        </article>
        <p class="text-[0.7rem] text-white/40 mt-3 text-center">Live preview · updates as you type</p>
      </div>
    </div>

  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>

  <script is:inline>
    (function() {
      function $(id) { return document.getElementById(id); }
      function val(id) { var el = $(id); return el ? (el.value || '') : ''; }
      function fmtDate(d) {
        if (!d) return '—';
        var dt = new Date(d);
        if (isNaN(dt.getTime())) return d;
        return dt.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
      }
      function escapeHtml(s) {
        return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      }

      function refresh() {
        var type = val('f_letterType') || 'recommendation';
        var name = val('f_recipientName') || '—';
        var roleTitle = val('f_roleTitle') || '—';
        var dept = val('f_department');
        var from = fmtDate(val('f_durationFrom'));
        var to = fmtDate(val('f_durationTo'));
        var body = val('f_body') || '';
        var addressee = val('f_addressee');

        // Title
        var titles = {
          recommendation: 'Letter of Recommendation',
          twmic: 'To Whom It May Concern',
          completion: 'Certificate of Completion'
        };
        $('ol_title').textContent = titles[type] || titles.recommendation;

        // Addressee block (only for LOR)
        $('recoFieldsWrap').style.display = (type === 'recommendation') ? '' : 'none';
        if (type === 'recommendation' && addressee) {
          $('ol_addresseeBlock').innerHTML = '<p style="white-space:pre-line;">' + escapeHtml(addressee) + '</p>';
        } else if (type === 'twmic') {
          $('ol_addresseeBlock').innerHTML = '<p style="font-weight:600;">To Whom It May Concern,</p>';
        } else {
          $('ol_addresseeBlock').innerHTML = '';
        }

        // Subject line
        var deptText = dept ? (', ' + dept) : '';
        var subjLine = '';
        if (type === 'recommendation') {
          subjLine = 'Subject: Recommendation for ' + name + ' — ' + roleTitle + deptText;
        } else if (type === 'twmic') {
          subjLine = 'Subject: Engagement Confirmation — ' + name;
        } else {
          subjLine = 'Subject: Certificate of Completion — ' + name;
        }
        $('ol_subject').textContent = subjLine;

        // Body
        var bodyHtml = '';
        if (type === 'completion') {
          bodyHtml = '<p>This is to certify that <b>' + escapeHtml(name) + '</b> has successfully completed an engagement as <b>' + escapeHtml(roleTitle) + '</b>' + (dept ? ' in the <b>' + escapeHtml(dept) + '</b> team' : '') + ' at <b>EduRankAI</b>.</p>';
          if (from !== '—' && to !== '—') {
            bodyHtml += '<p>The engagement ran from <b>' + from + '</b> to <b>' + to + '</b>.</p>';
          }
          if (body.trim()) {
            bodyHtml += '<p>' + escapeHtml(body).replace(/\n/g,'<br/>') + '</p>';
          } else {
            bodyHtml += '<p>During this period, ' + escapeHtml(name) + ' demonstrated commitment, capability, and character consistent with the standards EduRankAI seeks. We wish them well in future endeavors.</p>';
          }
          bodyHtml += '<p>This certificate is issued at the request of the bearer for whatever purpose it may serve.</p>';
        } else if (type === 'twmic') {
          bodyHtml = '<p>This letter confirms that <b>' + escapeHtml(name) + '</b> has been engaged with <b>EduRankAI</b> as <b>' + escapeHtml(roleTitle) + '</b>' + (dept ? ' (' + escapeHtml(dept) + ')' : '') + '.</p>';
          if (from !== '—' && to !== '—') {
            bodyHtml += '<p>Their engagement period: <b>' + from + '</b> through <b>' + to + '</b>.</p>';
          }
          if (body.trim()) {
            bodyHtml += '<p>' + escapeHtml(body).replace(/\n/g,'<br/>') + '</p>';
          }
          bodyHtml += '<p>This letter is issued at the request of the bearer for verification purposes.</p>';
        } else {
          // Recommendation
          if (addressee) {
            bodyHtml = '';
          }
          var intro = 'It is my pleasure to recommend <b>' + escapeHtml(name) + '</b>, who served as <b>' + escapeHtml(roleTitle) + '</b>' + (dept ? ' in our <b>' + escapeHtml(dept) + '</b> team' : '') + ' at EduRankAI';
          if (from !== '—' && to !== '—') {
            intro += ' from <b>' + from + '</b> to <b>' + to + '</b>';
          }
          intro += '.';
          bodyHtml += '<p>' + intro + '</p>';

          if (body.trim()) {
            bodyHtml += '<p>' + escapeHtml(body).replace(/\n/g,'<br/>') + '</p>';
          } else {
            bodyHtml += '<p><i>[Add specific examples of contributions, character, and outcomes in the Body field on the left.]</i></p>';
          }
          bodyHtml += '<p>I recommend them without reservation. They would be a strong addition to any team that values rigour and integrity.</p>';
        }

        $('ol_body').innerHTML = bodyHtml;

        $('ol_ref').textContent = val('f_refNumber') || '—';
        $('ol_issueDate').textContent = fmtDate(val('f_issueDate'));
        $('ol_sigName').textContent = val('f_signatoryName') || '—';
        $('ol_sigTitle').textContent = val('f_signatoryTitle') || '—';
      }

      var inputs = document.querySelectorAll('.rfi');
      for (var i = 0; i < inputs.length; i++) {
        inputs[i].addEventListener('input', refresh);
        inputs[i].addEventListener('change', refresh);
      }
      refresh();

      $('downloadBtn').addEventListener('click', function() {
        refresh();
        var btn = $('downloadBtn');
        btn.disabled = true;
        btn.textContent = 'Generating PDF...';
        var target = $('recoLetter');
        if (typeof html2canvas === 'undefined' || typeof window.jspdf === 'undefined') {
          alert('PDF library still loading.');
          btn.disabled = false;
          btn.textContent = 'Download PDF';
          return;
        }
        html2canvas(target, { scale: 2, backgroundColor: '#fdfcf8' }).then(function(canvas) {
          var imgData = canvas.toDataURL('image/jpeg', 0.95);
          var pdf = new window.jspdf.jsPDF('p', 'mm', 'a4');
          var pdfW = 210, pdfH = 297;
          var imgH = (canvas.height * pdfW) / canvas.width;
          var heightLeft = imgH;
          var pos = 0;
          pdf.addImage(imgData, 'JPEG', 0, pos, pdfW, imgH);
          heightLeft -= pdfH;
          while (heightLeft > 0) {
            pos = heightLeft - imgH;
            pdf.addPage();
            pdf.addImage(imgData, 'JPEG', 0, pos, pdfW, imgH);
            heightLeft -= pdfH;
          }
          var nm = (val('f_recipientName') || 'Letter').replace(/[^a-zA-Z0-9-_]/g, '_');
          var typeMap = { recommendation: 'LOR', twmic: 'TWMIC', completion: 'Certificate' };
          pdf.save('EduRankAI-' + (typeMap[val('f_letterType')] || 'Letter') + '-' + nm + '.pdf');
          btn.disabled = false;
          btn.textContent = 'Download PDF';
        }).catch(function(err) {
          alert('PDF failed: ' + err.message);
          btn.disabled = false;
          btn.textContent = 'Download PDF';
        });
      });

      $('printBtn').addEventListener('click', function() {
        refresh();
        setTimeout(function() { window.print(); }, 200);
      });
    })();
  </script>

  <style>
    .rfl { display:block;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.55);margin-bottom:6px; }
    .rfi { width:100%;padding:9px 12px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:8px;color:#fff;font-size:13px;font-family:inherit;outline:none; }
    .rfi:focus { border-color:#FF4F00; }
    textarea.rfi { resize:vertical; }
    .rfi option { background:#0a0a0c; }
    @media print {
      body * { visibility: hidden; }
      #recoLetter, #recoLetter * { visibility: visible; }
      #recoLetter { position: absolute; left: 0; top: 0; width: 100%; box-shadow:none !important; border-radius:0 !important; }
    }
  </style>
</AdminLayout>