---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { ensureRequisitionSchema, createRequisition, decideRequisition, listRequisitions, ENGAGEMENT_TYPES } from '@/lib/hr-requisition';
import { CLASSIFICATIONS, COUNTRY_CODES } from '@/lib/hr-classification';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

await ensureRequisitionSchema();
let okMsg = '', errMsg = '';

if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const action = (fd.get('action') as string) || 'create';
    if (action === 'decide') {
      await decideRequisition({
        id: fd.get('id') as string,
        level: fd.get('level') as any,
        userId: user.id,
        approve: fd.get('approve') === '1',
        notes: (fd.get('notes') as string) || undefined,
        rejectReason: (fd.get('reject_reason') as string) || undefined,
      });
      okMsg = 'Decision recorded.';
    } else {
      const r = await createRequisition({
        requesterUserId: user.id,
        requesterName: user.name || user.email,
        roleTitle: ((fd.get('role_title') as string) || '').trim().slice(0, 200),
        department: (fd.get('department') as string) || undefined,
        level: (fd.get('level') as string) || undefined,
        engagementType: (fd.get('engagement_type') as string) || 'permanent',
        country: (fd.get('country') as string) || undefined,
        workMode: (fd.get('work_mode') as string) || 'remote',
        headcount: parseInt(fd.get('headcount') as string, 10) || 1,
        justification: (fd.get('justification') as string || '').slice(0, 4000),
        budgetMin: parseFloat(fd.get('budget_min') as string) || undefined,
        budgetMax: parseFloat(fd.get('budget_max') as string) || undefined,
        budgetCurrency: (fd.get('budget_currency') as string) || 'CHF',
        targetJoinBy: (fd.get('target_join_by') as string) || undefined,
        kras: (fd.get('kras') as string || '').slice(0, 4000),
        skillsRequired: (fd.get('skills_required') as string || '').slice(0, 4000),
      });
      okMsg = 'Requisition #' + (r.id || '').slice(0, 8) + ' raised. Routed to Finance for approval.';
    }
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 240); }
}

const url = new URL(Astro.request.url);
const filterStatus = url.searchParams.get('status') || '';
const list = await listRequisitions(filterStatus || undefined);

function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day:'2-digit', month:'short', year:'numeric' }); } catch { return ''; } }

const STATUS_TONE: Record<string, string> = {
  pending_finance: '#fbbf24',
  pending_leadership: '#67e8f9',
  approved: '#86efac',
  rejected: '#fca5a5',
  withdrawn: '#9aa6b6',
};
---
<AdminLayout title="Hiring Requisitions" activeNav="">
<div style="padding:14px 16px 80px;max-width:1280px;margin:0 auto;">
  <p style="font-size:10.5px;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;font-family:'Geist Mono',monospace;font-weight:700;">HR · Workforce planning</p>
  <h1 style="font-size:24px;color:#fff;margin:6px 0 4px;font-weight:700;">Hiring Requisitions</h1>
  <p style="font-size:13px;color:#9aa6b6;margin:0 0 18px;">Per Lifecycle Manual §B.3 — managers raise here, Finance reviews budget, Leadership approves. Only approved requisitions become open roles.</p>

  {okMsg && <div style="background:rgba(74,222,128,0.10);border:1px solid rgba(74,222,128,0.32);color:#86efac;border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;">{okMsg}</div>}
  {errMsg && <div style="background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.32);color:#fca5a5;border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;">{errMsg}</div>}

  <details style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:0;margin-bottom:18px;">
    <summary style="cursor:pointer;padding:14px 18px;font-size:13px;color:#FF7040;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;font-family:'Geist Mono',monospace;list-style:none;">+ Raise new requisition</summary>
    <form method="POST" style="padding:0 18px 18px;display:grid;gap:10px;">
      <input type="hidden" name="action" value="create" />
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div><label style="font-size:10.5px;color:#9aa6b6;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;">Role title *</label><input name="role_title" required maxlength="200" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;margin-top:5px;" /></div>
        <div><label style="font-size:10.5px;color:#9aa6b6;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;">Department</label><input name="department" maxlength="120" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;margin-top:5px;" /></div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;">
        <div><label style="font-size:10.5px;color:#9aa6b6;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;">Engagement *</label>
          <select name="engagement_type" required style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;margin-top:5px;">
            {Object.entries(ENGAGEMENT_TYPES).map(([k, v]) => <option value={k}>{v.label}</option>)}
          </select>
        </div>
        <div><label style="font-size:10.5px;color:#9aa6b6;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;">Level</label><input name="level" placeholder="Intern / Associate / Senior / Staff / Principal" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;margin-top:5px;" /></div>
        <div><label style="font-size:10.5px;color:#9aa6b6;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;">Headcount</label><input name="headcount" type="number" value="1" min="1" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;margin-top:5px;" /></div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;">
        <div><label style="font-size:10.5px;color:#9aa6b6;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;">Country</label>
          <select name="country" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;margin-top:5px;">
            {COUNTRY_CODES.map((c) => <option value={c.code}>{c.name}</option>)}
          </select>
        </div>
        <div><label style="font-size:10.5px;color:#9aa6b6;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;">Work mode</label>
          <select name="work_mode" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;margin-top:5px;"><option>remote</option><option>hybrid</option><option>office</option></select>
        </div>
        <div><label style="font-size:10.5px;color:#9aa6b6;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;">Target join</label><input name="target_join_by" type="date" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;margin-top:5px;" /></div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 100px;gap:10px;">
        <div><label style="font-size:10.5px;color:#9aa6b6;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;">Budget min</label><input name="budget_min" type="number" step="0.01" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;margin-top:5px;" /></div>
        <div><label style="font-size:10.5px;color:#9aa6b6;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;">Budget max</label><input name="budget_max" type="number" step="0.01" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;margin-top:5px;" /></div>
        <div><label style="font-size:10.5px;color:#9aa6b6;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;">Currency</label><select name="budget_currency" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;margin-top:5px;"><option>CHF</option><option>INR</option><option>USD</option><option>EUR</option></select></div>
      </div>
      <div><label style="font-size:10.5px;color:#9aa6b6;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;">Business justification *</label><textarea name="justification" rows="2" required style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;margin-top:5px;font-family:'Inter Tight',sans-serif;resize:vertical;"></textarea></div>
      <div><label style="font-size:10.5px;color:#9aa6b6;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;">KRAs / success metrics</label><textarea name="kras" rows="3" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;margin-top:5px;font-family:'Inter Tight',sans-serif;resize:vertical;"></textarea></div>
      <div><label style="font-size:10.5px;color:#9aa6b6;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;">Skills required</label><textarea name="skills_required" rows="2" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;margin-top:5px;font-family:'Inter Tight',sans-serif;resize:vertical;"></textarea></div>
      <button type="submit" style="background:#FF4F00;color:#fff;border:none;padding:10px 22px;border-radius:8px;font-size:12.5px;font-weight:800;cursor:pointer;letter-spacing:0.04em;text-transform:uppercase;font-family:'Geist Mono',monospace;justify-self:start;">Raise requisition</button>
    </form>
  </details>

  <form method="GET" style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;">
    <select name="status" style="background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12.5px;">
      <option value="">All statuses</option>
      <option value="pending_finance" selected={filterStatus === 'pending_finance'}>Pending Finance</option>
      <option value="pending_leadership" selected={filterStatus === 'pending_leadership'}>Pending Leadership</option>
      <option value="approved" selected={filterStatus === 'approved'}>Approved</option>
      <option value="rejected" selected={filterStatus === 'rejected'}>Rejected</option>
    </select>
    <button type="submit" style="background:#15151a;border:1px solid #2a2a2f;color:#FF7040;padding:9px 16px;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer;">Filter</button>
  </form>

  {list.length === 0 ? (
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:36px;text-align:center;color:#6e6e78;font-size:13px;">No requisitions match.</div>
  ) : (
    <div style="display:flex;flex-direction:column;gap:8px;">
      {list.map((r: any) => {
        const stCol = STATUS_TONE[r.status] || '#9aa6b6';
        return (
          <details style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:0;">
            <summary style="cursor:pointer;padding:14px 18px;list-style:none;display:grid;grid-template-columns:1.4fr 1.2fr 1fr 110px 90px 110px;gap:12px;align-items:center;">
              <div><p style="font-size:13.5px;font-weight:700;color:#fff;margin:0;">{r.role_title}</p><p style="font-size:10.5px;color:#9aa6b6;margin:2px 0 0;font-family:'Geist Mono',monospace;">by {r.requester_name}</p></div>
              <p style="font-size:11.5px;color:#cfd6da;margin:0;">{r.department || '—'} · {r.level || '—'}</p>
              <p style="font-size:11.5px;color:#67e8f9;margin:0;font-family:'Geist Mono',monospace;">{r.engagement_type} · {r.country || '—'}</p>
              <p style="font-size:11px;color:#FF7040;margin:0;font-family:'Geist Mono',monospace;font-weight:700;">{r.budget_currency} {r.budget_band_min || '?'}–{r.budget_band_max || '?'}</p>
              <p style="font-size:11px;color:#9aa6b6;margin:0;font-family:'Geist Mono',monospace;">×{r.headcount}</p>
              <span style={`background:${stCol}22;color:${stCol};font-size:10px;font-weight:700;padding:3px 8px;border-radius:100px;text-align:center;font-family:'Geist Mono',monospace;letter-spacing:0.06em;text-transform:uppercase;`}>{r.status.replace(/_/g,' ')}</span>
            </summary>
            <div style="padding:0 18px 18px;border-top:1px solid #1a1a1f;">
              <div style="margin:14px 0;"><p style="font-size:10.5px;color:#FF7040;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;font-weight:700;margin:0 0 6px;">Justification</p><p style="font-size:12.5px;color:#d8d8de;margin:0;line-height:1.65;white-space:pre-wrap;">{r.justification}</p></div>
              {r.kras && <div style="margin:14px 0;"><p style="font-size:10.5px;color:#FF7040;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;font-weight:700;margin:0 0 6px;">KRAs</p><p style="font-size:12.5px;color:#d8d8de;margin:0;line-height:1.65;white-space:pre-wrap;">{r.kras}</p></div>}
              {r.skills_required && <div style="margin:14px 0;"><p style="font-size:10.5px;color:#FF7040;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;font-weight:700;margin:0 0 6px;">Skills</p><p style="font-size:12.5px;color:#d8d8de;margin:0;line-height:1.65;white-space:pre-wrap;">{r.skills_required}</p></div>}
              {r.finance_notes && <div style="margin:10px 0;padding:10px 14px;background:rgba(251,191,36,0.06);border-left:3px solid #fbbf24;border-radius:0 6px 6px 0;"><p style="font-size:10.5px;color:#fbbf24;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;font-weight:700;margin:0 0 4px;">Finance · {fmt(r.finance_approved_at)}</p><p style="font-size:12px;color:#d8d8de;margin:0;line-height:1.6;">{r.finance_notes}</p></div>}
              {r.leadership_notes && <div style="margin:10px 0;padding:10px 14px;background:rgba(134,239,172,0.06);border-left:3px solid #86efac;border-radius:0 6px 6px 0;"><p style="font-size:10.5px;color:#86efac;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;font-weight:700;margin:0 0 4px;">Leadership · {fmt(r.leadership_approved_at)}</p><p style="font-size:12px;color:#d8d8de;margin:0;line-height:1.6;">{r.leadership_notes}</p></div>}
              {r.rejection_reason && <div style="margin:10px 0;padding:10px 14px;background:rgba(252,165,165,0.06);border-left:3px solid #fca5a5;border-radius:0 6px 6px 0;"><p style="font-size:10.5px;color:#fca5a5;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;font-weight:700;margin:0 0 4px;">Rejected · {fmt(r.rejected_at)}</p><p style="font-size:12px;color:#d8d8de;margin:0;line-height:1.6;">{r.rejection_reason}</p></div>}

              {(r.status === 'pending_finance' || r.status === 'pending_leadership') && (
                <form method="POST" style="margin-top:14px;padding-top:14px;border-top:1px solid #1a1a1f;">
                  <input type="hidden" name="action" value="decide" />
                  <input type="hidden" name="id" value={r.id} />
                  <input type="hidden" name="level" value={r.status === 'pending_finance' ? 'finance' : 'leadership'} />
                  <p style="font-size:10.5px;color:#FF7040;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;font-weight:700;margin:0 0 6px;">{r.status === 'pending_finance' ? 'Finance' : 'Leadership'} decision</p>
                  <textarea name="notes" rows="2" placeholder="Decision notes" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12px;font-family:'Inter Tight',sans-serif;resize:vertical;"></textarea>
                  <div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap;">
                    <button type="submit" name="approve" value="1" style="background:#86efac18;border:1px solid #86efac;color:#86efac;padding:7px 14px;border-radius:5px;font-size:11px;font-weight:700;cursor:pointer;font-family:'Geist Mono',monospace;">Approve</button>
                    <button type="submit" name="approve" value="0" style="background:#fca5a518;border:1px solid #fca5a5;color:#fca5a5;padding:7px 14px;border-radius:5px;font-size:11px;font-weight:700;cursor:pointer;font-family:'Geist Mono',monospace;">Reject</button>
                  </div>
                </form>
              )}
            </div>
          </details>
        );
      })}
    </div>
  )}
</div>
</AdminLayout>
