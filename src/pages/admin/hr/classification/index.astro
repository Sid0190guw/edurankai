---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { ensureClassificationSchema, CLASSIFICATIONS, ENGAGEMENT_VIAS, COUNTRY_CODES } from '@/lib/hr-classification';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

await ensureClassificationSchema();
function rowsOf(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const id = fd.get('id') as string;
    const classification = fd.get('classification') as string;
    const country = fd.get('country') as string;
    const via = fd.get('engaged_via') as string;
    await db.execute(sql`UPDATE hr_employees SET classification = ${classification}, country_of_work = ${country}, engaged_via = ${via}, classification_reviewed_at = NOW(), classification_reviewed_by = ${user.id}, updated_at = NOW() WHERE id = ${id}`);
    okMsg = 'Classification updated.';
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 240); }
}

const employees = rowsOf(await db.execute(sql`
  SELECT id, full_name, email, classification, country_of_work, engaged_via, classification_reviewed_at, is_active
  FROM hr_employees WHERE is_active = true ORDER BY full_name LIMIT 300
`));

// Counts per classification + per country
const byClass: Record<string, number> = {};
const byCountry: Record<string, number> = {};
employees.forEach((e: any) => {
  byClass[e.classification || 'permanent'] = (byClass[e.classification || 'permanent'] || 0) + 1;
  byCountry[e.country_of_work || 'IN'] = (byCountry[e.country_of_work || 'IN'] || 0) + 1;
});

function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }); } catch { return ''; } }
---
<AdminLayout title="Worker Classification Register" activeNav="">
<div style="padding:14px 16px 80px;max-width:1280px;margin:0 auto;">
  <p style="font-size:10.5px;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;font-family:'Geist Mono',monospace;font-weight:700;">HR · Compliance · §2.1</p>
  <h1 style="font-size:24px;color:#fff;margin:6px 0 4px;font-weight:700;">Worker Classification Register</h1>
  <p style="font-size:13px;color:#9aa6b6;margin:0 0 18px;">Every person engaged must be classified correctly. Misclassification (e.g. calling an employee a contractor) is the single biggest compliance risk. Review at least once a year.</p>

  {okMsg && <div style="background:rgba(74,222,128,0.10);border:1px solid rgba(74,222,128,0.32);color:#86efac;border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;">{okMsg}</div>}
  {errMsg && <div style="background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.32);color:#fca5a5;border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;">{errMsg}</div>}

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px;">
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:16px;">
      <p style="font-size:10.5px;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 10px;font-family:'Geist Mono',monospace;font-weight:700;">By classification</p>
      {Object.entries(byClass).map(([k, n]) => {
        const meta = (CLASSIFICATIONS as any)[k] || { label: k, risk: 'low' };
        const riskCol = meta.risk === 'high' ? '#fca5a5' : meta.risk === 'medium' ? '#fbbf24' : '#86efac';
        return (
          <div style="display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid #1a1a1f;">
            <span style="font-size:12.5px;color:#fff;font-weight:600;">{meta.label} <span style={`color:${riskCol};font-size:9.5px;font-family:'Geist Mono',monospace;letter-spacing:0.08em;text-transform:uppercase;`}>· {meta.risk} risk</span></span>
            <span style="font-size:14px;color:#FF7040;font-weight:700;font-family:'Geist Mono',monospace;">{n}</span>
          </div>
        );
      })}
    </div>
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:16px;">
      <p style="font-size:10.5px;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 10px;font-family:'Geist Mono',monospace;font-weight:700;">By country</p>
      {Object.entries(byCountry).map(([k, n]) => {
        const c = COUNTRY_CODES.find(x => x.code === k);
        return (
          <div style="display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid #1a1a1f;">
            <span style="font-size:12.5px;color:#fff;font-weight:600;">{c ? c.name : k}</span>
            <span style="font-size:14px;color:#67e8f9;font-weight:700;font-family:'Geist Mono',monospace;">{n}</span>
          </div>
        );
      })}
    </div>
  </div>

  <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;overflow:hidden;">
    <div style="background:#15151a;border-bottom:1px solid #1a1a1f;padding:10px 14px;display:grid;grid-template-columns:1.4fr 1.2fr 1.1fr 1fr 110px 80px;gap:10px;font-size:10px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.08em;font-weight:700;">
      <div>Person</div><div>Classification</div><div>Country</div><div>Engaged via</div><div>Last review</div><div></div>
    </div>
    {employees.map((e: any) => {
      const meta = (CLASSIFICATIONS as any)[e.classification || 'permanent'] || CLASSIFICATIONS.permanent;
      const riskCol = meta.risk === 'high' ? '#fca5a5' : meta.risk === 'medium' ? '#fbbf24' : '#86efac';
      return (
        <form method="POST" style="display:grid;grid-template-columns:1.4fr 1.2fr 1.1fr 1fr 110px 80px;gap:10px;padding:9px 14px;border-bottom:1px solid #15151a;align-items:center;">
          <input type="hidden" name="id" value={e.id} />
          <div><p style="font-size:12.5px;color:#fff;font-weight:600;margin:0;">{e.full_name}</p><p style="font-size:10px;color:#8a8a94;margin:1px 0 0;font-family:'Geist Mono',monospace;">{e.email}</p></div>
          <select name="classification" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:6px 8px;border-radius:5px;font-size:11.5px;">{Object.entries(CLASSIFICATIONS).map(([k, v]) => <option value={k} selected={k === e.classification}>{v.label}</option>)}</select>
          <select name="country" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:6px 8px;border-radius:5px;font-size:11.5px;">{COUNTRY_CODES.map((c) => <option value={c.code} selected={c.code === e.country_of_work}>{c.name}</option>)}</select>
          <select name="engaged_via" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:6px 8px;border-radius:5px;font-size:11.5px;"><option value="">—</option>{Object.entries(ENGAGEMENT_VIAS).map(([k, v]) => <option value={k} selected={k === e.engaged_via}>{v.label}</option>)}</select>
          <span style="font-size:10.5px;color:#9aa6b6;font-family:'Geist Mono',monospace;">{e.classification_reviewed_at ? fmt(e.classification_reviewed_at) : 'never'}</span>
          <button type="submit" style="background:#1045BB;color:#fff;border:none;padding:6px 10px;border-radius:5px;font-size:10.5px;font-weight:700;cursor:pointer;font-family:'Geist Mono',monospace;">Save</button>
        </form>
      );
    })}
  </div>
</div>
</AdminLayout>
