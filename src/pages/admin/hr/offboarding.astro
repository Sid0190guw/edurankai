---
import AdminLayout from '@/layouts/AdminLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const today = new Date().toISOString().split('T')[0];

const defaults = {
  docType: 'relieving',
  employeeName: '',
  employeeId: '',
  roleTitle: '',
  department: '',
  joinDate: '',
  lastWorkingDate: '',
  resignationDate: '',
  reasonNotice: '',
  body: '',
  noObjectionItems: '',
  signatoryName: user.name || 'Siddharth Prasad',
  signatoryTitle: 'Founder & CEO',
  refNumber: 'OFF-2026-' + Math.random().toString(36).substring(2, 8).toUpperCase(),
  issueDate: today
};
---
<AdminLayout title="Offboarding Documents" description="Generate relieving / experience / NOC letters for outgoing employees.">
  <div class="mb-4">
    <a href="/admin/hr" class="text-[0.78rem] text-white/50 hover:text-white">&larr; HR Hub</a>
  </div>

  <div class="mb-5 pb-4 border-b border-white/8">
    <p class="font-mono text-[0.7rem] text-burn">DOCUMENT</p>
    <h1 class="font-display text-[1.6rem] font-semibold text-white">Offboarding Documents</h1>
    <p class="text-[0.85rem] text-white/60 mt-1">Three letter types: Relieving Letter · Experience Letter · No-Objection Certificate (NOC).</p>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-5 gap-5">

    <div class="xl:col-span-2 flex flex-col gap-4">

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Document Type</h2>
        <select id="f_docType" class="rfi">
          <option value="relieving">Relieving Letter</option>
          <option value="experience">Experience Letter</option>
          <option value="noc">No-Objection Certificate (NOC)</option>
        </select>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Employee</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div class="md:col-span-2"><label class="rfl">Full Name *</label><input id="f_employeeName" type="text" class="rfi" /></div>
          <div><label class="rfl">Employee ID</label><input id="f_employeeId" type="text" class="rfi" placeholder="ERA-EMP-..." /></div>
          <div><label class="rfl">Role / Designation *</label><input id="f_roleTitle" type="text" class="rfi" /></div>
          <div><label class="rfl">Department</label><input id="f_department" type="text" class="rfi" /></div>
          <div><label class="rfl">Date of Joining</label><input id="f_joinDate" type="date" class="rfi" /></div>
          <div><label class="rfl">Last Working Date</label><input id="f_lastWorkingDate" type="date" class="rfi" /></div>
          <div class="md:col-span-2" id="resignDateWrap"><label class="rfl">Resignation Date</label><input id="f_resignationDate" type="date" class="rfi" /></div>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-5" id="noticeWrap">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Notice &amp; Reason</h2>
        <div><label class="rfl">Notice period served / reason note (optional)</label><textarea id="f_reasonNotice" rows="2" class="rfi resize-y" placeholder="e.g. Served full 30-day notice. Reason: higher studies."></textarea></div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-5" id="nocWrap" style="display:none;">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">NOC Items</h2>
        <div><label class="rfl">No-objection items (one per line)</label>
          <textarea id="f_noObjectionItems" rows="4" class="rfi resize-y" placeholder="Pursuing higher education&#10;Joining another employer&#10;Travel abroad"></textarea>
        </div>
        <p class="text-[0.7rem] text-white/40 mt-2">The certificate will list these items.</p>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Body (optional)</h2>
        <div><label class="rfl">Additional context</label><textarea id="f_body" rows="3" class="rfi resize-y" placeholder="Optional remarks about contributions, conduct, dues cleared, etc."></textarea></div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Signatory</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div><label class="rfl">Name *</label><input id="f_signatoryName" type="text" class="rfi" value={defaults.signatoryName} /></div>
          <div><label class="rfl">Title</label><input id="f_signatoryTitle" type="text" class="rfi" value={defaults.signatoryTitle} /></div>
          <div><label class="rfl">Ref Number</label><input id="f_refNumber" type="text" class="rfi" value={defaults.refNumber} /></div>
          <div><label class="rfl">Issue Date</label><input id="f_issueDate" type="date" class="rfi" value={defaults.issueDate} /></div>
        </div>
      </div>

      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        <button type="button" id="downloadBtn" class="bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.95rem]">Download PDF</button>
        <button type="button" id="printBtn" class="bg-white/10 hover:bg-white/15 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.95rem]">Print</button>
      </div>
    </div>

    <div class="xl:col-span-3">
      <div class="sticky top-4">
        <article id="offDoc" style="background:#fdfcf8;color:#1a1a1f;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.25);font-family:'Inter',system-ui,sans-serif;border:1px solid rgba(0,0,0,0.06);">

          <header style="background:#fafaf6;padding:30px 36px 24px;border-bottom:3px solid #FF4F00;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:18px;flex-wrap:wrap;">
              <div>
                <p style="font-family:'Fraunces',serif;font-size:28px;font-weight:600;color:#0a0a0c;line-height:1;margin:0;">Edu<em style="color:#FF4F00;font-weight:500;">Rank</em>AI</p>
                <p style="font-size:10px;font-family:'Geist Mono',monospace;letter-spacing:0.18em;color:#FF4F00;margin:6px 0 0;font-weight:700;">BHARAT-BUILT FRONTIER AI LAB</p>
                <p style="font-size:11px;color:#6b6b76;margin:12px 0 2px;line-height:1.5;">AI Research and Technology &mdash; Guwahati, Assam, India</p>
                <p style="font-size:11px;color:#6b6b76;margin:0;line-height:1.5;">hr@edurankai.in &middot; www.edurankai.in</p>
              </div>
              <div style="text-align:right;">
                <p style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.16em;color:#9a9aa3;margin:0;">Reference</p>
                <p id="d_ref" style="font-family:'Geist Mono',monospace;font-size:13px;color:#1a1a1f;margin:3px 0 0;font-weight:600;">&mdash;</p>
                <p id="d_issueDate" style="font-size:11px;color:#6b6b76;margin:5px 0 0;">&mdash;</p>
              </div>
            </div>
          </header>

          <div style="padding:30px 36px;">
            <h2 id="d_title" style="font-family:'Fraunces',serif;font-size:22px;font-weight:600;color:#0a0a0c;margin:0 0 18px;text-align:center;">Relieving Letter</h2>

            <p style="font-weight:600;color:#0a0a0c;margin:0 0 14px;">To Whom It May Concern,</p>

            <div id="d_body" style="font-size:13.5px;line-height:1.85;color:#3a3a40;margin-bottom:24px;"></div>

            <div id="d_summary" style="border-top:1px solid rgba(0,0,0,0.08);padding-top:14px;margin-bottom:24px;">
              <p style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:#6b6b76;margin:0 0 8px;">Employee Details</p>
              <table style="width:100%;font-size:12.5px;border-collapse:collapse;"><tbody id="d_summaryBody"></tbody></table>
            </div>

            <div style="margin-top:32px;display:flex;justify-content:space-between;align-items:flex-end;gap:14px;">
              <div>
                <p style="font-size:13px;color:#3a3a40;margin:0 0 6px;">For EduRankAI,</p>
                <p id="d_sigName" style="font-family:'Fraunces',serif;font-style:italic;font-size:18px;color:#0a0a0c;margin:8px 0 4px;">&mdash;</p>
                <p id="d_sigTitle" style="font-size:12px;color:#6b6b76;margin:0;">&mdash;</p>
                <p style="font-size:12px;font-weight:600;color:#FF4F00;margin:2px 0 0;">EduRankAI</p>
              </div>
              <div style="width:60px;height:60px;border-radius:50%;border:2px solid rgba(255,79,0,0.35);background:rgba(255,79,0,0.06);display:flex;align-items:center;justify-content:center;">
                <span style="font-size:7px;font-weight:700;color:#FF4F00;text-align:center;line-height:1.15;">EDU<br/>RANK<br/>AI</span>
              </div>
            </div>

            <div style="margin-top:24px;padding-top:14px;border-top:1px solid rgba(0,0,0,0.08);font-size:9.5px;color:#9a9aa3;font-family:'Geist Mono',monospace;text-align:center;">
              EDURANKAI.IN &middot; BHARAT
            </div>
          </div>
        </article>
        <p class="text-[0.7rem] text-white/40 mt-3 text-center">Live preview &middot; updates as you type</p>
      </div>
    </div>

  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>

  <script is:inline>
    (function() {
      function $(id) { return document.getElementById(id); }
      function val(id) { var el = $(id); return el ? (el.value || '') : ''; }
      function fmtDate(d) {
        if (!d) return '-';
        var dt = new Date(d);
        if (isNaN(dt.getTime())) return d;
        return dt.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
      }
      function escapeHtml(s) { return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

      function refresh() {
        var type = val('f_docType') || 'relieving';
        var name = val('f_employeeName') || '-';
        var empId = val('f_employeeId');
        var role = val('f_roleTitle') || '-';
        var dept = val('f_department');
        var joinDate = fmtDate(val('f_joinDate'));
        var lastDate = fmtDate(val('f_lastWorkingDate'));
        var resignDate = fmtDate(val('f_resignationDate'));
        var reasonNotice = val('f_reasonNotice');
        var extraBody = val('f_body');
        var nocItems = val('f_noObjectionItems');

        // Toggle visibility of NOC vs other
        $('nocWrap').style.display = (type === 'noc') ? '' : 'none';
        $('resignDateWrap').style.display = (type === 'relieving') ? '' : 'none';
        $('noticeWrap').style.display = (type === 'relieving') ? '' : 'none';

        // Title
        var titles = {
          relieving: 'Relieving Letter',
          experience: 'Experience Letter',
          noc: 'No-Objection Certificate'
        };
        $('d_title').textContent = titles[type] || titles.relieving;

        // Body
        var bodyHtml = '';
        if (type === 'relieving') {
          bodyHtml = '<p>This is to confirm that <b>' + escapeHtml(name) + '</b>' + (empId ? ' (Employee ID: <b>' + escapeHtml(empId) + '</b>)' : '') + ', who was employed with <b>EduRankAI</b> as <b>' + escapeHtml(role) + '</b>' + (dept ? ', <b>' + escapeHtml(dept) + '</b> team' : '') + ', has been formally relieved from their duties effective <b>' + lastDate + '</b>.</p>';
          if (joinDate !== '-') {
            bodyHtml += '<p>Their tenure with the company began on <b>' + joinDate + '</b>.</p>';
          }
          if (resignDate !== '-') {
            bodyHtml += '<p>Resignation was tendered on <b>' + resignDate + '</b>.</p>';
          }
          if (reasonNotice && reasonNotice.trim()) {
            bodyHtml += '<p>' + escapeHtml(reasonNotice).replace(/\n/g,'<br/>') + '</p>';
          }
          bodyHtml += '<p>All financial and non-financial dues from both sides have been settled. The employee is hereby relieved from all responsibilities towards EduRankAI as of the last working date stated above.</p>';
          if (extraBody && extraBody.trim()) {
            bodyHtml += '<p>' + escapeHtml(extraBody).replace(/\n/g,'<br/>') + '</p>';
          }
          bodyHtml += '<p>We thank them for the contributions made during their tenure and wish them success in future endeavours.</p>';
        } else if (type === 'experience') {
          bodyHtml = '<p>This is to certify that <b>' + escapeHtml(name) + '</b>' + (empId ? ' (Employee ID: <b>' + escapeHtml(empId) + '</b>)' : '') + ' was employed with <b>EduRankAI</b> as <b>' + escapeHtml(role) + '</b>' + (dept ? ' in the <b>' + escapeHtml(dept) + '</b> team' : '') + '.</p>';
          if (joinDate !== '-' && lastDate !== '-') {
            bodyHtml += '<p>Their period of employment was from <b>' + joinDate + '</b> to <b>' + lastDate + '</b>.</p>';
          }
          if (extraBody && extraBody.trim()) {
            bodyHtml += '<p>' + escapeHtml(extraBody).replace(/\n/g,'<br/>') + '</p>';
          } else {
            bodyHtml += '<p>During the period of their employment, we found them to be diligent, capable, and committed. They handled their responsibilities with integrity and contributed positively to the team.</p>';
          }
          bodyHtml += '<p>We wish them all the best in their future career.</p>';
        } else {
          // NOC
          bodyHtml = '<p>This is to certify that <b>EduRankAI</b> has <b>no objection</b> regarding <b>' + escapeHtml(name) + '</b>' + (empId ? ' (Employee ID: <b>' + escapeHtml(empId) + '</b>)' : '') + ', currently/formerly engaged as <b>' + escapeHtml(role) + '</b>' + (dept ? ' in the <b>' + escapeHtml(dept) + '</b> team' : '') + '.</p>';
          if (nocItems && nocItems.trim()) {
            var items = nocItems.split('\n').filter(function(s) { return s.trim(); });
            if (items.length > 0) {
              bodyHtml += '<p>Specifically, we have no objection to the following:</p><ul style="margin:8px 0 14px 22px;">';
              for (var i = 0; i < items.length; i++) {
                bodyHtml += '<li style="margin-bottom:4px;">' + escapeHtml(items[i].trim()) + '</li>';
              }
              bodyHtml += '</ul>';
            }
          }
          if (extraBody && extraBody.trim()) {
            bodyHtml += '<p>' + escapeHtml(extraBody).replace(/\n/g,'<br/>') + '</p>';
          }
          bodyHtml += '<p>This certificate is issued upon the request of the bearer for whatever purpose it may serve.</p>';
        }
        $('d_body').innerHTML = bodyHtml;

        // Summary table
        var summary = [
          ['Name', name],
          ['Employee ID', empId],
          ['Designation', role],
          ['Department', dept],
          ['Date of Joining', joinDate !== '-' ? joinDate : ''],
          ['Last Working Date', (type !== 'noc' && lastDate !== '-') ? lastDate : '']
        ];
        var sHtml = '';
        for (var i = 0; i < summary.length; i++) {
          var k = summary[i][0], v = summary[i][1];
          if (!v) continue;
          sHtml += '<tr style="border-bottom:1px solid rgba(0,0,0,0.05);"><td style="padding:6px 0;color:#6b6b76;width:38%;">' + k + '</td><td style="padding:6px 0;color:#0a0a0c;font-weight:500;">' + escapeHtml(v) + '</td></tr>';
        }
        $('d_summaryBody').innerHTML = sHtml;

        // Signatory
        $('d_ref').textContent = val('f_refNumber') || '-';
        $('d_issueDate').textContent = fmtDate(val('f_issueDate'));
        $('d_sigName').textContent = val('f_signatoryName') || '-';
        $('d_sigTitle').textContent = val('f_signatoryTitle') || '-';
      }

      var inputs = document.querySelectorAll('.rfi');
      for (var i = 0; i < inputs.length; i++) {
        inputs[i].addEventListener('input', refresh);
        inputs[i].addEventListener('change', refresh);
      }
      refresh();

      $('downloadBtn').addEventListener('click', function() {
        refresh();
        var btn = $('downloadBtn');
        btn.disabled = true;
        btn.textContent = 'Generating PDF...';
        var target = $('offDoc');
        if (typeof html2canvas === 'undefined' || typeof window.jspdf === 'undefined') {
          alert('PDF library still loading.');
          btn.disabled = false;
          btn.textContent = 'Download PDF';
          return;
        }
        html2canvas(target, { scale: 2, backgroundColor: '#fdfcf8' }).then(function(canvas) {
          var imgData = canvas.toDataURL('image/jpeg', 0.95);
          var pdf = new window.jspdf.jsPDF('p', 'mm', 'a4');
          var pdfW = 210, pdfH = 297;
          var imgH = (canvas.height * pdfW) / canvas.width;
          var heightLeft = imgH;
          var pos = 0;
          pdf.addImage(imgData, 'JPEG', 0, pos, pdfW, imgH);
          heightLeft -= pdfH;
          while (heightLeft > 0) {
            pos = heightLeft - imgH;
            pdf.addPage();
            pdf.addImage(imgData, 'JPEG', 0, pos, pdfW, imgH);
            heightLeft -= pdfH;
          }
          var nm = (val('f_employeeName') || 'Letter').replace(/[^a-zA-Z0-9-_]/g, '_');
          var typeMap = { relieving: 'Relieving', experience: 'Experience', noc: 'NOC' };
          pdf.save('EduRankAI-' + (typeMap[val('f_docType')] || 'Letter') + '-' + nm + '.pdf');
          btn.disabled = false;
          btn.textContent = 'Download PDF';
        }).catch(function(err) {
          alert('PDF failed: ' + err.message);
          btn.disabled = false;
          btn.textContent = 'Download PDF';
        });
      });

      $('printBtn').addEventListener('click', function() {
        refresh();
        setTimeout(function() { window.print(); }, 200);
      });
    })();
  </script>

  <style>
    .rfl { display:block;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.55);margin-bottom:6px; }
    .rfi { width:100%;padding:9px 12px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:8px;color:#fff;font-size:13px;font-family:inherit;outline:none; }
    .rfi:focus { border-color:#FF4F00; }
    textarea.rfi { resize:vertical; }
    .rfi option { background:#0a0a0c; }
    @media print {
      body * { visibility: hidden; }
      #offDoc, #offDoc * { visibility: visible; }
      #offDoc { position: absolute; left: 0; top: 0; width: 100%; box-shadow:none !important; border-radius:0 !important; }
    }
  </style>
</AdminLayout>