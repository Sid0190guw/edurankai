---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { ensureBgvSchema, createBgvRecord, updateBgvCheck, listBgvRecords, BGV_CHECKS, BGV_STATUS_TONES } from '@/lib/hr-bgv';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

await ensureBgvSchema();
let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const action = (fd.get('action') as string) || 'create';
    if (action === 'create') {
      await createBgvRecord({
        name: ((fd.get('name') as string) || '').trim().slice(0, 200),
        email: ((fd.get('email') as string) || '').trim().slice(0, 200),
        consent: fd.get('consent') === 'on',
        ip: Astro.clientAddress,
        vendor: (fd.get('vendor') as string) || undefined,
      });
      okMsg = 'BGV record created.';
    } else if (action === 'update_check') {
      const id = fd.get('id') as string; const key = fd.get('key') as string; const status = fd.get('status') as string; const notes = (fd.get('notes') as string) || undefined;
      const r = await updateBgvCheck(id, key, status, notes); okMsg = r.ok ? 'Check updated.' : 'Failed.';
    }
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 240); }
}
const url = new URL(Astro.request.url);
const filterStatus = url.searchParams.get('status') || '';
const list = await listBgvRecords(filterStatus || undefined);
function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day:'2-digit', month:'short' }); } catch { return ''; } }
const STATUS_OPTIONS = ['pending','in_progress','clear','flagged','failed','n/a'];
---
<AdminLayout title="Background Verification (BGV)" activeNav="">
<div style="padding:14px 16px 80px;max-width:1280px;margin:0 auto;">
  <p style="font-size:10.5px;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;font-family:'Geist Mono',monospace;font-weight:700;">HR · Pre-joining</p>
  <h1 style="font-size:24px;color:#fff;margin:6px 0 4px;font-weight:700;">Background Verification</h1>
  <p style="font-size:13px;color:#9aa6b6;margin:0 0 18px;">Per Lifecycle Manual §B.10. Written consent required before any check is run. Make BGV clearance a written condition of the offer.</p>

  {okMsg && <div style="background:rgba(74,222,128,0.10);border:1px solid rgba(74,222,128,0.32);color:#86efac;border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;">{okMsg}</div>}
  {errMsg && <div style="background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.32);color:#fca5a5;border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;">{errMsg}</div>}

  <details style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:0;margin-bottom:18px;">
    <summary style="cursor:pointer;padding:14px 18px;font-size:13px;color:#FF7040;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;font-family:'Geist Mono',monospace;list-style:none;">+ Create BGV record</summary>
    <form method="POST" style="padding:0 18px 18px;display:grid;gap:10px;">
      <input type="hidden" name="action" value="create" />
      <input name="name" placeholder="Candidate name *" required style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;" />
      <input name="email" type="email" placeholder="Candidate email *" required style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;" />
      <input name="vendor" placeholder="Vendor (e.g. AuthBridge / First Advantage / Internal)" style="background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;" />
      <label style="display:flex;gap:8px;align-items:flex-start;font-size:12px;color:#d8d8de;line-height:1.55;"><input name="consent" type="checkbox" required style="margin-top:3px;" /> I confirm the candidate has given written consent to run these checks (DPDPA 2023 + global standard).</label>
      <button type="submit" style="background:#FF4F00;color:#fff;border:none;padding:10px 22px;border-radius:8px;font-size:12.5px;font-weight:800;cursor:pointer;letter-spacing:0.04em;text-transform:uppercase;font-family:'Geist Mono',monospace;justify-self:start;">Create record</button>
    </form>
  </details>

  <form method="GET" style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;">
    <select name="status" style="background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12.5px;">
      <option value="">All overall statuses</option>
      {STATUS_OPTIONS.map(s => <option value={s} selected={filterStatus === s}>{s}</option>)}
    </select>
    <button type="submit" style="background:#15151a;border:1px solid #2a2a2f;color:#FF7040;padding:9px 16px;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer;">Filter</button>
  </form>

  {list.length === 0 ? (<div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:36px;text-align:center;color:#6e6e78;font-size:13px;">No BGV records.</div>) : (
    <div style="display:flex;flex-direction:column;gap:8px;">
      {list.map((r: any) => (
        <details style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:0;">
          <summary style="cursor:pointer;padding:14px 18px;list-style:none;display:grid;grid-template-columns:1.4fr 1fr 1fr 90px 90px;gap:12px;align-items:center;">
            <div><p style="font-size:13px;color:#fff;font-weight:700;margin:0;">{r.candidate_name}</p><p style="font-size:10.5px;color:#9aa6b6;margin:2px 0 0;font-family:'Geist Mono',monospace;">{r.candidate_email}</p></div>
            <p style="font-size:11.5px;color:#cfd6da;margin:0;">{r.vendor || '—'}</p>
            <p style="font-size:11.5px;color:#9aa6b6;margin:0;font-family:'Geist Mono',monospace;">{r.consent_given ? 'consent ✓' : 'no consent'}</p>
            <span style={`background:${BGV_STATUS_TONES[r.overall_status]}22;color:${BGV_STATUS_TONES[r.overall_status]};font-size:10px;font-weight:700;padding:3px 8px;border-radius:100px;text-align:center;font-family:'Geist Mono',monospace;letter-spacing:0.06em;text-transform:uppercase;`}>{r.overall_status}</span>
            <p style="font-size:10.5px;color:#6e6e78;margin:0;font-family:'Geist Mono',monospace;">{fmt(r.created_at)}</p>
          </summary>
          <div style="padding:0 18px 18px;border-top:1px solid #1a1a1f;">
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:10px;margin-top:14px;">
              {BGV_CHECKS.map((c) => {
                const status = r[c.key] || 'pending';
                return (
                  <form method="POST" style="background:#08080a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 14px;">
                    <input type="hidden" name="action" value="update_check" /><input type="hidden" name="id" value={r.id} /><input type="hidden" name="key" value={c.key} />
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;"><p style="font-size:11.5px;color:#fff;font-weight:700;margin:0;">{c.label}</p><span style={`background:${BGV_STATUS_TONES[status]}22;color:${BGV_STATUS_TONES[status]};font-size:9.5px;font-weight:700;padding:2px 6px;border-radius:100px;font-family:'Geist Mono',monospace;letter-spacing:0.06em;text-transform:uppercase;`}>{status}</span></div>
                    <p style="font-size:10.5px;color:#9aa6b6;margin:0 0 6px;">{c.description}</p>
                    <div style="display:flex;gap:4px;margin-bottom:6px;">
                      <select name="status" style="flex:1;background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:5px 8px;border-radius:4px;font-size:11px;">{STATUS_OPTIONS.map(s => <option value={s} selected={s === status}>{s}</option>)}</select>
                      <button type="submit" style="background:#1045BB;color:#fff;border:none;padding:5px 10px;border-radius:4px;font-size:11px;font-weight:700;cursor:pointer;">Save</button>
                    </div>
                    <input name="notes" placeholder="Notes (optional)" style="width:100%;background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:5px 8px;border-radius:4px;font-size:11px;" />
                  </form>
                );
              })}
            </div>
          </div>
        </details>
      ))}
    </div>
  )}
</div>
</AdminLayout>
