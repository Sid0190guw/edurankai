---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

let empCount = 0, leaveCount = 0, attendanceToday = 0, payrollPending = 0;

try {
  const r = await db.execute(sql`
    SELECT
      (SELECT COUNT(*)::int FROM hr_employees WHERE is_active = true) as emps,
      (SELECT COUNT(*)::int FROM hr_leave_request WHERE status = 'pending') as leaves,
      (SELECT COUNT(*)::int FROM hr_attendance WHERE date = CURRENT_DATE) as att,
      (SELECT COUNT(*)::int FROM hr_payroll_runs WHERE status = 'draft') as payroll
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  const d = rows[0] as any;
  if (d) {
    empCount = Number(d.emps) || 0;
    leaveCount = Number(d.leaves) || 0;
    attendanceToday = Number(d.att) || 0;
    payrollPending = Number(d.payroll) || 0;
  }
} catch(e) {}

const modules = [
  {
    label: 'Employees',
    desc: 'Add, view, and manage employee profiles',
    href: '/admin/hr/employees',
    status: 'live',
    stat: empCount + ' active',
    color: '#10b981',
    svg: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>'
  },
  {
    label: 'Leave Management',
    desc: 'Approve/reject requests, allocate balances',
    href: '/admin/hr/leave',
    status: 'live',
    stat: leaveCount + ' pending',
    color: '#fbbf24',
    svg: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>'
  },
  {
    label: 'Attendance',
    desc: 'Daily tracking, monthly summary, bulk mark',
    href: '/admin/hr/attendance',
    status: 'live',
    stat: attendanceToday + ' marked today',
    color: '#60a5fa',
    svg: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>'
  },
  {
    label: 'Payroll',
    desc: 'Run payroll, payslips, salary structures',
    href: '/admin/hr/payroll',
    status: 'live',
    stat: payrollPending + ' pending runs',
    color: '#a78bfa',
    svg: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>'
  },
  {
    label: 'Recommendation Letter',
    desc: 'Generate LOR / TWMIC / completion certificates',
    href: '/admin/hr/recommendation',
    status: 'live',
    stat: null,
    color: '#34d399',
    svg: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>'
  },
  {
    label: 'Offboarding Docs',
    desc: 'Relieving / experience / NOC letters',
    href: '/admin/hr/offboarding',
    status: 'live',
    stat: null,
    color: '#f97316',
    svg: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>'
  },
  {
    label: 'Performance Reviews',
    desc: 'Rubric-based evaluation cycles, ratings',
    href: '/admin/hr/performance',
    status: 'live',
    stat: null,
    color: '#e879f9',
    svg: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>'
  },
  {
    label: 'Training & Certifications',
    desc: 'Learning paths, certification tracking',
    href: '/admin/hr/training',
    status: 'live',
    stat: null,
    color: '#6e6e78',
    svg: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>'
  },
  {
    label: 'Asset Management',
    desc: 'Laptops, accounts, equipment allocation',
    href: '/admin/hr/assets',
    status: 'planned',
    stat: null,
    color: '#6e6e78',
    svg: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>'
  },
];
---
<AdminLayout title="HR Management" activeNav="hr">
<div style="padding-bottom:80px;">

  <!-- Header -->
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">People Operations</p>
    <h1 style="font-size:20px;font-weight:700;color:#fff;margin:4px 0 0;">HR Management</h1>
  </div>

  <!-- Live stats -->
  <div style="padding:14px 16px 0;display:grid;grid-template-columns:repeat(4,1fr);gap:8px;">
    {[
      { label: 'Active Employees', value: empCount, color: '#10b981', href: '/admin/hr/employees' },
      { label: 'Pending Leave', value: leaveCount, color: '#fbbf24', href: '/admin/hr/leave' },
      { label: 'Marked Today', value: attendanceToday, color: '#60a5fa', href: '/admin/hr/attendance' },
      { label: 'Payroll Drafts', value: payrollPending, color: '#a78bfa', href: '/admin/hr/payroll' },
    ].map(s => (
      <a href={s.href} style="text-decoration:none;background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:10px;text-align:center;">
        <p style={`font-size:22px;font-weight:800;color:${s.color};margin:0;line-height:1;font-family:'Geist Mono',monospace;`}>{s.value}</p>
        <p style="font-size:9px;color:#6e6e78;margin:3px 0 0;line-height:1.3;">{s.label}</p>
      </a>
    ))}
  </div>

  <!-- Modules grid -->
  <div style="padding:14px 16px;display:flex;flex-direction:column;gap:6px;">
    {modules.map(m => (
      <a href={m.status === 'planned' ? '#' : m.href} style={`text-decoration:none;background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px 16px;display:flex;align-items:center;gap:14px;${m.status==='planned'?'opacity:0.5;cursor:not-allowed;':''}`}>
        <div style={`width:44px;height:44px;border-radius:10px;background:${m.color}18;border:1px solid ${m.color}33;display:flex;align-items:center;justify-content:center;flex-shrink:0;color:${m.color};`} set:html={m.svg}></div>
        <div style="flex:1;min-width:0;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:3px;">
            <p style="font-size:14px;font-weight:600;color:#fff;margin:0;">{m.label}</p>
            <span style={`font-size:9px;font-weight:700;padding:1px 7px;border-radius:100px;${m.status==='live'?'background:rgba(16,185,129,0.15);color:#6ee7b7;':'background:#15151a;color:#6e6e78;'}`}>{m.status.toUpperCase()}</span>
          </div>
          <p style="font-size:11px;color:#6e6e78;margin:0;">{m.desc}</p>
          {m.stat && <p style={`font-size:10px;color:${m.color};margin:4px 0 0;font-family:'Geist Mono',monospace;`}>{m.stat}</p>}
        </div>
        {m.status === 'live' && (
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6e6e78" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        )}
      </a>
    ))}
  </div>

</div>
</AdminLayout>
