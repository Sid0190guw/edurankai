---
import AdminLayout from '@/layouts/AdminLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const sections = [
  {
    group: 'Hiring',
    items: [
      { label: 'Applications', href: '/admin/applications', status: 'live', desc: 'Inbound application pipeline' },
      { label: 'Offer Letters', href: '/admin/offers', status: 'live', desc: 'Per-applicant offer records' },
      { label: 'Custom Offer Builder', href: '/admin/offer/blank', status: 'live', desc: 'Standalone offer letter generator with PDF download' }
    ]
  },
  {
    group: 'Documents',
    items: [
      { label: 'Recommendation Letter', href: '/admin/hr/recommendation', status: 'live', desc: 'Generate LOR / TWMIC / completion certificate' },
      { label: 'Offboarding Documents', href: '/admin/hr/offboarding', status: 'live', desc: 'Relieving / experience / NOC letter' }
    ]
  },
  {
    group: 'Onboarding',
    items: [
      { label: 'Onboarding Workflow', href: '#', status: 'planned', desc: 'Step-by-step checklist for new hires' },
      { label: 'IT Asset Allocation', href: '#', status: 'planned', desc: 'Track laptops, accounts, access' }
    ]
  },
  {
    group: 'Engagement',
    items: [
      { label: 'Employee Directory', href: '#', status: 'planned', desc: 'Active workforce, profiles' },
      { label: 'Leave Management', href: '#', status: 'planned', desc: 'Leave types, balances, applications' },
      { label: 'Attendance', href: '#', status: 'planned', desc: 'Check-in/out, hours, regularization' }
    ]
  },
  {
    group: 'Performance',
    items: [
      { label: 'Performance Reviews', href: '#', status: 'planned', desc: 'Rubric-based eval cycles' },
      { label: 'Promotions / Demotions', href: '#', status: 'planned', desc: 'Career progression record' },
      { label: 'Awards & Recognition', href: '#', status: 'planned', desc: 'Awards, citations, gifts' }
    ]
  },
  {
    group: 'Payroll',
    items: [
      { label: 'Salary Structures', href: '#', status: 'planned', desc: 'CTC, components, PF, ESIC, TDS' },
      { label: 'Payroll Runs', href: '#', status: 'planned', desc: 'Monthly payroll processing' },
      { label: 'Payslips', href: '#', status: 'planned', desc: 'Per-employee payslip downloads' }
    ]
  },
  {
    group: 'Offboarding',
    items: [
      { label: 'Resignations', href: '#', status: 'planned', desc: 'Resignation workflow + clearance' },
      { label: 'Exit Interviews', href: '#', status: 'planned', desc: 'Structured exit conversations' },
      { label: 'Final Settlement', href: '#', status: 'planned', desc: 'F&F, gratuity, dues' }
    ]
  }
];

function statusColor(s: string): string {
  if (s === 'live') return 'background:rgba(16,185,129,0.15);color:#6ee7b7;border:1px solid rgba(16,185,129,0.3);';
  if (s === 'beta') return 'background:rgba(251,191,36,0.15);color:#fbbf24;border:1px solid rgba(251,191,36,0.3);';
  return 'background:rgba(160,160,171,0.1);color:#a0a0ab;border:1px solid rgba(160,160,171,0.2);';
}
---
<AdminLayout title="HR Management" description="EduRankAI HR Management - all people operations.">
  <div class="admin-page" style="max-width:1400px;">

    <div class="admin-page-header" style="margin-bottom:18px;">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">People Operations</div>
        <h1 class="admin-page-title">HR Management</h1>
        <p class="admin-page-sub">Full lifecycle: hiring → onboarding → engagement → performance → payroll → offboarding. Live sub-sections fully functional; planned sub-sections coming in scheduled builds.</p>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(360px,1fr));gap:14px;">
      {sections.map((section) => (
        <div class="admin-card" style="padding:18px;">
          <h2 style="font-family:'Fraunces',serif;font-size:16px;font-weight:600;color:#fff;margin-bottom:12px;display:flex;align-items:center;gap:8px;">
            {section.group}
            <span style="font-size:10px;font-family:'Geist Mono',monospace;color:#6e6e78;font-weight:400;">({section.items.length})</span>
          </h2>
          <div style="display:flex;flex-direction:column;gap:6px;">
            {section.items.map((it) => (
              <a href={it.href} style={'padding:10px 12px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:8px;text-decoration:none;transition:background 0.15s;display:block;' + (it.status === 'planned' ? 'pointer-events:none;opacity:0.5;' : '')}>
                <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:3px;">
                  <span style="font-size:13px;color:#fff;font-weight:500;">{it.label}</span>
                  <span style={'font-size:9px;padding:2px 7px;border-radius:100px;text-transform:uppercase;letter-spacing:0.08em;font-weight:700;' + statusColor(it.status)}>{it.status}</span>
                </div>
                <p style="font-size:11.5px;color:#a0a0ab;line-height:1.5;margin:0;">{it.desc}</p>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div style="margin-top:24px;padding:16px 18px;background:rgba(255,79,0,0.05);border:1px solid rgba(255,79,0,0.2);border-radius:10px;">
      <p style="font-size:11px;color:#FF7040;font-family:'Geist Mono',monospace;letter-spacing:0.1em;text-transform:uppercase;font-weight:700;margin-bottom:6px;">Scope &amp; honesty</p>
      <p style="font-size:13px;color:#d8d8de;line-height:1.65;margin:0;">A complete in-house HRMS is real engineering: 30+ DB tables, 40+ pages, approval flows, payroll calculations, audit logging. Each <strong style="color:#fff;">planned</strong> sub-section above is a separate focused build. Today's live: Custom Offer Builder, Recommendation Letter, Offboarding Documents.</p>
    </div>

  </div>
</AdminLayout>