---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

// Quick stats
let empCount = 0, leaveCount = 0, payrollCount = 0;
try {
  const [e, l, p] = await Promise.all([
    db.execute(sql`SELECT COUNT(*)::int as n FROM hr_employees WHERE is_active = true`),
    db.execute(sql`SELECT COUNT(*)::int as n FROM hr_leave_requests WHERE status = 'pending'`),
    db.execute(sql`SELECT COUNT(*)::int as n FROM hr_payroll_runs WHERE status = 'draft'`),
  ]);
  empCount = (e.rows[0] as any).n;
  leaveCount = (l.rows[0] as any).n;
  payrollCount = (p.rows[0] as any).n;
} catch(e) {}

const modules = [
  {
    icon: '👥', label: 'Employees', href: '/admin/hr/employees', status: 'live',
    desc: 'Add, view, and manage employee profiles', stat: empCount, statLabel: 'active'
  },
  {
    icon: '📋', label: 'Leave Management', href: '/admin/hr/leave', status: 'live',
    desc: 'Approve/reject requests, allocate balances', stat: leaveCount, statLabel: 'pending'
  },
  {
    icon: '📅', label: 'Attendance', href: '/admin/hr/attendance', status: 'live',
    desc: 'Daily tracking, monthly summary, bulk mark', stat: null, statLabel: null
  },
  {
    icon: '💰', label: 'Payroll', href: '/admin/hr/payroll', status: 'live',
    desc: 'Run payroll, payslips, salary structures', stat: payrollCount, statLabel: 'draft runs'
  },
  {
    icon: '📄', label: 'Recommendation Letter', href: '/admin/hr/recommendation', status: 'live',
    desc: 'Generate LOR / TWMIC / completion certificates', stat: null, statLabel: null
  },
  {
    icon: '🚪', label: 'Offboarding Docs', href: '/admin/hr/offboarding', status: 'live',
    desc: 'Relieving / experience / NOC letters', stat: null, statLabel: null
  },
  {
    icon: '🏆', label: 'Performance Reviews', href: '#', status: 'planned',
    desc: 'Rubric-based evaluation cycles, ratings', stat: null, statLabel: null
  },
  {
    icon: '🎓', label: 'Training & Certifications', href: '#', status: 'planned',
    desc: 'Learning paths, certification tracking', stat: null, statLabel: null
  },
  {
    icon: '🏢', label: 'Asset Management', href: '#', status: 'planned',
    desc: 'Laptops, accounts, equipment allocation', stat: null, statLabel: null
  },
];
---
<AdminLayout title="HR Management" activeNav="hr">
<div style="padding-bottom:80px;">

  <!-- Header -->
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:16px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 4px;">People Operations</p>
    <h1 style="font-size:22px;font-weight:700;color:#fff;margin:0 0 4px;">HR Management</h1>
    <p style="font-size:12px;color:#6e6e78;margin:0;">Full lifecycle · Hiring → Onboarding → Engagement → Payroll</p>
  </div>

  <!-- Quick stats -->
  <div style="padding:16px;display:grid;grid-template-columns:repeat(3,1fr);gap:10px;">
    {[
      { label: 'Active Employees', value: empCount, color: '#10b981', href: '/admin/hr/employees' },
      { label: 'Pending Leave', value: leaveCount, color: '#fbbf24', href: '/admin/hr/leave' },
      { label: 'Draft Payrolls', value: payrollCount, color: '#60a5fa', href: '/admin/hr/payroll' },
    ].map(s => (
      <a href={s.href} style="text-decoration:none;background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:12px;text-align:center;display:block;">
        <p style={`font-size:24px;font-weight:800;color:${s.color};margin:0;line-height:1;`}>{s.value}</p>
        <p style="font-size:10px;color:#6e6e78;margin:4px 0 0;line-height:1.3;">{s.label}</p>
      </a>
    ))}
  </div>

  <!-- Module grid -->
  <div style="padding:0 16px;display:flex;flex-direction:column;gap:8px;">
    {modules.map(m => (
      <a href={m.href} style={`text-decoration:none;background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;display:flex;align-items:center;gap:12px;${m.status === 'planned' ? 'opacity:0.5;pointer-events:none;' : ''}`}>
        <span style="font-size:24px;flex-shrink:0;">{m.icon}</span>
        <div style="flex:1;min-width:0;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:2px;">
            <p style="font-size:14px;font-weight:600;color:#fff;margin:0;">{m.label}</p>
            <span style={`font-size:9px;font-weight:700;padding:1px 6px;border-radius:100px;text-transform:uppercase;${m.status === 'live' ? 'background:rgba(16,185,129,0.15);color:#6ee7b7;' : 'background:#15151a;color:#6e6e78;'}`}>
              {m.status}
            </span>
            {m.stat !== null && m.stat > 0 && (
              <span style="font-size:10px;font-weight:700;background:#FF4F00;color:#fff;padding:1px 6px;border-radius:100px;">
                {m.stat} {m.statLabel}
              </span>
            )}
          </div>
          <p style="font-size:11px;color:#6e6e78;margin:0;">{m.desc}</p>
        </div>
        {m.status === 'live' && <span style="color:#FF7040;font-size:16px;flex-shrink:0;">›</span>}
      </a>
    ))}
  </div>
</div>
</AdminLayout>
