---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

let okMsg = '', errorMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  try {
    if (action === 'reschedule') {
      const id = fd.get('id') as string;
      const newTime = fd.get('scheduled_at') as string;
      await db.execute(sql`UPDATE interview_rounds SET scheduled_at=${newTime}, status='rescheduled', updated_at=NOW() WHERE id=${id}`);
      okMsg = 'Interview rescheduled.';
    } else if (action === 'cancel') {
      const id = fd.get('id') as string;
      const reason = fd.get('reason') as string;
      await db.execute(sql`UPDATE interview_rounds SET status='cancelled', cancellation_reason=${reason}, updated_at=NOW() WHERE id=${id}`);
      okMsg = 'Interview cancelled.';
    } else if (action === 'mark_no_show') {
      const id = fd.get('id') as string;
      await db.execute(sql`UPDATE interview_rounds SET status='no_show', updated_at=NOW() WHERE id=${id}`);
      okMsg = 'Marked as no-show.';
    } else if (action === 'mark_completed') {
      const id = fd.get('id') as string;
      await db.execute(sql`UPDATE interview_rounds SET status='completed', updated_at=NOW() WHERE id=${id}`);
      okMsg = 'Marked as completed. Please submit scorecard.';
    }
  } catch(e: any) { errorMsg = e.message; }
}

const urlP = new URL(Astro.request.url);
const filter = urlP.searchParams.get('filter') || 'upcoming';

let interviews: any[] = [];
try {
  let whereClause = sql`WHERE 1=1`;
  if (filter === 'upcoming') {
    whereClause = sql`WHERE ir.scheduled_at >= NOW() AND ir.status IN ('scheduled','rescheduled')`;
  } else if (filter === 'today') {
    whereClause = sql`WHERE DATE(ir.scheduled_at) = CURRENT_DATE AND ir.status IN ('scheduled','rescheduled')`;
  } else if (filter === 'completed') {
    whereClause = sql`WHERE ir.status = 'completed'`;
  } else if (filter === 'pending_feedback') {
    whereClause = sql`WHERE ir.status = 'pending_feedback'`;
  } else if (filter === 'cancelled') {
    whereClause = sql`WHERE ir.status IN ('cancelled','no_show')`;
  }

  const r = await db.execute(sql`
    SELECT ir.*,
      a.first_name, a.last_name, a.email as candidate_email, a.application_number, a.status as app_status,
      a.role_title_snapshot,
      (SELECT COUNT(*)::int FROM interview_scorecards WHERE interview_id = ir.id) as scorecard_count
    FROM interview_rounds ir
    LEFT JOIN applications a ON ir.application_id = a.id
    ${whereClause}
    ORDER BY ir.scheduled_at ASC NULLS LAST
    LIMIT 100
  `);
  interviews = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

let stats = { today: 0, upcoming: 0, pending: 0, completed: 0 };
try {
  const r = await db.execute(sql`
    SELECT
      (SELECT COUNT(*)::int FROM interview_rounds WHERE DATE(scheduled_at) = CURRENT_DATE AND status IN ('scheduled','rescheduled')) as today_count,
      (SELECT COUNT(*)::int FROM interview_rounds WHERE scheduled_at >= NOW() AND status IN ('scheduled','rescheduled')) as upcoming_count,
      (SELECT COUNT(*)::int FROM interview_rounds WHERE status='pending_feedback') as pending_count,
      (SELECT COUNT(*)::int FROM interview_rounds WHERE status='completed') as completed_count
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  if (rows[0]) {
    stats.today = (rows[0] as any).today_count || 0;
    stats.upcoming = (rows[0] as any).upcoming_count || 0;
    stats.pending = (rows[0] as any).pending_count || 0;
    stats.completed = (rows[0] as any).completed_count || 0;
  }
} catch(e) {}

const TYPE_COLORS: Record<string,string> = {
  screening:'#60a5fa', technical:'#a78bfa', culture_fit:'#10b981',
  case_study:'#fbbf24', final:'#FF4F00', reference_check:'#8b5cf6', custom:'#6b7280'
};
---
<AdminLayout title="Interviews" activeNav="hr">
<div style="padding-bottom:80px;">
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
      <div>
        <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">Recruitment</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Interviews</h1>
      </div>
    </div>
    <div style="display:flex;gap:5px;overflow-x:auto;">
      {[['upcoming','Upcoming',stats.upcoming],['today','Today',stats.today],['pending_feedback','Pending Feedback',stats.pending],['completed','Completed',stats.completed],['cancelled','Cancelled',0]].map(([f,l,n]) => (
        <a href={`?filter=${f}`} style={`text-decoration:none;font-size:11px;font-weight:600;padding:6px 12px;border-radius:6px;white-space:nowrap;${filter===f?'background:#FF4F00;color:#fff;':'background:#15151a;color:#8a8a94;'}`}>{l}{(n as number)>0?` (${n})`:''}</a>
      ))}
    </div>
  </div>

  {errorMsg && <div style="margin:10px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  <div style="padding:12px 16px;">
    {interviews.length === 0 && (
      <div style="text-align:center;padding:40px;background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;color:#6e6e78;">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#6e6e78" stroke-width="1.5" style="margin-bottom:12px;"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <p style="font-size:14px;font-weight:600;color:#fff;margin-bottom:4px;">No {filter} interviews</p>
        <p style="font-size:12px;">Schedule from any application page.</p>
      </div>
    )}

    <div style="display:flex;flex-direction:column;gap:8px;">
      {interviews.map((i: any) => {
        const tc = (TYPE_COLORS as any)[i.round_type] || '#6b7280';
        const scheduledLocal = i.scheduled_at ? new Date(i.scheduled_at).toISOString() : '';
        return (
          <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
            <div style="padding:12px 14px;">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:8px;flex-wrap:wrap;">
                <div style="flex:1;min-width:200px;">
                  <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;flex-wrap:wrap;">
                    <span style={`font-size:9px;font-weight:700;padding:2px 8px;border-radius:100px;background:${tc}22;color:${tc};text-transform:uppercase;`}>Round {i.round_number} - {i.round_type?.replace('_',' ')}</span>
                    <span style="font-size:9px;background:#15151a;color:#8a8a94;padding:2px 8px;border-radius:100px;">{i.status?.replace('_',' ')}</span>
                    {i.scorecard_count > 0 && <span style="font-size:9px;background:rgba(16,185,129,0.15);color:#6ee7b7;padding:2px 8px;border-radius:100px;">{i.scorecard_count} scorecard</span>}
                  </div>
                  <p style="font-size:14px;font-weight:700;color:#fff;margin:0 0 2px;">{i.first_name} {i.last_name}</p>
                  <p style="font-size:11px;color:#8a8a94;margin:0;">{i.application_number} - {i.role_title_snapshot}</p>
                  <p style="font-size:11px;color:#6e6e78;margin:2px 0 0;">{i.candidate_email}</p>
                </div>
                <div style="text-align:right;flex-shrink:0;">
                  <p style="font-size:13px;font-weight:600;color:#fff;margin:0;" data-ts={scheduledLocal}>{i.scheduled_at || 'TBD'}</p>
                  <p style="font-size:10px;color:#6e6e78;margin:2px 0 0;">{i.duration_mins}min</p>
                </div>
              </div>
              <p style="font-size:13px;color:#d8d8de;margin:0 0 8px;">{i.title}</p>
              {i.notes && <p style="font-size:11px;color:#6e6e78;margin:0 0 8px;font-style:italic;">"{i.notes}"</p>}
              <div style="display:flex;gap:5px;flex-wrap:wrap;">
                {i.meeting_url && (i.status === 'scheduled' || i.status === 'rescheduled') && (
                  <a href={i.meeting_url} target="_blank" style="background:#10b981;border:none;color:#fff;font-size:11px;font-weight:600;padding:7px 12px;border-radius:6px;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:4px;">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
                    Join Room
                  </a>
                )}
                <a href={`/admin/applications/${i.application_id}`} style="background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;font-size:11px;padding:7px 12px;border-radius:6px;text-decoration:none;">View Application</a>
                {(i.status === 'scheduled' || i.status === 'rescheduled') && (
                  <>
                    <form method="POST" style="display:inline;">
                      <input type="hidden" name="action" value="mark_completed"/>
                      <input type="hidden" name="id" value={i.id}/>
                      <button type="submit" style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;font-size:11px;font-weight:600;padding:7px 12px;border-radius:6px;cursor:pointer;">Mark Completed</button>
                    </form>
                    <form method="POST" style="display:inline;" onsubmit="return confirm('Mark no-show?');">
                      <input type="hidden" name="action" value="mark_no_show"/>
                      <input type="hidden" name="id" value={i.id}/>
                      <button type="submit" style="background:#15151a;border:1px solid #1a1a1f;color:#fbbf24;font-size:11px;padding:7px 12px;border-radius:6px;cursor:pointer;">No-show</button>
                    </form>
                  </>
                )}
                {i.status === 'completed' && !i.scorecard_count && (
                  <a href={`/admin/interviews/${i.id}/scorecard`} style="background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:600;padding:7px 12px;border-radius:6px;text-decoration:none;">Submit Scorecard</a>
                )}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</div>
<script is:inline>
document.querySelectorAll('[data-ts]').forEach(function(el) {
  var ts = el.getAttribute('data-ts');
  if (!ts) return;
  var d = new Date(ts);
  el.textContent = d.toLocaleString(undefined, { weekday:'short', day:'numeric', month:'short', hour:'numeric', minute:'2-digit' });
});
</script>
</AdminLayout>
