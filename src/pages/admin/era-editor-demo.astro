---
import AdminLayout from '@/layouts/AdminLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const jsSample = "// JavaScript demo\nfunction greet(name) {\n  const msg = 'Hello, ' + name + '!';\n  console.log(msg);\n  return msg;\n}\n\ngreet('Bharat');";
const pySample = "# Python demo\nfrom math import sqrt\n\ndef hypot(a, b):\n    return sqrt(a*a + b*b)\n\nresult = hypot(3, 4)\nprint(f'Result is {result}')";
const sqlSample = "-- SQL demo\nSELECT u.id, u.name, COUNT(a.id) AS apps\nFROM users u\nLEFT JOIN applications a ON a.user_id = u.id\nWHERE u.created_at > NOW() - INTERVAL '30 days'\nGROUP BY u.id, u.name\nORDER BY apps DESC\nLIMIT 10;";
---
<AdminLayout title="ERA Editor Demo" activeNav="dashboard">
  <link rel="stylesheet" href="/era/era-editor.css" />

  <div style="padding:20px 16px 80px;max-width:1400px;margin:0 auto;">
    <div style="margin-bottom:18px;">
      <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">ERA Editor v1</p>
      <h1 style="font-size:22px;font-weight:700;color:#fff;margin:4px 0 6px;">Custom code editor demo</h1>
      <p style="font-size:13px;color:#8a8a94;margin:0;">Lightweight tokenizer + contenteditable surface. Try typing, brackets, Tab indent, Ctrl/Cmd+F to find.</p>
    </div>

    <div style="display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap;">
      <button id="toggleReadonly" type="button" style="background:#15151A;border:1px solid #1A1A1F;color:#fff;font-size:12px;font-weight:600;padding:8px 14px;border-radius:8px;cursor:pointer;">Toggle read-only</button>
      <button id="getValueBtn" type="button" style="background:#FF4F00;border:none;color:#fff;font-size:12px;font-weight:700;padding:8px 14px;border-radius:8px;cursor:pointer;">Get JS value</button>
      <button id="setSqlBtn" type="button" style="background:#15151A;border:1px solid #1A1A1F;color:#fff;font-size:12px;font-weight:600;padding:8px 14px;border-radius:8px;cursor:pointer;">Reset SQL</button>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(420px,1fr));gap:14px;">
      <div>
        <p style="font-size:11px;font-family:'Geist Mono',monospace;color:#6E6E78;margin:0 0 6px;text-transform:uppercase;letter-spacing:0.08em;">JavaScript</p>
        <div id="edJs" style="min-height:280px;"></div>
      </div>
      <div>
        <p style="font-size:11px;font-family:'Geist Mono',monospace;color:#6E6E78;margin:0 0 6px;text-transform:uppercase;letter-spacing:0.08em;">Python</p>
        <div id="edPy" style="min-height:280px;"></div>
      </div>
      <div>
        <p style="font-size:11px;font-family:'Geist Mono',monospace;color:#6E6E78;margin:0 0 6px;text-transform:uppercase;letter-spacing:0.08em;">SQL</p>
        <div id="edSql" style="min-height:280px;"></div>
      </div>
    </div>
  </div>

  <script is:inline src="/era/era-highlight.js"></script>
  <script is:inline src="/era/era-editor.js"></script>
  <script is:inline define:vars={{ jsSample, pySample, sqlSample }}>
    document.addEventListener('DOMContentLoaded', function() {
      var edJs = new ERA.Editor('#edJs', { language: 'javascript', value: jsSample });
      var edPy = new ERA.Editor('#edPy', { language: 'python', value: pySample });
      var edSql = new ERA.Editor('#edSql', { language: 'sql', value: sqlSample });

      var editors = [edJs, edPy, edSql];
      var readonly = false;
      document.getElementById('toggleReadonly').addEventListener('click', function() {
        readonly = !readonly;
        editors.forEach(function(e) { e.setReadonly(readonly); });
        this.textContent = readonly ? 'Switch to edit' : 'Toggle read-only';
      });
      document.getElementById('getValueBtn').addEventListener('click', function() {
        alert('JavaScript editor value:\n\n' + edJs.getValue());
      });
      document.getElementById('setSqlBtn').addEventListener('click', function() {
        edSql.setValue(sqlSample);
      });
    });
  </script>
</AdminLayout>
