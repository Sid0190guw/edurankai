---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { ROLE_LABELS } from '@/lib/auth/permissions';

const me = Astro.locals.user;
if (!me) return Astro.redirect('/admin/login');
if (me.role === 'applicant') return Astro.redirect('/portal');

const { id } = Astro.params;
function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

const target: any = rows(await db.execute(sql`SELECT * FROM users WHERE id = ${id} LIMIT 1`))[0];
if (!target) return Astro.redirect('/admin/users');

// Visibility: super admin / HR see everyone; a department head sees members of
// their own department; otherwise only your own profile.
const isAuthority = ['super_admin', 'hr'].includes(me.role);
const sameDeptHead = me.role === 'department_head' && me.assignedDepartmentId && me.assignedDepartmentId === target.assigned_department_id;
if (!isAuthority && !sameDeptHead && me.id !== target.id) return Astro.redirect('/admin/users');

// Recent activity (audit log).
const activity = rows(await db.execute(sql`SELECT action, entity, entity_id, ip_address, created_at FROM audit_log WHERE user_id = ${id} ORDER BY created_at DESC LIMIT 60`));

// Employee profile + today's clock status + today's report (if any).
const emp: any = rows(await db.execute(sql`SELECT * FROM hr_employees WHERE user_id = ${id} OR lower(personal_email) = ${(target.email || '').toLowerCase()} OR lower(email) = ${(target.email || '').toLowerCase()} LIMIT 1`))[0];
let clockToday: any[] = [], reportToday: any = null;
if (emp) {
  clockToday = rows(await db.execute(sql`SELECT event_type, event_time, location_name FROM hr_clock_events WHERE employee_id = ${emp.id} AND DATE(event_time) = CURRENT_DATE ORDER BY event_time ASC`));
  reportToday = rows(await db.execute(sql`SELECT * FROM hr_daily_reports WHERE employee_id = ${emp.id} AND report_date = CURRENT_DATE LIMIT 1`))[0] || null;
}
const lastClock = clockToday.length ? clockToday[clockToday.length - 1] : null;
const liveStatus = lastClock ? (lastClock.event_type === 'clock_in' || lastClock.event_type === 'break_end' ? 'Working' : lastClock.event_type === 'break_start' ? 'On break' : 'Clocked out') : 'Not clocked in';

function ago(d: any): string {
  if (!d) return 'never';
  const s = Math.floor((Date.now() - new Date(d).getTime()) / 1000);
  if (s < 60) return s + 's ago'; if (s < 3600) return Math.floor(s / 60) + 'm ago';
  if (s < 86400) return Math.floor(s / 3600) + 'h ago'; return Math.floor(s / 86400) + 'd ago';
}
function fmt(d: any): string { return d ? new Date(d).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day: 'numeric', month: 'short', hour: 'numeric', minute: '2-digit' }) : '-'; }
const handle = target.internal_handle || null;
const photo = target.photo_url || null;
---
<AdminLayout title={'Profile - ' + (target.name || target.email)} activeNav="users">
  <div class="admin-page" style="max-width:1000px;">
    <a href="/admin/users" style="font-size:11px;color:#FF7040;text-decoration:none;font-weight:600;">&lt; All users</a>

    <div style="display:flex;gap:16px;align-items:center;margin:12px 0 18px;flex-wrap:wrap;">
      {photo ? (
        <img src={photo} alt={target.name} style="width:72px;height:72px;border-radius:50%;object-fit:cover;border:2px solid #FF4F00;" />
      ) : (
        <div style="width:72px;height:72px;border-radius:50%;background:rgba(255,79,0,0.15);display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:800;color:#FF7040;">{(target.name || '?').charAt(0).toUpperCase()}</div>
      )}
      <div>
        <h1 style="font-size:20px;font-weight:800;color:#fff;margin:0;">{target.name || 'Unnamed'}</h1>
        <p style="font-size:12.5px;color:#a0a0ab;margin:4px 0 0;">{ROLE_LABELS[target.role] || target.role} · {target.email}{handle ? ' · @' + handle : ''}</p>
        <p style="font-size:11.5px;color:#6e6e78;margin:4px 0 0;">
          {target.photo_verified ? <span style="color:#6ee7b7;">Photo verified (ID + face)</span> : <span style="color:#fbbf24;">Photo not yet verified</span>}
          {' · '}Last login: {ago(target.last_login_at)} · {target.is_active ? 'active' : 'inactive'}
        </p>
      </div>
    </div>

    {emp && (
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:16px;margin-bottom:14px;">
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;">
          <p style="font-size:13px;font-weight:700;color:#fff;margin:0;">Live status today</p>
          <span style={'font-size:12px;font-weight:700;' + (liveStatus === 'Working' ? 'color:#6ee7b7;' : liveStatus === 'On break' ? 'color:#fbbf24;' : 'color:#8a8a94;')}>● {liveStatus}{lastClock ? ' · ' + fmt(lastClock.event_time) : ''}</span>
        </div>
        {clockToday.length > 0 && (
          <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:8px;">
            {clockToday.map((c: any) => <span style="font-size:11px;color:#a0a0ab;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:3px 8px;">{c.event_type.replace('_', ' ')} {new Date(c.event_time).toLocaleTimeString('en-IN', { timeZone: 'Asia/Kolkata', hour: 'numeric', minute: '2-digit' })}</span>)}
          </div>
        )}
        {reportToday ? (
          <div style="margin-top:10px;border-top:1px solid #1a1a1f;padding-top:10px;">
            <p style="font-size:11px;color:#6e6e78;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 4px;">Today's report</p>
            <p style="font-size:12.5px;color:#d8d8de;margin:0;white-space:pre-wrap;">{reportToday.work_done}</p>
            {reportToday.progress && <p style="font-size:12px;color:#a0a0ab;margin:6px 0 0;">Progress: {reportToday.progress}</p>}
          </div>
        ) : (
          <p style="font-size:11.5px;color:#fbbf24;margin:10px 0 0;">No daily report submitted today.</p>
        )}
      </div>
    )}

    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:16px;">
      <p style="font-size:13px;font-weight:700;color:#fff;margin:0 0 10px;">Recent activity ({activity.length})</p>
      {activity.length === 0 ? (
        <p style="font-size:12.5px;color:#6e6e78;">No recorded activity yet.</p>
      ) : (
        <div style="display:flex;flex-direction:column;">
          {activity.map((a: any) => (
            <div style="display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid #151519;font-size:12.5px;">
              <span style="color:#FF7040;font-family:monospace;min-width:150px;">{a.action}</span>
              <span style="color:#a0a0ab;flex:1;">{a.entity}{a.entity_id ? ' · ' + String(a.entity_id).slice(0, 8) : ''}</span>
              <span style="color:#6e6e78;white-space:nowrap;">{fmt(a.created_at)}</span>
            </div>
          ))}
        </div>
      )}
      <p style="font-size:10.5px;color:#6e6e78;margin-top:10px;">Activity updates on refresh. Visible to super admin, HR, and the reporting authority.</p>
    </div>
  </div>
</AdminLayout>
