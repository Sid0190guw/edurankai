---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

let okMsg = '', errorMsg = '';

function slugify(s: string) {
  return s.toLowerCase().replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '').substring(0,60);
}

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  try {
    if (action === 'create_test') {
      const title = (fd.get('title') as string || '').trim();
      const description = (fd.get('description') as string || '').trim();
      const testType = fd.get('test_type') as string || 'mixed';
      const durationMins = parseInt(fd.get('duration_mins') as string || '60');
      const passMark = parseInt(fd.get('pass_mark') as string || '50');
      const visibility = fd.get('visibility') as string || 'public';
      const proctoringEnabled = fd.get('proctoring_enabled') === 'on';
      const slug = slugify(title) + '-' + Math.random().toString(36).substring(2,6);

      const r = await db.execute(sql`
        INSERT INTO tests (title, slug, description, test_type, duration_mins, pass_mark, proctoring_enabled, instructions, created_by, is_published)
        VALUES (${title}, ${slug}, ${description}, ${testType}, ${durationMins}, ${passMark}, ${proctoringEnabled}, ${(fd.get('instructions') as string)||null}, ${user.id}, false)
        RETURNING id
      `);
      const rows = Array.isArray(r) ? r : (r?.rows || []);
      return Astro.redirect('/admin/tests/' + (rows[0] as any).id);
    } else if (action === 'publish') {
      await db.execute(sql`UPDATE tests SET is_published = true, updated_at = NOW() WHERE id = ${fd.get('id') as string}`);
      okMsg = 'Test published.';
    } else if (action === 'unpublish') {
      await db.execute(sql`UPDATE tests SET is_published = false, updated_at = NOW() WHERE id = ${fd.get('id') as string}`);
      okMsg = 'Test unpublished.';
    } else if (action === 'delete') {
      await db.execute(sql`DELETE FROM tests WHERE id = ${fd.get('id') as string}`);
      okMsg = 'Test deleted.';
    }
  } catch(e: any) { errorMsg = e.message; }
}

let tests: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT t.*,
      (SELECT COUNT(*)::int FROM test_questions WHERE test_id = t.id) as question_count,
      (SELECT COUNT(*)::int FROM test_attempts WHERE test_id = t.id AND status IN ('submitted','auto_submitted')) as attempt_count
    FROM tests t
    ORDER BY t.created_at DESC
  `);
  tests = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

const urlP = new URL(Astro.request.url);
const showNew = urlP.searchParams.get('new') === '1';
---
<AdminLayout title="Tests & Assessments" activeNav="hr">
<div style="padding-bottom:80px;">
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;display:flex;align-items:center;justify-content:space-between;">
    <div>
      <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">Recruitment + Aquintutor</p>
      <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Tests & Assessments</h1>
    </div>
    <a href="?new=1" style="background:#FF4F00;border:none;color:#fff;font-size:12px;font-weight:600;padding:8px 14px;border-radius:8px;text-decoration:none;">+ New Test</a>
  </div>

  {errorMsg && <div style="margin:10px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  {showNew && (
    <div style="padding:14px 16px;">
      <form method="POST" style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:18px;display:flex;flex-direction:column;gap:12px;max-width:680px;">
        <input type="hidden" name="action" value="create_test"/>
        <h2 style="font-size:16px;font-weight:700;color:#fff;margin:0;">Create New Test</h2>

        <div>
          <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:6px;">Title</label>
          <input name="title" required placeholder="e.g. Python Basics, Quantum Science 101" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;"/>
        </div>

        <div>
          <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:6px;">Description</label>
          <textarea name="description" rows="2" placeholder="What does this test cover?" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;resize:vertical;font-family:inherit;"></textarea>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;">
          <div>
            <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:6px;">Type</label>
            <select name="test_type" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
              <option value="mixed">Mixed</option>
              <option value="mcq">MCQ only</option>
              <option value="coding">Coding</option>
              <option value="subjective">Subjective</option>
              <option value="aptitude">Aptitude</option>
              <option value="personality">Personality</option>
              <option value="video">Video Response</option>
            </select>
          </div>
          <div>
            <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:6px;">Duration (min)</label>
            <input name="duration_mins" type="number" value="60" min="5" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;"/>
          </div>
          <div>
            <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:6px;">Pass mark (%)</label>
            <input name="pass_mark" type="number" value="50" min="0" max="100" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;"/>
          </div>
        </div>

        <div>
          <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:6px;">Visibility</label>
          <select name="visibility" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
            <option value="public">Public (Aquintutor - anyone can take)</option>
            <option value="recruitment">Recruitment only (invite link)</option>
            <option value="course">Course-linked (course certification)</option>
          </select>
        </div>

        <div>
          <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:6px;">Instructions</label>
          <textarea name="instructions" rows="3" placeholder="Rules, what to expect, do's and don'ts..." style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;resize:vertical;font-family:inherit;"></textarea>
        </div>

        <label style="display:flex;align-items:center;gap:8px;font-size:13px;color:#fff;cursor:pointer;">
          <input type="checkbox" name="proctoring_enabled" style="accent-color:#FF4F00;width:16px;height:16px;"/>
          Enable proctoring (webcam + tab-switch detection + face match)
        </label>

        <div style="display:flex;gap:8px;">
          <a href="/admin/tests" style="flex:1;background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;font-size:13px;padding:11px;border-radius:8px;text-decoration:none;text-align:center;">Cancel</a>
          <button type="submit" style="flex:2;background:#FF4F00;border:none;color:#fff;font-size:14px;font-weight:700;padding:11px;border-radius:8px;cursor:pointer;">Create Test - Add Questions</button>
        </div>
      </form>
    </div>
  )}

  {!showNew && (
    <div style="padding:14px 16px;">
      {tests.length === 0 ? (
        <div style="text-align:center;padding:48px 24px;background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;color:#6e6e78;">
          <p style="font-size:14px;font-weight:600;color:#fff;margin-bottom:6px;">No tests yet</p>
          <p style="font-size:12px;margin-bottom:14px;">Create your first test - MCQs, coding tests, aptitude, anything.</p>
          <a href="?new=1" style="background:#FF4F00;color:#fff;text-decoration:none;font-size:12px;font-weight:600;padding:9px 18px;border-radius:8px;">+ Create First Test</a>
        </div>
      ) : (
        <div style="display:flex;flex-direction:column;gap:8px;">
          {tests.map((t: any) => (
            <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
              <div style="padding:14px;">
                <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:10px;margin-bottom:8px;flex-wrap:wrap;">
                  <div style="flex:1;min-width:200px;">
                    <div style="display:flex;align-items:center;gap:6px;margin-bottom:6px;flex-wrap:wrap;">
                      <span style={`font-size:9px;font-weight:700;padding:2px 8px;border-radius:100px;background:${t.is_published?'rgba(16,185,129,0.15)':'rgba(251,191,36,0.15)'};color:${t.is_published?'#6ee7b7':'#fbbf24'};text-transform:uppercase;`}>{t.is_published ? 'Published' : 'Draft'}</span>
                      <span style="font-size:9px;background:#15151a;color:#8a8a94;padding:2px 8px;border-radius:100px;text-transform:uppercase;">{t.test_type}</span>
                      {t.proctoring_enabled && <span style="font-size:9px;background:rgba(239,68,68,0.1);color:#fca5a5;padding:2px 8px;border-radius:100px;">Proctored</span>}
                    </div>
                    <p style="font-size:15px;font-weight:700;color:#fff;margin:0 0 2px;">{t.title}</p>
                    {t.description && <p style="font-size:12px;color:#8a8a94;margin:0;">{t.description}</p>}
                  </div>
                  <div style="display:flex;gap:14px;flex-shrink:0;font-size:11px;">
                    <div style="text-align:center;">
                      <p style="font-size:16px;font-weight:800;color:#fff;margin:0;font-family:monospace;">{t.question_count}</p>
                      <p style="font-size:9px;color:#6e6e78;margin:0;text-transform:uppercase;">Questions</p>
                    </div>
                    <div style="text-align:center;">
                      <p style="font-size:16px;font-weight:800;color:#FF7040;margin:0;font-family:monospace;">{t.attempt_count}</p>
                      <p style="font-size:9px;color:#6e6e78;margin:0;text-transform:uppercase;">Attempts</p>
                    </div>
                    <div style="text-align:center;">
                      <p style="font-size:16px;font-weight:800;color:#fff;margin:0;font-family:monospace;">{t.duration_mins}</p>
                      <p style="font-size:9px;color:#6e6e78;margin:0;text-transform:uppercase;">Mins</p>
                    </div>
                  </div>
                </div>
                <div style="display:flex;gap:5px;flex-wrap:wrap;">
                  <a href={`/admin/tests/${t.id}`} style="background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;font-size:11px;padding:6px 12px;border-radius:6px;text-decoration:none;">Edit Questions</a>
                  {t.is_published && <a href={`/aquintutor/test/${t.slug}`} target="_blank" style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;font-size:11px;padding:6px 12px;border-radius:6px;text-decoration:none;">Preview Public Link</a>}
                  <a href={`/admin/tests/${t.id}/results`} style="background:#15151a;border:1px solid #1a1a1f;color:#FF7040;font-size:11px;padding:6px 12px;border-radius:6px;text-decoration:none;">Results ({t.attempt_count})</a>
                  {t.is_published ? (
                    <form method="POST" style="display:inline;"><input type="hidden" name="action" value="unpublish"/><input type="hidden" name="id" value={t.id}/><button type="submit" style="background:#15151a;border:1px solid #1a1a1f;color:#fbbf24;font-size:11px;padding:6px 12px;border-radius:6px;cursor:pointer;">Unpublish</button></form>
                  ) : (
                    t.question_count > 0 && <form method="POST" style="display:inline;"><input type="hidden" name="action" value="publish"/><input type="hidden" name="id" value={t.id}/><button type="submit" style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;font-size:11px;font-weight:600;padding:6px 12px;border-radius:6px;cursor:pointer;">Publish</button></form>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  )}
</div>
</AdminLayout>
