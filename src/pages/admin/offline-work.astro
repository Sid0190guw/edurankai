---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

function rows(r: any) { return Array.isArray(r) ? r : (r?.rows || []); }

const kind = (Astro.url.searchParams.get('kind') || '').trim();

let items: any[] = [];
let kinds: string[] = [];
try {
  await db.execute(sql`CREATE TABLE IF NOT EXISTS offline_work (
    client_id text PRIMARY KEY, user_id uuid, kind text, payload jsonb,
    created_at timestamptz, synced_at timestamptz NOT NULL DEFAULT now()
  )`);
  kinds = rows(await db.execute(sql`SELECT DISTINCT kind FROM offline_work ORDER BY kind`)).map((r: any) => r.kind).filter(Boolean);
  const base = sql`SELECT w.client_id, w.kind, w.payload, w.created_at, w.synced_at, u.name AS user_name, u.email AS user_email
    FROM offline_work w LEFT JOIN users u ON u.id = w.user_id`;
  const q = kind
    ? sql`${base} WHERE w.kind = ${kind} ORDER BY w.created_at DESC LIMIT 300`
    : sql`${base} ORDER BY w.created_at DESC LIMIT 300`;
  items = rows(await db.execute(q));
} catch (_) {}

function fmt(d: any) { try { return d ? new Date(d).toLocaleString() : ''; } catch { return ''; } }
function summarize(p: any): string {
  if (!p) return '';
  if (typeof p === 'string') { try { p = JSON.parse(p); } catch { return p; } }
  return Object.keys(p).map((k) => `${k}: ${typeof p[k] === 'object' ? JSON.stringify(p[k]) : p[k]}`).join('  ·  ');
}
---
<AdminLayout title="Offline work" activeNav="">
  <div style="max-width:1000px;">
    <h1 style="font-size:24px;font-weight:700;margin:0 0 4px;">Offline work</h1>
    <p style="font-size:14px;color:#8a8a94;margin:0 0 18px;">Work captured by users on their devices (with or without a connection) and synced here. {items.length} record{items.length === 1 ? '' : 's'}.</p>

    {kinds.length > 0 && (
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;">
        <a href="/admin/offline-work" class="ow-chip" style={!kind ? 'background:#FF7040;color:#fff;border-color:#FF7040;' : ''}>All</a>
        {kinds.map((k) => (
          <a href={`/admin/offline-work?kind=${encodeURIComponent(k)}`} class="ow-chip" style={kind === k ? 'background:#FF7040;color:#fff;border-color:#FF7040;' : ''}>{k}</a>
        ))}
      </div>
    )}

    {items.length === 0 ? (
      <p style="color:#8a8a94;font-size:14px;">Nothing synced yet.</p>
    ) : (
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead>
            <tr style="text-align:left;color:#8a8a94;border-bottom:1px solid rgba(0,0,0,0.1);">
              <th style="padding:8px 10px;">User</th>
              <th style="padding:8px 10px;">Type</th>
              <th style="padding:8px 10px;">Details</th>
              <th style="padding:8px 10px;white-space:nowrap;">Logged</th>
              <th style="padding:8px 10px;white-space:nowrap;">Synced</th>
            </tr>
          </thead>
          <tbody>
            {items.map((it) => (
              <tr style="border-bottom:1px solid rgba(0,0,0,0.06);vertical-align:top;">
                <td style="padding:8px 10px;"><div style="font-weight:600;">{it.user_name || '—'}</div><div style="color:#8a8a94;font-size:12px;">{it.user_email || ''}</div></td>
                <td style="padding:8px 10px;"><span class="ow-chip" style="font-size:11px;">{it.kind}</span></td>
                <td style="padding:8px 10px;max-width:420px;">{summarize(it.payload)}</td>
                <td style="padding:8px 10px;white-space:nowrap;color:#8a8a94;">{fmt(it.created_at)}</td>
                <td style="padding:8px 10px;white-space:nowrap;color:#8a8a94;">{fmt(it.synced_at)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>

  <style>
    .ow-chip { display:inline-block; border:1px solid rgba(0,0,0,0.15); border-radius:100px; padding:4px 12px; font-size:12px; font-weight:600; color:#374151; text-decoration:none; }
  </style>
</AdminLayout>
