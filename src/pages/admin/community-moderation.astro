---
// /admin/community-moderation — kernel discussion report queue (Prompt 20, admin surface). Gated by
// can(delete, discussion) = moderator. Review reports, remove posts, dismiss reports.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { moderatorQueue } from '@/lib/edu-community';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'delete', { type: 'discussion' });
if (!gate.allow) return Astro.redirect('/admin');
const queue = await moderatorQueue(50).catch(() => []);
const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:12px;';
function fmt(d: any) { try { return new Date(d).toLocaleString('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); } catch { return '-'; } }
---
<AdminLayout title="Discussion moderation" activeNav="community-moderation">
  <div style="max-width:900px;margin:0 auto;padding:24px;">
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0 0 4px;">Discussion moderation</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:0 0 16px;">Reported posts awaiting review. Removing a post hides it from students.</p>
    <div id="msg" style="display:none;margin:0 0 12px;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    {queue.length === 0 ? <p style="font-size:13px;color:#6e6e78;">Nothing in the queue.</p> :
      queue.map((r: any) => (
        <div style={CARD}>
          <div style="display:flex;justify-content:space-between;gap:8px;margin-bottom:6px;"><span style="font-size:12px;color:#cfd6da;">Post by <b>{r.author || 'user'}</b> · reported by {r.reporter || 'user'}</span><span style="font-family:'Geist Mono',monospace;font-size:10.5px;color:#8a8a94;">{fmt(r.created_at)}</span></div>
          {r.reason ? <p style="font-size:11.5px;color:#c0a35e;margin:0 0 8px;">Reason: {r.reason}</p> : null}
          <div style="background:#08080a;border:1px solid #26262c;border-radius:8px;padding:10px 12px;font-size:12.5px;color:#cfd6da;margin-bottom:8px;white-space:pre-wrap;">{r.body}</div>
          <div style="display:flex;gap:6px;">
            {!r.removed ? <button class="rm" data-id={r.post_id} type="button" style="background:#2a1414;border:1px solid #5f2f2f;color:#fca5a5;font-size:11px;font-weight:700;padding:6px 12px;border-radius:6px;cursor:pointer;">Remove post</button> : <span style="font-size:11px;color:#fca5a5;">already removed</span>}
            <button class="ds" data-id={r.id} type="button" style="background:#15151a;border:1px solid #26262c;color:#cfd6da;font-size:11px;padding:6px 12px;border-radius:6px;cursor:pointer;">Dismiss report</button>
          </div>
        </div>
      ))}
  </div>
  <script is:inline>
    (function () {
      var msg = document.getElementById('msg');
      function post(body) { return fetch('/api/admin/moderation', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }).then(function (r) { return r.json(); }); }
      function done(j) { msg.style.display = 'block'; msg.textContent = j.ok ? 'Done.' : (j.error || 'Failed'); msg.style.background = j.ok ? 'rgba(16,185,129,0.12)' : 'rgba(239,68,68,0.12)'; msg.style.color = j.ok ? '#6ee7b7' : '#fca5a5'; if (j.ok) setTimeout(function () { location.reload(); }, 500); }
      document.querySelectorAll('.rm').forEach(function (b) { b.addEventListener('click', function () { post({ action: 'remove', postId: b.getAttribute('data-id') }).then(done); }); });
      document.querySelectorAll('.ds').forEach(function (b) { b.addEventListener('click', function () { post({ action: 'dismiss', reportId: b.getAttribute('data-id') }).then(done); }); });
    })();
  </script>
</AdminLayout>
