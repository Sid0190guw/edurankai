---
import { randomBytes } from 'node:crypto';
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { users, departments } from '@/lib/db/schema';
import { can, ROLE_LABELS, DEPARTMENT_SCOPED_ROLES } from '@/lib/auth/permissions';
import { hashPassword } from '@/lib/auth/password';
import { logAudit } from '@/lib/audit';
import { asc, eq, desc } from 'drizzle-orm';
import { sql } from 'drizzle-orm';

const currentUser = Astro.locals.user!;
if (!can(currentUser, 'users.view')) return Astro.redirect('/admin');
const canEdit = can(currentUser, 'users.edit');

let errorMsg = '';
let okMsg = '';

const ALL_PAGES = [
  { id: 'dashboard', label: 'Dashboard', group: 'Core' },
  { id: 'applications', label: 'Applications', group: 'Core' },
  { id: 'offers', label: 'Offer Letters', group: 'Core' },
  { id: 'roles', label: 'Roles', group: 'Core' },
  { id: 'events', label: 'Events', group: 'Core' },
  { id: 'content', label: 'Content Pages', group: 'Core' },
  { id: 'products', label: 'Products', group: 'Core' },
  { id: 'hr', label: 'HR Overview', group: 'HR' },
  { id: 'hr.employees', label: 'Employees', group: 'HR' },
  { id: 'hr.leave', label: 'Leave', group: 'HR' },
  { id: 'hr.attendance', label: 'Attendance', group: 'HR' },
  { id: 'hr.payroll', label: 'Payroll', group: 'HR' },
  { id: 'hei', label: 'HEI Dashboard', group: 'HEI' },
  { id: 'hei.institutions', label: 'Institutions', group: 'HEI' },
  { id: 'hei.findings', label: 'Findings', group: 'HEI' },
  { id: 'hei.leads', label: 'Lead Queue', group: 'HEI' },
  { id: 'hei.surveys', label: 'Surveys', group: 'HEI' },
  { id: 'hei.rti', label: 'RTI Tracker', group: 'HEI' },
  { id: 'messages', label: 'DMs', group: 'Comms' },
  { id: 'chat', label: 'Discussion', group: 'Comms' },
  { id: 'notifications', label: 'Notifications', group: 'Comms' },
  { id: 'mail', label: 'Mail', group: 'Comms' },
  { id: 'users', label: 'Users', group: 'Admin' },
  { id: 'departments', label: 'Departments', group: 'Admin' },
  { id: 'settings', label: 'Settings', group: 'Admin' },
  { id: 'permissions', label: 'Permissions', group: 'Admin' },
  { id: 'audit', label: 'Audit Log', group: 'Admin' },
  { id: 'sections', label: 'Custom Sections', group: 'Admin' },
];

const PAGE_GROUPS = [...new Set(ALL_PAGES.map(p => p.group))];

function makeTempPassword(): string {
  const adj = ['Bharat', 'Frontier', 'Quantum', 'Rooted', 'Honest', 'Curious'];
  const noun = ['Lab', 'Index', 'Vector', 'Beam', 'River', 'Anchor'];
  const b = randomBytes(4);
  const digit = (b.readUInt16BE(0) % 9000) + 1000;
  return adj[b[2] % adj.length] + noun[b[3] % noun.length] + digit + '!';
}

if (Astro.request.method === 'POST' && canEdit) {
  const fd = await Astro.request.formData();
  const action = fd.get('_action') as string;
  try {
    if (action === 'create') {
      const username = (fd.get('username') as string || '').trim().toLowerCase();
      const name = (fd.get('name') as string || '').trim();
      const role = fd.get('role') as string;
      const assignedDepartmentId = (fd.get('assignedDepartmentId') as string || '').trim() || null;
      const customPassword = (fd.get('password') as string || '').trim();
      if (!username || !name || !role) { errorMsg = 'Username, name, and role required.'; }
      else {
        const finalEmail = username.includes('@') ? username : username + '@edurankai.in';
        const existing = await db.select({ id: users.id }).from(users).where(eq(users.email, finalEmail)).limit(1);
        if (existing.length > 0) { errorMsg = `"${finalEmail}" already exists.`; }
        else {
          const plainPassword = customPassword || makeTempPassword();
          const passwordHash = await hashPassword(plainPassword);
          const inserted = await db.insert(users).values({
            email: finalEmail, passwordHash, name, role: role as any,
            assignedDepartmentId, emailVerified: true, isActive: true
          }).returning({ id: users.id });
          const newUserId = inserted[0].id;

          // Save page permissions
          for (const page of ALL_PAGES) {
            const canView = fd.get(`perm_${page.id}_view`) === 'on';
            const canEditPerm = fd.get(`perm_${page.id}_edit`) === 'on';
            if (canView || canEditPerm) {
              await db.execute(sql`
                INSERT INTO user_page_permissions (user_id, page_id, can_view, can_edit, updated_by)
                VALUES (${newUserId}, ${page.id}, ${canView}, ${canEditPerm}, ${currentUser.id})
                ON CONFLICT (user_id, page_id) DO UPDATE SET can_view=${canView}, can_edit=${canEditPerm}
              `);
            }
          }

          await logAudit({ userId: currentUser.id, action: 'user.create', entity: 'user', entityId: newUserId, diff: { email: finalEmail, role }, ipAddress: Astro.clientAddress });
          okMsg = `Created: ${finalEmail}\nPassword: ${plainPassword}\n\nSave this password - shown once only.`;
        }
      }
    } else if (action === 'update_permissions') {
      const userId = fd.get('userId') as string;
      // Clear existing
      await db.execute(sql`DELETE FROM user_page_permissions WHERE user_id = ${userId}`);
      // Insert new
      for (const page of ALL_PAGES) {
        const canView = fd.get(`perm_${page.id}_view`) === 'on';
        const canEditPerm = fd.get(`perm_${page.id}_edit`) === 'on';
        if (canView || canEditPerm) {
          await db.execute(sql`
            INSERT INTO user_page_permissions (user_id, page_id, can_view, can_edit, updated_by)
            VALUES (${userId}, ${page.id}, ${canView}, ${canEditPerm}, ${currentUser.id})
          `);
        }
      }
      okMsg = 'Page permissions updated.';
    } else if (action === 'toggle_active') {
      const userId = fd.get('userId') as string;
      if (userId === currentUser.id) { errorMsg = "You can't deactivate yourself."; }
      else {
        const target = await db.select({ isActive: users.isActive }).from(users).where(eq(users.id, userId)).limit(1);
        if (target.length > 0) {
          await db.update(users).set({ isActive: !target[0].isActive, updatedAt: new Date() }).where(eq(users.id, userId));
          okMsg = target[0].isActive ? 'User deactivated.' : 'User reactivated.';
        }
      }
    } else if (action === 'change_role') {
      const userId = fd.get('userId') as string;
      const newRole = fd.get('role') as string;
      const newDept = (fd.get('assignedDepartmentId') as string || '').trim() || null;
      if (userId === currentUser.id) { errorMsg = "You can't change your own role."; }
      else {
        await db.update(users).set({ role: newRole as any, assignedDepartmentId: newDept, updatedAt: new Date() }).where(eq(users.id, userId));
        okMsg = 'Role updated.';
      }
    }
  } catch (err: any) { errorMsg = 'Failed: ' + (err.message || 'Unknown'); }
}

const url = new URL(Astro.request.url);
const filter = url.searchParams.get('filter') || 'admins';
const editPermId = url.searchParams.get('editperms') || '';

const allUsers = await db.select().from(users).orderBy(desc(users.createdAt));
let filteredUsers = allUsers;
if (filter === 'admins') filteredUsers = allUsers.filter(u => u.role !== 'applicant');
else if (filter === 'applicants') filteredUsers = allUsers.filter(u => u.role === 'applicant');
else if (filter === 'inactive') filteredUsers = allUsers.filter(u => !u.isActive);

const allDepts = await db.select().from(departments).orderBy(asc(departments.sortOrder));
const deptMap = Object.fromEntries(allDepts.map(d => [d.id, d.name]));

const counts = {
  admins: allUsers.filter(u => u.role !== 'applicant').length,
  applicants: allUsers.filter(u => u.role === 'applicant').length,
  inactive: allUsers.filter(u => !u.isActive).length,
  total: allUsers.length
};

const ROLES_AVAILABLE = Object.keys(ROLE_LABELS).filter(r => r !== 'applicant');
const ROLE_COLOR: Record<string, string> = {
  super_admin: '#f97316', admin: '#FF4F00', editor: '#60a5fa',
  reviewer: '#34d399', recruiter: '#a78bfa', marketing: '#fbbf24',
  department_head: '#f59e0b', applicant: '#6b7280',
};

// Load perms for user being edited
let editingUserPerms: Record<string, { view: boolean; edit: boolean }> = {};
if (editPermId) {
  try {
    const r = await db.execute(sql`SELECT page_id, can_view, can_edit FROM user_page_permissions WHERE user_id = ${editPermId}`);
    const rows = Array.isArray(r) ? r : (r?.rows || []);
    for (const row of rows as any[]) {
      editingUserPerms[row.page_id] = { view: row.can_view, edit: row.can_edit };
    }
  } catch(e) {}
}
const editingUser = editPermId ? allUsers.find(u => u.id === editPermId) : null;
---
<AdminLayout title="Users" activeNav="users">
<div style="padding-bottom:80px;">

  <!-- Header -->
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
      <div>
        <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">Access Control</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Users</h1>
      </div>
      {canEdit && (
        <button onclick="document.getElementById('addUserModal').style.display='flex'" style="background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:12px;padding:8px 14px;border-radius:8px;cursor:pointer;">+ Add User</button>
      )}
    </div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:12px;">
      {[
        { label: 'Total', value: counts.total, color: '#fff' },
        { label: 'Admins', value: counts.admins, color: '#FF7040' },
        { label: 'Applicants', value: counts.applicants, color: '#60a5fa' },
        { label: 'Inactive', value: counts.inactive, color: '#ef4444' },
      ].map(s => (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:8px;padding:8px;text-align:center;">
          <p style={`font-size:18px;font-weight:700;color:${s.color};margin:0;line-height:1;`}>{s.value}</p>
          <p style="font-size:9px;color:#6e6e78;margin:2px 0 0;text-transform:uppercase;">{s.label}</p>
        </div>
      ))}
    </div>
    <div style="display:flex;gap:6px;overflow-x:auto;">
      {[['admins',`Admins (${counts.admins})`],['applicants',`Applicants (${counts.applicants})`],['inactive',`Inactive (${counts.inactive})`],['all',`All (${counts.total})`]].map(([v,l]) => (
        <a href={`?filter=${v}`} style={`text-decoration:none;font-size:11px;font-weight:600;padding:5px 12px;border-radius:100px;white-space:nowrap;flex-shrink:0;${filter === v ? 'background:#FF4F00;color:#fff;' : 'background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;'}`}>{l}</a>
      ))}
    </div>
  </div>

  {errorMsg && <div style="margin:10px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:12px;font-family:'Geist Mono',monospace;white-space:pre-line;word-break:break-all;">{okMsg}</div>}

  <!-- User cards -->
  <div style="padding:12px 16px;display:flex;flex-direction:column;gap:8px;">
    {filteredUsers.map(u => {
      const roleColor = ROLE_COLOR[u.role || ''] || '#6b7280';
      const roleLabel = ROLE_LABELS[u.role as keyof typeof ROLE_LABELS] || u.role;
      const initial = (u.name || u.email || '?').substring(0,1).toUpperCase();
      const isMe = u.id === currentUser.id;
      return (
        <div style={`background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;${!u.isActive ? 'opacity:0.6;' : ''}`}>
          <div style="padding:12px 14px;display:flex;align-items:flex-start;gap:10px;">
            <div style={`width:42px;height:42px;border-radius:50%;background:${roleColor}33;border:1px solid ${roleColor}44;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;color:${roleColor};flex-shrink:0;`}>{initial}</div>
            <div style="flex:1;min-width:0;">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:6px;margin-bottom:4px;">
                <div style="min-width:0;">
                  <p style="font-size:14px;font-weight:600;color:#fff;margin:0;">{u.name || '-'} {isMe && <span style="font-size:10px;color:#6e6e78;">(you)</span>}</p>
                  <p style="font-size:11px;color:#6e6e78;margin:2px 0 0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{u.email}</p>
                </div>
                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;">
                  <span style={`font-size:9px;font-weight:700;padding:2px 8px;border-radius:100px;background:${roleColor}22;color:${roleColor};border:1px solid ${roleColor}33;`}>{roleLabel}</span>
                  {!u.isActive && <span style="font-size:9px;background:#1a1a1f;color:#6e6e78;padding:2px 6px;border-radius:4px;">inactive</span>}
                </div>
              </div>
              {u.assignedDepartmentId && deptMap[u.assignedDepartmentId] && (
                <p style="font-size:10px;color:#8a8a94;margin:0;">Dept: {deptMap[u.assignedDepartmentId]}</p>
              )}
            </div>
          </div>

          {canEdit && !isMe && (
            <div style="border-top:1px solid #1a1a1f;padding:8px 14px;display:flex;flex-direction:column;gap:8px;">
              <!-- Role change -->
              <form method="POST" style="display:flex;gap:6px;align-items:center;">
                <input type="hidden" name="_action" value="change_role" />
                <input type="hidden" name="userId" value={u.id} />
                <select name="role" style="flex:1;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:6px 8px;color:#fff;font-size:11px;outline:none;">
                  {ROLES_AVAILABLE.map(r => <option value={r} selected={u.role === r}>{ROLE_LABELS[r as keyof typeof ROLE_LABELS]}</option>)}
                </select>
                <select name="assignedDepartmentId" style="flex:1;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:6px 8px;color:#fff;font-size:11px;outline:none;">
                  <option value="">No dept</option>
                  {allDepts.map(d => <option value={d.id} selected={u.assignedDepartmentId === d.id}>{d.name}</option>)}
                </select>
                <button type="submit" style="background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;font-size:11px;padding:6px 10px;border-radius:6px;cursor:pointer;">Update</button>
              </form>
              <!-- Actions row -->
              <div style="display:flex;gap:6px;">
                <a href={`?filter=${filter}&editperms=${u.id}`} style="flex:1;text-align:center;background:#15151a;border:1px solid #1a1a1f;color:#FF7040;text-decoration:none;font-size:11px;font-weight:600;padding:7px;border-radius:6px;">
                  Page Permissions
                </a>
                <form method="POST" style="flex:1;">
                  <input type="hidden" name="_action" value="toggle_active" />
                  <input type="hidden" name="userId" value={u.id} />
                  <button type="submit" style={`width:100%;font-size:11px;font-weight:500;padding:7px;border-radius:6px;border:none;cursor:pointer;${u.isActive ? 'background:rgba(239,68,68,0.1);color:#fca5a5;' : 'background:rgba(16,185,129,0.1);color:#6ee7b7;'}`}>
                    {u.isActive ? 'Deactivate' : 'Reactivate'}
                  </button>
                </form>
              </div>
            </div>
          )}
        </div>
      );
    })}
  </div>
</div>

<!-- Add User Modal -->
<div id="addUserModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:100;align-items:flex-end;justify-content:center;">
  <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:16px 16px 0 0;width:100%;max-width:600px;max-height:95vh;overflow-y:auto;padding:20px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;position:sticky;top:0;background:#0f0f14;padding-bottom:12px;border-bottom:1px solid #1a1a1f;">
      <h2 style="font-size:15px;font-weight:700;color:#fff;margin:0;">Add Admin User</h2>
      <button onclick="document.getElementById('addUserModal').style.display='none'" style="background:#1a1a1f;border:none;color:#8a8a94;width:30px;height:30px;border-radius:6px;font-size:18px;cursor:pointer;">&times;</button>
    </div>
    <form method="POST" style="display:flex;flex-direction:column;gap:12px;">
      <input type="hidden" name="_action" value="create" />
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Username *</label>
        <input name="username" required placeholder="e.g. ravi or ravi@gmail.com" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
        <p style="font-size:10px;color:#6e6e78;margin:4px 0 0;">No @ needed - we'll append @edurankai.in</p>
      </div>
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Full Name *</label>
        <input name="name" required placeholder="Ravi Kumar" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div>
          <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Role *</label>
          <select name="role" required style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
            <option value="">Choose role...</option>
            {ROLES_AVAILABLE.map(r => <option value={r}>{ROLE_LABELS[r as keyof typeof ROLE_LABELS]}</option>)}
          </select>
        </div>
        <div>
          <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Department</label>
          <select name="assignedDepartmentId" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
            <option value="">No dept (sees all)</option>
            {allDepts.map(d => <option value={d.id}>{d.name}</option>)}
          </select>
        </div>
      </div>
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Password (optional)</label>
        <input name="password" type="text" placeholder="Leave blank to auto-generate" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
      </div>

      <!-- Page permissions grid -->
      <div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
          <label style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#FF7040;">Page Permissions</label>
          <div style="display:flex;gap:6px;">
            <button type="button" onclick="document.querySelectorAll('.perm-view').forEach(c=>c.checked=true)" style="font-size:10px;background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;padding:3px 8px;border-radius:4px;cursor:pointer;">All View</button>
            <button type="button" onclick="document.querySelectorAll('.perm-view,.perm-edit').forEach(c=>c.checked=true)" style="font-size:10px;background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;padding:3px 8px;border-radius:4px;cursor:pointer;">Full Access</button>
            <button type="button" onclick="document.querySelectorAll('.perm-view,.perm-edit').forEach(c=>c.checked=false)" style="font-size:10px;background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;padding:3px 8px;border-radius:4px;cursor:pointer;">Clear</button>
          </div>
        </div>
        {PAGE_GROUPS.map(group => (
          <div style="background:#15151a;border-radius:8px;overflow:hidden;margin-bottom:8px;">
            <div style="padding:7px 10px;background:#1a1a1f;display:flex;align-items:center;justify-content:space-between;">
              <span style="font-size:10px;font-weight:700;text-transform:uppercase;color:#6e6e78;">{group}</span>
              <div style="display:flex;gap:16px;">
                <span style="font-size:9px;color:#6e6e78;width:28px;text-align:center;">View</span>
                <span style="font-size:9px;color:#6e6e78;width:28px;text-align:center;">Edit</span>
              </div>
            </div>
            {ALL_PAGES.filter(p => p.group === group).map(page => (
              <div style="padding:6px 10px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid #0f0f14;">
                <span style="font-size:12px;color:#d8d8de;">{page.label}</span>
                <div style="display:flex;gap:16px;">
                  <div style="width:28px;text-align:center;">
                    <input type="checkbox" name={`perm_${page.id}_view`} class="perm-view" style="accent-color:#FF4F00;width:15px;height:15px;" />
                  </div>
                  <div style="width:28px;text-align:center;">
                    <input type="checkbox" name={`perm_${page.id}_edit`} class="perm-edit" style="accent-color:#FF4F00;width:15px;height:15px;" />
                  </div>
                </div>
              </div>
            ))}
          </div>
        ))}
      </div>

      <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">Create User with Permissions</button>
    </form>
  </div>
</div>

<!-- Edit Permissions Modal -->
{editingUser && (
  <div style="position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:100;overflow-y:auto;padding-top:20px;">
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;width:100%;max-width:600px;margin:0 auto;padding:20px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
        <div>
          <h2 style="font-size:15px;font-weight:700;color:#fff;margin:0;">Page Permissions</h2>
          <p style="font-size:12px;color:#6e6e78;margin:4px 0 0;">{editingUser.name} - {editingUser.email}</p>
        </div>
        <a href={`?filter=${filter}`} style="background:#1a1a1f;border:none;color:#8a8a94;width:30px;height:30px;border-radius:6px;font-size:18px;display:flex;align-items:center;justify-content:center;text-decoration:none;">&times;</a>
      </div>
      <div style="background:rgba(255,79,0,0.08);border:1px solid rgba(255,79,0,0.2);border-radius:8px;padding:10px 12px;margin-bottom:14px;">
        <p style="font-size:11px;color:#FF7040;margin:0;">These are per-user overrides. Super admins always have full access regardless of these settings.</p>
      </div>
      <form method="POST" style="display:flex;flex-direction:column;gap:8px;">
        <input type="hidden" name="_action" value="update_permissions" />
        <input type="hidden" name="userId" value={editingUser.id} />
        <div style="display:flex;justify-content:flex-end;gap:6px;margin-bottom:4px;">
          <button type="button" onclick="document.querySelectorAll('.eperm-view').forEach(c=>c.checked=true)" style="font-size:10px;background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;padding:4px 10px;border-radius:4px;cursor:pointer;">All View</button>
          <button type="button" onclick="document.querySelectorAll('.eperm-view,.eperm-edit').forEach(c=>c.checked=true)" style="font-size:10px;background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;padding:4px 10px;border-radius:4px;cursor:pointer;">Full Access</button>
          <button type="button" onclick="document.querySelectorAll('.eperm-view,.eperm-edit').forEach(c=>c.checked=false)" style="font-size:10px;background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;padding:4px 10px;border-radius:4px;cursor:pointer;">Clear All</button>
        </div>
        {PAGE_GROUPS.map(group => (
          <div style="background:#15151a;border-radius:8px;overflow:hidden;">
            <div style="padding:7px 10px;background:#1a1a1f;display:flex;align-items:center;justify-content:space-between;">
              <span style="font-size:10px;font-weight:700;text-transform:uppercase;color:#6e6e78;">{group}</span>
              <div style="display:flex;gap:16px;">
                <span style="font-size:9px;color:#6e6e78;width:28px;text-align:center;">View</span>
                <span style="font-size:9px;color:#6e6e78;width:28px;text-align:center;">Edit</span>
              </div>
            </div>
            {ALL_PAGES.filter(p => p.group === group).map(page => {
              const perm = editingUserPerms[page.id] || { view: false, edit: false };
              return (
                <div style="padding:7px 10px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid #0f0f14;">
                  <span style="font-size:12px;color:#d8d8de;">{page.label}</span>
                  <div style="display:flex;gap:16px;">
                    <div style="width:28px;text-align:center;">
                      <input type="checkbox" name={`perm_${page.id}_view`} class="eperm-view" style="accent-color:#FF4F00;width:15px;height:15px;" checked={perm.view} />
                    </div>
                    <div style="width:28px;text-align:center;">
                      <input type="checkbox" name={`perm_${page.id}_edit`} class="eperm-edit" style="accent-color:#FF4F00;width:15px;height:15px;" checked={perm.edit} />
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        ))}
        <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;margin-top:8px;">Save Permissions</button>
      </form>
    </div>
  </div>
)}

</AdminLayout>
