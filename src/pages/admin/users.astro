---
import { randomBytes } from 'node:crypto';
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { users, departments } from '@/lib/db/schema';
import { can, ROLE_LABELS, DEPARTMENT_SCOPED_ROLES } from '@/lib/auth/permissions';
import { hashPassword } from '@/lib/auth/password';
import { logAudit } from '@/lib/audit';
import { asc, eq, desc } from 'drizzle-orm';

const currentUser = Astro.locals.user!;
if (!can(currentUser, 'users.view')) return Astro.redirect('/admin');
const canEdit = can(currentUser, 'users.edit');

let errorMsg = '';
let okMsg = '';

function makeTempPassword(): string {
  const adj = ['Bharat', 'Frontier', 'Quantum', 'Rooted', 'Honest', 'Curious'];
  const noun = ['Lab', 'Index', 'Vector', 'Beam', 'River', 'Anchor'];
  const b = randomBytes(4);
  const digit = (b.readUInt16BE(0) % 9000) + 1000;
  return adj[b[2] % adj.length] + noun[b[3] % noun.length] + digit + '!';
}

if (Astro.request.method === 'POST' && canEdit) {
  const fd = await Astro.request.formData();
  const action = fd.get('_action') as string;
  try {
    if (action === 'create') {
      const username = (fd.get('username') as string || '').trim().toLowerCase();
      const name = (fd.get('name') as string || '').trim();
      const role = fd.get('role') as string;
      const assignedDepartmentId = (fd.get('assignedDepartmentId') as string || '').trim() || null;
      const customPassword = (fd.get('password') as string || '').trim();
      if (!username || !name || !role) { errorMsg = 'Username, name, and role required.'; }
      else if (!username.match(/^[a-z0-9._\-@]+$/)) { errorMsg = 'Invalid username format.'; }
      else {
        const finalEmail = username.includes('@') ? username : username + '@edurankai.in';
        const existing = await db.select({ id: users.id }).from(users).where(eq(users.email, finalEmail)).limit(1);
        if (existing.length > 0) { errorMsg = `Username "${finalEmail}" already exists.`; }
        else {
          const plainPassword = customPassword || makeTempPassword();
          const passwordHash = await hashPassword(plainPassword);
          const inserted = await db.insert(users).values({ email: finalEmail, passwordHash, name, role: role as any, assignedDepartmentId, emailVerified: true, isActive: true }).returning({ id: users.id });
          await logAudit({ userId: currentUser.id, action: 'user.create', entity: 'user', entityId: inserted[0].id, diff: { email: finalEmail, role }, ipAddress: Astro.clientAddress });
          okMsg = `✓ Created: ${finalEmail}\n🔑 Password: ${plainPassword}\n\nSave this password now — it won't be shown again.`;
        }
      }
    } else if (action === 'toggle_active') {
      const userId = fd.get('userId') as string;
      if (userId === currentUser.id) { errorMsg = "You can't deactivate yourself."; }
      else {
        const target = await db.select({ isActive: users.isActive }).from(users).where(eq(users.id, userId)).limit(1);
        if (target.length > 0) {
          await db.update(users).set({ isActive: !target[0].isActive, updatedAt: new Date() }).where(eq(users.id, userId));
          okMsg = target[0].isActive ? 'User deactivated.' : 'User re-activated.';
        }
      }
    } else if (action === 'change_role') {
      const userId = fd.get('userId') as string;
      const newRole = fd.get('role') as string;
      const newDept = (fd.get('assignedDepartmentId') as string || '').trim() || null;
      if (userId === currentUser.id) { errorMsg = "You can't change your own role."; }
      else {
        await db.update(users).set({ role: newRole as any, assignedDepartmentId: newDept, updatedAt: new Date() }).where(eq(users.id, userId));
        okMsg = 'Role updated.';
      }
    }
  } catch (err: any) { errorMsg = 'Failed: ' + (err.message || 'Unknown'); }
}

const url = new URL(Astro.request.url);
const filter = url.searchParams.get('filter') || 'admins';

const allUsers = await db.select().from(users).orderBy(desc(users.createdAt));
let filteredUsers = allUsers;
if (filter === 'admins') filteredUsers = allUsers.filter(u => u.role !== 'applicant');
else if (filter === 'applicants') filteredUsers = allUsers.filter(u => u.role === 'applicant');
else if (filter === 'inactive') filteredUsers = allUsers.filter(u => !u.isActive);

const allDepts = await db.select().from(departments).orderBy(asc(departments.sortOrder));
const deptMap = Object.fromEntries(allDepts.map(d => [d.id, d.name]));
const counts = {
  admins: allUsers.filter(u => u.role !== 'applicant').length,
  applicants: allUsers.filter(u => u.role === 'applicant').length,
  inactive: allUsers.filter(u => !u.isActive).length,
  total: allUsers.length
};
const ROLES_AVAILABLE = Object.keys(ROLE_LABELS).filter(r => r !== 'applicant');

const ROLE_COLOR: Record<string, string> = {
  super_admin: '#f97316', admin: '#FF4F00', editor: '#60a5fa',
  reviewer: '#34d399', recruiter: '#a78bfa', marketing: '#fbbf24',
  department_head: '#f59e0b', applicant: '#6b7280',
};
---
<AdminLayout title="Users" activeNav="users">
<div style="padding-bottom:80px;">

  <!-- Header -->
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
      <div>
        <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">Access Control</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Users</h1>
      </div>
      {canEdit && (
        <button onclick="document.getElementById('addUserModal').style.display='flex'" style="background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:12px;padding:8px 14px;border-radius:8px;cursor:pointer;">+ Add User</button>
      )}
    </div>

    <!-- Stats row -->
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:12px;">
      {[
        { label: 'Total', value: counts.total, color: '#fff' },
        { label: 'Admins', value: counts.admins, color: '#FF7040' },
        { label: 'Applicants', value: counts.applicants, color: '#60a5fa' },
        { label: 'Inactive', value: counts.inactive, color: '#ef4444' },
      ].map(s => (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:8px;padding:8px;text-align:center;">
          <p style={`font-size:18px;font-weight:700;color:${s.color};margin:0;line-height:1;`}>{s.value}</p>
          <p style="font-size:9px;color:#6e6e78;margin:2px 0 0;text-transform:uppercase;">{s.label}</p>
        </div>
      ))}
    </div>

    <!-- Filter pills -->
    <div style="display:flex;gap:6px;overflow-x:auto;">
      {[['admins',`Admins (${counts.admins})`],['applicants',`Applicants (${counts.applicants})`],['inactive',`Inactive (${counts.inactive})`],['all',`All (${counts.total})`]].map(([v,l]) => (
        <a href={`?filter=${v}`} style={`text-decoration:none;font-size:11px;font-weight:600;padding:5px 12px;border-radius:100px;white-space:nowrap;flex-shrink:0;${filter === v ? 'background:#FF4F00;color:#fff;' : 'background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;'}`}>{l}</a>
      ))}
    </div>
  </div>

  <!-- Messages -->
  {errorMsg && <div style="margin:10px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:12px;font-family:'Geist Mono',monospace;white-space:pre-line;word-break:break-all;">{okMsg}</div>}

  <!-- User cards -->
  <div style="padding:12px 16px;display:flex;flex-direction:column;gap:8px;">
    {filteredUsers.length === 0 && (
      <div style="text-align:center;padding:48px;color:#6e6e78;">
        <p style="font-size:32px;margin-bottom:8px;">👥</p>
        <p style="font-size:13px;">No users in this view</p>
      </div>
    )}
    {filteredUsers.map(u => {
      const roleColor = ROLE_COLOR[u.role || ''] || '#6b7280';
      const roleLabel = ROLE_LABELS[u.role as keyof typeof ROLE_LABELS] || u.role;
      const initial = (u.name || u.email || '?').substring(0, 1).toUpperCase();
      const isMe = u.id === currentUser.id;
      return (
        <div style={`background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;${!u.isActive ? 'opacity:0.6;' : ''}`}>
          <div style="padding:12px 14px;display:flex;align-items:flex-start;gap:10px;">
            <div style={`width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,${roleColor}33,${roleColor}11);border:1px solid ${roleColor}44;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;color:${roleColor};flex-shrink:0;`}>
              {initial}
            </div>
            <div style="flex:1;min-width:0;">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:6px;margin-bottom:4px;">
                <div style="min-width:0;">
                  <p style="font-size:14px;font-weight:600;color:#fff;margin:0;">{u.name || '—'} {isMe && <span style="font-size:10px;color:#6e6e78;">(you)</span>}</p>
                  <p style="font-size:11px;color:#6e6e78;margin:2px 0 0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{u.email}</p>
                </div>
                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;">
                  <span style={`font-size:9px;font-weight:700;padding:2px 8px;border-radius:100px;text-transform:uppercase;background:${roleColor}22;color:${roleColor};border:1px solid ${roleColor}33;`}>{roleLabel}</span>
                  {!u.isActive && <span style="font-size:9px;background:#1a1a1f;color:#6e6e78;padding:2px 6px;border-radius:4px;">inactive</span>}
                </div>
              </div>
              {u.assignedDepartmentId && deptMap[u.assignedDepartmentId] && (
                <p style="font-size:10px;color:#8a8a94;margin:0;">Dept: {deptMap[u.assignedDepartmentId]}</p>
              )}
              <p style="font-size:10px;color:#6e6e78;margin:4px 0 0;font-family:'Geist Mono',monospace;">{u.internalHandle ? `@${u.internalHandle}` : ''}</p>
            </div>
          </div>

          {canEdit && !isMe && (
            <div style="border-top:1px solid #1a1a1f;padding:8px 14px;display:flex;flex-direction:column;gap:8px;">
              <!-- Change role inline -->
              <form method="POST" style="display:flex;gap:6px;align-items:center;">
                <input type="hidden" name="_action" value="change_role" />
                <input type="hidden" name="userId" value={u.id} />
                <select name="role" style="flex:1;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:6px 8px;color:#fff;font-size:11px;outline:none;">
                  {ROLES_AVAILABLE.map(r => (
                    <option value={r} selected={u.role === r}>{ROLE_LABELS[r as keyof typeof ROLE_LABELS]}</option>
                  ))}
                </select>
                <select name="assignedDepartmentId" style="flex:1;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:6px 8px;color:#fff;font-size:11px;outline:none;">
                  <option value="">No dept</option>
                  {allDepts.map(d => (
                    <option value={d.id} selected={u.assignedDepartmentId === d.id}>{d.name}</option>
                  ))}
                </select>
                <button type="submit" style="background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;font-size:11px;padding:6px 10px;border-radius:6px;cursor:pointer;white-space:nowrap;">Update</button>
              </form>
              <!-- Toggle active -->
              <form method="POST">
                <input type="hidden" name="_action" value="toggle_active" />
                <input type="hidden" name="userId" value={u.id} />
                <button type="submit" style={`width:100%;font-size:12px;font-weight:500;padding:7px;border-radius:6px;border:none;cursor:pointer;${u.isActive ? 'background:rgba(239,68,68,0.1);color:#fca5a5;' : 'background:rgba(16,185,129,0.1);color:#6ee7b7;'}`}>
                  {u.isActive ? 'Deactivate Account' : 'Reactivate Account'}
                </button>
              </form>
            </div>
          )}
        </div>
      );
    })}
  </div>
</div>

<!-- Add User Modal -->
<div id="addUserModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:100;align-items:flex-end;justify-content:center;">
  <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:16px 16px 0 0;width:100%;max-width:600px;max-height:90vh;overflow-y:auto;padding:20px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <h2 style="font-size:15px;font-weight:700;color:#fff;margin:0;">Add Admin User</h2>
      <button onclick="document.getElementById('addUserModal').style.display='none'" style="background:#1a1a1f;border:none;color:#8a8a94;width:30px;height:30px;border-radius:6px;font-size:18px;cursor:pointer;">&times;</button>
    </div>
    <form method="POST" style="display:flex;flex-direction:column;gap:12px;">
      <input type="hidden" name="_action" value="create" />
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Username *</label>
        <input name="username" required placeholder="e.g. hr-recruiter or user@gmail.com" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
        <p style="font-size:10px;color:#6e6e78;margin:4px 0 0;">No @ needed — we'll append @edurankai.in. Or use a full email.</p>
      </div>
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Full Name *</label>
        <input name="name" required placeholder="Ravi Kumar" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
      </div>
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Role *</label>
        <select name="role" required style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
          <option value="">Choose role...</option>
          {ROLES_AVAILABLE.map(r => <option value={r}>{ROLE_LABELS[r as keyof typeof ROLE_LABELS]}</option>)}
        </select>
      </div>
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Department (optional)</label>
        <select name="assignedDepartmentId" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
          <option value="">No department (sees all)</option>
          {allDepts.map(d => <option value={d.id}>{d.name}</option>)}
        </select>
      </div>
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Password (optional)</label>
        <input name="password" type="text" placeholder="Leave blank to auto-generate" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
        <p style="font-size:10px;color:#6e6e78;margin:4px 0 0;">Auto-generated password shown once after creation. Save it immediately.</p>
      </div>
      <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">Create User</button>
    </form>
  </div>
</div>

</AdminLayout>
