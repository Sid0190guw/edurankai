---
import { randomBytes } from 'node:crypto';
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { users, departments, teamRoles, userRoleAssignments } from '@/lib/db/schema';
import { can, ROLE_LABELS, DEPARTMENT_SCOPED_ROLES } from '@/lib/auth/permissions';
import { hashPassword } from '@/lib/auth/password';
import { sendEmail, brandedEmail } from '@/lib/email';
import { logAudit } from '@/lib/audit';
import { asc, eq, desc } from 'drizzle-orm';
import { sql } from 'drizzle-orm';

const currentUser = Astro.locals.user!;
if (!can(currentUser, 'users.view')) {
  return Astro.redirect('/admin');
}
const canEdit = can(currentUser, 'users.edit');

let errorMsg = '';
let okMsg = '';

// Generate a strong temp password
function makeTempPassword(): string {
  const adj = ['Bharat', 'Frontier', 'Quantum', 'Rooted', 'Honest', 'Curious'];
  const noun = ['Lab', 'Index', 'Vector', 'Beam', 'River', 'Anchor'];
  const b = randomBytes(4);
  const digit = (b.readUInt16BE(0) % 9000) + 1000;
  return adj[b[2] % adj.length] + noun[b[3] % noun.length] + digit + '!';
}

if (Astro.request.method === 'POST' && canEdit) {
  const fd = await Astro.request.formData();
  const action = fd.get('_action') as string;

  try {
    if (action === 'create') {
      const username = (fd.get('username') as string || '').trim().toLowerCase();
      const name = (fd.get('name') as string || '').trim();
      const rawRole = (fd.get('role') as string) || '';
      const assignedDepartmentId = (fd.get('assignedDepartmentId') as string || '').trim() || null;
      const customPassword = (fd.get('password') as string || '').trim();
      // If a custom role is chosen, persist users.role as 'editor' as a baseline
      // and capture the custom role id to assign after the user row is created.
      const isCustom = rawRole.startsWith('custom:');
      const customRoleId = isCustom ? rawRole.slice('custom:'.length) : null;
      const role = isCustom ? 'editor' : rawRole;

      if (!username || !name || !rawRole) {
        errorMsg = 'Username, full name, and role are required.';
      } else if (!username.match(/^[a-z0-9._\-@]+$/)) {
        errorMsg = 'Username can only contain lowercase letters, digits, dot, hyphen, underscore, and @.';
      } else {
        const finalEmail = username.includes('@') ? username : username + '@edurankai.in';
        const existing = await db.select({ id: users.id }).from(users).where(eq(users.email, finalEmail)).limit(1);
        if (existing.length > 0) {
          errorMsg = 'Username "' + finalEmail + '" already exists.';
        } else {
          const plainPassword = customPassword || makeTempPassword();
          const passwordHash = await hashPassword(plainPassword);
          const inserted = await db.insert(users).values({
            email: finalEmail,
            passwordHash,
            name,
            role: role as any,
            assignedDepartmentId,
            emailVerified: true,
            isActive: true
          }).returning({ id: users.id });

          if (customRoleId) {
            await db.insert(userRoleAssignments).values({ userId: inserted[0].id, roleId: customRoleId, assignedByUserId: currentUser.id });
          }

          await logAudit({
            userId: currentUser.id,
            action: 'user.create',
            entity: 'user',
            entityId: inserted[0].id,
            diff: { email: finalEmail, role, customRoleId, assignedDepartmentId },
            ipAddress: Astro.clientAddress
          });

          okMsg = 'Created: ' + finalEmail + ' | Temp password: ' + plainPassword + ' | SHARE THIS WITH THE USER NOW - it will not be shown again.';
        }
      }
    }
    else if (action === 'reset_password') {
      const userId = fd.get('userId') as string;
      const newPass = makeTempPassword();
      const passwordHash = await hashPassword(newPass);
      await db.update(users).set({ passwordHash, updatedAt: new Date() }).where(eq(users.id, userId));
      await logAudit({
        userId: currentUser.id,
        action: 'user.password_reset',
        entity: 'user',
        entityId: userId,
        diff: {},
        ipAddress: Astro.clientAddress
      });
            // Send email
      const target = await db.select().from(users).where(eq(users.id, userId)).limit(1);
      const u = target[0];
      if (u && u.email) {
        await sendEmail({
          to: u.email,
          subject: 'Your EduRankAI password was reset',
          html: brandedEmail({
            heading: 'Password Reset',
            body: '<p>Hi ' + (u.name || 'there') + ',</p><p>An administrator has reset your password. Your new temporary password is:</p><p style="background:#f8f6f1;border-radius:8px;padding:14px;font-family:monospace;font-size:18px;font-weight:700;letter-spacing:0.05em;color:#FF4F00;text-align:center;">' + newPass + '</p><p>Please log in and change it immediately.</p>',
            ctaText: 'Sign In Now',
            ctaUrl: 'https://edurankai.in/portal/login',
            footerNote: 'If you did not request this reset, contact us immediately at hr@edurankai.in.'
          })
        });
      }
      okMsg = 'New temp password: ' + newPass + ' - emailed to user';
    }
    else if (action === 'toggle_active') {
      const userId = fd.get('userId') as string;
      const target = await db.select().from(users).where(eq(users.id, userId)).limit(1);
      if (target.length === 0) {
        errorMsg = 'User not found.';
      } else if (target[0].id === currentUser.id) {
        errorMsg = 'You cannot deactivate yourself.';
      } else {
        await db.update(users).set({ isActive: !target[0].isActive, updatedAt: new Date() }).where(eq(users.id, userId));
        await logAudit({
          userId: currentUser.id,
          action: target[0].isActive ? 'user.deactivate' : 'user.activate',
          entity: 'user',
          entityId: userId,
          diff: { isActive: !target[0].isActive },
          ipAddress: Astro.clientAddress
        });
        okMsg = target[0].isActive ? 'User deactivated.' : 'User re-activated.';
      }
    }
    else if (action === 'delete_user') {
      const userId = fd.get('userId') as string;
      const target = await db.select().from(users).where(eq(users.id, userId)).limit(1);
      if (target.length === 0) {
        errorMsg = 'User not found.';
      } else if (target[0].id === currentUser.id) {
        errorMsg = 'You cannot delete yourself.';
      } else {
        // Delete cascades: face enrollments, sessions, permissions, etc.
        await db.execute(sql`DELETE FROM user_face_enrollments WHERE user_id = ${userId}`);
        await db.execute(sql`DELETE FROM user_totp_secrets WHERE user_id = ${userId}`).catch(()=>{});
        await db.execute(sql`DELETE FROM user_locations WHERE user_id = ${userId}`).catch(()=>{});
        await db.execute(sql`DELETE FROM user_page_permissions WHERE user_id = ${userId}`).catch(()=>{});
        await db.delete(users).where(eq(users.id, userId));
        await logAudit({
          userId: currentUser.id,
          action: 'user.delete',
          entity: 'user',
          entityId: userId,
          diff: { name: target[0].name, email: target[0].email },
          ipAddress: Astro.clientAddress
        });
        okMsg = 'User deleted permanently: ' + target[0].name;
      }
    }
    else if (action === 'regenerate_face') {
      const userId = fd.get('userId') as string;
      await db.execute(sql`DELETE FROM user_face_enrollments WHERE user_id = ${userId}`);
      await logAudit({
        userId: currentUser.id,
        action: 'user.face_regenerate',
        entity: 'user',
        entityId: userId,
        diff: {},
        ipAddress: Astro.clientAddress
      });
      okMsg = 'Face enrollment cleared. User must re-enroll at /portal/enroll-face';
    }
    else if (action === 'approve_access') {
      const userId = fd.get('userId') as string;
      await db.execute(sql`UPDATE users SET access_status = 'approved', waiver_decided_by = ${currentUser.id}, waiver_decided_at = NOW(), updated_at = NOW() WHERE id = ${userId}`);
      await logAudit({ userId: currentUser.id, action: 'user.access_approve', entity: 'user', entityId: userId, diff: {}, ipAddress: Astro.clientAddress });
      okMsg = 'Account approved - the user now has full access.';
    }
    else if (action === 'approve_access_bulk') {
      // Approve a specific subset, or every pending applicant if no subset given.
      const raw = fd.getAll('userIds[]') as string[];
      const ids = (raw || []).map(s => (s || '').toString().trim()).filter(Boolean);
      let promoted = 0;
      if (ids.length > 0) {
        const r = await db.execute(sql`UPDATE users SET access_status = 'approved', waiver_decided_by = ${currentUser.id}, waiver_decided_at = NOW(), updated_at = NOW() WHERE id = ANY(${ids}::uuid[]) AND access_status = 'pending' RETURNING id`);
        const rs = Array.isArray(r) ? r : ((r as any)?.rows || []);
        promoted = rs.length;
        await logAudit({ userId: currentUser.id, action: 'user.access_approve_bulk', entity: 'user', entityId: ids.join(','), diff: { count: promoted, scope: 'selected' }, ipAddress: Astro.clientAddress });
      } else {
        const r = await db.execute(sql`UPDATE users SET access_status = 'approved', waiver_decided_by = ${currentUser.id}, waiver_decided_at = NOW(), updated_at = NOW() WHERE access_status = 'pending' AND role = 'applicant' RETURNING id`);
        const rs = Array.isArray(r) ? r : ((r as any)?.rows || []);
        promoted = rs.length;
        await logAudit({ userId: currentUser.id, action: 'user.access_approve_bulk', entity: 'user', entityId: '*', diff: { count: promoted, scope: 'all_pending' }, ipAddress: Astro.clientAddress });
      }
      okMsg = 'Approved ' + promoted + ' account(s). They now have full access.';
    }
    else if (action === 'reject_access') {
      const userId = fd.get('userId') as string;
      await db.execute(sql`UPDATE users SET access_status = 'rejected', waiver_decided_by = ${currentUser.id}, waiver_decided_at = NOW(), updated_at = NOW() WHERE id = ${userId}`);
      await logAudit({ userId: currentUser.id, action: 'user.access_reject', entity: 'user', entityId: userId, diff: {}, ipAddress: Astro.clientAddress });
      okMsg = 'Waiver request rejected - account stays restricted until the fee is paid.';
    }
    else if (action === 'change_role') {
      const userId = fd.get('userId') as string;
      const rawRole = (fd.get('role') as string) || '';
      const newDept = (fd.get('assignedDepartmentId') as string || '').trim() || null;
      if (userId === currentUser.id) {
        errorMsg = 'You cannot change your own role.';
      } else if (rawRole.startsWith('custom:')) {
        // Custom role selected: keep the user's built-in role unchanged (it's a
        // baseline), replace their custom-role assignment with this one.
        const roleId = rawRole.slice('custom:'.length);
        await db.update(users).set({ assignedDepartmentId: newDept, updatedAt: new Date() }).where(eq(users.id, userId));
        await db.delete(userRoleAssignments).where(eq(userRoleAssignments.userId, userId));
        await db.insert(userRoleAssignments).values({ userId, roleId, assignedByUserId: currentUser.id });
        await logAudit({ userId: currentUser.id, action: 'user.custom_role_assign', entity: 'user', entityId: userId, diff: { roleId, assignedDepartmentId: newDept }, ipAddress: Astro.clientAddress });
        okMsg = 'Custom role assigned. This user now only sees the pages that role grants.';
      } else {
        // Built-in role: set it and clear any custom-role assignments.
        await db.update(users).set({ role: rawRole as any, assignedDepartmentId: newDept, updatedAt: new Date() }).where(eq(users.id, userId));
        await db.delete(userRoleAssignments).where(eq(userRoleAssignments.userId, userId));
        await logAudit({ userId: currentUser.id, action: 'user.role_change', entity: 'user', entityId: userId, diff: { role: rawRole, assignedDepartmentId: newDept }, ipAddress: Astro.clientAddress });
        okMsg = 'Role updated.';
      }
    }
  } catch (err: any) {
    errorMsg = 'Failed: ' + (err.message || 'Unknown error');
  }
}

// Filter
const url = new URL(Astro.request.url);
const filter = url.searchParams.get('filter') || 'admins';

// Belt-and-braces: auto-promote every pending APPLICANT before rendering the
// list. Account creation is free and the application fee is the only paid
// step, so 'pending' for an applicant is always a signup-time bug, never a
// real state. Admins should never hand-approve applicant accounts again.
try {
  await db.execute(sql`UPDATE users SET access_status = 'approved', updated_at = NOW() WHERE access_status = 'pending' AND role = 'applicant'`);
} catch (_) {}

const allUsers = await db.select().from(users).orderBy(desc(users.createdAt));

// Access status + waiver fields live on raw columns (not in the Drizzle model).
const accessRowsRaw = await db.execute(sql`SELECT id, access_status, waiver_requested, waiver_reason, waiver_proof_url, photo_url FROM users`);
const accessRows = Array.isArray(accessRowsRaw) ? accessRowsRaw : (accessRowsRaw?.rows || []);
const accessMap: Record<string, any> = {};
for (const a of (accessRows as any[])) accessMap[a.id] = a;
const isPending = (uid: string) => (accessMap[uid]?.access_status || 'approved') === 'pending';

let filteredUsers = allUsers;
if (filter === 'admins') filteredUsers = allUsers.filter(u => u.role !== 'applicant');
else if (filter === 'applicants') filteredUsers = allUsers.filter(u => u.role === 'applicant');
else if (filter === 'inactive') filteredUsers = allUsers.filter(u => !u.isActive);
else if (filter === 'pending') filteredUsers = allUsers.filter(u => isPending(u.id));

const allDepts = await db.select().from(departments).orderBy(asc(departments.sortOrder));
const deptMap = Object.fromEntries(allDepts.map(d => [d.id, d.name]));

const counts = {
  admins: allUsers.filter(u => u.role !== 'applicant').length,
  applicants: allUsers.filter(u => u.role === 'applicant').length,
  inactive: allUsers.filter(u => !u.isActive).length,
  pending: allUsers.filter(u => isPending(u.id)).length,
  total: allUsers.length
};

const ROLES_AVAILABLE = Object.keys(ROLE_LABELS).filter(r => r !== 'applicant');

// Custom roles (page-permission roles created at /admin/team/roles) + who has them.
let customRoles: { id: string; name: string; color: string | null }[] = [];
const userRolesMap: Record<string, string[]> = {};
try {
  customRoles = await db.select({ id: teamRoles.id, name: teamRoles.name, color: teamRoles.color }).from(teamRoles).orderBy(asc(teamRoles.name));
  const assignRows = await db.select({ userId: userRoleAssignments.userId, roleId: userRoleAssignments.roleId }).from(userRoleAssignments);
  for (const a of assignRows) { (userRolesMap[a.userId] ||= []).push(a.roleId); }
} catch (e) {}
---
<AdminLayout title="Users" activeNav="users">
  <div class="admin-page" style="max-width:1300px;">

    <div class="admin-page-header" style="margin-bottom:24px;">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">Access</div>
        <h1 class="admin-page-title">Users</h1>
  <div style="margin-top:8px;display:flex;gap:6px;"><a href="/api/export/users" class="era-btn era-btn-secondary era-btn-sm" download style="display:inline-flex;align-items:center;gap:5px;text-decoration:none;"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>Export CSV</a></div>

        <p class="admin-page-sub">{counts.total} users total. {counts.admins} admin accounts. {counts.applicants} applicant accounts. {counts.inactive} deactivated.</p>
      </div>
    </div>

    {errorMsg && (
      <div style="background:rgba(220,38,38,0.08);border:1px solid rgba(220,38,38,0.25);color:#fca5a5;font-size:12.5px;padding:11px 14px;border-radius:7px;margin-bottom:18px;">
        {errorMsg}
      </div>
    )}
    {okMsg && (
      <div style="background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.25);color:#6ee7b7;font-size:12.5px;padding:14px;border-radius:7px;margin-bottom:18px;font-family:monospace;line-height:1.7;word-break:break-all;">
        {okMsg}
      </div>
    )}

    <div style="display:grid;grid-template-columns:1.6fr 1fr;gap:18px;align-items:flex-start;">

      <div class="admin-card" style="padding:0;overflow:hidden;">
        <div style="padding:12px 16px;border-bottom:1px solid #1f1f26;">
          <input type="text" id="userSearch" placeholder="Search by name, personal email, or @edurankai.in handle..." style="width:100%;padding:8px 12px;background:#08080a;border:1px solid #1f1f26;border-radius:7px;color:#fff;font-size:12.5px;outline:none;" />
        </div>
        <div style="padding:14px 16px;border-bottom:1px solid #1f1f26;display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
          <a href="?filter=admins" style={'font-size:11px;padding:5px 11px;border-radius:100px;text-decoration:none;border:1px solid ' + (filter === 'admins' ? '#FF4F00;background:#FF4F00;color:#fff' : '#1f1f26;color:#a0a0ab')}>Admins ({counts.admins})</a>
          <a href="?filter=applicants" style={'font-size:11px;padding:5px 11px;border-radius:100px;text-decoration:none;border:1px solid ' + (filter === 'applicants' ? '#FF4F00;background:#FF4F00;color:#fff' : '#1f1f26;color:#a0a0ab')}>Applicants ({counts.applicants})</a>
          <a href="?filter=pending" style={'font-size:11px;padding:5px 11px;border-radius:100px;text-decoration:none;border:1px solid ' + (filter === 'pending' ? '#FF4F00;background:#FF4F00;color:#fff' : (counts.pending > 0 ? '#fbbf24;color:#fbbf24' : '#1f1f26;color:#a0a0ab'))}>Pending approval ({counts.pending})</a>
          <a href="?filter=inactive" style={'font-size:11px;padding:5px 11px;border-radius:100px;text-decoration:none;border:1px solid ' + (filter === 'inactive' ? '#FF4F00;background:#FF4F00;color:#fff' : '#1f1f26;color:#a0a0ab')}>Deactivated ({counts.inactive})</a>
          <a href="?filter=all" style={'font-size:11px;padding:5px 11px;border-radius:100px;text-decoration:none;border:1px solid ' + (filter === 'all' ? '#FF4F00;background:#FF4F00;color:#fff' : '#1f1f26;color:#a0a0ab')}>All ({counts.total})</a>
        </div>

        {filter === 'pending' && counts.pending > 0 && (
          <div style="padding:12px 16px;background:rgba(251,191,36,0.06);border-bottom:1px solid #1f1f26;display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
            <p style="margin:0;font-size:11.5px;color:#fbbf24;font-weight:600;flex:1;min-width:180px;">{counts.pending} account(s) pending approval. Select rows below or use the bulk actions.</p>
            <form method="POST" style="margin:0;display:inline-flex;gap:6px;" id="bulkApproveForm">
              <input type="hidden" name="_action" value="approve_access_bulk" />
              <span id="bulkSelectionInputs"></span>
              <button type="button" id="bulkApproveSelectedBtn" disabled style="background:#10b981;border:none;color:#fff;font-size:11.5px;font-weight:700;padding:7px 14px;border-radius:6px;cursor:pointer;opacity:0.4;">Approve selected (<span id="bulkSelectedCount">0</span>)</button>
            </form>
            <form method="POST" style="margin:0;display:inline-flex;" onsubmit={`return confirm('Approve ALL ${counts.pending} pending applicants at once?');`}>
              <input type="hidden" name="_action" value="approve_access_bulk" />
              <button type="submit" style="background:#15151a;border:1px solid rgba(16,185,129,0.5);color:#10b981;font-size:11.5px;font-weight:700;padding:6px 12px;border-radius:6px;cursor:pointer;">Approve ALL pending ({counts.pending})</button>
            </form>
          </div>
        )}

        <table class="admin-table">
          <thead>
            <tr>
              {filter === 'pending' && <th style="width:32px;"><input type="checkbox" id="bulkSelectAll" style="accent-color:#10b981;cursor:pointer;" title="Select all visible" /></th>}
              <th>User</th>
              <th>Role / Dept</th>
              <th>Active</th>
              <th>Last login</th>
              <th style="text-align:right;">Actions</th>
            </tr>
          </thead>
          <tbody>
            {filteredUsers.map((u) => {
              const isCurrent = u.id === currentUser.id;
              const lastLogin = u.lastLoginAt ? new Date(u.lastLoginAt).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day:'numeric', month:'short' }) : 'Never';
              const roleLabel = ROLE_LABELS[u.role] || u.role;
              const deptName = u.assignedDepartmentId ? deptMap[u.assignedDepartmentId] : null;
              const handle = (u as any).internalHandle || null;
              return (
                <tr class="user-row" data-search={((u.name || '') + ' ' + (u.email || '') + ' ' + (handle || '')).toLowerCase()}>
                  {filter === 'pending' && (
                    <td style="vertical-align:top;padding-top:14px;">
                      {accessMap[u.id] && accessMap[u.id].access_status === 'pending' ? (
                        <input type="checkbox" class="bulk-select-row" data-uid={u.id} style="accent-color:#10b981;cursor:pointer;" />
                      ) : null}
                    </td>
                  )}
                  <td>
                    <div style="font-weight:500;color:#fff;display:flex;align-items:center;gap:8px;">
                      {accessMap[u.id] && accessMap[u.id].photo_url && <img src={accessMap[u.id].photo_url} alt="" style="width:26px;height:26px;border-radius:50%;object-fit:cover;border:1px solid #2a2a32;" />}
                      <a href={'/admin/users/' + u.id} style="color:#fff;text-decoration:none;">{u.name}</a>
                      {isCurrent && <span style="font-size:9px;background:rgba(255,79,0,0.12);color:#FF7040;padding:1px 7px;border-radius:100px;letter-spacing:0.06em;text-transform:uppercase;font-weight:700;">You</span>}
                    </div>
                    <div style="font-size:11px;color:#6e6e78;margin-top:3px;font-family:'Geist Mono',monospace;">{u.email} · <a href={'/admin/users/' + u.id} style="color:#60a5fa;text-decoration:none;">profile & activity</a></div>
                    {handle && handle !== u.email && (
                      <div style="font-size:11px;color:#FF7040;margin-top:2px;font-family:'Geist Mono',monospace;" title="Assigned internal credential - candidate can sign in with this too">@ {handle}</div>
                    )}
                    {accessMap[u.id] && accessMap[u.id].access_status === 'pending' && (
                      <div style="margin-top:4px;">
                        <span style="font-size:9px;background:rgba(251,191,36,0.14);color:#fbbf24;padding:1px 7px;border-radius:100px;letter-spacing:0.05em;text-transform:uppercase;font-weight:700;">Pending {accessMap[u.id].waiver_requested ? '· waiver requested' : '· unpaid'}</span>
                        {accessMap[u.id].waiver_requested && accessMap[u.id].waiver_reason && (
                          <details style="margin-top:3px;max-width:360px;"><summary style="font-size:11px;color:#93c5fd;cursor:pointer;">View waiver statement</summary><div style="font-size:11px;color:#a0a0ab;margin-top:4px;font-style:italic;white-space:pre-wrap;">{accessMap[u.id].waiver_reason}</div></details>
                        )}
                        {accessMap[u.id].waiver_requested && accessMap[u.id].waiver_proof_url && (
                          <div style="font-size:11px;margin-top:3px;"><a href={accessMap[u.id].waiver_proof_url} target="_blank" rel="noopener" style="color:#60a5fa;">Proof link &#8599;</a></div>
                        )}
                      </div>
                    )}
                  </td>
                  <td>
                    <div style="font-size:12px;color:#d8d8de;font-weight:500;">{roleLabel}</div>
                    {deptName && <div style="font-size:10.5px;color:#6e6e78;margin-top:2px;">{deptName}</div>}
                  </td>
                  <td>
                    <span style={'display:inline-flex;align-items:center;gap:5px;font-size:11px;color:' + (u.isActive ? '#10b981' : '#6e6e78') + ';'}>
                      <span style={'width:6px;height:6px;border-radius:50%;background:' + (u.isActive ? '#10b981' : '#6e6e78') + ';'}></span>
                      {u.isActive ? 'Yes' : 'No'}
                    </span>
                  </td>
                  <td><span style="font-size:11px;color:#6e6e78;">{lastLogin}</span></td>
                  <td style="text-align:right;">
                    {canEdit && !isCurrent && (
                      <div style="display:flex;gap:5px;justify-content:flex-end;flex-wrap:wrap;">
                        {accessMap[u.id] && accessMap[u.id].access_status === 'pending' && (
                          <>
                            <form method="POST" style="margin:0;display:inline;">
                              <input type="hidden" name="_action" value="approve_access" />
                              <input type="hidden" name="userId" value={u.id} />
                              <button type="submit" class="admin-btn" style="padding:4px 9px;font-size:10.5px;color:#6ee7b7;border-color:rgba(16,185,129,0.3);">Approve</button>
                            </form>
                            <form method="POST" style="margin:0;display:inline;" onsubmit="return confirm('Reject this waiver request? The account stays restricted.');">
                              <input type="hidden" name="_action" value="reject_access" />
                              <input type="hidden" name="userId" value={u.id} />
                              <button type="submit" class="admin-btn" style="padding:4px 9px;font-size:10.5px;color:#fca5a5;">Reject</button>
                            </form>
                          </>
                        )}
                        <form method="POST" style="margin:0;display:inline;">
                          <input type="hidden" name="_action" value="reset_password" />
                          <input type="hidden" name="userId" value={u.id} />
                          <button type="submit" class="admin-btn" style="padding:4px 9px;font-size:10.5px;">Reset PW</button>
                        </form>
                        <form method="POST" style="margin:0;display:inline;" onsubmit="return confirm('Clear face enrollment for ' + this.dataset.name + '? They must re-enroll.');" data-name={u.name}>
                          <input type="hidden" name="_action" value="regenerate_face" />
                          <input type="hidden" name="userId" value={u.id} />
                          <button type="submit" class="admin-btn" style="padding:4px 9px;font-size:10.5px;color:#fbbf24;">Reset Face</button>
                        </form>
                        <form method="POST" style="margin:0;display:inline;" onsubmit="return confirm(this.dataset.confirm);" data-confirm={(u.isActive ? 'Deactivate ' : 'Activate ') + u.name + '?'}>
                          <input type="hidden" name="_action" value="toggle_active" />
                          <input type="hidden" name="userId" value={u.id} />
                          <button type="submit" class="admin-btn" style={'padding:4px 9px;font-size:10.5px;' + (u.isActive ? 'color:#fca5a5;' : 'color:#6ee7b7;')}>
                            {u.isActive ? 'Deactivate' : 'Activate'}
                          </button>
                        </form>
                        <form method="POST" style="margin:0;display:inline;" onsubmit="return confirm('PERMANENTLY DELETE ' + this.dataset.name + '? This cannot be undone. Type DELETE to confirm.') && prompt('Type DELETE to confirm:') === 'DELETE';" data-name={u.name}>
                          <input type="hidden" name="_action" value="delete_user" />
                          <input type="hidden" name="userId" value={u.id} />
                          <button type="submit" class="admin-btn" style="padding:4px 9px;font-size:10.5px;color:#ef4444;border-color:rgba(239,68,68,0.3);">Delete</button>
                        </form>
                        <details style="width:100%;margin-top:4px;">
                          <summary style="cursor:pointer;font-size:10.5px;color:#FF7040;list-style:none;text-align:right;">Manage access</summary>
                          <form method="POST" style="margin:6px 0 0;display:flex;gap:6px;justify-content:flex-end;flex-wrap:wrap;align-items:center;background:#08080a;border:1px solid #1f1f26;border-radius:7px;padding:8px;">
                            <input type="hidden" name="_action" value="change_role" />
                            <input type="hidden" name="userId" value={u.id} />
                            <select name="role" class="rolefield-input" style="width:auto;min-width:160px;padding:5px 8px;font-size:11px;">
                              <optgroup label="Built-in roles">
                                {ROLES_AVAILABLE.map((r) => (
                                  <option value={r} selected={(userRolesMap[u.id] || []).length === 0 && u.role === r}>{ROLE_LABELS[r as keyof typeof ROLE_LABELS]}</option>
                                ))}
                                <option value="applicant" selected={(userRolesMap[u.id] || []).length === 0 && u.role === 'applicant'}>Applicant (no admin access)</option>
                              </optgroup>
                              {customRoles.length > 0 && (
                                <optgroup label="Custom roles">
                                  {customRoles.map((cr) => (
                                    <option value={`custom:${cr.id}`} selected={(userRolesMap[u.id] || []).includes(cr.id)}>{cr.name}</option>
                                  ))}
                                </optgroup>
                              )}
                            </select>
                            <select name="assignedDepartmentId" class="rolefield-input" style="width:auto;min-width:130px;padding:5px 8px;font-size:11px;">
                              <option value="">No department (sees all)</option>
                              {allDepts.map((d) => (<option value={d.id} selected={u.assignedDepartmentId === d.id}>{d.name}</option>))}
                            </select>
                            <button type="submit" class="admin-btn" style="padding:5px 11px;font-size:10.5px;color:#6ee7b7;">Save access</button>
                          </form>
                          {customRoles.length === 0 && (
                            <p style="margin:6px 0 0;font-size:10.5px;color:#6e6e78;text-align:right;"><a href="/admin/team/roles" style="color:#FF7040;text-decoration:none;">Create a custom role</a> to add it to this list.</p>
                          )}
                        </details>
                      </div>
                    )}
                  </td>
                </tr>
              );
            })}
            {filteredUsers.length === 0 && (
              <tr><td colspan="5" style="text-align:center;padding:30px;color:#6e6e78;font-size:13px;">No users in this view.</td></tr>
            )}
          </tbody>
        </table>
      </div>

      {canEdit && (
        <form method="POST" class="admin-card" style="display:flex;flex-direction:column;gap:14px;">
          <input type="hidden" name="_action" value="create" />
          <div>
            <div class="admin-card-title" style="margin:0 0 4px;">+ Create admin user</div>
            <p style="font-size:11px;color:#6e6e78;line-height:1.6;">Username doesn't need a real mailbox. If no @ given, we append @edurankai.in.</p>
          </div>

          <div>
            <label class="rolefield-label">Username *</label>
            <input name="username" required class="rolefield-input" placeholder="e.g. hr-recruiter-1" />
            <p style="font-size:10px;color:#6e6e78;margin-top:4px;">a-z, 0-9, . _ - @</p>
          </div>

          <div>
            <label class="rolefield-label">Full name *</label>
            <input name="name" required class="rolefield-input" placeholder="Jane Doe" />
          </div>

          <div>
            <label class="rolefield-label">Role *</label>
            <select name="role" required class="rolefield-input" id="role-select">
              <option value="">Choose...</option>
              <optgroup label="Built-in roles">
                {ROLES_AVAILABLE.map((r) => (
                  <option value={r}>{ROLE_LABELS[r as keyof typeof ROLE_LABELS]}</option>
                ))}
              </optgroup>
              {customRoles.length > 0 && (
                <optgroup label="Custom roles">
                  {customRoles.map((cr) => (
                    <option value={`custom:${cr.id}`}>{cr.name}</option>
                  ))}
                </optgroup>
              )}
            </select>
          </div>

          <div>
            <label class="rolefield-label">Assigned department (optional)</label>
            <select name="assignedDepartmentId" class="rolefield-input">
              <option value="">No department (sees all)</option>
              {allDepts.map((d) => (
                <option value={d.id}>{d.name}</option>
              ))}
            </select>
            <p style="font-size:10px;color:#6e6e78;margin-top:4px;">Required for Department Head, Reviewer, Recruiter</p>
          </div>

          <div>
            <label class="rolefield-label">Password (optional)</label>
            <input name="password" type="text" class="rolefield-input" placeholder="Leave blank to auto-generate" />
            <p style="font-size:10px;color:#6e6e78;margin-top:4px;">Auto-generated password will be shown on create. Save it immediately.</p>
          </div>

          <button type="submit" class="admin-btn admin-btn-primary" style="width:100%;justify-content:center;">Create User</button>
        </form>
      )}

    </div>
  </div>

  <style>
    .rolefield-label {
      display:block;font-size:10.5px;font-weight:600;color:#8a8a94;
      letter-spacing:0.1em;text-transform:uppercase;margin-bottom:6px;
    }
    .rolefield-input {
      width:100%;padding:8px 11px;background:#08080a;border:1px solid #1f1f26;
      border-radius:6px;color:#fff;font-size:12.5px;font-family:inherit;outline:none;
    }
    .rolefield-input:focus { border-color:#FF4F00; }
  </style>
  <script is:inline>
    (function () {
      var box = document.getElementById('userSearch');
      if (box) {
        box.addEventListener('input', function () {
          var q = box.value.trim().toLowerCase();
          document.querySelectorAll('.user-row').forEach(function (row) {
            var hay = row.getAttribute('data-search') || '';
            row.style.display = (!q || hay.indexOf(q) !== -1) ? '' : 'none';
          });
        });
      }

      // ---- Bulk approve on the pending tab ----
      var bulkForm = document.getElementById('bulkApproveForm');
      var bulkBtn = document.getElementById('bulkApproveSelectedBtn');
      var bulkCount = document.getElementById('bulkSelectedCount');
      var bulkInputs = document.getElementById('bulkSelectionInputs');
      var selectAll = document.getElementById('bulkSelectAll');
      var rowChecks = document.querySelectorAll('.bulk-select-row');

      function refreshBulk() {
        if (!bulkBtn || !bulkInputs || !bulkCount) return;
        var ids = [];
        rowChecks.forEach(function (cb) { if (cb.checked) ids.push(cb.getAttribute('data-uid')); });
        bulkCount.textContent = ids.length;
        if (ids.length > 0) {
          bulkBtn.disabled = false;
          bulkBtn.style.opacity = '1';
          bulkBtn.style.cursor = 'pointer';
        } else {
          bulkBtn.disabled = true;
          bulkBtn.style.opacity = '0.4';
          bulkBtn.style.cursor = 'not-allowed';
        }
        bulkInputs.innerHTML = '';
        ids.forEach(function (id) {
          var inp = document.createElement('input');
          inp.type = 'hidden'; inp.name = 'userIds[]'; inp.value = id;
          bulkInputs.appendChild(inp);
        });
      }

      rowChecks.forEach(function (cb) { cb.addEventListener('change', refreshBulk); });

      if (selectAll) {
        selectAll.addEventListener('change', function () {
          rowChecks.forEach(function (cb) {
            // Only flip checkboxes whose row is currently visible (respects search).
            var row = cb.closest('tr');
            if (row && row.style.display !== 'none') cb.checked = selectAll.checked;
          });
          refreshBulk();
        });
      }

      if (bulkBtn && bulkForm) {
        bulkBtn.addEventListener('click', function () {
          if (bulkBtn.disabled) return;
          if (confirm('Approve ' + bulkCount.textContent + ' selected account(s)?')) {
            bulkForm.submit();
          }
        });
      }
    })();
  </script>
</AdminLayout>
