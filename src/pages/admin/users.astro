---
import AdminLayout from '@/layouts/AdminLayout.astro';
const name = 'users';
const title = name.charAt(0).toUpperCase() + name.slice(1);
---
<AdminLayout title={title} activeNav={name}>
  <div class="admin-page">
    <div class="admin-page-header">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">Admin</div>
        <h1 class="admin-page-title">{title}</h1>
        <p class="admin-page-sub">This page will be built in a subsequent message.</p>
      </div>
    </div>
    <div class="admin-card">
      <div class="admin-card-title">Coming soon</div>
      <p style="font-size:13px;color:#8a8a94;line-height:1.7;margin-top:6px;">Full CRUD interface for {title.toLowerCase()} is scheduled for the next batch of messages. The database tables are already created and the data is ready.</p>
    </div>
  </div>
</AdminLayout>
