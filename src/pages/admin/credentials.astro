---
// /admin/credentials — registrar credential console (Prompt 10, admin surface). Gated by
// can(manage, credential). Issue a course credential to a student (P8 eligibility enforced),
// revoke, and browse the issued registry. Public verification lives at /credentials/course/[code].
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { can } from '@/lib/rbac';
import { contentService } from '@/lib/kernel-content';
import { listAllCredentials } from '@/lib/credential';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'manage', { type: 'credential' });
if (!gate.allow) return Astro.redirect('/admin');

const rows = (r: any): any[] => (Array.isArray(r) ? r : (r?.rows || []));
const users = rows(await db.execute(sql`SELECT id, name, email FROM users ORDER BY name LIMIT 200`));
const courses = (await contentService().listCourses().catch(() => [])).map((c: any) => ({ id: c.id, title: (c.data as any).title }));
const creds = await listAllCredentials(100).catch(() => []);

const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const IN = 'background:#15151a;border:1px solid #26262c;color:#fff;padding:7px 9px;border-radius:6px;font-size:12px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
function fmt(d: any) { try { return new Date(d).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); } catch { return '-'; } }
---
<AdminLayout title="Credentials" activeNav="credentials">
  <div style="max-width:1080px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Registrar</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Course credentials</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">Issue tamper-evident credentials to students who passed a course's required official assessments. Anyone can verify one (no login) at /credentials/course/&lt;code&gt;.</p>
    <div id="msg" style="display:none;margin:12px 0;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style={CARD}>
      <p style={HD}>Issue a credential</p>
      <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:end;">
        <div><label style="font-size:10px;color:#8a8a94;">Student</label><br/><select id="iUser" style={IN}>{users.map((u: any) => <option value={u.id}>{u.name} ({u.email})</option>)}</select></div>
        <div><label style="font-size:10px;color:#8a8a94;">Course</label><br/><select id="iCourse" style={IN}>{courses.map((c: any) => <option value={c.id}>{c.title}</option>)}</select></div>
        <button id="checkBtn" type="button" style="background:#15151a;border:1px solid #26262c;color:#cfd6da;font-size:11px;padding:8px 12px;border-radius:6px;cursor:pointer;">Check eligibility</button>
        <button id="issueBtn" type="button" style="background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:700;padding:8px 14px;border-radius:6px;cursor:pointer;">Issue</button>
      </div>
      {courses.length === 0 ? <p style="font-size:11.5px;color:#c0a35e;margin:8px 0 0;">No kernel courses yet — adopt one in /admin/knowledge and add assessments in /admin/assessments first.</p> : null}
    </div>

    <div style={CARD}>
      <p style={HD}>Issued registry ({creds.length})</p>
      {creds.length === 0 ? <p style="font-size:12px;color:#6e6e78;margin:0;">No credentials issued yet.</p> :
      <div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:12px;">
        <thead><tr style="color:#8a8a94;font-size:9px;text-transform:uppercase;font-family:'Geist Mono',monospace;text-align:left;"><th style="padding:5px 8px;">Code</th><th style="padding:5px 8px;">Holder</th><th style="padding:5px 8px;">Course</th><th style="padding:5px 8px;">Issued</th><th style="padding:5px 8px;">Status</th><th style="padding:5px 8px;"></th></tr></thead>
        <tbody>{creds.map((c: any) => (
          <tr style="border-top:1px solid #15151a;">
            <td style="padding:6px 8px;"><a href={'/credentials/course/' + c.code} style="color:#cfd6da;font-family:'Geist Mono',monospace;text-decoration:none;border-bottom:1px dotted #3a3a44;">{c.code}</a></td>
            <td style="padding:6px 8px;color:#cfd6da;">{c.holder || c.holder_name}</td>
            <td style="padding:6px 8px;color:#8a8a94;">{c.course_title}</td>
            <td style="padding:6px 8px;color:#8a8a94;font-family:'Geist Mono',monospace;white-space:nowrap;">{fmt(c.issued_at)}</td>
            <td style={'padding:6px 8px;font-weight:700;color:' + (c.revoked ? '#fca5a5' : '#6ee7b7')}>{c.revoked ? 'revoked' : 'valid'}</td>
            <td style="padding:6px 8px;">{!c.revoked ? <button class="revBtn" data-code={c.code} type="button" style="background:#2a1414;border:1px solid #5f2f2f;color:#fca5a5;font-size:10px;padding:4px 9px;border-radius:5px;cursor:pointer;">revoke</button> : null}</td>
          </tr>
        ))}</tbody>
      </table></div>}
    </div>
  </div>

  <script is:inline>
    (function () {
      var msg = document.getElementById('msg');
      function flash(t, ok) { msg.style.display = 'block'; msg.textContent = t; msg.style.background = ok ? 'rgba(16,185,129,0.12)' : 'rgba(239,68,68,0.12)'; msg.style.color = ok ? '#6ee7b7' : '#fca5a5'; }
      function post(body, cb) { return fetch('/api/admin/credentials', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }).then(function (r) { return r.json(); }).then(cb).catch(function () { flash('Network error', false); }); }
      function u() { return document.getElementById('iUser').value; } function c() { return document.getElementById('iCourse').value; }
      document.getElementById('checkBtn').addEventListener('click', function () { post({ action: 'check', userId: u(), courseObjId: c() }, function (j) { if (j.ok) flash(j.eligible ? ('Eligible — passed ' + j.passed + '/' + j.required + ' required assessments.') : ('Not eligible — passed ' + j.passed + '/' + j.required + ' required assessments.'), j.eligible); else flash(j.error || 'Failed', false); }); });
      document.getElementById('issueBtn').addEventListener('click', function () { post({ action: 'issue', userId: u(), courseObjId: c() }, function (j) { if (j.ok) { flash('Issued: ' + j.code, true); setTimeout(function () { location.reload(); }, 700); } else flash(j.error || 'Failed', false); }); });
      document.querySelectorAll('.revBtn').forEach(function (b) { b.addEventListener('click', function () { var reason = prompt('Reason for revoking?') || 'revoked'; post({ action: 'revoke', code: b.getAttribute('data-code'), reason: reason }, function (j) { if (j.ok) { flash('Revoked.', true); setTimeout(function () { location.reload(); }, 500); } else flash(j.error || 'Failed', false); }); }); });
    })();
  </script>
</AdminLayout>
