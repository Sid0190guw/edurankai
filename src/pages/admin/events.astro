---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { events } from '@/lib/db/schema';
import { desc, eq } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

let errorMsg = '';
let successMsg = '';

function slugify(s: string): string {
  return s.toLowerCase()
    .replace(/[^a-z0-9\s-]/g, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .replace(/^-|-$/g, '');
}

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;

  try {
    if (action === 'create') {
      const title = (fd.get('title') as string || '').trim();
      const description = (fd.get('description') as string || '').trim();
      const longDescription = (fd.get('longDescription') as string || '').trim();
      const mode = (fd.get('mode') as string || 'online').trim();
      const status = (fd.get('status') as string || 'upcoming').trim();
      const startsAtRaw = (fd.get('startsAt') as string || '').trim();
      const endsAtRaw = (fd.get('endsAt') as string || '').trim();
      const location = (fd.get('location') as string || '').trim();
      const capacityRaw = (fd.get('capacity') as string || '').trim();
      const registrationUrl = (fd.get('registrationUrl') as string || '').trim();
      const coverImageUrl = (fd.get('coverImageUrl') as string || '').trim();
      const videoUrl = (fd.get('videoUrl') as string || '').trim();
      const registrationFormSlug = (fd.get('registrationFormSlug') as string || '').trim();
      const tagsRaw = (fd.get('tags') as string || '').trim();

      if (!title) {
        errorMsg = 'Title is required';
      } else if (!startsAtRaw) {
        errorMsg = 'Start date is required';
      } else {
        let baseSlug = slugify(title);
        let finalSlug = baseSlug;
        let n = 1;
        while (true) {
          const dup = await db.select({ id: events.id }).from(events).where(eq(events.slug, finalSlug)).limit(1);
          if (dup.length === 0) break;
          n++;
          finalSlug = baseSlug + '-' + n;
        }

        const tags = tagsRaw ? tagsRaw.split(',').map(t => t.trim()).filter(Boolean) : [];
        const capacity = capacityRaw ? parseInt(capacityRaw) : null;

        await db.insert(events).values({
          slug: finalSlug,
          title,
          description: description || null,
          longDescription: longDescription || null,
          mode: mode as any,
          status: status as any,
          startsAt: new Date(startsAtRaw),
          endsAt: endsAtRaw ? new Date(endsAtRaw) : null,
          location: location || null,
          capacity: capacity,
          registrationUrl: registrationUrl || null,
          coverImageUrl: coverImageUrl || null,
          videoUrl: videoUrl || null,
          registrationFormSlug: registrationFormSlug || null,
          tags: tags,
          isFeatured: false
        });
        successMsg = 'Event created: ' + finalSlug;
      }
    } else if (action === 'delete') {
      const id = (fd.get('id') as string || '').trim();
      if (id) {
        await db.delete(events).where(eq(events.id, id));
        successMsg = 'Event deleted';
      }
    } else if (action === 'update_status') {
      const id = (fd.get('id') as string || '').trim();
      const newStatus = (fd.get('status') as string || '').trim();
      const valid = ['upcoming', 'past', 'cancelled', 'draft'];
      if (id && valid.includes(newStatus)) {
        await db.update(events).set({ status: newStatus as any, updatedAt: new Date() }).where(eq(events.id, id));
        successMsg = 'Status updated to: ' + newStatus;
      }
    } else if (action === 'update') {
      const id = (fd.get('id') as string || '').trim();
      const title = (fd.get('title') as string || '').trim();
      const description = (fd.get('description') as string || '').trim();
      const longDescription = (fd.get('longDescription') as string || '').trim();
      const mode = (fd.get('mode') as string || 'online').trim();
      const startsAtRaw = (fd.get('startsAt') as string || '').trim();
      const endsAtRaw = (fd.get('endsAt') as string || '').trim();
      const location = (fd.get('location') as string || '').trim();
      const capacityRaw = (fd.get('capacity') as string || '').trim();
      const registrationUrl = (fd.get('registrationUrl') as string || '').trim();
      const coverImageUrl = (fd.get('coverImageUrl') as string || '').trim();
      const videoUrl = (fd.get('videoUrl') as string || '').trim();
      const registrationFormSlug = (fd.get('registrationFormSlug') as string || '').trim();
      const tagsRaw = (fd.get('tags') as string || '').trim();
      const isFeatured = fd.get('isFeatured') === 'true';
      if (!id || !title) { errorMsg = 'ID and title required'; } else {
        const tags = tagsRaw ? tagsRaw.split(',').map((t: string) => t.trim()).filter(Boolean) : [];
        const capacity = capacityRaw ? parseInt(capacityRaw) : null;
        await db.update(events).set({ title, description: description||null, longDescription: longDescription||null, mode: mode as any, startsAt: startsAtRaw ? new Date(startsAtRaw) : null, endsAt: endsAtRaw ? new Date(endsAtRaw) : null, location: location||null, capacity, registrationUrl: registrationUrl||null, coverImageUrl: coverImageUrl||null, videoUrl: videoUrl||null, registrationFormSlug: registrationFormSlug||null, tags, isFeatured, updatedAt: new Date() }).where(eq(events.id, id));
        successMsg = 'Event updated: ' + title;
      }
    }
  } catch (err: any) {
    errorMsg = 'Failed: ' + (err.message || 'Unknown error');
  }
}

const allEvents = await db.select().from(events).orderBy(desc(events.startsAt));

const MODE_LABELS: Record<string, string> = {
  online: 'Online',
  in_person: 'In-Person',
  hybrid: 'Hybrid'
};

const STATUS_COLORS: Record<string, string> = {
  upcoming: 'bg-burn-pale/30 text-burn border-burn-dim/50',
  past: 'bg-white/5 text-white/60 border-white/10',
  cancelled: 'bg-red-500/10 text-red-300 border-red-500/30',
  draft: 'bg-white/5 text-white/40 border-white/10'
};

function formatDateTime(d: any): string {
  if (!d) return 'TBD';
  return new Date(d).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day: 'numeric', month: 'short', year: 'numeric', hour: 'numeric', minute: '2-digit' });
}
---
<AdminLayout title="Events" description="Manage events and schedules.">
<div style="padding-bottom:80px;">
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;margin-bottom:0;">
    <div style="display:flex;align-items:center;justify-content:space-between;">
      <div>
        <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">Calendar</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Events</h1>
      </div>
    </div>
  </div>
  <div style="padding:16px;">
  <div class="mb-6 flex flex-col md:flex-row md:items-end md:justify-between gap-3">
    <div>
      <h1 class="font-display text-[1.8rem] font-semibold text-white mb-1">Events</h1>
      <p class="text-[0.85rem] text-white/60">{allEvents.length} total events</p>
    </div>
  </div>

  {errorMsg && <div class="bg-red-500/10 border border-red-500/30 text-red-300 rounded-lg p-3 mb-4 text-[0.85rem]">{errorMsg}</div>}
  {successMsg && <div class="bg-leaf-bg/20 border border-leaf-border/50 text-leaf rounded-lg p-3 mb-4 text-[0.85rem]">{successMsg}</div>}

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

    <div class="lg:col-span-2 flex flex-col gap-3">
      <h2 class="font-display text-[1.05rem] font-semibold text-white mb-1">All events</h2>

      {allEvents.length === 0 ? (
        <div class="bg-white/5 border border-white/10 rounded-xl p-8 text-center">
          <p class="text-[0.9rem] text-white/60 mb-1">No events yet.</p>
          <p class="text-[0.78rem] text-white/40">Use the form on the right to create your first event.</p>
        </div>
      ) : (
        allEvents.map((e) => {
          const statusClass = STATUS_COLORS[e.status] || 'bg-white/5 text-white/60 border-white/10';
          return (
            <div class="bg-white/5 border border-white/10 rounded-xl p-4">
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2 mb-2">
                <div class="flex-1 min-w-0">
                  <p class="font-display text-[1rem] font-semibold text-white truncate">{e.title}</p>
                  <p class="text-[0.75rem] text-white/50 font-mono mt-0.5">/events/{e.slug}</p>
                </div>
                <span class={'shrink-0 inline-block text-[0.65rem] font-bold uppercase tracking-wider border px-2 py-0.5 rounded-full ' + statusClass}>
                  {e.status}
                </span>
              </div>
              <div class="text-[0.78rem] text-white/55 mb-3">
                {formatDateTime(e.startsAt)} - {MODE_LABELS[e.mode] || e.mode} - {e.location || 'No location'}
              </div>
              {e.description && (
                <p class="text-[0.82rem] text-white/70 mb-3 line-clamp-2">{e.description}</p>
              )}
              <div class="flex flex-wrap gap-2 items-center">
                <a href={'/admin/events/' + e.id} class="text-[0.72rem] text-burn font-semibold hover:underline font-mono">Manage levels & registrations</a>
                <span class="text-white/20">-</span>
                <a href={'/events/' + e.slug} target="_blank" class="text-[0.72rem] text-burn hover:underline font-mono">View public</a>
                <span class="text-white/20">-</span>
                <form method="POST" class="inline-flex items-center gap-1">
                  <input type="hidden" name="action" value="update_status" />
                  <input type="hidden" name="id" value={e.id} />
                  <select name="status" class="text-[0.72rem] bg-white/5 border border-white/10 rounded px-2 py-0.5 text-white outline-none">
                    <option value="upcoming" selected={e.status === 'upcoming'} class="bg-ink">upcoming</option>
                    <option value="past" selected={e.status === 'past'} class="bg-ink">past</option>
                    <option value="cancelled" selected={e.status === 'cancelled'} class="bg-ink">cancelled</option>
                    <option value="draft" selected={e.status === 'draft'} class="bg-ink">draft</option>
                  </select>
                  <button type="submit" class="text-[0.72rem] text-white/70 hover:text-white font-mono">change</button>
                </form>
                <span class="text-white/20">-</span>
                <span class="text-white/20">-</span>
                <button type="button" data-edit-id={e.id} class="edit-toggle-btn text-[0.72rem] text-sky-400 hover:text-sky-300 font-mono">edit</button>
                <form method="POST" class="inline" onsubmit="return confirm('Delete this event permanently?');">
                  <input type="hidden" name="action" value="delete" />
                  <input type="hidden" name="id" value={e.id} />
                  <button type="submit" class="text-[0.72rem] text-red-400 hover:text-red-300 font-mono">delete</button>
                </form>
              </div>
              <div id={"edit-"+e.id} style="display:none;" class="mt-4 pt-4 border-t border-white/10">
                <form method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-3">
                  <input type="hidden" name="action" value="update" />
                  <input type="hidden" name="id" value={e.id} />
                  <div class="md:col-span-2"><label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/40 mb-1">Title *</label><input type="text" name="title" required value={e.title} class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-white text-[0.82rem] outline-none focus:border-burn" /></div>
                  <div class="md:col-span-2"><label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/40 mb-1">Short Description</label><textarea name="description" rows="2" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-white text-[0.82rem] outline-none focus:border-burn resize-y">{e.description || ""}</textarea></div>
                  <div class="md:col-span-2"><label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/40 mb-1">Long Description</label><textarea name="longDescription" rows="3" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-white text-[0.82rem] outline-none focus:border-burn resize-y">{e.longDescription || ""}</textarea></div>
                  <div><label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/40 mb-1">Mode</label><select name="mode" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-white text-[0.82rem] outline-none"><option value="online" selected={e.mode==="online"} class="bg-ink">Online</option><option value="in_person" selected={e.mode==="in_person"} class="bg-ink">In-Person</option><option value="hybrid" selected={e.mode==="hybrid"} class="bg-ink">Hybrid</option></select></div>
                  <div><label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/40 mb-1">Location</label><input type="text" name="location" value={e.location || ""} class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-white text-[0.82rem] outline-none focus:border-burn" /></div>
                  <div><label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/40 mb-1">Starts At</label><input type="datetime-local" name="startsAt" value={e.startsAt ? new Date(e.startsAt).toISOString().slice(0,16) : ""} class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-white text-[0.82rem] outline-none focus:border-burn" /></div>
                  <div><label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/40 mb-1">Ends At</label><input type="datetime-local" name="endsAt" value={e.endsAt ? new Date(e.endsAt).toISOString().slice(0,16) : ""} class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-white text-[0.82rem] outline-none focus:border-burn" /></div>
                  <div><label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/40 mb-1">Capacity <span class="text-white/40 normal-case font-normal">(blank = open seating; values above 9999 are hidden publicly)</span></label><input type="number" name="capacity" min="0" max="9999" value={(e.capacity && e.capacity <= 9999) ? e.capacity : ""} class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-white text-[0.82rem] outline-none focus:border-burn" /></div>
                  <div><label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/40 mb-1">Registration URL</label><input type="url" name="registrationUrl" value={e.registrationUrl || ""} class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-white text-[0.82rem] outline-none focus:border-burn" /></div>
                  <div><label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/40 mb-1">Cover image / GIF</label><input type="url" name="coverImageUrl" value={(e as any).coverImageUrl || ""} placeholder="paste a URL or upload below" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-white text-[0.82rem] outline-none focus:border-burn" /><div class="flex items-center gap-2 mt-1"><input type="file" class="cover-upload text-[0.72rem] text-white/60" accept="image/png,image/jpeg,image/webp,image/gif" /><span class="cover-status text-[0.7rem] text-white/40"></span></div></div>
                  <div><label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/40 mb-1">Video / YouTube URL</label><input type="url" name="videoUrl" value={(e as any).videoUrl || ""} placeholder="https://youtu.be/... or .mp4" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-white text-[0.82rem] outline-none focus:border-burn" /></div>
                  <div><label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/40 mb-1">Registration form slug (from /admin/forms)</label><input type="text" name="registrationFormSlug" value={(e as any).registrationFormSlug || ""} placeholder="e.g. bootcamp-registration" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-white text-[0.82rem] outline-none focus:border-burn" /></div>
                  <div><label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/40 mb-1">Tags (comma separated)</label><input type="text" name="tags" value={Array.isArray(e.tags) ? e.tags.join(", ") : ""} class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-white text-[0.82rem] outline-none focus:border-burn" /></div>
                  <div class="flex items-center gap-2"><input type="checkbox" name="isFeatured" value="true" checked={e.isFeatured} class="accent-burn" /><label class="text-[0.82rem] text-white/70">Featured</label></div>
                  <div class="md:col-span-2 flex gap-2"><button type="submit" class="bg-burn hover:bg-burn/90 text-white font-semibold py-2 px-5 rounded-lg text-[0.82rem] border-0 cursor-pointer">Save</button><button type="button" data-edit-id={e.id} class="edit-cancel-btn bg-white/10 text-white font-semibold py-2 px-5 rounded-lg text-[0.82rem] border border-white/20 cursor-pointer">Cancel</button></div>
                </form>
              </div>
            </div>
            </div>
          );
        })
      )}
    </div>

    <div class="lg:col-span-1">
      <div class="bg-white/5 border border-white/10 rounded-xl p-5 sticky top-4">
        <h2 class="font-display text-[1.05rem] font-semibold text-white mb-3">Create Event</h2>

        <form method="POST" class="flex flex-col gap-3">
          <input type="hidden" name="action" value="create" />

          <div>
            <label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/50 mb-1.5">Title *</label>
            <input type="text" name="title" required placeholder="AI Safety Reading Group" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-[0.85rem] text-white outline-none focus:border-burn" />
          </div>

          <div>
            <label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/50 mb-1.5">Short description</label>
            <textarea name="description" rows="2" placeholder="One-line summary for the listing page" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-[0.85rem] text-white outline-none focus:border-burn resize-y"></textarea>
          </div>

          <div>
            <label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/50 mb-1.5">Long description</label>
            <textarea name="longDescription" rows="4" placeholder="Full details for the event page" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-[0.85rem] text-white outline-none focus:border-burn resize-y"></textarea>
          </div>

          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/50 mb-1.5">Mode</label>
              <select name="mode" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-[0.85rem] text-white outline-none focus:border-burn">
                <option value="online" class="bg-ink">Online</option>
                <option value="in_person" class="bg-ink">In-Person</option>
                <option value="hybrid" class="bg-ink">Hybrid</option>
              </select>
            </div>
            <div>
              <label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/50 mb-1.5">Status</label>
              <select name="status" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-[0.85rem] text-white outline-none focus:border-burn">
                <option value="upcoming" class="bg-ink">Upcoming</option>
                <option value="draft" class="bg-ink">Draft</option>
              </select>
            </div>
          </div>

          <div>
            <label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/50 mb-1.5">Starts at *</label>
            <input type="datetime-local" name="startsAt" required class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-[0.85rem] text-white outline-none focus:border-burn" />
          </div>

          <div>
            <label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/50 mb-1.5">Ends at (optional)</label>
            <input type="datetime-local" name="endsAt" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-[0.85rem] text-white outline-none focus:border-burn" />
          </div>

          <div>
            <label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/50 mb-1.5">Location</label>
            <input type="text" name="location" placeholder="Bangalore, or Zoom" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-[0.85rem] text-white outline-none focus:border-burn" />
          </div>

          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/50 mb-1.5">Capacity <span class="text-white/40 normal-case font-normal">(blank = open seating)</span></label>
              <input type="number" name="capacity" min="0" max="9999" placeholder="50" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-[0.85rem] text-white outline-none focus:border-burn" />
            </div>
            <div>
              <label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/50 mb-1.5">Tags (comma-sep)</label>
              <input type="text" name="tags" placeholder="ai-safety, research" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-[0.85rem] text-white outline-none focus:border-burn" />
            </div>
          </div>

          <div>
            <label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/50 mb-1.5">Registration URL</label>
            <input type="url" name="registrationUrl" placeholder="https://lu.ma/..." class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-[0.85rem] text-white outline-none focus:border-burn" />
          </div>

          <div>
            <label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/50 mb-1.5">Cover image / GIF</label>
            <input type="url" name="coverImageUrl" placeholder="paste a URL or upload below" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-[0.85rem] text-white outline-none focus:border-burn" />
            <div class="flex items-center gap-2 mt-1.5">
              <input type="file" class="cover-upload text-[0.78rem] text-white/60" accept="image/png,image/jpeg,image/webp,image/gif" />
              <span class="cover-status text-[0.72rem] text-white/40"></span>
            </div>
          </div>
          <div>
            <label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/50 mb-1.5">Video / YouTube URL</label>
            <input type="url" name="videoUrl" placeholder="https://youtu.be/... or .mp4" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-[0.85rem] text-white outline-none focus:border-burn" />
          </div>
          <div>
            <label class="block text-[0.65rem] font-bold uppercase tracking-wider text-white/50 mb-1.5">Registration form slug (optional, from Forms)</label>
            <input type="text" name="registrationFormSlug" placeholder="e.g. bootcamp-registration" class="w-full px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-[0.85rem] text-white outline-none focus:border-burn" />
          </div>

          <button type="submit" class="bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-4 rounded-lg text-[0.88rem] mt-1">Create Event</button>
        </form>
      </div>
    </div>

  </div>

<script is:inline>
document.addEventListener("DOMContentLoaded", function() {
  document.querySelectorAll(".edit-toggle-btn").forEach(function(btn) {
    btn.addEventListener("click", function() {
      var id = btn.getAttribute("data-edit-id");
      var el = document.getElementById("edit-" + id);
      if (el) el.style.display = el.style.display === "none" ? "block" : "none";
    });
  });
  document.querySelectorAll(".edit-cancel-btn").forEach(function(btn) {
    btn.addEventListener("click", function() {
      var id = btn.getAttribute("data-edit-id");
      var el = document.getElementById("edit-" + id);
      if (el) el.style.display = "none";
    });
  });
  // Cover image upload -> fills the coverImageUrl field in the same form.
  document.querySelectorAll(".cover-upload").forEach(function(inp) {
    inp.addEventListener("change", function() {
      var file = inp.files && inp.files[0]; if (!file) return;
      var form = inp.closest("form");
      var urlInput = form && form.querySelector('input[name="coverImageUrl"]');
      var status = inp.parentNode.querySelector(".cover-status");
      if (status) { status.textContent = "Uploading..."; status.style.color = "rgba(255,255,255,0.5)"; }
      var fd = new FormData(); fd.append("file", file);
      fetch("/api/admin/upload-image", { method: "POST", credentials: "same-origin", body: fd })
        .then(function(r){ return r.json(); }).then(function(d){
          if (d.ok && urlInput) { urlInput.value = d.url; if (status) { status.textContent = "Uploaded - saved in the URL box. Click Save."; status.style.color = "#6ee7b7"; } }
          else if (status) { status.textContent = d.error || "Upload failed"; status.style.color = "#fca5a5"; }
        }).catch(function(){ if (status) { status.textContent = "Network error"; status.style.color = "#fca5a5"; } });
    });
  });
});
</script>
  </div>
</div>
</AdminLayout>
