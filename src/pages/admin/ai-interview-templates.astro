---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

let okMsg = '';
let errorMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = (fd.get('action') as string) || '';
  try {
    if (action === 'create_template') {
      const title = (fd.get('title') as string || '').trim();
      const slug = (fd.get('slug') as string || '').trim().toLowerCase().replace(/[^a-z0-9-]/g, '-');
      const description = (fd.get('description') as string || '').trim() || null;
      const languageDefault = (fd.get('language_default') as string || 'en-IN').trim();
      const maxMinutes = parseInt(fd.get('max_minutes') as string || '30') || 30;
      if (!title || !slug) errorMsg = 'Title and slug are required.';
      else {
        await db.execute(sql`
          INSERT INTO ai_interview_templates (title, slug, description, language_default, max_minutes, is_published)
          VALUES (${title}, ${slug}, ${description}, ${languageDefault}, ${maxMinutes}, false)
        `);
        okMsg = 'Template created. Add seed questions below.';
      }
    } else if (action === 'update_template') {
      const id = fd.get('id') as string;
      const title = (fd.get('title') as string || '').trim();
      const description = (fd.get('description') as string || '').trim() || null;
      const languageDefault = (fd.get('language_default') as string || 'en-IN').trim();
      const maxMinutes = parseInt(fd.get('max_minutes') as string || '30') || 30;
      await db.execute(sql`
        UPDATE ai_interview_templates SET title=${title}, description=${description},
          language_default=${languageDefault}, max_minutes=${maxMinutes}, updated_at=NOW()
        WHERE id=${id}
      `);
      okMsg = 'Template updated.';
    } else if (action === 'toggle_publish') {
      const id = fd.get('id') as string;
      await db.execute(sql`UPDATE ai_interview_templates SET is_published = NOT is_published, updated_at = NOW() WHERE id = ${id}`);
      okMsg = 'Publish status toggled.';
    } else if (action === 'delete_template') {
      const id = fd.get('id') as string;
      await db.execute(sql`DELETE FROM ai_interview_seeds WHERE template_id = ${id}`);
      await db.execute(sql`DELETE FROM ai_interview_templates WHERE id = ${id}`);
      okMsg = 'Template deleted.';
    } else if (action === 'add_seed') {
      const templateId = fd.get('template_id') as string;
      const promptText = (fd.get('prompt_text') as string || '').trim();
      const topicsRaw = (fd.get('expected_topics') as string || '').trim();
      const topics = topicsRaw ? topicsRaw.split(',').map(s => s.trim()).filter(Boolean) : [];
      const sortOrder = parseInt(fd.get('sort_order') as string || '99') || 99;
      if (!promptText) errorMsg = 'Question text required.';
      else {
        await db.execute(sql`
          INSERT INTO ai_interview_seeds (template_id, prompt_text, expected_topics, sort_order, is_active)
          VALUES (${templateId}, ${promptText}, ${topics}, ${sortOrder}, true)
        `);
        okMsg = 'Question added.';
      }
    } else if (action === 'delete_seed') {
      const id = fd.get('id') as string;
      await db.execute(sql`DELETE FROM ai_interview_seeds WHERE id = ${id}`);
      okMsg = 'Question deleted.';
    } else if (action === 'toggle_seed') {
      const id = fd.get('id') as string;
      await db.execute(sql`UPDATE ai_interview_seeds SET is_active = NOT is_active WHERE id = ${id}`);
      okMsg = 'Toggled.';
    }
  } catch (e: any) {
    errorMsg = 'Error: ' + (e?.message || 'Unknown');
  }
}

let templates: any[] = [];
let seedsByTemplate: Record<string, any[]> = {};
try {
  const r = await db.execute(sql`
    SELECT id, slug, title, description, language_default, max_minutes, is_published, created_at,
      (SELECT COUNT(*)::int FROM ai_interview_seeds WHERE template_id = t.id) as seed_count,
      (SELECT COUNT(*)::int FROM ai_interview_sessions WHERE template_id = t.id) as session_count
    FROM ai_interview_templates t ORDER BY created_at DESC
  `);
  templates = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`SELECT id, template_id, prompt_text, expected_topics, sort_order, is_active FROM ai_interview_seeds ORDER BY template_id, sort_order ASC`);
  const rows = (Array.isArray(r) ? r : (r?.rows || [])) as any[];
  for (const s of rows) (seedsByTemplate[s.template_id] = seedsByTemplate[s.template_id] || []).push(s);
} catch (_) {}

const LANGS = ['en-IN','en-US','en-GB','hi-IN','bn-IN','ta-IN','te-IN','mr-IN','gu-IN','es-ES','fr-FR','de-DE','ar-SA','zh-CN','ja-JP'];
---
<AdminLayout title="AI Interview Templates" activeNav="ai-interview-templates">
  <div style="max-width:1100px;margin:0 auto;padding:24px;">

    <div style="margin-bottom:18px;">
      <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">AI Interviews</p>
      <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Templates &amp; seed questions</h1>
      <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:680px;line-height:1.55;">Each template is a multilingual AI-conducted interview. Candidates pick a language; the AI speaks the seed questions aloud and listens to spoken answers. If <code style="color:#FF7040;">ANTHROPIC_API_KEY</code> is set, the LLM may add one follow-up when an answer is vague.</p>
    </div>

    {okMsg && <div style="background:rgba(16,185,129,0.12);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;padding:10px 14px;border-radius:8px;margin-bottom:14px;font-size:13px;">{okMsg}</div>}
    {errorMsg && <div style="background:rgba(239,68,68,0.12);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;padding:10px 14px;border-radius:8px;margin-bottom:14px;font-size:13px;">{errorMsg}</div>}

    <!-- Create template -->
    <details style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:14px 18px;margin-bottom:18px;">
      <summary style="cursor:pointer;font-size:13px;font-weight:700;color:#fff;">+ Create new template</summary>
      <form method="POST" style="margin-top:14px;display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <input type="hidden" name="action" value="create_template" />
        <div><label style="font-size:10px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;">Title</label>
          <input name="title" required style="width:100%;background:#15151a;border:1px solid #1a1a1f;color:#fff;padding:8px 10px;border-radius:6px;font-size:13px;outline:none;margin-top:4px;" /></div>
        <div><label style="font-size:10px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;">Slug (URL)</label>
          <input name="slug" required placeholder="ai-screen-1" style="width:100%;background:#15151a;border:1px solid #1a1a1f;color:#fff;padding:8px 10px;border-radius:6px;font-size:13px;outline:none;margin-top:4px;" /></div>
        <div style="grid-column:span 2;"><label style="font-size:10px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;">Description</label>
          <textarea name="description" rows="2" style="width:100%;background:#15151a;border:1px solid #1a1a1f;color:#fff;padding:8px 10px;border-radius:6px;font-size:13px;outline:none;margin-top:4px;font-family:inherit;resize:vertical;"></textarea></div>
        <div><label style="font-size:10px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;">Default language</label>
          <select name="language_default" style="width:100%;background:#15151a;border:1px solid #1a1a1f;color:#fff;padding:8px 10px;border-radius:6px;font-size:13px;outline:none;margin-top:4px;">
            {LANGS.map(l => <option value={l}>{l}</option>)}
          </select></div>
        <div><label style="font-size:10px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;">Max minutes</label>
          <input name="max_minutes" type="number" min="5" max="180" value="30" style="width:100%;background:#15151a;border:1px solid #1a1a1f;color:#fff;padding:8px 10px;border-radius:6px;font-size:13px;outline:none;margin-top:4px;" /></div>
        <div style="grid-column:span 2;"><button type="submit" style="background:#FF4F00;color:#fff;border:none;font-size:13px;font-weight:700;padding:9px 16px;border-radius:8px;cursor:pointer;">Create template</button></div>
      </form>
    </details>

    {templates.length === 0 && (
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:30px;text-align:center;color:#8a8a94;font-size:13px;">No templates yet. Create one above.</div>
    )}

    {templates.map((t: any) => {
      const seeds = seedsByTemplate[t.id] || [];
      return (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:18px 22px;margin-bottom:14px;">
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:12px;">
            <div style="min-width:0;flex:1;">
              <h2 style="font-size:17px;font-weight:700;color:#fff;margin:0;">{t.title}</h2>
              <p style="font-size:11.5px;color:#8a8a94;margin:3px 0 0;font-family:'Geist Mono',monospace;">/{t.slug} &middot; lang {t.language_default} &middot; {t.max_minutes}m &middot; {t.seed_count} questions &middot; {t.session_count} sessions</p>
              {t.description && <p style="font-size:12.5px;color:#d8d8de;margin:8px 0 0;line-height:1.55;">{t.description}</p>}
            </div>
            <div style="display:flex;gap:6px;flex-wrap:wrap;">
              <form method="POST" style="display:inline;">
                <input type="hidden" name="action" value="toggle_publish" />
                <input type="hidden" name="id" value={t.id} />
                <button type="submit" style={'background:' + (t.is_published ? '#10b981' : '#15151a') + ';color:#fff;border:1px solid #1a1a1f;font-size:11px;font-weight:700;padding:5px 12px;border-radius:6px;cursor:pointer;'}>{t.is_published ? 'Published' : 'Draft'}</button>
              </form>
              <a href={'/aquintutor/interview/' + t.slug} target="_blank" style="background:#15151a;color:#fff;border:1px solid #1a1a1f;font-size:11px;font-weight:600;padding:5px 12px;border-radius:6px;text-decoration:none;">View</a>
              <form method="POST" style="display:inline;" onsubmit="return confirm('Delete this template and all its questions?')">
                <input type="hidden" name="action" value="delete_template" />
                <input type="hidden" name="id" value={t.id} />
                <button type="submit" style="background:rgba(239,68,68,0.12);color:#fca5a5;border:1px solid rgba(239,68,68,0.3);font-size:11px;font-weight:600;padding:5px 12px;border-radius:6px;cursor:pointer;">Delete</button>
              </form>
            </div>
          </div>

          <!-- Seeds list -->
          <div style="margin-top:10px;">
            <p style="font-size:10px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;margin:0 0 8px;font-weight:700;">Seed questions ({seeds.length})</p>
            {seeds.length === 0 && <p style="font-size:11.5px;color:#6e6e78;font-style:italic;margin:0 0 8px;">No questions yet - add the first one below.</p>}
            {seeds.map((s: any) => (
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:10px;background:#15151a;border:1px solid #1a1a1f;border-radius:10px;padding:8px 12px;margin-bottom:6px;">
                <div style="min-width:0;flex:1;">
                  <p style="font-size:12.5px;color:#fff;margin:0;">#{s.sort_order} &middot; {s.prompt_text}</p>
                  {s.expected_topics && s.expected_topics.length > 0 && <p style="font-size:10.5px;color:#8a8a94;margin:3px 0 0;font-family:'Geist Mono',monospace;">topics: {s.expected_topics.join(', ')}</p>}
                </div>
                <div style="display:flex;gap:4px;">
                  <form method="POST" style="display:inline;"><input type="hidden" name="action" value="toggle_seed" /><input type="hidden" name="id" value={s.id} />
                    <button type="submit" style={'background:' + (s.is_active ? '#10b981' : '#15151a') + ';color:#fff;border:1px solid #1a1a1f;font-size:10px;font-weight:600;padding:3px 8px;border-radius:5px;cursor:pointer;'}>{s.is_active ? 'On' : 'Off'}</button>
                  </form>
                  <form method="POST" style="display:inline;" onsubmit="return confirm('Delete this question?')"><input type="hidden" name="action" value="delete_seed" /><input type="hidden" name="id" value={s.id} />
                    <button type="submit" style="background:rgba(239,68,68,0.12);color:#fca5a5;border:1px solid rgba(239,68,68,0.3);font-size:10px;font-weight:600;padding:3px 8px;border-radius:5px;cursor:pointer;">X</button>
                  </form>
                </div>
              </div>
            ))}

            <form method="POST" style="display:grid;grid-template-columns:80px 1fr 200px 110px;gap:8px;margin-top:8px;align-items:end;">
              <input type="hidden" name="action" value="add_seed" />
              <input type="hidden" name="template_id" value={t.id} />
              <div>
                <label style="font-size:10px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;">Order</label>
                <input name="sort_order" type="number" min="1" value={seeds.length + 1} style="width:100%;background:#15151a;border:1px solid #1a1a1f;color:#fff;padding:7px 10px;border-radius:6px;font-size:12.5px;outline:none;" />
              </div>
              <div>
                <label style="font-size:10px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;">Question text</label>
                <input name="prompt_text" required style="width:100%;background:#15151a;border:1px solid #1a1a1f;color:#fff;padding:7px 10px;border-radius:6px;font-size:12.5px;outline:none;" />
              </div>
              <div>
                <label style="font-size:10px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;">Expected topics (comma)</label>
                <input name="expected_topics" placeholder="leadership, ownership" style="width:100%;background:#15151a;border:1px solid #1a1a1f;color:#fff;padding:7px 10px;border-radius:6px;font-size:12.5px;outline:none;" />
              </div>
              <button type="submit" style="background:#FF4F00;color:#fff;border:none;font-size:12px;font-weight:700;padding:8px 12px;border-radius:6px;cursor:pointer;">+ Add</button>
            </form>
          </div>
        </div>
      );
    })}
  </div>
</AdminLayout>
