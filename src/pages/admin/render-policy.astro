---
// /admin/render-policy — Adaptive Rendering inspector + config (Prompt 5, admin surface).
// Gated by can(configure, rendering). Shows the tier x type directive matrix, lets you set a
// per-object override, and PREVIEWS a KnowledgeObject rendered at all three tiers (real server
// render with each tier's directive). Near-zero client JS (one inline form script).
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { RENDER_MATRIX, resolveDirective, rewriteMedia, getOverride, type ObjectRenderType } from '@/lib/render-policy';
import { contentService } from '@/lib/kernel-content';
import { mdLite } from '@/lib/content-render';
import type { RenderTier } from '@/lib/edu-runtime';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'configure', { type: 'rendering' });
if (!gate.allow) return Astro.redirect('/admin');

const TIERS: RenderTier[] = ['lite', 'standard', 'rich'];
const TYPES = Object.keys(RENDER_MATRIX) as ObjectRenderType[];

// preview a KO across the three tiers
const koId = (Astro.url.searchParams.get('ko') || '').trim();
let previewUnit: any = null, previewOverride: any = null;
if (koId) {
  const v = await contentService().getUnitView(koId).catch(() => null);
  if (v) { previewUnit = v.unit; previewOverride = await getOverride(koId).catch(() => null); }
}

const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const IN = 'background:#15151a;border:1px solid #26262c;color:#fff;padding:7px 9px;border-radius:6px;font-size:12px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
const tierColor: Record<string, string> = { lite: '#8a8a94', standard: '#5ea0c0', rich: '#6ee7b7' };
---
<AdminLayout title="Rendering policy" activeNav="render-policy">
  <div style="max-width:1120px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Adaptive rendering</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Rendering policy</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">Same content, different pipeline. The runtime picks a tier per student; this matrix maps (tier &times; object type) to concrete directives. Runtime traces: <a href="/admin/learning" style="color:#FF7040;">/admin/learning</a>.</p>
    <div id="msg" style="display:none;margin:12px 0;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <!-- MATRIX -->
    <div style={CARD}>
      <p style={HD}>Directive matrix (tier &times; type)</p>
      <div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:11.5px;font-family:'Geist Mono',monospace;">
        <thead><tr style="color:#8a8a94;font-size:9px;text-transform:uppercase;text-align:left;"><th style="padding:5px 8px;">Type</th><th style="padding:5px 8px;">Tier</th><th style="padding:5px 8px;">Hydrate</th><th style="padding:5px 8px;">Image</th><th style="padding:5px 8px;">Anim</th><th style="padding:5px 8px;">Physics</th><th style="padding:5px 8px;">Audio</th></tr></thead>
        <tbody>
          {TYPES.map((t) => TIERS.map((tier) => { const d = RENDER_MATRIX[t][tier]; return (
            <tr style="border-top:1px solid #15151a;">
              <td style="padding:4px 8px;color:#cfd6da;">{t}</td>
              <td style={'padding:4px 8px;font-weight:700;color:' + tierColor[tier]}>{tier}</td>
              <td style="padding:4px 8px;color:#cfd6da;">{d.hydrate.length ? d.hydrate.join(', ') : 'none (server HTML)'}</td>
              <td style="padding:4px 8px;color:#8a8a94;">{d.image.maxWidth}px {d.image.format}{d.image.lazy ? ' lazy' : ''}</td>
              <td style="padding:4px 8px;color:#8a8a94;">{d.animation}</td>
              <td style="padding:4px 8px;color:#8a8a94;">{d.physics ? 'on' : 'off'}</td>
              <td style="padding:4px 8px;color:#8a8a94;">{d.audio}</td>
            </tr>); }))}
        </tbody>
      </table></div>
    </div>

    <!-- PREVIEW + OVERRIDE -->
    <div style={CARD}>
      <p style={HD}>Preview a knowledge unit across all three tiers</p>
      <form method="GET" style="display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap;"><input name="ko" value={koId} placeholder="KnowledgeObject id" style={IN + 'width:340px;max-width:70vw;'} /><button type="submit" style="background:#15151a;border:1px solid #26262c;color:#cfd6da;font-size:11px;padding:6px 12px;border-radius:6px;cursor:pointer;">Preview</button></form>

      {koId && !previewUnit ? <p style="font-size:12.5px;color:#fca5a5;">No KnowledgeObject with that id.</p> : null}
      {previewUnit ? (
        <div>
          <p style="font-size:13px;color:#fff;margin:0 0 4px;font-weight:700;">{(previewUnit.data as any).title}</p>
          {previewOverride ? <p style="font-size:11px;color:#c0a35e;margin:0 0 12px;font-family:'Geist Mono',monospace;">per-object override active: {JSON.stringify(previewOverride)}</p> : null}
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px;">
            {TIERS.map((tier) => { const d = resolveDirective('KnowledgeObject', tier, previewOverride); const body = rewriteMedia(mdLite((previewUnit.data as any).body || '_no body_'), d); return (
              <div style="background:#08080a;border:1px solid #1a1a1f;border-radius:10px;padding:12px;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;"><b style={'font-family:Geist Mono,monospace;font-size:12px;color:' + tierColor[tier]}>{tier}</b><span style="font-size:9.5px;color:#6e6e78;font-family:'Geist Mono',monospace;">{d.hydrate.length ? 'hydrate: ' + d.hydrate.join(',') : 'no client JS'}</span></div>
                <div style="font-size:9.5px;color:#6e6e78;font-family:'Geist Mono',monospace;margin-bottom:8px;">img {d.image.maxWidth}px {d.image.format} &middot; anim {d.animation}</div>
                <div style="background:#fbfaf4;color:#1a1712;border-radius:6px;padding:10px 12px;font-size:12px;max-height:220px;overflow:auto;" set:html={body}></div>
              </div>); })}
          </div>

          <div style="margin-top:16px;background:#08080a;border:1px solid #26262c;border-radius:10px;padding:12px;">
            <p style="font-size:11px;color:#8a8a94;margin:0 0 8px;font-family:'Geist Mono',monospace;text-transform:uppercase;">Per-object override</p>
            <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:end;">
              <div><label style="font-size:10px;color:#8a8a94;">Hydrate (csv)</label><br/><input id="ovHydrate" style={IN} placeholder="e.g. (blank = none)" /></div>
              <div><label style="font-size:10px;color:#8a8a94;">Animation</label><br/><select id="ovAnim" style={IN}><option value="">(matrix)</option><option value="none">none</option><option value="basic">basic</option><option value="full">full</option></select></div>
              <div><label style="font-size:10px;color:#8a8a94;">Image width</label><br/><input id="ovW" type="number" style={IN + 'width:90px;'} /></div>
              <button id="ovSave" type="button" style="background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:700;padding:8px 14px;border-radius:6px;cursor:pointer;">Save override</button>
              <button id="ovClear" type="button" style="background:#2a1414;border:1px solid #5f2f2f;color:#fca5a5;font-size:11px;padding:8px 12px;border-radius:6px;cursor:pointer;">Clear</button>
            </div>
          </div>
        </div>
      ) : null}
    </div>
  </div>

  <script is:inline define:vars={{ koId }}>
    (function () {
      var msg = document.getElementById('msg');
      function flash(t, ok) { msg.style.display = 'block'; msg.textContent = t; msg.style.background = ok ? 'rgba(16,185,129,0.12)' : 'rgba(239,68,68,0.12)'; msg.style.color = ok ? '#6ee7b7' : '#fca5a5'; }
      function post(body) { return fetch('/api/admin/render-policy', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }).then(function (r) { return r.json(); }).then(function (j) { if (j.ok) { flash('Saved.', true); setTimeout(function () { location.reload(); }, 500); } else flash(j.error || 'Failed', false); }).catch(function () { flash('Network error', false); }); }
      var save = document.getElementById('ovSave'); if (save) save.addEventListener('click', function () { post({ action: 'set', objectId: koId, hydrate: document.getElementById('ovHydrate').value, animation: document.getElementById('ovAnim').value || undefined, imageMaxWidth: document.getElementById('ovW').value || undefined }); });
      var clr = document.getElementById('ovClear'); if (clr) clr.addEventListener('click', function () { post({ action: 'clear', objectId: koId }); });
    })();
  </script>
</AdminLayout>
