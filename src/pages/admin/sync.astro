---
// /admin/sync — Knowledge-Delta sync console (Prompt 7, admin surface). Gated by can(audit, sync).
// Shows the pending delta (changed + affected objects), the conflict queue with deterministic
// resolve actions, and per-object version history. Real data from kernel + edu_sync_* tables.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { computeServerDelta, detectConflicts, pendingCount, versionHistory } from '@/lib/knowledge-sync';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'audit', { type: 'sync' });
if (!gate.allow) return Astro.redirect('/admin');
const canManage = (await can(user, 'manage', { type: 'sync' })).allow;

const delta = await computeServerDelta().catch(() => ({ changed: [], affected: [], objects: [] as any[] }));
const conflicts = await detectConflicts().catch(() => []);
const pending = await pendingCount().catch(() => 0);
const histFor = (Astro.url.searchParams.get('h') || '').trim();
const history = histFor ? await versionHistory(histFor).catch(() => []) : [];

const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
const stateColor: Record<string, string> = { synced: '#6ee7b7', dirty: '#c0a35e', pending: '#5ea0c0', conflict: '#fca5a5' };
function fmt(d: any) { try { return new Date(d).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); } catch { return '-'; } }
---
<AdminLayout title="Knowledge sync" activeNav="sync">
  <div style="max-width:1080px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Knowledge synchronization</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Delta sync &amp; conflicts</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">Only changed objects sync; a change propagates along its dependent chain. Conflicts (both sides changed) are never silently overwritten. Offline queue: <a href="/admin/offline" style="color:#FF7040;">/admin/offline</a>.</p>
    <div id="msg" style="display:none;margin:12px 0;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:12px;margin-bottom:16px;">
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Changed (dirty)</p><p style="font-size:26px;font-weight:800;color:#fff;margin:4px 0 0;">{delta.changed.length}</p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">In delta (affected)</p><p style="font-size:26px;font-weight:800;color:#fff;margin:4px 0 0;">{delta.affected.length}</p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Conflicts</p><p style={'font-size:26px;font-weight:800;margin:4px 0 0;color:' + (conflicts.length ? '#fca5a5' : '#fff')}>{conflicts.length}</p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Queue depth</p><p style="font-size:26px;font-weight:800;color:#fff;margin:4px 0 0;">{pending}</p></div>
    </div>

    <!-- CONFLICTS -->
    <div style={CARD}>
      <p style={HD}>Conflict queue</p>
      {conflicts.length === 0 ? <p style="font-size:12.5px;color:#6e6e78;margin:0;">No conflicts. Concurrent changes on both sides would appear here for a deterministic resolve.</p> :
      <div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:12px;">
        <thead><tr style="color:#8a8a94;font-size:9px;text-transform:uppercase;font-family:'Geist Mono',monospace;text-align:left;"><th style="padding:5px 8px;">Object</th><th style="padding:5px 8px;">Base v</th><th style="padding:5px 8px;">Server v</th><th style="padding:5px 8px;">Resolve</th></tr></thead>
        <tbody>
          {conflicts.map((c: any) => (
            <tr style="border-top:1px solid #15151a;">
              <td style="padding:6px 8px;color:#cfd6da;font-family:'Geist Mono',monospace;">{String(c.objectId).slice(0, 8)}</td>
              <td style="padding:6px 8px;color:#8a8a94;">{c.baseVersion ?? '-'}</td>
              <td style="padding:6px 8px;color:#8a8a94;">{c.serverVersion}</td>
              <td style="padding:6px 8px;">{canManage ? (
                <span style="display:flex;gap:5px;flex-wrap:wrap;align-items:center;">
                  <select class="polSel" data-id={c.objectId} style="background:#15151a;border:1px solid #26262c;color:#fff;padding:4px 6px;border-radius:5px;font-size:11px;"><option value="server-wins">server-wins</option><option value="local-wins">local-wins</option><option value="higher-version">higher-version</option></select>
                  <button class="resBtn" data-id={c.objectId} type="button" style="background:#0f2f22;border:1px solid #1f5f42;color:#6ee7b7;font-size:11px;padding:5px 10px;border-radius:6px;cursor:pointer;">Resolve</button>
                </span>) : <span style="color:#6e6e78;font-size:11px;">view only</span>}</td>
            </tr>
          ))}
        </tbody>
      </table></div>}
    </div>

    <!-- DELTA -->
    <div style={CARD}>
      <p style={HD}>Pending delta (changed + affected only)</p>
      {delta.objects.length === 0 ? <p style="font-size:12.5px;color:#6e6e78;margin:0;">Nothing to sync. All objects are in the synced state.</p> :
      <div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:12px;">
        <thead><tr style="color:#8a8a94;font-size:9px;text-transform:uppercase;font-family:'Geist Mono',monospace;text-align:left;"><th style="padding:5px 8px;">Object</th><th style="padding:5px 8px;">Type</th><th style="padding:5px 8px;">Version</th><th style="padding:5px 8px;">State</th><th style="padding:5px 8px;">History</th></tr></thead>
        <tbody>
          {delta.objects.map((o: any) => (
            <tr style="border-top:1px solid #15151a;">
              <td style="padding:6px 8px;color:#cfd6da;font-family:'Geist Mono',monospace;">{String(o.id).slice(0, 8)}</td>
              <td style="padding:6px 8px;color:#8a8a94;">{o.type}</td>
              <td style="padding:6px 8px;color:#cfd6da;">v{o.version}</td>
              <td style="padding:6px 8px;"><span style={'font-family:Geist Mono,monospace;font-size:11px;font-weight:700;color:' + (stateColor[o.synchronization_state] || '#8a8a94')}>{o.synchronization_state}</span></td>
              <td style="padding:6px 8px;"><a href={'?h=' + o.id} style="color:#8a8a94;font-size:11px;text-decoration:none;border-bottom:1px dotted #3a3a44;">history</a></td>
            </tr>
          ))}
        </tbody>
      </table></div>}
      {canManage && delta.changed.length ? <button id="pushBtn" data-ids={delta.changed.join(',')} type="button" style="margin-top:12px;background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:700;padding:8px 14px;border-radius:6px;cursor:pointer;">Push all dirty (accept as synced)</button> : null}
    </div>

    {histFor ? (
      <div style={CARD}>
        <p style={HD}>Version history &middot; {histFor.slice(0, 8)}</p>
        {history.length === 0 ? <p style="font-size:12.5px;color:#6e6e78;margin:0;">No sync events for this object yet.</p> :
          <div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:11.5px;font-family:'Geist Mono',monospace;">
            <thead><tr style="color:#8a8a94;font-size:9px;text-transform:uppercase;text-align:left;"><th style="padding:5px 8px;">When</th><th style="padding:5px 8px;">Action</th><th style="padding:5px 8px;">From</th><th style="padding:5px 8px;">To</th><th style="padding:5px 8px;">Resolution</th></tr></thead>
            <tbody>{history.map((h: any) => (<tr style="border-top:1px solid #15151a;"><td style="padding:5px 8px;color:#8a8a94;">{fmt(h.at)}</td><td style="padding:5px 8px;color:#cfd6da;">{h.action}</td><td style="padding:5px 8px;color:#8a8a94;">{h.from_version ?? '-'}</td><td style="padding:5px 8px;color:#8a8a94;">{h.to_version ?? '-'}</td><td style="padding:5px 8px;color:#8a8a94;">{h.resolution ?? '-'}</td></tr>))}</tbody>
          </table></div>}
      </div>
    ) : null}
  </div>

  <script is:inline>
    (function () {
      var msg = document.getElementById('msg');
      function flash(t, ok) { msg.style.display = 'block'; msg.textContent = t; msg.style.background = ok ? 'rgba(16,185,129,0.12)' : 'rgba(239,68,68,0.12)'; msg.style.color = ok ? '#6ee7b7' : '#fca5a5'; }
      function post(body) { return fetch('/api/admin/sync', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }).then(function (r) { return r.json(); }).then(function (j) { if (j.ok) { flash('Done.', true); setTimeout(function () { location.reload(); }, 500); } else flash(j.error || 'Failed', false); }).catch(function () { flash('Network error', false); }); }
      document.querySelectorAll('.resBtn').forEach(function (b) { b.addEventListener('click', function () { var id = b.getAttribute('data-id'); var pol = document.querySelector('.polSel[data-id="' + id + '"]').value; post({ action: 'resolve', objectId: id, policy: pol }); }); });
      var pb = document.getElementById('pushBtn'); if (pb) pb.addEventListener('click', function () { post({ action: 'push', objectIds: pb.getAttribute('data-ids').split(',') }); });
    })();
  </script>
</AdminLayout>
