---
// /admin/billing — payments & refunds console + revenue from REAL data (Prompt AP5b). Registrar-gated.
// Revenue counts only captured payments and separates live vs test/comp — never a fabricated number.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { allPayments } from '@/lib/course-payments';
import { PLANS, revenuePaise, gatewayMode } from '@/lib/payment-gateway';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'manage', { type: 'enrolment' });
if (!gate.allow) return Astro.redirect('/admin');
const payments = await allPayments(120).catch(() => []);
const rev = revenuePaise(payments);
const mode = gatewayMode();
const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
function inr(paise: number) { return '₹' + (paise / 100).toLocaleString('en-IN'); }
---
<AdminLayout title="Billing" activeNav="billing">
  <div style="max-width:940px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Registrar</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Payments &amp; refunds</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;">Gateway mode: <b style={mode === 'live' ? 'color:#6ee7b7;' : 'color:#c0a35e;'}>{mode}</b>. Plans: {PLANS.map((p) => p.label + ' (' + inr(p.priceInr * 100) + ')').join(' · ')}.</p>
    <div id="msg" style="display:none;margin:12px 0;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin:16px 0;">
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Revenue (real / live)</p><p style="font-size:26px;font-weight:800;color:#6ee7b7;margin:4px 0 0;">{inr(rev.live)}</p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Test / comp (not real)</p><p style="font-size:26px;font-weight:800;color:#c0a35e;margin:4px 0 0;">{inr(rev.sandbox)}</p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Payments</p><p style="font-size:26px;font-weight:800;color:#fff;margin:4px 0 0;">{payments.length}</p></div>
    </div>

    <div style={CARD}>
      <p style={HD}>Payments</p>
      <table style="width:100%;border-collapse:collapse;font-size:12.5px;">
        <thead><tr style="text-align:left;color:#8a8a94;font-size:11px;text-transform:uppercase;"><th style="padding:6px 8px;">Plan</th><th style="padding:6px 8px;">Amount</th><th style="padding:6px 8px;">Status</th><th style="padding:6px 8px;">Mode</th><th style="padding:6px 8px;"></th></tr></thead>
        <tbody>
          {payments.map((p: any) => (
            <tr style="border-top:1px solid #1a1a1f;color:#d6d6de;">
              <td style="padding:7px 8px;">{p.plan}</td>
              <td style="padding:7px 8px;">{inr(p.amount_paise)}</td>
              <td style={'padding:7px 8px;color:' + (p.status === 'paid' ? '#6ee7b7' : p.status === 'refunded' ? '#c0a35e' : '#8a8a94')}>{p.status}</td>
              <td style="padding:7px 8px;font-family:'Geist Mono',monospace;font-size:11px;color:#8a8a94;">{p.mode}</td>
              <td style="padding:7px 8px;">{p.status === 'paid' && p.payment_id && p.payment_id !== 'comp' && p.payment_id !== 'free'
                ? <button class="refundBtn" data-pid={p.payment_id} style="background:#2a0f0f;color:#fca5a5;border:1px solid #3a1a1a;border-radius:7px;padding:5px 11px;font-size:12px;cursor:pointer;">Refund</button>
                : null}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <script is:inline>
    document.querySelectorAll('.refundBtn').forEach(function (b) {
      b.addEventListener('click', function () {
        if (!confirm('Refund this payment and re-lock the course?')) return;
        var msg = document.getElementById('msg');
        fetch('/api/admin/billing', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'refund', paymentId: b.getAttribute('data-pid') }) })
          .then(function (r) { return r.json(); }).then(function (j) { msg.style.display = 'block'; if (j.ok) { msg.style.background = '#0f2a1c'; msg.style.color = '#6ee7b7'; msg.textContent = 'Refunded. Reloading…'; setTimeout(function () { location.reload(); }, 800); } else { msg.style.background = '#2a0f0f'; msg.style.color = '#fca5a5'; msg.textContent = j.error || 'Failed'; } });
      });
    });
  </script>
</AdminLayout>
