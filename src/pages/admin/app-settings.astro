---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { getCheckoutSettings, saveSettings, CHECKOUT_DEFAULTS } from '@/lib/app-settings';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role !== 'super_admin') return Astro.redirect('/admin');

let okMsg = '';
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const value = {
    heading: (fd.get('heading') as string || '').trim() || CHECKOUT_DEFAULTS.heading,
    subhead: (fd.get('subhead') as string || '').trim(),
    included: (fd.get('included') as string || '').split('\n').map((s) => s.trim()).filter(Boolean),
    taxMode: (fd.get('taxMode') as string || 'inclusive'),
    taxNote: (fd.get('taxNote') as string || '').trim(),
    disclaimer: (fd.get('disclaimer') as string || '').trim() || CHECKOUT_DEFAULTS.disclaimer,
    showAid: fd.get('showAid') === 'on',
  };
  try { await saveSettings('checkout', value); okMsg = 'Checkout settings saved.'; } catch (_) { okMsg = 'Save failed.'; }
}

const s = await getCheckoutSettings();
---
<AdminLayout title="Checkout & Fee Settings" activeNav="appsettings">
  <div class="admin-page" style="max-width:760px;">
    <div class="admin-page-header">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">Configuration</div>
        <h1 class="admin-page-title">Checkout &amp; Fees</h1>
        <p class="admin-page-sub">Control the wording, the "what's included" list, tax treatment and which options appear on the application checkout. Charge amounts stay role-driven and server-computed — this never changes what a candidate is charged.</p>
      </div>
    </div>

    {okMsg && <div style="margin:0 0 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

    <form method="POST">
      <div class="s-card">
        <p class="s-h">Heading</p>
        <label class="s-l">Title</label>
        <input name="heading" value={s.heading} class="s-i" />
        <label class="s-l" style="margin-top:10px;">Subtext (blank = role-based default sentence)</label>
        <input name="subhead" value={s.subhead} class="s-i" placeholder="Every application goes through manual verification..." />
      </div>

      <div class="s-card">
        <p class="s-h">What's included</p>
        <label class="s-l">One bullet per line</label>
        <textarea name="included" rows="4" class="s-i" style="resize:vertical;">{s.included.join('\n')}</textarea>
      </div>

      <div class="s-card">
        <p class="s-h">Tax</p>
        <div style="display:grid;grid-template-columns:1fr 2fr;gap:12px;">
          <div>
            <label class="s-l">Mode</label>
            <select name="taxMode" class="s-i">
              <option value="inclusive" selected={s.taxMode === 'inclusive'}>Inclusive</option>
              <option value="exclusive" selected={s.taxMode === 'exclusive'}>Exclusive</option>
              <option value="none" selected={s.taxMode === 'none'}>Don't show</option>
            </select>
          </div>
          <div>
            <label class="s-l">Tax note shown on the fee</label>
            <input name="taxNote" value={s.taxNote} class="s-i" placeholder="e.g. Inclusive of 18% GST" />
          </div>
        </div>
        <p style="font-size:11.5px;color:#6e6e78;margin:8px 0 0;">Shown under the fee amount. Use "Exclusive" + a note like "+ 18% GST at checkout" if tax is added separately.</p>
      </div>

      <div class="s-card">
        <p class="s-h">Disclaimer</p>
        <textarea name="disclaimer" rows="3" class="s-i" style="resize:vertical;">{s.disclaimer}</textarea>
      </div>

      <div class="s-card" style="display:flex;align-items:center;justify-content:space-between;gap:14px;">
        <div>
          <p class="s-h" style="margin:0;">Show financial-aid options</p>
          <p style="font-size:12px;color:#8a8a94;margin:3px 0 0;">The "I need financial aid" path, coupon redemption and pay-from-abroad. Off = candidates can only pay the fee.</p>
        </div>
        <label style="position:relative;display:inline-block;width:48px;height:26px;flex-shrink:0;">
          <input type="checkbox" name="showAid" checked={s.showAid} style="opacity:0;width:0;height:0;" id="aidToggle" />
          <span id="aidTrack" style={'position:absolute;inset:0;border-radius:100px;cursor:pointer;transition:.2s;background:' + (s.showAid ? '#FF4F00' : '#2a2a32') + ';'}></span>
          <span id="aidKnob" style={'position:absolute;top:3px;left:' + (s.showAid ? '25px' : '3px') + ';width:20px;height:20px;background:#fff;border-radius:50%;transition:.2s;pointer-events:none;'}></span>
        </label>
      </div>

      <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:700;font-size:14px;padding:13px;border-radius:10px;cursor:pointer;">Save settings</button>
    </form>
  </div>

  <style>
    .s-card { background:#0f0f14; border:1px solid #1a1a1f; border-radius:12px; padding:16px; margin-bottom:14px; }
    .s-h { font-size:14px; font-weight:600; color:#fff; margin:0 0 10px; }
    .s-l { display:block; font-size:10px; text-transform:uppercase; letter-spacing:0.08em; color:#8a8a94; font-weight:700; margin-bottom:5px; }
    .s-i { width:100%; background:#08080a; border:1px solid #1a1a1f; border-radius:8px; padding:10px 12px; color:#fff; font-size:13px; outline:none; }
    .s-i:focus { border-color:#FF4F00; }
  </style>
  <script is:inline>
    (function () {
      var t = document.getElementById('aidToggle'); if (!t) return;
      function paint() {
        document.getElementById('aidTrack').style.background = t.checked ? '#FF4F00' : '#2a2a32';
        document.getElementById('aidKnob').style.left = t.checked ? '25px' : '3px';
      }
      t.parentElement.addEventListener('click', function (e) { if (e.target !== t) { t.checked = !t.checked; paint(); } });
      t.addEventListener('change', paint);
    })();
  </script>
</AdminLayout>
