---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { hashPassword, verifyPassword } from '@/lib/auth/password';
import { getMailboxAddress } from '@/lib/mail';
import { ROLE_LABELS } from '@/lib/auth/permissions';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

function rows(r: any) { return Array.isArray(r) ? r : (r?.rows || []); }

let okMsg = '';
let errMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('_action') as string;
  try {
    if (action === 'change_password') {
      const current = (fd.get('current') as string || '');
      const next = (fd.get('next') as string || '');
      const confirm = (fd.get('confirm') as string || '');
      if (!current || !next) errMsg = 'Fill in both fields.';
      else if (next.length < 8) errMsg = 'New password must be at least 8 characters.';
      else if (next !== confirm) errMsg = 'New passwords do not match.';
      else {
        const ur = rows(await db.execute(sql`SELECT password_hash FROM users WHERE id = ${user.id} LIMIT 1`));
        const ok = ur[0] && await verifyPassword(ur[0].password_hash, current);
        if (!ok) errMsg = 'Current password is incorrect.';
        else {
          const hash = await hashPassword(next);
          await db.execute(sql`UPDATE users SET password_hash = ${hash}, updated_at = NOW() WHERE id = ${user.id}`);
          okMsg = 'Password updated.';
        }
      }
    } else if (action === 'update_my_hr') {
      // Self-service: every personal / contact / address / gov-ID / banking
      // field on the employee's own HR record. Designation, salary, joining,
      // and employment type stay HR-only (rejected here even if posted).
      const empId = (fd.get('empId') as string || '').trim();
      if (empId) {
        await db.execute(sql`
          UPDATE hr_employees SET
            phone                       = ${(fd.get('phone') as string || '').trim() || null},
            personal_email              = ${(fd.get('personalEmail') as string || '').trim() || null},
            date_of_birth               = ${(fd.get('dob') as string || '').trim() || null},
            gender                      = ${(fd.get('gender') as string || '').trim() || null},
            nationality                 = ${(fd.get('nationality') as string || '').trim() || null},
            blood_group                 = ${(fd.get('bloodGroup') as string || '').trim() || null},
            emergency_contact_name      = ${(fd.get('emergencyName') as string || '').trim() || null},
            emergency_contact_phone     = ${(fd.get('emergencyPhone') as string || '').trim() || null},
            emergency_contact_relation  = ${(fd.get('emergencyRelation') as string || '').trim() || null},
            city                        = ${(fd.get('city') as string || '').trim() || null},
            state                       = ${(fd.get('state') as string || '').trim() || null},
            country                     = ${(fd.get('country') as string || '').trim() || null},
            pan_number                  = ${(fd.get('panNumber') as string || '').trim() || null},
            aadhaar_number              = ${(fd.get('aadhaarNumber') as string || '').trim() || null},
            bank_account_number         = ${(fd.get('bankAccountNumber') as string || '').trim() || null},
            bank_name                   = ${(fd.get('bankName') as string || '').trim() || null},
            bank_ifsc                   = ${(fd.get('bankIfsc') as string || '').trim() || null},
            bank_branch                 = ${(fd.get('bankBranch') as string || '').trim() || null},
            uan_number                  = ${(fd.get('uanNumber') as string || '').trim() || null},
            pf_number                   = ${(fd.get('pfNumber') as string || '').trim() || null},
            esic_number                 = ${(fd.get('esicNumber') as string || '').trim() || null},
            updated_at = NOW()
          WHERE id = ${empId} AND (user_id = ${user.id} OR personal_email = ${user.email} OR email = ${user.email})
        `);
        okMsg = 'Your details were saved. HR will see the updates next time they open your record.';
      }
    } else if (action === 'save_signature') {
      const signature = (fd.get('signature') as string || '').slice(0, 5000);
      const displayName = (fd.get('display_name') as string || '').slice(0, 200);
      await db.execute(sql`
        INSERT INTO mail_settings (user_id, signature_html, display_name, updated_at)
        VALUES (${user.id}, ${signature}, ${displayName}, NOW())
        ON CONFLICT (user_id) DO UPDATE SET signature_html = EXCLUDED.signature_html, display_name = EXCLUDED.display_name, updated_at = NOW()
      `);
      okMsg = 'Mail signature saved.';
    }
  } catch (e: any) { errMsg = 'Failed: ' + (e?.message || 'error'); }
}

const mailbox = await getMailboxAddress(user.id);
let settings: any = {};
try { settings = rows(await db.execute(sql`SELECT signature_html, display_name FROM mail_settings WHERE user_id = ${user.id} LIMIT 1`))[0] || {}; } catch (e) {}
let extra: any = {};
try { extra = rows(await db.execute(sql`SELECT photo_url, created_at, last_login_at FROM users WHERE id = ${user.id} LIMIT 1`))[0] || {}; } catch (e) {}

// Linked employee record (HR profile). Matched by user_id or one of the emails.
let emp: any = null;
try {
  emp = rows(await db.execute(sql`
    SELECT e.*, d.name AS department_name
    FROM hr_employees e
    LEFT JOIN departments d ON e.department_id = d.id
    WHERE e.user_id = ${user.id} OR e.personal_email = ${user.email} OR e.email = ${user.email}
    LIMIT 1
  `))[0] || null;
} catch (e) {}
function fmtDate(d: any) { return d ? new Date(d).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) : '—'; }
function dateInput(d: any) { return d ? String(d).slice(0, 10) : ''; }

const roleLabel = (ROLE_LABELS as any)[user.role] || user.role;
const initial = (user.name || '?').trim().charAt(0).toUpperCase();
const memberSince = extra.created_at ? new Date(extra.created_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) : '';
const lastLogin = extra.last_login_at ? new Date(extra.last_login_at).toLocaleString('en-IN', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : 'This session';
---
<AdminLayout title="Profile" activeNav="">
  <div class="admin-page" style="max-width:760px;">
    <div class="admin-page-header" style="margin-bottom:20px;">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">Account</div>
        <h1 class="admin-page-title">Your profile</h1>
        <p class="admin-page-sub">Manage your account, password, and mail identity.</p>
      </div>
    </div>

    {okMsg && <div style="background:rgba(16,185,129,0.10);border:1px solid rgba(16,185,129,0.28);color:#6ee7b7;font-size:12.5px;padding:11px 14px;border-radius:8px;margin-bottom:16px;">{okMsg}</div>}
    {errMsg && <div style="background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.28);color:#fca5a5;font-size:12.5px;padding:11px 14px;border-radius:8px;margin-bottom:16px;">{errMsg}</div>}

    <div class="admin-card" style="display:flex;align-items:center;gap:16px;margin-bottom:16px;">
      {extra.photo_url
        ? <img src={extra.photo_url} alt="" style="width:64px;height:64px;border-radius:50%;object-fit:cover;border:1px solid var(--o-stroke);" />
        : <div style="width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--o-brand,#FF4F00),var(--o-brand-bright,#ff8a4c));display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:800;color:#fff;">{initial}</div>}
      <div style="min-width:0;">
        <div style="font-size:18px;font-weight:800;color:var(--o-hi,#fff);">{user.name}</div>
        <div style="font-size:12.5px;color:var(--o-mid,#8a8a94);">{roleLabel}{memberSince ? ' · since ' + memberSince : ''}</div>
        <div style="font-size:12px;color:var(--o-mid,#8a8a94);margin-top:2px;font-family:'Geist Mono',monospace;">Last login: {lastLogin}</div>
      </div>
    </div>

    {emp && (
      <div class="admin-card" style="margin-bottom:16px;">
        <div class="admin-card-title" style="margin-bottom:10px;">Your HR profile</div>
        <p style="font-size:11.5px;color:var(--o-mid,#8a8a94);margin:0 0 12px;line-height:1.6;">HR can see and edit everything below. The greyed fields are set by HR; the rest you can fill in / keep up to date yourself.</p>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;background:var(--o-panel,rgba(255,255,255,0.03));border:1px solid var(--o-stroke,#1a1a1f);border-radius:10px;padding:12px;">
          <div><div style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:var(--o-mid,#8a8a94);">Employee code</div><div style="font-size:13px;font-family:'Geist Mono',monospace;color:var(--o-hi,#fff);">{emp.employee_code || '—'}</div></div>
          <div><div style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:var(--o-mid,#8a8a94);">Designation</div><div style="font-size:13px;color:var(--o-hi,#fff);">{emp.designation || '—'}</div></div>
          <div><div style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:var(--o-mid,#8a8a94);">Department</div><div style="font-size:13px;color:var(--o-hi,#fff);">{emp.department_name || '—'}</div></div>
          <div><div style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:var(--o-mid,#8a8a94);">Joining date</div><div style="font-size:13px;color:var(--o-hi,#fff);">{fmtDate(emp.joining_date)}</div></div>
          <div><div style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:var(--o-mid,#8a8a94);">Employment type</div><div style="font-size:13px;color:var(--o-hi,#fff);">{(emp.employment_type || '').replace('_', ' ') || '—'}</div></div>
          <div><div style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:var(--o-mid,#8a8a94);">Status</div><div style="font-size:13px;color:var(--o-hi,#fff);text-transform:capitalize;">{(emp.employment_status || (emp.is_active ? 'active' : 'inactive')).replace('_',' ')}</div></div>
        </div>
      </div>
    )}

    {emp && (
      <form method="POST" class="admin-card" style="margin-bottom:16px;display:flex;flex-direction:column;gap:14px;">
        <input type="hidden" name="_action" value="update_my_hr" />
        <input type="hidden" name="empId" value={emp.id} />

        <div class="admin-card-title">Personal &amp; address</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          <div><label class="rolefield-label">Work phone</label><input type="tel" name="phone" value={emp.phone || ''} class="rolefield-input" /></div>
          <div><label class="rolefield-label">Personal email</label><input type="email" name="personalEmail" value={emp.personal_email || ''} class="rolefield-input" /></div>
          <div><label class="rolefield-label">Date of birth</label><input type="date" name="dob" value={dateInput(emp.date_of_birth)} class="rolefield-input" /></div>
          <div><label class="rolefield-label">Gender</label>
            <select name="gender" class="rolefield-input">
              <option value="">Select</option>
              {['male','female','other','prefer_not_to_say'].map((g) => (<option value={g} selected={emp.gender === g}>{g.replace(/_/g,' ')}</option>))}
            </select>
          </div>
          <div><label class="rolefield-label">Blood group</label>
            <select name="bloodGroup" class="rolefield-input">
              <option value="">Select</option>
              {['A+','A-','B+','B-','O+','O-','AB+','AB-'].map((b) => (<option value={b} selected={emp.blood_group === b}>{b}</option>))}
            </select>
          </div>
          <div><label class="rolefield-label">Nationality</label><input type="text" name="nationality" value={emp.nationality || ''} class="rolefield-input" /></div>
          <div><label class="rolefield-label">City</label><input type="text" name="city" value={emp.city || ''} class="rolefield-input" /></div>
          <div><label class="rolefield-label">State</label><input type="text" name="state" value={emp.state || ''} class="rolefield-input" /></div>
          <div><label class="rolefield-label">Country</label><input type="text" name="country" value={emp.country || ''} class="rolefield-input" /></div>
        </div>

        <div style="border-top:1px solid var(--o-stroke,#1a1a1f);padding-top:14px;">
          <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--o-mid,#8a8a94);margin-bottom:10px;">Emergency contact</div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
            <div><label class="rolefield-label">Name</label><input type="text" name="emergencyName" value={emp.emergency_contact_name || ''} class="rolefield-input" /></div>
            <div><label class="rolefield-label">Phone</label><input type="tel" name="emergencyPhone" value={emp.emergency_contact_phone || ''} class="rolefield-input" /></div>
            <div><label class="rolefield-label">Relation</label><input type="text" name="emergencyRelation" value={emp.emergency_contact_relation || ''} class="rolefield-input" placeholder="Spouse, Parent..." /></div>
          </div>
        </div>

        <div style="border-top:1px solid var(--o-stroke,#1a1a1f);padding-top:14px;">
          <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--o-mid,#8a8a94);margin-bottom:10px;">Government IDs</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div><label class="rolefield-label">PAN number</label><input type="text" name="panNumber" value={emp.pan_number || ''} class="rolefield-input" placeholder="ABCDE1234F" /></div>
            <div><label class="rolefield-label">Aadhaar number</label><input type="text" name="aadhaarNumber" value={emp.aadhaar_number || ''} class="rolefield-input" placeholder="XXXX XXXX XXXX" /></div>
          </div>
        </div>

        <div style="border-top:1px solid var(--o-stroke,#1a1a1f);padding-top:14px;">
          <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--o-mid,#8a8a94);margin-bottom:6px;">Banking &amp; payroll</div>
          <p style="font-size:11px;color:var(--o-mid,#8a8a94);margin:0 0 10px;">Used for salary credit. Visible only to you and HR.</p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div><label class="rolefield-label">Account number</label><input type="text" name="bankAccountNumber" value={emp.bank_account_number || ''} class="rolefield-input" /></div>
            <div><label class="rolefield-label">Bank name</label><input type="text" name="bankName" value={emp.bank_name || ''} class="rolefield-input" /></div>
            <div><label class="rolefield-label">IFSC</label><input type="text" name="bankIfsc" value={emp.bank_ifsc || ''} class="rolefield-input" placeholder="HDFC0001234" /></div>
            <div><label class="rolefield-label">Branch</label><input type="text" name="bankBranch" value={emp.bank_branch || ''} class="rolefield-input" /></div>
            <div><label class="rolefield-label">UAN (PF)</label><input type="text" name="uanNumber" value={emp.uan_number || ''} class="rolefield-input" /></div>
            <div><label class="rolefield-label">PF number</label><input type="text" name="pfNumber" value={emp.pf_number || ''} class="rolefield-input" /></div>
            <div><label class="rolefield-label">ESIC number</label><input type="text" name="esicNumber" value={emp.esic_number || ''} class="rolefield-input" /></div>
          </div>
        </div>

        <div><button type="submit" class="admin-btn-primary" style="padding:9px 22px;">Save my details</button></div>
      </form>
    )}

    <div class="admin-card" style="margin-bottom:16px;">
      <div class="admin-card-title" style="margin-bottom:12px;">Identity</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div>
          <div style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:var(--o-mid,#8a8a94);margin-bottom:3px;">Login email</div>
          <div style="font-size:13px;color:var(--o-hi,#fff);font-family:'Geist Mono',monospace;word-break:break-all;">{user.email}</div>
        </div>
        <div>
          <div style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:var(--o-mid,#8a8a94);margin-bottom:3px;">Mailbox address</div>
          <div style="font-size:13px;color:var(--o-brand,#FF7040);font-family:'Geist Mono',monospace;word-break:break-all;">{mailbox}</div>
        </div>
      </div>
      <a href="/admin/mail" style="display:inline-block;margin-top:12px;font-size:12px;color:var(--o-brand,#FF7040);text-decoration:none;">Open your inbox &rarr;</a>
    </div>

    <form method="POST" class="admin-card" style="margin-bottom:16px;display:flex;flex-direction:column;gap:12px;">
      <input type="hidden" name="_action" value="change_password" />
      <div class="admin-card-title">Change password</div>
      <div>
        <label class="rolefield-label">Current password</label>
        <input type="password" name="current" required class="rolefield-input" autocomplete="current-password" />
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div>
          <label class="rolefield-label">New password</label>
          <input type="password" name="next" required minlength="8" class="rolefield-input" autocomplete="new-password" />
        </div>
        <div>
          <label class="rolefield-label">Confirm new</label>
          <input type="password" name="confirm" required minlength="8" class="rolefield-input" autocomplete="new-password" />
        </div>
      </div>
      <div><button type="submit" class="admin-btn-primary" style="padding:9px 20px;">Update password</button></div>
    </form>

    <form method="POST" class="admin-card" style="display:flex;flex-direction:column;gap:12px;">
      <input type="hidden" name="_action" value="save_signature" />
      <div class="admin-card-title">Mail identity</div>
      <div>
        <label class="rolefield-label">Display name (shown on outgoing mail)</label>
        <input type="text" name="display_name" value={settings.display_name || user.name} class="rolefield-input" />
      </div>
      <div>
        <label class="rolefield-label">Signature</label>
        <textarea name="signature" rows="4" class="rolefield-input" placeholder="-- Your name, role, EduRankAI">{settings.signature_html || ''}</textarea>
      </div>
      <div><button type="submit" class="admin-btn-primary" style="padding:9px 20px;">Save mail identity</button></div>
    </form>
  </div>
</AdminLayout>
