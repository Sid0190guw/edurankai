---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { hashPassword, verifyPassword } from '@/lib/auth/password';
import { getMailboxAddress } from '@/lib/mail';
import { ROLE_LABELS } from '@/lib/auth/permissions';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

function rows(r: any) { return Array.isArray(r) ? r : (r?.rows || []); }

let okMsg = '';
let errMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('_action') as string;
  try {
    if (action === 'change_password') {
      const current = (fd.get('current') as string || '');
      const next = (fd.get('next') as string || '');
      const confirm = (fd.get('confirm') as string || '');
      if (!current || !next) errMsg = 'Fill in both fields.';
      else if (next.length < 8) errMsg = 'New password must be at least 8 characters.';
      else if (next !== confirm) errMsg = 'New passwords do not match.';
      else {
        const ur = rows(await db.execute(sql`SELECT password_hash FROM users WHERE id = ${user.id} LIMIT 1`));
        const ok = ur[0] && await verifyPassword(ur[0].password_hash, current);
        if (!ok) errMsg = 'Current password is incorrect.';
        else {
          const hash = await hashPassword(next);
          await db.execute(sql`UPDATE users SET password_hash = ${hash}, updated_at = NOW() WHERE id = ${user.id}`);
          okMsg = 'Password updated.';
        }
      }
    } else if (action === 'save_signature') {
      const signature = (fd.get('signature') as string || '').slice(0, 5000);
      const displayName = (fd.get('display_name') as string || '').slice(0, 200);
      await db.execute(sql`
        INSERT INTO mail_settings (user_id, signature_html, display_name, updated_at)
        VALUES (${user.id}, ${signature}, ${displayName}, NOW())
        ON CONFLICT (user_id) DO UPDATE SET signature_html = EXCLUDED.signature_html, display_name = EXCLUDED.display_name, updated_at = NOW()
      `);
      okMsg = 'Mail signature saved.';
    }
  } catch (e: any) { errMsg = 'Failed: ' + (e?.message || 'error'); }
}

const mailbox = await getMailboxAddress(user.id);
let settings: any = {};
try { settings = rows(await db.execute(sql`SELECT signature_html, display_name FROM mail_settings WHERE user_id = ${user.id} LIMIT 1`))[0] || {}; } catch (e) {}
let extra: any = {};
try { extra = rows(await db.execute(sql`SELECT photo_url, created_at, last_login_at FROM users WHERE id = ${user.id} LIMIT 1`))[0] || {}; } catch (e) {}

const roleLabel = (ROLE_LABELS as any)[user.role] || user.role;
const initial = (user.name || '?').trim().charAt(0).toUpperCase();
const memberSince = extra.created_at ? new Date(extra.created_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) : '';
const lastLogin = extra.last_login_at ? new Date(extra.last_login_at).toLocaleString('en-IN', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : 'This session';
---
<AdminLayout title="Profile" activeNav="">
  <div class="admin-page" style="max-width:760px;">
    <div class="admin-page-header" style="margin-bottom:20px;">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">Account</div>
        <h1 class="admin-page-title">Your profile</h1>
        <p class="admin-page-sub">Manage your account, password, and mail identity.</p>
      </div>
    </div>

    {okMsg && <div style="background:rgba(16,185,129,0.10);border:1px solid rgba(16,185,129,0.28);color:#6ee7b7;font-size:12.5px;padding:11px 14px;border-radius:8px;margin-bottom:16px;">{okMsg}</div>}
    {errMsg && <div style="background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.28);color:#fca5a5;font-size:12.5px;padding:11px 14px;border-radius:8px;margin-bottom:16px;">{errMsg}</div>}

    <div class="admin-card" style="display:flex;align-items:center;gap:16px;margin-bottom:16px;">
      {extra.photo_url
        ? <img src={extra.photo_url} alt="" style="width:64px;height:64px;border-radius:50%;object-fit:cover;border:1px solid var(--o-stroke);" />
        : <div style="width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--o-brand,#FF4F00),var(--o-brand-bright,#ff8a4c));display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:800;color:#fff;">{initial}</div>}
      <div style="min-width:0;">
        <div style="font-size:18px;font-weight:800;color:var(--o-hi,#fff);">{user.name}</div>
        <div style="font-size:12.5px;color:var(--o-mid,#8a8a94);">{roleLabel}{memberSince ? ' · since ' + memberSince : ''}</div>
        <div style="font-size:12px;color:var(--o-mid,#8a8a94);margin-top:2px;font-family:'Geist Mono',monospace;">Last login: {lastLogin}</div>
      </div>
    </div>

    <div class="admin-card" style="margin-bottom:16px;">
      <div class="admin-card-title" style="margin-bottom:12px;">Identity</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div>
          <div style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:var(--o-mid,#8a8a94);margin-bottom:3px;">Login email</div>
          <div style="font-size:13px;color:var(--o-hi,#fff);font-family:'Geist Mono',monospace;word-break:break-all;">{user.email}</div>
        </div>
        <div>
          <div style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:var(--o-mid,#8a8a94);margin-bottom:3px;">Mailbox address</div>
          <div style="font-size:13px;color:var(--o-brand,#FF7040);font-family:'Geist Mono',monospace;word-break:break-all;">{mailbox}</div>
        </div>
      </div>
      <a href="/admin/mail" style="display:inline-block;margin-top:12px;font-size:12px;color:var(--o-brand,#FF7040);text-decoration:none;">Open your inbox &rarr;</a>
    </div>

    <form method="POST" class="admin-card" style="margin-bottom:16px;display:flex;flex-direction:column;gap:12px;">
      <input type="hidden" name="_action" value="change_password" />
      <div class="admin-card-title">Change password</div>
      <div>
        <label class="rolefield-label">Current password</label>
        <input type="password" name="current" required class="rolefield-input" autocomplete="current-password" />
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div>
          <label class="rolefield-label">New password</label>
          <input type="password" name="next" required minlength="8" class="rolefield-input" autocomplete="new-password" />
        </div>
        <div>
          <label class="rolefield-label">Confirm new</label>
          <input type="password" name="confirm" required minlength="8" class="rolefield-input" autocomplete="new-password" />
        </div>
      </div>
      <div><button type="submit" class="admin-btn-primary" style="padding:9px 20px;">Update password</button></div>
    </form>

    <form method="POST" class="admin-card" style="display:flex;flex-direction:column;gap:12px;">
      <input type="hidden" name="_action" value="save_signature" />
      <div class="admin-card-title">Mail identity</div>
      <div>
        <label class="rolefield-label">Display name (shown on outgoing mail)</label>
        <input type="text" name="display_name" value={settings.display_name || user.name} class="rolefield-input" />
      </div>
      <div>
        <label class="rolefield-label">Signature</label>
        <textarea name="signature" rows="4" class="rolefield-input" placeholder="-- Your name, role, EduRankAI">{settings.signature_html || ''}</textarea>
      </div>
      <div><button type="submit" class="admin-btn-primary" style="padding:9px 20px;">Save mail identity</button></div>
    </form>
  </div>
</AdminLayout>
