---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

let okMsg = '';
let errorMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  try {
    if (action === 'create') {
      const title = (fd.get('title') as string || '').trim();
      const slug = (fd.get('slug') as string || '').trim().toLowerCase().replace(/[^a-z0-9-]/g, '-');
      const shortDesc = (fd.get('short_desc') as string || '').trim() || null;
      const category = (fd.get('category') as string || 'general').trim();
      const level = (fd.get('level') as string || 'beginner').trim();
      const accessType = (fd.get('access_type') as string || 'public').trim();
      const isFree = fd.get('is_free') === 'on';
      if (!title || !slug) { errorMsg = 'Title and slug are required.'; }
      else {
        await db.execute(sql`
          INSERT INTO training_courses (title, slug, short_desc, category, level, access_type, is_free, is_published, created_by, created_at, updated_at)
          VALUES (${title}, ${slug}, ${shortDesc}, ${category}, ${level}, ${accessType}, ${isFree}, false, ${user.id}, NOW(), NOW())
        `);
        okMsg = 'Course "' + title + '" created. Click Edit to add lessons and publish.';
      }
    } else if (action === 'toggle_publish') {
      const id = fd.get('id') as string;
      await db.execute(sql`UPDATE training_courses SET is_published = NOT is_published, updated_at = NOW() WHERE id = ${id}`);
      okMsg = 'Publish status toggled.';
    } else if (action === 'delete') {
      const id = fd.get('id') as string;
      await db.execute(sql`DELETE FROM training_courses WHERE id = ${id}`);
      okMsg = 'Course deleted.';
    }
  } catch (e: any) {
    errorMsg = 'Error: ' + (e?.message || 'Unknown');
  }
}

let courses: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT c.id, c.slug, c.title, c.short_desc, c.category, c.level, c.is_published, c.is_free,
      c.access_type, c.enrolled_count, c.duration_hours,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as lesson_count,
      (SELECT COUNT(*)::int FROM training_modules WHERE course_id = c.id) as module_count
    FROM training_courses c ORDER BY c.created_at DESC
  `);
  courses = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const url = new URL(Astro.request.url);
const filter = url.searchParams.get('filter') || 'all';
let filtered = courses;
if (filter === 'published') filtered = courses.filter(c => c.is_published);
if (filter === 'draft') filtered = courses.filter(c => !c.is_published);

const CATEGORIES = ['general', 'technology', 'business', 'design', 'mathematics', 'liberal-arts', 'language', 'communication', 'compliance', 'hr'];
const LEVELS = ['beginner', 'intermediate', 'advanced'];
const ACCESS = [
  { v: 'public', l: 'Public (anyone)' },
  { v: 'both', l: 'Public + portal users' },
  { v: 'employees', l: 'Employees only' },
  { v: 'applicants', l: 'Applicants only' },
];
---
<AdminLayout title="Courses - LMS" activeNav="courses">
<div style="padding:0 0 80px;">
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:16px;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:12px;flex-wrap:wrap;">
      <div>
        <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">AquinTutor LMS</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;line-height:1.2;">Courses</h1>
      </div>
      <button onclick="document.getElementById('newCourseModal').style.display='flex'" style="background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:12px;padding:8px 14px;border-radius:8px;cursor:pointer;">+ New course</button>
    </div>
    <div style="display:flex;gap:6px;flex-wrap:wrap;">
      {[['all','All'],['published','Published'],['draft','Draft']].map(([v,l]) => (
        <a href={'?filter=' + v} style={'text-decoration:none;font-size:11px;font-weight:600;padding:5px 12px;border-radius:100px;' + (filter === v ? 'background:#FF4F00;color:#fff;' : 'background:#15151a;color:#8a8a94;border:1px solid #1a1a1f;')}>{l}</a>
      ))}
    </div>
  </div>

  {errorMsg && <div style="margin:12px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:12px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  <div style="padding:12px 16px;display:flex;flex-direction:column;gap:8px;">
    {filtered.length === 0 && (
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:32px;text-align:center;color:#6e6e78;">
        <p style="font-size:14px;color:#fff;margin-bottom:6px;">No courses yet</p>
        <p style="font-size:12px;">Click "+ New course" to create your first one.</p>
      </div>
    )}
    {filtered.map((c) => (
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:10px;flex-wrap:wrap;">
          <div style="flex:1;min-width:0;">
            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:5px;">
              <span style={'font-size:9px;font-weight:700;padding:2px 7px;border-radius:100px;text-transform:uppercase;letter-spacing:0.06em;' + (c.is_published ? 'background:rgba(16,185,129,0.15);color:#6ee7b7;' : 'background:rgba(251,191,36,0.15);color:#fbbf24;')}>{c.is_published ? 'Published' : 'Draft'}</span>
              {c.is_free && <span style="font-size:9px;font-weight:700;padding:2px 7px;border-radius:100px;background:rgba(96,165,250,0.15);color:#93c5fd;text-transform:uppercase;letter-spacing:0.06em;">Free</span>}
              <span style="font-size:9px;color:#6e6e78;font-family:'Geist Mono',monospace;">{c.level} . {c.category}</span>
            </div>
            <p style="font-size:14px;font-weight:600;color:#fff;margin:0 0 3px;">{c.title}</p>
            <p style="font-size:11px;color:#6e6e78;margin:0;font-family:'Geist Mono',monospace;">/aquintutor/courses/{c.slug}</p>
            <p style="font-size:11px;color:#8a8a94;margin:4px 0 0;">{c.short_desc || 'No description.'}</p>
            <div style="display:flex;gap:10px;margin-top:6px;font-size:10.5px;color:#6e6e78;font-family:'Geist Mono',monospace;">
              <span>{c.module_count || 0} modules</span>
              <span>{c.lesson_count || 0} lessons</span>
              <span>{c.enrolled_count || 0} enrolled</span>
            </div>
          </div>
          <div style="display:flex;flex-direction:column;gap:6px;align-items:flex-end;">
            <a href={'/admin/courses/' + c.id + '/edit'} style="background:#FF4F00;color:#fff;text-decoration:none;font-size:11px;font-weight:600;padding:6px 12px;border-radius:6px;">Edit</a>
            <form method="POST" style="margin:0;">
              <input type="hidden" name="action" value="toggle_publish" />
              <input type="hidden" name="id" value={c.id} />
              <button type="submit" style="background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;font-size:11px;padding:6px 10px;border-radius:6px;cursor:pointer;">{c.is_published ? 'Unpublish' : 'Publish'}</button>
            </form>
            <form method="POST" style="margin:0;" onsubmit={'return confirm("Delete course \"' + c.title + '\" and all its lessons? Cannot be undone.")'}>
              <input type="hidden" name="action" value="delete" />
              <input type="hidden" name="id" value={c.id} />
              <button type="submit" style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;font-size:11px;padding:6px 10px;border-radius:6px;cursor:pointer;">Delete</button>
            </form>
          </div>
        </div>
      </div>
    ))}
  </div>
</div>

<div id="newCourseModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:200;align-items:flex-end;justify-content:center;">
  <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:16px 16px 0 0;width:100%;max-width:560px;max-height:90vh;overflow-y:auto;padding:20px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
      <h2 style="font-size:15px;font-weight:700;color:#fff;margin:0;">New course</h2>
      <button onclick="document.getElementById('newCourseModal').style.display='none'" style="background:#1a1a1f;border:none;color:#8a8a94;width:30px;height:30px;border-radius:6px;font-size:18px;cursor:pointer;">&times;</button>
    </div>
    <form method="POST" style="display:flex;flex-direction:column;gap:12px;">
      <input type="hidden" name="action" value="create" />
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#FF7040;margin-bottom:5px;">Title *</label>
        <input type="text" name="title" required placeholder="e.g. Foundations of Reasoning in AI" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
      </div>
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#FF7040;margin-bottom:5px;">Slug * (URL)</label>
        <input type="text" name="slug" required placeholder="foundations-of-reasoning-in-ai" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;font-family:'Geist Mono',monospace;" />
      </div>
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#FF7040;margin-bottom:5px;">Short description (one line)</label>
        <input type="text" name="short_desc" placeholder="What this course teaches in 1-2 sentences" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div>
          <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#FF7040;margin-bottom:5px;">Category</label>
          <select name="category" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
            {CATEGORIES.map(c => <option value={c}>{c}</option>)}
          </select>
        </div>
        <div>
          <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#FF7040;margin-bottom:5px;">Level</label>
          <select name="level" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
            {LEVELS.map(l => <option value={l}>{l}</option>)}
          </select>
        </div>
      </div>
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#FF7040;margin-bottom:5px;">Access</label>
        <select name="access_type" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
          {ACCESS.map(a => <option value={a.v}>{a.l}</option>)}
        </select>
      </div>
      <label style="display:flex;align-items:center;gap:8px;font-size:13px;color:#d8d8de;cursor:pointer;">
        <input type="checkbox" name="is_free" checked />
        <span>Free course (no payment required)</span>
      </label>
      <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;margin-top:6px;">Create course as draft</button>
      <p style="font-size:11px;color:#6e6e78;text-align:center;margin:0;">You'll add lessons and publish on the next screen.</p>
    </form>
  </div>
</div>
</AdminLayout>
