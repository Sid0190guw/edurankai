---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/courses');

let okMsg = '';
let errorMsg = '';
let course: any = null;
let modules: any[] = [];
let lessons: any[] = [];

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  try {
    if (action === 'update_meta') {
      const title = (fd.get('title') as string || '').trim();
      const slug = (fd.get('slug') as string || '').trim().toLowerCase().replace(/[^a-z0-9-]/g, '-');
      const shortDesc = (fd.get('short_desc') as string || '').trim() || null;
      const description = (fd.get('description') as string || '').trim() || null;
      const category = (fd.get('category') as string || '').trim();
      const level = (fd.get('level') as string || '').trim();
      const accessType = (fd.get('access_type') as string || '').trim();
      const durationHours = parseFloat(fd.get('duration_hours') as string || '0') || 0;
      const isFree = fd.get('is_free') === 'on';
      const instructorName = (fd.get('instructor_name') as string || '').trim() || null;
      const instructorTitle = (fd.get('instructor_title') as string || '').trim() || null;
      const learningOutcomes = ((fd.get('learning_outcomes') as string || '').trim().split('\n').map(s => s.trim()).filter(Boolean));
      const prerequisites = ((fd.get('prerequisites') as string || '').trim().split('\n').map(s => s.trim()).filter(Boolean));
      const tags = ((fd.get('tags') as string || '').trim().split(',').map(s => s.trim()).filter(Boolean));
      await db.execute(sql`
        UPDATE training_courses SET
          title = ${title}, slug = ${slug}, short_desc = ${shortDesc}, description = ${description},
          category = ${category}, level = ${level}, access_type = ${accessType}, is_free = ${isFree},
          duration_hours = ${durationHours},
          instructor_name = ${instructorName}, instructor_title = ${instructorTitle},
          learning_outcomes = ${learningOutcomes}, prerequisites = ${prerequisites}, tags = ${tags},
          updated_at = NOW()
        WHERE id = ${id}
      `);
      okMsg = 'Course details saved.';
    } else if (action === 'add_module') {
      const title = (fd.get('title') as string || '').trim();
      const description = (fd.get('description') as string || '').trim() || null;
      const sortOrder = parseInt(fd.get('sort_order') as string || '99');
      if (title) {
        await db.execute(sql`INSERT INTO training_modules (course_id, title, description, sort_order) VALUES (${id}, ${title}, ${description}, ${sortOrder})`);
        okMsg = 'Module added.';
      }
    } else if (action === 'delete_module') {
      const moduleId = fd.get('module_id') as string;
      await db.execute(sql`DELETE FROM training_modules WHERE id = ${moduleId}`);
      okMsg = 'Module deleted.';
    } else if (action === 'add_lesson') {
      const title = (fd.get('title') as string || '').trim();
      const moduleId = (fd.get('module_id') as string || '').trim() || null;
      const type = (fd.get('type') as string || 'text').trim();
      const content = (fd.get('content') as string || '').trim() || null;
      const videoUrl = (fd.get('video_url') as string || '').trim() || null;
      const durationMins = parseInt(fd.get('duration_mins') as string || '0');
      const sortOrder = parseInt(fd.get('sort_order') as string || '99');
      const isPreview = fd.get('is_preview') === 'on';
      if (title) {
        await db.execute(sql`
          INSERT INTO training_lessons (course_id, module_id, title, type, content, video_url, duration_mins, sort_order, is_preview)
          VALUES (${id}, ${moduleId}, ${title}, ${type}, ${content}, ${videoUrl}, ${durationMins}, ${sortOrder}, ${isPreview})
        `);
        okMsg = 'Lesson added.';
      }
    } else if (action === 'delete_lesson') {
      const lessonId = fd.get('lesson_id') as string;
      await db.execute(sql`DELETE FROM training_lessons WHERE id = ${lessonId}`);
      okMsg = 'Lesson deleted.';
    } else if (action === 'publish') {
      await db.execute(sql`UPDATE training_courses SET is_published = true, updated_at = NOW() WHERE id = ${id}`);
      okMsg = 'Course published. Visible at /aquintutor/courses/<slug>.';
    } else if (action === 'unpublish') {
      await db.execute(sql`UPDATE training_courses SET is_published = false, updated_at = NOW() WHERE id = ${id}`);
      okMsg = 'Course unpublished.';
    }
  } catch (e: any) {
    errorMsg = 'Error: ' + (e?.message || 'Unknown');
  }
}

try {
  const r = await db.execute(sql`SELECT * FROM training_courses WHERE id = ${id} LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  course = rows[0] || null;
} catch (_) {}
if (!course) return Astro.redirect('/admin/courses');

try {
  const r = await db.execute(sql`SELECT id, title, description, sort_order FROM training_modules WHERE course_id = ${id} ORDER BY sort_order ASC`);
  modules = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT id, title, type, content, video_url, duration_mins, sort_order, is_preview, module_id FROM training_lessons WHERE course_id = ${id} ORDER BY sort_order ASC`);
  lessons = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const lessonsByModule: Record<string, any[]> = {};
const unmoduledLessons: any[] = [];
for (const l of lessons) {
  if (l.module_id) {
    (lessonsByModule[l.module_id] = lessonsByModule[l.module_id] || []).push(l);
  } else {
    unmoduledLessons.push(l);
  }
}

const CATEGORIES = ['general', 'technology', 'business', 'design', 'mathematics', 'liberal-arts', 'language', 'communication', 'compliance', 'hr'];
const LEVELS = ['beginner', 'intermediate', 'advanced'];
const ACCESS = [
  { v: 'public', l: 'Public' },
  { v: 'both', l: 'Public + portal' },
  { v: 'employees', l: 'Employees only' },
  { v: 'applicants', l: 'Applicants only' },
];
const LESSON_TYPES = ['text', 'video', 'quiz', 'pdf', 'link'];

const learningOutcomesText = Array.isArray(course.learning_outcomes) ? course.learning_outcomes.join('\n') : '';
const prerequisitesText = Array.isArray(course.prerequisites) ? course.prerequisites.join('\n') : '';
const tagsText = Array.isArray(course.tags) ? course.tags.join(', ') : '';
---
<AdminLayout title={'Edit: ' + course.title} activeNav="courses">
<div style="padding:0 0 80px;">
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <a href="/admin/courses" style="font-size:11px;font-family:'Geist Mono',monospace;color:#6e6e78;text-decoration:none;display:inline-block;margin-bottom:6px;">&larr; Courses</a>
    <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;">
      <div style="min-width:0;">
        <h1 style="font-size:16px;font-weight:700;color:#fff;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{course.title}</h1>
        <p style="font-size:11px;font-family:'Geist Mono',monospace;color:#6e6e78;margin:2px 0 0;">/aquintutor/courses/{course.slug}</p>
      </div>
      <div style="display:flex;gap:6px;flex-shrink:0;">
        <a href={'/aquintutor/courses/' + course.slug} target="_blank" rel="noopener" style="background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;text-decoration:none;font-size:11px;font-weight:600;padding:7px 12px;border-radius:8px;">Preview</a>
        {course.is_published ? (
          <form method="POST" style="margin:0;"><input type="hidden" name="action" value="unpublish" /><button type="submit" style="background:rgba(251,191,36,0.15);border:1px solid rgba(251,191,36,0.3);color:#fbbf24;font-size:11px;font-weight:600;padding:7px 12px;border-radius:8px;cursor:pointer;">Unpublish</button></form>
        ) : (
          <form method="POST" style="margin:0;"><input type="hidden" name="action" value="publish" /><button type="submit" style="background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:600;padding:7px 12px;border-radius:8px;cursor:pointer;">Publish</button></form>
        )}
      </div>
    </div>
  </div>

  {errorMsg && <div style="margin:12px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:12px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  <div style="padding:16px;display:flex;flex-direction:column;gap:14px;max-width:900px;margin:0 auto;">

    <!-- COURSE META FORM -->
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:18px;">
      <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#FF7040;margin:0 0 14px;">Course details</p>
      <form method="POST" style="display:flex;flex-direction:column;gap:12px;">
        <input type="hidden" name="action" value="update_meta" />
        <div style="display:grid;grid-template-columns:2fr 1fr;gap:10px;">
          <div>
            <label style="display:block;font-size:10px;font-weight:700;color:#6e6e78;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:4px;">Title</label>
            <input type="text" name="title" value={course.title} required style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;color:#6e6e78;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:4px;">Slug</label>
            <input type="text" name="slug" value={course.slug} required style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;font-family:'Geist Mono',monospace;" />
          </div>
        </div>
        <div>
          <label style="display:block;font-size:10px;font-weight:700;color:#6e6e78;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:4px;">Short description</label>
          <input type="text" name="short_desc" value={course.short_desc || ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
        </div>
        <div>
          <label style="display:block;font-size:10px;font-weight:700;color:#6e6e78;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:4px;">Full description (paragraphs supported)</label>
          <textarea name="description" rows="5" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;resize:vertical;line-height:1.6;">{course.description || ''}</textarea>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:10px;">
          <div>
            <label style="display:block;font-size:10px;font-weight:700;color:#6e6e78;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:4px;">Category</label>
            <select name="category" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px;color:#fff;font-size:13px;outline:none;">
              {CATEGORIES.map(c => <option value={c} selected={course.category === c}>{c}</option>)}
            </select>
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;color:#6e6e78;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:4px;">Level</label>
            <select name="level" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px;color:#fff;font-size:13px;outline:none;">
              {LEVELS.map(l => <option value={l} selected={course.level === l}>{l}</option>)}
            </select>
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;color:#6e6e78;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:4px;">Access</label>
            <select name="access_type" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px;color:#fff;font-size:13px;outline:none;">
              {ACCESS.map(a => <option value={a.v} selected={course.access_type === a.v}>{a.l}</option>)}
            </select>
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;color:#6e6e78;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:4px;">Duration (hours)</label>
            <input type="number" step="0.5" name="duration_hours" value={course.duration_hours || 0} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px;color:#fff;font-size:13px;outline:none;" />
          </div>
        </div>
        <label style="display:flex;align-items:center;gap:8px;font-size:13px;color:#d8d8de;cursor:pointer;">
          <input type="checkbox" name="is_free" checked={course.is_free} />
          <span>Free course</span>
        </label>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
          <div>
            <label style="display:block;font-size:10px;font-weight:700;color:#6e6e78;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:4px;">Instructor name</label>
            <input type="text" name="instructor_name" value={course.instructor_name || ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;color:#6e6e78;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:4px;">Instructor title</label>
            <input type="text" name="instructor_title" value={course.instructor_title || ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
          </div>
        </div>
        <div>
          <label style="display:block;font-size:10px;font-weight:700;color:#6e6e78;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:4px;">Learning outcomes (one per line)</label>
          <textarea name="learning_outcomes" rows="4" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;resize:vertical;">{learningOutcomesText}</textarea>
        </div>
        <div>
          <label style="display:block;font-size:10px;font-weight:700;color:#6e6e78;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:4px;">Prerequisites (one per line)</label>
          <textarea name="prerequisites" rows="3" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;resize:vertical;">{prerequisitesText}</textarea>
        </div>
        <div>
          <label style="display:block;font-size:10px;font-weight:700;color:#6e6e78;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:4px;">Tags (comma-separated)</label>
          <input type="text" name="tags" value={tagsText} placeholder="ai, reasoning, foundational-models" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
        </div>
        <button type="submit" style="background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:13px;padding:10px 18px;border-radius:8px;cursor:pointer;align-self:flex-start;">Save details</button>
      </form>
    </div>

    <!-- MODULES -->
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:18px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
        <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#FF7040;margin:0;">Modules ({modules.length})</p>
        <button type="button" onclick="document.getElementById('addModuleForm').style.display='block';this.style.display='none';" style="background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;font-size:11px;font-weight:600;padding:6px 10px;border-radius:6px;cursor:pointer;">+ Add module</button>
      </div>

      <form id="addModuleForm" method="POST" style="display:none;background:#08080a;border:1px solid #1a1a1f;border-radius:8px;padding:12px;margin-bottom:12px;flex-direction:column;gap:8px;">
        <input type="hidden" name="action" value="add_module" />
        <input type="text" name="title" placeholder="Module title" required style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12.5px;outline:none;" />
        <input type="text" name="description" placeholder="Optional description" style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12.5px;outline:none;" />
        <input type="number" name="sort_order" placeholder="Order (lower = first)" value={modules.length + 1} style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12.5px;outline:none;width:140px;" />
        <div style="display:flex;gap:6px;"><button type="submit" style="background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:12px;padding:7px 12px;border-radius:6px;cursor:pointer;">Add</button></div>
      </form>

      {modules.length === 0 && <p style="font-size:12px;color:#6e6e78;font-style:italic;">No modules yet. Lessons can also be added without a module.</p>}
      {modules.map((m: any, mi: number) => (
        <div style="background:#08080a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:center;gap:10px;">
          <div style="flex:1;min-width:0;">
            <p style="font-size:13px;font-weight:600;color:#fff;margin:0;"><span style="font-family:'Geist Mono',monospace;font-size:10px;color:#FF7040;margin-right:8px;">{String(mi + 1).padStart(2, '0')}</span>{m.title}</p>
            {m.description && <p style="font-size:11px;color:#6e6e78;margin:3px 0 0;">{m.description}</p>}
            <p style="font-size:10.5px;color:#6e6e78;margin:3px 0 0;">{(lessonsByModule[m.id] || []).length} lessons . sort {m.sort_order}</p>
          </div>
          <form method="POST" style="margin:0;" onsubmit='return confirm("Delete module and ALL its lessons?")'>
            <input type="hidden" name="action" value="delete_module" />
            <input type="hidden" name="module_id" value={m.id} />
            <button type="submit" style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;font-size:11px;padding:5px 9px;border-radius:6px;cursor:pointer;">Delete</button>
          </form>
        </div>
      ))}
    </div>

    <!-- LESSONS -->
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:18px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
        <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#FF7040;margin:0;">Lessons ({lessons.length})</p>
        <button type="button" onclick="document.getElementById('addLessonForm').style.display='flex';this.style.display='none';" style="background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;font-size:11px;font-weight:600;padding:6px 10px;border-radius:6px;cursor:pointer;">+ Add lesson</button>
      </div>

      <form id="addLessonForm" method="POST" style="display:none;background:#08080a;border:1px solid #1a1a1f;border-radius:8px;padding:12px;margin-bottom:12px;flex-direction:column;gap:8px;">
        <input type="hidden" name="action" value="add_lesson" />
        <input type="text" name="title" placeholder="Lesson title" required style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12.5px;outline:none;" />
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;">
          <select name="module_id" style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12px;outline:none;">
            <option value="">No module</option>
            {modules.map((m: any) => <option value={m.id}>{m.title}</option>)}
          </select>
          <select name="type" style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12px;outline:none;">
            {LESSON_TYPES.map(t => <option value={t}>{t}</option>)}
          </select>
          <input type="number" name="duration_mins" placeholder="Mins" value="10" style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12px;outline:none;" />
        </div>
        <input type="text" name="video_url" placeholder="Video URL (YouTube/Vimeo) if type=video" style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12.5px;outline:none;" />
        <textarea name="content" placeholder="Lesson content (markdown supported for text type)" rows="5" style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12.5px;outline:none;resize:vertical;font-family:inherit;line-height:1.55;"></textarea>
        <div style="display:flex;gap:10px;align-items:center;justify-content:space-between;flex-wrap:wrap;">
          <label style="display:flex;align-items:center;gap:6px;font-size:12px;color:#d8d8de;cursor:pointer;">
            <input type="checkbox" name="is_preview" />
            <span>Free preview (visible without enrolment)</span>
          </label>
          <input type="number" name="sort_order" placeholder="Order" value={lessons.length + 1} style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12px;outline:none;width:90px;" />
        </div>
        <div style="display:flex;gap:6px;"><button type="submit" style="background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:12px;padding:7px 12px;border-radius:6px;cursor:pointer;">Add lesson</button></div>
      </form>

      {lessons.length === 0 && <p style="font-size:12px;color:#6e6e78;font-style:italic;">No lessons yet.</p>}
      {lessons.map((l: any, li: number) => {
        const mod = modules.find((mm: any) => mm.id === l.module_id);
        return (
          <div style="background:#08080a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center;gap:10px;">
            <div style="flex:1;min-width:0;">
              <p style="font-size:12.5px;color:#fff;margin:0;font-weight:500;"><span style="font-family:'Geist Mono',monospace;font-size:10px;color:#6e6e78;margin-right:8px;">{String(li + 1).padStart(2, '0')}</span>{l.title}</p>
              <p style="font-size:10.5px;color:#6e6e78;margin:3px 0 0;">
                <span style="text-transform:uppercase;">{l.type}</span>
                {l.duration_mins > 0 && <span> . {l.duration_mins}m</span>}
                {mod && <span> . in: {mod.title}</span>}
                {l.is_preview && <span style="color:#FF7040;"> . FREE PREVIEW</span>}
              </p>
            </div>
            <form method="POST" style="margin:0;" onsubmit='return confirm("Delete lesson?")'>
              <input type="hidden" name="action" value="delete_lesson" />
              <input type="hidden" name="lesson_id" value={l.id} />
              <button type="submit" style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;font-size:11px;padding:5px 9px;border-radius:6px;cursor:pointer;">Delete</button>
            </form>
          </div>
        );
      })}
    </div>

  </div>
</div>
</AdminLayout>
