---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { offerLetters, users } from '@/lib/db/schema';
import { desc } from 'drizzle-orm';

const currentUser = Astro.locals.user!;
if (!currentUser || currentUser.role === 'applicant') return Astro.redirect('/portal');

const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get('status') || 'all';
const search = (url.searchParams.get('q') || '').toLowerCase().trim();

const allOffers = await db.select({
  id: offerLetters.id, token: offerLetters.token,
  applicationId: offerLetters.applicationId, status: offerLetters.status,
  templateType: offerLetters.templateType, candidateName: offerLetters.candidateName,
  candidateEmail: offerLetters.candidateEmail, roleTitle: offerLetters.roleTitle,
  department: offerLetters.department, refNumber: offerLetters.refNumber,
  offerDate: offerLetters.offerDate, joiningDate: offerLetters.joiningDate,
  expiryDate: offerLetters.expiryDate, createdAt: offerLetters.createdAt,
  generatedByUserId: offerLetters.generatedByUserId,
  signedAt: offerLetters.signedAt, declinedAt: offerLetters.declinedAt,
}).from(offerLetters).orderBy(desc(offerLetters.createdAt));

let filtered = allOffers;
if (statusFilter !== 'all') filtered = filtered.filter(o => o.status === statusFilter);
if (search) filtered = filtered.filter(o =>
  o.candidateName.toLowerCase().includes(search) ||
  o.candidateEmail.toLowerCase().includes(search) ||
  o.roleTitle.toLowerCase().includes(search) ||
  (o.refNumber || '').toLowerCase().includes(search)
);

const counts = {
  all: allOffers.length,
  draft: allOffers.filter(o => o.status === 'draft').length,
  sent: allOffers.filter(o => o.status === 'sent').length,
  signed: allOffers.filter(o => o.status === 'signed').length,
  declined: allOffers.filter(o => o.status === 'declined').length,
  expired: allOffers.filter(o => o.status === 'expired').length,
};

const STATUS_COLOR: Record<string, string> = {
  draft: '#fbbf24', sent: '#60a5fa', signed: '#10b981', declined: '#f87171', expired: '#6e6e78'
};
const STATUS_ICON: Record<string, string> = {
  draft: '📝', sent: '📤', signed: '✅', declined: '❌', expired: '⏰'
};

function fmtDate(d: string | null | undefined) {
  if (!d) return '—';
  try { return new Date(d).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }); }
  catch { return d; }
}
---
<AdminLayout title="Offer Letters" activeNav="offers">
<div style="padding-bottom:80px;">

  <!-- Header -->
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
      <div>
        <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">Hiring</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Offer Letters</h1>
      </div>
      <a href="/admin/offer/blank" style="background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:12px;padding:8px 14px;border-radius:8px;text-decoration:none;">+ New</a>
    </div>

    <!-- Stats -->
    <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:6px;margin-bottom:12px;">
      {[
        { label: 'Sent', value: counts.sent, color: '#60a5fa' },
        { label: 'Signed', value: counts.signed, color: '#10b981' },
        { label: 'Draft', value: counts.draft, color: '#fbbf24' },
        { label: 'Declined', value: counts.declined, color: '#f87171' },
        { label: 'Expired', value: counts.expired, color: '#6e6e78' },
      ].map(s => (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:8px;padding:6px;text-align:center;">
          <p style={`font-size:16px;font-weight:700;color:${s.color};margin:0;line-height:1;`}>{s.value}</p>
          <p style="font-size:9px;color:#6e6e78;margin:2px 0 0;text-transform:uppercase;">{s.label}</p>
        </div>
      ))}
    </div>

    <!-- Search + Filter -->
    <form method="GET" style="display:flex;gap:8px;">
      <input type="text" name="q" value={search} placeholder="Search name, email, role..." style="flex:1;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:8px 12px;color:#fff;font-size:13px;outline:none;min-width:0;" />
      <select name="status" onchange="this.form.submit()" style="background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:8px 10px;color:#fff;font-size:12px;outline:none;cursor:pointer;">
        <option value="all" selected={statusFilter === 'all'}>All</option>
        {['draft','sent','signed','declined','expired'].map(s => (
          <option value={s} selected={statusFilter === s}>{s}</option>
        ))}
      </select>
      <button type="submit" style="background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:8px 12px;color:#fff;font-size:12px;cursor:pointer;">Go</button>
    </form>
  </div>

  <!-- Cards -->
  <div style="padding:12px 16px;display:flex;flex-direction:column;gap:8px;">
    {filtered.length === 0 && (
      <div style="text-align:center;padding:48px;color:#6e6e78;">
        <p style="font-size:32px;margin-bottom:8px;">📄</p>
        <p style="font-size:13px;">{allOffers.length === 0 ? 'No offer letters yet.' : 'No offers match your filters.'}</p>
        {allOffers.length === 0 && <p style="font-size:12px;margin-top:4px;">Generate one from an application detail page.</p>}
      </div>
    )}
    {filtered.map(o => {
      const color = STATUS_COLOR[o.status] || '#6e6e78';
      const icon = STATUS_ICON[o.status] || '📄';
      return (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
          <div style="padding:12px 14px;">
            <div style="display:flex;align-items:flex-start;gap:10px;margin-bottom:10px;">
              <div style={`width:40px;height:40px;border-radius:10px;background:${color}22;border:1px solid ${color}33;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;`}>
                {icon}
              </div>
              <div style="flex:1;min-width:0;">
                <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:6px;">
                  <div style="min-width:0;">
                    <p style="font-size:14px;font-weight:600;color:#fff;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{o.candidateName}</p>
                    <p style="font-size:11px;color:#6e6e78;margin:2px 0 0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{o.roleTitle}</p>
                  </div>
                  <span style={`font-size:9px;font-weight:700;padding:3px 8px;border-radius:100px;text-transform:uppercase;background:${color}22;color:${color};border:1px solid ${color}33;flex-shrink:0;`}>
                    {o.status}
                  </span>
                </div>
              </div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">
              <div style="background:#15151a;border-radius:6px;padding:6px 8px;">
                <p style="font-size:9px;color:#6e6e78;text-transform:uppercase;margin:0;">Ref</p>
                <p style="font-size:11px;color:#d8d8de;margin:2px 0 0;font-family:'Geist Mono',monospace;">{o.refNumber || '—'}</p>
              </div>
              <div style="background:#15151a;border-radius:6px;padding:6px 8px;">
                <p style="font-size:9px;color:#6e6e78;text-transform:uppercase;margin:0;">Type</p>
                <p style="font-size:11px;color:#d8d8de;margin:2px 0 0;text-transform:capitalize;">{o.templateType || '—'}</p>
              </div>
              <div style="background:#15151a;border-radius:6px;padding:6px 8px;">
                <p style="font-size:9px;color:#6e6e78;text-transform:uppercase;margin:0;">Offer Date</p>
                <p style="font-size:11px;color:#d8d8de;margin:2px 0 0;">{fmtDate(o.offerDate)}</p>
              </div>
              <div style="background:#15151a;border-radius:6px;padding:6px 8px;">
                <p style="font-size:9px;color:#6e6e78;text-transform:uppercase;margin:0;">{o.status === 'signed' ? 'Signed On' : 'Joining Date'}</p>
                <p style="font-size:11px;color:#d8d8de;margin:2px 0 0;">{o.status === 'signed' ? fmtDate(o.signedAt as any) : fmtDate(o.joiningDate)}</p>
              </div>
            </div>
          </div>

          <div style="border-top:1px solid #1a1a1f;padding:8px 14px;display:flex;gap:6px;">
            <a href={`/admin/applications/${o.applicationId}/offer-letter`} style="flex:1;text-align:center;background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;text-decoration:none;font-size:12px;font-weight:500;padding:7px;border-radius:6px;">
              Edit
            </a>
            <a href={`/portal/offer/${o.token}`} target="_blank" style="flex:1;text-align:center;background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;text-decoration:none;font-size:12px;font-weight:500;padding:7px;border-radius:6px;">
              View ↗
            </a>
            <a href={`/offer/verify/${o.token}`} target="_blank" style="flex:1;text-align:center;background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;text-decoration:none;font-size:12px;font-weight:500;padding:7px;border-radius:6px;">
              Verify ↗
            </a>
          </div>
        </div>
      );
    })}
  </div>
</div>
</AdminLayout>
