---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { canViewPage } from '@/lib/auth/pagePermissions';
import { db } from '@/lib/db';
import { offerLetters, applications, users } from '@/lib/db/schema';
import { can } from '@/lib/auth/permissions';
import { eq, desc } from 'drizzle-orm';

const currentUser = Astro.locals.user!;
if (!(await canViewPage(currentUser, 'offers'))) return Astro.redirect('/admin');
if (!can(currentUser, 'applications.view')) return Astro.redirect('/admin');

const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get('status') || 'all';
const search = (url.searchParams.get('q') || '').toLowerCase().trim();

// Fetch all offers
const allOffers = await db.select({
  id: offerLetters.id,
  token: offerLetters.token,
  applicationId: offerLetters.applicationId,
  status: offerLetters.status,
  templateType: offerLetters.templateType,
  candidateName: offerLetters.candidateName,
  candidateEmail: offerLetters.candidateEmail,
  roleTitle: offerLetters.roleTitle,
  department: offerLetters.department,
  refNumber: offerLetters.refNumber,
  offerDate: offerLetters.offerDate,
  joiningDate: offerLetters.joiningDate,
  expiryDate: offerLetters.expiryDate,
  createdAt: offerLetters.createdAt,
  generatedByUserId: offerLetters.generatedByUserId
}).from(offerLetters).orderBy(desc(offerLetters.createdAt));

// Filter
let filtered = allOffers;
if (statusFilter !== 'all') filtered = filtered.filter(o => o.status === statusFilter);
if (search) {
  filtered = filtered.filter(o =>
    o.candidateName.toLowerCase().includes(search) ||
    o.candidateEmail.toLowerCase().includes(search) ||
    o.roleTitle.toLowerCase().includes(search) ||
    (o.refNumber || '').toLowerCase().includes(search)
  );
}

// Get user names for "generated by"
const allAdmins = await db.select({ id: users.id, name: users.name }).from(users);
const adminMap = Object.fromEntries(allAdmins.map(u => [u.id, u.name]));

// Counts
const counts = {
  all: allOffers.length,
  draft: allOffers.filter(o => o.status === 'draft').length,
  sent: allOffers.filter(o => o.status === 'sent').length,
  signed: allOffers.filter(o => o.status === 'signed').length,
  declined: allOffers.filter(o => o.status === 'declined').length,
  expired: allOffers.filter(o => o.status === 'expired').length
};

const statusColor: Record<string, string> = {
  draft: '#fbbf24',
  sent: '#60a5fa',
  signed: '#10b981',
  declined: '#f87171',
  expired: '#6e6e78'
};

function fmtDate(d: string | null | undefined): string {
  if (!d) return '-';
  try {
    return new Date(d).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
  } catch {
    return d;
  }
}

function fmtDateTime(d: Date | string | null | undefined): string {
  if (!d) return '-';
  return new Date(d).toLocaleString('en-IN', { day: 'numeric', month: 'short', hour: 'numeric', minute: '2-digit' });
}
---
<AdminLayout title="Offer Letters" activeNav="offers">
  <div class="admin-page" style="max-width:1400px;">

    <div class="admin-page-header" style="margin-bottom:24px;">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">Hiring</div>
        <h1 class="admin-page-title">Offer Letters</h1>
        <p class="admin-page-sub">{counts.all} offer letters total. {counts.sent} sent, {counts.signed} signed, {counts.declined} declined.</p>
      </div>
    </div>

    <!-- FILTERS -->
    <form method="GET" class="admin-card" style="display:flex;gap:10px;align-items:end;margin-bottom:18px;padding:14px 16px;flex-wrap:wrap;">
      <div style="flex:1;min-width:200px;">
        <label class="rolefield-label">Search</label>
        <input name="q" value={search} placeholder="Name, email, role, ref number..." class="rolefield-input" />
      </div>
      <div style="min-width:140px;">
        <label class="rolefield-label">Status</label>
        <select name="status" class="rolefield-input">
          <option value="all" selected={statusFilter === 'all'}>All ({counts.all})</option>
          <option value="draft" selected={statusFilter === 'draft'}>Draft ({counts.draft})</option>
          <option value="sent" selected={statusFilter === 'sent'}>Sent ({counts.sent})</option>
          <option value="signed" selected={statusFilter === 'signed'}>Signed ({counts.signed})</option>
          <option value="declined" selected={statusFilter === 'declined'}>Declined ({counts.declined})</option>
          <option value="expired" selected={statusFilter === 'expired'}>Expired ({counts.expired})</option>
        </select>
      </div>
      <div style="display:flex;gap:6px;">
        <button type="submit" class="admin-btn admin-btn-primary" style="padding:8px 14px;font-size:11px;">Apply</button>
        {(statusFilter !== 'all' || search) && <a href="/admin/offers" class="admin-btn" style="padding:8px 14px;font-size:11px;display:flex;align-items:center;">Clear</a>}
      </div>
    </form>

    <!-- LIST -->
    <div class="admin-card" style="padding:0;overflow:hidden;">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Candidate</th>
            <th>Role</th>
            <th>Status</th>
            <th>Ref</th>
            <th>Offer / Join / Expires</th>
            <th>Created</th>
            <th style="text-align:right;">Actions</th>
          </tr>
        </thead>
        <tbody>
          {filtered.length === 0 && (
            <tr>
              <td colspan="7" style="text-align:center;padding:40px 20px;color:#6e6e78;font-size:13px;">
                {allOffers.length === 0 ? 'No offer letters yet. Generate one from an application detail page.' : 'No offers match your filters.'}
              </td>
            </tr>
          )}
          {filtered.map((o) => {
            const sc = statusColor[o.status] || '#6e6e78';
            const generatedBy = o.generatedByUserId ? adminMap[o.generatedByUserId] : null;
            return (
              <tr>
                <td>
                  <div style="font-weight:500;color:#fff;">{o.candidateName}</div>
                  <div style="font-size:10.5px;color:#6e6e78;margin-top:2px;font-family:'Geist Mono',monospace;">{o.candidateEmail}</div>
                </td>
                <td>
                  <div style="font-size:12px;color:#d8d8de;">{o.roleTitle}</div>
                  {o.department && <div style="font-size:10.5px;color:#6e6e78;margin-top:2px;">{o.department}</div>}
                  <div style="font-size:10px;color:#6e6e78;margin-top:2px;font-family:'Geist Mono',monospace;">{o.templateType}</div>
                </td>
                <td>
                  <span style={'display:inline-flex;align-items:center;gap:5px;font-size:11px;color:' + sc + ';font-weight:600;'}>
                    <span style={'width:6px;height:6px;border-radius:50%;background:' + sc + ';'}></span>
                    {o.status.charAt(0).toUpperCase() + o.status.slice(1)}
                  </span>
                </td>
                <td>
                  <span style="font-size:10.5px;color:#a0a0ab;font-family:'Geist Mono',monospace;">{o.refNumber}</span>
                </td>
                <td>
                  <div style="font-size:10.5px;color:#a0a0ab;line-height:1.7;">
                    <div><span style="color:#6e6e78;">Offer:</span> {fmtDate(o.offerDate)}</div>
                    <div><span style="color:#6e6e78;">Join:</span> {fmtDate(o.joiningDate)}</div>
                    <div><span style="color:#6e6e78;">Expires:</span> {fmtDate(o.expiryDate)}</div>
                  </div>
                </td>
                <td>
                  <div style="font-size:10.5px;color:#a0a0ab;">{fmtDateTime(o.createdAt)}</div>
                  {generatedBy && <div style="font-size:9.5px;color:#6e6e78;margin-top:2px;">by {generatedBy}</div>}
                </td>
                <td style="text-align:right;">
                  <div style="display:flex;gap:5px;justify-content:flex-end;flex-wrap:wrap;">
                    <a href={'/admin/applications/' + o.applicationId + '/offer-letter'} class="admin-btn" style="padding:4px 9px;font-size:10.5px;">Edit</a>
                    <a href={'/portal/offer/' + o.token} target="_blank" class="admin-btn" style="padding:4px 9px;font-size:10.5px;">View &#8599;</a>
                    <a href={'/admin/applications/' + o.applicationId} class="admin-btn" style="padding:4px 9px;font-size:10.5px;">App</a>
                  </div>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    {filtered.length > 0 && (
      <p style="font-size:11px;color:#6e6e78;margin-top:10px;font-family:'Geist Mono',monospace;">Showing {filtered.length} of {counts.all} offer letters</p>
    )}

  </div>

  <style>
    .rolefield-label { display:block;font-size:10.5px;font-weight:600;color:#8a8a94;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:6px; }
    .rolefield-input { width:100%;padding:8px 11px;background:#08080a;border:1px solid #1f1f26;border-radius:6px;color:#fff;font-size:12px;font-family:inherit;outline:none; }
    .rolefield-input:focus { border-color:#FF4F00; }
  </style>
</AdminLayout>