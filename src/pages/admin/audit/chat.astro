---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { chatChannels, chatMessages, chatAuditLog, users } from '@/lib/db/schema';
import { eq, desc, asc, sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role !== 'super_admin') {
  return new Response('Only super_admin can access chat audit', { status: 403 });
}

const url = new URL(Astro.request.url);
const channelSlug = url.searchParams.get('channel') || '';
const reason = url.searchParams.get('reason') || '';
let messages: any[] = [];
let channel: any = null;
let auditLogged = false;

if (channelSlug && reason && reason.length > 5) {
  const ch = await db.select().from(chatChannels).where(eq(chatChannels.slug, channelSlug)).limit(1);
  if (ch.length > 0) {
    channel = ch[0];
    messages = await db.select().from(chatMessages)
      .where(eq(chatMessages.channelId, channel.id))
      .orderBy(asc(chatMessages.createdAt))
      .limit(500);

    // Log the audit access
    await db.insert(chatAuditLog).values({
      accessedByUserId: user.id,
      accessedChannelId: channel.id,
      reason: reason,
      action: 'view_channel',
      ipAddress: Astro.request.headers.get('x-forwarded-for') || null,
      userAgent: Astro.request.headers.get('user-agent') || null
    });
    auditLogged = true;
  }
}

const allChannels = await db.select().from(chatChannels).orderBy(asc(chatChannels.name));

// Recent audit log entries
const recentAudits = await db.select({
  id: chatAuditLog.id,
  reason: chatAuditLog.reason,
  accessedAt: chatAuditLog.accessedAt,
  action: chatAuditLog.action,
  channelId: chatAuditLog.accessedChannelId,
  userId: chatAuditLog.accessedByUserId
}).from(chatAuditLog).orderBy(desc(chatAuditLog.accessedAt)).limit(20);
---
<AdminLayout title="Chat Audit (Super Admin)" description="Forensic access to private chat — every view is logged.">
  <div class="admin-page" style="max-width:1300px;">
    <div class="admin-page-header" style="margin-bottom:18px;">
      <p class="admin-page-eyebrow" style="color:#fca5a5;">Forensic · Super Admin Only</p>
      <h1 class="admin-page-title">Chat Audit</h1>
      <p class="admin-page-sub">Every access on this page is permanently logged. Only use for confirmed misconduct investigations, with a documented reason.</p>
    </div>

    {auditLogged && <div style="background:rgba(251,191,36,0.1);border:1px solid rgba(251,191,36,0.3);color:#fbbf24;padding:10px 14px;border-radius:8px;margin-bottom:14px;font-size:12px;">⚠ This access was logged for channel <strong>{channel?.name}</strong>. Reason: "{reason}"</div>}

    <form method="GET" class="admin-card" style="padding:14px;margin-bottom:16px;display:flex;gap:8px;flex-wrap:wrap;align-items:end;">
      <div style="flex:1;min-width:220px;"><label style="display:block;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.55);margin-bottom:5px;">Channel</label>
        <select name="channel" class="rfi" required>
          <option value="">Pick channel...</option>
          {allChannels.map((c) => <option value={c.slug} selected={c.slug === channelSlug}>{c.name} {c.isPrivate ? '🔒' : ''} {c.isDm ? '(DM)' : ''}</option>)}
        </select>
      </div>
      <div style="flex:2;min-width:300px;"><label style="display:block;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.55);margin-bottom:5px;">Reason for accessing *</label>
        <input type="text" name="reason" required minlength="6" value={reason} placeholder="Investigating reported misconduct — case #..." class="rfi" />
      </div>
      <button type="submit" class="admin-btn admin-btn-primary" style="padding:9px 16px;font-size:12.5px;">View &amp; Log</button>
    </form>

    {channel && messages.length > 0 && (
      <div class="admin-card" style="padding:0;overflow:hidden;">
        <div style="padding:12px 16px;background:#15151a;border-bottom:1px solid #1f1f26;">
          <p style="font-size:13px;color:#fff;font-weight:600;margin:0;"># {channel.name}</p>
          <p style="font-size:11px;color:#6e6e78;margin:2px 0 0;">{messages.length} messages</p>
        </div>
        <div style="max-height:600px;overflow-y:auto;padding:14px 16px;">
          {messages.map((m) => (
            <div style="padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.05);">
              <div style="display:flex;justify-content:space-between;font-size:10.5px;color:#6e6e78;font-family:'Geist Mono',monospace;margin-bottom:4px;">
                <span><strong style="color:#a0a0ab;">{m.senderName}</strong> · {new Date(m.createdAt).toLocaleString('en-IN')}</span>
                <span>{m.messageCode}</span>
              </div>
              <p style="font-size:13px;color:#d8d8de;margin:0;white-space:pre-wrap;">{m.body}</p>
            </div>
          ))}
        </div>
      </div>
    )}

    <div class="admin-card" style="padding:16px;margin-top:18px;">
      <h2 style="font-size:14px;color:#fff;margin:0 0 10px;">Recent audit accesses (last 20)</h2>
      {recentAudits.length === 0 && <p style="color:#6e6e78;font-size:12px;">No audit accesses logged yet.</p>}
      <table class="admin-table" style="margin-top:8px;">
        <thead><tr><th>When</th><th>Action</th><th>Reason</th></tr></thead>
        <tbody>
          {recentAudits.map((a) => (
            <tr>
              <td style="font-family:'Geist Mono',monospace;font-size:11px;color:#a0a0ab;">{new Date(a.accessedAt).toLocaleString('en-IN')}</td>
              <td style="font-size:11.5px;color:#fbbf24;">{a.action}</td>
              <td style="font-size:11.5px;color:#d8d8de;">{a.reason}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
  <style>
    .rfi { width:100%;padding:9px 12px;background:#15151a;border:1px solid #1f1f26;border-radius:8px;color:#fff;font-size:13px;font-family:inherit;outline:none; }
    .rfi:focus { border-color:#FF4F00; }
  </style>
</AdminLayout>