---
// /admin/moderation-live — live-safety policy + incident log (Prompt AP2b). Distinct from the async
// community moderation console. Gated by the moderator/admin delete capability. Shows the stage-aware
// safety policy and the redacted, data-minimized incident log; every moderator action is audited.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { listQueue } from '@/lib/moderation';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'delete', { type: 'moderation' });
if (!gate.allow) return Astro.redirect('/admin');
const pending = await listQueue('pending', 40).catch(() => []);
const removed = await listQueue('removed', 20).catch(() => []);
const blocked = await listQueue('blocked', 20).catch(() => []);
const incidents = [...pending, ...blocked, ...removed].sort((a: any, b: any) => Number(b.id) - Number(a.id)).slice(0, 60);
const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
---
<AdminLayout title="Live safety" activeNav="moderation-live">
  <div style="max-width:900px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Child safety</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Live moderation &amp; safety</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">Real-time screening across live rooms (chat + broadcast). Moderators work the live queue at <a href="/aquintutor/moderate" style="color:#9bd1ff;">/aquintutor/moderate</a>.</p>

    <div style={CARD}>
      <p style={HD}>Stage-aware safety policy</p>
      <ul style="font-size:13px;color:#d6d6de;line-height:1.7;margin:0;padding-left:18px;">
        <li>Adult rooms: coarse language is <b>flagged</b> for review but sent; harassment/self-harm is <b>blocked</b>.</li>
        <li>Minor rooms (minor stages): <b>strict</b> — coarse language and unmoderated peer-contact attempts (phone/email/handle) are <b>blocked</b>, never just flagged. A reframe cannot lower this.</li>
        <li>A minor safety event (harassment or contact) alerts the <b>linked guardian</b> automatically.</li>
        <li>Incident logs for minors are <b>data-minimized</b> — category + severity, not the message text.</li>
      </ul>
    </div>

    <div style={CARD}>
      <p style={HD}>Incident log ({incidents.length})</p>
      {incidents.length ? (
        <table style="width:100%;border-collapse:collapse;font-size:12.5px;">
          <thead><tr style="text-align:left;color:#8a8a94;font-size:11px;text-transform:uppercase;"><th style="padding:6px 8px;">#</th><th style="padding:6px 8px;">Severity</th><th style="padding:6px 8px;">Categories</th><th style="padding:6px 8px;">Surface</th><th style="padding:6px 8px;">Redacted</th><th style="padding:6px 8px;">Status</th></tr></thead>
          <tbody>
            {incidents.map((q: any) => (
              <tr style="border-top:1px solid #1a1a1f;color:#d6d6de;">
                <td style="padding:7px 8px;font-family:'Geist Mono',monospace;font-size:11px;color:#8a8a94;">{q.id}</td>
                <td style={'padding:7px 8px;color:' + (q.severity === 'severe' ? '#fca5a5' : '#c0a35e')}>{q.severity}</td>
                <td style="padding:7px 8px;font-family:'Geist Mono',monospace;font-size:11px;color:#9bd1ff;">{(q.categories || []).join(', ')}</td>
                <td style="padding:7px 8px;">{q.surface}</td>
                <td style="padding:7px 8px;color:#8a8a94;max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{q.redacted}</td>
                <td style="padding:7px 8px;">{q.status}</td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : <p style="font-size:12.5px;color:#8a8a94;margin:0;">No incidents logged.</p>}
    </div>
  </div>
</AdminLayout>
