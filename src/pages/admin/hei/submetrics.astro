---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { heiSubmetrics, heiDimensions } from '@/lib/db/schema';
import { asc, eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user || user.role === 'applicant') return Astro.redirect('/portal');

let errorMsg = '';
let okMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('_action') as string;
  try {
    if (action === 'create' || action === 'update') {
      const id = fd.get('id') as string;
      const candidate = {
        dimensionId: (fd.get('dimensionId') as string || '').trim(),
        title: (fd.get('title') as string || '').trim(),
        description: (fd.get('description') as string || '').trim() || null,
        weightWithinDimension: (fd.get('weightWithinDimension') as string || '0').trim(),
        sortOrder: parseInt((fd.get('sortOrder') as string) || '0', 10)
      };
      if (!candidate.dimensionId || !candidate.title) {
        errorMsg = 'Dimension and title required.';
      } else {
        if (action === 'create') {
          await db.insert(heiSubmetrics).values(candidate);
          okMsg = 'Created: ' + candidate.title;
        } else {
          await db.update(heiSubmetrics).set(candidate).where(eq(heiSubmetrics.id, id));
          okMsg = 'Updated: ' + candidate.title;
        }
      }
    } else if (action === 'delete') {
      const id = fd.get('id') as string;
      await db.delete(heiSubmetrics).where(eq(heiSubmetrics.id, id));
      okMsg = 'Deleted.';
    }
  } catch (err: any) {
    errorMsg = 'Failed: ' + (err.message || 'Unknown error');
  }
}

const url = new URL(Astro.request.url);
const editId = url.searchParams.get('edit') || '';
const filterDim = url.searchParams.get('dim') || '';

const allDims = await db.select().from(heiDimensions).orderBy(asc(heiDimensions.sortOrder));
const dimMap = Object.fromEntries(allDims.map(d => [d.id, d]));

let allSubs = await db.select().from(heiSubmetrics).orderBy(asc(heiSubmetrics.dimensionId), asc(heiSubmetrics.sortOrder));
if (filterDim) allSubs = allSubs.filter(s => s.dimensionId === filterDim);

const editing = editId ? allSubs.find(s => s.id === editId) || (await db.select().from(heiSubmetrics).where(eq(heiSubmetrics.id, editId)).limit(1))[0] : null;
---
<AdminLayout title="HEI Sub-metrics" activeNav="hei">
  <div class="admin-page" style="max-width:1400px;">

    <div class="admin-page-header" style="margin-bottom:20px;">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">HEI Data</div>
        <h1 class="admin-page-title">Sub-metrics</h1>
        <p class="admin-page-sub">Detailed scoring criteria under each of the 7 dimensions.</p>
      </div>
    </div>

    <div style="display:flex;gap:8px;margin-bottom:18px;flex-wrap:wrap;">
      <a href="/admin/hei/submetrics" style={'font-size:11px;padding:6px 12px;border-radius:100px;text-decoration:none;border:1px solid ' + (!filterDim ? '#FF4F00;background:#FF4F00;color:#fff' : '#1f1f26;color:#a0a0ab')}>All dimensions</a>
      {allDims.map((d) => (
        <a href={'/admin/hei/submetrics?dim=' + d.id} style={'font-size:11px;padding:6px 12px;border-radius:100px;text-decoration:none;border:1px solid ' + (filterDim === d.id ? '#FF4F00;background:#FF4F00;color:#fff' : '#1f1f26;color:#a0a0ab')}>{d.title}</a>
      ))}
    </div>

    {errorMsg && <div style="background:rgba(220,38,38,0.08);border:1px solid rgba(220,38,38,0.25);color:#fca5a5;font-size:12.5px;padding:11px 14px;border-radius:7px;margin-bottom:18px;">{errorMsg}</div>}
    {okMsg && <div style="background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.25);color:#6ee7b7;font-size:12.5px;padding:11px 14px;border-radius:7px;margin-bottom:18px;">{okMsg}</div>}

    <div style="display:grid;grid-template-columns:1.5fr 1fr;gap:18px;align-items:flex-start;">

      <div class="admin-card" style="padding:0;overflow:hidden;">
        <div style="padding:14px 16px;border-bottom:1px solid #1f1f26;display:flex;justify-content:space-between;align-items:center;">
          <span style="font-size:11px;color:#6e6e78;text-transform:uppercase;letter-spacing:0.1em;font-weight:700;">{allSubs.length} sub-metrics</span>
          {!editing && <a href={'?edit=new' + (filterDim ? '&dim=' + filterDim : '')} class="admin-btn admin-btn-primary" style="padding:5px 11px;font-size:11px;text-decoration:none;">+ Add sub-metric</a>}
        </div>
        <table class="admin-table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Dimension</th>
              <th>Weight</th>
              <th>Order</th>
              <th style="text-align:right;">Actions</th>
            </tr>
          </thead>
          <tbody>
            {allSubs.map((s) => {
              const dim = dimMap[s.dimensionId];
              return (
                <tr style={editing && editing.id === s.id ? 'background:rgba(255,79,0,0.06);' : ''}>
                  <td>
                    <div style="font-weight:500;color:#fff;font-size:12.5px;">{s.title}</div>
                    {s.description && <div style="font-size:10.5px;color:#6e6e78;margin-top:3px;line-height:1.5;">{s.description.substring(0, 100)}{s.description.length > 100 ? '...' : ''}</div>}
                  </td>
                  <td><span style="font-size:11px;color:#a0a0ab;">{dim ? dim.title : '-'}</span></td>
                  <td><span style="font-size:11px;color:#FF7040;font-weight:600;">{s.weightWithinDimension}%</span></td>
                  <td><span style="font-size:11px;color:#6e6e78;">{s.sortOrder}</span></td>
                  <td style="text-align:right;">
                    <div style="display:flex;gap:5px;justify-content:flex-end;">
                      <a href={'?edit=' + s.id} class="admin-btn" style="padding:4px 9px;font-size:10.5px;">Edit</a>
                      <form method="POST" style="margin:0;display:inline;" onsubmit="return confirm('Delete this sub-metric?');">
                        <input type="hidden" name="_action" value="delete" />
                        <input type="hidden" name="id" value={s.id} />
                        <button type="submit" class="admin-btn" style="padding:4px 9px;font-size:10.5px;color:#fca5a5;">Del</button>
                      </form>
                    </div>
                  </td>
                </tr>
              );
            })}
            {allSubs.length === 0 && <tr><td colspan="5" style="text-align:center;padding:30px;color:#6e6e78;font-size:13px;">No sub-metrics yet.</td></tr>}
          </tbody>
        </table>
      </div>

      {(editing || editId === 'new') && (
        <form method="POST" class="admin-card" style="display:flex;flex-direction:column;gap:11px;">
          <input type="hidden" name="_action" value={editing ? 'update' : 'create'} />
          {editing && <input type="hidden" name="id" value={editing.id} />}

          <div class="admin-card-title" style="margin:0 0 4px;font-size:13px;">{editing ? 'Edit sub-metric' : '+ Add sub-metric'}</div>

          <div>
            <label class="rfl">Dimension *</label>
            <select name="dimensionId" required class="rfi">
              <option value="">Choose...</option>
              {allDims.map((d) => <option value={d.id} selected={(editing && editing.dimensionId === d.id) || (!editing && filterDim === d.id)}>{d.title}</option>)}
            </select>
          </div>

          <div>
            <label class="rfl">Title *</label>
            <input name="title" required class="rfi" placeholder="e.g. Learning outcome attainment rate" value={editing ? editing.title : ''} />
          </div>

          <div>
            <label class="rfl">Description</label>
            <textarea name="description" rows="3" class="rfi">{editing && editing.description ? editing.description : ''}</textarea>
          </div>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <div>
              <label class="rfl">Weight within dimension</label>
              <input name="weightWithinDimension" class="rfi" placeholder="20.0" value={editing ? editing.weightWithinDimension : '20'} />
            </div>
            <div>
              <label class="rfl">Sort order</label>
              <input type="number" name="sortOrder" class="rfi" value={editing ? editing.sortOrder : 0} />
            </div>
          </div>

          <div style="display:flex;gap:8px;margin-top:6px;">
            <button type="submit" class="admin-btn admin-btn-primary" style="flex:1;justify-content:center;">{editing ? 'Save' : 'Create'}</button>
            <a href="/admin/hei/submetrics" class="admin-btn" style="padding:8px 14px;display:flex;align-items:center;text-decoration:none;">Cancel</a>
          </div>
        </form>
      )}

      {!editing && editId !== 'new' && (
        <div class="admin-card" style="text-align:center;padding:30px 20px;">
          <p style="font-size:12px;color:#6e6e78;line-height:1.7;">Pick a dimension above to filter. Click <strong>+ Add sub-metric</strong> to create.</p>
        </div>
      )}

    </div>
  </div>

  <style>
    .rfl { display:block;font-size:10px;font-weight:600;color:#8a8a94;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:4px; }
    .rfi { width:100%;padding:7px 10px;background:#08080a;border:1px solid #1f1f26;border-radius:5px;color:#fff;font-size:12px;font-family:inherit;outline:none; }
    .rfi:focus { border-color:#FF4F00; }
    textarea.rfi { resize:vertical; }
  </style>
</AdminLayout>