---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');

let okMsg = '', errorMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  try {
    if (action === 'add_rti') {
      const subject = (fd.get('subject') as string || '').trim();
      const instName = (fd.get('institution_name') as string || '').trim();
      const filedAt = fd.get('filed_at') as string || new Date().toISOString();
      const notes = (fd.get('notes') as string || '').trim();
      if (!subject) { errorMsg = 'Subject required.'; }
      else {
        await db.execute(sql`INSERT INTO hei_rti_filings (subject, institution_name, filed_at, status, notes, filed_by) VALUES (${subject}, ${instName||null}, ${filedAt}, 'filed', ${notes||null}, ${user.id})`);
        okMsg = 'RTI filing added.';
      }
    } else if (action === 'update_status') {
      const id = fd.get('id') as string;
      const status = fd.get('status') as string;
      const response = (fd.get('response_text') as string || '').trim();
      await db.execute(sql`UPDATE hei_rti_filings SET status = ${status}, response_text = ${response||null}, responded_at = ${status==='responded' ? new Date().toISOString() : null}, updated_at = NOW() WHERE id = ${id}`);
      okMsg = 'RTI status updated.';
    }
  } catch(e: any) { errorMsg = e.message; }
}

const url = new URL(Astro.request.url);
const filter = url.searchParams.get('filter') || 'all';

let filings: any[] = [];
try {
  const statusFilter = filter !== 'all' ? sql`AND status = ${filter}` : sql``;
  const r = await db.execute(sql`SELECT * FROM hei_rti_filings WHERE 1=1 ${statusFilter} ORDER BY filed_at DESC LIMIT 100`);
  filings = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

const STATUS_COLOR: Record<string,string> = { filed:'#60a5fa', responded:'#10b981', awaiting:'#fbbf24', declined:'#ef4444', appealed:'#a78bfa' };

function fmtDate(d: any) { if (!d) return '-'; return new Date(d).toLocaleDateString('en-IN',{ timeZone: 'Asia/Kolkata',day:'numeric',month:'short',year:'numeric'}); }
---
<AdminLayout title="RTI Tracker" activeNav="hei">
<div style="padding-bottom:80px;">
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
      <div>
        <p style="font-size:10px;font-family:monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">HEI Editorial</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">RTI Tracker</h1>
      </div>
      <div style="display:flex;gap:6px;">
        <a href="/admin/hei" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;text-decoration:none;font-size:11px;padding:6px 10px;border-radius:6px;">Dashboard</a>
        <button onclick="document.getElementById('addRtiModal').style.display='flex'" style="background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:600;padding:6px 12px;border-radius:6px;cursor:pointer;">+ File RTI</button>
      </div>
    </div>
    <div style="display:flex;gap:5px;overflow-x:auto;">
      {(['all','filed','responded','awaiting','declined','appealed'] as const).map(f => (
        <a href={`?filter=${f}`} style={`text-decoration:none;font-size:11px;font-weight:600;padding:5px 10px;border-radius:100px;white-space:nowrap;${filter===f?'background:#FF4F00;color:#fff;':'background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;'}`}>{f.charAt(0).toUpperCase()+f.slice(1)}</a>
      ))}
    </div>
  </div>

  {errorMsg && <div style="margin:10px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  <div style="padding:12px 16px;display:flex;flex-direction:column;gap:8px;">
    {filings.length === 0 && <div style="text-align:center;padding:40px;color:#6e6e78;background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;"><p style="font-size:13px;">No RTI filings yet.</p></div>}
    {filings.map((f: any) => {
      const sc = STATUS_COLOR[f.status] || '#6b7280';
      return (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
          <div style="padding:12px 14px;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:6px;">
              <div style="flex:1;min-width:0;">
                <p style="font-size:13px;font-weight:600;color:#fff;margin:0 0 4px;">{f.subject}</p>
                <p style="font-size:10px;color:#6e6e78;margin:0;font-family:monospace;">{f.institution_name && f.institution_name + ' - '}Filed: {fmtDate(f.filed_at)}</p>
              </div>
              <span style={`font-size:9px;font-weight:700;padding:2px 8px;border-radius:100px;background:${sc}22;color:${sc};flex-shrink:0;`}>{f.status?.toUpperCase()}</span>
            </div>
            {f.response_text && <div style="background:#15151a;border-radius:6px;padding:8px 10px;margin-top:8px;"><p style="font-size:11px;color:#8a8a94;margin:0;line-height:1.4;">Response: {f.response_text.substring(0,200)}{f.response_text.length>200?'...':''}</p></div>}
          </div>
          <div style="border-top:1px solid #1a1a1f;padding:6px 14px;">
            <form method="POST" style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
              <input type="hidden" name="action" value="update_status" /><input type="hidden" name="id" value={f.id} />
              <select name="status" style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:5px 8px;color:#fff;font-size:11px;outline:none;">
                {['filed','responded','awaiting','declined','appealed'].map(s => <option value={s} selected={f.status===s}>{s}</option>)}
              </select>
              <input name="response_text" placeholder="Response notes..." style="flex:1;min-width:100px;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:5px 8px;color:#fff;font-size:11px;outline:none;" />
              <button type="submit" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;font-size:10px;padding:5px 8px;border-radius:6px;cursor:pointer;">Update</button>
            </form>
          </div>
        </div>
      );
    })}
  </div>
</div>

<div id="addRtiModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:100;align-items:flex-end;justify-content:center;">
  <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:16px 16px 0 0;width:100%;max-width:600px;padding:20px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <h2 style="font-size:15px;font-weight:700;color:#fff;margin:0;">File RTI</h2>
      <button onclick="document.getElementById('addRtiModal').style.display='none'" style="background:#1a1a1f;border:none;color:#8a8a94;width:30px;height:30px;border-radius:6px;font-size:18px;cursor:pointer;">&times;</button>
    </div>
    <form method="POST" style="display:flex;flex-direction:column;gap:12px;">
      <input type="hidden" name="action" value="add_rti" />
      <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Subject *</label><input name="subject" required placeholder="Counsellor-student ratio, placement data..." style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" /></div>
      <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Institution</label><input name="institution_name" placeholder="a national engineering institute..." style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" /></div>
      <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Filed On</label><input name="filed_at" type="date" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" /></div>
      <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Notes</label><textarea name="notes" rows="3" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;resize:vertical;"></textarea></div>
      <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">File RTI</button>
    </form>
  </div>
</div>
</AdminLayout>
