---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');

let okMsg = '', errorMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  try {
    if (action === 'create_form') {
      const title = (fd.get('title') as string || '').trim();
      const desc = (fd.get('description') as string || '').trim();
      const slug = title.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'') + '-' + Date.now();
      if (!title) { errorMsg = 'Title required.'; }
      else {
        await db.execute(sql`INSERT INTO hei_survey_forms (title, slug, description, created_by) VALUES (${title}, ${slug}, ${desc||null}, ${user.id})`);
        okMsg = 'Survey form created.';
      }
    } else if (action === 'toggle_form') {
      const id = fd.get('id') as string;
      const cur = await db.execute(sql`SELECT is_active FROM hei_survey_forms WHERE id = ${id} LIMIT 1`);
      const rows = Array.isArray(cur) ? cur : (cur?.rows || []);
      const isActive = (rows[0] as any)?.is_active;
      await db.execute(sql`UPDATE hei_survey_forms SET is_active = ${!isActive}, updated_at = NOW() WHERE id = ${id}`);
      okMsg = isActive ? 'Form paused.' : 'Form activated.';
    }
  } catch(e: any) { errorMsg = e.message; }
}

let forms: any[] = [];
let totalResponses = 0;
try {
  const r = await db.execute(sql`SELECT f.*, (SELECT COUNT(*)::int FROM hei_survey_responses WHERE form_id = f.id) as responses FROM hei_survey_forms f ORDER BY f.created_at DESC`);
  forms = Array.isArray(r) ? r : (r?.rows || []);
  totalResponses = forms.reduce((s:number,f:any) => s + (Number(f.responses)||0), 0);
} catch(e) {}

function timeAgo(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const days = Math.floor(diff/86400000);
  if (days === 0) return 'today';
  if (days === 1) return 'yesterday';
  return days + 'd ago';
}
---
<AdminLayout title="Surveys" activeNav="hei">
<div style="padding-bottom:80px;">
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
      <div>
        <p style="font-size:10px;font-family:monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">HEI Editorial</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Survey Forms</h1>
      </div>
      <div style="display:flex;gap:6px;">
        <a href="/admin/hei" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;text-decoration:none;font-size:11px;padding:6px 10px;border-radius:6px;">Dashboard</a>
        <button onclick="document.getElementById('addFormModal').style.display='flex'" style="background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:600;padding:6px 12px;border-radius:6px;cursor:pointer;">+ New Form</button>
      </div>
    </div>
    <p style="font-size:11px;color:#6e6e78;margin:4px 0 0;">{forms.length} forms - {totalResponses} total responses</p>
  </div>

  {errorMsg && <div style="margin:10px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  <div style="padding:12px 16px;display:flex;flex-direction:column;gap:8px;">
    {forms.length === 0 && <div style="text-align:center;padding:40px;color:#6e6e78;background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;"><p style="font-size:13px;">No survey forms yet.</p><p style="font-size:11px;margin-top:4px;">Create forms to collect verified student and alumni responses.</p></div>}
    {forms.map((f: any) => (
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
        <div style="padding:12px 14px;display:flex;align-items:flex-start;gap:10px;">
          <div style="flex:1;min-width:0;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
              <p style="font-size:13px;font-weight:600;color:#fff;margin:0;">{f.title}</p>
              <span style={`font-size:9px;font-weight:700;padding:2px 6px;border-radius:100px;${f.is_active?'background:rgba(16,185,129,0.15);color:#6ee7b7;':'background:#15151a;color:#6e6e78;'}`}>{f.is_active?'Active':'Paused'}</span>
            </div>
            {f.description && <p style="font-size:11px;color:#8a8a94;margin:0 0 4px;">{f.description}</p>}
            <p style="font-size:10px;color:#6e6e78;margin:0;font-family:monospace;">/{f.slug} - Created {timeAgo(f.created_at)}</p>
          </div>
          <div style="text-align:right;flex-shrink:0;">
            <p style="font-size:22px;font-weight:700;color:#FF7040;margin:0;font-family:monospace;">{f.responses||0}</p>
            <p style="font-size:9px;color:#6e6e78;margin:0;">responses</p>
          </div>
        </div>
        <div style="border-top:1px solid #1a1a1f;padding:6px 14px;display:flex;gap:6px;">
          <form method="POST" style="display:contents;">
            <input type="hidden" name="action" value="toggle_form" /><input type="hidden" name="id" value={f.id} />
            <button type="submit" style={`font-size:11px;font-weight:500;padding:5px 12px;border-radius:6px;border:none;cursor:pointer;${f.is_active?'background:rgba(251,191,36,0.1);color:#fbbf24;':'background:rgba(16,185,129,0.1);color:#6ee7b7;'}`}>{f.is_active?'Pause':'Activate'}</button>
          </form>
          <a href={`/surveys/${f.slug}`} target="_blank" style="font-size:11px;font-weight:500;padding:5px 12px;border-radius:6px;background:#15151a;border:1px solid #1a1a1f;color:#60a5fa;text-decoration:none;">Preview</a>
        </div>
      </div>
    ))}
  </div>
</div>

<div id="addFormModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:100;align-items:flex-end;justify-content:center;">
  <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:16px 16px 0 0;width:100%;max-width:600px;padding:20px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <h2 style="font-size:15px;font-weight:700;color:#fff;margin:0;">New Survey Form</h2>
      <button onclick="document.getElementById('addFormModal').style.display='none'" style="background:#1a1a1f;border:none;color:#8a8a94;width:30px;height:30px;border-radius:6px;font-size:18px;cursor:pointer;">&times;</button>
    </div>
    <form method="POST" style="display:flex;flex-direction:column;gap:12px;">
      <input type="hidden" name="action" value="create_form" />
      <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Form Title *</label><input name="title" required placeholder="Campus Rating 2026, PERMA Pulse..." style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" /></div>
      <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Description</label><textarea name="description" rows="3" placeholder="What this survey measures..." style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;resize:vertical;"></textarea></div>
      <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">Create Form</button>
    </form>
  </div>
</div>
</AdminLayout>
