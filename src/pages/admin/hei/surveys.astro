---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');

let okMsg = '', errorMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  try {
    if (action === 'create_form') {
      const title = (fd.get('title') as string || '').trim();
      const desc = (fd.get('description') as string || '').trim();
      const questionsRaw = fd.get('questions_json') as string;
      const slug = title.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'') + '-' + Date.now();
      if (!title) { errorMsg = 'Title required.'; }
      else {
        let questions = [];
        try { questions = JSON.parse(questionsRaw || '[]'); } catch(e) {}
        await db.execute(sql`
          INSERT INTO hei_survey_forms (title, slug, description, questions, created_by, is_active)
          VALUES (${title}, ${slug}, ${desc||null}, ${JSON.stringify(questions)}, ${user.id}, true)
        `);
        okMsg = 'Survey form created successfully!';
      }
    } else if (action === 'toggle_form') {
      const id = fd.get('id') as string;
      const cur = await db.execute(sql`SELECT is_active FROM hei_survey_forms WHERE id = ${id} LIMIT 1`);
      const rows = Array.isArray(cur) ? cur : (cur?.rows || []);
      const isActive = (rows[0] as any)?.is_active;
      await db.execute(sql`UPDATE hei_survey_forms SET is_active = ${!isActive}, updated_at = NOW() WHERE id = ${id}`);
      okMsg = isActive ? 'Form paused.' : 'Form activated.';
    } else if (action === 'delete_form') {
      await db.execute(sql`DELETE FROM hei_survey_forms WHERE id = ${fd.get('id') as string}`);
      okMsg = 'Form deleted.';
    }
  } catch(e: any) { errorMsg = e.message; }
}

const url = new URL(Astro.request.url);
const editId = url.searchParams.get('edit') || '';

let forms: any[] = [];
let totalResponses = 0;
try {
  const r = await db.execute(sql`
    SELECT f.*, (SELECT COUNT(*)::int FROM hei_survey_responses WHERE form_id = f.id) as responses
    FROM hei_survey_forms f ORDER BY f.created_at DESC
  `);
  forms = Array.isArray(r) ? r : (r?.rows || []);
  totalResponses = forms.reduce((s: number, f: any) => s + (Number(f.responses)||0), 0);
} catch(e) {}

let editForm: any = null;
if (editId) {
  editForm = forms.find((f: any) => f.id === editId);
}

function timeAgo(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const days = Math.floor(diff/86400000);
  if (days === 0) return 'today';
  if (days === 1) return 'yesterday';
  return days + 'd ago';
}
---
<AdminLayout title="Surveys" activeNav="hei">
<style>
  .qtype-btn { background: #15151a; border: 1px solid #1a1a1f; color: #8a8a94; font-size: 11px; padding: 6px 10px; border-radius: 6px; cursor: pointer; display: flex; align-items: center; gap: 5px; white-space: nowrap; }
  .qtype-btn:hover { background: #1a1a1f; color: #fff; border-color: #FF4F00; }
  .question-card { background: #0f0f14; border: 1px solid #1a1a1f; border-radius: 10px; padding: 14px; margin-bottom: 8px; position: relative; }
  .question-card:hover { border-color: #2a2a2f; }
  .q-type-badge { font-size: 9px; font-weight: 700; padding: 2px 8px; border-radius: 100px; background: rgba(255,112,64,0.15); color: #FF7040; display: inline-block; margin-bottom: 8px; }
  .q-handle { cursor: grab; color: #6e6e78; font-size: 14px; margin-right: 8px; }
  .q-delete { position: absolute; top: 10px; right: 10px; background: none; border: none; color: #6e6e78; cursor: pointer; font-size: 16px; padding: 4px; border-radius: 4px; }
  .q-delete:hover { color: #ef4444; background: rgba(239,68,68,0.1); }
  .form-input { width: 100%; background: #15151a; border: 1px solid #1a1a1f; border-radius: 8px; padding: 9px 12px; color: #fff; font-size: 13px; outline: none; }
  .form-input:focus { border-color: #FF4F00; }
  .required-toggle { display: flex; align-items: center; gap: 6px; font-size: 11px; color: #6e6e78; cursor: pointer; }
  .option-row { display: flex; align-items: center; gap: 6px; margin-bottom: 6px; }
  .option-row input { flex: 1; background: #15151a; border: 1px solid #1a1a1f; border-radius: 6px; padding: 6px 10px; color: #fff; font-size: 12px; outline: none; }
</style>

<div style="padding-bottom:80px;">
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
      <div>
        <p style="font-size:10px;font-family:monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">HEI Editorial</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Survey Forms</h1>
      </div>
      <div style="display:flex;gap:6px;">
        <a href="/admin/hei" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;text-decoration:none;font-size:11px;padding:6px 10px;border-radius:6px;">Dashboard</a>
        <button onclick="openBuilder()" style="background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:600;padding:6px 12px;border-radius:6px;cursor:pointer;">+ New Form</button>
      </div>
    </div>
    <p style="font-size:11px;color:#6e6e78;margin:4px 0 0;">{forms.length} forms - {totalResponses} total responses</p>
  </div>

  {errorMsg && <div style="margin:10px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  <!-- Forms list -->
  <div style="padding:12px 16px;display:flex;flex-direction:column;gap:8px;">
    {forms.length === 0 && (
      <div style="text-align:center;padding:48px 24px;color:#6e6e78;background:#0f0f14;border:1px dashed #1a1a1f;border-radius:12px;">
        <p style="font-size:28px;margin-bottom:8px;">[F]</p>
        <p style="font-size:14px;font-weight:600;color:#fff;margin-bottom:4px;">No survey forms yet</p>
        <p style="font-size:12px;margin-bottom:16px;">Create your first form to collect verified responses from students and alumni.</p>
        <button onclick="openBuilder()" style="background:#FF4F00;border:none;color:#fff;font-size:12px;font-weight:600;padding:9px 18px;border-radius:8px;cursor:pointer;">Create First Form</button>
      </div>
    )}

    {forms.map((f: any) => {
      let questions = [];
      try { questions = typeof f.questions === 'string' ? JSON.parse(f.questions) : (f.questions || []); } catch(e) {}
      return (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
          <div style="padding:14px 16px;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:10px;">
              <div style="flex:1;min-width:0;">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;flex-wrap:wrap;">
                  <p style="font-size:14px;font-weight:700;color:#fff;margin:0;">{f.title}</p>
                  <span style={`font-size:9px;font-weight:700;padding:2px 8px;border-radius:100px;${f.is_active?'background:rgba(16,185,129,0.15);color:#6ee7b7;':'background:#15151a;color:#6e6e78;'}`}>{f.is_active?'Active':'Paused'}</span>
                </div>
                {f.description && <p style="font-size:12px;color:#8a8a94;margin:0 0 6px;">{f.description}</p>}
                <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
                  <span style="font-size:10px;color:#6e6e78;">{questions.length} questions</span>
                  <span style="font-size:10px;color:#6e6e78;">Created {timeAgo(f.created_at)}</span>
                  <span style="font-size:10px;font-family:monospace;color:#6e6e78;">/{f.slug}</span>
                </div>
              </div>
              <div style="text-align:center;flex-shrink:0;background:#15151a;border-radius:8px;padding:8px 12px;">
                <p style="font-size:22px;font-weight:800;color:#FF7040;margin:0;font-family:monospace;">{f.responses||0}</p>
                <p style="font-size:9px;color:#6e6e78;margin:0;">responses</p>
              </div>
            </div>

            <!-- Questions preview -->
            {questions.length > 0 && (
              <div style="margin-top:10px;padding-top:10px;border-top:1px solid #1a1a1f;display:flex;flex-direction:column;gap:4px;">
                {(questions as any[]).slice(0,3).map((q: any, i: number) => (
                  <div style="display:flex;align-items:center;gap:8px;">
                    <span style="font-size:9px;font-weight:700;padding:1px 6px;border-radius:4px;background:#15151a;color:#8a8a94;font-family:monospace;flex-shrink:0;">{q.type?.toUpperCase()}</span>
                    <span style="font-size:11px;color:#8a8a94;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{q.label}</span>
                    {q.required && <span style="font-size:9px;color:#ef4444;flex-shrink:0;">*</span>}
                  </div>
                ))}
                {questions.length > 3 && <p style="font-size:10px;color:#6e6e78;margin:2px 0 0;">+{questions.length-3} more questions</p>}
              </div>
            )}
          </div>

          <div style="border-top:1px solid #1a1a1f;padding:8px 16px;display:flex;gap:6px;flex-wrap:wrap;">
            <button onclick={`editForm('${f.id}', ${JSON.stringify(JSON.stringify({title:f.title,desc:f.description||'',questions}))})`} style="background:#15151a;border:1px solid #1a1a1f;color:#FF7040;font-size:11px;font-weight:600;padding:6px 12px;border-radius:6px;cursor:pointer;">Edit</button>
            <a href={`/surveys/${f.slug}`} target="_blank" style="background:#15151a;border:1px solid #1a1a1f;color:#60a5fa;text-decoration:none;font-size:11px;font-weight:500;padding:6px 12px;border-radius:6px;">Preview</a>
            <form method="POST" style="display:contents;">
              <input type="hidden" name="action" value="toggle_form" /><input type="hidden" name="id" value={f.id} />
              <button type="submit" style={`font-size:11px;padding:6px 12px;border-radius:6px;border:none;cursor:pointer;${f.is_active?'background:rgba(251,191,36,0.1);color:#fbbf24;':'background:rgba(16,185,129,0.1);color:#6ee7b7;'}`}>{f.is_active?'Pause':'Activate'}</button>
            </form>
            <form method="POST" style="display:contents;" onsubmit="return confirm('Delete this form and all its responses?')">
              <input type="hidden" name="action" value="delete_form" /><input type="hidden" name="id" value={f.id} />
              <button type="submit" style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);color:#fca5a5;font-size:11px;padding:6px 10px;border-radius:6px;cursor:pointer;margin-left:auto;">Delete</button>
            </form>
          </div>
        </div>
      );
    })}
  </div>
</div>

<!-- Form Builder Modal -->
<div id="formBuilderModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:200;overflow-y:auto;padding:16px;">
  <div style="background:#0e0e12;border:1px solid #1a1a1f;border-radius:16px;width:100%;max-width:700px;margin:0 auto;overflow:hidden;">

    <!-- Builder header -->
    <div style="background:#0f0f14;border-bottom:1px solid #1a1a1f;padding:14px 16px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:10;">
      <div>
        <p style="font-size:10px;font-family:monospace;color:#FF7040;letter-spacing:0.1em;text-transform:uppercase;margin:0;">Form Builder</p>
        <h2 style="font-size:16px;font-weight:700;color:#fff;margin:0;" id="builderTitle">New Survey Form</h2>
      </div>
      <button onclick="closeBuilder()" style="background:#1a1a1f;border:none;color:#8a8a94;width:32px;height:32px;border-radius:8px;font-size:20px;cursor:pointer;display:flex;align-items:center;justify-content:center;">&times;</button>
    </div>

    <div style="padding:16px;">
      <!-- Form meta -->
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:14px;margin-bottom:14px;">
        <div style="margin-bottom:10px;">
          <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Form Title *</label>
          <input id="fb-title" class="form-input" placeholder="Campus Rating 2026, PERMA Pulse, Alumni 5-year..." />
        </div>
        <div>
          <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Description</label>
          <textarea id="fb-desc" rows="2" class="form-input" placeholder="Brief description shown to respondents..." style="resize:vertical;"></textarea>
        </div>
      </div>

      <!-- Question types toolbar -->
      <div style="margin-bottom:12px;">
        <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:8px;">Add Question</p>
        <div style="display:flex;gap:6px;flex-wrap:wrap;">
          <button class="qtype-btn" onclick="addQuestion('text')">[T] Short text</button>
          <button class="qtype-btn" onclick="addQuestion('textarea')">[P] Long text</button>
          <button class="qtype-btn" onclick="addQuestion('rating')">[*] Rating (1-5)</button>
          <button class="qtype-btn" onclick="addQuestion('select')">[F] Dropdown</button>
          <button class="qtype-btn" onclick="addQuestion('radio')">[R] Single choice</button>
          <button class="qtype-btn" onclick="addQuestion('checkbox')">[X] Multi-choice</button>
          <button class="qtype-btn" onclick="addQuestion('scale')">[S] Likert scale</button>
          <button class="qtype-btn" onclick="addQuestion('number')">[N] Number</button>
          <button class="qtype-btn" onclick="addQuestion('date')">[D] Date</button>
          <button class="qtype-btn" onclick="addQuestion('section')">-- Section break</button>
        </div>
      </div>

      <!-- Questions list -->
      <div id="questionsList" style="min-height:80px;">
        <div id="emptyState" style="text-align:center;padding:32px;color:#6e6e78;background:#0f0f14;border:2px dashed #1a1a1f;border-radius:10px;">
          <p style="font-size:13px;margin-bottom:4px;">No questions yet</p>
          <p style="font-size:11px;">Click a question type above to add your first question</p>
        </div>
      </div>

      <!-- Submit -->
      <div style="margin-top:14px;display:flex;gap:8px;">
        <button onclick="closeBuilder()" style="flex:1;background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;font-weight:600;font-size:13px;padding:12px;border-radius:10px;cursor:pointer;">Cancel</button>
        <button onclick="saveForm()" style="flex:2;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">Save Form</button>
      </div>
    </div>
  </div>
</div>

<!-- Hidden form for submission -->
<form id="saveFormEl" method="POST" style="display:none;">
  <input type="hidden" name="action" value="create_form" />
  <input type="hidden" name="title" id="sf-title" />
  <input type="hidden" name="description" id="sf-desc" />
  <input type="hidden" name="questions_json" id="sf-questions" />
</form>

<script is:inline>
var questions = [];
var qCounter = 0;

function openBuilder() {
  questions = [];
  qCounter = 0;
  document.getElementById('fb-title').value = '';
  document.getElementById('fb-desc').value = '';
  document.getElementById('questionsList').innerHTML = document.getElementById('emptyState') ? document.getElementById('emptyState').outerHTML : '';
  renderQuestions();
  document.getElementById('formBuilderModal').style.display = 'block';
  document.body.style.overflow = 'hidden';
}

function editForm(id, dataJson) {
  var data = JSON.parse(JSON.parse(dataJson));
  questions = data.questions || [];
  qCounter = questions.length;
  document.getElementById('fb-title').value = data.title || '';
  document.getElementById('fb-desc').value = data.desc || '';
  document.getElementById('builderTitle').textContent = 'Edit Form';
  renderQuestions();
  document.getElementById('formBuilderModal').style.display = 'block';
  document.body.style.overflow = 'hidden';
}

function closeBuilder() {
  document.getElementById('formBuilderModal').style.display = 'none';
  document.body.style.overflow = '';
}

function addQuestion(type) {
  var q = { id: 'q' + (++qCounter), type: type, label: '', required: false, options: [] };
  if (type === 'select' || type === 'radio' || type === 'checkbox') {
    q.options = ['Option 1', 'Option 2'];
  }
  if (type === 'scale') {
    q.options = ['Strongly disagree', 'Disagree', 'Neutral', 'Agree', 'Strongly agree'];
  }
  if (type === 'rating') {
    q.options = ['1', '2', '3', '4', '5'];
  }
  if (type === 'section') {
    q.label = 'Section Title';
  }
  questions.push(q);
  renderQuestions();
}

function deleteQuestion(id) {
  questions = questions.filter(function(q) { return q.id !== id; });
  renderQuestions();
}

function getQ(id) {
  return questions.find(function(q) { return q.id === id; });
}

function updateQ(id, field, value) {
  var q = getQ(id);
  if (q) q[field] = value;
}

function addOption(id) {
  var q = getQ(id);
  if (q) { q.options.push('New option'); renderQuestions(); }
}

function deleteOption(id, idx) {
  var q = getQ(id);
  if (q && q.options.length > 1) { q.options.splice(idx, 1); renderQuestions(); }
}

function updateOption(id, idx, value) {
  var q = getQ(id);
  if (q) q.options[idx] = value;
}

function renderQuestions() {
  var container = document.getElementById('questionsList');
  if (questions.length === 0) {
    container.innerHTML = '<div style="text-align:center;padding:32px;color:#6e6e78;background:#0f0f14;border:2px dashed #1a1a1f;border-radius:10px;"><p style="font-size:13px;margin-bottom:4px;">No questions yet</p><p style="font-size:11px;">Click a question type above to add your first question</p></div>';
    return;
  }
  var html = '';
  questions.forEach(function(q, idx) {
    var typeLabel = {text:'Short text',textarea:'Long text',rating:'Rating',select:'Dropdown',radio:'Single choice',checkbox:'Multi-choice',scale:'Likert scale',number:'Number',date:'Date',section:'Section'}[q.type] || q.type;
    if (q.type === 'section') {
      html += '<div class="question-card" style="background:#15151a;border-color:#FF4F00;border-style:dashed;">';
      html += '<button class="q-delete" onclick="deleteQuestion(\''+q.id+'\')">&times;</button>';
      html += '<p style="font-size:9px;font-weight:700;text-transform:uppercase;color:#FF7040;margin:0 0 8px;">Section Break</p>';
      html += '<input class="form-input" placeholder="Section title..." value="'+escHtml(q.label)+'" oninput="updateQ(\''+q.id+'\',\'label\',this.value)" style="font-weight:600;" />';
      html += '</div>';
    } else {
      html += '<div class="question-card">';
      html += '<button class="q-delete" onclick="deleteQuestion(\''+q.id+'\')">&times;</button>';
      html += '<div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">';
      html += '<span class="q-type-badge">'+typeLabel+'</span>';
      html += '<span style="font-size:10px;color:#6e6e78;">#'+(idx+1)+'</span>';
      html += '</div>';
      html += '<div style="margin-bottom:10px;"><input class="form-input" placeholder="Question text..." value="'+escHtml(q.label)+'" oninput="updateQ(\''+q.id+'\',\'label\',this.value)" /></div>';
      
      // Options for select/radio/checkbox/scale
      if (q.type === 'select' || q.type === 'radio' || q.type === 'checkbox' || q.type === 'scale') {
        html += '<div style="margin-bottom:10px;">';
        html += '<p style="font-size:10px;color:#6e6e78;margin:0 0 6px;">Options</p>';
        q.options.forEach(function(opt, oi) {
          html += '<div class="option-row">';
          html += '<span style="font-size:12px;color:#6e6e78;width:16px;flex-shrink:0;">'+(oi+1)+'.</span>';
          html += '<input value="'+escHtml(opt)+'" oninput="updateOption(\''+q.id+'\','+oi+',this.value)" />';
          html += '<button type="button" onclick="deleteOption(\''+q.id+'\','+oi+')" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:16px;padding:2px;">&times;</button>';
          html += '</div>';
        });
        if (q.type !== 'scale') {
          html += '<button type="button" onclick="addOption(\''+q.id+'\')" style="background:#15151a;border:1px dashed #1a1a1f;color:#6e6e78;font-size:11px;padding:5px 12px;border-radius:6px;cursor:pointer;margin-top:4px;">+ Add option</button>';
        }
        html += '</div>';
      }

      // Rating preview
      if (q.type === 'rating') {
        html += '<div style="display:flex;gap:6px;margin-bottom:10px;">';
        for (var i=1;i<=5;i++) { html += '<div style="width:32px;height:32px;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:14px;">'+i+'</div>'; }
        html += '</div>';
      }

      // Required toggle
      html += '<label class="required-toggle"><input type="checkbox" '+(q.required?'checked':'')+' onchange="updateQ(\''+q.id+'\',\'required\',this.checked)" style="accent-color:#FF4F00;" /><span>Required</span></label>';
      html += '</div>';
    }
  });
  container.innerHTML = html;
}

function escHtml(s) {
  return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function saveForm() {
  var title = document.getElementById('fb-title').value.trim();
  if (!title) { alert('Please enter a form title.'); return; }
  if (questions.length === 0) { if (!confirm('Save form with no questions?')) return; }
  
  // Sync all input values before saving
  var inputs = document.querySelectorAll('#questionsList input[oninput], #questionsList textarea[oninput]');
  inputs.forEach(function(el) {
    if (el.getAttribute('oninput')) eval(el.getAttribute('oninput').replace('this.value', '"'+el.value.replace(/"/g,'\\"')+'"'));
  });

  document.getElementById('sf-title').value = title;
  document.getElementById('sf-desc').value = document.getElementById('fb-desc').value;
  document.getElementById('sf-questions').value = JSON.stringify(questions);
  document.getElementById('saveFormEl').submit();
}
</script>
</AdminLayout>
