---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');

let okMsg = '', errorMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  try {
    if (action === 'add') {
      const title = (fd.get('title') as string || '').trim();
      const riskType = fd.get('risk_type') as string;
      const notes = (fd.get('notes') as string || '').trim();
      const findingId = fd.get('finding_id') as string;
      if (!title) { errorMsg = 'Title required.'; }
      else {
        await db.execute(sql`INSERT INTO hei_legal_queue (title, risk_type, notes, finding_id, status, created_by) VALUES (${title}, ${riskType||null}, ${notes||null}, ${findingId||null}, 'open', ${user.id})`);
        okMsg = 'Added to legal queue.';
      }
    } else if (action === 'update') {
      const id = fd.get('id') as string;
      const status = fd.get('status') as string;
      const notes = (fd.get('notes') as string || '').trim();
      await db.execute(sql`UPDATE hei_legal_queue SET status = ${status}, notes = ${notes||null}, resolved_at = ${['cleared','rejected'].includes(status) ? new Date().toISOString() : null} WHERE id = ${id}`);
      okMsg = 'Legal queue updated.';
    }
  } catch(e: any) { errorMsg = e.message; }
}

const url = new URL(Astro.request.url);
const filter = url.searchParams.get('filter') || 'open';

let items: any[] = [];
try {
  const sf = filter !== 'all' ? sql`AND status = ${filter}` : sql``;
  const r = await db.execute(sql`SELECT q.*, f.title as finding_title FROM hei_legal_queue q LEFT JOIN hei_findings f ON q.finding_id = f.id WHERE 1=1 ${sf} ORDER BY q.created_at DESC`);
  items = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

let findings: any[] = [];
try {
  const r = await db.execute(sql`SELECT id, title FROM hei_findings ORDER BY title LIMIT 50`);
  findings = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

const STATUS_COLOR: Record<string,string> = { open:'#ef4444', in_review:'#fbbf24', cleared:'#10b981', rejected:'#6b7280' };
const RISK_COLOR: Record<string,string> = { defamation:'#ef4444', named_case:'#f97316', public_official:'#fbbf24', citation:'#60a5fa', other:'#6b7280' };

function timeAgo(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const days = Math.floor(diff/86400000);
  if (days===0) return 'today';
  return days + 'd ago';
}
---
<AdminLayout title="Legal Queue" activeNav="hei">
<div style="padding-bottom:80px;">
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
      <div>
        <p style="font-size:10px;font-family:monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">HEI Editorial</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Legal Queue</h1>
      </div>
      <div style="display:flex;gap:6px;">
        <a href="/admin/hei" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;text-decoration:none;font-size:11px;padding:6px 10px;border-radius:6px;">Dashboard</a>
        <button onclick="document.getElementById('addLegalModal').style.display='flex'" style="background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:600;padding:6px 12px;border-radius:6px;cursor:pointer;">+ Add Item</button>
      </div>
    </div>
    <div style="display:flex;gap:5px;overflow-x:auto;">
      {(['open','in_review','cleared','rejected','all'] as const).map(f => (
        <a href={`?filter=${f}`} style={`text-decoration:none;font-size:11px;font-weight:600;padding:5px 10px;border-radius:100px;white-space:nowrap;${filter===f?'background:#FF4F00;color:#fff;':'background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;'}`}>{f.replace('_',' ')}</a>
      ))}
    </div>
  </div>

  {errorMsg && <div style="margin:10px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  {items.length === 0 && (
    <div style="margin:16px;text-align:center;padding:40px;color:#6e6e78;background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;">
      <p style="font-size:13px;">No items in legal queue.</p>
    </div>
  )}

  <div style="padding:12px 16px;display:flex;flex-direction:column;gap:8px;">
    {items.map((item: any) => {
      const sc = STATUS_COLOR[item.status] || '#6b7280';
      const rc = RISK_COLOR[item.risk_type] || '#6b7280';
      return (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
          <div style="padding:12px 14px;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:6px;">
              <div style="flex:1;min-width:0;">
                <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;flex-wrap:wrap;">
                  <span style={`font-size:9px;font-weight:700;padding:2px 7px;border-radius:100px;background:${sc}22;color:${sc};`}>{item.status?.replace('_',' ').toUpperCase()}</span>
                  {item.risk_type && <span style={`font-size:9px;padding:2px 7px;border-radius:100px;background:${rc}22;color:${rc};`}>{item.risk_type?.replace('_',' ')}</span>}
                </div>
                <p style="font-size:13px;font-weight:600;color:#fff;margin:0 0 3px;">{item.title}</p>
                {item.finding_title && <p style="font-size:10px;color:#8a8a94;margin:0;">Re: {item.finding_title}</p>}
                <p style="font-size:10px;color:#6e6e78;margin:4px 0 0;">Added {timeAgo(item.created_at)}</p>
              </div>
            </div>
            {item.notes && <p style="font-size:11px;color:#8a8a94;margin:6px 0 0;line-height:1.4;">{item.notes}</p>}
          </div>
          <div style="border-top:1px solid #1a1a1f;padding:8px 14px;">
            <form method="POST" style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
              <input type="hidden" name="action" value="update" /><input type="hidden" name="id" value={item.id} />
              <select name="status" style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:5px 8px;color:#fff;font-size:11px;outline:none;">
                {['open','in_review','cleared','rejected'].map(s => <option value={s} selected={item.status===s}>{s.replace('_',' ')}</option>)}
              </select>
              <input name="notes" placeholder="Update notes..." defaultValue={item.notes||''} style="flex:1;min-width:100px;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:5px 8px;color:#fff;font-size:11px;outline:none;" />
              <button type="submit" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;font-size:10px;padding:5px 8px;border-radius:6px;cursor:pointer;">Update</button>
            </form>
          </div>
        </div>
      );
    })}
  </div>
</div>

<div id="addLegalModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:100;align-items:flex-end;justify-content:center;">
  <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:16px 16px 0 0;width:100%;max-width:600px;padding:20px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <h2 style="font-size:15px;font-weight:700;color:#fff;margin:0;">Add to Legal Queue</h2>
      <button onclick="document.getElementById('addLegalModal').style.display='none'" style="background:#1a1a1f;border:none;color:#8a8a94;width:30px;height:30px;border-radius:6px;font-size:18px;cursor:pointer;">&times;</button>
    </div>
    <form method="POST" style="display:flex;flex-direction:column;gap:12px;">
      <input type="hidden" name="action" value="add" />
      <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Title *</label><input name="title" required placeholder="Legal risk description..." style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" /></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Risk Type</label>
          <select name="risk_type" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:12px;outline:none;">
            <option value="defamation">Defamation</option><option value="named_case">Named case</option><option value="public_official">Public official</option><option value="citation">Citation dispute</option><option value="other">Other</option>
          </select>
        </div>
        <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Related Finding</label>
          <select name="finding_id" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:12px;outline:none;">
            <option value="">None</option>
            {findings.map((f:any) => <option value={f.id}>{f.title.substring(0,40)}</option>)}
          </select>
        </div>
      </div>
      <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Notes</label><textarea name="notes" rows="3" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;resize:vertical;"></textarea></div>
      <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">Add to Queue</button>
    </form>
  </div>
</div>
</AdminLayout>
