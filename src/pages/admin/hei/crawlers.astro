---
import HeiAdminLayout from '@/layouts/HeiAdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');

let okMsg = '', errorMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  try {
    if (action === 'toggle') {
      const id = fd.get('id') as string;
      const cur = await db.execute(sql`SELECT status FROM hei_crawlers WHERE id = ${id} LIMIT 1`);
      const rows = Array.isArray(cur) ? cur : (cur?.rows || []);
      const curStatus = (rows[0] as any)?.status;
      const newStatus = curStatus === 'active' ? 'paused' : 'active';
      await db.execute(sql`UPDATE hei_crawlers SET status = ${newStatus}, updated_at = NOW() WHERE id = ${id}`);
      okMsg = 'Crawler ' + newStatus + '.';
    } else if (action === 'update_counts') {
      const id = fd.get('id') as string;
      const sources = parseInt(fd.get('sources_count') as string || '0') || 0;
      const records = parseInt(fd.get('records_24h') as string || '0') || 0;
      await db.execute(sql`UPDATE hei_crawlers SET sources_count = ${sources}, records_24h = ${records}, updated_at = NOW() WHERE id = ${id}`);
      okMsg = 'Crawler stats updated.';
    } else if (action === 'add_crawler') {
      const code = (fd.get('code') as string || '').trim().toUpperCase();
      const name = (fd.get('name') as string || '').trim();
      const desc = (fd.get('description') as string || '').trim();
      if (!code || !name) { errorMsg = 'Code and name required.'; }
      else {
        await db.execute(sql`INSERT INTO hei_crawlers (code, name, description, status) VALUES (${code}, ${name}, ${desc||null}, 'active') ON CONFLICT (code) DO NOTHING`);
        okMsg = 'Crawler added.';
      }
    }
  } catch(e: any) { errorMsg = e.message; }
}

let crawlers: any[] = [];
try {
  const r = await db.execute(sql`SELECT * FROM hei_crawlers ORDER BY code`);
  crawlers = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

function timeAgo(d: any) {
  if (!d) return 'never';
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff/60000);
  if (mins < 60) return mins + 'm ago';
  return Math.floor(mins/60) + 'h ago';
}
---
<HeiAdminLayout title="Crawlers" activeNav="hei">
<div style="padding-bottom:80px;">
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
      <div>
        <p style="font-size:10px;font-family:monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">HEI Editorial</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Crawler Health</h1>
      </div>
      <div style="display:flex;gap:6px;">
        <a href="/admin/hei" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;text-decoration:none;font-size:11px;padding:6px 10px;border-radius:6px;">Dashboard</a>
        <button onclick="document.getElementById('addCrawlerModal').style.display='flex'" style="background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:600;padding:6px 12px;border-radius:6px;cursor:pointer;">+ Add Pipeline</button>
      </div>
    </div>
    <p style="font-size:11px;color:#6e6e78;margin:4px 0 0;">{crawlers.filter((c:any)=>c.status==='active').length} active pipelines - {crawlers.length} total</p>
  </div>

  {errorMsg && <div style="margin:10px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  <div style="padding:12px 16px;display:flex;flex-direction:column;gap:8px;">
    {crawlers.map((c: any) => {
      const statusColor = c.status==='active' ? '#10b981' : c.status==='error' ? '#ef4444' : '#fbbf24';
      return (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
          <div style="padding:12px 14px;display:flex;align-items:center;gap:10px;">
            <div style={`width:10px;height:10px;border-radius:50%;background:${statusColor};flex-shrink:0;${c.status==='active'?'box-shadow:0 0 6px '+statusColor+';':''}`}></div>
            <div style="background:#15151a;border-radius:6px;padding:3px 10px;font-size:11px;font-weight:700;color:#FF7040;font-family:monospace;flex-shrink:0;">{c.code}</div>
            <div style="flex:1;min-width:0;">
              <p style="font-size:13px;font-weight:600;color:#fff;margin:0;">{c.name}</p>
              <p style="font-size:10px;color:#6e6e78;margin:2px 0 0;">{c.description}</p>
            </div>
            <div style="text-align:right;flex-shrink:0;">
              <p style="font-size:18px;font-weight:700;color:#10b981;margin:0;font-family:monospace;">{c.sources_count||0}</p>
              <p style="font-size:9px;color:#6e6e78;margin:0;">sources</p>
            </div>
          </div>
          <div style="border-top:1px solid #1a1a1f;padding:8px 14px;display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:4px;">
            <div style="text-align:center;"><p style="font-size:14px;font-weight:700;color:#fff;margin:0;font-family:monospace;">{c.records_24h||0}</p><p style="font-size:9px;color:#6e6e78;margin:0;">records 24h</p></div>
            <div style="text-align:center;"><p style="font-size:12px;font-weight:600;margin:0;" style={`color:${statusColor}`}>{c.status?.toUpperCase()}</p><p style="font-size:9px;color:#6e6e78;margin:0;">status</p></div>
            <div style="text-align:center;"><p style="font-size:11px;color:#fff;margin:0;">{timeAgo(c.updated_at)}</p><p style="font-size:9px;color:#6e6e78;margin:0;">last update</p></div>
          </div>
          <div style="border-top:1px solid #1a1a1f;padding:6px 14px;display:flex;gap:6px;">
            <form method="POST" style="display:contents;">
              <input type="hidden" name="action" value="toggle" /><input type="hidden" name="id" value={c.id} />
              <button type="submit" style={`font-size:11px;font-weight:600;padding:5px 12px;border-radius:6px;border:none;cursor:pointer;${c.status==='active'?'background:rgba(251,191,36,0.1);color:#fbbf24;':'background:rgba(16,185,129,0.1);color:#6ee7b7;'}`}>{c.status==='active'?'Pause':'Resume'}</button>
            </form>
            <form method="POST" style="display:flex;gap:4px;margin-left:auto;">
              <input type="hidden" name="action" value="update_counts" /><input type="hidden" name="id" value={c.id} />
              <input name="sources_count" type="number" placeholder="Sources" value={c.sources_count||0} style="width:70px;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:4px 8px;color:#fff;font-size:11px;outline:none;" />
              <input name="records_24h" type="number" placeholder="24h records" value={c.records_24h||0} style="width:80px;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:4px 8px;color:#fff;font-size:11px;outline:none;" />
              <button type="submit" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;font-size:10px;padding:4px 8px;border-radius:6px;cursor:pointer;">Update</button>
            </form>
          </div>
        </div>
      );
    })}
  </div>
</div>

<div id="addCrawlerModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:100;align-items:flex-end;justify-content:center;">
  <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:16px 16px 0 0;width:100%;max-width:600px;padding:20px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <h2 style="font-size:15px;font-weight:700;color:#fff;margin:0;">Add Pipeline</h2>
      <button onclick="document.getElementById('addCrawlerModal').style.display='none'" style="background:#1a1a1f;border:none;color:#8a8a94;width:30px;height:30px;border-radius:6px;font-size:18px;cursor:pointer;">&times;</button>
    </div>
    <form method="POST" style="display:flex;flex-direction:column;gap:12px;">
      <input type="hidden" name="action" value="add_crawler" />
      <div style="display:grid;grid-template-columns:100px 1fr;gap:10px;">
        <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Code *</label><input name="code" placeholder="P8" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;font-family:monospace;" /></div>
        <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Name *</label><input name="name" placeholder="Pipeline name" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" /></div>
      </div>
      <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Description</label><input name="description" placeholder="Data sources and methodology" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" /></div>
      <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">Add Pipeline</button>
    </form>
  </div>
</div>
</HeiAdminLayout>
