---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { heiInstitutions, heiEntityTypes, heiInstitutionScores, heiDimensions } from '@/lib/db/schema';
import { asc, eq, desc, inArray, sql } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user || user.role === 'applicant') return Astro.redirect('/portal');

let errorMsg = '';
let okMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('_action') as string;

  try {
    if (action === 'create' || action === 'update') {
      const id = fd.get('id') as string;
      const candidate: any = {
        slug: (fd.get('slug') as string || '').trim().toLowerCase(),
        name: (fd.get('name') as string || '').trim(),
        tier: (fd.get('tier') as string || 'university').trim(),
        country: (fd.get('country') as string || 'India').trim(),
        stateRegion: (fd.get('stateRegion') as string || '').trim() || null,
        city: (fd.get('city') as string || '').trim() || null,
        type: (fd.get('type') as string || '').trim() || null,
        establishedYear: parseInt((fd.get('establishedYear') as string) || '0', 10) || null,
        studentCount: parseInt((fd.get('studentCount') as string) || '0', 10) || null,
        websiteUrl: (fd.get('websiteUrl') as string || '').trim() || null,
        entityTypeId: (fd.get('entityTypeId') as string || '').trim() || null,
        parentInstitutionId: (fd.get('parentInstitutionId') as string || '').trim() || null,
        nirfRank: parseInt((fd.get('nirfRank') as string) || '0', 10) || null,
        qsRank: parseInt((fd.get('qsRank') as string) || '0', 10) || null,
        theRank: parseInt((fd.get('theRank') as string) || '0', 10) || null,
        truthScore: (fd.get('truthScore') as string || '').trim() || null,
        truthRank: parseInt((fd.get('truthRank') as string) || '0', 10) || null,
        hasFullData: fd.get('hasFullData') === 'on',
        isPublished: fd.get('isPublished') === 'on',
        notes: (fd.get('notes') as string || '').trim() || null
      };
      if (!candidate.slug || !candidate.name) {
        errorMsg = 'Slug and name are required.';
      } else {
        if (action === 'create') {
          const exists = await db.select({ id: heiInstitutions.id }).from(heiInstitutions).where(eq(heiInstitutions.slug, candidate.slug)).limit(1);
          if (exists.length > 0) { errorMsg = 'Slug already exists.'; }
          else { await db.insert(heiInstitutions).values(candidate); okMsg = 'Created: ' + candidate.name; }
        } else {
          await db.update(heiInstitutions).set({ ...candidate, updatedAt: new Date() }).where(eq(heiInstitutions.id, id));
          okMsg = 'Updated: ' + candidate.name;
        }
      }
    } else if (action === 'delete') {
      const id = fd.get('id') as string;
      await db.delete(heiInstitutions).where(eq(heiInstitutions.id, id));
      okMsg = 'Deleted.';
    } else if (action === 'toggle_publish') {
      const id = fd.get('id') as string;
      const target = await db.select().from(heiInstitutions).where(eq(heiInstitutions.id, id)).limit(1);
      if (target.length > 0) {
        await db.update(heiInstitutions).set({ isPublished: !target[0].isPublished, updatedAt: new Date() }).where(eq(heiInstitutions.id, id));
        okMsg = target[0].isPublished ? 'Hidden' : 'Published';
      }
    } else if (action === 'bulk_publish' || action === 'bulk_unpublish' || action === 'bulk_delete' || action === 'bulk_compute' || action === 'bulk_set_type') {
      const idsRaw = fd.get('selected_ids') as string;
      const ids = (idsRaw || '').split(',').map(s => s.trim()).filter(s => s.length > 0);
      if (ids.length === 0) {
        errorMsg = 'No institutions selected.';
      } else {
        if (action === 'bulk_publish') {
          await db.update(heiInstitutions).set({ isPublished: true, updatedAt: new Date() }).where(inArray(heiInstitutions.id, ids));
          okMsg = 'Published ' + ids.length + ' institutions.';
        } else if (action === 'bulk_unpublish') {
          await db.update(heiInstitutions).set({ isPublished: false, updatedAt: new Date() }).where(inArray(heiInstitutions.id, ids));
          okMsg = 'Unpublished ' + ids.length + ' institutions.';
        } else if (action === 'bulk_delete') {
          await db.delete(heiInstitutions).where(inArray(heiInstitutions.id, ids));
          okMsg = 'Deleted ' + ids.length + ' institutions.';
        } else if (action === 'bulk_compute') {
          // For each institution: compute truth score from existing dimension scores
          const allDims = await db.select().from(heiDimensions);
          const dimMap = Object.fromEntries(allDims.map(d => [d.id, parseFloat(d.weightPercent || '0')]));
          let computed = 0;
          let skipped = 0;
          for (const id of ids) {
            const scores = await db.select().from(heiInstitutionScores).where(eq(heiInstitutionScores.institutionId, id));
            if (scores.length === 0) { skipped++; continue; }
            let weightedSum = 0;
            let totalWeight = 0;
            for (const s of scores) {
              const w = dimMap[s.dimensionId] || 0;
              if (w > 0) {
                weightedSum += parseFloat(s.score) * w / 100;
                totalWeight += w;
              }
            }
            if (totalWeight > 0) {
              const finalScore = (weightedSum * 100 / totalWeight).toFixed(2);
              await db.update(heiInstitutions).set({ truthScore: finalScore, isPublished: true, updatedAt: new Date() }).where(eq(heiInstitutions.id, id));
              computed++;
            } else {
              skipped++;
            }
          }
          okMsg = 'Computed Truth Score + published ' + computed + '. Skipped ' + skipped + ' (no dimension scores entered).';
        } else if (action === 'bulk_set_type') {
          const typeId = fd.get('bulk_entity_type_id') as string;
          if (!typeId) { errorMsg = 'Pick an entity type for bulk update.'; }
          else {
            await db.update(heiInstitutions).set({ entityTypeId: typeId, updatedAt: new Date() }).where(inArray(heiInstitutions.id, ids));
            okMsg = 'Set entity type on ' + ids.length + ' institutions.';
          }
        }
      }
    }
  } catch (err: any) {
    errorMsg = 'Failed: ' + (err.message || 'Unknown error');
  }
}

const url = new URL(Astro.request.url);
const editId = url.searchParams.get('edit') || '';
const filterCountry = url.searchParams.get('country') || '';
const filterType = url.searchParams.get('type') || '';
const filterStatus = url.searchParams.get('status') || '';
const search = (url.searchParams.get('q') || '').toLowerCase().trim();

let allInst = await db.select().from(heiInstitutions).orderBy(asc(heiInstitutions.truthRank), asc(heiInstitutions.name));
if (filterCountry) allInst = allInst.filter(i => i.country === filterCountry);
if (filterType) allInst = allInst.filter(i => i.entityTypeId === filterType);
if (filterStatus === 'published') allInst = allInst.filter(i => i.isPublished);
if (filterStatus === 'draft') allInst = allInst.filter(i => !i.isPublished);
if (filterStatus === 'has_score') allInst = allInst.filter(i => i.truthScore !== null);
if (filterStatus === 'no_score') allInst = allInst.filter(i => i.truthScore === null);
if (search) allInst = allInst.filter(i =>
  i.name.toLowerCase().includes(search) ||
  (i.city || '').toLowerCase().includes(search) ||
  i.country.toLowerCase().includes(search)
);

const editing = editId && editId !== 'new' ? allInst.find(i => i.id === editId) || (await db.select().from(heiInstitutions).where(eq(heiInstitutions.id, editId)).limit(1))[0] : null;

const allTypes = await db.select().from(heiEntityTypes).where(eq(heiEntityTypes.isActive, true)).orderBy(asc(heiEntityTypes.sortOrder));
const typeMap = Object.fromEntries(allTypes.map(t => [t.id, t.label]));
const typesByCategory: Record<string, any[]> = {};
for (const t of allTypes) {
  if (!typesByCategory[t.category]) typesByCategory[t.category] = [];
  typesByCategory[t.category].push(t);
}

const parentCandidates = await db.select({ id: heiInstitutions.id, name: heiInstitutions.name }).from(heiInstitutions).orderBy(asc(heiInstitutions.name));

const totalAll = await db.select({ id: heiInstitutions.id }).from(heiInstitutions);
const counts = {
  total: totalAll.length,
  filtered: allInst.length,
  published: allInst.filter(i => i.isPublished).length,
  hasScore: allInst.filter(i => i.truthScore !== null).length
};

const countries = Array.from(new Set((await db.select({ country: heiInstitutions.country }).from(heiInstitutions)).map(r => r.country))).sort();

function categoryLabel(c: string): string {
  return c.replace(/_/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase());
}
---
<AdminLayout title="HEI Institutions" activeNav="hei">
  <div class="admin-page" style="max-width:1500px;">

    <div class="admin-page-header" style="margin-bottom:18px;">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">HEI Data</div>
        <h1 class="admin-page-title">Institutions</h1>
        <p class="admin-page-sub">{counts.total} total / {counts.filtered} shown / {counts.published} published / {counts.hasScore} with Truth Score</p>
      </div>
    </div>

    {errorMsg && <div style="background:rgba(220,38,38,0.08);border:1px solid rgba(220,38,38,0.25);color:#fca5a5;font-size:12px;padding:10px 13px;border-radius:6px;margin-bottom:14px;">{errorMsg}</div>}
    {okMsg && <div style="background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.25);color:#6ee7b7;font-size:12px;padding:10px 13px;border-radius:6px;margin-bottom:14px;">{okMsg}</div>}

    <!-- FILTERS -->
    <form method="GET" class="admin-card" style="padding:12px;margin-bottom:14px;display:flex;flex-wrap:wrap;gap:8px;align-items:end;">
      <div style="flex:1;min-width:180px;">
        <label class="rfl">Search</label>
        <input name="q" value={search} placeholder="Name, city, country..." class="rfi" />
      </div>
      <div style="min-width:170px;">
        <label class="rfl">Country</label>
        <select name="country" class="rfi">
          <option value="">All</option>
          {countries.map((c) => <option value={c} selected={filterCountry === c}>{c}</option>)}
        </select>
      </div>
      <div style="min-width:200px;">
        <label class="rfl">Entity Type</label>
        <select name="type" class="rfi">
          <option value="">All</option>
          {Object.entries(typesByCategory).map(([cat, types]) => (
            <optgroup label={categoryLabel(cat)}>
              {types.map((t) => <option value={t.id} selected={filterType === t.id}>{t.label}</option>)}
            </optgroup>
          ))}
        </select>
      </div>
      <div style="min-width:160px;">
        <label class="rfl">Status</label>
        <select name="status" class="rfi">
          <option value="">All</option>
          <option value="published" selected={filterStatus === 'published'}>Published</option>
          <option value="draft" selected={filterStatus === 'draft'}>Draft</option>
          <option value="has_score" selected={filterStatus === 'has_score'}>Has Truth Score</option>
          <option value="no_score" selected={filterStatus === 'no_score'}>No Truth Score</option>
        </select>
      </div>
      <button type="submit" class="admin-btn admin-btn-primary" style="padding:7px 14px;font-size:11px;">Filter</button>
      {(filterCountry || filterType || filterStatus || search) && <a href="/admin/hei/institutions" class="admin-btn" style="padding:7px 14px;font-size:11px;text-decoration:none;display:flex;align-items:center;">Clear</a>}
    </form>

    <!-- BULK ACTION BAR -->
    <form method="POST" id="bulkForm" class="admin-card" style="padding:10px 14px;margin-bottom:14px;display:flex;flex-wrap:wrap;gap:8px;align-items:center;">
      <input type="hidden" name="selected_ids" id="selected_ids" value="" />
      <span style="font-size:11px;color:#6e6e78;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;">Bulk:</span>
      <button type="submit" name="_action" value="bulk_publish" class="admin-btn" style="padding:5px 10px;font-size:10.5px;color:#6ee7b7;">Publish</button>
      <button type="submit" name="_action" value="bulk_unpublish" class="admin-btn" style="padding:5px 10px;font-size:10.5px;">Unpublish</button>
      <button type="submit" name="_action" value="bulk_compute" class="admin-btn" style="padding:5px 10px;font-size:10.5px;color:#FF7040;" onclick="return confirm('Compute Truth Score from existing dimension scores AND publish for selected institutions?');">Compute &amp; Publish</button>
      <select name="bulk_entity_type_id" class="rfi" style="padding:5px 9px;font-size:10.5px;max-width:200px;">
        <option value="">— pick entity type —</option>
        {Object.entries(typesByCategory).map(([cat, types]) => (
          <optgroup label={categoryLabel(cat)}>
            {types.map((t) => <option value={t.id}>{t.label}</option>)}
          </optgroup>
        ))}
      </select>
      <button type="submit" name="_action" value="bulk_set_type" class="admin-btn" style="padding:5px 10px;font-size:10.5px;">Set Type</button>
      <button type="submit" name="_action" value="bulk_delete" class="admin-btn" style="padding:5px 10px;font-size:10.5px;color:#fca5a5;" onclick="return confirm('Delete the selected institutions permanently? This cannot be undone.');">Delete</button>
      <span id="selectedCount" style="font-size:11px;color:#a0a0ab;margin-left:auto;">0 selected</span>
    </form>

    <div style="display:grid;grid-template-columns:1.7fr 1fr;gap:14px;align-items:flex-start;">

      <!-- LIST -->
      <div class="admin-card" style="padding:0;overflow:hidden;">
        <div style="padding:12px 14px;border-bottom:1px solid #1f1f26;display:flex;justify-content:space-between;align-items:center;">
          <span style="font-size:10.5px;color:#6e6e78;text-transform:uppercase;letter-spacing:0.1em;font-weight:700;">{counts.filtered} institutions</span>
          {!editing && <a href="?edit=new" class="admin-btn admin-btn-primary" style="padding:4px 10px;font-size:10.5px;text-decoration:none;">+ New</a>}
        </div>
        <table class="admin-table">
          <thead>
            <tr>
              <th style="width:30px;"><input type="checkbox" id="selectAll" style="accent-color:#FF4F00;" /></th>
              <th>Institution</th>
              <th>Type</th>
              <th>Truth</th>
              <th>Status</th>
              <th style="text-align:right;">Actions</th>
            </tr>
          </thead>
          <tbody>
            {allInst.map((i) => (
              <tr style={editing && editing.id === i.id ? 'background:rgba(255,79,0,0.06);' : ''}>
                <td><input type="checkbox" class="row-check" data-id={i.id} style="accent-color:#FF4F00;" /></td>
                <td>
                  <div style="font-weight:500;color:#fff;font-size:12.5px;">{i.name}</div>
                  <div style="font-size:10.5px;color:#6e6e78;margin-top:2px;">{i.city ? i.city + ', ' : ''}{i.country}</div>
                </td>
                <td><span style="font-size:10.5px;color:#a0a0ab;">{i.entityTypeId ? (typeMap[i.entityTypeId] || i.entityTypeId) : <span style="color:#6e6e78;font-style:italic;">— unset —</span>}</span></td>
                <td>{i.truthScore ? <div><div style="font-weight:600;color:#fff;font-size:13px;">{i.truthScore}</div>{i.truthRank && <div style="font-size:10px;color:#6e6e78;">#{i.truthRank}</div>}</div> : <span style="color:#6e6e78;font-size:11px;">—</span>}</td>
                <td><span style={'font-size:10.5px;color:' + (i.isPublished ? '#10b981' : '#fbbf24') + ';'}>{i.isPublished ? '● Pub' : '○ Draft'}</span></td>
                <td style="text-align:right;">
                  <div style="display:flex;gap:4px;justify-content:flex-end;">
                    <a href={'/admin/hei/score/' + i.id} class="admin-btn" style="padding:3px 8px;font-size:10px;color:#FF7040;">Score</a>
                    <a href={'?edit=' + i.id} class="admin-btn" style="padding:3px 8px;font-size:10px;">Edit</a>
                    <form method="POST" style="margin:0;display:inline;" onsubmit="return confirm('Delete this institution permanently?');">
                      <input type="hidden" name="_action" value="delete" />
                      <input type="hidden" name="id" value={i.id} />
                      <button type="submit" class="admin-btn" style="padding:3px 8px;font-size:10px;color:#fca5a5;">Del</button>
                    </form>
                  </div>
                </td>
              </tr>
            ))}
            {allInst.length === 0 && <tr><td colspan="6" style="text-align:center;padding:30px;color:#6e6e78;font-size:13px;">No institutions match filters.</td></tr>}
          </tbody>
        </table>
      </div>

      <!-- EDIT FORM -->
      {(editing || editId === 'new') && (
        <form method="POST" class="admin-card" style="display:flex;flex-direction:column;gap:11px;">
          <input type="hidden" name="_action" value={editing ? 'update' : 'create'} />
          {editing && <input type="hidden" name="id" value={editing.id} />}
          <div class="admin-card-title" style="margin:0 0 4px;font-size:13px;">{editing ? 'Edit: ' + editing.name : '+ New institution'}</div>

          <div><label class="rfl">Name *</label><input name="name" required class="rfi" value={editing ? editing.name : ''} /></div>
          <div><label class="rfl">Slug *</label><input name="slug" required pattern="[a-z0-9-]+" class="rfi" placeholder="iit-bombay" value={editing ? editing.slug : ''} /></div>

          <div>
            <label class="rfl">Entity type</label>
            <select name="entityTypeId" class="rfi">
              <option value="">— unset —</option>
              {Object.entries(typesByCategory).map(([cat, types]) => (
                <optgroup label={categoryLabel(cat)}>
                  {types.map((t) => <option value={t.id} selected={editing && editing.entityTypeId === t.id}>{t.label}</option>)}
                </optgroup>
              ))}
            </select>
          </div>

          <div>
            <label class="rfl">Parent institution (optional)</label>
            <select name="parentInstitutionId" class="rfi">
              <option value="">— none —</option>
              {parentCandidates.filter(p => !editing || p.id !== editing.id).map((p) => <option value={p.id} selected={editing && editing.parentInstitutionId === p.id}>{p.name}</option>)}
            </select>
          </div>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <div><label class="rfl">Country</label><input name="country" class="rfi" value={editing ? editing.country : 'India'} /></div>
            <div><label class="rfl">State / region</label><input name="stateRegion" class="rfi" value={editing && editing.stateRegion ? editing.stateRegion : ''} /></div>
            <div><label class="rfl">City</label><input name="city" class="rfi" value={editing && editing.city ? editing.city : ''} /></div>
            <div><label class="rfl">Established</label><input type="number" name="establishedYear" class="rfi" value={editing && editing.establishedYear ? editing.establishedYear : ''} /></div>
            <div><label class="rfl">Type (notes)</label><input name="type" class="rfi" placeholder="Public/Private/..." value={editing && editing.type ? editing.type : ''} /></div>
            <div><label class="rfl">Students</label><input type="number" name="studentCount" class="rfi" value={editing && editing.studentCount ? editing.studentCount : ''} /></div>
            <div><label class="rfl">Tier (legacy)</label>
              <select name="tier" class="rfi">
                <option value="university" selected={!editing || editing.tier === 'university'}>University</option>
                <option value="college" selected={editing && editing.tier === 'college'}>College</option>
                <option value="school" selected={editing && editing.tier === 'school'}>School</option>
                <option value="govt_programme" selected={editing && editing.tier === 'govt_programme'}>Govt Programme</option>
              </select>
            </div>
          </div>

          <div><label class="rfl">Website</label><input name="websiteUrl" type="url" class="rfi" value={editing && editing.websiteUrl ? editing.websiteUrl : ''} /></div>

          <div style="padding:10px;background:rgba(255,79,0,0.05);border:1px solid rgba(255,79,0,0.2);border-radius:6px;">
            <p style="font-size:10px;color:#FF7040;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:8px;">Rankings</p>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;">
              <div><label class="rfl">NIRF</label><input type="number" name="nirfRank" class="rfi" value={editing && editing.nirfRank ? editing.nirfRank : ''} /></div>
              <div><label class="rfl">QS</label><input type="number" name="qsRank" class="rfi" value={editing && editing.qsRank ? editing.qsRank : ''} /></div>
              <div><label class="rfl">THE</label><input type="number" name="theRank" class="rfi" value={editing && editing.theRank ? editing.theRank : ''} /></div>
              <div><label class="rfl">Truth score</label><input name="truthScore" class="rfi" placeholder="0-100" value={editing && editing.truthScore ? editing.truthScore : ''} /></div>
              <div><label class="rfl">Truth rank</label><input type="number" name="truthRank" class="rfi" value={editing && editing.truthRank ? editing.truthRank : ''} /></div>
            </div>
          </div>

          <div><label class="rfl">Notes</label><textarea name="notes" rows="2" class="rfi">{editing && editing.notes ? editing.notes : ''}</textarea></div>

          <label style="display:flex;align-items:center;gap:8px;color:#d8d8de;font-size:12px;">
            <input type="checkbox" name="hasFullData" style="accent-color:#FF4F00;" checked={editing && editing.hasFullData} />
            <span>Has full data (eligible for ranking)</span>
          </label>
          <label style="display:flex;align-items:center;gap:8px;color:#d8d8de;font-size:12px;">
            <input type="checkbox" name="isPublished" style="accent-color:#FF4F00;" checked={editing && editing.isPublished} />
            <span>Publish on public /hei page</span>
          </label>

          <div style="display:flex;gap:8px;margin-top:6px;">
            <button type="submit" class="admin-btn admin-btn-primary" style="flex:1;justify-content:center;">{editing ? 'Save' : 'Create'}</button>
            <a href="/admin/hei/institutions" class="admin-btn" style="padding:8px 14px;display:flex;align-items:center;text-decoration:none;">Cancel</a>
          </div>
        </form>
      )}

      {!editing && editId !== 'new' && (
        <div class="admin-card" style="text-align:center;padding:30px 20px;">
          <p style="font-size:12px;color:#6e6e78;line-height:1.7;">Use checkboxes + bulk action bar above to publish or delete many at once. Click <strong>Score</strong> on a row to enter per-dimension scores, then click <strong>Compute &amp; Publish</strong> in the bulk bar to auto-calculate Truth Scores.</p>
        </div>
      )}
    </div>
  </div>

  <script is:inline>
    (function() {
      const selectAll = document.getElementById('selectAll');
      const checks = Array.from(document.querySelectorAll('.row-check'));
      const idsInput = document.getElementById('selected_ids');
      const countLabel = document.getElementById('selectedCount');

      function updateSelected() {
        const selected = checks.filter(c => c.checked).map(c => c.dataset.id);
        idsInput.value = selected.join(',');
        countLabel.textContent = selected.length + ' selected';
      }

      if (selectAll) {
        selectAll.addEventListener('change', function() {
          checks.forEach(c => c.checked = selectAll.checked);
          updateSelected();
        });
      }
      checks.forEach(c => c.addEventListener('change', updateSelected));
    })();
  </script>

  <style>
    .rfl { display:block;font-size:10px;font-weight:600;color:#8a8a94;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:4px; }
    .rfi { width:100%;padding:7px 10px;background:#08080a;border:1px solid #1f1f26;border-radius:5px;color:#fff;font-size:12px;font-family:inherit;outline:none; }
    .rfi:focus { border-color:#FF4F00; }
    textarea.rfi { resize:vertical; }
  </style>
</AdminLayout>