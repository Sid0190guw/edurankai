---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { heiInstitutions, heiEntityTypes, heiDimensions, heiInstitutionScores } from '@/lib/db/schema';
import { eq, asc, inArray } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

let errorMsg = '';
let okMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('_action') as string;
  try {
    if (action === 'create' || action === 'update') {
      const id = fd.get('id') as string;
      const data = {
        name: (fd.get('name') as string || '').trim(),
        slug: (fd.get('slug') as string || '').trim().toLowerCase(),
        entityTypeId: (fd.get('entityTypeId') as string || '') || null,
        parentInstitutionId: (fd.get('parentInstitutionId') as string || '') || null,
        country: (fd.get('country') as string || 'India').trim(),
        stateRegion: (fd.get('stateRegion') as string || '') || null,
        city: (fd.get('city') as string || '') || null,
        establishedYear: fd.get('establishedYear') ? parseInt(fd.get('establishedYear') as string) : null,
        type: (fd.get('type') as string || '') || null,
        studentCount: fd.get('studentCount') ? parseInt(fd.get('studentCount') as string) : null,
        tier: (fd.get('tier') as string || 'university') as any,
        websiteUrl: (fd.get('websiteUrl') as string || '') || null,
        nirfRank: fd.get('nirfRank') ? parseInt(fd.get('nirfRank') as string) : null,
        qsRank: fd.get('qsRank') ? parseInt(fd.get('qsRank') as string) : null,
        theRank: fd.get('theRank') ? parseInt(fd.get('theRank') as string) : null,
        truthScore: (fd.get('truthScore') as string || '') || null,
        truthRank: fd.get('truthRank') ? parseInt(fd.get('truthRank') as string) : null,
        notes: (fd.get('notes') as string || '') || null,
        hasFullData: fd.get('hasFullData') === 'on',
        isPublished: fd.get('isPublished') === 'on',
        updatedAt: new Date(),
      };
      if (!data.name || !data.slug) { errorMsg = 'Name and slug are required.'; }
      else if (action === 'create') {
        await db.insert(heiInstitutions).values(data as any);
        okMsg = 'Institution created: ' + data.name;
      } else {
        await db.update(heiInstitutions).set(data).where(eq(heiInstitutions.id, id));
        okMsg = 'Updated: ' + data.name;
      }
    } else if (action === 'delete') {
      const id = fd.get('id') as string;
      await db.delete(heiInstitutions).where(eq(heiInstitutions.id, id));
      okMsg = 'Deleted.';
    } else if (action === 'toggle_publish') {
      const id = fd.get('id') as string;
      const target = await db.select({ isPublished: heiInstitutions.isPublished }).from(heiInstitutions).where(eq(heiInstitutions.id, id)).limit(1);
      if (target.length > 0) {
        await db.update(heiInstitutions).set({ isPublished: !target[0].isPublished, updatedAt: new Date() }).where(eq(heiInstitutions.id, id));
        okMsg = target[0].isPublished ? 'Hidden' : 'Published';
      }
    } else if (['bulk_publish','bulk_unpublish','bulk_delete','bulk_compute','bulk_set_type'].includes(action)) {
      const ids = ((fd.get('selected_ids') as string) || '').split(',').map(s => s.trim()).filter(Boolean);
      if (ids.length === 0) { errorMsg = 'No institutions selected.'; }
      else if (action === 'bulk_publish') {
        await db.update(heiInstitutions).set({ isPublished: true, updatedAt: new Date() }).where(inArray(heiInstitutions.id, ids));
        okMsg = `Published ${ids.length} institutions.`;
      } else if (action === 'bulk_unpublish') {
        await db.update(heiInstitutions).set({ isPublished: false, updatedAt: new Date() }).where(inArray(heiInstitutions.id, ids));
        okMsg = `Unpublished ${ids.length} institutions.`;
      } else if (action === 'bulk_delete') {
        await db.delete(heiInstitutions).where(inArray(heiInstitutions.id, ids));
        okMsg = `Deleted ${ids.length} institutions.`;
      } else if (action === 'bulk_compute') {
        const allDims = await db.select().from(heiDimensions);
        const dimMap = Object.fromEntries(allDims.map(d => [d.id, parseFloat(d.weightPercent || '0')]));
        let computed = 0, skipped = 0;
        for (const id of ids) {
          const scores = await db.select().from(heiInstitutionScores).where(eq(heiInstitutionScores.institutionId, id));
          if (scores.length === 0) { skipped++; continue; }
          let weightedSum = 0, totalWeight = 0;
          for (const s of scores) {
            const w = dimMap[s.dimensionId] || 0;
            if (w > 0) { weightedSum += parseFloat(s.score) * w / 100; totalWeight += w; }
          }
          if (totalWeight > 0) {
            const finalScore = (weightedSum * 100 / totalWeight).toFixed(2);
            await db.update(heiInstitutions).set({ truthScore: finalScore, isPublished: true, updatedAt: new Date() }).where(eq(heiInstitutions.id, id));
            computed++;
          } else { skipped++; }
        }
        okMsg = `Computed + published ${computed}. Skipped ${skipped} (no scores).`;
      } else if (action === 'bulk_set_type') {
        const typeId = fd.get('bulk_entity_type_id') as string;
        if (!typeId) { errorMsg = 'Pick an entity type.'; }
        else { await db.update(heiInstitutions).set({ entityTypeId: typeId, updatedAt: new Date() }).where(inArray(heiInstitutions.id, ids)); okMsg = `Set type on ${ids.length} institutions.`; }
      }
    }
  } catch (err: any) { errorMsg = 'Failed: ' + (err.message || 'Unknown'); }
}

const url = new URL(Astro.request.url);
const editId = url.searchParams.get('edit') || '';
const filterCountry = url.searchParams.get('country') || '';
const filterType = url.searchParams.get('type') || '';
const filterStatus = url.searchParams.get('status') || '';
const search = (url.searchParams.get('q') || '').toLowerCase().trim();
const page = parseInt(url.searchParams.get('page') || '1');
const perPage = 30;

let allInst = await db.select().from(heiInstitutions).orderBy(asc(heiInstitutions.truthRank), asc(heiInstitutions.name));
if (filterCountry) allInst = allInst.filter(i => i.country === filterCountry);
if (filterType) allInst = allInst.filter(i => i.entityTypeId === filterType);
if (filterStatus === 'published') allInst = allInst.filter(i => i.isPublished);
if (filterStatus === 'draft') allInst = allInst.filter(i => !i.isPublished);
if (filterStatus === 'has_score') allInst = allInst.filter(i => i.truthScore !== null);
if (filterStatus === 'no_score') allInst = allInst.filter(i => i.truthScore === null);
if (search) allInst = allInst.filter(i => i.name.toLowerCase().includes(search) || (i.city||'').toLowerCase().includes(search) || i.country.toLowerCase().includes(search));

const totalFiltered = allInst.length;
const totalPages = Math.ceil(totalFiltered / perPage);
const pagedInst = allInst.slice((page-1)*perPage, page*perPage);

const editing = editId && editId !== 'new' ? allInst.find(i => i.id === editId) || (await db.select().from(heiInstitutions).where(eq(heiInstitutions.id, editId)).limit(1))[0] : null;
const allTypes = await db.select().from(heiEntityTypes).where(eq(heiEntityTypes.isActive, true)).orderBy(asc(heiEntityTypes.sortOrder));
const typeMap = Object.fromEntries(allTypes.map(t => [t.id, t.label]));
const typesByCategory: Record<string, any[]> = {};
for (const t of allTypes) { if (!typesByCategory[t.category]) typesByCategory[t.category] = []; typesByCategory[t.category].push(t); }
const parentCandidates = await db.select({ id: heiInstitutions.id, name: heiInstitutions.name }).from(heiInstitutions).orderBy(asc(heiInstitutions.name));
const countries = Array.from(new Set((await db.select({ country: heiInstitutions.country }).from(heiInstitutions)).map(r => r.country))).sort();
const totalAll = allInst.length;
const publishedCount = allInst.filter(i => i.isPublished).length;
const hasScoreCount = allInst.filter(i => i.truthScore !== null).length;

function categoryLabel(c: string) { return c.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()); }
---
<AdminLayout title="HEI Institutions" activeNav="hei">
<div style="padding-bottom:100px;">

  <!-- Header -->
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
      <div>
        <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">HEI Data</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Institutions</h1>
      </div>
      <div style="display:flex;gap:6px;">
        <a href="/admin/hei/import" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;text-decoration:none;font-size:11px;padding:7px 10px;border-radius:7px;">↑ Import</a>
        <a href="?edit=new" style="background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:12px;padding:7px 12px;border-radius:8px;text-decoration:none;">+ New</a>
      </div>
    </div>

    <!-- Stats -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:10px;">
      {[
        { label: 'Total', value: totalAll, color: '#fff' },
        { label: 'Published', value: publishedCount, color: '#10b981' },
        { label: 'Scored', value: hasScoreCount, color: '#FF7040' },
      ].map(s => (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:8px;padding:8px;text-align:center;">
          <p style={`font-size:18px;font-weight:700;color:${s.color};margin:0;line-height:1;`}>{s.value}</p>
          <p style="font-size:9px;color:#6e6e78;margin:2px 0 0;text-transform:uppercase;">{s.label}</p>
        </div>
      ))}
    </div>

    <!-- Search -->
    <form method="GET" style="display:flex;gap:8px;">
      <input type="text" name="q" value={search} placeholder="Search name, city, country..." style="flex:1;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:8px 12px;color:#fff;font-size:13px;outline:none;min-width:0;" />
      <button type="button" onclick="document.getElementById('filterPanel').style.display=document.getElementById('filterPanel').style.display==='none'?'block':'none'" style="background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:8px 12px;color:#fff;font-size:12px;cursor:pointer;">⚙ Filter</button>
      <button type="submit" style="background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:8px 12px;color:#fff;font-size:12px;cursor:pointer;">Go</button>
    </form>
  </div>

  <!-- Filter panel (collapsible) -->
  <div id="filterPanel" style="display:none;background:#0f0f14;border-bottom:1px solid #1a1a1f;padding:12px 16px;">
    <form method="GET" style="display:flex;flex-direction:column;gap:8px;">
      <input type="hidden" name="q" value={search} />
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
        <div>
          <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;color:#6e6e78;margin-bottom:4px;">Country</label>
          <select name="country" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:7px;padding:8px 10px;color:#fff;font-size:12px;outline:none;">
            <option value="">All</option>
            {countries.map(c => <option value={c} selected={filterCountry === c}>{c}</option>)}
          </select>
        </div>
        <div>
          <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;color:#6e6e78;margin-bottom:4px;">Status</label>
          <select name="status" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:7px;padding:8px 10px;color:#fff;font-size:12px;outline:none;">
            <option value="">All</option>
            <option value="published" selected={filterStatus==='published'}>Published</option>
            <option value="draft" selected={filterStatus==='draft'}>Draft</option>
            <option value="has_score" selected={filterStatus==='has_score'}>Has Score</option>
            <option value="no_score" selected={filterStatus==='no_score'}>No Score</option>
          </select>
        </div>
        <div style="grid-column:1/-1;">
          <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;color:#6e6e78;margin-bottom:4px;">Entity Type</label>
          <select name="type" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:7px;padding:8px 10px;color:#fff;font-size:12px;outline:none;">
            <option value="">All types</option>
            {Object.entries(typesByCategory).map(([cat, types]) => (
              <optgroup label={categoryLabel(cat)}>
                {(types as any[]).map(t => <option value={t.id} selected={filterType === t.id}>{t.label}</option>)}
              </optgroup>
            ))}
          </select>
        </div>
      </div>
      <div style="display:flex;gap:8px;">
        <button type="submit" style="flex:1;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:13px;padding:9px;border-radius:8px;cursor:pointer;">Apply Filters</button>
        <a href="/admin/hei/institutions" style="flex:1;text-align:center;background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;text-decoration:none;font-size:13px;font-weight:500;padding:9px;border-radius:8px;">Clear</a>
      </div>
    </form>
  </div>

  {errorMsg && <div style="margin:10px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  <!-- Results count -->
  <div style="padding:10px 16px;display:flex;align-items:center;justify-content:space-between;">
    <p style="font-size:12px;color:#6e6e78;margin:0;">{totalFiltered} institutions{(filterCountry||filterType||filterStatus||search) ? ' (filtered)' : ''} · Page {page}/{totalPages}</p>
    {(filterCountry||filterType||filterStatus||search) && <a href="/admin/hei/institutions" style="font-size:11px;color:#FF7040;text-decoration:none;">Clear filters</a>}
  </div>

  <!-- Institution cards -->
  <form method="POST" id="bulkForm">
    <input type="hidden" name="selected_ids" id="selected_ids" value="" />

    <div style="padding:0 16px;display:flex;flex-direction:column;gap:6px;">
      {pagedInst.length === 0 && (
        <div style="text-align:center;padding:48px;color:#6e6e78;">
          <p style="font-size:32px;margin-bottom:8px;">🏛️</p>
          <p style="font-size:13px;">No institutions match your filters</p>
        </div>
      )}
      {pagedInst.map(inst => (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;overflow:hidden;">
          <div style="padding:10px 12px;display:flex;align-items:center;gap:10px;">
            <input type="checkbox" class="row-check" data-id={inst.id} style="accent-color:#FF4F00;width:16px;height:16px;flex-shrink:0;" />
            <div style="flex:1;min-width:0;">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:6px;">
                <div style="min-width:0;">
                  <p style="font-size:13px;font-weight:600;color:#fff;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{inst.name}</p>
                  <p style="font-size:10px;color:#6e6e78;margin:2px 0 0;">{inst.city ? inst.city + ', ' : ''}{inst.country}{inst.entityTypeId ? ` · ${typeMap[inst.entityTypeId] || ''}` : ''}</p>
                </div>
                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:3px;flex-shrink:0;">
                  {inst.truthScore && <span style="font-size:11px;font-weight:700;color:#FF7040;">{parseFloat(inst.truthScore as any).toFixed(1)}{inst.truthRank ? ` #${inst.truthRank}` : ''}</span>}
                  <span style={`font-size:9px;font-weight:600;padding:1px 6px;border-radius:100px;${inst.isPublished ? 'background:rgba(16,185,129,0.15);color:#6ee7b7;' : 'background:#15151a;color:#6e6e78;'}`}>
                    {inst.isPublished ? 'Pub' : 'Draft'}
                  </span>
                </div>
              </div>
            </div>
          </div>
          <div style="border-top:1px solid #1a1a1f;padding:6px 12px;display:flex;gap:5px;">
            <a href={`/admin/hei/score/${inst.id}`} style="flex:1;text-align:center;background:#15151a;border:1px solid #1a1a1f;color:#FF7040;text-decoration:none;font-size:11px;font-weight:600;padding:5px;border-radius:5px;">Score</a>
            <a href={`?edit=${inst.id}`} style="flex:1;text-align:center;background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;text-decoration:none;font-size:11px;font-weight:500;padding:5px;border-radius:5px;">Edit</a>
            <form method="POST" style="flex:1;">
              <input type="hidden" name="_action" value="toggle_publish" />
              <input type="hidden" name="id" value={inst.id} />
              <button type="submit" style={`width:100%;font-size:11px;font-weight:500;padding:5px;border-radius:5px;border:none;cursor:pointer;${inst.isPublished ? 'background:rgba(251,191,36,0.1);color:#fbbf24;' : 'background:rgba(16,185,129,0.1);color:#6ee7b7;'}`}>
                {inst.isPublished ? 'Unpub' : 'Publish'}
              </button>
            </form>
            <form method="POST" style="flex:0;" onsubmit="return confirm('Delete this institution?')">
              <input type="hidden" name="_action" value="delete" />
              <input type="hidden" name="id" value={inst.id} />
              <button type="submit" style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);color:#fca5a5;font-size:11px;padding:5px 8px;border-radius:5px;cursor:pointer;">Del</button>
            </form>
          </div>
        </div>
      ))}
    </div>

    <!-- Bulk action bar - sticky bottom -->
    <div id="bulkBar" style="display:none;position:fixed;bottom:0;left:0;right:0;background:#0f0f14;border-top:1px solid #1a1a1f;padding:10px 16px;z-index:50;">
      <div style="display:flex;align-items:center;gap:6px;margin-bottom:6px;">
        <span id="selectedCount" style="font-size:12px;font-weight:600;color:#fff;">0 selected</span>
        <button type="button" onclick="document.querySelectorAll('.row-check').forEach(c=>c.checked=false);updateBulk()" style="background:none;border:none;color:#6e6e78;font-size:11px;cursor:pointer;">Clear</button>
      </div>
      <div style="display:flex;gap:6px;flex-wrap:wrap;">
        <button type="submit" name="_action" value="bulk_publish" style="background:rgba(16,185,129,0.15);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;font-size:11px;font-weight:600;padding:7px 12px;border-radius:7px;cursor:pointer;">Publish</button>
        <button type="submit" name="_action" value="bulk_unpublish" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;font-size:11px;font-weight:600;padding:7px 12px;border-radius:7px;cursor:pointer;">Unpublish</button>
        <button type="submit" name="_action" value="bulk_compute" onclick="return confirm('Compute Truth Score + publish for selected?')" style="background:rgba(255,79,0,0.15);border:1px solid rgba(255,79,0,0.3);color:#FF7040;font-size:11px;font-weight:600;padding:7px 12px;border-radius:7px;cursor:pointer;">Compute & Publish</button>
        <div style="display:flex;gap:4px;flex:1;">
          <select name="bulk_entity_type_id" style="flex:1;background:#15151a;border:1px solid #1a1a1f;border-radius:7px;padding:7px 8px;color:#fff;font-size:11px;outline:none;min-width:0;">
            <option value="">— Set type —</option>
            {Object.entries(typesByCategory).map(([cat, types]) => (
              <optgroup label={categoryLabel(cat)}>
                {(types as any[]).map(t => <option value={t.id}>{t.label}</option>)}
              </optgroup>
            ))}
          </select>
          <button type="submit" name="_action" value="bulk_set_type" style="background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;font-size:11px;font-weight:600;padding:7px 10px;border-radius:7px;cursor:pointer;">Set</button>
        </div>
        <button type="submit" name="_action" value="bulk_delete" onclick="return confirm('Delete selected institutions permanently?')" style="background:rgba(239,68,68,0.15);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;font-size:11px;font-weight:600;padding:7px 12px;border-radius:7px;cursor:pointer;">Delete</button>
      </div>
    </div>
  </form>

  <!-- Pagination -->
  {totalPages > 1 && (
    <div style="display:flex;align-items:center;justify-content:center;gap:10px;padding:16px;">
      {page > 1 && <a href={`?q=${search}&country=${filterCountry}&type=${filterType}&status=${filterStatus}&page=${page-1}`} style="background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;text-decoration:none;padding:8px 16px;border-radius:8px;font-size:12px;">← Prev</a>}
      <span style="font-size:12px;color:#6e6e78;">{page} / {totalPages}</span>
      {page < totalPages && <a href={`?q=${search}&country=${filterCountry}&type=${filterType}&status=${filterStatus}&page=${page+1}`} style="background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;text-decoration:none;padding:8px 16px;border-radius:8px;font-size:12px;">Next →</a>}
    </div>
  )}

  <!-- Edit/Create form (slides up as modal on mobile) -->
  {(editing || editId === 'new') && (
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:100;overflow-y:auto;padding:20px 0 0;">
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:16px 16px 0 0;min-height:100%;padding:20px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;position:sticky;top:0;background:#0f0f14;padding-bottom:12px;border-bottom:1px solid #1a1a1f;">
          <h2 style="font-size:15px;font-weight:700;color:#fff;margin:0;">{editing ? `Edit: ${editing.name}` : 'New Institution'}</h2>
          <a href="/admin/hei/institutions" style="background:#1a1a1f;border:none;color:#8a8a94;width:30px;height:30px;border-radius:6px;font-size:18px;display:flex;align-items:center;justify-content:center;text-decoration:none;">&times;</a>
        </div>
        <form method="POST" style="display:flex;flex-direction:column;gap:12px;">
          <input type="hidden" name="_action" value={editing ? 'update' : 'create'} />
          {editing && <input type="hidden" name="id" value={editing.id} />}

          <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Name *</label><input name="name" required value={editing ? editing.name : ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" /></div>
          <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Slug *</label><input name="slug" required pattern="[a-z0-9-]+" placeholder="iit-bombay" value={editing ? editing.slug : ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;font-family:'Geist Mono',monospace;" /></div>

          <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Entity Type</label>
            <select name="entityTypeId" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
              <option value="">— unset —</option>
              {Object.entries(typesByCategory).map(([cat, types]) => (
                <optgroup label={categoryLabel(cat)}>
                  {(types as any[]).map(t => <option value={t.id} selected={editing && editing.entityTypeId === t.id}>{t.label}</option>)}
                </optgroup>
              ))}
            </select>
          </div>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Country</label><input name="country" value={editing ? editing.country : 'India'} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" /></div>
            <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">State / Region</label><input name="stateRegion" value={editing && editing.stateRegion ? editing.stateRegion : ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" /></div>
            <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">City</label><input name="city" value={editing && editing.city ? editing.city : ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" /></div>
            <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Established</label><input type="number" name="establishedYear" value={editing && editing.establishedYear ? editing.establishedYear : ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" /></div>
            <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Students</label><input type="number" name="studentCount" value={editing && editing.studentCount ? editing.studentCount : ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" /></div>
            <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Tier</label>
              <select name="tier" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
                {['university','college','school','govt_programme'].map(t => <option value={t} selected={editing && editing.tier === t}>{t}</option>)}
              </select>
            </div>
          </div>

          <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Website</label><input name="websiteUrl" type="url" value={editing && editing.websiteUrl ? editing.websiteUrl : ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" /></div>

          <!-- Rankings -->
          <div style="background:#0a0a0c;border:1px solid rgba(255,79,0,0.2);border-radius:10px;padding:12px;">
            <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#FF7040;margin:0 0 10px;">Rankings</p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
              {[['nirfRank','NIRF Rank'],['qsRank','QS Rank'],['theRank','THE Rank'],['truthScore','Truth Score (0-100)'],['truthRank','Truth Rank']].map(([n,l]: any) => (
                <div>
                  <label style="display:block;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:4px;">{l}</label>
                  <input name={n} value={editing && (editing as any)[n] ? (editing as any)[n] : ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:7px;padding:8px 10px;color:#fff;font-size:12px;outline:none;" />
                </div>
              ))}
            </div>
          </div>

          <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Notes</label><textarea name="notes" rows="2" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;resize:vertical;">{editing && editing.notes ? editing.notes : ''}</textarea></div>

          <div style="display:flex;flex-direction:column;gap:8px;">
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
              <input type="checkbox" name="hasFullData" style="accent-color:#FF4F00;width:16px;height:16px;" checked={editing && editing.hasFullData} />
              <span style="font-size:13px;color:#d8d8de;">Has full data (eligible for ranking)</span>
            </label>
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
              <input type="checkbox" name="isPublished" style="accent-color:#FF4F00;width:16px;height:16px;" checked={editing && editing.isPublished} />
              <span style="font-size:13px;color:#d8d8de;">Publish on public /hei page</span>
            </label>
          </div>

          <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">
            {editing ? 'Save Changes' : 'Create Institution'}
          </button>
        </form>
      </div>
    </div>
  )}
</div>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  var checks = Array.from(document.querySelectorAll('.row-check'));
  var idsInput = document.getElementById('selected_ids');
  var countLabel = document.getElementById('selectedCount');
  var bulkBar = document.getElementById('bulkBar');

  window.updateBulk = function() {
    var sel = checks.filter(function(c) { return c.checked; }).map(function(c) { return c.getAttribute('data-id'); });
    idsInput.value = sel.join(',');
    countLabel.textContent = sel.length + ' selected';
    bulkBar.style.display = sel.length > 0 ? 'block' : 'none';
  };

  checks.forEach(function(c) { c.addEventListener('change', window.updateBulk); });
});
</script>
</AdminLayout>
