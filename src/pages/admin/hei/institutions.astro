---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { heiInstitutions } from '@/lib/db/schema';
import { asc, eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user || user.role === 'applicant') return Astro.redirect('/portal');

let errorMsg = '';
let okMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('_action') as string;

  try {
    if (action === 'create' || action === 'update') {
      const id = fd.get('id') as string;
      const candidate = {
        slug: (fd.get('slug') as string || '').trim().toLowerCase(),
        name: (fd.get('name') as string || '').trim(),
        tier: (fd.get('tier') as string || 'university').trim(),
        country: (fd.get('country') as string || 'India').trim(),
        stateRegion: (fd.get('stateRegion') as string || '').trim() || null,
        city: (fd.get('city') as string || '').trim() || null,
        type: (fd.get('type') as string || '').trim() || null,
        establishedYear: parseInt((fd.get('establishedYear') as string) || '0', 10) || null,
        studentCount: parseInt((fd.get('studentCount') as string) || '0', 10) || null,
        websiteUrl: (fd.get('websiteUrl') as string || '').trim() || null,
        nirfRank: parseInt((fd.get('nirfRank') as string) || '0', 10) || null,
        qsRank: parseInt((fd.get('qsRank') as string) || '0', 10) || null,
        theRank: parseInt((fd.get('theRank') as string) || '0', 10) || null,
        truthScore: (fd.get('truthScore') as string || '').trim() || null,
        truthRank: parseInt((fd.get('truthRank') as string) || '0', 10) || null,
        hasFullData: fd.get('hasFullData') === 'on',
        isPublished: fd.get('isPublished') === 'on',
        notes: (fd.get('notes') as string || '').trim() || null
      };

      if (!candidate.slug || !candidate.name) {
        errorMsg = 'Slug and name are required.';
      } else if (!candidate.slug.match(/^[a-z0-9-]+$/)) {
        errorMsg = 'Slug must be lowercase letters, digits, hyphens only.';
      } else {
        if (action === 'create') {
          const existing = await db.select({ id: heiInstitutions.id }).from(heiInstitutions).where(eq(heiInstitutions.slug, candidate.slug)).limit(1);
          if (existing.length > 0) {
            errorMsg = 'Slug already exists.';
          } else {
            await db.insert(heiInstitutions).values(candidate);
            okMsg = 'Created: ' + candidate.name;
          }
        } else {
          await db.update(heiInstitutions).set({ ...candidate, updatedAt: new Date() }).where(eq(heiInstitutions.id, id));
          okMsg = 'Updated: ' + candidate.name;
        }
      }
    } else if (action === 'delete') {
      const id = fd.get('id') as string;
      await db.delete(heiInstitutions).where(eq(heiInstitutions.id, id));
      okMsg = 'Deleted.';
    } else if (action === 'toggle_publish') {
      const id = fd.get('id') as string;
      const target = await db.select().from(heiInstitutions).where(eq(heiInstitutions.id, id)).limit(1);
      if (target.length > 0) {
        await db.update(heiInstitutions).set({ isPublished: !target[0].isPublished, updatedAt: new Date() }).where(eq(heiInstitutions.id, id));
        okMsg = target[0].isPublished ? 'Hidden from public' : 'Published';
      }
    }
  } catch (err: any) {
    errorMsg = 'Failed: ' + (err.message || 'Unknown error');
  }
}

const url = new URL(Astro.request.url);
const editId = url.searchParams.get('edit') || '';
const all = await db.select().from(heiInstitutions).orderBy(asc(heiInstitutions.truthRank), asc(heiInstitutions.name));
const editing = editId ? all.find(i => i.id === editId) : null;

const counts = {
  total: all.length,
  published: all.filter(i => i.isPublished).length,
  withData: all.filter(i => i.hasFullData).length
};
---
<AdminLayout title="HEI Institutions" activeNav="hei">
  <div class="admin-page" style="max-width:1400px;">

    <div class="admin-page-header" style="margin-bottom:24px;">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">HEI Data</div>
        <h1 class="admin-page-title">Institutions</h1>
        <p class="admin-page-sub">{counts.total} institutions / {counts.published} published / {counts.withData} with full data</p>
      </div>
    </div>

    {errorMsg && <div style="background:rgba(220,38,38,0.08);border:1px solid rgba(220,38,38,0.25);color:#fca5a5;font-size:12.5px;padding:11px 14px;border-radius:7px;margin-bottom:18px;">{errorMsg}</div>}
    {okMsg && <div style="background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.25);color:#6ee7b7;font-size:12.5px;padding:11px 14px;border-radius:7px;margin-bottom:18px;">{okMsg}</div>}

    <div style="display:grid;grid-template-columns:1.5fr 1fr;gap:18px;align-items:flex-start;">

      <div class="admin-card" style="padding:0;overflow:hidden;">
        <div style="padding:14px 16px;border-bottom:1px solid #1f1f26;display:flex;justify-content:space-between;align-items:center;">
          <span style="font-size:11px;color:#6e6e78;text-transform:uppercase;letter-spacing:0.1em;font-weight:700;">All institutions</span>
          {!editing && <a href="?edit=new" class="admin-btn admin-btn-primary" style="padding:5px 11px;font-size:11px;text-decoration:none;">+ New institution</a>}
        </div>
        <table class="admin-table">
          <thead>
            <tr>
              <th>Institution</th>
              <th>Truth</th>
              <th>NIRF/QS/THE</th>
              <th>Status</th>
              <th style="text-align:right;">Actions</th>
            </tr>
          </thead>
          <tbody>
            {all.map((i) => (
              <tr style={editing && editing.id === i.id ? 'background:rgba(255,79,0,0.06);' : ''}>
                <td>
                  <div style="font-weight:500;color:#fff;">{i.name}</div>
                  <div style="font-size:10.5px;color:#6e6e78;margin-top:2px;">{i.city ? i.city + ', ' : ''}{i.country} {i.tier !== 'university' ? '/ ' + i.tier : ''}</div>
                </td>
                <td>
                  {i.truthScore ? (
                    <div>
                      <div style="font-weight:600;color:#fff;font-size:13px;">{i.truthScore}</div>
                      {i.truthRank && <div style="font-size:10px;color:#6e6e78;">rank #{i.truthRank}</div>}
                    </div>
                  ) : <span style="color:#6e6e78;font-size:11px;">-</span>}
                </td>
                <td style="font-size:10.5px;color:#a0a0ab;">
                  <div>NIRF: {i.nirfRank || '-'}</div>
                  <div>QS: {i.qsRank || '-'}</div>
                  <div>THE: {i.theRank || '-'}</div>
                </td>
                <td>
                  <div style="display:flex;flex-direction:column;gap:3px;">
                    <span style={'font-size:10.5px;color:' + (i.isPublished ? '#10b981' : '#fbbf24') + ';'}>
                      {i.isPublished ? '● Published' : '○ Draft'}
                    </span>
                    {i.hasFullData && <span style="font-size:10.5px;color:#60a5fa;">● Full data</span>}
                  </div>
                </td>
                <td style="text-align:right;">
                  <div style="display:flex;gap:5px;justify-content:flex-end;flex-wrap:wrap;">
                    <a href={'?edit=' + i.id} class="admin-btn" style="padding:4px 9px;font-size:10.5px;">Edit</a>
                    <form method="POST" style="margin:0;display:inline;">
                      <input type="hidden" name="_action" value="toggle_publish" />
                      <input type="hidden" name="id" value={i.id} />
                      <button type="submit" class="admin-btn" style="padding:4px 9px;font-size:10.5px;">{i.isPublished ? 'Unpub' : 'Pub'}</button>
                    </form>
                    <form method="POST" style="margin:0;display:inline;" onsubmit="return confirm('Delete this institution permanently?');">
                      <input type="hidden" name="_action" value="delete" />
                      <input type="hidden" name="id" value={i.id} />
                      <button type="submit" class="admin-btn" style="padding:4px 9px;font-size:10.5px;color:#fca5a5;">Del</button>
                    </form>
                  </div>
                </td>
              </tr>
            ))}
            {all.length === 0 && <tr><td colspan="5" style="text-align:center;padding:30px;color:#6e6e78;font-size:13px;">No institutions yet. Add one on the right.</td></tr>}
          </tbody>
        </table>
      </div>

      {(editing || editId === 'new') && (
        <form method="POST" class="admin-card" style="display:flex;flex-direction:column;gap:11px;">
          <input type="hidden" name="_action" value={editing ? 'update' : 'create'} />
          {editing && <input type="hidden" name="id" value={editing.id} />}

          <div>
            <div class="admin-card-title" style="margin:0 0 4px;font-size:13px;">{editing ? 'Edit: ' + editing.name : '+ New institution'}</div>
          </div>

          <div>
            <label class="rfl">Name *</label>
            <input name="name" required class="rfi" value={editing ? editing.name : ''} />
          </div>
          <div>
            <label class="rfl">Slug *</label>
            <input name="slug" required pattern="[a-z0-9-]+" class="rfi" placeholder="iit-bombay" value={editing ? editing.slug : ''} />
          </div>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <div>
              <label class="rfl">Tier</label>
              <select name="tier" class="rfi">
                <option value="university" selected={!editing || editing.tier === 'university'}>University</option>
                <option value="college" selected={editing && editing.tier === 'college'}>College</option>
                <option value="school" selected={editing && editing.tier === 'school'}>School</option>
                <option value="govt_programme" selected={editing && editing.tier === 'govt_programme'}>Govt Programme</option>
              </select>
            </div>
            <div>
              <label class="rfl">Type</label>
              <input name="type" class="rfi" placeholder="Public / Private" value={editing && editing.type ? editing.type : ''} />
            </div>
            <div>
              <label class="rfl">Country</label>
              <input name="country" class="rfi" value={editing ? editing.country : 'India'} />
            </div>
            <div>
              <label class="rfl">State / region</label>
              <input name="stateRegion" class="rfi" value={editing && editing.stateRegion ? editing.stateRegion : ''} />
            </div>
            <div>
              <label class="rfl">City</label>
              <input name="city" class="rfi" value={editing && editing.city ? editing.city : ''} />
            </div>
            <div>
              <label class="rfl">Established</label>
              <input type="number" name="establishedYear" class="rfi" value={editing && editing.establishedYear ? editing.establishedYear : ''} />
            </div>
          </div>

          <div>
            <label class="rfl">Website</label>
            <input name="websiteUrl" type="url" class="rfi" value={editing && editing.websiteUrl ? editing.websiteUrl : ''} />
          </div>

          <div>
            <label class="rfl">Students enrolled</label>
            <input type="number" name="studentCount" class="rfi" value={editing && editing.studentCount ? editing.studentCount : ''} />
          </div>

          <div style="padding:10px;background:rgba(255,79,0,0.05);border:1px solid rgba(255,79,0,0.2);border-radius:6px;">
            <p style="font-size:10px;color:#FF7040;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:8px;">Rankings</p>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;">
              <div>
                <label class="rfl">NIRF rank</label>
                <input type="number" name="nirfRank" class="rfi" value={editing && editing.nirfRank ? editing.nirfRank : ''} />
              </div>
              <div>
                <label class="rfl">QS rank</label>
                <input type="number" name="qsRank" class="rfi" value={editing && editing.qsRank ? editing.qsRank : ''} />
              </div>
              <div>
                <label class="rfl">THE rank</label>
                <input type="number" name="theRank" class="rfi" value={editing && editing.theRank ? editing.theRank : ''} />
              </div>
              <div>
                <label class="rfl">Truth score</label>
                <input name="truthScore" class="rfi" placeholder="0.00 - 100.00" value={editing && editing.truthScore ? editing.truthScore : ''} />
              </div>
              <div>
                <label class="rfl">Truth rank</label>
                <input type="number" name="truthRank" class="rfi" value={editing && editing.truthRank ? editing.truthRank : ''} />
              </div>
            </div>
          </div>

          <div>
            <label class="rfl">Notes (internal)</label>
            <textarea name="notes" rows="2" class="rfi">{editing && editing.notes ? editing.notes : ''}</textarea>
          </div>

          <label style="display:flex;align-items:center;gap:8px;color:#d8d8de;font-size:12px;">
            <input type="checkbox" name="hasFullData" style="accent-color:#FF4F00;" checked={editing && editing.hasFullData} />
            <span>Has full data (eligible for ranking)</span>
          </label>

          <label style="display:flex;align-items:center;gap:8px;color:#d8d8de;font-size:12px;">
            <input type="checkbox" name="isPublished" style="accent-color:#FF4F00;" checked={editing && editing.isPublished} />
            <span>Publish on public /hei page</span>
          </label>

          <div style="display:flex;gap:8px;margin-top:6px;">
            <button type="submit" class="admin-btn admin-btn-primary" style="flex:1;justify-content:center;">{editing ? 'Save changes' : 'Create'}</button>
            <a href="/admin/hei/institutions" class="admin-btn" style="padding:8px 14px;display:flex;align-items:center;text-decoration:none;">Cancel</a>
          </div>
        </form>
      )}

      {!editing && editId !== 'new' && (
        <div class="admin-card" style="text-align:center;padding:40px 20px;">
          <p style="font-size:13px;color:#6e6e78;line-height:1.7;">Click <strong>+ New institution</strong> to add. Click <strong>Edit</strong> on a row to update.</p>
        </div>
      )}

    </div>
  </div>

  <style>
    .rfl { display:block;font-size:10px;font-weight:600;color:#8a8a94;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:4px; }
    .rfi { width:100%;padding:7px 10px;background:#08080a;border:1px solid #1f1f26;border-radius:5px;color:#fff;font-size:12px;font-family:inherit;outline:none; }
    .rfi:focus { border-color:#FF4F00; }
    textarea.rfi { resize:vertical;line-height:1.55; }
  </style>
</AdminLayout>