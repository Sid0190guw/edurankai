---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { heiMetrics, heiAspects, heiPipelines, heiSdgIndicMap, heiPurusharthas } from '@/lib/db/schema';
import { asc, eq } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user || user.role === 'applicant') return Astro.redirect('/portal');

const metrics = await db.select().from(heiMetrics).where(eq(heiMetrics.methodologyVersion, 'v1.0')).orderBy(asc(heiMetrics.sortOrder));
const aspects = await db.select().from(heiAspects).where(eq(heiAspects.methodologyVersion, 'v1.0')).orderBy(asc(heiAspects.sortOrder));
const pipelines = await db.select().from(heiPipelines).orderBy(asc(heiPipelines.sortOrder));
const sdgMap = await db.select().from(heiSdgIndicMap).orderBy(asc(heiSdgIndicMap.sdgNumber));
const purusharthas = await db.select().from(heiPurusharthas).orderBy(asc(heiPurusharthas.sortOrder));

const aspectsByMetric: Record<string, any[]> = {};
for (const a of aspects) {
  if (!aspectsByMetric[a.metricId]) aspectsByMetric[a.metricId] = [];
  aspectsByMetric[a.metricId].push(a);
}

const totalWeight = metrics.reduce((s, m) => s + parseFloat(m.weightPercent || '0'), 0);

const PIPELINE_USE_LABEL: Record<string, string> = {
  direct_citation: 'Direct citation',
  aggregate_only: 'Aggregate only',
  outcome_metrics: 'Outcome metrics',
  investigation_lead: 'Investigation leads only'
};
---
<AdminLayout title="HEI v1.0 Methodology" activeNav="hei">
  <div class="admin-page" style="max-width:1280px;">

    <div class="admin-page-header" style="margin-bottom:24px;">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">HEI Canonical Framework</div>
        <h1 class="admin-page-title">v1.0 Methodology</h1>
        <p class="admin-page-sub">
          {metrics.length} metrics / {aspects.length} aspects / {pipelines.length} pipelines / {sdgMap.length} SDG-Indic mappings / {purusharthas.length} puruṣārthas
          <br/>
          <span style="font-size:11px;color:#fbbf24;">Read-only inspector. Edit screens for each table can be added incrementally.</span>
        </p>
      </div>
    </div>

    <!-- METRICS + ASPECTS -->
    <div class="admin-card" style="padding:20px;margin-bottom:18px;">
      <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:14px;">
        <div>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:22px;color:#fff;font-weight:600;letter-spacing:-0.01em;">Four metrics, twenty-three aspects</h2>
          <p style="font-size:11.5px;color:#a0a0ab;line-height:1.6;margin-top:4px;">HEI Score = 0.30·HDI + 0.20·R&amp;I + 0.30·Excellence + 0.20·Wellbeing</p>
        </div>
        <span style="font-family:'Geist Mono',monospace;font-size:11px;color:#FF7040;font-weight:600;">Σ {totalWeight.toFixed(0)}%</span>
      </div>

      {metrics.map((m) => {
        const myAspects = aspectsByMetric[m.id] || [];
        return (
          <div style="margin-bottom:16px;padding:14px;background:#08080a;border:1px solid #1f1f26;border-radius:7px;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:8px;">
              <div style="flex:1;">
                <h3 style="font-family:'Cormorant Garamond',serif;font-size:18px;color:#fff;font-weight:600;">{m.title}</h3>
                {m.subtitle && <p style="font-style:italic;color:#a0a0ab;font-size:12px;margin-top:2px;">{m.subtitle}</p>}
              </div>
              <span style="font-family:'Geist Mono',monospace;font-size:14px;background:rgba(255,79,0,0.15);color:#FF7040;padding:4px 12px;border-radius:100px;font-weight:700;flex-shrink:0;">{m.weightPercent}%</span>
            </div>
            <p style="font-size:12.5px;color:#d8d8de;line-height:1.65;margin-bottom:10px;">{m.description}</p>
            {m.blurb && <p style="font-size:11.5px;color:#6e6e78;font-style:italic;line-height:1.6;margin-bottom:12px;border-left:2px solid #1f1f26;padding-left:10px;">{m.blurb}</p>}

            {myAspects.length > 0 && (
              <div style="margin-top:12px;border-top:1px solid #15151a;padding-top:12px;">
                <p style="font-family:'Geist Mono',monospace;font-size:10px;color:#FF7040;letter-spacing:0.12em;font-weight:700;margin-bottom:8px;">{myAspects.length} aspects</p>
                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(310px,1fr));gap:10px;">
                  {myAspects.map((a) => (
                    <div style="padding:11px 13px;background:#0e0e12;border:1px solid #1a1a20;border-radius:5px;">
                      <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:4px;">
                        <span style="font-weight:600;color:#fff;font-size:13px;">{a.title}</span>
                        {a.sdgLinks && <span style="font-family:'Geist Mono',monospace;font-size:9.5px;color:#FF7040;flex-shrink:0;">{a.sdgLinks}</span>}
                      </div>
                      {a.sanskritRoot && <p style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:12px;color:#a0a0ab;margin-bottom:5px;">{a.sanskritRoot}</p>}
                      <p style="font-size:11px;color:#a0a0ab;line-height:1.55;">{a.description}</p>
                      {a.measurementNotes && <p style="font-size:10px;color:#6e6e78;line-height:1.5;margin-top:5px;font-style:italic;">{a.measurementNotes}</p>}
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        );
      })}
    </div>

    <!-- PIPELINES -->
    <div class="admin-card" style="padding:20px;margin-bottom:18px;">
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:20px;color:#fff;font-weight:600;margin-bottom:6px;">Seven evidence pipelines</h2>
      <p style="font-size:11.5px;color:#a0a0ab;margin-bottom:14px;">Triangulation required: at least two of P1, P2, P4, P5 for any published claim about a named institution.</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(310px,1fr));gap:11px;">
        {pipelines.map((p) => (
          <div style="padding:13px 15px;background:#08080a;border:1px solid #1f1f26;border-radius:7px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
              <span style="font-family:'Geist Mono',monospace;font-weight:700;color:#FF7040;font-size:13px;">{p.id}</span>
              <span style={'font-size:9.5px;font-family:Geist Mono,monospace;padding:2px 8px;border-radius:100px;' + (p.useClass === 'investigation_lead' ? 'background:rgba(251,191,36,0.15);color:#fbbf24;' : p.useClass === 'aggregate_only' ? 'background:rgba(96,165,250,0.15);color:#60a5fa;' : 'background:rgba(16,185,129,0.15);color:#6ee7b7;')}>{PIPELINE_USE_LABEL[p.useClass] || p.useClass}</span>
            </div>
            <h3 style="font-weight:600;color:#fff;font-size:13.5px;margin-bottom:5px;">{p.title}</h3>
            <p style="font-size:11px;color:#a0a0ab;line-height:1.55;margin-bottom:6px;">{p.sources}</p>
            <p style="font-size:10.5px;color:#6e6e78;font-style:italic;line-height:1.5;">{p.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- PURUSHARTHAS -->
    <div class="admin-card" style="padding:20px;margin-bottom:18px;">
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:20px;color:#fff;font-weight:600;margin-bottom:14px;">The four puruṣārthas</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:11px;">
        {purusharthas.map((p) => (
          <div style="padding:13px 15px;background:#08080a;border:1px solid #1f1f26;border-radius:7px;">
            <h3 style="font-family:'Cormorant Garamond',serif;font-size:17px;color:#fff;font-weight:600;">{p.title}</h3>
            {p.transliteration && <p style="font-style:italic;color:#a0a0ab;font-size:11.5px;margin-bottom:6px;">{p.transliteration}</p>}
            <p style="font-size:11px;color:#a0a0ab;line-height:1.55;">{p.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- SDG-INDIC MAPPING -->
    <div class="admin-card" style="padding:20px;">
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:20px;color:#fff;font-weight:600;margin-bottom:6px;">17 UN SDGs ↔ Indic principles</h2>
      <p style="font-size:11.5px;color:#a0a0ab;margin-bottom:14px;">Two vocabularies, one standard. HEI reports in both.</p>
      <table class="admin-table" style="font-size:11.5px;">
        <thead>
          <tr>
            <th style="width:38px;">#</th>
            <th>UN SDG</th>
            <th>Indic principle</th>
            <th>Sanskrit phrase</th>
            <th>Explanation</th>
          </tr>
        </thead>
        <tbody>
          {sdgMap.map((m) => (
            <tr>
              <td style="font-family:'Geist Mono',monospace;color:#FF7040;font-weight:600;">{m.sdgNumber}</td>
              <td style="color:#fff;font-weight:500;">{m.sdgName}</td>
              <td style="color:#d8d8de;">{m.indicPrinciple}</td>
              <td style="font-family:'Cormorant Garamond',serif;font-style:italic;color:#a0a0ab;font-size:12px;">{m.sanskritPhrase || ''}</td>
              <td style="color:#a0a0ab;font-size:11px;line-height:1.55;">{m.explanation}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

  </div>
</AdminLayout>