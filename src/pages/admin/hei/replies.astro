---
import HeiAdminLayout from '@/layouts/HeiAdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');

let okMsg = '', errorMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  try {
    if (action === 'add_reply') {
      const findingId = fd.get('finding_id') as string;
      const instName = (fd.get('institution_name') as string || '').trim();
      const sentAt = fd.get('sent_at') as string;
      const deadline = fd.get('deadline_at') as string;
      await db.execute(sql`INSERT INTO hei_right_of_reply (finding_id, institution_name, sent_at, deadline_at, status) VALUES (${findingId||null}, ${instName||null}, ${sentAt||null}, ${deadline||null}, 'sent')`);
      okMsg = 'Right-of-reply sent.';
    } else if (action === 'record_response') {
      const id = fd.get('id') as string;
      const response = (fd.get('response_text') as string || '').trim();
      const modifier = parseFloat(fd.get('modifier_score') as string || '0') || 0;
      await db.execute(sql`UPDATE hei_right_of_reply SET status = 'responded', response_text = ${response}, response_received_at = NOW(), modifier_score = ${modifier} WHERE id = ${id}`);
      okMsg = 'Response recorded.';
    }
  } catch(e: any) { errorMsg = e.message; }
}

const url = new URL(Astro.request.url);
const filter = url.searchParams.get('filter') || 'active';

let replies: any[] = [];
try {
  const sf = filter === 'active' ? sql`AND r.status IN ('sent','pending')` : filter === 'responded' ? sql`AND r.status = 'responded'` : sql``;
  const r = await db.execute(sql`SELECT r.*, f.title as finding_title FROM hei_right_of_reply r LEFT JOIN hei_findings f ON r.finding_id = f.id WHERE 1=1 ${sf} ORDER BY r.sent_at DESC LIMIT 100`);
  replies = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

let findings: any[] = [];
try {
  const r = await db.execute(sql`SELECT id, title FROM hei_findings WHERE status IN ('draft','review') ORDER BY title LIMIT 50`);
  findings = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

function fmtDate(d: any) { if (!d) return '-'; return new Date(d).toLocaleDateString('en-IN',{ timeZone: 'Asia/Kolkata',day:'numeric',month:'short',year:'numeric'}); }
const STATUS_COLOR: Record<string,string> = { pending:'#6b7280', sent:'#60a5fa', responded:'#10b981', no_response:'#ef4444', waived:'#a78bfa' };
---
<HeiAdminLayout title="Right of Reply" activeNav="hei">
<div style="padding-bottom:80px;">
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
      <div>
        <p style="font-size:10px;font-family:monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">HEI Editorial</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Right of Reply</h1>
      </div>
      <div style="display:flex;gap:6px;">
        <a href="/admin/hei" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;text-decoration:none;font-size:11px;padding:6px 10px;border-radius:6px;">Dashboard</a>
        <button onclick="document.getElementById('addReplyModal').style.display='flex'" style="background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:600;padding:6px 12px;border-radius:6px;cursor:pointer;">+ Send Notice</button>
      </div>
    </div>
    <div style="display:flex;gap:5px;overflow-x:auto;">
      {(['active','responded','all'] as const).map(f => (
        <a href={`?filter=${f}`} style={`text-decoration:none;font-size:11px;font-weight:600;padding:5px 10px;border-radius:100px;white-space:nowrap;${filter===f?'background:#FF4F00;color:#fff;':'background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;'}`}>{f.charAt(0).toUpperCase()+f.slice(1)}</a>
      ))}
    </div>
  </div>

  {errorMsg && <div style="margin:10px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  <div style="padding:12px 16px;display:flex;flex-direction:column;gap:8px;">
    {replies.length === 0 && <div style="text-align:center;padding:40px;color:#6e6e78;background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;"><p style="font-size:13px;">No right-of-reply notices yet.</p></div>}
    {replies.map((r: any) => {
      const sc = STATUS_COLOR[r.status] || '#6b7280';
      const isOverdue = r.deadline_at && new Date(r.deadline_at) < new Date() && r.status !== 'responded';
      return (
        <div style={`background:#0f0f14;border:1px solid ${isOverdue?'rgba(239,68,68,0.3)':'#1a1a1f'};border-radius:12px;overflow:hidden;`}>
          <div style="padding:12px 14px;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:6px;">
              <div style="flex:1;min-width:0;">
                <p style="font-size:13px;font-weight:600;color:#fff;margin:0 0 2px;">{r.institution_name || 'Unknown institution'}</p>
                {r.finding_title && <p style="font-size:11px;color:#8a8a94;margin:0 0 4px;">Re: {r.finding_title}</p>}
                <p style="font-size:10px;color:#6e6e78;margin:0;font-family:monospace;">Sent: {fmtDate(r.sent_at)} - Deadline: {fmtDate(r.deadline_at)}{isOverdue?' (OVERDUE)':''}</p>
              </div>
              <span style={`font-size:9px;font-weight:700;padding:2px 8px;border-radius:100px;background:${sc}22;color:${sc};flex-shrink:0;`}>{r.status?.toUpperCase()}</span>
            </div>
            {r.response_text && <div style="background:#15151a;border-radius:6px;padding:8px 10px;margin-top:6px;"><p style="font-size:11px;color:#8a8a94;margin:0 0 2px;font-weight:600;">Institution response:</p><p style="font-size:11px;color:#8a8a94;margin:0;line-height:1.4;">{r.response_text.substring(0,300)}{r.response_text.length>300?'...':''}</p></div>}
            {r.modifier_score !== 0 && <p style="font-size:11px;color:#6e6e78;margin:6px 0 0;">Score modifier: {r.modifier_score > 0 ? '+':''}{r.modifier_score}</p>}
          </div>
          {r.status !== 'responded' && (
            <div style="border-top:1px solid #1a1a1f;padding:8px 14px;">
              <form method="POST" style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
                <input type="hidden" name="action" value="record_response" /><input type="hidden" name="id" value={r.id} />
                <input name="response_text" placeholder="Paste institution response..." style="flex:1;min-width:150px;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:6px 10px;color:#fff;font-size:11px;outline:none;" />
                <input name="modifier_score" type="number" step="0.1" placeholder="+/-score" style="width:70px;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:6px 8px;color:#fff;font-size:11px;outline:none;" />
                <button type="submit" style="background:rgba(16,185,129,0.15);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;font-size:11px;font-weight:600;padding:6px 10px;border-radius:6px;cursor:pointer;">Record Response</button>
              </form>
            </div>
          )}
        </div>
      );
    })}
  </div>
</div>

<div id="addReplyModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:100;align-items:flex-end;justify-content:center;">
  <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:16px 16px 0 0;width:100%;max-width:600px;padding:20px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <h2 style="font-size:15px;font-weight:700;color:#fff;margin:0;">Send Right-of-Reply Notice</h2>
      <button onclick="document.getElementById('addReplyModal').style.display='none'" style="background:#1a1a1f;border:none;color:#8a8a94;width:30px;height:30px;border-radius:6px;font-size:18px;cursor:pointer;">&times;</button>
    </div>
    <form method="POST" style="display:flex;flex-direction:column;gap:12px;">
      <input type="hidden" name="action" value="add_reply" />
      <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Finding</label>
        <select name="finding_id" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
          <option value="">No specific finding</option>
          {findings.map((f:any) => <option value={f.id}>{f.title}</option>)}
        </select>
      </div>
      <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Institution *</label><input name="institution_name" required placeholder="a national engineering institute..." style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" /></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Sent On</label><input name="sent_at" type="date" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" /></div>
        <div><label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Response Deadline</label><input name="deadline_at" type="date" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" /></div>
      </div>
      <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">Send Notice</button>
    </form>
  </div>
</div>
</HeiAdminLayout>
