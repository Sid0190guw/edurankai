---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { heiStories, heiInstitutions } from '@/lib/db/schema';
import { asc, eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user || user.role === 'applicant') return Astro.redirect('/portal');

let errorMsg = '';
let okMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('_action') as string;
  try {
    if (action === 'create' || action === 'update') {
      const id = fd.get('id') as string;
      const candidate: any = {
        slug: (fd.get('slug') as string || '').trim().toLowerCase(),
        headline: (fd.get('headline') as string || '').trim(),
        deck: (fd.get('deck') as string || '').trim() || null,
        body: (fd.get('body') as string || '').trim(),
        category: (fd.get('category') as string || 'investigation').trim(),
        institutionId: (fd.get('institutionId') as string || '').trim() || null,
        isPublished: fd.get('isPublished') === 'on',
        coverImageUrl: (fd.get('coverImageUrl') as string || '').trim() || null
      };
      if (!candidate.slug || !candidate.headline || !candidate.body) {
        errorMsg = 'Slug, headline, and body are required.';
      } else if (!candidate.slug.match(/^[a-z0-9-]+$/)) {
        errorMsg = 'Slug must be lowercase letters, digits, hyphens only.';
      } else {
        if (candidate.isPublished) {
          candidate.publishedAt = new Date();
        }
        candidate.authorUserId = user.id;

        if (action === 'create') {
          const exists = await db.select({ id: heiStories.id }).from(heiStories).where(eq(heiStories.slug, candidate.slug)).limit(1);
          if (exists.length > 0) {
            errorMsg = 'Slug already exists.';
          } else {
            await db.insert(heiStories).values(candidate);
            okMsg = 'Created: ' + candidate.headline;
          }
        } else {
          await db.update(heiStories).set({ ...candidate, updatedAt: new Date() }).where(eq(heiStories.id, id));
          okMsg = 'Updated: ' + candidate.headline;
        }
      }
    } else if (action === 'delete') {
      const id = fd.get('id') as string;
      await db.delete(heiStories).where(eq(heiStories.id, id));
      okMsg = 'Deleted.';
    } else if (action === 'toggle_publish') {
      const id = fd.get('id') as string;
      const target = await db.select().from(heiStories).where(eq(heiStories.id, id)).limit(1);
      if (target.length > 0) {
        await db.update(heiStories).set({
          isPublished: !target[0].isPublished,
          publishedAt: !target[0].isPublished ? new Date() : target[0].publishedAt,
          updatedAt: new Date()
        }).where(eq(heiStories.id, id));
        okMsg = target[0].isPublished ? 'Unpublished' : 'Published';
      }
    }
  } catch (err: any) {
    errorMsg = 'Failed: ' + (err.message || 'Unknown error');
  }
}

const url = new URL(Astro.request.url);
const editId = url.searchParams.get('edit') || '';
const all = await db.select().from(heiStories).orderBy(desc(heiStories.publishedAt), desc(heiStories.createdAt));
const editing = editId ? all.find(s => s.id === editId) : null;

const allInst = await db.select({ id: heiInstitutions.id, name: heiInstitutions.name }).from(heiInstitutions).orderBy(asc(heiInstitutions.name));
const instMap = Object.fromEntries(allInst.map(i => [i.id, i.name]));

const counts = {
  total: all.length,
  published: all.filter(s => s.isPublished).length,
  draft: all.filter(s => !s.isPublished).length
};

const CATEGORIES = [
  { value: 'investigation', label: 'Investigation' },
  { value: 'analysis', label: 'Analysis' },
  { value: 'methodology', label: 'Methodology update' },
  { value: 'institution_profile', label: 'Institution profile' },
  { value: 'editorial', label: 'Editorial' },
  { value: 'data_release', label: 'Data release' }
];

function fmt(d: any) {
  if (!d) return '-';
  return new Date(d).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
}
---
<AdminLayout title="HEI Stories" activeNav="hei-stories">
  <div class="admin-page" style="max-width:1400px;">

    <div class="admin-page-header" style="margin-bottom:24px;">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">HEI Editorial</div>
        <h1 class="admin-page-title">Stories &amp; investigations</h1>
        <p class="admin-page-sub">{counts.total} stories / {counts.published} published / {counts.draft} draft. These appear in the Truth Report on /hei.</p>
      </div>
    </div>

    {errorMsg && <div style="background:rgba(220,38,38,0.08);border:1px solid rgba(220,38,38,0.25);color:#fca5a5;font-size:12.5px;padding:11px 14px;border-radius:7px;margin-bottom:18px;">{errorMsg}</div>}
    {okMsg && <div style="background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.25);color:#6ee7b7;font-size:12.5px;padding:11px 14px;border-radius:7px;margin-bottom:18px;">{okMsg}</div>}

    <div style="display:grid;grid-template-columns:1fr 1.3fr;gap:18px;align-items:flex-start;">

      <div class="admin-card" style="padding:0;overflow:hidden;">
        <div style="padding:14px 16px;border-bottom:1px solid #1f1f26;display:flex;justify-content:space-between;align-items:center;">
          <span style="font-size:11px;color:#6e6e78;text-transform:uppercase;letter-spacing:0.1em;font-weight:700;">All stories</span>
          {!editing && <a href="?edit=new" class="admin-btn admin-btn-primary" style="padding:5px 11px;font-size:11px;text-decoration:none;">+ New story</a>}
        </div>
        <table class="admin-table">
          <thead>
            <tr>
              <th>Story</th>
              <th>Status</th>
              <th style="text-align:right;">Actions</th>
            </tr>
          </thead>
          <tbody>
            {all.map((s) => (
              <tr style={editing && editing.id === s.id ? 'background:rgba(255,79,0,0.06);' : ''}>
                <td>
                  <div style="font-weight:500;color:#fff;font-size:12.5px;line-height:1.4;">{s.headline}</div>
                  <div style="font-size:10px;color:#6e6e78;margin-top:3px;font-family:'Geist Mono',monospace;">/hei/story/{s.slug}</div>
                  <div style="font-size:10.5px;color:#a0a0ab;margin-top:3px;">{s.category}{s.institutionId && instMap[s.institutionId] ? ' / ' + instMap[s.institutionId] : ''}</div>
                </td>
                <td>
                  <span style={'font-size:10.5px;color:' + (s.isPublished ? '#10b981' : '#fbbf24') + ';'}>
                    {s.isPublished ? '● Published' : '○ Draft'}
                  </span>
                  {s.publishedAt && s.isPublished && <div style="font-size:9.5px;color:#6e6e78;margin-top:2px;">{fmt(s.publishedAt)}</div>}
                </td>
                <td style="text-align:right;">
                  <div style="display:flex;gap:5px;justify-content:flex-end;flex-wrap:wrap;">
                    <a href={'?edit=' + s.id} class="admin-btn" style="padding:4px 9px;font-size:10.5px;">Edit</a>
                    <form method="POST" style="margin:0;display:inline;">
                      <input type="hidden" name="_action" value="toggle_publish" />
                      <input type="hidden" name="id" value={s.id} />
                      <button type="submit" class="admin-btn" style="padding:4px 9px;font-size:10.5px;">{s.isPublished ? 'Unpub' : 'Pub'}</button>
                    </form>
                    <form method="POST" style="margin:0;display:inline;" onsubmit="return confirm('Delete this story permanently?');">
                      <input type="hidden" name="_action" value="delete" />
                      <input type="hidden" name="id" value={s.id} />
                      <button type="submit" class="admin-btn" style="padding:4px 9px;font-size:10.5px;color:#fca5a5;">Del</button>
                    </form>
                  </div>
                </td>
              </tr>
            ))}
            {all.length === 0 && <tr><td colspan="3" style="text-align:center;padding:30px;color:#6e6e78;font-size:13px;">No stories yet.</td></tr>}
          </tbody>
        </table>
      </div>

      {(editing || editId === 'new') && (
        <form method="POST" class="admin-card" style="display:flex;flex-direction:column;gap:12px;">
          <input type="hidden" name="_action" value={editing ? 'update' : 'create'} />
          {editing && <input type="hidden" name="id" value={editing.id} />}

          <div class="admin-card-title" style="margin:0 0 4px;font-size:13px;">{editing ? 'Edit story' : '+ New story'}</div>

          <div>
            <label class="rfl">Headline *</label>
            <input name="headline" required class="rfi" placeholder="e.g. The university that hides its dropout rate" value={editing ? editing.headline : ''} />
          </div>

          <div>
            <label class="rfl">Slug *</label>
            <input name="slug" required pattern="[a-z0-9-]+" class="rfi" placeholder="university-hides-dropout-rate" value={editing ? editing.slug : ''} />
          </div>

          <div>
            <label class="rfl">Deck (sub-headline)</label>
            <textarea name="deck" rows="2" class="rfi">{editing && editing.deck ? editing.deck : ''}</textarea>
          </div>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <div>
              <label class="rfl">Category</label>
              <select name="category" class="rfi">
                {CATEGORIES.map((c) => <option value={c.value} selected={(editing && editing.category === c.value) || (!editing && c.value === 'investigation')}>{c.label}</option>)}
              </select>
            </div>
            <div>
              <label class="rfl">Linked institution</label>
              <select name="institutionId" class="rfi">
                <option value="">None</option>
                {allInst.map((i) => <option value={i.id} selected={editing && editing.institutionId === i.id}>{i.name}</option>)}
              </select>
            </div>
          </div>

          <div>
            <label class="rfl">Cover image URL (optional)</label>
            <input name="coverImageUrl" type="url" class="rfi" value={editing && editing.coverImageUrl ? editing.coverImageUrl : ''} />
          </div>

          <div>
            <label class="rfl">Body (Markdown) *</label>
            <textarea name="body" required rows="14" class="rfi" style="font-family:'Geist Mono',monospace;font-size:11.5px;line-height:1.55;" placeholder="# Sub-heading&#10;&#10;The story body. Use **bold**, _italic_, [links](url), and standard markdown.">{editing ? editing.body : ''}</textarea>
          </div>

          <label style="display:flex;align-items:center;gap:8px;color:#d8d8de;font-size:12px;">
            <input type="checkbox" name="isPublished" style="accent-color:#FF4F00;" checked={editing && editing.isPublished} />
            <span>Publish to /hei</span>
          </label>

          <div style="display:flex;gap:8px;margin-top:6px;">
            <button type="submit" class="admin-btn admin-btn-primary" style="flex:1;justify-content:center;">{editing ? 'Save' : 'Create'}</button>
            <a href="/admin/hei/stories" class="admin-btn" style="padding:8px 14px;display:flex;align-items:center;text-decoration:none;">Cancel</a>
          </div>
        </form>
      )}

      {!editing && editId !== 'new' && (
        <div class="admin-card" style="text-align:center;padding:40px 20px;">
          <p style="font-size:13px;color:#6e6e78;line-height:1.7;">Pick a story to edit, or click <strong>+ New story</strong>.</p>
        </div>
      )}

    </div>
  </div>

  <style>
    .rfl { display:block;font-size:10px;font-weight:600;color:#8a8a94;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:4px; }
    .rfi { width:100%;padding:7px 10px;background:#08080a;border:1px solid #1f1f26;border-radius:5px;color:#fff;font-size:12px;font-family:inherit;outline:none; }
    .rfi:focus { border-color:#FF4F00; }
    textarea.rfi { resize:vertical; }
  </style>
</AdminLayout>