---
import HeiAdminLayout from '@/layouts/HeiAdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const firstName = user.name ? user.name.split(' ')[0] : 'there';
const hour = new Date().getHours();
const greeting = hour < 12 ? 'Good morning' : hour < 17 ? 'Good afternoon' : 'Good evening';

// Load all dashboard data
let stats = { leads: 0, drafts: 0, replies: 0, published: 0, sources: 0, surveys: 0, rti: 0, coverage: 0, legal: 0 };
let leads: any[] = [];
let crawlers: any[] = [];
let auditLog: any[] = [];
let workbench: any[] = [];
let pendingFindings = 0;

try {
  const r = await db.execute(sql`
    SELECT
      (SELECT COUNT(*)::int FROM hei_leads WHERE status NOT IN ('promoted','dismissed')) as leads,
      (SELECT COUNT(*)::int FROM hei_findings WHERE status = 'draft') as drafts,
      (SELECT COUNT(*)::int FROM hei_right_of_reply WHERE status IN ('sent','pending')) as replies,
      (SELECT COUNT(*)::int FROM hei_institutions WHERE is_published = true) as published,
      (SELECT COALESCE(SUM(sources_count),0)::int FROM hei_crawlers WHERE status = 'active') as sources,
      (SELECT COUNT(*)::int FROM hei_survey_responses) as surveys,
      (SELECT COUNT(*)::int FROM hei_rti_filings) as rti,
      (SELECT COUNT(*)::int FROM hei_institutions) as coverage,
      (SELECT COUNT(*)::int FROM hei_legal_queue WHERE status = 'open') as legal
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  if (rows[0]) {
    const d = rows[0] as any;
    stats = {
      leads: Number(d.leads)||0, drafts: Number(d.drafts)||0,
      replies: Number(d.replies)||0, published: Number(d.published)||0,
      sources: Number(d.sources)||0, surveys: Number(d.surveys)||0,
      rti: Number(d.rti)||0, coverage: Number(d.coverage)||0,
      legal: Number(d.legal)||0
    };
  }
} catch(e) {}

// Leads
try {
  const r = await db.execute(sql`
    SELECT l.*, u.name as assignee_name,
      SUBSTRING(u.name FROM 1 FOR 2) as assignee_initials
    FROM hei_leads l
    LEFT JOIN users u ON l.assigned_to = u.id
    WHERE l.status NOT IN ('promoted','dismissed')
    ORDER BY CASE l.priority WHEN 'critical' THEN 1 WHEN 'high' THEN 2 WHEN 'medium' THEN 3 WHEN 'low' THEN 4 ELSE 5 END,
    l.created_at DESC
    LIMIT 10
  `);
  leads = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

// Crawlers
try {
  const r = await db.execute(sql`SELECT * FROM hei_crawlers ORDER BY code`);
  crawlers = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

// Audit log (from existing audit_log table)
try {
  const r = await db.execute(sql`
    SELECT al.*, u.name as user_name, SUBSTRING(u.name FROM 1 FOR 2) as initials
    FROM audit_log al
    LEFT JOIN users u ON al.user_id = u.id
    WHERE al.entity IN ('hei_finding','hei_lead','hei_crawler','hei_institution')
       OR al.action LIKE 'hei%'
    ORDER BY al.created_at DESC
    LIMIT 10
  `);
  auditLog = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

// Workbench - findings awaiting sign-off
try {
  const r = await db.execute(sql`
    SELECT f.*, i.name as institution_name,
      (SELECT COUNT(*)::int FROM hei_evidence_locks WHERE finding_id = f.id) as total_locks,
      (SELECT COUNT(*)::int FROM hei_evidence_locks WHERE finding_id = f.id AND is_locked = true) as locked_count
    FROM hei_findings f
    LEFT JOIN hei_institutions i ON f.institution_id = i.id
    WHERE f.status IN ('review','pending_publication')
    ORDER BY f.updated_at DESC
    LIMIT 5
  `);
  workbench = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

// Handle POST actions
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  try {
    if (action === 'promote_lead') {
      const id = fd.get('id') as string;
      await db.execute(sql`UPDATE hei_leads SET status = 'promoted', updated_at = NOW() WHERE id = ${id}`);
      // Create a draft finding
      const lead = leads.find((l: any) => l.id === id) as any;
      if (lead) {
        await db.execute(sql`
          INSERT INTO hei_findings (title, description, status, institution_id, created_by)
          VALUES (${lead.title}, ${lead.summary || ''}, 'draft', ${lead.institution_id || null}, ${user.id})
        `);
      }
      return Astro.redirect('/admin/hei');
    } else if (action === 'dismiss_lead') {
      const id = fd.get('id') as string;
      await db.execute(sql`UPDATE hei_leads SET status = 'dismissed', updated_at = NOW() WHERE id = ${id}`);
      return Astro.redirect('/admin/hei');
    } else if (action === 'add_lead') {
      const title = (fd.get('title') as string || '').trim();
      const summary = (fd.get('summary') as string || '').trim();
      const priority = (fd.get('priority') as string || 'medium');
      const category = (fd.get('category') as string || 'general');
      const pipeline = (fd.get('pipeline') as string || '');
      const institutionName = (fd.get('institution_name') as string || '').trim();
      if (title) {
        await db.execute(sql`
          INSERT INTO hei_leads (title, summary, priority, category, pipeline, institution_name, status, created_by)
          VALUES (${title}, ${summary || null}, ${priority}, ${category}, ${pipeline || null}, ${institutionName || null}, 'needs_review', ${user.id})
        `);
      }
      return Astro.redirect('/admin/hei');
    }
  } catch(e: any) { console.error(e.message); }
}

const PRIORITY_CONFIG: Record<string, { color: string; bg: string; label: string }> = {
  critical: { color: '#ef4444', bg: 'rgba(239,68,68,0.1)', label: 'CRITICAL' },
  high: { color: '#f97316', bg: 'rgba(249,115,22,0.1)', label: 'HIGH' },
  medium: { color: '#fbbf24', bg: 'rgba(251,191,36,0.1)', label: 'MEDIUM' },
  low: { color: '#6b7280', bg: 'rgba(107,114,128,0.1)', label: 'LOW' },
  signal: { color: '#60a5fa', bg: 'rgba(96,165,250,0.1)', label: 'SIGNAL' },
};

const STATUS_CONFIG: Record<string, { color: string; label: string }> = {
  needs_review: { color: '#fbbf24', label: 'NEEDS REVIEW' },
  drafting: { color: '#60a5fa', label: 'DRAFTING' },
  context_needed: { color: '#a78bfa', label: 'CONTEXT NEEDED' },
  file_rti: { color: '#f97316', label: 'FILE RTI' },
  promoted: { color: '#10b981', label: 'PROMOTED' },
};

function timeAgo(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins + 'm ago';
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return hrs + 'h ago';
  return Math.floor(hrs / 24) + 'd ago';
}

const activeCrawlers = crawlers.filter((c: any) => c.status === 'active').length;

// The editorial data-flow pipeline: ingestion -> leads -> findings -> reply -> published
const PIPE_ICON: Record<string, string> = {
  ingest: '<path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5"/><circle cx="12" cy="12" r="2"/><path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.5"/><path d="M19.1 4.9C23 8.8 23 15.1 19.1 19"/>',
  lead: '<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>',
  finding: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  reply: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
  publish: '<path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2z"/><path d="M2 12h20"/><path d="M12 2a15 15 0 0 1 0 20 15 15 0 0 1 0-20"/>',
};
const pipeline = [
  { key: 'ingest', label: 'Ingestion', sub: 'active sources', count: stats.sources, href: '/admin/hei/crawlers', color: '#60a5fa' },
  { key: 'lead', label: 'Lead queue', sub: 'to review', count: stats.leads, href: '/admin/hei/leads', color: '#FF7040' },
  { key: 'finding', label: 'Draft findings', sub: 'in workbench', count: stats.drafts, href: '/admin/hei/findings', color: '#fbbf24' },
  { key: 'reply', label: 'Right-of-reply', sub: 'window open', count: stats.replies, href: '/admin/hei/replies', color: '#a78bfa' },
  { key: 'publish', label: 'Published', sub: 'ranked live', count: stats.published, href: '/admin/hei/institutions', color: '#10b981' },
];
---
<HeiAdminLayout title="Editorial Dashboard" active="dashboard">
<style>
  .hx { padding: 20px; max-width: 1400px; }
  .hx-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; flex-wrap: wrap; margin-bottom: 20px; }
  .hx-eyebrow { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #FF7040; font-weight: 700; margin: 0 0 4px; }
  .hx-title { font-size: 22px; font-weight: 700; color: #fff; margin: 0 0 6px; letter-spacing: -0.01em; }
  .hx-sub { font-size: 13px; color: #8a8a94; line-height: 1.55; margin: 0; max-width: 60ch; }
  .hx-live { display: inline-flex; align-items: center; gap: 7px; font-family: 'Geist Mono', monospace; font-size: 11px; color: #6ee7b7; background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.25); padding: 6px 12px; border-radius: 100px; white-space: nowrap; }
  .hx-dot { width: 7px; height: 7px; border-radius: 50%; background: #10b981; animation: hxpulse 2s infinite; }
  @keyframes hxpulse { 0%,100%{opacity:1} 50%{opacity:0.35} }

  /* Pipeline data-flow panel */
  .hx-flow { background: linear-gradient(180deg,#0f0f14,#0c0c11); border: 1px solid #1a1a1f; border-radius: 16px; padding: 18px 16px; margin-bottom: 18px; }
  .hx-flow-h { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #6e6e78; font-weight: 700; margin: 0 0 14px; display: flex; align-items: center; gap: 8px; }
  .hx-flow-row { display: flex; align-items: stretch; gap: 0; overflow-x: auto; padding-bottom: 4px; }
  .hx-node { flex: 1; min-width: 130px; text-decoration: none; display: flex; flex-direction: column; gap: 8px; background: #0b0d13; border: 1px solid #1a1a1f; border-radius: 12px; padding: 14px; transition: transform .12s, border-color .12s; }
  .hx-node:hover { transform: translateY(-2px); }
  .hx-node-top { display: flex; align-items: center; justify-content: space-between; }
  .hx-node-ic { width: 30px; height: 30px; border-radius: 8px; display: flex; align-items: center; justify-content: center; }
  .hx-node-count { font-family: 'Geist Mono', monospace; font-size: 26px; font-weight: 800; color: #fff; line-height: 1; }
  .hx-node-label { font-size: 12.5px; font-weight: 700; color: #fff; }
  .hx-node-sub { font-size: 10.5px; color: #6e6e78; }
  .hx-arrow { display: flex; align-items: center; justify-content: center; color: #2a2a33; flex-shrink: 0; width: 26px; }
  @media (max-width: 760px) { .hx-arrow { transform: rotate(90deg); width: auto; height: 20px; } .hx-flow-row { flex-direction: column; } .hx-node { min-width: 0; } }

  .hx-kpis { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 18px; }
  @media (max-width: 720px) { .hx-kpis { grid-template-columns: repeat(2, 1fr); } }
  .hx-kpi { background: #0f0f14; border: 1px solid #1a1a1f; border-radius: 12px; padding: 14px; text-decoration: none; display: block; transition: border-color .12s; }
  .hx-kpi:hover { border-color: #2a2a33; }
  .hx-kpi-num { font-family: 'Geist Mono', monospace; font-size: 22px; font-weight: 800; line-height: 1; }
  .hx-kpi-label { font-size: 11px; color: #8a8a94; margin-top: 6px; }

  .hx-cols { display: grid; grid-template-columns: minmax(0,1fr) 340px; gap: 16px; align-items: start; }
  @media (max-width: 1000px) { .hx-cols { grid-template-columns: 1fr; } }
  .hx-card { background: #0f0f14; border: 1px solid #1a1a1f; border-radius: 14px; overflow: hidden; margin-bottom: 16px; }
  .hx-card-h { padding: 13px 16px; border-bottom: 1px solid #16161b; display: flex; align-items: center; justify-content: space-between; }
  .hx-card-h h2 { font-size: 12px; font-weight: 700; color: #fff; margin: 0; letter-spacing: 0.02em; }
  .hx-card-h a { font-size: 11px; color: #FF7040; text-decoration: none; font-weight: 600; }
  .hx-card-b { padding: 14px 16px; }

  .hx-lead { border: 1px solid #1a1a1f; border-radius: 10px; padding: 12px; margin-bottom: 8px; background: #0b0d13; }
  .hx-lead:last-child { margin-bottom: 0; }
  .hx-lead-badge { font-size: 9px; font-weight: 700; padding: 2px 8px; border-radius: 100px; text-transform: uppercase; display: inline-block; margin-bottom: 7px; letter-spacing: 0.04em; }
  .hx-lead-title { font-size: 13.5px; font-weight: 600; color: #fff; margin: 0 0 4px; line-height: 1.4; }
  .hx-lead-meta { font-size: 10.5px; color: #6e6e78; font-family: 'Geist Mono', monospace; }
  .hx-lead-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 10px; gap: 8px; flex-wrap: wrap; }
  .hx-btn { font-size: 11px; font-weight: 600; padding: 5px 11px; border-radius: 6px; border: none; cursor: pointer; }
  .hx-crawler { display: flex; align-items: center; gap: 10px; padding: 9px 0; border-bottom: 1px solid #14141a; }
  .hx-crawler:last-child { border-bottom: none; }
  .hx-audit { display: flex; align-items: flex-start; gap: 9px; padding: 8px 0; border-bottom: 1px solid #14141a; }
  .hx-audit:last-child { border-bottom: none; }
  .hx-add { width: 100%; background: #15151a; border: 1px solid #1a1a1f; color: #a0a0ab; font-size: 12px; font-weight: 600; padding: 10px; border-radius: 9px; cursor: pointer; margin-top: 8px; transition: border-color .12s; }
  .hx-add:hover { border-color: #FF4F00; color: #fff; }
</style>

<div class="hx">
  <!-- Header -->
  <div class="hx-head">
    <div>
      <p class="hx-eyebrow">HEI · Editorial Control Plane</p>
      <h1 class="hx-title">{greeting}, {firstName}. {stats.drafts > 0 ? `${stats.drafts} finding${stats.drafts > 1 ? 's' : ''} awaiting review.` : 'The desk is clear.'}</h1>
      <p class="hx-sub">
        {stats.coverage} institutions tracked · continuous ingestion across {stats.sources} sources.
        {stats.leads > 0 ? ` ${stats.leads} lead${stats.leads>1?'s':''} in queue.` : ''}
        {stats.replies > 0 ? ` ${stats.replies} in the right-of-reply window.` : ''}
        {stats.legal > 0 ? ` ${stats.legal} in legal review.` : ''}
      </p>
    </div>
    <div style="text-align:right;">
      <div class="hx-live"><span class="hx-dot"></span>{activeCrawlers} pipeline{activeCrawlers===1?'':'s'} active</div>
      <div style="font-family:'Geist Mono',monospace;font-size:10px;color:#6e6e78;margin-top:8px;">{new Date().toLocaleDateString('en-IN', { timeZone:'Asia/Kolkata', day:'numeric', month:'short', year:'numeric' })} · {new Date().toLocaleTimeString('en-IN', { timeZone:'Asia/Kolkata', hour:'2-digit', minute:'2-digit' })} IST</div>
    </div>
  </div>

  <!-- Data-flow pipeline -->
  <div class="hx-flow">
    <p class="hx-flow-h">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#FF7040" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/></svg>
      Editorial data flow · source to publication
    </p>
    <div class="hx-flow-row">
      {pipeline.map((n, i) => (
        <>
          <a href={n.href} class="hx-node" style={`border-top:2px solid ${n.color};`}>
            <div class="hx-node-top">
              <span class="hx-node-ic" style={`background:${n.color}1f;color:${n.color};`}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={PIPE_ICON[n.key]}></svg>
              </span>
              <span class="hx-node-count" style={`color:${n.count>0?'#fff':'#3a3a45'};`}>{n.count}</span>
            </div>
            <div><div class="hx-node-label">{n.label}</div><div class="hx-node-sub">{n.sub}</div></div>
          </a>
          {i < pipeline.length - 1 && (
            <span class="hx-arrow"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
          )}
        </>
      ))}
    </div>
  </div>

  <!-- KPI row -->
  <div class="hx-kpis">
    <a href="/admin/hei/surveys" class="hx-kpi"><div class="hx-kpi-num" style="color:#a78bfa;">{stats.surveys}</div><div class="hx-kpi-label">Survey responses</div></a>
    <a href="/admin/hei/rti" class="hx-kpi"><div class="hx-kpi-num" style="color:#f97316;">{stats.rti}</div><div class="hx-kpi-label">RTI filings tracked</div></a>
    <a href="/admin/hei/legal" class="hx-kpi"><div class="hx-kpi-num" style="color:#ef4444;">{stats.legal}</div><div class="hx-kpi-label">Legal queue (open)</div></a>
    <a href="/admin/hei/institutions" class="hx-kpi"><div class="hx-kpi-num" style="color:#10b981;">{stats.coverage}</div><div class="hx-kpi-label">Institutions covered</div></a>
  </div>

  <!-- Two-column work area -->
  <div class="hx-cols">
    <!-- Main column -->
    <div>
      <div class="hx-card">
        <div class="hx-card-h"><h2>Lead queue · awaiting editorial review</h2><a href="/admin/hei/leads">View all →</a></div>
        <div class="hx-card-b">
          {leads.length === 0 && (
            <div style="text-align:center;padding:28px;color:#6e6e78;">
              <p style="font-size:13px;margin:0;">No leads in queue.</p>
              <p style="font-size:11px;margin:4px 0 0;">Add one below, or connect crawlers to auto-populate.</p>
            </div>
          )}
          {leads.map((lead: any) => {
            const pc = PRIORITY_CONFIG[lead.priority] || PRIORITY_CONFIG['medium'];
            const sc = STATUS_CONFIG[lead.status] || { color: '#6e6e78', label: lead.status };
            return (
              <div class="hx-lead">
                <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">
                  <div style="flex:1;min-width:0;">
                    <span class="hx-lead-badge" style={`background:${pc.bg};color:${pc.color};`}>{pc.label}</span>
                    <p class="hx-lead-title">{lead.title}</p>
                    <div class="hx-lead-meta">
                      {lead.institution_name && <span>{lead.institution_name} · </span>}
                      {lead.pipeline && <span>{lead.pipeline} · </span>}
                      <span>{timeAgo(lead.created_at)}</span>
                    </div>
                    {lead.summary && <p style="font-size:11.5px;color:#8a8a94;margin:6px 0 0;line-height:1.45;">{lead.summary}</p>}
                  </div>
                  {lead.confidence_pct > 0 && (
                    <div style="text-align:right;flex-shrink:0;">
                      <div style="font-family:'Geist Mono',monospace;font-size:14px;font-weight:700;color:#fff;">{lead.confidence_pct}%</div>
                      <div style="font-size:9px;color:#6e6e78;">confidence</div>
                    </div>
                  )}
                </div>
                <div class="hx-lead-foot">
                  <div style="display:flex;align-items:center;gap:8px;">
                    <span style={`font-size:9px;font-weight:700;color:${sc.color};letter-spacing:0.04em;`}>{sc.label}</span>
                    {lead.assignee_name && <div style="width:20px;height:20px;border-radius:50%;background:#15151a;display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;color:#8a8a94;">{lead.assignee_initials}</div>}
                  </div>
                  <div style="display:flex;gap:5px;">
                    <form method="POST" style="display:inline;">
                      <input type="hidden" name="action" value="promote_lead" /><input type="hidden" name="id" value={lead.id} />
                      <button type="submit" class="hx-btn" style="background:rgba(16,185,129,0.15);color:#6ee7b7;">Promote to draft</button>
                    </form>
                    <form method="POST" style="display:inline;">
                      <input type="hidden" name="action" value="dismiss_lead" /><input type="hidden" name="id" value={lead.id} />
                      <button type="submit" class="hx-btn" style="background:#15151a;color:#6e6e78;">Dismiss</button>
                    </form>
                  </div>
                </div>
              </div>
            );
          })}
          <button onclick="document.getElementById('addLeadModal').style.display='flex'" class="hx-add">+ Add lead manually</button>
        </div>
      </div>

      {workbench.length > 0 && (
        <div class="hx-card">
          <div class="hx-card-h"><h2>In your workbench · findings in review</h2><a href="/admin/hei/findings">View all →</a></div>
          <div class="hx-card-b">
            {workbench.map((f: any) => (
              <div class="hx-lead">
                <span class="hx-lead-badge" style="background:rgba(96,165,250,0.15);color:#60a5fa;">IN REVIEW · {f.locked_count || 0}/{f.total_locks || 0} EVIDENCE LOCKED</span>
                <p class="hx-lead-title">{f.title}</p>
                {f.institution_name && <p class="hx-lead-meta">{f.institution_name}</p>}
                {f.description && <p style="font-size:12px;color:#8a8a94;margin:6px 0 0;line-height:1.5;">{f.description?.substring(0,200)}{f.description?.length > 200 ? '…' : ''}</p>}
                <div style="display:flex;gap:8px;margin-top:10px;">
                  <a href="/admin/hei/findings" style="flex:1;text-align:center;background:#15151a;border:1px solid #1a1a1f;color:#a0a0ab;text-decoration:none;font-size:11px;font-weight:600;padding:7px;border-radius:6px;">Review</a>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>

    <!-- Sidebar -->
    <div>
      <div class="hx-card">
        <div class="hx-card-h"><h2>Crawler health</h2><a href="/admin/hei/crawlers">Manage →</a></div>
        <div class="hx-card-b">
          {crawlers.map((c: any) => (
            <div class="hx-crawler">
              <span style={`width:7px;height:7px;border-radius:50%;flex-shrink:0;background:${c.status==='active'?'#10b981':c.status==='error'?'#ef4444':'#fbbf24'};`}></span>
              <span style="font-family:'Geist Mono',monospace;font-size:10px;font-weight:700;background:#15151a;padding:2px 7px;border-radius:4px;color:#FF7040;flex-shrink:0;">{c.code}</span>
              <div style="flex:1;min-width:0;">
                <div style="font-size:12px;font-weight:600;color:#fff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{c.name}</div>
                <div style="font-size:10px;color:#6e6e78;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{c.description}</div>
              </div>
              <div style="text-align:right;flex-shrink:0;"><div style="font-family:'Geist Mono',monospace;font-size:13px;font-weight:700;color:#10b981;">{c.sources_count || 0}</div><div style="font-size:9px;color:#6e6e78;">sources</div></div>
            </div>
          ))}
          {crawlers.length === 0 && <div style="text-align:center;padding:16px;color:#6e6e78;font-size:11.5px;">No crawlers configured yet.</div>}
        </div>
      </div>

      <div class="hx-card">
        <div class="hx-card-h"><h2>Audit log</h2><a href="/admin/audit">Full log →</a></div>
        <div class="hx-card-b">
          {auditLog.length === 0 && <p style="font-size:11.5px;color:#6e6e78;text-align:center;padding:10px;margin:0;">No HEI events recently.</p>}
          {auditLog.map((entry: any) => (
            <div class="hx-audit">
              <div style={`width:22px;height:22px;border-radius:50%;background:${entry.user_name?'#15151a':'#0f0f14'};border:${entry.user_name?'none':'1px solid #1a1a1f'};display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;color:#8a8a94;flex-shrink:0;margin-top:1px;`}>{entry.user_name ? (entry.initials || '?') : 'sys'}</div>
              <div style="flex:1;font-size:11px;color:#8a8a94;line-height:1.4;min-width:0;">{entry.user_name && <strong style="color:#d8d8de;">{entry.user_name?.split(' ')[0]} </strong>}{entry.action} {entry.entity_id ? '· ' + String(entry.entity_id).slice(0,8) : ''}</div>
              <div style="font-size:9px;color:#6e6e78;font-family:'Geist Mono',monospace;flex-shrink:0;">{timeAgo(entry.created_at)}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Add Lead Modal -->
<div id="addLeadModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:200;align-items:center;justify-content:center;padding:16px;">
  <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:16px;width:100%;max-width:600px;padding:20px;max-height:90vh;overflow-y:auto;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <h2 style="font-size:15px;font-weight:700;color:#fff;margin:0;">Add lead to queue</h2>
      <button onclick="document.getElementById('addLeadModal').style.display='none'" style="background:#1a1a1f;border:none;color:#8a8a94;width:30px;height:30px;border-radius:6px;font-size:18px;cursor:pointer;">&times;</button>
    </div>
    <form method="POST" style="display:flex;flex-direction:column;gap:12px;">
      <input type="hidden" name="action" value="add_lead" />
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Title *</label>
        <input name="title" required placeholder="Brief description of the lead…" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;box-sizing:border-box;" />
      </div>
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Institution</label>
        <input name="institution_name" placeholder="Institution name…" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;box-sizing:border-box;" />
      </div>
      <div>
        <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Summary</label>
        <textarea name="summary" rows="3" placeholder="Additional context…" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;resize:vertical;box-sizing:border-box;"></textarea>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;">
        <div>
          <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Priority</label>
          <select name="priority" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
            <option value="critical">Critical</option><option value="high">High</option><option value="medium" selected>Medium</option><option value="low">Low</option><option value="signal">Signal only</option>
          </select>
        </div>
        <div>
          <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Category</label>
          <select name="category" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
            <option value="equity">Equity</option><option value="wellbeing">Wellbeing</option><option value="outcomes">Outcomes</option><option value="integrity">Integrity</option><option value="research">Research</option><option value="general" selected>General</option>
          </select>
        </div>
        <div>
          <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Pipeline</label>
          <select name="pipeline" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;">
            <option value="">Manual</option><option value="P1">P1 · Public data</option><option value="P2">P2 · RTI / FOI</option><option value="P3">P3 · Survey</option><option value="P4">P4 · Alumni scan</option><option value="P5">P5 · Research integrity</option><option value="P6">P6 · News monitoring</option><option value="P7">P7 · Social signal</option>
          </select>
        </div>
      </div>
      <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">Add to lead queue</button>
    </form>
  </div>
</div>

</HeiAdminLayout>
