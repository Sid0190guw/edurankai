---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

let okMsg = '';
let errorMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  try {
    if (action === 'create') {
      const name = (fd.get('name') as string || '').trim();
      const slug = (fd.get('slug') as string || '').trim().toLowerCase().replace(/[^a-z0-9-]/g, '-');
      const title = (fd.get('title') as string || '').trim() || null;
      if (!name || !slug) { errorMsg = 'Name and slug required.'; }
      else {
        await db.execute(sql`
          INSERT INTO training_instructors (name, slug, title, created_at, updated_at)
          VALUES (${name}, ${slug}, ${title}, NOW(), NOW())
        `);
        okMsg = 'Instructor created.';
      }
    } else if (action === 'update') {
      const id = fd.get('id') as string;
      const name = (fd.get('name') as string || '').trim();
      const title = (fd.get('title') as string || '').trim() || null;
      const bio = (fd.get('bio') as string || '').trim() || null;
      const photoUrl = (fd.get('photo_url') as string || '').trim() || null;
      const linkedinUrl = (fd.get('linkedin_url') as string || '').trim() || null;
      const twitterUrl = (fd.get('twitter_url') as string || '').trim() || null;
      const websiteUrl = (fd.get('website_url') as string || '').trim() || null;
      const yearsExperience = parseInt(fd.get('years_experience') as string || '0') || 0;
      const isFeatured = fd.get('is_featured') === 'on';
      const specialties = ((fd.get('specialties') as string || '').trim().split(',').map(s => s.trim()).filter(Boolean));
      await db.execute(sql`
        UPDATE training_instructors SET
          name=${name}, title=${title}, bio=${bio}, photo_url=${photoUrl},
          linkedin_url=${linkedinUrl}, twitter_url=${twitterUrl}, website_url=${websiteUrl},
          years_experience=${yearsExperience}, is_featured=${isFeatured}, specialties=${specialties},
          updated_at=NOW()
        WHERE id=${id}
      `);
      okMsg = 'Instructor updated.';
    } else if (action === 'delete') {
      const id = fd.get('id') as string;
      await db.execute(sql`DELETE FROM training_instructors WHERE id = ${id}`);
      okMsg = 'Deleted.';
    }
  } catch (e: any) {
    errorMsg = 'Error: ' + (e?.message || 'Unknown');
  }
}

let instructors: any[] = [];
try {
  const r = await db.execute(sql`SELECT * FROM training_instructors ORDER BY is_featured DESC, sort_order ASC, name ASC`);
  instructors = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}
---
<AdminLayout title="Faculty / Instructors" activeNav="instructors">
<div style="padding:0 0 80px;">
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:16px;position:sticky;top:0;z-index:10;display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;">
    <div>
      <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;">AquinTutor LMS</p>
      <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Faculty</h1>
    </div>
    <button onclick="document.getElementById('newInstrModal').style.display='flex'" style="background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:12px;padding:8px 14px;border-radius:8px;cursor:pointer;">+ New instructor</button>
  </div>

  {errorMsg && <div style="margin:12px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:12px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  <div style="padding:16px;display:flex;flex-direction:column;gap:10px;max-width:900px;margin:0 auto;">
    {instructors.length === 0 && <p style="text-align:center;padding:30px;color:#6e6e78;">No instructors yet. Click "+ New instructor" to add one.</p>}
    {instructors.map((i: any) => {
      const specialtiesText = Array.isArray(i.specialties) ? i.specialties.join(', ') : '';
      return (
        <details style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
          <summary style="cursor:pointer;list-style:none;padding:14px;display:flex;justify-content:space-between;align-items:center;gap:10px;">
            <div style="display:flex;align-items:center;gap:10px;flex:1;min-width:0;">
              <div style="width:36px;height:36px;border-radius:50%;background:#15151a;border:1px solid #1a1a1f;display:flex;align-items:center;justify-content:center;color:#FF7040;font-weight:700;flex-shrink:0;">{(i.name || '?').substring(0, 1).toUpperCase()}</div>
              <div style="min-width:0;">
                <p style="font-size:13.5px;font-weight:600;color:#fff;margin:0;">{i.name}{i.is_featured && <span style="background:rgba(251,191,36,0.15);color:#fbbf24;font-size:9px;font-weight:700;padding:2px 6px;border-radius:100px;margin-left:6px;">Featured</span>}</p>
                <p style="font-size:11px;color:#6e6e78;margin:0;font-family:'Geist Mono',monospace;">/aquintutor/instructors/{i.slug}</p>
              </div>
            </div>
            <span style="font-size:10px;color:#FF7040;flex-shrink:0;">Edit &darr;</span>
          </summary>
          <div style="padding:0 14px 14px;border-top:1px solid #1a1a1f;">
            <form method="POST" style="display:flex;flex-direction:column;gap:10px;margin-top:12px;">
              <input type="hidden" name="action" value="update" />
              <input type="hidden" name="id" value={i.id} />
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
                <input type="text" name="name" value={i.name} placeholder="Full name" style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:13px;outline:none;" />
                <input type="text" name="title" value={i.title || ''} placeholder="Title / role" style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:13px;outline:none;" />
              </div>
              <textarea name="bio" rows="4" placeholder="Bio (paragraphs supported)" style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:13px;outline:none;resize:vertical;line-height:1.55;">{i.bio || ''}</textarea>
              <input type="text" name="photo_url" value={i.photo_url || ''} placeholder="Photo URL (https://...)" style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:13px;outline:none;" />
              <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;">
                <input type="text" name="linkedin_url" value={i.linkedin_url || ''} placeholder="LinkedIn URL" style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12px;outline:none;" />
                <input type="text" name="twitter_url" value={i.twitter_url || ''} placeholder="Twitter URL" style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12px;outline:none;" />
                <input type="text" name="website_url" value={i.website_url || ''} placeholder="Website URL" style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12px;outline:none;" />
              </div>
              <div style="display:grid;grid-template-columns:2fr 1fr 1fr;gap:8px;">
                <input type="text" name="specialties" value={specialtiesText} placeholder="Specialties (comma-separated)" style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:13px;outline:none;" />
                <input type="number" name="years_experience" value={i.years_experience || 0} placeholder="Years exp." style="background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:13px;outline:none;" />
                <label style="display:flex;align-items:center;gap:6px;font-size:12.5px;color:#d8d8de;cursor:pointer;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;">
                  <input type="checkbox" name="is_featured" checked={i.is_featured} />
                  <span>Featured</span>
                </label>
              </div>
              <div style="display:flex;gap:6px;flex-wrap:wrap;">
                <button type="submit" style="background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:12px;padding:7px 14px;border-radius:6px;cursor:pointer;">Save</button>
                <a href={'/aquintutor/instructors/' + i.slug} target="_blank" rel="noopener" style="background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;text-decoration:none;font-size:11px;font-weight:500;padding:7px 12px;border-radius:6px;">Preview</a>
              </div>
            </form>
            <form method="POST" style="margin-top:8px;" onsubmit='return confirm("Delete instructor?")'>
              <input type="hidden" name="action" value="delete" />
              <input type="hidden" name="id" value={i.id} />
              <button type="submit" style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;font-size:11px;padding:6px 12px;border-radius:6px;cursor:pointer;">Delete</button>
            </form>
          </div>
        </details>
      );
    })}
  </div>
</div>

<div id="newInstrModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:200;align-items:flex-end;justify-content:center;">
  <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:16px 16px 0 0;width:100%;max-width:500px;padding:20px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
      <h2 style="font-size:15px;font-weight:700;color:#fff;margin:0;">New instructor</h2>
      <button onclick="document.getElementById('newInstrModal').style.display='none'" style="background:#1a1a1f;border:none;color:#8a8a94;width:30px;height:30px;border-radius:6px;font-size:18px;cursor:pointer;">&times;</button>
    </div>
    <form method="POST" style="display:flex;flex-direction:column;gap:10px;">
      <input type="hidden" name="action" value="create" />
      <input type="text" name="name" required placeholder="Full name" style="background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
      <input type="text" name="slug" required placeholder="firstname-lastname" style="background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;font-family:'Geist Mono',monospace;" />
      <input type="text" name="title" placeholder="Title / role (optional)" style="background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
      <button type="submit" style="background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">Create instructor</button>
    </form>
  </div>
</div>
</AdminLayout>
