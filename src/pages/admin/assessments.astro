---
// /admin/assessments — assessment authoring + manual grading (Prompt 8, admin surface). Gated to
// admin-surface roles. Create an AssessmentObject attached to a KnowledgeObject (assesses edge),
// build an item bank (mcq/numeric/true-false/short-answer), publish, grade the short-answer queue,
// and inspect attempts. Real backend (kernel + edu_assessment_* + /api/admin/assessments).
import AdminLayout from '@/layouts/AdminLayout.astro';
import { requireAdminRole } from '@/lib/rbac';
import { contentService } from '@/lib/kernel-content';
import { listAllAssessments, listItems, manualQueue, listAttempts } from '@/lib/assessment';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (!(await requireAdminRole(user))) return Astro.redirect('/admin');

const units = (await contentService().listUnits().catch(() => [])).map((u: any) => ({ id: u.id, title: (u.data as any).title, state: u.lifecycleState }));
const assessments = await listAllAssessments().catch(() => []);
const sel = (Astro.url.searchParams.get('a') || '').trim();
const selItems = sel ? await listItems(sel, true).catch(() => []) : [];
const selMeta = assessments.find((a: any) => a.id === sel);
const queue = await manualQueue(50).catch(() => []);
const attempts = await listAttempts(30).catch(() => []);

const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const IN = 'background:#15151a;border:1px solid #26262c;color:#fff;padding:7px 9px;border-radius:6px;font-size:12px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
const stC: Record<string, string> = { created: '#8a8a94', validated: '#c0a35e', indexed: '#5ea0c0', published: '#6ee7b7', archived: '#a06060' };
function fmt(d: any) { try { return new Date(d).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); } catch { return '-'; } }
---
<AdminLayout title="Assessments" activeNav="assessments">
  <div style="max-width:1120px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Assessment engine</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Assessments &amp; grading</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">Author items, publish, and grade short answers. Objective items auto-grade; publishing + grading need the execute capability. Authoring: <a href="/admin/knowledge" style="color:#FF7040;">/admin/knowledge</a>.</p>
    <div id="msg" style="display:none;margin:12px 0;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <!-- CREATE + LIST -->
    <div style={CARD}>
      <p style={HD}>Assessments</p>
      <div style="display:flex;gap:6px;flex-wrap:wrap;align-items:end;margin-bottom:12px;">
        <div><label style="font-size:10px;color:#8a8a94;">Title</label><br/><input id="cTitle" style={IN} placeholder="e.g. Limits check" /></div>
        <div><label style="font-size:10px;color:#8a8a94;">Kind</label><br/><select id="cKind" style={IN}><option value="quiz">quiz</option><option value="exam">exam</option><option value="olympiad">olympiad</option></select></div>
        <div><label style="font-size:10px;color:#8a8a94;">Assesses (KnowledgeObject)</label><br/><select id="cKo" style={IN}>{units.map((u) => <option value={u.id}>{u.title}</option>)}</select></div>
        <div><label style="font-size:10px;color:#8a8a94;">Security</label><br/><select id="cLabel" style={IN}><option value="public">public</option><option value="enrolled-only">enrolled-only</option><option value="exam-secure">exam-secure</option></select></div>
        <button id="cBtn" type="button" style="background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:700;padding:8px 14px;border-radius:6px;cursor:pointer;">Create</button>
      </div>
      {assessments.length === 0 ? <p style="font-size:12px;color:#6e6e78;margin:0;">No assessments yet.</p> :
        <div style="display:flex;flex-wrap:wrap;gap:6px;">{assessments.map((a: any) => (
          <a href={'?a=' + a.id} style={'text-decoration:none;background:' + (a.id === sel ? 'rgba(255,79,0,0.14)' : '#08080a') + ';border:1px solid #26262c;border-radius:8px;padding:6px 11px;font-size:12px;color:#cfd6da;'}>{a.title} <span style={'color:' + (stC[a.state] || '#8a8a94')}>· {a.state}</span></a>
        ))}</div>}
    </div>

    <!-- SELECTED ASSESSMENT: ITEMS + ADD -->
    {sel && selMeta ? (
      <div style={CARD}>
        <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;">
          <p style={HD + 'margin:0;'}>{selMeta.title} — items ({selItems.length})</p>
          {selMeta.state !== 'published' ? <button id="pubBtn" data-id={sel} type="button" style="background:#0f2f22;border:1px solid #1f5f42;color:#6ee7b7;font-size:11px;padding:6px 12px;border-radius:6px;cursor:pointer;">Publish</button> : <span style="font-size:11px;color:#6ee7b7;font-family:'Geist Mono',monospace;">published</span>}
        </div>
        {selItems.map((it: any, i: number) => (
          <div style="border-top:1px solid #15151a;padding:8px 0;display:flex;justify-content:space-between;gap:8px;">
            <span style="font-size:12.5px;color:#cfd6da;">{i + 1}. [{it.type}] {it.prompt} <span style="color:#6e6e78;">({it.points}pt)</span></span>
            <button class="delItem" data-id={it.id} type="button" style="background:none;border:none;color:#fca5a5;cursor:pointer;font-size:13px;">&times;</button>
          </div>
        ))}
        <div style="margin-top:12px;background:#08080a;border:1px solid #26262c;border-radius:10px;padding:12px;">
          <p style="font-size:10px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;margin:0 0 8px;">Add item</p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <div style="grid-column:1/-1;"><select id="iType" style={IN + 'width:auto;'}><option value="mcq">mcq</option><option value="true_false">true/false</option><option value="numeric">numeric</option><option value="short_answer">short answer</option></select> <input id="iPoints" type="number" value="1" style={IN + 'width:70px;'} title="points" /></div>
            <div style="grid-column:1/-1;"><input id="iPrompt" style={IN + 'width:100%;box-sizing:border-box;'} placeholder="Question prompt" /></div>
            <div style="grid-column:1/-1;" id="wOptions"><textarea id="iOptions" rows="3" style={IN + 'width:100%;box-sizing:border-box;'} placeholder="MCQ options, one per line"></textarea></div>
            <div id="wCorrect"><input id="iCorrect" type="number" value="0" style={IN} title="correct option index (0-based)" placeholder="correct index" /></div>
            <div id="wNumeric" style="display:none;"><input id="iValue" type="number" step="any" style={IN} placeholder="answer value" /> <input id="iTol" type="number" step="any" value="0" style={IN + 'width:90px;'} placeholder="tolerance" /></div>
            <div id="wTF" style="display:none;"><select id="iTF" style={IN}><option value="true">True</option><option value="false">False</option></select></div>
          </div>
          <button id="addItemBtn" type="button" style="background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:700;padding:8px 14px;border-radius:6px;cursor:pointer;margin-top:10px;">Add item</button>
        </div>
      </div>
    ) : null}

    <!-- MANUAL GRADE QUEUE -->
    <div style={CARD}>
      <p style={HD}>Manual grade queue (short answers)</p>
      {queue.length === 0 ? <p style="font-size:12px;color:#6e6e78;margin:0;">Nothing awaiting manual grading.</p> :
        queue.map((q: any) => (
          <div style="border-top:1px solid #15151a;padding:8px 0;display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;">
            <span style="font-size:12.5px;color:#cfd6da;">{q.user_name || String(q.user_id).slice(0, 8)} · auto {q.auto_score}/{q.max_score} · {q.mode}</span>
            <span style="display:flex;gap:5px;align-items:center;"><input class="gPts" data-id={q.id} type="number" value="0" style={IN + 'width:80px;'} title="manual points to add" /><button class="gBtn" data-id={q.id} type="button" style="background:#0f2f22;border:1px solid #1f5f42;color:#6ee7b7;font-size:11px;padding:5px 11px;border-radius:6px;cursor:pointer;">Finalize</button></span>
          </div>
        ))}
    </div>

    <!-- ATTEMPTS -->
    <div style={CARD}>
      <p style={HD}>Recent attempts</p>
      {attempts.length === 0 ? <p style="font-size:12px;color:#6e6e78;margin:0;">No attempts yet.</p> :
      <div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:12px;">
        <thead><tr style="color:#8a8a94;font-size:9px;text-transform:uppercase;font-family:'Geist Mono',monospace;text-align:left;"><th style="padding:5px 8px;">When</th><th style="padding:5px 8px;">Student</th><th style="padding:5px 8px;">Mode</th><th style="padding:5px 8px;">State</th><th style="padding:5px 8px;">Score</th></tr></thead>
        <tbody>{attempts.map((a: any) => (
          <tr style="border-top:1px solid #15151a;"><td style="padding:5px 8px;color:#8a8a94;font-family:'Geist Mono',monospace;white-space:nowrap;">{fmt(a.started_at)}</td><td style="padding:5px 8px;color:#cfd6da;">{a.user_name || String(a.user_id).slice(0, 8)}</td><td style="padding:5px 8px;color:#8a8a94;">{a.mode}</td><td style="padding:5px 8px;color:#8a8a94;">{a.state}</td><td style={'padding:5px 8px;font-weight:700;color:' + (a.passed ? '#6ee7b7' : '#c0a35e')}>{a.pct}%</td></tr>
        ))}</tbody>
      </table></div>}
    </div>
  </div>

  <script is:inline define:vars={{ sel }}>
    (function () {
      var msg = document.getElementById('msg');
      function flash(t, ok) { msg.style.display = 'block'; msg.textContent = t; msg.style.background = ok ? 'rgba(16,185,129,0.12)' : 'rgba(239,68,68,0.12)'; msg.style.color = ok ? '#6ee7b7' : '#fca5a5'; }
      function post(body) { return fetch('/api/admin/assessments', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }).then(function (r) { return r.json(); }).then(function (j) { if (j.ok) { flash('Saved.', true); setTimeout(function () { location.href = j.id && body.action === 'create' ? ('?a=' + j.id) : location.href.split('#')[0]; if (body.action !== 'create') location.reload(); }, 400); } else flash(j.error || 'Failed', false); return j; }).catch(function () { flash('Network error', false); }); }
      var c = document.getElementById('cBtn'); if (c) c.addEventListener('click', function () { post({ action: 'create', title: document.getElementById('cTitle').value, kind: document.getElementById('cKind').value, koId: document.getElementById('cKo').value, securityLabel: document.getElementById('cLabel').value }); });
      var ty = document.getElementById('iType');
      if (ty) { var refresh = function () { var t = ty.value; document.getElementById('wOptions').style.display = t === 'mcq' ? 'block' : 'none'; document.getElementById('wCorrect').style.display = t === 'mcq' ? 'block' : 'none'; document.getElementById('wNumeric').style.display = t === 'numeric' ? 'block' : 'none'; document.getElementById('wTF').style.display = t === 'true_false' ? 'block' : 'none'; }; ty.addEventListener('change', refresh); refresh(); }
      var ai = document.getElementById('addItemBtn'); if (ai) ai.addEventListener('click', function () {
        var t = document.getElementById('iType').value, body = { action: 'addItem', assessmentId: sel, type: t, prompt: document.getElementById('iPrompt').value, points: document.getElementById('iPoints').value };
        if (t === 'mcq') { body.options = document.getElementById('iOptions').value; body.correctIndex = document.getElementById('iCorrect').value; }
        else if (t === 'numeric') { body.value = document.getElementById('iValue').value; body.tolerance = document.getElementById('iTol').value; }
        else if (t === 'true_false') { body.value = document.getElementById('iTF').value; }
        post(body);
      });
      document.querySelectorAll('.delItem').forEach(function (b) { b.addEventListener('click', function () { post({ action: 'deleteItem', itemId: b.getAttribute('data-id') }); }); });
      var pb = document.getElementById('pubBtn'); if (pb) pb.addEventListener('click', function () { post({ action: 'publish', assessmentId: pb.getAttribute('data-id') }); });
      document.querySelectorAll('.gBtn').forEach(function (b) { b.addEventListener('click', function () { var id = b.getAttribute('data-id'); post({ action: 'gradeManual', attemptId: id, manualPoints: document.querySelector('.gPts[data-id="' + id + '"]').value }); }); });
    })();
  </script>
</AdminLayout>
