---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { roles, departments } from '@/lib/db/schema';
import { can } from '@/lib/auth/permissions';
import { desc, eq, asc, ilike, and, or, SQL } from 'drizzle-orm';
import { CATALOG_DEPARTMENTS, ROLE_CATALOG } from '@/data/role-catalog';
import { getProductOptions, setRoleProducts, setRoleOpenings } from '@/lib/role-products';
import { logAudit } from '@/lib/audit';

const user = Astro.locals.user!;
const canEdit = can(user, 'roles.edit');

// Gap-filling import of the canonical role catalog. Idempotent and edit-safe:
// a catalog role is inserted ONLY if no existing role shares its slug or its
// normalized title (case/punctuation/plural-insensitive) — most roles were
// hand-written in this panel already and must never be duplicated or touched.
let importMsg = '';
const normTitle = (s: string) =>
  (s || '').toLowerCase().replace(/[^a-z0-9 ]+/g, ' ').split(/\s+/).filter(Boolean).map((w) => w.replace(/s$/, '')).join('');

if (Astro.request.method === 'POST' && canEdit) {
  const fd = await Astro.request.formData();
  if (fd.get('_action') === 'import_catalog') {
    try {
      for (const d of CATALOG_DEPARTMENTS) {
        await db.insert(departments).values({ id: d.id, name: d.name, icon: d.icon, description: d.description, sortOrder: 50 }).onConflictDoNothing();
      }
      const existing = await db.select({ slug: roles.slug, title: roles.title }).from(roles);
      const haveSlugs = new Set(existing.map((r) => r.slug));
      const haveTitles = new Set(existing.map((r) => normTitle(r.title)));
      const productOptions = await getProductOptions();
      const added: string[] = [];
      let skipped = 0;
      for (const c of ROLE_CATALOG) {
        if (haveSlugs.has(c.slug) || haveTitles.has(normTitle(c.title))) { skipped++; continue; }
        const inserted = await db.insert(roles).values({
          slug: c.slug,
          departmentId: c.departmentId,
          title: c.title,
          level: c.level,
          function: c.function,
          engagementType: c.engagementType,
          location: c.location,
          duration: c.duration,
          salary: c.salary,
          about: c.about,
          responsibilities: c.responsibilities as string[],
          skills: c.skills as string[],
          eligibility: c.eligibility as string[],
          isOpen: true,
          isFeatured: !!c.isFeatured,
          sortOrder: 50,
        }).returning({ id: roles.id });
        if (c.productMatch) {
          const tags = productOptions.filter((p) => p.slug.includes(c.productMatch!) || p.name.toLowerCase().includes(c.productMatch!)).map((p) => p.slug);
          if (tags.length) await setRoleProducts(inserted[0].id, tags);
        }
        if (c.openings) await setRoleOpenings(inserted[0].id, c.openings);
        added.push(c.title);
      }
      await logAudit({ userId: user.id, action: 'role.import_catalog', entity: 'role', entityId: 'catalog', diff: { added, skipped }, ipAddress: Astro.clientAddress });
      importMsg = added.length
        ? 'Imported ' + added.length + ' new role' + (added.length === 1 ? '' : 's') + ' (' + skipped + ' already present, untouched): ' + added.join(' · ')
        : 'Nothing to import — all ' + skipped + ' catalog roles already exist. Your roles were not touched.';
    } catch (e: any) {
      importMsg = 'Import failed: ' + (e?.cause?.message || e?.message || 'unknown error');
    }
  }
}

const url = new URL(Astro.request.url);
const q = url.searchParams.get('q') || '';
const deptFilter = url.searchParams.get('dept') || '';
const openFilter = url.searchParams.get('open') || '';

const conditions: SQL[] = [];
if (q) conditions.push(or(ilike(roles.title, '%' + q + '%'), ilike(roles.function, '%' + q + '%'))!);
if (deptFilter) conditions.push(eq(roles.departmentId, deptFilter));
if (openFilter === 'open') conditions.push(eq(roles.isOpen, true));
if (openFilter === 'closed') conditions.push(eq(roles.isOpen, false));

const where = conditions.length ? and(...conditions) : undefined;
const rolesList = await db.select({
  id: roles.id, title: roles.title, slug: roles.slug, level: roles.level,
  departmentId: roles.departmentId, isOpen: roles.isOpen, isFeatured: roles.isFeatured,
  createdAt: roles.createdAt, engagementType: roles.engagementType,
}).from(roles).where(where).orderBy(desc(roles.isFeatured), asc(roles.sortOrder), desc(roles.createdAt));

const allDepts = await db.select().from(departments).orderBy(asc(departments.sortOrder));
const deptMap = Object.fromEntries(allDepts.map(d => [d.id, d.name]));

const openCount = rolesList.filter(r => r.isOpen).length;
const closedCount = rolesList.filter(r => !r.isOpen).length;
const featuredCount = rolesList.filter(r => r.isFeatured).length;
---
<AdminLayout title="Roles" activeNav="roles">
<div style="padding-bottom:80px;">

  <!-- Header -->
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
      <div>
        <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">Careers</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Roles</h1>
      </div>
      {canEdit && (
        <div style="display:flex;gap:8px;align-items:center;">
          <form method="POST" onsubmit="return confirm('Import the built-in role catalog? Only roles you do not already have will be added — existing roles are never changed.');" style="margin:0;">
            <input type="hidden" name="_action" value="import_catalog" />
            <button type="submit" style="background:#15151a;border:1px solid #2a2a30;color:#e8e8ee;font-weight:600;font-size:12px;padding:8px 14px;border-radius:8px;cursor:pointer;">Import catalog ({ROLE_CATALOG.length})</button>
          </form>
          <a href="/admin/roles/new" style="background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:12px;padding:8px 14px;border-radius:8px;text-decoration:none;">+ New Role</a>
        </div>
      )}
    </div>
    {importMsg && (
      <div style="margin:0 0 12px;background:rgba(96,165,250,0.08);border:1px solid rgba(96,165,250,0.25);color:#93c5fd;border-radius:8px;padding:9px 12px;font-size:12px;line-height:1.5;">{importMsg}</div>
    )}

    <!-- Stats -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:12px;">
      {[
        { label: 'Open', value: openCount, color: '#10b981' },
        { label: 'Closed', value: closedCount, color: '#6e6e78' },
        { label: 'Featured', value: featuredCount, color: '#FF7040' },
      ].map(s => (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:8px;padding:8px;text-align:center;">
          <p style={`font-size:20px;font-weight:700;color:${s.color};margin:0;line-height:1;`}>{s.value}</p>
          <p style="font-size:9px;color:#6e6e78;margin:2px 0 0;text-transform:uppercase;">{s.label}</p>
        </div>
      ))}
    </div>

    <!-- Search + Filters -->
    <form method="GET" style="display:flex;flex-direction:column;gap:8px;">
      <input type="text" name="q" value={q} placeholder="Search title or function..." style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:8px 12px;color:#fff;font-size:13px;outline:none;" />
      <div style="display:flex;gap:8px;">
        <select name="dept" style="flex:1;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:8px 10px;color:#fff;font-size:12px;outline:none;">
          <option value="">All departments</option>
          {allDepts.map(d => <option value={d.id} selected={deptFilter === d.id}>{d.name}</option>)}
        </select>
        <select name="open" style="flex:1;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:8px 10px;color:#fff;font-size:12px;outline:none;">
          <option value="">All statuses</option>
          <option value="open" selected={openFilter === 'open'}>Open only</option>
          <option value="closed" selected={openFilter === 'closed'}>Closed only</option>
        </select>
        <button type="submit" style="background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:8px 14px;color:#fff;font-size:12px;cursor:pointer;">Go</button>
      </div>
    </form>
  </div>

  <!-- Role cards -->
  <div style="padding:12px 16px;display:flex;flex-direction:column;gap:8px;">
    {rolesList.length === 0 && (
      <div style="text-align:center;padding:48px;color:#6e6e78;">
        <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom:8px;opacity:0.7;"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        <p style="font-size:13px;">No roles yet.</p>
        {canEdit && <a href="/admin/roles/new" style="color:#FF7040;font-size:12px;">Create the first role →</a>}
      </div>
    )}
    {rolesList.map(r => {
      const deptName = deptMap[r.departmentId] || r.departmentId;
      return (
        <a href={`/admin/roles/${r.id}`} style="text-decoration:none;background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;display:block;">
          <div style="padding:12px 14px;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:8px;">
              <div style="min-width:0;">
                <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;margin-bottom:2px;">
                  <p style="font-size:14px;font-weight:600;color:#fff;margin:0;">{r.title}</p>
                  {r.isFeatured && <span style="font-size:9px;font-weight:700;background:rgba(255,79,0,0.15);color:#FF7040;padding:1px 6px;border-radius:100px;text-transform:uppercase;">Featured</span>}
                </div>
                <p style="font-size:11px;color:#6e6e78;margin:0;">{deptName}</p>
              </div>
              <span style={`font-size:10px;font-weight:700;padding:3px 8px;border-radius:100px;flex-shrink:0;${r.isOpen ? 'background:rgba(16,185,129,0.15);color:#6ee7b7;' : 'background:#15151a;color:#6e6e78;'}`}>
                {r.isOpen ? 'Open' : 'Closed'}
              </span>
            </div>
            <div style="display:flex;gap:6px;flex-wrap:wrap;">
              {r.level && <span style="font-size:10px;background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;padding:2px 8px;border-radius:100px;">{r.level}</span>}
              {r.engagementType && <span style="font-size:10px;background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;padding:2px 8px;border-radius:100px;">{r.engagementType}</span>}
              <span style="font-size:10px;color:#6e6e78;font-family:'Geist Mono',monospace;padding:2px 0;">{r.slug}</span>
            </div>
          </div>
          <div style="border-top:1px solid #1a1a1f;padding:8px 14px;display:flex;align-items:center;justify-content:space-between;">
            <span style="font-size:11px;color:#6e6e78;">{new Date(r.createdAt).toLocaleDateString('en-IN',{ timeZone: 'Asia/Kolkata',day:'numeric',month:'short',year:'numeric'})}</span>
            <span style="font-size:11px;color:#FF7040;font-weight:500;">Edit →</span>
          </div>
        </a>
      );
    })}
  </div>
</div>
</AdminLayout>
