---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { canViewPage } from '@/lib/auth/pagePermissions';
import { db } from '@/lib/db';
import { roles, departments } from '@/lib/db/schema';
import { can } from '@/lib/auth/permissions';
import { desc, eq, asc, ilike, and, or, SQL } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!(await canViewPage(user, 'roles'))) return Astro.redirect('/admin');
const canEdit = can(user, 'roles.edit');

const url = new URL(Astro.request.url);
const q = url.searchParams.get('q') || '';
const deptFilter = url.searchParams.get('dept') || '';
const levelFilter = url.searchParams.get('level') || '';
const openFilter = url.searchParams.get('open') || '';

const conditions: SQL[] = [];
if (q) conditions.push(or(ilike(roles.title, '%' + q + '%'), ilike(roles.function, '%' + q + '%'))!);
if (deptFilter) conditions.push(eq(roles.departmentId, deptFilter));
if (levelFilter) conditions.push(eq(roles.level, levelFilter as any));
if (openFilter === 'open') conditions.push(eq(roles.isOpen, true));
if (openFilter === 'closed') conditions.push(eq(roles.isOpen, false));

const where = conditions.length ? and(...conditions) : undefined;

const rolesList = await db.select({
  id: roles.id,
  title: roles.title,
  slug: roles.slug,
  level: roles.level,
  departmentId: roles.departmentId,
  isOpen: roles.isOpen,
  isFeatured: roles.isFeatured,
  createdAt: roles.createdAt,
  engagementType: roles.engagementType
}).from(roles).where(where).orderBy(desc(roles.isFeatured), asc(roles.sortOrder), desc(roles.createdAt));

const allDepts = await db.select().from(departments).orderBy(asc(departments.sortOrder));
const deptMap = Object.fromEntries(allDepts.map((d) => [d.id, d.name]));

const totalCount = rolesList.length;
---
<AdminLayout title="Roles" activeNav="roles">
  <div class="admin-page">
    <div class="admin-page-header">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">Hiring</div>
        <h1 class="admin-page-title">Roles</h1>
        <p class="admin-page-sub">{totalCount} role{totalCount === 1 ? '' : 's'} in the database. These power the public /careers page.</p>
      </div>
      {canEdit && (
        <a href="/admin/roles/new" class="admin-btn admin-btn-primary">+ New Role</a>
      )}
    </div>

    <form method="GET" style="display:flex;gap:8px;margin-bottom:18px;flex-wrap:wrap;align-items:center;">
      <input type="text" name="q" value={q} placeholder="Search title or function..."
        style="flex:1;min-width:200px;padding:7px 12px;background:#08080a;border:1px solid #1f1f26;border-radius:6px;color:#fff;font-size:12.5px;font-family:inherit;outline:none;" />
      <select name="dept" style="padding:7px 12px;background:#08080a;border:1px solid #1f1f26;border-radius:6px;color:#fff;font-size:12.5px;font-family:inherit;outline:none;">
        <option value="">All departments</option>
        {allDepts.map((d) => {
          const sel = deptFilter === d.id;
          return <option value={d.id} selected={sel}>{d.name}</option>;
        })}
      </select>
      <select name="level" style="padding:7px 12px;background:#08080a;border:1px solid #1f1f26;border-radius:6px;color:#fff;font-size:12.5px;font-family:inherit;outline:none;">
        <option value="">All levels</option>
        {['C-Level','Lead','Senior','Mid','Junior','Intern','Apprentice'].map((lv) => {
          const sel = levelFilter === lv;
          return <option value={lv} selected={sel}>{lv}</option>;
        })}
      </select>
      <select name="open" style="padding:7px 12px;background:#08080a;border:1px solid #1f1f26;border-radius:6px;color:#fff;font-size:12.5px;font-family:inherit;outline:none;">
        <option value="">All statuses</option>
        <option value="open" selected={openFilter === 'open'}>Open only</option>
        <option value="closed" selected={openFilter === 'closed'}>Closed only</option>
      </select>
      <button type="submit" class="admin-btn">Filter</button>
      {(q || deptFilter || levelFilter || openFilter) && (
        <a href="/admin/roles" class="admin-btn">Clear</a>
      )}
    </form>

    <div class="admin-card" style="padding:0;overflow:hidden;">
      {rolesList.length === 0 ? (
        <div class="admin-table-empty">
          No roles yet. {canEdit && <a href="/admin/roles/new" style="color:#FF7040;">Create the first role</a>}
        </div>
      ) : (
        <table class="admin-table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Department</th>
              <th>Level</th>
              <th>Type</th>
              <th>Status</th>
              <th style="text-align:right;">Actions</th>
            </tr>
          </thead>
          <tbody>
            {rolesList.map((r) => {
              const deptName = deptMap[r.departmentId] || r.departmentId;
              const statusColor = r.isOpen ? '#10b981' : '#6e6e78';
              const statusText = r.isOpen ? 'Open' : 'Closed';
              const featured = r.isFeatured;
              const editHref = '/admin/roles/' + r.id;
              return (
                <tr>
                  <td>
                    <div style="font-weight:500;color:#fff;">{r.title}</div>
                    <div style="font-size:10.5px;color:#6e6e78;font-family:'Geist Mono',monospace;margin-top:2px;">{r.slug}</div>
                  </td>
                  <td><span style="font-size:11.5px;color:#a0a0ab;">{deptName}</span></td>
                  <td>
                    <span style="background:#15151a;border:1px solid #1f1f26;color:#d8d8de;font-size:10.5px;padding:2px 8px;border-radius:100px;font-weight:500;">{r.level}</span>
                  </td>
                  <td><span style="font-size:11.5px;color:#a0a0ab;">{r.engagementType}</span></td>
                  <td>
                    <span style={'display:inline-flex;align-items:center;gap:5px;font-size:11px;color:' + statusColor + ';'}>
                      <span style={'width:6px;height:6px;border-radius:50%;background:' + statusColor + ';'}></span>
                      {statusText}
                    </span>
                    {featured && (
                      <span style="margin-left:6px;font-size:9px;background:rgba(255,79,0,0.12);color:#FF7040;padding:1px 6px;border-radius:100px;letter-spacing:0.05em;text-transform:uppercase;font-weight:700;">Featured</span>
                    )}
                  </td>
                  <td style="text-align:right;">
                    <a href={editHref} class="admin-btn" style="padding:5px 11px;font-size:11px;">Edit</a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      )}
    </div>
  </div>
</AdminLayout>
