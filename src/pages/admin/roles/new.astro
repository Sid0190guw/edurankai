---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { roles, departments } from '@/lib/db/schema';
import { can } from '@/lib/auth/permissions';
import { roleSchema, parseLines, slugify } from '@/lib/validators';
import { logAudit } from '@/lib/audit';
import { asc, eq } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!can(user, 'roles.edit')) {
  return Astro.redirect('/admin/roles');
}

const allDepts = await db.select().from(departments).orderBy(asc(departments.sortOrder));

let errorMsg = '';
let formData: Record<string, any> = {};

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const title = (fd.get('title') as string || '').trim();
  const rawSlug = (fd.get('slug') as string || '').trim();
  const finalSlug = rawSlug || slugify(title);

  formData = {
    title,
    slug: finalSlug,
    departmentId: fd.get('departmentId'),
    level: fd.get('level'),
    function: fd.get('function'),
    engagementType: fd.get('engagementType'),
    location: fd.get('location'),
    duration: fd.get('duration'),
    salary: fd.get('salary'),
    about: fd.get('about'),
    responsibilities: parseLines(fd.get('responsibilities') as string),
    skills: parseLines(fd.get('skills') as string),
    eligibility: parseLines(fd.get('eligibility') as string),
    isOpen: fd.get('isOpen') === 'on',
    isFeatured: fd.get('isFeatured') === 'on',
    sortOrder: parseInt((fd.get('sortOrder') as string) || '0', 10)
  };

  const parsed = roleSchema.safeParse(formData);

  if (!parsed.success) {
    errorMsg = parsed.error.errors.map((e) => e.path.join('.') + ': ' + e.message).join('  ·  ');
  } else {
    const existing = await db.select({ id: roles.id }).from(roles).where(eq(roles.slug, parsed.data.slug)).limit(1);
    if (existing.length > 0) {
      errorMsg = 'A role with slug "' + parsed.data.slug + '" already exists. Pick a different slug.';
    } else {
      const inserted = await db.insert(roles).values(parsed.data).returning({ id: roles.id });
      await logAudit({
        userId: user.id,
        action: 'role.create',
        entity: 'role',
        entityId: inserted[0].id,
        diff: { created: parsed.data },
        ipAddress: Astro.clientAddress
      });
      return Astro.redirect('/admin/roles');
    }
  }
}

const LEVELS = ['C-Level', 'Lead', 'Senior', 'Mid', 'Junior', 'Intern', 'Apprentice'];
const ENGAGEMENTS = ['Full-Time', 'Internship', 'Apprenticeship'];
---
<AdminLayout title="New Role" activeNav="roles">
  <div class="admin-page" style="max-width:880px;">
    <div class="admin-page-header">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow"><a href="/admin/roles" style="color:#6e6e78;text-decoration:none;">← Roles</a></div>
        <h1 class="admin-page-title">Create New Role</h1>
        <p class="admin-page-sub">This role will appear on the public /careers page once saved.</p>
      </div>
    </div>

    {errorMsg && (
      <div style="background:rgba(220,38,38,0.08);border:1px solid rgba(220,38,38,0.25);color:#fca5a5;font-size:12.5px;padding:11px 14px;border-radius:7px;margin-bottom:18px;line-height:1.7;">
        {errorMsg}
      </div>
    )}

    <form method="POST" class="admin-card" style="display:flex;flex-direction:column;gap:18px;">

      <div style="display:grid;grid-template-columns:2fr 1fr;gap:16px;">
        <div>
          <label class="rolefield-label">Title *</label>
          <input name="title" required value={formData.title || ''} placeholder="e.g. Senior ML Engineer" class="rolefield-input" />
        </div>
        <div>
          <label class="rolefield-label">Slug (auto from title if blank)</label>
          <input name="slug" value={formData.slug || ''} placeholder="senior-ml-engineer" class="rolefield-input" pattern="[a-z0-9-]+" />
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;">
        <div>
          <label class="rolefield-label">Department *</label>
          <select name="departmentId" required class="rolefield-input">
            <option value="">— Choose —</option>
            {allDepts.map((d) => {
              const sel = formData.departmentId === d.id;
              return <option value={d.id} selected={sel}>{d.name}</option>;
            })}
          </select>
        </div>
        <div>
          <label class="rolefield-label">Level *</label>
          <select name="level" required class="rolefield-input">
            {LEVELS.map((lv) => {
              const sel = formData.level === lv;
              return <option value={lv} selected={sel}>{lv}</option>;
            })}
          </select>
        </div>
        <div>
          <label class="rolefield-label">Engagement *</label>
          <select name="engagementType" required class="rolefield-input">
            {ENGAGEMENTS.map((e) => {
              const sel = formData.engagementType === e;
              return <option value={e} selected={sel}>{e}</option>;
            })}
          </select>
        </div>
      </div>

      <div>
        <label class="rolefield-label">Function (one-line description) *</label>
        <input name="function" required value={formData.function || ''} placeholder="e.g. Optimize training pipelines and model architectures" class="rolefield-input" />
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;">
        <div>
          <label class="rolefield-label">Location *</label>
          <input name="location" required value={formData.location || 'Remote'} class="rolefield-input" />
        </div>
        <div>
          <label class="rolefield-label">Duration *</label>
          <input name="duration" required value={formData.duration || 'Permanent'} placeholder="Permanent / 3 Months / 6 Months" class="rolefield-input" />
        </div>
        <div>
          <label class="rolefield-label">Salary / Comp *</label>
          <input name="salary" required value={formData.salary || 'Not Disclosed'} class="rolefield-input" />
        </div>
      </div>

      <div>
        <label class="rolefield-label">About this role *</label>
        <textarea name="about" required rows="4" class="rolefield-input" placeholder="2-4 sentences describing the role and what makes it interesting.">{formData.about || ''}</textarea>
      </div>

      <div>
        <label class="rolefield-label">Responsibilities (one per line)</label>
        <textarea name="responsibilities" rows="6" class="rolefield-input" placeholder="Design and optimise ML training pipelines\nMentor junior engineers\nOwn model deployment and monitoring">{(formData.responsibilities || []).join('\n')}</textarea>
      </div>

      <div>
        <label class="rolefield-label">Skills (one per line)</label>
        <textarea name="skills" rows="5" class="rolefield-input" placeholder="PyTorch\nDistributed training\nMLOps">{(formData.skills || []).join('\n')}</textarea>
      </div>

      <div>
        <label class="rolefield-label">Eligibility (one per line)</label>
        <textarea name="eligibility" rows="4" class="rolefield-input" placeholder="5+ years ML engineering\nPhD in CS preferred\nStrong written English">{(formData.eligibility || []).join('\n')}</textarea>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;align-items:end;">
        <div>
          <label class="rolefield-label">Sort order</label>
          <input type="number" name="sortOrder" value={formData.sortOrder ?? 0} class="rolefield-input" />
        </div>
        <label style="display:flex;align-items:center;gap:8px;color:#d8d8de;font-size:12.5px;padding:8px 0;cursor:pointer;">
          <input type="checkbox" name="isOpen" checked={formData.isOpen ?? true} style="accent-color:#FF4F00;width:14px;height:14px;" />
          <span>Open for applications</span>
        </label>
        <label style="display:flex;align-items:center;gap:8px;color:#d8d8de;font-size:12.5px;padding:8px 0;cursor:pointer;">
          <input type="checkbox" name="isFeatured" checked={formData.isFeatured ?? false} style="accent-color:#FF4F00;width:14px;height:14px;" />
          <span>Featured (pinned to top)</span>
        </label>
      </div>

      <div style="display:flex;gap:10px;justify-content:flex-end;padding-top:16px;border-top:1px solid #15151a;">
        <a href="/admin/roles" class="admin-btn">Cancel</a>
        <button type="submit" class="admin-btn admin-btn-primary">Create Role</button>
      </div>
    </form>
  </div>

  <style>
    .rolefield-label {
      display: block;
      font-size: 10.5px;
      font-weight: 600;
      color: #8a8a94;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 6px;
    }
    .rolefield-input {
      width: 100%;
      padding: 9px 12px;
      background: #08080a;
      border: 1px solid #1f1f26;
      border-radius: 6px;
      color: #fff;
      font-size: 13px;
      font-family: inherit;
      outline: none;
      line-height: 1.5;
    }
    .rolefield-input:focus { border-color: #FF4F00; }
    textarea.rolefield-input { resize: vertical; min-height: 80px; }
  </style>
</AdminLayout>
