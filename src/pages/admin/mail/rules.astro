---
import AdminLayout from '@/layouts/AdminLayout.astro';
import {
  getSignature, setSignature, listLabels, createLabel, deleteLabel,
  listRules, createRule, deleteRule,
} from '@/lib/mail-advanced';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');

let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = (fd.get('_action') as string) || '';
  const g = (k: string) => ((fd.get(k) as string) || '').trim();
  try {
    if (action === 'save_signature') {
      await setSignature(user.id, ((fd.get('html') as string) || '').slice(0, 20000), fd.get('on') === 'on');
      okMsg = 'Signature saved.';
    } else if (action === 'add_label') {
      if (!g('name')) throw new Error('Label name required');
      await createLabel(user.id, g('name'), g('color') || '#67e8f9');
      okMsg = 'Label saved.';
    } else if (action === 'del_label') {
      await deleteLabel(user.id, g('id'));
      okMsg = 'Label removed.';
    } else if (action === 'add_rule') {
      if (!g('match_value')) throw new Error('Match value required');
      await createRule(user.id, {
        matchField: g('match_field') || 'from',
        matchOp: g('match_op') || 'contains',
        matchValue: g('match_value'),
        action: g('action') || 'label',
        actionValue: g('action_value'),
      });
      okMsg = 'Rule added.';
    } else if (action === 'del_rule') {
      await deleteRule(user.id, g('id'));
      okMsg = 'Rule removed.';
    }
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 200); }
}

const sig = await getSignature(user.id).catch(() => ({ html: '', on: false }));
const labels: any[] = await listLabels(user.id).catch(() => []);
const rules: any[] = await listRules(user.id).catch(() => []);

const SWATCHES = ['#67e8f9', '#a78bfa', '#fca5a5', '#86efac', '#fcd34d', '#f9a8d4', '#93c5fd', '#fdba74'];
function fieldLabel(f: string) { return ({ from: 'From', to: 'To', subject: 'Subject', body: 'Body' } as any)[f] || f; }
function opLabel(o: string) { return ({ contains: 'contains', equals: 'equals', startswith: 'starts with', endswith: 'ends with' } as any)[o] || o; }
function actLabel(a: string, v: string) {
  if (a === 'label') return 'apply label "' + (v || '') + '"';
  if (a === 'folder') return 'move to ' + (v || '');
  if (a === 'star') return 'star it';
  if (a === 'read') return 'mark read';
  return a;
}
---
<AdminLayout title="Mail rules" activeNav="mail">
  <section class="page">
    <div class="page-head">
      <div>
        <p class="eyebrow">Mail</p>
        <h1>Signature, labels &amp; rules</h1>
        <p class="sub">Your personal mailbox preferences. <a href="/admin/mail">Back to inbox</a></p>
      </div>
    </div>

    {okMsg && <div class="flash ok">{okMsg}</div>}
    {errMsg && <div class="flash err">{errMsg}</div>}

    <!-- SIGNATURE -->
    <div class="card">
      <h2>Email signature</h2>
      <p class="card-sub">Appended to messages you send (toggle off per-message in the composer). HTML allowed.</p>
      <form method="post">
        <input type="hidden" name="_action" value="save_signature" />
        <textarea name="html" rows="6" class="ta" placeholder="e.g. <strong>Your Name</strong><br>EduRankAI">{sig.html}</textarea>
        <div class="row-between">
          <label class="chk"><input type="checkbox" name="on" checked={sig.on} /> Attach by default</label>
          <button class="btn" type="submit">Save signature</button>
        </div>
      </form>
    </div>

    <!-- LABELS -->
    <div class="card">
      <h2>Labels</h2>
      <p class="card-sub">Color-coded tags you can apply to conversations and use in rules.</p>
      <div class="chips">
        {labels.length === 0 ? <span class="muted">No labels yet.</span> : labels.map((l: any) => (
          <span class="chip" style={`background:${l.color}22;border-color:${l.color}`}>
            <span class="dot" style={`background:${l.color}`}></span>{l.name}
            <form method="post" class="inline"><input type="hidden" name="_action" value="del_label" /><input type="hidden" name="id" value={l.id} /><button class="chip-x" type="submit" title="Remove">&times;</button></form>
          </span>
        ))}
      </div>
      <form method="post" class="label-form">
        <input type="hidden" name="_action" value="add_label" />
        <input name="name" class="inp" placeholder="Label name" maxlength="60" required />
        <select name="color" class="inp sel">
          {SWATCHES.map((c) => <option value={c} style={`background:${c}`}>{c}</option>)}
        </select>
        <button class="btn" type="submit">Add label</button>
      </form>
    </div>

    <!-- RULES -->
    <div class="card">
      <h2>Inbound rules</h2>
      <p class="card-sub">Run automatically on every incoming message, top to bottom.</p>
      {rules.length === 0 ? <p class="muted">No rules yet.</p> : (
        <ul class="rules">
          {rules.map((r: any) => (
            <li class="rule">
              <span class="rule-text">
                If <b>{fieldLabel(r.match_field)}</b> {opLabel(r.match_op)} <b>{r.match_value}</b> &rarr; {actLabel(r.action, r.action_value)}
              </span>
              <form method="post" class="inline"><input type="hidden" name="_action" value="del_rule" /><input type="hidden" name="id" value={r.id} /><button class="rule-x" type="submit">Remove</button></form>
            </li>
          ))}
        </ul>
      )}
      <form method="post" class="rule-form">
        <input type="hidden" name="_action" value="add_rule" />
        <span>If</span>
        <select name="match_field" class="inp sel"><option value="from">From</option><option value="to">To</option><option value="subject">Subject</option><option value="body">Body</option></select>
        <select name="match_op" class="inp sel"><option value="contains">contains</option><option value="equals">equals</option><option value="startswith">starts with</option><option value="endswith">ends with</option></select>
        <input name="match_value" class="inp" placeholder="value" maxlength="200" required />
        <span>then</span>
        <select name="action" class="inp sel"><option value="label">apply label</option><option value="folder">move to folder</option><option value="star">star</option><option value="read">mark read</option></select>
        <input name="action_value" class="inp" placeholder="label / folder name" maxlength="80" />
        <button class="btn" type="submit">Add rule</button>
      </form>
      <p class="hint">For "apply label", action value is the label name (created if new). For "move to folder", use inbox / archive / spam / trash. Star / mark-read need no value.</p>
    </div>
  </section>

  <style>
    .page { max-width: 880px; margin: 0 auto; padding: 4px 2px 40px; }
    .page-head { margin-bottom: 18px; }
    .eyebrow { font-size: 0.62rem; font-family: monospace; text-transform: uppercase; letter-spacing: 0.15em; color: #FF4F00; font-weight: 700; margin: 0 0 4px; }
    .page-head h1 { font-size: 1.5rem; font-weight: 600; color: #100b08; margin: 0 0 4px; }
    .sub { font-size: 0.86rem; color: #6a635c; margin: 0; }
    .sub a, .card-sub a { color: #FF4F00; text-decoration: none; }
    .flash { padding: 10px 14px; border-radius: 10px; font-size: 0.85rem; margin-bottom: 14px; }
    .flash.ok { background: #ecfdf5; color: #047857; border: 1px solid #a7f3d0; }
    .flash.err { background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; }
    .card { background: #fff; border: 1px solid rgba(14,11,8,0.1); border-radius: 14px; padding: 20px 22px; margin-bottom: 16px; }
    .card h2 { font-size: 1.05rem; font-weight: 600; color: #100b08; margin: 0 0 3px; }
    .card-sub { font-size: 0.82rem; color: #8a8078; margin: 0 0 14px; }
    .ta { width: 100%; border: 1px solid rgba(14,11,8,0.14); border-radius: 10px; padding: 11px 13px; font-size: 0.88rem; font-family: monospace; line-height: 1.6; outline: 0; resize: vertical; }
    .ta:focus, .inp:focus { border-color: #FF4F00; }
    .row-between { display: flex; justify-content: space-between; align-items: center; margin-top: 10px; flex-wrap: wrap; gap: 10px; }
    .chk { font-size: 0.84rem; color: #4a443e; display: inline-flex; align-items: center; gap: 7px; }
    .btn { background: #FF4F00; color: #fff; border: 0; border-radius: 9px; padding: 9px 18px; font-weight: 700; font-size: 0.84rem; cursor: pointer; }
    .btn:hover { background: #e84800; }
    .inp { border: 1px solid rgba(14,11,8,0.14); border-radius: 9px; padding: 8px 11px; font-size: 0.85rem; outline: 0; font-family: inherit; }
    .sel { background: #fff; cursor: pointer; }
    .chips { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
    .chip { display: inline-flex; align-items: center; gap: 7px; border: 1px solid; border-radius: 100px; padding: 4px 11px; font-size: 0.82rem; color: #2b2620; font-weight: 500; }
    .chip .dot { width: 9px; height: 9px; border-radius: 100px; }
    .chip-x { background: 0; border: 0; color: #6a635c; font-size: 1.05rem; cursor: pointer; line-height: 1; padding: 0 0 0 2px; }
    .inline { display: inline; }
    .label-form, .rule-form { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
    .rule-form span { font-size: 0.84rem; color: #6a635c; }
    .rules { list-style: none; padding: 0; margin: 0 0 14px; display: flex; flex-direction: column; gap: 7px; }
    .rule { display: flex; justify-content: space-between; align-items: center; gap: 12px; background: #faf7f3; border: 1px solid rgba(14,11,8,0.08); border-radius: 10px; padding: 9px 13px; }
    .rule-text { font-size: 0.85rem; color: #2b2620; }
    .rule-x { background: 0; border: 0; color: #b91c1c; font-size: 0.78rem; font-weight: 600; cursor: pointer; }
    .muted { color: #a99e94; font-size: 0.85rem; }
    .hint { font-size: 0.74rem; color: #a99e94; margin: 12px 0 0; line-height: 1.5; }
  </style>
</AdminLayout>
