---
// /admin/mail/groups — manage named mail distribution lists.
// Each group has a hidden_recipients flag — when true, group mail BCCs every
// member so they never see each other's addresses (privacy-by-default mode).
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { ensureMailGroupsSchema, listGroups, getGroupMembers, getGroupBySlug } from '@/lib/mail-groups';

const user = Astro.locals.user!;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

await ensureMailGroupsSchema();
function rowsOf(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const action = (fd.get('_action') as string || '').trim();
    if (action === 'create') {
      const slug = ((fd.get('slug') as string || '').toLowerCase().trim()).replace(/[^a-z0-9-]/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '').slice(0, 64);
      const name = (fd.get('name') as string || '').trim().slice(0, 200);
      const description = (fd.get('description') as string || '').trim().slice(0, 4000) || null;
      const hidden = fd.get('hidden_recipients') === 'on';
      if (!slug || !name) errMsg = 'Slug and name are required.';
      else {
        await db.execute(sql`INSERT INTO mail_groups (slug, name, description, hidden_recipients, created_by_user_id) VALUES (${slug}, ${name}, ${description}, ${hidden}, ${user.id}) ON CONFLICT (slug) DO UPDATE SET name=EXCLUDED.name, description=EXCLUDED.description, hidden_recipients=EXCLUDED.hidden_recipients, updated_at=NOW()`);
        okMsg = 'Group saved.';
      }
    } else if (action === 'add_member') {
      const groupId = (fd.get('group_id') as string || '').trim();
      const emailInput = (fd.get('email') as string || '').trim().toLowerCase().slice(0, 255);
      const nameInput = (fd.get('name') as string || '').trim().slice(0, 200) || null;
      if (!groupId || !emailInput || !/.+@.+\..+/.test(emailInput)) errMsg = 'Group ID + valid email required.';
      else {
        // Match against an existing user if possible so the membership is
        // tracked by user_id (auto-follows if the user updates their email).
        const u = rowsOf(await db.execute(sql`SELECT id, name FROM users WHERE LOWER(email) = ${emailInput} LIMIT 1`))[0] as any;
        if (u) {
          await db.execute(sql`INSERT INTO mail_group_members (group_id, user_id, added_by_user_id) VALUES (${groupId}, ${u.id}, ${user.id})`);
        } else {
          await db.execute(sql`INSERT INTO mail_group_members (group_id, external_email, external_name, added_by_user_id) VALUES (${groupId}, ${emailInput}, ${nameInput}, ${user.id})`);
        }
        okMsg = 'Member added.';
      }
    } else if (action === 'remove_member') {
      const id = (fd.get('id') as string || '').trim();
      if (id) {
        await db.execute(sql`DELETE FROM mail_group_members WHERE id = ${id}`);
        okMsg = 'Member removed.';
      }
    } else if (action === 'delete_group') {
      const id = (fd.get('id') as string || '').trim();
      if (id) {
        await db.execute(sql`DELETE FROM mail_groups WHERE id = ${id}`);
        okMsg = 'Group deleted.';
      }
    } else if (action === 'add_all_applicants') {
      // Convenience: drop every applicant user into the group in one shot.
      const groupId = (fd.get('group_id') as string || '').trim();
      if (groupId) {
        await db.execute(sql`
          INSERT INTO mail_group_members (group_id, user_id, added_by_user_id)
          SELECT ${groupId}, u.id, ${user.id} FROM users u
          WHERE u.role = 'applicant' AND u.is_active = true
            AND NOT EXISTS (SELECT 1 FROM mail_group_members m WHERE m.group_id = ${groupId} AND m.user_id = u.id)
        `);
        okMsg = 'All current applicants added to the group.';
      }
    } else if (action === 'add_all_admins') {
      const groupId = (fd.get('group_id') as string || '').trim();
      if (groupId) {
        await db.execute(sql`
          INSERT INTO mail_group_members (group_id, user_id, added_by_user_id)
          SELECT ${groupId}, u.id, ${user.id} FROM users u
          WHERE u.role != 'applicant' AND u.is_active = true
            AND NOT EXISTS (SELECT 1 FROM mail_group_members m WHERE m.group_id = ${groupId} AND m.user_id = u.id)
        `);
        okMsg = 'All current admins added to the group.';
      }
    }
  } catch (e: any) { errMsg = 'Failed: ' + (e?.message || 'unknown'); }
}

const groups = await listGroups();
const url = new URL(Astro.request.url);
const editGroupSlug = url.searchParams.get('edit') || '';
let editGroup = null;
let editMembers: any[] = [];
if (editGroupSlug) {
  editGroup = await getGroupBySlug(editGroupSlug);
  if (editGroup) {
    editMembers = rowsOf(await db.execute(sql`
      SELECT m.id, m.user_id, m.external_email, m.external_name, m.added_at,
        COALESCE(m.external_email, u.email) AS email,
        COALESCE(m.external_name, u.name) AS name
      FROM mail_group_members m
      LEFT JOIN users u ON u.id = m.user_id
      WHERE m.group_id = ${editGroup.id}
      ORDER BY m.added_at DESC
    `));
  }
}
---
<AdminLayout title="Mail Groups" activeNav="mail">
<div class="admin-page" style="max-width:980px;">

  <div class="admin-page-header" style="margin-bottom:18px;">
    <div class="admin-page-title-block">
      <div class="admin-page-eyebrow">Mail</div>
      <h1 class="admin-page-title">Mail Groups</h1>
      <p class="admin-page-sub">Named distribution lists for one-shot bulk mail. Hidden-recipient groups BCC every member — recipients never see each other.</p>
    </div>
  </div>

  {okMsg && <div style="background:rgba(16,185,129,0.10);border:1px solid rgba(16,185,129,0.30);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;margin-bottom:14px;">{okMsg}</div>}
  {errMsg && <div style="background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.30);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;margin-bottom:14px;">{errMsg}</div>}

  <!-- How to use this -->
  <div class="admin-card" style="margin-bottom:16px;background:rgba(255,80,0,0.04);">
    <p style="font-size:13px;font-weight:700;color:var(--o-hi,#fff);margin:0 0 8px;">How to send to a group</p>
    <p style="font-size:12px;color:var(--o-mid,#9aa6b6);margin:0 0 6px;line-height:1.6;">In any mail compose To / Cc / Bcc field, type <code style="font-family:'Geist Mono',monospace;background:var(--o-panel,#08080a);padding:2px 7px;border-radius:4px;color:#FF7040;">@group:slug</code> — for example <code style="font-family:'Geist Mono',monospace;background:var(--o-panel,#08080a);padding:2px 7px;border-radius:4px;color:#FF7040;">@group:all-applicants</code>. When the message is sent, the token expands to every member of that group.</p>
    <p style="font-size:12px;color:var(--o-mid,#9aa6b6);margin:0;line-height:1.6;">If the group has <strong style="color:#fbbf24;">hidden recipients</strong> ON, members are routed to BCC automatically — they never see each other's addresses, regardless of which field you put the token in.</p>
  </div>

  <!-- Create / edit group -->
  <div class="admin-card" style="margin-bottom:16px;">
    <h2 style="font-family:Fraunces,serif;font-size:1.1rem;font-weight:600;color:var(--o-hi,#fff);margin:0 0 12px;">{editGroup ? 'Edit group: ' + editGroup.name : 'Create a new group'}</h2>
    <form method="POST">
      <input type="hidden" name="_action" value="create" />
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:10px;margin-bottom:10px;">
        <div>
          <label style="display:block;font-size:11px;color:var(--o-mid,#9aa6b6);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:4px;">Slug *</label>
          <input name="slug" type="text" required maxlength="64" pattern="[a-z0-9-]+" value={editGroup?.slug || ''} placeholder="all-applicants" readonly={!!editGroup} style="width:100%;background:var(--o-panel,#08080a);border:1px solid var(--o-stroke,#2a2a2f);color:var(--o-hi,#fff);padding:8px 11px;border-radius:6px;font-size:12.5px;font-family:'Geist Mono',monospace;" />
        </div>
        <div>
          <label style="display:block;font-size:11px;color:var(--o-mid,#9aa6b6);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:4px;">Display name *</label>
          <input name="name" type="text" required maxlength="200" value={editGroup?.name || ''} placeholder="All applicants" style="width:100%;background:var(--o-panel,#08080a);border:1px solid var(--o-stroke,#2a2a2f);color:var(--o-hi,#fff);padding:8px 11px;border-radius:6px;font-size:12.5px;" />
        </div>
      </div>
      <label style="display:block;font-size:11px;color:var(--o-mid,#9aa6b6);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:4px;">Description</label>
      <textarea name="description" rows="2" maxlength="4000" placeholder="What this group is for, who it includes." style="width:100%;background:var(--o-panel,#08080a);border:1px solid var(--o-stroke,#2a2a2f);color:var(--o-hi,#fff);padding:8px 11px;border-radius:6px;font-size:12.5px;font-family:'Inter Tight',sans-serif;resize:vertical;outline:none;margin-bottom:10px;">{editGroup?.description || ''}</textarea>
      <label style="display:flex;align-items:center;gap:9px;font-size:12.5px;color:var(--o-hi,#fff);cursor:pointer;margin-bottom:12px;">
        <input type="checkbox" name="hidden_recipients" checked={!editGroup || editGroup.hidden_recipients} style="accent-color:#FF4F00;width:16px;height:16px;" />
        <span><strong>Hidden recipients</strong> — when ON, group mail goes to every member as BCC so they never see who else received it. Recommended for applicant lists, large stakeholder lists, anything privacy-sensitive.</span>
      </label>
      <button type="submit" style="background:#FF4F00;color:#fff;border:none;font-size:12.5px;font-weight:700;padding:9px 18px;border-radius:7px;cursor:pointer;">{editGroup ? 'Update group' : 'Create group'}</button>
    </form>
  </div>

  {editGroup && (
    <>
      <!-- Member management -->
      <div class="admin-card" style="margin-bottom:16px;">
        <h2 style="font-family:Fraunces,serif;font-size:1.1rem;font-weight:600;color:var(--o-hi,#fff);margin:0 0 12px;">Members of <code style="font-family:'Geist Mono',monospace;color:#FF7040;font-size:0.95rem;">@group:{editGroup.slug}</code> ({editMembers.length})</h2>
        <form method="POST" style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px;">
          <input type="hidden" name="_action" value="add_member" />
          <input type="hidden" name="group_id" value={editGroup.id} />
          <input name="email" type="email" required placeholder="member@example.com" style="flex:1;min-width:240px;background:var(--o-panel,#08080a);border:1px solid var(--o-stroke,#2a2a2f);color:var(--o-hi,#fff);padding:8px 11px;border-radius:6px;font-size:12px;font-family:'Geist Mono',monospace;" />
          <input name="name" type="text" placeholder="Display name (optional)" style="flex:1;min-width:180px;background:var(--o-panel,#08080a);border:1px solid var(--o-stroke,#2a2a2f);color:var(--o-hi,#fff);padding:8px 11px;border-radius:6px;font-size:12px;" />
          <button type="submit" style="background:#10b981;color:#fff;border:none;font-size:12px;font-weight:700;padding:8px 16px;border-radius:6px;cursor:pointer;">Add member</button>
        </form>

        <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px;">
          <form method="POST" onsubmit="return confirm('Add every active applicant to this group?');" style="margin:0;">
            <input type="hidden" name="_action" value="add_all_applicants" />
            <input type="hidden" name="group_id" value={editGroup.id} />
            <button type="submit" style="background:#15151a;border:1px solid #2a2a2f;color:#9aa6b6;font-size:11px;font-weight:600;padding:6px 12px;border-radius:6px;cursor:pointer;">+ Add all applicants</button>
          </form>
          <form method="POST" onsubmit="return confirm('Add every active admin / staff user to this group?');" style="margin:0;">
            <input type="hidden" name="_action" value="add_all_admins" />
            <input type="hidden" name="group_id" value={editGroup.id} />
            <button type="submit" style="background:#15151a;border:1px solid #2a2a2f;color:#9aa6b6;font-size:11px;font-weight:600;padding:6px 12px;border-radius:6px;cursor:pointer;">+ Add all admins</button>
          </form>
        </div>

        {editMembers.length === 0 ? (
          <p style="font-size:12px;color:#6e6e78;text-align:center;padding:18px 0;">No members yet.</p>
        ) : (
          <div style="display:flex;flex-direction:column;gap:5px;">
            {editMembers.map((m: any) => (
              <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;background:var(--o-panel,#08080a);border:1px solid var(--o-stroke,#1a1a1f);border-radius:7px;padding:8px 12px;">
                <div style="min-width:0;flex:1;">
                  <p style="font-size:12.5px;color:var(--o-hi,#fff);margin:0;font-weight:500;">{m.name || m.email}</p>
                  <p style="font-size:11px;color:#8a8a94;margin:2px 0 0;font-family:'Geist Mono',monospace;">{m.email} {m.user_id ? '· internal user' : '· external contact'}</p>
                </div>
                <form method="POST" style="margin:0;" onsubmit="return confirm('Remove this member?');">
                  <input type="hidden" name="_action" value="remove_member" />
                  <input type="hidden" name="id" value={m.id} />
                  <button type="submit" style="background:transparent;border:1px solid rgba(239,68,68,0.4);color:#fca5a5;font-size:10.5px;font-weight:600;padding:4px 10px;border-radius:5px;cursor:pointer;">Remove</button>
                </form>
              </div>
            ))}
          </div>
        )}
      </div>

      <a href="/admin/mail/groups" style="font-size:12px;color:var(--o-mid,#9aa6b6);text-decoration:none;display:inline-block;margin-bottom:10px;">← Back to all groups</a>
    </>
  )}

  {!editGroup && (
    <div class="admin-card">
      <h2 style="font-family:Fraunces,serif;font-size:1.1rem;font-weight:600;color:var(--o-hi,#fff);margin:0 0 12px;">All groups ({groups.length})</h2>
      {groups.length === 0 ? (
        <p style="font-size:12.5px;color:#6e6e78;text-align:center;padding:30px 0;">No groups yet. Create one above.</p>
      ) : (
        <div style="display:flex;flex-direction:column;gap:6px;">
          {groups.map((g: any) => (
            <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;background:var(--o-panel,#08080a);border:1px solid var(--o-stroke,#1a1a1f);border-radius:8px;padding:10px 14px;flex-wrap:wrap;">
              <div style="min-width:0;flex:1;">
                <p style="font-size:13px;color:var(--o-hi,#fff);margin:0;font-weight:600;">{g.name} <span style="font-family:'Geist Mono',monospace;color:#FF7040;font-size:11px;font-weight:500;">@group:{g.slug}</span></p>
                <p style="font-size:11.5px;color:#8a8a94;margin:3px 0 0;">{g.member_count} member(s) · {g.hidden_recipients ? <span style="color:#fbbf24;">hidden recipients</span> : <span style="color:#6ee7b7;">visible to all</span>}</p>
                {g.description && <p style="font-size:11px;color:#6e6e78;margin:4px 0 0;line-height:1.5;">{g.description}</p>}
              </div>
              <div style="display:flex;gap:6px;flex-shrink:0;">
                <a href={'?edit=' + g.slug} style="background:#15151a;border:1px solid #2a2a2f;color:#9aa6b6;font-size:11px;font-weight:600;padding:6px 12px;border-radius:6px;text-decoration:none;">Edit + members</a>
                <form method="POST" onsubmit="return confirm('Delete this group? Members are not deleted, only the list.');" style="margin:0;">
                  <input type="hidden" name="_action" value="delete_group" />
                  <input type="hidden" name="id" value={g.id} />
                  <button type="submit" style="background:transparent;border:1px solid rgba(239,68,68,0.4);color:#fca5a5;font-size:11px;font-weight:600;padding:6px 12px;border-radius:6px;cursor:pointer;">Delete</button>
                </form>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  )}
</div>
</AdminLayout>
