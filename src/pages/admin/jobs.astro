---
// /admin/jobs — background-jobs health + delivery log (Prompt AP6b). Queue depth by status, recent
// deliveries, and controls to run the worker or requeue failed jobs. Gated: administer (platform).
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { queueHealth, recentJobLog } from '@/lib/job-queue';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'administer', { type: 'platform' });
if (!gate.allow) return Astro.redirect('/admin');
const health = await queueHealth().catch(() => ({ pending: 0, processing: 0, failed: 0, done: 0 }));
const log = await recentJobLog(60).catch(() => []);
const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
---
<AdminLayout title="Background jobs" activeNav="jobs">
  <div style="max-width:900px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Reliability</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Background jobs</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">Notifications + async work run through a durable Postgres queue with retries, idempotency, and rate-limiting. The daily cron drains it; you can also run it now. A dedicated broker is a follow-up only for very high volume.</p>
    <div id="msg" style="display:none;margin:12px 0;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin:16px 0;">
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Pending</p><p style="font-size:26px;font-weight:800;color:#c0a35e;margin:4px 0 0;">{health.pending}</p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Processing</p><p style="font-size:26px;font-weight:800;color:#9bd1ff;margin:4px 0 0;">{health.processing}</p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Failed</p><p style="font-size:26px;font-weight:800;color:#fca5a5;margin:4px 0 0;">{health.failed}</p></div>
      <div style={CARD + 'margin:0;'}><p style="font-size:11px;color:#8a8a94;margin:0;">Done</p><p style="font-size:26px;font-weight:800;color:#6ee7b7;margin:4px 0 0;">{health.done}</p></div>
    </div>

    <div style="display:flex;gap:8px;margin-bottom:16px;">
      <button id="runNow" style="background:#1c2230;color:#9bd1ff;border:1px solid #26324a;border-radius:8px;padding:9px 16px;font-size:13px;cursor:pointer;">Run worker now</button>
      <button id="retry" style="background:#2a1f0f;color:#c0a35e;border:1px solid #3a2f1a;border-radius:8px;padding:9px 16px;font-size:13px;cursor:pointer;">Requeue failed</button>
    </div>

    <div style={CARD}>
      <p style={HD}>Delivery log ({log.length})</p>
      {log.length ? (
        <table style="width:100%;border-collapse:collapse;font-size:12.5px;">
          <thead><tr style="text-align:left;color:#8a8a94;font-size:11px;text-transform:uppercase;"><th style="padding:6px 8px;">Job</th><th style="padding:6px 8px;">Kind</th><th style="padding:6px 8px;">Channel</th><th style="padding:6px 8px;">Status</th><th style="padding:6px 8px;">Detail</th></tr></thead>
          <tbody>
            {log.map((l: any) => (
              <tr style="border-top:1px solid #1a1a1f;color:#d6d6de;">
                <td style="padding:6px 8px;font-family:'Geist Mono',monospace;font-size:11px;color:#8a8a94;">{l.job_id}</td>
                <td style="padding:6px 8px;">{l.kind}</td>
                <td style="padding:6px 8px;">{l.channel}</td>
                <td style={'padding:6px 8px;color:' + (l.status === 'sent' || l.status === 'done' ? '#6ee7b7' : l.status === 'retry' ? '#c0a35e' : '#fca5a5')}>{l.status}</td>
                <td style="padding:6px 8px;color:#8a8a94;max-width:240px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{l.detail}</td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : <p style="font-size:12.5px;color:#8a8a94;margin:0;">No deliveries logged yet.</p>}
    </div>
  </div>

  <script is:inline>
    function act(qs, label) {
      var msg = document.getElementById('msg');
      fetch('/api/jobs/run' + qs, { method: 'POST' }).then(function (r) { return r.json(); }).then(function (j) {
        msg.style.display = 'block';
        if (j.ok) { msg.style.background = '#0f2a1c'; msg.style.color = '#6ee7b7'; msg.textContent = label + ' — ' + JSON.stringify(j.health || {}); setTimeout(function () { location.reload(); }, 1000); }
        else { msg.style.background = '#2a0f0f'; msg.style.color = '#fca5a5'; msg.textContent = j.error || 'Failed'; }
      });
    }
    document.getElementById('runNow').addEventListener('click', function () { act('', 'Worker ran'); });
    document.getElementById('retry').addEventListener('click', function () { act('?action=retry', 'Requeued failed'); });
  </script>
</AdminLayout>
