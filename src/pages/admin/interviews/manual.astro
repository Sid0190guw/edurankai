---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { randomBytes } from 'node:crypto';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
function genToken(): string { return randomBytes(18).toString('base64url'); }
let okMsg = '', errMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action');
  try {
    if (action === 'create') {
      const title = (fd.get('title') as string || '').trim();
      const candidateName = (fd.get('candidate_name') as string || '').trim();
      const candidateEmail = (fd.get('candidate_email') as string || '').trim() || null;
      const roleTitle = (fd.get('role_title') as string || '').trim() || null;
      const scheduledAt = (fd.get('scheduled_at') as string || '').trim() ? new Date(fd.get('scheduled_at') as string) : null;
      const duration = parseInt(fd.get('duration_mins') as string || '45') || 45;
      const meetingLink = (fd.get('meeting_link') as string || '').trim() || null;
      const instructions = (fd.get('instructions') as string || '').trim() || null;
      if (!title || !candidateName) { errMsg = 'Title and candidate name are required.'; }
      else {
        await db.execute(sql`
          INSERT INTO manual_interviews (join_token, title, candidate_name, candidate_email, role_title, scheduled_at, duration_mins, meeting_link, instructions, created_by)
          VALUES (${genToken()}, ${title}, ${candidateName}, ${candidateEmail}, ${roleTitle}, ${scheduledAt}, ${duration}, ${meetingLink}, ${instructions}, ${user.id})
        `);
        okMsg = 'Interview scheduled. Share the candidate link from its row.';
      }
    } else if (action === 'delete') {
      const id = (fd.get('id') as string || '').trim();
      if (id) { await db.execute(sql`DELETE FROM manual_interviews WHERE id = ${id}`); okMsg = 'Interview removed.'; }
    } else if (action === 'set_status') {
      const id = (fd.get('id') as string || '').trim();
      const st = (fd.get('status') as string || '').trim();
      if (id && ['scheduled','in_progress','completed','cancelled'].includes(st)) { await db.execute(sql`UPDATE manual_interviews SET status = ${st}, updated_at = NOW() WHERE id = ${id}`); okMsg = 'Status updated.'; }
    }
  } catch (e: any) { errMsg = 'Failed: ' + (e?.message || 'error'); }
}

const list = rows(await db.execute(sql`
  SELECT mi.*, (SELECT COUNT(*)::int FROM interview_panel_scores s WHERE s.interview_id = mi.id) AS judges
  FROM manual_interviews mi ORDER BY mi.created_at DESC LIMIT 200`));
const origin = Astro.url.origin;
const fmt = (d: any) => d ? new Date(d).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day: 'numeric', month: 'short', year: 'numeric', hour: 'numeric', minute: '2-digit' }) : 'Not scheduled';
const STC: Record<string, string> = { scheduled: '#fbbf24', in_progress: '#60a5fa', completed: '#6ee7b7', cancelled: '#fca5a5' };
---
<AdminLayout title="Manual Interviews" activeNav="manual-interviews">
  <div class="admin-page" style="max-width:1200px;">
    <div class="admin-page-header" style="margin-bottom:18px;">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">Interviews</div>
        <h1 class="admin-page-title">Manual interviews</h1>
        <p class="admin-page-sub">Schedule a human-panel interview, share the join link with the candidate, and let the faculty panel score it fairly. The final decision is recorded by an admin.</p>
      </div>
    </div>
    {errMsg && <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 13px;margin-bottom:14px;font-size:12.5px;">{errMsg}</div>}
    {okMsg && <div style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 13px;margin-bottom:14px;font-size:12.5px;">{okMsg}</div>}

    <div style="display:grid;grid-template-columns:1.5fr 1fr;gap:18px;align-items:start;">
      <div style="display:flex;flex-direction:column;gap:10px;">
        {list.map((mi: any) => (
          <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px 16px;">
            <div style="display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;">
              <div>
                <p style="font-size:14px;font-weight:700;color:#fff;margin:0;">{mi.candidate_name} <span style="color:#6e6e78;font-weight:400;">· {mi.title}</span></p>
                <p style="font-size:11.5px;color:#8a8a94;margin:3px 0 0;">{mi.role_title || ''} · {fmt(mi.scheduled_at)} · {mi.duration_mins}m · {mi.judges} judge{mi.judges === 1 ? '' : 's'}</p>
              </div>
              <span style={'font-size:10px;font-family:monospace;text-transform:uppercase;align-self:start;color:' + (STC[mi.status] || '#8a8a94')}>{mi.status}{mi.final_decision ? ' · ' + mi.final_decision : ''}</span>
            </div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-top:10px;">
              <a href={'/admin/interviews/manual/' + mi.id} style="font-size:11px;color:#FF7040;font-weight:600;text-decoration:none;">Panel &amp; decision</a>
              <span style="color:#2a2a30;">|</span>
              <input readonly value={origin + '/interview/' + mi.join_token} onclick="this.select();document.execCommand('copy');" style="flex:1;min-width:160px;font-size:11px;font-family:monospace;background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;padding:5px 8px;border-radius:6px;" title="Click to copy candidate link" />
              {mi.meeting_link && <a href={mi.meeting_link} target="_blank" style="font-size:11px;color:#60a5fa;text-decoration:none;">Meeting</a>}
              <form method="POST" style="display:inline;" onsubmit="return confirm('Delete this interview?');"><input type="hidden" name="action" value="delete" /><input type="hidden" name="id" value={mi.id} /><button type="submit" style="font-size:11px;color:#fca5a5;background:none;border:none;cursor:pointer;">delete</button></form>
            </div>
          </div>
        ))}
        {list.length === 0 && <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:24px;text-align:center;color:#6e6e78;font-size:13px;">No interviews yet.</div>}
      </div>

      <form method="POST" style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:16px;display:flex;flex-direction:column;gap:10px;">
        <input type="hidden" name="action" value="create" />
        <p style="font-size:13px;font-weight:700;color:#fff;margin:0;">+ Schedule interview</p>
        <input name="title" required placeholder="Round title (e.g. Technical Round 1)" class="mif" />
        <input name="candidate_name" required placeholder="Candidate full name" class="mif" />
        <input name="candidate_email" type="email" placeholder="Candidate email (optional)" class="mif" />
        <input name="role_title" placeholder="Role (optional)" class="mif" />
        <label style="font-size:10px;color:#8a8a94;text-transform:uppercase;font-family:monospace;">Scheduled at<input name="scheduled_at" type="datetime-local" class="mif" /></label>
        <input name="duration_mins" type="number" value="45" min="5" placeholder="Duration (mins)" class="mif" />
        <input name="meeting_link" type="url" placeholder="Meeting link (Zoom/Meet/Jitsi)" class="mif" />
        <textarea name="instructions" rows="2" placeholder="Instructions for the candidate (optional)" class="mif"></textarea>
        <button type="submit" class="admin-btn admin-btn-primary" style="justify-content:center;">Schedule &amp; generate link</button>
      </form>
    </div>
  </div>
  <style>
    .mif { width:100%;padding:8px 11px;background:#08080a;border:1px solid #1f1f26;border-radius:6px;color:#fff;font-size:12.5px;font-family:inherit;outline:none; }
    .mif:focus { border-color:#FF4F00; }
  </style>
</AdminLayout>
