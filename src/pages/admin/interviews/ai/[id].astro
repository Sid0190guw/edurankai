---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { proctorEventLabel } from '@/lib/proctor-events';
import { computeRiskScore, riskBand, riskColor } from '@/lib/sentinel';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const { id } = Astro.params;

let session: any = null;
let transcript: any[] = [];
let events: any[] = [];
let stats = { flag: 0, warn: 0, info: 0, total: 0 };

try {
  const r = await db.execute(sql`
    SELECT s.*, t.title as template_title, t.slug as template_slug
    FROM ai_interview_sessions s LEFT JOIN ai_interview_templates t ON s.template_id = t.id
    WHERE s.id = ${id} LIMIT 1
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  session = rows[0] || null;
} catch (_) {}

if (!session) return Astro.redirect('/admin/interviews/ai');

try {
  const r = await db.execute(sql`SELECT turn_index, role, text, lang, is_follow_up, client_ts FROM ai_interview_transcript WHERE session_id = ${id} ORDER BY turn_index ASC`);
  transcript = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`SELECT event_type, severity, detail, client_ts, created_at FROM ai_interview_events WHERE session_id = ${id} ORDER BY created_at ASC LIMIT 2000`);
  events = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

for (const e of events as any[]) {
  stats.total++;
  if (e.severity === 'flag') stats.flag++;
  else if (e.severity === 'warn') stats.warn++;
  else stats.info++;
}

// Recompute risk from the full log so it's always current even if events were
// inserted out of band. Stored risk_score may differ slightly during a live session.
const recomputedRisk = computeRiskScore(events as any);
const storedRisk = Number(session.risk_score || 0);
const displayRisk = Math.max(recomputedRisk, storedRisk);
const band = riskBand(displayRisk);
const bandColor = riskColor(displayRisk);
const fp = session.fingerprint || null;

function fmtTime(d: any) {
  if (!d) return '-';
  try { return new Date(d).toLocaleString('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit', second: '2-digit' }); } catch { return d; }
}
function dur() {
  if (!session.ended_at || !session.started_at) return '-';
  const ms = new Date(session.ended_at).getTime() - new Date(session.started_at).getTime();
  const m = Math.floor(ms / 60000); const r = Math.floor((ms % 60000) / 1000);
  return m + 'm ' + r + 's';
}
const sevColor = (s: string) => s === 'flag' ? '#ef4444' : s === 'warn' ? '#fbbf24' : '#8a8a94';
---
<AdminLayout title={'AI session ' + (id || '').slice(0,8)} activeNav="ai-interviews">
  <div style="max-width:1280px;margin:0 auto;padding:24px;">

    <a href="/admin/interviews/ai" style="font-size:11px;color:#FF7040;text-decoration:none;font-weight:600;display:inline-block;margin-bottom:10px;">&lt; All sessions</a>

    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:18px 22px;margin-bottom:16px;">
      <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 4px;">Session {session.id.slice(0,8)}</p>
      <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">{session.candidate_name || session.candidate_email || 'Anonymous candidate'}</h1>
      <p style="font-size:12.5px;color:#a0a0ab;margin:6px 0 0;">{session.candidate_email} &middot; {session.template_title}</p>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-top:16px;">
        <div style={'background:' + bandColor + '22;border:1px solid ' + bandColor + ';border-radius:10px;padding:10px 12px;'}>
          <p style="font-size:10px;color:#6e6e78;text-transform:uppercase;font-family:'Geist Mono',monospace;margin:0 0 4px;">Sentinel risk</p>
          <p style={'font-size:18px;font-weight:800;margin:0;font-family:Geist Mono,monospace;color:' + bandColor + ';'}>{displayRisk}<span style="font-size:11px;opacity:0.7;">/100</span></p>
          <p style={'font-size:10px;text-transform:uppercase;font-family:Geist Mono,monospace;margin:2px 0 0;color:' + bandColor + ';font-weight:600;'}>{band}</p>
        </div>
        <div style="background:#15151a;border:1px solid #1a1a1f;border-radius:10px;padding:10px 12px;">
          <p style="font-size:10px;color:#6e6e78;text-transform:uppercase;font-family:'Geist Mono',monospace;margin:0 0 4px;">Strikes</p>
          <p style="font-size:18px;font-weight:800;margin:0;font-family:Geist Mono,monospace;color:#fff;">{session.strikes_count || 0}</p>
        </div>
        {[
          ['Status', session.status, session.status === 'auto_terminated' ? '#ef4444' : ''],
          ['Language', session.language, ''],
          ['Duration', dur(), ''],
          ['Turns', transcript.length, ''],
          ['Flag events', stats.flag, '#ef4444'],
          ['Warn events', stats.warn, '#fbbf24'],
          ['Tab switches', session.tab_switches || 0, ''],
          ['FS exits', session.fullscreen_exits || 0, ''],
          ['Started', fmtTime(session.started_at), ''],
          ['Ended', fmtTime(session.ended_at), ''],
        ].map(([label, value, color]) => (
          <div style="background:#15151a;border:1px solid #1a1a1f;border-radius:10px;padding:10px 12px;">
            <p style="font-size:10px;color:#6e6e78;text-transform:uppercase;font-family:'Geist Mono',monospace;margin:0 0 4px;">{label}</p>
            <p style={'font-size:14px;font-weight:700;margin:0;font-family:Geist Mono,monospace;color:' + (color || '#fff') + ';'}>{value || (value === 0 ? '0' : '-')}</p>
          </div>
        ))}
      </div>

      {session.auto_terminated_reason && (
        <div style="margin-top:14px;background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.35);border-radius:10px;padding:10px 14px;">
          <p style="font-size:10px;color:#fca5a5;font-family:'Geist Mono',monospace;text-transform:uppercase;margin:0 0 2px;">Auto-terminated</p>
          <p style="font-size:13px;color:#fff;margin:0;font-family:'Geist Mono',monospace;">{session.auto_terminated_reason}</p>
        </div>
      )}

      {fp && (
        <details style="margin-top:14px;background:#0d1117;border:1px solid #1a1a1f;border-radius:10px;padding:10px 14px;">
          <summary style="cursor:pointer;font-size:11.5px;color:#fff;font-weight:700;">Browser fingerprint</summary>
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px;margin-top:10px;">
            {fp.ua && <div><p style="font-size:9.5px;color:#6e6e78;font-family:'Geist Mono',monospace;text-transform:uppercase;margin:0;">User-agent</p><p style="font-size:11px;color:#d8d8de;margin:2px 0 0;word-break:break-word;">{fp.ua}</p></div>}
            {fp.platform && <div><p style="font-size:9.5px;color:#6e6e78;font-family:'Geist Mono',monospace;text-transform:uppercase;margin:0;">Platform</p><p style="font-size:11.5px;color:#d8d8de;margin:2px 0 0;">{fp.platform}</p></div>}
            {fp.tz && <div><p style="font-size:9.5px;color:#6e6e78;font-family:'Geist Mono',monospace;text-transform:uppercase;margin:0;">Timezone</p><p style="font-size:11.5px;color:#d8d8de;margin:2px 0 0;">{fp.tz}</p></div>}
            {fp.lang && <div><p style="font-size:9.5px;color:#6e6e78;font-family:'Geist Mono',monospace;text-transform:uppercase;margin:0;">Locale</p><p style="font-size:11.5px;color:#d8d8de;margin:2px 0 0;">{fp.lang}</p></div>}
            {fp.screen && <div><p style="font-size:9.5px;color:#6e6e78;font-family:'Geist Mono',monospace;text-transform:uppercase;margin:0;">Screen</p><p style="font-size:11.5px;color:#d8d8de;margin:2px 0 0;font-family:'Geist Mono',monospace;">{fp.screen.w}×{fp.screen.h} @ {fp.screen.dpr}x · avail {fp.screen.availW}×{fp.screen.availH}</p></div>}
            {fp.inner && <div><p style="font-size:9.5px;color:#6e6e78;font-family:'Geist Mono',monospace;text-transform:uppercase;margin:0;">Window</p><p style="font-size:11.5px;color:#d8d8de;margin:2px 0 0;font-family:'Geist Mono',monospace;">{fp.inner.w}×{fp.inner.h}</p></div>}
            {fp.cores != null && <div><p style="font-size:9.5px;color:#6e6e78;font-family:'Geist Mono',monospace;text-transform:uppercase;margin:0;">CPU cores</p><p style="font-size:11.5px;color:#d8d8de;margin:2px 0 0;">{fp.cores}</p></div>}
            {fp.memGb != null && <div><p style="font-size:9.5px;color:#6e6e78;font-family:'Geist Mono',monospace;text-transform:uppercase;margin:0;">Memory</p><p style="font-size:11.5px;color:#d8d8de;margin:2px 0 0;">{fp.memGb} GB</p></div>}
            {fp.touchPoints != null && <div><p style="font-size:9.5px;color:#6e6e78;font-family:'Geist Mono',monospace;text-transform:uppercase;margin:0;">Touch points</p><p style="font-size:11.5px;color:#d8d8de;margin:2px 0 0;">{fp.touchPoints}</p></div>}
          </div>
        </details>
      )}

      {session.face_descriptor && (
        <p style="margin-top:10px;font-size:11px;color:#6ee7b7;font-family:'Geist Mono',monospace;">Identity reference enrolled (128-d descriptor) - identity verification was active.</p>
      )}
    </div>

    <div style="display:grid;grid-template-columns:1.3fr 1fr;gap:14px;align-items:flex-start;">
      <!-- Transcript -->
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;overflow:hidden;">
        <div style="padding:12px 18px;background:#15151a;border-bottom:1px solid #1a1a1f;display:flex;align-items:center;justify-content:space-between;gap:10px;">
          <h2 style="font-size:13px;font-weight:700;color:#fff;margin:0;">Transcript &middot; {transcript.length} turns</h2>
          <p style="font-size:10.5px;color:#8a8a94;font-family:'Geist Mono',monospace;">lang: {session.language}</p>
        </div>
        {transcript.length === 0 && <p style="padding:20px;color:#8a8a94;font-size:12px;text-align:center;">No turns yet.</p>}
        <div style="max-height:680px;overflow-y:auto;padding:8px;">
          {transcript.map((t: any) => (
            <div style={'padding:10px 14px;border-bottom:1px solid #15151a;'}>
              <p style={'font-size:10px;text-transform:uppercase;letter-spacing:0.08em;font-family:Geist Mono,monospace;margin:0 0 5px;color:' + (t.role === 'ai' ? '#FF7040' : '#10b981') + ';'}>
                {t.role === 'ai' ? 'AI Interviewer' : 'Candidate'} &middot; #{t.turn_index} &middot; {t.lang || ''}{t.is_follow_up ? ' &middot; FOLLOW-UP' : ''}
              </p>
              <p style="font-size:13.5px;color:#d8d8de;margin:0;line-height:1.55;white-space:pre-wrap;">{t.text}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Event log -->
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;overflow:hidden;">
        <div style="padding:12px 18px;background:#15151a;border-bottom:1px solid #1a1a1f;">
          <h2 style="font-size:13px;font-weight:700;color:#fff;margin:0;">Activity log &middot; {events.length} events</h2>
          <p style="font-size:10.5px;color:#8a8a94;margin:4px 0 0;">text-only, no audio/video stored</p>
        </div>
        {events.length === 0 && <p style="padding:20px;color:#8a8a94;font-size:12px;text-align:center;">No events.</p>}
        <div style="max-height:680px;overflow-y:auto;">
          {events.map((e: any) => (
            <div style="display:grid;grid-template-columns:6px 1fr 50px;gap:10px;padding:7px 14px;border-bottom:1px solid #15151a;align-items:flex-start;">
              <div style={'width:6px;height:6px;border-radius:50%;background:' + sevColor(e.severity) + ';margin-top:5px;'}></div>
              <div style="min-width:0;">
                <p style={'font-size:12px;font-weight:600;margin:0;color:' + (e.severity === 'flag' ? '#fca5a5' : e.severity === 'warn' ? '#fbbf24' : '#d8d8de') + ';'}>{proctorEventLabel(e.event_type)}</p>
                <p style="font-size:10px;color:#6e6e78;margin:2px 0 0;font-family:'Geist Mono',monospace;">{fmtTime(e.client_ts || e.created_at)}</p>
                {e.detail && Object.keys(e.detail).length > 0 && (
                  <p style="font-size:10px;color:#6e6e78;margin:2px 0 0;font-family:'Geist Mono',monospace;word-break:break-word;">{JSON.stringify(e.detail)}</p>
                )}
              </div>
              <p style={'font-size:9.5px;text-transform:uppercase;text-align:right;font-family:Geist Mono,monospace;margin:0;color:' + sevColor(e.severity) + ';'}>{e.severity}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</AdminLayout>
