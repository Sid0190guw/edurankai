---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const { id } = Astro.params;
let interview: any = null;
let existingCard: any = null;
let okMsg = '', errorMsg = '';

try {
  const r = await db.execute(sql`
    SELECT ir.*, a.first_name, a.last_name, a.email as candidate_email, a.role_title_snapshot, a.application_number
    FROM interview_rounds ir
    LEFT JOIN applications a ON ir.application_id = a.id
    WHERE ir.id = ${id} LIMIT 1
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  interview = rows[0] || null;

  const r2 = await db.execute(sql`SELECT * FROM interview_scorecards WHERE interview_id = ${id} AND interviewer_id = ${user.id} LIMIT 1`);
  const r2rows = Array.isArray(r2) ? r2 : (r2?.rows || []);
  existingCard = r2rows[0] || null;
} catch(e) {}

if (!interview) return Astro.redirect('/admin/interviews');

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  try {
    const techScore = parseInt(fd.get('technical_score') as string || '0');
    const commScore = parseInt(fd.get('communication_score') as string || '0');
    const cultScore = parseInt(fd.get('culture_score') as string || '0');
    const psScore = parseInt(fd.get('problem_solving_score') as string || '0');
    const overall = ((techScore + commScore + cultScore + psScore) / 4).toFixed(2);
    const recommendation = fd.get('recommendation') as string;
    const strengths = fd.get('strengths') as string;
    const weaknesses = fd.get('weaknesses') as string;
    const notes = fd.get('notes') as string;

    await db.execute(sql`
      INSERT INTO interview_scorecards
        (interview_id, interviewer_id, technical_score, communication_score, culture_score, problem_solving_score, overall_score, recommendation, strengths, weaknesses, notes)
      VALUES (${id}, ${user.id}, ${techScore}, ${commScore}, ${cultScore}, ${psScore}, ${overall}, ${recommendation}, ${strengths||null}, ${weaknesses||null}, ${notes||null})
      ON CONFLICT (interview_id, interviewer_id) DO UPDATE SET
        technical_score=${techScore}, communication_score=${commScore}, culture_score=${cultScore},
        problem_solving_score=${psScore}, overall_score=${overall}, recommendation=${recommendation},
        strengths=${strengths||null}, weaknesses=${weaknesses||null}, notes=${notes||null}, submitted_at=NOW()
    `);

    // Update interview's aggregate score
    await db.execute(sql`
      UPDATE interview_rounds SET
        final_score = (SELECT AVG(overall_score) FROM interview_scorecards WHERE interview_id = ${id}),
        final_recommendation = ${recommendation},
        updated_at = NOW()
      WHERE id = ${id}
    `);

    return Astro.redirect('/admin/interviews?saved=1');
  } catch(e: any) { errorMsg = e.message; }
}

const scheduledLocal = interview.scheduled_at ? new Date(interview.scheduled_at).toISOString() : '';
---
<AdminLayout title="Interview Scorecard" activeNav="hr">
<style>
  .score-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 6px; margin-top: 8px; }
  .score-radio { display: flex; flex-direction: column; align-items: center; gap: 4px; padding: 10px 4px; background: #15151a; border: 1px solid #1a1a1f; border-radius: 8px; cursor: pointer; transition: all 0.15s; }
  .score-radio input { display: none; }
  .score-radio:hover { border-color: #FF4F00; }
  .score-radio:has(input:checked) { background: rgba(255,79,0,0.15); border-color: #FF4F00; }
  .score-num { font-size: 18px; font-weight: 800; color: #d8d8de; }
  .score-radio:has(input:checked) .score-num { color: #FF7040; }
  .score-label { font-size: 9px; color: #6e6e78; text-transform: uppercase; letter-spacing: 0.05em; }
  .ev-input { width: 100%; background: #15151a; border: 1px solid #1a1a1f; border-radius: 8px; padding: 10px 12px; color: #fff; font-size: 13px; outline: none; font-family: inherit; resize: vertical; }
  .ev-input:focus { border-color: #FF4F00; }
</style>
<div style="padding-bottom:80px;">
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;">
    <a href="/admin/interviews" style="font-size:11px;color:#6e6e78;text-decoration:none;display:inline-flex;align-items:center;gap:4px;margin-bottom:8px;">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      Back to interviews
    </a>
    <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Interview Scorecard</h1>
    <p style="font-size:12px;color:#8a8a94;margin:4px 0 0;">{interview.first_name} {interview.last_name} - Round {interview.round_number}</p>
  </div>

  {errorMsg && <div style="margin:10px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}

  <div style="padding:14px 16px;max-width:760px;">
    <!-- Candidate summary -->
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;margin-bottom:14px;display:flex;align-items:center;gap:12px;">
      <div style="width:40px;height:40px;border-radius:50%;background:rgba(255,79,0,0.15);display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;color:#FF7040;flex-shrink:0;">{interview.first_name?.charAt(0)}</div>
      <div style="flex:1;min-width:0;">
        <p style="font-size:14px;font-weight:700;color:#fff;margin:0;">{interview.first_name} {interview.last_name}</p>
        <p style="font-size:11px;color:#8a8a94;margin:0;">{interview.role_title_snapshot} - {interview.application_number}</p>
      </div>
      <div style="text-align:right;flex-shrink:0;">
        <p style="font-size:11px;color:#6e6e78;margin:0;" data-ts={scheduledLocal}>{interview.scheduled_at}</p>
        <p style="font-size:10px;color:#6e6e78;margin:0;text-transform:capitalize;">{interview.round_type?.replace('_',' ')}</p>
      </div>
    </div>

    <form method="POST">
      <!-- Score sliders -->
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:18px;margin-bottom:14px;">
        <p style="font-size:13px;font-weight:700;color:#fff;margin:0 0 14px;">Rate the candidate (1=Poor, 5=Excellent)</p>

        {[
          { key: 'technical_score', label: 'Technical Skill', desc: 'Domain knowledge, depth' },
          { key: 'communication_score', label: 'Communication', desc: 'Clarity, articulation' },
          { key: 'problem_solving_score', label: 'Problem Solving', desc: 'Analysis, creativity' },
          { key: 'culture_score', label: 'Culture Fit', desc: 'Alignment with values' },
        ].map((s) => (
          <div style="margin-bottom:16px;">
            <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:4px;">
              <p style="font-size:12px;font-weight:600;color:#fff;margin:0;">{s.label}</p>
              <p style="font-size:10px;color:#6e6e78;margin:0;">{s.desc}</p>
            </div>
            <div class="score-grid">
              {[1,2,3,4,5].map(n => (
                <label class="score-radio">
                  <input type="radio" name={s.key} value={n} required checked={existingCard && existingCard[s.key] === n}/>
                  <span class="score-num">{n}</span>
                  <span class="score-label">{n===1?'Poor':n===2?'Weak':n===3?'OK':n===4?'Good':'Excellent'}</span>
                </label>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Recommendation -->
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:18px;margin-bottom:14px;">
        <p style="font-size:13px;font-weight:700;color:#fff;margin:0 0 10px;">Recommendation</p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
          {[
            { v: 'strong_hire', label: 'Strong Hire', color: '#10b981' },
            { v: 'hire', label: 'Hire', color: '#6ee7b7' },
            { v: 'no_hire', label: 'No Hire', color: '#fbbf24' },
            { v: 'strong_no_hire', label: 'Strong No Hire', color: '#ef4444' },
          ].map(r => (
            <label style={`background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;cursor:pointer;display:flex;align-items:center;gap:8px;`}>
              <input type="radio" name="recommendation" value={r.v} required checked={existingCard?.recommendation === r.v} style="accent-color:#FF4F00;"/>
              <span style={`width:8px;height:8px;border-radius:50%;background:${r.color};`}></span>
              <span style="font-size:12px;font-weight:600;color:#fff;">{r.label}</span>
            </label>
          ))}
        </div>
      </div>

      <!-- Strengths & Weaknesses -->
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:18px;margin-bottom:14px;">
        <div style="margin-bottom:14px;">
          <p style="font-size:12px;font-weight:600;color:#fff;margin:0 0 6px;">Strengths</p>
          <textarea name="strengths" rows="3" class="ev-input" placeholder="What stood out positively?">{existingCard?.strengths || ''}</textarea>
        </div>
        <div>
          <p style="font-size:12px;font-weight:600;color:#fff;margin:0 0 6px;">Weaknesses / Concerns</p>
          <textarea name="weaknesses" rows="3" class="ev-input" placeholder="What gaps or red flags?">{existingCard?.weaknesses || ''}</textarea>
        </div>
      </div>

      <!-- Notes -->
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:18px;margin-bottom:16px;">
        <p style="font-size:12px;font-weight:600;color:#fff;margin:0 0 6px;">Detailed Notes (private)</p>
        <textarea name="notes" rows="5" class="ev-input" placeholder="Questions asked, specific answers, observations...">{existingCard?.notes || ''}</textarea>
      </div>

      <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-size:14px;font-weight:700;padding:13px;border-radius:10px;cursor:pointer;">{existingCard ? 'Update Scorecard' : 'Submit Scorecard'}</button>
    </form>
  </div>
</div>
<script is:inline>
document.querySelectorAll('[data-ts]').forEach(function(el) {
  var ts = el.getAttribute('data-ts');
  if (!ts) return;
  var d = new Date(ts);
  el.textContent = d.toLocaleString(undefined, { weekday:'short', day:'numeric', month:'short', hour:'numeric', minute:'2-digit' });
});
</script>
</AdminLayout>
