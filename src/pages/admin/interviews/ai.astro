---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

let sessions: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT s.id, s.candidate_name, s.candidate_email, s.language, s.status, s.started_at, s.ended_at,
      t.title as template_title, t.slug as template_slug,
      (SELECT COUNT(*)::int FROM ai_interview_transcript WHERE session_id = s.id) as turn_count,
      (SELECT COUNT(*)::int FROM ai_interview_events WHERE session_id = s.id AND severity IN ('warn','flag')) as flag_count
    FROM ai_interview_sessions s LEFT JOIN ai_interview_templates t ON s.template_id = t.id
    ORDER BY s.started_at DESC NULLS LAST LIMIT 200
  `);
  sessions = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

function ago(d: any) {
  if (!d) return '-';
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins + 'm ago';
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return hrs + 'h ago';
  return Math.floor(hrs / 24) + 'd ago';
}
function dur(s: any) {
  if (!s.ended_at || !s.started_at) return '-';
  const ms = new Date(s.ended_at).getTime() - new Date(s.started_at).getTime();
  const m = Math.floor(ms / 60000); const r = Math.floor((ms % 60000) / 1000);
  return m + 'm ' + r + 's';
}
---
<AdminLayout title="AI Interview Sessions" activeNav="ai-interviews">
  <div style="max-width:1280px;margin:0 auto;padding:24px;">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:14px;flex-wrap:wrap;margin-bottom:18px;">
      <div>
        <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">AI Interviews</p>
        <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Sessions</h1>
        <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:680px;line-height:1.55;">Every AI-conducted interview session with its transcript turn count and proctoring flag count. Click into a session to see the full transcript and event log.</p>
      </div>
      <a href="/admin/ai-interview-templates" style="background:#FF4F00;color:#fff;border:none;font-size:12px;font-weight:700;padding:8px 14px;border-radius:8px;text-decoration:none;">Templates &amp; questions</a>
    </div>

    {sessions.length === 0 && (
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:30px;text-align:center;color:#8a8a94;font-size:13px;">No sessions yet. Send candidates to the published interview URL to begin.</div>
    )}

    {sessions.length > 0 && (
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;overflow:hidden;">
        <div style="display:grid;grid-template-columns:1.4fr 1.4fr 80px 100px 100px 90px 80px 1fr;gap:10px;padding:10px 14px;background:#15151a;border-bottom:1px solid #1a1a1f;font-size:10px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.08em;font-weight:700;">
          <div>Candidate</div><div>Template</div><div>Lang</div><div>Status</div><div>Started</div><div>Duration</div><div>Flags</div><div></div>
        </div>
        {sessions.map((s: any) => (
          <a href={'/admin/interviews/ai/' + s.id} style="display:grid;grid-template-columns:1.4fr 1.4fr 80px 100px 100px 90px 80px 1fr;gap:10px;padding:11px 14px;border-bottom:1px solid #15151a;text-decoration:none;color:#fff;align-items:center;">
            <div style="min-width:0;">
              <p style="font-size:12.5px;font-weight:600;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{s.candidate_name || s.candidate_email || 'Anonymous'}</p>
              <p style="font-size:10.5px;color:#8a8a94;margin:2px 0 0;font-family:'Geist Mono',monospace;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{s.candidate_email}</p>
            </div>
            <p style="font-size:11.5px;color:#d8d8de;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{s.template_title || '-'}</p>
            <p style="font-size:11px;color:#a0a0ab;margin:0;font-family:'Geist Mono',monospace;">{s.language}</p>
            <p style="font-size:11px;margin:0;">{s.status}</p>
            <p style="font-size:11px;color:#a0a0ab;margin:0;font-family:'Geist Mono',monospace;">{ago(s.started_at)}</p>
            <p style="font-size:11px;color:#a0a0ab;margin:0;font-family:'Geist Mono',monospace;">{dur(s)}</p>
            <p style="font-size:11.5px;margin:0;">
              {s.flag_count > 0
                ? <span style="background:rgba(239,68,68,0.18);color:#fca5a5;padding:2px 8px;border-radius:100px;font-weight:700;">{s.flag_count}</span>
                : <span style="color:#10b981;font-weight:600;">clean</span>}
            </p>
            <p style="font-size:11px;color:#FF7040;font-weight:600;margin:0;">{s.turn_count} turns &rarr;</p>
          </a>
        ))}
      </div>
    )}
  </div>
</AdminLayout>
