---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get('status') || 'open';
const activeId = url.searchParams.get('c') || '';

let conversations: any[] = [];
let activeConv: any = null;
let activeMessages: any[] = [];
let unreadCount = 0;

try {
  const r = await db.execute(sql`
    SELECT c.id, c.visitor_name, c.visitor_email, c.visitor_path, c.status,
      c.message_count, c.unread_admin, c.last_message_at, c.last_message_by,
      c.last_message_preview, c.created_at,
      u.name as assigned_name
    FROM help_conversations c
    LEFT JOIN users u ON c.assigned_to = u.id
    ${statusFilter === 'all' ? sql`` : sql`WHERE c.status = ${statusFilter}`}
    ORDER BY c.last_message_at DESC NULLS LAST, c.created_at DESC LIMIT 200
  `);
  conversations = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM help_conversations WHERE status = 'open' AND unread_admin > 0`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  unreadCount = (rows[0] as any)?.n || 0;
} catch (_) {}

if (activeId) {
  try {
    const r = await db.execute(sql`
      SELECT c.*, u.name as assigned_name FROM help_conversations c
      LEFT JOIN users u ON c.assigned_to = u.id
      WHERE c.id = ${activeId} LIMIT 1
    `);
    const rows = Array.isArray(r) ? r : (r?.rows || []);
    activeConv = rows[0] || null;
  } catch (_) {}
  if (activeConv) {
    try {
      const r = await db.execute(sql`
        SELECT id, sender_role, sender_name, body, created_at
        FROM help_messages WHERE conversation_id = ${activeId}
        ORDER BY created_at ASC LIMIT 500
      `);
      activeMessages = Array.isArray(r) ? r : (r?.rows || []);
    } catch (_) {}
    // Mark as read
    await db.execute(sql`UPDATE help_conversations SET unread_admin = 0 WHERE id = ${activeId}`);
  }
}

function timeAgo(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins + 'm ago';
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return hrs + 'h ago';
  const days = Math.floor(hrs / 24);
  if (days < 7) return days + 'd ago';
  return new Date(d).toLocaleDateString('en-IN', { day: '2-digit', month: 'short' });
}
function formatTime(d: any) {
  if (!d) return '';
  return new Date(d).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' });
}
---
<AdminLayout title="Help Inbox" activeNav="help">
<div style="display:grid;grid-template-columns:320px 1fr;height:calc(100vh - 70px);background:#0a0a0c;" class="help-grid">

  <!-- LEFT: Conversation list -->
  <aside style="background:#0f0f14;border-right:1px solid #1a1a1f;display:flex;flex-direction:column;overflow:hidden;">
    <div style="padding:14px 16px;border-bottom:1px solid #1a1a1f;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
        <div>
          <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">Help</p>
          <h1 style="font-size:16px;font-weight:700;color:#fff;margin:0;line-height:1.2;">Inbox{unreadCount > 0 ? ' (' + unreadCount + ')' : ''}</h1>
        </div>
      </div>
      <div style="display:flex;gap:6px;">
        {[['open','Open'],['closed','Closed'],['all','All']].map(([v,l]) => (
          <a href={'?status=' + v} style={'text-decoration:none;font-size:10.5px;font-weight:600;padding:4px 10px;border-radius:100px;' + (statusFilter === v ? 'background:#FF4F00;color:#fff;' : 'background:#15151a;color:#8a8a94;border:1px solid #1a1a1f;')}>{l}</a>
        ))}
      </div>
    </div>
    <div style="flex:1;overflow-y:auto;">
      {conversations.length === 0 && (
        <div style="padding:40px 16px;text-align:center;color:#6e6e78;font-size:12px;">
          No {statusFilter === 'all' ? '' : statusFilter} conversations yet.
        </div>
      )}
      {conversations.map((c) => {
        const isActive = c.id === activeId;
        const isUnread = c.unread_admin > 0;
        const name = c.visitor_name || c.visitor_email || 'Anonymous visitor';
        return (
          <a href={'?c=' + c.id + '&status=' + statusFilter} style={'display:block;padding:12px 14px;text-decoration:none;border-bottom:1px solid #15151a;' + (isActive ? 'background:rgba(255,79,0,0.08);border-left:3px solid #FF4F00;' : isUnread ? 'background:#13131a;' : '') + 'transition:background 0.12s;'}>
            <div style="display:flex;align-items:center;justify-content:space-between;gap:6px;margin-bottom:4px;">
              <p style={'font-size:12.5px;font-weight:' + (isUnread ? '700' : '600') + ';color:#fff;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;min-width:0;flex:1;'}>{name}</p>
              {isUnread && <span style="background:#FF4F00;color:#fff;font-size:9px;font-weight:700;padding:1px 6px;border-radius:100px;flex-shrink:0;">{c.unread_admin}</span>}
            </div>
            <p style="font-size:11.5px;color:#8a8a94;margin:0 0 4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;line-height:1.4;">
              {c.last_message_by === 'admin' ? 'You: ' : ''}{c.last_message_preview || '(no message yet)'}
            </p>
            <p style="font-size:10px;color:#6e6e78;margin:0;font-family:'Geist Mono',monospace;">
              {timeAgo(c.last_message_at || c.created_at)}
              {c.visitor_path && <span> &middot; from {c.visitor_path}</span>}
            </p>
          </a>
        );
      })}
    </div>
  </aside>

  <!-- RIGHT: Active thread or empty state -->
  <main style="display:flex;flex-direction:column;background:#08080a;min-width:0;overflow:hidden;">
    {!activeConv ? (
      <div style="flex:1;display:flex;align-items:center;justify-content:center;flex-direction:column;color:#6e6e78;padding:40px;text-align:center;">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom:14px;opacity:0.5;"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
        <p style="font-size:14px;color:#d8d8de;margin:0 0 4px;">Select a conversation</p>
        <p style="font-size:12px;margin:0;">Visitor messages from the site's help widget land here.</p>
      </div>
    ) : (
      <>
        <header style="padding:12px 18px;border-bottom:1px solid #1a1a1f;display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;">
          <div style="min-width:0;flex:1;">
            <p style="font-size:14px;font-weight:600;color:#fff;margin:0;">{activeConv.visitor_name || activeConv.visitor_email || 'Anonymous visitor'}</p>
            <p style="font-size:11px;color:#6e6e78;margin:2px 0 0;display:flex;flex-wrap:wrap;gap:6px 10px;align-items:center;">
              {activeConv.visitor_email && (
                <span><a href={'mailto:' + activeConv.visitor_email} style="color:#FF7040;text-decoration:none;">{activeConv.visitor_email}</a></span>
              )}
              {activeConv.visitor_phone && (
                <span><a href={'tel:' + activeConv.visitor_phone} style="color:#FF7040;text-decoration:none;">{activeConv.visitor_phone}</a></span>
              )}
              {activeConv.visitor_dob && (
                <span style="color:#a0a0ab;">DOB {new Date(activeConv.visitor_dob).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' })}</span>
              )}
              {activeConv.visitor_path && <span>from {activeConv.visitor_path}</span>}
              <span>{activeConv.message_count} message{activeConv.message_count === 1 ? '' : 's'}</span>
              <span>status: {activeConv.status}</span>
            </p>
          </div>
          <div style="display:flex;gap:6px;">
            {activeConv.status === 'open' ? (
              <button id="closeBtn" type="button" style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;font-size:11px;font-weight:600;padding:6px 12px;border-radius:6px;cursor:pointer;">Close</button>
            ) : (
              <button id="reopenBtn" type="button" style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;font-size:11px;font-weight:600;padding:6px 12px;border-radius:6px;cursor:pointer;">Reopen</button>
            )}
          </div>
        </header>

        <div id="messageStream" style="flex:1;overflow-y:auto;padding:18px;display:flex;flex-direction:column;gap:12px;">
          {activeMessages.length === 0 && (
            <p style="text-align:center;color:#6e6e78;font-size:12px;font-style:italic;padding:20px;">No messages in this conversation yet.</p>
          )}
          {activeMessages.map((msg: any) => {
            const isAdmin = msg.sender_role === 'admin';
            const isSystem = msg.sender_role === 'system';
            return (
              <div style={'display:flex;flex-direction:column;align-items:' + (isAdmin ? 'flex-end' : 'flex-start') + ';'}>
                {!isSystem && (
                  <p style="font-size:10.5px;color:#6e6e78;margin-bottom:3px;font-family:'Geist Mono',monospace;">
                    {isAdmin ? (msg.sender_name || 'You') : (msg.sender_name || activeConv.visitor_name || 'Visitor')} &middot; {formatTime(msg.created_at)}
                  </p>
                )}
                <div style={'max-width:78%;padding:10px 14px;border-radius:14px;font-size:13.5px;line-height:1.5;word-wrap:break-word;white-space:pre-wrap;' + (isSystem ? 'background:#15151a;color:#8a8a94;font-style:italic;border:1px solid #1a1a1f;align-self:center;max-width:90%;text-align:center;font-size:11.5px;' : isAdmin ? 'background:#FF4F00;color:#fff;' : 'background:#15151a;color:#d8d8de;border:1px solid #1a1a1f;')}>
                  {msg.body}
                </div>
              </div>
            );
          })}
        </div>

        <footer style="padding:14px 18px;border-top:1px solid #1a1a1f;background:#0a0a0c;">
          <form id="replyForm" style="display:flex;gap:8px;align-items:flex-end;">
            <textarea id="replyBody" required rows="2" placeholder="Type your reply..." maxlength="5000" style="flex:1;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:9px 12px;color:#fff;font-size:14px;font-family:inherit;outline:none;resize:none;line-height:1.5;max-height:160px;"></textarea>
            <button type="submit" id="sendBtn" style="background:#FF4F00;border:none;border-radius:8px;padding:10px 22px;color:#fff;font-weight:600;font-size:13.5px;cursor:pointer;height:44px;">Send</button>
          </form>
          <p style="font-size:10.5px;color:#6e6e78;margin-top:6px;line-height:1.5;">
            <kbd style="background:#15151a;border:1px solid #1a1a1f;padding:1px 5px;border-radius:3px;font-size:9.5px;">Enter</kbd> to send &middot;
            <kbd style="background:#15151a;border:1px solid #1a1a1f;padding:1px 5px;border-radius:3px;font-size:9.5px;">Shift+Enter</kbd> new line &middot; auto-refreshes every 5s
          </p>
        </footer>
      </>
    )}
  </main>
</div>

<style>
  @media (max-width: 768px) {
    .help-grid { grid-template-columns: 1fr !important; }
    .help-grid > aside { display: none; }
  }
</style>

{activeConv && (
  <script is:inline define:vars={{ conversationId: activeConv.id, lastMessageTs: activeMessages.length > 0 ? activeMessages[activeMessages.length - 1].created_at : '1970-01-01T00:00:00Z' }}>
    (function() {
      var stream = document.getElementById('messageStream');
      var form = document.getElementById('replyForm');
      var input = document.getElementById('replyBody');
      var sendBtn = document.getElementById('sendBtn');
      var closeBtn = document.getElementById('closeBtn');
      var reopenBtn = document.getElementById('reopenBtn');
      var lastTs = lastMessageTs;

      function formatTime(iso) {
        try { return new Date(iso).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' }); } catch (e) { return ''; }
      }
      function escapeHtml(s) {
        return (s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      }
      function appendMessage(m) {
        var isAdmin = m.sender_role === 'admin';
        var wrap = document.createElement('div');
        wrap.style.cssText = 'display:flex;flex-direction:column;align-items:' + (isAdmin ? 'flex-end' : 'flex-start') + ';';
        wrap.innerHTML =
          '<p style="font-size:10.5px;color:#6e6e78;margin-bottom:3px;font-family:Geist Mono,monospace;">' +
            (isAdmin ? (m.sender_name || 'You') : (m.sender_name || 'Visitor')) + ' &middot; ' + formatTime(m.created_at) +
          '</p>' +
          '<div style="max-width:78%;padding:10px 14px;border-radius:14px;font-size:13.5px;line-height:1.5;word-wrap:break-word;white-space:pre-wrap;' +
            (isAdmin ? 'background:#FF4F00;color:#fff;' : 'background:#15151a;color:#d8d8de;border:1px solid #1a1a1f;') + '">' +
            escapeHtml(m.body).replace(/\n/g, '<br/>') +
          '</div>';
        stream.appendChild(wrap);
        stream.scrollTop = stream.scrollHeight;
      }

      // Send
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var body = input.value.trim();
        if (!body) return;
        sendBtn.disabled = true; sendBtn.textContent = 'Sending...';
        fetch('/api/admin/help/reply', {
          method: 'POST', credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ conversationId: conversationId, body: body })
        }).then(function(r) { return r.json(); }).then(function(d) {
          sendBtn.disabled = false; sendBtn.textContent = 'Send';
          if (d.ok) {
            input.value = '';
            if (d.message) { appendMessage(d.message); lastTs = d.message.created_at; }
          } else {
            alert(d.error || 'Failed to send');
          }
        }).catch(function() { sendBtn.disabled = false; sendBtn.textContent = 'Send'; alert('Network error'); });
      });

      // Enter to send, Shift+Enter newline
      input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); form.dispatchEvent(new Event('submit', { cancelable: true })); }
      });

      // Poll every 5s for new visitor messages
      setInterval(function() {
        fetch('/api/admin/help/thread?id=' + encodeURIComponent(conversationId), { credentials: 'same-origin' })
          .then(function(r) { return r.json(); })
          .then(function(d) {
            if (!d.ok || !d.messages) return;
            var rendered = stream.children.length;
            if (d.messages.length > rendered) {
              for (var i = rendered; i < d.messages.length; i++) appendMessage(d.messages[i]);
              lastTs = d.messages[d.messages.length - 1].created_at;
            }
          }).catch(function() {});
      }, 5000);

      // Close / reopen
      function setStatus(s) {
        fetch('/api/admin/help/reply', {
          method: 'POST', credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ conversationId: conversationId, body: s === 'closed' ? '(Conversation closed)' : '(Conversation reopened)', closeAfter: s === 'closed' })
        }).then(function(r) { return r.json(); }).then(function() { location.reload(); });
      }
      if (closeBtn) closeBtn.addEventListener('click', function() { if (confirm('Close this conversation?')) setStatus('closed'); });
      if (reopenBtn) reopenBtn.addEventListener('click', function() { setStatus('open'); });

      stream.scrollTop = stream.scrollHeight;
    })();
  </script>
)}
</AdminLayout>
