---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');

let okMsg = '', errorMsg = '';
let enrolled = false;
let enrolledAt = null;

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  try {
    if (action === 'enroll') {
      const descriptor = fd.get('face_descriptor') as string;
      const deviceInfo = fd.get('device_info') as string;
      if (!descriptor) { errorMsg = 'No face data received.'; }
      else {
        const parsed = JSON.parse(descriptor);
        if (!Array.isArray(parsed) || parsed.length !== 128) {
          errorMsg = 'Invalid face data. Please try again.';
        } else {
          await db.execute(sql`
            INSERT INTO user_face_enrollments (user_id, face_descriptor, device_info)
            VALUES (${user.id}, ${descriptor}, ${deviceInfo || null})
            ON CONFLICT (user_id) DO UPDATE SET
              face_descriptor = ${descriptor},
              device_info = ${deviceInfo || null},
              enrolled_at = NOW(),
              is_active = true
          `);
          okMsg = 'Face enrolled successfully. Face 2FA is now active for your account.';
          enrolled = true;
        }
      }
    } else if (action === 'remove') {
      await db.execute(sql`UPDATE user_face_enrollments SET is_active = false WHERE user_id = ${user.id}`);
      okMsg = 'Face 2FA removed. Login will use password only.';
      enrolled = false;
    }
  } catch(e: any) { errorMsg = e.message; }
}

// Check if already enrolled
try {
  const r = await db.execute(sql`SELECT enrolled_at, device_info, is_active FROM user_face_enrollments WHERE user_id = ${user.id} LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  if (rows.length > 0 && (rows[0] as any).is_active) {
    enrolled = true;
    enrolledAt = (rows[0] as any).enrolled_at;
  }
} catch(e) {}
---
<AdminLayout title="Face 2FA Enrollment" activeNav="settings">
<div style="padding-bottom:80px;">
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">Security</p>
    <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Face 2FA Enrollment</h1>
  </div>

  {errorMsg && <div style="margin:10px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  <div style="padding:16px;display:flex;flex-direction:column;gap:14px;">

    <!-- Status card -->
    <div style={`background:#0f0f14;border:1px solid ${enrolled ? 'rgba(16,185,129,0.3)' : '#1a1a1f'};border-radius:12px;padding:16px;display:flex;align-items:center;gap:14px;`}>
      <div style={`width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:${enrolled ? 'rgba(16,185,129,0.15)' : '#15151a'};`}>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke={enrolled ? '#10b981' : '#6e6e78'} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
        </svg>
      </div>
      <div style="flex:1;">
        <p style={`font-size:14px;font-weight:600;margin:0;color:${enrolled ? '#10b981' : '#fff'};`}>{enrolled ? 'Face 2FA Active' : 'Face 2FA Not Enrolled'}</p>
        <p style="font-size:12px;color:#6e6e78;margin:3px 0 0;">
          {enrolled ? `Enrolled - login requires face verification` : 'Enroll your face to add an extra layer of security'}
        </p>
      </div>
    </div>

    <!-- How it works -->
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;">
      <p style="font-size:12px;font-weight:600;color:#fff;margin:0 0 10px;">How Face 2FA works</p>
      {[
        'Your face is converted to a mathematical descriptor (128 numbers) - no photo is stored',
        'On login: enter password first, then verify your face via camera',
        'Face matching happens entirely in your browser - nothing is sent to any server',
        'Works on any device with a camera - phone, laptop, tablet',
      ].map((item, i) => (
        <div style="display:flex;align-items:flex-start;gap:10px;margin-bottom:8px;">
          <div style="width:18px;height:18px;border-radius:50%;background:#FF4F0022;border:1px solid #FF4F0044;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:#FF7040;flex-shrink:0;margin-top:1px;">{i+1}</div>
          <p style="font-size:12px;color:#8a8a94;margin:0;line-height:1.5;">{item}</p>
        </div>
      ))}
    </div>

    <!-- Camera enrollment -->
    {!enrolled && (
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
        <div style="padding:14px 16px;border-bottom:1px solid #1a1a1f;">
          <p style="font-size:13px;font-weight:600;color:#fff;margin:0;">Enroll Your Face</p>
          <p style="font-size:11px;color:#6e6e78;margin:4px 0 0;">Position your face in the frame and click Capture</p>
        </div>
        <div style="padding:16px;">
          <!-- Camera view -->
          <div style="position:relative;background:#000;border-radius:10px;overflow:hidden;margin-bottom:12px;aspect-ratio:4/3;">
            <video id="videoEl" autoplay playsinline muted style="width:100%;height:100%;object-fit:cover;display:block;transform:scaleX(-1);"></video>
            <canvas id="canvasEl" style="display:none;"></canvas>
            <div id="faceOverlay" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;">
              <div style="width:160px;height:200px;border:2px solid rgba(255,79,0,0.6);border-radius:50%;"></div>
            </div>
            <div id="cameraStatus" style="position:absolute;bottom:12px;left:0;right:0;text-align:center;">
              <span style="background:rgba(0,0,0,0.7);color:#fff;font-size:11px;padding:4px 12px;border-radius:100px;">Starting camera...</span>
            </div>
          </div>
          <div id="loadingBar" style="background:#15151a;border-radius:100px;height:3px;margin-bottom:12px;display:none;">
            <div id="loadingProg" style="background:#FF4F00;height:100%;width:0%;border-radius:100px;transition:width 0.3s;"></div>
          </div>
          <button id="captureBtn" onclick="startCapture()" disabled style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;opacity:0.5;">Loading face detection...</button>
        </div>
      </div>
    )}

    <!-- Remove enrollment -->
    {enrolled && (
      <form method="POST">
        <input type="hidden" name="action" value="remove" />
        <button type="submit" onclick="return confirm('Remove Face 2FA? You will only need password to login.')" style="width:100%;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);color:#fca5a5;font-weight:600;font-size:13px;padding:12px;border-radius:10px;cursor:pointer;">Remove Face 2FA</button>
      </form>
    )}

    <!-- Re-enroll if already enrolled -->
    {enrolled && (
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
        <div style="padding:14px 16px;border-bottom:1px solid #1a1a1f;">
          <p style="font-size:13px;font-weight:600;color:#fff;margin:0;">Re-enroll Face</p>
          <p style="font-size:11px;color:#6e6e78;margin:4px 0 0;">Update your face data if recognition is failing</p>
        </div>
        <div style="padding:16px;">
          <div style="position:relative;background:#000;border-radius:10px;overflow:hidden;margin-bottom:12px;aspect-ratio:4/3;">
            <video id="videoEl" autoplay playsinline muted style="width:100%;height:100%;object-fit:cover;display:block;transform:scaleX(-1);"></video>
            <div id="faceOverlay" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;">
              <div style="width:160px;height:200px;border:2px solid rgba(16,185,129,0.6);border-radius:50%;"></div>
            </div>
            <div id="cameraStatus" style="position:absolute;bottom:12px;left:0;right:0;text-align:center;">
              <span style="background:rgba(0,0,0,0.7);color:#fff;font-size:11px;padding:4px 12px;border-radius:100px;">Starting camera...</span>
            </div>
          </div>
          <button id="captureBtn" onclick="startCapture()" disabled style="width:100%;background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;font-weight:600;font-size:13px;padding:12px;border-radius:10px;cursor:pointer;opacity:0.5;">Loading face detection...</button>
        </div>
      </div>
    )}

  </div>
</div>

<!-- Hidden form for enrollment submission -->
<form id="enrollForm" method="POST" style="display:none;">
  <input type="hidden" name="action" value="enroll" />
  <input type="hidden" id="faceDescriptorInput" name="face_descriptor" />
  <input type="hidden" id="deviceInfoInput" name="device_info" />
</form>

<!-- TensorFlow.js + face-api.js -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/face-api.js/0.22.2/face-api.min.js"></script>
<script is:inline>
var videoEl = document.getElementById('videoEl');
var canvasEl = document.getElementById('canvasEl');
var captureBtn = document.getElementById('captureBtn');
var statusEl = document.getElementById('cameraStatus');
var loadingBar = document.getElementById('loadingBar');
var loadingProg = document.getElementById('loadingProg');
var stream = null;
var modelsLoaded = false;

function setStatus(msg, color) {
  if (statusEl) statusEl.innerHTML = '<span style="background:rgba(0,0,0,0.7);color:' + (color||'#fff') + ';font-size:11px;padding:4px 12px;border-radius:100px;">' + msg + '</span>';
}

async function init() {
  try {
    setStatus('Loading face detection models...');
    if (loadingBar) loadingBar.style.display = 'block';
    
    var MODEL_URL = 'https://cdn.jsdelivr.net/npm/@vladmandic/face-api@latest/model';
    await Promise.all([
      faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL),
      faceapi.nets.faceLandmark68TinyNet.loadFromUri(MODEL_URL),
      faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL),
    ]);
    if (loadingProg) loadingProg.style.width = '60%';
    modelsLoaded = true;
    
    stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: 640, height: 480 } });
    if (videoEl) videoEl.srcObject = stream;
    if (loadingProg) loadingProg.style.width = '100%';
    
    setTimeout(function() {
      if (loadingBar) loadingBar.style.display = 'none';
      setStatus('Position your face in the oval', '#10b981');
      if (captureBtn) {
        captureBtn.disabled = false;
        captureBtn.style.opacity = '1';
        captureBtn.textContent = 'Capture & Enroll Face';
      }
    }, 500);
    
    // Live detection loop
    detectLoop();
  } catch(e) {
    setStatus('Camera error: ' + e.message, '#ef4444');
    console.error(e);
  }
}

async function detectLoop() {
  if (!videoEl || !modelsLoaded) return;
  try {
    var det = await faceapi.detectSingleFace(videoEl, new faceapi.TinyFaceDetectorOptions()).withFaceLandmarks(true);
    if (det) {
      setStatus('Face detected - ready to capture', '#10b981');
      if (captureBtn) captureBtn.style.background = '#10b981';
    } else {
      setStatus('No face detected - adjust position', '#fbbf24');
      if (captureBtn) captureBtn.style.background = '#FF4F00';
    }
  } catch(e) {}
  setTimeout(detectLoop, 500);
}

async function startCapture() {
  if (!modelsLoaded || !videoEl) return;
  if (captureBtn) { captureBtn.disabled = true; captureBtn.textContent = 'Capturing...'; }
  setStatus('Analyzing face...', '#fbbf24');
  
  try {
    // Capture 3 samples and average them for better accuracy
    var descriptors = [];
    for (var i = 0; i < 3; i++) {
      var det = await faceapi.detectSingleFace(videoEl, new faceapi.TinyFaceDetectorOptions())
        .withFaceLandmarks(true)
        .withFaceDescriptor();
      if (det) descriptors.push(Array.from(det.descriptor));
      await new Promise(function(r) { setTimeout(r, 300); });
    }
    
    if (descriptors.length === 0) {
      setStatus('No face detected. Please try again.', '#ef4444');
      if (captureBtn) { captureBtn.disabled = false; captureBtn.textContent = 'Capture & Enroll Face'; }
      return;
    }
    
    // Average the descriptors
    var avg = new Array(128).fill(0);
    descriptors.forEach(function(d) { d.forEach(function(v, i) { avg[i] += v / descriptors.length; }); });
    
    document.getElementById('faceDescriptorInput').value = JSON.stringify(avg);
    document.getElementById('deviceInfoInput').value = navigator.userAgent;
    
    setStatus('Face captured! Saving...', '#10b981');
    document.getElementById('enrollForm').submit();
  } catch(e) {
    setStatus('Error: ' + e.message, '#ef4444');
    if (captureBtn) { captureBtn.disabled = false; captureBtn.textContent = 'Capture & Enroll Face'; }
  }
}

// Start on load
if (videoEl) init();
</script>
</AdminLayout>
