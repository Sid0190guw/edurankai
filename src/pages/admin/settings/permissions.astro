---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { can } from '@/lib/auth/permissions';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (!can(user, 'settings.edit')) return Astro.redirect('/admin');

let okMsg = '';
let errorMsg = '';

const ALL_PAGES = [
  { id: 'dashboard', label: 'Dashboard', group: 'Core' },
  { id: 'applications', label: 'Applications', group: 'Core' },
  { id: 'offers', label: 'Offer Letters', group: 'Core' },
  { id: 'roles', label: 'Roles', group: 'Core' },
  { id: 'departments', label: 'Departments', group: 'Core' },
  { id: 'events', label: 'Events', group: 'Core' },
  { id: 'users', label: 'Users', group: 'Core' },
  { id: 'content', label: 'Content Pages', group: 'Core' },
  { id: 'products', label: 'Products', group: 'Core' },
  { id: 'settings', label: 'Settings', group: 'Core' },
  { id: 'hr', label: 'HR Management', group: 'HR' },
  { id: 'hr.employees', label: 'Employees', group: 'HR' },
  { id: 'hr.leave', label: 'Leave', group: 'HR' },
  { id: 'hr.attendance', label: 'Attendance', group: 'HR' },
  { id: 'hr.payroll', label: 'Payroll', group: 'HR' },
  { id: 'hei', label: 'HEI Institutions', group: 'HEI' },
  { id: 'hei.import', label: 'HEI CSV Import', group: 'HEI' },
  { id: 'hei.score', label: 'HEI Scoring', group: 'HEI' },
  { id: 'hei.findings', label: 'HEI Findings', group: 'HEI' },
  { id: 'hei.stories', label: 'HEI Stories', group: 'HEI' },
  { id: 'hei.claims', label: 'HEI Claims', group: 'HEI' },
  { id: 'hei.submissions', label: 'HEI Submissions', group: 'HEI' },
  { id: 'messages', label: 'DMs', group: 'Communication' },
  { id: 'chat', label: 'Discussion', group: 'Communication' },
  { id: 'notifications', label: 'Notifications', group: 'Communication' },
  { id: 'audit', label: 'Audit Log', group: 'System' },
];

const ALL_ROLES = ['super_admin', 'admin', 'editor', 'reviewer', 'recruiter', 'marketing', 'department_head'];

const ROLE_LABELS: Record<string, string> = {
  super_admin: 'Super Admin', admin: 'Admin', editor: 'Editor',
  reviewer: 'Reviewer', recruiter: 'Recruiter', marketing: 'Marketing',
  department_head: 'Dept Head',
};

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;

  try {
    if (action === 'update_permissions') {
      const role = fd.get('role') as string;
      if (!ALL_ROLES.includes(role)) throw new Error('Invalid role');

      for (const page of ALL_PAGES) {
        const canView = fd.get(`perm_${page.id}_view`) === 'on';
        const canEdit = fd.get(`perm_${page.id}_edit`) === 'on';

        await db.execute(sql`
          INSERT INTO role_page_permissions (role, page_id, can_view, can_edit, updated_at, updated_by_user_id)
          VALUES (${role}, ${page.id}, ${canView}, ${canEdit}, NOW(), ${user.id})
          ON CONFLICT (role, page_id)
          DO UPDATE SET can_view = ${canView}, can_edit = ${canEdit}, updated_at = NOW(), updated_by_user_id = ${user.id}
        `);
      }
      okMsg = `Permissions updated for ${ROLE_LABELS[role] || role}.`;
    }
  } catch (e: any) {
    errorMsg = 'Error: ' + (e.message || 'Unknown');
  }
}

const url = new URL(Astro.request.url);
const selectedRole = url.searchParams.get('role') || 'admin';

// Load current permissions for selected role
const permsResult = await db.execute(sql`
  SELECT page_id, can_view, can_edit FROM role_page_permissions WHERE role = ${selectedRole}
`);
const permsMap: Record<string, { view: boolean; edit: boolean }> = {};
for (const row of (permsResult?.rows || []) as any[]) {
  permsMap[row.page_id] = { view: row.can_view, edit: row.can_edit };
}

// Group pages
const groups: Record<string, typeof ALL_PAGES> = {};
for (const page of ALL_PAGES) {
  if (!groups[page.group]) groups[page.group] = [];
  groups[page.group].push(page);
}
---
<AdminLayout title="Role Permissions" activeNav="settings">
<div style="padding-bottom:80px;">

  <!-- Header -->
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="margin-bottom:12px;">
      <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">System</p>
      <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Role Permissions</h1>
    </div>
    <!-- Role selector -->
    <div style="display:flex;gap:6px;overflow-x:auto;padding-bottom:2px;">
      {ALL_ROLES.map(r => (
        <a href={`?role=${r}`} style={`text-decoration:none;font-size:11px;font-weight:600;padding:5px 12px;border-radius:100px;white-space:nowrap;flex-shrink:0;${selectedRole === r ? 'background:#FF4F00;color:#fff;' : 'background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;'}`}>
          {ROLE_LABELS[r]}
        </a>
      ))}
    </div>
  </div>

  {errorMsg && <div style="margin:10px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  {selectedRole === 'super_admin' && (
    <div style="margin:12px 16px;background:rgba(255,79,0,0.08);border:1px solid rgba(255,79,0,0.2);border-radius:8px;padding:10px 14px;">
      <p style="font-size:12px;color:#FF7040;margin:0;">Super Admin always has full access to everything. Permissions here are ignored for super_admin.</p>
    </div>
  )}

  <form method="POST" style="padding:12px 16px;display:flex;flex-direction:column;gap:12px;">
    <input type="hidden" name="action" value="update_permissions" />
    <input type="hidden" name="role" value={selectedRole} />

    {Object.entries(groups).map(([groupName, pages]) => (
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
        <div style="padding:10px 14px;border-bottom:1px solid #1a1a1f;display:flex;align-items:center;justify-content:space-between;">
          <p style="font-size:12px;font-weight:700;color:#fff;margin:0;text-transform:uppercase;letter-spacing:0.08em;">{groupName}</p>
          <div style="display:flex;gap:12px;">
            <span style="font-size:10px;color:#6e6e78;width:36px;text-align:center;">View</span>
            <span style="font-size:10px;color:#6e6e78;width:36px;text-align:center;">Edit</span>
          </div>
        </div>
        {pages.map(page => {
          const perm = permsMap[page.id] || { view: false, edit: false };
          return (
            <div style="padding:10px 14px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid #0a0a0c;">
              <span style="font-size:13px;color:#d8d8de;">{page.label}</span>
              <div style="display:flex;gap:12px;">
                <div style="width:36px;text-align:center;">
                  <input type="checkbox" name={`perm_${page.id}_view`} style="accent-color:#FF4F00;width:16px;height:16px;" checked={perm.view} />
                </div>
                <div style="width:36px;text-align:center;">
                  <input type="checkbox" name={`perm_${page.id}_edit`} style="accent-color:#FF4F00;width:16px;height:16px;" checked={perm.edit} />
                </div>
              </div>
            </div>
          );
        })}
      </div>
    ))}

    <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">
      Save Permissions for {ROLE_LABELS[selectedRole] || selectedRole}
    </button>
  </form>

</div>
</AdminLayout>
