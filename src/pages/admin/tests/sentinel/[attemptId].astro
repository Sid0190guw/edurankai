---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { proctorEventLabel } from '@/lib/proctor-events';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const { attemptId } = Astro.params;

let attempt: any = null;
let events: any[] = [];
let initialFlag = 0;
let initialWarn = 0;

try {
  const r = await db.execute(sql`
    SELECT a.*, t.title as test_title, t.slug as test_slug
    FROM test_attempts a LEFT JOIN tests t ON a.test_id = t.id
    WHERE a.id = ${attemptId} LIMIT 1
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  attempt = rows[0] || null;
} catch (_) {}

if (!attempt) return Astro.redirect('/admin/tests/attempts');

try {
  const r = await db.execute(sql`
    SELECT id, event_type, severity, detail, client_ts, created_at
    FROM test_attempt_events WHERE attempt_id = ${attemptId}
    ORDER BY created_at DESC LIMIT 80
  `);
  events = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

for (const e of events as any[]) {
  if (e.severity === 'flag') initialFlag++;
  else if (e.severity === 'warn') initialWarn++;
}

const isLive = attempt.status === 'in_progress';
const integrity = Math.max(0, 100 - (initialFlag * 5 + initialWarn * 1.5));

function fmtTime(d: any) { try { return new Date(d).toLocaleTimeString('en-IN', { timeZone: 'Asia/Kolkata', hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false }); } catch { return ''; } }
function dur() {
  if (!attempt.started_at) return '-';
  const end = attempt.ended_at || attempt.submitted_at || Date.now();
  const ms = new Date(end).getTime() - new Date(attempt.started_at).getTime();
  const m = Math.floor(ms / 60000); const r = Math.floor((ms % 60000) / 1000);
  return m + 'm ' + r + 's';
}
---
<AdminLayout title={'Sentinel - ' + attemptId.slice(0,8)} activeNav="tests">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Instrument+Serif:ital@0;1&display=swap" />
  <style>
    .sentinel { --bg:#0b0d10; --surface:#14181d; --surface-2:#1c2128; --surface-3:#242a32; --border:#2a3038; --ink:#f4f1ea; --ink-2:#c8c3b8; --ink-3:#8a8579; --terracotta:#d97757; --ok:#7dd3a8; --warn:#f0b54f; --bad:#e07a6c; --info:#7fb3ff; --font-sans:"Space Grotesk",system-ui,sans-serif; --font-mono:"JetBrains Mono",ui-monospace,monospace; --font-serif:"Instrument Serif",serif; background:var(--bg); color:var(--ink); padding:24px; min-height:calc(100vh - 70px); font-family:var(--font-sans); }
    .sentinel .scene-header { display:flex; align-items:flex-end; justify-content:space-between; gap:16px; flex-wrap:wrap; margin-bottom:18px; }
    .sentinel .scene-header .left { min-width:0; flex:1; }
    .sentinel .scene-header .chip { font-family:var(--font-mono); font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ok); background:rgba(125,211,168,0.08); border:1px solid rgba(125,211,168,0.3); padding:4px 10px; border-radius:999px; display:inline-flex; align-items:center; gap:6px; }
    .sentinel .scene-header h1 { font-family:var(--font-serif); font-size:clamp(28px,4vw,40px); font-weight:400; margin:8px 0 0; color:var(--ink); }
    .sentinel .scene-header .sub { font-family:var(--font-sans); font-size:13px; color:var(--ink-2); margin:6px 0 0; }
    .sentinel .scene-header .live-pill { font-family:var(--font-mono); font-size:11px; letter-spacing:0.16em; text-transform:uppercase; background:var(--bg); border:1px solid var(--border); padding:6px 14px; border-radius:999px; color:var(--ink-2); display:inline-flex; align-items:center; gap:8px; }
    .sentinel .live-pill .dot { width:8px; height:8px; border-radius:50%; background:var(--ok); box-shadow:0 0 12px var(--ok); animation:pulse 1.2s infinite; }
    @keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.4; } }

    .sentinel .grid { display:grid; grid-template-columns:1.4fr 1fr; gap:16px; margin-bottom:16px; }
    .sentinel .card { background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:18px 20px; }
    .sentinel .card h3 { font-family:var(--font-mono); font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-3); margin:0 0 12px; font-weight:500; }

    /* KPI row */
    .sentinel .kpis { display:grid; grid-template-columns:repeat(auto-fit,minmax(140px,1fr)); gap:10px; margin-bottom:16px; }
    .sentinel .kpis .tile { background:var(--surface); border:1px solid var(--border); border-radius:10px; padding:12px 14px; }
    .sentinel .kpis .tile p:first-child { font-family:var(--font-mono); font-size:9px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-3); margin:0 0 4px; font-weight:500; }
    .sentinel .kpis .tile p:last-child { font-family:var(--font-mono); font-size:18px; font-weight:600; color:var(--ink); margin:0; font-variant-numeric:tabular-nums; }
    .sentinel .kpis .tile.warn p:last-child { color:var(--warn); }
    .sentinel .kpis .tile.bad p:last-child { color:var(--bad); }

    /* Signal cards */
    .sentinel .signal { display:flex; align-items:center; justify-content:space-between; gap:10px; padding:10px 14px; border-bottom:1px solid var(--border); }
    .sentinel .signal:last-child { border-bottom:0; }
    .sentinel .signal .label { font-family:var(--font-mono); font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:var(--ink-2); }
    .sentinel .signal .val { display:inline-flex; align-items:center; gap:8px; font-family:var(--font-mono); font-size:12px; color:var(--ok); font-weight:600; }
    .sentinel .signal .val.warn { color:var(--warn); }
    .sentinel .signal .val.bad { color:var(--bad); }
    .sentinel .signal .val .dot { width:6px; height:6px; border-radius:50%; background:var(--ok); box-shadow:0 0 8px var(--ok); }
    .sentinel .signal .val.warn .dot { background:var(--warn); box-shadow:0 0 8px var(--warn); }
    .sentinel .signal .val.bad .dot { background:var(--bad); box-shadow:0 0 8px var(--bad); }

    /* Integrity gauge */
    .sentinel .gauge-wrap { display:flex; align-items:center; gap:18px; padding:6px 0; }
    .sentinel .gauge { position:relative; width:100px; height:100px; }
    .sentinel .gauge svg { transform:rotate(-90deg); }
    .sentinel .gauge .face { position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; }
    .sentinel .gauge .num { font-family:var(--font-mono); font-size:24px; font-weight:600; color:var(--ink); font-variant-numeric:tabular-nums; }
    .sentinel .gauge .lab { font-family:var(--font-mono); font-size:9px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-3); }

    /* Event stream */
    .sentinel .stream { max-height:560px; overflow-y:auto; }
    .sentinel .event { display:grid; grid-template-columns:90px 8px 1fr 60px; gap:10px; padding:8px 0; border-bottom:1px solid var(--border); align-items:flex-start; }
    .sentinel .event:first-child { border-top:1px solid var(--border); }
    .sentinel .event .ts { font-family:var(--font-mono); font-size:11px; color:var(--ink-3); font-variant-numeric:tabular-nums; }
    .sentinel .event .marker { width:6px; height:6px; border-radius:50%; background:var(--ink-3); margin-top:5px; }
    .sentinel .event.flag .marker { background:var(--bad); box-shadow:0 0 8px var(--bad); }
    .sentinel .event.warn .marker { background:var(--warn); box-shadow:0 0 8px var(--warn); }
    .sentinel .event .body p { margin:0; font-size:12.5px; }
    .sentinel .event .body .name { font-weight:600; color:var(--ink-2); }
    .sentinel .event.flag .body .name { color:var(--bad); }
    .sentinel .event.warn .body .name { color:var(--warn); }
    .sentinel .event .body .detail { color:var(--ink-3); font-family:var(--font-mono); font-size:10px; margin-top:2px; word-break:break-word; }
    .sentinel .event .sev { font-family:var(--font-mono); font-size:9px; letter-spacing:0.16em; text-transform:uppercase; text-align:right; color:var(--ink-3); }
    .sentinel .event.flag .sev { color:var(--bad); }
    .sentinel .event.warn .sev { color:var(--warn); }

    /* Pipeline */
    .sentinel .pipeline { display:flex; align-items:center; gap:8px; flex-wrap:wrap; padding:14px 0; }
    .sentinel .pipeline .stage { background:var(--surface); border:1px solid var(--border); border-radius:10px; padding:10px 14px; }
    .sentinel .pipeline .stage .k { font-family:var(--font-mono); font-size:9px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-3); }
    .sentinel .pipeline .stage .v { font-family:var(--font-mono); font-size:12px; color:var(--ink); margin-top:3px; font-weight:600; }
    .sentinel .pipeline .arrow { color:var(--ink-3); font-family:var(--font-mono); }

    .sentinel .decision { background:linear-gradient(135deg, rgba(125,211,168,0.08), rgba(125,211,168,0.02)); border:1px solid var(--ok); border-radius:10px; padding:14px 16px; }
    .sentinel .decision.warn { background:linear-gradient(135deg, rgba(240,181,79,0.08), rgba(240,181,79,0.02)); border-color:var(--warn); }
    .sentinel .decision.bad { background:linear-gradient(135deg, rgba(224,122,108,0.08), rgba(224,122,108,0.02)); border-color:var(--bad); }
    .sentinel .decision .k { font-family:var(--font-mono); font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-3); }
    .sentinel .decision .v { font-family:var(--font-sans); font-size:14px; color:var(--ink); margin-top:4px; font-weight:600; }

    .sentinel a.back { display:inline-block; font-family:var(--font-mono); font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:var(--terracotta); text-decoration:none; margin-bottom:14px; }
    @media (max-width: 900px) { .sentinel .grid { grid-template-columns:1fr; } }
  </style>

  <div class="sentinel">
    <a href={'/admin/tests/attempts/' + attemptId} class="back">&lt; Back to attempt detail</a>

    <div class="scene-header">
      <div class="left">
        <span class="chip">AI PROCTOR &middot; Sentinel</span>
        <h1>{attempt.candidate_name || attempt.candidate_email || 'Anonymous candidate'}</h1>
        <p class="sub">{attempt.test_title} &middot; session {attemptId.slice(0,8)} &middot; {attempt.status}</p>
      </div>
      <span class="live-pill" id="livePill">
        {isLive && <span class="dot"></span>}
        <span id="liveLabel">{isLive ? 'LIVE - polling every 3s' : 'Replay - attempt closed'}</span>
      </span>
    </div>

    <!-- KPI row -->
    <div class="kpis">
      <div class="tile"><p>Integrity</p><p id="kpiIntegrity">{Math.round(integrity)}%</p></div>
      <div class="tile"><p>Score</p><p>{attempt.percentage != null ? Math.round(attempt.percentage) + '%' : '-'}</p></div>
      <div class="tile"><p>Duration</p><p>{dur()}</p></div>
      <div class="tile warn"><p>Tab switches</p><p id="kpiTabs">{attempt.tab_switches || 0}</p></div>
      <div class="tile warn"><p>Fullscreen exits</p><p>{attempt.fullscreen_exits || 0}</p></div>
      <div class="tile bad"><p>Flag events</p><p id="kpiFlags">{initialFlag}</p></div>
      <div class="tile"><p>Warn events</p><p id="kpiWarns">{initialWarn}</p></div>
    </div>

    <!-- Main two-column -->
    <div class="grid">
      <!-- Live event stream -->
      <div class="card">
        <h3>Event stream &middot; <span id="eventCount">{events.length}</span> events (newest first)</h3>
        <div class="stream" id="stream">
          {events.length === 0 && <p style="font-size:12px;color:var(--ink-3);text-align:center;padding:20px;">No events yet. Stream will populate as the candidate interacts with the test.</p>}
          {events.map((e: any) => (
            <div class={'event ' + (e.severity || 'info')}>
              <p class="ts">{fmtTime(e.client_ts || e.created_at)}</p>
              <span class="marker"></span>
              <div class="body">
                <p class="name">{proctorEventLabel(e.event_type)}</p>
                {e.detail && Object.keys(e.detail).length > 0 && <p class="detail">{JSON.stringify(e.detail)}</p>}
              </div>
              <p class="sev">{e.severity || 'info'}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Signal stack -->
      <div>
        <div class="card" style="margin-bottom:14px;">
          <h3>Integrity gauge</h3>
          <div class="gauge-wrap">
            <div class="gauge">
              <svg width="100" height="100">
                <circle cx="50" cy="50" r="44" stroke="rgba(255,255,255,0.08)" stroke-width="6" fill="none"/>
                <circle id="gaugeRing" cx="50" cy="50" r="44" stroke="#7dd3a8" stroke-width="6" fill="none"
                  stroke-dasharray="276" stroke-dashoffset={276 * (1 - integrity / 100)}
                  stroke-linecap="round"
                  style={'filter: drop-shadow(0 0 6px #7dd3a8aa); transition: stroke-dashoffset 0.5s;'} />
              </svg>
              <div class="face">
                <div class="num" id="gaugeNum">{Math.round(integrity)}%</div>
                <div class="lab">score</div>
              </div>
            </div>
            <div style="flex:1;">
              <p style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink-3);margin:0 0 6px;">Live integrity</p>
              <p style="font-size:13px;color:var(--ink-2);margin:0;line-height:1.5;">Each flag event subtracts 5 points; each warn subtracts 1.5. Below 60 triggers human invigilator review.</p>
            </div>
          </div>
        </div>

        <div class="card" style="margin-bottom:14px;">
          <h3>Signals</h3>
          <div class="signal"><span class="label">Face</span><span class="val" id="sigFace"><span class="dot"></span><span>Steady</span></span></div>
          <div class="signal"><span class="label">Voice</span><span class="val" id="sigVoice"><span class="dot"></span><span>Quiet</span></span></div>
          <div class="signal"><span class="label">Window focus</span><span class="val" id="sigFocus"><span class="dot"></span><span>In tab</span></span></div>
          <div class="signal"><span class="label">Network</span><span class="val" id="sigNet"><span class="dot"></span><span>Online</span></span></div>
        </div>

        <div class="card">
          <h3>Decision pipeline</h3>
          <div class="pipeline">
            <div class="stage"><div class="k">1 &middot; Sensors</div><div class="v">tab &middot; face &middot; voice &middot; focus &middot; net</div></div>
            <span class="arrow">&rsaquo;</span>
            <div class="stage"><div class="k">2 &middot; Anomaly score</div><div class="v" id="pipeAnom">{(initialFlag * 5 + initialWarn * 1.5).toFixed(1)}</div></div>
            <span class="arrow">&rsaquo;</span>
            <div class="stage"><div class="k">3 &middot; Classifier</div><div class="v" id="pipeClass">{initialFlag > 0 ? 'flag' : initialWarn > 0 ? 'warn' : 'clean'}</div></div>
            <span class="arrow">&rsaquo;</span>
            <div class="stage"><div class="k">4 &middot; Policy</div><div class="v" id="pipePol">{integrity < 60 ? 'escalate' : 'continue'}</div></div>
          </div>
          <div class={'decision ' + (integrity < 60 ? 'bad' : integrity < 80 ? 'warn' : '')} id="decisionCard">
            <p class="k">Decision</p>
            <p class="v" id="decisionText">{integrity < 60 ? 'Escalate to human invigilator' : integrity < 80 ? 'Continue with caution - flags observed' : 'Continue - no escalation needed'}</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  {isLive && (
    <script is:inline define:vars={{ attemptId }}>
      (function() {
        var lastTs = null;
        // Compute most recent event ts from rendered DOM to seed polling
        var firstEv = document.querySelector('.sentinel .stream .event .ts');
        if (firstEv) lastTs = new Date().toISOString();
        var stream = document.getElementById('stream');
        var eventCount = document.getElementById('eventCount');
        var counters = { flags: parseInt(document.getElementById('kpiFlags').textContent) || 0,
                         warns: parseInt(document.getElementById('kpiWarns').textContent) || 0,
                         tabs: parseInt(document.getElementById('kpiTabs').textContent) || 0,
                         total: parseInt(eventCount.textContent) || 0 };

        var LABELS = {
          tab_hidden:'Tab hidden (switched away)', tab_visible:'Tab back in focus',
          window_blur:'Window lost focus', window_focus:'Window regained focus',
          fullscreen_enter:'Entered fullscreen', fullscreen_exit:'Exited fullscreen',
          right_click_blocked:'Right-click blocked',
          copy:'Copy', paste:'Paste', cut:'Cut',
          copy_blocked:'Copy blocked', paste_blocked:'Paste blocked',
          keyboard_shortcut_blocked:'Shortcut blocked',
          devtools_suspected:'DevTools suspected',
          network_offline:'Went offline', network_online:'Back online',
          mouse_leave:'Mouse left window', mouse_enter:'Mouse re-entered',
          idle_start:'Idle period started', idle_end:'Idle ended',
          orientation_change:'Orientation changed', resize:'Window resized',
          attempt_listeners_attached:'Test session started',
          media_consent_granted:'Camera + mic permission granted',
          media_consent_denied:'Camera + mic permission denied',
          media_lost:'Camera or mic stream lost',
          face_lost:'No face detected on camera', face_visible:'Face back on camera',
          multiple_faces:'Multiple faces detected', looking_away:'Looking away from screen',
          voice_detected:'Voice / talking detected', voice_silenced:'Voice stopped'
        };
        function escapeHtml(s) { return String(s == null ? '' : s).replace(/[&<>"']/g, function(c) { return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]; }); }
        function fmtTime(d) { try { return new Date(d).toLocaleTimeString('en-IN', { timeZone: 'Asia/Kolkata', hour:'2-digit', minute:'2-digit', second:'2-digit', hour12:false }); } catch(e) { return ''; } }

        function renderEvent(e) {
          var sev = e.severity || 'info';
          var label = LABELS[e.event_type] || e.event_type;
          var detail = e.detail && Object.keys(e.detail).length > 0 ? '<p class="detail">' + escapeHtml(JSON.stringify(e.detail)) + '</p>' : '';
          var d = document.createElement('div');
          d.className = 'event ' + sev;
          d.innerHTML =
            '<p class="ts">' + fmtTime(e.client_ts || e.created_at) + '</p>' +
            '<span class="marker"></span>' +
            '<div class="body"><p class="name">' + escapeHtml(label) + '</p>' + detail + '</div>' +
            '<p class="sev">' + sev + '</p>';
          return d;
        }

        function updateSignals(events) {
          // Look at recent events to derive signal status
          var face = 'Steady', faceCls = '';
          var voice = 'Quiet', voiceCls = '';
          var focus = 'In tab', focusCls = '';
          var net = 'Online', netCls = '';
          for (var i = events.length - 1; i >= 0; i--) {
            var t = events[i].event_type;
            if ((t === 'face_lost' || t === 'multiple_faces' || t === 'looking_away') && face === 'Steady') {
              face = t === 'multiple_faces' ? 'Multiple' : t === 'looking_away' ? 'Looking away' : 'Lost'; faceCls = events[i].severity || 'warn';
            }
            if (t === 'voice_detected' && voice === 'Quiet') { voice = 'Talking'; voiceCls = 'warn'; }
            if ((t === 'tab_hidden' || t === 'window_blur') && focus === 'In tab') { focus = 'Lost focus'; focusCls = 'warn'; }
            if (t === 'network_offline' && net === 'Online') { net = 'Offline'; netCls = 'bad'; }
          }
          function setSig(id, label, cls) {
            var el = document.getElementById(id);
            el.className = 'val' + (cls ? ' ' + cls : '');
            el.innerHTML = '<span class="dot"></span><span>' + label + '</span>';
          }
          setSig('sigFace', face, faceCls);
          setSig('sigVoice', voice, voiceCls);
          setSig('sigFocus', focus, focusCls);
          setSig('sigNet', net, netCls);
        }

        function poll() {
          var url = '/api/admin/tests/attempt-events?id=' + encodeURIComponent(attemptId) + (lastTs ? '&since=' + encodeURIComponent(lastTs) : '');
          fetch(url, { credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .then(function(d) {
              if (!d.ok) return;
              if (d.events && d.events.length > 0) {
                // Prepend new events (newest first)
                d.events.forEach(function(e) {
                  stream.insertBefore(renderEvent(e), stream.firstChild);
                  if (e.severity === 'flag') counters.flags++;
                  else if (e.severity === 'warn') counters.warns++;
                  counters.total++;
                });
                lastTs = d.events[d.events.length - 1].created_at;
                eventCount.textContent = counters.total;
                document.getElementById('kpiFlags').textContent = counters.flags;
                document.getElementById('kpiWarns').textContent = counters.warns;
                // Update integrity gauge
                var integ = Math.max(0, 100 - (counters.flags * 5 + counters.warns * 1.5));
                document.getElementById('gaugeNum').textContent = Math.round(integ) + '%';
                document.getElementById('kpiIntegrity').textContent = Math.round(integ) + '%';
                var ring = document.getElementById('gaugeRing');
                if (ring) {
                  ring.setAttribute('stroke-dashoffset', String(276 * (1 - integ/100)));
                  ring.setAttribute('stroke', integ < 60 ? '#e07a6c' : integ < 80 ? '#f0b54f' : '#7dd3a8');
                  ring.style.filter = 'drop-shadow(0 0 6px ' + (integ < 60 ? '#e07a6caa' : integ < 80 ? '#f0b54faa' : '#7dd3a8aa') + ')';
                }
                document.getElementById('pipeAnom').textContent = (counters.flags * 5 + counters.warns * 1.5).toFixed(1);
                document.getElementById('pipeClass').textContent = counters.flags > 0 ? 'flag' : counters.warns > 0 ? 'warn' : 'clean';
                document.getElementById('pipePol').textContent = integ < 60 ? 'escalate' : 'continue';
                var dc = document.getElementById('decisionCard');
                var dt = document.getElementById('decisionText');
                dc.className = 'decision' + (integ < 60 ? ' bad' : integ < 80 ? ' warn' : '');
                dt.textContent = integ < 60 ? 'Escalate to human invigilator' : integ < 80 ? 'Continue with caution - flags observed' : 'Continue - no escalation needed';
                updateSignals(d.events);
              }
              if (d.counters && d.counters.status && d.counters.status !== 'in_progress') {
                document.getElementById('liveLabel').textContent = 'Closed - ' + d.counters.status;
                var pill = document.getElementById('livePill');
                var dotEl = pill.querySelector('.dot');
                if (dotEl) dotEl.style.background = '#8a8579';
              }
            }).catch(function() {});
        }
        setInterval(poll, 3000);
      })();
    </script>
  )}
</AdminLayout>
