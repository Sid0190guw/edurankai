---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const url = new URL(Astro.request.url);
const testFilter = url.searchParams.get('test') || '';
const flagFilter = url.searchParams.get('flag') || '';

let attempts: any[] = [];
let tests: any[] = [];

try {
  const r = await db.execute(sql`SELECT id, slug, title FROM tests ORDER BY title`);
  tests = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT a.id, a.candidate_name, a.candidate_email, a.percentage, a.status,
      a.started_at, a.submitted_at, a.duration_seconds, a.tab_switches, a.fullscreen_exits,
      t.title as test_title, t.slug as test_slug,
      (SELECT COUNT(*)::int FROM test_attempt_events WHERE attempt_id = a.id AND severity IN ('warn','flag')) as flag_count,
      (SELECT COUNT(*)::int FROM test_attempt_events WHERE attempt_id = a.id) as event_count
    FROM test_attempts a
    LEFT JOIN tests t ON a.test_id = t.id
    ${testFilter ? sql`WHERE t.slug = ${testFilter}` : sql``}
    ORDER BY a.started_at DESC NULLS LAST LIMIT 200
  `);
  attempts = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

if (flagFilter === '1') {
  attempts = attempts.filter((a: any) => (a.flag_count || 0) > 0);
}

function ago(d: any) {
  if (!d) return '-';
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins + 'm ago';
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return hrs + 'h ago';
  return Math.floor(hrs / 24) + 'd ago';
}
function fmtDur(s: number) {
  if (!s) return '-';
  const m = Math.floor(s / 60); const r = s % 60;
  return m + 'm ' + r + 's';
}
---
<AdminLayout title="Test Attempts" activeNav="tests">
  <div style="max-width:1280px;margin:0 auto;padding:24px;">

    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:14px;flex-wrap:wrap;margin-bottom:20px;">
      <div>
        <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Test attempts</p>
        <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Proctored activity log</h1>
        <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:640px;line-height:1.55;">Every test attempt with its proctoring event count. Click an attempt to see the full text-only activity trail (tab switches, copy/paste, blocked shortcuts, focus loss, etc.).</p>
      </div>
      <a href="/admin/tests" style="background:#15151a;border:1px solid #1a1a1f;color:#fff;font-size:12px;font-weight:600;padding:8px 14px;border-radius:8px;text-decoration:none;">&lt; All tests</a>
    </div>

    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;">
      <a href="?" style={'background:' + (!testFilter && flagFilter !== '1' ? '#FF4F00' : '#15151a') + ';border:1px solid #1a1a1f;color:#fff;font-size:11px;font-weight:600;padding:6px 12px;border-radius:100px;text-decoration:none;'}>All attempts</a>
      <a href="?flag=1" style={'background:' + (flagFilter === '1' ? '#FF4F00' : '#15151a') + ';border:1px solid #1a1a1f;color:#fff;font-size:11px;font-weight:600;padding:6px 12px;border-radius:100px;text-decoration:none;'}>Flagged only</a>
      {tests.map(t => (
        <a href={'?test=' + t.slug} style={'background:' + (testFilter === t.slug ? '#FF4F00' : '#15151a') + ';border:1px solid #1a1a1f;color:#fff;font-size:11px;font-weight:600;padding:6px 12px;border-radius:100px;text-decoration:none;max-width:240px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;'}>{t.title}</a>
      ))}
    </div>

    {attempts.length === 0 && (
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:30px;text-align:center;color:#8a8a94;font-size:13px;">No attempts match the current filter.</div>
    )}

    {attempts.length > 0 && (
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;overflow:hidden;">
        <div style="display:grid;grid-template-columns:1.4fr 1.4fr 80px 90px 80px 120px 80px 1fr;gap:10px;padding:10px 14px;background:#15151a;border-bottom:1px solid #1a1a1f;font-size:10px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.08em;font-weight:700;">
          <div>Candidate</div><div>Test</div><div>Score</div><div>Status</div><div>Duration</div><div>Flags</div><div>Events</div><div></div>
        </div>
        {attempts.map(a => (
          <a href={'/admin/tests/attempts/' + a.id} style="display:grid;grid-template-columns:1.4fr 1.4fr 80px 90px 80px 120px 80px 1fr;gap:10px;padding:11px 14px;border-bottom:1px solid #15151a;text-decoration:none;color:#fff;align-items:center;transition:background 0.12s;">
            <div style="min-width:0;">
              <p style="font-size:12.5px;font-weight:600;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{a.candidate_name || a.candidate_email || 'Anonymous'}</p>
              <p style="font-size:10.5px;color:#8a8a94;margin:2px 0 0;font-family:'Geist Mono',monospace;">{ago(a.started_at)}</p>
            </div>
            <p style="font-size:11.5px;color:#d8d8de;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{a.test_title || '-'}</p>
            <p style="font-size:13px;font-weight:700;color:#FF7040;margin:0;font-family:'Geist Mono',monospace;">{a.percentage != null ? Math.round(a.percentage) + '%' : '-'}</p>
            <p style="font-size:11px;margin:0;">{a.status}</p>
            <p style="font-size:11px;color:#a0a0ab;margin:0;font-family:'Geist Mono',monospace;">{fmtDur(a.duration_seconds)}</p>
            <p style="font-size:11.5px;margin:0;">
              {(a.flag_count || 0) > 0
                ? <span style="background:rgba(239,68,68,0.18);color:#fca5a5;padding:2px 8px;border-radius:100px;font-weight:700;">{a.flag_count} flags</span>
                : <span style="color:#10b981;font-weight:600;">clean</span>}
            </p>
            <p style="font-size:11px;color:#8a8a94;font-family:'Geist Mono',monospace;margin:0;">{a.event_count || 0}</p>
            <p style="font-size:11px;color:#FF7040;font-weight:600;margin:0;">View &rarr;</p>
          </a>
        ))}
      </div>
    )}
  </div>
</AdminLayout>
