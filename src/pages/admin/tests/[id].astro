---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const { id } = Astro.params;
let test: any = null;
let questions: any[] = [];
let okMsg = '', errorMsg = '';

try {
  const r = await db.execute(sql`SELECT * FROM tests WHERE id = ${id} LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  test = rows[0] || null;
} catch(e) {}

if (!test) return Astro.redirect('/admin/tests');

// Restricted exams: their questions are limited to designated authority only
// (super admin / HR). Other staff cannot view or edit the question bank.
const isExamAuthority = user.role === 'super_admin' || user.role === 'hr';
if (test.restricted && !isExamAuthority) {
  return Astro.redirect('/admin/tests?denied=restricted');
}

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  try {
    if (action === 'declare_results') {
      await db.execute(sql`UPDATE tests SET results_declared = true, results_declared_at = NOW(), updated_at = NOW() WHERE id = ${id}`);
      okMsg = 'Results declared - candidates can now see their results and ranking.';
      const r = await db.execute(sql`SELECT * FROM tests WHERE id = ${id} LIMIT 1`);
      test = (Array.isArray(r) ? r : (r?.rows || []))[0] || test;
    } else if (action === 'unpublish_results') {
      await db.execute(sql`UPDATE tests SET results_declared = false, results_declared_at = NULL, updated_at = NOW() WHERE id = ${id}`);
      okMsg = 'Results withdrawn from candidates.';
      const r = await db.execute(sql`SELECT * FROM tests WHERE id = ${id} LIMIT 1`);
      test = (Array.isArray(r) ? r : (r?.rows || []))[0] || test;
    } else if (action === 'add_question') {
      const qType = fd.get('question_type') as string;
      const qText = (fd.get('question_text') as string || '').trim();
      const marks = parseInt(fd.get('marks') as string || '1');
      const difficulty = fd.get('difficulty') as string || 'medium';
      const explanation = (fd.get('explanation') as string || '').trim() || null;

      let options: any = [];
      let correctAnswer: any = null;
      let codeStarter: string | null = null;
      let codeLang: string | null = null;
      let testCases: any = [];

      if (qType === 'mcq_single' || qType === 'mcq_multi') {
        const optsRaw = (fd.get('options') as string || '').split('\n').map(s => s.trim()).filter(Boolean);
        options = optsRaw.map((text, i) => ({ id: i, text }));
        if (qType === 'mcq_single') {
          correctAnswer = parseInt(fd.get('correct_index') as string || '0');
        } else {
          correctAnswer = (fd.get('correct_indices') as string || '').split(',').map(s => parseInt(s.trim())).filter(n => !isNaN(n));
        }
      } else if (qType === 'true_false') {
        options = [{id:0,text:'True'},{id:1,text:'False'}];
        correctAnswer = fd.get('correct_index') === '0' ? 0 : 1;
      } else if (qType === 'short_answer' || qType === 'long_answer') {
        correctAnswer = (fd.get('correct_answer') as string || '').trim();
      } else if (qType === 'code') {
        codeStarter = (fd.get('code_starter') as string || '').trim();
        codeLang = fd.get('code_language') as string || 'python';
        const tcRaw = (fd.get('test_cases') as string || '').trim();
        if (tcRaw) {
          try { testCases = JSON.parse(tcRaw); } catch(e) {
            testCases = tcRaw.split('\n').filter(Boolean).map(line => {
              const [input, expected] = line.split('|');
              return { input: (input||'').trim(), expected: (expected||'').trim() };
            });
          }
        }
      }

      const countR = await db.execute(sql`SELECT COUNT(*)::int as c FROM test_questions WHERE test_id = ${id}`);
      const countRows = Array.isArray(countR) ? countR : (countR?.rows || []);
      const sortOrder = ((countRows[0] as any)?.c || 0) + 1;

      await db.execute(sql`
        INSERT INTO test_questions (test_id, question_type, question_text, code_starter, code_language, options, correct_answer, test_cases, marks, difficulty, explanation, sort_order)
        VALUES (${id}, ${qType}, ${qText}, ${codeStarter}, ${codeLang}, ${JSON.stringify(options)}, ${JSON.stringify(correctAnswer)}, ${JSON.stringify(testCases)}, ${marks}, ${difficulty}, ${explanation}, ${sortOrder})
      `);

      // Update test totals
      await db.execute(sql`
        UPDATE tests SET
          total_questions = (SELECT COUNT(*)::int FROM test_questions WHERE test_id = ${id}),
          total_marks = (SELECT COALESCE(SUM(marks),0)::int FROM test_questions WHERE test_id = ${id}),
          updated_at = NOW()
        WHERE id = ${id}
      `);
      okMsg = 'Question added.';
    } else if (action === 'delete_question') {
      await db.execute(sql`DELETE FROM test_questions WHERE id = ${fd.get('qid') as string}`);
      await db.execute(sql`
        UPDATE tests SET
          total_questions = (SELECT COUNT(*)::int FROM test_questions WHERE test_id = ${id}),
          total_marks = (SELECT COALESCE(SUM(marks),0)::int FROM test_questions WHERE test_id = ${id}),
          updated_at = NOW()
        WHERE id = ${id}
      `);
      okMsg = 'Question deleted.';
    } else if (action === 'update_settings') {
      const title = (fd.get('title') as string || '').trim();
      const slug = (fd.get('slug') as string || '').trim().toLowerCase().replace(/[^a-z0-9-]/g, '-');
      const description = (fd.get('description') as string || '').trim() || null;
      const testType = (fd.get('test_type') as string || 'mcq').trim();
      const durationMins = parseInt(fd.get('duration_mins') as string || '60') || 60;
      const passMark = parseInt(fd.get('pass_mark') as string || '60') || 60;
      const questionsToShowRaw = parseInt(fd.get('questions_to_show') as string || '0') || 0;
      const questionsToShow = questionsToShowRaw > 0 ? questionsToShowRaw : null;
      const resultReleaseMode = ((fd.get('result_release_mode') as string) || 'immediate').trim();
      const rankingMode = ((fd.get('ranking_mode') as string) || 'none').trim();
      let negFrac = parseFloat(fd.get('negative_mark_fraction') as string || '0'); if (!(negFrac >= 0 && negFrac <= 1)) negFrac = 0;
      const restricted = fd.get('restricted') === 'on';
      const allowedAttemptsRaw = parseInt(fd.get('allowed_attempts') as string || '0') || 0;
      const allowedAttempts = allowedAttemptsRaw > 0 ? allowedAttemptsRaw : null;
      const availableFrom = (fd.get('available_from') as string || '').trim() ? new Date(fd.get('available_from') as string) : null;
      const availableUntil = (fd.get('available_until') as string || '').trim() ? new Date(fd.get('available_until') as string) : null;
      const accessCode = (fd.get('access_code') as string || '').trim() || null;
      const showCorrect = fd.get('show_correct_answers') === 'on';
      const oneQ = fd.get('one_question_at_a_time') === 'on';
      const currency = (fd.get('currency') as string || 'INR').toUpperCase().slice(0, 3);
      const priceMinor = parseInt(fd.get('price_minor') as string || '0') || 0;
      const isPremium = fd.get('is_premium') === 'on';
      const isPublished = fd.get('is_published') === 'on';
      const randomQ = fd.get('randomize_questions') === 'on';
      const randomO = fd.get('randomize_options') === 'on';
      const showResults = fd.get('show_results_to_candidate') === 'on';
      const proctoringEnabled = fd.get('proctoring_enabled') === 'on';
      const copyPasteBlocked = fd.get('copy_paste_blocked') === 'on';
      const instructions = (fd.get('instructions') as string || '').trim() || null;
      await db.execute(sql`
        UPDATE tests SET
          title = ${title},
          slug = ${slug},
          description = ${description},
          test_type = ${testType},
          duration_mins = ${durationMins},
          pass_mark = ${passMark},
          questions_to_show = ${questionsToShow},
          result_release_mode = ${resultReleaseMode},
          ranking_mode = ${rankingMode},
          negative_mark_fraction = ${negFrac},
          restricted = ${restricted},
          allowed_attempts = ${allowedAttempts},
          available_from = ${availableFrom},
          available_until = ${availableUntil},
          access_code = ${accessCode},
          show_correct_answers = ${showCorrect},
          one_question_at_a_time = ${oneQ},
          currency = ${currency},
          price_inr_paise = ${priceMinor},
          is_premium = ${isPremium},
          is_published = ${isPublished},
          randomize_questions = ${randomQ},
          randomize_options = ${randomO},
          show_results_to_candidate = ${showResults},
          proctoring_enabled = ${proctoringEnabled},
          copy_paste_blocked = ${copyPasteBlocked},
          instructions = ${instructions},
          updated_at = NOW()
        WHERE id = ${id}
      `);
      okMsg = 'Settings saved.';
      // Refresh local test object
      const r = await db.execute(sql`SELECT * FROM tests WHERE id = ${id} LIMIT 1`);
      const rows = Array.isArray(r) ? r : (r?.rows || []);
      test = rows[0] || test;
    } else if (action === 'edit_question') {
      const qid = fd.get('qid') as string;
      const qText = (fd.get('question_text') as string || '').trim();
      const marks = parseInt(fd.get('marks') as string || '1') || 1;
      const difficulty = (fd.get('difficulty') as string) || 'medium';
      const explanation = (fd.get('explanation') as string || '').trim() || null;
      await db.execute(sql`UPDATE test_questions SET question_text = ${qText}, marks = ${marks}, difficulty = ${difficulty}, explanation = ${explanation} WHERE id = ${qid}`);
      okMsg = 'Question updated.';
    }
  } catch(e: any) { errorMsg = e.message; }
}

try {
  const r = await db.execute(sql`SELECT * FROM test_questions WHERE test_id = ${id} ORDER BY sort_order, created_at`);
  questions = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

// Leaderboard (auto-ranked by score) for evaluation in the admin panel.
let leaderboard: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT rank, candidate_name, candidate_email, percentage, total_score, max_score, negative_marks, duration_seconds, tab_switches, fullscreen_exits, id
    FROM test_attempts
    WHERE test_id = ${id} AND status IN ('submitted','auto_submitted')
    ORDER BY rank ASC NULLS LAST, percentage DESC NULLS LAST
    LIMIT 200
  `);
  leaderboard = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const Q_TYPE_LABELS: Record<string,string> = {
  mcq_single:'MCQ (Single)', mcq_multi:'MCQ (Multi)', true_false:'True/False',
  short_answer:'Short Answer', long_answer:'Long Answer', code:'Coding', file_upload:'File Upload', video_response:'Video'
};
---
<AdminLayout title={'Edit: ' + test.title} activeNav="hr">
<div style="padding-bottom:80px;">
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;">
    <a href="/admin/tests" style="font-size:11px;color:#6e6e78;text-decoration:none;display:inline-flex;align-items:center;gap:4px;margin-bottom:6px;">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      Back to tests
    </a>
    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;">
      <div>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">{test.title}</h1>
        <p style="font-size:11px;color:#8a8a94;margin:2px 0 0;">{test.test_type} - {test.duration_mins}min - {questions.length} questions - {test.total_marks} marks total</p>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <a href={`/admin/tests/${id}/translations`} style="background:rgba(96,165,250,0.1);border:1px solid rgba(96,165,250,0.3);color:#93c5fd;font-size:11px;font-weight:600;padding:7px 14px;border-radius:6px;text-decoration:none;">Translations</a>
        {test.is_published && <a href={`/aquintutor/test/${test.slug}`} target="_blank" style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;font-size:11px;font-weight:600;padding:7px 14px;border-radius:6px;text-decoration:none;">View Public</a>}
      </div>
    </div>
  </div>

  {errorMsg && <div style="margin:10px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  <!-- TEST SETTINGS - pricing + premium + publish + meta -->
  <details style="margin:14px 16px;background:#14181d;border:1px solid #2a3038;border-radius:12px;padding:14px 18px;" open={Astro.url.searchParams.get('settings') === '1'}>
    <summary style="cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:#d97757;">Test settings &middot; pricing &middot; publish</summary>
    <form method="POST" style="margin-top:14px;display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;">
      <input type="hidden" name="action" value="update_settings" />

      <div style="grid-column:1/-1;display:grid;grid-template-columns:2fr 1fr 100px 100px;gap:10px;">
        <div><label style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;">Title</label><input name="title" value={test.title} required style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:13px;margin-top:4px;font-family:inherit;" /></div>
        <div><label style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;">Slug</label><input name="slug" value={test.slug} required style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:13px;margin-top:4px;font-family:'JetBrains Mono',monospace;" /></div>
        <div><label style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;">Type</label>
          <select name="test_type" style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:13px;margin-top:4px;font-family:inherit;">
            {['mcq','coding','aptitude','subjective','personality','video','mixed'].map((t) => <option value={t} selected={test.test_type === t}>{t}</option>)}
          </select>
        </div>
        <div><label style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;">Duration (min)</label><input name="duration_mins" type="number" min="1" value={test.duration_mins || 60} style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:13px;margin-top:4px;font-family:'JetBrains Mono',monospace;" /></div>
      </div>

      <div style="grid-column:1/-1;">
        <label style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;">Description</label>
        <textarea name="description" rows="2" style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:13px;margin-top:4px;resize:vertical;font-family:inherit;">{test.description || ''}</textarea>
      </div>

      <div style="grid-column:1/-1;display:grid;grid-template-columns:90px 1fr 100px 100px 130px;gap:10px;">
        <div><label style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;">Currency</label>
          <select name="currency" style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:13px;margin-top:4px;font-family:'JetBrains Mono',monospace;">
            {['INR','CHF','USD','EUR','GBP','SGD','AED','JPY'].map((c) => <option value={c} selected={(test.currency || 'INR') === c}>{c}</option>)}
          </select>
        </div>
        <div><label style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;">Price (minor units, e.g. 100 = 1 CHF / Rs 1)</label><input name="price_minor" type="number" min="0" value={test.price_inr_paise || 0} style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:13px;margin-top:4px;font-family:'JetBrains Mono',monospace;" /></div>
        <div><label style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;">Pass mark %</label><input name="pass_mark" type="number" min="0" max="100" value={test.pass_mark || 60} style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:13px;margin-top:4px;font-family:'JetBrains Mono',monospace;" /></div>
        <div><label style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;" title="From the bank, how many to serve each candidate (shuffled). Blank = all.">Questions to show</label><input name="questions_to_show" type="number" min="0" value={test.questions_to_show || ''} placeholder={'all (' + questions.length + ')'} style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:13px;margin-top:4px;font-family:'JetBrains Mono',monospace;" /></div>
      </div>

      <div style="grid-column:1/-1;display:flex;flex-wrap:wrap;gap:14px 22px;padding:10px 0;border-top:1px solid #2a3038;border-bottom:1px solid #2a3038;">
        <label style="display:flex;align-items:center;gap:8px;font-size:12.5px;color:#c8c3b8;cursor:pointer;"><input type="checkbox" name="is_published" checked={test.is_published} /> <span>Published (live)</span></label>
        <label style="display:flex;align-items:center;gap:8px;font-size:12.5px;color:#c8c3b8;cursor:pointer;"><input type="checkbox" name="is_premium" checked={test.is_premium} /> <span>Premium (paid)</span></label>
        <label style="display:flex;align-items:center;gap:8px;font-size:12.5px;color:#c8c3b8;cursor:pointer;"><input type="checkbox" name="randomize_questions" checked={test.randomize_questions} /> <span>Randomise question order</span></label>
        <label style="display:flex;align-items:center;gap:8px;font-size:12.5px;color:#c8c3b8;cursor:pointer;"><input type="checkbox" name="randomize_options" checked={test.randomize_options} /> <span>Randomise option order</span></label>
        <label style="display:flex;align-items:center;gap:8px;font-size:12.5px;color:#c8c3b8;cursor:pointer;"><input type="checkbox" name="show_results_to_candidate" checked={test.show_results_to_candidate} /> <span>Show score to candidate</span></label>
        <label style="display:flex;align-items:center;gap:8px;font-size:12.5px;color:#c8c3b8;cursor:pointer;"><input type="checkbox" name="proctoring_enabled" checked={test.proctoring_enabled} /> <span>ATLAS proctoring (camera + mic)</span></label>
        <label style="display:flex;align-items:center;gap:8px;font-size:12.5px;color:#c8c3b8;cursor:pointer;"><input type="checkbox" name="copy_paste_blocked" checked={test.copy_paste_blocked} /> <span>Block copy / paste</span></label>
      </div>

      <div style="grid-column:1/-1;display:grid;grid-template-columns:1fr 1fr 130px;gap:10px;">
        <div><label style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;">Result release</label>
          <select name="result_release_mode" style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:13px;margin-top:4px;font-family:inherit;">
            <option value="immediate" selected={(test.result_release_mode || 'immediate') === 'immediate'}>Immediate (show after submit)</option>
            <option value="on_declare" selected={test.result_release_mode === 'on_declare'}>Hold until authority declares</option>
          </select>
        </div>
        <div><label style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;">Ranking shown to candidate</label>
          <select name="ranking_mode" style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:13px;margin-top:4px;font-family:inherit;">
            <option value="none" selected={(test.ranking_mode || 'none') === 'none'}>None</option>
            <option value="rank" selected={test.ranking_mode === 'rank'}>Own rank only</option>
            <option value="leaderboard" selected={test.ranking_mode === 'leaderboard'}>Full leaderboard</option>
          </select>
        </div>
        <div><label style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;" title="Fraction of a question's marks deducted per wrong objective answer. 0.25 = -1/4. Blanks never penalised.">Negative marking</label><input name="negative_mark_fraction" type="number" step="0.05" min="0" max="1" value={test.negative_mark_fraction || 0} style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:13px;margin-top:4px;font-family:'JetBrains Mono',monospace;" /></div>
      </div>

      <div style="grid-column:1/-1;display:flex;flex-wrap:wrap;gap:14px 22px;padding-bottom:8px;">
        <label style="display:flex;align-items:center;gap:8px;font-size:12.5px;color:#c8c3b8;cursor:pointer;"><input type="checkbox" name="restricted" checked={test.restricted} /> <span>Restricted exam (questions limited to designated authority)</span></label>
        <label style="display:flex;align-items:center;gap:8px;font-size:12.5px;color:#c8c3b8;cursor:pointer;"><input type="checkbox" name="show_correct_answers" checked={test.show_correct_answers !== false} /> <span>Show correct answers in review</span></label>
        <label style="display:flex;align-items:center;gap:8px;font-size:12.5px;color:#c8c3b8;cursor:pointer;"><input type="checkbox" name="one_question_at_a_time" checked={test.one_question_at_a_time} /> <span>One question at a time</span></label>
      </div>

      <div style="grid-column:1/-1;display:grid;grid-template-columns:120px 1fr 1fr 1fr;gap:10px;">
        <div><label style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;" title="Max attempts per candidate. Blank = unlimited.">Allowed attempts</label><input name="allowed_attempts" type="number" min="0" value={test.allowed_attempts || ''} placeholder="unlimited" style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:13px;margin-top:4px;font-family:'JetBrains Mono',monospace;" /></div>
        <div><label style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;">Available from</label><input name="available_from" type="datetime-local" value={test.available_from ? new Date(test.available_from).toISOString().slice(0,16) : ''} style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:13px;margin-top:4px;" /></div>
        <div><label style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;">Available until</label><input name="available_until" type="datetime-local" value={test.available_until ? new Date(test.available_until).toISOString().slice(0,16) : ''} style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:13px;margin-top:4px;" /></div>
        <div><label style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;" title="If set, candidates must enter this code to start.">Access code</label><input name="access_code" type="text" value={test.access_code || ''} placeholder="none" style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:13px;margin-top:4px;font-family:'JetBrains Mono',monospace;" /></div>
      </div>

      <div style="grid-column:1/-1;">
        <label style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;">Instructions (shown to candidate before they start)</label>
        <textarea name="instructions" rows="3" style="width:100%;background:#1c2128;border:1px solid #2a3038;color:#f4f1ea;padding:8px 10px;border-radius:6px;font-size:13px;margin-top:4px;resize:vertical;font-family:inherit;">{test.instructions || ''}</textarea>
      </div>

      <div style="grid-column:1/-1;display:flex;gap:10px;align-items:center;">
        <button type="submit" class="btn-atlas">Save settings</button>
        <p style="font-size:11px;color:#8a8579;margin:0;">For currency=CHF, price=100 means 1 CHF (Razorpay charges live INR equivalent).</p>
      </div>
    </form>
  </details>

  <!-- RESULTS & RANKING - declare + leaderboard for evaluation -->
  <details style="margin:14px 16px;background:#14181d;border:1px solid #2a3038;border-radius:12px;padding:14px 18px;">
    <summary style="cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:#d97757;">Results &middot; ranking &middot; declaration ({leaderboard.length} attempts)</summary>

    <div style="margin-top:14px;display:flex;flex-wrap:wrap;gap:10px;align-items:center;">
      <span style="font-size:12.5px;color:#c8c3b8;">Release mode: <strong style="color:#f4f1ea;">{test.result_release_mode === 'on_declare' ? 'Held until declared' : 'Immediate'}</strong></span>
      {test.result_release_mode === 'on_declare' && (
        test.results_declared ? (
          <>
            <span style="font-size:11px;background:rgba(16,185,129,0.12);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;padding:4px 10px;border-radius:100px;">Declared</span>
            <form method="POST" style="display:inline;" onsubmit="return confirm('Withdraw results from candidates?');"><input type="hidden" name="action" value="unpublish_results" /><button type="submit" style="font-size:11px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;padding:5px 12px;border-radius:6px;cursor:pointer;">Withdraw results</button></form>
          </>
        ) : (
          <form method="POST" style="display:inline;" onsubmit="return confirm('Declare results to all candidates now? Ranking is auto-computed from scores.');"><input type="hidden" name="action" value="declare_results" /><button type="submit" class="btn-atlas">Declare results now</button></form>
        )
      )}
    </div>
    <p style="font-size:11px;color:#8a8579;margin:8px 0 0;line-height:1.6;">Ranks are auto-computed from scores (ties broken by faster time). Proctoring flags are advisory only and never auto-penalise a candidate - a human reviews the attempt and decides. This protects candidates from harm caused by any false detection.</p>

    <div style="margin-top:14px;overflow-x:auto;">
      <table style="width:100%;border-collapse:collapse;font-size:12.5px;">
        <thead><tr style="text-align:left;color:#8a8579;border-bottom:1px solid #2a3038;">
          <th style="padding:6px 8px;">Rank</th><th style="padding:6px 8px;">Candidate</th><th style="padding:6px 8px;">Score</th><th style="padding:6px 8px;">Neg</th><th style="padding:6px 8px;">Time</th><th style="padding:6px 8px;">Flags</th><th style="padding:6px 8px;"></th>
        </tr></thead>
        <tbody>
          {leaderboard.map((a: any) => (
            <tr style="border-bottom:1px solid #1a1a1f;color:#c8c3b8;">
              <td style="padding:6px 8px;font-family:'JetBrains Mono',monospace;color:#d97757;font-weight:700;">{a.rank || '-'}</td>
              <td style="padding:6px 8px;">{a.candidate_name || a.candidate_email || 'anon'}</td>
              <td style="padding:6px 8px;font-family:'JetBrains Mono',monospace;">{a.percentage != null ? Math.round(a.percentage) + '%' : '-'} <span style="color:#6e6e78;">({a.total_score}/{a.max_score})</span></td>
              <td style="padding:6px 8px;color:#fca5a5;">{a.negative_marks && Number(a.negative_marks) > 0 ? '-' + a.negative_marks : '-'}</td>
              <td style="padding:6px 8px;color:#8a8579;">{a.duration_seconds ? Math.floor(a.duration_seconds / 60) + 'm' : '-'}</td>
              <td style="padding:6px 8px;">{((a.tab_switches || 0) + (a.fullscreen_exits || 0)) > 0 ? <span style="color:#f0b54f;">{(a.tab_switches || 0) + (a.fullscreen_exits || 0)}</span> : <span style="color:#6ee7b7;">clean</span>}</td>
              <td style="padding:6px 8px;"><a href={'/admin/tests/attempts/' + a.id} style="color:#60a5fa;text-decoration:none;">review</a></td>
            </tr>
          ))}
          {leaderboard.length === 0 && <tr><td colspan="7" style="padding:14px 8px;color:#6e6e78;">No graded attempts yet.</td></tr>}
        </tbody>
      </table>
    </div>
  </details>

  <div style="padding:14px 16px;display:grid;grid-template-columns:1fr 360px;gap:16px;">

    <!-- Questions list -->
    <div>
      <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0 0 10px;">{questions.length} Questions</p>
      {questions.length === 0 && (
        <div style="background:#0f0f14;border:1px dashed #1a1a1f;border-radius:12px;padding:32px;text-align:center;color:#6e6e78;">
          <p style="font-size:13px;color:#fff;margin-bottom:4px;">No questions yet</p>
          <p style="font-size:11px;">Add your first question using the form on the right.</p>
        </div>
      )}
      <div style="display:flex;flex-direction:column;gap:6px;">
        {questions.map((q: any, idx: number) => (
          <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px 14px;">
            <div style="display:flex;align-items:flex-start;gap:10px;">
              <div style="width:28px;height:28px;background:rgba(255,79,0,0.15);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#FF7040;flex-shrink:0;">{idx+1}</div>
              <div style="flex:1;min-width:0;">
                <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;flex-wrap:wrap;">
                  <span style="font-size:9px;background:#15151a;color:#8a8a94;padding:2px 7px;border-radius:100px;text-transform:uppercase;">{Q_TYPE_LABELS[q.question_type] || q.question_type}</span>
                  <span style={`font-size:9px;padding:2px 7px;border-radius:100px;background:${q.difficulty==='easy'?'rgba(16,185,129,0.15)':q.difficulty==='hard'?'rgba(239,68,68,0.15)':'rgba(251,191,36,0.15)'};color:${q.difficulty==='easy'?'#6ee7b7':q.difficulty==='hard'?'#fca5a5':'#fbbf24'};text-transform:uppercase;`}>{q.difficulty}</span>
                  <span style="font-size:9px;color:#6e6e78;">{q.marks} mark{q.marks!==1?'s':''}</span>
                </div>
                <p style="font-size:13px;color:#d8d8de;margin:0;line-height:1.5;">{q.question_text}</p>
              </div>
              <form method="POST" style="display:inline;flex-shrink:0;" onsubmit="return confirm('Delete this question?');">
                <input type="hidden" name="action" value="delete_question"/>
                <input type="hidden" name="qid" value={q.id}/>
                <button type="submit" style="background:none;border:none;color:#6e6e78;cursor:pointer;font-size:16px;padding:4px 8px;">x</button>
              </form>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Add question form (sticky) -->
    <div style="position:sticky;top:80px;height:fit-content;">
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;">
        <p style="font-size:13px;font-weight:700;color:#fff;margin:0 0 12px;">Add Question</p>
        <form method="POST" id="qForm" style="display:flex;flex-direction:column;gap:10px;">
          <input type="hidden" name="action" value="add_question"/>

          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;color:#6e6e78;margin-bottom:4px;">Type</label>
            <select name="question_type" id="qType" onchange="toggleQFields(this.value)" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12px;outline:none;">
              <option value="mcq_single">Multiple Choice (Single answer)</option>
              <option value="mcq_multi">Multiple Choice (Multi-select)</option>
              <option value="true_false">True / False</option>
              <option value="short_answer">Short Answer</option>
              <option value="long_answer">Long Answer (Essay)</option>
              <option value="code">Coding Challenge</option>
            </select>
          </div>

          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;color:#6e6e78;margin-bottom:4px;">Question</label>
            <textarea name="question_text" rows="3" required placeholder="What is..." style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12px;outline:none;resize:vertical;font-family:inherit;"></textarea>
          </div>

          <div id="qMCQFields">
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;color:#6e6e78;margin-bottom:4px;">Options (one per line)</label>
            <textarea name="options" rows="4" placeholder="Option 1&#10;Option 2&#10;Option 3&#10;Option 4" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12px;outline:none;resize:vertical;font-family:inherit;"></textarea>
            <div id="singleIndex" style="margin-top:6px;">
              <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;color:#6e6e78;margin-bottom:4px;">Correct option index (0-based)</label>
              <input name="correct_index" type="number" min="0" value="0" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12px;outline:none;"/>
            </div>
            <div id="multiIndex" style="display:none;margin-top:6px;">
              <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;color:#6e6e78;margin-bottom:4px;">Correct indices (comma-separated)</label>
              <input name="correct_indices" placeholder="0,2,3" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12px;outline:none;"/>
            </div>
          </div>

          <div id="qTextFields" style="display:none;">
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;color:#6e6e78;margin-bottom:4px;">Model answer (for AI grading)</label>
            <textarea name="correct_answer" rows="2" placeholder="Reference answer..." style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12px;outline:none;resize:vertical;font-family:inherit;"></textarea>
          </div>

          <div id="qCodeFields" style="display:none;">
            <select name="code_language" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12px;outline:none;margin-bottom:6px;">
              <option value="python">Python</option>
              <option value="javascript">JavaScript</option>
              <option value="java">Java</option>
              <option value="cpp">C++</option>
            </select>
            <textarea name="code_starter" rows="3" placeholder="def solution(n):&#10;    # Your code" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:11px;outline:none;resize:vertical;font-family:monospace;margin-bottom:6px;"></textarea>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;color:#6e6e78;margin-bottom:4px;">Test cases (input|expected per line)</label>
            <textarea name="test_cases" rows="3" placeholder="5|25&#10;10|100" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:11px;outline:none;resize:vertical;font-family:monospace;"></textarea>
          </div>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">
            <div>
              <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;color:#6e6e78;margin-bottom:4px;">Marks</label>
              <input name="marks" type="number" value="1" min="1" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12px;outline:none;"/>
            </div>
            <div>
              <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;color:#6e6e78;margin-bottom:4px;">Difficulty</label>
              <select name="difficulty" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12px;outline:none;">
                <option value="easy">Easy</option>
                <option value="medium" selected>Medium</option>
                <option value="hard">Hard</option>
              </select>
            </div>
          </div>

          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;color:#6e6e78;margin-bottom:4px;">Explanation (shown after submission)</label>
            <textarea name="explanation" rows="2" placeholder="Why this answer is correct..." style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:6px;padding:8px 10px;color:#fff;font-size:12px;outline:none;resize:vertical;font-family:inherit;"></textarea>
          </div>

          <button type="submit" style="background:#FF4F00;border:none;color:#fff;font-size:13px;font-weight:700;padding:10px;border-radius:8px;cursor:pointer;">+ Add Question</button>
        </form>
      </div>
    </div>
  </div>
</div>

<script is:inline>
function toggleQFields(type) {
  document.getElementById('qMCQFields').style.display = (type==='mcq_single'||type==='mcq_multi'||type==='true_false') ? 'block' : 'none';
  document.getElementById('singleIndex').style.display = (type==='mcq_single'||type==='true_false') ? 'block' : 'none';
  document.getElementById('multiIndex').style.display = type==='mcq_multi' ? 'block' : 'none';
  document.getElementById('qTextFields').style.display = (type==='short_answer'||type==='long_answer') ? 'block' : 'none';
  document.getElementById('qCodeFields').style.display = type==='code' ? 'block' : 'none';
}
</script>
</AdminLayout>
