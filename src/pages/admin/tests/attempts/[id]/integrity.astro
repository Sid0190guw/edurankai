---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { computeIntegrityScore, EVENT_SEVERITY, RISK_BAND_COLORS } from '@/lib/proctoring-integrity';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/tests/attempts');

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

// Load the attempt and events. Test_attempts uses started_at not created_at.
let attempt: any = null;
let events: any[] = [];
try {
  attempt = rows(await db.execute(sql`
    SELECT a.id, a.test_id, a.candidate_email, a.candidate_name, a.status,
      a.started_at, a.submitted_at, a.total_score, a.auto_score, a.percentage,
      t.title AS test_title, t.slug AS test_slug
    FROM test_attempts a LEFT JOIN tests t ON t.id = a.test_id
    WHERE a.id = ${id} LIMIT 1
  `))[0];
} catch (e) { /* swallow — render empty state below */ }
if (!attempt) return Astro.redirect('/admin/tests/attempts');

try {
  events = rows(await db.execute(sql`
    SELECT event_type AS type, severity, detail, client_ts, created_at
    FROM test_attempt_events WHERE attempt_id = ${id}
    ORDER BY COALESCE(client_ts, created_at) ASC LIMIT 2000
  `));
} catch (e) { events = []; }

const result = computeIntegrityScore(events);
const band = RISK_BAND_COLORS[result.riskBand];

function fmt(d: any): string {
  try { return new Date(d).toLocaleString('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit', second: '2-digit' }); } catch { return ''; }
}
function eventLabel(t: string) { return (EVENT_SEVERITY[t] && EVENT_SEVERITY[t].label) || t; }
function eventCategory(t: string) { return (EVENT_SEVERITY[t] && EVENT_SEVERITY[t].category) || 'other'; }
function eventWeight(t: string) { return (EVENT_SEVERITY[t] && EVENT_SEVERITY[t].weight) || 0; }

const startTs = attempt.started_at ? new Date(attempt.started_at).getTime() : null;
const endTs = attempt.submitted_at ? new Date(attempt.submitted_at).getTime() : Date.now();
const totalDuration = startTs ? Math.max(1, endTs - startTs) : 1;
---
<AdminLayout title="Integrity Report" activeNav="">
<div style="padding:14px 16px 80px;">
  <a href={'/admin/tests/attempts/' + id} style="font-size:11.5px;color:#7e98a1;text-decoration:none;font-family:'Geist Mono',monospace;letter-spacing:0.08em;">← Back to attempt</a>

  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:18px 0;margin-top:10px;">
    <p style="font-size:10.5px;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;font-family:'Geist Mono',monospace;font-weight:700;">Integrity Report</p>
    <h1 style="font-size:22px;color:#fff;margin:6px 0 4px;font-weight:700;">{attempt.test_title || 'Test attempt'}</h1>
    <p style="font-size:13px;color:#9aa6b6;margin:0;">{attempt.candidate_name || attempt.candidate_email} · {fmt(attempt.started_at)}</p>
  </div>

  <!-- Integrity score card -->
  <div style={`background:${band.bg};border:1px solid ${band.border};border-radius:14px;padding:24px;margin-top:16px;display:grid;grid-template-columns:auto 1fr auto;gap:20px;align-items:center;flex-wrap:wrap;`}>
    <div style="text-align:center;">
      <p style="font-size:11px;letter-spacing:0.14em;text-transform:uppercase;font-family:'Geist Mono',monospace;color:#9aa6b6;font-weight:700;margin:0 0 6px;">Integrity Score</p>
      <p style={`font-size:64px;font-weight:800;color:${band.fg};line-height:1;margin:0;font-family:'Inter Tight',sans-serif;`}>{result.score}<span style="font-size:24px;color:#6e6e78;">/100</span></p>
      <span style={`display:inline-block;margin-top:8px;background:${band.bg};color:${band.fg};border:1px solid ${band.border};font-family:'Geist Mono',monospace;font-size:10.5px;font-weight:700;padding:3px 12px;border-radius:100px;text-transform:uppercase;letter-spacing:0.14em;`}>{band.label}</span>
    </div>
    <div>
      <p style="font-size:11px;color:#9aa6b6;margin:0 0 6px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;font-family:'Geist Mono',monospace;">Severity breakdown</p>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:6px;font-family:'Inter Tight',sans-serif;">
        <div style="background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.32);border-radius:6px;padding:8px;text-align:center;">
          <p style="font-size:20px;color:#fca5a5;font-weight:700;margin:0;line-height:1;">{result.bySeverity.critical}</p>
          <p style="font-size:9.5px;color:#9aa6b6;margin:3px 0 0;font-family:'Geist Mono',monospace;letter-spacing:0.08em;text-transform:uppercase;">Critical</p>
        </div>
        <div style="background:rgba(249,115,22,0.10);border:1px solid rgba(249,115,22,0.32);border-radius:6px;padding:8px;text-align:center;">
          <p style="font-size:20px;color:#fb923c;font-weight:700;margin:0;line-height:1;">{result.bySeverity.high}</p>
          <p style="font-size:9.5px;color:#9aa6b6;margin:3px 0 0;font-family:'Geist Mono',monospace;letter-spacing:0.08em;text-transform:uppercase;">High</p>
        </div>
        <div style="background:rgba(251,191,36,0.10);border:1px solid rgba(251,191,36,0.32);border-radius:6px;padding:8px;text-align:center;">
          <p style="font-size:20px;color:#fbbf24;font-weight:700;margin:0;line-height:1;">{result.bySeverity.medium}</p>
          <p style="font-size:9.5px;color:#9aa6b6;margin:3px 0 0;font-family:'Geist Mono',monospace;letter-spacing:0.08em;text-transform:uppercase;">Medium</p>
        </div>
        <div style="background:rgba(34,211,238,0.10);border:1px solid rgba(34,211,238,0.32);border-radius:6px;padding:8px;text-align:center;">
          <p style="font-size:20px;color:#67e8f9;font-weight:700;margin:0;line-height:1;">{result.bySeverity.low}</p>
          <p style="font-size:9.5px;color:#9aa6b6;margin:3px 0 0;font-family:'Geist Mono',monospace;letter-spacing:0.08em;text-transform:uppercase;">Low</p>
        </div>
      </div>
    </div>
    <div style="text-align:right;">
      <p style="font-size:11px;color:#9aa6b6;margin:0;font-family:'Geist Mono',monospace;letter-spacing:0.08em;text-transform:uppercase;">Total events</p>
      <p style="font-size:28px;color:#fff;font-weight:700;margin:4px 0 0;font-family:'Inter Tight',sans-serif;">{result.totalEvents}</p>
      <p style="font-size:11px;color:#FF7040;margin:6px 0 0;font-family:'Geist Mono',monospace;">{result.flaggedEvents} flagged</p>
    </div>
  </div>

  <!-- Top flag types -->
  {result.topFlags.length > 0 && (
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:18px;margin-top:14px;">
      <p style="font-size:11px;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 12px;font-family:'Geist Mono',monospace;font-weight:700;">Top contributing flags</p>
      <div style="display:flex;flex-direction:column;gap:6px;">
        {result.topFlags.map((f: any) => {
          const contrib = Math.round(f.weight * f.count);
          return (
            <div style="display:grid;grid-template-columns:auto 1fr auto auto;gap:10px;align-items:center;background:#08080a;border:1px solid #1a1a1f;border-radius:8px;padding:9px 14px;">
              <span style="font-family:'Geist Mono',monospace;font-size:10px;color:#fbbf24;font-weight:700;background:rgba(251,191,36,0.12);padding:3px 8px;border-radius:100px;letter-spacing:0.08em;text-transform:uppercase;">{f.weight >= 20 ? 'critical' : f.weight >= 12 ? 'high' : f.weight >= 4 ? 'medium' : 'low'}</span>
              <span style="color:#fff;font-size:13px;font-weight:600;">{f.label}</span>
              <span style="font-family:'Geist Mono',monospace;font-size:11.5px;color:#9aa6b6;">×{f.count}</span>
              <span style="font-family:'Geist Mono',monospace;font-size:11.5px;color:#fca5a5;font-weight:700;">-{contrib}</span>
            </div>
          );
        })}
      </div>
    </div>
  )}

  <!-- Event timeline -->
  <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:18px;margin-top:14px;">
    <p style="font-size:11px;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;font-family:'Geist Mono',monospace;font-weight:700;">Event timeline ({events.length})</p>
    <p style="font-size:11.5px;color:#6e6e78;margin:0 0 14px;line-height:1.5;">Hover an event for detail. Coloured by category. Position on the bar is proportional to time-in-attempt.</p>

    {startTs && (
      <div style="background:#08080a;border:1px solid #1a1a1f;border-radius:8px;padding:12px;margin-bottom:14px;position:relative;height:48px;">
        {events.map((e: any) => {
          const ts = e.client_ts ? new Date(e.client_ts).getTime() : new Date(e.created_at).getTime();
          const pct = Math.min(99, Math.max(0, ((ts - startTs) / totalDuration) * 100));
          const w = eventWeight(e.type);
          const colour = w >= 20 ? '#fca5a5' : w >= 12 ? '#fb923c' : w >= 4 ? '#fbbf24' : '#67e8f9';
          return (
            <span title={e.type + ' @ ' + fmt(ts)} style={`position:absolute;left:${pct}%;top:8px;bottom:8px;width:2px;background:${colour};opacity:${Math.min(1, 0.4 + w/30)};cursor:pointer;`}></span>
          );
        })}
      </div>
    )}

    <div style="max-height:520px;overflow-y:auto;display:flex;flex-direction:column;gap:3px;">
      {events.slice().reverse().map((e: any) => {
        const w = eventWeight(e.type);
        const colour = w >= 20 ? '#fca5a5' : w >= 12 ? '#fb923c' : w >= 4 ? '#fbbf24' : w > 0 ? '#67e8f9' : '#6e6e78';
        return (
          <div style="display:grid;grid-template-columns:auto auto auto 1fr auto;gap:10px;align-items:center;background:#08080a;border:1px solid #1a1a1f;border-radius:6px;padding:6px 12px;">
            <span style="font-family:'Geist Mono',monospace;font-size:10.5px;color:#6e6e78;min-width:120px;">{fmt(e.client_ts || e.created_at)}</span>
            <span style={`font-family:'Geist Mono',monospace;font-size:9.5px;color:${colour};font-weight:700;background:${colour === '#6e6e78' ? 'transparent' : 'rgba(255,255,255,0.04)'};padding:2px 7px;border-radius:100px;letter-spacing:0.06em;text-transform:uppercase;min-width:48px;text-align:center;`}>{eventCategory(e.type)}</span>
            <span style="color:#fff;font-size:11.5px;font-weight:600;min-width:120px;">{eventLabel(e.type)}</span>
            <span style="color:#9aa6b6;font-size:10.5px;font-family:'Geist Mono',monospace;">{e.detail ? JSON.stringify(e.detail).slice(0,80) : ''}</span>
            {w > 0 && <span style={`font-family:'Geist Mono',monospace;font-size:10px;color:${colour};font-weight:700;`}>-{w}</span>}
          </div>
        );
      })}
      {events.length === 0 && <div style="text-align:center;color:#6e6e78;padding:24px;font-size:12px;">No events logged for this attempt.</div>}
    </div>
  </div>
</div>
</AdminLayout>
