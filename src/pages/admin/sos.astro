---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');

let okMsg = '';
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const id = fd.get('id') as string;
  const status = fd.get('status') as string;
  try {
    await db.execute(sql`UPDATE sos_events SET status=${status}, resolved_by=${user.id}, resolved_at=NOW() WHERE id=${id}`);
    okMsg = 'SOS status updated.';
  } catch(e) {}
}

let events: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT s.*, u.name as user_name, u.email as user_email
    FROM sos_events s JOIN users u ON s.user_id = u.id
    ORDER BY CASE s.status WHEN 'active' THEN 1 ELSE 2 END, s.created_at DESC
    LIMIT 50
  `);
  events = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

let onlineLocations: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT ul.*, u.name, u.role FROM user_locations ul
    JOIN users u ON ul.user_id = u.id
    WHERE ul.updated_at >= NOW() - INTERVAL '10 minutes'
    ORDER BY ul.updated_at DESC LIMIT 50
  `);
  onlineLocations = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

function timeAgo(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins + 'm ago';
  return Math.floor(mins / 60) + 'h ago';
}
---
<AdminLayout title="SOS & Safety" activeNav="sos">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<style>
  #sosMap { height: 400px; border-radius: 12px; }
  .leaflet-popup-content-wrapper { background: #0f0f14; border: 1px solid #1a1a1f; border-radius: 10px; color: #fff; }
  .leaflet-popup-tip { background: #0f0f14; }
  @keyframes sosPulse { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(1.4);opacity:0.6} }
</style>
<div style="padding-bottom:80px;">
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;">
    <div style="display:flex;align-items:center;justify-content:space-between;">
      <div>
        <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#ef4444;letter-spacing:0.12em;text-transform:uppercase;margin:0;">Safety</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">SOS & Proximity</h1>
      </div>
      <div style="display:flex;align-items:center;gap:8px;">
        {events.filter((e:any)=>e.status==='active').length > 0 && (
          <div style="background:rgba(239,68,68,0.15);border:1px solid rgba(239,68,68,0.4);border-radius:100px;padding:4px 12px;animation:sosPulse 2s infinite;">
            <span style="font-size:12px;font-weight:700;color:#ef4444;">{events.filter((e:any)=>e.status==='active').length} ACTIVE SOS</span>
          </div>
        )}
        <span style="font-size:11px;color:#6e6e78;background:#15151a;border:1px solid #1a1a1f;padding:4px 10px;border-radius:100px;">{onlineLocations.length} tracked</span>
      </div>
    </div>
  </div>

  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  <div style="padding:12px 16px;display:flex;flex-direction:column;gap:12px;">

    <!-- Live map -->
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
      <div style="padding:10px 14px;border-bottom:1px solid #1a1a1f;display:flex;align-items:center;gap:8px;">
        <div style="width:8px;height:8px;background:#10b981;border-radius:50%;animation:sosPulse 2s infinite;"></div>
        <p style="font-size:12px;font-weight:600;color:#fff;margin:0;">Live User Locations (last 10 min)</p>
      </div>
      {onlineLocations.length === 0 ? (
        <div style="padding:32px;text-align:center;color:#6e6e78;">
          <p style="font-size:13px;">No active location data. Users share location via GPS permission.</p>
        </div>
      ) : (
        <div id="sosMap"></div>
      )}
    </div>

    <!-- Active SOS alerts -->
    {events.filter((e:any)=>e.status==='active').map((ev: any) => {
      let nearby: any[] = [];
      try { nearby = typeof ev.nearby_users === 'string' ? JSON.parse(ev.nearby_users) : (ev.nearby_users || []); } catch(e) {}
      return (
        <div style="background:#0f0f14;border:2px solid rgba(239,68,68,0.5);border-radius:12px;overflow:hidden;">
          <div style="background:rgba(239,68,68,0.1);padding:12px 14px;border-bottom:1px solid rgba(239,68,68,0.2);">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
              <div style="width:10px;height:10px;background:#ef4444;border-radius:50%;animation:sosPulse 1s infinite;flex-shrink:0;"></div>
              <p style="font-size:14px;font-weight:700;color:#ef4444;margin:0;">SOS ALERT</p>
              <span style="font-size:10px;color:#6e6e78;margin-left:auto;">{timeAgo(ev.created_at)}</span>
            </div>
            <p style="font-size:13px;font-weight:600;color:#fff;margin:0 0 2px;">{ev.user_name}</p>
            <p style="font-size:11px;color:#8a8a94;margin:0;">{ev.user_email}</p>
            {ev.message && <p style="font-size:12px;color:#fca5a5;margin:6px 0 0;">"{ev.message}"</p>}
          </div>
          <div style="padding:12px 14px;">
            <p style="font-size:11px;font-weight:700;color:#6e6e78;text-transform:uppercase;margin:0 0 8px;">Location: {ev.lat}, {ev.lon}</p>
            <p style="font-size:11px;font-weight:700;color:#6e6e78;text-transform:uppercase;margin:0 0 8px;">{nearby.length} users were nearby ({nearby.length === 0 ? 'No witnesses' : 'Potential witnesses'})</p>
            {nearby.length > 0 && (
              <div style="display:flex;flex-direction:column;gap:4px;margin-bottom:12px;">
                {nearby.map((n: any) => (
                  <div style="background:#15151a;border-radius:6px;padding:6px 10px;display:flex;justify-content:space-between;">
                    <span style="font-size:12px;color:#fff;">{n.name}</span>
                    <span style="font-size:11px;color:#6e6e78;">{Math.round(n.distance_m)}m away</span>
                  </div>
                ))}
              </div>
            )}
            <div style="display:flex;gap:6px;">
              <a href={`https://maps.google.com/?q=${ev.lat},${ev.lon}`} target="_blank" style="flex:1;text-align:center;background:#15151a;border:1px solid #1a1a1f;color:#60a5fa;text-decoration:none;font-size:11px;font-weight:600;padding:7px;border-radius:6px;">Open in Maps</a>
              <form method="POST" style="display:contents;">
                <input type="hidden" name="id" value={ev.id}/><input type="hidden" name="status" value="resolved"/>
                <button type="submit" style="flex:1;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;font-size:11px;font-weight:600;padding:7px;border-radius:6px;cursor:pointer;">Mark Resolved</button>
              </form>
              <form method="POST" style="display:contents;">
                <input type="hidden" name="id" value={ev.id}/><input type="hidden" name="status" value="false_alarm"/>
                <button type="submit" style="background:#15151a;border:1px solid #1a1a1f;color:#6e6e78;font-size:11px;padding:7px 10px;border-radius:6px;cursor:pointer;">False alarm</button>
              </form>
            </div>
          </div>
        </div>
      );
    })}

    <!-- Past SOS -->
    {events.filter((e:any)=>e.status!=='active').length > 0 && (
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
        <div style="padding:10px 14px;border-bottom:1px solid #1a1a1f;"><p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0;">Past Events</p></div>
        {events.filter((e:any)=>e.status!=='active').map((ev: any) => (
          <div style="padding:10px 14px;display:flex;align-items:center;gap:10px;border-bottom:1px solid #0a0a0c;">
            <div style={`width:8px;height:8px;border-radius:50%;background:${ev.status==='resolved'?'#10b981':'#6b7280'};flex-shrink:0;`}></div>
            <div style="flex:1;">
              <p style="font-size:12px;font-weight:600;color:#fff;margin:0;">{ev.user_name}</p>
              <p style="font-size:10px;color:#6e6e78;margin:1px 0 0;">{ev.status} - {timeAgo(ev.created_at)}</p>
            </div>
          </div>
        ))}
      </div>
    )}

  </div>
</div>

{onlineLocations.length > 0 && (
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script is:inline define:vars={{ locations: onlineLocations, sosEvents: events.filter((e:any)=>e.status==='active') }}>
  document.addEventListener('DOMContentLoaded', function() {
    var map = L.map('sosMap').setView([20.5937, 78.9629], 5);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', { maxZoom: 19 }).addTo(map);
    var bounds = [];

    // SOS events - red pulsing
    sosEvents.forEach(function(ev) {
      if (!ev.lat || !ev.lon) return;
      bounds.push([ev.lat, ev.lon]);
      var m = L.circleMarker([ev.lat, ev.lon], { radius: 16, fillColor: '#ef4444', color: '#fff', weight: 2, opacity: 1, fillOpacity: 0.9 }).addTo(map);
      m.bindPopup('<div style="min-width:140px;"><p style="font-size:13px;font-weight:700;color:#ef4444;margin:0 0 4px;">SOS: ' + ev.user_name + '</p><p style="font-size:11px;color:#8a8a94;margin:0;">' + (ev.message||'No message') + '</p></div>');
    });

    // Regular user locations
    locations.forEach(function(loc) {
      if (!loc.lat || !loc.lon) return;
      bounds.push([loc.lat, loc.lon]);
      var color = loc.role === 'applicant' ? '#60a5fa' : '#FF7040';
      var m = L.circleMarker([loc.lat, loc.lon], { radius: 7, fillColor: color, color: color, weight: 1, opacity: 1, fillOpacity: 0.8 }).addTo(map);
      m.bindPopup('<div><p style="font-size:12px;font-weight:600;color:#fff;margin:0;">' + loc.name + '</p><p style="font-size:10px;color:#8a8a94;margin:2px 0 0;">' + loc.role + '</p></div>');
    });

    if (bounds.length > 0) map.fitBounds(bounds, { padding: [30, 30] });
  });
  </script>
)}
</AdminLayout>
