---
import AdminLayout from '@/layouts/AdminLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');
---
<AdminLayout title="Dashboard" activeNav="dashboard">
<div style="padding:24px 16px;">
  <h1 style="color:#fff;font-size:20px;margin:0 0 8px;">Dashboard</h1>
  <p style="color:#6e6e78;font-size:13px;">Welcome, {user.name || user.email}</p>
  <div style="margin-top:20px;display:flex;flex-direction:column;gap:8px;">
    <a href="/admin/applications" style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:14px;color:#FF7040;text-decoration:none;font-weight:600;">Applications</a>
    <a href="/admin/hr" style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:14px;color:#60a5fa;text-decoration:none;font-weight:600;">HR Management</a>
    <a href="/admin/hei/institutions" style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:14px;color:#34d399;text-decoration:none;font-weight:600;">HEI Institutions</a>
    <a href="/admin/users" style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:14px;color:#a78bfa;text-decoration:none;font-weight:600;">Users</a>
  </div>
</div>
</AdminLayout>