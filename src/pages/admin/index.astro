---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { applications, roles, events, users } from '@/lib/db/schema';
import { desc, sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const firstName = user.name ? user.name.split(' ')[0] : 'there';
const hour = new Date().getHours();
const greeting = hour < 12 ? 'Good morning' : hour < 17 ? 'Good afternoon' : 'Good evening';

// Stats
const [appCount, roleCount, eventCount, userCount] = await Promise.all([
  db.select({ n: sql<number>`count(*)::int` }).from(applications).then(r => r[0].n),
  db.select({ n: sql<number>`count(*)::int` }).from(roles).then(r => r[0].n),
  db.select({ n: sql<number>`count(*)::int` }).from(events).then(r => r[0].n),
  db.select({ n: sql<number>`count(*)::int` }).from(users).then(r => r[0].n),
]);

// Status breakdown
const statusCounts = await db.execute(sql`
  SELECT status, COUNT(*)::int as n FROM applications GROUP BY status ORDER BY n DESC
`);

// New this week

const newThisWeek = await db.select({ n: sql<number>`count(*)::int` }).from(applications)
  .then(r => r[0].n);

// Recent applications
const recentApps = await db.select({
  id: applications.id,
  firstName: applications.firstName,
  lastName: applications.lastName,
  email: applications.email,
  roleTitleSnapshot: applications.roleTitleSnapshot,
  status: applications.status,
  createdAt: applications.createdAt,
}).from(applications).orderBy(desc(applications.createdAt)).limit(5);

const STATUS_COLOR: Record<string, string> = {
  submitted: '#fbbf24',
  reviewing: '#60a5fa',
  shortlisted: '#34d399',
  interview: '#a78bfa',
  offered: '#f97316',
  hired: '#10b981',
  rejected: '#f87171',
  withdrawn: '#6b7280',
};
---
<AdminLayout title="Dashboard" activeNav="dashboard">
<div style="padding-bottom:80px;">

  <!-- Welcome header -->
  <div style="background:linear-gradient(135deg,#0f0f14 0%,#15151a 100%);border-bottom:1px solid #1a1a1f;padding:20px 16px 16px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.14em;text-transform:uppercase;margin:0 0 4px;">{new Date().toLocaleDateString('en-IN',{weekday:'long',day:'numeric',month:'long'})}</p>
    <h1 style="font-size:22px;font-weight:700;color:#fff;margin:0 0 4px;line-height:1.2;">{greeting}, {firstName}.</h1>
    <p style="font-size:12px;color:#6e6e78;margin:0;">EduRankAI Admin Panel · Live data</p>
  </div>

  <!-- Primary stats -->
  <div style="padding:16px;display:grid;grid-template-columns:1fr 1fr;gap:10px;">
    {[
      { label: 'Applications', value: appCount, sub: `${newThisWeek} new this week`, href: '/admin/applications', color: '#FF7040' },
      { label: 'Open Roles', value: roleCount, sub: 'across all departments', href: '/admin/roles', color: '#60a5fa' },
      { label: 'Events', value: eventCount, sub: 'upcoming + past', href: '/admin/events', color: '#34d399' },
      { label: 'Users', value: userCount, sub: 'staff + applicants', href: '/admin/users', color: '#a78bfa' },
    ].map(s => (
      <a href={s.href} style="text-decoration:none;background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;display:block;position:relative;overflow:hidden;">
        <div style={`position:absolute;top:0;left:0;right:0;height:2px;background:${s.color};`}></div>
        <p style={`font-size:28px;font-weight:800;color:${s.color};margin:0;line-height:1;font-family:'Geist Mono',monospace;`}>{s.value}</p>
        <p style="font-size:12px;font-weight:600;color:#fff;margin:6px 0 2px;">{s.label}</p>
        <p style="font-size:10px;color:#6e6e78;margin:0;">{s.sub}</p>
      </a>
    ))}
  </div>

  <!-- Application status breakdown -->
  {statusCounts.rows.length > 0 && (
    <div style="padding:0 16px 16px;">
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;">
        <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0 0 12px;">Application Pipeline</p>
        <div style="display:flex;flex-direction:column;gap:8px;">
          {(statusCounts.rows as any[]).map(row => {
            const pct = appCount > 0 ? Math.round((row.n / appCount) * 100) : 0;
            const color = STATUS_COLOR[row.status] || '#6e6e78';
            return (
              <div>
                <div style="display:flex;justify-content:space-between;margin-bottom:4px;">
                  <span style={`font-size:11px;font-weight:600;color:${color};text-transform:capitalize;`}>{row.status}</span>
                  <span style="font-size:11px;color:#6e6e78;font-family:'Geist Mono',monospace;">{row.n} ({pct}%)</span>
                </div>
                <div style="background:#15151a;border-radius:100px;height:4px;">
                  <div style={`background:${color};height:100%;width:${pct}%;border-radius:100px;transition:width 0.3s;`}></div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  )}

  <!-- Recent applications -->
  <div style="padding:0 16px 16px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
      <p style="font-size:13px;font-weight:600;color:#fff;margin:0;">Recent Applications</p>
      <a href="/admin/applications" style="font-size:11px;color:#FF7040;text-decoration:none;">View all →</a>
    </div>
    <div style="display:flex;flex-direction:column;gap:6px;">
      {recentApps.length === 0 && (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:24px;text-align:center;color:#6e6e78;font-size:12px;">
          No applications yet
        </div>
      )}
      {recentApps.map(a => {
        const name = ((a.firstName||'') + ' ' + (a.lastName||'')).trim() || a.email;
        const color = STATUS_COLOR[a.status || ''] || '#6e6e78';
        return (
          <a href={`/admin/applications/${a.id}`} style="text-decoration:none;background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:10px 12px;display:flex;align-items:center;gap:10px;">
            <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#FF4F00,#FF7040);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;color:#fff;flex-shrink:0;">
              {name.substring(0,1).toUpperCase()}
            </div>
            <div style="flex:1;min-width:0;">
              <p style="font-size:13px;font-weight:600;color:#fff;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{name}</p>
              <p style="font-size:11px;color:#6e6e78;margin:2px 0 0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{a.roleTitleSnapshot || 'No role'}</p>
            </div>
            <span style={`font-size:9px;font-weight:700;padding:2px 8px;border-radius:100px;text-transform:uppercase;background:${color}22;color:${color};flex-shrink:0;`}>
              {a.status}
            </span>
          </a>
        );
      })}
    </div>
  </div>

  <!-- Quick actions -->
  <div style="padding:0 16px 16px;">
    <p style="font-size:13px;font-weight:600;color:#fff;margin:0 0 10px;">Quick Actions</p>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
      {[
        { label: 'New Role', href: '/admin/roles/new', icon: '💼' },
        { label: 'New Event', href: '/admin/events', icon: '📅' },
        { label: 'Add Employee', href: '/admin/hr/employees', icon: '👤' },
        { label: 'Run Payroll', href: '/admin/hr/payroll', icon: '💰' },
        { label: 'Leave Requests', href: '/admin/hr/leave', icon: '📋' },
        { label: 'HEI Institutions', href: '/admin/hei/institutions', icon: '🏛️' },
      ].map(action => (
        <a href={action.href} style="text-decoration:none;background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px;display:flex;align-items:center;gap:10px;transition:background 0.12s;">
          <span style="font-size:20px;">{action.icon}</span>
          <span style="font-size:12px;font-weight:600;color:#d8d8de;">{action.label}</span>
        </a>
      ))}
    </div>
  </div>

  <!-- View public site -->
  <div style="padding:0 16px;">
    <a href="/" target="_blank" style="display:block;text-align:center;background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;text-decoration:none;font-size:12px;font-weight:500;padding:12px;border-radius:10px;">
      View Public Site ↗
    </a>
  </div>

</div>
</AdminLayout>
