---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const firstName = user.name ? user.name.split(' ')[0] : 'there';
const hour = new Date().getHours();
const greeting = hour < 12 ? 'Good morning' : hour < 17 ? 'Good afternoon' : 'Good evening';

let appCount = 0, roleCount = 0, userCount = 0, eventCount = 0, newThisWeek = 0;
let empCount = 0, pendingLeave = 0, heiCount = 0;
let statusRows: any[] = [];
let recentApps: any[] = [];

try {
  const counts = await db.execute(sql`
    SELECT
      (SELECT COUNT(*) FROM applications)::int as a,
      (SELECT COUNT(*) FROM roles WHERE is_open = true)::int as r,
      (SELECT COUNT(*) FROM users WHERE role != 'applicant')::int as u,
      (SELECT COUNT(*) FROM events)::int as e,
      (SELECT COUNT(*) FROM applications WHERE created_at >= NOW() - INTERVAL '7 days')::int as nw,
      (SELECT COUNT(*) FROM hei_institutions WHERE is_published = true)::int as h,
      (SELECT COUNT(*) FROM hr_employees WHERE is_active = true)::int as emp,
      (SELECT COUNT(*) FROM hr_leave_requests WHERE status = 'pending')::int as lv
  `);
  // postgres-js driver returns array directly, not {rows:[]}
  const row = (Array.isArray(counts) ? counts[0] : counts?.rows?.[0]) as any;
  if (row) {
    appCount = Number(row.a) || 0;
    roleCount = Number(row.r) || 0;
    userCount = Number(row.u) || 0;
    eventCount = Number(row.e) || 0;
    newThisWeek = Number(row.nw) || 0;
    heiCount = Number(row.h) || 0;
    empCount = Number(row.emp) || 0;
    pendingLeave = Number(row.lv) || 0;
  }
} catch(e) { console.error('Dashboard stats error:', e); }
try {
  const rs = await db.execute(sql`SELECT status, COUNT(*)::int as n FROM applications GROUP BY status ORDER BY n DESC`);
  statusRows = (Array.isArray(rs) ? rs : (rs?.rows || [])) as any[];
} catch(e) {}
try {
  const rra = await db.execute(sql`SELECT id, first_name, last_name, email, role_title_snapshot, status, created_at FROM applications ORDER BY created_at DESC LIMIT 6`);
  recentApps = (Array.isArray(rra) ? rra : (rra?.rows || [])) as any[];
} catch(e) {}

const STATUS_COLOR: Record<string,string> = {
  submitted:'#fbbf24',reviewing:'#60a5fa',shortlisted:'#34d399',
  interview:'#a78bfa',offered:'#f97316',hired:'#10b981',
  rejected:'#f87171',withdrawn:'#6b7280',task_sent:'#e879f9',
};
---
<AdminLayout title="Dashboard" activeNav="dashboard">
<div style="padding-bottom:80px;">

  <div style="background:linear-gradient(135deg,#0f0f14 0%,#15151a 100%);border-bottom:1px solid #1a1a1f;padding:20px 16px 16px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.14em;text-transform:uppercase;margin:0 0 2px;">{new Date().toLocaleDateString('en-IN',{weekday:'long',day:'numeric',month:'long',year:'numeric'})}</p>
    <h1 style="font-size:22px;font-weight:700;color:#fff;margin:0 0 2px;line-height:1.2;">{greeting}, {firstName}.</h1>
    <p style="font-size:12px;color:#6e6e78;margin:0;">EduRankAI Admin - Live data</p>
  </div>

  <div class="admin-stats-grid-4" style="padding:14px 16px 0;display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px;">
    {[
      {label:'Applications',value:appCount,sub:newThisWeek+' new this week',href:'/admin/applications',color:'#FF7040'},
      {label:'Open Roles',value:roleCount,sub:'actively hiring',href:'/admin/roles',color:'#60a5fa'},
      {label:'Active Staff',value:userCount,sub:'admin users',href:'/admin/users',color:'#a78bfa'},
      {label:'Events',value:eventCount,sub:'total events',href:'/admin/events',color:'#34d399'},
    ].map(s=>(
      <a href={s.href} style="text-decoration:none;background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;display:block;position:relative;overflow:hidden;">
        <div style={`position:absolute;top:0;left:0;right:0;height:2px;background:${s.color};`}></div>
        <p style={`font-size:28px;font-weight:800;color:${s.color};margin:0;line-height:1;font-family:'Geist Mono',monospace;`}>{s.value}</p>
        <p style="font-size:12px;font-weight:600;color:#fff;margin:5px 0 2px;">{s.label}</p>
        <p style="font-size:10px;color:#6e6e78;margin:0;">{s.sub}</p>
      </a>
    ))}
  </div>

  <div class="admin-stats-grid-3" style="padding:8px 16px 0;display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px;">
    {[
      {label:'Employees',value:empCount,href:'/admin/hr/employees',color:'#10b981'},
      {label:'Pending Leave',value:pendingLeave,href:'/admin/hr/leave',color:'#fbbf24'},
      {label:'HEI Published',value:heiCount,href:'/admin/hei/institutions',color:'#FF7040'},
    ].map(s=>(
      <a href={s.href} style="text-decoration:none;background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:10px;text-align:center;display:block;">
        <p style={`font-size:22px;font-weight:800;color:${s.color};margin:0;line-height:1;font-family:'Geist Mono',monospace;`}>{s.value}</p>
        <p style="font-size:10px;color:#6e6e78;margin:4px 0 0;line-height:1.3;">{s.label}</p>
      </a>
    ))}
  </div>

  {statusRows.length > 0 && (
    <div style="padding:14px 16px 0;">
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
          <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0;">Application Pipeline</p>
          <a href="/admin/applications" style="font-size:10px;color:#FF7040;text-decoration:none;">View all</a>
        </div>
        <div style="display:flex;flex-direction:column;gap:7px;">
          {statusRows.map((row:any)=>{
            if (!row || !row.status) return null;
            const pct = appCount > 0 ? Math.round((row.n/appCount)*100) : 0;
            const color = STATUS_COLOR[row.status] || '#6e6e78';
            return (
              <div>
                <div style="display:flex;justify-content:space-between;margin-bottom:3px;">
                  <span style={`font-size:11px;font-weight:600;color:${color};text-transform:capitalize;`}>{row.status.replace('_',' ')}</span>
                  <span style="font-size:11px;color:#6e6e78;font-family:'Geist Mono',monospace;">{row.n} ({pct}%)</span>
                </div>
                <div style="background:#15151a;border-radius:100px;height:3px;">
                  <div style={`background:${color};height:100%;width:${pct}%;border-radius:100px;`}></div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  )}

  <div style="padding:14px 16px 0;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
      <p style="font-size:13px;font-weight:600;color:#fff;margin:0;">Recent Applications</p>
      <a href="/admin/applications" style="font-size:11px;color:#FF7040;text-decoration:none;">View all</a>
    </div>
    <div style="display:flex;flex-direction:column;gap:6px;">
      {recentApps.length === 0 && (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:24px;text-align:center;color:#6e6e78;font-size:12px;">No applications yet</div>
      )}
      {recentApps.map((a:any)=>{
        if (!a) return null;
        const name = ((a.first_name||'')+' '+(a.last_name||'')).trim()||a.email||'Unknown';
        const color = STATUS_COLOR[a.status||'']||'#6e6e78';
        const date = a.created_at ? new Date(a.created_at).toLocaleDateString('en-IN',{day:'numeric',month:'short'}) : '';
        return (
          <a href={`/admin/applications/${a.id}`} style="text-decoration:none;background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:10px 12px;display:flex;align-items:center;gap:10px;">
            <div style={`width:34px;height:34px;border-radius:50%;background:${color}22;border:1px solid ${color}44;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;color:${color};flex-shrink:0;`}>{name.substring(0,1).toUpperCase()}</div>
            <div style="flex:1;min-width:0;">
              <p style="font-size:13px;font-weight:600;color:#fff;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{name}</p>
              <p style="font-size:11px;color:#6e6e78;margin:1px 0 0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{a.role_title_snapshot||'No role'}</p>
            </div>
            <div style="display:flex;flex-direction:column;align-items:flex-end;gap:3px;flex-shrink:0;">
              <span style={`font-size:9px;font-weight:700;padding:2px 7px;border-radius:100px;text-transform:uppercase;background:${color}22;color:${color};`}>{a.status}</span>
              <span style="font-size:10px;color:#6e6e78;">{date}</span>
            </div>
          </a>
        );
      })}
    </div>
  </div>

  <div style="padding:14px 16px 0;">
    <p style="font-size:13px;font-weight:600;color:#fff;margin:0 0 10px;">Quick Actions</p>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
      {[
        {label:'New Role',href:'/admin/roles/new',color:'#60a5fa'},
        {label:'Add Employee',href:'/admin/hr/employees',color:'#10b981'},
        {label:'Leave Requests',href:'/admin/hr/leave',color:'#fbbf24'},
        {label:'Run Payroll',href:'/admin/hr/payroll',color:'#a78bfa'},
        {label:'HEI Institutions',href:'/admin/hei/institutions',color:'#FF7040'},
        {label:'View Public Site',href:'/',color:'#6e6e78'},
      ].map(action=>(
        <a href={action.href} style={`text-decoration:none;background:#0f0f14;border:1px solid #1a1a1f;border-left:3px solid ${action.color};border-radius:10px;padding:12px;display:flex;align-items:center;`}>
          <span style={`font-size:12px;font-weight:600;color:${action.color};`}>{action.label}</span>
        </a>
      ))}
    </div>
  </div>

</div>
</AdminLayout>
