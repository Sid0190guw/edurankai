---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { applications, roles, events, users, departments } from '@/lib/db/schema';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
   if (!user) return Astro.redirect('/admin/login');
   if (user.role === 'applicant') return Astro.redirect('/portal');
   
const appResult = await db.select({ count: sql<number>`count(*)::int` }).from(applications);
const roleResult = await db.select({ count: sql<number>`count(*)::int` }).from(roles);
const eventResult = await db.select({ count: sql<number>`count(*)::int` }).from(events);
const userResult = await db.select({ count: sql<number>`count(*)::int` }).from(users);
const deptResult = await db.select({ count: sql<number>`count(*)::int` }).from(departments);

const appCount = appResult[0].count;
const roleCount = roleResult[0].count;
const eventCount = eventResult[0].count;
const userCount = userResult[0].count;
const deptCount = deptResult[0].count;

const stats = [
  { label: 'Applications', value: appCount, meta: 'all-time submissions', href: '/admin/applications' },
  { label: 'Open Roles', value: roleCount, meta: 'across all departments', href: '/admin/roles' },
  { label: 'Events', value: eventCount, meta: 'upcoming + past', href: '/admin/events' },
  { label: 'Users', value: userCount, meta: 'staff + applicants', href: '/admin/users' }
];

const firstName = user.name ? user.name.split(' ')[0] : 'there';

const hourNow = new Date().getHours();
let greeting = 'Good evening';
if (hourNow < 12) greeting = 'Good morning';
else if (hourNow < 17) greeting = 'Good afternoon';
---
<AdminLayout title="Dashboard" activeNav="dashboard">
  <div class="admin-page">
    <div class="admin-page-header">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">Overview</div>
        <h1 class="admin-page-title">{greeting}, {firstName}.</h1>
        <p class="admin-page-sub">Welcome back to the EduRankAI control panel. Everything below is live data from your Neon database.</p>
      </div>
      <a href="/" class="admin-btn">View Public Site</a>
    </div>

    <div class="admin-grid-4" style="margin-bottom:24px;">
      {stats.map((s) => {
        const v = s.value;
        const l = s.label;
        const m = s.meta;
        const h = s.href;
        return (
          <a href={h} style="text-decoration:none;color:inherit;display:block;" class="admin-card">
            <div class="admin-card-title">{l}</div>
            <div class="admin-card-value">{v}</div>
            <div class="admin-card-meta">{m}</div>
          </a>
        );
      })}
    </div>

    <div class="admin-grid-2">
      <div class="admin-card">
        <div class="admin-card-title">Recent Applications</div>
        <div class="admin-table-empty" style="padding:32px 16px;">
          No applications yet. Once the Apply form goes live in Message 9, submissions land here.
        </div>
      </div>

      <div class="admin-card">
        <div class="admin-card-title">Quick Actions</div>
        <div style="display:flex;flex-direction:column;gap:8px;margin-top:8px;">
          <a href="/admin/roles" class="admin-btn" style="justify-content:flex-start;">Create new role</a>
          <a href="/admin/events" class="admin-btn" style="justify-content:flex-start;">Schedule event</a>
          <a href="/admin/products" class="admin-btn" style="justify-content:flex-start;">Add product</a>
          <a href="/admin/users" class="admin-btn" style="justify-content:flex-start;">Invite team member</a>
        </div>
      </div>
    </div>

    <div style="margin-top:24px;padding:16px;background:#0e0e12;border:1px solid #1a1a20;border-radius:10px;font-size:12px;color:#8a8a94;line-height:1.7;">
      <strong style="color:#fff;font-weight:600;">Build progress:</strong> The skeleton, database, auth, and admin shell are live. You have {deptCount} departments and {userCount} user(s) in the system. Coming next: roles CRUD, public careers, applications inbox, and the public apply form.
    </div>
  </div>
</AdminLayout>
