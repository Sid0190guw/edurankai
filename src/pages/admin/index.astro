---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const firstName = user.name ? user.name.split(' ')[0] : 'there';
const hour = new Date().getHours();
const greeting = hour < 12 ? 'Good morning' : hour < 17 ? 'Good afternoon' : 'Good evening';

let appCount = 0, roleCount = 0, userCount = 0, eventCount = 0, newThisWeek = 0;
let statusRows: any[] = [];
let recentApps: any[] = [];

try {
  const counts = await db.execute(sql`
    SELECT
      (SELECT COUNT(*)::int FROM applications) as apps,
      (SELECT COUNT(*)::int FROM roles) as roles,
      (SELECT COUNT(*)::int FROM users) as users,
      (SELECT COUNT(*)::int FROM events) as events,
      (SELECT COUNT(*)::int FROM applications WHERE created_at >= NOW() - INTERVAL '7 days') as new_this_week
  `);
  const r = counts.rows[0] as any;
  appCount = r.apps || 0;
  roleCount = r.roles || 0;
  userCount = r.users || 0;
  eventCount = r.events || 0;
  newThisWeek = r.new_this_week || 0;
} catch(e) {}

try {
  const sc = await db.execute(sql`SELECT status, COUNT(*)::int as n FROM applications GROUP BY status ORDER BY n DESC`);
  statusRows = sc.rows as any[];
} catch(e) {}

try {
  const ra = await db.execute(sql`SELECT id, first_name, last_name, email, role_title_snapshot, status FROM applications ORDER BY created_at DESC LIMIT 5`);
  recentApps = ra.rows as any[];
} catch(e) {}

const STATUS_COLOR: Record<string, string> = {
  submitted: '#fbbf24', reviewing: '#60a5fa', shortlisted: '#34d399',
  interview: '#a78bfa', offered: '#f97316', hired: '#10b981',
  rejected: '#f87171', withdrawn: '#6b7280',
};
---
<AdminLayout title="Dashboard" activeNav="dashboard">
<div style="padding-bottom:80px;">

  <!-- Header -->
  <div style="background:linear-gradient(135deg,#0f0f14 0%,#15151a 100%);border-bottom:1px solid #1a1a1f;padding:20px 16px 16px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.14em;text-transform:uppercase;margin:0 0 4px;">{new Date().toLocaleDateString('en-IN',{weekday:'long',day:'numeric',month:'long'})}</p>
    <h1 style="font-size:22px;font-weight:700;color:#fff;margin:0 0 4px;">{greeting}, {firstName}.</h1>
    <p style="font-size:12px;color:#6e6e78;margin:0;">EduRankAI Admin Panel</p>
  </div>

  <!-- Stats grid -->
  <div style="padding:16px;display:grid;grid-template-columns:1fr 1fr;gap:10px;">
    {[
      { label: 'Applications', value: appCount, sub: newThisWeek + ' new this week', href: '/admin/applications', color: '#FF7040' },
      { label: 'Open Roles', value: roleCount, sub: 'across departments', href: '/admin/roles', color: '#60a5fa' },
      { label: 'Events', value: eventCount, sub: 'upcoming + past', href: '/admin/events', color: '#34d399' },
      { label: 'Users', value: userCount, sub: 'staff + applicants', href: '/admin/users', color: '#a78bfa' },
    ].map(s => (
      <a href={s.href} style="text-decoration:none;background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;display:block;position:relative;overflow:hidden;">
        <div style={`position:absolute;top:0;left:0;right:0;height:2px;background:${s.color};`}></div>
        <p style={`font-size:28px;font-weight:800;color:${s.color};margin:0;line-height:1;font-family:'Geist Mono',monospace;`}>{s.value}</p>
        <p style="font-size:12px;font-weight:600;color:#fff;margin:6px 0 2px;">{s.label}</p>
        <p style="font-size:10px;color:#6e6e78;margin:0;">{s.sub}</p>
      </a>
    ))}
  </div>

  <!-- Pipeline -->
  {statusRows.length > 0 && (
    <div style="padding:0 16px 16px;">
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;">
        <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0 0 12px;">Application Pipeline</p>
        <div style="display:flex;flex-direction:column;gap:8px;">
          {statusRows.map((row: any) => {
            const pct = appCount > 0 ? Math.round((row.n / appCount) * 100) : 0;
            const color = STATUS_COLOR[row.status] || '#6e6e78';
            return (
              <div>
                <div style="display:flex;justify-content:space-between;margin-bottom:4px;">
                  <span style={`font-size:11px;font-weight:600;color:${color};text-transform:capitalize;`}>{row.status}</span>
                  <span style="font-size:11px;color:#6e6e78;font-family:'Geist Mono',monospace;">{row.n} ({pct}%)</span>
                </div>
                <div style="background:#15151a;border-radius:100px;height:4px;">
                  <div style={`background:${color};height:100%;width:${pct}%;border-radius:100px;`}></div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  )}

  <!-- Recent applications -->
  <div style="padding:0 16px 16px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
      <p style="font-size:13px;font-weight:600;color:#fff;margin:0;">Recent Applications</p>
      <a href="/admin/applications" style="font-size:11px;color:#FF7040;text-decoration:none;">View all</a>
    </div>
    <div style="display:flex;flex-direction:column;gap:6px;">
      {recentApps.length === 0 && (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:24px;text-align:center;color:#6e6e78;font-size:12px;">No applications yet</div>
      )}
      {recentApps.map((a: any) => {
        const name = ((a.first_name||'') + ' ' + (a.last_name||'')).trim() || a.email;
        const color = STATUS_COLOR[a.status||''] || '#6e6e78';
        return (
          <a href={`/admin/applications/${a.id}`} style="text-decoration:none;background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:10px 12px;display:flex;align-items:center;gap:10px;">
            <div style={`width:36px;height:36px;border-radius:50%;background:${color}22;border:1px solid ${color}44;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;color:${color};flex-shrink:0;`}>{name.substring(0,1).toUpperCase()}</div>
            <div style="flex:1;min-width:0;">
              <p style="font-size:13px;font-weight:600;color:#fff;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{name}</p>
              <p style="font-size:11px;color:#6e6e78;margin:2px 0 0;">{a.role_title_snapshot || 'No role'}</p>
            </div>
            <span style={`font-size:9px;font-weight:700;padding:2px 8px;border-radius:100px;text-transform:uppercase;background:${color}22;color:${color};`}>{a.status}</span>
          </a>
        );
      })}
    </div>
  </div>

  <!-- Quick actions -->
  <div style="padding:0 16px;">
    <p style="font-size:13px;font-weight:600;color:#fff;margin:0 0 10px;">Quick Actions</p>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
      {[
        { label: 'New Role', href: '/admin/roles/new' },
        { label: 'HR Employees', href: '/admin/hr/employees' },
        { label: 'Leave Requests', href: '/admin/hr/leave' },
        { label: 'HEI Institutions', href: '/admin/hei/institutions' },
        { label: 'Run Payroll', href: '/admin/hr/payroll' },
        { label: 'View Public Site', href: '/' },
      ].map(action => (
        <a href={action.href} style="text-decoration:none;background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px;display:flex;align-items:center;">
          <span style="font-size:12px;font-weight:600;color:#d8d8de;">{action.label}</span>
        </a>
      ))}
    </div>
  </div>

</div>
</AdminLayout>
