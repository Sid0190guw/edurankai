---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { adminSectionLabel } from '@/lib/admin-sections';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const deniedKey = Astro.url.searchParams.get('denied');
const deniedLabel = deniedKey ? adminSectionLabel(deniedKey) : '';

const firstName = user.name ? user.name.split(' ')[0] : 'there';
const hour = new Date().getHours();
const greeting = hour < 12 ? 'Good morning' : hour < 17 ? 'Good afternoon' : 'Good evening';

let appCount = 0, roleCount = 0, userCount = 0, eventCount = 0, newThisWeek = 0;
let empCount = 0, pendingLeave = 0, heiCount = 0;
let statusRows: any[] = [];
let recentApps: any[] = [];

try {
  const counts = await db.execute(sql`
    SELECT
      (SELECT COUNT(*) FROM applications)::int as a,
      (SELECT COUNT(*) FROM roles WHERE is_open = true)::int as r,
      (SELECT COUNT(*) FROM users WHERE role != 'applicant')::int as u,
      (SELECT COUNT(*) FROM events)::int as e,
      (SELECT COUNT(*) FROM applications WHERE created_at >= NOW() - INTERVAL '7 days')::int as nw,
      (SELECT COUNT(*) FROM hei_institutions WHERE is_published = true)::int as h,
      (SELECT COUNT(*) FROM hr_employees WHERE is_active = true)::int as emp,
      (SELECT COUNT(*) FROM hr_leave_requests WHERE status = 'pending')::int as lv
  `);
  // postgres-js driver returns array directly, not {rows:[]}
  const row = (Array.isArray(counts) ? counts[0] : counts?.rows?.[0]) as any;
  if (row) {
    appCount = Number(row.a) || 0;
    roleCount = Number(row.r) || 0;
    userCount = Number(row.u) || 0;
    eventCount = Number(row.e) || 0;
    newThisWeek = Number(row.nw) || 0;
    heiCount = Number(row.h) || 0;
    empCount = Number(row.emp) || 0;
    pendingLeave = Number(row.lv) || 0;
  }
} catch(e) { console.error('Dashboard stats error:', e); }
try {
  const rs = await db.execute(sql`SELECT status, COUNT(*)::int as n FROM applications GROUP BY status ORDER BY n DESC`);
  statusRows = (Array.isArray(rs) ? rs : (rs?.rows || [])) as any[];
} catch(e) {}
try {
  const rra = await db.execute(sql`SELECT id, first_name, last_name, email, role_title_snapshot, status, created_at FROM applications ORDER BY created_at DESC LIMIT 6`);
  recentApps = (Array.isArray(rra) ? rra : (rra?.rows || [])) as any[];
} catch(e) {}

const STATUS_COLOR: Record<string,string> = {
  submitted:'#fbbf24',reviewing:'#60a5fa',shortlisted:'#34d399',
  interview:'#a78bfa',offered:'#f97316',hired:'#10b981',
  rejected:'#f87171',withdrawn:'#6b7280',task_sent:'#e879f9',
};
---
<AdminLayout title="Dashboard" activeNav="dashboard">
<div style="padding-bottom:80px;">

  {deniedLabel && (
    <div style="margin:12px 16px 0;background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.28);border-radius:10px;padding:11px 14px;display:flex;align-items:center;gap:10px;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f87171" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M15 9l-6 6M9 9l6 6"/></svg>
      <p style="font-size:12.5px;color:#fca5a5;margin:0;">You don't have access to <b>{deniedLabel}</b>. Ask an admin to grant it under Custom Roles.</p>
    </div>
  )}

  <div style="background:linear-gradient(135deg,#0f0f14 0%,#15151a 100%);border-bottom:1px solid #1a1a1f;">
    <div class="dash-wrap" style="padding:26px 22px 22px;">
      <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.14em;text-transform:uppercase;margin:0 0 4px;">{new Date().toLocaleDateString('en-IN',{ timeZone: 'Asia/Kolkata',weekday:'long',day:'numeric',month:'long',year:'numeric'})}</p>
      <h1 style="font-size:clamp(22px,3vw,30px);font-weight:800;color:#fff;margin:0 0 3px;line-height:1.1;letter-spacing:-0.02em;">{greeting}, {firstName}.</h1>
      <p style="font-size:12.5px;color:#6e6e78;margin:0;">EduRankAI Admin · Live data</p>
    </div>
  </div>

  <div class="dash-wrap" style="padding:20px 22px 0;">
    <div class="dash-stats">
      {[
        {label:'Applications',value:appCount,sub:newThisWeek+' new this week',href:'/admin/applications',color:'#FF7040'},
        {label:'Open Roles',value:roleCount,sub:'actively hiring',href:'/admin/roles',color:'#60a5fa'},
        {label:'Active Staff',value:userCount,sub:'admin users',href:'/admin/users',color:'#a78bfa'},
        {label:'Events',value:eventCount,sub:'total events',href:'/admin/events',color:'#34d399'},
      ].map(s=>(
        <a href={s.href} class="ds-tap ds-reveal dash-card" style="text-decoration:none;background:#0f0f14;border:1px solid #1a1a1f;border-radius:16px;padding:20px;display:block;position:relative;overflow:hidden;">
          <div style={`position:absolute;inset:0;pointer-events:none;background:radial-gradient(180px 120px at 82% -10%, ${s.color}33, transparent 70%);`}></div>
          <div style={`position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg, ${s.color}, transparent);box-shadow:0 0 12px ${s.color};`}></div>
          <p class="ds-count" data-count={s.value} style={`font-size:38px;font-weight:800;color:${s.color};margin:0;line-height:1;font-family:'Space Grotesk','Geist Mono',monospace;letter-spacing:-0.02em;text-shadow:0 0 24px ${s.color}55;position:relative;`}>0</p>
          <p style="font-size:13px;font-weight:700;color:#fff;margin:9px 0 2px;position:relative;">{s.label}</p>
          <p style="font-size:10.5px;color:#9aa6b6;margin:0;position:relative;">{s.sub}</p>
        </a>
      ))}
    </div>

    <div class="dash-mini" style="margin-top:12px;">
      {[
        {label:'Employees',value:empCount,href:'/admin/hr/employees',color:'#10b981'},
        {label:'Pending Leave',value:pendingLeave,href:'/admin/hr/leave',color:'#fbbf24'},
        {label:'HEI Published',value:heiCount,href:'/admin/hei/institutions',color:'#FF7040'},
      ].map(s=>(
        <a href={s.href} class="ds-tap ds-reveal dash-card" style="text-decoration:none;background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:12px;text-align:center;display:block;">
          <p class="ds-count" data-count={s.value} style={`font-size:24px;font-weight:800;color:${s.color};margin:0;line-height:1;font-family:'Geist Mono',monospace;`}>0</p>
          <p style="font-size:10.5px;color:#9aa6b6;margin:5px 0 0;line-height:1.3;">{s.label}</p>
        </a>
      ))}
    </div>

    <div class="dash-two" style="margin-top:18px;">
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
          <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#9aa6b6;margin:0;">Application Pipeline</p>
          <a href="/admin/applications" style="font-size:10.5px;color:#FF7040;text-decoration:none;font-weight:600;">View all →</a>
        </div>
        {statusRows.length > 0 ? (
          <div style="display:flex;flex-direction:column;gap:10px;">
            {statusRows.map((row:any)=>{
              if (!row || !row.status) return null;
              const pct = appCount > 0 ? Math.round((row.n/appCount)*100) : 0;
              const color = STATUS_COLOR[row.status] || '#6e6e78';
              return (
                <div>
                  <div style="display:flex;justify-content:space-between;margin-bottom:4px;">
                    <span style={`font-size:11.5px;font-weight:600;color:${color};text-transform:capitalize;`}>{row.status.replace('_',' ')}</span>
                    <span style="font-size:11px;color:#6e6e78;font-family:'Geist Mono',monospace;">{row.n} · {pct}%</span>
                  </div>
                  <div style="background:#15151a;border-radius:100px;height:5px;overflow:hidden;">
                    <div style={`background:${color};height:100%;width:${pct}%;border-radius:100px;box-shadow:0 0 8px ${color}88;`}></div>
                  </div>
                </div>
              );
            })}
          </div>
        ) : (
          <p style="font-size:12px;color:#6e6e78;margin:0;">No pipeline data yet.</p>
        )}
      </div>

      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
          <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#9aa6b6;margin:0;">Recent Applications</p>
          <a href="/admin/applications" style="font-size:10.5px;color:#FF7040;text-decoration:none;font-weight:600;">View all →</a>
        </div>
        <div style="display:flex;flex-direction:column;gap:7px;">
          {recentApps.length === 0 && (
            <div style="padding:20px;text-align:center;color:#6e6e78;font-size:12px;">No applications yet</div>
          )}
          {recentApps.map((a:any)=>{
            if (!a) return null;
            const name = ((a.first_name||'')+' '+(a.last_name||'')).trim()||a.email||'Unknown';
            const color = STATUS_COLOR[a.status||'']||'#6e6e78';
            const date = a.created_at ? new Date(a.created_at).toLocaleDateString('en-IN',{ timeZone: 'Asia/Kolkata',day:'numeric',month:'short'}) : '';
            return (
              <a href={`/admin/applications/${a.id}`} class="dash-row" style="text-decoration:none;background:#121218;border:1px solid #1a1a1f;border-radius:10px;padding:10px 12px;display:flex;align-items:center;gap:10px;">
                <div style={`width:34px;height:34px;border-radius:50%;background:${color}22;border:1px solid ${color}44;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;color:${color};flex-shrink:0;`}>{name.substring(0,1).toUpperCase()}</div>
                <div style="flex:1;min-width:0;">
                  <p style="font-size:13px;font-weight:600;color:#fff;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{name}</p>
                  <p style="font-size:11px;color:#6e6e78;margin:1px 0 0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{a.role_title_snapshot||'No role'}</p>
                </div>
                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:3px;flex-shrink:0;">
                  <span style={`font-size:9px;font-weight:700;padding:2px 7px;border-radius:100px;text-transform:uppercase;background:${color}22;color:${color};`}>{a.status}</span>
                  <span style="font-size:10px;color:#6e6e78;">{date}</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </div>

    <div style="margin-top:18px;padding-bottom:8px;">
      <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#9aa6b6;margin:0 0 10px;">Quick Actions</p>
      <div class="dash-qa">
        {[
          {label:'New Role',href:'/admin/roles/new',color:'#60a5fa'},
          {label:'Add Employee',href:'/admin/hr/employees',color:'#10b981'},
          {label:'Leave Requests',href:'/admin/hr/leave',color:'#fbbf24'},
          {label:'Run Payroll',href:'/admin/hr/payroll',color:'#a78bfa'},
          {label:'HEI Institutions',href:'/admin/hei/institutions',color:'#FF7040'},
          {label:'View Public Site',href:'/',color:'#6e6e78'},
        ].map(action=>(
          <a href={action.href} class="dash-qa-card" style={`text-decoration:none;background:#0f0f14;border:1px solid #1a1a1f;border-left:3px solid ${action.color};border-radius:10px;padding:13px 14px;display:flex;align-items:center;justify-content:space-between;gap:8px;`}>
            <span style={`font-size:12.5px;font-weight:600;color:${action.color};`}>{action.label}</span>
            <span style={`font-size:13px;color:${action.color};opacity:0.6;`}>→</span>
          </a>
        ))}
      </div>
    </div>
  </div>

</div>

<style>
  .dash-wrap { max-width: 1180px; margin: 0 auto; }
  .dash-stats { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 12px; }
  .dash-mini { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 10px; }
  .dash-two { display: grid; grid-template-columns: 1fr; gap: 14px; }
  .dash-qa { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 10px; }
  .dash-card, .dash-row, .dash-qa-card { transition: transform .18s ease, border-color .18s ease, background .18s ease; }
  .dash-card:hover { transform: translateY(-2px); border-color: #2a2a33; }
  .dash-row:hover { background: #16161d; border-color: #2a2a33; }
  .dash-qa-card:hover { transform: translateY(-1px); background: #15151c; }
  @media (min-width: 760px) {
    .dash-stats { grid-template-columns: repeat(4, minmax(0,1fr)); }
    .dash-two { grid-template-columns: 1fr 1fr; align-items: start; }
    .dash-qa { grid-template-columns: repeat(3, minmax(0,1fr)); }
  }
  @media (prefers-reduced-motion: reduce) {
    .dash-card, .dash-row, .dash-qa-card { transition: none; }
    .dash-card:hover, .dash-qa-card:hover { transform: none; }
  }
</style>
</AdminLayout>
