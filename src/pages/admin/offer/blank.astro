---
import AdminLayout from '@/layouts/AdminLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const today = new Date().toISOString().split('T')[0];
const defaults = {
  candidateName: '',
  candidateEmail: '',
  candidatePhone: '',
  candidateCity: '',
  roleTitle: '',
  department: '',
  employmentType: 'Internship',
  workMode: 'Remote',
  duration: '3 Months',
  hoursCommitment: '2.5 hrs/day, 5 days/week',
  compensation: 'Unpaid',
  reportingTo: '',
  offerDate: today,
  joiningDate: '',
  expiryDate: '',
  responseDeadline: '',
  signatoryName: user.name || 'Siddharth Prasad',
  signatoryTitle: 'Founder & CEO',
  customNote: '',
  language: 'en',
  templateType: 'intern',
  refNumber: 'ERA-CUSTOM-' + Date.now().toString().slice(-6)
};
---
<AdminLayout title="Custom Offer Letter" description="Build a standalone custom offer letter (no applicant link required).">
  <div class="mb-4">
    <a href="/admin/applications" class="text-[0.78rem] text-white/50 hover:text-white">&larr; Back to applications</a>
  </div>

  <div class="mb-5 pb-4 border-b border-white/8">
    <p class="font-mono text-[0.7rem] text-burn">CUSTOM</p>
    <h1 class="font-display text-[1.6rem] font-semibold text-white">Build Custom Offer Letter</h1>
    <p class="text-[0.85rem] text-white/60 mt-1">Fill any details. Download as PDF directly. Not linked to any applicant in the system.</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

    <!-- FORM (left, 2 cols) -->
    <div class="lg:col-span-2 flex flex-col gap-4">

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Candidate</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div><label class="rfl">Name *</label><input id="f_candidateName" type="text" class="rfi" value={defaults.candidateName} placeholder="Recipient name" /></div>
          <div><label class="rfl">Email *</label><input id="f_candidateEmail" type="email" class="rfi" value={defaults.candidateEmail} placeholder="recipient@example.com" /></div>
          <div><label class="rfl">Phone</label><input id="f_candidatePhone" type="text" class="rfi" value={defaults.candidatePhone} /></div>
          <div><label class="rfl">City</label><input id="f_candidateCity" type="text" class="rfi" value={defaults.candidateCity} /></div>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Role & Terms</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div><label class="rfl">Role Title *</label><input id="f_roleTitle" type="text" class="rfi" value={defaults.roleTitle} placeholder="e.g. AI Researcher" /></div>
          <div><label class="rfl">Department</label><input id="f_department" type="text" class="rfi" value={defaults.department} /></div>
          <div><label class="rfl">Template Type</label>
            <select id="f_templateType" class="rfi">
              <option value="intern">Intern / Apprentice</option>
              <option value="fulltime">Full-Time</option>
              <option value="contract">Contract</option>
              <option value="leadership">Leadership / C-Level</option>
            </select>
          </div>
          <div><label class="rfl">Employment Type</label>
            <select id="f_employmentType" class="rfi">
              <option value="Internship">Internship</option>
              <option value="Apprenticeship">Apprenticeship</option>
              <option value="Full-Time">Full-Time</option>
              <option value="Contract">Contract</option>
              <option value="Part-Time">Part-Time</option>
            </select>
          </div>
          <div><label class="rfl">Work Mode</label>
            <select id="f_workMode" class="rfi">
              <option value="Remote">Remote</option>
              <option value="Hybrid">Hybrid</option>
              <option value="On-Site">On-Site</option>
            </select>
          </div>
          <div><label class="rfl">Duration</label><input id="f_duration" type="text" class="rfi" value={defaults.duration} /></div>
          <div><label class="rfl">Hours Commitment</label><input id="f_hoursCommitment" type="text" class="rfi" value={defaults.hoursCommitment} /></div>
          <div><label class="rfl">Compensation</label><input id="f_compensation" type="text" class="rfi" value={defaults.compensation} placeholder="Unpaid / Amount / Not Disclosed" /></div>
          <div class="md:col-span-2"><label class="rfl">Reporting To</label><input id="f_reportingTo" type="text" class="rfi" value={defaults.reportingTo} placeholder="e.g. Head of AI" /></div>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Dates</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div><label class="rfl">Offer Date</label><input id="f_offerDate" type="date" class="rfi" value={defaults.offerDate} /></div>
          <div><label class="rfl">Joining Date</label><input id="f_joiningDate" type="date" class="rfi" value={defaults.joiningDate} /></div>
          <div><label class="rfl">Response Deadline</label><input id="f_responseDeadline" type="date" class="rfi" value={defaults.responseDeadline} /></div>
          <div><label class="rfl">Offer Expiry</label><input id="f_expiryDate" type="date" class="rfi" value={defaults.expiryDate} /></div>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Signatory & Letter</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div><label class="rfl">Signatory Name *</label><input id="f_signatoryName" type="text" class="rfi" value={defaults.signatoryName} /></div>
          <div><label class="rfl">Signatory Title</label><input id="f_signatoryTitle" type="text" class="rfi" value={defaults.signatoryTitle} /></div>
          <div><label class="rfl">Ref Number</label><input id="f_refNumber" type="text" class="rfi" value={defaults.refNumber} /></div>
          <div><label class="rfl">Language</label>
            <select id="f_language" class="rfi">
              <option value="en">English</option>
              <option value="hi">हिन्दी</option>
              <option value="sa">संस्कृत</option>
              <option value="es">Español</option>
            </select>
          </div>
          <div class="md:col-span-2"><label class="rfl">Custom Note (optional)</label><textarea id="f_customNote" rows="3" class="rfi resize-y"></textarea></div>
        </div>
      </div>

      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        <button type="button" id="previewBtn" class="bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.95rem]">Preview Offer</button>
        <button type="button" id="downloadBtn" class="bg-ink hover:bg-ink/90 text-white border border-white/20 font-semibold py-2.5 px-5 rounded-lg text-[0.95rem]">Download PDF</button>
        <button type="button" id="printBtn" class="bg-white/10 hover:bg-white/15 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.95rem]">Print</button>
      </div>

    </div>

    <!-- PREVIEW (right, 1 col) -->
    <div class="lg:col-span-1">
      <div class="sticky top-4">
        <div id="offerPreview" style="background:#ffffff;color:#0a0a0c;padding:38px 30px;border-radius:12px;font-family:'Inter',system-ui,sans-serif;min-height:580px;">
          <div style="text-align:center;padding-bottom:24px;border-bottom:2px solid #FF4F00;">
            <h2 style="font-family:'Fraunces',serif;font-size:24px;font-weight:600;color:#0a0a0c;margin:0;">EduRank<span style="color:#FF4F00;">AI</span></h2>
            <p style="font-size:11px;color:#6b6b76;margin:4px 0 0;font-family:'Geist Mono',monospace;letter-spacing:0.1em;">BHARAT-BUILT FRONTIER AI LAB</p>
          </div>

          <div style="display:flex;justify-content:space-between;margin-top:24px;font-size:11px;color:#6b6b76;font-family:'Geist Mono',monospace;">
            <span>Ref: <span id="p_ref">—</span></span>
            <span id="p_offerDate">—</span>
          </div>

          <h3 style="font-family:'Fraunces',serif;font-size:22px;color:#0a0a0c;margin:24px 0 12px;font-weight:600;">Offer of <span id="p_employmentType">Internship</span></h3>

          <p style="font-size:14px;line-height:1.7;color:#3a3a40;margin-bottom:18px;">
            Dear <strong id="p_candidateName" style="color:#0a0a0c;">[Name]</strong>,
          </p>

          <p style="font-size:13.5px;line-height:1.65;color:#3a3a40;">
            We are pleased to offer you the position of <strong id="p_roleTitle" style="color:#0a0a0c;">[Role]</strong><span id="p_deptWrap"> in the <strong id="p_department" style="color:#0a0a0c;">[Dept]</strong> department</span> at EduRankAI.
          </p>

          <table style="width:100%;margin:18px 0;font-size:13px;border-collapse:collapse;">
            <tr><td style="padding:6px 0;color:#6b6b76;">Employment Type:</td><td style="padding:6px 0;color:#0a0a0c;font-weight:500;" id="p_empType2">—</td></tr>
            <tr><td style="padding:6px 0;color:#6b6b76;">Work Mode:</td><td style="padding:6px 0;color:#0a0a0c;font-weight:500;" id="p_workMode">—</td></tr>
            <tr><td style="padding:6px 0;color:#6b6b76;">Duration:</td><td style="padding:6px 0;color:#0a0a0c;font-weight:500;" id="p_duration">—</td></tr>
            <tr><td style="padding:6px 0;color:#6b6b76;">Hours:</td><td style="padding:6px 0;color:#0a0a0c;font-weight:500;" id="p_hours">—</td></tr>
            <tr><td style="padding:6px 0;color:#6b6b76;">Compensation:</td><td style="padding:6px 0;color:#0a0a0c;font-weight:500;" id="p_comp">—</td></tr>
            <tr><td style="padding:6px 0;color:#6b6b76;">Joining Date:</td><td style="padding:6px 0;color:#0a0a0c;font-weight:500;" id="p_joining">—</td></tr>
            <tr id="p_reportRow"><td style="padding:6px 0;color:#6b6b76;">Reporting To:</td><td style="padding:6px 0;color:#0a0a0c;font-weight:500;" id="p_reportingTo">—</td></tr>
          </table>

          <div id="p_customNoteWrap" style="display:none;margin:14px 0;padding:14px;background:#faf8f4;border-left:3px solid #FF4F00;border-radius:0 6px 6px 0;font-size:12.5px;line-height:1.6;color:#3a3a40;">
            <span id="p_customNote"></span>
          </div>

          <p style="font-size:12.5px;color:#3a3a40;line-height:1.65;margin-top:18px;">
            <strong>Response deadline:</strong> <span id="p_responseDeadline">—</span><br>
            <strong>Offer expires:</strong> <span id="p_expiry">—</span>
          </p>

          <p style="font-size:13px;color:#3a3a40;line-height:1.65;margin-top:24px;">
            We're excited at the possibility of you joining us. Please confirm your acceptance by the response deadline.
          </p>

          <div style="margin-top:36px;">
            <p style="font-size:13px;margin:0;color:#3a3a40;">Warm regards,</p>
            <p style="font-family:'Fraunces',serif;font-style:italic;font-size:18px;margin:6px 0;color:#0a0a0c;" id="p_signatoryName">—</p>
            <p style="font-size:12px;color:#6b6b76;margin:0;" id="p_signatoryTitle">—</p>
            <p style="font-size:11px;color:#6b6b76;margin:2px 0 0;">EduRankAI</p>
          </div>

          <div style="margin-top:30px;padding-top:14px;border-top:1px solid #e5e5ea;font-size:9.5px;color:#a0a0ab;font-family:'Geist Mono',monospace;text-align:center;">
            <p style="margin:0;">EDURANKAI.IN · BHARAT</p>
          </div>
        </div>

        <p class="text-[0.7rem] text-white/40 mt-3 text-center">Live preview · updates as you type</p>
      </div>
    </div>

  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>

  <script is:inline>
    (function() {
      function $(id) { return document.getElementById(id); }
      function val(id) { var el = $(id); return el ? (el.value || '') : ''; }
      function fmtDate(d) { return d ? new Date(d).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) : '—'; }

      function refresh() {
        $('p_candidateName').textContent = val('f_candidateName') || '[Name]';
        $('p_roleTitle').textContent = val('f_roleTitle') || '[Role]';

        var dept = val('f_department');
        if (dept) {
          $('p_deptWrap').style.display = '';
          $('p_department').textContent = dept;
        } else {
          $('p_deptWrap').style.display = 'none';
        }

        var empType = val('f_employmentType');
        $('p_employmentType').textContent = empType || 'Internship';
        $('p_empType2').textContent = empType || '—';
        $('p_workMode').textContent = val('f_workMode') || '—';
        $('p_duration').textContent = val('f_duration') || '—';
        $('p_hours').textContent = val('f_hoursCommitment') || '—';
        $('p_comp').textContent = val('f_compensation') || '—';
        $('p_joining').textContent = fmtDate(val('f_joiningDate'));

        var rep = val('f_reportingTo');
        if (rep) { $('p_reportRow').style.display = ''; $('p_reportingTo').textContent = rep; }
        else { $('p_reportRow').style.display = 'none'; }

        $('p_responseDeadline').textContent = fmtDate(val('f_responseDeadline'));
        $('p_expiry').textContent = fmtDate(val('f_expiryDate'));
        $('p_signatoryName').textContent = val('f_signatoryName') || '—';
        $('p_signatoryTitle').textContent = val('f_signatoryTitle') || '—';
        $('p_ref').textContent = val('f_refNumber') || '—';
        $('p_offerDate').textContent = fmtDate(val('f_offerDate'));

        var note = val('f_customNote');
        if (note && note.trim()) {
          $('p_customNoteWrap').style.display = '';
          $('p_customNote').textContent = note;
        } else {
          $('p_customNoteWrap').style.display = 'none';
        }
      }

      // Bind live updates
      var inputs = document.querySelectorAll('.rfi');
      for (var i = 0; i < inputs.length; i++) {
        inputs[i].addEventListener('input', refresh);
        inputs[i].addEventListener('change', refresh);
      }
      refresh();

      // Preview button just refreshes
      $('previewBtn').addEventListener('click', refresh);

      // Download PDF
      $('downloadBtn').addEventListener('click', function() {
        refresh();
        var btn = $('downloadBtn');
        btn.disabled = true;
        btn.textContent = 'Generating PDF...';
        var preview = $('offerPreview');
        if (typeof html2canvas === 'undefined' || typeof window.jspdf === 'undefined') {
          alert('PDF library not loaded. Refresh and try again.');
          btn.disabled = false;
          btn.textContent = 'Download PDF';
          return;
        }
        html2canvas(preview, { scale: 2, backgroundColor: '#ffffff' }).then(function(canvas) {
          var imgData = canvas.toDataURL('image/jpeg', 0.95);
          var pdf = new window.jspdf.jsPDF('p', 'mm', 'a4');
          var pdfW = 210, pdfH = 297;
          var imgW = pdfW;
          var imgH = (canvas.height * pdfW) / canvas.width;
          var heightLeft = imgH;
          var pos = 0;
          pdf.addImage(imgData, 'JPEG', 0, pos, imgW, imgH);
          heightLeft -= pdfH;
          while (heightLeft > 0) {
            pos = heightLeft - imgH;
            pdf.addPage();
            pdf.addImage(imgData, 'JPEG', 0, pos, imgW, imgH);
            heightLeft -= pdfH;
          }
          var name = (val('f_candidateName') || 'Custom').replace(/[^a-zA-Z0-9-_]/g, '_');
          pdf.save('EduRankAI-Offer-' + name + '.pdf');
          btn.disabled = false;
          btn.textContent = 'Download PDF';
        }).catch(function(err) {
          alert('PDF generation failed: ' + err.message);
          btn.disabled = false;
          btn.textContent = 'Download PDF';
        });
      });

      // Print
      $('printBtn').addEventListener('click', function() {
        refresh();
        window.print();
      });
    })();
  </script>

  <style>
    .rfl { display:block;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.5);margin-bottom:6px; }
    .rfi { width:100%;padding:9px 12px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:8px;color:#fff;font-size:13px;font-family:inherit;outline:none;transition:border-color 0.15s; }
    .rfi:focus { border-color:#FF4F00; }
    textarea.rfi { resize:vertical; }

    @media print {
      body * { visibility: hidden; }
      #offerPreview, #offerPreview * { visibility: visible; }
      #offerPreview { position: absolute; left: 0; top: 0; width: 100%; }
    }
  </style>
</AdminLayout>