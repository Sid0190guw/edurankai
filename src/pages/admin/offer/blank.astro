---
import AdminLayout from '@/layouts/AdminLayout.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { applications, brandProfiles } from '@/lib/db/schema';
import { eq, asc } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');

// Token-aware access: if user is applicant, allow only when ?from=<their-own-app-id>
const urlForGate = new URL(Astro.request.url);
const fromAppId = urlForGate.searchParams.get('from');

if (user.role === 'applicant') {
  if (!fromAppId) return Astro.redirect('/portal');
  const ownCheck = await db.select({ uid: applications.applicantUserId }).from(applications)
    .where(eq(applications.id, fromAppId))
    .limit(1);
  if (ownCheck.length === 0 || ownCheck[0].uid !== user.id) return Astro.redirect('/portal');
}

// Pick layout based on role: applicants get BaseLayout (no admin chrome)
const Layout: any = user.role === 'applicant' ? BaseLayout : AdminLayout;
const isApplicant = user.role === 'applicant';

// Load brand profiles
let brands: any[] = [];
try {
  brands = await db.select().from(brandProfiles).where(eq(brandProfiles.isActive, true)).orderBy(asc(brandProfiles.sortOrder));
} catch (e) {
  // Table may not exist yet
  brands = [];
}

if (brands.length === 0) {
  brands = [
    { slug: 'edurankai', name: 'EduRankAI', tagline: 'BHARAT-BUILT FRONTIER AI LAB', primaryColor: '#FF4F00', domain: 'edurankai.in' },
    { slug: 'karate-support', name: 'Karate Support', tagline: 'POWERED BY EDURANKAI', primaryColor: '#FF4F00', domain: 'karate.support' },
    { slug: 'other', name: 'Other', tagline: 'POWERED BY EDURANKAI', primaryColor: '#FF4F00', domain: null }
  ];
}

// Pre-fill from applicationId
let prefill: any = null;
if (fromAppId) {
  const found = await db.select().from(applications).where(eq(applications.id, fromAppId)).limit(1);
  if (found.length > 0) prefill = found[0];
}

const today = new Date().toISOString().split('T')[0];
const refNumber = 'ERA-2026-' + Math.random().toString(36).substring(2, 8).toUpperCase();

const defaults = {
  brandSlug: 'edurankai',
  candidateName: prefill ? ((prefill.firstName || '') + ' ' + (prefill.lastName || '')).trim() : '',
  candidateEmail: prefill ? prefill.email : '',
  candidatePhone: prefill && prefill.phone ? prefill.phone : '',
  candidateCity: prefill && prefill.city ? prefill.city : '',
  roleTitle: prefill && prefill.roleTitleSnapshot ? prefill.roleTitleSnapshot : '',
  department: prefill && prefill.departmentSnapshot ? prefill.departmentSnapshot : '',
  employmentType: 'Internship',
  workMode: 'Remote',
  duration: '3 Months',
  hoursCommitment: '2.5 hrs/day, 5 days/week',
  compensation: 'Unpaid',
  reportingTo: '',
  offerDate: today,
  joiningDate: '',
  expiryDate: '',
  responseDeadline: '',
  signatoryName: user.name || 'Siddharth Prasad',
  signatoryTitle: 'Founder & CEO',
  customNote: '',
  refNumber
};

const brandsJson = JSON.stringify(brands);
---
<Layout title="Offer Letter Builder" description="Professional offer letter builder with brand switching.">
<style is:global>
  body.applicant-view-mode .ofl,
  body.applicant-view-mode .ofi,
  body.applicant-view-mode .form-section,
  body.applicant-view-mode #leftPanel,
  body.applicant-view-mode .left-form-column,
  body.applicant-view-mode .lg\:col-span-1 > .bg-white\/5,
  body.applicant-view-mode .lg\:col-span-2 > .bg-white\/5,
  body.applicant-view-mode .grid > div:has(.ofl),
  body.applicant-view-mode .grid > div:first-child {
    display: none !important;
  }
  body.applicant-view-mode .grid {
    display: block !important;
    grid-template-columns: none !important;
  }
  body.applicant-view-mode #downloadBtn,
  body.applicant-view-mode #printBtn {
    display: inline-block !important;
    position: fixed;
    bottom: 24px;
    z-index: 100;
  }
  body.applicant-view-mode #downloadBtn { left: 24px; }
  body.applicant-view-mode #printBtn { left: 200px; }
</style>
<script is:inline define:vars={{ isApp: isApplicant }}>
  if (isApp) document.body.classList.add('applicant-view-mode');
</script>

  <div class="mb-4">
    <a href="/admin/applications" class="text-[0.78rem] text-white/50 hover:text-white">&larr; Back to applications</a>
  </div>

  <div class="mb-5 pb-4 border-b border-white/8">
    <p class="font-mono text-[0.7rem] text-burn">OFFER BUILDER</p>
    <h1 class="font-display text-[1.6rem] font-semibold text-white">Create Offer Letter</h1>
    <p class="text-[0.85rem] text-white/60 mt-1">Live preview. Switch brand. Download as PDF or print.</p>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-5 gap-5">

    <!-- FORM (left, 2 of 5 cols) -->
    <div class="xl:col-span-2 flex flex-col gap-4">

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Brand</h2>
        <div><label class="rfl">Brand profile</label>
          <select id="f_brandSlug" class="rfi">
            {brands.map((b: any) => <option value={b.slug} selected={b.slug === defaults.brandSlug}>{b.name}</option>)}
          </select>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Candidate</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div><label class="rfl">Name *</label><input id="f_candidateName" type="text" class="rfi" value={defaults.candidateName} placeholder="Full name" /></div>
          <div><label class="rfl">Email *</label><input id="f_candidateEmail" type="email" class="rfi" value={defaults.candidateEmail} /></div>
          <div><label class="rfl">Phone</label><input id="f_candidatePhone" type="text" class="rfi" value={defaults.candidatePhone} /></div>
          <div><label class="rfl">City</label><input id="f_candidateCity" type="text" class="rfi" value={defaults.candidateCity} /></div>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Role &amp; Terms</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div><label class="rfl">Role *</label><input id="f_roleTitle" type="text" class="rfi" value={defaults.roleTitle} placeholder="e.g. AI Researcher" /></div>
          <div><label class="rfl">Department</label><input id="f_department" type="text" class="rfi" value={defaults.department} /></div>
          <div><label class="rfl">Employment Type</label>
            <select id="f_employmentType" class="rfi">
              <option value="Internship" selected>Internship</option>
              <option value="Apprenticeship">Apprenticeship</option>
              <option value="Full-Time">Full-Time</option>
              <option value="Contract">Contract</option>
              <option value="Part-Time">Part-Time</option>
            </select>
          </div>
          <div><label class="rfl">Work Mode</label>
            <select id="f_workMode" class="rfi">
              <option value="Remote" selected>Remote</option>
              <option value="Hybrid">Hybrid</option>
              <option value="On-Site">On-Site</option>
            </select>
          </div>
          <div><label class="rfl">Duration</label><input id="f_duration" type="text" class="rfi" value={defaults.duration} /></div>
          <div><label class="rfl">Hours</label><input id="f_hoursCommitment" type="text" class="rfi" value={defaults.hoursCommitment} /></div>
          <div><label class="rfl">Compensation</label><input id="f_compensation" type="text" class="rfi" value={defaults.compensation} /></div>
          <div><label class="rfl">Reporting To</label><input id="f_reportingTo" type="text" class="rfi" value={defaults.reportingTo} placeholder="e.g. Head of AI" /></div>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Dates</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div><label class="rfl">Offer Date</label><input id="f_offerDate" type="date" class="rfi" value={defaults.offerDate} /></div>
          <div><label class="rfl">Joining Date</label><input id="f_joiningDate" type="date" class="rfi" value={defaults.joiningDate} /></div>
          <div><label class="rfl">Response Deadline</label><input id="f_responseDeadline" type="date" class="rfi" value={defaults.responseDeadline} /></div>
          <div><label class="rfl">Offer Expiry</label><input id="f_expiryDate" type="date" class="rfi" value={defaults.expiryDate} /></div>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-5">
        <h2 class="font-display text-[1rem] font-semibold text-white mb-3">Signatory</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div><label class="rfl">Name *</label><input id="f_signatoryName" type="text" class="rfi" value={defaults.signatoryName} /></div>
          <div><label class="rfl">Title</label><input id="f_signatoryTitle" type="text" class="rfi" value={defaults.signatoryTitle} /></div>
          <div><label class="rfl">Reference No.</label><input id="f_refNumber" type="text" class="rfi" value={defaults.refNumber} /></div>
          <div class="md:col-span-2"><label class="rfl">Custom note (optional)</label><textarea id="f_customNote" rows="2" class="rfi resize-y"></textarea></div>
        </div>
      </div>

      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        <button type="button" id="downloadBtn" class="bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.95rem]">Download PDF</button>
        <button type="button" id="printBtn" class="bg-white/10 hover:bg-white/15 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.95rem]">Print</button>
      </div>
    </div>

    <!-- PROFESSIONAL OFFER LETTER PREVIEW (right, 3 of 5 cols) -->
    <div class="xl:col-span-3">
      <div class="sticky top-4">
        <article id="offerLetter" style="background:#fdfcf8;color:#1a1a1f;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.25);font-family:'Inter',system-ui,sans-serif;border:1px solid rgba(0,0,0,0.06);">

          <!-- HEADER -->
          <header id="ol_header" style="background:#fafaf6;padding:32px 36px 26px;border-bottom:3px solid #FF4F00;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:18px;flex-wrap:wrap;">
              <div>
                <p id="ol_brandName" style="font-family:'Fraunces',serif;font-size:30px;font-weight:600;color:#0a0a0c;line-height:1;margin:0;letter-spacing:-0.02em;">Edu<em style="font-style:italic;color:#FF4F00;font-weight:500;">Rank</em>AI</p>
                <p id="ol_tagline" style="font-size:10px;font-family:'Geist Mono',monospace;letter-spacing:0.18em;color:#FF4F00;margin:6px 0 0;font-weight:700;">BHARAT-BUILT FRONTIER AI LAB</p>
                <p id="ol_addr1" style="font-size:11px;color:#6b6b76;margin:14px 0 2px;line-height:1.5;">AI Research and Technology — Guwahati, Assam, India</p>
                <p id="ol_addr2" style="font-size:11px;color:#6b6b76;margin:0 0 2px;line-height:1.5;">Guwahati, Assam, India — 781039</p>
                <p id="ol_addr3" style="font-size:11px;color:#6b6b76;margin:0;line-height:1.5;">hr@edurankai.in · www.edurankai.in</p>
              </div>
              <div style="text-align:right;">
                <p style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.16em;color:#9a9aa3;margin:0;">Reference</p>
                <p id="ol_ref" style="font-family:'Geist Mono',monospace;font-size:14px;color:#1a1a1f;margin:3px 0 0;font-weight:600;">—</p>
                <p id="ol_offerDate" style="font-size:11px;color:#6b6b76;margin:6px 0 0;">—</p>
                <p style="display:inline-block;margin-top:8px;font-size:9px;font-weight:700;letter-spacing:0.15em;color:#a16207;border:1px solid rgba(161,98,7,0.3);background:rgba(251,191,36,0.1);border-radius:3px;padding:3px 7px;text-transform:uppercase;">Private &amp; Confidential</p>
              </div>
            </div>
          </header>

          <div style="padding:30px 36px 30px;">

            <!-- CANDIDATE BLOCK -->
            <div style="margin-bottom:20px;">
              <p id="ol_candidateName" style="font-family:'Fraunces',serif;font-size:19px;font-weight:600;color:#0a0a0c;margin:0;">—</p>
              <p id="ol_candidateMeta" style="font-size:12px;color:#6b6b76;margin:4px 0 0;line-height:1.5;">—</p>
            </div>

            <!-- RE CALLOUT -->
            <div style="background:rgba(255,79,0,0.06);border-left:4px solid #FF4F00;border-radius:0 6px 6px 0;padding:12px 14px;margin-bottom:22px;">
              <p style="font-size:14px;color:#0a0a0c;margin:0;font-weight:600;"><span style="color:#6b6b76;font-weight:400;">Re: </span><span id="ol_re">Offer of —</span></p>
            </div>

            <!-- 3-TILE STATS -->
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:22px;">
              <div style="background:rgba(255,79,0,0.05);border:1px solid rgba(255,79,0,0.18);border-radius:9px;padding:12px;text-align:center;">
                <p id="ol_tileDuration" style="font-family:'Fraunces',serif;font-size:15px;font-weight:600;color:#FF4F00;margin:0;">—</p>
                <p style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6b6b76;margin:4px 0 0;">Duration</p>
              </div>
              <div style="background:rgba(255,79,0,0.05);border:1px solid rgba(255,79,0,0.18);border-radius:9px;padding:12px;text-align:center;">
                <p id="ol_tileWorkMode" style="font-family:'Fraunces',serif;font-size:15px;font-weight:600;color:#FF4F00;margin:0;">—</p>
                <p style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6b6b76;margin:4px 0 0;">Work Mode</p>
              </div>
              <div style="background:rgba(255,79,0,0.05);border:1px solid rgba(255,79,0,0.18);border-radius:9px;padding:12px;text-align:center;">
                <p id="ol_tileComp" style="font-family:'Fraunces',serif;font-size:15px;font-weight:600;color:#FF4F00;margin:0;">—</p>
                <p style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6b6b76;margin:4px 0 0;">Compensation</p>
              </div>
            </div>

            <!-- BODY -->
            <div id="ol_body" style="font-size:13.5px;line-height:1.75;color:#3a3a40;margin-bottom:20px;"></div>

            <!-- SUMMARY TABLE -->
            <div style="border-top:1px solid rgba(0,0,0,0.08);padding-top:16px;margin-bottom:20px;">
              <p style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:#6b6b76;margin:0 0 10px;">Offer Summary</p>
              <table style="width:100%;font-size:12.5px;border-collapse:collapse;">
                <tbody id="ol_summary"></tbody>
              </table>
            </div>

            <!-- SIGNATORY + SEAL -->
            <div style="border-top:1px solid rgba(0,0,0,0.08);padding-top:18px;margin-bottom:20px;display:flex;justify-content:space-between;align-items:flex-end;gap:14px;">
              <div>
                <p style="font-size:10.5px;color:#6b6b76;margin:0 0 6px;">Issued <span id="ol_issuedDate">—</span></p>
                <p id="ol_sigName" style="font-family:'Fraunces',serif;font-size:16px;font-weight:600;color:#0a0a0c;margin:0;">—</p>
                <p id="ol_sigTitle" style="font-size:12px;color:#6b6b76;margin:2px 0 0;">—</p>
                <p id="ol_sigOrg" style="font-size:12px;font-weight:600;color:#FF4F00;margin:2px 0 0;">EduRankAI</p>
              </div>
              <div style="width:62px;height:62px;border-radius:50%;border:2px solid rgba(255,79,0,0.35);background:rgba(255,79,0,0.06);display:flex;flex-direction:column;align-items:center;justify-content:center;">
                <span style="color:#FF4F00;font-size:11px;line-height:1;">◆</span>
                <span id="ol_sealText" style="font-size:6.5px;font-weight:700;color:#FF4F00;text-align:center;line-height:1.15;margin-top:2px;">EDU<br/>RANK<br/>AI</span>
              </div>
            </div>

            <!-- VERIFICATION QR -->
            <div style="border-top:1px solid rgba(0,0,0,0.08);padding-top:16px;">
              <p style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:#6b6b76;margin:0 0 9px;">Verification</p>
              <div style="display:flex;align-items:center;gap:12px;background:#f4f1e8;border-radius:8px;padding:12px;">
                <div id="ol_qrBox" style="width:64px;height:64px;background:#fff;border:1px solid rgba(0,0,0,0.08);border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:9.5px;color:#6b6b76;">QR</div>
                <div style="flex:1;font-size:11.5px;color:#3a3a40;line-height:1.55;">
                  <p style="font-weight:600;color:#0a0a0c;margin:0 0 3px;">Verify this offer letter</p>
                  <p style="margin:0 0 2px;">Scan the QR code or visit:</p>
                  <p id="ol_verifyUrl" style="font-family:'Geist Mono',monospace;color:#FF4F00;font-size:10.5px;word-break:break-all;margin:0;">edurankai.in/offer/verify/...</p>
                </div>
              </div>
              <p style="margin-top:8px;font-size:10px;color:#9a9aa3;font-family:'Geist Mono',monospace;">Integrity hash: <span id="ol_hash">—</span></p>
            </div>

          </div>
        </article>
        <p class="text-[0.7rem] text-white/40 mt-3 text-center">Live preview · updates as you type</p>
      </div>
    </div>

  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>

  <script is:inline define:vars={{ brandsJson }}>
    (function() {
      var brands = JSON.parse(brandsJson);
      var brandMap = {};
      for (var i = 0; i < brands.length; i++) brandMap[brands[i].slug] = brands[i];

      function $(id) { return document.getElementById(id); }
      function val(id) { var el = $(id); return el ? (el.value || '') : ''; }
      function fmtDate(d) {
        if (!d) return '—';
        var dt = new Date(d);
        if (isNaN(dt.getTime())) return '—';
        return dt.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
      }

      function fnvHash(s) {
        var h = 2166136261;
        for (var i = 0; i < s.length; i++) {
          h = h ^ s.charCodeAt(i);
          h = Math.imul(h, 16777619);
        }
        return (h >>> 0).toString(36).toUpperCase().padStart(8, '0').substring(0, 8);
      }

      var bodyTemplates = {
        Internship: 'This Internship is offered on the terms summarised herein. You will work <b>{workMode}</b>, committing <b>{hoursCommitment}</b>. The engagement runs for <b>{duration}</b>, commencing <b>{joiningDate}</b>. You will receive mid-point and final reviews assessed via {brandName}\'s rubric-based evaluation. Outstanding performers receive a Letter of Recommendation; all successful completers receive a Certificate of Completion. By accepting, you confirm you have read and agree to {brandName}\'s Recruitment Policy and Code of Conduct.',
        Apprenticeship: 'This Apprenticeship engagement is offered on the terms summarised herein. You will work <b>{workMode}</b> committing <b>{hoursCommitment}</b>, for <b>{duration}</b>, commencing <b>{joiningDate}</b>. Apprentices follow a structured competency pathway with periodic rubric evaluations.',
        'Full-Time': 'This offer is contingent on completion of pre-employment requirements. Your employment commences on <b>{joiningDate}</b> as a Full-Time employee. Onboarding details will be confirmed within 7 days of acceptance. Compensation: <b>{compensation}</b>. Work mode: <b>{workMode}</b>.',
        Contract: 'This Contract engagement runs <b>{duration}</b>, commencing <b>{joiningDate}</b>. Compensation: <b>{compensation}</b>. Deliverables and milestones will be confirmed in the accompanying Statement of Work.',
        'Part-Time': 'This Part-Time engagement commences <b>{joiningDate}</b>, running for <b>{duration}</b>. Hours: <b>{hoursCommitment}</b>. Compensation: <b>{compensation}</b>.'
      };

      function renderBody() {
        var first = (val('f_candidateName') || '').split(' ')[0] || 'Candidate';
        var empType = val('f_employmentType') || 'Internship';
        var role = val('f_roleTitle') || '—';
        var dept = val('f_department');
        var brandSlug = val('f_brandSlug') || 'edurankai';
        var brand = brandMap[brandSlug] || brandMap['edurankai'];
        var brandName = brand ? brand.name : 'EduRankAI';
        var joining = fmtDate(val('f_joiningDate'));
        var workMode = val('f_workMode') || '—';
        var hoursCommit = val('f_hoursCommitment') || '—';
        var duration = val('f_duration') || '—';
        var comp = val('f_compensation') || '—';
        var customNote = val('f_customNote');

        var deptText = dept ? (' within the <b>' + dept + '</b> team') : '';
        var intro = '<p>Dear <b>' + first + '</b>,</p>' +
          '<p>We are pleased to extend this formal offer of an <b>' + empType + '</b> for the position of <b>' + role + '</b>' + deptText + ' at <b>' + brandName + '</b>. Following a thorough evaluation of your application and conversations, we are confident you demonstrate the capability, character, and commitment we look for.</p>';

        var bodyTmpl = bodyTemplates[empType] || bodyTemplates.Internship;
        var bodyParagraph = bodyTmpl
          .replace(/\{workMode\}/g, workMode)
          .replace(/\{hoursCommitment\}/g, hoursCommit)
          .replace(/\{duration\}/g, duration)
          .replace(/\{joiningDate\}/g, joining)
          .replace(/\{compensation\}/g, comp)
          .replace(/\{brandName\}/g, brandName);

        var note = customNote ? ('<p style="font-style:italic;color:#5a5a60;border-left:2px solid rgba(255,79,0,0.3);padding-left:10px;">' + customNote.replace(/</g,'&lt;') + '</p>') : '';

        $('ol_body').innerHTML = intro + '<p>' + bodyParagraph + '</p>' + note;
      }

      function renderSummary() {
        var rows = [
          ['Position', val('f_roleTitle')],
          ['Department', val('f_department')],
          ['Employment Type', val('f_employmentType')],
          ['Work Mode', val('f_workMode')],
          ['Duration', val('f_duration')],
          ['Joining Date', fmtDate(val('f_joiningDate'))],
          ['Reporting To', val('f_reportingTo')],
          ['Working Hours', val('f_hoursCommitment')],
          ['Compensation', val('f_compensation')],
          ['Response Deadline', fmtDate(val('f_responseDeadline'))],
          ['Offer Expires', fmtDate(val('f_expiryDate'))]
        ];
        var html = '';
        for (var i = 0; i < rows.length; i++) {
          var k = rows[i][0], v = rows[i][1];
          if (!v || v === '—') continue;
          html += '<tr style="border-bottom:1px solid rgba(0,0,0,0.05);"><td style="padding:7px 0;color:#6b6b76;width:40%;">' + k + '</td><td style="padding:7px 0;color:#0a0a0c;font-weight:500;">' + v + '</td></tr>';
        }
        $('ol_summary').innerHTML = html;
      }

      function renderHeader() {
        var slug = val('f_brandSlug') || 'edurankai';
        var brand = brandMap[slug] || brandMap['edurankai'] || { name: 'EduRankAI', tagline: 'BHARAT-BUILT FRONTIER AI LAB', domain: 'edurankai.in' };
        // Render brand name with italic Rank emphasis if EduRankAI
        if (brand.slug === 'edurankai') {
          $('ol_brandName').innerHTML = 'Edu<em style="font-style:italic;color:#FF4F00;font-weight:500;">Rank</em>AI';
        } else {
          $('ol_brandName').textContent = brand.name;
        }
        $('ol_tagline').textContent = brand.tagline || '';
        // Address swap
        if (brand.slug === 'edurankai') {
          $('ol_addr1').textContent = 'AI Research and Technology — Guwahati, Assam, India';
          $('ol_addr2').textContent = 'Guwahati, Assam, India — 781039';
          $('ol_addr3').textContent = 'hr@edurankai.in · www.edurankai.in';
        } else if (brand.slug === 'karate-support') {
          $('ol_addr1').textContent = 'Karate Support — Powered by EduRankAI';
          $('ol_addr2').textContent = 'Guwahati, Assam, India';
          $('ol_addr3').textContent = 'support@karate.support · www.karate.support';
        } else {
          $('ol_addr1').textContent = (brand.domain ? (brand.domain + ' — ') : '') + 'Powered by EduRankAI';
          $('ol_addr2').textContent = 'Guwahati, Assam, India';
          $('ol_addr3').textContent = brand.domain ? brand.domain : '';
        }
        $('ol_sigOrg').textContent = brand.name;
        // Seal text
        var sealLines = brand.name.toUpperCase().replace(/[^A-Z0-9]/g,'').match(/.{1,4}/g) || ['ERA'];
        $('ol_sealText').innerHTML = sealLines.slice(0,3).join('<br/>');
      }

      function refresh() {
        renderHeader();
        $('ol_candidateName').textContent = val('f_candidateName') || '—';
        var meta = [];
        if (val('f_candidateEmail')) meta.push(val('f_candidateEmail'));
        if (val('f_candidatePhone')) meta.push(val('f_candidatePhone'));
        if (val('f_candidateCity')) meta.push(val('f_candidateCity'));
        $('ol_candidateMeta').textContent = meta.join(' · ') || '—';

        var role = val('f_roleTitle') || '—';
        var dept = val('f_department');
        var emp = val('f_employmentType') || 'Internship';
        $('ol_re').textContent = 'Offer of ' + emp + ' — ' + role + (dept ? ', ' + dept : '');

        $('ol_tileDuration').textContent = val('f_duration') || '—';
        $('ol_tileWorkMode').textContent = val('f_workMode') || '—';
        $('ol_tileComp').textContent = val('f_compensation') || '—';

        renderBody();
        renderSummary();

        $('ol_ref').textContent = val('f_refNumber') || '—';
        $('ol_offerDate').textContent = fmtDate(val('f_offerDate'));
        $('ol_issuedDate').textContent = fmtDate(val('f_offerDate'));
        $('ol_sigName').textContent = val('f_signatoryName') || '—';
        $('ol_sigTitle').textContent = val('f_signatoryTitle') || '—';

        // Hash + verify URL
        var hashInput = [val('f_refNumber'), val('f_candidateName'), val('f_roleTitle'), val('f_department'), val('f_offerDate'), val('f_employmentType')].join('|');
        var hash = fnvHash(hashInput);
        $('ol_hash').textContent = hash;

        var verifyToken = (val('f_refNumber') || 'PREVIEW') + '-' + hash;
        var verifyUrl = 'https://www.edurankai.in/offer/verify/' + verifyToken;
        $('ol_verifyUrl').textContent = verifyUrl;

        // QR
        var qrBox = $('ol_qrBox');
        if (qrBox && typeof QRCode !== 'undefined') {
          qrBox.innerHTML = '';
          var canvas = document.createElement('canvas');
          canvas.width = 64; canvas.height = 64;
          QRCode.toCanvas(canvas, verifyUrl, { width: 64, margin: 0, color: { dark: '#0a0a0c', light: '#ffffff' } }, function(err) {
            if (!err) {
              canvas.style.width = '64px';
              canvas.style.height = '64px';
              qrBox.appendChild(canvas);
            } else {
              qrBox.textContent = 'QR';
            }
          });
        }
      }

      // Bind live updates to all .rfi inputs
      var inputs = document.querySelectorAll('.rfi');
      for (var i = 0; i < inputs.length; i++) {
        inputs[i].addEventListener('input', refresh);
        inputs[i].addEventListener('change', refresh);
      }
      // Initial render after slight delay (QRCode lib loading)
      setTimeout(refresh, 250);
      refresh();

      // Download PDF
      $('downloadBtn').addEventListener('click', function() {
        refresh();
        var btn = $('downloadBtn');
        btn.disabled = true;
        btn.textContent = 'Generating PDF...';
        if (typeof html2canvas === 'undefined' || typeof window.jspdf === 'undefined') {
          alert('PDF library still loading. Try again in 2 seconds.');
          btn.disabled = false;
          btn.textContent = 'Download PDF';
          return;
        }
        var target = $('offerLetter');
        html2canvas(target, { scale: 2, backgroundColor: '#fdfcf8', useCORS: true }).then(function(canvas) {
          var imgData = canvas.toDataURL('image/jpeg', 0.95);
          var pdf = new window.jspdf.jsPDF('p', 'mm', 'a4');
          var pdfW = 210, pdfH = 297;
          var imgH = (canvas.height * pdfW) / canvas.width;
          var heightLeft = imgH;
          var pos = 0;
          pdf.addImage(imgData, 'JPEG', 0, pos, pdfW, imgH);
          heightLeft -= pdfH;
          while (heightLeft > 0) {
            pos = heightLeft - imgH;
            pdf.addPage();
            pdf.addImage(imgData, 'JPEG', 0, pos, pdfW, imgH);
            heightLeft -= pdfH;
          }
          var name = (val('f_candidateName') || 'Offer').replace(/[^a-zA-Z0-9-_]/g, '_');
          var brand = brandMap[val('f_brandSlug')] || { name: 'EduRankAI' };
          pdf.save(brand.name.replace(/[^a-zA-Z0-9-]/g,'') + '-Offer-' + name + '.pdf');
          btn.disabled = false;
          btn.textContent = 'Download PDF';
        }).catch(function(err) {
          alert('PDF failed: ' + err.message);
          btn.disabled = false;
          btn.textContent = 'Download PDF';
        });
      });

      // Print
      $('printBtn').addEventListener('click', function() {
        refresh();
        setTimeout(function() { window.print(); }, 200);
      });
    })();
  </script>

  <style>
    .rfl { display:block;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.5);margin-bottom:6px; }
    .rfi { width:100%;padding:9px 12px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:8px;color:#fff;font-size:13px;font-family:inherit;outline:none;transition:border-color 0.15s; }
    .rfi:focus { border-color:#FF4F00; }
    textarea.rfi { resize:vertical; }
    @media print {
      body * { visibility: hidden; }
      #offerLetter, #offerLetter * { visibility: visible; }
      #offerLetter { position: absolute; left: 0; top: 0; width: 100%; box-shadow: none !important; border: none !important; border-radius: 0 !important; }
    }
  </style>
</Layout>