---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const envCheck = {
  DATABASE_URL: !!process.env.DATABASE_URL,
  RAZORPAY_KEY_ID: !!process.env.RAZORPAY_KEY_ID,
  RAZORPAY_KEY_SECRET: !!process.env.RAZORPAY_KEY_SECRET,
  RAZORPAY_WEBHOOK_SECRET: !!process.env.RAZORPAY_WEBHOOK_SECRET,
  ANTHROPIC_API_KEY: !!process.env.ANTHROPIC_API_KEY,
  BLOB_READ_WRITE_TOKEN: !!process.env.BLOB_READ_WRITE_TOKEN,
  VAPID_PUBLIC_KEY: !!process.env.VAPID_PUBLIC_KEY,
  VAPID_PRIVATE_KEY: !!process.env.VAPID_PRIVATE_KEY,
};

// Razorpay key id prefix (rzp_live_ vs rzp_test_) - tells you which environment
let razorpayMode: string | null = null;
if (process.env.RAZORPAY_KEY_ID) {
  if (process.env.RAZORPAY_KEY_ID.startsWith('rzp_live_')) razorpayMode = 'LIVE';
  else if (process.env.RAZORPAY_KEY_ID.startsWith('rzp_test_')) razorpayMode = 'TEST';
  else razorpayMode = 'UNKNOWN';
}

// Table presence
let tableCheck: any = {};
try {
  const r = await db.execute(sql`
    SELECT
      EXISTS(SELECT 1 FROM information_schema.tables WHERE table_name='users')::boolean as users,
      EXISTS(SELECT 1 FROM information_schema.tables WHERE table_name='tests')::boolean as tests,
      EXISTS(SELECT 1 FROM information_schema.tables WHERE table_name='test_attempts')::boolean as test_attempts,
      EXISTS(SELECT 1 FROM information_schema.tables WHERE table_name='test_attempt_events')::boolean as test_attempt_events,
      EXISTS(SELECT 1 FROM information_schema.tables WHERE table_name='payments')::boolean as payments,
      EXISTS(SELECT 1 FROM information_schema.tables WHERE table_name='schools')::boolean as schools,
      EXISTS(SELECT 1 FROM information_schema.tables WHERE table_name='academic_departments')::boolean as academic_departments,
      EXISTS(SELECT 1 FROM information_schema.tables WHERE table_name='training_courses')::boolean as training_courses,
      EXISTS(SELECT 1 FROM information_schema.tables WHERE table_name='training_paths')::boolean as training_paths,
      EXISTS(SELECT 1 FROM information_schema.tables WHERE table_name='training_instructors')::boolean as training_instructors,
      EXISTS(SELECT 1 FROM information_schema.tables WHERE table_name='ai_interview_sessions')::boolean as ai_interview_sessions,
      EXISTS(SELECT 1 FROM information_schema.tables WHERE table_name='help_conversations')::boolean as help_conversations,
      EXISTS(SELECT 1 FROM information_schema.tables WHERE table_name='identity_verifications')::boolean as identity_verifications,
      EXISTS(SELECT 1 FROM information_schema.tables WHERE table_name='user_face_enrollments')::boolean as user_face_enrollments
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  tableCheck = rows[0] || {};
} catch (_) {}

// Row counts
let counts: any = {};
try {
  const r = await db.execute(sql`
    SELECT
      (SELECT COUNT(*) FROM users)::int as users,
      (SELECT COUNT(*) FROM tests WHERE is_published = true)::int as published_tests,
      (SELECT COUNT(*) FROM tests WHERE is_premium = true)::int as premium_tests,
      (SELECT COUNT(*) FROM test_questions)::int as test_questions,
      (SELECT COUNT(*) FROM test_attempts)::int as test_attempts,
      (SELECT COUNT(*) FROM test_attempt_events)::int as test_attempt_events,
      (SELECT COUNT(*) FROM payments WHERE status = 'paid')::int as paid_payments,
      (SELECT COUNT(*) FROM schools)::int as schools,
      (SELECT COUNT(*) FROM academic_departments)::int as academic_departments,
      (SELECT COUNT(*) FROM training_courses WHERE is_published = true)::int as published_courses,
      (SELECT COUNT(*) FROM user_face_enrollments WHERE is_active = true)::int as face_enrolled_users,
      (SELECT COUNT(*) FROM identity_verifications)::int as identity_verifications
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  counts = rows[0] || {};
} catch (_) {}

const KEY_ROUTES = [
  { name: 'AquinTutor homepage', url: '/aquintutor', desc: 'Editorial newspaper landing' },
  { name: 'Schools catalogue', url: '/aquintutor/schools', desc: 'Six schools index' },
  { name: 'AquinTutor sign-in', url: '/aquintutor/login', desc: 'Editorial sign-in' },
  { name: 'AquinTutor sign-up', url: '/aquintutor/signup', desc: 'Editorial enrolment' },
  { name: 'Course catalogue', url: '/aquintutor/courses', desc: 'All published courses' },
  { name: 'Quantum Challenge', url: '/aquintutor/test/quantum-challenge-100', desc: '100 MCQ, 1 CHF, ATLAS proctored' },
  { name: 'Identity setup', url: '/identity-setup', desc: 'Gov ID + face match' },
  { name: 'Question-set recovery', url: '/verify-by-questions', desc: 'Knowledge-question identity recovery' },
  { name: 'Forgot password', url: '/forgot-password', desc: 'Email + DOB reset' },
  { name: 'Admin overview', url: '/admin/aquintutor', desc: 'AquinTutor hub' },
  { name: 'Admin schools', url: '/admin/schools', desc: 'Schools + departments CRUD' },
  { name: 'Admin tests', url: '/admin/tests', desc: 'Tests list' },
  { name: 'Admin attempts log', url: '/admin/tests/attempts', desc: 'Per-attempt event log' },
  { name: 'Admin identity verifications', url: '/admin/identity-verifications', desc: 'Face/ID verdicts' },
  { name: 'Admin AI interviews', url: '/admin/interviews/ai', desc: 'AI interview sessions' },
  { name: 'Help inbox', url: '/admin/help', desc: 'Visitor chat conversations' },
];
---
<AdminLayout title="System Diagnostics" activeNav="diagnostics">
  <div style="max-width:1280px;margin:0 auto;padding:24px;color:#f4f1ea;font-family:'Space Grotesk',system-ui,sans-serif;">

    <div style="margin-bottom:24px;">
      <p style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#d97757;margin:0 0 6px;font-weight:500;">System &middot; Diagnostics</p>
      <h1 style="font-family:'Instrument Serif',serif;font-size:clamp(28px,3vw,40px);font-weight:400;color:#f4f1ea;margin:0;">Operational readiness</h1>
      <p style="font-size:13px;color:#c8c3b8;margin:8px 0 0;max-width:680px;line-height:1.55;">Env keys, DB tables, row counts, key public routes. Refresh after adding env vars in Vercel to confirm they were picked up by the deploy.</p>
    </div>

    <!-- Env keys -->
    <div style="background:#14181d;border:1px solid #2a3038;border-radius:14px;padding:18px 22px;margin-bottom:18px;">
      <h2 style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;margin:0 0 14px;font-weight:600;">Environment variables ({Object.values(envCheck).filter(Boolean).length} / {Object.keys(envCheck).length} set)</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:10px;">
        {Object.entries(envCheck).map(([k, v]) => (
          <div style={'background:#1c2128;border:1px solid ' + (v ? 'rgba(125,211,168,0.35)' : 'rgba(224,122,108,0.35)') + ';border-radius:10px;padding:11px 14px;'}>
            <p style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#f4f1ea;margin:0;font-weight:600;">{k}</p>
            <p style={'font-family:JetBrains Mono,monospace;font-size:10.5px;margin:4px 0 0;letter-spacing:0.16em;text-transform:uppercase;color:' + (v ? '#7dd3a8' : '#e07a6c') + ';'}>{v ? 'OK - configured' : 'MISSING'}</p>
          </div>
        ))}
      </div>
      {razorpayMode && (
        <p style="font-family:JetBrains Mono,monospace;font-size:11px;color:#7fb3ff;margin:12px 0 0;letter-spacing:0.1em;">Razorpay key mode: <strong>{razorpayMode}</strong>{razorpayMode === 'LIVE' && ' - real money will be charged on Quantum Challenge enrolments.'}{razorpayMode === 'TEST' && ' - test mode, no real money charged.'}</p>
      )}
      {!envCheck.RAZORPAY_KEY_ID && (
        <p style="font-family:JetBrains Mono,monospace;font-size:11px;color:#f0b54f;margin:12px 0 0;">If you added RAZORPAY_* to Team Shared in Vercel, you must <strong>link them to this project</strong> from the Shared env vars page, then redeploy. Or add at the Project level: <code style="background:#1c2128;padding:2px 6px;border-radius:4px;">/edurankai-s-projects/edurankai/settings/environment-variables</code></p>
      )}
    </div>

    <!-- DB Tables -->
    <div style="background:#14181d;border:1px solid #2a3038;border-radius:14px;padding:18px 22px;margin-bottom:18px;">
      <h2 style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;margin:0 0 14px;font-weight:600;">Database tables ({Object.values(tableCheck).filter(Boolean).length} / {Object.keys(tableCheck).length} present)</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:8px;">
        {Object.entries(tableCheck).map(([k, v]) => (
          <div style={'background:#1c2128;border:1px solid ' + (v ? '#2a3038' : 'rgba(224,122,108,0.35)') + ';border-radius:8px;padding:9px 12px;display:flex;align-items:center;justify-content:space-between;'}>
            <span style="font-family:'JetBrains Mono',monospace;font-size:11.5px;color:#f4f1ea;">{k}</span>
            <span style={'font-family:JetBrains Mono,monospace;font-size:9px;letter-spacing:0.16em;color:' + (v ? '#7dd3a8' : '#e07a6c') + ';'}>{v ? 'OK' : 'MISSING'}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Counts -->
    <div style="background:#14181d;border:1px solid #2a3038;border-radius:14px;padding:18px 22px;margin-bottom:18px;">
      <h2 style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;margin:0 0 14px;font-weight:600;">Live counts</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px;">
        {Object.entries(counts).map(([k, v]) => (
          <div style="background:#1c2128;border:1px solid #2a3038;border-radius:10px;padding:11px 14px;">
            <p style="font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;margin:0 0 4px;font-weight:500;">{k.replace(/_/g, ' ')}</p>
            <p style="font-family:'JetBrains Mono',monospace;font-size:20px;font-weight:600;color:#f4f1ea;margin:0;font-variant-numeric:tabular-nums;">{v as any}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Key routes -->
    <div style="background:#14181d;border:1px solid #2a3038;border-radius:14px;padding:18px 22px;">
      <h2 style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#8a8579;margin:0 0 14px;font-weight:600;">Key routes ({KEY_ROUTES.length})</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:8px;">
        {KEY_ROUTES.map((r) => (
          <a href={r.url} target="_blank" style="background:#1c2128;border:1px solid #2a3038;border-radius:8px;padding:10px 14px;text-decoration:none;color:#f4f1ea;display:block;">
            <p style="font-size:12.5px;font-weight:600;margin:0;">{r.name}</p>
            <p style="font-family:'JetBrains Mono',monospace;font-size:10.5px;color:#7fb3ff;margin:3px 0 0;">{r.url}</p>
            <p style="font-size:11px;color:#8a8579;margin:4px 0 0;">{r.desc}</p>
          </a>
        ))}
      </div>
    </div>

  </div>
</AdminLayout>
