---
// /admin/campus — facilities / institutional info management (Prompt 21, admin surface). Gated by
// can(configure, campus). Honest info blocks shown on the campus hub. No immersive content.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { listFacilities } from '@/lib/hub';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'configure', { type: 'campus' });
if (!gate.allow) return Astro.redirect('/admin');
const facilities = await listFacilities().catch(() => []);
const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const IN = 'background:#15151a;border:1px solid #26262c;color:#fff;padding:7px 9px;border-radius:6px;font-size:12px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
---
<AdminLayout title="Campus content" activeNav="campus">
  <div style="max-width:900px;margin:0 auto;padding:24px;">
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0 0 4px;">Campus content</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:0 0 16px;">Honest facilities/institutional info shown on the campus hub (/aquintutor/hub).</p>
    <div id="msg" style="display:none;margin:0 0 12px;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style={CARD}>
      <p style={HD}>Add / update an info block</p>
      <div style="display:flex;gap:6px;flex-wrap:wrap;align-items:end;margin-bottom:8px;">
        <div><label style="font-size:10px;color:#8a8a94;">Key</label><br/><input id="fKey" style={IN} placeholder="library" /></div>
        <div style="flex:1;min-width:180px;"><label style="font-size:10px;color:#8a8a94;">Title</label><br/><input id="fTitle" style={IN + 'width:100%;box-sizing:border-box;'} /></div>
        <div style="width:80px;"><label style="font-size:10px;color:#8a8a94;">Sort</label><br/><input id="fSort" type="number" value="0" style={IN + 'width:100%;'} /></div>
      </div>
      <textarea id="fBody" rows="3" style={IN + 'width:100%;box-sizing:border-box;'} placeholder="Honest description (no fabricated facilities)."></textarea>
      <button id="saveBtn" type="button" style="background:#FF4F00;border:none;color:#fff;font-size:11px;font-weight:700;padding:8px 14px;border-radius:6px;cursor:pointer;margin-top:8px;">Save</button>
    </div>

    <div style={CARD}>
      <p style={HD}>Current blocks ({facilities.length})</p>
      {facilities.length === 0 ? <p style="font-size:12px;color:#6e6e78;margin:0;">None yet.</p> :
        facilities.map((f: any) => <div style="padding:8px 0;border-bottom:1px solid #15151a;"><b style="color:#cfd6da;font-size:13px;">{f.title}</b> <span style="color:#6e6e78;font-size:10.5px;font-family:'Geist Mono',monospace;">{f.key}</span><p style="color:#8a8a94;font-size:12px;margin:3px 0 0;">{f.body}</p></div>)}
    </div>
  </div>
  <script is:inline>
    (function () {
      var msg = document.getElementById('msg');
      document.getElementById('saveBtn').addEventListener('click', function () {
        fetch('/api/admin/campus', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ key: document.getElementById('fKey').value, title: document.getElementById('fTitle').value, body: document.getElementById('fBody').value, sort: document.getElementById('fSort').value }) })
          .then(function (r) { return r.json(); }).then(function (j) { msg.style.display = 'block'; msg.textContent = j.ok ? 'Saved.' : (j.error || 'Failed'); msg.style.background = j.ok ? 'rgba(16,185,129,0.12)' : 'rgba(239,68,68,0.12)'; msg.style.color = j.ok ? '#6ee7b7' : '#fca5a5'; if (j.ok) setTimeout(function () { location.reload(); }, 600); });
      });
    })();
  </script>
</AdminLayout>
