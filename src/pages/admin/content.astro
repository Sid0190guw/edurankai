---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { contentPages } from '@/lib/db/schema';
import { can } from '@/lib/auth/permissions';
import { logAudit } from '@/lib/audit';
import { asc, eq } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!can(user, 'content.view')) return Astro.redirect('/admin');
const canEdit = can(user, 'content.edit');

let errorMsg = '';
let okMsg = '';

if (Astro.request.method === 'POST' && canEdit) {
  const fd = await Astro.request.formData();
  const action = fd.get('_action') as string;
  try {
    if (action === 'create' || action === 'update') {
      const id = fd.get('id') as string;
      const candidate = {
        slug: (fd.get('slug') as string || '').trim().toLowerCase(),
        title: (fd.get('title') as string || '').trim(),
        body: (fd.get('body') as string || ''),
        metaDescription: (fd.get('metaDescription') as string || '').trim() || null,
        isPublished: fd.get('isPublished') === 'on',
        lastEditedByUserId: user.id
      };
      if (!candidate.slug || !candidate.title || !candidate.body) {
        errorMsg = 'Title, slug, and body are required.';
      } else if (!/^[a-z0-9-]+$/.test(candidate.slug)) {
        errorMsg = 'Slug must be lowercase letters, numbers, and hyphens only.';
      } else {
        if (action === 'create') {
          await db.insert(contentPages).values({ ...candidate, version: 1 });
          okMsg = 'Page created: /p/' + candidate.slug;
        } else {
          const current = await db.select({ version: contentPages.version }).from(contentPages).where(eq(contentPages.id, id)).limit(1);
          const nextVersion = (current[0]?.version || 1) + 1;
          await db.update(contentPages).set({ ...candidate, version: nextVersion, updatedAt: new Date() }).where(eq(contentPages.id, id));
          await logAudit({ userId: user.id, action: 'content.update', entity: 'content_page', entityId: id, diff: candidate, ipAddress: Astro.clientAddress });
          okMsg = 'Page updated (v' + nextVersion + ').';
        }
      }
    } else if (action === 'toggle_publish') {
      const id = fd.get('id') as string;
      const current = await db.select({ isPublished: contentPages.isPublished, slug: contentPages.slug }).from(contentPages).where(eq(contentPages.id, id)).limit(1);
      if (current.length > 0) {
        await db.update(contentPages).set({ isPublished: !current[0].isPublished, updatedAt: new Date() }).where(eq(contentPages.id, id));
        okMsg = (current[0].isPublished ? 'Unpublished' : 'Published') + ': /p/' + current[0].slug;
      }
    } else if (action === 'delete') {
      const id = fd.get('id') as string;
      await db.delete(contentPages).where(eq(contentPages.id, id));
      okMsg = 'Page deleted.';
    }
  } catch (err: any) { errorMsg = 'Failed: ' + (err.message || 'Unknown'); }
}

const url = new URL(Astro.request.url);
const editId = url.searchParams.get('edit') || '';
const allPages = await db.select().from(contentPages).orderBy(asc(contentPages.slug));
const editing = editId && editId !== 'new' ? allPages.find(p => p.id === editId) || (await db.select().from(contentPages).where(eq(contentPages.id, editId)).limit(1))[0] : null;
---
<AdminLayout title="Content Pages" activeNav="content">
<div style="padding-bottom:80px;">

  <!-- Header -->
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;justify-content:space-between;">
      <div>
        <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">CMS</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">Content Pages</h1>
      </div>
      {canEdit && !editing && (
        <a href="?edit=new" style="background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:12px;padding:8px 14px;border-radius:8px;text-decoration:none;">+ New Page</a>
      )}
    </div>
  </div>

  {errorMsg && <div style="margin:10px 16px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;">{errorMsg}</div>}
  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  <!-- Page list -->
  <div style="padding:12px 16px;display:flex;flex-direction:column;gap:6px;">
    {allPages.length === 0 && (
      <div style="text-align:center;padding:48px;color:#6e6e78;">
        <p style="font-size:32px;margin-bottom:8px;">📄</p>
        <p style="font-size:13px;">No content pages yet.</p>
      </div>
    )}
    {allPages.map(p => (
      <div style={`background:#0f0f14;border:1px solid ${editing && editing.id === p.id ? '#FF4F00' : '#1a1a1f'};border-radius:10px;overflow:hidden;`}>
        <div style="padding:10px 14px;display:flex;align-items:center;gap:10px;">
          <div style="flex:1;min-width:0;">
            <p style="font-size:13px;font-weight:600;color:#fff;margin:0;">{p.title}</p>
            <p style="font-size:10px;color:#6e6e78;margin:2px 0 0;font-family:'Geist Mono',monospace;">/p/{p.slug} · v{p.version}</p>
          </div>
          <span style={`font-size:9px;font-weight:700;padding:2px 8px;border-radius:100px;${p.isPublished ? 'background:rgba(16,185,129,0.15);color:#6ee7b7;' : 'background:rgba(251,191,36,0.15);color:#fbbf24;'}`}>
            {p.isPublished ? 'Published' : 'Draft'}
          </span>
        </div>
        {canEdit && (
          <div style="border-top:1px solid #1a1a1f;padding:8px 14px;display:flex;gap:6px;">
            <a href={`?edit=${p.id}`} style="flex:1;text-align:center;background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;text-decoration:none;font-size:12px;font-weight:500;padding:6px;border-radius:6px;">Edit</a>
            <form method="POST" style="flex:1;">
              <input type="hidden" name="_action" value="toggle_publish" />
              <input type="hidden" name="id" value={p.id} />
              <button type="submit" style={`width:100%;font-size:12px;font-weight:500;padding:6px;border-radius:6px;border:none;cursor:pointer;${p.isPublished ? 'background:rgba(251,191,36,0.1);color:#fbbf24;' : 'background:rgba(16,185,129,0.1);color:#6ee7b7;'}`}>
                {p.isPublished ? 'Unpublish' : 'Publish'}
              </button>
            </form>
            <a href={`/p/${p.slug}`} target="_blank" style="flex:1;text-align:center;background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;text-decoration:none;font-size:12px;font-weight:500;padding:6px;border-radius:6px;">View ↗</a>
            <form method="POST" style="flex:0;" onsubmit="return confirm('Delete permanently?')">
              <input type="hidden" name="_action" value="delete" />
              <input type="hidden" name="id" value={p.id} />
              <button type="submit" style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);color:#fca5a5;font-size:12px;font-weight:500;padding:6px 10px;border-radius:6px;cursor:pointer;">Del</button>
            </form>
          </div>
        )}
      </div>
    ))}
  </div>

  <!-- Edit/Create form -->
  {canEdit && (editing || editId === 'new') && (
    <div style="padding:0 16px 16px;">
      <div style="background:#0f0f14;border:1px solid #FF4F00;border-radius:12px;padding:16px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
          <p style="font-size:14px;font-weight:700;color:#fff;margin:0;">{editing ? `Edit: ${editing.title}` : 'New Content Page'}</p>
          <a href="/admin/content" style="font-size:12px;color:#6e6e78;text-decoration:none;">Cancel</a>
        </div>
        <form method="POST" style="display:flex;flex-direction:column;gap:12px;">
          <input type="hidden" name="_action" value={editing ? 'update' : 'create'} />
          {editing && <input type="hidden" name="id" value={editing.id} />}
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Title *</label>
            <input name="title" required value={editing ? editing.title : ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Slug *</label>
            <input name="slug" required pattern="[a-z0-9-]+" placeholder="privacy-policy" value={editing ? editing.slug : ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;font-family:'Geist Mono',monospace;" />
            <p style="font-size:10px;color:#6e6e78;margin:4px 0 0;">Public URL: /p/{editing ? editing.slug : 'slug'}</p>
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Meta Description</label>
            <input name="metaDescription" maxlength="300" placeholder="Shown in search results" value={editing && editing.metaDescription ? editing.metaDescription : ''} style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:13px;outline:none;" />
          </div>
          <div>
            <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:5px;">Body (Markdown) *</label>
            <textarea name="body" rows="14" required placeholder="# Heading&#10;&#10;Your content here..." style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:10px 12px;color:#fff;font-size:12px;outline:none;font-family:'Geist Mono',monospace;line-height:1.6;resize:vertical;">{editing ? editing.body : ''}</textarea>
            <p style="font-size:10px;color:#6e6e78;margin:4px 0 0;">Supports standard Markdown: # headings, **bold**, _italic_, [links](url), - lists</p>
          </div>
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
            <input type="checkbox" name="isPublished" style="accent-color:#FF4F00;width:16px;height:16px;" checked={editing ? editing.isPublished : false} />
            <span style="font-size:13px;color:#d8d8de;">Publish (visible at /p/{editing ? editing.slug : 'slug'})</span>
          </label>
          <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">
            {editing ? 'Save Changes' : 'Create Page'}
          </button>
        </form>
      </div>
    </div>
  )}

</div>
</AdminLayout>
