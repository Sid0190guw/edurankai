---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { createApiKey, listApiKeys, revokeApiKey } from '@/lib/api-keys';
import { SITE } from '@/lib/site';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

let okMsg = '', errMsg = '', newKey = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const action = (fd.get('action') as string) || '';
    if (action === 'create') {
      const label = (fd.get('label') as string || '').trim().slice(0, 200);
      const organization = (fd.get('organization') as string || '').trim().slice(0, 200);
      const created = await createApiKey({ label, organization, createdBy: user.id });
      newKey = created.key;
      okMsg = 'API key created. Copy it now - it is shown only once.';
    } else if (action === 'revoke') {
      await revokeApiKey(fd.get('id') as string);
      okMsg = 'Key revoked.';
    }
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 240); }
}

const keys = await listApiKeys();
const base = SITE.url.replace(/\/$/, '');
function fmt(d: any) { try { return d ? new Date(d).toLocaleString('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) : '-'; } catch { return '-'; } }
---
<AdminLayout title="API Keys" activeNav="api-keys">
  <div style="max-width:1000px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Integrations</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">University &amp; partner API keys</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:720px;line-height:1.55;">Issue a key to a university or LMS so they can pull our lab + course catalogue over REST and embed our labs in their own platform. Keys are read-only.</p>

    {okMsg && <div style="background:rgba(16,185,129,0.12);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;padding:10px 14px;border-radius:8px;margin:14px 0;font-size:13px;">{okMsg}</div>}
    {errMsg && <div style="background:rgba(239,68,68,0.12);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;padding:10px 14px;border-radius:8px;margin:14px 0;font-size:13px;">{errMsg}</div>}

    {newKey && (
      <div style="background:#0d1117;border:1px solid #67e8f9;border-radius:12px;padding:16px;margin:14px 0;">
        <p style="font-size:10px;color:#67e8f9;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;margin:0 0 8px;font-weight:700;">Your new API key - copy it now</p>
        <code style="display:block;background:#08080a;border:1px solid #1a1a1f;border-radius:8px;padding:12px 14px;color:#fff;font-size:13px;word-break:break-all;font-family:'Geist Mono',monospace;">{newKey}</code>
        <p style="font-size:11px;color:#8a8a94;margin:8px 0 0;">Store it securely. We only keep a hash - it cannot be shown again.</p>
      </div>
    )}

    <details style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:14px 18px;margin:16px 0;">
      <summary style="cursor:pointer;font-size:13px;font-weight:700;color:#fff;">+ Issue a new API key</summary>
      <form method="POST" style="margin-top:14px;display:grid;grid-template-columns:1fr 1fr auto;gap:10px;align-items:end;">
        <input type="hidden" name="action" value="create" />
        <div><label style="font-size:10px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;">Organization</label><input name="organization" placeholder="IIT Example" style="width:100%;background:#15151a;border:1px solid #1a1a1f;color:#fff;padding:8px 10px;border-radius:6px;font-size:13px;margin-top:4px;" /></div>
        <div><label style="font-size:10px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;">Label</label><input name="label" placeholder="Production LMS" style="width:100%;background:#15151a;border:1px solid #1a1a1f;color:#fff;padding:8px 10px;border-radius:6px;font-size:13px;margin-top:4px;" /></div>
        <button type="submit" style="background:#FF4F00;color:#fff;border:none;font-size:13px;font-weight:700;padding:9px 16px;border-radius:8px;cursor:pointer;">Create key</button>
      </form>
    </details>

    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;overflow:hidden;margin-bottom:18px;">
      <div style="display:grid;grid-template-columns:1.2fr 1fr 110px 130px 80px 70px;gap:8px;padding:10px 14px;background:#15151a;border-bottom:1px solid #1a1a1f;font-family:'Geist Mono',monospace;font-size:9px;letter-spacing:0.12em;text-transform:uppercase;color:#8a8a94;font-weight:700;">
        <div>Organization</div><div>Prefix</div><div>Status</div><div>Last used</div><div>Calls</div><div></div>
      </div>
      {keys.length === 0 && <div style="padding:24px;text-align:center;color:#8a8a94;font-size:13px;">No keys yet.</div>}
      {keys.map((k: any) => (
        <div style="display:grid;grid-template-columns:1.2fr 1fr 110px 130px 80px 70px;gap:8px;padding:11px 14px;border-bottom:1px solid #15151a;align-items:center;">
          <div style="min-width:0;"><p style="font-size:12.5px;color:#fff;margin:0;font-weight:600;">{k.organization || '-'}</p><p style="font-size:10.5px;color:#8a8a94;margin:2px 0 0;">{k.label || ''}</p></div>
          <code style="font-size:11px;color:#cfd6da;font-family:'Geist Mono',monospace;">{k.key_prefix}...</code>
          <span style={'font-size:10px;font-family:Geist Mono,monospace;text-transform:uppercase;font-weight:700;padding:2px 8px;border-radius:100px;' + (k.is_active ? 'background:rgba(16,185,129,0.16);color:#6ee7b7;' : 'background:rgba(239,68,68,0.16);color:#fca5a5;')}>{k.is_active ? 'Active' : 'Revoked'}</span>
          <span style="font-size:11px;color:#8a8a94;font-family:'Geist Mono',monospace;">{fmt(k.last_used_at)}</span>
          <span style="font-size:12px;color:#cfd6da;font-family:'Geist Mono',monospace;">{k.request_count || 0}</span>
          <div>{k.is_active && (
            <form method="POST" onsubmit="return confirm('Revoke this key? Integrations using it will stop working.')">
              <input type="hidden" name="action" value="revoke" /><input type="hidden" name="id" value={k.id} />
              <button type="submit" style="background:rgba(239,68,68,0.12);color:#fca5a5;border:1px solid rgba(239,68,68,0.3);font-size:10px;font-weight:700;padding:3px 9px;border-radius:5px;cursor:pointer;">Revoke</button>
            </form>
          )}</div>
        </div>
      ))}
    </div>

    <div style="background:#0d1117;border:1px solid #1a1a1f;border-radius:14px;padding:18px;">
      <p style="font-size:11px;color:#67e8f9;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;margin:0 0 10px;font-weight:700;">Quick start for partners</p>
      <pre style="background:#08080a;border:1px solid #1a1a1f;border-radius:8px;padding:14px;overflow-x:auto;font-size:11.5px;color:#cfd6da;font-family:'Geist Mono',monospace;line-height:1.7;margin:0;"># list embeddable labs
curl -H "x-api-key: erk_live_..." {base + "/api/v1/labs"}

# get a login-free embed URL for one lab
curl -H "x-api-key: erk_live_..." "{base + "/api/v1/embed?slug=vlsi"}"

# list published courses
curl -H "x-api-key: erk_live_..." {base + "/api/v1/courses"}</pre>
      <p style="font-size:11.5px;color:#8a8a94;margin:10px 0 0;">Full docs: <a href="/developers" style="color:#67e8f9;">{base}/developers</a></p>
    </div>
  </div>
</AdminLayout>
