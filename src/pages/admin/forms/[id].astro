---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const { id } = Astro.params;
function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
let okMsg = '', errMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  try {
    if (fd.get('action') === 'save') {
      const title = (fd.get('title') as string || '').trim();
      const description = (fd.get('description') as string || '').trim() || null;
      const feeChf = parseInt(fd.get('fee_chf') as string || '0') || 0;
      const successMessage = (fd.get('success_message') as string || '').trim() || null;
      const isPublished = fd.get('is_published') === 'on';
      let fields: any = [];
      try { fields = JSON.parse(fd.get('fields_json') as string || '[]'); } catch { fields = []; }
      if (!Array.isArray(fields)) fields = [];
      // sanitise
      fields = fields.filter((f: any) => f && f.label).map((f: any, i: number) => ({
        key: (f.key || ('f' + i)).toString().slice(0, 40),
        type: ['text','email','phone','number','textarea','select','radio','checkbox','date'].includes(f.type) ? f.type : 'text',
        label: String(f.label).slice(0, 200),
        required: !!f.required,
        options: Array.isArray(f.options) ? f.options.map((o: any) => String(o).slice(0, 120)).filter(Boolean) : [],
        placeholder: f.placeholder ? String(f.placeholder).slice(0, 120) : '',
      }));
      await db.execute(sql`UPDATE forms SET title = ${title}, description = ${description}, fee_chf = ${feeChf}, success_message = ${successMessage}, is_published = ${isPublished}, fields = ${sql.raw("'" + JSON.stringify(fields).replace(/'/g, "''") + "'::jsonb")}, updated_at = NOW() WHERE id = ${id}`);
      okMsg = 'Saved.';
    }
  } catch (e: any) { errMsg = 'Failed: ' + (e?.message || 'error'); }
}

const form: any = rows(await db.execute(sql`SELECT * FROM forms WHERE id = ${id} LIMIT 1`))[0];
if (!form) return Astro.redirect('/admin/forms');
const responses = rows(await db.execute(sql`SELECT * FROM form_responses WHERE form_id = ${id} ORDER BY created_at DESC LIMIT 300`));
const fields = Array.isArray(form.fields) ? form.fields : [];
const origin = Astro.url.origin;
const fmt = (d: any) => d ? new Date(d).toLocaleString('en-IN', { day: 'numeric', month: 'short', hour: 'numeric', minute: '2-digit' }) : '';
---
<AdminLayout title={'Form - ' + form.title} activeNav="forms">
  <div class="admin-page" style="max-width:1000px;">
    <a href="/admin/forms" style="font-size:11px;color:#FF7040;text-decoration:none;font-weight:600;">&lt; All forms</a>
    <h1 class="admin-page-title" style="margin-top:8px;">{form.title}</h1>
    <p class="admin-page-sub">Public link: <span style="font-family:monospace;color:#c8c3b8;">{origin}/f/{form.slug}</span></p>
    {errMsg && <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 13px;margin:12px 0;font-size:12.5px;">{errMsg}</div>}
    {okMsg && <div style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 13px;margin:12px 0;font-size:12.5px;">{okMsg}</div>}

    <form method="POST" id="formEditor" style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:18px;margin-top:14px;">
      <input type="hidden" name="action" value="save" />
      <input type="hidden" name="fields_json" id="fields_json" />
      <div style="display:grid;grid-template-columns:2fr 110px;gap:10px;">
        <div><label class="fl">Title</label><input name="title" value={form.title} class="fi" /></div>
        <div><label class="fl">Fee (CHF)</label><input name="fee_chf" type="number" min="0" value={form.fee_chf || 0} class="fi" /></div>
      </div>
      <div style="margin-top:10px;"><label class="fl">Description</label><textarea name="description" rows="2" class="fi">{form.description || ''}</textarea></div>
      <div style="margin-top:10px;"><label class="fl">Success message (after submit)</label><input name="success_message" value={form.success_message || ''} placeholder="Thanks! Your response is recorded." class="fi" /></div>
      <label style="display:flex;align-items:center;gap:8px;font-size:12.5px;color:#c8c3b8;margin-top:10px;cursor:pointer;"><input type="checkbox" name="is_published" checked={form.is_published} /> Published (publicly fillable)</label>

      <p style="font-size:12px;font-weight:700;color:#fff;margin:16px 0 8px;">Fields</p>
      <div id="fieldList" style="display:flex;flex-direction:column;gap:8px;"></div>
      <button type="button" id="addField" style="margin-top:10px;font-size:12px;background:#222831;border:1px solid #2a3038;color:#fff;padding:7px 14px;border-radius:7px;cursor:pointer;">+ Add field</button>

      <div style="margin-top:16px;"><button type="submit" class="admin-btn admin-btn-primary">Save form</button></div>
    </form>

    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:18px;margin-top:16px;">
      <p style="font-size:13px;font-weight:700;color:#fff;margin:0 0 10px;">Responses ({responses.length})</p>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:12px;">
          <thead><tr style="text-align:left;color:#6e6e78;border-bottom:1px solid #1a1a1f;"><th style="padding:6px 8px;">When</th><th style="padding:6px 8px;">Name</th><th style="padding:6px 8px;">Email</th><th style="padding:6px 8px;">Phone</th><th style="padding:6px 8px;">Fee</th><th style="padding:6px 8px;">Data</th></tr></thead>
          <tbody>
            {responses.map((r: any) => (
              <tr style="border-bottom:1px solid #151519;color:#c8c3b8;vertical-align:top;">
                <td style="padding:6px 8px;white-space:nowrap;">{fmt(r.created_at)}</td>
                <td style="padding:6px 8px;">{r.respondent_name || '-'}</td>
                <td style="padding:6px 8px;">{r.respondent_email || '-'}</td>
                <td style="padding:6px 8px;">{r.respondent_phone || '-'}</td>
                <td style="padding:6px 8px;"><span style={r.payment_status === 'paid' ? 'color:#6ee7b7;' : 'color:#8a8a94;'}>{r.payment_status}</span></td>
                <td style="padding:6px 8px;font-family:monospace;font-size:11px;max-width:320px;word-break:break-word;">{JSON.stringify(r.data)}</td>
              </tr>
            ))}
            {responses.length === 0 && <tr><td colspan="6" style="padding:14px 8px;color:#6e6e78;">No responses yet.</td></tr>}
          </tbody>
        </table>
      </div>
      <a href={'/api/forms/export/' + form.id} style="font-size:11px;color:#60a5fa;text-decoration:none;display:inline-block;margin-top:8px;">Export CSV</a>
    </div>
  </div>

  <style>.fl{display:block;font-size:10px;font-weight:600;color:#8a8a94;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:4px;}.fi{width:100%;padding:8px 10px;background:#08080a;border:1px solid #1f1f26;border-radius:6px;color:#fff;font-size:12.5px;font-family:inherit;outline:none;}.fi:focus{border-color:#FF4F00;}.fld{background:#15151a;border:1px solid #1f1f26;border-radius:8px;padding:10px;}</style>
  <script is:inline define:vars={{ initial: fields }}>
    (function () {
      var TYPES = ['text','email','phone','number','textarea','select','radio','checkbox','date'];
      var list = document.getElementById('fieldList');
      function row(f) {
        f = f || { type: 'text', label: '', required: false, options: [] };
        var d = document.createElement('div'); d.className = 'fld';
        d.innerHTML =
          '<div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">' +
            '<select class="fi f-type" style="max-width:130px;">' + TYPES.map(function(t){return '<option value="'+t+'"'+(f.type===t?' selected':'')+'>'+t+'</option>';}).join('') + '</select>' +
            '<input class="fi f-label" placeholder="Question / label" value="'+(f.label||'').replace(/"/g,'&quot;')+'" style="flex:1;min-width:160px;" />' +
            '<label style="font-size:11px;color:#c8c3b8;display:flex;gap:5px;align-items:center;"><input type="checkbox" class="f-req"'+(f.required?' checked':'')+'/> required</label>' +
            '<button type="button" class="f-del" style="background:none;border:none;color:#fca5a5;cursor:pointer;font-size:12px;">remove</button>' +
          '</div>' +
          '<input class="fi f-opts" placeholder="Options (comma-separated) - for select/radio/checkbox" value="'+((f.options||[]).join(', ')).replace(/"/g,'&quot;')+'" style="margin-top:6px;display:'+(['select','radio','checkbox'].indexOf(f.type)>=0?'block':'none')+';" />';
        d.querySelector('.f-del').addEventListener('click', function(){ d.remove(); });
        var typeSel = d.querySelector('.f-type'); var opts = d.querySelector('.f-opts');
        typeSel.addEventListener('change', function(){ opts.style.display = ['select','radio','checkbox'].indexOf(typeSel.value)>=0 ? 'block':'none'; });
        list.appendChild(d);
      }
      (initial && initial.length ? initial : []).forEach(row);
      if (!initial || !initial.length) row();
      document.getElementById('addField').addEventListener('click', function(){ row(); });
      document.getElementById('formEditor').addEventListener('submit', function(){
        var out = [];
        list.querySelectorAll('.fld').forEach(function(d, i){
          var label = d.querySelector('.f-label').value.trim(); if (!label) return;
          var type = d.querySelector('.f-type').value;
          var required = d.querySelector('.f-req').checked;
          var optsRaw = d.querySelector('.f-opts').value;
          var options = (['select','radio','checkbox'].indexOf(type)>=0 && optsRaw) ? optsRaw.split(',').map(function(s){return s.trim();}).filter(Boolean) : [];
          var key = label.toLowerCase().replace(/[^a-z0-9]+/g,'_').replace(/^_|_$/g,'').slice(0,40) || ('f'+i);
          out.push({ key: key, type: type, label: label, required: required, options: options });
        });
        document.getElementById('fields_json').value = JSON.stringify(out);
      });
    })();
  </script>
</AdminLayout>
