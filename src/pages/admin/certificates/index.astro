---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { ensureUniversalCertSchema, listUniversal, issueUniversalCertificate, revokeUniversal, UCERT_KIND_LABELS } from '@/lib/universal-certificates';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

await ensureUniversalCertSchema();

let successMsg = '', errorMsg = '', issuedSerial = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const action = (fd.get('action') as string) || 'issue';
    if (action === 'revoke') {
      const serial = (fd.get('serial') as string || '').trim();
      const reason = (fd.get('reason') as string || '').trim().slice(0, 1000);
      if (!serial || !reason) errorMsg = 'Serial + reason required.';
      else { await revokeUniversal(serial, user.id, reason); successMsg = 'Certificate ' + serial + ' revoked.'; }
    } else {
      const kind = (fd.get('kind') as string || 'custom') as any;
      const recipientName = (fd.get('recipient_name') as string || '').trim().slice(0, 200);
      const recipientEmail = (fd.get('recipient_email') as string || '').trim().slice(0, 200) || undefined;
      const title = (fd.get('title') as string || '').trim().slice(0, 300);
      const body = (fd.get('body') as string || '').trim().slice(0, 5000) || undefined;
      const achievement = (fd.get('achievement') as string || '').trim().slice(0, 1000) || undefined;
      const issuedByName = (fd.get('issued_by_name') as string || '').trim() || undefined;
      const issuedByDesignation = (fd.get('issued_by_designation') as string || '').trim() || undefined;
      const issuerOrg = (fd.get('issuer_org') as string || '').trim() || 'EduRankAI';
      const scoreRaw = parseFloat(fd.get('score_pct') as string || '');
      const scorePct = isFinite(scoreRaw) && scoreRaw >= 0 ? scoreRaw : undefined;
      const validFrom = (fd.get('valid_from') as string || '').trim() || undefined;
      const validUntil = (fd.get('valid_until') as string || '').trim() || undefined;
      if (!recipientName || !title) errorMsg = 'Recipient name + title are required.';
      else {
        const r = await issueUniversalCertificate({
          kind, recipientName, recipientEmail, title, body, achievement,
          issuedByUserId: user.id, issuedByName, issuedByDesignation, issuerOrg,
          scorePct, validFrom, validUntil,
        });
        if (r.ok) {
          issuedSerial = r.serial;
          successMsg = 'Certificate issued: ' + r.serial + (r.existing ? ' (already existed — returning same)' : '');
        } else errorMsg = 'Issue failed.';
      }
    }
  } catch (e: any) { errorMsg = String(e?.message || e).slice(0, 300); }
}

const url = new URL(Astro.request.url);
const filterKind = url.searchParams.get('kind') || '';
const q = url.searchParams.get('q') || '';
const certs = await listUniversal({ kind: filterKind || undefined, q, limit: 200 });

function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }); } catch { return ''; } }
---
<AdminLayout title="Certificate Generator" activeNav="">
<div style="padding:14px 16px 80px;max-width:1280px;margin:0 auto;">
  <p style="font-size:10.5px;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;font-family:'Geist Mono',monospace;font-weight:700;">Credentials</p>
  <h1 style="font-size:24px;color:#fff;margin:6px 0 4px;font-weight:700;">Certificate Generator</h1>
  <p style="font-size:13px;color:#9aa6b6;margin:0 0 18px;">Issue any kind of credential — course completion, test pass, event participation, internship, employment, LOR, or a free-form custom certificate. Each issuance gets a permanent serial + public verify URL.</p>

  {successMsg && <div style="background:rgba(74,222,128,0.12);border:1px solid rgba(74,222,128,0.32);color:#86efac;border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;">{successMsg}{issuedSerial && <> · <a href={'/credentials/' + issuedSerial} target="_blank" style="color:#86efac;text-decoration:underline;">View public credential</a></>}</div>}
  {errorMsg && <div style="background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.32);color:#fca5a5;border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;">{errorMsg}</div>}

  <!-- Issue form -->
  <details open={!issuedSerial} style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:18px;margin-bottom:18px;">
    <summary style="cursor:pointer;color:#FF7040;font-size:13px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;font-family:'Geist Mono',monospace;">Issue a new certificate</summary>
    <form method="POST" style="margin-top:16px;display:grid;gap:10px;">
      <input type="hidden" name="action" value="issue" />

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div>
          <label style="font-size:10.5px;color:#9aa6b6;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">Kind *</label>
          <select name="kind" required style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12.5px;margin-top:4px;">
            {Object.entries(UCERT_KIND_LABELS).map(([k, v]) => (
              <option value={k}>{v.label}</option>
            ))}
          </select>
        </div>
        <div>
          <label style="font-size:10.5px;color:#9aa6b6;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">Issuer org</label>
          <input name="issuer_org" type="text" placeholder="EduRankAI" maxlength="200" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12.5px;margin-top:4px;" />
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div>
          <label style="font-size:10.5px;color:#9aa6b6;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">Recipient name *</label>
          <input name="recipient_name" type="text" required maxlength="200" placeholder="Full name as it should appear" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12.5px;margin-top:4px;" />
        </div>
        <div>
          <label style="font-size:10.5px;color:#9aa6b6;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">Recipient email</label>
          <input name="recipient_email" type="email" maxlength="200" placeholder="(optional, for verification look-up)" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12.5px;margin-top:4px;" />
        </div>
      </div>

      <div>
        <label style="font-size:10.5px;color:#9aa6b6;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">Title *</label>
        <input name="title" type="text" required maxlength="300" placeholder="e.g. Certificate of Completion — Quantum Foundations" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12.5px;margin-top:4px;" />
      </div>

      <div>
        <label style="font-size:10.5px;color:#9aa6b6;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">Achievement / summary</label>
        <input name="achievement" type="text" maxlength="1000" placeholder="e.g. Scored 94% on a 100-question proctored assessment" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12.5px;margin-top:4px;" />
      </div>

      <div>
        <label style="font-size:10.5px;color:#9aa6b6;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">Body (citation / letter text)</label>
        <textarea name="body" rows="4" maxlength="5000" placeholder="Free-form text rendered on the certificate body. For LOR, write the full letter here." style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12.5px;margin-top:4px;font-family:'Inter Tight',sans-serif;resize:vertical;"></textarea>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;">
        <div>
          <label style="font-size:10.5px;color:#9aa6b6;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">Score %</label>
          <input name="score_pct" type="number" min="0" max="100" step="0.01" placeholder="e.g. 94.5" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12.5px;margin-top:4px;" />
        </div>
        <div>
          <label style="font-size:10.5px;color:#9aa6b6;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">Valid from</label>
          <input name="valid_from" type="date" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12.5px;margin-top:4px;" />
        </div>
        <div>
          <label style="font-size:10.5px;color:#9aa6b6;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">Valid until</label>
          <input name="valid_until" type="date" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12.5px;margin-top:4px;" />
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div>
          <label style="font-size:10.5px;color:#9aa6b6;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">Signed by — name</label>
          <input name="issued_by_name" type="text" maxlength="200" placeholder="e.g. Siddharth Prasad" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12.5px;margin-top:4px;" />
        </div>
        <div>
          <label style="font-size:10.5px;color:#9aa6b6;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">Signed by — designation</label>
          <input name="issued_by_designation" type="text" maxlength="200" placeholder="e.g. Founder, EduRankAI" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12.5px;margin-top:4px;" />
        </div>
      </div>

      <button type="submit" style="background:#FF7040;color:#1a0a04;border:none;padding:10px 22px;border-radius:8px;font-size:13px;font-weight:800;cursor:pointer;letter-spacing:0.04em;text-transform:uppercase;font-family:'Geist Mono',monospace;justify-self:start;margin-top:6px;">Issue certificate</button>
    </form>
  </details>

  <!-- Filters + search -->
  <form method="GET" style="display:flex;gap:8px;margin-bottom:14px;align-items:center;flex-wrap:wrap;">
    <input name="q" value={q} type="text" placeholder="Search by name, email, serial, or title..." style="flex:1;min-width:240px;background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;" />
    <select name="kind" style="background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12.5px;">
      <option value="">All kinds</option>
      {Object.entries(UCERT_KIND_LABELS).map(([k, v]) => (
        <option value={k} selected={filterKind === k}>{v.label}</option>
      ))}
    </select>
    <button type="submit" style="background:#15151a;border:1px solid #2a2a2f;color:#FF7040;padding:9px 16px;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer;">Filter</button>
  </form>

  <!-- List -->
  <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;overflow:hidden;">
    <div style="display:grid;grid-template-columns:1.6fr 1.6fr 1fr 110px 100px 90px;gap:10px;padding:10px 14px;background:#15151a;border-bottom:1px solid #1a1a1f;font-size:10px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.08em;font-weight:700;">
      <div>Recipient</div><div>Title</div><div>Serial</div><div>Kind</div><div>Issued</div><div>Verified</div>
    </div>
    {certs.length === 0 ? (
      <div style="padding:36px;text-align:center;color:#6e6e78;font-size:13px;">
        No certificates issued yet{q || filterKind ? ' for this filter' : ''}. Issue your first using the form above.
      </div>
    ) : certs.map((c: any) => {
      const kindMeta = UCERT_KIND_LABELS[c.kind] || UCERT_KIND_LABELS.custom;
      return (
        <a href={'/credentials/' + c.serial} target="_blank" style="display:grid;grid-template-columns:1.6fr 1.6fr 1fr 110px 100px 90px;gap:10px;padding:11px 14px;border-bottom:1px solid #15151a;text-decoration:none;color:#fff;align-items:center;">
          <div style="min-width:0;">
            <p style="font-size:12.5px;font-weight:600;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{c.recipient_name}{c.revoked && <span style="margin-left:6px;background:rgba(239,68,68,0.16);color:#fca5a5;font-size:9px;padding:1px 6px;border-radius:100px;font-family:'Geist Mono',monospace;letter-spacing:0.08em;text-transform:uppercase;font-weight:700;">Revoked</span>}</p>
            <p style="font-size:10.5px;color:#8a8a94;margin:2px 0 0;font-family:'Geist Mono',monospace;">{c.recipient_email || '—'}</p>
          </div>
          <p style="font-size:11.5px;color:#d8d8de;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{c.title}</p>
          <p style="font-size:10.5px;color:#FF7040;margin:0;font-family:'Geist Mono',monospace;font-weight:700;">{c.serial}</p>
          <span style={`background:${kindMeta.accent}22;color:${kindMeta.accent};font-size:10px;font-weight:700;padding:3px 8px;border-radius:100px;font-family:'Geist Mono',monospace;letter-spacing:0.06em;text-transform:uppercase;justify-self:start;`}>{c.kind}</span>
          <p style="font-size:10.5px;color:#a0a0ab;margin:0;font-family:'Geist Mono',monospace;">{fmt(c.signed_at)}</p>
          <p style="font-size:10.5px;color:#8a8a94;margin:0;font-family:'Geist Mono',monospace;">{c.verify_count} ×</p>
        </a>
      );
    })}
  </div>
</div>
</AdminLayout>
