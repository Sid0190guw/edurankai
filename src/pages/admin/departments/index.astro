---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { canViewPage } from '@/lib/auth/pagePermissions';
import { db } from '@/lib/db';
import { departments, roles } from '@/lib/db/schema';
import { can } from '@/lib/auth/permissions';
import { departmentSchema } from '@/lib/validators';
import { logAudit } from '@/lib/audit';
import { asc, eq } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!(await canViewPage(user, 'departments'))) return Astro.redirect('/admin');
const canEdit = can(user, 'roles.edit');

let errorMsg = '';
let okMsg = '';

if (Astro.request.method === 'POST' && canEdit) {
  const fd = await Astro.request.formData();
  const intent = fd.get('_intent');

  if (intent === 'create') {
    const candidate = {
      id: (fd.get('id') as string || '').trim().toLowerCase(),
      name: (fd.get('name') as string || '').trim(),
      icon: (fd.get('icon') as string || '').trim(),
      description: (fd.get('description') as string || '').trim(),
      isFlagship: fd.get('isFlagship') === 'on',
      sortOrder: parseInt((fd.get('sortOrder') as string) || '99', 10),
      isVisible: true
    };

    const parsed = departmentSchema.safeParse(candidate);
    if (!parsed.success) {
      errorMsg = parsed.error.errors.map((e) => e.path.join('.') + ': ' + e.message).join(' | ');
    } else {
      const existing = await db.select({ id: departments.id }).from(departments).where(eq(departments.id, parsed.data.id)).limit(1);
      if (existing.length > 0) {
        errorMsg = 'Department ID "' + parsed.data.id + '" already exists.';
      } else {
        await db.insert(departments).values(parsed.data);
        await logAudit({
          userId: user.id,
          action: 'department.create',
          entity: 'department',
          entityId: parsed.data.id,
          diff: { created: parsed.data },
          ipAddress: Astro.clientAddress
        });
        okMsg = 'Department "' + parsed.data.name + '" created.';
      }
    }
  }
}

// Fetch departments WITHOUT the subquery (serverless-safe)
const deptsRaw = await db.select().from(departments).orderBy(asc(departments.sortOrder));

// Count roles per department in JS (no SQL subquery)
const allRolesForCount = await db.select({ departmentId: roles.departmentId }).from(roles);
const roleCounts: Record<string, number> = {};
for (const r of allRolesForCount) {
  if (r.departmentId) {
    roleCounts[r.departmentId] = (roleCounts[r.departmentId] || 0) + 1;
  }
}

const allDepts = deptsRaw.map(d => ({
  id: d.id,
  name: d.name,
  icon: d.icon,
  description: d.description,
  isFlagship: d.isFlagship,
  isVisible: d.isVisible,
  sortOrder: d.sortOrder,
  roleCount: roleCounts[d.id] || 0
}));
---
<AdminLayout title="Departments" activeNav="departments">
  <div class="admin-page" style="max-width:1100px;">
    <div class="admin-page-header">
      <div class="admin-page-title-block">
        <div class="admin-page-eyebrow">Structure</div>
        <h1 class="admin-page-title">Departments</h1>
        <p class="admin-page-sub">{allDepts.length} departments. Roles are grouped under these on the public /careers page.</p>
      </div>
    </div>

    {errorMsg && (
      <div style="background:rgba(220,38,38,0.08);border:1px solid rgba(220,38,38,0.25);color:#fca5a5;font-size:12.5px;padding:11px 14px;border-radius:7px;margin-bottom:18px;">
        {errorMsg}
      </div>
    )}
    {okMsg && (
      <div style="background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.25);color:#6ee7b7;font-size:12.5px;padding:11px 14px;border-radius:7px;margin-bottom:18px;">
        {okMsg}
      </div>
    )}

    <div style="display:grid;grid-template-columns:2fr 1fr;gap:18px;align-items:flex-start;">

      <div class="admin-card" style="padding:0;overflow:hidden;">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Department</th>
              <th>ID</th>
              <th style="text-align:center;">Roles</th>
              <th>Visible</th>
              <th style="text-align:right;">Actions</th>
            </tr>
          </thead>
          <tbody>
            {allDepts.map((d) => {
              const editHref = '/admin/departments/' + d.id;
              const visibleColor = d.isVisible ? '#10b981' : '#6e6e78';
              const visibleText = d.isVisible ? 'Yes' : 'No';
              return (
                <tr>
                  <td>
                    <div style="font-weight:500;color:#fff;display:flex;align-items:center;gap:8px;">
                      {d.name}
                      {d.isFlagship && (
                        <span style="font-size:9px;background:rgba(255,79,0,0.12);color:#FF7040;padding:1px 7px;border-radius:100px;letter-spacing:0.06em;text-transform:uppercase;font-weight:700;">Flagship</span>
                      )}
                    </div>
                    <div style="font-size:11px;color:#6e6e78;margin-top:3px;line-height:1.5;max-width:480px;">{d.description}</div>
                  </td>
                  <td><span style="font-size:11px;color:#a0a0ab;font-family:'Geist Mono',monospace;">{d.id}</span></td>
                  <td style="text-align:center;">
                    <span style="background:#15151a;border:1px solid #1f1f26;color:#d8d8de;font-size:11px;padding:2px 10px;border-radius:100px;font-weight:500;font-family:'Geist Mono',monospace;">{d.roleCount}</span>
                  </td>
                  <td>
                    <span style={'display:inline-flex;align-items:center;gap:5px;font-size:11px;color:' + visibleColor + ';'}>
                      <span style={'width:6px;height:6px;border-radius:50%;background:' + visibleColor + ';'}></span>
                      {visibleText}
                    </span>
                  </td>
                  <td style="text-align:right;">
                    {canEdit && <a href={editHref} class="admin-btn" style="padding:5px 11px;font-size:11px;">Edit</a>}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      {canEdit && (
        <form method="POST" class="admin-card" style="display:flex;flex-direction:column;gap:14px;">
          <input type="hidden" name="_intent" value="create" />
          <div>
            <div class="admin-card-title" style="margin:0 0 4px;">Add new department</div>
            <p style="font-size:11px;color:#6e6e78;line-height:1.6;">Use this for new teams. ID must be unique and url-safe.</p>
          </div>

          <div>
            <label class="rolefield-label">Name *</label>
            <input name="name" required class="rolefield-input" placeholder="e.g. Robotics Lab" />
          </div>

          <div>
            <label class="rolefield-label">ID (slug) *</label>
            <input name="id" required pattern="[a-z0-9-]+" class="rolefield-input" placeholder="e.g. robotics" />
          </div>

          <div>
            <label class="rolefield-label">Icon key *</label>
            <input name="icon" required value="briefcase" class="rolefield-input" placeholder="e.g. robot" />
          </div>

          <div>
            <label class="rolefield-label">Description *</label>
            <textarea name="description" required rows="3" class="rolefield-input" placeholder="One-line description"></textarea>
          </div>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            <div>
              <label class="rolefield-label">Sort order</label>
              <input type="number" name="sortOrder" value="99" class="rolefield-input" />
            </div>
            <label style="display:flex;align-items:center;gap:8px;color:#d8d8de;font-size:12px;padding-top:22px;cursor:pointer;">
              <input type="checkbox" name="isFlagship" style="accent-color:#FF4F00;" />
              <span>Flagship</span>
            </label>
          </div>

          <button type="submit" class="admin-btn admin-btn-primary" style="width:100%;justify-content:center;">+ Create Department</button>
        </form>
      )}

    </div>
  </div>

  <style>
    .rolefield-label {
      display:block;font-size:10.5px;font-weight:600;color:#8a8a94;
      letter-spacing:0.1em;text-transform:uppercase;margin-bottom:6px;
    }
    .rolefield-input {
      width:100%;padding:8px 11px;background:#08080a;border:1px solid #1f1f26;
      border-radius:6px;color:#fff;font-size:12.5px;font-family:inherit;outline:none;
    }
    .rolefield-input:focus { border-color:#FF4F00; }
    textarea.rolefield-input { resize:vertical;min-height:60px; }
  </style>
</AdminLayout>