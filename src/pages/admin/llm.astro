---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { getConfig } from '@/lib/llm/gateway';
// Super-admin control plane for AquinTutor's own-LLM gateway. Choose the backend
// (your self-hosted model or Claude), test the connection, watch usage, and
// export the captured training corpus for fine-tuning your own model.
const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role !== 'super_admin') return Astro.redirect('/admin');
const cfg = await getConfig();
---
<AdminLayout title="AI model" activeNav="">
  <div class="admin-page" style="max-width:900px;">
    <div class="admin-page-header"><div class="admin-page-title-block">
      <div class="admin-page-eyebrow">AquinTutor · Intelligence</div>
      <h1 class="admin-page-title">AI model &amp; training</h1>
      <p class="admin-page-sub">Run the Aquin tutor on your own self-hosted model or on Claude — switch any time. Every exchange is captured as training data for your own model. Super-admin only. Off by default; nothing else depends on it.</p>
    </div></div>

    <div id="msg" style="display:none;margin:0 0 16px;border-radius:8px;padding:10px 14px;font-size:13px;"></div>

    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:18px;margin-bottom:16px;">
      <label style="display:flex;align-items:center;gap:10px;font-size:14px;color:#fff;font-weight:600;">
        <input type="checkbox" id="enabled" checked={cfg.enabled} style="width:18px;height:18px;" /> Tutor enabled (learners can chat)
      </label>

      <div style="margin-top:16px;font-size:12px;color:#8a8a94;text-transform:uppercase;letter-spacing:0.08em;font-weight:700;">Backend</div>
      <div style="display:flex;gap:8px;margin-top:8px;" id="provRow">
        <button type="button" class="prov" data-p="own" style="flex:1;">Our own model</button>
        <button type="button" class="prov" data-p="claude" style="flex:1;">Claude tokens</button>
      </div>

      <div id="ownBox" style="margin-top:14px;">
        <div class="fl">Model endpoint (chat-completions compatible)</div>
        <input id="baseUrl" class="fi" placeholder="https://model.edurankai.in/v1" value={cfg.baseUrl} />
        <div class="fl">Model name</div>
        <input id="model" class="fi" placeholder="aquin-1" value={cfg.model} />
        <div class="fl">API key (optional — for your gateway)</div>
        <input id="apiKey" class="fi" type="password" placeholder={cfg.apiKey ? '•••••• (set — leave blank to keep)' : 'optional'} />
        <div style="font-size:12px;color:#8a8a94;margin-top:6px;line-height:1.6;">Point this at your inference server (vLLM, TGI, llama.cpp server, Ollama, text-generation-webui — anything that serves the standard chat-completions protocol). No code change needed when your model goes live.</div>
      </div>

      <div id="claudeBox" style="margin-top:14px;display:none;">
        <div class="fl">Claude model</div>
        <select id="claudeModel" class="fi">
          <option value="claude-opus-4-8" selected={cfg.claudeModel==='claude-opus-4-8'}>claude-opus-4-8 (most capable)</option>
          <option value="claude-sonnet-5" selected={cfg.claudeModel==='claude-sonnet-5'}>claude-sonnet-5 (balanced)</option>
          <option value="claude-haiku-4-5" selected={cfg.claudeModel==='claude-haiku-4-5'}>claude-haiku-4-5 (fast)</option>
        </select>
        <div class="fl">API key</div>
        <input id="claudeApiKey" class="fi" type="password" placeholder={cfg.claudeApiKey ? '•••••• (set — leave blank to keep)' : 'sk-ant-...'} />
        <div style="font-size:12px;color:#8a8a94;margin-top:6px;line-height:1.6;">Uses the server ANTHROPIC_API_KEY automatically if you leave this blank.</div>
      </div>

      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:16px;">
        <div style="flex:1;min-width:140px;"><div class="fl">Max tokens</div><input id="maxTokens" class="fi" type="number" min="16" max="8192" value={cfg.maxTokens} /></div>
        <div style="flex:1;min-width:140px;"><div class="fl">Temperature (own only)</div><input id="temperature" class="fi" type="number" step="0.1" min="0" max="2" value={cfg.temperature} /></div>
        <div style="flex:1;min-width:140px;"><div class="fl">Timeout (ms)</div><input id="timeoutMs" class="fi" type="number" min="3000" max="120000" value={cfg.timeoutMs} /></div>
      </div>

      <div class="fl" style="margin-top:14px;">Extra system instructions (optional)</div>
      <textarea id="systemPreamble" class="fi" rows="2" placeholder="Appended to the Socratic tutor system prompt.">{cfg.systemPreamble}</textarea>

      <label style="display:flex;align-items:center;gap:10px;font-size:13px;color:#cfd6da;margin-top:14px;">
        <input type="checkbox" id="captureTraining" checked={cfg.captureTraining} style="width:16px;height:16px;" /> Capture every exchange as training data for our own model
      </label>

      <div style="display:flex;gap:10px;margin-top:18px;flex-wrap:wrap;">
        <button type="button" id="saveBtn" style="background:#c2410c;color:#fff;border:none;border-radius:8px;padding:10px 22px;font-size:14px;font-weight:600;cursor:pointer;">Save</button>
        <button type="button" id="testBtn" style="background:transparent;color:#cfd6da;border:1px solid #333;border-radius:8px;padding:10px 18px;font-size:14px;font-weight:600;cursor:pointer;">Test connection</button>
        <span id="testOut" style="font-size:13px;color:#8a8a94;align-self:center;"></span>
      </div>
    </div>

    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:18px;">
      <div style="display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap;gap:8px;">
        <div style="font-weight:700;color:#fff;">Training corpus</div>
        <a href="/api/admin/llm?export=jsonl" style="color:#86efac;text-decoration:none;font-size:13px;font-weight:600;">Export JSONL &rarr;</a>
      </div>
      <div style="display:flex;gap:22px;margin-top:12px;">
        <div><div style="font-size:1.8rem;font-weight:700;color:#fff;" id="trTotal">0</div><div style="font-size:11px;color:#8a8a94;text-transform:uppercase;letter-spacing:0.08em;">Examples</div></div>
        <div><div style="font-size:1.8rem;font-weight:700;color:#c2410c;" id="trToday">0</div><div style="font-size:11px;color:#8a8a94;text-transform:uppercase;letter-spacing:0.08em;">Today</div></div>
      </div>
      <div id="usageBox" style="margin-top:14px;font-size:12.5px;color:#8a8a94;line-height:1.8;"></div>
      <div style="font-size:12px;color:#6b6b74;margin-top:10px;line-height:1.6;">Each example is one prompt + Aquin's reply, exported in the standard chat fine-tuning shape (system + messages + assistant). Feed it to your own model's fine-tuning pipeline.</div>
    </div>
  </div>

  <style>
    .fl { font-size:12px;color:#8a8a94;margin:12px 0 5px;font-weight:600; }
    .fi { width:100%;background:#08080b;border:1px solid #262630;border-radius:8px;padding:9px 12px;color:#fff;font-size:14px;outline:none;font-family:inherit; }
    .prov { background:#08080b;border:1px solid #262630;border-radius:8px;padding:9px 12px;color:#cfd6da;font-size:13px;font-weight:600;cursor:pointer; }
    .prov.on { background:#c2410c;border-color:#c2410c;color:#fff; }
  </style>

  <script is:inline define:vars={{ initProvider: cfg.provider }}>
  (function(){
    var provider = initProvider === 'claude' ? 'claude' : 'own';
    function paintProv(){
      document.querySelectorAll('.prov').forEach(function(b){ b.classList.toggle('on', b.getAttribute('data-p')===provider); });
      document.getElementById('ownBox').style.display = provider==='own' ? 'block' : 'none';
      document.getElementById('claudeBox').style.display = provider==='claude' ? 'block' : 'none';
    }
    document.querySelectorAll('.prov').forEach(function(b){ b.addEventListener('click', function(){ provider = b.getAttribute('data-p'); paintProv(); }); });
    paintProv();

    function msg(text, ok){ var m=document.getElementById('msg'); m.style.display='block'; m.textContent=text;
      m.style.background = ok ? 'rgba(16,185,129,0.1)' : 'rgba(239,68,68,0.1)';
      m.style.border = '1px solid ' + (ok ? 'rgba(16,185,129,0.3)' : 'rgba(239,68,68,0.3)');
      m.style.color = ok ? '#6ee7b7' : '#fca5a5'; }
    function val(id){ return document.getElementById(id).value; }
    function collect(){ return { enabled:document.getElementById('enabled').checked, provider:provider,
      baseUrl:val('baseUrl'), model:val('model'), apiKey:val('apiKey'),
      claudeModel:val('claudeModel'), claudeApiKey:val('claudeApiKey'),
      maxTokens:Number(val('maxTokens')), temperature:Number(val('temperature')), timeoutMs:Number(val('timeoutMs')),
      systemPreamble:val('systemPreamble'), captureTraining:document.getElementById('captureTraining').checked }; }

    document.getElementById('saveBtn').addEventListener('click', function(){
      fetch('/api/admin/llm',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'same-origin',body:JSON.stringify({action:'save',config:collect()})})
        .then(function(r){return r.json();}).then(function(j){ if(j.ok){ msg('Saved.', true); document.getElementById('apiKey').value=''; document.getElementById('claudeApiKey').value=''; load(); } else msg(j.error||'Save failed', false); });
    });
    document.getElementById('testBtn').addEventListener('click', function(){
      var o=document.getElementById('testOut'); o.textContent='Testing…';
      fetch('/api/admin/llm',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'same-origin',body:JSON.stringify({action:'test'})})
        .then(function(r){return r.json();}).then(function(j){ o.textContent = j.ok ? ('OK · '+j.model+' · '+j.latencyMs+'ms · "'+(j.sample||'')+'"') : ('Failed: '+(j.error||'unknown')); o.style.color = j.ok ? '#6ee7b7' : '#fca5a5'; })
        .catch(function(){ o.textContent='Request failed'; });
    });

    function load(){
      fetch('/api/admin/llm',{credentials:'same-origin'}).then(function(r){return r.json();}).then(function(j){
        if(!j.ok) return;
        document.getElementById('trTotal').textContent = j.training.total;
        document.getElementById('trToday').textContent = j.training.today;
        var by={}; (j.usage||[]).forEach(function(u){ var k=u.provider||'—'; by[k]=by[k]||{ok:0,error:0,out:0}; by[k][u.status==='ok'?'ok':'error']+=u.n; by[k].out+=u.out_tokens; });
        document.getElementById('usageBox').innerHTML = Object.keys(by).length ? Object.keys(by).map(function(k){ return '<div>'+k+': '+by[k].ok+' ok, '+by[k].error+' errors, '+by[k].out+' out-tokens (7d)</div>'; }).join('') : 'No usage in the last 7 days.';
      });
    }
    load();
  })();
  </script>
</AdminLayout>
