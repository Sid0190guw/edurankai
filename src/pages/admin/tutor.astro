---
// /admin/tutor — Ask Aquin conversation inspector (Prompt 9, admin surface). Gated by can(audit).
// Lists real tutor sessions and shows a selected transcript. Model / system prompt / safety limits
// are configured in the existing LLM console (/admin/llm) — this is the read-only review surface.
import AdminLayout from '@/layouts/AdminLayout.astro';
import { can } from '@/lib/rbac';
import { listTutorSessions, getTutorConversation } from '@/lib/ask-aquin';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
const gate = await can(user, 'audit', { type: 'tutor' });
if (!gate.allow) return Astro.redirect('/admin');

const sessions = await listTutorSessions(60).catch(() => []);
const sel = (Astro.url.searchParams.get('s') || '').trim();
const convo = sel ? await getTutorConversation(sel).catch(() => []) : [];

const CARD = 'background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:16px 18px;margin-bottom:16px;';
const HD = "font-size:11px;color:#8a8a94;text-transform:uppercase;font-family:'Geist Mono',monospace;letter-spacing:0.1em;font-weight:700;margin:0 0 10px;";
function fmt(d: any) { try { return new Date(d).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); } catch { return '-'; } }
---
<AdminLayout title="AI tutor" activeNav="tutor">
  <div style="max-width:1080px;margin:0 auto;padding:24px;">
    <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Ask Aquin</p>
    <h1 style="font-size:22px;font-weight:800;color:#fff;margin:0;">Tutor conversations</h1>
    <p style="font-size:12.5px;color:#8a8a94;margin:6px 0 0;max-width:760px;line-height:1.55;">Grounded, access-scoped tutoring per lesson. Configure model, system prompt, and safety limits in the <a href="/admin/llm" style="color:#FF7040;">LLM console</a>.</p>

    <div style="display:grid;grid-template-columns:300px 1fr;gap:16px;margin-top:16px;" class="tutor-grid">
      <div style={CARD}>
        <p style={HD}>Recent sessions ({sessions.length})</p>
        {sessions.length === 0 ? <p style="font-size:12px;color:#6e6e78;margin:0;">No conversations yet.</p> :
          <div style="display:flex;flex-direction:column;gap:4px;">{sessions.map((s: any) => (
            <a href={'?s=' + encodeURIComponent(s.session_id)} style={'text-decoration:none;border-radius:8px;padding:8px 10px;font-size:12px;border:1px solid #26262c;' + (s.session_id === sel ? 'background:rgba(255,79,0,0.14);color:#fff;' : 'background:#08080a;color:#cfd6da;')}>
              <div style="font-weight:600;">{s.user_name || 'student'}</div>
              <div style="color:#8a8a94;font-size:10.5px;">{s.turns} turns · {fmt(s.last_at)}</div>
            </a>
          ))}</div>}
      </div>

      <div style={CARD}>
        <p style={HD}>Transcript</p>
        {!sel ? <p style="font-size:12.5px;color:#6e6e78;margin:0;">Select a session to read its transcript.</p> :
          convo.length === 0 ? <p style="font-size:12.5px;color:#6e6e78;margin:0;">No turns recorded.</p> :
          <div style="display:flex;flex-direction:column;gap:10px;">{convo.map((m: any) => (
            <div style={'max-width:88%;padding:10px 14px;border-radius:12px;font-size:13px;line-height:1.55;white-space:pre-wrap;' + (m.role === 'user' ? 'align-self:flex-end;background:#15151a;color:#fff;' : 'align-self:flex-start;background:#08080a;border:1px solid #26262c;color:#cfd6da;')}>
              <div style="font-size:9px;text-transform:uppercase;font-family:'Geist Mono',monospace;color:#8a8a94;margin-bottom:4px;">{m.role} · {fmt(m.at)}</div>
              {m.content}
            </div>
          ))}</div>}
      </div>
    </div>
  </div>
  <style>@media (max-width:720px){ .tutor-grid{ grid-template-columns:1fr !important; } }</style>
</AdminLayout>
