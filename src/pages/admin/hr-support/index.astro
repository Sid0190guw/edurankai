---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { ensureHrSupportSchema, SUPPORT_KINDS } from '@/lib/hr-support';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

await ensureHrSupportSchema();
function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

const url = new URL(Astro.request.url);
const filterStatus = url.searchParams.get('status') || '';
const filterPayment = url.searchParams.get('payment') || '';
const q = url.searchParams.get('q') || '';

const like = '%' + q + '%';
const all = rows(await db.execute(sql`
  SELECT id, candidate_name, candidate_email, candidate_phone, support_kind, situation,
    target_role_slug, requested_slot_at, requested_slot_label, fee_amount, fee_currency,
    payment_status, meet_link, meet_scheduled_at, completed_at, created_at, updated_at
  FROM hr_application_support
  WHERE 1=1
    ${q ? sql`AND (candidate_name ILIKE ${like} OR candidate_email ILIKE ${like})` : sql``}
    ${filterStatus ? sql`AND (CASE WHEN completed_at IS NOT NULL THEN 'completed' WHEN meet_scheduled_at IS NOT NULL THEN 'scheduled' ELSE 'open' END) = ${filterStatus}` : sql``}
    ${filterPayment ? sql`AND payment_status = ${filterPayment}` : sql``}
  ORDER BY created_at DESC LIMIT 300
`));

function fmt(d: any) { try { return new Date(d).toLocaleString('en-IN', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' }); } catch { return ''; } }

const stats = {
  total: all.length,
  paid: all.filter((r: any) => r.payment_status === 'paid').length,
  scheduled: all.filter((r: any) => r.meet_scheduled_at).length,
  completed: all.filter((r: any) => r.completed_at).length,
  awaiting_payment: all.filter((r: any) => r.payment_status === 'pending').length,
};
---
<AdminLayout title="HR Application Support" activeNav="">
<div style="padding:14px 16px 80px;max-width:1280px;margin:0 auto;">
  <p style="font-size:10.5px;color:#1045BB;letter-spacing:0.12em;text-transform:uppercase;margin:0;font-family:'Geist Mono',monospace;font-weight:700;">Candidate ops</p>
  <h1 style="font-size:24px;color:#fff;margin:6px 0 4px;font-weight:700;">HR Application Support</h1>
  <p style="font-size:13px;color:#9aa6b6;margin:0 0 18px;">Paid 25 CHF service. Candidates pick a slot, pay, you confirm via Google Meet. Full thread + automated reply templates per request.</p>

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:8px;margin-bottom:20px;">
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px 14px;"><p style="font-size:10px;color:#9aa6b6;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 4px;font-family:'Geist Mono',monospace;">Total</p><p style="font-size:24px;color:#fff;margin:0;font-weight:700;">{stats.total}</p></div>
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px 14px;"><p style="font-size:10px;color:#FFC107;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 4px;font-family:'Geist Mono',monospace;">Awaiting payment</p><p style="font-size:24px;color:#fff;margin:0;font-weight:700;">{stats.awaiting_payment}</p></div>
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px 14px;"><p style="font-size:10px;color:#86efac;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 4px;font-family:'Geist Mono',monospace;">Paid</p><p style="font-size:24px;color:#fff;margin:0;font-weight:700;">{stats.paid}</p></div>
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px 14px;"><p style="font-size:10px;color:#67e8f9;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 4px;font-family:'Geist Mono',monospace;">Scheduled</p><p style="font-size:24px;color:#fff;margin:0;font-weight:700;">{stats.scheduled}</p></div>
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:12px 14px;"><p style="font-size:10px;color:#c4b5fd;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 4px;font-family:'Geist Mono',monospace;">Completed</p><p style="font-size:24px;color:#fff;margin:0;font-weight:700;">{stats.completed}</p></div>
  </div>

  <form method="GET" style="display:flex;gap:8px;margin-bottom:14px;align-items:center;flex-wrap:wrap;">
    <input name="q" value={q} type="text" placeholder="Search name or email..." style="flex:1;min-width:220px;background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;" />
    <select name="payment" style="background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12px;">
      <option value="">All payments</option>
      <option value="pending" selected={filterPayment === 'pending'}>Pending</option>
      <option value="paid" selected={filterPayment === 'paid'}>Paid</option>
      <option value="refunded" selected={filterPayment === 'refunded'}>Refunded</option>
      <option value="cancelled" selected={filterPayment === 'cancelled'}>Cancelled</option>
    </select>
    <select name="status" style="background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:9px 10px;border-radius:6px;font-size:12px;">
      <option value="">All statuses</option>
      <option value="open" selected={filterStatus === 'open'}>Open</option>
      <option value="scheduled" selected={filterStatus === 'scheduled'}>Scheduled</option>
      <option value="completed" selected={filterStatus === 'completed'}>Completed</option>
    </select>
    <button type="submit" style="background:#15151a;border:1px solid #2a2a2f;color:#1045BB;padding:9px 16px;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer;">Filter</button>
  </form>

  {all.length === 0 ? (
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:36px;text-align:center;color:#6e6e78;font-size:13px;">No HR Support requests yet.</div>
  ) : (
    <div style="display:flex;flex-direction:column;gap:8px;">
      {all.map((r: any) => {
        const kindMeta = SUPPORT_KINDS[r.support_kind] || SUPPORT_KINDS.general;
        const status = r.completed_at ? 'completed' : (r.meet_scheduled_at ? 'scheduled' : (r.payment_status === 'paid' ? 'paid' : 'awaiting payment'));
        const statusColor = status === 'completed' ? '#c4b5fd' : status === 'scheduled' ? '#67e8f9' : status === 'paid' ? '#86efac' : '#FFC107';
        return (
          <a href={'/admin/hr-support/' + r.id} style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;padding:14px 18px;text-decoration:none;color:#fff;display:grid;grid-template-columns:1.4fr 1.2fr 1fr 100px 100px 80px;gap:12px;align-items:center;hover:border-color:#1045BB;">
            <div style="min-width:0;">
              <p style="font-size:13px;font-weight:700;margin:0;color:#fff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{r.candidate_name}</p>
              <p style="font-size:10.5px;color:#9aa6b6;margin:2px 0 0;font-family:'Geist Mono',monospace;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{r.candidate_email}</p>
            </div>
            <p style="font-size:11.5px;color:#cfd6da;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{kindMeta.label}</p>
            <p style="font-size:11px;color:#67e8f9;margin:0;font-family:'Geist Mono',monospace;">{r.requested_slot_label || fmt(r.requested_slot_at) || '—'}</p>
            <span style={`background:${statusColor}22;color:${statusColor};font-size:10px;font-weight:700;padding:3px 8px;border-radius:100px;text-align:center;font-family:'Geist Mono',monospace;letter-spacing:0.06em;text-transform:uppercase;`}>{status}</span>
            <p style="font-size:10.5px;color:#FF7040;margin:0;font-family:'Geist Mono',monospace;font-weight:700;">{r.fee_currency} {Number(r.fee_amount).toFixed(0)}</p>
            <p style="font-size:10.5px;color:#6e6e78;margin:0;font-family:'Geist Mono',monospace;">{fmt(r.created_at)}</p>
          </a>
        );
      })}
    </div>
  )}
</div>
</AdminLayout>
