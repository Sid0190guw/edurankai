---
import AdminLayout from '@/layouts/AdminLayout.astro';
import TwoFactorPanel from '@/components/security/TwoFactorPanel.astro';
import { isTotpEnabled, countUnusedBackupCodes } from '@/lib/auth/twofactor';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

let enabled = false;
let backupRemaining = 0;
try {
  enabled = await isTotpEnabled(user.id);
  if (enabled) backupRemaining = await countUnusedBackupCodes(user.id);
} catch (_) {}
const accountLabel = user.email || (user as any).internalHandle || user.name || '';
---
<AdminLayout title="Security">
  <div style="max-width:640px;">
    <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:#DC5000;margin:0 0 8px;">Account security</p>
    <h1 style="font-size:26px;font-weight:700;color:#111;margin:0 0 6px;">Two-factor authentication</h1>
    <p style="font-size:14px;color:#6b7280;margin:0 0 24px;line-height:1.6;">A second step at sign-in protects admin access even if a password leaks. This is in addition to any face-recognition step already on your account.</p>

    <TwoFactorPanel enabled={enabled} backupRemaining={backupRemaining} accountLabel={accountLabel} />
  </div>
</AdminLayout>
