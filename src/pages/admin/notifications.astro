---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { NOTIFICATION_TYPES } from '@/lib/push';
import { notificationPreferences } from '@/lib/db/schema';
import { eq } from 'drizzle-orm';
import { CATEGORY_META, metaFor } from '@/lib/notification-catalog';
import { ensureNotificationsSchema } from '@/lib/notifications-schema';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

await ensureNotificationsSchema();

// Load this admin's saved opt-out map so toggles render their real state.
let savedPrefs: Record<string, boolean> = {};
try {
  const rows = await db.select().from(notificationPreferences)
    .where(eq(notificationPreferences.userId, user.id)).limit(1);
  if (rows.length > 0 && rows[0].prefs && typeof rows[0].prefs === 'object') {
    savedPrefs = rows[0].prefs as any;
  }
} catch (_) {}

// Group the catalogue for display
const prefGroups: Record<string, typeof NOTIFICATION_TYPES> = {};
for (const t of NOTIFICATION_TYPES) {
  (prefGroups[t.group] = prefGroups[t.group] || []).push(t);
}

const VAPID_PUBLIC = import.meta.env.VAPID_PUBLIC_KEY || 'PASTE_YOUR_PUBLIC_KEY_HERE';

let okMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  try {
    if (action === 'mark_read') {
      const notifId = fd.get('id') as string;
      await db.execute(sql`UPDATE notifications SET is_read = true, read_at = NOW() WHERE id = ${notifId} AND user_id = ${user.id}`);
    } else if (action === 'mark_all_read') {
      await db.execute(sql`UPDATE notifications SET is_read = true, read_at = NOW() WHERE user_id = ${user.id} AND is_read = false`);
      okMsg = 'All notifications marked as read.';
    } else if (action === 'delete_notif') {
      const notifId = fd.get('id') as string;
      await db.execute(sql`DELETE FROM notifications WHERE id = ${notifId} AND user_id = ${user.id}`);
    } else if (action === 'archive') {
      const notifId = fd.get('id') as string;
      await db.execute(sql`UPDATE notifications SET is_archived = true, is_read = true, read_at = COALESCE(read_at, NOW()) WHERE id = ${notifId} AND user_id = ${user.id}`);
    } else if (action === 'unarchive') {
      const notifId = fd.get('id') as string;
      await db.execute(sql`UPDATE notifications SET is_archived = false WHERE id = ${notifId} AND user_id = ${user.id}`);
    } else if (action === 'archive_all_read') {
      await db.execute(sql`UPDATE notifications SET is_archived = true WHERE user_id = ${user.id} AND is_read = true AND COALESCE(is_archived, false) = false`);
      okMsg = 'Archived all read notifications.';
    } else if (action === 'clear_all_read') {
      await db.execute(sql`DELETE FROM notifications WHERE user_id = ${user.id} AND is_read = true`);
      okMsg = 'Cleared all read notifications.';
    }
  } catch(e: any) {}
}

const url = new URL(Astro.request.url);
const tab = url.searchParams.get('tab') || 'inbox';
const filter = url.searchParams.get('filter') || 'all';
const view = url.searchParams.get('view') || 'inbox';       // inbox | archived
const category = url.searchParams.get('category') || 'all';
const q = (url.searchParams.get('q') || '').trim();

// Build the filtered history query (server-side; no polling).
let notifications: any[] = [];
let unreadCount = 0;
try {
  const conds = [sql`user_id = ${user.id}`];
  conds.push(view === 'archived' ? sql`is_archived = true` : sql`COALESCE(is_archived, false) = false`);
  if (filter === 'unread') conds.push(sql`is_read = false`);
  else if (filter === 'read') conds.push(sql`is_read = true`);
  if (category !== 'all') conds.push(sql`category = ${category}`);
  if (q) conds.push(sql`(title ILIKE ${'%' + q + '%'} OR body ILIKE ${'%' + q + '%'})`);
  const r = await db.execute(sql`
    SELECT * FROM notifications
    WHERE ${sql.join(conds, sql` AND `)}
    ORDER BY created_at DESC
    LIMIT 100
  `);
  notifications = Array.isArray(r) ? r : (r?.rows || []);
  const uc = await db.execute(sql`SELECT COUNT(*)::int AS n FROM notifications WHERE user_id = ${user.id} AND is_read = false AND COALESCE(is_archived, false) = false`);
  const ucRows = Array.isArray(uc) ? uc : (uc?.rows || []);
  unreadCount = Number((ucRows[0] as any)?.n) || 0;
} catch(e) {}

// Category icon glyphs (no emoji — inline SVG injected into <svg> via set:html).
const ICONS: Record<string, string> = {
  briefcase: '<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>',
  message: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
  wallet: '<path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/>',
  calendar: '<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>',
  users: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/>',
  book: '<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>',
  building: '<rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 22v-4h6v4M8 6h.01M16 6h.01M8 10h.01M16 10h.01M8 14h.01M16 14h.01"/>',
  bell: '<path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>',
};
const PRIORITY_COLOR: Record<string, string> = { critical: '#ef4444', high: '#f59e0b', medium: '#6e6e78', low: '#4b4b54' };

function metaForRow(n: any) {
  const fallback = metaFor(n.type);
  const catKey = (n.category && (CATEGORY_META as any)[n.category]) ? n.category : fallback.category;
  const cat = (CATEGORY_META as any)[catKey] || CATEGORY_META.system;
  const priority = n.priority || fallback.priority;
  return { cat, catKey, priority };
}

// Date buckets for grouped history.
function groupOf(d: any): string {
  const date = new Date(d); const now = new Date();
  const startToday = new Date(now.getFullYear(), now.getMonth(), now.getDate());
  const startYest = new Date(startToday); startYest.setDate(startYest.getDate() - 1);
  const startWeek = new Date(startToday); startWeek.setDate(startWeek.getDate() - 7);
  const startMonth = new Date(now.getFullYear(), now.getMonth(), 1);
  if (date >= startToday) return 'Today';
  if (date >= startYest) return 'Yesterday';
  if (date >= startWeek) return 'This Week';
  if (date >= startMonth) return 'This Month';
  return 'Older';
}
const GROUP_ORDER = ['Today', 'Yesterday', 'This Week', 'This Month', 'Older'];
const grouped: Record<string, any[]> = {};
for (const n of notifications) { const g = groupOf(n.created_at); (grouped[g] = grouped[g] || []).push(n); }
const activeGroups = GROUP_ORDER.filter((g) => grouped[g] && grouped[g].length);

function timeAgo(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins + 'm ago';
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return hrs + 'h ago';
  return Math.floor(hrs / 24) + 'd ago';
}
---
<AdminLayout title="Notifications" activeNav="notifications">
<div style="padding-bottom:80px;">

  <!-- Header -->
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
      <div>
        <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">Activity</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">
          Notifications
          {unreadCount > 0 && <span style="font-size:12px;font-weight:700;background:#FF4F00;color:#fff;padding:2px 8px;border-radius:100px;margin-left:8px;">{unreadCount}</span>}
        </h1>
      </div>
      {tab === 'inbox' && notifications.length > 0 && (
        <form method="POST" style="display:flex;gap:6px;">
          <button name="action" value="mark_all_read" type="submit" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;font-size:11px;padding:6px 10px;border-radius:6px;cursor:pointer;">Mark all read</button>
          <button name="action" value="clear_all_read" type="submit" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;font-size:11px;padding:6px 10px;border-radius:6px;cursor:pointer;">Clear read</button>
        </form>
      )}
    </div>

    <!-- Tabs -->
    <div style="display:flex;gap:4px;">
      {[['inbox','Inbox'],['settings','Push Settings']].map(([t,l]) => (
        <a href={`?tab=${t}`} style={`text-decoration:none;font-size:12px;font-weight:600;padding:6px 12px;border-radius:6px;${tab === t ? 'background:#FF4F00;color:#fff;' : 'background:#15151a;color:#8a8a94;'}`}>{l}</a>
      ))}
    </div>
  </div>

  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  <!-- INBOX TAB (Notification Center) -->
  {tab === 'inbox' && (
    <div style="padding:12px 16px;">
      <!-- Search -->
      <form method="GET" style="display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap;">
        <input type="hidden" name="tab" value="inbox" />
        <input type="hidden" name="view" value={view} />
        <input type="hidden" name="filter" value={filter} />
        {category !== 'all' && <input type="hidden" name="category" value={category} />}
        <div style="flex:1;min-width:180px;display:flex;align-items:center;gap:8px;background:#0f0f14;border:1px solid #1a1a1f;border-radius:8px;padding:7px 11px;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#6e6e78" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="text" name="q" value={q} placeholder="Search notifications..." style="flex:1;background:transparent;border:0;outline:0;color:#fff;font-size:13px;" />
        </div>
        <button type="submit" style="background:#FF4F00;border:none;color:#fff;font-size:12px;font-weight:600;padding:7px 14px;border-radius:8px;cursor:pointer;">Search</button>
        {(q || category !== 'all' || filter !== 'all') && (
          <a href={`?tab=inbox&view=${view}`} style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;font-size:12px;text-decoration:none;padding:7px 12px;border-radius:8px;display:inline-flex;align-items:center;">Clear</a>
        )}
      </form>

      <!-- View toggle + bulk actions -->
      <div style="display:flex;gap:6px;margin-bottom:10px;align-items:center;">
        {[['inbox','Inbox'],['archived','Archived']].map(([v,l]) => (
          <a href={`?tab=inbox&view=${v}`} style={`text-decoration:none;font-size:11px;font-weight:600;padding:5px 12px;border-radius:100px;${view === v ? 'background:#FF4F00;color:#fff;' : 'background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;'}`}>{l}</a>
        ))}
        <div style="flex:1;"></div>
        {notifications.length > 0 && view === 'inbox' && (
          <form method="POST" style="display:flex;gap:6px;">
            <button name="action" value="mark_all_read" type="submit" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;font-size:11px;padding:5px 10px;border-radius:100px;cursor:pointer;">Mark all read</button>
            <button name="action" value="archive_all_read" type="submit" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;font-size:11px;padding:5px 10px;border-radius:100px;cursor:pointer;">Archive read</button>
          </form>
        )}
      </div>

      <!-- Read/unread filter -->
      <div style="display:flex;gap:6px;margin-bottom:10px;flex-wrap:wrap;">
        {[['all','All'],['unread',`Unread (${unreadCount})`],['read','Read']].map(([v,l]) => (
          <a href={`?tab=inbox&view=${view}&filter=${v}${category!=='all'?`&category=${category}`:''}${q?`&q=${encodeURIComponent(q)}`:''}`} style={`text-decoration:none;font-size:11px;font-weight:600;padding:5px 12px;border-radius:100px;${filter === v ? 'background:#1f1f26;color:#fff;border:1px solid #2a2a32;' : 'background:#0f0f14;border:1px solid #1a1a1f;color:#8a8a94;'}`}>{l}</a>
        ))}
      </div>

      <!-- Category chips -->
      <div style="display:flex;gap:6px;margin-bottom:16px;flex-wrap:wrap;">
        <a href={`?tab=inbox&view=${view}&filter=${filter}`} style={`text-decoration:none;font-size:11px;font-weight:600;padding:4px 11px;border-radius:100px;${category==='all'?'background:#FF4F00;color:#fff;':'background:#0f0f14;border:1px solid #1a1a1f;color:#8a8a94;'}`}>All</a>
        {Object.entries(CATEGORY_META).map(([key, c]) => (
          <a href={`?tab=inbox&view=${view}&filter=${filter}&category=${key}`} style={`display:inline-flex;align-items:center;gap:5px;text-decoration:none;font-size:11px;font-weight:600;padding:4px 11px;border-radius:100px;${category===key?`background:${c.color}22;border:1px solid ${c.color};color:${c.color};`:'background:#0f0f14;border:1px solid #1a1a1f;color:#8a8a94;'}`}>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS[c.icon] || ICONS.bell}></svg>
            {c.label}
          </a>
        ))}
      </div>

      {notifications.length === 0 && (
        <div style="text-align:center;padding:48px;color:#6e6e78;">
          <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#3a3a42" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 10px;display:block;"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
          <p style="font-size:13px;">{view === 'archived' ? 'Nothing archived.' : (q || category !== 'all' || filter === 'unread') ? 'No notifications match this filter.' : 'No notifications yet.'}</p>
        </div>
      )}

      {activeGroups.map((g) => (
        <div style="margin-bottom:18px;">
          <p style="font-size:10px;font-family:'Geist Mono',monospace;letter-spacing:0.14em;text-transform:uppercase;color:#6e6e78;margin:0 0 8px;font-weight:700;">{g}</p>
          <div style="display:flex;flex-direction:column;gap:6px;">
            {grouped[g].map((n: any) => {
              const m = metaForRow(n);
              const isHi = m.priority === 'critical' || m.priority === 'high';
              return (
                <div style={`background:#0f0f14;border:1px solid ${n.is_read ? '#1a1a1f' : m.cat.color + '44'};border-radius:12px;overflow:hidden;${n.is_read ? 'opacity:0.72;' : ''}`}>
                  <div style="padding:12px 14px;display:flex;align-items:flex-start;gap:10px;">
                    <div style={`width:38px;height:38px;border-radius:10px;background:${m.cat.color}1a;color:${m.cat.color};display:flex;align-items:center;justify-content:center;flex-shrink:0;`}>
                      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS[m.cat.icon] || ICONS.bell}></svg>
                    </div>
                    <div style="flex:1;min-width:0;">
                      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">
                        <p style={`font-size:13px;font-weight:${n.is_read ? '500' : '600'};color:${n.is_read ? '#a0a0a8' : '#fff'};margin:0;`}>{n.title}</p>
                        <span style="font-size:10px;color:#6e6e78;flex-shrink:0;font-family:'Geist Mono',monospace;">{timeAgo(n.created_at)}</span>
                      </div>
                      {n.body && <p style="font-size:12px;color:#8a8a94;margin:3px 0 0;line-height:1.45;">{n.body}</p>}
                      <div style="display:flex;align-items:center;gap:8px;margin-top:6px;">
                        <span style={`font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:${m.cat.color};`}>{m.cat.label}</span>
                        {isHi && <span style={`font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:${PRIORITY_COLOR[m.priority]};background:${PRIORITY_COLOR[m.priority]}1f;padding:1px 7px;border-radius:100px;`}>{m.priority}</span>}
                        {!n.is_read && <span style="width:6px;height:6px;background:#FF4F00;border-radius:50%;display:inline-block;"></span>}
                      </div>
                    </div>
                  </div>
                  <div style="border-top:1px solid #1a1a1f;padding:6px 14px;display:flex;gap:6px;">
                    {n.action_url && (
                      <a href={n.action_url} style={`flex:1;text-align:center;background:#15151a;border:1px solid #1a1a1f;color:${m.cat.color};text-decoration:none;font-size:11px;font-weight:600;padding:6px;border-radius:6px;`}>View</a>
                    )}
                    {!n.is_read && (
                      <form method="POST" style="flex:1;">
                        <input type="hidden" name="action" value="mark_read" />
                        <input type="hidden" name="id" value={n.id} />
                        <button type="submit" style="width:100%;background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;font-size:11px;padding:6px;border-radius:6px;cursor:pointer;">Mark read</button>
                      </form>
                    )}
                    {view === 'archived' ? (
                      <form method="POST">
                        <input type="hidden" name="action" value="unarchive" />
                        <input type="hidden" name="id" value={n.id} />
                        <button type="submit" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;font-size:11px;padding:6px 10px;border-radius:6px;cursor:pointer;">Unarchive</button>
                      </form>
                    ) : (
                      <form method="POST">
                        <input type="hidden" name="action" value="archive" />
                        <input type="hidden" name="id" value={n.id} />
                        <button type="submit" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;font-size:11px;padding:6px 10px;border-radius:6px;cursor:pointer;">Archive</button>
                      </form>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  )}

  <!-- PUSH SETTINGS TAB -->
  {tab === 'settings' && (
    <div style="padding:12px 16px;">
      <meta name="vapid-public-key" content={VAPID_PUBLIC} />

      <!-- Push status card -->
      <div id="pushStatus" style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;margin-bottom:12px;">
        <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0 0 6px;">Push Status</p>
        <p id="pushStatusText" style="font-size:14px;font-weight:600;color:#fff;margin:0;">Checking...</p>
        <p id="pushStatusSub" style="font-size:11px;color:#6e6e78;margin:4px 0 0;"></p>
        <div style="display:flex;gap:8px;margin-top:12px;">
          <button id="enablePushBtn" style="display:none;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:13px;padding:9px 16px;border-radius:8px;cursor:pointer;">Enable Notifications</button>
          <button id="disablePushBtn" style="display:none;background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;font-weight:600;font-size:13px;padding:9px 16px;border-radius:8px;cursor:pointer;">Disable</button>
        </div>
      </div>

      <!-- Preferences -->
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
        <div style="padding:12px 14px;border-bottom:1px solid #1a1a1f;display:flex;align-items:center;justify-content:space-between;">
          <p style="font-size:13px;font-weight:600;color:#fff;margin:0;">What to notify me about</p>
          <span id="prefSaveState" style="font-size:11px;color:#6e6e78;"></span>
        </div>
        {Object.entries(prefGroups).map(([group, items]) => (
          <div>
            <div style="padding:9px 14px;background:#0a0a0c;border-bottom:1px solid #1a1a1f;">
              <p style="font-size:10px;font-family:'Geist Mono',monospace;letter-spacing:0.14em;text-transform:uppercase;color:#FF7040;margin:0;font-weight:700;">{group}</p>
            </div>
            {items.map(pref => {
              const on = savedPrefs[pref.type] !== false;
              return (
                <div style="padding:12px 14px;border-bottom:1px solid #0a0a0c;display:flex;align-items:center;justify-content:space-between;gap:14px;">
                  <div>
                    <p style="font-size:13px;font-weight:500;color:#fff;margin:0;">{pref.label}</p>
                    <p style="font-size:11px;color:#6e6e78;margin:2px 0 0;">{pref.desc}</p>
                  </div>
                  <label style="position:relative;display:inline-block;width:44px;height:24px;flex-shrink:0;">
                    <input type="checkbox" class="pref-toggle" data-type={pref.type} checked={on} style="opacity:0;width:0;height:0;position:absolute;" />
                    <span style={'position:absolute;cursor:pointer;inset:0;background:' + (on ? '#FF4F00' : '#1a1a1f') + ';border-radius:100px;transition:0.2s;'} class="pref-slider"></span>
                    <span style={'position:absolute;top:3px;left:' + (on ? '23px' : '3px') + ';width:18px;height:18px;background:#fff;border-radius:50%;transition:0.2s;pointer-events:none;'} class="pref-knob"></span>
                  </label>
                </div>
              );
            })}
          </div>
        ))}
      </div>
    </div>
  )}
</div>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  // Push notification setup
  var vapidKey = document.querySelector('meta[name="vapid-public-key"]')?.getAttribute('content');
  var statusText = document.getElementById('pushStatusText');
  var statusSub = document.getElementById('pushStatusSub');
  var enableBtn = document.getElementById('enablePushBtn');
  var disableBtn = document.getElementById('disablePushBtn');

  function urlBase64ToUint8Array(base64String) {
    var padding = '='.repeat((4 - base64String.length % 4) % 4);
    var base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
    var rawData = window.atob(base64);
    var outputArray = new Uint8Array(rawData.length);
    for (var i = 0; i < rawData.length; ++i) { outputArray[i] = rawData.charCodeAt(i); }
    return outputArray;
  }

  if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
    if (statusText) statusText.textContent = 'Push not supported in this browser';
    if (statusSub) statusSub.textContent = 'Use Chrome or Edge for push notifications.';
    return;
  }

  navigator.serviceWorker.register('/sw.js').then(function(reg) {
    return reg.pushManager.getSubscription().then(function(sub) {
      if (sub) {
        if (statusText) statusText.textContent = 'Notifications enabled';
        if (statusSub) statusSub.textContent = 'You will receive push notifications on this device.';
        if (disableBtn) disableBtn.style.display = 'block';
      } else {
        if (statusText) statusText.textContent = 'Notifications disabled';
        if (statusSub) statusSub.textContent = 'Enable to get real-time alerts for applications, messages and more.';
        if (enableBtn) enableBtn.style.display = 'block';
      }

      if (enableBtn) enableBtn.addEventListener('click', function() {
        enableBtn.disabled = true;
        enableBtn.textContent = 'Enabling...';
        reg.pushManager.subscribe({
          userVisibleOnly: true,
          applicationServerKey: urlBase64ToUint8Array(vapidKey)
        }).then(function(sub) {
          return fetch('/admin/api/push/subscribe', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(sub)
          });
        }).then(function() {
          if (statusText) statusText.textContent = 'Notifications enabled';
          if (statusSub) statusSub.textContent = 'You will receive push notifications on this device.';
          enableBtn.style.display = 'none';
          if (disableBtn) disableBtn.style.display = 'block';
        }).catch(function(err) {
          if (statusText) statusText.textContent = 'Error enabling notifications';
          if (statusSub) statusSub.textContent = err.message;
          enableBtn.disabled = false;
          enableBtn.textContent = 'Enable Notifications';
        });
      });

      if (disableBtn) disableBtn.addEventListener('click', function() {
        disableBtn.disabled = true;
        reg.pushManager.getSubscription().then(function(sub) {
          if (sub) return sub.unsubscribe();
        }).then(function() {
          if (statusText) statusText.textContent = 'Notifications disabled';
          if (statusSub) statusSub.textContent = 'You will no longer receive push notifications on this device.';
          disableBtn.style.display = 'none';
          if (enableBtn) { enableBtn.style.display = 'block'; enableBtn.disabled = false; }
        });
      });
    });
  }).catch(function(err) {
    if (statusText) statusText.textContent = 'Service worker error';
    if (statusSub) statusSub.textContent = err.message;
  });

  // Toggle sliders: visual + persist to server
  var saveState = document.getElementById('prefSaveState');
  function flash(msg, ok) {
    if (!saveState) return;
    saveState.textContent = msg;
    saveState.style.color = ok ? '#10b981' : '#ef4444';
    setTimeout(function() { if (saveState) saveState.textContent = ''; }, 2000);
  }
  document.querySelectorAll('.pref-toggle').forEach(function(toggle) {
    var slider = toggle.parentElement.querySelector('.pref-slider');
    var knob = toggle.parentElement.querySelector('.pref-knob');
    function paint() {
      if (slider) slider.style.background = toggle.checked ? '#FF4F00' : '#1a1a1f';
      if (knob) knob.style.left = toggle.checked ? '23px' : '3px';
    }
    paint();
    toggle.addEventListener('change', function() {
      paint();
      var type = toggle.getAttribute('data-type');
      toggle.disabled = true;
      fetch('/admin/api/push/preferences', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type: type, enabled: toggle.checked })
      }).then(function(r) { return r.json(); }).then(function(d) {
        toggle.disabled = false;
        if (d && d.ok) flash('Saved', true);
        else { flash('Failed to save', false); toggle.checked = !toggle.checked; paint(); }
      }).catch(function() {
        toggle.disabled = false;
        flash('Network error', false);
        toggle.checked = !toggle.checked; paint();
      });
    });
  });
});
</script>
</AdminLayout>
