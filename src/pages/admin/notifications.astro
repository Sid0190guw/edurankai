---
import AdminLayout from '@/layouts/AdminLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

const VAPID_PUBLIC = import.meta.env.VAPID_PUBLIC_KEY || '';
---
<AdminLayout title="Notification Settings" activeNav="notifications">
  <div class="mb-6">
    <h1 class="font-display text-[1.6rem] font-semibold text-white">Notification Settings</h1>
    <p class="text-[0.85rem] text-white/60 mt-1">Manage browser push notifications for your account.</p>
  </div>

  <!-- Push permission status -->
  <div id="pushStatus" class="mb-6 p-4 rounded-xl border border-white/10 bg-white/5">
    <div class="flex items-center justify-between flex-wrap gap-3">
      <div>
        <p class="text-[0.7rem] font-mono uppercase tracking-wider text-white/40 mb-1">Push Status</p>
        <p id="pushStatusText" class="text-[0.95rem] font-semibold text-white">Checking...</p>
        <p id="pushStatusSub" class="text-[0.78rem] text-white/50 mt-1"></p>
      </div>
      <div class="flex gap-2">
        <button id="enablePushBtn" class="bg-burn hover:bg-burn/90 text-white font-semibold py-2 px-5 rounded-lg text-[0.85rem] border-0 cursor-pointer hidden">Enable Notifications</button>
        <button id="disablePushBtn" class="bg-white/10 hover:bg-white/15 text-white font-semibold py-2 px-5 rounded-lg text-[0.85rem] border border-white/20 cursor-pointer hidden">Disable</button>
      </div>
    </div>
  </div>

  <!-- Notification type toggles -->
  <div class="bg-white/5 border border-white/10 rounded-xl p-5 mb-5">
    <h2 class="font-display text-[1rem] font-semibold text-white mb-4">What to notify me about</h2>
    <div id="prefsForm" class="flex flex-col gap-3">
      {[
        { key: 'notifyChat', label: 'New chat messages', sub: 'When someone sends a message in any channel' },
        { key: 'notifyNewApplication', label: 'New applications', sub: 'When someone submits an application' },
        { key: 'notifyApplicationStatus', label: 'Application status changes', sub: 'When an application moves to a new stage' },
        { key: 'notifyOfferSigned', label: 'Offer accepted', sub: 'When a candidate signs their offer letter' },
        { key: 'notifyNewUser', label: 'New user registrations', sub: 'When someone creates a portal account' },
        { key: 'notifyNewHeiSubmission', label: 'HEI submissions', sub: 'When an institution submits a claim or data update' },
      ].map(item => (
        <label class="flex items-center justify-between gap-4 p-3 rounded-lg bg-white/3 border border-white/8 cursor-pointer hover:bg-white/5 transition-colors">
          <div>
            <p class="text-[0.9rem] font-medium text-white">{item.label}</p>
            <p class="text-[0.75rem] text-white/50 mt-0.5">{item.sub}</p>
          </div>
          <input type="checkbox" data-pref={item.key} class="w-4 h-4 accent-burn cursor-pointer" checked />
        </label>
      ))}
    </div>
    <button id="savePrefsBtn" class="mt-4 bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-6 rounded-lg text-[0.88rem] border-0 cursor-pointer">Save Preferences</button>
    <p id="saveStatus" class="text-[0.78rem] text-leaf mt-2 hidden">Saved.</p>
  </div>

  <div class="text-[0.75rem] text-white/30 leading-relaxed max-w-lg">
    Push notifications are delivered by your browser. You can revoke permission at any time via your browser's site settings. Notifications only work when your browser is open; for background push on mobile you need to have the site added to your home screen.
  </div>
</AdminLayout>

<script is:inline define:vars={{ vapidPublicKey: VAPID_PUBLIC }}>
(function() {
  var enableBtn = document.getElementById('enablePushBtn');
  var disableBtn = document.getElementById('disablePushBtn');
  var statusText = document.getElementById('pushStatusText');
  var statusSub = document.getElementById('pushStatusSub');
  var saveBtn = document.getElementById('savePrefsBtn');
  var saveStatus = document.getElementById('saveStatus');

  // ── Load preferences ──────────────────────────────────────────────────
  fetch('/admin/api/push/preferences', { credentials: 'same-origin' })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data.ok || !data.prefs) return;
      var prefs = data.prefs;
      document.querySelectorAll('[data-pref]').forEach(function(cb) {
        var key = cb.getAttribute('data-pref');
        if (prefs[key] !== undefined) cb.checked = prefs[key];
      });
    });

  // ── Save preferences ──────────────────────────────────────────────────
  saveBtn.addEventListener('click', function() {
    var body = {};
    document.querySelectorAll('[data-pref]').forEach(function(cb) {
      body[cb.getAttribute('data-pref')] = cb.checked;
    });
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';
    fetch('/admin/api/push/preferences', {
      method: 'POST', credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    }).then(function() {
      saveStatus.classList.remove('hidden');
      setTimeout(function() { saveStatus.classList.add('hidden'); }, 3000);
    }).finally(function() {
      saveBtn.disabled = false;
      saveBtn.textContent = 'Save Preferences';
    });
  });

  // ── Push subscription flow ────────────────────────────────────────────
  if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
    statusText.textContent = 'Not supported in this browser';
    statusSub.textContent = 'Use Chrome, Edge, or Firefox for push notifications.';
    return;
  }

  function urlBase64ToUint8Array(base64String) {
    var padding = '='.repeat((4 - base64String.length % 4) % 4);
    var base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
    var rawData = atob(base64);
    var arr = new Uint8Array(rawData.length);
    for (var i = 0; i < rawData.length; ++i) arr[i] = rawData.charCodeAt(i);
    return arr;
  }

  function updateUI(permission, subscription) {
    if (permission === 'denied') {
      statusText.textContent = 'Blocked by browser';
      statusSub.textContent = 'Go to browser site settings and allow notifications for this site.';
      enableBtn.classList.add('hidden');
      disableBtn.classList.add('hidden');
    } else if (subscription) {
      statusText.textContent = '✓ Notifications enabled on this device';
      statusSub.textContent = 'You will receive push notifications in this browser.';
      enableBtn.classList.add('hidden');
      disableBtn.classList.remove('hidden');
    } else {
      statusText.textContent = 'Not enabled';
      statusSub.textContent = 'Click Enable to start receiving notifications.';
      enableBtn.classList.remove('hidden');
      disableBtn.classList.add('hidden');
    }
  }

  var swReg = null;

  navigator.serviceWorker.register('/sw.js').then(function(reg) {
    swReg = reg;
    var perm = Notification.permission;
    reg.pushManager.getSubscription().then(function(sub) {
      updateUI(perm, sub);
    });
  }).catch(function(err) {
    statusText.textContent = 'Service worker error';
    statusSub.textContent = err.message;
  });

  enableBtn.addEventListener('click', function() {
    if (!swReg) return;
    enableBtn.disabled = true;
    enableBtn.textContent = 'Enabling...';
    Notification.requestPermission().then(function(perm) {
      if (perm !== 'granted') {
        updateUI(perm, null);
        enableBtn.disabled = false;
        enableBtn.textContent = 'Enable Notifications';
        return;
      }
      return swReg.pushManager.subscribe({
        userVisibleOnly: true,
        applicationServerKey: urlBase64ToUint8Array(vapidPublicKey)
      }).then(function(sub) {
        var subJson = sub.toJSON();
        return fetch('/admin/api/push/subscribe', {
          method: 'POST', credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ endpoint: subJson.endpoint, keys: subJson.keys })
        }).then(function() { updateUI('granted', sub); });
      });
    }).catch(function(err) {
      statusText.textContent = 'Error enabling notifications';
      statusSub.textContent = err.message;
    }).finally(function() {
      enableBtn.disabled = false;
      enableBtn.textContent = 'Enable Notifications';
    });
  });

  disableBtn.addEventListener('click', function() {
    if (!swReg) return;
    disableBtn.disabled = true;
    swReg.pushManager.getSubscription().then(function(sub) {
      if (!sub) { updateUI('default', null); return; }
      var endpoint = sub.endpoint;
      return sub.unsubscribe().then(function() {
        return fetch('/admin/api/push/subscribe', {
          method: 'DELETE', credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ endpoint: endpoint })
        });
      }).then(function() { updateUI('default', null); });
    }).finally(function() { disableBtn.disabled = false; });
  });
})();
</script>
