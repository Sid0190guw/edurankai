---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { NOTIFICATION_TYPES } from '@/lib/push';
import { notificationPreferences } from '@/lib/db/schema';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
if (user.role === 'applicant') return Astro.redirect('/portal');

// Load this admin's saved opt-out map so toggles render their real state.
let savedPrefs: Record<string, boolean> = {};
try {
  const rows = await db.select().from(notificationPreferences)
    .where(eq(notificationPreferences.userId, user.id)).limit(1);
  if (rows.length > 0 && rows[0].prefs && typeof rows[0].prefs === 'object') {
    savedPrefs = rows[0].prefs as any;
  }
} catch (_) {}

// Group the catalogue for display
const prefGroups: Record<string, typeof NOTIFICATION_TYPES> = {};
for (const t of NOTIFICATION_TYPES) {
  (prefGroups[t.group] = prefGroups[t.group] || []).push(t);
}

const VAPID_PUBLIC = import.meta.env.VAPID_PUBLIC_KEY || 'PASTE_YOUR_PUBLIC_KEY_HERE';

let okMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  try {
    if (action === 'mark_read') {
      const notifId = fd.get('id') as string;
      await db.execute(sql`UPDATE notifications SET is_read = true, read_at = NOW() WHERE id = ${notifId} AND user_id = ${user.id}`);
    } else if (action === 'mark_all_read') {
      await db.execute(sql`UPDATE notifications SET is_read = true, read_at = NOW() WHERE user_id = ${user.id} AND is_read = false`);
      okMsg = 'All notifications marked as read.';
    } else if (action === 'delete_notif') {
      const notifId = fd.get('id') as string;
      await db.execute(sql`DELETE FROM notifications WHERE id = ${notifId} AND user_id = ${user.id}`);
    } else if (action === 'clear_all_read') {
      await db.execute(sql`DELETE FROM notifications WHERE user_id = ${user.id} AND is_read = true`);
      okMsg = 'Cleared all read notifications.';
    }
  } catch(e: any) {}
}

const url = new URL(Astro.request.url);
const tab = url.searchParams.get('tab') || 'inbox';
const filter = url.searchParams.get('filter') || 'all';

// Load notifications
let notifications: any[] = [];
let unreadCount = 0;
try {
  const whereClause = filter === 'unread' ? sql`AND is_read = false` : filter === 'read' ? sql`AND is_read = true` : sql``;
  const r = await db.execute(sql`
    SELECT * FROM notifications
    WHERE user_id = ${user.id} ${whereClause}
    ORDER BY created_at DESC
    LIMIT 50
  `);
  notifications = Array.isArray(r) ? r : (r?.rows || []);
  const uc = await db.execute(sql`SELECT COUNT(*)::int as n FROM notifications WHERE user_id = ${user.id} AND is_read = false`);
  const ucRows = Array.isArray(uc) ? uc : (uc?.rows || []);
  unreadCount = Number((ucRows[0] as any)?.n) || 0;
} catch(e) {}

// Notification type config
const TYPE_CONFIG: Record<string, { color: string; icon: string; bg: string }> = {
  application: { color: '#FF7040', icon: '📋', bg: 'rgba(255,112,64,0.1)' },
  hire: { color: '#10b981', icon: '🎉', bg: 'rgba(16,185,129,0.1)' },
  leave: { color: '#fbbf24', icon: '📅', bg: 'rgba(251,191,36,0.1)' },
  message: { color: '#60a5fa', icon: '💬', bg: 'rgba(96,165,250,0.1)' },
  offer: { color: '#a78bfa', icon: '📄', bg: 'rgba(167,139,250,0.1)' },
  payroll: { color: '#34d399', icon: '💰', bg: 'rgba(52,211,153,0.1)' },
  system: { color: '#6e6e78', icon: '⚙️', bg: 'rgba(110,110,120,0.1)' },
  info: { color: '#6e6e78', icon: '🔔', bg: 'rgba(110,110,120,0.1)' },
};

function timeAgo(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins + 'm ago';
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return hrs + 'h ago';
  return Math.floor(hrs / 24) + 'd ago';
}
---
<AdminLayout title="Notifications" activeNav="notifications">
<div style="padding-bottom:80px;">

  <!-- Header -->
  <div style="background:#08080a;border-bottom:1px solid #1a1a1f;padding:14px 16px;position:sticky;top:0;z-index:10;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
      <div>
        <p style="font-size:10px;font-family:'Geist Mono',monospace;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;">Activity</p>
        <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0;">
          Notifications
          {unreadCount > 0 && <span style="font-size:12px;font-weight:700;background:#FF4F00;color:#fff;padding:2px 8px;border-radius:100px;margin-left:8px;">{unreadCount}</span>}
        </h1>
      </div>
      {tab === 'inbox' && notifications.length > 0 && (
        <form method="POST" style="display:flex;gap:6px;">
          <button name="action" value="mark_all_read" type="submit" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;font-size:11px;padding:6px 10px;border-radius:6px;cursor:pointer;">Mark all read</button>
          <button name="action" value="clear_all_read" type="submit" style="background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;font-size:11px;padding:6px 10px;border-radius:6px;cursor:pointer;">Clear read</button>
        </form>
      )}
    </div>

    <!-- Tabs -->
    <div style="display:flex;gap:4px;">
      {[['inbox','Inbox'],['settings','Push Settings']].map(([t,l]) => (
        <a href={`?tab=${t}`} style={`text-decoration:none;font-size:12px;font-weight:600;padding:6px 12px;border-radius:6px;${tab === t ? 'background:#FF4F00;color:#fff;' : 'background:#15151a;color:#8a8a94;'}`}>{l}</a>
      ))}
    </div>
  </div>

  {okMsg && <div style="margin:10px 16px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;border-radius:8px;padding:10px 14px;font-size:13px;">{okMsg}</div>}

  <!-- INBOX TAB -->
  {tab === 'inbox' && (
    <div style="padding:12px 16px;">
      <!-- Filter pills -->
      <div style="display:flex;gap:6px;margin-bottom:12px;">
        {[['all','All'],['unread',`Unread (${unreadCount})`],['read','Read']].map(([v,l]) => (
          <a href={`?tab=inbox&filter=${v}`} style={`text-decoration:none;font-size:11px;font-weight:600;padding:5px 12px;border-radius:100px;${filter === v ? 'background:#FF4F00;color:#fff;' : 'background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;'}`}>{l}</a>
        ))}
      </div>

      {notifications.length === 0 && (
        <div style="text-align:center;padding:48px;color:#6e6e78;">
          <p style="font-size:32px;margin-bottom:8px;">🔔</p>
          <p style="font-size:13px;">{filter === 'unread' ? 'No unread notifications.' : 'No notifications yet.'}</p>
          <p style="font-size:12px;margin-top:4px;color:#6e6e78;">Notifications appear here when applications are submitted, status changes, leave is requested, and more.</p>
        </div>
      )}

      <div style="display:flex;flex-direction:column;gap:6px;">
        {notifications.map((n: any) => {
          const cfg = TYPE_CONFIG[n.type] || TYPE_CONFIG['info'];
          return (
            <div style={`background:${n.is_read ? '#0f0f14' : '#0f0f14'};border:1px solid ${n.is_read ? '#1a1a1f' : '#FF4F0033'};border-radius:12px;overflow:hidden;${n.is_read ? 'opacity:0.75;' : ''}`}>
              <div style="padding:12px 14px;display:flex;align-items:flex-start;gap:10px;">
                <!-- Icon -->
                <div style={`width:38px;height:38px;border-radius:10px;background:${cfg.bg};display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;`}>
                  {cfg.icon}
                </div>
                <!-- Content -->
                <div style="flex:1;min-width:0;">
                  <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">
                    <p style={`font-size:13px;font-weight:${n.is_read ? '500' : '600'};color:${n.is_read ? '#8a8a94' : '#fff'};margin:0;`}>{n.title}</p>
                    <span style="font-size:10px;color:#6e6e78;flex-shrink:0;font-family:'Geist Mono',monospace;">{timeAgo(n.created_at)}</span>
                  </div>
                  {n.body && <p style="font-size:12px;color:#6e6e78;margin:3px 0 0;line-height:1.4;">{n.body}</p>}
                  {!n.is_read && <div style="width:6px;height:6px;background:#FF4F00;border-radius:50%;display:inline-block;margin-top:4px;"></div>}
                </div>
              </div>

              <!-- Actions -->
              <div style="border-top:1px solid #1a1a1f;padding:6px 14px;display:flex;gap:6px;">
                {n.action_url && (
                  <a href={n.action_url} style="flex:1;text-align:center;background:#15151a;border:1px solid #1a1a1f;color:#FF7040;text-decoration:none;font-size:11px;font-weight:600;padding:6px;border-radius:6px;">
                    View →
                  </a>
                )}
                {!n.is_read && (
                  <form method="POST" style="flex:1;">
                    <input type="hidden" name="action" value="mark_read" />
                    <input type="hidden" name="id" value={n.id} />
                    <button type="submit" style="width:100%;background:#15151a;border:1px solid #1a1a1f;color:#8a8a94;font-size:11px;padding:6px;border-radius:6px;cursor:pointer;">Mark read</button>
                  </form>
                )}
                <form method="POST">
                  <input type="hidden" name="action" value="delete_notif" />
                  <input type="hidden" name="id" value={n.id} />
                  <button type="submit" style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);color:#fca5a5;font-size:11px;padding:6px 10px;border-radius:6px;cursor:pointer;">Del</button>
                </form>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  )}

  <!-- PUSH SETTINGS TAB -->
  {tab === 'settings' && (
    <div style="padding:12px 16px;">
      <meta name="vapid-public-key" content={VAPID_PUBLIC} />

      <!-- Push status card -->
      <div id="pushStatus" style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:14px;margin-bottom:12px;">
        <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin:0 0 6px;">Push Status</p>
        <p id="pushStatusText" style="font-size:14px;font-weight:600;color:#fff;margin:0;">Checking...</p>
        <p id="pushStatusSub" style="font-size:11px;color:#6e6e78;margin:4px 0 0;"></p>
        <div style="display:flex;gap:8px;margin-top:12px;">
          <button id="enablePushBtn" style="display:none;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:13px;padding:9px 16px;border-radius:8px;cursor:pointer;">Enable Notifications</button>
          <button id="disablePushBtn" style="display:none;background:#15151a;border:1px solid #1a1a1f;color:#d8d8de;font-weight:600;font-size:13px;padding:9px 16px;border-radius:8px;cursor:pointer;">Disable</button>
        </div>
      </div>

      <!-- Preferences -->
      <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
        <div style="padding:12px 14px;border-bottom:1px solid #1a1a1f;display:flex;align-items:center;justify-content:space-between;">
          <p style="font-size:13px;font-weight:600;color:#fff;margin:0;">What to notify me about</p>
          <span id="prefSaveState" style="font-size:11px;color:#6e6e78;"></span>
        </div>
        {Object.entries(prefGroups).map(([group, items]) => (
          <div>
            <div style="padding:9px 14px;background:#0a0a0c;border-bottom:1px solid #1a1a1f;">
              <p style="font-size:10px;font-family:'Geist Mono',monospace;letter-spacing:0.14em;text-transform:uppercase;color:#FF7040;margin:0;font-weight:700;">{group}</p>
            </div>
            {items.map(pref => {
              const on = savedPrefs[pref.type] !== false;
              return (
                <div style="padding:12px 14px;border-bottom:1px solid #0a0a0c;display:flex;align-items:center;justify-content:space-between;gap:14px;">
                  <div>
                    <p style="font-size:13px;font-weight:500;color:#fff;margin:0;">{pref.label}</p>
                    <p style="font-size:11px;color:#6e6e78;margin:2px 0 0;">{pref.desc}</p>
                  </div>
                  <label style="position:relative;display:inline-block;width:44px;height:24px;flex-shrink:0;">
                    <input type="checkbox" class="pref-toggle" data-type={pref.type} checked={on} style="opacity:0;width:0;height:0;position:absolute;" />
                    <span style={'position:absolute;cursor:pointer;inset:0;background:' + (on ? '#FF4F00' : '#1a1a1f') + ';border-radius:100px;transition:0.2s;'} class="pref-slider"></span>
                    <span style={'position:absolute;top:3px;left:' + (on ? '23px' : '3px') + ';width:18px;height:18px;background:#fff;border-radius:50%;transition:0.2s;pointer-events:none;'} class="pref-knob"></span>
                  </label>
                </div>
              );
            })}
          </div>
        ))}
      </div>
    </div>
  )}
</div>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  // Push notification setup
  var vapidKey = document.querySelector('meta[name="vapid-public-key"]')?.getAttribute('content');
  var statusText = document.getElementById('pushStatusText');
  var statusSub = document.getElementById('pushStatusSub');
  var enableBtn = document.getElementById('enablePushBtn');
  var disableBtn = document.getElementById('disablePushBtn');

  function urlBase64ToUint8Array(base64String) {
    var padding = '='.repeat((4 - base64String.length % 4) % 4);
    var base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
    var rawData = window.atob(base64);
    var outputArray = new Uint8Array(rawData.length);
    for (var i = 0; i < rawData.length; ++i) { outputArray[i] = rawData.charCodeAt(i); }
    return outputArray;
  }

  if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
    if (statusText) statusText.textContent = 'Push not supported in this browser';
    if (statusSub) statusSub.textContent = 'Use Chrome or Edge for push notifications.';
    return;
  }

  navigator.serviceWorker.register('/sw.js').then(function(reg) {
    return reg.pushManager.getSubscription().then(function(sub) {
      if (sub) {
        if (statusText) statusText.textContent = 'Notifications enabled';
        if (statusSub) statusSub.textContent = 'You will receive push notifications on this device.';
        if (disableBtn) disableBtn.style.display = 'block';
      } else {
        if (statusText) statusText.textContent = 'Notifications disabled';
        if (statusSub) statusSub.textContent = 'Enable to get real-time alerts for applications, messages and more.';
        if (enableBtn) enableBtn.style.display = 'block';
      }

      if (enableBtn) enableBtn.addEventListener('click', function() {
        enableBtn.disabled = true;
        enableBtn.textContent = 'Enabling...';
        reg.pushManager.subscribe({
          userVisibleOnly: true,
          applicationServerKey: urlBase64ToUint8Array(vapidKey)
        }).then(function(sub) {
          return fetch('/admin/api/push/subscribe', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(sub)
          });
        }).then(function() {
          if (statusText) statusText.textContent = 'Notifications enabled';
          if (statusSub) statusSub.textContent = 'You will receive push notifications on this device.';
          enableBtn.style.display = 'none';
          if (disableBtn) disableBtn.style.display = 'block';
        }).catch(function(err) {
          if (statusText) statusText.textContent = 'Error enabling notifications';
          if (statusSub) statusSub.textContent = err.message;
          enableBtn.disabled = false;
          enableBtn.textContent = 'Enable Notifications';
        });
      });

      if (disableBtn) disableBtn.addEventListener('click', function() {
        disableBtn.disabled = true;
        reg.pushManager.getSubscription().then(function(sub) {
          if (sub) return sub.unsubscribe();
        }).then(function() {
          if (statusText) statusText.textContent = 'Notifications disabled';
          if (statusSub) statusSub.textContent = 'You will no longer receive push notifications on this device.';
          disableBtn.style.display = 'none';
          if (enableBtn) { enableBtn.style.display = 'block'; enableBtn.disabled = false; }
        });
      });
    });
  }).catch(function(err) {
    if (statusText) statusText.textContent = 'Service worker error';
    if (statusSub) statusSub.textContent = err.message;
  });

  // Toggle sliders: visual + persist to server
  var saveState = document.getElementById('prefSaveState');
  function flash(msg, ok) {
    if (!saveState) return;
    saveState.textContent = msg;
    saveState.style.color = ok ? '#10b981' : '#ef4444';
    setTimeout(function() { if (saveState) saveState.textContent = ''; }, 2000);
  }
  document.querySelectorAll('.pref-toggle').forEach(function(toggle) {
    var slider = toggle.parentElement.querySelector('.pref-slider');
    var knob = toggle.parentElement.querySelector('.pref-knob');
    function paint() {
      if (slider) slider.style.background = toggle.checked ? '#FF4F00' : '#1a1a1f';
      if (knob) knob.style.left = toggle.checked ? '23px' : '3px';
    }
    paint();
    toggle.addEventListener('change', function() {
      paint();
      var type = toggle.getAttribute('data-type');
      toggle.disabled = true;
      fetch('/admin/api/push/preferences', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type: type, enabled: toggle.checked })
      }).then(function(r) { return r.json(); }).then(function(d) {
        toggle.disabled = false;
        if (d && d.ok) flash('Saved', true);
        else { flash('Failed to save', false); toggle.checked = !toggle.checked; paint(); }
      }).catch(function() {
        toggle.disabled = false;
        flash('Network error', false);
        toggle.checked = !toggle.checked; paint();
      });
    });
  });
});
</script>
</AdminLayout>
