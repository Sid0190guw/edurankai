---
import AdminLayout from '@/layouts/AdminLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');
---
<AdminLayout title="Mobile Diagnostic" description="Diagnose mobile sidebar issues">
  <div class="admin-page" style="max-width:900px;">
    <h1 style="color:#fff;font-size:20px;margin-bottom:18px;">📱 Mobile Diagnostic</h1>

    <div id="diagOutput" style="background:#0a0a0c;border:1px solid #1f1f26;border-radius:8px;padding:14px;font-family:'Geist Mono',monospace;font-size:12px;color:#a0a0ab;line-height:1.7;white-space:pre-wrap;word-wrap:break-word;">
Running diagnostic...
    </div>

    <div style="margin-top:18px;display:flex;flex-direction:column;gap:10px;">
      <button id="testHamburger" style="background:#FF4F00;border:none;color:#fff;padding:14px;border-radius:8px;font-weight:700;font-size:14px;cursor:pointer;">TEST 1: Find hamburger button</button>
      <button id="testSidebar" style="background:#FF4F00;border:none;color:#fff;padding:14px;border-radius:8px;font-weight:700;font-size:14px;cursor:pointer;">TEST 2: Find sidebar</button>
      <button id="testOpen" style="background:#10b981;border:none;color:#fff;padding:14px;border-radius:8px;font-weight:700;font-size:14px;cursor:pointer;">TEST 3: Force-open sidebar</button>
      <button id="testLink" style="background:#3b82f6;border:none;color:#fff;padding:14px;border-radius:8px;font-weight:700;font-size:14px;cursor:pointer;">TEST 4: Tap a sidebar link</button>
    </div>
  </div>

  <script is:inline>
    var out = document.getElementById('diagOutput');
    var log = '';
    function add(msg) {
      log += msg + '\n';
      out.textContent = log;
    }

    add('=== DEVICE ===');
    add('Screen: ' + window.innerWidth + ' x ' + window.innerHeight);
    add('UA: ' + navigator.userAgent.substring(0, 100));
    add('Touch: ' + ('ontouchstart' in window));
    add('');

    add('=== ELEMENTS ===');
    var hamburger = document.getElementById('adminMobileToggle');
    add('hamburger #adminMobileToggle: ' + (hamburger ? 'FOUND' : 'MISSING'));
    if (hamburger) {
      var hRect = hamburger.getBoundingClientRect();
      add('  visible: ' + (hRect.width > 0 && hRect.height > 0));
      add('  size: ' + hRect.width.toFixed(0) + 'x' + hRect.height.toFixed(0));
      add('  pos: top=' + hRect.top.toFixed(0) + ' left=' + hRect.left.toFixed(0));
    }

    var sidebar = document.querySelector('.admin-sidebar');
    add('sidebar .admin-sidebar: ' + (sidebar ? 'FOUND' : 'MISSING'));
    if (sidebar) {
      var sStyle = window.getComputedStyle(sidebar);
      add('  display: ' + sStyle.display);
      add('  position: ' + sStyle.position);
      add('  transform: ' + sStyle.transform);
      add('  z-index: ' + sStyle.zIndex);
      add('  visibility: ' + sStyle.visibility);
      add('  opacity: ' + sStyle.opacity);
      add('  parent: ' + (sidebar.parentElement ? sidebar.parentElement.tagName + (sidebar.parentElement.className ? ' ' + sidebar.parentElement.className.substring(0,40) : '') : 'NONE'));

      var sLinks = sidebar.querySelectorAll('a[href]');
      add('  link count: ' + sLinks.length);
      if (sLinks.length > 0) {
        var firstLink = sLinks[0];
        add('  first link href: ' + firstLink.getAttribute('href'));
        var fStyle = window.getComputedStyle(firstLink);
        add('  first link pointer-events: ' + fStyle.pointerEvents);
      }
    }

    add('');
    add('=== TAP TESTS ABOVE ===');

    document.getElementById('testHamburger').addEventListener('click', function() {
      var h = document.getElementById('adminMobileToggle');
      if (!h) { add('TEST 1: hamburger MISSING from DOM'); return; }
      add('TEST 1: hamburger found, firing click');
      h.click();
      setTimeout(function() {
        var s = document.querySelector('.admin-sidebar');
        if (!s) { add('  sidebar gone after click!'); return; }
        var rect = s.getBoundingClientRect();
        var style = window.getComputedStyle(s);
        add('  after click: top=' + rect.top.toFixed(0) + ' left=' + rect.left.toFixed(0) + ' w=' + rect.width.toFixed(0));
        add('  transform: ' + style.transform);
        add('  parent: ' + (s.parentElement ? s.parentElement.tagName : 'NONE'));
      }, 300);
    });

    document.getElementById('testSidebar').addEventListener('click', function() {
      var s = document.querySelector('.admin-sidebar');
      if (!s) { add('TEST 2: sidebar MISSING'); return; }
      var rect = s.getBoundingClientRect();
      add('TEST 2: sidebar at top=' + rect.top.toFixed(0) + ' left=' + rect.left.toFixed(0) + ' w=' + rect.width.toFixed(0) + ' h=' + rect.height.toFixed(0));
      add('  innerHTML length: ' + s.innerHTML.length);
      add('  childElementCount: ' + s.childElementCount);
    });

    document.getElementById('testOpen').addEventListener('click', function() {
      var s = document.querySelector('.admin-sidebar');
      if (!s) { add('TEST 3: sidebar missing'); return; }
      document.body.appendChild(s);
      s.style.cssText = 'position:fixed !important;top:0 !important;left:0 !important;width:280px !important;height:100vh !important;background:#0a0a0c !important;color:#fff !important;z-index:99999 !important;transform:translateX(0) !important;display:block !important;visibility:visible !important;opacity:1 !important;padding:20px 0 !important;overflow-y:auto !important;border-right:2px solid #FF4F00 !important;';
      add('TEST 3: sidebar forced open with !important styles');
      setTimeout(function() {
        var rect = s.getBoundingClientRect();
        add('  now at: top=' + rect.top.toFixed(0) + ' left=' + rect.left.toFixed(0) + ' visible=' + (rect.width > 0 && rect.height > 0));
        var sLinks = s.querySelectorAll('a[href]');
        add('  links visible: ' + sLinks.length);
      }, 100);
    });

    document.getElementById('testLink').addEventListener('click', function() {
      var s = document.querySelector('.admin-sidebar');
      if (!s) { add('TEST 4: sidebar missing'); return; }
      var links = s.querySelectorAll('a[href]');
      if (links.length === 0) { add('TEST 4: no links in sidebar'); return; }
      var first = links[0];
      add('TEST 4: about to fire native click on link href=' + first.getAttribute('href'));
      add('  link pointer-events: ' + window.getComputedStyle(first).pointerEvents);
      add('  link parent visible: ' + (first.parentElement ? 'yes' : 'no'));
      // Try multiple ways
      try {
        first.click();
        add('  .click() called - if page navigated, this works');
      } catch(e) {
        add('  click failed: ' + e.message);
      }
    });
  </script>
</AdminLayout>