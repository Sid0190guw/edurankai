---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { roles, departments } from '@/lib/db/schema';
import { eq, asc, desc, and, or, ilike, SQL } from 'drizzle-orm';

const url = new URL(Astro.request.url);
const q = url.searchParams.get('q') || '';
const deptFilter = url.searchParams.get('dept') || '';
const levelFilter = url.searchParams.get('level') || '';

const conditions = [eq(roles.isOpen, true)];
if (q) {
  conditions.push(or(ilike(roles.title, '%' + q + '%'), ilike(roles.function, '%' + q + '%'))!);
}
if (deptFilter) conditions.push(eq(roles.departmentId, deptFilter));
if (levelFilter) conditions.push(eq(roles.level, levelFilter));

const openRoles = await db.select({
  id: roles.id,
  title: roles.title,
  slug: roles.slug,
  level: roles.level,
  departmentId: roles.departmentId,
  function: roles.function,
  engagementType: roles.engagementType,
  location: roles.location,
  salary: roles.salary,
  isFeatured: roles.isFeatured
}).from(roles).where(and(...conditions)).orderBy(desc(roles.isFeatured), asc(roles.sortOrder), asc(roles.title));

const allDepts = await db.select().from(departments).orderBy(asc(departments.sortOrder));
const deptMap = Object.fromEntries(allDepts.map((d) => [d.id, d.name]));

// Group roles by department for display
const groupedRoles = {};
for (const r of openRoles) {
  const deptName = deptMap[r.departmentId] || 'Other';
  if (!groupedRoles[deptName]) groupedRoles[deptName] = [];
  groupedRoles[deptName].push(r);
}
const deptOrder = allDepts.map((d) => d.name).filter((n) => groupedRoles[n]);

const totalCount = openRoles.length;
const LEVELS = ['C-Level', 'Lead', 'Senior', 'Mid', 'Junior', 'Intern', 'Apprentice'];

const levelColors = {
  'C-Level': 'bg-plum-bg text-plum border-plum-border',
  'Lead': 'bg-leaf-bg text-leaf border-leaf-border',
  'Senior': 'bg-sky-bg text-sky border-sky-border',
  'Mid': 'bg-burn-pale text-burn border-burn-dim',
  'Junior': 'bg-cream-2 text-ink-soft border-ink/15',
  'Intern': 'bg-gold-bg text-gold-deep border-gold-border',
  'Apprentice': 'bg-leaf-bg text-leaf border-leaf-border'
};
---
<BaseLayout title="Careers - EduRankAI" description="Join EduRankAI - we are hiring across every level from interns to C-Suite. Frontier AI educational intelligence company. Remote-first.">
  <section class="px-[5vw] py-16 md:py-20 max-w-7xl mx-auto">
    <div class="max-w-3xl mb-12">
      <p class="eyebrow mb-3">Careers</p>
      <h1 class="font-display text-[clamp(2.2rem,5vw,3.5rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-5">
        Show us <em class="italic text-burn font-medium">who you are.</em>
      </h1>
      <p class="text-[0.95rem] md:text-base text-ink-soft font-light leading-[1.8] mb-2">
        We hire at every level - C-Suite, Director, Senior, Lead, Mid, Junior, Intern, and Apprentice - across AI, research, product, legal, HR, and more. Remote-first. Purpose-led. Every application read personally.
      </p>
      <p class="text-[0.85rem] text-ink-soft/80 font-light leading-relaxed">
        Internships and apprenticeships are unpaid with structured mentorship, conversion pathways, and (for Founder Office) revenue share. Full-time roles include ESOP allocation for exceptional contribution.
      </p>
    </div>

    <form method="GET" class="bg-white border border-ink/10 rounded-2xl p-4 md:p-5 mb-10 flex flex-col md:flex-row gap-3 items-stretch md:items-center">
      <div class="flex-1 flex items-center gap-3 bg-cream-2 border border-ink/10 rounded-lg px-4 py-2.5">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-ink-soft/60 flex-shrink-0"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" name="q" value={q} placeholder="Search roles, functions, departments..." class="flex-1 bg-transparent border-0 outline-none text-[0.9rem] text-ink placeholder:text-ink-soft/60" />
      </div>
      <select name="dept" class="border border-ink/15 bg-white rounded-lg px-3 py-2.5 text-[0.85rem] text-ink-2 outline-none focus:border-burn">
        <option value="">All departments</option>
        {allDepts.map((d) => {
          const sel = deptFilter === d.id;
          return <option value={d.id} selected={sel}>{d.name}</option>;
        })}
      </select>
      <select name="level" class="border border-ink/15 bg-white rounded-lg px-3 py-2.5 text-[0.85rem] text-ink-2 outline-none focus:border-burn">
        <option value="">All levels</option>
        {LEVELS.map((lv) => {
          const sel = levelFilter === lv;
          return <option value={lv} selected={sel}>{lv}</option>;
        })}
      </select>
      <button type="submit" class="btn-primary whitespace-nowrap">Filter</button>
      {(q || deptFilter || levelFilter) && (
        <a href="/careers" class="btn-ghost whitespace-nowrap">Clear</a>
      )}
    </form>

    <div class="mb-8 flex items-center justify-between">
      <p class="text-[0.85rem] text-ink-soft">
        <strong class="text-ink font-semibold">{totalCount}</strong> {totalCount === 1 ? 'open role' : 'open roles'}
      </p>
      <span class="text-[0.75rem] font-mono text-ink-soft/60">
        Updated {new Date().toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' })}
      </span>
    </div>

    {totalCount === 0 && (
      <div class="bg-cream-2 border border-ink/10 rounded-2xl p-10 md:p-14 text-center">
        <p class="font-display text-2xl font-medium text-ink mb-3">No roles match your filters right now.</p>
        <p class="text-[0.9rem] text-ink-soft mb-6 max-w-md mx-auto leading-relaxed">
          Try clearing filters, or write to us anyway. Brilliant people open new roles wherever they land.
        </p>
        <a href="mailto:hr@edurankai.in?subject=Open Application" class="btn-primary">Write to HR</a>
      </div>
    )}

    {deptOrder.map((deptName) => {
      const deptRoles = groupedRoles[deptName];
      const isFounders = deptName === "Founder's Office";
      return (
        <div class="mb-12">
          <div class={'flex items-center gap-3 mb-5 pb-3 ' + (isFounders ? 'border-b-2 border-burn' : 'border-b border-ink/10')}>
            <h2 class="font-display text-lg md:text-xl font-semibold text-ink">{deptName}</h2>
            <span class="text-[0.7rem] font-mono uppercase tracking-wider text-burn bg-burn-pale border border-burn-dim px-2.5 py-0.5 rounded-full font-semibold">
              {deptRoles.length} {deptRoles.length === 1 ? 'role' : 'roles'}
            </span>
            {isFounders && (
              <span class="ml-auto text-[0.65rem] font-mono uppercase tracking-wider text-burn bg-burn-pale border border-burn-dim px-2.5 py-0.5 rounded-full font-bold">★ Flagship</span>
            )}
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
            {deptRoles.map((r) => {
              const href = '/careers/' + r.slug;
              const lvlClass = levelColors[r.level] || 'bg-cream-2 text-ink-soft border-ink/15';
              const isFeat = r.isFeatured;
              return (
                <a href={href} class={'group bg-white border rounded-xl p-5 transition-all hover:-translate-y-1 hover:shadow-lg flex flex-col ' + (isFeat ? 'border-burn-dim hover:border-burn' : 'border-ink/10 hover:border-burn-dim')}>
                  <h3 class="font-display text-[1.05rem] font-semibold text-ink mb-2 leading-snug group-hover:text-burn transition-colors">{r.title}</h3>
                  <p class="text-[0.78rem] text-ink-soft font-light leading-relaxed mb-3 flex-1">{r.function}</p>
                  <div class="flex flex-wrap gap-1.5 mb-3">
                    <span class={'text-[0.65rem] font-bold uppercase tracking-wider px-2 py-0.5 rounded border ' + lvlClass}>{r.level}</span>
                    <span class="text-[0.65rem] font-semibold text-ink-soft bg-cream-2 border border-ink/10 px-2 py-0.5 rounded">{r.engagementType}</span>
                  </div>
                  <span class="text-[0.78rem] font-semibold text-burn group-hover:gap-2 inline-flex items-center gap-1 transition-all">View role →</span>
                </a>
              );
            })}
          </div>
        </div>
      );
    })}

    <div class="mt-16 bg-cream-2 border border-ink/10 rounded-2xl p-8 md:p-10 text-center">
      <p class="eyebrow mb-3">No role fits?</p>
      <h3 class="font-display text-2xl md:text-3xl font-medium text-ink mb-4">Write to us anyway.</h3>
      <p class="text-[0.9rem] text-ink-soft font-light leading-relaxed mb-6 max-w-xl mx-auto">
        We read every email personally. Tell us what you do, what you have built, and what you want to build at EduRankAI.
      </p>
      <a href="mailto:hr@edurankai.in?subject=Open Application" class="btn-primary">hr@edurankai.in</a>
    </div>
  </section>
</BaseLayout>
