  <style>
    .dept-fold-toggle { display:inline-flex; align-items:center; gap:5px; font-family:inherit; font-size:0.72rem; font-weight:600; color:#9a5b3f; background:#fff; border:1px solid rgba(255,79,0,0.25); border-radius:100px; padding:4px 11px; cursor:pointer; transition:background .18s ease, border-color .18s ease; white-space:nowrap; }
    .dept-fold-toggle:hover { background:#FFF1EA; border-color:#FF4F00; }
    .dept-chev { transition: transform .3s ease; }
    .dept-fold-toggle[aria-expanded="true"] .dept-chev { transform: rotate(180deg); }
    /* Accordion Pleat Slide (#21) — smooth open/close via grid-rows */
    .dept-fold { display:grid; grid-template-rows:0fr; transition: grid-template-rows .35s cubic-bezier(.4,0,.2,1); }
    .dept-fold.open { grid-template-rows:1fr; }
    .dept-fold-inner { overflow:hidden; min-height:0; }
    /* ---- Team locator (desktop sticky sidebar) ---- */
    .team-nav { display:flex; align-items:center; justify-content:space-between; gap:8px; padding:7px 9px 7px 6px; border-radius:9px; text-decoration:none; color:#6b6259; transition:background .18s ease, color .18s ease; }
    .team-nav:hover { background:#FBF6F1; color:#1a1510; }
    .team-nav.is-active { background:#FFF1EA; color:#FF4F00; font-weight:600; }
    .team-nav-label { display:flex; align-items:center; gap:9px; min-width:0; font-size:0.85rem; }
    .team-bar { width:3px; height:8px; border-radius:99px; background:transparent; transition:background .2s ease, height .2s ease; flex-shrink:0; }
    .team-nav:hover .team-bar { background:rgba(26,21,16,0.18); height:15px; }
    .team-nav.is-active .team-bar { background:#FF4F00; height:15px; }
    .team-ct { font-family:ui-monospace,monospace; font-size:0.64rem; font-style:normal; color:#9a8f84; background:rgba(26,21,16,0.05); padding:1px 7px; border-radius:99px; flex-shrink:0; transition:all .18s ease; }
    .team-nav.is-active .team-ct { color:#FF4F00; background:#fff; }
    /* ---- Team chips (mobile horizontal locator) ---- */
    .team-chip { display:inline-flex; align-items:center; gap:7px; flex-shrink:0; padding:6px 12px; border-radius:99px; border:1px solid rgba(26,21,16,0.12); background:#fff; color:#6b6259; font-size:0.8rem; font-weight:500; text-decoration:none; white-space:nowrap; transition:background .18s ease, color .18s ease, border-color .18s ease; }
    .team-chip.is-active { background:#FF4F00; border-color:#FF4F00; color:#fff; font-weight:600; }
    .team-chip.is-active .team-ct { background:rgba(255,255,255,0.22); color:#fff; }
    /* hide scrollbars on locators */
    .team-hscroll, .team-vscroll { scrollbar-width:none; -ms-overflow-style:none; scroll-behavior:smooth; }
    .team-hscroll::-webkit-scrollbar, .team-vscroll::-webkit-scrollbar { display:none; }
    @media (prefers-reduced-motion: reduce) {
      .dept-fold { transition:none; }
      .dept-chev { transition:none; }
      .team-nav, .team-bar, .team-ct, .team-chip { transition:none; }
    }
  </style>
  <script is:inline>
    document.addEventListener('click', function (e) {
      var t = e.target;
      var btn = (t && t.closest) ? t.closest('.dept-fold-toggle') : null;
      if (!btn) return;
      var id = btn.getAttribute('aria-controls');
      var panel = id ? document.getElementById(id) : null;
      if (!panel) return;
      var open = panel.classList.toggle('open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
  </script>
</BaseLayout>
