---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { roles, departments } from '@/lib/db/schema';
import { eq, asc, desc, and, or, ilike, sql, SQL } from 'drizzle-orm';

const url = new URL(Astro.request.url);
const q = url.searchParams.get('q') || '';
const deptFilter = url.searchParams.get('dept') || '';
const levelFilter = url.searchParams.get('level') || '';

const conditions = [eq(roles.isOpen, true)];
if (q) {
  conditions.push(or(ilike(roles.title, '%' + q + '%'), ilike(roles.function, '%' + q + '%'))!);
}
if (deptFilter) conditions.push(eq(roles.departmentId, deptFilter));
if (levelFilter) conditions.push(eq(roles.level, levelFilter));

const openRoles = await db.select({
  id: roles.id,
  title: roles.title,
  slug: roles.slug,
  level: roles.level,
  departmentId: roles.departmentId,
  function: roles.function,
  engagementType: roles.engagementType,
  location: roles.location,
  salary: roles.salary,
  isFeatured: roles.isFeatured
}).from(roles).where(and(...conditions)).orderBy(desc(roles.isFeatured), asc(roles.sortOrder), asc(roles.title));

const allDepts = await db.select().from(departments).orderBy(asc(departments.sortOrder));
const deptMap = Object.fromEntries(allDepts.map((d) => [d.id, d.name]));
const deptByName: Record<string, any> = Object.fromEntries(allDepts.map((d) => [d.name, d]));

// Group roles by department for display
const groupedRoles = {};
for (const r of openRoles) {
  const deptName = deptMap[r.departmentId] || 'Other';
  if (!groupedRoles[deptName]) groupedRoles[deptName] = [];
  groupedRoles[deptName].push(r);
}
const deptOrder = allDepts.map((d) => d.name).filter((n) => groupedRoles[n]);

const totalCount = openRoles.length;
const LEVELS = ['C-Level', 'Lead', 'Senior', 'Mid', 'Junior', 'Intern', 'Apprentice'];

// Open departments + fee range for the metrics strip. Fee columns aren't in
// the Drizzle schema (runtime ALTER) so query raw.
const openDeptCount = Object.keys(groupedRoles).length;
let feeRange = { min: 1, max: 100, currency: 'CHF' };
try {
  const fr = await db.execute(sql`
    SELECT MIN(application_fee_amount) AS min, MAX(application_fee_amount) AS max,
      MAX(application_fee_currency) AS currency
    FROM roles WHERE is_open = true AND application_fee_amount IS NOT NULL
  `);
  const frs = (Array.isArray(fr) ? fr : ((fr as any)?.rows || [])) as any[];
  if (frs[0]) {
    feeRange = {
      min: frs[0].min != null ? Number(frs[0].min) : 1,
      max: frs[0].max != null ? Number(frs[0].max) : 100,
      currency: frs[0].currency || 'CHF',
    };
  }
} catch (_) {}

const levelColors = {
  'C-Level': 'bg-plum-bg text-plum border-plum-border',
  'Lead': 'bg-leaf-bg text-leaf border-leaf-border',
  'Senior': 'bg-sky-bg text-sky border-sky-border',
  'Mid': 'bg-burn-pale text-burn border-burn-dim',
  'Junior': 'bg-cream-2 text-ink-soft border-ink/15',
  'Intern': 'bg-gold-bg text-gold-deep border-gold-border',
  'Apprentice': 'bg-leaf-bg text-leaf border-leaf-border'
};
---
<BaseLayout title="Careers - EduRankAI" description="Join EduRankAI - we are hiring across every level from interns to C-Suite. Frontier AI educational intelligence company. Remote-first.">
  <section class="px-[5vw] pt-12 md:pt-16 pb-6 md:pb-8 max-w-7xl mx-auto">
    <div class="max-w-3xl mb-7">
      <p class="eyebrow mb-3">Careers</p>
      <h1 class="font-display text-[clamp(2.2rem,5vw,3.5rem)] font-semibold text-ink leading-[1.05] tracking-tight mb-4">
        Show us <em class="italic text-burn font-medium">who you are.</em>
      </h1>
      <p class="text-[0.96rem] md:text-base text-ink-soft font-light leading-[1.7]">
        Hiring at every level — C-Suite to Intern — across AI, research, product, hardware, CSR, and more. Remote-first. Every application read by a human.
      </p>
    </div>

    <!-- Metrics strip: at-a-glance signal so applicants don't have to read a wall. -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-2 mb-5 max-w-4xl">
      <div class="bg-white border border-ink/10 rounded-xl px-4 py-3">
        <p class="text-[0.6rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-1">Open roles</p>
        <p class="font-display text-[1.5rem] font-semibold text-ink leading-none">{totalCount}</p>
      </div>
      <div class="bg-white border border-ink/10 rounded-xl px-4 py-3">
        <p class="text-[0.6rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-1">Departments</p>
        <p class="font-display text-[1.5rem] font-semibold text-ink leading-none">{openDeptCount}</p>
      </div>
      <div class="bg-white border border-ink/10 rounded-xl px-4 py-3">
        <p class="text-[0.6rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-1">Application fee</p>
        <p class="font-display text-[1.05rem] font-semibold text-ink leading-tight">{feeRange.currency} {feeRange.min}–{feeRange.max}</p>
        <p class="text-[0.66rem] text-ink-soft mt-0.5">scaled by level</p>
      </div>
      <div class="bg-burn-pale border border-burn-dim rounded-xl px-4 py-3">
        <p class="text-[0.6rem] font-mono uppercase tracking-[0.14em] text-burn font-bold mb-1">Hardship?</p>
        <p class="text-[0.88rem] font-semibold text-ink leading-tight">Waiver available</p>
        <p class="text-[0.66rem] text-ink-soft mt-0.5">reviewed individually</p>
      </div>
    </div>

    <!-- Plain-spoken note on what the fee is, and is not. Comes directly from the founder. -->
    <div class="max-w-4xl mb-6 bg-white border-l-4 border-burn rounded-xl px-5 py-4" style="border-color: transparent transparent transparent #FF4F00; border-width: 1px 1px 1px 4px; border-style: solid; border-left-color: #FF4F00; border-top-color: rgba(14,11,8,0.08); border-right-color: rgba(14,11,8,0.08); border-bottom-color: rgba(14,11,8,0.08);">
      <p class="font-display text-[1.05rem] font-semibold text-ink leading-snug m-0 mb-2">
        The fee is part of the qualification.
      </p>
      <p class="text-[0.88rem] text-ink-2 leading-[1.7] m-0">
        It is a small, deliberate filter — not a revenue line. If it bothers you because of <em class="italic text-burn not-italic font-medium">face</em> or pride, you have already disqualified yourself. The roles we are hiring for need people who can put ego aside and show up on merit alone. If, on the other hand, the fee is genuinely difficult because of <strong class="text-ink font-semibold">financial hardship</strong>, that is a different conversation entirely — apply for a <a href="/policy/candidate-transparency#hardship-waiver" class="text-burn font-semibold underline underline-offset-2">fee waiver</a>. We read every request individually and grant generously, with no questions on the public record.
      </p>
      <p class="text-[0.88rem] text-ink-2 leading-[1.7] m-0 mt-3 pt-3 border-t border-ink/8">
        And if you genuinely believe you are a <strong class="text-ink font-semibold">deserving candidate</strong> for one of these roles — <em class="italic text-burn not-italic font-medium">act on it.</em> Apply. The worst outcome is a thoughtful reply. The cost of not applying is paid quietly, by you, for the rest of your career.
      </p>
    </div>

    <!-- Read-before-you-apply: the single highest-leverage trust signal for applicants worried about data or fees. -->
    <a href="/policy/candidate-transparency" class="block max-w-4xl mb-5 no-underline" style="background:#fff;border:1px solid rgba(0,0,0,0.08);border-left:4px solid #DC5000;border-radius:12px;padding:12px 16px;color:#1c1d22;">
      <div class="flex items-center gap-3">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#DC5000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
        <div style="flex:1;min-width:0;">
          <p class="text-[0.85rem] font-semibold text-ink m-0 leading-tight">Before you apply: what we collect, what it costs, and what we will never do with your data</p>
          <p class="text-[0.74rem] text-ink-soft m-0 mt-0.5">2-minute read. No sales, no ads, no model-training on candidate data. Hardship → waiver.</p>
        </div>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#DC5000" stroke-width="2.5" style="flex-shrink:0;"><path d="m9 18 6-6-6-6"/></svg>
      </div>
    </a>

    <!-- Secondary policy chips — clean row, no wall of context above. -->
    <div class="flex flex-wrap gap-2 mb-3 max-w-4xl">
      <a href="/policy/hiring" class="inline-flex items-center gap-1.5 text-[0.76rem] font-semibold text-burn px-3 py-1.5 rounded-md border border-burn-dim bg-burn-pale hover:bg-burn-pale/80 transition-colors no-underline">Hiring policy &rarr;</a>
      <a href="/policy/recruitment" class="inline-flex items-center gap-1.5 text-[0.76rem] font-semibold text-burn px-3 py-1.5 rounded-md border border-burn-dim bg-burn-pale hover:bg-burn-pale/80 transition-colors no-underline">Recruitment &amp; work &rarr;</a>
      <a href="/policy/work-culture" class="inline-flex items-center gap-1.5 text-[0.76rem] font-semibold text-burn px-3 py-1.5 rounded-md border border-burn-dim bg-burn-pale hover:bg-burn-pale/80 transition-colors no-underline">Work culture &rarr;</a>
      <a href="/policy/fees" class="inline-flex items-center gap-1.5 text-[0.76rem] font-semibold text-burn px-3 py-1.5 rounded-md border border-burn-dim bg-burn-pale hover:bg-burn-pale/80 transition-colors no-underline">Why a fee? &rarr;</a>
    </div>

  </section>

  <section class="px-[5vw] pb-8 md:pb-12 max-w-7xl mx-auto">
    <form method="GET" class="bg-white border border-ink/10 rounded-2xl p-4 md:p-5 mb-10 flex flex-col md:flex-row gap-3 items-stretch md:items-center">
      <div class="flex-1 flex items-center gap-3 bg-cream-2 border border-ink/10 rounded-lg px-4 py-2.5">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-ink-soft/60 flex-shrink-0"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" name="q" value={q} placeholder="Search roles, functions, departments..." class="flex-1 bg-transparent border-0 outline-none text-[0.9rem] text-ink placeholder:text-ink-soft/60" />
      </div>
      <select name="dept" class="border border-ink/15 bg-white rounded-lg px-3 py-2.5 text-[0.85rem] text-ink-2 outline-none focus:border-burn">
        <option value="">All departments</option>
        {allDepts.map((d) => {
          const sel = deptFilter === d.id;
          return <option value={d.id} selected={sel}>{d.name}</option>;
        })}
      </select>
      <select name="level" class="border border-ink/15 bg-white rounded-lg px-3 py-2.5 text-[0.85rem] text-ink-2 outline-none focus:border-burn">
        <option value="">All levels</option>
        {LEVELS.map((lv) => {
          const sel = levelFilter === lv;
          return <option value={lv} selected={sel}>{lv}</option>;
        })}
      </select>
      <button type="submit" class="btn-primary whitespace-nowrap">Filter</button>
      {(q || deptFilter || levelFilter) && (
        <a href="/careers" class="btn-ghost whitespace-nowrap">Clear</a>
      )}
    </form>

    <div class="mb-8 flex items-center justify-between">
      <p class="text-[0.85rem] text-ink-soft">
        <strong class="text-ink font-semibold">{totalCount}</strong> {totalCount === 1 ? 'open role' : 'open roles'}
      </p>
      <span class="text-[0.75rem] font-mono text-ink-soft/60">
        Updated {new Date().toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' })}
      </span>
    </div>

    {totalCount === 0 && (
      <div class="bg-cream-2 border border-ink/10 rounded-2xl p-10 md:p-14 text-center">
        <p class="font-display text-2xl font-medium text-ink mb-3">No roles match your filters right now.</p>
        <p class="text-[0.9rem] text-ink-soft mb-6 max-w-md mx-auto leading-relaxed">
          Try clearing filters, or write to us anyway. Brilliant people open new roles wherever they land.
        </p>
        <a href="mailto:hr@edurankai.in?subject=Open Application" class="btn-primary">Write to HR</a>
      </div>
    )}

    {deptOrder.map((deptName) => {
      const deptRoles = groupedRoles[deptName];
      const isFounders = deptName === "Founder's Office";
      const deptIntro = deptByName[deptName]?.description as string | null;
      return (
        <div class="mb-12">
          <div class={'flex items-center gap-3 mb-5 pb-3 ' + (isFounders ? 'border-b-2 border-burn' : 'border-b border-ink/10')}>
            <h2 class="font-display text-lg md:text-xl font-semibold text-ink">{deptName}</h2>
            <span class="text-[0.7rem] font-mono uppercase tracking-wider text-burn bg-burn-pale border border-burn-dim px-2.5 py-0.5 rounded-full font-semibold">
              {deptRoles.length} {deptRoles.length === 1 ? 'role' : 'roles'}
            </span>
            {isFounders && (
              <span class="ml-auto text-[0.65rem] font-mono uppercase tracking-wider text-burn bg-burn-pale border border-burn-dim px-2.5 py-0.5 rounded-full font-bold">★ Flagship</span>
            )}
          </div>
          {deptIntro && (
            <div class="bg-cream-2 border border-ink/10 rounded-xl p-5 md:p-6 mb-5">
              <p class="text-[0.9rem] text-ink-2 font-light leading-[1.85] whitespace-pre-line">{deptIntro}</p>
            </div>
          )}
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
            {deptRoles.map((r) => {
              const href = '/careers/' + r.slug;
              const lvlClass = levelColors[r.level] || 'bg-cream-2 text-ink-soft border-ink/15';
              const isFeat = r.isFeatured;
              return (
                <a href={href} class={'group bg-white border rounded-xl p-5 transition-all hover:-translate-y-1 hover:shadow-lg flex flex-col ' + (isFeat ? 'border-burn-dim hover:border-burn' : 'border-ink/10 hover:border-burn-dim')}>
                  <h3 class="font-display text-[1.05rem] font-semibold text-ink mb-2 leading-snug group-hover:text-burn transition-colors">{r.title}</h3>
                  <p class="text-[0.78rem] text-ink-soft font-light leading-relaxed mb-3 flex-1">{r.function}</p>
                  <div class="flex flex-wrap gap-1.5 mb-3">
                    <span class={'text-[0.65rem] font-bold uppercase tracking-wider px-2 py-0.5 rounded border ' + lvlClass}>{r.level}</span>
                    <span class="text-[0.65rem] font-semibold text-ink-soft bg-cream-2 border border-ink/10 px-2 py-0.5 rounded">{r.engagementType}</span>
                  </div>
                  <span class="text-[0.78rem] font-semibold text-burn group-hover:gap-2 inline-flex items-center gap-1 transition-all">View role →</span>
                </a>
              );
            })}
          </div>
        </div>
      );
    })}

    <div class="mt-16 bg-cream-2 border border-ink/10 rounded-2xl p-8 md:p-10 text-center">
      <p class="eyebrow mb-3">No role fits?</p>
      <h3 class="font-display text-2xl md:text-3xl font-medium text-ink mb-4">Write to us anyway.</h3>
      <p class="text-[0.9rem] text-ink-soft font-light leading-relaxed mb-6 max-w-xl mx-auto">
        We read every email personally. Tell us what you do, what you have built, and what you want to build at EduRankAI.
      </p>
      <a href="mailto:hr@edurankai.in?subject=Open Application" class="btn-primary">hr@edurankai.in</a>
    </div>
  </section>
</BaseLayout>
