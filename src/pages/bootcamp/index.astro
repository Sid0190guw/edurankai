---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="EduRankAI Bootcamp · Quantum + HPC" description="30-day intensive: Quantum computing + High-performance computing. Real simulators, real code, real cohort. Hands-on tracks for serious engineers.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; }
  .bc-hero { padding: 80px 5vw 60px; max-width: 1400px; margin: 0 auto; position: relative; }
  .bc-eyebrow { font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.3em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0; }
  .bc-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(48px, 8vw, 96px); font-weight: 600; letter-spacing: -0.04em; margin: 18px 0; line-height: 0.95; max-width: 980px; }
  .bc-title em { font-style: italic; font-weight: 500; background: linear-gradient(135deg, #a78bfa, #67e8f9); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
  .bc-sub { font-size: 18px; color: #9aa6b6; max-width: 720px; line-height: 1.7; }
  .bc-meta-strip { display: flex; gap: 40px; flex-wrap: wrap; margin-top: 30px; padding-top: 24px; border-top: 1px solid #2a2a35; }
  .bc-meta { font-family: 'Geist Mono', monospace; }
  .bc-meta-val { font-size: 26px; color: #fff; font-weight: 700; line-height: 1; }
  .bc-meta-lbl { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #9aa6b6; margin-top: 4px; font-weight: 700; }

  .bc-tracks { padding: 60px 5vw; max-width: 1400px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  @media (max-width: 1024px) { .bc-tracks { grid-template-columns: 1fr; } }
  .bc-track { background: #11131a; border: 1px solid #2a2a35; border-radius: 18px; padding: 36px; position: relative; overflow: hidden; }
  .bc-track-q { border-color: #a78bfa44; }
  .bc-track-q::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, #a78bfa, #67e8f9); }
  .bc-track-h { border-color: #67e8f944; }
  .bc-track-h::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, #67e8f9, #86efac); }
  .bc-track-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; font-weight: 700; margin: 0; }
  .bc-track-q .bc-track-eye { color: #a78bfa; }
  .bc-track-h .bc-track-eye { color: #67e8f9; }
  .bc-track-title { font-family: 'Cormorant Garamond', serif; font-size: 36px; font-weight: 600; margin: 8px 0 12px; letter-spacing: -0.02em; }
  .bc-track-sub { color: #9aa6b6; line-height: 1.6; font-size: 14px; }
  .bc-modules { margin-top: 22px; }
  .bc-mod { padding: 12px 0; border-bottom: 1px solid #1a1a25; }
  .bc-mod:last-child { border-bottom: none; }
  .bc-mod-row { display: grid; grid-template-columns: 40px 1fr auto; gap: 12px; align-items: center; }
  .bc-mod-n { font-family: 'Geist Mono', monospace; color: #67e8f9; font-weight: 700; font-size: 12px; }
  .bc-track-q .bc-mod-n { color: #a78bfa; }
  .bc-mod-title { font-size: 14px; color: #fff; font-weight: 600; }
  .bc-mod-lessons { font-family: 'Geist Mono', monospace; font-size: 10.5px; color: #9aa6b6; }

  .bc-cta-row { display: flex; gap: 12px; margin-top: 28px; flex-wrap: wrap; }
  .bc-cta { background: #67e8f9; color: #04161b; padding: 14px 28px; border-radius: 10px; font-weight: 800; text-decoration: none; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; }
  .bc-cta-q { background: #a78bfa; color: #2a1958; }
  .bc-cta-ghost { background: transparent; border: 1px solid #2a2a35; color: #cfd6da; }
  .bc-cta:hover { transform: translateY(-1px); }

  .bc-sim-preview { padding: 40px 5vw 80px; max-width: 1400px; margin: 0 auto; }
  .bc-sim-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  @media (max-width: 1024px) { .bc-sim-grid { grid-template-columns: 1fr; } }
  .bc-sim-card { background: #11131a; border: 1px solid #2a2a35; border-radius: 14px; padding: 22px; text-decoration: none; color: inherit; }
  .bc-sim-card:hover { border-color: #67e8f9; }
  .bc-sim-eye { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; margin-bottom: 6px; font-weight: 700; }
  .bc-sim-title { font-family: 'Cormorant Garamond', serif; font-size: 22px; margin: 4px 0 6px; }
  .bc-sim-sub { font-size: 13px; color: #9aa6b6; line-height: 1.55; }

  /* Animated mini quantum vector in hero */
  .hero-bg { position: absolute; top: 0; right: 0; width: 50%; height: 100%; overflow: hidden; opacity: 0.5; pointer-events: none; }
  @media (max-width: 1024px) { .hero-bg { display: none; } }
</style>

<main>

  <section class="bc-hero">
    <p class="bc-eyebrow">EduRankAI · Bootcamp 2026</p>
    <h1 class="bc-title">Build with <em>qubits</em> and <em>cores</em>.</h1>
    <p class="bc-sub">A 30-day intensive on quantum computing + high-performance computing. Real simulators you can run in your browser. Real cohorts of serious engineers. Real outcomes — a portfolio of circuits, schedulers, and benchmarks you would ship.</p>

    <div class="bc-meta-strip">
      <div class="bc-meta">
        <p class="bc-meta-val">30 days</p>
        <p class="bc-meta-lbl">Cohort</p>
      </div>
      <div class="bc-meta">
        <p class="bc-meta-val">2 tracks</p>
        <p class="bc-meta-lbl">Quantum · HPC</p>
      </div>
      <div class="bc-meta">
        <p class="bc-meta-val">96 lessons</p>
        <p class="bc-meta-lbl">48 per track</p>
      </div>
      <div class="bc-meta">
        <p class="bc-meta-val">100% live</p>
        <p class="bc-meta-lbl">Browser simulators</p>
      </div>
    </div>

    <!-- Animated quantum vector visual -->
    <svg class="hero-bg" viewBox="0 0 600 600" preserveAspectRatio="xMidYMid slice">
      <defs>
        <radialGradient id="qg" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="#a78bfa" stop-opacity="0.6"/><stop offset="100%" stop-color="#a78bfa" stop-opacity="0"/></radialGradient>
        <linearGradient id="qline" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#a78bfa" stop-opacity="0"/><stop offset="50%" stop-color="#67e8f9" stop-opacity="0.9"/><stop offset="100%" stop-color="#a78bfa" stop-opacity="0"/></linearGradient>
      </defs>
      <circle cx="300" cy="300" r="250" fill="none" stroke="#a78bfa" stroke-width="0.5" opacity="0.3"/>
      <circle cx="300" cy="300" r="180" fill="none" stroke="#67e8f9" stroke-width="0.5" opacity="0.3"/>
      <circle cx="300" cy="300" r="120" fill="none" stroke="#a78bfa" stroke-width="0.5" opacity="0.3"/>
      <circle cx="300" cy="300" r="200" fill="url(#qg)" opacity="0.5">
        <animate attributeName="r" values="180;250;180" dur="6s" repeatCount="indefinite"/>
        <animate attributeName="opacity" values="0.3;0.6;0.3" dur="6s" repeatCount="indefinite"/>
      </circle>
      <g>
        <line x1="300" y1="300" x2="300" y2="50" stroke="url(#qline)" stroke-width="2">
          <animateTransform attributeName="transform" type="rotate" from="0 300 300" to="360 300 300" dur="14s" repeatCount="indefinite"/>
        </line>
        <line x1="300" y1="300" x2="300" y2="50" stroke="url(#qline)" stroke-width="2" opacity="0.5">
          <animateTransform attributeName="transform" type="rotate" from="120 300 300" to="480 300 300" dur="14s" repeatCount="indefinite"/>
        </line>
        <line x1="300" y1="300" x2="300" y2="50" stroke="url(#qline)" stroke-width="2" opacity="0.5">
          <animateTransform attributeName="transform" type="rotate" from="240 300 300" to="600 300 300" dur="14s" repeatCount="indefinite"/>
        </line>
      </g>
      <circle cx="300" cy="300" r="6" fill="#67e8f9"><animate attributeName="r" values="4;8;4" dur="1.4s" repeatCount="indefinite"/></circle>
    </svg>
  </section>

  <section class="bc-tracks">

    <article class="bc-track bc-track-q">
      <p class="bc-track-eye">Track A · Quantum</p>
      <h2 class="bc-track-title">Quantum computing foundations to <em style="color:#a78bfa;font-style:italic;">Shor's</em>.</h2>
      <p class="bc-track-sub">From classical bits → qubits → superposition → entanglement → Bell states → Deutsch–Jozsa → Grover's search → Shor's algorithm → QAOA → noise + error correction. Every lesson runs against the in-browser circuit composer.</p>

      <div class="bc-modules">
        {[
          { n: '01', t: 'Bits, qubits, and amplitudes', l: 4 },
          { n: '02', t: 'Single-qubit gates · Bloch sphere', l: 4 },
          { n: '03', t: 'Multi-qubit systems · tensor product', l: 4 },
          { n: '04', t: 'CNOT, Bell states, and entanglement', l: 4 },
          { n: '05', t: 'Quantum teleportation', l: 4 },
          { n: '06', t: "Deutsch–Jozsa · Bernstein–Vazirani", l: 4 },
          { n: '07', t: "Grover's search algorithm", l: 4 },
          { n: '08', t: 'Quantum Fourier transform', l: 4 },
          { n: '09', t: "Shor's factoring algorithm", l: 4 },
          { n: '10', t: 'QAOA and variational quantum algorithms', l: 4 },
          { n: '11', t: 'Noise channels and decoherence', l: 4 },
          { n: '12', t: 'Quantum error correction (Shor code)', l: 4 },
        ].map((m) => (
          <div class="bc-mod">
            <div class="bc-mod-row">
              <span class="bc-mod-n">{m.n}</span>
              <span class="bc-mod-title">{m.t}</span>
              <span class="bc-mod-lessons">{m.l} lessons</span>
            </div>
          </div>
        ))}
      </div>

      <div class="bc-cta-row">
        <a href="/aquintutor/quantum/composer" class="bc-cta bc-cta-q">Try the simulator</a>
        <a href="/careers?role=bootcamp-quantum" class="bc-cta bc-cta-ghost">Apply for cohort</a>
      </div>
    </article>

    <article class="bc-track bc-track-h">
      <p class="bc-track-eye">Track B · HPC</p>
      <h2 class="bc-track-title">From <em style="color:#67e8f9;font-style:italic;">serial</em> code to a working scheduler.</h2>
      <p class="bc-track-sub">Amdahl's + Gustafson's law → shared-memory → distributed → OpenMP → MPI → CUDA → cache hierarchies → matrix-multiply optimisations. Every lesson runs against the in-browser HPC job simulator.</p>

      <div class="bc-modules">
        {[
          { n: '01', t: 'Serial vs parallel · Amdahl and Gustafson', l: 4 },
          { n: '02', t: 'Memory hierarchy and cache misses', l: 4 },
          { n: '03', t: 'Vectorisation and SIMD', l: 4 },
          { n: '04', t: 'Shared-memory parallelism with OpenMP', l: 4 },
          { n: '05', t: 'Distributed memory with MPI', l: 4 },
          { n: '06', t: 'CUDA basics · grids and blocks', l: 4 },
          { n: '07', t: 'Reduction patterns', l: 4 },
          { n: '08', t: 'Matrix multiply optimisation', l: 4 },
          { n: '09', t: 'Load balancing and scheduling', l: 4 },
          { n: '10', t: 'HPC for ML training', l: 4 },
          { n: '11', t: 'Modern hardware (GPU/TPU/Trainium)', l: 4 },
          { n: '12', t: 'Cluster topologies and Slurm', l: 4 },
        ].map((m) => (
          <div class="bc-mod">
            <div class="bc-mod-row">
              <span class="bc-mod-n">{m.n}</span>
              <span class="bc-mod-title">{m.t}</span>
              <span class="bc-mod-lessons">{m.l} lessons</span>
            </div>
          </div>
        ))}
      </div>

      <div class="bc-cta-row">
        <a href="/aquintutor/hpc/simulator" class="bc-cta">Try the simulator</a>
        <a href="/careers?role=bootcamp-hpc" class="bc-cta bc-cta-ghost">Apply for cohort</a>
      </div>
    </article>

  </section>

  <section class="bc-sim-preview">
    <p class="bc-eyebrow" style="margin-bottom:16px;">Browser-side simulators</p>
    <h2 style="font-family:'Cormorant Garamond',serif;font-size:36px;font-weight:600;letter-spacing:-0.02em;margin:0 0 24px;">Original — built from scratch.</h2>
    <div class="bc-sim-grid">
      <a href="/aquintutor/quantum/composer" class="bc-sim-card">
        <p class="bc-sim-eye" style="color:#a78bfa;">Quantum circuit composer</p>
        <p class="bc-sim-title">Up to 6 qubits · 64-amplitude state vector.</p>
        <p class="bc-sim-sub">Drag H, X, Y, Z, S, T gates onto wires. CNOT + SWAP + measurement. Real complex-number matrix math. Live Bloch sphere per qubit. QASM 2.0 export.</p>
      </a>
      <a href="/aquintutor/hpc/simulator" class="bc-sim-card">
        <p class="bc-sim-eye">HPC job simulator</p>
        <p class="bc-sim-title">Cluster · workload · Gantt · Amdahl.</p>
        <p class="bc-sim-sub">Configure nodes × cores × latency. Pick workload (GEMM / Monte Carlo / N-body / stencil / reduction). Watch the per-core Gantt + Amdahl curve + utilisation heatmap.</p>
      </a>
    </div>
  </section>

</main>
</BaseLayout>
