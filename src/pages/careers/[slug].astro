---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { roles, departments } from '@/lib/db/schema';
import { eq, and, ne } from 'drizzle-orm';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/careers');

const found = await db.select().from(roles).where(eq(roles.slug, slug)).limit(1);
if (found.length === 0) return Astro.redirect('/careers');

const r = found[0];
if (!r.isOpen) return Astro.redirect('/careers');

const deptResult = await db.select().from(departments).where(eq(departments.id, r.departmentId)).limit(1);
const deptName = deptResult.length > 0 ? deptResult[0].name : 'EduRankAI';

const relatedRoles = await db.select({
  slug: roles.slug,
  title: roles.title,
  level: roles.level,
  engagementType: roles.engagementType
}).from(roles).where(and(eq(roles.departmentId, r.departmentId), ne(roles.id, r.id), eq(roles.isOpen, true))).limit(4);

const levelColors: Record<string, string> = {
  'C-Level': 'bg-plum-bg text-plum border-plum-border',
  'Lead': 'bg-leaf-bg text-leaf border-leaf-border',
  'Senior': 'bg-sky-bg text-sky border-sky-border',
  'Mid': 'bg-burn-pale text-burn border-burn-dim',
  'Junior': 'bg-cream-2 text-ink-soft border-ink/15',
  'Intern': 'bg-gold-bg text-gold-deep border-gold-border',
  'Apprentice': 'bg-leaf-bg text-leaf border-leaf-border'
};
const levelClass = levelColors[r.level] || 'bg-cream-2 text-ink-soft border-ink/15';

const levelFraming: Record<string, { tagline: string; scope: string }> = {
  'C-Level': { tagline: 'Founding leadership', scope: 'Build the function from zero. Set the strategy. Own the outcome.' },
  'Lead': { tagline: 'Senior leadership', scope: 'Set direction within your domain. Build and mentor a team. Own outcomes at the function level.' },
  'Senior': { tagline: 'Individual contributor at the frontier', scope: 'Own complex problems end-to-end. Set technical direction. Mentor mid and junior teammates.' },
  'Mid': { tagline: 'Trusted operator', scope: 'Drive specific initiatives with minimal supervision. Deepen craft. Begin mentoring others.' },
  'Junior': { tagline: 'Early career, real ownership', scope: 'Work on real problems day one. Be supported by senior mentors. Grow fast.' },
  'Intern': { tagline: 'Learn at the frontier', scope: 'Contribute to live projects. Shadow senior practitioners. Build a portfolio that matters.' },
  'Apprentice': { tagline: 'Structured learning programme', scope: 'Six-month immersion with mentorship. From foundation to contribution.' }
};
const framing = levelFraming[r.level] || { tagline: '', scope: '' };

const applyHref = '/apply?role=' + r.slug;

const engagementInfo: Record<string, string> = {
  'Full-Time': 'Permanent role. Full-time commitment. Remote-first, with periodic in-person off-sites.',
  'Internship': 'Three months. Remote. 2.5 hours per day, five days per week. Unpaid (we are early-stage and honest about it).',
  'Apprenticeship': 'Six months. Remote. Two hours per day minimum. Structured mentorship. Unpaid.'
};
const engagementText = engagementInfo[r.engagementType] || '';

// Parse "up to ₹120 LPA + equity" -> { max: 12000000 }. Conservative: only the
// upper bound is structured, since the salary text is positioned that way.
function parseLpa(text: string | null | undefined): number | null {
  if (!text) return null;
  const m = String(text).match(/(\d+(?:\.\d+)?)\s*LPA/i);
  if (!m) return null;
  const lpa = parseFloat(m[1]);
  return Number.isFinite(lpa) ? Math.round(lpa * 100000) : null;
}
const salaryMaxINR = parseLpa(r.salary);

const expByLevel: Record<string, number> = {
  'C-Level': 12, 'Lead': 8, 'Senior': 5, 'Mid': 3, 'Junior': 1, 'Intern': 0, 'Apprentice': 0,
};
const yearsExp = expByLevel[r.level || 'Mid'] ?? 0;

const today = new Date();
const datePostedISO = new Date(r.createdAt).toISOString().split('T')[0];
const validThrough = new Date(today.getTime() + 60 * 24 * 3600 * 1000).toISOString();

const jobPostingSchema: any = {
  '@context': 'https://schema.org/',
  '@type': 'JobPosting',
  title: r.title,
  description: '<p>' + (r.about || '') + '</p>'
    + (r.responsibilities && r.responsibilities.length ? '<h3>Responsibilities</h3><ul>' + (r.responsibilities as string[]).map(x => '<li>' + x + '</li>').join('') + '</ul>' : '')
    + (r.skills && r.skills.length ? '<h3>Skills</h3><ul>' + (r.skills as string[]).map(x => '<li>' + x + '</li>').join('') + '</ul>' : ''),
  identifier: { '@type': 'PropertyValue', name: 'EduRankAI', value: r.slug },
  datePosted: datePostedISO,
  validThrough,                               // Google requires this; 60-day window
  directApply: true,                          // tells Google Jobs the apply lives here
  employmentType: r.engagementType === 'Full-Time' ? 'FULL_TIME' : (r.engagementType === 'Internship' ? 'INTERN' : (r.engagementType === 'Apprenticeship' ? 'CONTRACTOR' : 'FULL_TIME')),
  workHours: r.engagementType === 'Internship' ? 'PT 2H30M per day, 5 days/week' : (r.engagementType === 'Apprenticeship' ? 'PT 2H per day' : '40 hours per week'),
  industry: 'Artificial Intelligence Research',
  occupationalCategory: deptName,
  experienceRequirements: {
    '@type': 'OccupationalExperienceRequirements',
    monthsOfExperience: yearsExp * 12,
  },
  educationRequirements: {
    '@type': 'EducationalOccupationalCredential',
    credentialCategory: r.level === 'Intern' || r.level === 'Apprentice' ? 'high school' : 'bachelor degree',
  },
  hiringOrganization: {
    '@type': 'Organization',
    name: 'EduRankAI',
    sameAs: 'https://www.edurankai.in',
    logo: 'https://www.edurankai.in/favicon.svg',
  },
  jobLocation: {
    '@type': 'Place',
    address: { '@type': 'PostalAddress', addressCountry: 'IN', addressRegion: 'Remote / Worldwide' },
  },
  jobLocationType: 'TELECOMMUTE',
  applicantLocationRequirements: { '@type': 'Country', name: 'Any' },
};
if (salaryMaxINR) {
  jobPostingSchema.baseSalary = {
    '@type': 'MonetaryAmount',
    currency: 'INR',
    value: {
      '@type': 'QuantitativeValue',
      maxValue: salaryMaxINR,
      unitText: 'YEAR',
    },
  };
}

// C-suite-tuned page title and description: surface seniority + comp band
// up-front so the result wins on senior search queries.
const seniorTitle = ['C-Level', 'Lead'].includes(r.level || '');
const pageTitle = seniorTitle
  ? r.title + ' (Equity + up to ' + (r.salary || 'top market band') + ') | ' + deptName + ' | EduRankAI'
  : r.title + ' - ' + deptName + ' - EduRankAI Careers';
const baseDesc = (r.about || '').replace(/\s+/g, ' ').trim();
const metaDesc = seniorTitle
  ? `${r.title} at EduRankAI - frontier AI research lab. ${r.salary ? r.salary + '. ' : ''}${baseDesc.substring(0, 130)}`.slice(0, 300)
  : (baseDesc.length > 160 ? baseDesc.substring(0, 157) + '...' : baseDesc);
---
<BaseLayout title={pageTitle} description={metaDesc}>
  <script type="application/ld+json" set:html={JSON.stringify(jobPostingSchema)}></script>

  <section class="px-[5vw] py-12 md:py-16 max-w-4xl mx-auto">
    <a href="/careers" class="inline-flex items-center gap-2 text-[0.8rem] font-mono text-ink-soft hover:text-burn transition-colors mb-8">
      <span>&larr;</span> Back to all roles
    </a>

    <div class="mb-10 pb-10 border-b border-ink/10">
      <div class="flex items-center gap-2 mb-3">
        <p class="eyebrow">{deptName}</p>
        <span class="text-ink-soft/40">/</span>
        <p class="text-[0.7rem] font-mono uppercase tracking-[0.15em] text-ink-soft">{framing.tagline}</p>
      </div>
      <h1 class="font-display text-[clamp(2rem,4.5vw,3.2rem)] font-semibold text-ink leading-[1.05] tracking-tight mb-5">
        {r.title}
      </h1>
      <p class="text-[1.05rem] text-ink-2 leading-relaxed mb-6 max-w-2xl">{r.function}</p>
      <div class="flex flex-wrap gap-2">
        <span class={'text-[0.7rem] font-bold uppercase tracking-wider px-2.5 py-1 rounded-md border ' + levelClass}>{r.level}</span>
        <span class="text-[0.7rem] font-semibold text-ink-soft bg-cream-2 border border-ink/10 px-2.5 py-1 rounded-md">{r.engagementType}</span>
        <span class="text-[0.7rem] font-semibold text-ink-soft bg-cream-2 border border-ink/10 px-2.5 py-1 rounded-md">{r.location}</span>
        {r.duration && <span class="text-[0.7rem] font-semibold text-ink-soft bg-cream-2 border border-ink/10 px-2.5 py-1 rounded-md">{r.duration}</span>}
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-12">
      <div class="bg-cream-2 border border-ink/10 rounded-xl p-4">
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-ink-soft mb-2 font-bold">Compensation</p>
        <p class="text-[0.88rem] text-ink leading-snug font-medium">{r.salary}</p>
      </div>
      <div class="bg-cream-2 border border-ink/10 rounded-xl p-4">
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-ink-soft mb-2 font-bold">Engagement</p>
        <p class="text-[0.88rem] text-ink leading-snug font-medium">{r.engagementType}</p>
        <p class="text-[0.74rem] text-ink-soft mt-1">{engagementText}</p>
      </div>
      <div class="bg-cream-2 border border-ink/10 rounded-xl p-4">
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-ink-soft mb-2 font-bold">Scope of role</p>
        <p class="text-[0.82rem] text-ink leading-snug">{framing.scope}</p>
      </div>
    </div>

    <div class="mb-12">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn mb-2 font-bold">01 &mdash; The role</p>
      <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-5">Why this role exists at EduRankAI</h2>
      <p class="text-[0.96rem] text-ink-2 leading-[1.85] font-light whitespace-pre-line">{r.about}</p>
    </div>

    {r.responsibilities && r.responsibilities.length > 0 && (
      <div class="mb-12">
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn mb-2 font-bold">02 &mdash; The work</p>
        <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-5">What you will own</h2>
        <ul class="space-y-4">
          {r.responsibilities.map((item, idx) => (
            <li class="flex gap-4 text-[0.93rem] text-ink-2 leading-[1.7]">
              <span class="font-mono text-[0.75rem] text-burn flex-shrink-0 mt-1 font-bold">{String(idx + 1).padStart(2, '0')}</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    {r.skills && r.skills.length > 0 && (
      <div class="mb-12">
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn mb-2 font-bold">03 &mdash; The expertise</p>
        <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-5">What we look for</h2>
        <div class="flex flex-wrap gap-2">
          {r.skills.map((s) => (
            <span class="text-[0.85rem] text-ink-2 bg-white border border-ink/15 px-3.5 py-2 rounded-md font-medium">{s}</span>
          ))}
        </div>
      </div>
    )}

    {r.eligibility && r.eligibility.length > 0 && (
      <div class="mb-12">
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn mb-2 font-bold">04 &mdash; The bar</p>
        <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-5">Who thrives here</h2>
        <ul class="space-y-3">
          {r.eligibility.map((item) => (
            <li class="flex gap-3 text-[0.93rem] text-ink-2 leading-[1.7]">
              <span class="text-burn flex-shrink-0 mt-1 font-bold">&rarr;</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <div class="mb-12">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn mb-2 font-bold">05 &mdash; How we work</p>
      <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-5">The EduRankAI environment</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {r.location && r.location.toLowerCase().includes('remote') ? (
          <div class="bg-white border border-ink/10 rounded-xl p-5">
            <p class="text-[0.85rem] font-semibold text-ink mb-2">Remote-first, async-first</p>
            <p class="text-[0.82rem] text-ink-soft leading-relaxed">Work from anywhere. We optimise for deep work, not face time. Periodic in-person off-sites for the full-time team.</p>
          </div>
        ) : (
          <div class="bg-white border border-ink/10 rounded-xl p-5">
            <p class="text-[0.85rem] font-semibold text-ink mb-2">Where you work matters</p>
            <p class="text-[0.82rem] text-ink-soft leading-relaxed">This role is based in {r.location}. We chose this on purpose — the work calls for proximity, collaboration, and presence. We will help with relocation where appropriate.</p>
          </div>
        )}
        <div class="bg-white border border-ink/10 rounded-xl p-5">
          <p class="text-[0.85rem] font-semibold text-ink mb-2">High autonomy, high standards</p>
          <p class="text-[0.82rem] text-ink-soft leading-relaxed">We hire adults and trust them. You will be expected to set your own goals, communicate clearly, and ship.</p>
        </div>
        <div class="bg-white border border-ink/10 rounded-xl p-5">
          <p class="text-[0.85rem] font-semibold text-ink mb-2">Builders, not bureaucrats</p>
          <p class="text-[0.82rem] text-ink-soft leading-relaxed">We optimise for clarity over process. Make the call, ship the work, write up what you learned.</p>
        </div>
        <div class="bg-white border border-ink/10 rounded-xl p-5">
          <p class="text-[0.85rem] font-semibold text-ink mb-2">Bharat-built, globally ambitious</p>
          <p class="text-[0.82rem] text-ink-soft leading-relaxed">We are an Indian frontier AI lab. We build for India first and the world second &mdash; in that order.</p>
        </div>
      </div>
    </div>

    <div class="mb-12">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn mb-2 font-bold">06 &mdash; Hiring process</p>
      <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-5">What to expect after you apply</h2>
      <ol class="space-y-4">
        <li class="flex gap-4 text-[0.92rem] text-ink-2 leading-[1.7]">
          <span class="font-mono text-[0.72rem] text-burn flex-shrink-0 mt-1 font-bold">01</span>
          <div>
            <p class="font-semibold text-ink mb-1">Application review</p>
            <p class="text-ink-soft text-[0.86rem]">Every application is read personally within five business days. We respond either way.</p>
          </div>
        </li>
        <li class="flex gap-4 text-[0.92rem] text-ink-2 leading-[1.7]">
          <span class="font-mono text-[0.72rem] text-burn flex-shrink-0 mt-1 font-bold">02</span>
          <div>
            <p class="font-semibold text-ink mb-1">Take-home or live exercise</p>
            <p class="text-ink-soft text-[0.86rem]">Role-specific. Time-boxed. Real problems we are actually working on, not invented puzzles.</p>
          </div>
        </li>
        <li class="flex gap-4 text-[0.92rem] text-ink-2 leading-[1.7]">
          <span class="font-mono text-[0.72rem] text-burn flex-shrink-0 mt-1 font-bold">03</span>
          <div>
            <p class="font-semibold text-ink mb-1">Conversations</p>
            <p class="text-ink-soft text-[0.86rem]">Deep technical and values conversations with the team you would join. No trick questions. No panel ambushes.</p>
          </div>
        </li>
        <li class="flex gap-4 text-[0.92rem] text-ink-2 leading-[1.7]">
          <span class="font-mono text-[0.72rem] text-burn flex-shrink-0 mt-1 font-bold">04</span>
          <div>
            <p class="font-semibold text-ink mb-1">Offer or honest no</p>
            <p class="text-ink-soft text-[0.86rem]">If yes: digital offer letter, signed in-portal, transparent terms. If no: written feedback if you want it.</p>
          </div>
        </li>
      </ol>
    </div>

    <div class="bg-white border-2 border-burn rounded-2xl p-6 md:p-8 mt-12">
      <h3 class="font-display text-xl md:text-2xl font-semibold text-ink mb-3">Ready to apply?</h3>
      <p class="text-[0.9rem] text-ink-soft mb-5 leading-relaxed">
        We read every application personally. If you are the right person for this role &mdash; regardless of pedigree, background, or where you are based &mdash; you will hear back from us within five business days.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href={applyHref} class="btn-primary flex-1 justify-center inline-flex items-center gap-2 text-center">Apply for {r.title} <span>&rarr;</span></a>
        <a href="/careers" class="btn-ghost flex-1 justify-center">See all open roles</a>
      </div>
    </div>

    {relatedRoles.length > 0 && (
      <div class="mt-16 pt-12 border-t border-ink/10">
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-ink-soft mb-3 font-bold">Other roles in {deptName}</p>
        <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-6">Explore related openings</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {relatedRoles.map((rel) => (
            <a href={'/careers/' + rel.slug} class="bg-white border border-ink/10 rounded-xl p-5 hover:border-burn transition-colors group">
              <p class="font-display text-[1.05rem] font-semibold text-ink group-hover:text-burn transition-colors mb-2">{rel.title}</p>
              <div class="flex gap-2">
                <span class={'text-[0.68rem] font-bold uppercase tracking-wider px-2 py-0.5 rounded border ' + (levelColors[rel.level] || 'bg-cream-2 text-ink-soft border-ink/15')}>{rel.level}</span>
                <span class="text-[0.68rem] font-semibold text-ink-soft bg-cream-2 border border-ink/10 px-2 py-0.5 rounded">{rel.engagementType}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </section>

  <!-- Sticky apply bar - appears after user scrolls past the hero -->
  <div id="stickyApply" style="position:fixed;left:0;right:0;bottom:0;z-index:40;background:rgba(255,255,255,0.96);backdrop-filter:blur(14px);border-top:1px solid rgba(0,0,0,0.1);padding:10px 5vw;transform:translateY(100%);transition:transform 0.25s ease;box-shadow:0 -4px 22px rgba(0,0,0,0.06);">
    <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:12px;">
      <div style="min-width:0;flex:1;">
        <p style="font-size:11.5px;color:#6b7280;font-family:'Geist Mono',monospace;letter-spacing:0.08em;text-transform:uppercase;margin:0 0 1px;line-height:1.2;">{r.level} {r.engagementType}</p>
        <p style="font-size:14px;font-weight:600;color:#0F0F12;margin:0;line-height:1.25;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{r.title}</p>
      </div>
      <a href={applyHref} class="btn-primary" style="flex-shrink:0;font-size:13px;padding:9px 18px;white-space:nowrap;">Apply &rarr;</a>
    </div>
  </div>

  <script is:inline>
    (function() {
      var bar = document.getElementById('stickyApply');
      if (!bar) return;
      var threshold = 600;
      function check() {
        if (window.scrollY > threshold) {
          bar.style.transform = 'translateY(0)';
        } else {
          bar.style.transform = 'translateY(100%)';
        }
      }
      window.addEventListener('scroll', check, { passive: true });
      check();
    })();
  </script>
</BaseLayout>