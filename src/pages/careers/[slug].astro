---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { roles, departments } from '@/lib/db/schema';
import { eq } from 'drizzle-orm';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/careers');

const found = await db.select().from(roles).where(eq(roles.slug, slug)).limit(1);
if (found.length === 0) return Astro.redirect('/careers');

const r = found[0];
if (!r.isOpen) return Astro.redirect('/careers');

const deptResult = await db.select().from(departments).where(eq(departments.id, r.departmentId)).limit(1);
const deptName = deptResult.length > 0 ? deptResult[0].name : 'EduRankAI';

const levelColors = {
  'C-Level': 'bg-plum-bg text-plum border-plum-border',
  'Lead': 'bg-leaf-bg text-leaf border-leaf-border',
  'Senior': 'bg-sky-bg text-sky border-sky-border',
  'Mid': 'bg-burn-pale text-burn border-burn-dim',
  'Junior': 'bg-cream-2 text-ink-soft border-ink/15',
  'Intern': 'bg-gold-bg text-gold-deep border-gold-border',
  'Apprentice': 'bg-leaf-bg text-leaf border-leaf-border'
};
const levelClass = levelColors[r.level] || 'bg-cream-2 text-ink-soft border-ink/15';

const applyHref = '/apply?role=' + r.slug;

const jobPostingSchema = {
  '@context': 'https://schema.org/',
  '@type': 'JobPosting',
  title: r.title,
  description: r.about + '\n\nResponsibilities: ' + (r.responsibilities || []).join('; ') + '. Skills: ' + (r.skills || []).join(', ') + '.',
  identifier: { '@type': 'PropertyValue', name: 'EduRankAI', value: r.slug },
  datePosted: new Date(r.createdAt).toISOString().split('T')[0],
  employmentType: r.engagementType === 'Full-Time' ? 'FULL_TIME' : (r.engagementType === 'Internship' ? 'INTERN' : 'CONTRACTOR'),
  hiringOrganization: {
    '@type': 'Organization',
    name: 'EduRankAI',
    sameAs: 'https://www.edurankai.in',
    logo: 'https://www.edurankai.in/favicon.svg'
  },
  jobLocation: {
    '@type': 'Place',
    address: { '@type': 'PostalAddress', addressCountry: 'IN', addressRegion: 'Remote / Worldwide' }
  },
  jobLocationType: 'TELECOMMUTE',
  applicantLocationRequirements: { '@type': 'Country', name: 'Any' }
};

const metaDesc = r.about.length > 160 ? r.about.substring(0, 157) + '...' : r.about;
const pageTitle = r.title + ' - ' + deptName + ' - EduRankAI Careers';
---
<BaseLayout title={pageTitle} description={metaDesc}>
  <script type="application/ld+json" set:html={JSON.stringify(jobPostingSchema)}></script>

  <section class="px-[5vw] py-12 md:py-16 max-w-4xl mx-auto">
    <a href="/careers" class="inline-flex items-center gap-2 text-[0.8rem] font-mono text-ink-soft hover:text-burn transition-colors mb-8">
      <span>←</span> Back to all roles
    </a>

    <div class="mb-8 pb-8 border-b border-ink/10">
      <p class="eyebrow mb-2">{deptName}</p>
      <h1 class="font-display text-[clamp(2rem,4.5vw,3rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-5">
        {r.title}
      </h1>
      <div class="flex flex-wrap gap-2 mb-4">
        <span class={'text-[0.7rem] font-bold uppercase tracking-wider px-2.5 py-1 rounded-md border ' + levelClass}>{r.level}</span>
        <span class="text-[0.7rem] font-semibold text-ink-soft bg-cream-2 border border-ink/10 px-2.5 py-1 rounded-md">{r.engagementType}</span>
        <span class="text-[0.7rem] font-semibold text-ink-soft bg-cream-2 border border-ink/10 px-2.5 py-1 rounded-md">{r.location}</span>
        <span class="text-[0.7rem] font-semibold text-ink-soft bg-cream-2 border border-ink/10 px-2.5 py-1 rounded-md">{r.duration}</span>
      </div>
      <p class="text-[0.92rem] text-ink-2 leading-relaxed">{r.function}</p>
    </div>

    <div class="bg-cream-2 border border-burn-dim rounded-xl p-5 md:p-6 mb-10">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn mb-2 font-bold">Compensation</p>
      <p class="text-[0.92rem] text-ink leading-relaxed font-medium">{r.salary}</p>
    </div>

    <div class="mb-10">
      <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-4">About this role</h2>
      <p class="text-[0.92rem] text-ink-2 leading-[1.85] font-light whitespace-pre-line">{r.about}</p>
    </div>

    {r.responsibilities && r.responsibilities.length > 0 && (
      <div class="mb-10">
        <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-4">What you will own</h2>
        <ul class="space-y-3">
          {r.responsibilities.map((item) => (
            <li class="flex gap-3 text-[0.9rem] text-ink-2 leading-relaxed">
              <span class="text-burn flex-shrink-0 mt-1 font-bold">→</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    {r.skills && r.skills.length > 0 && (
      <div class="mb-10">
        <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-4">What we look for</h2>
        <div class="flex flex-wrap gap-2">
          {r.skills.map((s) => (
            <span class="text-[0.8rem] text-ink-2 bg-white border border-ink/15 px-3 py-1.5 rounded-md">{s}</span>
          ))}
        </div>
      </div>
    )}

    {r.eligibility && r.eligibility.length > 0 && (
      <div class="mb-10">
        <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-4">Who should apply</h2>
        <ul class="space-y-3">
          {r.eligibility.map((item) => (
            <li class="flex gap-3 text-[0.9rem] text-ink-2 leading-relaxed">
              <span class="text-burn flex-shrink-0 mt-1 font-bold">→</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <div class="bg-white border border-burn rounded-2xl p-6 md:p-8 mt-12">
      <h3 class="font-display text-xl md:text-2xl font-semibold text-ink mb-3">Ready to apply?</h3>
      <p class="text-[0.88rem] text-ink-soft mb-5 leading-relaxed">
        We read every application personally. The right person, regardless of background, will always get a response within 5 business days.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href={applyHref} class="btn-primary flex-1 justify-center inline-flex items-center gap-2">Apply Now <span>→</span></a>
        <a href="/careers" class="btn-ghost flex-1 justify-center">See all roles</a>
      </div>
      <p class="text-[0.7rem] text-ink-soft/70 mt-4 leading-relaxed">
        Full applicant portal launching soon. For now, you will be guided through a quick application flow.
      </p>
    </div>
  </section>
</BaseLayout>
