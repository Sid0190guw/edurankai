---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { ensureFeeWaiverSchema } from '@/lib/fee-waiver';

const me = Astro.locals.user;
let waiverMsg = '', waiverErr = '', waiverAuthNeeded = false;

if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    if (!me) waiverAuthNeeded = true;
    else if (me.role && me.role !== 'applicant') waiverErr = 'Fee waivers are for applicant accounts only.';
    else {
      const situation = (fd.get('situation_note') as string || '').trim().slice(0, 4000);
      const expertise = (fd.get('expertise_note') as string || '').trim().slice(0, 4000);
      const driveUrl = (fd.get('drive_url') as string || '').trim().slice(0, 1000);
      if (situation.length < 60) waiverErr = 'Situation must be at least 60 characters — we need enough context to decide fairly.';
      else if (expertise.length < 60) waiverErr = 'Expertise / fit note must be at least 60 characters.';
      else if (!driveUrl || !/^https?:\/\//i.test(driveUrl)) waiverErr = 'Drive URL is required and must start with http:// or https://.';
      else {
        await ensureFeeWaiverSchema();
        await db.execute(sql`
          INSERT INTO application_fee_waivers (user_id, intent_id, situation_note, expertise_note, drive_url, status)
          VALUES (${me.id}, NULL, ${situation}, ${expertise}, ${driveUrl}, 'pending')
        `);
        waiverMsg = 'Waiver request received. We will reply inside your portal within 5 business days.';
      }
    }
  } catch (e: any) { waiverErr = String(e?.message || e).slice(0, 240); }
}
---
<BaseLayout title="Fee waiver request — EduRankAI Careers" description="Request a waiver of the EduRankAI application fee. We read every request individually and reply inside your portal within 5 business days.">

<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/careers" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← Back to careers</a>

  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-3">Hardship · fee waiver</p>
    <h1 class="font-display text-[clamp(2rem,4.5vw,3rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-4">
      Request a <em class="italic text-burn font-medium">fee waiver.</em>
    </h1>
    <p class="text-[0.98rem] text-ink-2 font-light leading-[1.85]">
      We read every request individually. If approved, the exact extent of aid (full or partial) and a unique voucher code will appear in your <a href="/portal/waivers" class="text-burn font-semibold underline underline-offset-2">portal</a>, ready to redeem at the payment step.
    </p>
  </div>

  <div class="bg-white border-l-4 border-burn rounded-xl px-5 py-4 mb-6" style="border-top:1px solid rgba(14,11,8,0.08);border-right:1px solid rgba(14,11,8,0.08);border-bottom:1px solid rgba(14,11,8,0.08);border-left:4px solid #FF4F00;">
    <p class="text-[0.88rem] text-ink-2 leading-[1.7] m-0">
      <strong class="text-ink font-semibold">No one is appealed</strong> — not the CEO, not an intern. We do not run an exception channel. For consideration, apply through the <strong class="text-ink font-semibold">right channel only</strong>. We will reply inside your portal within 5 business days.
    </p>
  </div>
</section>

<section class="px-[5vw] pb-20 max-w-3xl mx-auto">

  {waiverMsg && (
    <div class="bg-leaf-bg border border-leaf-border rounded-2xl p-6">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-leaf font-bold mb-2">Submitted</p>
      <p class="font-display text-[1.2rem] font-semibold text-ink leading-tight m-0 mb-2">{waiverMsg}</p>
      <p class="text-[0.86rem] text-ink-2 leading-relaxed m-0 mb-4">If approved, a voucher code and the extent of aid will appear in your portal — ready to apply at the payment step.</p>
      <a href="/portal/waivers" class="bg-leaf hover:bg-leaf/90 text-white font-semibold py-2.5 px-5 rounded-xl text-[0.88rem] no-underline inline-block">Track this request →</a>
    </div>
  )}

  {waiverErr && !waiverAuthNeeded && (
    <div class="bg-burn-pale border border-burn-dim rounded-xl px-4 py-3 mb-4 text-[0.86rem] text-burn font-semibold">{waiverErr}</div>
  )}

  {waiverAuthNeeded && (
    <div class="bg-cream-2/60 border border-ink/10 rounded-2xl px-5 py-5">
      <p class="text-[0.88rem] text-ink-2 leading-relaxed m-0 mb-3">Sign in or create a portal account to submit a waiver request. We need an account so we can reply privately and grant the voucher only to you.</p>
      <a href={'/portal/login?next=' + encodeURIComponent('/careers/fee-waiver')} class="bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-5 rounded-xl text-[0.88rem] no-underline inline-block">Sign in to continue →</a>
    </div>
  )}

  {!waiverMsg && !waiverAuthNeeded && (
    <form method="POST" class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
      <div>
        <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Your situation <span class="text-burn">*</span></label>
        <textarea name="situation_note" rows="5" required minlength="60" maxlength="4000" placeholder="What makes the fee genuinely hard right now? Be specific — income range, dependents, currency disadvantage, recent disruption." class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink font-body leading-relaxed resize-y focus:border-burn focus:outline-none"></textarea>
        <p class="text-[0.74rem] text-ink-soft mt-1.5 m-0">Minimum 60 characters. No documents required — your word + later verification is enough.</p>
      </div>

      <div>
        <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Why you are a serious candidate <span class="text-burn">*</span></label>
        <textarea name="expertise_note" rows="5" required minlength="60" maxlength="4000" placeholder="What have you actually built, shipped, written, or done? Concrete artefacts beat credentials." class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink font-body leading-relaxed resize-y focus:border-burn focus:outline-none"></textarea>
      </div>

      <div>
        <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Drive URL with proof of work <span class="text-burn">*</span></label>
        <input name="drive_url" type="url" required placeholder="https://drive.google.com/..." class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink focus:border-burn focus:outline-none" />
        <p class="text-[0.74rem] text-ink-soft mt-1.5 m-0">Google Drive / Dropbox / GitHub / website. Code, writing, designs, research — whatever shows what you can do. Public links only.</p>
      </div>

      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3 pt-2">
        <button type="submit" class="btn-primary">Submit waiver request →</button>
        <p class="text-[0.78rem] text-ink-soft m-0">Decision arrives in your portal within 5 business days.</p>
      </div>
    </form>
  )}

</section>
</BaseLayout>
