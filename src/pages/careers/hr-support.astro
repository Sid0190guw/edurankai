---
import BaseLayout from '@/layouts/BaseLayout.astro';

const me = Astro.locals.user;
let supportErr = '';
let supportRedirectId = '';

if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const name = (fd.get('candidate_name') as string || '').trim().slice(0, 200);
    const email = (fd.get('candidate_email') as string || '').trim().slice(0, 200);
    const phone = (fd.get('candidate_phone') as string || '').trim().slice(0, 40) || undefined;
    const kind = (fd.get('support_kind') as string || 'general').toString();
    const situation = (fd.get('situation') as string || '').trim().slice(0, 5000);
    const targetRole = (fd.get('target_role_slug') as string || '').trim().slice(0, 120) || undefined;
    const tz = (fd.get('timezone') as string || '').trim().slice(0, 60) || undefined;
    const slotIso = (fd.get('slot_at') as string || '').trim();
    const slotLabel = (fd.get('slot_label') as string || '').trim().slice(0, 60);
    if (!name || !email || !/.+@.+\..+/.test(email)) supportErr = 'Name and a valid email are required.';
    else if (situation.length < 30) supportErr = 'Tell us a little more about what you need help with (at least 30 characters).';
    else if (!slotIso) supportErr = 'Please pick a meeting slot from the calendar below.';
    else {
      const { createHrSupportRequest } = await import('@/lib/hr-support');
      const r = await createHrSupportRequest({
        userId: me?.id, candidateName: name, candidateEmail: email, candidatePhone: phone,
        supportKind: kind, situation, targetRoleSlug: targetRole, preferredWindow: slotLabel || undefined, timezone: tz,
      });
      if (r.ok && r.id) {
        try {
          const { db } = await import('@/lib/db');
          const { sql } = await import('drizzle-orm');
          await db.execute(sql`UPDATE hr_application_support SET requested_slot_at = ${slotIso}::timestamptz, requested_slot_label = ${slotLabel || null}, updated_at = NOW() WHERE id = ${r.id}`);
        } catch (_) {}
        supportRedirectId = r.id;
      }
      else supportErr = 'Could not create request. Please try again.';
    }
  } catch (e: any) { supportErr = String(e?.message || e).slice(0, 240); }
}

if (supportRedirectId) return Astro.redirect('/payments/hr-support/' + supportRedirectId);

// Generate next-14-days × 3-slots-per-day (10:00 / 14:00 / 17:00 IST).
// Rendered server-side so it works without JS, with a small client script
// to highlight the chosen slot.
const TZ_OFFSET_MS = 5.5 * 60 * 60 * 1000; // IST
function pad(n: number) { return n < 10 ? '0' + n : '' + n; }
const today = new Date();
today.setUTCHours(0, 0, 0, 0);
const SLOT_DAYS = [] as { dateLabel: string; weekday: string; ymd: string; slots: { iso: string; label: string; hh: number }[] }[];
const HOURS = [10, 14, 17];
for (let d = 1; d <= 14; d++) {
  const day = new Date(today.getTime() + d * 86400000);
  const ymd = day.getUTCFullYear() + '-' + pad(day.getUTCMonth() + 1) + '-' + pad(day.getUTCDate());
  const weekday = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][day.getUTCDay()];
  const dateLabel = pad(day.getUTCDate()) + ' ' + ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][day.getUTCMonth()];
  const slots = HOURS.map(hh => {
    const slotUtcMs = day.getTime() + hh * 3600000 - TZ_OFFSET_MS;
    const iso = new Date(slotUtcMs).toISOString();
    return { iso, label: pad(hh) + ':00 IST', hh };
  });
  SLOT_DAYS.push({ dateLabel, weekday, ymd, slots });
}
---
<BaseLayout title="HR Application Support · 25 CHF — EduRankAI Careers" description="Book a virtual meeting with EduRankAI's HR team to get guided step-by-step through your application. 25 CHF, 30–45 minutes, on Google Meet.">

<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/careers" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← Back to careers</a>

  <div class="mt-5 mb-6 flex items-start gap-4 flex-wrap">
    <div style="flex-shrink:0;width:44px;height:44px;border-radius:50%;background:#EBF0FF;display:flex;align-items:center;justify-content:center;">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1045BB" stroke-width="2.2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
    </div>
    <div class="flex-1 min-w-[200px]">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-sky font-bold mb-2">HR application support · 25 CHF</p>
      <h1 class="font-display text-[clamp(2rem,4.5vw,3rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-3">
        Get an HR rep on a <em class="italic text-burn font-medium">call.</em>
      </h1>
      <p class="text-[0.98rem] text-ink-2 font-light leading-[1.85]">
        Book a virtual meeting with our HR team. We will walk through your situation, review your profile, and guide you step-by-step on how to actually complete a successful application. <strong class="text-ink font-semibold">25 CHF</strong> — one session, 30–45 minutes, on Google Meet.
      </p>
    </div>
  </div>
</section>

<section class="px-[5vw] pb-20 max-w-3xl mx-auto">

  {supportErr && <div class="bg-burn-pale border border-burn-dim rounded-xl px-4 py-3 mb-4 text-[0.86rem] text-burn font-semibold">{supportErr}</div>}

  <form method="POST" class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Full name <span class="text-burn">*</span></label>
        <input name="candidate_name" type="text" required maxlength="200" value={me?.name || ''} placeholder="As it should appear on Google Meet" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink focus:border-sky focus:outline-none" />
      </div>
      <div>
        <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Email <span class="text-burn">*</span></label>
        <input name="candidate_email" type="email" required maxlength="200" value={me?.email || ''} placeholder="you@example.com" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink focus:border-sky focus:outline-none" />
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Phone (optional)</label>
        <input name="candidate_phone" type="tel" maxlength="40" placeholder="+91 9XXXXXXXXX" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink focus:border-sky focus:outline-none" />
      </div>
      <div>
        <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Target role (slug, optional)</label>
        <input name="target_role_slug" type="text" maxlength="120" placeholder="e.g. compliance-analyst" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink focus:border-sky focus:outline-none" />
      </div>
    </div>

    <div>
      <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">What kind of support do you need? <span class="text-burn">*</span></label>
      <select name="support_kind" required class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink focus:border-sky focus:outline-none">
        <option value="application_strategy">Application strategy — how to position myself for this kind of role</option>
        <option value="role_selection">Role selection — which role(s) actually fit me</option>
        <option value="interview_prep">Interview prep — I have an interview lined up</option>
        <option value="profile_review">Profile review — walk through my profile + portfolio</option>
        <option value="cv_review">CV review — specific changes to make</option>
        <option value="portfolio_review">Portfolio review — review my work samples</option>
        <option value="general">General guidance — I will explain</option>
      </select>
    </div>

    <div>
      <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Your situation <span class="text-burn">*</span></label>
      <textarea name="situation" rows="5" required minlength="30" maxlength="5000" placeholder="Tell us what you are stuck on. The more specific, the better the call goes." class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink font-body leading-relaxed resize-y focus:border-sky focus:outline-none"></textarea>
    </div>

    {/* ============ CALENDAR · SLOT PICKER ============ */}
    <div>
      <div class="flex justify-between items-baseline mb-3 flex-wrap gap-2">
        <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold m-0">Pick your slot <span class="text-burn">*</span></label>
        <p class="text-[0.72rem] text-ink-soft m-0">All slots shown in <strong class="text-ink">IST</strong> · 30–45 min · Google Meet</p>
      </div>
      <input type="hidden" name="slot_at" id="slotAt" required />
      <input type="hidden" name="slot_label" id="slotLabel" />
      <div class="bg-cream border border-ink/10 rounded-xl p-3 md:p-4 overflow-x-auto">
        <div class="grid gap-2" style="grid-template-columns: repeat(7, minmax(110px, 1fr));">
          {SLOT_DAYS.map((d) => (
            <div class="bg-white border border-ink/10 rounded-lg p-2 flex flex-col gap-1.5">
              <div class="text-center pb-1.5 border-b border-ink/8">
                <p class="font-mono text-[0.6rem] uppercase tracking-[0.12em] text-ink-soft font-bold m-0">{d.weekday}</p>
                <p class="font-display text-[0.95rem] font-semibold text-ink leading-none m-0 mt-1">{d.dateLabel}</p>
              </div>
              {d.slots.map((s) => (
                <button type="button" class="slot-btn font-mono text-[0.72rem] font-semibold text-ink-2 bg-cream border border-ink/10 rounded-md py-1.5 px-2 hover:bg-sky-bg hover:border-sky hover:text-sky transition-colors cursor-pointer" data-iso={s.iso} data-label={d.dateLabel + ' · ' + s.label}>
                  {s.label}
                </button>
              ))}
            </div>
          ))}
        </div>
      </div>
      <p id="slotConfirm" class="text-[0.78rem] text-sky font-semibold mt-2 m-0" style="display:none;"></p>
      <p class="text-[0.72rem] text-ink-soft mt-1.5 m-0">If your timezone differs, mention it in the situation field — we adjust accordingly.</p>
    </div>

    <div class="bg-sky-bg/40 border border-sky-border rounded-xl px-4 py-3">
      <p class="text-[0.82rem] text-ink-2 leading-relaxed m-0">
        <strong class="text-ink font-semibold">Next step:</strong> Submitting takes you to a secure payment page (Razorpay, 25 CHF). Once paid, our HR team confirms within 24 hours and emails you a Google Meet link with a scheduled slot in your preferred window.
      </p>
    </div>

    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3 pt-2">
      <button type="submit" class="bg-sky hover:bg-sky/90 text-white font-semibold py-3 px-7 rounded-xl text-[0.92rem]">Continue to payment · 25 CHF →</button>
      <p class="text-[0.78rem] text-ink-soft m-0">Refund within 24 hours if no slot can be found.</p>
    </div>

  </form>

</section>

<script is:inline>
  (function () {
    var slotAt = document.getElementById('slotAt');
    var slotLabel = document.getElementById('slotLabel');
    var confirm = document.getElementById('slotConfirm');
    var btns = document.querySelectorAll('.slot-btn');
    btns.forEach(function (b) {
      b.addEventListener('click', function () {
        btns.forEach(function (x) {
          x.style.background = '';
          x.style.borderColor = '';
          x.style.color = '';
          x.style.fontWeight = '600';
        });
        b.style.background = '#1045BB';
        b.style.borderColor = '#1045BB';
        b.style.color = '#fff';
        b.style.fontWeight = '700';
        slotAt.value = b.getAttribute('data-iso');
        slotLabel.value = b.getAttribute('data-label');
        confirm.textContent = 'Selected: ' + b.getAttribute('data-label');
        confirm.style.display = 'block';
      });
    });
  })();
</script>
</BaseLayout>
