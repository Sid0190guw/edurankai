---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ensureCaSchema, applyAsAmbassador } from '@/lib/campus-ambassadors';

const user = Astro.locals.user;
await ensureCaSchema();

let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const name = ((fd.get('name') as string) || '').trim().slice(0, 200);
    const email = ((fd.get('email') as string) || '').trim().slice(0, 200);
    const phone = ((fd.get('phone') as string) || '').trim().slice(0, 40) || undefined;
    const institution = ((fd.get('institution') as string) || '').trim().slice(0, 200);
    const courseYear = ((fd.get('course_year') as string) || '').trim().slice(0, 80) || undefined;
    const country = ((fd.get('country') as string) || '').trim().slice(0, 80) || 'IN';
    const whyJoin = ((fd.get('why_join') as string) || '').trim().slice(0, 5000);
    const outreachPlan = ((fd.get('outreach_plan') as string) || '').trim().slice(0, 5000) || undefined;
    const ig = ((fd.get('instagram') as string) || '').trim().slice(0, 80) || undefined;
    const li = ((fd.get('linkedin') as string) || '').trim().slice(0, 200) || undefined;
    const tw = ((fd.get('twitter') as string) || '').trim().slice(0, 80) || undefined;
    if (!name || !email || !institution || !whyJoin || whyJoin.length < 100) {
      errMsg = 'Name, email, institution, and a 100+ character "why" are required.';
    } else {
      const r = await applyAsAmbassador({
        userId: user?.id, name, email, phone, institution, courseYear, country, whyJoin, outreachPlan,
        socialHandles: { instagram: ig, linkedin: li, twitter: tw },
      });
      okMsg = 'Application received. We review every CAmb application individually and reply within 7 business days.';
    }
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 240); }
}
---
<BaseLayout title="Campus Ambassador programme · EduRankAI" description="Become an EduRankAI Campus Ambassador. Lead outreach, run sessions, earn a stipend + verifiable credentials. Open to students in any institution worldwide.">

<section class="px-[5vw] pt-12 md:pt-16 pb-6 max-w-3xl mx-auto">
  <a href="/careers" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← Careers</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-3">Campus Ambassador programme</p>
    <h1 class="font-display text-[clamp(2.2rem,5vw,3.6rem)] font-semibold text-ink leading-[1.05] mb-4">
      Be the face of <em class="italic text-burn font-medium">Bharat's frontier AI lab</em> on your campus.
    </h1>
    <p class="text-[1rem] text-ink-2 font-light leading-[1.85]">
      Run sessions. Drive signups. Bring the work that EduRankAI is doing — frontier reasoning models, the Holistic Education Index, AquinTutor, karate.support — to the students around you who actually care. Open to undergraduates and postgraduates anywhere in the world.
    </p>
  </div>
</section>

<section class="px-[5vw] pb-10 max-w-3xl mx-auto">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
    <div class="bg-white border border-ink/10 rounded-2xl p-5">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-burn font-bold mb-2">What you get</p>
      <ul class="space-y-1.5 text-[0.88rem] text-ink-2 m-0 pl-4 list-disc leading-relaxed">
        <li>Monthly stipend (scaled to outcomes)</li>
        <li>Verifiable Campus Ambassador credential</li>
        <li>Direct line to EduRankAI founders</li>
        <li>First-look at internships + research roles</li>
        <li>EduRankAI swag + branded materials</li>
      </ul>
    </div>
    <div class="bg-white border border-ink/10 rounded-2xl p-5">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-burn font-bold mb-2">What we expect</p>
      <ul class="space-y-1.5 text-[0.88rem] text-ink-2 m-0 pl-4 list-disc leading-relaxed">
        <li>~5 hours / week minimum commitment</li>
        <li>One session or event per month on campus</li>
        <li>Honest representation — never overstate</li>
        <li>Quarterly written CA report (via portal)</li>
        <li>Active social presence on at least one platform</li>
      </ul>
    </div>
  </div>
</section>

<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  {okMsg && (
    <div class="bg-leaf-bg border border-leaf-border rounded-2xl px-5 py-5 mb-5">
      <p class="font-display text-[1.1rem] font-semibold text-leaf m-0">{okMsg}</p>
      <p class="text-[0.86rem] text-ink-2 m-0 mt-2">Want to do something while you wait? Read the <a href="/policy/recruitment" class="text-leaf font-semibold underline">recruitment policy</a> and start drafting your first quarterly report idea.</p>
    </div>
  )}
  {errMsg && <div class="bg-burn-pale border border-burn-dim rounded-xl px-4 py-3 mb-4 text-[0.88rem] text-burn font-semibold">{errMsg}</div>}

  {!okMsg && (
    <form method="POST" class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-burn font-bold m-0">Apply</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Full name <span class="text-burn">*</span></label><input name="name" type="text" required maxlength="200" value={user?.name || ''} class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink focus:border-burn focus:outline-none" /></div>
        <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Email <span class="text-burn">*</span></label><input name="email" type="email" required maxlength="200" value={user?.email || ''} class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink focus:border-burn focus:outline-none" /></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Phone</label><input name="phone" type="tel" maxlength="40" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink focus:border-burn focus:outline-none" /></div>
        <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Country</label><input name="country" type="text" maxlength="80" value="IN" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink focus:border-burn focus:outline-none" /></div>
      </div>
      <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Institution <span class="text-burn">*</span></label><input name="institution" type="text" required maxlength="200" placeholder="e.g. a national engineering institute" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink focus:border-burn focus:outline-none" /></div>
      <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Course + year</label><input name="course_year" type="text" maxlength="80" placeholder="e.g. BTech CS, 3rd year" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink focus:border-burn focus:outline-none" /></div>
      <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Why you, why now <span class="text-burn">*</span></label><textarea name="why_join" rows="5" required minlength="100" maxlength="5000" placeholder="What in your background makes you a good fit? What do you actually believe in our mission?" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink font-body leading-relaxed resize-y focus:border-burn focus:outline-none"></textarea><p class="text-[0.72rem] text-ink-soft mt-1.5 m-0">Minimum 100 characters.</p></div>
      <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Your outreach plan for the first quarter</label><textarea name="outreach_plan" rows="4" maxlength="5000" placeholder="What will you actually do? Events / posts / classroom sessions / lab visits — be specific." class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink font-body leading-relaxed resize-y focus:border-burn focus:outline-none"></textarea></div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Instagram</label><input name="instagram" type="text" maxlength="80" placeholder="@handle" class="w-full bg-cream border border-ink/15 rounded-xl px-3 py-2 text-[0.9rem] text-ink" /></div>
        <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">LinkedIn</label><input name="linkedin" type="text" maxlength="200" placeholder="profile URL" class="w-full bg-cream border border-ink/15 rounded-xl px-3 py-2 text-[0.9rem] text-ink" /></div>
        <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Twitter / X</label><input name="twitter" type="text" maxlength="80" placeholder="@handle" class="w-full bg-cream border border-ink/15 rounded-xl px-3 py-2 text-[0.9rem] text-ink" /></div>
      </div>
      <button type="submit" class="btn-primary">Submit application →</button>
    </form>
  )}
</section>
</BaseLayout>
