---
// /r/[slug] — public web version of a resume built with the free builder.
// Server-rendered from the stored JSON (never stored HTML) with every field
// escaped, so a shared link can never carry script. noindex: resumes are for
// the people they are sent to, not for search engines.
import { getSharedResume } from '@/lib/resume';

const { slug } = Astro.params;
if (!slug || !/^[a-z0-9]{6,20}$/.test(slug)) return Astro.redirect('/resume');

const row = await getSharedResume(slug);
if (!row) return Astro.redirect('/resume?shared=expired');

const d: any = row.data || {};
const tpl = /^[a-z]+$/.test(row.template || '') ? row.template : 'classic';

const esc = (s: any) => String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

// Inline [[skill]] / [[skill|https://proof]] tags — same grammar as the builder.
function tokTags(s: string, mk: (label: string, url: string) => string): string {
  let out = '', last = 0, m: RegExpExecArray | null;
  const re = /\[\[([^\]|]+)(?:\|([^\]]+))?\]\]/g;
  while ((m = re.exec(s))) { out += esc(s.slice(last, m.index)); out += mk(m[1].trim(), (m[2] || '').trim()); last = re.lastIndex; }
  out += esc(s.slice(last));
  return out;
}
const inl = (s: string) => tokTags(s || '', (label, url) =>
  /^https?:\/\//i.test(url)
    ? '<a class="rp-tag" href="' + esc(url) + '" target="_blank" rel="noopener nofollow">' + esc(label) + '</a>'
    : '<span class="rp-tag">' + esc(label) + '</span>');
function bullets(s: string): string {
  const ls = (s || '').split(/\n+/).map((x) => x.trim()).filter(Boolean);
  return ls.length > 1 ? '<ul>' + ls.map((x) => '<li>' + inl(x) + '</li>').join('') + '</ul>' : (ls[0] ? '<p>' + inl(ls[0]) + '</p>' : '');
}
function parseSkills(raw: any): { name: string; url: string }[] {
  const out: { name: string; url: string }[] = [];
  String(raw || '').split(/\n/).forEach((line) => {
    line = (line || '').trim(); if (!line) return;
    const bar = line.indexOf('|');
    if (bar >= 0) { const name = line.slice(0, bar).trim(); const url = line.slice(bar + 1).trim(); if (name) out.push({ name, url: /^https?:\/\//i.test(url) ? url : '' }); }
    else line.split(',').forEach((n) => { n = n.trim(); if (n) out.push({ name: n, url: '' }); });
  });
  return out;
}
function contactItem(x: string, kind: string): string {
  if (!x) return '';
  let href = '';
  if (kind === 'email') href = 'mailto:' + x;
  else if (kind === 'phone') href = 'tel:' + x.replace(/[^\d+]/g, '');
  else if (kind === 'url') href = /^https?:\/\//i.test(x) ? x : 'https://' + x;
  if (!href) return '<span>' + esc(x) + '</span>';
  return '<a href="' + esc(href) + '" style="color:inherit;text-decoration:none;" target="_blank" rel="noopener">' + esc(x) + '</a>';
}
function block(title: string, items: any[], fmt: (e: any) => string): string {
  if (!items || !items.length) return '';
  return '<section><div class="rp-sec">' + esc(title) + '</div>' + items.map(fmt).join('') + '</section>';
}

const contact = [
  contactItem(d.email, 'email'), contactItem(d.phone, 'phone'),
  d.location ? '<span>' + esc(d.location) + '</span>' : '',
  contactItem(d.linkedin, 'url'), contactItem(d.website, 'url'), contactItem(d.github, 'url'),
].filter(Boolean).join('');

let body = '<div class="rp-head">';
const photo = String(d.photoUrl || '');
if (/^https:\/\//i.test(photo)) body += '<img class="rp-photo" src="' + esc(photo) + '" alt="" />';
body += '<div style="flex:1;min-width:0;"><h1>' + (esc(d.fullName) || 'Resume') + '</h1>' + (d.title ? '<p class="rp-title">' + esc(d.title) + '</p>' : '') + '<div class="rp-contact">' + contact + '</div></div></div>';
if (d.summary) body += '<section><div class="rp-sec">Summary</div><p style="margin:0;font-size:12px;">' + inl(d.summary) + '</p></section>';
body += block('Experience', d.experience || [], (e) => '<div class="rp-item"><div class="rp-r1"><span><b>' + esc(e.title || '') + '</b>' + (e.org ? ' <span class="rp-sub">— ' + esc(e.org) + '</span>' : '') + '</span><span class="rp-when">' + esc([e.location, e.period].filter(Boolean).join(' · ')) + '</span></div>' + bullets(e.detail) + '</div>');
body += block('Projects', d.projects || [], (e) => '<div class="rp-item"><div class="rp-r1"><span><b>' + esc(e.title || '') + '</b>' + (e.stack ? ' <span class="rp-sub">— ' + esc(e.stack) + '</span>' : '') + '</span><span class="rp-when">' + esc(e.period || '') + '</span></div>' + bullets(e.detail) + '</div>');
body += block('Education', d.education || [], (e) => '<div class="rp-item"><div class="rp-r1"><span><b>' + esc(e.school || '') + '</b>' + (e.degree ? ' <span class="rp-sub">— ' + esc(e.degree) + '</span>' : '') + '</span><span class="rp-when">' + esc([e.grade, e.period].filter(Boolean).join(' · ')) + '</span></div>' + bullets(e.detail) + '</div>');
const sk = parseSkills(d.skills);
if (sk.length) body += '<section><div class="rp-sec">Skills</div><div class="rp-skills">' + sk.map((x) => x.url ? '<a href="' + esc(x.url) + '" target="_blank" rel="noopener nofollow">' + esc(x.name) + '</a>' : '<span>' + esc(x.name) + '</span>').join('') + '</div></section>';
body += block('Achievements', d.achievements || [], (e) => '<div class="rp-item"><div class="rp-r1"><span><b>' + esc(e.title || '') + '</b></span><span class="rp-when">' + esc(e.when || '') + '</span></div>' + (e.detail ? '<p>' + esc(e.detail) + '</p>' : '') + '</div>');
(Array.isArray(d.customSections) ? d.customSections : []).forEach((s: any) => {
  body += block(String(s?.title || ''), s?.items || [], (e) => '<div class="rp-item"><div class="rp-r1"><span><b>' + esc(e.title || '') + '</b>' + (e.sub ? ' <span class="rp-sub">— ' + esc(e.sub) + '</span>' : '') + '</span><span class="rp-when">' + esc(e.period || '') + '</span></div>' + bullets(e.detail) + '</div>');
});

const pageTitle = (d.fullName ? d.fullName + ' — Resume' : 'Resume') + ' | EduRankAI';
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{pageTitle}</title>
    <link rel="stylesheet" href="/resume-paper.css" />
    <style>
      body { margin:0; background:#efe9e1; font-family:'Inter',system-ui,sans-serif; }
      .share-wrap { max-width:900px; margin:0 auto; padding:28px 14px 60px; }
      .share-bar { display:flex; align-items:center; justify-content:space-between; gap:10px; flex-wrap:wrap; margin-bottom:16px; }
      .share-brand { font-size:13px; color:#6b5d49; }
      .share-brand a { color:#FF4F00; font-weight:700; text-decoration:none; }
      .share-actions { display:flex; gap:8px; }
      .share-btn { font-size:13px; font-weight:600; padding:8px 16px; border-radius:8px; border:1px solid rgba(26,21,16,0.18); background:#fff; color:#1a1510; cursor:pointer; text-decoration:none; }
      .share-btn.primary { background:#FF4F00; border-color:#FF4F00; color:#fff; }
      @media print { .share-bar { display:none !important; } body { background:#fff; } .share-wrap { padding:0; max-width:none; } .rb-paper { box-shadow:none; border-radius:0; max-width:none; } }
    </style>
  </head>
  <body>
    <div class="share-wrap">
      <div class="share-bar">
        <span class="share-brand">Shared resume · viewed {row.share_views} {row.share_views === 1 ? 'time' : 'times'}</span>
        <span class="share-actions">
          <button type="button" class="share-btn" onclick="window.print()">Save as PDF</button>
          <a class="share-btn primary" href="/resume">Build your own — free</a>
        </span>
      </div>
      <div class={'rb-paper tpl-' + tpl} set:html={body}></div>
    </div>
  </body>
</html>
