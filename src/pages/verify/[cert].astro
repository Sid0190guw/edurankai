---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { verifyCertificate } from '@/lib/certificates';

const { cert } = Astro.params;
const certData = cert ? await verifyCertificate(cert) : null;

function fmt(d: any) {
  try { return new Date(d).toLocaleDateString('en-IN', { day: '2-digit', month: 'long', year: 'numeric' }); } catch { return ''; }
}
---
<BaseLayout title={'Verify ' + cert + ' - EduRankAI'} description="Public certificate verification page.">
  <section class="px-[5vw] py-16 max-w-2xl mx-auto">
    <p class="eyebrow mb-6">Certificate verification</p>
    {certData ? (
      <div class="bg-white border border-ink/10 rounded-2xl p-8 shadow-sm">
        <div class="flex items-start gap-4 mb-6">
          <div class="w-12 h-12 rounded-full bg-emerald-50 border border-emerald-200 flex items-center justify-center">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <p class="font-mono text-[0.62rem] uppercase tracking-[0.16em] text-emerald-700 font-bold mb-1">Verified</p>
            <h1 class="font-display text-[1.7rem] font-semibold text-ink leading-tight">{certData.course_title}</h1>
          </div>
        </div>
        <dl class="grid grid-cols-1 md:grid-cols-2 gap-y-3 gap-x-8 text-[0.92rem]">
          <div><dt class="text-ink-soft text-[0.78rem] font-mono uppercase tracking-wider">Awarded to</dt><dd class="text-ink font-semibold">{certData.user_name || 'Anonymous'}</dd></div>
          <div><dt class="text-ink-soft text-[0.78rem] font-mono uppercase tracking-wider">Certificate number</dt><dd class="font-mono text-ink">{certData.cert_number}</dd></div>
          <div><dt class="text-ink-soft text-[0.78rem] font-mono uppercase tracking-wider">Issued on</dt><dd class="text-ink">{fmt(certData.issued_at)}</dd></div>
          {certData.grade && <div><dt class="text-ink-soft text-[0.78rem] font-mono uppercase tracking-wider">Grade</dt><dd class="text-ink font-semibold">{certData.grade}</dd></div>}
        </dl>
        <p class="text-[0.78rem] text-ink-soft mt-6 pt-5 border-t border-ink/8 leading-relaxed">This is an authentic EduRankAI / AquinTutor course-completion certificate. Issued by EduRankAI on the date shown above.</p>
      </div>
    ) : (
      <div class="bg-cream-2 border border-ink/10 rounded-2xl p-8">
        <p class="font-mono text-[0.62rem] uppercase tracking-[0.16em] text-red-700 font-bold mb-2">Not found</p>
        <h1 class="font-display text-[1.4rem] font-semibold text-ink mb-2">Certificate <span class="font-mono text-burn">{cert}</span> does not exist.</h1>
        <p class="text-[0.92rem] text-ink-soft leading-relaxed">If you believe this is an error, contact <a href="mailto:hr@edurankai.in" class="text-burn hover:underline">hr@edurankai.in</a> with the certificate number you were given.</p>
      </div>
    )}
  </section>
</BaseLayout>
