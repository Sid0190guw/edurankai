---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { verifyCertificate } from '@/lib/certificates';

const { cert } = Astro.params;
const r = cert ? await verifyCertificate(cert) : null;
const c = r?.cert;

function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'long', year: 'numeric' }); } catch { return ''; } }

const checks = r && r.anchored ? [
  { label: 'Content integrity', ok: r.contentIntact, detail: 'The certificate fields hash to the recorded content hash — no field has been altered.' },
  { label: 'Block integrity', ok: r.blockIntact, detail: 'The block hash recomputes from prev-hash + content-hash + index.' },
  { label: 'Issuer signature', ok: r.signatureValid, detail: 'Ed25519 signature verifies against EduRankAI’s published public key.' },
  { label: 'Chain link', ok: r.chainLinked, detail: 'The previous-block reference matches the actual prior certificate in the ledger.' },
] : [];
---
<BaseLayout title={'Verify ' + cert + ' · EduRankAI'} description="Cryptographically verify an EduRankAI certificate against the credential ledger.">

<style>
  body { background: #FAF8F5; color: #0E0B08; }
  .vf-wrap { max-width: 760px; margin: 0 auto; padding: 40px 5vw 80px; }
  .vf-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #7A6F68; font-weight: 700; }
  .vf-banner { border-radius: 18px; padding: 28px 30px; margin: 14px 0 22px; display: flex; gap: 18px; align-items: center; }
  .vf-banner.ok { background: linear-gradient(135deg, #EBF5EF, #fff); border: 1px solid #86efac; }
  .vf-banner.bad { background: linear-gradient(135deg, #FFF1F0, #fff); border: 1px solid #fca5a5; }
  .vf-banner.legacy { background: linear-gradient(135deg, #FFFBEA, #fff); border: 1px solid #fcd34d; }
  .vf-shield { width: 56px; height: 56px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .vf-banner.ok .vf-shield { background: #1A6B35; }
  .vf-banner.bad .vf-shield { background: #b91c1c; }
  .vf-banner.legacy .vf-shield { background: #946322; }
  .vf-verdict { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; font-weight: 800; }
  .vf-banner.ok .vf-verdict { color: #1A6B35; }
  .vf-banner.bad .vf-verdict { color: #b91c1c; }
  .vf-banner.legacy .vf-verdict { color: #946322; }
  .vf-banner h1 { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 600; margin: 4px 0 0; letter-spacing: -0.02em; line-height: 1.1; }

  .vf-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 16px; padding: 26px 28px; margin-bottom: 16px; }
  .vf-card h2 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin: 0 0 14px; }
  .vf-row { display: grid; grid-template-columns: 150px 1fr; gap: 10px; padding: 8px 0; border-bottom: 1px solid rgba(14,11,8,0.06); font-size: 14.5px; }
  .vf-row:last-child { border-bottom: none; }
  .vf-row dt { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.06em; text-transform: uppercase; color: #7A6F68; font-weight: 700; padding-top: 2px; }
  .vf-row dd { margin: 0; color: #0E0B08; }
  .vf-mono { font-family: ui-monospace, monospace; font-size: 12px; color: #2E2520; word-break: break-all; }

  .vf-check { display: flex; gap: 12px; align-items: flex-start; padding: 11px 0; border-bottom: 1px solid rgba(14,11,8,0.06); }
  .vf-check:last-child { border-bottom: none; }
  .vf-check-dot { width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px; }
  .vf-check-dot.ok { background: rgba(26,107,53,0.12); color: #1A6B35; }
  .vf-check-dot.no { background: rgba(185,28,28,0.10); color: #b91c1c; }
  .vf-check-l { font-weight: 700; font-size: 14px; color: #0E0B08; margin: 0; }
  .vf-check-d { font-size: 12.5px; color: #7A6F68; line-height: 1.5; margin: 2px 0 0; }

  .vf-ledger { background: #0E0B08; color: #cfd6da; border-radius: 14px; padding: 20px 22px; margin-bottom: 16px; }
  .vf-ledger h2 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 12px; }
  .vf-hashrow { display: grid; grid-template-columns: 110px 1fr; gap: 10px; padding: 6px 0; font-family: ui-monospace, monospace; font-size: 11.5px; border-bottom: 1px solid rgba(255,255,255,0.08); }
  .vf-hashrow:last-child { border-bottom: none; }
  .vf-hashrow .k { color: #67e8f9; text-transform: uppercase; letter-spacing: 0.08em; font-size: 9.5px; padding-top: 3px; }
  .vf-hashrow .v { color: #e8e8ee; word-break: break-all; }
  .vf-note { font-size: 13px; color: #7A6F68; line-height: 1.65; margin-top: 14px; }
  .vf-note a { color: #FF4F00; }
  .vf-actions { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; }
  .vf-btn { background: #FF4F00; color: #fff; padding: 10px 18px; border-radius: 8px; text-decoration: none; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 700; }
  .vf-btn.ghost { background: transparent; border: 1px solid rgba(14,11,8,0.15); color: #0E0B08; }
</style>

<main class="vf-wrap">
  <p class="vf-eye">EduRankAI · Credential ledger</p>

  {!r || !r.found ? (
    <div class="vf-banner bad">
      <div class="vf-shield"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.4" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></div>
      <div>
        <p class="vf-verdict">Not found</p>
        <h1>No certificate with this number.</h1>
      </div>
    </div>
  ) : (
    <>
      <div class={"vf-banner " + (r.verified ? "ok" : (r.anchored ? "bad" : "legacy"))}>
        <div class="vf-shield">
          {r.verified
            ? <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            : r.anchored
              ? <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.4" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              : <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>}
        </div>
        <div>
          <p class="vf-verdict">{r.verified ? 'Verified · cryptographically authentic' : r.anchored ? 'Tampered · does not verify' : 'Found · not ledger-anchored'}</p>
          <h1>{c.course_title}</h1>
        </div>
      </div>

      <div class="vf-card">
        <h2>Credential</h2>
        <dl style="margin:0;">
          <div class="vf-row"><dt>Holder</dt><dd>{c.holder_name || c.user_name || 'Learner'}</dd></div>
          <div class="vf-row"><dt>Course</dt><dd>{c.course_title}</dd></div>
          <div class="vf-row"><dt>Issued</dt><dd>{fmt(c.issued_at)}</dd></div>
          {c.grade && <div class="vf-row"><dt>Grade</dt><dd>{c.grade}</dd></div>}
          <div class="vf-row"><dt>Certificate no.</dt><dd class="vf-mono">{c.cert_number}</dd></div>
          <div class="vf-row"><dt>Issuer</dt><dd>{c.issuer || 'EduRankAI'}</dd></div>
        </dl>
      </div>

      {r.anchored && (
        <div class="vf-card">
          <h2>Verification checks</h2>
          {checks.map((ck) => (
            <div class="vf-check">
              <div class={"vf-check-dot " + (ck.ok ? "ok" : "no")}>
                {ck.ok
                  ? <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  : <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>}
              </div>
              <div>
                <p class="vf-check-l">{ck.label} {ck.ok ? '· pass' : '· FAIL'}</p>
                <p class="vf-check-d">{ck.detail}</p>
              </div>
            </div>
          ))}
        </div>
      )}

      {r.anchored && (
        <div class="vf-ledger">
          <h2>Ledger record · block #{c.chain_index}</h2>
          <div class="vf-hashrow"><span class="k">Content hash</span><span class="v">{c.content_hash}</span></div>
          <div class="vf-hashrow"><span class="k">Prev hash</span><span class="v">{c.prev_hash}</span></div>
          <div class="vf-hashrow"><span class="k">Block hash</span><span class="v">{c.block_hash}</span></div>
          <div class="vf-hashrow"><span class="k">Signature</span><span class="v">{(c.signature || '').slice(0, 64)}…</span></div>
        </div>
      )}

      <p class="vf-note">
        {r.anchored
          ? 'This credential is a block in EduRankAI’s hash-chained ledger. Each certificate’s block hash includes the previous block’s hash, so altering any past record breaks every later one — tamper-evident like a public blockchain. The Ed25519 signature proves it was issued by EduRankAI. '
          : 'This certificate predates the cryptographic ledger and is recorded by certificate number only. '}
        <a href="/verify">Explore the full ledger &rarr;</a>
      </p>

      <div class="vf-actions">
        <a href={'/credentials/' + c.cert_number} class="vf-btn">View credential</a>
        <a href="/verify" class="vf-btn ghost">Ledger explorer</a>
      </div>
    </>
  )}
</main>
</BaseLayout>
