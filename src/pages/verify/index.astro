---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLedger, getLedgerStats, getPublicKeyPem } from '@/lib/certificates';

const stats = await getLedgerStats();
const ledger = await getLedger(60);
let pubKey = '';
try { pubKey = await getPublicKeyPem(); } catch {}

function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }); } catch { return ''; } }
function short(h: string | undefined) { if (!h) return '—'; return h.slice(0, 8) + '…' + h.slice(-6); }
---
<BaseLayout title="Credential ledger · EduRankAI" description="The EduRankAI verifiable credential ledger — a hash-chained, Ed25519-signed record of every certificate issued.">

<style>
  body { background: #FAF8F5; color: #0E0B08; }
  .lg-wrap { max-width: 1000px; margin: 0 auto; padding: 44px 5vw 80px; }
  .lg-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .lg-h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(34px, 5vw, 54px); font-weight: 600; letter-spacing: -0.03em; margin: 8px 0 12px; line-height: 1.02; }
  .lg-h1 em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .lg-sub { font-size: 16px; color: #2E2520; max-width: 660px; line-height: 1.65; }

  .lg-strip { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px; margin: 26px 0; }
  .lg-stat { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 12px; padding: 16px 18px; }
  .lg-stat-v { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 600; line-height: 1; }
  .lg-stat-l { font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #7A6F68; margin-top: 6px; font-weight: 700; }

  .lg-search { display: flex; gap: 8px; margin: 18px 0 26px; flex-wrap: wrap; }
  .lg-search input { flex: 1; min-width: 240px; background: #fff; border: 1px solid rgba(14,11,8,0.15); padding: 12px 16px; border-radius: 10px; font-family: ui-monospace, monospace; font-size: 14px; }
  .lg-search button { background: #FF4F00; color: #fff; border: none; padding: 12px 24px; border-radius: 10px; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 700; cursor: pointer; }

  .lg-key { background: #0E0B08; color: #cfd6da; border-radius: 14px; padding: 20px 22px; margin-bottom: 26px; }
  .lg-key h2 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 10px; }
  .lg-key pre { font-family: ui-monospace, monospace; font-size: 10.5px; color: #86efac; white-space: pre-wrap; word-break: break-all; margin: 0; line-height: 1.4; }

  .lg-chain h2 { font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 600; margin: 0 0 14px; letter-spacing: -0.01em; }
  .lg-block { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 12px; padding: 16px 18px; margin-bottom: 8px; display: grid; grid-template-columns: 60px 1fr auto; gap: 14px; align-items: center; }
  .lg-block-idx { font-family: 'Geist Mono', monospace; font-size: 22px; font-weight: 700; color: #FF4F00; text-align: center; }
  .lg-block-title { font-family: 'Cormorant Garamond', serif; font-size: 17px; font-weight: 600; line-height: 1.2; }
  .lg-block-sub { font-family: ui-monospace, monospace; font-size: 11px; color: #7A6F68; margin-top: 3px; }
  .lg-block-hash { font-family: ui-monospace, monospace; font-size: 11px; color: #2E2520; text-align: right; }
  .lg-block-hash a { color: #FF4F00; text-decoration: none; }
  .lg-empty { padding: 30px; text-align: center; color: #7A6F68; font-family: 'Geist Mono', monospace; font-size: 13px; background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 12px; }
  .lg-note { font-size: 13px; color: #7A6F68; line-height: 1.65; margin-top: 18px; }
</style>

<main class="lg-wrap">
  <p class="lg-eye">EduRankAI · Public credential ledger</p>
  <h1 class="lg-h1">Every certificate, <em>provably real</em>.</h1>
  <p class="lg-sub">Each EduRankAI certificate is a block in a hash chain — its block hash includes the previous block's hash, so tampering with any past record breaks every later one. Each block is signed with Ed25519. Anyone can verify a credential here without trusting us.</p>

  <div class="lg-strip">
    <div class="lg-stat"><div class="lg-stat-v">{stats.total}</div><div class="lg-stat-l">Certificates on chain</div></div>
    <div class="lg-stat"><div class="lg-stat-v">{stats.height}</div><div class="lg-stat-l">Chain height</div></div>
    <div class="lg-stat"><div class="lg-stat-v">SHA-256</div><div class="lg-stat-l">Hash function</div></div>
    <div class="lg-stat"><div class="lg-stat-v">Ed25519</div><div class="lg-stat-l">Signature scheme</div></div>
  </div>

  <form class="lg-search" id="verifyForm">
    <input id="certInput" type="text" placeholder="Enter a certificate number, e.g. ERA-CERT-..." />
    <button type="submit">Verify</button>
  </form>

  {pubKey && (
    <div class="lg-key">
      <h2>EduRankAI issuing public key · Ed25519</h2>
      <pre>{pubKey.trim()}</pre>
    </div>
  )}

  <div class="lg-chain">
    <h2>The chain</h2>
    {ledger.length === 0 ? (
      <div class="lg-empty">No certificates issued yet. Complete a course and the first block appears here.</div>
    ) : (
      ledger.map((b: any) => (
        <div class="lg-block">
          <div class="lg-block-idx">#{b.chain_index}</div>
          <div>
            <div class="lg-block-title">{b.course_title}</div>
            <div class="lg-block-sub">{b.holder_name || b.user_name || 'Learner'} · {fmt(b.issued_at)} · {b.cert_number}</div>
          </div>
          <div class="lg-block-hash">
            block {short(b.block_hash)}<br/>
            <a href={'/verify/' + b.cert_number}>verify &rarr;</a>
          </div>
        </div>
      ))
    )}
  </div>

  <p class="lg-note">The ledger root can additionally be anchored to a public blockchain on a periodic basis for third-party timestamping. The signing private key never leaves EduRankAI's server; only the public key above is published, which is all that is needed to verify any certificate.</p>
</main>

<script is:inline>
  document.getElementById('verifyForm').addEventListener('submit', function (e) {
    e.preventDefault();
    var v = document.getElementById('certInput').value.trim();
    if (v) window.location.href = '/verify/' + encodeURIComponent(v);
  });
</script>
</BaseLayout>
