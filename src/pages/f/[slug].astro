---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { isConfigured } from '@/lib/razorpay';

const { slug } = Astro.params;
if (!slug) return new Response('Not found', { status: 404 });
function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
const form: any = rows(await db.execute(sql`SELECT * FROM forms WHERE slug = ${slug} AND is_published = true LIMIT 1`))[0];

const fields = form && Array.isArray(form.fields) ? form.fields : [];
const feeChf = form ? (parseInt(form.fee_chf || 0) || 0) : 0;
const paymentsReady = isConfigured();
---
<BaseLayout title={form ? form.title : 'Form'} description={form?.description || 'EduRankAI form'}>
  <section class="px-[5vw] py-10 md:py-16 max-w-xl mx-auto">
    {!form ? (
      <div class="bg-white border border-ink/10 rounded-2xl p-8 text-center">
        <h1 class="font-display text-[1.5rem] font-semibold text-ink mb-2">Form not found</h1>
        <p class="text-[0.9rem] text-ink-soft">This form is unavailable or not published.</p>
      </div>
    ) : (
      <>
        <h1 class="font-display text-[clamp(1.7rem,4.5vw,2.4rem)] font-semibold text-ink leading-tight mb-2">{form.title}</h1>
        {form.description && <p class="text-[0.95rem] text-ink-soft leading-relaxed mb-2 whitespace-pre-wrap">{form.description}</p>}
        {feeChf > 0 && <p class="text-[0.85rem] text-ink-2 mb-5 inline-block bg-burn-pale border border-burn-dim rounded-lg px-3 py-1.5">Fee on submit: <strong>{feeChf} CHF</strong> (charged in INR via Razorpay)</p>}

        <form id="pubForm" class="flex flex-col gap-4 bg-white border border-ink/10 rounded-2xl p-5 md:p-6 mt-3">
          {fields.map((f: any) => (
            <div data-field data-key={f.key} data-type={f.type}>
              <label class="block text-[0.8rem] font-semibold text-ink mb-1.5">{f.label}{f.required && <span class="text-burn"> *</span>}</label>
              {f.type === 'textarea' ? (
                <textarea data-input rows="3" placeholder={f.placeholder || ''} class="pfi"></textarea>
              ) : f.type === 'select' ? (
                <select data-input class="pfi"><option value="">Choose...</option>{(f.options || []).map((o: string) => <option value={o}>{o}</option>)}</select>
              ) : f.type === 'radio' ? (
                <div class="flex flex-col gap-1.5">{(f.options || []).map((o: string) => <label class="flex items-center gap-2 text-[0.88rem] text-ink-2"><input type="radio" name={'r_' + f.key} value={o} class="accent-burn" /> {o}</label>)}</div>
              ) : f.type === 'checkbox' ? (
                <div class="flex flex-col gap-1.5">{(f.options || []).map((o: string) => <label class="flex items-center gap-2 text-[0.88rem] text-ink-2"><input type="checkbox" data-cb value={o} class="accent-burn" /> {o}</label>)}</div>
              ) : (
                <input data-input type={f.type === 'number' ? 'number' : f.type === 'email' ? 'email' : f.type === 'date' ? 'date' : f.type === 'phone' ? 'tel' : 'text'} placeholder={f.placeholder || ''} class="pfi" />
              )}
            </div>
          ))}
          <button type="submit" id="pubSubmit" class="bg-burn hover:bg-burn/90 text-white font-semibold py-3 rounded-lg text-[0.92rem] mt-1">{feeChf > 0 ? 'Pay ' + feeChf + ' CHF & submit' : 'Submit'}</button>
          <p id="pubErr" class="text-[0.82rem] text-red-700 text-center" style="display:none;"></p>
        </form>
        <div id="pubDone" style="display:none;" class="bg-leaf-bg/40 border border-leaf-border rounded-2xl p-6 text-center mt-3">
          <p class="font-semibold text-leaf mb-1">Submitted</p>
          <p id="pubDoneMsg" class="text-[0.9rem] text-ink-2"></p>
        </div>
      </>
    )}
  </section>

  {form && (
    <>
      {feeChf > 0 && paymentsReady && <script is:inline src="https://checkout.razorpay.com/v1/checkout.js"></script>}
      <script is:inline define:vars={{ slug, fee: feeChf }}>
        (function () {
          var form = document.getElementById('pubForm'); if (!form) return;
          var err = document.getElementById('pubErr'), btn = document.getElementById('pubSubmit');
          function showErr(m) { err.textContent = m; err.style.display = 'block'; }
          function done(msg) { form.style.display = 'none'; document.getElementById('pubDone').style.display = 'block'; document.getElementById('pubDoneMsg').textContent = msg || 'Your response has been recorded.'; }
          function collect() {
            var data = {};
            document.querySelectorAll('[data-field]').forEach(function (wrap) {
              var key = wrap.getAttribute('data-key'), type = wrap.getAttribute('data-type');
              if (type === 'radio') { var c = wrap.querySelector('input[type=radio]:checked'); data[key] = c ? c.value : ''; }
              else if (type === 'checkbox') { var arr = []; wrap.querySelectorAll('[data-cb]:checked').forEach(function (x) { arr.push(x.value); }); data[key] = arr; }
              else { var el = wrap.querySelector('[data-input]'); data[key] = el ? el.value.trim() : ''; }
            });
            return data;
          }
          form.addEventListener('submit', function (e) {
            e.preventDefault(); err.style.display = 'none';
            var prev = btn.textContent; btn.disabled = true; btn.textContent = 'Submitting...';
            fetch('/api/forms/submit', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ slug: slug, data: collect() }) })
              .then(function (r) { return r.json(); }).then(function (d) {
                if (!d.ok) { btn.disabled = false; btn.textContent = prev; showErr(d.error || 'Could not submit.'); return; }
                if (d.done) { done(d.message); return; }
                if (typeof Razorpay === 'undefined') { btn.disabled = false; btn.textContent = prev; showErr('Razorpay failed to load.'); return; }
                var rzp = new Razorpay({ key: d.keyId, amount: d.amountPaise, currency: d.currency, name: 'EduRankAI', description: d.formTitle || 'Form fee', order_id: d.orderId, prefill: d.prefill || {}, theme: { color: '#FF4F00' },
                  handler: function (resp) { btn.textContent = 'Verifying...';
                    fetch('/api/forms/confirm', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ razorpay_order_id: resp.razorpay_order_id, razorpay_payment_id: resp.razorpay_payment_id, razorpay_signature: resp.razorpay_signature }) })
                      .then(function (r) { return r.json(); }).then(function (c) { if (c.ok) { done(c.message); } else { btn.disabled = false; btn.textContent = prev; showErr(c.error || 'Verify failed.'); } })
                      .catch(function () { btn.disabled = false; btn.textContent = prev; showErr('Network error.'); });
                  },
                  modal: { ondismiss: function () { btn.disabled = false; btn.textContent = prev; } } });
                rzp.open();
              }).catch(function () { btn.disabled = false; btn.textContent = prev; showErr('Network error.'); });
          });
        })();
      </script>
    </>
  )}
  <style>.pfi{width:100%;padding:9px 12px;background:var(--cream-2,#f6f3ec);border:1px solid rgba(0,0,0,0.12);border-radius:8px;font-size:0.9rem;outline:none;}.pfi:focus{border-color:#FF4F00;}</style>
</BaseLayout>
