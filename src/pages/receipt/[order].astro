---
// /receipt/[order] — payment receipt / invoice for any captured payment.
// Access: the signed-in owner, a super admin, or a link carrying ?e=<email>
// matching the payment (the emailed receipt link uses that form).
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const rows = (r: any): any[] => (Array.isArray(r) ? r : (r?.rows || []));
const { order } = Astro.params;
if (!order) return Astro.redirect('/');

const pay = rows(await db.execute(sql`
  SELECT order_id, payment_id, amount_paise, currency, status, purpose, reference_type, reference_id, user_id, email, created_at, notes
  FROM payments WHERE order_id = ${order} LIMIT 1
`).catch(() => []))[0] as any;
if (!pay) return Astro.redirect('/');

// Itemised breakdown + waiver flag, from the payment's stored notes.
let notes: any = {};
try { notes = typeof pay.notes === 'string' ? JSON.parse(pay.notes) : (pay.notes || {}); } catch (_) { notes = {}; }
const bd = notes.breakdown || {};
const isWaiver = !!notes.waiver || /waiv/i.test(pay.purpose || '');
const waiverReason = notes.waiverReason || 'Application fee waived under our Talent Accessibility Initiative.';
const paidWithCredit = !!notes.credit;
const money = (paise: number) => (Number(paise || 0) / 100).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

const me: any = Astro.locals.user;
const eParam = (new URL(Astro.request.url).searchParams.get('e') || '').trim().toLowerCase();
const payEmail = String(pay.email || '').trim().toLowerCase();
const allowed =
  (me && me.role === 'super_admin') ||
  (me && pay.user_id && me.id === pay.user_id) ||
  (payEmail && eParam && eParam === payEmail);
if (!allowed) return Astro.redirect(me ? '/' : '/portal/login?next=' + encodeURIComponent('/receipt/' + order));

// Bill-to and line-item context from the application, when this payment
// belongs to one.
let app: any = null;
try {
  if (pay.reference_type === 'application' && pay.reference_id) {
    app = rows(await db.execute(sql`SELECT first_name, last_name, email, city, role_title_snapshot, application_number FROM applications WHERE id = ${pay.reference_id} LIMIT 1`))[0] || null;
  }
  if (!app && payEmail) {
    app = rows(await db.execute(sql`SELECT first_name, last_name, email, city, role_title_snapshot, application_number FROM applications WHERE LOWER(email) = ${payEmail} ORDER BY created_at DESC LIMIT 1`))[0] || null;
  }
} catch (_) {}

const purposeLabel = /application/i.test(pay.purpose || '')
  ? 'Application fee' + (app?.role_title_snapshot ? ' — ' + app.role_title_snapshot : '')
  : /enroll|course|test/i.test(pay.purpose || '')
    ? 'Programme enrollment'
    : 'Payment';

const amount = (Number(pay.amount_paise || 0) / 100).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const cur = pay.currency || 'INR';
const curSym = cur === 'INR' ? 'Rs. ' : cur + ' ';
const when = pay.created_at ? new Date(pay.created_at) : new Date();
const dateStr = when.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'Asia/Kolkata' });
const receiptNo = 'ERA-' + when.getFullYear() + '-' + String(pay.order_id || '').replace(/^order_/, '').slice(0, 10).toUpperCase();
const paid = String(pay.status || '').toLowerCase() === 'paid';
const billName = app ? ((app.first_name || '') + ' ' + (app.last_name || '')).trim() : (me?.name || '');
---
<BaseLayout title={'Receipt ' + receiptNo + ' - EduRankAI'} description="Payment receipt">
  <section class="px-[5vw] py-10 md:py-14 max-w-2xl mx-auto">
    <div id="receiptCard" class="bg-white border border-ink/10 rounded-2xl p-7 md:p-9">
      <div class="flex items-start justify-between gap-4 pb-6 border-b border-ink/8 mb-6">
        <div>
          <p class="font-display text-[1.4rem] font-bold text-ink">EduRank<span class="text-burn">AI</span></p>
          <p class="text-[0.75rem] text-ink-soft mt-1">edurankai.in · connect@edurankai.in</p>
        </div>
        <div class="text-right">
          <span class={'inline-block text-[0.68rem] font-bold uppercase tracking-wider border px-2.5 py-1 rounded-full ' + (paid ? 'bg-leaf-bg text-leaf border-leaf-border' : 'bg-burn-pale text-burn border-burn-dim')}>{paid ? 'Paid' : pay.status}</span>
          <p class="text-[0.78rem] font-mono text-ink-soft mt-2">{receiptNo}</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-7">
        <div>
          <p class="text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-1.5">Billed to</p>
          {billName && <p class="text-[0.92rem] font-semibold text-ink">{billName}</p>}
          <p class="text-[0.85rem] text-ink-2">{pay.email || app?.email || ''}</p>
          {app?.city && <p class="text-[0.85rem] text-ink-2">{app.city}, India</p>}
        </div>
        <div class="md:text-right">
          <p class="text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-1.5">Receipt date</p>
          <p class="text-[0.92rem] text-ink font-semibold">{dateStr}</p>
          {app?.application_number && <p class="text-[0.8rem] text-ink-soft mt-1">Application {app.application_number}</p>}
        </div>
      </div>

      {isWaiver && (
        <div class="flex items-start gap-2.5 bg-leaf-bg border border-leaf-border rounded-xl px-4 py-3.5 mb-6">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1c7a45" stroke-width="2" class="mt-0.5 shrink-0"><path d="M20 6L9 17l-5-5"/></svg>
          <div>
            <p class="text-[0.9rem] font-semibold text-leaf">Application fee waived — nothing was charged.</p>
            <p class="text-[0.82rem] text-leaf/90 leading-relaxed mt-0.5">{waiverReason}</p>
          </div>
        </div>
      )}

      <table class="w-full mb-7">
        <thead>
          <tr class="border-b border-ink/10">
            <th class="text-left text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft py-2">Description</th>
            <th class="text-right text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft py-2">Amount</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-ink/5">
            <td class="py-3 text-[0.92rem] text-ink">{purposeLabel}</td>
            <td class="py-3 text-[0.92rem] text-ink text-right font-mono">{curSym}{money(bd.baseInrPaise != null ? bd.baseInrPaise : pay.amount_paise)}</td>
          </tr>
          {bd.offerDiscountPaise > 0 && (
            <tr class="border-b border-ink/5">
              <td class="py-3 text-[0.92rem] text-leaf">Offer discount{bd.offerLabel ? ' — ' + bd.offerLabel : ''}</td>
              <td class="py-3 text-[0.92rem] text-leaf text-right font-mono">− {curSym}{money(bd.offerDiscountPaise)}</td>
            </tr>
          )}
          {isWaiver && (
            <tr class="border-b border-ink/5">
              <td class="py-3 text-[0.92rem] text-leaf">Talent Accessibility Initiative — fee waiver</td>
              <td class="py-3 text-[0.92rem] text-leaf text-right font-mono">− {curSym}{money(bd.baseInrPaise != null ? bd.baseInrPaise : 0)}</td>
            </tr>
          )}
          {paidWithCredit && !isWaiver && (
            <tr class="border-b border-ink/5">
              <td class="py-3 text-[0.92rem] text-ink-soft">Paid from wallet credit</td>
              <td class="py-3 text-[0.92rem] text-ink-soft text-right font-mono">− {curSym}{amount}</td>
            </tr>
          )}
          <tr>
            <td class="py-3 text-[0.95rem] font-bold text-ink">{isWaiver ? 'Amount paid' : 'Total (inclusive of all taxes)'}</td>
            <td class="py-3 text-[1.05rem] font-bold text-ink text-right font-mono">{curSym}{isWaiver ? '0.00' : amount}</td>
          </tr>
        </tbody>
      </table>

      <div class="bg-cream-2/70 border border-ink/8 rounded-xl p-4 text-[0.78rem] text-ink-2 leading-relaxed font-mono">
        <p>Order ID: {pay.order_id}</p>
        {pay.payment_id && <p>Payment ID: {pay.payment_id}</p>}
        <p>Method: {isWaiver ? 'Fee waiver (no charge)' : paidWithCredit ? 'Wallet credit' : 'Online (card / UPI / netbanking)'}</p>
      </div>

      <p class="text-[0.72rem] text-ink-soft mt-6 leading-relaxed">This is a computer-generated receipt from EduRankAI and does not require a signature. For questions about this payment, write to connect@edurankai.in quoting the receipt number.</p>
    </div>

    <div class="flex gap-3 mt-5 print:hidden" id="receiptActions">
      <button type="button" onclick="window.print()" class="bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.88rem]">Download / print receipt</button>
      <a href="/portal" class="bg-white border border-ink/15 text-ink font-semibold py-2.5 px-5 rounded-lg text-[0.88rem]">Back to portal</a>
    </div>
  </section>

  <style>
    @media print {
      header, footer, nav, #receiptActions, .era-fab, [id^="era-"] { display: none !important; }
      #receiptCard { border: none !important; border-radius: 0 !important; padding: 0 !important; }
      body { background: #fff !important; }
    }
  </style>
</BaseLayout>
