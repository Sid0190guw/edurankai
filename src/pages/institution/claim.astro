---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { heiInstitutions, institutionClaims } from '@/lib/db/schema';
import { eq, ilike, or, asc } from 'drizzle-orm';
import { randomBytes } from 'node:crypto';

let errorMsg = '';
let okMsg = '';
let claimToken = '';
let matchedInstitution: any = null;
let searchResults: any[] = [];
let step = 'search';

const url = new URL(Astro.request.url);
const preselectId = url.searchParams.get('id') || '';
if (preselectId) {
  const found = await db.select().from(heiInstitutions).where(eq(heiInstitutions.id, preselectId)).limit(1);
  if (found.length > 0) {
    matchedInstitution = found[0];
    step = 'form';
  }
}

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('_action') as string;

  if (action === 'search') {
    const q = (fd.get('q') as string || '').trim();
    if (q.length < 3) {
      errorMsg = 'Search at least 3 characters.';
    } else {
      const term = '%' + q + '%';
      searchResults = await db.select().from(heiInstitutions)
        .where(or(
          ilike(heiInstitutions.name, term),
          ilike(heiInstitutions.city, term)
        ))
        .orderBy(asc(heiInstitutions.name))
        .limit(20);
      step = 'search';
    }
  } else if (action === 'submit_claim') {
    const institutionId = (fd.get('institution_id') as string || '').trim();
    const contactName = (fd.get('contactName') as string || '').trim();
    const contactDesignation = (fd.get('contactDesignation') as string || '').trim();
    const contactEmail = (fd.get('contactEmail') as string || '').trim().toLowerCase();
    const contactPhone = (fd.get('contactPhone') as string || '').trim() || null;
    const letterheadUrl = (fd.get('letterheadUrl') as string || '').trim() || null;
    const additionalEvidenceUrl = (fd.get('additionalEvidenceUrl') as string || '').trim() || null;

    if (!institutionId || !contactName || !contactDesignation || !contactEmail) {
      errorMsg = 'Please complete all required fields.';
      const found = await db.select().from(heiInstitutions).where(eq(heiInstitutions.id, institutionId)).limit(1);
      if (found.length > 0) { matchedInstitution = found[0]; step = 'form'; }
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(contactEmail)) {
      errorMsg = 'Please enter a valid email.';
      const found = await db.select().from(heiInstitutions).where(eq(heiInstitutions.id, institutionId)).limit(1);
      if (found.length > 0) { matchedInstitution = found[0]; step = 'form'; }
    } else {
      // Check existing claim for this institution
      const existing = await db.select().from(institutionClaims).where(eq(institutionClaims.institutionId, institutionId)).limit(1);
      if (existing.length > 0 && existing[0].status === 'verified') {
        errorMsg = 'This institution has already been verified. For changes, contact hei@edurankai.in.';
        step = 'search';
      } else if (existing.length > 0 && existing[0].status === 'pending') {
        errorMsg = 'A claim for this institution is already under review. Reference: ' + existing[0].claimToken;
        step = 'search';
      } else {
        const token = randomBytes(20).toString('hex');
        await db.insert(institutionClaims).values({
          institutionId,
          claimToken: token,
          contactName, contactDesignation, contactEmail, contactPhone,
          letterheadUrl, additionalEvidenceUrl,
          status: 'pending'
        });
        claimToken = token;
        step = 'success';
      }
    }
  }
}
---
<BaseLayout title="Claim your institution - EduRankAI" description="Claim your institution on EduRankAI Truth Report. Verified institutions can submit data, respond to findings, and showcase verified evidence.">
  <section class="px-[5vw] py-12 md:py-16 max-w-3xl mx-auto">

    <div class="mb-8 text-center">
      <p class="eyebrow mb-3">Institution Verification</p>
      <h1 class="font-display text-3xl md:text-4xl font-semibold text-ink leading-tight mb-3">Claim your institution</h1>
      <p class="text-[0.92rem] text-ink-soft leading-relaxed max-w-xl mx-auto">Verified institutions can submit context data, respond to findings, and showcase evidence on the EduRankAI Truth Report.</p>
    </div>

    {errorMsg && (
      <div style="background:rgba(220,38,38,0.06);border:1px solid rgba(220,38,38,0.2);color:#b91c1c;font-size:0.85rem;padding:11px 14px;border-radius:8px;margin-bottom:18px;">
        {errorMsg}
      </div>
    )}

    {step === 'success' && (
      <div class="bg-leaf-bg/40 border border-leaf-border rounded-2xl p-6 md:p-7">
        <p class="text-[0.72rem] font-mono uppercase tracking-wider text-leaf font-bold mb-3">Claim received</p>
        <h2 class="font-display text-2xl font-semibold text-ink mb-3">Thank you. We will review and respond.</h2>
        <p class="text-[0.92rem] text-ink-2 leading-relaxed mb-4">Your claim is being reviewed by the EduRankAI editorial team. Verification typically takes 5-10 business days. We may contact you for additional evidence.</p>
        <div class="bg-white border border-leaf-border/40 rounded-lg p-4 my-4">
          <p class="text-[0.75rem] font-mono uppercase tracking-wider text-ink-soft mb-1">Reference number</p>
          <p class="font-mono text-ink font-bold text-[1.1rem]">{claimToken}</p>
        </div>
        <p class="text-[0.85rem] text-ink-soft">Save this reference number. Email <a href="mailto:hei@edurankai.in" class="text-burn font-semibold hover:underline">hei@edurankai.in</a> for questions.</p>
        <p class="text-[0.85rem] text-ink-soft mt-4">
          <a href="/hei" class="text-burn font-semibold hover:underline">&larr; Back to Truth Report</a>
        </p>
      </div>
    )}

    {step === 'search' && (
      <>
        <form method="POST" class="bg-white border border-ink/10 rounded-2xl p-6 md:p-7 mb-6">
          <input type="hidden" name="_action" value="search" />
          <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Search your institution</label>
          <div class="flex gap-2">
            <input type="text" name="q" required minlength="3" placeholder="e.g. IIT Bombay, Stanford, Oxford..." class="flex-1 px-4 py-3 border border-ink/15 rounded-lg text-[0.95rem] outline-none focus:border-burn bg-cream-2" />
            <button type="submit" class="bg-burn hover:bg-burn/90 text-white font-semibold px-6 py-3 rounded-lg text-[0.9rem]">Search</button>
          </div>
          <p class="text-[0.78rem] text-ink-soft mt-3">If your institution is not listed, email <a href="mailto:hei@edurankai.in" class="text-burn hover:underline">hei@edurankai.in</a> with your institution name and we will add it.</p>
        </form>

        {searchResults.length > 0 && (
          <div class="bg-cream-2 border border-ink/8 rounded-2xl p-4">
            <p class="text-[0.72rem] font-mono uppercase tracking-wider text-ink-soft font-bold mb-3 px-2">{searchResults.length} match{searchResults.length === 1 ? '' : 'es'}</p>
            <div class="flex flex-col gap-2">
              {searchResults.map((r) => (
                <a href={'/institution/claim?id=' + r.id} class="block bg-white border border-ink/10 hover:border-burn/40 rounded-lg p-4 transition-all">
                  <div class="flex justify-between items-start gap-3">
                    <div>
                      <p class="font-semibold text-ink text-[0.95rem]">{r.name}</p>
                      <p class="text-[0.82rem] text-ink-soft mt-1">{r.city ? r.city + ', ' : ''}{r.country}{r.establishedYear ? ' · Est. ' + r.establishedYear : ''}</p>
                    </div>
                    <span class="text-[0.78rem] font-semibold text-burn">Claim &rarr;</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </>
    )}

    {step === 'form' && matchedInstitution && (
      <div>
        <div class="bg-burn-pale border border-burn-dim rounded-2xl p-5 mb-5">
          <p class="text-[0.72rem] font-mono uppercase tracking-wider text-burn font-bold mb-2">Claiming</p>
          <p class="font-display text-xl font-semibold text-ink">{matchedInstitution.name}</p>
          <p class="text-[0.85rem] text-ink-soft mt-1">{matchedInstitution.city ? matchedInstitution.city + ', ' : ''}{matchedInstitution.country}</p>
          <p class="text-[0.78rem] text-ink-soft mt-3"><a href="/institution/claim" class="text-burn hover:underline">&larr; Different institution? Search again</a></p>
        </div>

        <form method="POST" class="bg-white border border-ink/10 rounded-2xl p-6 md:p-7 flex flex-col gap-5">
          <input type="hidden" name="_action" value="submit_claim" />
          <input type="hidden" name="institution_id" value={matchedInstitution.id} />

          <div>
            <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Your full name *</label>
            <input type="text" name="contactName" required class="w-full px-4 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
          </div>

          <div>
            <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Your designation *</label>
            <input type="text" name="contactDesignation" required placeholder="e.g. Registrar, Vice Chancellor, Public Relations Officer" class="w-full px-4 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
          </div>

          <div>
            <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Official email *</label>
            <input type="email" name="contactEmail" required placeholder="must be official institution domain" class="w-full px-4 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
            <p class="text-[0.72rem] text-ink-soft mt-1.5">Personal email addresses (gmail, yahoo, etc) will be rejected.</p>
          </div>

          <div>
            <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Phone (optional)</label>
            <input type="tel" name="contactPhone" class="w-full px-4 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
          </div>

          <div>
            <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Authorization letterhead URL</label>
            <input type="url" name="letterheadUrl" placeholder="https://... (link to scanned official letterhead, signed by competent authority)" class="w-full px-4 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
            <p class="text-[0.72rem] text-ink-soft mt-1.5">Upload to Google Drive / your institution's website / Dropbox and paste the link. Required for verification.</p>
          </div>

          <div>
            <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Additional evidence URL (optional)</label>
            <input type="url" name="additionalEvidenceUrl" placeholder="https://... (any supporting documents)" class="w-full px-4 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
          </div>

          <div class="bg-cream-2 border border-ink/8 rounded-lg p-4 text-[0.82rem] text-ink-2 leading-relaxed">
            <p class="font-semibold mb-2 text-ink">By submitting, you confirm:</p>
            <ul class="list-disc pl-5 space-y-1">
              <li>You are authorized to represent <strong>{matchedInstitution.name}</strong> in this capacity</li>
              <li>The information provided is accurate and verifiable</li>
              <li>You understand EduRankAI may contact you for additional evidence</li>
              <li>You agree to right-of-reply protocols on any findings</li>
            </ul>
          </div>

          <button type="submit" class="bg-burn hover:bg-burn/90 text-white font-semibold py-3 px-6 rounded-lg text-[0.95rem] mt-2">Submit claim for review</button>

          <p class="text-center text-[0.78rem] text-ink-soft pt-2">
            Questions? <a href="mailto:hei@edurankai.in" class="text-burn hover:underline">hei@edurankai.in</a>
          </p>
        </form>
      </div>
    )}

  </section>
</BaseLayout>