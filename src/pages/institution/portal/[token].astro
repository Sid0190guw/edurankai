---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { institutionClaims, heiInstitutions, institutionSubmissions, institutionSubmissionScores, heiDimensions } from '@/lib/db/schema';
import { eq, desc, asc } from 'drizzle-orm';

const { token } = Astro.params;
if (!token) return new Response('Not found', { status: 404 });

const claim = await db.select().from(institutionClaims).where(eq(institutionClaims.claimToken, token)).limit(1);
if (claim.length === 0) {
  return new Response('Invalid or expired access link.', { status: 404 });
}
const myClaim = claim[0];

const inst = await db.select().from(heiInstitutions).where(eq(heiInstitutions.id, myClaim.institutionId)).limit(1);
const institution = inst[0] || null;

if (myClaim.status !== 'verified') {
  // Show status page only
}

// All submissions for this institution
const submissions = await db.select().from(institutionSubmissions).where(eq(institutionSubmissions.institutionId, myClaim.institutionId)).orderBy(desc(institutionSubmissions.submittedAt));

// Recent submission scores breakdown
let latestScoreDetails: any[] = [];
if (submissions.length > 0) {
  latestScoreDetails = await db.select().from(institutionSubmissionScores).where(eq(institutionSubmissionScores.submissionId, submissions[0].id));
}

const dimensions = await db.select().from(heiDimensions).orderBy(asc(heiDimensions.sortOrder));
const dimMap = Object.fromEntries(dimensions.map(d => [d.id, d.title]));

function fmt(d: any) { return d ? new Date(d).toLocaleString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) : '-'; }
---
<BaseLayout title={'Institution Portal - ' + (institution ? institution.name : 'EduRankAI')} description="Verified institution portal for EduRankAI">
  <section class="px-[5vw] py-10 md:py-14 max-w-5xl mx-auto">

    <div class="mb-8">
      <p class="eyebrow mb-2">Institution Portal</p>
      <h1 class="font-display text-3xl md:text-4xl font-semibold text-ink leading-tight">{institution ? institution.name : 'Institution'}</h1>
      <p class="text-[0.88rem] text-ink-soft mt-2">Authenticated as <strong>{myClaim.contactName}</strong> · {myClaim.contactDesignation}</p>
    </div>

    {/* === STATUS BANNER === */}
    {myClaim.status === 'pending' && (
      <div class="bg-gold-bg/30 border border-gold-border rounded-2xl p-6 mb-6">
        <p class="text-[0.72rem] font-mono uppercase tracking-wider text-gold-deep font-bold mb-2">Verification pending</p>
        <p class="text-[0.92rem] text-ink-2 leading-relaxed">Your claim is under editorial review. You will be able to submit scores once verified. Typical turnaround: 5-10 business days.</p>
      </div>
    )}

    {myClaim.status === 'rejected' && (
      <div class="bg-red-50 border border-red-200 rounded-2xl p-6 mb-6">
        <p class="text-[0.72rem] font-mono uppercase tracking-wider text-red-700 font-bold mb-2">Claim rejected</p>
        <p class="text-[0.92rem] text-ink-2 leading-relaxed">{myClaim.decisionNotes || 'Your claim was not verified. Please contact hei@edurankai.in to discuss.'}</p>
      </div>
    )}

    {myClaim.status === 'verified' && (
      <>
        <div class="bg-leaf-bg/40 border border-leaf-border rounded-2xl p-6 mb-6">
          <p class="text-[0.72rem] font-mono uppercase tracking-wider text-leaf font-bold mb-2">Verified institution</p>
          <p class="text-[0.92rem] text-ink-2 leading-relaxed">You can now submit context data and score evidence. All submissions go through editorial review per the methodology.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-4 mb-6">
          <a href={'/institution/portal/' + token + '/submit'} class="bg-white border-2 border-burn/20 hover:border-burn rounded-2xl p-6 transition-all">
            <p class="text-[0.72rem] font-mono uppercase tracking-wider text-burn font-bold mb-2">Submit data</p>
            <h3 class="font-display text-xl font-semibold text-ink mb-2">Submit dimension scores + evidence</h3>
            <p class="text-[0.85rem] text-ink-soft leading-relaxed">Fill in your scores across the 7 dimensions, with evidence URLs for each. Editorial team reviews per-dimension.</p>
            <p class="text-[0.85rem] text-burn font-semibold mt-3">Open form &rarr;</p>
          </a>
          <div class="bg-cream-2 border border-ink/8 rounded-2xl p-6">
            <p class="text-[0.72rem] font-mono uppercase tracking-wider text-ink-soft font-bold mb-2">Right of reply</p>
            <h3 class="font-display text-xl font-semibold text-ink mb-2">Findings notices</h3>
            <p class="text-[0.85rem] text-ink-soft leading-relaxed">When editorial team publishes findings about your institution, you receive 30 days to respond. Findings appear here.</p>
            <p class="text-[0.85rem] text-ink-soft mt-3 italic">No active findings.</p>
          </div>
        </div>

        {submissions.length > 0 && (
          <div class="bg-white border border-ink/10 rounded-2xl p-6 mb-6">
            <h3 class="font-display text-lg font-semibold text-ink mb-4">Submission history</h3>
            <div class="flex flex-col gap-3">
              {submissions.map((s) => (
                <div class="bg-cream-2 border border-ink/8 rounded-lg p-4">
                  <div class="flex justify-between items-start gap-3 flex-wrap">
                    <div>
                      <p class="text-[0.78rem] text-ink-soft">Submitted {fmt(s.submittedAt)}</p>
                      <p class="text-[0.82rem] text-ink-2 mt-1">{s.submittedByEmail}</p>
                    </div>
                    <span class={'text-[0.7rem] uppercase tracking-wider font-bold px-2 py-1 rounded-full ' +
                      (s.submissionStatus === 'accepted' ? 'bg-leaf-bg text-leaf border border-leaf-border' :
                       s.submissionStatus === 'rejected' ? 'bg-red-50 text-red-700 border border-red-200' :
                       s.submissionStatus === 'partially_accepted' ? 'bg-gold-bg/40 text-gold-deep border border-gold-border' :
                       'bg-burn-pale text-burn border border-burn-dim')}>
                      {(s.submissionStatus || '').replace(/_/g, ' ')}
                    </span>
                  </div>
                  {s.notes && <p class="text-[0.82rem] text-ink-soft mt-2 italic">{s.notes}</p>}
                </div>
              ))}
            </div>

            {latestScoreDetails.length > 0 && (
              <div class="mt-5 pt-5 border-t border-ink/10">
                <p class="text-[0.78rem] font-mono uppercase tracking-wider text-ink-soft font-bold mb-3">Latest submission detail (per dimension)</p>
                <table class="w-full text-[0.85rem] text-ink-2">
                  <thead>
                    <tr class="border-b border-ink/10 text-left text-[0.72rem] uppercase tracking-wider text-ink-soft">
                      <th class="py-2">Dimension</th>
                      <th class="py-2">Proposed</th>
                      <th class="py-2">Decision</th>
                      <th class="py-2">Accepted</th>
                    </tr>
                  </thead>
                  <tbody>
                    {latestScoreDetails.map((d) => (
                      <tr class="border-b border-ink/5">
                        <td class="py-2">{dimMap[d.dimensionId] || d.dimensionId}</td>
                        <td class="py-2 font-mono">{d.proposedScore}</td>
                        <td class="py-2"><span class={'text-[0.72rem] uppercase ' + (d.adminDecision === 'accepted' ? 'text-leaf' : d.adminDecision === 'rejected' ? 'text-red-700' : 'text-burn')}>{d.adminDecision}</span></td>
                        <td class="py-2 font-mono">{d.adminAcceptedScore || '-'}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>
        )}
      </>
    )}

    <div class="text-center mt-8 text-[0.78rem] text-ink-soft">
      Questions? <a href="mailto:hei@edurankai.in" class="text-burn hover:underline font-semibold">hei@edurankai.in</a>
    </div>

  </section>
</BaseLayout>