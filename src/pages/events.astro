---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { events } from '@/lib/db/schema';
import { eq, ne, asc, desc, and, or } from 'drizzle-orm';

// Get upcoming events (future, status='upcoming')
const upcoming = await db.select().from(events)
  .where(eq(events.status, 'upcoming'))
  .orderBy(asc(events.startsAt));

// Get past events (status='past')
const past = await db.select().from(events)
  .where(eq(events.status, 'past'))
  .orderBy(desc(events.startsAt))
  .limit(10);

const MODE_LABELS: Record<string, string> = {
  online: 'Online',
  in_person: 'In-Person',
  hybrid: 'Hybrid'
};

function formatDate(d: any): string {
  if (!d) return 'TBD';
  return new Date(d).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
}

function formatDateTime(d: any): string {
  if (!d) return 'TBD';
  return new Date(d).toLocaleString('en-IN', { day: 'numeric', month: 'short', year: 'numeric', hour: 'numeric', minute: '2-digit' });
}
---
<BaseLayout title="Events - EduRankAI" description="Talks, workshops, and conversations from EduRankAI.">

  <section class="px-[5vw] py-12 md:py-20 max-w-4xl mx-auto">

    <div class="mb-10 md:mb-14">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-2">EVENTS</p>
      <h1 class="font-display text-[clamp(2.2rem,5.5vw,3.5rem)] font-semibold text-ink leading-[1.05] tracking-tight mb-4">
        Talks, workshops, <em class="italic text-burn font-medium">and conversations.</em>
      </h1>
      <p class="text-[1.05rem] text-ink-soft leading-relaxed max-w-2xl">
        We host events on AI safety, education research, frontier model evaluation, and the spaces in between. Most are small and intentional rather than broadcasts.
      </p>
    </div>

    {upcoming.length > 0 && (
      <div class="mb-12">
        <h2 class="font-display text-[1.4rem] font-semibold text-ink mb-5">Upcoming</h2>
        <div class="flex flex-col gap-4">
          {upcoming.map((e) => (
            <a href={'/events/' + e.slug} class="bg-white border border-ink/10 hover:border-burn-dim rounded-2xl p-5 md:p-6 transition-all block group">
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-3 mb-2">
                <h3 class="font-display text-[1.2rem] font-semibold text-ink leading-tight group-hover:text-burn transition-colors">{e.title}</h3>
                <div class="flex gap-2 shrink-0">
                  <span class="text-[0.65rem] font-bold uppercase tracking-wider bg-burn-pale text-burn border border-burn-dim px-2 py-0.5 rounded-full">Upcoming</span>
                  <span class="text-[0.65rem] font-bold uppercase tracking-wider bg-sky-bg text-sky border border-sky-border px-2 py-0.5 rounded-full">{MODE_LABELS[e.mode] || e.mode}</span>
                </div>
              </div>
              <p class="text-[0.85rem] text-ink-2 leading-relaxed mb-3">{e.description}</p>
              <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-[0.78rem] text-ink-soft">
                <span class="font-mono">{formatDateTime(e.startsAt)}</span>
                {e.location && <span>at {e.location}</span>}
                {e.capacity && <span>{e.capacity} spots</span>}
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    {upcoming.length === 0 && (
      <div class="bg-cream-2 border border-ink/10 rounded-2xl p-8 md:p-10 mb-12 text-center">
        <p class="font-display text-[1.1rem] font-semibold text-ink mb-1">No events scheduled right now</p>
        <p class="text-[0.88rem] text-ink-soft">Check back soon or follow us on LinkedIn for announcements.</p>
      </div>
    )}

    {past.length > 0 && (
      <div>
        <h2 class="font-display text-[1.4rem] font-semibold text-ink mb-5">Past events</h2>
        <div class="flex flex-col gap-2">
          {past.map((e) => (
            <a href={'/events/' + e.slug} class="bg-cream-2/40 border border-ink/8 hover:border-ink/20 rounded-xl p-4 transition-all block group">
              <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2">
                <div>
                  <p class="font-semibold text-ink text-[0.95rem] group-hover:text-burn transition-colors">{e.title}</p>
                  <p class="text-[0.75rem] text-ink-soft mt-0.5">{formatDate(e.startsAt)} - {MODE_LABELS[e.mode] || e.mode} - {e.location || ''}</p>
                </div>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-ink-soft group-hover:text-burn transition-colors hidden md:block"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

  </section>

</BaseLayout>
