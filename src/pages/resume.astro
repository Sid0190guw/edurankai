      // Print a CLEAN copy in its own window — the in-place visibility hack went
      // blank on some phones/browsers (display:none preview can't be un-hidden).
      function printResume(){
        render();
        var paper = document.getElementById('resumePaper'); if(!paper) return;
        var css=''; document.querySelectorAll('style').forEach(function(s){ css += s.textContent + '\n'; });
        var links=''; document.querySelectorAll('link[rel="stylesheet"]').forEach(function(l){ if(l.href) links += '<link rel="stylesheet" href="'+l.href+'">'; });
        // Print inside a hidden iframe (not a pop-up). @page{margin:0} is honoured
        // here, so the browser's own date / title / URL / page-number header &
        // footer have no margin to print into and disappear. Text stays selectable
        // (ATS-parseable) — we do NOT rasterise to an image.
        var doc='<!doctype html><html><head><meta charset="utf-8"><title>Resume</title>'+links
          +'<style>'+css+'</style>'
          +'<style>@page{size:A4;margin:0;} html,body{margin:0!important;padding:0!important;background:#fff;} '
          +'.rb-preview-wrap,.rb-form,.rb-mtoggle{display:none!important;} '
          +'.rb-paper{max-width:none!important;width:auto!important;box-shadow:none!important;border-radius:0!important;margin:0!important;padding:14mm!important;display:block!important;position:static!important;} '
          +'@media print{ body *,#resumePaper,#resumePaper *{visibility:visible!important;} #resumePaper{position:static!important;} }</style>'
          +'</head><body>'+paper.outerHTML+'</body></html>';
        var old=document.getElementById('rbPrintFrame'); if(old) old.remove();
        var ifr=document.createElement('iframe'); ifr.id='rbPrintFrame';
        ifr.setAttribute('aria-hidden','true');
        ifr.style.cssText='position:fixed;right:0;bottom:0;width:0;height:0;border:0;visibility:hidden;';
        document.body.appendChild(ifr);
        var idoc=ifr.contentWindow.document; idoc.open(); idoc.write(doc); idoc.close();
        var fired=false, go=function(){ if(fired) return; fired=true; try{ ifr.contentWindow.focus(); ifr.contentWindow.print(); }catch(_){ /* fall back to a pop-up if the iframe is blocked */ var w=window.open('','_blank'); if(w){ w.document.open(); w.document.write(doc); w.document.close(); setTimeout(function(){ try{ w.print(); }catch(_){} }, 400); } } };
        if (ifr.contentWindow.document.readyState==='complete') setTimeout(go, 350);
        ifr.onload=function(){ setTimeout(go, 250); };
        setTimeout(go, 900);
      }
