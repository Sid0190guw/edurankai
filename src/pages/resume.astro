        nm.addEventListener('input', render);
        var del = document.createElement('button'); del.type='button'; del.className='rm'; del.textContent='Remove section'; del.style.marginLeft='8px';
        del.addEventListener('click', function(){ sec.remove(); render(); });
        head.appendChild(nm); head.appendChild(del); sec.appendChild(head);
        var list = document.createElement('div'); list.className='rb-list'; list.setAttribute('data-secitems',''); list.style.marginTop='8px'; sec.appendChild(list);
        (items && items.length ? items : [{}]).forEach(function(it){ list.appendChild(rowTpl('custom', it)); });
        var add = document.createElement('button'); add.type='button'; add.className='rb-add'; add.textContent='+ Add entry'; add.style.marginTop='6px';
        add.addEventListener('click', function(){ list.appendChild(rowTpl('custom', {})); render(); });
        sec.appendChild(add);
