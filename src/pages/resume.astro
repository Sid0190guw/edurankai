      (src.customSections || []).forEach(function (s) { addSection(s.title, s.items); });
      function collectSections() {
        var out = [];
        document.querySelectorAll('#customSections .rb-sec').forEach(function(sec){
          var nameEl = sec.querySelector('[data-secname]'); var name = (nameEl && nameEl.value || '').trim();
          var items = [];
          sec.querySelectorAll('[data-secitems] .rb-row').forEach(function(r){
            var o={}, any=false; r.querySelectorAll('[data-k]').forEach(function(i){ var v=(i.value||'').trim(); o[i.getAttribute('data-k')]=v; if(v) any=true; }); if(any) items.push(o);
          });
          if (name && items.length) out.push({ title:name, items:items });
        });
        return out;
      }

      function collect(listId) {
        var out = [];
        document.querySelectorAll('#' + listId + ' .rb-row').forEach(function (r) {
          var o = {}, any = false;
          r.querySelectorAll('[data-k]').forEach(function (i) { var v=(i.value||'').trim(); o[i.getAttribute('data-k')]=v; if(v) any=true; });
          if (any) out.push(o);
        });
        return out;
      }
      function esc(s){ return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
      // Inline skill tags: write [[karate]] or [[karate|https://proof]] inside any
      // bullet/summary and it renders as a clickable tag IN CONTEXT (no separate
      // skills section needed). tokTags escapes the non-tag text via escFn.
      function tokTags(s, escFn, mk){
        var out='', re=/\[\[([^\]|]+)(?:\|([^\]]+))?\]\]/g, last=0, m;
        while ((m = re.exec(s))) { out += escFn(s.slice(last, m.index)); out += mk(m[1].trim(), (m[2]||'').trim()); last = re.lastIndex; }
        out += escFn(s.slice(last)); return out;
      }
      function inl(s){ return tokTags(s||'', esc, function(label, url){ return /^https?:\/\//i.test(url) ? '<a class="rp-tag" href="'+esc(url)+'" target="_blank" rel="noopener nofollow">'+esc(label)+'</a>' : '<span class="rp-tag">'+esc(label)+'</span>'; }); }
      function bullets(s){ var ls=(s||'').split(/\n+/).map(function(x){return x.trim();}).filter(Boolean); return ls.length>1 ? '<ul>'+ls.map(function(x){return '<li>'+inl(x)+'</li>';}).join('')+'</ul>' : (ls[0]?'<p>'+inl(ls[0])+'</p>':''); }
      // Skills/competencies: one per line (or comma-separated); optional proof link after " | ".
      function parseSkills(raw){
        var out=[];
        (raw||'').split(/\n/).forEach(function(line){
          line=(line||'').trim(); if(!line) return;
          var bar=line.indexOf('|');
          if(bar>=0){ var name=line.slice(0,bar).trim(); var url=line.slice(bar+1).trim(); if(name) out.push({name:name, url:/^https?:\/\//i.test(url)?url:''}); }
          else { line.split(',').forEach(function(n){ n=n.trim(); if(n) out.push({name:n, url:''}); }); }
        });
        return out;
      }

      function data() {
        return {
          level:(document.getElementById('f_level')||{}).value||'', template:curTpl,
          fullName:F.fullName.value, title:F.title.value, email:F.email.value, phone:F.phone.value,
          location:F.location.value, linkedin:F.linkedin.value, website:F.website.value, github:F.github.value,
          photoUrl:F.photoUrl.value, summary:F.summary.value, skills:F.skills.value,
          experience:collect('expList'), education:collect('eduList'), projects:collect('projList'), achievements:collect('achList'),
