      // ---- LaTeX (.tex) export — compiles on Overleaf ----
      function texEsc(s){ return (s||'').toString().replace(/\\/g,'\\textbackslash{}').replace(/([&%$#_{}])/g,'\\$1').replace(/~/g,'\\textasciitilde{}').replace(/\^/g,'\\textasciicircum{}'); }
      function texTagify(s){ return tokTags(s||'', texEsc, function(label,url){ return /^https?:\/\//i.test(url) ? '\\href{'+url.replace(/([%#&_{}])/g,'\\$1')+'}{'+texEsc(label)+'}' : texEsc(label); }); }
      function texBullets(s){ var ls=(s||'').split(/\n+/).map(function(x){return x.trim();}).filter(Boolean); if(!ls.length) return ''; return '\\begin{itemize}\n'+ls.map(function(x){return '  \\item '+texTagify(x);}).join('\n')+'\n\\end{itemize}'; }
      function genTex(d){
        var L=[];
        L.push('% Generated by the EduRankAI resume builder');
        L.push('\\documentclass[11pt,a4paper]{article}');
        L.push('\\usepackage[margin=1.7cm]{geometry}\\usepackage{enumitem}\\usepackage[hidelinks]{hyperref}\\usepackage{titlesec}\\usepackage{parskip}');
        L.push('\\titleformat{\\section}{\\large\\bfseries\\scshape}{}{0em}{}[\\titlerule]\\titlespacing{\\section}{0pt}{10pt}{4pt}');
        L.push('\\setlist[itemize]{leftmargin=1.3em,itemsep=1pt,topsep=2pt}\\pagestyle{empty}');
        L.push('\\begin{document}');
        L.push('\\begin{center}');
        L.push('{\\LARGE\\bfseries '+texEsc(d.fullName||'Your Name')+'}\\\\[3pt]');
        if(d.title) L.push('{\\large '+texEsc(d.title)+'}\\\\[3pt]');
        var contact=[d.email,d.phone,d.location,d.linkedin,d.website,d.github].filter(Boolean).map(texEsc).join(' $\\mid$ ');
        if(contact) L.push(contact);
        L.push('\\end{center}');
        if(d.summary){ L.push('\\section*{Summary}'); L.push(texTagify(d.summary)); }
        function block(title,arr,fmt){ if(!arr||!arr.length)return; L.push('\\section*{'+title+'}'); arr.forEach(fmt); }
        block('Experience',d.experience,function(e){ L.push('\\textbf{'+texEsc(e.title||'')+'}'+(e.org?' --- '+texEsc(e.org):'')+' \\hfill '+texEsc([e.location,e.period].filter(Boolean).join(', '))+'\\par'); var b=texBullets(e.detail); if(b)L.push(b); });
        block('Projects',d.projects,function(e){ L.push('\\textbf{'+texEsc(e.title||'')+'}'+(e.stack?' --- '+texEsc(e.stack):'')+' \\hfill '+texEsc(e.period||'')+'\\par'); var b=texBullets(e.detail); if(b)L.push(b); });
        block('Education',d.education,function(e){ L.push('\\textbf{'+texEsc(e.school||'')+'}'+(e.degree?' --- '+texEsc(e.degree):'')+' \\hfill '+texEsc([e.grade,e.period].filter(Boolean).join(', '))+'\\par'); });
        var sk=parseSkills(d.skills);
        if(sk.length){ L.push('\\section*{Skills}'); L.push(sk.map(function(x){ return x.url ? '\\href{'+x.url.replace(/([%#&_{}])/g,'\\$1')+'}{'+texEsc(x.name)+'}' : texEsc(x.name); }).join(', ')); }
        block('Achievements',d.achievements,function(e){ L.push('\\textbf{'+texEsc(e.title||'')+'} \\hfill '+texEsc(e.when||'')+'\\par'+(e.detail?' '+texEsc(e.detail):'')); });
        (d.customSections||[]).forEach(function(s){ block(s.title, s.items, function(e){ L.push('\\textbf{'+texEsc(e.title||'')+'}'+(e.sub?' --- '+texEsc(e.sub):'')+' \\hfill '+texEsc(e.period||'')+'\\par'); var b=texBullets(e.detail); if(b)L.push(b); }); });
        L.push('\\end{document}');
        return L.join('\n');
      }
      document.getElementById('texBtn').addEventListener('click', function(){
