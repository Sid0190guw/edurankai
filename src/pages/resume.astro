        var blob=new Blob([genTex(d)],{type:'application/x-tex'});
        var a=document.createElement('a'); a.href=URL.createObjectURL(blob);
        a.download=((d.fullName||'resume').replace(/[^a-z0-9]+/gi,'-').toLowerCase().replace(/^-+|-+$/g,'')||'resume')+'-resume.tex';
        document.body.appendChild(a); a.click();
