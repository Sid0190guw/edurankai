      (src.experience || []).forEach(function (e) { addRow('exp','expList', e); });
      (src.education || []).forEach(function (e) { addRow('edu','eduList', e); });
      (src.projects || []).forEach(function (e) { addRow('proj','projList', e); });
      (src.achievements || []).forEach(function (e) { addRow('ach','achList', e); });
      if (!(src.experience||[]).length) addRow('exp','expList',{});
      if (!(src.education||[]).length) addRow('edu','eduList',{});

      // ---- Custom sections (Conferences, Honours, Publications, Positions...) ----
      function sectionBlock(name, items) {
        var sec = document.createElement('div'); sec.className = 'rb-sec';
        sec.style.cssText = 'border:1px solid rgba(26,21,16,0.12);border-radius:12px;padding:12px;';
