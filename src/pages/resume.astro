---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getApplicantProfile } from '@/lib/applicant-profile';

// Public tool — login is NOT required. If an applicant is signed in we pre-fill
// from their profile so they don't retype anything.
const user = Astro.locals.user;
let prof: any = null;
if (user && user.role === 'applicant') { try { prof = await getApplicantProfile(user.id); } catch (_) {} }
const c = (prof?.common || {}) as any;
const links = (prof?.links || {}) as any;
const prefill = {
  fullName: (((c.firstName || '') + ' ' + (c.lastName || '')).trim()),
  title: prof?.headline || '',
  email: user?.email || c.email || '',
  phone: c.phone || '',
  location: c.currentCity || '',
  photoUrl: c.photoUrl || '',
  linkedin: links.linkedin || c.linkedin || '',
  website: links.portfolio || c.resumeLink || '',
  github: links.github || '',
  summary: prof?.bio || '',
  skills: (Array.isArray(prof?.skills) ? prof.skills : []).map((s: string) => {
    const u = ((prof?.links?.skills || {}) as any)[s];
    return u ? (s + ' | ' + u) : s;
  }).join('\n'),
  experience: Array.isArray(prof?.experience) ? prof.experience : [],
  education: Array.isArray(prof?.education) ? prof.education : [],
};
---
<BaseLayout title="Resume builder - EduRankAI" description="Build a clean, ATS-friendly resume in minutes. Free, no sign-up. Multiple professional templates.">
  <section class="rb-shell px-[5vw] py-6 max-w-[1300px] mx-auto">
    <div class="mb-5">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-1">Free tool · no sign-up</p>
      <h1 class="font-display text-[clamp(1.6rem,4vw,2.3rem)] font-semibold text-ink leading-tight">ATS resume <em class="italic text-burn font-medium">builder</em>.</h1>
      <p class="text-[0.9rem] text-ink-soft mt-2 leading-relaxed max-w-2xl">Pick a template, fill the form, download a clean PDF that applicant-tracking systems parse correctly. {user ? 'Pre-filled from your profile.' : 'No account needed.'}</p>
    </div>

    <div class="rb-grid">
      <!-- FORM -->
      <div class="rb-form">
        <div class="rb-card">
          <p class="rb-h">Import &amp; merge existing resumes</p>
          <p class="rb-tip">Upload one or more resumes (PDF or .txt). They're read in your browser — nothing is uploaded, no AI — and the content is merged into the builder below for you to refine.</p>
          <input id="importFiles" type="file" accept=".pdf,.txt,.md,text/plain,application/pdf" multiple style="display:none;" />
          <div class="flex gap-2 flex-wrap items-center">
            <button type="button" id="importPick" class="rb-tpl">Choose files</button>
            <button type="button" id="importGo" class="rb-tpl" style="background:#1a1510;color:#fff;border-color:#1a1510;opacity:0.5;" disabled>Import &amp; merge</button>
            <span id="importStatus" class="rb-tip" style="margin:0;"></span>
          </div>
        </div>
        <div class="rb-card">
          <label class="rb-l">Your level / situation</label>
          <select id="f_level" class="rb-i" style="margin-bottom:0;">
            <optgroup label="Career level">
              <option value="intern">Intern / Student</option>
              <option value="entry">Entry-level (0-2 yrs)</option>
              <option value="mid" selected>Mid-level (2-5 yrs)</option>
              <option value="senior">Senior (5-8 yrs)</option>
              <option value="manager">Manager / Team Lead</option>
              <option value="director">Director / VP</option>
              <option value="csuite">C-Suite / Executive</option>
            </optgroup>
            <optgroup label="Special situations">
              <option value="founder">Founder</option>
              <option value="freelance">Freelancer / Self-employed</option>
              <option value="academic">Academic CV (research)</option>
            </optgroup>
          </select>
          <div id="guidancePanel" class="rb-guide"></div>
          <p class="rb-tip" style="margin-top:8px;">Not sure of your level? Pick the closest — the guidance and layout adjust, and you can change it anytime.</p>
        </div>

        <div class="rb-card">
          <label class="rb-l">Template <span id="tplRec" class="rb-rec"></span></label>
          <div class="flex gap-2 flex-wrap">
            <button type="button" class="rb-tpl is-on" data-tpl="classic">Classic</button>
            <button type="button" class="rb-tpl" data-tpl="executive">Executive</button>
            <button type="button" class="rb-tpl" data-tpl="modern">Modern</button>
            <button type="button" class="rb-tpl" data-tpl="compact">Compact</button>
            <button type="button" class="rb-tpl" data-tpl="corporate">Corporate</button>
          </div>
          <label class="rb-l mt-3">Photo (optional — replaces a logo)</label>
          <div class="flex items-center gap-2">
            <input id="f_photoUrl" class="rb-i" style="flex:1;margin:0;" placeholder="Upload, or paste a direct image URL" />
            <input id="rbPhotoFile" type="file" accept="image/png,image/jpeg,image/webp" style="display:none;" />
            <button type="button" id="rbPhotoBtn" class="rb-tpl" style="white-space:nowrap;">Upload</button>
          </div>
          <p class="rb-tip" style="margin-top:6px;">Stays on your device and is embedded into the PDF. Square images look best.</p>
        </div>

        <div class="rb-card">
          <p class="rb-h">Header</p>
          <div class="rb-2"><div><label class="rb-l">Full name</label><input id="f_fullName" class="rb-i" /></div><div><label class="rb-l">Title / headline</label><input id="f_title" class="rb-i" placeholder="e.g. Chief Technology Officer" /></div></div>
          <div class="rb-2"><div><label class="rb-l">Email</label><input id="f_email" class="rb-i" /></div><div><label class="rb-l">Phone</label><input id="f_phone" class="rb-i" /></div></div>
          <div class="rb-2"><div><label class="rb-l">Location</label><input id="f_location" class="rb-i" /></div><div><label class="rb-l">LinkedIn</label><input id="f_linkedin" class="rb-i" /></div></div>
          <div class="rb-2"><div><label class="rb-l">Website</label><input id="f_website" class="rb-i" /></div><div><label class="rb-l">GitHub</label><input id="f_github" class="rb-i" /></div></div>
        </div>

        <div class="rb-card"><p class="rb-h">Summary</p>
          <p class="rb-tip" id="tip_summary">2-3 lines: who you are, your strongest proof point, and what you're aiming for.</p>
          <textarea id="f_summary" rows="4" class="rb-i" placeholder="2-3 lines on who you are and the value you bring."></textarea></div>

        <div class="rb-card">
          <div class="rb-hrow"><p class="rb-h">Experience</p><button type="button" data-add="exp" class="rb-add">+ Add</button></div>
          <p class="rb-tip">Tip: tag a skill right inside a bullet with <b>[[karate]]</b> or <b>[[karate|https://proof]]</b> — it becomes a clickable tag in context, so you don't need a separate skills list.</p>
          <p class="rb-tip" id="tip_exp">Each highlight: action verb + what you did + a measurable result. e.g. "Cut API latency 40% by caching hot paths." One per line.</p>
          <div id="expList" class="rb-list"></div>
        </div>
        <div class="rb-card">
          <div class="rb-hrow"><p class="rb-h">Education</p><button type="button" data-add="edu" class="rb-add">+ Add</button></div>
          <div id="eduList" class="rb-list"></div>
        </div>
        <div class="rb-card">
          <div class="rb-hrow"><p class="rb-h">Projects</p><button type="button" data-add="proj" class="rb-add">+ Add</button></div>
          <div id="projList" class="rb-list"></div>
        </div>
        <div class="rb-card"><p class="rb-h">Skills</p>
          <p class="rb-tip">One per line, or comma-separated. Add a proof link after " | " and the tag becomes clickable on your CV (e.g. link a competency to the project that proves it).</p>
          <textarea id="f_skills" rows="4" class="rb-i" style="resize:vertical;" placeholder={"Process improvement | https://github.com/you/project\nData-driven planning\nCritical thinking"}></textarea></div>
        <div class="rb-card">
          <div class="rb-hrow"><p class="rb-h">Achievements</p><button type="button" data-add="ach" class="rb-add">+ Add</button></div>
          <div id="achList" class="rb-list"></div>
        </div>

        <div class="rb-card">
          <div class="rb-hrow"><p class="rb-h">More sections</p><button type="button" id="addSectionBtn" class="rb-add">+ Add section</button></div>
          <p class="rb-tip">Add any section your field needs — Conferences, Key Courses, Honours &amp; Awards, Publications, Positions of Responsibility, Grants, Languages, Volunteering, Interests...</p>
          <div id="customSections" class="rb-list" style="gap:14px;"></div>
        </div>

        <div class="flex gap-2 sticky bottom-3">
          <button type="button" id="downloadBtn" class="flex-1 bg-burn hover:bg-burn/90 text-white font-semibold py-3 rounded-lg text-[0.92rem]">Download PDF</button>
          <button type="button" id="texBtn" class="bg-ink hover:bg-ink/90 text-white font-semibold py-3 px-4 rounded-lg text-[0.88rem]" title="Download LaTeX source for Overleaf">.tex</button>
        </div>
        <p class="text-[0.72rem] text-ink-soft text-center mt-1">Auto-saved on this device as you type. The final resume is saved with us only when you download. <a href="#" id="rbClearDraft" class="text-burn hover:underline">Start over</a> · <a href="/policy" class="text-burn hover:underline">Privacy</a>.</p>
      </div>

      <!-- PREVIEW -->
      <div class="rb-preview-wrap">
        <p class="text-[0.72rem] text-ink-soft text-center mb-2">Tip: you can click anywhere in the resume below and type to edit it directly. Editing a form field on the left refreshes the preview.</p>
        <div id="resumePaper" class="rb-paper tpl-classic">
          <div id="rp_content" contenteditable="true" spellcheck="false"></div>
        </div>
      </div>
    </div>

    <!-- Mobile edit/preview toggle -->
    <div class="rb-mtoggle">
      <button type="button" data-view="edit" class="is-on">Edit</button>
      <button type="button" data-view="preview">Preview</button>
      <button type="button" id="mDownload">Download</button>
    </div>
  </section>

  <style is:global>
    .rb-grid { display:grid; grid-template-columns:1fr; gap:20px; }
    @media (min-width:1000px) { .rb-grid { grid-template-columns:minmax(0,420px) 1fr; align-items:start; } .rb-preview-wrap { position:sticky; top:16px; } }
    .rb-card { background:#fff; border:1px solid rgba(26,21,16,0.1); border-radius:14px; padding:16px; margin-bottom:14px; }
    .rb-h { font-family:'Fraunces',Georgia,serif; font-size:1rem; font-weight:600; color:#1a1510; margin:0 0 10px; }
    .rb-hrow { display:flex; align-items:center; justify-content:space-between; margin-bottom:10px; }
    .rb-l { display:block; font-size:0.68rem; font-family:ui-monospace,monospace; text-transform:uppercase; letter-spacing:0.08em; color:#9a5b3f; font-weight:700; margin-bottom:5px; }
    .rb-i { width:100%; background:#fbf6f1; border:1px solid rgba(26,21,16,0.12); border-radius:8px; padding:9px 11px; font-size:0.88rem; color:#1a1510; outline:none; margin-bottom:8px; }
    .rb-i:focus { border-color:#FF4F00; background:#fff; }
    .rb-2 { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
    .rb-tpl { font-size:0.8rem; font-weight:600; padding:8px 14px; border-radius:8px; border:1px solid rgba(26,21,16,0.15); background:#fff; color:#1a1510; cursor:pointer; }
    .rb-tpl.is-on { background:#FF4F00; border-color:#FF4F00; color:#fff; }
    .rb-add { font-size:0.78rem; font-weight:700; color:#FF4F00; background:none; border:none; cursor:pointer; }
    .rb-list { display:flex; flex-direction:column; gap:8px; }
    .rb-row { border:1px solid rgba(26,21,16,0.1); border-radius:10px; padding:10px; display:grid; grid-template-columns:1fr 1fr; gap:6px; }
    .rb-row input, .rb-row textarea { width:100%; background:#fbf6f1; border:1px solid rgba(26,21,16,0.1); border-radius:7px; padding:7px 9px; font-size:0.82rem; outline:none; }
    .rb-row .full { grid-column:1/-1; }
    .rb-row .rm { grid-column:1/-1; text-align:right; font-size:0.72rem; color:#9a8f84; background:none; border:none; cursor:pointer; }

    /* ---- Paper / preview (A4-ish, ATS-friendly: real text, single column) ---- */
    .rb-paper { background:#fff; color:#111; width:100%; max-width:820px; margin:0 auto; box-shadow:0 10px 40px rgba(0,0,0,0.12); border-radius:6px; padding:42px 46px; font-family:'Inter',system-ui,sans-serif; font-size:13px; line-height:1.5; }
    .rb-paper #rp_content:focus { outline:none; }
    .rb-paper #rp_content { cursor:text; }
    .rb-paper h1 { font-size:25px; margin:0; letter-spacing:-0.01em; }
    .rb-paper .rp-title { font-size:13.5px; color:#333; margin:3px 0 0; }
    .rb-paper .rp-contact { font-size:11.5px; color:#444; margin-top:6px; display:flex; flex-wrap:wrap; gap:4px 12px; }
    .rb-paper .rp-head { display:flex; gap:18px; align-items:flex-start; border-bottom:2px solid #111; padding-bottom:12px; margin-bottom:14px; }
    .rb-paper .rp-photo { width:84px; height:84px; border-radius:6px; object-fit:cover; flex-shrink:0; border:1px solid #ddd; }
    .rb-paper section { margin-bottom:13px; }
    .rb-paper .rp-sec { font-size:11px; font-weight:800; letter-spacing:0.12em; text-transform:uppercase; color:#111; border-bottom:1px solid #bbb; padding-bottom:3px; margin-bottom:7px; }
    .rb-paper .rp-item { margin-bottom:8px; }
    .rb-paper .rp-item .rp-r1 { display:flex; justify-content:space-between; gap:10px; }
    .rb-paper .rp-item b { font-size:13px; }
    .rb-paper .rp-item .rp-sub { color:#444; font-size:12px; }
    .rb-paper .rp-item .rp-when { color:#666; font-size:11.5px; white-space:nowrap; }
    .rb-paper .rp-item p { margin:2px 0 0; font-size:12px; color:#222; }
    .rb-paper .rp-skills { display:flex; flex-wrap:wrap; gap:5px; }
    .rb-paper .rp-skills span { font-size:11.5px; background:#f1f1f1; border:1px solid #e2e2e2; border-radius:4px; padding:2px 8px; }
    .rb-paper .rp-skills a { font-size:11.5px; background:#f1f1f1; border:1px solid #d8c4b8; border-radius:4px; padding:2px 8px; color:#9a3b12; text-decoration:none; }
    .rb-paper .rp-skills a:hover { border-color:#FF4F00; }
    /* Inline skill tags inside bullets/summary ([[skill]] / [[skill|link]]) */
    .rb-paper .rp-tag { background:#eef3ff; border:1px solid #cdd9f0; border-radius:4px; padding:0 5px; font-size:0.94em; color:#1d4ed8; text-decoration:none; white-space:nowrap; }
    .rb-paper a.rp-tag:hover { border-color:#1d4ed8; }
    .rb-paper.tpl-corporate .rp-tag { background:none; border:0; padding:0; color:inherit; font-weight:600; border-bottom:1px dotted #888; border-radius:0; }
    .rb-paper.tpl-executive .rp-tag, .rb-paper.tpl-classic .rp-tag { background:#f2efe9; border-color:#e3ddd2; color:#0E2A47; }
    .rb-paper ul { margin:3px 0 0; padding-left:16px; } .rb-paper li { font-size:12px; margin-bottom:2px; }

    /* Executive variant */
    .rb-paper.tpl-executive { font-family:Georgia,'Times New Roman',serif; }
    .rb-paper.tpl-executive h1 { font-size:28px; color:#0E2A47; }
    .rb-paper.tpl-executive .rp-head { border-bottom:3px double #0E2A47; }
    .rb-paper.tpl-executive .rp-sec { color:#0E2A47; border-bottom-color:#0E2A47; }
    /* Modern variant — orange accent, clean sans */
    .rb-paper.tpl-modern h1 { color:#FF4F00; }
    .rb-paper.tpl-modern .rp-head { border-bottom:2px solid #FF4F00; }
    .rb-paper.tpl-modern .rp-sec { color:#FF4F00; border-bottom-color:#f4c9b5; letter-spacing:0.16em; }
    .rb-paper.tpl-modern .rp-skills span { background:#fff3ec; border-color:#fad7c5; }
    /* Compact variant — fits more on one page */
    .rb-paper.tpl-compact { font-size:11.5px; padding:30px 34px; }
    .rb-paper.tpl-compact h1 { font-size:21px; }
    .rb-paper.tpl-compact section { margin-bottom:9px; }
    .rb-paper.tpl-compact .rp-head { padding-bottom:9px; margin-bottom:10px; }
    .rb-paper.tpl-compact .rp-item { margin-bottom:5px; }
    /* Corporate variant — clean B&W, big bold name, uppercase ruled headers, multi-column skills */
    .rb-paper.tpl-corporate { font-family:'Inter',Arial,system-ui,sans-serif; color:#111; }
    .rb-paper.tpl-corporate .rp-head { border-bottom:1px solid #000; align-items:flex-end; }
    .rb-paper.tpl-corporate h1 { font-size:34px; font-weight:800; letter-spacing:-0.01em; text-transform:none; }
    .rb-paper.tpl-corporate .rp-title { font-size:12.5px; color:#222; }
    .rb-paper.tpl-corporate .rp-sec { font-size:12px; font-weight:800; letter-spacing:0.18em; color:#000; border-bottom:1px solid #000; padding-bottom:5px; margin-bottom:9px; }
    .rb-paper.tpl-corporate section { margin-bottom:16px; }
    .rb-paper.tpl-corporate .rp-item b { font-weight:700; }
    .rb-paper.tpl-corporate .rp-when { font-weight:700; color:#000; }
    .rb-paper.tpl-corporate .rp-skills { display:block; column-count:3; column-gap:24px; }
    .rb-paper.tpl-corporate .rp-skills span { display:block; background:none; border:0; padding:2px 0; font-size:12px; break-inside:avoid; }
    .rb-paper.tpl-corporate .rp-skills a { display:inline-block; background:none; border:0; padding:2px 0; font-size:12px; break-inside:avoid; color:#111; text-decoration:none; border-bottom:1px dotted #999; }
    @media (max-width:640px) { .rb-paper.tpl-corporate .rp-skills { column-count:2; } }

    .rb-tip { font-size:0.74rem; color:#8a7f74; line-height:1.5; margin:0 0 8px; }
    .rb-rec { font-size:0.66rem; color:#FF4F00; font-weight:700; text-transform:none; letter-spacing:0; margin-left:4px; }
    .rb-guide { margin-top:10px; background:#fbf6f1; border:1px solid rgba(26,21,16,0.08); border-radius:10px; padding:11px 13px; }
    .rb-guide .g-intro { font-size:0.82rem; color:#3a322b; line-height:1.55; margin:0 0 7px; }
    .rb-guide ul { margin:0; padding-left:16px; } .rb-guide li { font-size:0.78rem; color:#5b5249; line-height:1.5; margin-bottom:3px; }
    .rb-mtoggle { display:none; }
    @media (max-width:640px) {
      .rb-2 { grid-template-columns:1fr; }
      .rb-row { grid-template-columns:1fr; }
      .rb-paper { padding:24px 22px; font-size:12px; }
      .rb-paper h1 { font-size:21px; }
      .rb-paper .rp-head { gap:12px; }
      .rb-paper .rp-photo { width:64px; height:64px; }
    }
    @media (max-width:999px) {
      .rb-mtoggle { display:flex; position:fixed; bottom:14px; left:50%; transform:translateX(-50%); z-index:60; background:#1a1510; border-radius:999px; padding:4px; gap:3px; box-shadow:0 10px 30px rgba(0,0,0,0.28); }
      .rb-mtoggle button { border:0; background:none; color:#cfc7bf; font-size:0.8rem; font-weight:600; padding:8px 18px; border-radius:999px; cursor:pointer; }
      .rb-mtoggle button.is-on { background:#FF4F00; color:#fff; }
      .rb-mtoggle #mDownload { color:#FF9b6e; }
      .rb-shell .rb-preview-wrap { display:none; }
      .rb-shell.show-preview .rb-form { display:none; }
      .rb-shell.show-preview .rb-preview-wrap { display:block; }
      .rb-form { padding-bottom:64px; }
    }

    @media print {
      @page { size:A4; margin:0; }
      /* On phones the preview is display:none while editing — force it back for
         print, else the printed page is blank (visibility can't override display). */
      .rb-shell .rb-preview-wrap, .rb-shell.show-preview .rb-preview-wrap { display:block !important; }
      .rb-form, .rb-mtoggle { display:none !important; }
      body * { visibility:hidden !important; }
      #resumePaper, #resumePaper * { visibility:visible !important; }
      #resumePaper { position:absolute; left:0; top:0; width:100%; max-width:none; box-shadow:none; border-radius:0; margin:0; padding:14mm 14mm; }
      .era-fab, #eraToastStack { display:none !important; }
    }
  </style>

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
  <script is:inline define:vars={{ prefill }}>
    (function () {
      // Draft autosave lives in THIS device's cache only (localStorage) — never on
      // our servers, so it costs no storage/compute. The FINAL resume is saved with
      // us only when the user clicks Download (see the download handler).
      var DRAFT_KEY = 'aqt_resume_draft';
      var saved = null;
      try { saved = JSON.parse(localStorage.getItem(DRAFT_KEY) || 'null'); } catch (_) {}
      // Seed source: a saved draft from this device wins; else the profile prefill.
      var src = (saved && typeof saved === 'object') ? saved : {
        level: '', template: '', fullName: prefill.fullName, title: prefill.title, email: prefill.email,
        phone: prefill.phone, location: prefill.location, linkedin: prefill.linkedin, website: prefill.website,
        github: prefill.github, photoUrl: prefill.photoUrl, summary: prefill.summary, skills: prefill.skills,
        experience: prefill.experience || [], education: prefill.education || [], projects: [], achievements: [], customSections: []
      };
      var F = {};
      ['fullName','title','email','phone','location','linkedin','website','github','summary','skills','photoUrl'].forEach(function (k) {
        F[k] = document.getElementById('f_' + k);
        if (F[k] && src[k]) F[k].value = src[k];
      });
      var lvlEl0 = document.getElementById('f_level'); if (lvlEl0 && src.level) lvlEl0.value = src.level;

      function rowTpl(kind, item) {
        item = item || {};
        var fields = {
          exp:  [['title','Role / title',0],['org','Organisation',0],['period','Period (e.g. 2023-2025)',0],['location','Location',0],['detail','Highlights (one per line)',1]],
          edu:  [['school','Institution',0],['degree','Degree / field',0],['period','Period',0],['grade','Grade / GPA',0],['detail','Notes',1]],
          proj: [['title','Project',0],['link','Link',0],['period','When',0],['stack','Stack',0],['detail','What it does (one per line)',1]],
          ach:  [['title','Achievement',0],['when','Year',0],['detail','Detail',1]],
          custom: [['title','Title',0],['sub','Subtitle / org (optional)',0],['period','When (optional)',0],['detail','Details (one per line)',1]]
        }[kind];
        var w = document.createElement('div'); w.className = 'rb-row';
        fields.forEach(function (f) {
          var el = f[2] ? document.createElement('textarea') : document.createElement('input');
          if (f[2]) { el.rows = 2; el.className = 'full'; }
          el.setAttribute('data-k', f[0]); el.placeholder = f[1]; el.value = item[f[0]] || '';
          el.addEventListener('input', render);
          w.appendChild(el);
        });
        var rm = document.createElement('button'); rm.type='button'; rm.className='rm'; rm.textContent='Remove';
        rm.addEventListener('click', function () { w.remove(); render(); });
        w.appendChild(rm);
        return w;
      }
      function addRow(kind, listId, item) { document.getElementById(listId).appendChild(rowTpl(kind, item)); }
      var lists = { exp:'expList', edu:'eduList', proj:'projList', ach:'achList' };
      document.querySelectorAll('[data-add]').forEach(function (b) {
        b.addEventListener('click', function () { addRow(b.getAttribute('data-add'), lists[b.getAttribute('data-add')], {}); render(); });
      });
