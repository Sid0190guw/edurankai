      // ====== Import & merge existing resumes (client-side, no AI) ======
      function norm(s){ return (s||'').toLowerCase().replace(/[^a-z0-9]+/g,'').slice(0,40); }
      function sectionMap(){ return [
        [/\b(summary|profile|objective|about me|about)\b/i,'SUMMARY'],
        [/\b(technical skills|key competencies|core competenc\w*|competencies|skills)\b/i,'SKILLS'],
        [/\b(work experience|professional experience|employment|work history|experience)\b/i,'EXPERIENCE'],
        [/\b(education|academic)\b/i,'EDUCATION'],
        [/\b(projects?|course projects)\b/i,'PROJECTS'],
        [/\b(achievements?|honou?rs|awards)\b/i,'ACHIEVEMENTS'],
        [/\b(certificat\w*)\b/i,'CERTIFICATIONS'],
        [/\b(publications?)\b/i,'PUBLICATIONS'],
        [/\b(conferences?|symposia|workshops?)\b/i,'CONFERENCES'],
        [/\b(positions? of responsibility|leadership|extracurricular|activities|volunteer\w*)\b/i,'ACTIVITIES'],
        [/\b(languages?)\b/i,'LANGUAGES'],
        [/\b(interests?|hobbies)\b/i,'INTERESTS']
      ]; }
      function headerKey(L, SECT){
        if (!L || L.length > 45) return null;
        if (L.split(' ').length > 6) return null;
        for (var i=0;i<SECT.length;i++){ if (SECT[i][0].test(L)) return SECT[i][1]; }
        return null;
      }
      function splitEntries(arr){
        if(!arr || !arr.length) return [];
        var dateRe=/(\b(19|20)\d{2}\b|present|jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec)/i;
        var entries=[], cur=null;
        arr.forEach(function(L){
          if (dateRe.test(L) || !cur){ if(cur) entries.push(cur); cur={ title:L, detail:'' }; }
          else { cur.detail += (cur.detail?'\n':'') + L; }
        });
        if(cur) entries.push(cur);
        return entries;
      }
      function parseResume(text){
        text=(text||'').replace(/\r/g,'');
        var lines=text.split('\n').map(function(l){return l.replace(/\s+/g,' ').trim();}).filter(function(l){return l!=='';});
        var joined=lines.join('\n');
        var email=(joined.match(/[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}/i)||[''])[0];
        var phone=((joined.match(/(\+?\d[\d\s().-]{7,}\d)/)||[''])[0]||'').trim();
        var linkedin=(joined.match(/(https?:\/\/)?([a-z0-9.]*\.)?linkedin\.com\/[^\s)|,]+/i)||[''])[0];
        var github=(joined.match(/(https?:\/\/)?(www\.)?github\.com\/[^\s)|,]+/i)||[''])[0];
        var website=(joined.match(/https?:\/\/[^\s)|,]+/i)||[''])[0];
        if (website && /linkedin\.com|github\.com/i.test(website)) website='';
        var name=''; for (var i=0;i<Math.min(4,lines.length);i++){ var L=lines[i]; if(L.indexOf('@')<0 && !/\d{4}/.test(L) && L.length<60 && /[a-zA-Z]/.test(L)){ name=L; break; } }
        var SECT=sectionMap(), cur='__top', blocks={__top:[]};
        lines.forEach(function(L){ var k=headerKey(L,SECT); if(k){ cur=k; if(!blocks[cur]) blocks[cur]=[]; } else blocks[cur].push(L); });
        var summary=(blocks.SUMMARY||blocks.__top||[]).filter(function(L){ return L.indexOf('@')<0 && !/https?:\/\//i.test(L) && L!==name && !/^\+?\d[\d\s().-]{6,}/.test(L); }).slice(0,4).join(' ');
        var skills=[]; (blocks.SKILLS||[]).forEach(function(L){ L.split(/[,•|]/).forEach(function(s){ s=s.trim().replace(/^[-*]\s*/,''); if(s && s.length<44) skills.push(s); }); });
        var core={SUMMARY:1,SKILLS:1,EXPERIENCE:1,EDUCATION:1,PROJECTS:1,ACHIEVEMENTS:1,__top:1};
        var pretty={CERTIFICATIONS:'Certifications',PUBLICATIONS:'Publications',CONFERENCES:'Conferences, Symposia & Workshops',ACTIVITIES:'Positions of Responsibility',LANGUAGES:'Languages',INTERESTS:'Interests'};
        var custom=[]; Object.keys(blocks).forEach(function(k){ if(core[k]) return; var items=splitEntries(blocks[k]); if(items.length) custom.push({ title: pretty[k]||k.charAt(0)+k.slice(1).toLowerCase(), items: items.map(function(e){ return { title:e.title, sub:'', period:'', detail:e.detail }; }) }); });
        return { name:name, email:email, phone:phone, linkedin:linkedin, github:github, website:website, summary:summary, skills:skills,
          raw: lines.join('\n'),
          experience:splitEntries(blocks.EXPERIENCE), education:splitEntries(blocks.EDUCATION), projects:splitEntries(blocks.PROJECTS), achievements:splitEntries(blocks.ACHIEVEMENTS), custom:custom };
      }
      function mergeResumes(list){
        var m={ name:'',email:'',phone:'',linkedin:'',github:'',website:'',summary:'', raw:'', skills:[], experience:[], education:[], projects:[], achievements:[], custom:[] };
        list.forEach(function(r){
          if(r.raw){ m.raw += (m.raw?'\n\n':'')+r.raw; }
          ['name','email','phone','linkedin','github','website','summary'].forEach(function(k){ if(!m[k] && r[k]) m[k]=r[k]; });
          (r.skills||[]).forEach(function(s){ if(m.skills.map(norm).indexOf(norm(s))<0) m.skills.push(s); });
          ['experience','education','projects','achievements'].forEach(function(k){ (r[k]||[]).forEach(function(e){ if(!m[k].some(function(x){return norm(x.title)===norm(e.title) && norm(x.detail)===norm(e.detail);})) m[k].push(e); }); });
          (r.custom||[]).forEach(function(s){ var ex=null; m.custom.forEach(function(c){ if(norm(c.title)===norm(s.title)) ex=c; }); if(ex){ s.items.forEach(function(it){ if(!ex.items.some(function(x){return norm(x.title)===norm(it.title);})) ex.items.push(it); }); } else m.custom.push(s); });
        });
        return m;
      }
      async function readFileText(file){
        var nm=(file.name||'').toLowerCase();
        if (nm.indexOf('.pdf')>=0 || file.type==='application/pdf'){
          for (var w=0; w<25 && !window.pdfjsLib; w++){ await new Promise(function(r){ setTimeout(r,200); }); }
          if (!window.pdfjsLib) throw new Error('PDF reader could not load (network may be blocking it). Save your resume as .txt and import that instead.');
          try { window.pdfjsLib.GlobalWorkerOptions.workerSrc='https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js'; } catch(_){}
          var buf=await file.arrayBuffer(); var pdf=await window.pdfjsLib.getDocument({ data:buf }).promise; var t='';
          for (var p=1;p<=pdf.numPages;p++){ var pg=await pdf.getPage(p); var c=await pg.getTextContent(); t += c.items.map(function(it){return it.str;}).join(' ') + '\n'; }
          return t;
        }
        return await file.text();
      }
      function applyImport(m){
        function setIfEmpty(k,v){ if(F[k] && v && !(''+F[k].value).trim()) F[k].value=v; }
        setIfEmpty('fullName',m.name); setIfEmpty('email',m.email); setIfEmpty('phone',m.phone);
        setIfEmpty('linkedin',m.linkedin); setIfEmpty('github',m.github); setIfEmpty('website',m.website); setIfEmpty('summary',m.summary);
        if (m.skills.length && F.skills){ var ex=(F.skills.value||'').split('\n').map(function(x){return x.trim();}).filter(Boolean); m.skills.forEach(function(s){ if(ex.map(norm).indexOf(norm(s))<0) ex.push(s); }); F.skills.value=ex.join('\n'); }
        m.experience.forEach(function(e){ addRow('exp','expList',{ title:e.title, detail:e.detail }); });
        m.education.forEach(function(e){ addRow('edu','eduList',{ school:e.title, detail:e.detail }); });
        m.projects.forEach(function(e){ addRow('proj','projList',{ title:e.title, detail:e.detail }); });
        m.achievements.forEach(function(e){ addRow('ach','achList',{ title:e.title, detail:e.detail }); });
        (m.custom||[]).forEach(function(s){ addSection(s.title, s.items); });
        // If the PDF text was too unstructured to split, never drop it — give the
        // user the full extracted text in an editable section to reorganise.
        if ((m.raw||'').trim()) addSection('Imported text — review, move into sections, then delete', [{ title:'', sub:'', period:'', detail:(m.raw||'').slice(0, 8000) }]);
      }
      // Links inside a contenteditable preview do not navigate on click (the
      // browser treats the click as cursor placement). Open them explicitly so
      // proof-links and contact links are testable before download.
      (function linkClicks(){
        var rp = document.getElementById('rp_content');
        if (!rp) return;
        rp.addEventListener('click', function(e){
          var a = e.target && e.target.closest ? e.target.closest('a') : null;
          if (a && a.href) { e.preventDefault(); window.open(a.href, '_blank', 'noopener'); }
        });
      })();
      // Photo upload — read on-device as a data URL (no upload, no login).
      (function photoSetup(){
        var btn=document.getElementById('rbPhotoBtn'), fi=document.getElementById('rbPhotoFile');
        if(!btn||!fi) return;
        btn.addEventListener('click', function(){ fi.click(); });
        fi.addEventListener('change', function(){
          var f=fi.files&&fi.files[0]; if(!f) return;
          if(f.size>4*1024*1024){ alert('Image too large (max 4 MB).'); return; }
          var rd=new FileReader();
          rd.onload=function(){ if(F.photoUrl){ F.photoUrl.value=rd.result; render(); } };
          rd.readAsDataURL(f);
        });
      })();
      (function importSetup(){
        var picker=document.getElementById('importFiles'), pickBtn=document.getElementById('importPick'), goBtn=document.getElementById('importGo'), st=document.getElementById('importStatus');
        if(!picker||!goBtn) return;
        var files=[];
        pickBtn.addEventListener('click', function(){ picker.click(); });
        picker.addEventListener('change', function(){ files=Array.prototype.slice.call(picker.files||[]); goBtn.disabled=!files.length; goBtn.style.opacity=files.length?'1':'0.5'; st.textContent=files.length?(files.length+' file(s) selected'):''; });
        goBtn.addEventListener('click', async function(){
          if(!files.length) return; goBtn.disabled=true; st.textContent='Reading...';
          var texts=[], err='';
          for (var i=0;i<files.length;i++){ try { var tx=await readFileText(files[i]); if((tx||'').trim()) texts.push(tx); st.textContent='Read '+(i+1)+'/'+files.length; } catch(e){ err=(e&&e.message)||'Could not read a file'; } }
          if(!texts.length){ st.textContent = err || 'No text found — a scanned / image-only PDF has no text layer. Try a .txt or a text-based PDF.'; goBtn.disabled=false; return; }
          try { applyImport(mergeResumes(texts.map(parseResume))); render(); st.textContent='Imported '+texts.length+' file(s). Your text is in the "Imported text" section below — review & move into the right sections.'; }
          catch(e){ st.textContent='Import failed: '+((e&&e.message)||''); }
          goBtn.disabled=false;
        });
      })();

      render();
    })();
  </script>
</BaseLayout>
