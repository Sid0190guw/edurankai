---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getFounder, saveFounder, listBookings, setBookingHandled, deleteBooking, getRevenue, gcalLink, type FounderSettings } from '@/lib/founder';

// Founder Console — deliberately NOT part of the main admin panel. Reachable
// only by its URL and only for the single super-admin founder account.
const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login?next=/founder/admin');
const isFounder = user.role === 'super_admin' && (user.email || '').toLowerCase() === 'siddharth@edurankai.in';
if (!isFounder) return Astro.redirect('/');

let okMsg = '';
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('_action');
  try {
    if (action === 'save') {
      let availability: any;
      try { const aj = fd.get('availabilityJson'); if (aj) availability = JSON.parse(aj as string); } catch {}
      if (!availability || typeof availability !== 'object') availability = (await getFounder()).availability;
      const blockedDates = ((fd.get('blockedDates') as string) || '').split(/[,\n]/).map((s) => s.trim()).filter((s) => /^\d{4}-\d{2}-\d{2}$/.test(s));
      const p: FounderSettings = {
        name: (fd.get('name') as string || '').trim(),
        role: (fd.get('role') as string || 'Founder').trim(),
        tagline: (fd.get('tagline') as string || '').trim(),
        bio: (fd.get('bio') as string || '').trim(),
        photoUrl: (fd.get('photoUrl') as string || '').trim(),
        connectNumber: (fd.get('connectNumber') as string || '').trim(),
        connectMessage: (fd.get('connectMessage') as string || '').trim(),
        connectLabel: (fd.get('connectLabel') as string || 'Message me directly').trim(),
        calendarUrl: (fd.get('calendarUrl') as string || '').trim(),
        isPublic: fd.get('isPublic') === 'on',
        showInNav: fd.get('showInNav') === 'on',
        textPriceChf: Math.max(0, Number(fd.get('textPriceChf') || 0)),
        consultPriceChf: Math.max(0, Number(fd.get('consultPriceChf') || 0)),
        currency: (fd.get('currency') as string || 'CHF').trim().toUpperCase().slice(0, 3),
        gateText: fd.get('gateText') === 'on',
        gateConsult: fd.get('gateConsult') === 'on',
        timezone: (fd.get('timezone') as string || 'Asia/Kolkata').trim(),
        slotMinutes: Math.max(5, Number(fd.get('slotMinutes') || 30)),
        bufferMinutes: Math.max(0, Number(fd.get('bufferMinutes') || 0)),
        minNoticeHours: Math.max(0, Number(fd.get('minNoticeHours') || 12)),
        maxDaysAhead: Math.max(1, Number(fd.get('maxDaysAhead') || 30)),
        availability,
        blockedDates,
      };
      await saveFounder(p);
      okMsg = 'Saved.';
    } else if (action === 'handle') {
      await setBookingHandled(fd.get('id') as string, fd.get('to') === '1');
      okMsg = 'Updated.';
    } else if (action === 'delete') {
      await deleteBooking(fd.get('id') as string);
      okMsg = 'Deleted.';
    }
  } catch (e: any) { okMsg = 'Error: ' + (e?.cause?.message || e?.message || 'failed'); }
}

const f = await getFounder();
const bookings = await listBookings(300);
const rev = await getRevenue();
const inr = (paise: number) => '₹' + (paise / 100).toLocaleString('en-IN', { maximumFractionDigits: 0 });
const fmt = (d: any) => d ? new Date(d).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) : '—';
---
<BaseLayout title="Founder Console" description="" showNav={false} showFooter={false} noindex={true}>
  <div class="fc">
    <header class="fc-top">
      <div>
        <p class="fc-eyebrow">EduRankAI · Private</p>
        <h1 class="fc-h1">Founder <em>Console</em></h1>
      </div>
      <div class="fc-top-actions">
        <a href="/founder" target="_blank" class="fc-btn ghost">View public page</a>
        <a href="/admin" class="fc-btn ghost">Admin</a>
      </div>
    </header>

    {okMsg && <div class="fc-toast">{okMsg}</div>}

    <div class="fc-stats">
      <div class="fc-stat"><span class="fc-stat-k">Direct-line payments</span><span class="fc-stat-v">{rev.textPaid}</span><span class="fc-stat-s">{inr(rev.textRevenuePaise)}</span></div>
      <div class="fc-stat"><span class="fc-stat-k">Consultations paid</span><span class="fc-stat-v">{rev.consultPaid}</span><span class="fc-stat-s">{inr(rev.consultRevenuePaise)}</span></div>
      <div class="fc-stat accent"><span class="fc-stat-k">Total revenue</span><span class="fc-stat-v">{inr(rev.textRevenuePaise + rev.consultRevenuePaise)}</span><span class="fc-stat-s">{rev.requests} requests total</span></div>
      <div class="fc-stat"><span class="fc-stat-k">Awaiting you</span><span class="fc-stat-v">{bookings.filter((b:any)=>!b.handled).length}</span><span class="fc-stat-s">unhandled</span></div>
    </div>

    <div class="fc-grid">
      <!-- Settings -->
      <form method="POST" class="fc-card">
        <input type="hidden" name="_action" value="save" />
        <h2 class="fc-card-h">Your page &amp; direct line</h2>

        <p class="fc-sec">Identity</p>
        <div class="fc-2">
          <label>Name<input name="name" value={f.name} placeholder="Siddharth ..." /></label>
          <label>Role<input name="role" value={f.role} /></label>
        </div>
        <label>Tagline<input name="tagline" value={f.tagline} placeholder="Founder, EduRankAI" /></label>
        <label>Bio<textarea name="bio" rows="4" placeholder="A few lines about you...">{f.bio}</textarea></label>
        <label>Photo URL<input name="photoUrl" value={f.photoUrl} placeholder="https://..." /></label>

        <p class="fc-sec">Direct line (the messaging service is never named publicly)</p>
        <div class="fc-2">
          <label>Number with country code<input name="connectNumber" value={f.connectNumber} placeholder="9198XXXXXXXX" /></label>
          <label>Button label<input name="connectLabel" value={f.connectLabel} /></label>
        </div>
        <label>Prefilled message<textarea name="connectMessage" rows="2">{f.connectMessage}</textarea></label>

        <p class="fc-sec">Pricing — the serious-intent filter</p>
        <div class="fc-3">
          <label>Text price<input name="textPriceChf" type="number" step="1" min="0" value={f.textPriceChf} /></label>
          <label>Consultancy price<input name="consultPriceChf" type="number" step="1" min="0" value={f.consultPriceChf} /></label>
          <label>Currency<input name="currency" value={f.currency} maxlength="3" /></label>
        </div>
        <div class="fc-toggles">
          <label class="fc-check"><input type="checkbox" name="gateText" checked={f.gateText} /> Charge for the direct text line</label>
          <label class="fc-check"><input type="checkbox" name="gateConsult" checked={f.gateConsult} /> Charge for consultancy calls</label>
        </div>

        <p class="fc-sec">Availability — your live appointment calendar</p>
        <div class="fc-3">
          <label>Timezone<input name="timezone" value={f.timezone} placeholder="Asia/Kolkata" /></label>
          <label>Slot length (min)<input name="slotMinutes" type="number" min="5" step="5" value={f.slotMinutes} /></label>
          <label>Gap between (min)<input name="bufferMinutes" type="number" min="0" step="5" value={f.bufferMinutes} /></label>
        </div>
        <div class="fc-2">
          <label>Min notice (hours)<input name="minNoticeHours" type="number" min="0" value={f.minNoticeHours} /></label>
          <label>Bookable up to (days ahead)<input name="maxDaysAhead" type="number" min="1" value={f.maxDaysAhead} /></label>
        </div>
        <div id="availEditor" class="fc-avail" data-avail={JSON.stringify(f.availability)}></div>
        <input type="hidden" name="availabilityJson" id="availJson" value={JSON.stringify(f.availability)} />
        <label style="margin-top:12px;">Blocked dates (one-off, comma-separated YYYY-MM-DD)<input name="blockedDates" value={(f.blockedDates || []).join(', ')} placeholder="2026-08-15, 2026-08-16" /></label>

        <p class="fc-sec">Calendar mirror (optional)</p>
        <label>External scheduling link — shown only if you prefer it over the built-in calendar<input name="calendarUrl" value={f.calendarUrl} placeholder="https://..." /></label>

        <p class="fc-sec">Visibility</p>
        <div class="fc-toggles">
          <label class="fc-check"><input type="checkbox" name="isPublic" checked={f.isPublic} /> Page is live at /founder</label>
          <label class="fc-check"><input type="checkbox" name="showInNav" checked={f.showInNav} /> Show in site navigation (off for now)</label>
        </div>

        <button type="submit" class="fc-btn primary" style="margin-top:14px;width:100%;">Save changes</button>
      </form>

      <!-- Requests -->
      <div class="fc-card">
        <h2 class="fc-card-h">Requests for your time</h2>
        {bookings.length === 0 ? (
          <p class="fc-empty">No requests yet.</p>
        ) : (
          <div class="fc-reqs">
            {bookings.map((b: any) => {
              const cal = b.preferred ? gcalLink('Consultation with ' + (f.name || 'Founder'), new Date(b.preferred).toISOString(), b.duration_min || 30, 'edurankai.in/founder — ' + (b.name || '') + ' <' + (b.email || '') + '>' + (b.note ? '\n' + b.note : '')) : '';
              return (
                <div class={'fc-req' + (b.handled ? ' done' : '')}>
                  <div class="fc-req-top">
                    <span class={'fc-tag ' + b.kind}>{b.kind === 'text' ? 'DIRECT TEXT' : 'CONSULT'}</span>
                    {b.paid ? <span class="fc-tag paid">PAID {b.amount_paise ? inr(b.amount_paise) : ''}</span> : <span class="fc-tag unpaid">UNPAID</span>}
                    <span class="fc-req-when">{fmt(b.created_at)}</span>
                  </div>
                  <p class="fc-req-name">{b.name || '—'} <span class="fc-req-mail">{b.email}</span>{b.phone ? <span class="fc-req-mail"> · {b.phone}</span> : null}</p>
                  {b.preferred && <p class="fc-req-slot">Preferred: {fmt(b.preferred)} · {b.duration_min || 30} min</p>}
                  {b.note && <p class="fc-req-note">{b.note}</p>}
                  <div class="fc-req-actions">
                    {cal && <a href={cal} target="_blank" rel="noopener" class="fc-btn tiny">Add to calendar</a>}
                    {b.email && <a href={'mailto:' + b.email} class="fc-btn tiny ghost">Reply</a>}
                    <form method="POST" style="display:inline;"><input type="hidden" name="_action" value="handle" /><input type="hidden" name="id" value={b.id} /><input type="hidden" name="to" value={b.handled ? '0' : '1'} /><button type="submit" class="fc-btn tiny ghost">{b.handled ? 'Reopen' : 'Mark done'}</button></form>
                    <form method="POST" style="display:inline;" onsubmit="return confirm('Delete this request?');"><input type="hidden" name="_action" value="delete" /><input type="hidden" name="id" value={b.id} /><button type="submit" class="fc-btn tiny danger">Delete</button></form>
                  </div>
                </div>
              );
            })}
          </div>
        )}
      </div>
    </div>
  </div>

  <style is:global>
    .fc { max-width:1180px; margin:0 auto; padding:28px 5vw 80px; }
    .fc-top { display:flex; align-items:flex-end; justify-content:space-between; gap:14px; margin-bottom:22px; flex-wrap:wrap; }
    .fc-eyebrow { font-size:0.66rem; font-family:'Geist Mono',monospace; text-transform:uppercase; letter-spacing:0.18em; color:#FF4F00; font-weight:700; margin:0 0 4px; }
    .fc-h1 { font-family:'Fraunces',Georgia,serif; font-size:clamp(1.8rem,4vw,2.6rem); font-weight:600; color:var(--ink,#1a1510); margin:0; letter-spacing:-0.01em; }
    .fc-h1 em { color:#FF4F00; font-style:italic; }
    .fc-top-actions { display:flex; gap:8px; }
    .fc-toast { background:rgba(28,122,69,0.1); border:1px solid rgba(28,122,69,0.3); color:#1c7a45; border-radius:10px; padding:10px 14px; font-size:0.85rem; margin-bottom:18px; }
    .fc-stats { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:12px; margin-bottom:22px; }
    .fc-stat { background:#fff; border:1px solid rgba(26,21,16,0.1); border-radius:16px; padding:16px 18px; display:flex; flex-direction:column; gap:2px; }
    .fc-stat.accent { background:linear-gradient(135deg,#1a1510,#2a2018); border-color:#2a2018; }
    .fc-stat.accent .fc-stat-k, .fc-stat.accent .fc-stat-s { color:rgba(255,255,255,0.7); }
    .fc-stat.accent .fc-stat-v { color:#FF9066; }
    .fc-stat-k { font-size:0.7rem; text-transform:uppercase; letter-spacing:0.08em; color:#9a8f84; font-weight:700; }
    .fc-stat-v { font-family:'Fraunces',Georgia,serif; font-size:1.8rem; font-weight:600; color:var(--ink,#1a1510); line-height:1.1; }
    .fc-stat-s { font-size:0.74rem; color:#9a8f84; }
    .fc-grid { display:grid; grid-template-columns:1.1fr 1fr; gap:18px; align-items:start; }
    @media (max-width:900px){ .fc-grid { grid-template-columns:1fr; } }
    .fc-card { background:#fff; border:1px solid rgba(26,21,16,0.1); border-radius:18px; padding:20px 22px; }
    .fc-card-h { font-family:'Fraunces',Georgia,serif; font-size:1.15rem; font-weight:600; color:var(--ink,#1a1510); margin:0 0 12px; }
    .fc-sec { font-size:0.66rem; font-family:'Geist Mono',monospace; text-transform:uppercase; letter-spacing:0.12em; color:#FF4F00; font-weight:700; margin:16px 0 8px; }
    .fc-card label { display:block; font-size:0.72rem; font-weight:700; color:#6b5d49; margin-bottom:8px; text-transform:none; letter-spacing:0; }
    .fc-card input, .fc-card textarea { width:100%; margin-top:4px; background:#fbf6f1; border:1px solid rgba(26,21,16,0.12); border-radius:9px; padding:9px 11px; font-size:0.88rem; color:var(--ink,#1a1510); outline:none; font-family:inherit; }
    .fc-card input:focus, .fc-card textarea:focus { border-color:#FF4F00; background:#fff; }
    .fc-2 { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
    .fc-3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:12px; }
    @media (max-width:520px){ .fc-2,.fc-3 { grid-template-columns:1fr; } }
    .fc-toggles { display:flex; flex-direction:column; gap:8px; margin-top:4px; }
    .fc-check { display:flex; align-items:center; gap:9px; font-size:0.82rem; font-weight:500; color:var(--ink,#1a1510); }
    .fc-check input { width:auto; margin:0; accent-color:#FF4F00; }
    .fc-btn { display:inline-flex; align-items:center; justify-content:center; font-size:0.82rem; font-weight:600; padding:9px 16px; border-radius:9px; border:1px solid rgba(26,21,16,0.15); background:#fff; color:var(--ink,#1a1510); cursor:pointer; text-decoration:none; }
    .fc-btn.primary { background:#FF4F00; border-color:#FF4F00; color:#fff; }
    .fc-btn.ghost { background:transparent; }
    .fc-btn.tiny { font-size:0.72rem; padding:5px 11px; }
    .fc-btn.danger { color:#b3382c; border-color:rgba(179,56,44,0.3); background:rgba(179,56,44,0.06); }
    .fc-empty { color:#9a8f84; font-size:0.86rem; text-align:center; padding:30px; }
    .fc-reqs { display:flex; flex-direction:column; gap:10px; }
    .fc-req { border:1px solid rgba(26,21,16,0.1); border-radius:13px; padding:12px 14px; }
    .fc-req.done { opacity:0.6; }
    .fc-req-top { display:flex; align-items:center; gap:7px; flex-wrap:wrap; margin-bottom:6px; }
    .fc-tag { font-size:0.6rem; font-weight:800; letter-spacing:0.06em; padding:2px 8px; border-radius:100px; }
    .fc-tag.text { background:rgba(255,79,0,0.12); color:#c2410c; }
    .fc-tag.consult { background:rgba(26,21,16,0.08); color:#1a1510; }
    .fc-tag.paid { background:rgba(28,122,69,0.12); color:#1c7a45; }
    .fc-tag.unpaid { background:rgba(154,143,132,0.14); color:#6b5d49; }
    .fc-req-when { margin-left:auto; font-size:0.72rem; color:#9a8f84; }
    .fc-req-name { font-size:0.92rem; font-weight:700; color:var(--ink,#1a1510); margin:0; }
    .fc-req-mail { font-weight:400; color:#9a8f84; font-size:0.82rem; }
    .fc-req-slot { font-size:0.78rem; color:#c2410c; margin:3px 0 0; font-weight:600; }
    .fc-req-note { font-size:0.82rem; color:#4a4238; margin:5px 0 0; line-height:1.5; }
    .fc-req-actions { display:flex; gap:6px; flex-wrap:wrap; margin-top:9px; }
    .fc-req-actions form { margin:0; }
    .fc-avail { display:flex; flex-direction:column; gap:7px; margin-top:6px; }
    .fc-avail-day { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
    .fc-avail-day > b { width:42px; font-size:0.74rem; color:#6b5d49; }
    .fc-win { display:inline-flex; align-items:center; gap:4px; background:#fff3ee; border:1px solid #ffd4bc; border-radius:8px; padding:3px 5px 3px 9px; font-size:0.76rem; color:#c2410c; font-family:'Geist Mono',monospace; }
    .fc-win button { background:none; border:none; color:#c2410c; cursor:pointer; font-size:0.9rem; line-height:1; padding:0 2px; }
    .fc-win-add { background:none; border:1px dashed rgba(26,21,16,0.25); border-radius:8px; padding:3px 9px; font-size:0.74rem; color:#6b5d49; cursor:pointer; }
    .fc-win-add:hover { border-color:#FF4F00; color:#FF4F00; }
  </style>

  <script is:inline>
    (function () {
      var host = document.getElementById('availEditor'); if (!host) return;
      var hidden = document.getElementById('availJson');
      var WD = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
      var avail = {};
      try { avail = JSON.parse(host.getAttribute('data-avail') || '{}') || {}; } catch (e) { avail = {}; }
      function sync() { hidden.value = JSON.stringify(avail); }
      function render() {
        host.innerHTML = '';
        for (var d = 0; d < 7; d++) {
          (function (day) {
            var row = document.createElement('div'); row.className = 'fc-avail-day';
            var b = document.createElement('b'); b.textContent = WD[day]; row.appendChild(b);
            (avail[String(day)] || []).forEach(function (w, i) {
              var pill = document.createElement('span'); pill.className = 'fc-win';
              pill.appendChild(document.createTextNode(w[0] + '–' + w[1]));
              var x = document.createElement('button'); x.type = 'button'; x.textContent = '×';
              x.addEventListener('click', function () { avail[String(day)].splice(i, 1); if (!avail[String(day)].length) delete avail[String(day)]; sync(); render(); });
              pill.appendChild(x); row.appendChild(pill);
            });
            var add = document.createElement('button'); add.type = 'button'; add.className = 'fc-win-add'; add.textContent = '+ window';
            add.addEventListener('click', function () {
              var s = prompt('Start time (HH:MM, 24h):', '15:00'); if (!s || !/^\d{1,2}:\d{2}$/.test(s)) return;
              var e = prompt('End time (HH:MM, 24h):', '18:00'); if (!e || !/^\d{1,2}:\d{2}$/.test(e)) return;
              if (!avail[String(day)]) avail[String(day)] = [];
              avail[String(day)].push([s, e]); sync(); render();
            });
            row.appendChild(add);
            host.appendChild(row);
          })(d);
        }
      }
      render(); sync();
    })();
  </script>
</BaseLayout>
