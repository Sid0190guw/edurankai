---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { contentPages } from '@/lib/db/schema';
import { eq, and } from 'drizzle-orm';
import { marked } from 'marked';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/');

const found = await db.select().from(contentPages).where(and(eq(contentPages.slug, slug), eq(contentPages.isPublished, true))).limit(1);
if (found.length === 0) {
  return new Response('Not found', { status: 404 });
}

const page = found[0];
const bodyHtml = marked.parse(page.body || '');
const updated = new Date(page.updatedAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
const metaDesc = page.metaDescription || (page.body ? page.body.substring(0, 160).replace(/[#*_]/g, '') + '...' : page.title);
---
<BaseLayout title={page.title + ' - EduRankAI'} description={metaDesc}>
  <article class="px-[5vw] py-12 md:py-16 max-w-3xl mx-auto">
    <header class="mb-10 pb-8 border-b border-ink/10">
      <h1 class="font-display text-[clamp(2rem,5vw,3rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-3">{page.title}</h1>
      <p class="text-[0.75rem] text-ink-soft font-mono">Last updated {updated}</p>
    </header>
    <div class="prose-content text-[0.95rem] text-ink-2 leading-[1.85] font-light" set:html={bodyHtml}></div>
  </article>

  <style is:global>
    .prose-content h1 { font-family: var(--font-display); font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 600; color: var(--ink); line-height: 1.2; margin: 2em 0 0.7em; }
    .prose-content h2 { font-family: var(--font-display); font-size: clamp(1.25rem, 2.4vw, 1.6rem); font-weight: 600; color: var(--ink); line-height: 1.25; margin: 2em 0 0.6em; }
    .prose-content h3 { font-family: var(--font-display); font-size: 1.15rem; font-weight: 600; color: var(--ink); line-height: 1.3; margin: 1.8em 0 0.5em; }
    .prose-content p { margin: 1em 0; }
    .prose-content ul, .prose-content ol { margin: 1em 0; padding-left: 1.5em; }
    .prose-content li { margin: 0.4em 0; line-height: 1.75; }
    .prose-content ul li { list-style: disc; }
    .prose-content ol li { list-style: decimal; }
    .prose-content strong { color: var(--ink); font-weight: 600; }
    .prose-content em { font-style: italic; }
    .prose-content a { color: var(--burn); text-decoration: underline; text-underline-offset: 3px; }
    .prose-content a:hover { color: var(--burn-2); }
    .prose-content blockquote { border-left: 3px solid var(--burn); padding-left: 1.2em; margin: 1.4em 0; color: var(--ink-soft); font-style: italic; }
    .prose-content code { font-family: var(--font-mono); font-size: 0.88em; background: rgba(0,0,0,0.05); padding: 0.15em 0.4em; border-radius: 4px; }
    .prose-content pre { background: rgba(0,0,0,0.04); padding: 1em; border-radius: 8px; overflow-x: auto; margin: 1.4em 0; }
    .prose-content pre code { background: none; padding: 0; }
    .prose-content hr { border: 0; border-top: 1px solid rgba(0,0,0,0.08); margin: 2em 0; }
  </style>
</BaseLayout>