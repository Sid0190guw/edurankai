---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import {
  heiInstitutions,
  heiDimensions,
  heiInstitutionScores,
  heiEntityTypes,
  heiFindings,
  institutionClaims
} from '@/lib/db/schema';
import { eq, asc, and } from 'drizzle-orm';

const { slug } = Astro.params;
if (!slug) return new Response('Not found', { status: 404 });

const found = await db.select().from(heiInstitutions).where(eq(heiInstitutions.slug, slug)).limit(1);
const inst = found[0];
if (!inst) return new Response('Institution not found.', { status: 404 });

// Don't expose drafts publicly
if (!inst.isPublished) return new Response('This institution profile is not yet public.', { status: 404 });

// Entity type
let entityType: any = null;
if (inst.entityTypeId) {
  const et = await db.select().from(heiEntityTypes).where(eq(heiEntityTypes.id, inst.entityTypeId)).limit(1);
  entityType = et[0] || null;
}

// Dimension scores
const dimensions = await db.select().from(heiDimensions).orderBy(asc(heiDimensions.sortOrder));
const scores = await db.select().from(heiInstitutionScores).where(eq(heiInstitutionScores.institutionId, inst.id));
const scoreMap: Record<string, any> = {};
for (const s of scores) scoreMap[s.dimensionId] = s;

// Published findings only
const findings = await db.select().from(heiFindings).where(
  and(eq(heiFindings.institutionId, inst.id), eq(heiFindings.status, 'published'))
);

// Claim status (for transparency, not contact info)
const claim = await db.select().from(institutionClaims).where(eq(institutionClaims.institutionId, inst.id)).limit(1);
const isClaimed = claim.length > 0 && claim[0].status === 'verified';

function fmt(d: any) { return d ? new Date(d).toLocaleString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) : ''; }
---
<BaseLayout title={inst.name + ' - HEI Truth Report'} description={inst.name + ' on EduRankAI HEI Truth Report. Verified score and methodology breakdown.'}>
  <section class="px-[5vw] py-10 md:py-14 max-w-5xl mx-auto">

    <a href="/hei" class="text-[0.85rem] text-burn hover:underline font-semibold inline-block mb-5">&larr; HEI Truth Report</a>

    <!-- HEADER -->
    <div class="bg-white border border-ink/10 rounded-2xl p-7 md:p-9 mb-6">
      <div class="flex justify-between items-start gap-4 flex-wrap">
        <div style="flex:1;min-width:280px;">
          <p class="eyebrow mb-2">{entityType ? entityType.label : (inst.tier || 'Institution')}</p>
          <h1 class="font-display text-3xl md:text-4xl font-semibold text-ink leading-tight">{inst.name}</h1>
          <p class="text-[0.95rem] text-ink-soft mt-2">
            {inst.city ? inst.city + ', ' : ''}{inst.stateRegion ? inst.stateRegion + ', ' : ''}{inst.country}
            {inst.establishedYear && ' · Est. ' + inst.establishedYear}
          </p>

          <div class="flex flex-wrap gap-2 mt-4">
            {isClaimed && <span class="text-[0.7rem] uppercase tracking-wider font-bold px-2.5 py-1 rounded-full bg-leaf-bg text-leaf border border-leaf-border">✓ Verified institution</span>}
            {inst.websiteUrl && <a href={inst.websiteUrl} target="_blank" rel="noopener" class="text-[0.78rem] text-burn hover:underline font-semibold">Official website &rarr;</a>}
          </div>
        </div>

        {inst.truthScore && (
          <div style="text-align:right;">
            <div class="text-[0.7rem] font-mono uppercase tracking-wider text-ink-soft font-bold">Truth Score</div>
            <div class="font-display text-5xl font-semibold text-burn mt-1">{inst.truthScore}</div>
            {inst.truthRank && <div class="text-[0.78rem] text-ink-soft mt-1">Rank #{inst.truthRank}</div>}
          </div>
        )}
      </div>

      <!-- External rankings -->
      {(inst.nirfRank || inst.qsRank || inst.theRank) && (
        <div class="mt-6 pt-5 border-t border-ink/10 flex flex-wrap gap-5">
          {inst.nirfRank && <div><div class="text-[0.7rem] font-mono uppercase tracking-wider text-ink-soft font-bold">NIRF</div><div class="font-display text-xl font-semibold text-ink mt-0.5">#{inst.nirfRank}</div></div>}
          {inst.qsRank && <div><div class="text-[0.7rem] font-mono uppercase tracking-wider text-ink-soft font-bold">QS</div><div class="font-display text-xl font-semibold text-ink mt-0.5">#{inst.qsRank}</div></div>}
          {inst.theRank && <div><div class="text-[0.7rem] font-mono uppercase tracking-wider text-ink-soft font-bold">THE</div><div class="font-display text-xl font-semibold text-ink mt-0.5">#{inst.theRank}</div></div>}
        </div>
      )}
    </div>

    <!-- DIMENSION BREAKDOWN -->
    {!inst.truthScore && (
      <div class="bg-gold-bg/30 border border-gold-border rounded-2xl p-6 mb-6">
        <p class="text-[0.72rem] font-mono uppercase tracking-wider text-gold-deep font-bold mb-2">Pending evaluation</p>
        <p class="text-[0.92rem] text-ink-2 leading-relaxed">This institution is in the EduRankAI database but has not yet received a Truth Score. Score requires triangulated evidence per the 7-pipeline methodology.</p>
      </div>
    )}

    {inst.truthScore && (
      <div class="bg-white border border-ink/10 rounded-2xl p-7 mb-6">
        <h2 class="font-display text-2xl font-semibold text-ink mb-2">Dimension breakdown (v0.4)</h2>
        <p class="text-[0.85rem] text-ink-soft mb-5">Truth Score is the weighted average across these 7 dimensions.</p>

        <div class="flex flex-col gap-3">
          {dimensions.map((d) => {
            const s = scoreMap[d.id];
            return (
              <div class="bg-cream-2 border border-ink/8 rounded-lg p-4">
                <div class="flex justify-between items-start gap-3 flex-wrap mb-2">
                  <div style="flex:1;min-width:200px;">
                    <h3 class="font-semibold text-ink text-[0.95rem]">{d.title}</h3>
                    {d.subtitle && <p class="text-[0.78rem] text-ink-soft italic mt-0.5">{d.subtitle}</p>}
                  </div>
                  <div style="text-align:right;">
                    <div class="text-[0.62rem] font-mono uppercase tracking-wider text-ink-soft">Weight</div>
                    <div class="font-mono font-bold text-burn text-[0.92rem]">{d.weightPercent}%</div>
                  </div>
                </div>

                {s ? (
                  <div class="flex items-center gap-3 mt-3">
                    <div style="flex:1;">
                      <div class="h-2 bg-ink/10 rounded-full overflow-hidden">
                        <div style={'height:100%;background:#FF4F00;width:' + Math.min(100, parseFloat(s.score || '0')) + '%;'}></div>
                      </div>
                    </div>
                    <div class="font-mono font-bold text-ink text-[1rem]">{parseFloat(s.score).toFixed(1)}</div>
                  </div>
                ) : (
                  <p class="text-[0.78rem] text-ink-soft italic mt-2">No score yet</p>
                )}
              </div>
            );
          })}
        </div>
      </div>
    )}

    <!-- PUBLISHED FINDINGS -->
    {findings.length > 0 && (
      <div class="bg-white border border-ink/10 rounded-2xl p-7 mb-6">
        <h2 class="font-display text-2xl font-semibold text-ink mb-2">Published findings</h2>
        <p class="text-[0.85rem] text-ink-soft mb-5">Editorial findings about this institution, with right-of-reply response if provided.</p>

        <div class="flex flex-col gap-5">
          {findings.map((f) => (
            <div class="bg-cream-2 border-l-4 border-burn rounded-r-lg p-5">
              <p class="text-[0.72rem] font-mono uppercase tracking-wider text-burn font-bold mb-1">Published {fmt(f.publishedAt)}</p>
              <h3 class="font-display text-lg font-semibold text-ink mb-2">{f.findingTitle}</h3>
              <p class="text-[0.92rem] text-ink-2 leading-relaxed mb-3">{f.findingBody}</p>
              <p class="text-[0.82rem] text-ink-soft mb-3"><strong class="text-ink">Evidence:</strong> {f.evidenceSummary}</p>

              {f.institutionResponse && (
                <div class="mt-3 bg-leaf-bg/30 border-l-4 border-leaf rounded-r-lg p-3">
                  <p class="text-[0.7rem] font-mono uppercase tracking-wider text-leaf font-bold mb-1">Institution response · {fmt(f.institutionResponseAt)}</p>
                  <p class="text-[0.88rem] text-ink-2 leading-relaxed">{f.institutionResponse}</p>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- METHODOLOGY LINK -->
    <div class="text-center mt-10 mb-2">
      <p class="text-[0.85rem] text-ink-soft mb-3">How are these scores calculated?</p>
      <a href="/hei" class="inline-block bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-6 rounded-lg text-[0.9rem]">View HEI Methodology &rarr;</a>
    </div>

    {!isClaimed && (
      <div class="bg-cream-2 border border-ink/8 rounded-2xl p-5 mt-6 text-center">
        <p class="text-[0.85rem] text-ink-2 mb-2">Represent <strong>{inst.name}</strong>?</p>
        <a href={'/hei/register?id=' + inst.id} class="inline-block text-burn font-semibold hover:underline text-[0.9rem]">Claim this institution &rarr;</a>
      </div>
    )}

  </section>
</BaseLayout>