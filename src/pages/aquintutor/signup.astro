---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

if (Astro.locals.user) return Astro.redirect('/aquintutor/dashboard');

let errorMsg = '';
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const email = (fd.get('email') as string || '').trim().toLowerCase();
  const name = (fd.get('name') as string || '').trim();
  const password = (fd.get('password') as string) || '';
  const consent = fd.get('consent');
  if (!consent) errorMsg = 'You must agree to the Privacy Policy and Terms of Service.';
  else if (!email || !name || !password) errorMsg = 'All fields are required.';
  else if (password.length < 8) errorMsg = 'Password must be at least 8 characters.';
  else if (!/.+@.+\..+/.test(email)) errorMsg = 'Please enter a valid email.';
  else {
    try {
      const { db } = await import('@/lib/db');
      const { users } = await import('@/lib/db/schema');
      const { hashPassword } = await import('@/lib/auth/password');
      const { generateSessionToken, createSession } = await import('@/lib/auth/session');
      const { setSessionCookie } = await import('@/lib/auth/cookie');
      const { eq } = await import('drizzle-orm');

      const existing = await db.select({ id: users.id }).from(users).where(eq(users.email, email)).limit(1);
      if (existing.length > 0) {
        errorMsg = 'An account with this email already exists. Sign in instead.';
      } else {
        const passwordHash = await hashPassword(password);
        const inserted = await db.insert(users).values({
          email, name, passwordHash, role: 'applicant', isActive: true,
          consentGivenAt: new Date(), consentIp: Astro.clientAddress
        }).returning({ id: users.id });
        try { const { pushNotify } = await import('@/lib/push'); await pushNotify.newUser(name, inserted[0].id); } catch (_) {}
        const token = generateSessionToken();
        const session = await createSession(token, inserted[0].id, {
          userAgent: Astro.request.headers.get('user-agent') || undefined,
          ipAddress: Astro.clientAddress
        });
        setSessionCookie(Astro.cookies, token, session.expiresAt);
        // New learners set up their tier + goal first (Phase-0 onboarding gate).
        return Astro.redirect('/aquintutor/onboarding');
      }
    } catch (e: any) {
      errorMsg = 'Could not create account. Please try again.';
    }
  }
}
---
<AquintutorLayout title="Apply for admission" description="Apply for admission to AquinTutor - the frontier research institution of EduRankAI. Vedic sciences, ASI, quantum technology, advanced computing." noindex={true}>

  <section style="border-bottom:1px solid var(--rule); position:relative; overflow:hidden;">
    <div aria-hidden="true" style="position:absolute; right:-60px; top:60px; opacity:0.05; pointer-events:none;" class="hide-mobile">
      <svg width="320" height="320" viewBox="0 0 100 100" fill="none">
        <circle cx="50" cy="50" r="44" stroke="var(--ink)" stroke-width="0.4"/>
        <path d="M30 50 L45 65 L70 35" stroke="var(--ink)" stroke-width="0.4"/>
      </svg>
    </div>
    <div style="max-width:540px; margin:0 auto; padding:72px 28px 64px; position:relative; z-index:1;">

      <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 14px;">Admission &middot; by application</p>

      <h1 class="font-display" style="font-size:clamp(2rem, 5vw, 3.5rem); line-height:1.02; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--ink);">
        Apply to the<br/>
        <span style="font-style:italic; font-weight:300; color:var(--ink-500);">institution.</span>
      </h1>

      <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.1rem, 1.5vw, 1.35rem); line-height:1.5; color:var(--ink-500); margin:22px 0 0; max-width:36rem;">
        A frontier research institution working in Vedic sciences, artificial super-intelligence, quantum technology and advanced computing. Faculty-authored curriculum, proctored examinations, verifiable credentials. Two intakes a year.
      </p>

      {errorMsg && (
        <div style="background:rgba(160,66,30,0.08); border:1px solid rgba(160,66,30,0.4); color:var(--rust); padding:12px 16px; border-radius:8px; margin-top:24px; font-family:'Inter Tight',sans-serif; font-size:13.5px;">{errorMsg}</div>
      )}

      <form method="POST" style="margin-top:32px; display:flex; flex-direction:column; gap:18px;">
        <div>
          <label for="name" style="display:block; font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); margin-bottom:6px; font-weight:600;">Full name</label>
          <input id="name" name="name" type="text" autocomplete="name" required autofocus maxlength="200" style="width:100%; padding:11px 14px; border:1px solid var(--rule); border-radius:8px; background:var(--paper); font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink); outline:none;" />
        </div>
        <div>
          <label for="email" style="display:block; font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); margin-bottom:6px; font-weight:600;">Email</label>
          <input id="email" name="email" type="email" autocomplete="email" required maxlength="255" style="width:100%; padding:11px 14px; border:1px solid var(--rule); border-radius:8px; background:var(--paper); font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink); outline:none;" />
        </div>
        <div>
          <label for="password" style="display:block; font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); margin-bottom:6px; font-weight:600;">Password</label>
          <input id="password" name="password" type="password" autocomplete="new-password" required minlength="8" style="width:100%; padding:11px 14px; border:1px solid var(--rule); border-radius:8px; background:var(--paper); font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink); outline:none;" />
          <p style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500); margin:6px 0 0;">At least 8 characters.</p>
        </div>
        <label style="display:flex; align-items:flex-start; gap:10px; font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink-500); line-height:1.5; margin-top:6px;">
          <input type="checkbox" name="consent" required style="margin-top:4px; accent-color:var(--rust);" />
          <span>I agree to the <a href="/p/privacy" style="color:var(--ink); text-decoration:underline;">Privacy Policy</a> and <a href="/p/terms" style="color:var(--ink); text-decoration:underline;">Terms of Service</a>.</span>
        </label>
        <button type="submit" style="margin-top:8px; background:var(--ink); color:var(--sand-50); padding:13px 24px; border:none; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; cursor:pointer; align-self:flex-start;">Submit application &rarr;</button>
      </form>

      <div style="margin-top:40px; padding-top:24px; border-top:1px solid var(--rule); display:flex; flex-wrap:wrap; gap:12px; align-items:center; justify-content:space-between;">
        <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:15px; color:var(--ink-500); margin:0;">Already on the register?</p>
        <a href="/aquintutor/login" style="background:transparent; color:var(--ink); padding:10px 18px; border-radius:6px; border:1px solid var(--ink); font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; text-decoration:none;">Sign in &rarr;</a>
      </div>
    </div>
  </section>

</AquintutorLayout>
