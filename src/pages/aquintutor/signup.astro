---
import '@/styles/aquintutor-academy.css';

if (Astro.locals.user) return Astro.redirect('/aquintutor');

let errorMsg = '';
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const email = (fd.get('email') as string || '').trim().toLowerCase();
  const name = (fd.get('name') as string || '').trim();
  const password = (fd.get('password') as string) || '';
  const consent = fd.get('consent');
  if (!consent) errorMsg = 'You must agree to the Privacy Policy and Terms of Service.';
  else if (!email || !name || !password) errorMsg = 'All fields are required.';
  else if (password.length < 8) errorMsg = 'Password must be at least 8 characters.';
  else if (!/.+@.+\..+/.test(email)) errorMsg = 'Please enter a valid email.';
  else {
    try {
      const { db } = await import('@/lib/db');
      const { users } = await import('@/lib/db/schema');
      const { hashPassword } = await import('@/lib/auth/password');
      const { generateSessionToken, createSession } = await import('@/lib/auth/session');
      const { setSessionCookie } = await import('@/lib/auth/cookie');
      const { eq } = await import('drizzle-orm');

      const existing = await db.select({ id: users.id }).from(users).where(eq(users.email, email)).limit(1);
      if (existing.length > 0) {
        errorMsg = 'An account with this email already exists. Sign in instead.';
      } else {
        const passwordHash = await hashPassword(password);
        const inserted = await db.insert(users).values({
          email, name, passwordHash, role: 'applicant', isActive: true,
          consentGivenAt: new Date(), consentIp: Astro.clientAddress
        }).returning({ id: users.id });
        try { const { pushNotify } = await import('@/lib/push'); await pushNotify.newUser(name, inserted[0].id); } catch (_) {}
        const token = generateSessionToken();
        const session = await createSession(token, inserted[0].id, {
          userAgent: Astro.request.headers.get('user-agent') || undefined,
          ipAddress: Astro.clientAddress
        });
        setSessionCookie(Astro.cookies, token, session.expiresAt);
        return Astro.redirect('/aquintutor');
      }
    } catch (e: any) {
      errorMsg = 'Could not create account. Please try again.';
    }
  }
}
---
<!doctype html>
<html lang="en" class="academy editorial">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Enrol - AquinTutor</title>
  <meta name="description" content="Enrol in AquinTutor - from 1 CHF. The virtual institution of EduRankAI." />
  <meta name="robots" content="noindex" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="theme-color" content="#FBFAF4" />
</head>
<body class="academy editorial grain">

  <header style="border-bottom:1px solid var(--rule); background:rgba(251,250,244,0.85); backdrop-filter:blur(6px); position:relative; z-index:20;">
    <div style="border-bottom:1px solid rgba(11,14,20,0.08);">
      <div style="max-width:1400px; margin:0 auto; padding:8px 24px; display:flex; align-items:center; justify-content:space-between;" class="numplate">
        <span style="color:var(--ink-500);">EST. MMXXVI &middot; AN INSTITUTION OF EDURANK&middot;AI</span>
        <span class="hide-mobile" style="color:var(--ink-500);">ENROL &middot; AQUINTUTOR</span>
      </div>
    </div>
    <div style="max-width:1400px; margin:0 auto; padding:20px 24px; display:flex; align-items:center; justify-content:space-between;">
      <a href="/aquintutor" style="display:flex; align-items:baseline; gap:8px; text-decoration:none; color:var(--ink);">
        <span class="font-display" style="font-size:30px; font-weight:500; letter-spacing:-0.02em;">Aquin<span style="color:var(--rust);">Tutor</span></span>
        <span class="numplate" style="color:var(--ink-300);">.ai</span>
      </a>
      <nav class="hide-mobile" style="display:flex; align-items:center; gap:32px;">
        <a href="/aquintutor/schools" class="eyebrow" style="color:var(--ink-500); text-decoration:none;">Schools</a>
        <a href="/aquintutor/courses" class="eyebrow" style="color:var(--ink-500); text-decoration:none;">Courses</a>
      </nav>
      <a href="/aquintutor/login" class="eyebrow" style="color:var(--ink-500); text-decoration:none; padding:8px 12px;">Sign in</a>
    </div>
  </header>

  <section style="max-width:540px; margin:0 auto; padding:80px 24px 64px;">
    <div style="display:flex; align-items:center; gap:16px; margin-bottom:32px;" class="numplate">
      <span style="height:1px; width:48px; background:var(--ink);"></span>
      <span style="color:var(--ink-500);">ENROL &middot; 1 CHF ENROLMENT</span>
    </div>

    <h1 class="font-display" style="font-size:clamp(3rem, 7vw, 5rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0;">
      Begin a private<br/>
      <span style="font-style:italic; font-weight:300; color:var(--ink-500);">university year.</span>
    </h1>

    <p class="font-serif" style="font-size:1.5rem; line-height:1.3; color:var(--ink-500); margin-top:24px;">
      A single one Swiss-franc enrolment registers you across the institution &mdash; every school, every department, every course on the active register. Proctored examinations are billed separately, only for the credentials you choose to sit.
    </p>

    {errorMsg && (
      <div style="background:rgba(160,66,30,0.08); border:1px solid var(--rust); color:var(--rust); padding:14px 16px; border-radius:12px; margin-top:32px; font-family:'Cormorant Garamond',serif; font-size:1.125rem; font-style:italic;">
        {errorMsg}
      </div>
    )}

    <form method="POST" style="margin-top:40px; display:flex; flex-direction:column; gap:18px;">
      <div>
        <label class="eyebrow" for="name" style="display:block; margin-bottom:8px;">Full name</label>
        <input id="name" name="name" type="text" autocomplete="name" required autofocus style="width:100%; background:var(--paper); border:none; border-bottom:1.5px solid var(--ink); padding:12px 0; font-family:'Inter Tight',sans-serif; font-size:16px; color:var(--ink); outline:none; border-radius:0;" />
      </div>
      <div>
        <label class="eyebrow" for="email" style="display:block; margin-bottom:8px;">Email</label>
        <input id="email" name="email" type="email" autocomplete="email" required style="width:100%; background:var(--paper); border:none; border-bottom:1.5px solid var(--ink); padding:12px 0; font-family:'Inter Tight',sans-serif; font-size:16px; color:var(--ink); outline:none; border-radius:0;" />
      </div>
      <div>
        <label class="eyebrow" for="password" style="display:block; margin-bottom:8px;">Password (8+ chars)</label>
        <input id="password" name="password" type="password" autocomplete="new-password" required minlength="8" style="width:100%; background:var(--paper); border:none; border-bottom:1.5px solid var(--ink); padding:12px 0; font-family:'Inter Tight',sans-serif; font-size:16px; color:var(--ink); outline:none; border-radius:0;" />
      </div>
      <label style="display:flex; align-items:flex-start; gap:10px; font-size:14px; color:var(--ink-500); line-height:1.5; margin-top:8px;">
        <input type="checkbox" name="consent" required style="margin-top:4px;" />
        <span>I agree to the <a href="/p/privacy" style="color:var(--ink); text-decoration:underline;">Privacy Policy</a> and <a href="/p/terms" style="color:var(--ink); text-decoration:underline;">Terms of Service</a>.</span>
      </label>
      <button type="submit" class="btn-pill filled" style="margin-top:14px; align-self:flex-start;">Create account &rarr;</button>
    </form>

    <div style="margin-top:48px; padding-top:32px; border-top:1px solid var(--rule); display:flex; flex-wrap:wrap; gap:14px; align-items:center; justify-content:space-between;">
      <p class="font-serif" style="font-size:1.125rem; color:var(--ink-500); margin:0; font-style:italic;">Already enrolled?</p>
      <a href="/aquintutor/login" class="btn-pill outline" style="padding:10px 20px; font-size:11px;">Sign in &rarr;</a>
    </div>
  </section>
</body>
</html>
