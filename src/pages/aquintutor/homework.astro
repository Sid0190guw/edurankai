---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
// Homework Helper — the Aquin Sub-Juniors signature. A student types a problem
// (or attaches a photo for reference); Aquin identifies the RULE and guides
// them Socratically but NEVER shows the final answer — it only checks the
// student's own attempt. An exit-ticket then verifies real understanding, and a
// task-planner breaks a big assignment into dated daily micro-tasks. All the
// maths (arithmetic evaluator + linear-equation solver + step generation) is
// computed here — no LLM, no answer-vending.
const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/homework'));
---
<AquintutorLayout title="Homework Helper" description="Type a maths problem and Aquin guides you to solve it yourself — it identifies the rule and checks your attempt, but never hands you the answer. Then it verifies you actually understood.">
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:900px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a><span style="margin:0 8px;">/</span><span style="color:var(--rust); font-weight:600;">HOMEWORK HELPER</span>
    </div>
  </div>

  <section style="max-width:760px; margin:0 auto; padding:40px 28px 80px;">
    <p style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--rust); font-weight:700; margin:0 0 8px;">Aquin Sub-Juniors</p>
    <h1 class="font-display" style="font-size:clamp(1.8rem,4vw,2.6rem); font-weight:500; letter-spacing:-0.01em; margin:0 0 6px; color:var(--ink);">I won't do it for you. I'll get you there.</h1>
    <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); line-height:1.6; margin:0 0 26px;">Type your problem below. I find the rule and coach you — but I never show the answer. You solve it; I check it; then I make sure you really understood.</p>

    <!-- Problem -->
    <div style="background:#fff; border:1.5px solid var(--rule); border-radius:16px; padding:18px;">
      <div style="display:flex; gap:8px; align-items:center; margin-bottom:10px;">
        <input id="hwIn" placeholder="e.g.  38 + 7   or   2x + 5 = 15   or   2 + 3 × 4" style="flex:1; background:var(--sand-50); border:1.5px solid var(--rule); border-radius:10px; padding:12px 14px; font-size:16px; font-family:'Geist Mono',monospace; color:var(--ink); outline:none;" />
        <label style="background:var(--sand-100); border:1.5px solid var(--rule); border-radius:10px; padding:11px 13px; cursor:pointer; color:var(--ink-500);" title="Attach a photo for reference">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
          <input id="hwPhoto" type="file" accept="image/*" style="display:none;" />
        </label>
      </div>
      <img id="hwPhotoPrev" style="display:none; max-height:120px; border-radius:8px; margin-bottom:10px; border:1px solid var(--rule);" />
      <button id="hwGo" type="button" style="background:var(--rust); color:#fff; border:none; font-family:'Inter Tight',sans-serif; font-size:15px; font-weight:600; padding:11px 24px; border-radius:10px; cursor:pointer;">Coach me</button>
      <p id="hwErr" style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); margin:10px 0 0; min-height:1em;"></p>
    </div>

    <div id="hwSession" style="display:none; margin-top:18px;"></div>

    <!-- Task planner -->
    <div style="margin-top:40px; border-top:1px solid var(--rule); padding-top:26px;">
      <h2 class="font-display" style="font-size:1.4rem; font-weight:500; color:var(--ink); margin:0 0 4px;">Big assignment? Let's break it down.</h2>
      <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); margin:0 0 14px;">Paste the assignment and its due date. I'll split it into small daily tasks so it never becomes a last-night panic.</p>
      <textarea id="tpText" rows="2" placeholder="e.g. History research paper on the Indus Valley — 1200 words with sources" style="width:100%; background:#fff; border:1.5px solid var(--rule); border-radius:10px; padding:11px 13px; font-size:14px; color:var(--ink); outline:none; font-family:inherit; margin-bottom:10px;"></textarea>
      <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
        <input id="tpDue" type="date" style="background:#fff; border:1.5px solid var(--rule); border-radius:10px; padding:10px 12px; font-size:14px; color:var(--ink); outline:none;" />
        <button id="tpGo" type="button" style="background:var(--ink); color:var(--sand-50); border:none; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; padding:10px 20px; border-radius:10px; cursor:pointer;">Make my plan</button>
      </div>
      <div id="tpOut" style="margin-top:16px;"></div>
    </div>
  </section>

  <script is:inline>
  (function(){
    var C={ ink:'var(--ink)', rust:'var(--rust)', mid:'var(--ink-500)', rule:'var(--rule)' };
    // ---------- maths engine ----------
    function tokenize(s){ return (s.match(/\d+\.?\d*|[+\-*/()x=×÷]/g)||[]).map(function(t){return t==='×'?'*':t==='÷'?'/':t;}); }
    function evalArith(expr){ // shunting-yard over + - * / ( )
      var out=[],ops=[],prec={'+':1,'-':1,'*':2,'/':2};
      var toks=tokenize(expr);
      toks.forEach(function(t){
        if(/^\d/.test(t)) out.push(parseFloat(t));
        else if(t in prec){ while(ops.length && prec[ops[ops.length-1]]>=prec[t]) out.push(ops.pop()); ops.push(t); }
        else if(t==='(') ops.push(t);
        else if(t===')'){ while(ops.length && ops[ops.length-1]!=='(') out.push(ops.pop()); ops.pop(); }
      });
      while(ops.length) out.push(ops.pop());
      var st=[]; out.forEach(function(t){ if(typeof t==='number') st.push(t); else { var b=st.pop(),a=st.pop(); st.push(t==='+'?a+b:t==='-'?a-b:t==='*'?a*b:a/b); } });
      return st[0];
    }
    function parseSide(s){ // linear in x -> {a, b}
      s=s.replace(/\s+/g,''); if(s==='') return {a:0,b:0};
      var a=0,b=0,re=/([+\-]?)(\d*\.?\d*)(x?)/g,m;
      while((m=re.exec(s))!==null){ if(m[0]==='') continue; var sign=m[1]==='-'?-1:1; var num=m[2]===''?1:parseFloat(m[2]); if(m[3]==='x') a+=sign*num; else if(m[2]!=='') b+=sign*num; }
      return {a:a,b:b};
    }
    function classify(input){
      var s=input.trim();
      if(s.indexOf('=')>=0 && /x/i.test(s)){
        var parts=s.split('='); var L=parseSide(parts[0]),R=parseSide(parts[1]);
        var a=L.a-R.a, b=R.b-L.b; if(a===0) return null;
        var ans=b/a;
        var twoStep=(L.b!==0||R.b!==0)&&L.a!==0;
        return { type:'equation', rule:(twoStep?'Two-step linear equation':'One-step linear equation'),
          method:['Get the x-term alone: move plain numbers to the other side by doing the opposite (+ becomes −).','Then divide both sides by the number in front of x.','Whatever you do to one side, do to the other — keep it balanced.'],
          answer:ans, verify:{a:a} };
      }
      if(/^[\d+\-*/()\s×÷.]+$/.test(s) && /[+\-*/×÷]/.test(s)){
        var hasMix=/[*/×÷]/.test(s)&&/[+\-]/.test(s), hasParen=/[()]/.test(s);
        var rule = hasParen?'Order of operations — brackets first' : hasMix?'Order of operations (BODMAS)' : /\+/.test(s)?'Addition' : /-/.test(s)?'Subtraction' : /[*×]/.test(s)?'Multiplication':'Division';
        return { type:'arith', rule:rule,
          method: hasParen?['Do anything in brackets first.','Then × and ÷ before + and −.','Work left to right within the same level.']
                : hasMix?['Multiply and divide BEFORE you add or subtract.','Do the × / ÷ parts first, then combine with + / −.']
                : ['Line up the digits by place value.','Work from the ones column; carry or borrow if you need to.'],
          answer: evalArith(s) };
      }
      return null;
    }
    // ---------- session ----------
    var sess=document.getElementById('hwSession'), curClass=null, hintN=0;
    document.getElementById('hwGo').addEventListener('click', start);
    document.getElementById('hwIn').addEventListener('keydown', function(e){ if(e.key==='Enter') start(); });
    document.getElementById('hwPhoto').addEventListener('change', function(){ var f=this.files&&this.files[0]; if(!f) return; var r=new FileReader(); r.onload=function(){ var p=document.getElementById('hwPhotoPrev'); p.src=r.result; p.style.display='block'; }; r.readAsDataURL(f); document.getElementById('hwErr').textContent='Photo attached for reference — now type the problem so I can coach you (I read what you type).'; });
    function start(){
      var input=document.getElementById('hwIn').value.trim(), err=document.getElementById('hwErr');
      curClass=classify(input);
      if(!curClass){ err.textContent="I can coach arithmetic (like 38 + 7, or 2 + 3 × 4) and simple equations (like 2x + 5 = 15). Type one of those and I'll guide you."; return; }
      err.textContent=''; hintN=0;
      sess.style.display='block';
      sess.innerHTML =
        '<div style="background:#fff;border:1.5px solid '+C.rule+';border-radius:16px;padding:18px;">'
        +'<div style="font-family:JetBrains Mono,monospace;font-size:10.5px;letter-spacing:0.12em;text-transform:uppercase;color:'+C.rust+';font-weight:700;margin-bottom:6px;">'+curClass.rule+'</div>'
        +'<p style="font-family:Inter Tight,sans-serif;font-size:15px;color:'+C.ink+';line-height:1.6;margin:0 0 4px;">Here is the method — but you do the solving.</p>'
        +'<ul id="hwMethod" style="margin:0 0 14px;padding-left:18px;font-family:Inter Tight,sans-serif;font-size:14px;color:'+C.ink+';line-height:1.7;"></ul>'
        +'<label style="font-family:Inter Tight,sans-serif;font-size:13px;color:'+C.mid+';">Your answer'
        +'<div style="display:flex;gap:8px;margin-top:5px;"><input id="hwAns" inputmode="numeric" placeholder="Solve it yourself" style="flex:1;background:var(--sand-50);border:1.5px solid '+C.rule+';border-radius:10px;padding:11px 13px;font-size:16px;font-family:Geist Mono,monospace;color:'+C.ink+';outline:none;" />'
        +'<button id="hwCheck" style="background:'+C.rust+';color:#fff;border:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;padding:11px 18px;border-radius:10px;cursor:pointer;">Check</button>'
        +'<button id="hwHint" style="background:transparent;border:1.5px solid '+C.rule+';color:'+C.mid+';font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;padding:11px 15px;border-radius:10px;cursor:pointer;">Hint</button></div></label>'
        +'<div id="hwHints"></div>'
        +'<p id="hwMsg" style="font-family:Inter Tight,sans-serif;font-size:13.5px;margin:12px 0 0;min-height:1em;"></p>'
        +'</div>';
      var ml=document.getElementById('hwMethod'); curClass.method.forEach(function(m){ var li=document.createElement('li'); li.textContent=m; ml.appendChild(li); });
      var ans=document.getElementById('hwAns'); ans.focus();
      document.getElementById('hwCheck').addEventListener('click', check);
      ans.addEventListener('keydown', function(e){ if(e.key==='Enter') check(); });
      document.getElementById('hwHint').addEventListener('click', hint);
    }
    function hint(){
      var box=document.getElementById('hwHints');
      if(hintN>=curClass.method.length){ document.getElementById('hwMsg').style.color=C.mid; document.getElementById('hwMsg').textContent="That's the full method — try your best attempt. I will not just give the answer; solving it yourself is the whole point."; return; }
      var d=document.createElement('div'); d.style.cssText='font-family:Inter Tight,sans-serif;font-size:14px;color:#2b577e;background:rgba(43,87,126,0.07);border-left:3px solid #2b577e;border-radius:0 8px 8px 0;padding:9px 12px;margin-top:8px;';
      d.textContent='Coach: '+curClass.method[hintN]; box.appendChild(d); hintN++;
    }
    function check(){
      var v=parseFloat((document.getElementById('hwAns').value||'').replace(/[, ]/g,'')), msg=document.getElementById('hwMsg');
      if(isNaN(v)){ msg.style.color=C.rust; msg.textContent='Type your answer as a number.'; return; }
      if(Math.abs(v-curClass.answer)<1e-6){ msg.style.color='#1c7a45'; msg.textContent='Correct — and you got there yourself. Now let me check you really understood it.'; setTimeout(exitTicket,700); }
      else { msg.style.color=C.rust; msg.textContent='Not yet — and I still won\'t give the answer. Read the next hint and try again.'; hint(); }
    }
    // ---------- exit ticket ----------
    function ri(a,b){ return a+Math.floor(Math.random()*(b-a+1)); }
    function freshProblem(){
      if(curClass.type==='equation'){ var x=ri(3,15), a=ri(2,6), b=ri(2,12); return { q:a+'x + '+b+' = '+(a*x+b), ans:x, prompt:'Solve for x:' }; }
      var op=curClass.rule;
      if(/BODMAS|Order/.test(op)){ var p=ri(2,9),q=ri(2,6),r=ri(2,6); return { q:p+' + '+q+' × '+r, ans:p+q*r, prompt:'Work it out (mind the order):' }; }
      if(/Addition/.test(op)){ var p=ri(18,49),q=ri(6,9); return { q:p+' + '+q, ans:p+q, prompt:'Add:' }; }
      if(/Subtraction/.test(op)){ var p=ri(41,79),q=ri(4,9); return { q:p+' − '+q, ans:p-q, prompt:'Subtract:' }; }
      if(/Multiplication/.test(op)){ var p=ri(3,9),q=ri(3,6); return { q:p+' × '+q, ans:p*q, prompt:'Multiply:' }; }
      var p=ri(2,9),q=ri(2,6); return { q:(p*q)+' ÷ '+q, ans:p, prompt:'Divide:' };
    }
    function exitTicket(){
      var ex=freshProblem();
      var d=document.createElement('div'); d.style.cssText='background:#fff;border:1.5px solid '+C.rust+';border-radius:16px;padding:18px;margin-top:14px;';
      d.innerHTML='<div style="font-family:JetBrains Mono,monospace;font-size:10.5px;letter-spacing:0.12em;text-transform:uppercase;color:'+C.rust+';font-weight:700;margin-bottom:6px;">Exit ticket · prove you\'ve got it</div>'
        +'<p style="font-family:Inter Tight,sans-serif;font-size:13px;color:'+C.mid+';margin:0 0 6px;">A fresh one — different numbers. Pass it and your homework is <b>verified</b>, not just "done".</p>'
        +'<p style="font-family:Inter Tight,sans-serif;font-size:16px;font-weight:600;color:'+C.ink+';margin:6px 0 12px;">'+ex.prompt+' <span style="font-family:Geist Mono,monospace;">'+ex.q+'</span></p>'
        +'<div style="display:flex;gap:8px;"><input id="etAns" inputmode="numeric" placeholder="Your answer" style="flex:1;background:var(--sand-50);border:1.5px solid '+C.rule+';border-radius:10px;padding:11px 13px;font-size:16px;font-family:Geist Mono,monospace;color:'+C.ink+';outline:none;" />'
        +'<button id="etChk" style="background:'+C.rust+';color:#fff;border:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;padding:11px 18px;border-radius:10px;cursor:pointer;">Submit</button></div>'
        +'<p id="etMsg" style="font-family:Inter Tight,sans-serif;font-size:13.5px;margin:12px 0 0;min-height:1em;"></p>';
      sess.appendChild(d);
      var inp=document.getElementById('etAns'); inp.focus();
      function sub(){ var v=parseFloat((inp.value||'').replace(/[, ]/g,'')), m=document.getElementById('etMsg'); if(isNaN(v)){m.style.color=C.rust;m.textContent='Type a number.';return;}
        var pass=Math.abs(v-ex.ans)<1e-6;
        fetch('/api/aquintutor/learn',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'same-origin',body:JSON.stringify({action:'verify',skillId:'homework-'+curClass.type,verified:pass})}).catch(function(){});
        if(pass){ m.style.color='#1c7a45'; m.innerHTML='<b>Verified.</b> You understood it — this shows as verified on the parent/teacher dashboard, not a fake "completed".'; }
        else { m.style.color=C.rust; m.textContent='Not quite — so the idea isn\'t locked in yet. Go back to the method and try the original again. Nothing is lost.'; }
      }
      document.getElementById('etChk').addEventListener('click', sub); inp.addEventListener('keydown', function(e){ if(e.key==='Enter') sub(); });
    }
    // ---------- task planner ----------
    document.getElementById('tpGo').addEventListener('click', function(){
      var text=document.getElementById('tpText').value.trim(), due=document.getElementById('tpDue').value, out=document.getElementById('tpOut');
      if(!text){ out.innerHTML='<p style="color:'+C.rust+';font-family:Inter Tight,sans-serif;font-size:13px;">Describe the assignment first.</p>'; return; }
      if(!due){ out.innerHTML='<p style="color:'+C.rust+';font-family:Inter Tight,sans-serif;font-size:13px;">Pick the due date.</p>'; return; }
      var today=new Date(); today.setHours(0,0,0,0); var d=new Date(due+'T00:00:00');
      var days=Math.max(1,Math.round((d-today)/86400000));
      var steps=['Understand the task — read it twice, list what\'s being asked, gather sources/materials.','Plan — outline the structure and the main points.','Do the first chunk of the actual work.','Do the next chunk — keep momentum.','Review, fix mistakes, and polish.','Final check and submit.'];
      var n=Math.min(steps.length, days);
      // spread n steps across the available days
      var out2='<div style="border:1.5px solid '+C.rule+';border-radius:14px;overflow:hidden;">';
      for(var i=0;i<n;i++){
        var dayOffset=Math.round(i*(days-1)/(n-1||1)); var dt=new Date(today.getTime()+dayOffset*86400000);
        var label=dt.toLocaleDateString(undefined,{weekday:'short',month:'short',day:'numeric'});
        out2+='<div style="display:flex;gap:12px;padding:11px 14px;'+(i<n-1?'border-bottom:1px solid '+C.rule+';':'')+'">'
          +'<span style="font-family:JetBrains Mono,monospace;font-size:11px;color:'+C.rust+';font-weight:700;min-width:64px;">'+label+'</span>'
          +'<span style="font-family:Inter Tight,sans-serif;font-size:13.5px;color:'+C.ink+';">'+steps[i]+'</span></div>';
      }
      out2+='</div><p style="font-family:Inter Tight,sans-serif;font-size:12px;color:'+C.mid+';margin:10px 0 0;">'+days+' day'+(days>1?'s':'')+' until it\'s due — a little each day beats one panicked night.</p>';
      out.innerHTML=out2;
    });
  })();
  </script>
</AquintutorLayout>
