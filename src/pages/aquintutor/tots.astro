---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
// Tots — the Aquin voice-first experience for pre-readers (ages ~3-6). A child
// who cannot type or read TAPS a picture or SAYS a word. Every instruction is
// spoken aloud (SpeechSynthesis); answers can be spoken (SpeechRecognition) or
// tapped. Big targets, SVG art (no emoji), spoken praise, star rewards. All
// activities generated in-browser, no LLM.
const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/tots'));
---
<AquintutorLayout title="Aquin Little Ones" description="Voice-first learning for children too young to read or type. Aquin speaks every instruction; your child taps a picture or says the answer. Counting, shapes, colours and letters.">
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:900px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a><span style="margin:0 8px;">/</span><span style="color:var(--rust); font-weight:600;">LITTLE ONES</span>
    </div>
  </div>

  <section style="max-width:820px; margin:0 auto; padding:30px 24px 80px;">
    <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap; margin-bottom:6px;">
      <div>
        <p style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--rust); font-weight:700; margin:0 0 6px;">Aquin Tots · voice-first</p>
        <h1 class="font-display" style="font-size:clamp(1.8rem,4vw,2.5rem); font-weight:500; margin:0; color:var(--ink);">Play &amp; learn — just tap or talk.</h1>
      </div>
      <div id="stars" style="font-family:'JetBrains Mono',monospace; font-size:13px; color:var(--rust); font-weight:700; display:flex; align-items:center; gap:6px;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--rust)" stroke="none"><path d="M12 2l3 7h7l-5.5 4 2 7L12 16l-6.5 4 2-7L2 9h7z"/></svg><span id="starCount">0</span>
      </div>
    </div>
    <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); margin:8px 0 22px;">No reading needed. Aquin says everything out loud. Your child answers by tapping a picture — or tap the microphone and let them say it.</p>

    <div id="totHome" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:14px;">
      <button class="tot-game" data-g="count" style="background:#fff8ef; border:2px solid #f2d9b3; border-radius:22px; padding:26px 18px; cursor:pointer; text-align:center;">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#c2410c" stroke-width="1.7"><circle cx="7" cy="8" r="3"/><circle cx="16" cy="8" r="3"/><circle cx="11.5" cy="16" r="3"/></svg>
        <div class="font-display" style="font-size:1.4rem; font-weight:600; color:var(--ink); margin-top:8px;">Counting</div>
      </button>
      <button class="tot-game" data-g="shape" style="background:#eef6f0; border:2px solid #bfe0cb; border-radius:22px; padding:26px 18px; cursor:pointer; text-align:center;">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#1c7a45" stroke-width="1.7"><circle cx="7" cy="8" r="4"/><rect x="13" y="4" width="8" height="8" rx="1.5"/><path d="M7 14l4 7H3z"/></svg>
        <div class="font-display" style="font-size:1.4rem; font-weight:600; color:var(--ink); margin-top:8px;">Shapes &amp; Colours</div>
      </button>
      <button class="tot-game" data-g="letter" style="background:#eef1f8; border:2px solid #c3cbe6; border-radius:22px; padding:26px 18px; cursor:pointer; text-align:center;">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#3b4fa0" stroke-width="1.7"><path d="M4 20L9 5l5 15"/><path d="M6 14h6"/><path d="M17 8v12"/></svg>
        <div class="font-display" style="font-size:1.4rem; font-weight:600; color:var(--ink); margin-top:8px;">Letters</div>
      </button>
    </div>

    <div id="totPlay" style="display:none;"></div>
  </section>

  <style is:global>
    .tot-game:active { transform:scale(0.97); }
    .tot-opt { border:none; border-radius:22px; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:transform .1s; }
    .tot-opt:active { transform:scale(0.94); }
    .tot-num { background:#fff; border:2.5px solid var(--rule); border-radius:20px; font-family:'Fraunces',Georgia,serif; font-weight:600; color:var(--ink); cursor:pointer; }
    .tot-num:active { transform:scale(0.94); }
  </style>

  <script is:inline>
  (function(){
    var COLORS=[{n:'red',h:'#e23b3b'},{n:'blue',h:'#2f6fd0'},{n:'green',h:'#1c7a45'},{n:'yellow',h:'#e0a91b'},{n:'purple',h:'#7a3ba0'}];
    var SHAPES=['circle','square','triangle','star'];
    var LETTERS='ABCDEFGHKMOPRST'.split('');
    var NUMWORDS={zero:0,one:1,two:2,three:3,four:4,five:5,six:6,seven:7,eight:8,nine:9,ten:10,to:2,too:2,for:4,ate:8,tree:3,free:3};
    var stars=0, starEl=document.getElementById('starCount');
    var home=document.getElementById('totHome'), play=document.getElementById('totPlay');

    // ---- speech out ----
    function speak(t){ try{ var s=window.speechSynthesis; if(!s) return; s.cancel(); var u=new SpeechSynthesisUtterance(t); u.rate=0.92; u.pitch=1.12; s.speak(u); }catch(e){} }
    // ---- speech in ----
    var SR=window.SpeechRecognition||window.webkitSpeechRecognition;
    function listen(cb){ if(!SR){ cb(null); return false; } try{ var r=new SR(); r.lang='en-US'; r.maxAlternatives=3; r.onresult=function(e){ var t=''; for(var i=0;i<e.results[0].length;i++) t+=' '+e.results[0][i].transcript; cb(t.toLowerCase().trim()); }; r.onerror=function(){ cb(null); }; r.start(); return true; }catch(e){ cb(null); return false; } }

    function award(){ stars++; starEl.textContent=stars; }
    function svgShape(shape,color,size){
      var s=size||64;
      if(shape==='circle') return '<svg width="'+s+'" height="'+s+'" viewBox="0 0 100 100"><circle cx="50" cy="50" r="40" fill="'+color+'"/></svg>';
      if(shape==='square') return '<svg width="'+s+'" height="'+s+'" viewBox="0 0 100 100"><rect x="14" y="14" width="72" height="72" rx="8" fill="'+color+'"/></svg>';
      if(shape==='triangle') return '<svg width="'+s+'" height="'+s+'" viewBox="0 0 100 100"><path d="M50 12L88 84H12z" fill="'+color+'"/></svg>';
      return '<svg width="'+s+'" height="'+s+'" viewBox="0 0 100 100"><path d="M50 8l11 26 28 2-21 18 7 27-25-15-25 15 7-27L11 36l28-2z" fill="'+color+'"/></svg>';
    }
    function balloon(color){ return '<svg width="52" height="72" viewBox="0 0 52 72"><ellipse cx="26" cy="26" rx="22" ry="26" fill="'+color+'"/><path d="M26 52 L26 70" stroke="#8a7a63" stroke-width="2"/></svg>'; }

    function ri(a,b){ return a+Math.floor(Math.random()*(b-a+1)); }
    function pick(arr){ return arr[Math.floor(Math.random()*arr.length)]; }

    function backBar(){ return '<button id="totBack" style="background:transparent;border:1.5px solid var(--rule);border-radius:12px;padding:8px 16px;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;color:var(--ink-500);cursor:pointer;margin-bottom:18px;">&larr; Back to games</button>'; }
    function wireBack(){ var b=document.getElementById('totBack'); if(b) b.addEventListener('click', function(){ try{window.speechSynthesis.cancel();}catch(e){}; play.style.display='none'; home.style.display='grid'; }); }
    function praise(){ speak(pick(['Yes! Well done!','Great job!','You did it!','Brilliant!','Super!'])); }

    document.querySelectorAll('.tot-game').forEach(function(b){ b.addEventListener('click', function(){ home.style.display='none'; play.style.display='block'; var g=b.getAttribute('data-g'); if(g==='count') roundCount(1); else if(g==='shape') roundShape(1); else roundLetter(1); }); });

    // ---------- COUNTING ----------
    function roundCount(n){
      if(n>5){ return finish('count'); }
      var target=ri(1,5), color=pick(COLORS).h, balloons='';
      for(var i=0;i<target;i++) balloons+=balloon(color);
      var opts=''; for(var k=1;k<=5;k++) opts+='<button class="tot-num" data-v="'+k+'" style="width:74px;height:74px;font-size:2rem;">'+k+'</button>';
      play.innerHTML=backBar()
        +'<div style="text-align:center;">'
        +'<div style="font-family:Inter Tight,sans-serif;font-size:18px;font-weight:600;color:var(--ink);margin-bottom:14px;">How many balloons?</div>'
        +'<div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:center;min-height:76px;margin-bottom:22px;">'+balloons+'</div>'
        +'<div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:center;margin-bottom:16px;">'+opts+'</div>'
        +micBtn()+'<p id="totMsg" style="font-family:Inter Tight,sans-serif;font-size:15px;font-weight:600;min-height:1.2em;margin-top:14px;"></p></div>';
      wireBack(); speak('How many balloons? Tap the number, or press the microphone and say it.');
      function answer(v){ var m=document.getElementById('totMsg'); if(v===target){ award(); praise(); m.style.color='#1c7a45'; m.textContent='Correct!'; setTimeout(function(){ roundCount(n+1); }, 1100); } else { speak('Try again. Count them slowly.'); m.style.color='var(--rust)'; m.textContent='Count again...'; } }
      play.querySelectorAll('.tot-num').forEach(function(b){ b.addEventListener('click', function(){ answer(Number(b.getAttribute('data-v'))); }); });
      wireMic(function(t){ var v=parseVoiceNum(t); if(v!=null) answer(v); });
    }
    function parseVoiceNum(t){ if(!t) return null; var d=t.match(/\d+/); if(d) return Number(d[0]); for(var w in NUMWORDS){ if(t.indexOf(w)>=0) return NUMWORDS[w]; } return null; }

    // ---------- SHAPES & COLOURS ----------
    function roundShape(n){
      if(n>5){ return finish('shape'); }
      var choices=[]; var used={};
      var tShape=pick(SHAPES), tColor=pick(COLORS); used[tShape+tColor.n]=1; choices.push({shape:tShape,color:tColor,correct:true});
      while(choices.length<4){ var s=pick(SHAPES), c=pick(COLORS); if(used[s+c.n]) continue; used[s+c.n]=1; choices.push({shape:s,color:c,correct:false}); }
      choices.sort(function(){ return Math.random()-0.5; });
      var grid=''; choices.forEach(function(o,i){ grid+='<button class="tot-opt" data-c="'+(o.correct?1:0)+'" style="background:#fff;border:2.5px solid var(--rule);width:110px;height:110px;">'+svgShape(o.shape,o.color.h,72)+'</button>'; });
      play.innerHTML=backBar()
        +'<div style="text-align:center;">'
        +'<div style="font-family:Inter Tight,sans-serif;font-size:18px;font-weight:600;color:var(--ink);margin-bottom:18px;">Tap the <span style="color:'+tColor.h+';">'+tColor.n+'</span> '+tShape+'</div>'
        +'<div style="display:flex;gap:14px;flex-wrap:wrap;justify-content:center;margin-bottom:16px;">'+grid+'</div>'
        +'<p id="totMsg" style="font-family:Inter Tight,sans-serif;font-size:15px;font-weight:600;min-height:1.2em;"></p></div>';
      wireBack(); speak('Tap the '+tColor.n+' '+tShape+'.');
      play.querySelectorAll('.tot-opt').forEach(function(b){ b.addEventListener('click', function(){ var m=document.getElementById('totMsg'); if(b.getAttribute('data-c')==='1'){ award(); praise(); m.style.color='#1c7a45'; m.textContent='Yes!'; setTimeout(function(){ roundShape(n+1); },1000); } else { speak('Not that one. Try again.'); m.style.color='var(--rust)'; m.textContent='Try another...'; } }); });
    }

    // ---------- LETTERS ----------
    function roundLetter(n){
      if(n>5){ return finish('letter'); }
      var target=pick(LETTERS), pool=[target], used={}; used[target]=1;
      while(pool.length<3){ var l=pick(LETTERS); if(used[l]) continue; used[l]=1; pool.push(l); }
      pool.sort(function(){ return Math.random()-0.5; });
      var grid=''; pool.forEach(function(l){ grid+='<button class="tot-num" data-l="'+l+'" style="width:96px;height:96px;font-size:3rem;">'+l+'</button>'; });
      play.innerHTML=backBar()
        +'<div style="text-align:center;">'
        +'<div style="font-family:Inter Tight,sans-serif;font-size:18px;font-weight:600;color:var(--ink);margin-bottom:6px;">Find the letter</div>'
        +'<div class="font-display" style="font-size:4.5rem;font-weight:600;color:var(--rust);line-height:1;margin-bottom:18px;">'+target+'</div>'
        +'<div style="display:flex;gap:14px;flex-wrap:wrap;justify-content:center;margin-bottom:16px;">'+grid+'</div>'
        +micBtn()+'<p id="totMsg" style="font-family:Inter Tight,sans-serif;font-size:15px;font-weight:600;min-height:1.2em;margin-top:14px;"></p></div>';
      wireBack(); speak('Find the letter '+target+'. Tap it, or say its name.');
      function answer(l){ var m=document.getElementById('totMsg'); if(l===target){ award(); praise(); m.style.color='#1c7a45'; m.textContent='Correct!'; setTimeout(function(){ roundLetter(n+1); },1000); } else { speak('That is '+l+'. Find '+target+'.'); m.style.color='var(--rust)'; m.textContent='Try again...'; } }
      play.querySelectorAll('.tot-num').forEach(function(b){ b.addEventListener('click', function(){ answer(b.getAttribute('data-l')); }); });
      wireMic(function(t){ if(!t) return; var up=t.toUpperCase().replace(/[^A-Z]/g,''); var found=null; for(var i=0;i<up.length;i++){ if(LETTERS.indexOf(up[i])>=0){ found=up[i]; break; } } if(found) answer(found); });
    }

    // ---- mic helper ----
    function micBtn(){ if(!SR) return ''; return '<button id="totMic" style="background:var(--rust);color:#fff;border:none;border-radius:50px;padding:11px 22px;font-family:Inter Tight,sans-serif;font-size:15px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:8px;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg>Say it</button>'; }
    function wireMic(cb){ var b=document.getElementById('totMic'); if(!b) return; b.addEventListener('click', function(){ b.textContent='Listening...'; speak('I am listening.'); setTimeout(function(){ listen(function(t){ b.innerHTML='<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:6px;"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg>Say it'; cb(t); }); }, 600); }); }

    function finish(game){
      speak('Amazing! You finished. You earned stars!');
      play.innerHTML='<div style="text-align:center;padding:20px 0;">'
        +'<svg width="70" height="70" viewBox="0 0 24 24" fill="var(--rust)"><path d="M12 2l3 7h7l-5.5 4 2 7L12 16l-6.5 4 2-7L2 9h7z"/></svg>'
        +'<h2 class="font-display" style="font-size:1.7rem;font-weight:600;color:var(--ink);margin:10px 0 4px;">You did it!</h2>'
        +'<p style="font-family:Inter Tight,sans-serif;font-size:15px;color:var(--ink-500);margin:0 0 18px;">You have '+stars+' stars. Play more?</p>'
        +'<button id="totMore" style="background:var(--rust);color:#fff;border:none;border-radius:14px;padding:12px 28px;font-family:Inter Tight,sans-serif;font-size:16px;font-weight:600;cursor:pointer;">Play again</button></div>';
      var m=document.getElementById('totMore'); m.addEventListener('click', function(){ play.style.display='none'; home.style.display='grid'; });
      fetch('/api/aquintutor/learn',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'same-origin',body:JSON.stringify({action:'verify',skillId:'tots-'+game,verified:true})}).catch(function(){});
    }
  })();
  </script>
</AquintutorLayout>
