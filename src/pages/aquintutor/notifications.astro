---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/notifications'));

function rows(r: any) { return Array.isArray(r) ? r : (r?.rows || []); }
try { await db.execute(sql`CREATE TABLE IF NOT EXISTS notifications (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
  title TEXT NOT NULL, body TEXT,
  type TEXT NOT NULL DEFAULT 'info', action_url TEXT,
  entity_type TEXT, entity_id TEXT,
  is_read BOOLEAN DEFAULT false, read_at TIMESTAMPTZ,
  created_at TIMESTAMPTZ DEFAULT NOW())`); } catch (_) {}

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  if (fd.get('action') === 'mark_all_read') {
    await db.execute(sql`UPDATE notifications SET is_read = true, read_at = NOW() WHERE user_id = ${user.id} AND is_read = false`).catch(() => {});
  }
}

const items = rows(await db.execute(sql`
  SELECT id, title, body, type, action_url, is_read, created_at
  FROM notifications WHERE user_id = ${user.id}
  ORDER BY created_at DESC LIMIT 100
`));

function ago(d: any) {
  const ms = Date.now() - new Date(d).getTime();
  const m = Math.floor(ms / 60000);
  if (m < 1) return 'just now';
  if (m < 60) return m + 'm';
  const h = Math.floor(m / 60);
  if (h < 24) return h + 'h';
  return Math.floor(h / 24) + 'd';
}
---
<AquintutorLayout title="Notifications" description="Streak nudges, league results, friend joins.">
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:760px; margin:0 auto; padding:36px 28px;">
      <div style="display:flex; justify-content:space-between; align-items:flex-end; gap:14px; flex-wrap:wrap;">
        <div>
          <p style="font-family:'Inter Tight',monospace; font-size:12px; color:var(--rust); font-weight:700; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Notifications</p>
          <h1 class="font-display" style="font-size:clamp(1.8rem,3.5vw,2.6rem); line-height:1.1; font-weight:500; margin:0;">Inbox</h1>
        </div>
        {items.length > 0 && (
          <form method="POST">
            <input type="hidden" name="action" value="mark_all_read" />
            <button type="submit" style="background:var(--paper); color:var(--ink); padding:9px 14px; border:1px solid var(--rule); border-radius:8px; font-family:'Inter Tight',sans-serif; font-size:12.5px; font-weight:700; cursor:pointer;">Mark all read</button>
          </form>
        )}
      </div>
    </div>
  </section>

  <section>
    <div style="max-width:760px; margin:0 auto; padding:20px 28px 80px;">
      {items.length === 0 && (
        <div style="background:var(--paper); border:1px dashed var(--rule); border-radius:14px; padding:30px; text-align:center; color:var(--ink-500);">No notifications yet.</div>
      )}
      {items.map((n: any) => (
        <a href={n.action_url || '#'} style={'display:flex; gap:14px; padding:14px 18px; background:' + (n.is_read ? 'var(--paper)' : 'rgba(217,119,87,0.06)') + '; border:1px solid var(--rule); border-radius:12px; margin-bottom:10px; text-decoration:none; color:inherit;'}>
          <span style={'width:8px; height:8px; border-radius:50%; background:' + (n.is_read ? 'transparent' : 'var(--rust)') + '; margin-top:7px; flex-shrink:0;'}></span>
          <div style="flex:1; min-width:0;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:14.5px; font-weight:600; color:var(--ink); margin:0;">{n.title}</p>
            {n.body && <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink-500); margin:3px 0 0; line-height:1.55;">{n.body}</p>}
          </div>
          <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500); flex-shrink:0; margin-top:2px;">{ago(n.created_at)}</p>
        </a>
      ))}
    </div>
  </section>
</AquintutorLayout>
