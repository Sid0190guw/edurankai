---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import VerifiedSummary from '@/components/aquintutor/VerifiedSummary.astro';
import { getVerifiedSummary } from '@/lib/aquintutor-summary';
import { listShares } from '@/lib/aquintutor-share';
// My Verified Learning — the single pane that makes the core principle visible:
// what you have actually VERIFIED, not merely marked done. Aggregates every
// signal the eight tiers write (mastery, exit tickets, teach-back, spaced
// repetition, research, credential path). SSR. Learners can mint a read-only
// share link for a parent or teacher.
const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/mastery'));
const s = await getVerifiedSummary(user.id);
const shares = await listShares(user.id).catch(() => []);
const firstName = (user.name || '').split(' ')[0] || 'there';
---
<AquintutorLayout title="My verified learning" description="What you have actually proven you understand — verified skills, exit tickets, recall, research and credential progress in one place.">
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:900px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a><span style="margin:0 8px;">/</span><span style="color:var(--rust); font-weight:600;">MY VERIFIED LEARNING</span>
    </div>
  </div>

  <section style="max-width:820px; margin:0 auto; padding:36px 24px 80px;">
    <p style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--rust); font-weight:700; margin:0 0 8px;">
      {s.profile ? s.profile.tierName + (s.profile.goal ? ' · ' + s.profile.goal : '') : 'AquinTutor'}
    </p>
    <h1 class="font-display" style="font-size:clamp(1.8rem,4vw,2.6rem); font-weight:500; letter-spacing:-0.01em; margin:0 0 6px; color:var(--ink);">What you've <em style="color:var(--rust); font-style:italic;">proven</em>, {firstName}.</h1>
    <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); line-height:1.6; margin:0 0 26px; max-width:620px;">Not hours watched — understanding demonstrated. Everything here was earned by passing an exit ticket, teaching it back, or logging real evidence.</p>

    {!s.hasAnything && (
      <div style="background:#fff; border:1.5px dashed var(--rule); border-radius:16px; padding:32px; text-align:center;">
        <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.15rem; color:var(--ink-500); margin:0 0 16px;">Nothing verified yet. Pick your stage and start — the first thing you prove will appear here.</p>
        <a href="/aquintutor/onboarding" style="background:var(--rust); color:#fff; text-decoration:none; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; padding:11px 24px; border-radius:10px;">Set up my path</a>
      </div>
    )}

    {s.hasAnything && <VerifiedSummary summary={s} readOnly={false} />}

    <!-- share with a parent or teacher -->
    <div style="margin-top:30px; border-top:1px solid var(--rule); padding-top:24px;">
      <h2 class="font-display" style="font-size:1.3rem; font-weight:600; color:var(--ink); margin:0 0 4px;">Share with a parent or teacher</h2>
      <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); margin:0 0 14px; max-width:600px;">Create a private, read-only link. Whoever has it can see your verified progress &mdash; no account needed &mdash; and you can turn it off any time.</p>
      <button id="mkShare" type="button" style="background:var(--ink); color:var(--sand-50); border:none; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; padding:10px 20px; border-radius:10px; cursor:pointer;">Create a share link</button>
      <div id="shareList" style="margin-top:14px; display:flex; flex-direction:column; gap:8px;">
        {shares.map((sh: any) => (
          <div class="share-row" data-token={sh.token} style="display:flex; gap:8px; align-items:center; flex-wrap:wrap; background:#fff; border:1.5px solid var(--rule); border-radius:10px; padding:9px 12px;">
            <input readonly value={'/aquintutor/shared-progress/' + sh.token} class="share-url" style="flex:1; min-width:200px; border:none; background:transparent; font-family:'Geist Mono','JetBrains Mono',monospace; font-size:12px; color:var(--ink); outline:none;" />
            <button class="share-copy" style="background:var(--sand-100); border:1px solid var(--rule); border-radius:8px; padding:5px 12px; font-family:'Inter Tight',sans-serif; font-size:12px; font-weight:600; color:var(--ink-500); cursor:pointer;">Copy</button>
            <button class="share-revoke" style="background:transparent; border:1px solid #e6c3bf; border-radius:8px; padding:5px 12px; font-family:'Inter Tight',sans-serif; font-size:12px; font-weight:600; color:#b3271c; cursor:pointer;">Turn off</button>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
  (function(){
    var listEl = document.getElementById('shareList');
    function fullUrl(path){ return location.origin + path; }
    function wire(row){
      row.querySelector('.share-copy').addEventListener('click', function(){
        var inp = row.querySelector('.share-url'); var t = fullUrl(inp.value); var b = this;
        (navigator.clipboard && navigator.clipboard.writeText ? navigator.clipboard.writeText(t) : Promise.reject()).then(function(){ b.textContent='Copied'; setTimeout(function(){b.textContent='Copy';},1200); }).catch(function(){ inp.select(); });
      });
      row.querySelector('.share-revoke').addEventListener('click', function(){
        if(!confirm('Turn off this link? Anyone using it will lose access.')) return;
        var token = row.getAttribute('data-token');
        fetch('/api/aquintutor/progress-share',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'same-origin',body:JSON.stringify({action:'revoke',token:token})}).then(function(r){return r.json();}).then(function(j){ if(j&&j.ok) row.remove(); });
      });
    }
    Array.prototype.forEach.call(listEl.querySelectorAll('.share-row'), wire);
    document.getElementById('mkShare').addEventListener('click', function(){
      var b=this; b.disabled=true; b.textContent='Creating…';
      fetch('/api/aquintutor/progress-share',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'same-origin',body:JSON.stringify({action:'create'})}).then(function(r){return r.json();}).then(function(j){
        b.disabled=false; b.textContent='Create a share link';
        if(!j||!j.ok||!j.path){ return; }
        var row=document.createElement('div'); row.className='share-row'; row.setAttribute('data-token', j.token);
        row.style.cssText='display:flex; gap:8px; align-items:center; flex-wrap:wrap; background:#fff; border:1.5px solid var(--rule); border-radius:10px; padding:9px 12px;';
        row.innerHTML='<input readonly class="share-url" style="flex:1; min-width:200px; border:none; background:transparent; font-family:Geist Mono,JetBrains Mono,monospace; font-size:12px; color:var(--ink); outline:none;" />'
          +'<button class="share-copy" style="background:var(--sand-100); border:1px solid var(--rule); border-radius:8px; padding:5px 12px; font-family:Inter Tight,sans-serif; font-size:12px; font-weight:600; color:var(--ink-500); cursor:pointer;">Copy</button>'
          +'<button class="share-revoke" style="background:transparent; border:1px solid #e6c3bf; border-radius:8px; padding:5px 12px; font-family:Inter Tight,sans-serif; font-size:12px; font-weight:600; color:#b3271c; cursor:pointer;">Turn off</button>';
        row.querySelector('.share-url').value=j.path;
        listEl.insertBefore(row, listEl.firstChild); wire(row);
      }).catch(function(){ b.disabled=false; b.textContent='Create a share link'; });
    });
  })();
  </script>
</AquintutorLayout>
