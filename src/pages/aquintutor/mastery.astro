---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { getVerifiedSummary } from '@/lib/aquintutor-summary';
// My Verified Learning — the single pane that makes the core principle visible:
// what you have actually VERIFIED, not merely marked done. Aggregates every
// signal the eight tiers write (mastery, exit tickets, teach-back, spaced
// repetition, research, credential path). SSR, reusable for a guardian view.
const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/mastery'));
const s = await getVerifiedSummary(user.id);
const firstName = (user.name || '').split(' ')[0] || 'there';
function ago(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins + 'm ago';
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return hrs + 'h ago';
  const days = Math.floor(hrs / 24);
  if (days < 30) return days + 'd ago';
  try { return new Date(d).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day: 'numeric', month: 'short' }); } catch { return ''; }
}
const statusOrder = ['to-read', 'reading', 'read', 'cited'];
---
<AquintutorLayout title="My verified learning" description="What you have actually proven you understand — verified skills, exit tickets, recall, research and credential progress in one place.">
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:900px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a><span style="margin:0 8px;">/</span><span style="color:var(--rust); font-weight:600;">MY VERIFIED LEARNING</span>
    </div>
  </div>

  <section style="max-width:820px; margin:0 auto; padding:36px 24px 80px;">
    <p style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--rust); font-weight:700; margin:0 0 8px;">
      {s.profile ? s.profile.tierName + (s.profile.goal ? ' · ' + s.profile.goal : '') : 'AquinTutor'}
    </p>
    <h1 class="font-display" style="font-size:clamp(1.8rem,4vw,2.6rem); font-weight:500; letter-spacing:-0.01em; margin:0 0 6px; color:var(--ink);">What you've <em style="color:var(--rust); font-style:italic;">proven</em>, {firstName}.</h1>
    <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); line-height:1.6; margin:0 0 26px; max-width:620px;">Not hours watched — understanding demonstrated. Everything here was earned by passing an exit ticket, teaching it back, or logging real evidence.</p>

    {!s.hasAnything && (
      <div style="background:#fff; border:1.5px dashed var(--rule); border-radius:16px; padding:32px; text-align:center;">
        <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.15rem; color:var(--ink-500); margin:0 0 16px;">Nothing verified yet. Pick your stage and start — the first thing you prove will appear here.</p>
        <a href="/aquintutor/onboarding" style="background:var(--rust); color:#fff; text-decoration:none; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; padding:11px 24px; border-radius:10px;">Set up my path</a>
      </div>
    )}

    {s.hasAnything && (
      <div>
        <!-- headline: verified vs unverified -->
        <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:22px;">
          <div style="flex:2; min-width:200px; background:#eef3ee; border:1.5px solid #1c7a45; border-radius:16px; padding:20px;">
            <div style="font-family:'Fraunces',Georgia,serif; font-size:3rem; font-weight:600; color:#1c7a45; line-height:1;">{s.mastery.verified}</div>
            <div style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:#1c7a45; margin-top:6px; font-weight:700;">Skills verified</div>
            <div style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink-500); margin-top:6px;">Proven by an exit ticket or lab demo — the real number.</div>
          </div>
          <div style="flex:1; min-width:160px; background:#fff; border:1.5px solid var(--rule); border-radius:16px; padding:20px;">
            <div style="font-family:'Fraunces',Georgia,serif; font-size:2rem; font-weight:600; color:var(--ink); line-height:1;">{s.mastery.growing}</div>
            <div style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:var(--ink-500); margin-top:6px; font-weight:700;">In progress</div>
          </div>
        </div>

        {s.mastery.masteredUnverified > 0 && (
          <div style="background:#fdf3e7; border:1.5px solid #e0a91b; border-radius:12px; padding:12px 16px; margin-bottom:22px; display:flex; align-items:center; gap:10px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#9a6a12" stroke-width="2" style="flex-shrink:0;"><path d="M12 9v4M12 17h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
            <span style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:#7a5310;"><b>{s.mastery.masteredUnverified} marked done but not yet verified.</b> Completing isn't the same as understanding — go back and pass the exit ticket to make it count.</span>
          </div>
        )}

        <!-- recent exit tickets -->
        {s.verifyLog.length > 0 && (
          <div style="margin-bottom:26px;">
            <h2 class="font-display" style="font-size:1.3rem; font-weight:600; color:var(--ink); margin:0 0 12px;">Recent checks</h2>
            <div style="background:#fff; border:1.5px solid var(--rule); border-radius:14px; overflow:hidden;">
              {s.verifyLog.map((v, i) => (
                <div style={'display:flex; align-items:center; gap:12px; padding:11px 16px;' + (i < s.verifyLog.length - 1 ? ' border-bottom:1px solid var(--rule);' : '')}>
                  <span style={'display:inline-flex; align-items:center; justify-content:center; width:22px; height:22px; border-radius:6px; flex-shrink:0; background:' + (v.verified ? '#1c7a45' : '#f6e3e0') + ';'}>
                    {v.verified
                      ? <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
                      : <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#b3271c" stroke-width="3"><path d="M18 6L6 18M6 6l12 12"/></svg>}
                  </span>
                  <span style="flex:1; font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink);">{v.label}</span>
                  <span style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--ink-500);">{ago(v.at)}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- teach-back -->
        {s.teachback.count > 0 && (
          <div style="margin-bottom:26px;">
            <h2 class="font-display" style="font-size:1.3rem; font-weight:600; color:var(--ink); margin:0 0 12px;">Taught it back <span style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--ink-500); font-weight:400;">{s.teachback.count} recalls</span></h2>
            <div style="display:flex; gap:8px; flex-wrap:wrap;">
              {s.teachback.recent.map((t) => (
                <div style="background:#fff; border:1.5px solid var(--rule); border-radius:10px; padding:10px 14px;">
                  <div style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink); font-weight:600;">{t.label}</div>
                  <div style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--rust);">{t.matched}/{t.total} key ideas · {ago(t.at)}</div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- recall / SRS -->
        {s.recall.total > 0 && (
          <div style="margin-bottom:26px;">
            <h2 class="font-display" style="font-size:1.3rem; font-weight:600; color:var(--ink); margin:0 0 12px;">Recall (spaced repetition)</h2>
            <div style="background:#fff; border:1.5px solid var(--rule); border-radius:14px; padding:16px; display:flex; gap:22px; flex-wrap:wrap; align-items:center;">
              <div><div style="font-family:'Fraunces',Georgia,serif; font-size:1.7rem; font-weight:600; color:var(--rust); line-height:1;">{s.recall.due}</div><div style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-500); margin-top:3px;">Due now</div></div>
              <div><div style="font-family:'Fraunces',Georgia,serif; font-size:1.7rem; font-weight:600; color:var(--ink); line-height:1;">{s.recall.mature}</div><div style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-500); margin-top:3px;">Locked in</div></div>
              <div><div style="font-family:'Fraunces',Georgia,serif; font-size:1.7rem; font-weight:600; color:var(--ink); line-height:1;">{s.recall.total}</div><div style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-500); margin-top:3px;">In deck</div></div>
              <a href="/aquintutor/recall" style="margin-left:auto; background:var(--rust); color:#fff; text-decoration:none; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; padding:9px 18px; border-radius:9px;">Review now</a>
            </div>
          </div>
        )}

        <!-- research -->
        {(s.research.refs > 0 || s.research.thesisDone > 0) && (
          <div style="margin-bottom:26px;">
            <h2 class="font-display" style="font-size:1.3rem; font-weight:600; color:var(--ink); margin:0 0 12px;">Research</h2>
            <div style="background:#fff; border:1.5px solid var(--rule); border-radius:14px; padding:16px;">
              <div style="display:flex; gap:22px; flex-wrap:wrap; align-items:center;">
                <div><div style="font-family:'Fraunces',Georgia,serif; font-size:1.7rem; font-weight:600; color:var(--ink); line-height:1;">{s.research.refs}</div><div style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-500); margin-top:3px;">References</div></div>
                <div><div style="font-family:'Fraunces',Georgia,serif; font-size:1.7rem; font-weight:600; color:var(--ink); line-height:1;">{s.research.thesisDone}/{s.research.thesisTotal}</div><div style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-500); margin-top:3px;">Thesis milestones</div></div>
                <a href="/aquintutor/research-workspace" style="margin-left:auto; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; color:var(--rust); text-decoration:none;">Open desk</a>
              </div>
              {s.research.refs > 0 && (
                <div style="display:flex; gap:6px; flex-wrap:wrap; margin-top:12px;">
                  {statusOrder.filter((k) => s.research.byStatus[k]).map((k) => (
                    <span style="font-family:'JetBrains Mono',monospace; font-size:11px; background:var(--sand-100); border-radius:6px; padding:3px 9px; color:var(--ink-500);">{s.research.byStatus[k]} {k}</span>
                  ))}
                </div>
              )}
            </div>
          </div>
        )}

        <!-- credential -->
        {s.credential.tracks.length > 0 && (
          <div style="margin-bottom:26px;">
            <h2 class="font-display" style="font-size:1.3rem; font-weight:600; color:var(--ink); margin:0 0 12px;">Credential path</h2>
            <div style="display:flex; flex-direction:column; gap:10px;">
              {s.credential.tracks.map((t) => (
                <a href={'/aquintutor/credential-path?track=' + t.id} style="text-decoration:none; background:#fff; border:1.5px solid var(--rule); border-radius:14px; padding:14px 16px; display:block;">
                  <div style="display:flex; justify-content:space-between; align-items:baseline;">
                    <span style="font-family:'Inter Tight',sans-serif; font-size:15px; font-weight:600; color:var(--ink);">{t.name}</span>
                    <span style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--rust); font-weight:700;">{t.done}/{t.total}</span>
                  </div>
                  <div style="height:7px; background:var(--sand-100); border-radius:99px; overflow:hidden; margin-top:8px;"><div style={'height:100%; background:#1c7a45; width:' + Math.round((t.total ? t.done / t.total : 0) * 100) + '%;'}></div></div>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    )}
  </section>
</AquintutorLayout>
