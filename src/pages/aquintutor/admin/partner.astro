---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login?next=/aquintutor/admin/partner');
if (user.role === 'applicant') return Astro.redirect('/portal');

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
async function safeRows(q: any): Promise<any[]> { try { return rows(await db.execute(q)); } catch { return []; } }
const isSuper = user.role === 'admin' || user.role === 'super_admin';
const viewUserId = (new URL(Astro.request.url).searchParams.get('as')) || user.id;

// Partner's hosted courses (authored) + their partnership application(s).
const authored = await safeRows(sql`SELECT course_id FROM training_course_authors WHERE user_id = ${viewUserId}`);
const myCourseIds = authored.map((a: any) => a.course_id);
const seeAll = isSuper && myCourseIds.length === 0;

let courses: any[] = [];
if (seeAll) courses = await safeRows(sql`SELECT id, slug, title, is_published, COALESCE(enrolled_count,0) AS enrolled, COALESCE(price_inr_paise,0) AS price FROM training_courses ORDER BY created_at DESC LIMIT 30`);
else if (myCourseIds.length) courses = await safeRows(sql`SELECT id, slug, title, is_published, COALESCE(enrolled_count,0) AS enrolled, COALESCE(price_inr_paise,0) AS price FROM training_courses WHERE id = ANY(${myCourseIds}) ORDER BY created_at DESC LIMIT 30`);
const courseIds = courses.map((c: any) => c.id);

const myApplications = await safeRows(sql`SELECT id, org_name, intended_course_title, tier, status, created_at FROM partnership_applications WHERE (user_id = ${viewUserId} OR contact_email = ${(user as any).email || ''}) ORDER BY created_at DESC LIMIT 10`);

let totalEnroll = 0, totalCerts = 0, grossInr = 0;
if (courseIds.length) {
  totalEnroll = (await safeRows(sql`SELECT COUNT(*)::int AS c FROM training_enrollments WHERE course_id = ANY(${courseIds})`))[0]?.c || 0;
  totalCerts = (await safeRows(sql`SELECT COUNT(*)::int AS c FROM course_certificates WHERE course_id = ANY(${courseIds})`))[0]?.c || 0;
  grossInr = courses.reduce((s: number, c: any) => s + (Number(c.price) || 0) * (Number(c.enrolled) || 0), 0);
}
const grossChf = Math.round(grossInr / 100 / 95); // rough INR paise -> CHF display
function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }); } catch { return '—'; } }
---
<AquintutorLayout title="Partner panel" description="AquinTutor partner hosting console." noindex={true}>
<style>
  .pt { max-width: 1200px; margin: 0 auto; padding: 0 28px; }
  .pt-crumb { border-bottom: 1px solid var(--rule); background: var(--sand-100); margin: 0 -28px; }
  .pt-crumb-in { max-width: 1200px; margin: 0 auto; padding: 10px 28px; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.08em; color: var(--ink-500); }
  .pt-crumb-in a { color: var(--ink-500); text-decoration: none; } .pt-crumb-in .cur { color: var(--rust); font-weight: 600; }
  .pt-hero { padding: 40px 0 18px; }
  .pt-eye { font-family: 'JetBrains Mono', monospace; font-size: 10.5px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--rust); font-weight: 700; margin: 0; }
  .pt-h1 { font-family: 'Fraunces', serif; font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 500; letter-spacing: -0.02em; margin: 8px 0 0; }
  .pt-h1 em { font-style: italic; color: var(--rust); }
  .pt-kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px; margin: 8px 0 22px; }
  .pt-kpi { background: var(--paper); border: 1px solid var(--rule); border-radius: 14px; padding: 16px 18px; }
  .pt-kpi-v { font-family: 'Fraunces', serif; font-size: 28px; font-weight: 500; line-height: 1; }
  .pt-kpi-l { font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-500); margin-top: 7px; font-weight: 600; }
  .pt-sect-h { font-family: 'Fraunces', serif; font-size: 1.35rem; font-weight: 500; margin: 26px 0 12px; } .pt-sect-h em { font-style: italic; color: var(--rust); }
  .pt-card { background: var(--paper); border: 1px solid var(--rule); border-radius: 14px; overflow: hidden; margin-bottom: 20px; }
  table.pt-tbl { width: 100%; border-collapse: collapse; }
  .pt-tbl th { font-family: 'JetBrains Mono', monospace; font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-500); text-align: left; padding: 11px 16px; border-bottom: 1px solid var(--rule); font-weight: 700; background: var(--sand-100); }
  .pt-tbl td { padding: 11px 16px; border-bottom: 1px solid var(--rule); font-size: 13.5px; } .pt-tbl tr:last-child td { border-bottom: none; }
  .pt-pill { font-family: 'JetBrains Mono', monospace; font-size: 9.5px; letter-spacing: 0.06em; text-transform: uppercase; padding: 3px 9px; border-radius: 100px; font-weight: 700; }
  .pt-pill.green { background: rgba(26,107,53,0.12); color: #1A6B35; } .pt-pill.grey { background: rgba(59,58,48,0.10); color: var(--ink-500); } .pt-pill.amber { background: rgba(176,124,0,0.14); color: #946322; } .pt-pill.red { background: rgba(160,66,30,0.12); color: var(--rust); }
  .pt-btn { background: var(--rust); border: none; color: #fff; padding: 9px 18px; border-radius: 8px; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 700; text-decoration: none; display: inline-block; }
  .pt-link { color: var(--rust); text-decoration: none; font-weight: 500; }
  .pt-empty { padding: 26px; text-align: center; color: var(--ink-500); font-family: 'JetBrains Mono', monospace; font-size: 12px; }
</style>

<div class="pt-crumb"><div class="pt-crumb-in"><a href="/aquintutor">AQUINTUTOR</a> <span style="margin:0 8px;">/</span> {isSuper ? <a href="/aquintutor/admin">COMMAND CENTER</a> : 'ADMIN'} <span style="margin:0 8px;">/</span> <span class="cur">PARTNER</span></div></div>

<main class="pt">
  <div class="pt-hero">
    <p class="pt-eye">AquinTutor · Partner console</p>
    <h1 class="pt-h1">Your <em>catalogue</em>.</h1>
  </div>

  <div class="pt-kpis">
    <div class="pt-kpi"><div class="pt-kpi-v">{courses.length}</div><div class="pt-kpi-l">Hosted courses</div></div>
    <div class="pt-kpi"><div class="pt-kpi-v">{totalEnroll}</div><div class="pt-kpi-l">Total enrolments</div></div>
    <div class="pt-kpi"><div class="pt-kpi-v">{totalCerts}</div><div class="pt-kpi-l">Certificates issued</div></div>
    <div class="pt-kpi"><div class="pt-kpi-v">~CHF {grossChf}</div><div class="pt-kpi-l">Gross (pre-tax)</div></div>
  </div>

  <h2 class="pt-sect-h">My <em>partnership</em></h2>
  <div class="pt-card">
  {myApplications.length === 0 ? (
    <div class="pt-empty">No partnership application on file. <a href="/aquintutor/partnerships" class="pt-link">Apply to host a course &rarr;</a></div>
  ) : (
    <table class="pt-tbl">
      <thead><tr><th>Organisation</th><th>Intended course</th><th>Tier</th><th>Status</th><th>Applied</th></tr></thead>
      <tbody>
        {myApplications.map((a) => (
          <tr>
            <td>{a.org_name}</td><td>{a.intended_course_title}</td>
            <td><span class="pt-pill grey">{a.tier}</span></td>
            <td><span class={"pt-pill " + (a.status === 'approved' ? 'green' : a.status === 'declined' ? 'red' : 'amber')}>{a.status}</span></td>
            <td>{fmt(a.created_at)}</td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
  </div>

  <h2 class="pt-sect-h">My <em>courses</em></h2>
  <div class="pt-card">
  {courses.length === 0 ? (
    <div class="pt-empty">No hosted courses yet. Once your partnership is approved, your courses appear here. <a href="/aquintutor/partnerships" class="pt-link">Apply &rarr;</a></div>
  ) : (
    <table class="pt-tbl">
      <thead><tr><th>Course</th><th>Price</th><th>Enrolled</th><th>Status</th><th></th></tr></thead>
      <tbody>
        {courses.map((c) => (
          <tr>
            <td><a href={'/admin/aquintutor/courses/' + c.id + '/edit'} class="pt-link">{c.title}</a></td>
            <td>{c.price ? '₹' + (c.price / 100).toFixed(0) : 'Free'}</td>
            <td>{c.enrolled}</td>
            <td>{c.is_published ? <span class="pt-pill green">Live</span> : <span class="pt-pill grey">Draft</span>}</td>
            <td><a href={'/aquintutor/courses/' + c.slug} class="pt-link" target="_blank" rel="noopener">View</a></td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
  </div>

  <div style="margin:8px 0 50px;"><a href="/aquintutor/partnerships" class="pt-btn">Host another course &rarr;</a></div>
</main>
</AquintutorLayout>
