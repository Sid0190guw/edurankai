---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { listAllPayouts, decidePayout, payoutTotals } from '@/lib/partner-payouts';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login?next=/aquintutor/admin/payouts');
const isSuper = user.role === 'admin' || user.role === 'super_admin';
// Partners must never see other partners' payouts.
if (!isSuper) return Astro.redirect('/aquintutor/admin/partner');

let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const action = (fd.get('_action') as string) || '';
    const id = (fd.get('id') as string) || '';
    const note = ((fd.get('note') as string) || '').trim();
    const paidRef = ((fd.get('paid_ref') as string) || '').trim();
    if (id && (action === 'approve' || action === 'paid' || action === 'rejected')) {
      const r = await decidePayout(id, action as any, user.id, note || undefined, paidRef || undefined);
      okMsg = r.ok ? 'Updated.' : '';
      errMsg = r.ok ? '' : (r.error || 'Could not update.');
    }
  } catch (_) { errMsg = 'Could not update.'; }
}

const url = new URL(Astro.request.url);
const filter = url.searchParams.get('status') || 'all';
const payouts = await listAllPayouts(filter);
const totals = await payoutTotals();

function inr(paise: any) { const n = Number(paise) || 0; return '₹' + (n / 100).toLocaleString('en-IN', { maximumFractionDigits: 0 }); }
function fmt(d: any) { try { return d ? new Date(d).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) : '-'; } catch { return '-'; } }
const TABS = ['all', 'requested', 'approved', 'paid', 'rejected'];
function badge(s: string) {
  if (s === 'paid') return 'background:rgba(16,185,129,0.14);color:#047857;';
  if (s === 'rejected') return 'background:rgba(239,68,68,0.12);color:#b91c1c;';
  if (s === 'approved') return 'background:rgba(59,130,246,0.12);color:#1d4ed8;';
  return 'background:rgba(250,204,21,0.16);color:#92400e;';
}
---
<AquintutorLayout title="Partner payouts">
  <section style="max-width:1000px;margin:0 auto;padding:8px 4px 48px;">
    <p style="font-size:11px;font-family:monospace;text-transform:uppercase;letter-spacing:0.15em;color:#FF4F00;font-weight:700;margin:0 0 4px;">AquinTutor admin</p>
    <h1 style="font-size:1.6rem;font-weight:600;margin:0 0 4px;">Partner payout ledger</h1>
    <p style="font-size:14px;color:var(--ac-ink-soft,#6a635c);margin:0 0 18px;">Review and settle partner revenue-share payouts. <a href="/aquintutor/admin/partner" style="color:#FF4F00;text-decoration:none;">Back to partner console</a></p>

    {okMsg && <div style="background:#ecfdf5;color:#047857;border:1px solid #a7f3d0;border-radius:8px;padding:9px 13px;font-size:13px;margin-bottom:13px;">{okMsg}</div>}
    {errMsg && <div style="background:#fef2f2;color:#b91c1c;border:1px solid #fecaca;border-radius:8px;padding:9px 13px;font-size:13px;margin-bottom:13px;">{errMsg}</div>}

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-bottom:18px;">
      <div style="background:var(--ac-paper,#fff);border:1px solid rgba(0,0,0,0.08);border-radius:10px;padding:14px;"><strong style="font-size:1.5rem;display:block;line-height:1;">{totals.requested}</strong><span style="font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:#8a8078;">Awaiting review</span></div>
      <div style="background:var(--ac-paper,#fff);border:1px solid rgba(0,0,0,0.08);border-radius:10px;padding:14px;"><strong style="font-size:1.5rem;display:block;line-height:1;">{inr(totals.pendingAmt)}</strong><span style="font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:#8a8078;">Pending amount</span></div>
      <div style="background:var(--ac-paper,#fff);border:1px solid rgba(0,0,0,0.08);border-radius:10px;padding:14px;"><strong style="font-size:1.5rem;display:block;line-height:1;">{inr(totals.paidAmt)}</strong><span style="font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:#8a8078;">Paid lifetime</span></div>
    </div>

    <div style="display:flex;gap:6px;margin-bottom:14px;flex-wrap:wrap;">
      {TABS.map((t) => (
        <a href={'/aquintutor/admin/payouts?status=' + t} style={'font-size:13px;font-weight:600;padding:6px 14px;border-radius:100px;text-decoration:none;text-transform:capitalize;' + (filter === t ? 'background:#FF4F00;color:#fff;' : 'background:rgba(0,0,0,0.05);color:#4a443e;')}>{t}</a>
      ))}
    </div>

    <div style="background:var(--ac-paper,#fff);border:1px solid rgba(0,0,0,0.08);border-radius:12px;overflow:hidden;">
      {payouts.length === 0 ? (
        <p style="padding:30px;text-align:center;color:#8a8078;font-size:14px;">No payouts in this view.</p>
      ) : (
        <div style="overflow-x:auto;">
          <table style="width:100%;border-collapse:collapse;font-size:13.5px;">
            <thead><tr style="text-align:left;">
              <th style="padding:10px 12px;border-bottom:1px solid rgba(0,0,0,0.08);font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#9a8f86;">Partner</th>
              <th style="padding:10px 12px;border-bottom:1px solid rgba(0,0,0,0.08);font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#9a8f86;">Amount</th>
              <th style="padding:10px 12px;border-bottom:1px solid rgba(0,0,0,0.08);font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#9a8f86;">Method</th>
              <th style="padding:10px 12px;border-bottom:1px solid rgba(0,0,0,0.08);font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#9a8f86;">Requested</th>
              <th style="padding:10px 12px;border-bottom:1px solid rgba(0,0,0,0.08);font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#9a8f86;">Status</th>
              <th style="padding:10px 12px;border-bottom:1px solid rgba(0,0,0,0.08);font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#9a8f86;">Action</th>
            </tr></thead>
            <tbody>
              {payouts.map((p: any) => (
                <tr style="border-bottom:1px solid rgba(0,0,0,0.05);vertical-align:top;">
                  <td style="padding:11px 12px;">
                    <strong style="display:block;">{p.partner_name || 'Partner'}</strong>
                    <span style="font-size:12px;color:#8a8078;">{p.partner_email}</span>
                    {p.details && <span style="display:block;font-size:11.5px;color:#9a8f86;margin-top:3px;">{p.details}</span>}
                  </td>
                  <td style="padding:11px 12px;font-weight:700;">{inr(p.amount_paise)}</td>
                  <td style="padding:11px 12px;">{p.method}</td>
                  <td style="padding:11px 12px;color:#6a635c;">{fmt(p.requested_at)}</td>
                  <td style="padding:11px 12px;"><span style={'font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;padding:2px 9px;border-radius:100px;' + badge(p.status)}>{p.status}</span>{p.paid_ref && <span style="display:block;font-size:11px;color:#8a8078;margin-top:3px;">ref: {p.paid_ref}</span>}</td>
                  <td style="padding:11px 12px;">
                    {(p.status === 'requested' || p.status === 'approved') ? (
                      <div style="display:flex;flex-direction:column;gap:6px;min-width:170px;">
                        {p.status === 'requested' && (
                          <form method="post" style="display:flex;gap:5px;">
                            <input type="hidden" name="_action" value="approve" /><input type="hidden" name="id" value={p.id} />
                            <button type="submit" style="background:rgba(59,130,246,0.12);color:#1d4ed8;border:0;border-radius:7px;padding:6px 12px;font-size:12.5px;font-weight:600;cursor:pointer;">Approve</button>
                          </form>
                        )}
                        <form method="post" style="display:flex;gap:5px;align-items:center;">
                          <input type="hidden" name="_action" value="paid" /><input type="hidden" name="id" value={p.id} />
                          <input type="text" name="paid_ref" placeholder="txn ref" style="border:1px solid rgba(0,0,0,0.15);border-radius:6px;padding:5px 8px;font-size:12px;width:88px;" />
                          <button type="submit" style="background:rgba(16,185,129,0.14);color:#047857;border:0;border-radius:7px;padding:6px 12px;font-size:12.5px;font-weight:600;cursor:pointer;">Mark paid</button>
                        </form>
                        <form method="post" style="display:flex;gap:5px;">
                          <input type="hidden" name="_action" value="rejected" /><input type="hidden" name="id" value={p.id} />
                          <button type="submit" style="background:rgba(239,68,68,0.10);color:#b91c1c;border:0;border-radius:7px;padding:6px 12px;font-size:12.5px;font-weight:600;cursor:pointer;">Reject</button>
                        </form>
                      </div>
                    ) : <span style="font-size:12px;color:#a99e94;">settled</span>}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </section>
</AquintutorLayout>
