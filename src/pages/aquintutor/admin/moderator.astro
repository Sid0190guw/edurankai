---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login?next=/aquintutor/admin/moderator');
if (user.role === 'applicant') return Astro.redirect('/portal');

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
async function safeRows(q: any): Promise<any[]> { try { return rows(await db.execute(q)); } catch { return []; } }

let flash = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const entity = String(fd.get('entity') || ''), action = String(fd.get('action') || ''), id = String(fd.get('id') || '');
    if (!id) throw new Error('missing id');
    if (entity === 'doubt' && action === 'resolve') await db.execute(sql`UPDATE doubts SET status = 'resolved' WHERE id = ${id}`);
    else if (entity === 'doubt' && action === 'delete') await db.execute(sql`DELETE FROM doubts WHERE id = ${id}`);
    else if (entity === 'feed' && action === 'remove') await db.execute(sql`DELETE FROM feed_posts WHERE id = ${id}`);
    else if (entity === 'feed' && action === 'pin') await db.execute(sql`UPDATE feed_posts SET is_pinned = true WHERE id = ${id}`);
    else if (entity === 'club' && action === 'hide') await db.execute(sql`UPDATE clubs SET is_active = false WHERE id = ${id}`);
    else throw new Error('unknown');
    flash = entity + ' · ' + action + ' done';
  } catch (e: any) { flash = 'Error: ' + String(e?.message || e).slice(0, 120); }
}

const doubts = await safeRows(sql`SELECT id, status, created_at, subject FROM doubts ORDER BY (status='open') DESC, created_at DESC LIMIT 30`);
const feed = await safeRows(sql`SELECT id, kind, COALESCE(title,'(untitled)') AS title, COALESCE(view_count,0) AS views, COALESCE(like_count,0) AS likes, is_pinned FROM feed_posts ORDER BY created_at DESC LIMIT 25`);
const clubs = await safeRows(sql`SELECT id, slug, name, COALESCE(member_count,0) AS members, is_active FROM clubs ORDER BY created_at DESC LIMIT 20`);
// Proctoring integrity events (advisory only — humans decide).
const integrity = await safeRows(sql`SELECT event_type, severity, COUNT(*)::int AS n FROM test_attempt_events GROUP BY event_type, severity ORDER BY n DESC LIMIT 14`);

const kpi = {
  openDoubts: doubts.filter((d: any) => d.status === 'open').length,
  feed: feed.length,
  flaggedClubs: clubs.filter((c: any) => !c.is_active).length,
  integrityEvents: integrity.reduce((s: number, e: any) => s + (e.n || 0), 0),
};
function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }); } catch { return '—'; } }
const isSuper = user.role === 'admin' || user.role === 'super_admin';
---
<AquintutorLayout title="Moderator panel" description="AquinTutor content + integrity moderation." noindex={true}>
<style>
  .md { max-width: 1280px; margin: 0 auto; padding: 0 28px; }
  .md-crumb { border-bottom: 1px solid var(--rule); background: var(--sand-100); margin: 0 -28px; }
  .md-crumb-in { max-width: 1280px; margin: 0 auto; padding: 10px 28px; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.08em; color: var(--ink-500); }
  .md-crumb-in a { color: var(--ink-500); text-decoration: none; } .md-crumb-in .cur { color: var(--rust); font-weight: 600; }
  .md-hero { padding: 40px 0 18px; }
  .md-eye { font-family: 'JetBrains Mono', monospace; font-size: 10.5px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--rust); font-weight: 700; margin: 0; }
  .md-h1 { font-family: 'Fraunces', serif; font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 500; letter-spacing: -0.02em; margin: 8px 0 0; }
  .md-h1 em { font-style: italic; color: var(--rust); }
  .md-flash { padding: 10px 16px; border-radius: 10px; margin-bottom: 16px; font-family: 'JetBrains Mono', monospace; font-size: 12px; background: rgba(26,107,53,0.08); border: 1px solid rgba(26,107,53,0.35); color: #1A6B35; }
  .md-kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px; margin: 8px 0 22px; }
  .md-kpi { background: var(--paper); border: 1px solid var(--rule); border-radius: 14px; padding: 16px 18px; }
  .md-kpi-v { font-family: 'Fraunces', serif; font-size: 28px; font-weight: 500; line-height: 1; }
  .md-kpi-l { font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-500); margin-top: 7px; font-weight: 600; }
  .md-sect-h { font-family: 'Fraunces', serif; font-size: 1.35rem; font-weight: 500; margin: 26px 0 12px; }
  .md-sect-h em { font-style: italic; color: var(--rust); }
  .md-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; } @media (max-width: 900px) { .md-grid { grid-template-columns: 1fr; } }
  .md-card { background: var(--paper); border: 1px solid var(--rule); border-radius: 14px; overflow: hidden; margin-bottom: 16px; }
  table.md-tbl { width: 100%; border-collapse: collapse; }
  .md-tbl th { font-family: 'JetBrains Mono', monospace; font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-500); text-align: left; padding: 10px 14px; border-bottom: 1px solid var(--rule); font-weight: 700; background: var(--sand-100); }
  .md-tbl td { padding: 10px 14px; border-bottom: 1px solid var(--rule); font-size: 13px; }
  .md-tbl tr:last-child td { border-bottom: none; }
  .md-pill { font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.06em; text-transform: uppercase; padding: 2px 8px; border-radius: 100px; font-weight: 700; }
  .md-pill.green { background: rgba(26,107,53,0.12); color: #1A6B35; } .md-pill.amber { background: rgba(176,124,0,0.14); color: #946322; }
  .md-pill.red { background: rgba(160,66,30,0.12); color: var(--rust); } .md-pill.grey { background: rgba(59,58,48,0.10); color: var(--ink-500); }
  .md-acts { display: flex; gap: 5px; flex-wrap: wrap; }
  .md-btn { background: var(--paper); border: 1px solid var(--rule); color: var(--ink); padding: 4px 10px; border-radius: 6px; font-family: 'JetBrains Mono', monospace; font-size: 10px; cursor: pointer; font-weight: 600; }
  .md-btn.go { border-color: rgba(26,107,53,0.45); color: #1A6B35; } .md-btn.warn { border-color: rgba(160,66,30,0.45); color: var(--rust); }
  form.inline { display: inline; margin: 0; }
  .md-empty { padding: 22px; text-align: center; color: var(--ink-500); font-family: 'JetBrains Mono', monospace; font-size: 12px; }
  .md-note { background: rgba(176,124,0,0.08); border: 1px solid rgba(176,124,0,0.3); border-radius: 12px; padding: 14px 18px; font-size: 13px; color: #6b4e0e; line-height: 1.6; margin-bottom: 18px; }
</style>

<div class="md-crumb"><div class="md-crumb-in"><a href="/aquintutor">AQUINTUTOR</a> <span style="margin:0 8px;">/</span> {isSuper ? <a href="/aquintutor/admin">COMMAND CENTER</a> : 'ADMIN'} <span style="margin:0 8px;">/</span> <span class="cur">MODERATOR</span></div></div>

<main class="md">
  <div class="md-hero">
    <p class="md-eye">AquinTutor · Moderation &amp; integrity</p>
    <h1 class="md-h1">Keep it <em>clean</em>.</h1>
  </div>

  {flash && <div class="md-flash">{flash}</div>}

  <div class="md-note">Integrity signals below are <strong>advisory only</strong>. Automated flags never penalise a learner automatically — a human reviews the full context and decides. False positives can cause real harm.</div>

  <div class="md-kpis">
    <div class="md-kpi"><div class="md-kpi-v">{kpi.openDoubts}</div><div class="md-kpi-l">Open doubts</div></div>
    <div class="md-kpi"><div class="md-kpi-v">{kpi.feed}</div><div class="md-kpi-l">Feed posts</div></div>
    <div class="md-kpi"><div class="md-kpi-v">{kpi.flaggedClubs}</div><div class="md-kpi-l">Hidden clubs</div></div>
    <div class="md-kpi"><div class="md-kpi-v">{kpi.integrityEvents}</div><div class="md-kpi-l">Integrity events</div></div>
  </div>

  <div class="md-grid">
    <div>
      <h2 class="md-sect-h">Doubt <em>queue</em></h2>
      <div class="md-card">
      {doubts.length === 0 ? <div class="md-empty">No doubts.</div> : (
        <table class="md-tbl"><thead><tr><th>Subject</th><th>Posted</th><th>Status</th><th></th></tr></thead><tbody>
          {doubts.map((d) => (
            <tr>
              <td>{d.subject || String(d.id).slice(0,8)}</td><td>{fmt(d.created_at)}</td>
              <td><span class={"md-pill " + (d.status === 'resolved' ? 'green' : 'amber')}>{d.status}</span></td>
              <td><div class="md-acts">
                {d.status !== 'resolved' && <form class="inline" method="POST"><input type="hidden" name="entity" value="doubt"/><input type="hidden" name="action" value="resolve"/><input type="hidden" name="id" value={d.id}/><button class="md-btn go">Resolve</button></form>}
                <form class="inline" method="POST" onsubmit="return confirm('Delete?')"><input type="hidden" name="entity" value="doubt"/><input type="hidden" name="action" value="delete"/><input type="hidden" name="id" value={d.id}/><button class="md-btn warn">Delete</button></form>
              </div></td>
            </tr>
          ))}
        </tbody></table>
      )}
      </div>
    </div>

    <div>
      <h2 class="md-sect-h">Feed <em>posts</em></h2>
      <div class="md-card">
      {feed.length === 0 ? <div class="md-empty">No posts.</div> : (
        <table class="md-tbl"><thead><tr><th>Post</th><th>Kind</th><th>Views</th><th></th></tr></thead><tbody>
          {feed.map((f) => (
            <tr>
              <td>{f.title}{f.is_pinned && <span class="md-pill grey" style="margin-left:6px;">pin</span>}</td>
              <td><span class="md-pill grey">{f.kind}</span></td><td>{f.views}</td>
              <td><div class="md-acts">
                {!f.is_pinned && <form class="inline" method="POST"><input type="hidden" name="entity" value="feed"/><input type="hidden" name="action" value="pin"/><input type="hidden" name="id" value={f.id}/><button class="md-btn">Pin</button></form>}
                <form class="inline" method="POST" onsubmit="return confirm('Remove?')"><input type="hidden" name="entity" value="feed"/><input type="hidden" name="action" value="remove"/><input type="hidden" name="id" value={f.id}/><button class="md-btn warn">Remove</button></form>
              </div></td>
            </tr>
          ))}
        </tbody></table>
      )}
      </div>
    </div>
  </div>

  <h2 class="md-sect-h">Integrity <em>signals</em> · advisory</h2>
  <div class="md-card">
  {integrity.length === 0 ? <div class="md-empty">No proctoring events recorded yet.</div> : (
    <table class="md-tbl"><thead><tr><th>Event type</th><th>Severity</th><th>Count</th></tr></thead><tbody>
      {integrity.map((e) => (
        <tr>
          <td style="font-family:'JetBrains Mono',monospace;font-size:12px;">{e.event_type}</td>
          <td><span class={"md-pill " + (e.severity === 'high' ? 'red' : e.severity === 'medium' ? 'amber' : 'grey')}>{e.severity || 'low'}</span></td>
          <td>{e.n}</td>
        </tr>
      ))}
    </tbody></table>
  )}
  </div>
</main>
</AquintutorLayout>
