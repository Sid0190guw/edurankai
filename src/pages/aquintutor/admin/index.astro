                {f.is_pinned
                  ? <form class="inline" method="POST"><input type="hidden" name="entity" value="feed"/><input type="hidden" name="action" value="unpin"/><input type="hidden" name="id" value={f.id}/><button class="cc-btn">Unpin</button></form>
                  : <form class="inline" method="POST"><input type="hidden" name="entity" value="feed"/><input type="hidden" name="action" value="pin"/><input type="hidden" name="id" value={f.id}/><button class="cc-btn alt">Pin</button></form>}
                <form class="inline" method="POST" onsubmit="return confirm('Remove post?')"><input type="hidden" name="entity" value="feed"/><input type="hidden" name="action" value="remove"/><input type="hidden" name="id" value={f.id}/><button class="cc-btn warn">Remove</button></form>
              </div></td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
    </div>
  </div>

  {/* COMPUTE & PRACTICE */}
  <div class="cc-panel" data-panel="compute">
    <h2 class="cc-sect-h">LLM training <em>jobs</em></h2>
    <div class="cc-card">
    {jobs.length === 0 ? <div class="cc-empty">No training jobs.</div> : (
      <table class="cc-tbl">
        <thead><tr><th>Job</th><th>Base model</th><th>Progress</th><th>Status</th><th>Set</th></tr></thead>
        <tbody>
          {jobs.map((j) => (
            <tr>
              <td>{j.job_name}</td><td class="cc-sub">{j.base_model || '—'}</td><td>{j.pct}%</td>
              <td><span class="cc-pill amber">{j.status}</span></td>
              <td><div class="cc-acts">
                {['queued','running','completed','failed','cancelled'].map((s) => (
                  <form class="inline" method="POST"><input type="hidden" name="entity" value="job"/><input type="hidden" name="action" value="status"/><input type="hidden" name="value" value={s}/><input type="hidden" name="id" value={j.id}/><button class="cc-btn">{s}</button></form>
                ))}
              </div></td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
    </div>

    <h2 class="cc-sect-h">Practice <em>problems</em></h2>
    <div class="cc-card">
    {practice.length === 0 ? <div class="cc-empty">No practice problems.</div> : (
      <table class="cc-tbl">
        <thead><tr><th>Title</th><th>Topic</th><th>Difficulty</th><th>Solved</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          {practice.map((p) => (
            <tr>
              <td>{p.title}</td><td>{p.topic || '—'}</td>
              <td><span class={"cc-pill " + (p.difficulty === 'Hard' ? 'red' : p.difficulty === 'Medium' ? 'amber' : 'green')}>{p.difficulty || '—'}</span></td>
              <td>{p.solved}</td>
              <td>{p.is_active ? <span class="cc-pill green">Live</span> : <span class="cc-pill grey">Hidden</span>}</td>
              <td><div class="cc-acts">
                {p.is_active
                  ? <form class="inline" method="POST"><input type="hidden" name="entity" value="practice"/><input type="hidden" name="action" value="deactivate"/><input type="hidden" name="id" value={p.id}/><button class="cc-btn">Hide</button></form>
                  : <form class="inline" method="POST"><input type="hidden" name="entity" value="practice"/><input type="hidden" name="action" value="activate"/><input type="hidden" name="id" value={p.id}/><button class="cc-btn go">Publish</button></form>}
              </div></td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
    </div>
  </div>

  <div style="height:50px;"></div>
</main>

<script is:inline>
  (function () {
    var tabs = document.querySelectorAll('.cc-tab');
    var panels = document.querySelectorAll('.cc-panel');
    tabs.forEach(function (t) {
      t.addEventListener('click', function () {
        tabs.forEach(function (x) { x.classList.remove('active'); });
        panels.forEach(function (x) { x.classList.remove('active'); });
        t.classList.add('active');
        var p = document.querySelector('.cc-panel[data-panel="' + t.getAttribute('data-tab') + '"]');
        if (p) p.classList.add('active');
        try { history.replaceState(null, '', '#' + t.getAttribute('data-tab')); } catch (e) {}
      });
    });
    var h = (location.hash || '').replace('#', '');
    if (h) { var tb = document.querySelector('.cc-tab[data-tab="' + h + '"]'); if (tb) tb.click(); }
  })();
</script>
</AquintutorLayout>
