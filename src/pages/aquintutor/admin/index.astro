---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login?next=/aquintutor/admin');
if (user.role === 'applicant') return Astro.redirect('/portal');
const isAdmin = user.role === 'admin' || user.role === 'super_admin';
if (!isAdmin) return Astro.redirect('/aquintutor');

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
async function safeRows(q: any): Promise<any[]> { try { return rows(await db.execute(q)); } catch { return []; } }
async function count(table: string, where?: any): Promise<number> {
  try {
    const q = where
      ? sql`SELECT COUNT(*)::int AS c FROM ${sql.raw(table)} WHERE ${where}`
      : sql`SELECT COUNT(*)::int AS c FROM ${sql.raw(table)}`;
    const r = rows(await db.execute(q));
    return r[0]?.c ?? 0;
  } catch { return 0; }
}

// ---------------------------------------------------------------- POST actions
let flash = '', flashOk = false;
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const entity = String(fd.get('entity') || '');
    const action = String(fd.get('action') || '');
    const id = String(fd.get('id') || '');
    const value = String(fd.get('value') || '');

    // ---- one-click showcase course (no id needed) -------------------------
    if (entity === 'showcase' && action === 'seed') {
      const { ensureAquintutorAuthoringSchema, createModule, createBlock } = await import('@/lib/aquintutor-authoring');
      await ensureAquintutorAuthoringSchema();
      const slug = 'aquintutor-showcase';
      const existing = rows(await db.execute(sql`SELECT id FROM training_courses WHERE slug = ${slug} LIMIT 1`))[0] as any;
      let courseId = existing?.id;
      if (!courseId) {
        const c = rows(await db.execute(sql`INSERT INTO training_courses (slug, title, subtitle, short_desc, description, level, access_type, is_published, school, difficulty, duration_hours, credit_hours, created_at, updated_at)
          VALUES (${slug}, 'AquinTutor Showcase · Physics of Motion', 'Text, a worked example, a LIVE simulator, and a proctored test — in one lesson.', 'A short course that demonstrates what AquinTutor does that a video platform cannot.', 'Learn the pendulum by manipulating a real simulator embedded in the lesson, then prove it on a proctored test that issues a blockchain certificate.', 'beginner', 'public', true, 'Sciences', 'beginner', 1, 1, NOW(), NOW())
          RETURNING id`))[0] as any;
        courseId = c?.id;
      } else {
        // rebuild lessons/modules for a clean demo
        await db.execute(sql`DELETE FROM training_lessons WHERE course_id = ${courseId}`).catch(()=>{});
        await db.execute(sql`DELETE FROM training_modules WHERE course_id = ${courseId}`).catch(()=>{});
        await db.execute(sql`UPDATE training_courses SET is_published = true WHERE id = ${courseId}`).catch(()=>{});
      }
      const mkLesson = async (moduleId: string, lslug: string, title: string, ord: number) => {
        const l = rows(await db.execute(sql`INSERT INTO training_lessons (course_id, module_id, slug, title, status, lesson_kind, order_in_module, estimated_minutes, created_at, updated_at)
          VALUES (${courseId}, ${moduleId}, ${lslug}, ${title}, 'published', 'lesson', ${ord}, 8, NOW(), NOW()) RETURNING id`))[0] as any;
        return l?.id;
      };
      const m1 = await createModule({ courseId, title: 'Orientation', order: 0 });
      const m2 = await createModule({ courseId, title: 'The live lab', order: 1 });
      const m3 = await createModule({ courseId, title: 'Prove it', order: 2 });

      const l1 = await mkLesson(m1, 'what-is-a-pendulum', 'What is a pendulum?', 0);
      if (l1) {
        await createBlock(l1, { kind: 'heading', content: { level: 1, text: 'The simple pendulum' } });
        await createBlock(l1, { kind: 'text', content: { md: 'A pendulum swings because gravity pulls the bob back toward the bottom. Its period — the time for one full swing — depends on **length** and **gravity**, not on how heavy the bob is. That last part surprises most people.' } });
        await createBlock(l1, { kind: 'callout', content: { tone: 'tip', title: 'Key idea', body: 'Period T = 2π·√(L/g). Double the length and the period grows by √2, not 2.' } });
        await createBlock(l1, { kind: 'mcq', content: { question: 'Which change makes a pendulum swing slower (longer period)?', options: ['A heavier bob', 'A longer string', 'Stronger gravity', 'A bigger initial push'], correct: 1, explanation: 'Period depends on length and gravity only — a longer string increases the period.' } });
      }
      const l2 = await mkLesson(m2, 'see-it-move', 'See it move — live', 0);
      if (l2) {
        await createBlock(l2, { kind: 'text', content: { md: 'Reading about it is one thing. **Drive it yourself.** Drag the sliders below — change the length and watch the period change in real time. Switch to *Driven* mode and turn up the drive to see resonance and chaos.' } });
        await createBlock(l2, { kind: 'embed_lab', content: { slug: 'pendulum', height: 640, caption: 'A real pendulum simulator — RK4 physics, live energy + phase plots. Not a video.' } });
        await createBlock(l2, { kind: 'callout', content: { tone: 'info', title: 'This is the difference', body: 'A video platform shows you a pendulum. AquinTutor hands you the controls.' } });
        await createBlock(l2, { kind: 'embed_simulator', content: { target: 'quantum/composer', height: 680, caption: 'And when the subject is quantum — here is a real circuit composer, also embedded in a lesson.' } });
      }
      const l3 = await mkLesson(m3, 'your-assessment', 'Your assessment', 0);
      if (l3) {
        await createBlock(l3, { kind: 'text', content: { md: 'Finish the course by passing a short proctored assessment. On completion you receive a **blockchain-verifiable certificate** anyone can check at /verify.' } });
        await createBlock(l3, { kind: 'mcq', content: { question: 'The period of a pendulum is independent of…', options: ['its length', 'the local gravity', 'the mass of the bob', 'none of these'], correct: 2, explanation: 'Correct — to first order the period does not depend on the bob mass.' } });
        await createBlock(l3, { kind: 'callout', content: { tone: 'success', title: 'On completion', body: 'A signed, hash-chained certificate is auto-issued and appears on the public ledger at /verify.' } });
      }
      flash = 'Showcase course built · open /aquintutor/courses/aquintutor-showcase'; flashOk = true;
      // fall through to render
    } else {
    if (!id) throw new Error('missing id');
    const run = (q: any) => db.execute(q);

    if (entity === 'course' && action === 'publish') await run(sql`UPDATE training_courses SET is_published = true WHERE id = ${id}`);
    else if (entity === 'course' && action === 'unpublish') await run(sql`UPDATE training_courses SET is_published = false WHERE id = ${id}`);
    else if (entity === 'course' && action === 'delete') await run(sql`DELETE FROM training_courses WHERE id = ${id}`);
    else if (entity === 'mentor' && action === 'verify') await run(sql`UPDATE mentors SET verified = true, is_active = true WHERE id = ${id}`);
    else if (entity === 'mentor' && action === 'unverify') await run(sql`UPDATE mentors SET verified = false WHERE id = ${id}`);
    else if (entity === 'mentor' && action === 'deactivate') await run(sql`UPDATE mentors SET is_active = false WHERE id = ${id}`);
    else if (entity === 'partnership' && action === 'status') await run(sql`UPDATE partnership_applications SET status = ${value} WHERE id = ${id}`);
    else if (entity === 'eir' && action === 'status') await run(sql`UPDATE eir_applications SET status = ${value} WHERE id = ${id}`);
    else if (entity === 'atlas' && action === 'status') await run(sql`UPDATE atlas_partner_leads SET status = ${value} WHERE id = ${id}`);
    else if (entity === 'placement' && action === 'status') await run(sql`UPDATE senior_placement_requests SET status = ${value} WHERE id = ${id}`);
    else if (entity === 'studyabroad' && action === 'status') await run(sql`UPDATE study_abroad_requests SET status = ${value} WHERE id = ${id}`);
    else if (entity === 'counselling' && action === 'status') await run(sql`UPDATE counselling_requests SET status = ${value} WHERE id = ${id}`);
    else if (entity === 'club' && action === 'activate') await run(sql`UPDATE clubs SET is_active = true WHERE id = ${id}`);
    else if (entity === 'club' && action === 'deactivate') await run(sql`UPDATE clubs SET is_active = false WHERE id = ${id}`);
    else if (entity === 'club' && action === 'delete') await run(sql`DELETE FROM clubs WHERE id = ${id}`);
    else if (entity === 'hackathon' && action === 'status') await run(sql`UPDATE hackathons SET status = ${value} WHERE id = ${id}`);
    else if (entity === 'doubt' && action === 'resolve') await run(sql`UPDATE doubts SET status = 'resolved' WHERE id = ${id}`);
    else if (entity === 'doubt' && action === 'delete') await run(sql`DELETE FROM doubts WHERE id = ${id}`);
    else if (entity === 'feed' && action === 'pin') await run(sql`UPDATE feed_posts SET is_pinned = true WHERE id = ${id}`);
    else if (entity === 'feed' && action === 'unpin') await run(sql`UPDATE feed_posts SET is_pinned = false WHERE id = ${id}`);
    else if (entity === 'feed' && action === 'remove') await run(sql`DELETE FROM feed_posts WHERE id = ${id}`);
    else if (entity === 'job' && action === 'status') await run(sql`UPDATE training_jobs SET status = ${value} WHERE id = ${id}`);
    else if (entity === 'practice' && action === 'activate') await run(sql`UPDATE practice_problems SET is_active = true WHERE id = ${id}`);
    else if (entity === 'practice' && action === 'deactivate') await run(sql`UPDATE practice_problems SET is_active = false WHERE id = ${id}`);
    else if (entity === 'liveclass' && action === 'status') await run(sql`UPDATE live_classes SET status = ${value} WHERE id = ${id}`);
    else throw new Error('unknown action');

    flash = entity + ' updated · ' + action; flashOk = true;
    }
  } catch (e: any) { flash = 'Error: ' + String(e?.message || e).slice(0, 160); flashOk = false; }
}

// ------------------------------------------------------------------ dashboard
const kpi = {
  courses: await count('training_courses'),
  coursesPub: await count('training_courses', sql`is_published = true`),
  lessons: await count('training_lessons'),
  enrollments: await count('training_enrollments'),
  certificates: await count('course_certificates') + await count('universal_certificates'),
  mentors: await count('mentors'),
  mentorsUnverified: await count('mentors', sql`verified = false`),
  clubs: await count('clubs', sql`is_active = true`),
  hackathons: await count('hackathons'),
  doubts: await count('doubts', sql`status = 'open'`),
  feedPosts: await count('feed_posts'),
  practice: await count('practice_problems', sql`is_active = true`),
  liveClasses: await count('live_classes'),
  trainingJobs: await count('training_jobs'),
  meetRooms: await count('meet_rooms'),
  libraryResources: await count('library_resources'),
  jobsBoard: await count('jobs_board', sql`is_active = true`),
  networkProfiles: await count('network_profiles'),
};
const queue = {
  partnership: await count('partnership_applications', sql`status = 'submitted'`),
  eir: await count('eir_applications', sql`status = 'pending'`),
  atlas: await count('atlas_partner_leads', sql`status = 'open'`),
  placement: await count('senior_placement_requests', sql`status = 'open'`),
  studyabroad: await count('study_abroad_requests', sql`status = 'open'`),
  counselling: await count('counselling_requests', sql`status = 'pending'`),
};
const totalQueue = queue.partnership + queue.eir + queue.atlas + queue.placement + queue.studyabroad + queue.counselling;

// ----------------------------------------------------------------- live rows
const courses = await safeRows(sql`SELECT id, slug, title, is_published, COALESCE(enrolled_count,0) AS enrolled, school FROM training_courses ORDER BY updated_at DESC NULLS LAST, created_at DESC LIMIT 25`);
const mentors = await safeRows(sql`SELECT id, slug, full_name, title, verified, is_active, COALESCE(rate_chf_per_hour,0) AS rate, COALESCE(sessions_completed,0) AS sessions FROM mentors ORDER BY created_at DESC LIMIT 25`);
const partnerships = await safeRows(sql`SELECT id, org_name, contact_email, intended_course_title, tier, status FROM partnership_applications ORDER BY created_at DESC LIMIT 25`);
const eir = await safeRows(sql`SELECT id, name, email, status, created_at FROM eir_applications ORDER BY created_at DESC LIMIT 25`);
const atlas = await safeRows(sql`SELECT id, company, email, monthly_volume, status FROM atlas_partner_leads ORDER BY created_at DESC LIMIT 15`);
const placement = await safeRows(sql`SELECT id, name, email, years_experience, status FROM senior_placement_requests ORDER BY created_at DESC LIMIT 15`);
const studyabroad = await safeRows(sql`SELECT id, name, target_level, target_countries, status FROM study_abroad_requests ORDER BY created_at DESC LIMIT 15`);
const counselling = await safeRows(sql`SELECT id, status, created_at FROM counselling_requests ORDER BY created_at DESC LIMIT 15`);
const clubs = await safeRows(sql`SELECT id, slug, name, COALESCE(member_count,0) AS members, is_active, category FROM clubs ORDER BY created_at DESC LIMIT 25`);
const hackathons = await safeRows(sql`SELECT id, slug, title, status, prize_pool_chf FROM hackathons ORDER BY created_at DESC LIMIT 15`);
const doubts = await safeRows(sql`SELECT id, status, created_at FROM doubts ORDER BY created_at DESC LIMIT 20`);
const feed = await safeRows(sql`SELECT id, kind, COALESCE(title,'(untitled)') AS title, COALESCE(view_count,0) AS views, COALESCE(like_count,0) AS likes, is_pinned FROM feed_posts ORDER BY created_at DESC LIMIT 20`);
const jobs = await safeRows(sql`SELECT id, job_name, base_model, status, COALESCE(progress_pct,0) AS pct FROM training_jobs ORDER BY created_at DESC LIMIT 15`);
const practice = await safeRows(sql`SELECT id, slug, title, topic, difficulty, is_active, COALESCE(solved_count,0) AS solved FROM practice_problems ORDER BY created_at DESC LIMIT 25`);
const liveclasses = await safeRows(sql`SELECT id, title, status, scheduled_at, COALESCE(enrolled_count,0) AS enrolled FROM live_classes ORDER BY scheduled_at DESC NULLS LAST LIMIT 15`);

function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }); } catch { return '—'; } }
---
<AquintutorLayout title="Command Center" description="Full administrative control of every AquinTutor surface." noindex={true}>

<style>
  .cc { max-width: 1400px; margin: 0 auto; padding: 0 28px; }
  .cc-crumb { border-bottom: 1px solid var(--rule); background: var(--sand-100); margin: 0 -28px 0; }
  .cc-crumb-in { max-width: 1400px; margin: 0 auto; padding: 10px 28px; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.08em; color: var(--ink-500); }
  .cc-crumb-in a { color: var(--ink-500); text-decoration: none; }
  .cc-crumb-in .cur { color: var(--rust); font-weight: 600; }

  .cc-hero { padding: 44px 0 24px; display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 16px; }
  .cc-eye { font-family: 'JetBrains Mono', monospace; font-size: 10.5px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--rust); font-weight: 700; margin: 0; }
  .cc-h1 { font-family: 'Fraunces', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 500; line-height: 0.98; letter-spacing: -0.02em; color: var(--ink); margin: 10px 0 0; }
  .cc-h1 em { font-style: italic; color: var(--rust); }
  .cc-userbox { text-align: right; }
  .cc-userpill { font-family: 'JetBrains Mono', monospace; font-size: 10.5px; color: var(--ink-500); background: var(--sand-100); border: 1px solid var(--rule); padding: 6px 12px; border-radius: 100px; }
  .cc-userbox a { display: block; margin-top: 8px; font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--rust); text-decoration: none; letter-spacing: 0.04em; }

  .cc-flash { padding: 11px 16px; border-radius: 10px; margin-bottom: 18px; font-family: 'JetBrains Mono', monospace; font-size: 12px; }
  .cc-flash.ok { background: rgba(26,107,53,0.08); border: 1px solid rgba(26,107,53,0.4); color: #1A6B35; }
  .cc-flash.err { background: rgba(160,66,30,0.08); border: 1px solid rgba(160,66,30,0.4); color: var(--rust); }

  .cc-quick { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 22px; }
  .cc-quick a { background: var(--paper); border: 1px solid var(--rule); color: var(--ink); padding: 8px 14px; border-radius: 8px; text-decoration: none; font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.02em; transition: all .15s; }
  .cc-quick a:hover { border-color: var(--rust); color: var(--rust); transform: translateY(-1px); }

  .cc-kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px; margin-bottom: 18px; }
  .cc-kpi { background: var(--paper); border: 1px solid var(--rule); border-radius: 14px; padding: 16px 18px; position: relative; }
  .cc-kpi-val { font-family: 'Fraunces', serif; font-size: 30px; font-weight: 500; line-height: 1; color: var(--ink); letter-spacing: -0.02em; }
  .cc-kpi-lbl { font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-500); margin-top: 7px; font-weight: 600; }
  .cc-kpi.alert { border-color: var(--rust); }
  .cc-kpi.alert .cc-kpi-val { color: var(--rust); }
  .cc-kpi.alert::after { content: ''; position: absolute; top: 12px; right: 12px; width: 7px; height: 7px; border-radius: 50%; background: var(--rust); }

  .cc-tabs { display: flex; gap: 4px; flex-wrap: wrap; margin: 20px 0 22px; border-bottom: 1px solid var(--rule); padding-bottom: 0; }
  .cc-tab { background: transparent; border: none; border-bottom: 2px solid transparent; color: var(--ink-500); padding: 10px 16px; cursor: pointer; font-family: 'JetBrains Mono', monospace; font-size: 11.5px; font-weight: 600; letter-spacing: 0.04em; margin-bottom: -1px; }
  .cc-tab:hover { color: var(--ink); }
  .cc-tab.active { color: var(--rust); border-bottom-color: var(--rust); }
  .cc-tab .badge { background: var(--rust); color: var(--sand-50); border-radius: 100px; padding: 1px 7px; font-size: 9px; margin-left: 6px; font-weight: 700; }

  .cc-panel { display: none; }
  .cc-panel.active { display: block; }
  .cc-sect-h { font-family: 'Fraunces', serif; font-size: 1.4rem; font-weight: 500; letter-spacing: -0.01em; color: var(--ink); margin: 0 0 14px; }
  .cc-sect-h em { font-style: italic; color: var(--rust); }
  .cc-sect-h .cnt { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--ink-500); font-weight: 600; margin-left: 8px; letter-spacing: 0.06em; }

  .cc-card { background: var(--paper); border: 1px solid var(--rule); border-radius: 14px; overflow: hidden; margin-bottom: 28px; }
  table.cc-tbl { width: 100%; border-collapse: collapse; }
  .cc-tbl th { font-family: 'JetBrains Mono', monospace; font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-500); text-align: left; padding: 11px 16px; border-bottom: 1px solid var(--rule); font-weight: 700; background: var(--sand-100); }
  .cc-tbl td { padding: 11px 16px; border-bottom: 1px solid var(--rule); font-size: 13.5px; color: var(--ink); vertical-align: middle; font-family: 'Inter Tight', sans-serif; }
  .cc-tbl tr:last-child td { border-bottom: none; }
  .cc-tbl tr:hover td { background: var(--sand-100); }
  .cc-sub { color: var(--ink-500); font-size: 11px; font-family: 'JetBrains Mono', monospace; }

  .cc-pill { font-family: 'JetBrains Mono', monospace; font-size: 9.5px; letter-spacing: 0.06em; text-transform: uppercase; padding: 3px 9px; border-radius: 100px; font-weight: 700; display: inline-block; }
  .cc-pill.green { background: rgba(26,107,53,0.12); color: #1A6B35; }
  .cc-pill.amber { background: rgba(176,124,0,0.14); color: #946322; }
  .cc-pill.red { background: rgba(160,66,30,0.12); color: var(--rust); }
  .cc-pill.grey { background: rgba(59,58,48,0.10); color: var(--ink-500); }

  .cc-acts { display: flex; gap: 5px; flex-wrap: wrap; }
  .cc-btn { background: var(--paper); border: 1px solid var(--rule); color: var(--ink); padding: 5px 11px; border-radius: 6px; font-family: 'JetBrains Mono', monospace; font-size: 10px; cursor: pointer; font-weight: 600; letter-spacing: 0.03em; transition: all .12s; }
  .cc-btn:hover { border-color: var(--ink); }
  .cc-btn.go { border-color: rgba(26,107,53,0.45); color: #1A6B35; }
  .cc-btn.go:hover { background: #1A6B35; color: var(--sand-50); border-color: #1A6B35; }
  .cc-btn.warn { border-color: rgba(160,66,30,0.45); color: var(--rust); }
  .cc-btn.warn:hover { background: var(--rust); color: var(--sand-50); border-color: var(--rust); }
  .cc-btn.alt { border-color: rgba(16,69,187,0.35); color: #1045BB; }
  form.inline { display: inline; margin: 0; }
  .cc-link { color: var(--rust); text-decoration: none; font-weight: 500; }
  .cc-link:hover { text-decoration: underline; }
  .cc-empty { padding: 26px; text-align: center; color: var(--ink-500); font-family: 'JetBrains Mono', monospace; font-size: 12px; }
  .cc-grid2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(360px, 1fr)); gap: 16px; }
</style>

<div class="cc-crumb"><div class="cc-crumb-in"><a href="/aquintutor">AQUINTUTOR</a> <span style="margin:0 8px;">/</span> <span class="cur">COMMAND CENTER</span></div></div>

<main class="cc">

  <div class="cc-hero">
    <div>
      <p class="cc-eye">AquinTutor &middot; Administration</p>
      <h1 class="cc-h1">Full <em>control</em>.</h1>
    </div>
    <div class="cc-userbox">
      <span class="cc-userpill">{user.role} &middot; {(user as any).full_name || (user as any).email}</span>
      <a href="/admin">Main admin &rarr;</a>
    </div>
  </div>

  {flash && <div class={"cc-flash " + (flashOk ? "ok" : "err")}>{flash}</div>}

  <div class="cc-quick">
    <a href="/aquintutor/admin/courses">Course authoring</a>
    <a href="/admin/aquintutor">LMS overview</a>
    <a href="/admin/instructors">Faculty</a>
    <a href="/admin/schools">Schools</a>
    <a href="/admin/certificates">Certificates</a>
    <a href="/aquintutor/admin/analytics">Cohort analytics</a>
    <a href="/verify">Credential ledger</a>
    <a href="/aquintutor/partnerships">Partnerships</a>
    <a href="/aquintutor/labs">Virtual labs</a>
    <a href="/admin/ai-interview-templates">AI interviews</a>
    <a href="/admin/identity-verifications">Identity &amp; docs</a>
    <a href="/admin/interviews/ai">Interview sessions</a>
    <a href="/admin/api-keys">API keys</a>
    <a href="/developers">Developer API</a>
    <a href="/academy">Academies</a>
  </div>

  <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-bottom:18px;padding:12px 16px;background:var(--sand-100);border:1px solid var(--rule);border-radius:12px;">
    <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink-500);font-weight:700;">Role panels</span>
    <a href="/aquintutor/admin" style="background:var(--ink);color:var(--sand-50);padding:7px 14px;border-radius:8px;text-decoration:none;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;">Super-admin</a>
    <a href="/aquintutor/admin/partner" style="background:var(--paper);border:1px solid var(--rule);color:var(--ink);padding:7px 14px;border-radius:8px;text-decoration:none;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:600;">Partner</a>
    <a href="/aquintutor/admin/teacher" style="background:var(--paper);border:1px solid var(--rule);color:var(--ink);padding:7px 14px;border-radius:8px;text-decoration:none;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:600;">Teacher</a>
