                <form class="inline" method="POST"><input type="hidden" name="entity" value="eir"/><input type="hidden" name="action" value="status"/><input type="hidden" name="value" value="declined"/><input type="hidden" name="id" value={e.id}/><button class="cc-btn warn">Decline</button></form>
