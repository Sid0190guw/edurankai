      <a href="/aquintutor/hpc/simulator" style="background:var(--paper);border:1px solid var(--rule);color:var(--ink);padding:8px 14px;border-radius:8px;text-decoration:none;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:600;">HPC sim</a>
      <a href="/aquintutor/labs/animator" style="background:var(--paper);border:1px solid var(--rule);color:var(--ink);padding:8px 14px;border-radius:8px;text-decoration:none;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:600;">Animation studio</a>
