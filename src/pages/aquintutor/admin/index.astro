                <a href={'/aquintutor/admin/courses/' + c.id + '/edit'} class="cc-btn" style="border-color:var(--rust);color:var(--rust);font-weight:700;">Edit content</a>
                {c.is_published
                  ? <form class="inline" method="POST"><input type="hidden" name="entity" value="course"/><input type="hidden" name="action" value="unpublish"/><input type="hidden" name="id" value={c.id}/><button class="cc-btn">Unpublish</button></form>
