---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { getOrCreateInviteCode, getFriendList } from '@/lib/friends';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/friends'));

const myCode = await getOrCreateInviteCode(user.id);
const friends = await getFriendList(user.id);
const origin = new URL(Astro.request.url).origin;
const shareUrl = origin + '/aquintutor/invite?code=' + myCode;
function shorten(n: string): string {
  if (!n) return 'anonymous';
  const parts = String(n).trim().split(/\s+/);
  if (parts.length === 1) return parts[0];
  return parts[0] + ' ' + parts[parts.length - 1][0] + '.';
}
---
<AquintutorLayout title="Friends" description="Add friends, see their weekly XP, and pull them into the league together.">
  <section style="border-bottom:1px solid var(--rule); background:linear-gradient(180deg,#fff8f3 0%, var(--paper) 100%);">
    <div style="max-width:880px; margin:0 auto; padding:48px 28px;">
      <p style="font-family:'Inter Tight',monospace; font-size:12px; color:var(--rust); font-weight:700; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Friends</p>
      <h1 class="font-display" style="font-size:clamp(2rem,4vw,3rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500; margin:0 0 8px;">Learn together. Compete together.</h1>
      <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); line-height:1.6;">Add friends to see who's putting in the work this week. You both earn +50 XP when they accept your invite.</p>
    </div>
  </section>

  <section>
    <div style="max-width:880px; margin:0 auto; padding:36px 28px 24px;">
      <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:24px;">
        <p style="font-family:'Inter Tight',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:700; margin:0 0 12px;">Your invite code</p>
        <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap; margin-bottom:14px;">
          <span class="font-display" style="font-family:'JetBrains Mono',monospace; font-size:32px; font-weight:700; letter-spacing:0.08em; color:var(--rust); padding:8px 16px; background:rgba(217,119,87,0.08); border-radius:10px;">{myCode}</span>
          <button type="button" id="copyBtn" style="background:var(--ink); color:#fff; padding:10px 16px; border:none; border-radius:10px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:700; cursor:pointer;">Copy invite link</button>
        </div>
        <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink-500); line-height:1.6;">Share this code with friends. When they enter it (or open <code style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--rust);">/aquintutor/invite?code={myCode}</code>), you both earn +50 XP and become friends instantly.</p>
        <input type="text" readonly value={shareUrl} id="shareUrl" style="width:100%; margin-top:10px; padding:10px 14px; background:var(--sand-100); border:1px solid var(--rule); border-radius:8px; font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--ink-500);" onclick="this.select()" />
      </div>

      <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:24px; margin-top:18px;">
        <p style="font-family:'Inter Tight',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:700; margin:0 0 12px;">Enter a friend's code</p>
        <form id="acceptForm" style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
          <input type="text" id="codeInput" placeholder="ABCDEFGH" maxlength="8" style="flex:1; min-width:200px; padding:12px 16px; border:2px solid var(--rule); border-radius:10px; font-family:'JetBrains Mono',monospace; font-size:18px; letter-spacing:0.08em; outline:none; text-transform:uppercase;" />
          <button type="submit" style="background:var(--rust); color:#fff; padding:12px 22px; border:none; border-radius:10px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:700; cursor:pointer;">Add friend →</button>
        </form>
        <p id="acceptMsg" style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink-500); margin:10px 0 0; min-height:18px;"></p>
      </div>
    </div>
  </section>

  <section>
    <div style="max-width:880px; margin:0 auto; padding:14px 28px 80px;">
      <p style="font-family:'Inter Tight',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:700; margin:0 0 14px;">Your friends ({friends.length})</p>
      {friends.length === 0 ? (
        <div style="background:var(--paper); border:1px dashed var(--rule); border-radius:14px; padding:30px; text-align:center;">
          <p style="font-family:'Fraunces',serif; font-size:1.2rem; color:var(--ink); margin:0 0 6px;">No friends yet.</p>
          <p style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink-500); line-height:1.6;">Share your invite code above. The first friend you bring earns you both +50 XP.</p>
        </div>
      ) : (
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; overflow:hidden;">
          {friends.map((f: any) => (
            <div style="display:grid; grid-template-columns:1fr 90px 90px 80px 80px; gap:14px; align-items:center; padding:14px 18px; border-bottom:1px solid var(--rule);">
              <span style="font-family:'Inter Tight',sans-serif; font-size:15px; font-weight:600; color:var(--ink);">{shorten(f.name)}</span>
              <span style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--ink-500); text-align:right;">Lv {f.level}</span>
              <span style="font-family:'JetBrains Mono',monospace; font-size:13px; font-weight:700; color:var(--rust); text-align:right;">{Number(f.week_xp).toLocaleString()} XP wk</span>
              <span style="font-family:'JetBrains Mono',monospace; font-size:12px; color:#f97316; display:inline-flex; align-items:center; justify-content:flex-end; gap:5px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>{f.streak}</span>
              <button type="button" data-remove={f.user_id} class="rm" style="background:none; border:none; padding:6px; font-size:11px; color:#ef4444; cursor:pointer; text-align:right;">Remove</button>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <script is:inline define:vars={{ shareUrl }}>
    (function () {
      var copy = document.getElementById('copyBtn');
      if (copy) {
        copy.addEventListener('click', function () {
          try { navigator.clipboard.writeText(shareUrl); copy.textContent = 'Copied ✓'; setTimeout(function () { copy.textContent = 'Copy invite link'; }, 1500); } catch (_) {}
        });
      }
      var input = document.getElementById('codeInput');
      input.addEventListener('input', function () { input.value = input.value.toUpperCase().replace(/[^A-Z2-9]/g, ''); });

      document.getElementById('acceptForm').addEventListener('submit', function (e) {
        e.preventDefault();
        var msg = document.getElementById('acceptMsg');
        var code = input.value.trim();
        if (!code) return;
        msg.textContent = 'Checking…'; msg.style.color = '#5b5b5b';
        fetch('/api/aquintutor/friends/accept', { method:'POST', credentials:'same-origin', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ code: code })})
          .then(function (r) { return r.json(); })
          .then(function (d) {
            if (!d.ok) { msg.style.color = '#ef4444'; msg.textContent = d.error || 'Failed'; return; }
            msg.style.color = '#10b981';
            msg.textContent = '✓ Now friends with ' + (d.friendName || 'them') + '. +50 XP each!';
            setTimeout(function () { location.reload(); }, 1200);
          })
          .catch(function () { msg.style.color = '#ef4444'; msg.textContent = 'Network error'; });
      });

      document.querySelectorAll('.rm').forEach(function (b) {
        b.addEventListener('click', function () {
          if (!confirm('Remove this friend?')) return;
          fetch('/api/aquintutor/friends/remove', { method:'POST', credentials:'same-origin', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ friendId: b.getAttribute('data-remove') })})
            .then(function () { location.reload(); });
        });
      });
    })();
  </script>
</AquintutorLayout>
