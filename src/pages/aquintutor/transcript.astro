---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

const reqs = [
  { name: 'Core CS', taken: 12, total: 24, color: '#2b577e' },
  { name: 'AI specialisation', taken: 9, total: 18, color: '#2b577e' },
  { name: 'Math foundations', taken: 9, total: 12, color: '#5b4a92' },
  { name: 'Liberal arts (gen ed)', taken: 6, total: 12, color: '#8a486b' },
  { name: 'Vedic studies (req)', taken: 3, total: 6, color: '#a8472c' },
  { name: 'Free electives', taken: 8, total: 48, color: '#6b5f4c' },
];

const courses = [
  { term: 'Sp26', code: 'QT-407', title: 'Quantum Foundations', cr: 4, grade: '-', gpa: '-', status: 'in progress', c: '#5b4a92' },
  { term: 'Sp26', code: 'AI-512', title: 'Transformers in Practice', cr: 4, grade: '-', gpa: '-', status: 'in progress', c: '#2b577e' },
  { term: 'Sp26', code: 'DA-201', title: 'Design & Architecture Studio', cr: 3, grade: '-', gpa: '-', status: 'in progress', c: '#a04330' },
  { term: 'Sp26', code: 'VS-118', title: 'Vastu & Sacred Geometry', cr: 3, grade: '-', gpa: '-', status: 'in progress', c: '#a8472c' },
  { term: 'F25', code: 'CS-201', title: 'Data Structures', cr: 4, grade: 'A', gpa: '4.00', status: 'complete', c: '#2b577e' },
  { term: 'F25', code: 'MA-205', title: 'Linear Algebra', cr: 4, grade: 'A-', gpa: '3.67', status: 'complete', c: '#5b4a92' },
  { term: 'F25', code: 'AI-301', title: 'Intro to ML', cr: 4, grade: 'A', gpa: '4.00', status: 'complete', c: '#2b577e' },
  { term: 'F25', code: 'LA-101', title: 'Critical Reading', cr: 3, grade: 'A-', gpa: '3.67', status: 'complete', c: '#8a486b' },
  { term: 'Sp25', code: 'CS-101', title: 'Intro to Computing', cr: 4, grade: 'A', gpa: '4.00', status: 'complete', c: '#2b577e' },
  { term: 'Sp25', code: 'MA-101', title: 'Calculus I', cr: 4, grade: 'B+', gpa: '3.33', status: 'complete', c: '#5b4a92' },
];

const badges = [
  { name: 'Coherent Mind', color: '#5b4a92', glyph: 'QM', rarity: 'epic' },
  { name: 'Token Tamer', color: '#2b577e', glyph: 'AI', rarity: 'epic' },
  { name: 'Golden Section', color: '#a04330', glyph: 'DS', rarity: 'rare' },
  { name: 'Discount Eye', color: '#4a7048', glyph: 'BU', rarity: 'rare' },
  { name: 'Close Reader', color: '#8a486b', glyph: 'LB', rarity: 'common' },
  { name: 'Kinetic Sense', color: '#946322', glyph: 'RB', rarity: 'locked' },
];

const gpaData = [
  { term: 'Sp24', gpa: 3.4 },
  { term: 'F24', gpa: 3.55 },
  { term: 'Sp25', gpa: 3.67 },
  { term: 'F25', gpa: 3.78 },
  { term: 'Sp26', gpa: 3.85, current: true },
];

function gradeColor(g: string) {
  if (g === '-') return 'var(--ink-300)';
  if (g.startsWith('A')) return '#4a7048';
  if (g.startsWith('B')) return '#3b5675';
  return '#a87526';
}

const W = 320, H = 160, PAD = 30;
const xs = (i: number) => PAD + (i / (gpaData.length - 1)) * (W - PAD * 2);
const ys = (v: number) => H - PAD - ((v - 2.5) / 1.5) * (H - PAD * 2);
const linePath = gpaData.map((d, i) => (i === 0 ? 'M ' : 'L ') + xs(i) + ' ' + ys(d.gpa)).join(' ');
const areaPath = linePath + ' L ' + xs(gpaData.length - 1) + ' ' + (H - PAD) + ' L ' + xs(0) + ' ' + (H - PAD) + ' Z';
---
<AquintutorLayout title="Transcript" description="Your academic transcript - degree progress, course history, GPA trend, badges, and verifiable credentials.">

  <!-- BREADCRUMB -->
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1400px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a>
      <span style="margin:0 8px;">/</span>
      <a href="/aquintutor/dashboard" style="color:var(--ink-500); text-decoration:none;">DASHBOARD</a>
      <span style="margin:0 8px;">/</span>
      <span style="color:var(--rust); font-weight:600;">TRANSCRIPT · YEAR 2 · SPRING 2026</span>
    </div>
  </div>

  <!-- HEADER -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:32px 28px 24px;">
      <div style="display:flex; align-items:start; justify-content:space-between; gap:18px; flex-wrap:wrap;">
        <div>
          <div style="display:inline-flex; align-items:center; gap:8px; padding:4px 12px; background:rgba(160,66,30,0.08); border:1px solid rgba(160,66,30,0.3); border-radius:999px; font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.16em; text-transform:uppercase; color:var(--rust); font-weight:600; margin-bottom:12px;">TRANSCRIPT &middot; YEAR 2 &middot; SPRING 2026</div>
          <h1 class="font-display" style="font-size:clamp(1.85rem, 4vw, 2.85rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0; color:var(--ink);">BS &middot; Computer Science + AI</h1>
          <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1rem, 1.3vw, 1.2rem); color:var(--ink-500); line-height:1.5; margin:12px 0 0;">Accredited by EduRank·AI &middot; 47 of 120 credits earned &middot; GPA 3.78 &middot; projected graduation Spring 2028.</p>
        </div>
        <div style="display:flex; gap:8px; flex-wrap:wrap;">
          <button type="button" style="background:transparent; color:var(--ink); padding:10px 18px; border:1px solid var(--rule); border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:6px;"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12M7 10l5 5 5-5M5 21h14"/></svg>Export PDF</button>
          <button type="button" style="background:var(--rust); color:#fff; padding:10px 18px; border:none; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; cursor:pointer;">Share verified link</button>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN GRID -->
  <section style="background:var(--sand-100); border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:24px 28px 48px; display:grid; grid-template-columns:1fr; gap:18px;" class="tr-grid">

      <!-- LEFT: Degree progress + courses table -->
      <div style="display:flex; flex-direction:column; gap:18px; min-width:0;">

        <!-- Degree progress -->
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; overflow:hidden;">
          <div style="display:flex; align-items:center; justify-content:space-between; padding:16px 20px; border-bottom:1px solid var(--rule); background:var(--sand-100);">
            <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0;">Degree progress</p>
            <span style="font-family:'JetBrains Mono',monospace; font-size:11.5px; color:var(--rust); font-weight:600;">47 / 120 cr &middot; 39%</span>
          </div>
          <div style="padding:22px; display:flex; flex-direction:column; gap:14px;">
            {reqs.map((r) => (
              <div>
                <div style="display:flex; justify-content:space-between; margin-bottom:5px;">
                  <span style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink); font-weight:500;">{r.name}</span>
                  <span style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--ink-500);">{r.taken} / {r.total} cr</span>
                </div>
                <div style="height:6px; background:var(--rule); border-radius:3px; overflow:hidden;">
                  <div style={'width:' + (r.taken / r.total * 100) + '%; height:100%; background:' + r.color + ';'}></div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Courses table -->
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; overflow:hidden;">
          <div style="display:flex; align-items:center; justify-content:space-between; padding:16px 20px; border-bottom:1px solid var(--rule); background:var(--sand-100);">
            <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0;">Course history &middot; 10 of 14</p>
            <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500);">SORTED: NEWEST FIRST</span>
          </div>
          <div style="overflow-x:auto;">
            <table style="width:100%; border-collapse:collapse;">
              <thead>
                <tr>
                  {['Term', 'Code', 'Title', 'Cr', 'Grade', 'GPA', 'Status'].map((h) => (
                    <th style="padding:11px 16px; text-align:left; font-family:'JetBrains Mono',monospace; font-size:9.5px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); border-bottom:1px solid var(--rule); white-space:nowrap; font-weight:600;">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {courses.map((r) => (
                  <tr style="border-bottom:1px solid var(--rule);">
                    <td style="padding:13px 16px; font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--ink-500); white-space:nowrap;">{r.term}</td>
                    <td style={'padding:13px 16px; font-family:JetBrains Mono,monospace; font-size:11px; color:' + r.c + '; font-weight:600;'}>{r.code}</td>
                    <td style="padding:13px 16px; font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink);">{r.title}</td>
                    <td style="padding:13px 16px; font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--ink);">{r.cr}</td>
                    <td style={'padding:13px 16px; font-family:JetBrains Mono,monospace; font-size:13.5px; font-weight:700; color:' + gradeColor(r.grade) + ';'}>{r.grade}</td>
                    <td style="padding:13px 16px; font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--ink-500);">{r.gpa}</td>
                    <td style="padding:13px 16px;">
                      {r.status === 'complete'
                        ? <span style="display:inline-flex; align-items:center; gap:5px; padding:3px 9px; background:rgba(74,112,72,0.10); border:1px solid #4a7048; border-radius:999px; font-family:'JetBrains Mono',monospace; font-size:9.5px; letter-spacing:0.12em; text-transform:uppercase; color:#4a7048; font-weight:600;">&check; complete</span>
                        : <span style="display:inline-flex; align-items:center; gap:5px; padding:3px 9px; background:rgba(160,66,30,0.10); border:1px solid var(--rust); border-radius:999px; font-family:'JetBrains Mono',monospace; font-size:9.5px; letter-spacing:0.12em; text-transform:uppercase; color:var(--rust); font-weight:600;">in progress</span>}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- RIGHT: GPA chart + badges + credentials -->
      <aside style="display:flex; flex-direction:column; gap:18px; min-width:0;">

        <!-- GPA chart -->
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:20px;">
          <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:8px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0;">GPA trend &middot; 5 terms</p>
            <div>
              <span class="font-display" style="font-size:2.25rem; color:#4a7048; font-weight:500; line-height:1; letter-spacing:-0.02em;">3.78</span>
              <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500); margin-left:4px;">cumulative</span>
            </div>
          </div>
          <svg viewBox={'0 0 ' + W + ' ' + H} width="100%" height="160" style="display:block;">
            {[3, 3.5, 4].map((v) => (
              <g>
                <line x1={PAD} y1={ys(v)} x2={W-PAD} y2={ys(v)} stroke="var(--rule)" stroke-dasharray="3 3"/>
                <text x={PAD - 4} y={ys(v) + 3} font-family="JetBrains Mono" font-size="9" fill="var(--ink-500)" text-anchor="end">{v.toFixed(1)}</text>
              </g>
            ))}
            <path d={areaPath} fill="rgba(74,112,72,0.10)"/>
            <path d={linePath} fill="none" stroke="#4a7048" stroke-width="2"/>
            {gpaData.map((d, i) => (
              <g>
                <circle cx={xs(i)} cy={ys(d.gpa)} r={d.current ? 5 : 3.5} fill={d.current ? 'var(--rust)' : '#4a7048'} stroke="#fff" stroke-width={d.current ? 1.5 : 0}/>
                <text x={xs(i)} y={H - 8} font-family="JetBrains Mono" font-size="9" fill="var(--ink-500)" text-anchor="middle">{d.term}</text>
              </g>
            ))}
          </svg>
        </div>

        <!-- Badges -->
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:20px;">
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0;">Badges &middot; 14 earned</p>
            <span style="font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--ink-500);">3 epic &middot; 6 rare &middot; 5 common</span>
          </div>
          <div style="display:grid; grid-template-columns:repeat(3, 1fr); gap:8px;">
            {badges.map((b) => (
              <div style={'padding:12px; background:' + (b.rarity === 'locked' ? 'var(--sand-100)' : b.color + '10') + '; border:1px solid ' + (b.rarity === 'locked' ? 'var(--rule)' : b.color + '50') + '; border-radius:8px; opacity:' + (b.rarity === 'locked' ? '0.5' : '1') + '; display:flex; flex-direction:column; align-items:center; gap:6px;'}>
                <div style={'width:38px; height:38px; border-radius:50%; background:' + (b.rarity === 'locked' ? 'var(--sand-100)' : b.color + '30') + '; border:1.5px solid ' + (b.rarity === 'locked' ? 'var(--rule)' : b.color) + '; display:flex; align-items:center; justify-content:center; font-family:JetBrains Mono,monospace; font-size:10px; color:' + b.color + '; font-weight:700;'}>{b.glyph}</div>
                <span style="font-family:'JetBrains Mono',monospace; font-size:8.5px; letter-spacing:0.06em; color:var(--ink-500); text-align:center; line-height:1.2; text-transform:uppercase;">{b.name}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Credentials -->
        <div style="background:linear-gradient(135deg, rgba(160,66,30,0.06), rgba(74,112,72,0.04)); border:1px solid rgba(160,66,30,0.3); border-radius:14px; padding:20px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--rust); font-weight:600; margin:0;">Verifiable credentials</p>
          <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:14px; color:var(--ink); line-height:1.55; margin:10px 0 14px;">Your transcript is anchored to a public ledger. Recruiters and graduate programmes can verify any course, grade, or badge with a one-click link.</p>
          <div style="display:flex; gap:6px; flex-wrap:wrap;">
            {['SOC 2', 'EduRank · Accredited', 'W3C VC'].map((b) => (
              <span style="display:inline-flex; align-items:center; padding:3px 9px; background:var(--paper); border:1px solid var(--rule); border-radius:999px; font-family:'JetBrains Mono',monospace; font-size:9.5px; letter-spacing:0.1em; color:var(--ink-500); font-weight:600; text-transform:uppercase;">{b}</span>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </section>

  <style>
    @media (min-width: 1000px) { .tr-grid { grid-template-columns: 1.5fr 1fr !important; } }
  </style>
</AquintutorLayout>
