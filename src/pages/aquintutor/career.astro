---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

const opps = [
  { type: 'INT', kind: 'internship', title: 'AI Research Intern', org: 'Anthropic', loc: 'San Francisco', dur: 'Summer 2026', match: 94, deadline: '21 days', color: '#2b577e' },
  { type: 'INT', kind: 'internship', title: 'Quantum Computing Intern', org: 'IBM Research', loc: 'Yorktown Heights', dur: '12 weeks', match: 86, deadline: '14 days', color: '#5b4a92' },
  { type: 'RES', kind: 'research', title: 'UROP · Interpretability', org: 'AquinTutor Lab', loc: 'remote', dur: 'Year-long', match: 92, deadline: 'rolling', color: '#a04330' },
  { type: 'PhD', kind: 'grad', title: 'PhD · Machine Learning', org: 'CMU', loc: 'Pittsburgh', dur: '5 yr', match: 74, deadline: 'Dec 15', color: '#4a7048' },
  { type: 'JOB', kind: 'job', title: 'Robotics Software Engineer', org: 'Boston Dynamics', loc: 'Waltham', dur: 'full-time', match: 71, deadline: 'open', color: '#946322' },
];

const skills = [
  { name: 'Machine Learning', you: 84, role: 85, gap: 1 },
  { name: 'Linear Algebra', you: 92, role: 80, gap: -12 },
  { name: 'PyTorch / JAX', you: 70, role: 85, gap: 15 },
  { name: 'Research writing', you: 55, role: 70, gap: 15 },
  { name: 'Interpretability', you: 42, role: 75, gap: 33 },
];

const mentors = [
  { name: 'Dr. Naomi Wu', role: 'Research Sci · AI safety', org: 'Anthropic', avail: 'Tue 16:00', color: '#2b577e' },
  { name: 'Prof. R. Chen', role: 'Robotics · CMU', org: 'Carnegie Mellon', avail: 'Thu 10:00', color: '#946322' },
  { name: 'Achuth Iyer', role: 'Alum · ML engineer', org: 'OpenAI', avail: 'Fri 14:00', color: '#4a7048' },
];

function matchColor(m: number) {
  if (m >= 85) return '#4a7048';
  if (m >= 70) return '#3b5675';
  return 'var(--ink-500)';
}
function gapColor(g: number) {
  if (g <= 0) return '#4a7048';
  if (g > 20) return '#a04330';
  if (g > 10) return '#a87526';
  return 'var(--ink-500)';
}
---
<AquintutorLayout title="Career" description="Career outcomes, internships, jobs, graduate programmes, alumni mentors - ranked by skill fit and your stated goals.">

  <!-- BREADCRUMB -->
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1400px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a>
      <span style="margin:0 8px;">/</span>
      <a href="/aquintutor/dashboard" style="color:var(--ink-500); text-decoration:none;">DASHBOARD</a>
      <span style="margin:0 8px;">/</span>
      <span style="color:var(--rust); font-weight:600;">CAREER · 124 OPPORTUNITIES</span>
    </div>
  </div>

  <!-- HEADER -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:32px 28px 24px;">
      <div style="display:flex; align-items:start; justify-content:space-between; gap:18px; flex-wrap:wrap;">
        <div>
          <div style="display:inline-flex; align-items:center; gap:8px; padding:4px 12px; background:rgba(160,66,30,0.08); border:1px solid rgba(160,66,30,0.3); border-radius:999px; font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.16em; text-transform:uppercase; color:var(--rust); font-weight:600; margin-bottom:12px;">CAREER &middot; 124 OPPORTUNITIES MATCHED</div>
          <h1 class="font-display" style="font-size:clamp(1.85rem, 4vw, 2.85rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0; color:var(--ink); max-width:42rem;">Where AquinTutor sends you next.</h1>
          <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1rem, 1.3vw, 1.2rem); color:var(--ink-500); line-height:1.5; margin:14px 0 0; max-width:42rem;">Internships, jobs, graduate programmes, alumni mentors - ranked by skill fit and your stated goals. Aquin closes the gap, faculty write the letters.</p>
        </div>
        <div style="display:flex; gap:8px; flex-wrap:wrap;">
          <button type="button" style="background:transparent; color:var(--ink); padding:10px 18px; border:1px solid var(--rule); border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; cursor:pointer;">Edit goals</button>
          <button type="button" style="background:var(--rust); color:#fff; padding:10px 18px; border:none; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; cursor:pointer;">Update CV</button>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN GRID -->
  <section style="background:var(--sand-100); border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:24px 28px 48px; display:grid; grid-template-columns:1fr; gap:18px;" class="cr-grid">

      <!-- LEFT -->
      <div style="display:flex; flex-direction:column; gap:18px; min-width:0;">

        <!-- Career goal card -->
        <div style="background:linear-gradient(135deg, rgba(160,66,30,0.08), rgba(74,112,72,0.04)); border:1px solid rgba(160,66,30,0.3); border-radius:14px; padding:22px;">
          <div style="display:flex; align-items:start; gap:14px;">
            <span style="display:inline-flex; align-items:center; justify-content:center; width:46px; height:46px; min-width:46px; border-radius:10px; background:rgba(160,66,30,0.2); border:1px solid var(--rust); color:var(--rust); flex-shrink:0;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
            </span>
            <div style="flex:1;">
              <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--rust); font-weight:600; margin:0 0 6px;">Your goal</p>
              <h2 class="font-display" style="font-size:clamp(1.35rem, 2vw, 1.75rem); font-weight:500; line-height:1.25; letter-spacing:-0.015em; color:var(--ink); margin:0;">Research engineer at an AI lab focused on interpretability.</h2>
              <p style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink-500); line-height:1.5; margin:10px 0 0;">On track for graduate-school applications in Autumn 2027. Aquin recommends two more research projects and a peer-reviewed publication before then.</p>
            </div>
          </div>
        </div>

        <!-- Opportunities -->
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; overflow:hidden;">
          <div style="display:flex; align-items:center; justify-content:space-between; padding:16px 20px; border-bottom:1px solid var(--rule); background:var(--sand-100);">
            <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0;">Top matches &middot; 5 of 124</p>
            <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500);">SORTED BY FIT</span>
          </div>
          <div style="padding:14px; display:flex; flex-direction:column; gap:10px;">
            {opps.map((o) => (
              <article style="display:flex; align-items:center; gap:14px; padding:14px 16px; background:var(--sand-100); border:1px solid var(--rule); border-radius:10px; cursor:pointer;">
                <div style={'width:48px; height:48px; flex-shrink:0; border-radius:8px; background:' + o.color + '15; border:1px solid ' + o.color + '40; display:flex; align-items:center; justify-content:center; font-family:JetBrains Mono,monospace; font-size:11px; letter-spacing:0.12em; color:' + o.color + '; text-transform:uppercase; font-weight:600;'}>{o.type}</div>
                <div style="flex:1; min-width:0;">
                  <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap; margin-bottom:4px;">
                    <span style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink); font-weight:600;">{o.title}</span>
                    <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500);">&middot; {o.org}</span>
                  </div>
                  <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500); margin:0; letter-spacing:0.04em;">{o.loc} &middot; {o.dur} &middot; deadline {o.deadline}</p>
                </div>
                <div style="display:flex; flex-direction:column; align-items:flex-end; gap:2px; flex-shrink:0;">
                  <span style={'font-family:JetBrains Mono,monospace; font-size:1.25rem; font-weight:700; color:' + matchColor(o.match) + '; font-variant-numeric:tabular-nums; line-height:1;'}>{o.match}%</span>
                  <span style="font-family:'JetBrains Mono',monospace; font-size:8.5px; letter-spacing:0.16em; color:var(--ink-500); text-transform:uppercase;">match</span>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>

      <!-- RIGHT -->
      <aside style="display:flex; flex-direction:column; gap:18px; min-width:0;">

        <!-- Skill match -->
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:20px;">
          <div style="display:flex; justify-content:space-between; margin-bottom:14px; flex-wrap:wrap; gap:8px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0;">Skill match vs target role</p>
            <span style="display:inline-flex; align-items:center; padding:3px 9px; background:rgba(74,112,72,0.10); border:1px solid #4a7048; border-radius:999px; font-family:'JetBrains Mono',monospace; font-size:9.5px; letter-spacing:0.1em; color:#4a7048; font-weight:600;">ANTHROPIC INTERN</span>
          </div>
          <div style="display:flex; flex-direction:column; gap:12px;">
            {skills.map((s) => (
              <div>
                <div style="display:flex; justify-content:space-between; margin-bottom:5px;">
                  <span style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink);">{s.name}</span>
                  <span style={'font-family:JetBrains Mono,monospace; font-size:10.5px; color:' + gapColor(s.gap) + '; font-weight:600;'}>{s.gap <= 0 ? 'on target' : 'gap ' + s.gap + '%'}</span>
                </div>
                <div style="position:relative; height:6px; background:var(--rule); border-radius:999px;">
                  <div style={'position:absolute; left:0; top:0; bottom:0; width:' + s.you + '%; background:var(--rust); border-radius:999px;'}></div>
                  <span style={'position:absolute; left:' + s.role + '%; top:-3px; bottom:-3px; width:2px; background:#4a7048;'}></span>
                </div>
              </div>
            ))}
          </div>
          <div style="margin-top:14px; padding:11px 14px; background:rgba(61,107,118,0.08); border:1px solid rgba(61,107,118,0.3); border-radius:8px; display:flex; align-items:start; gap:10px;">
            <span style="display:inline-flex; align-items:center; justify-content:center; width:22px; height:22px; min-width:22px; border-radius:50%; background:#3d6b76; color:#dbe7e9; font-family:'Fraunces',serif; font-weight:500; font-size:11px;">A</span>
            <p style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink); line-height:1.5; margin:0;">Two interpretability projects this term close 80% of the gap. <a href="/aquintutor/aquin" style="color:#3d6b76; font-weight:600; text-decoration:underline;">Plan with Aquin &rarr;</a></p>
          </div>
        </div>

        <!-- Mentors -->
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; overflow:hidden;">
          <div style="padding:14px 18px; border-bottom:1px solid var(--rule); background:var(--sand-100);">
            <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0;">Mentor sessions &middot; 3 booked</p>
          </div>
          <div style="padding:10px;">
            {mentors.map((m) => (
              <div style="display:flex; align-items:center; gap:12px; padding:11px 12px;">
                <span style={'display:inline-flex; align-items:center; justify-content:center; width:38px; height:38px; min-width:38px; border-radius:50%; background:' + m.color + '; color:#fff; font-family:Fraunces,serif; font-weight:500; font-size:14px;'}>{m.name.split(' ').slice(-1)[0][0]}</span>
                <div style="flex:1; min-width:0;">
                  <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink); font-weight:500; margin:0;">{m.name}</p>
                  <p style="font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--ink-500); margin:2px 0 0; letter-spacing:0.04em;">{m.role} &middot; {m.org}</p>
                </div>
                <span style="display:inline-flex; align-items:center; padding:3px 9px; background:rgba(160,66,30,0.08); border:1px solid rgba(160,66,30,0.3); border-radius:999px; font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.06em; color:var(--rust); font-weight:600;">{m.avail}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Alumni outcomes -->
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:20px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0;">Cohort outcomes &middot; class of 2025</p>
          <div style="display:grid; grid-template-columns:repeat(2, 1fr); gap:10px; margin-top:14px;">
            {[
              { v: '92%', l: 'employed within 6mo', c: '#4a7048' },
              { v: '$118k', l: 'median first salary', c: 'var(--rust)' },
              { v: '38%', l: 'continued to grad school', c: '#3b5675' },
              { v: '247', l: 'alumni in your network', c: '#5b4a92' },
            ].map((s) => (
              <div style="padding:12px; background:var(--sand-100); border:1px solid var(--rule); border-radius:8px;">
                <p class="font-display" style={'font-size:1.6rem; color:' + s.c + '; line-height:1; font-weight:500; letter-spacing:-0.02em; margin:0;'}>{s.v}</p>
                <p style="font-family:'JetBrains Mono',monospace; font-size:9px; letter-spacing:0.12em; color:var(--ink-500); margin:6px 0 0; text-transform:uppercase;">{s.l}</p>
              </div>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </section>

  <style>
    @media (min-width: 1000px) { .cr-grid { grid-template-columns: 1fr 1fr !important; } }
  </style>
</AquintutorLayout>
