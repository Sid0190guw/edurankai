---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

const facilities = [
  { id: 'halls', label: 'Holographic Hall', code: 'HALL-01', color: '#5b4a92', live: 'GR · Penrose-Hayes · 2,140 attending', tagline: 'Volumetric lecture theatre with live captions and gaze heatmaps.' },
  { id: 'labs',  label: 'Virtual Surgical Lab', code: 'SURG-03', color: '#a04330', live: 'Laparoscopic appendectomy · station 03', tagline: 'Haptic-tracked endoscopic procedure simulator with real-time vitals.' },
  { id: 'forge', label: 'The Forge', code: 'FORGE-A', color: '#946322', live: 'CNC mill · Pune Workshop A · cutting', tagline: 'Tele-operated CNC mill and additive cell over 5G + fibre.' },
  { id: 'aquin', label: 'Aquin Co-pilot', code: 'AQUIN-AI', color: '#3d6b76', live: 'AI-512 · live · generating diagrams', tagline: 'AI tutor that watches your screen, anticipates your questions, and draws.' },
  { id: 'tests', label: 'ATLAS Test Center', code: 'ATLAS', color: '#2b577e', live: 'JEE Advanced mock · 12,420 testing', tagline: 'Proctored testing infrastructure with text-only event logging.' },
  { id: 'lang',  label: 'Tokyo Language House', code: 'LANG-JP', color: '#a8472c', live: '14 conversation rooms open · JP ↔ EN', tagline: 'Live tandem conversation rooms across 92 languages, native pairings.' },
];

const summary = [
  { l: 'Facilities live', v: '6' },
  { l: 'Concurrent learners', v: '14,720' },
  { l: 'Bytes uploaded from candidates', v: '0' },
  { l: 'Average latency', v: '28ms' },
  { l: 'Languages supported', v: '92' },
  { l: 'Open 24/7', v: 'Always', accent: true },
];
---
<AquintutorLayout title="Campus facilities" description="The virtual infrastructure of AquinTutor - holographic halls, surgical labs, the Forge for tele-CNC, AI co-pilots, ATLAS testing, language houses.">

  <!-- BREADCRUMB -->
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1320px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a>
      <span style="margin:0 8px;">/</span>
      <span style="color:var(--rust); font-weight:600;">CAMPUS FACILITIES</span>
    </div>
  </div>

  <!-- HERO -->
  <section style="border-bottom:1px solid var(--rule); position:relative; overflow:hidden;">
    <div aria-hidden="true" style="position:absolute; right:-60px; top:80px; opacity:0.06; pointer-events:none;" class="hide-mobile">
      <svg width="380" height="380" viewBox="0 0 100 100" fill="none">
        <rect x="20" y="20" width="60" height="60" stroke="var(--ink)" stroke-width="0.4" fill="none"/>
        <rect x="10" y="10" width="80" height="80" stroke="var(--ink)" stroke-width="0.3" fill="none" stroke-dasharray="2 2"/>
        <circle cx="50" cy="50" r="36" stroke="var(--ink)" stroke-width="0.3" fill="none"/>
        <line x1="20" y1="20" x2="80" y2="80" stroke="var(--ink)" stroke-width="0.3"/>
        <line x1="80" y1="20" x2="20" y2="80" stroke="var(--ink)" stroke-width="0.3"/>
      </svg>
    </div>
    <div style="max-width:1320px; margin:0 auto; padding:64px 28px 40px; position:relative; z-index:1;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); font-weight:600; letter-spacing:0.04em; margin:0 0 16px;">Campus facilities &middot; virtual infrastructure</p>
      <h1 class="font-display" style="font-size:clamp(2.25rem, 5vw, 4.25rem); line-height:0.98; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--ink); max-width:46rem;">
        Six working facilities.<br/>
        <span style="font-style:italic; font-weight:300; color:var(--ink-500);">All in your browser.</span>
      </h1>
      <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.15rem, 1.5vw, 1.4rem); line-height:1.5; color:var(--ink-500); margin:24px 0 0; max-width:42rem;">
        AquinTutor is more than the catalogue. Behind every course is a working facility - a holographic lecture theatre, a surgical lab with haptics, a tele-operated CNC mill in Pune, an AI co-pilot at your shoulder, proctored testing infrastructure, and language houses staffed by native speakers across twelve time zones.
      </p>
    </div>
  </section>

  <!-- STAT STRIP -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1320px; margin:0 auto; padding:28px 28px;">
      <div style="display:grid; grid-template-columns:repeat(2, 1fr); gap:12px;" class="stat-row">
        {summary.map((s) => (
          <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px 18px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">{s.l}</p>
            <p class="font-display" style={'font-size:1.5rem; font-weight:500; margin:0; line-height:1; letter-spacing:-0.02em; ' + (s.accent ? 'color:var(--rust);' : 'color:var(--ink);')}>{s.v}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FACILITY DIRECTORY -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1320px; margin:0 auto; padding:48px 28px 24px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">Directory</p>
      <h2 class="font-display" style="font-size:clamp(1.5rem, 2.5vw, 2rem); font-weight:500; line-height:1.12; letter-spacing:-0.015em; margin:0 0 24px; color:var(--ink); max-width:36rem;">Six facilities, in order of how often a student touches them.</h2>
      <div style="display:grid; grid-template-columns:1fr; gap:10px;" class="dir-grid">
        {facilities.map((f, i) => (
          <a href={'#' + f.id} style={'background:var(--paper); border:1px solid var(--rule); border-left:4px solid ' + f.color + '; border-radius:10px; padding:16px 18px; text-decoration:none; color:var(--ink); display:flex; flex-direction:column; gap:8px;'}>
            <div style="display:flex; align-items:center; justify-content:space-between; gap:8px;">
              <span style={'font-family:JetBrains Mono,monospace; font-size:10px; letter-spacing:0.16em; font-weight:600; color:' + f.color + ';'}>{f.code}</span>
              <span style="font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--ink-500); letter-spacing:0.1em;">{String(i + 1).padStart(2, '0')}/06</span>
            </div>
            <h3 class="font-display" style="font-size:1.05rem; font-weight:500; margin:0; line-height:1.2; letter-spacing:-0.015em;">{f.label}</h3>
            <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink-500); line-height:1.5; margin:0;">{f.tagline}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════ -->
  <!-- 1. HOLOGRAPHIC HALL                                                  -->
  <!-- ════════════════════════════════════════════════════════════════════ -->
  <section id="halls" style="background:#0b0d10; color:#f4f1ea; border-bottom:1px solid #1a1f28; position:relative; overflow:hidden; scroll-margin-top:60px;">
    <div aria-hidden="true" style="position:absolute; inset:0; background:repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(167,139,250,0.018) 3px, rgba(167,139,250,0.018) 4px); pointer-events:none;"></div>
    <div style="max-width:1320px; margin:0 auto; padding:64px 28px; position:relative; z-index:1;">
      <div style="display:grid; grid-template-columns:1fr; gap:32px; align-items:start;" class="facility-split">
        <div>
          <div style="display:inline-flex; align-items:center; gap:8px; padding:5px 14px; background:rgba(167,139,250,0.10); border:1px solid rgba(167,139,250,0.35); border-radius:999px; font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:#a78bfa; font-weight:600; margin-bottom:14px;">
            <span style="display:inline-block; width:6px; height:6px; border-radius:50%; background:#e07a6c; box-shadow:0 0 8px #e07a6c; animation:pulse 1.6s infinite;"></span>
            HALL 01 &middot; LIVE NOW
          </div>
          <h2 class="font-display" style="font-size:clamp(1.85rem, 3.5vw, 2.75rem); line-height:1.05; letter-spacing:-0.025em; font-weight:500; margin:0 0 16px; color:#f4f1ea;">
            Holographic<br/>
            <span style="font-style:italic; font-weight:300; color:rgba(244,241,234,0.6);">lecture theatre.</span>
          </h2>
          <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.05rem, 1.4vw, 1.2rem); line-height:1.55; color:rgba(244,241,234,0.78); margin:0 0 24px; max-width:34rem;">A volumetric stage where every student appears as a presence, every lecturer as a real body in space, and every demonstration as a floating object you can walk around. Live captions in 92 languages. Gaze heatmaps for the faculty.</p>
          <ul style="list-style:none; padding:0; margin:0 0 28px; display:flex; flex-direction:column; gap:8px;">
            {['Volumetric video at 4K · 60fps · per lecturer','Live caption tracks in 92 languages, auto-translated','Faculty-visible gaze heatmap of every row, every second','Hand-raise queue with seat number routing','Q&A panel with up-vote sorting and live attribution'].map((l) => (
              <li style="display:flex; align-items:start; gap:10px; font-family:'Inter Tight',sans-serif; font-size:13.5px; color:rgba(244,241,234,0.78); line-height:1.55;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg>
                <span>{l}</span>
              </li>
            ))}
          </ul>
          <div style="display:flex; gap:8px; flex-wrap:wrap;">
            <a href="/aquintutor/courses" style="background:#a78bfa; color:#1a0f08; padding:11px 20px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13.5px; font-weight:600; text-decoration:none;">Enter the hall &rarr;</a>
            <a href="/aquintutor/courses" style="background:transparent; color:#f4f1ea; padding:11px 20px; border-radius:6px; border:1px solid rgba(244,241,234,0.35); font-family:'Inter Tight',sans-serif; font-size:13.5px; font-weight:600; text-decoration:none;">Schedule</a>
          </div>
        </div>

        <!-- Hall preview mock -->
        <div style="background:#06080c; border:1px solid #1a1f28; border-radius:14px; padding:16px; position:relative; overflow:hidden;">
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.18em; color:rgba(244,241,234,0.55); text-transform:uppercase;">
            <span style="display:inline-flex; align-items:center; gap:6px;"><span style="display:inline-block; width:6px; height:6px; border-radius:50%; background:#e07a6c; animation:pulse 1.6s infinite;"></span>REC 4K VOLUMETRIC</span>
            <span>GR · L 7.2 · 00:42:18</span>
          </div>

          <svg viewBox="0 0 480 320" preserveAspectRatio="xMidYMid slice" width="100%" style="display:block; border-radius:10px; background:radial-gradient(ellipse at 50% 70%, #14182a 0%, #06080c 70%);">
            <defs>
              <radialGradient id="halo-hall" cx="50%" cy="40%" r="40%"><stop offset="0" stop-color="rgba(167,139,250,0.55)"/><stop offset="0.6" stop-color="rgba(167,139,250,0.10)"/><stop offset="1" stop-color="rgba(167,139,250,0)"/></radialGradient>
              <radialGradient id="vol-hall" cx="50%" cy="40%" r="60%"><stop offset="0" stop-color="rgba(167,139,250,0.85)"/><stop offset="1" stop-color="rgba(167,139,250,0.05)"/></radialGradient>
            </defs>
            <!-- floor perspective -->
            {Array.from({length:10}).map((_, i) => <line key={i} x1={-80 + i*48} y1="320" x2="240" y2="190" stroke="rgba(167,139,250,0.10)" stroke-width="0.6"/>)}
            {Array.from({length:10}).map((_, i) => <line key={'r'+i} x1={560 - i*48} y1="320" x2="240" y2="190" stroke="rgba(167,139,250,0.10)" stroke-width="0.6"/>)}
            {Array.from({length:5}).map((_, i) => <ellipse key={'h'+i} cx="240" cy={190 + i*22} rx={30 + i*32} ry={3 + i} fill="none" stroke="rgba(167,139,250,0.10)" stroke-width="0.6"/>)}
            <circle cx="240" cy="148" r="80" fill="url(#halo-hall)"/>
            <!-- Bloch holograph -->
            <g transform="translate(360 105)" opacity="0.9">
              <ellipse cx="0" cy="0" rx="44" ry="44" fill="none" stroke="rgba(207,189,255,0.6)" stroke-width="0.7"/>
              <ellipse cx="0" cy="0" rx="44" ry="14" fill="none" stroke="rgba(207,189,255,0.55)" stroke-dasharray="3 3"/>
              <line x1="-50" y1="0" x2="50" y2="0" stroke="rgba(255,255,255,0.18)"/>
              <line x1="0" y1="-50" x2="0" y2="50" stroke="rgba(255,255,255,0.18)"/>
              <line x1="0" y1="0" x2="30" y2="-26" stroke="#c9b3ff" stroke-width="1.8"/>
              <circle cx="30" cy="-26" r="4" fill="#c9b3ff"/>
            </g>
            <!-- equation -->
            <g transform="translate(120 100)" opacity="0.85">
              <rect x="-90" y="-22" width="180" height="44" rx="5" fill="rgba(16,20,32,0.7)" stroke="rgba(167,139,250,0.4)"/>
              <text x="0" y="-2" text-anchor="middle" font-family="JetBrains Mono" font-size="7" letter-spacing="0.18em" fill="rgba(167,139,250,0.85)">SLIDE 14 · CAUSAL STRUCTURE</text>
              <text x="0" y="14" text-anchor="middle" font-family="Cormorant Garamond" font-size="13" font-style="italic" fill="rgba(255,255,255,0.92)">"Light cones tile spacetime."</text>
            </g>
            <!-- lecturer volumetric -->
            <g transform="translate(240 150)">
              <ellipse cx="0" cy="0" rx="14" ry="18" fill="url(#vol-hall)"/>
              <path d="M -16 32 Q -16 12 -9 9 L 9 9 Q 16 12 16 32 Z" fill="url(#vol-hall)"/>
              {Array.from({length:14}).map((_, i) => {
                const a = (i/14) * Math.PI * 2;
                const x = Math.cos(a) * 13;
                const y = Math.sin(a) * 17;
                return <circle key={i} cx={x} cy={y} r="0.4" fill="rgba(255,255,255,0.85)"/>;
              })}
            </g>
            <!-- seats -->
            {Array.from({length:3}).map((_, row) => Array.from({length: 13 + row*3}).map((_, i) => {
              const total = 13 + row*3;
              const t = (i + 0.5)/total - 0.5;
              const cx2 = 240 + t * (130 + row*40);
              const cy2 = 250 + row * 18;
              return <circle key={'s'+row+i} cx={cx2} cy={cy2} r="1.4" fill="rgba(207,189,255,0.6)"/>;
            }))}
          </svg>

          <!-- Caption + counts row -->
          <div style="margin-top:12px; padding:10px 14px; background:rgba(8,10,14,0.92); border:1px solid rgba(207,189,255,0.2); border-radius:8px;">
            <p style="font-family:'JetBrains Mono',monospace; font-size:9px; letter-spacing:0.16em; text-transform:uppercase; color:rgba(207,189,255,0.7); margin:0 0 3px;">LIVE CAPTION &middot; EN &middot; AUTO</p>
            <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:13.5px; color:#f4f1ea; line-height:1.4; margin:0;">"…and so the metric tensor <em style="color:#c9b3ff;">g<sub>&mu;&nu;</sub></em> tells you, locally, what light cones look like at every event in spacetime…"</p>
          </div>

          <div style="display:grid; grid-template-columns:repeat(4, 1fr); gap:6px; margin-top:10px;">
            {[{l:'attending', v: '2,140'}, {l:'hands up', v: '12'}, {l:'msg/min', v: '168'}, {l:'gaze 5s', v: 'live'}].map((s) => (
              <div style="background:#10141e; border:1px solid #1c2230; border-radius:6px; padding:8px 10px;">
                <p style="font-family:'JetBrains Mono',monospace; font-size:8px; letter-spacing:0.14em; text-transform:uppercase; color:rgba(244,241,234,0.5); margin:0 0 3px;">{s.l}</p>
                <p style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#c9b3ff; font-weight:600; margin:0;">{s.v}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════ -->
  <!-- 2. VIRTUAL SURGICAL LAB                                              -->
  <!-- ════════════════════════════════════════════════════════════════════ -->
  <section id="labs" style="border-bottom:1px solid var(--rule); scroll-margin-top:60px;">
    <div style="max-width:1320px; margin:0 auto; padding:64px 28px;">
      <div style="display:grid; grid-template-columns:1fr; gap:32px; align-items:start;" class="facility-split">
        <!-- Surgical mock first on this side -->
        <div style="background:#0a0d12; border:1px solid var(--rule); border-radius:14px; padding:16px; position:relative; overflow:hidden;">
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.18em; text-transform:uppercase;">
            <span style="display:inline-flex; align-items:center; gap:6px; color:#7dd3a8;"><span style="display:inline-block; width:6px; height:6px; border-radius:50%; background:#7dd3a8; box-shadow:0 0 6px #7dd3a8;"></span>SCOPE 4K 60fps</span>
            <span style="color:rgba(244,241,234,0.55);">STATION 03 &middot; STORZ 26</span>
          </div>

          <svg viewBox="0 0 480 320" preserveAspectRatio="xMidYMid slice" width="100%" style="display:block; border-radius:8px; background:radial-gradient(circle at 50% 50%, #2a1410 0%, #0a0506 80%);">
            <!-- viscera -->
            <ellipse cx="240" cy="180" rx="160" ry="110" fill="rgba(212,82,55,0.25)"/>
            <path d="M 110 180 Q 160 130 230 140 Q 310 150 350 200 Q 320 240 240 240 Q 160 240 110 180 Z" fill="rgba(168,71,44,0.4)" stroke="rgba(255,200,180,0.15)" stroke-width="0.5"/>
            <!-- appendix -->
            <path d="M 280 200 Q 310 220 320 250" stroke="#e07a6c" stroke-width="6" fill="none" stroke-linecap="round"/>
            <!-- grasper instruments -->
            <line x1="60" y1="320" x2="220" y2="180" stroke="#c8c3b8" stroke-width="4"/>
            <circle cx="225" cy="178" r="3" fill="#c8c3b8"/>
            <line x1="420" y1="320" x2="280" y2="200" stroke="#c8c3b8" stroke-width="4"/>
            <!-- aim cross -->
            <line x1="220" y1="170" x2="240" y2="190" stroke="rgba(125,211,168,0.7)" stroke-width="1"/>
            <line x1="240" y1="170" x2="220" y2="190" stroke="rgba(125,211,168,0.7)" stroke-width="1"/>
          </svg>

          <!-- Vitals strip -->
          <div style="display:grid; grid-template-columns:repeat(4, 1fr); gap:6px; margin-top:10px;">
            {[
              { k: 'HR', v: '78', u: 'bpm', c: '#7dd3a8' },
              { k: 'BP', v: '118/74', u: 'mmHg', c: '#7fb3ff' },
              { k: 'SpO2', v: '99', u: '%', c: '#7dd3a8' },
              { k: 'CO2', v: '38', u: 'mmHg', c: '#f0b54f' },
            ].map((vit) => (
              <div style="background:#10141e; border:1px solid #1c2230; border-radius:6px; padding:8px 10px;">
                <p style="font-family:'JetBrains Mono',monospace; font-size:8px; letter-spacing:0.14em; color:rgba(244,241,234,0.5); margin:0;">{vit.k}</p>
                <p style={'font-family:JetBrains Mono,monospace; font-size:15px; color:' + vit.c + '; font-weight:700; line-height:1; margin:2px 0;'}>{vit.v}</p>
                <p style="font-family:'JetBrains Mono',monospace; font-size:8px; color:rgba(244,241,234,0.4); margin:0;">{vit.u}</p>
              </div>
            ))}
          </div>

          <!-- Step prompt -->
          <p style="margin:10px 0 0; padding:8px 14px; background:rgba(168,71,44,0.92); border-radius:999px; font-family:'Inter Tight',sans-serif; font-size:11.5px; color:#fff; font-weight:600; text-align:center;">Identify the mesoappendix &middot; grasp gently &middot; harmonic 4mm from caecal wall</p>
        </div>

        <div>
          <div style="display:inline-flex; align-items:center; gap:8px; padding:5px 14px; background:rgba(160,67,48,0.08); border:1px solid rgba(160,67,48,0.3); border-radius:999px; font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--bad,#a04330); font-weight:600; margin-bottom:14px;">
            <span style="display:inline-block; width:6px; height:6px; border-radius:50%; background:#a04330; box-shadow:0 0 6px #a04330; animation:pulse 1.6s infinite;"></span>
            SURG-03 &middot; LAPAROSCOPIC
          </div>
          <h2 class="font-display" style="font-size:clamp(1.85rem, 3.5vw, 2.75rem); line-height:1.05; letter-spacing:-0.025em; font-weight:500; margin:0 0 16px; color:var(--ink);">
            Virtual surgical lab.<br/>
            <span style="font-style:italic; font-weight:300; color:var(--ink-500);">Haptic, scored, and supervised.</span>
          </h2>
          <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.05rem, 1.4vw, 1.2rem); line-height:1.55; color:var(--ink-500); margin:0 0 24px; max-width:34rem;">Tracked endoscopic procedures on virtual cadavers. Force on tissue is measured. Tool economy, tissue handling, visualisation, and time-on-task are scored against attending-level standards.</p>
          <ul style="list-style:none; padding:0; margin:0 0 24px; display:flex; flex-direction:column; gap:8px;">
            {['Storz 26 scope simulation · 4K · 60fps · WB 5600K','Live vitals: HR, BP, SpO2, CO2 with deviation alerts','Haptic force tracker with safe-range envelope (≤3.5 N)','Aquin live cues: wrist angle, instrument economy, depth','Per-attempt scorecard sealed and version-controlled'].map((l) => (
              <li style="display:flex; align-items:start; gap:10px; font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink-500); line-height:1.55;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a04330" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg>
