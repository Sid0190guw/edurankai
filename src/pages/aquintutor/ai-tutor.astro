---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { getConfig, isReady } from '@/lib/llm/gateway';
// Aquin — the conversational Socratic tutor. Streams from the own-LLM gateway
// (self-hosted model or Claude, per super-admin). Never hands over answers; every
// exchange trains AquinTutor's own model. Gated: shows a "coming online" state
// until the model is switched on.
const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/ai-tutor'));
const online = isReady(await getConfig());
---
<AquintutorLayout title="Ask Aquin" description="A Socratic tutor that helps you reach the answer yourself — it coaches with questions and hints and never just hands over the solution.">
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:760px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a><span style="margin:0 8px;">/</span><span style="color:var(--rust); font-weight:600;">ASK AQUIN</span>
    </div>
  </div>

  <section style="max-width:720px; margin:0 auto; padding:28px 20px 40px;">
    <p style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--rust); font-weight:700; margin:0 0 6px;">Socratic tutor</p>
    <h1 class="font-display" style="font-size:clamp(1.7rem,4vw,2.3rem); font-weight:500; margin:0 0 6px; color:var(--ink);">Ask Aquin anything you're stuck on.</h1>
    <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); line-height:1.6; margin:0 0 18px;">Aquin coaches you to the answer with questions and hints. It won't just hand over the solution to a problem you're meant to solve &mdash; that's the point.</p>

    {!online && (
      <div style="background:#fff; border:1.5px dashed var(--rule); border-radius:16px; padding:30px; text-align:center;">
        <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="var(--ink-500)" stroke-width="1.7" style="margin-bottom:8px;"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        <h2 class="font-display" style="font-size:1.3rem; font-weight:600; color:var(--ink); margin:0 0 6px;">Aquin's tutor is coming online.</h2>
        <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); margin:0;">We're bringing our own model up. In the meantime, the Homework Helper, Knowledge map and Backlog Recovery all work without it.</p>
      </div>
    )}

    {online && (
      <div>
        <div id="chat" style="display:flex; flex-direction:column; gap:12px; min-height:200px; margin-bottom:14px;"></div>
        <div style="display:flex; gap:8px; align-items:flex-end; position:sticky; bottom:12px; background:var(--sand-50); padding-top:6px;">
          <textarea id="inp" rows="1" placeholder="What are you working on?" style="flex:1; resize:none; background:#fff; border:1.5px solid var(--rule); border-radius:12px; padding:11px 14px; font-size:15px; font-family:inherit; color:var(--ink); outline:none; max-height:140px;"></textarea>
          <button id="send" type="button" style="background:var(--rust); color:#fff; border:none; border-radius:12px; padding:11px 20px; font-family:'Inter Tight',sans-serif; font-size:15px; font-weight:600; cursor:pointer; flex-shrink:0;">Ask</button>
        </div>
        <p style="font-family:'Inter Tight',sans-serif; font-size:11.5px; color:var(--ink-500); margin:10px 0 0; text-align:center;">Aquin is a study aid and can make mistakes. It won't give final answers to homework &mdash; it coaches you to them.</p>
      </div>
    )}
  </section>

  {online && (
    <script is:inline>
    (function(){
      var chat=document.getElementById('chat'), inp=document.getElementById('inp'), send=document.getElementById('send');
      var history=[]; var busy=false;
      inp.addEventListener('input', function(){ inp.style.height='auto'; inp.style.height=Math.min(140, inp.scrollHeight)+'px'; });
      inp.addEventListener('keydown', function(e){ if(e.key==='Enter' && !e.shiftKey){ e.preventDefault(); ask(); } });
      send.addEventListener('click', ask);

      function bubble(role, text){
        var d=document.createElement('div');
        var me = role==='user';
        d.style.cssText='max-width:88%; align-self:'+(me?'flex-end':'flex-start')+'; background:'+(me?'var(--rust)':'#fff')+'; color:'+(me?'#fff':'var(--ink)')+'; border:'+(me?'none':'1.5px solid var(--rule)')+'; border-radius:14px; padding:11px 14px; font-family:Inter Tight,sans-serif; font-size:15px; line-height:1.6; white-space:pre-wrap; word-break:break-word;';
        d.textContent=text; chat.appendChild(d); chat.scrollIntoView({block:'end'}); window.scrollTo(0,document.body.scrollHeight); return d;
      }
      function ask(){
        if(busy) return; var text=inp.value.trim(); if(!text) return;
        bubble('user', text); history.push({role:'user',content:text});
        inp.value=''; inp.style.height='auto'; busy=true; send.disabled=true; send.textContent='…';
        var out=bubble('assistant',''); out.style.opacity='0.7';
        fetch('/api/aquintutor/aquin-chat',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'same-origin',body:JSON.stringify({mode:'socratic-tutor',messages:history})})
          .then(function(res){
            if(!res.ok || !res.body){ return res.json().then(function(j){ throw new Error(j.error||'unavailable'); }); }
            out.style.opacity='1'; var reader=res.body.getReader(), dec=new TextDecoder(), buf='', acc='';
            function pump(){ return reader.read().then(function(r){
              if(r.done){ finish(acc); return; }
              buf+=dec.decode(r.value,{stream:true}); var lines=buf.split('\n'); buf=lines.pop()||'';
              lines.forEach(function(line){ var s=line.trim(); if(!s.startsWith('data:')) return; try{ var j=JSON.parse(s.slice(5).trim());
                if(j.t){ acc+=j.t; out.textContent=acc; window.scrollTo(0,document.body.scrollHeight); }
                else if(j.error){ out.textContent=j.error; out.style.color='var(--rust)'; }
              }catch(e){} });
              return pump();
            }); }
            return pump();
          })
          .catch(function(e){ out.textContent=(e&&e.message)||'Aquin is unavailable right now.'; out.style.color='var(--rust)'; finish(''); })
          ;
        function finish(txt){ if(txt) history.push({role:'assistant',content:txt}); busy=false; send.disabled=false; send.textContent='Ask'; }
      }
    })();
    </script>
  )}
</AquintutorLayout>
