---
// /aquintutor/board — live teaching board (Prompt A1a, main surface, faculty-gated). Renders a
// parametric template locally (SVG, light), a vector pen-ink layer, and play/pause/scrub. Exposes
// window.AquinBoard.trigger(id, params) — the SAME entry point A2 (speech) and A1b (broadcast) call.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { can } from '@/lib/rbac';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/board');
const gate = await can(user, 'write', { type: 'AnimationObject' });   // faculty+ can drive; students can't
if (!gate.allow) return Astro.redirect('/aquintutor/hub');
const koId = (Astro.url.searchParams.get('ko') || '').trim();
const sessionId = (Astro.url.searchParams.get('session') || ('board-' + user.id)).trim();
const joinUrl = new URL('/aquintutor/board/live?session=' + encodeURIComponent(sessionId), Astro.url.origin).toString();
---
<AquintutorLayout title="Teaching board">
  <main style="max-width:900px;margin:0 auto;padding:36px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Live board</p>
    <h1 style="font-family:Fraunces,serif;font-size:28px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 4px;line-height:1.15;">Teaching board</h1>
    <p style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#6b6455;margin:0 0 16px;">Pick a template, set parameters, and it renders live. (Live broadcast to students is A1b; speech-driven firing is A2 — this board exposes the trigger seam they call.)</p>
    <div id="msg" style="display:none;margin:0 0 12px;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style="position:relative;background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:14px;overflow:hidden;">
      <svg id="anim" viewBox="0 0 320 200" style="display:block;width:100%;height:auto;aspect-ratio:16/10;"></svg>
      <svg id="ink" viewBox="0 0 320 200" preserveAspectRatio="none" style="position:absolute;inset:0;width:100%;height:100%;touch-action:none;cursor:crosshair;"></svg>
    </div>

    <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-top:12px;">
      <select id="tpl" style="font-family:'Inter Tight',sans-serif;font-size:14px;padding:8px 10px;border:1px solid var(--line,#e6e1d6);border-radius:9px;"></select>
      <button id="play" type="button" style="background:var(--ink,#1a1712);color:var(--sand-50,#fbfaf4);border:none;border-radius:9px;padding:9px 16px;font-family:'Inter Tight',sans-serif;font-size:13.5px;font-weight:600;cursor:pointer;">Play</button>
      <input id="scrub" type="range" min="0" max="1" step="0.01" value="0" style="flex:1;min-width:140px;" />
      <label style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#6b6455;"><input type="checkbox" id="pen" /> Pen</label>
      <button id="clearInk" type="button" style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:9px;padding:8px 12px;font-family:'Inter Tight',sans-serif;font-size:12.5px;cursor:pointer;">Clear ink</button>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-top:12px;">
      <button id="broadcast" type="button" style="background:var(--rust,#b3541e);color:#fff;border:none;border-radius:9px;padding:9px 18px;font-family:'Inter Tight',sans-serif;font-size:13.5px;font-weight:700;cursor:pointer;">Broadcast to class</button>
      <span style="font-family:'Inter Tight',sans-serif;font-size:12px;color:#8a8378;">Play/scrub is a local rehearsal; Broadcast fires it to joined students at their own quality tier.</span>
    </div>
    <div id="params" style="display:flex;gap:14px;flex-wrap:wrap;margin-top:12px;"></div>

    <div style="display:grid;grid-template-columns:1fr;gap:14px;margin-top:22px;">
      <div style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:12px;padding:14px 16px;">
        <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:#8a8378;margin:0 0 8px;">Live session</p>
        <p style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#6b6455;margin:0 0 8px;">Students join at this link (they render adaptively for their device — no video is sent):</p>
        <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
          <input id="joinLink" readonly value={joinUrl} style="flex:1;min-width:200px;font-family:'Geist Mono',monospace;font-size:12px;padding:8px 10px;border:1px solid var(--line,#e6e1d6);border-radius:8px;background:#faf9f4;color:#1a1712;" />
          <button id="copyLink" type="button" style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:8px;padding:8px 12px;font-family:'Inter Tight',sans-serif;font-size:12.5px;cursor:pointer;">Copy</button>
          <a href={joinUrl} target="_blank" style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:var(--rust,#b3541e);text-decoration:none;font-weight:600;">Preview student view</a>
        </div>
      </div>
      <div style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:12px;padding:14px 16px;">
        <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;flex-wrap:wrap;">
          <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:#8a8378;margin:0;">Who's watching</p>
          <span id="online" style="font-family:'Inter Tight',sans-serif;font-size:12px;color:#2f7d5b;">—</span>
        </div>
        <div id="roster" style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#6b6455;margin-top:8px;">No one has joined yet.</div>
        <div id="fires" style="font-family:'Geist Mono',monospace;font-size:11.5px;color:#8a8378;margin-top:10px;"></div>
      </div>

      <div style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:12px;padding:14px 16px;">
        <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;flex-wrap:wrap;">
          <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:#8a8378;margin:0;">Speak to the board</p>
          <label style="font-family:'Inter Tight',sans-serif;font-size:12px;color:#6b6455;"><input type="checkbox" id="autofire" /> Auto-fire confident matches</label>
        </div>
        <p style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#6b6455;margin:6px 0 10px;">Say e.g. &ldquo;launch a projectile at thirty degrees&rdquo; or &ldquo;draw a sine wave, amplitude four&rdquo;. Off by default it asks you to confirm; the model never invents a template or an out-of-range value.</p>
        <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
          <button id="mic" type="button" style="background:var(--ink,#1a1712);color:var(--sand-50,#fbfaf4);border:none;border-radius:9px;padding:9px 16px;font-family:'Inter Tight',sans-serif;font-size:13.5px;font-weight:600;cursor:pointer;">Start listening</button>
          <input id="phrase" placeholder="…or type a phrase" style="flex:1;min-width:160px;font-family:'Inter Tight',sans-serif;font-size:13px;padding:8px 10px;border:1px solid var(--line,#e6e1d6);border-radius:8px;" />
          <button id="interpret" type="button" style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:8px;padding:8px 12px;font-family:'Inter Tight',sans-serif;font-size:12.5px;cursor:pointer;">Interpret</button>
        </div>
        <p id="heard" style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#8a8378;margin:10px 0 0;min-height:18px;"></p>
        <div id="suggestion" style="display:none;margin-top:8px;padding:10px 12px;border:1px solid var(--rust,#b3541e);border-radius:9px;background:#fdf6ee;"></div>
        <div id="detlog" style="font-family:'Geist Mono',monospace;font-size:11px;color:#8a8378;margin-top:12px;"></div>
      </div>
    </div>
  </main>

  <script src="/aquin-anim-templates.js" defer></script>
  <script is:inline define:vars={{ koId, sessionId }}>
    (function () {
      function ready(fn) { if (window.AquinAnim) fn(); else setTimeout(function () { ready(fn); }, 50); }
      ready(function () {
        var A = window.AquinAnim, anim = document.getElementById('anim'), ink = document.getElementById('ink');
        var tplSel = document.getElementById('tpl'), paramsEl = document.getElementById('params'), scrub = document.getElementById('scrub'), playBtn = document.getElementById('play');
        var msg = document.getElementById('msg');
        var state = { templateId: 'projectile', params: {}, playState: 'paused', timelinePos: 0 };
        var raf = null;
        A.list().forEach(function (t) { var o = document.createElement('option'); o.value = t.id; o.textContent = t.name; tplSel.appendChild(o); });

        function flash(t, ok) { msg.style.display = 'block'; msg.textContent = t; msg.style.background = ok ? '#eef8f1' : '#fdecec'; msg.style.color = ok ? '#2f7d5b' : '#9b2c2c'; }
        function render() { A.renderSVG(anim, { templateId: state.templateId, params: state.params, playState: state.playState, timelinePos: state.timelinePos }, 'rich'); }
        function buildParams() {
          paramsEl.innerHTML = ''; var tpl = A.get(state.templateId);
          tpl.schema.forEach(function (s) {
            var wrap = document.createElement('label'); wrap.style.cssText = 'font-family:Inter Tight,sans-serif;font-size:12px;color:#6b6455;';
            if (s.type === 'list') { wrap.innerHTML = s.label + '<br>'; var inp = document.createElement('input'); inp.value = (state.params[s.key] || s.def).join(','); inp.style.cssText = 'font-size:13px;padding:6px 8px;border:1px solid #e6e1d6;border-radius:7px;width:160px;'; inp.addEventListener('input', function () { state.params[s.key] = inp.value.split(',').map(Number).filter(function (n) { return !isNaN(n); }); state.params = A.clampParams(state.templateId, state.params); render(); }); wrap.appendChild(inp); }
            else { wrap.innerHTML = s.label + ' <b class="v"></b><br>'; var r = document.createElement('input'); r.type = 'range'; r.min = s.min; r.max = s.max; r.step = (s.max - s.min) / 100; r.value = state.params[s.key]; var vb = null; r.addEventListener('input', function () { state.params[s.key] = Number(r.value); if (vb) vb.textContent = Number(r.value).toFixed(1); render(); }); wrap.appendChild(r); setTimeout(function () { vb = wrap.querySelector('.v'); if (vb) vb.textContent = Number(state.params[s.key]).toFixed(1); }, 0); }
            paramsEl.appendChild(wrap);
          });
        }
        function selectTemplate(id, params) { state.templateId = id; state.params = A.clampParams(id, params || {}); state.timelinePos = 0; tplSel.value = id; buildParams(); render(); }
        function stop() { if (raf) cancelAnimationFrame(raf); raf = null; state.playState = 'paused'; playBtn.textContent = 'Play'; }
        function play() {
          var tpl = A.get(state.templateId), dur = (tpl.duration ? tpl.duration(state.params) : 3) * 1000, start = performance.now() - state.timelinePos * dur;
          state.playState = 'playing'; playBtn.textContent = 'Pause';
          function step(now) { var p = Math.min(1, (now - start) / dur); state.timelinePos = p; scrub.value = p; render(); if (p < 1 && state.playState === 'playing') raf = requestAnimationFrame(step); else stop(); }
          raf = requestAnimationFrame(step);
        }

        tplSel.addEventListener('change', function () { stop(); selectTemplate(tplSel.value); });
        playBtn.addEventListener('click', function () { if (state.playState === 'playing') stop(); else play(); });
        scrub.addEventListener('input', function () { stop(); state.timelinePos = Number(scrub.value); render(); });

        // vector pen ink (points -> polyline; vector data, never pixels)
        var drawing = false, cur = null;
        function pt(e) { var r = ink.getBoundingClientRect(); return { x: ((e.clientX - r.left) / r.width) * 320, y: ((e.clientY - r.top) / r.height) * 200 }; }
        ink.addEventListener('pointerdown', function (e) { if (!document.getElementById('pen').checked) return; drawing = true; cur = document.createElementNS('http://www.w3.org/2000/svg', 'polyline'); cur.setAttribute('fill', 'none'); cur.setAttribute('stroke', '#1a1712'); cur.setAttribute('stroke-width', '2'); cur.setAttribute('points', ''); ink.appendChild(cur); var p = pt(e); cur.setAttribute('points', p.x + ',' + p.y); });
        ink.addEventListener('pointermove', function (e) { if (!drawing) return; var p = pt(e); cur.setAttribute('points', cur.getAttribute('points') + ' ' + p.x + ',' + p.y); });
        window.addEventListener('pointerup', function () { drawing = false; });
        document.getElementById('clearInk').addEventListener('click', function () { while (ink.firstChild) ink.removeChild(ink.firstChild); });

        // ── the shared entry point A2 (speech) and A1b (broadcast) call ──
        window.AquinBoard = {
          trigger: function (id, params, detectionId) {
            if (!A.get(id)) return false;
            stop(); selectTemplate(id, params); play();
            fetch('/api/aquintutor/board', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'fire', templateId: id, params: state.params, koId: koId || undefined, session: sessionId, playState: 'playing', timelinePos: 0, detectionId: detectionId || undefined }) })
              .then(function (r) { return r.json(); }).then(function (j) { flash(j.ok ? ('Broadcast ' + id + (j.seq ? ' (#' + j.seq + ')' : '')) : (j.error || 'Failed'), j.ok); });
            return true;
          },
          getState: function () { return { templateId: state.templateId, params: state.params, playState: state.playState, timelinePos: state.timelinePos }; },
        };
        document.getElementById('broadcast').addEventListener('click', function () { window.AquinBoard.trigger(state.templateId, state.params); });
        document.getElementById('copyLink').addEventListener('click', function () { var i = document.getElementById('joinLink'); i.select(); navigator.clipboard && navigator.clipboard.writeText(i.value); flash('Join link copied', true); });

        // live session inspector (who joined, at which tier, what was fired) — polls the faculty API
        function poll() {
          fetch('/api/aquintutor/board/inspect?session=' + encodeURIComponent(sessionId)).then(function (r) { return r.json(); }).then(function (j) {
            if (!j.ok) return;
            document.getElementById('online').textContent = j.online + ' online / ' + j.participants.length + ' joined';
            var roster = document.getElementById('roster');
            roster.innerHTML = j.participants.length ? j.participants.map(function (p) { return '<span style="display:inline-block;margin:2px 6px 2px 0;padding:3px 9px;border-radius:100px;background:' + (p.online ? '#eef8f1' : '#f2efe8') + ';color:' + (p.online ? '#2f7d5b' : '#8a8378') + ';">' + (p.online ? '● ' : '○ ') + p.tier + '</span>'; }).join('') : 'No one has joined yet.';
            document.getElementById('fires').textContent = j.totalFires ? (j.totalFires + ' fired — last: ' + j.fires.slice(0, 3).map(function (f) { return f.templateId; }).join(', ')) : '';
            var dl = document.getElementById('detlog');
            dl.innerHTML = (j.detections || []).slice(0, 6).map(function (d) { return (d.fired ? '● ' : '○ ') + (d.templateId || 'no match') + ' · ' + Math.round(d.confidence * 100) + '% · ' + d.source + ' · "' + (d.transcript || '').slice(0, 40) + '"'; }).join('<br>');
          }).catch(function () {});
        }
        poll(); setInterval(poll, 4000);

        // ── A2: speech -> suggestion -> (confirm | auto-fire) ──
        var sugBox = document.getElementById('suggestion'), heard = document.getElementById('heard');
        function showSuggestion(sug, detId) {
          if (!sug || !sug.templateId) { sugBox.style.display = 'none'; heard.textContent = heard.textContent + ' — no template matched.'; return; }
          var pstr = Object.keys(sug.params).map(function (k) { return k + '=' + sug.params[k]; }).join(', ');
          if (document.getElementById('autofire').checked && sug.confidence >= 0.6) {
            sugBox.style.display = 'none';
            window.AquinBoard.trigger(sug.templateId, sug.params, detId);
            return;
          }
          sugBox.style.display = 'block';
          sugBox.innerHTML = '<div style="font-family:Inter Tight,sans-serif;font-size:13px;color:#1a1712;margin-bottom:8px;"><b>' + (A.get(sug.templateId) ? A.get(sug.templateId).name : sug.templateId) + '</b> (' + Math.round(sug.confidence * 100) + '% · ' + sug.source + ')<br><span style="color:#6b6455;">' + pstr + '</span></div>';
          var fire = document.createElement('button'); fire.textContent = 'Fire to class'; fire.style.cssText = 'background:var(--rust,#b3541e);color:#fff;border:none;border-radius:8px;padding:7px 14px;font-family:Inter Tight,sans-serif;font-size:12.5px;font-weight:700;cursor:pointer;margin-right:8px;';
          fire.addEventListener('click', function () { window.AquinBoard.trigger(sug.templateId, sug.params, detId); sugBox.style.display = 'none'; });
          var dismiss = document.createElement('button'); dismiss.textContent = 'Dismiss'; dismiss.style.cssText = 'background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:8px;padding:7px 12px;font-family:Inter Tight,sans-serif;font-size:12.5px;cursor:pointer;';
          dismiss.addEventListener('click', function () { sugBox.style.display = 'none'; });
          sugBox.appendChild(fire); sugBox.appendChild(dismiss);
        }
        function interpret(text) {
          if (!text) return; heard.textContent = 'Heard: "' + text + '"';
          fetch('/api/aquintutor/board/interpret', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ text: text, session: sessionId }) })
            .then(function (r) { return r.json(); }).then(function (j) { if (j.ok) { showSuggestion(j.suggestion, j.detectionId); poll(); } else { heard.textContent = j.error || 'Could not interpret'; } })
            .catch(function () { heard.textContent = 'Interpretation failed'; });
        }
        document.getElementById('interpret').addEventListener('click', function () { interpret(document.getElementById('phrase').value.trim()); });
        document.getElementById('phrase').addEventListener('keydown', function (e) { if (e.key === 'Enter') interpret(this.value.trim()); });

        // live ASR via the browser Speech API (real, no external key); typed input is the fallback
        var SR = window.SpeechRecognition || window.webkitSpeechRecognition, rec = null, listening = false;
        var micBtn = document.getElementById('mic');
        if (!SR) { micBtn.disabled = true; micBtn.textContent = 'Voice not supported — type instead'; micBtn.style.opacity = '0.6'; }
        else micBtn.addEventListener('click', function () {
          if (listening) { rec && rec.stop(); return; }
          rec = new SR(); rec.lang = 'en-US'; rec.interimResults = true; rec.continuous = true;
          rec.onstart = function () { listening = true; micBtn.textContent = 'Stop listening'; micBtn.style.background = 'var(--rust,#b3541e)'; };
          rec.onend = function () { listening = false; micBtn.textContent = 'Start listening'; micBtn.style.background = 'var(--ink,#1a1712)'; };
          rec.onerror = function (e) { heard.textContent = 'Mic error: ' + (e.error || 'unknown'); };
          rec.onresult = function (e) {
            var interim = '', final = '';
            for (var i = e.resultIndex; i < e.results.length; i++) { var tr = e.results[i][0].transcript; if (e.results[i].isFinal) final += tr; else interim += tr; }
            if (interim) heard.textContent = 'Listening: ' + interim;
            if (final.trim()) interpret(final.trim());
          };
          rec.start();
        });

        fetch('/api/aquintutor/board', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'ensure' }) });
        selectTemplate('projectile');
      });
    })();
  </script>
</AquintutorLayout>
