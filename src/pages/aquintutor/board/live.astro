---
// /aquintutor/board/live?session=SID — the student's live view (Prompt A1b, main surface).
// Opens the SSE feed, is told its render tier by the server (real Prompt-5 policy), and renders each
// fired spec ADAPTIVELY: lite = a single static keyframe (zero animation), standard/rich = animated.
// Reconnection is automatic (EventSource) and resumes from Last-Event-ID. Zero bundled client JS.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import SceneGL from '@/components/SceneGL.astro';
import { can } from '@/lib/rbac';

const user = Astro.locals.user;
const sessionId = (Astro.url.searchParams.get('session') || '').trim();
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/board/live?session=' + sessionId));
await can(user, 'read', { type: 'AnimationObject' });   // audit the join
if (!sessionId) return Astro.redirect('/aquintutor/hub');
---
<AquintutorLayout title="Live class board">
  <main style="max-width:820px;margin:0 auto;padding:36px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Live board</p>
    <h1 style="font-family:Fraunces,serif;font-size:26px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 4px;line-height:1.15;">Following the class board</h1>
    <p id="status" style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#6b6455;margin:0 0 16px;">Connecting to the session…</p>

    <div style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:14px;overflow:hidden;">
      <svg id="anim" viewBox="0 0 320 200" style="display:block;width:100%;height:auto;aspect-ratio:16/10;"></svg>
      <div id="sceneStage" style="display:none;background:#0e0f13;min-height:120px;"></div>
    </div>
    <p id="cap" style="font-family:'Inter Tight',sans-serif;font-size:12px;color:#8a8378;margin:10px 0 0;"></p>
  </main>

  <script src="/aquin-anim-templates.js" defer></script>
  <script src="/aquin-scene-engine.js" defer></script>
  <SceneGL />
  <script is:inline define:vars={{ sessionId }}>
    (function () {
      function ready(fn) { if (window.AquinAnim && window.AquinScene) fn(); else setTimeout(function () { ready(fn); }, 50); }
      ready(function () {
        var A = window.AquinAnim, anim = document.getElementById('anim'), sceneStage = document.getElementById('sceneStage'), status = document.getElementById('status'), cap = document.getElementById('cap');
        var tier = 'standard', animate = true, raf = null;
        var c = (navigator.connection || {});
        var qp = new URLSearchParams({ session: sessionId });
        if (navigator.deviceMemory) qp.set('dm', String(navigator.deviceMemory));
        if (c.effectiveType) qp.set('ect', c.effectiveType);
        if (c.saveData) qp.set('sd', '1');
        qp.set('vw', String(window.innerWidth || 0));
        if (window.matchMedia && matchMedia('(prefers-reduced-motion: reduce)').matches) qp.set('prm', '1');

        function stop() { if (raf) cancelAnimationFrame(raf); raf = null; }
        function showScene(spec) {
          // A3a: a scene-spec broadcast — render at THIS student's tier (rich/standard WebGL, lite 2D)
          stop(); anim.style.display = 'none'; sceneStage.style.display = 'block';
          var out = window.AquinScene.render(sceneStage, spec, tier);
          cap.textContent = (spec.title || 'Scene') + ' — ' + out.renderer + ' (' + tier + ')';
        }
        function show(spec) {
          if (spec.templateId === 'scene' && spec.params && spec.params.scene) { showScene(spec.params.scene); return; }
          anim.style.display = 'block'; sceneStage.style.display = 'none';
          stop();
          if (!animate || spec.playState !== 'playing') { A.renderSVG(anim, spec, tier); cap.textContent = A.get(spec.templateId) ? A.get(spec.templateId).name : spec.templateId; return; }
          var tpl = A.get(spec.templateId), dur = (tpl.duration ? tpl.duration(spec.params) : 3) * 1000, start = performance.now() - (spec.timelinePos || 0) * dur;
          cap.textContent = tpl.name;
          function step(now) { var p = Math.min(1, (now - start) / dur); A.renderSVG(anim, { templateId: spec.templateId, params: spec.params, playState: 'playing', timelinePos: p }, tier); if (p < 1) raf = requestAnimationFrame(step); }
          raf = requestAnimationFrame(step);
        }

        var es = new EventSource('/api/aquintutor/board/stream?' + qp.toString());
        es.addEventListener('ready', function (e) { var d = JSON.parse(e.data); tier = d.tier; animate = d.animate; status.textContent = 'Connected — ' + tier + ' quality' + (animate ? '' : ' (static, data-saver)') + '. Waiting for your teacher.'; status.style.color = '#2f7d5b'; });
        es.addEventListener('fire', function (e) { show(JSON.parse(e.data)); });
        es.onerror = function () { status.textContent = 'Reconnecting…'; status.style.color = '#b3541e'; };   // EventSource auto-retries
      });
    })();
  </script>
</AquintutorLayout>
