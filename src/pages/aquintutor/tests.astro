---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
function rows(r: any) { return Array.isArray(r) ? r : (r?.rows || []); }

let tests: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT t.id, t.slug, t.title, t.description, t.duration_mins, t.total_questions,
      COALESCE(t.price_chf, 0) AS price_chf, COALESCE(t.is_premium, false) AS is_premium,
      COALESCE(t.practice_enabled, true) AS practice_enabled,
      (SELECT COUNT(*)::int FROM test_attempts WHERE test_id = t.id AND status IN ('submitted','auto_submitted')) AS attempts
    FROM tests t
    WHERE t.is_published = true
    ORDER BY t.created_at ASC
  `);
  tests = rows(r);
} catch (_) {}

// Pull my best attempt per test so cards can show "best so far"
const myBest: Record<string, any> = {};
if (user) {
  try {
    const r = await db.execute(sql`
      SELECT DISTINCT ON (test_id) test_id, percentage, submitted_at
      FROM test_attempts
      WHERE candidate_id = ${user.id} AND status IN ('submitted','auto_submitted')
      ORDER BY test_id, percentage DESC NULLS LAST
    `);
    for (const a of rows(r)) myBest[String((a as any).test_id)] = a;
  } catch (_) {}
}
---
<AquintutorLayout title="Test catalog" description="Browse every test on AquinTutor.">
  <section style="border-bottom:1px solid var(--rule); background:linear-gradient(180deg,#fff8f3 0%, var(--paper) 100%);">
    <div style="max-width:1280px; margin:0 auto; padding:48px 28px;">
      <p style="font-family:'Inter Tight',monospace; font-size:12px; color:var(--rust); font-weight:700; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Test catalog</p>
      <h1 class="font-display" style="font-size:clamp(2rem,4vw,3rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500; margin:0 0 10px;">{tests.length} tests live.</h1>
      <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); line-height:1.6; max-width:48ch;">Every test has unlimited free practice. The official 1 CHF attempt saves your score, percentile, and counts toward leaderboard + achievements.</p>
      <div style="display:flex; gap:10px; margin-top:20px; flex-wrap:wrap;">
        <a href="/aquintutor/daily" style="background:var(--rust); color:#fff; padding:10px 16px; border-radius:10px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:700; text-decoration:none;">🎯 Today's challenge →</a>
        <a href="/aquintutor/leaderboard" style="background:var(--paper); color:var(--ink); padding:10px 16px; border-radius:10px; border:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:700; text-decoration:none;">🏆 Leaderboard</a>
        <a href="/aquintutor/achievements" style="background:var(--paper); color:var(--ink); padding:10px 16px; border-radius:10px; border:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:700; text-decoration:none;">🏅 Achievements</a>
      </div>
    </div>
  </section>

  <section>
    <div style="max-width:1280px; margin:0 auto; padding:36px 28px 80px;">
      <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(310px, 1fr)); gap:18px;">
        {tests.map((t: any) => {
          const best = myBest[String(t.id)];
          const priceChf = Number(t.price_chf || 0);
          const free = !t.is_premium || priceChf < 0.01;
          return (
            <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:22px 24px; display:flex; flex-direction:column; gap:12px;">
              <div style="display:flex; justify-content:space-between; gap:10px; align-items:flex-start;">
                <p class="font-display" style="font-size:1.15rem; font-weight:600; line-height:1.25; margin:0;">{t.title}</p>
                <span style={'font-family:JetBrains Mono,monospace; font-size:11px; font-weight:700; padding:3px 9px; border-radius:100px; ' + (free ? 'background:rgba(16,185,129,0.15); color:#047857;' : 'background:rgba(217,119,87,0.15); color:#b85e3f;')}>{free ? 'FREE' : t.price_chf + ' CHF'}</span>
              </div>
              <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink-500); line-height:1.6; margin:0;">{(t.description || '').slice(0, 160)}{(t.description || '').length > 160 ? '…' : ''}</p>
              <div style="display:flex; gap:14px; flex-wrap:wrap; font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--ink-500);">
                <span>📋 {t.total_questions} qs</span>
                <span>⏱ {t.duration_mins}m</span>
                <span>👥 {t.attempts} taken</span>
              </div>
              {best && (
                <p style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--rust); font-weight:700; margin:0;">Your best: {Math.round(parseFloat(best.percentage || '0'))}%</p>
              )}
              <div style="display:flex; gap:6px; margin-top:auto;">
                {t.practice_enabled && (
                  <a href={'/aquintutor/practice/' + t.slug} style="flex:1; background:var(--sand-100); color:var(--ink); padding:10px; border-radius:10px; font-family:'Inter Tight',sans-serif; font-size:12.5px; font-weight:700; text-decoration:none; text-align:center; border:1px solid var(--rule);">Practise</a>
                )}
                <a href={'/aquintutor/test/' + t.slug} style="flex:1; background:var(--ink); color:#fff; padding:10px; border-radius:10px; font-family:'Inter Tight',sans-serif; font-size:12.5px; font-weight:700; text-decoration:none; text-align:center;">{free ? 'Take test →' : 'Official →'}</a>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
</AquintutorLayout>
