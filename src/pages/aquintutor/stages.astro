---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

const stages = [
  { id: 'tots', name: 'Aquin Tots', ages: 'Ages 3-5', grades: 'Pre-KG · Kindergarten', color: '#a04330', soft: 'rgba(168,71,44,0.10)', headline: 'Their first 1,000 books, in 200 hours.', blurb: 'Voice-first stories, phonics, numbers, colours, big-feelings vocabulary. The screen does less; the child does more.', pillars: ['Storytime + read-aloud', 'Phonics & numbers', 'Colours, shapes, music', 'Social-emotional moments', 'Weekly parent letter'], cohort: '14,200 little learners', label: 'parents pay · child plays' },
  { id: 'juniors', name: 'Aquin Juniors', ages: 'Ages 6-10', grades: 'Grades 1-5 · Primary', color: '#946322', soft: 'rgba(148,99,34,0.10)', headline: 'Reading levels up. Math feels like a quest.', blurb: 'Curriculum-aligned to national boards, Common Core, IB-PYP. An avatar, a coach, a reading buddy, and homework that grades itself fairly.', pillars: ['Quest-mapped curriculum', 'Reading buddy (live)', 'Math coach (adaptive)', 'Science wonder labs', 'Parent + teacher dashboards'], cohort: '38,400 students', label: 'schools licensed: 412' },
  { id: 'scholars', name: 'Aquin Scholars', ages: 'Ages 11-18', grades: 'Grades 6-12 · Middle + High', color: '#2b577e', soft: 'rgba(43,87,126,0.10)', headline: 'Board-exam ready. College-app ready.', blurb: 'national boards, IB-MYP/DP, AP, A-Levels, SAT, engineering entrance, medical entrance. Subject teachers, peer study rooms, mentor matching, project portfolios that survive into college applications.', pillars: ['Curriculum tracks (10 boards)', 'engineering entrance / medical entrance / SAT prep', 'Peer study circles', 'College-app portfolio', 'ATLAS for board exams'], cohort: '62,100 students', label: 'tutors: 4,200 verified' },
  { id: 'undergrad', name: 'AquinTutor', ages: 'Ages 18-22', grades: 'Undergraduate', color: '#a8472c', soft: 'rgba(168,71,44,0.10)', headline: 'A real degree. Real professors. Aquin alongside.', blurb: "Accredited bachelor's programmes across 38 disciplines - from Quantum Computing to Sanskrit. Live lectures, labs, internships, transcripts that recruiters trust.", pillars: ['9 faculty per cohort, real institutions', 'Live labs + studios', 'Internship matching', 'W3C verifiable transcripts', 'Aquin 1:1 tutor (24/7)'], cohort: '11,800 undergraduates', label: 'accredited: national higher-ed regulator · AACSB · ABET', isCurrent: true },
  { id: 'research', name: 'AquinTutor Research', ages: 'Ages 22+', grades: "Master's · PhD · Postdoc", color: '#5b4a92', soft: 'rgba(91,74,146,0.10)', headline: "For the people writing tomorrow's field.", blurb: 'Advisor matching across 2,400 PIs. Literature graphs, paper drafting with Aquin, conference submission tracking, peer review queues, virtual lab notebooks, thesis runway.', pillars: ['Advisor matching · 2,400 PIs', 'Literature graphs + citation mining', 'Aquin co-author (with audit trail)', 'Lab notebook + git for science', 'Thesis runway · 4-year tracker'], cohort: '3,200 grad students', label: 'PIs hosting research: 2,400' },
  { id: 'atelier', name: 'AquinTutor Atelier', ages: 'Any age', grades: 'Vocational · Lifelong', color: '#4a7048', soft: 'rgba(74,112,72,0.10)', headline: 'Carpentry to coding, at any age, at your speed.', blurb: 'Micro-credentials in trades, languages, traditions, and second careers. NCVET-aligned, industry-recognised, employer-verified. From welding to Vedic sound.', pillars: ['Trades: carpentry, HVAC, welding', 'Languages & cultural traditions', 'Mid-career switches', 'Industry-recognised badges', 'Apprenticeship matching'], cohort: '21,600 learners · ages 17-72', label: 'NCVET aligned · employer verified' },
];

const total = stages.reduce((s, x) => s + parseInt(x.cohort.replace(/[^0-9]/g, '').slice(0, 6)), 0);
const positions = [4, 18, 35, 52, 70, 88];
---
<AquintutorLayout title="For every learner · Pre-KG to PhD" description="AquinTutor follows a learner across their entire life - pre-K through PhD, vocational through retirement. Six interfaces, one Aquin.">

  <!-- BREADCRUMB -->
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1400px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a>
      <span style="margin:0 8px;">/</span>
      <span style="color:var(--rust); font-weight:600;">FOR EVERY LEARNER · PRE-KG TO PhD</span>
    </div>
  </div>

  <!-- HERO -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:56px 28px 40px;">
      <div style="display:flex; align-items:center; gap:14px; margin-bottom:18px;">
        <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.22em; text-transform:uppercase; color:var(--ink-500);">One platform · six shells</span>
        <span style="width:4px; height:4px; border-radius:50%; background:var(--ink-300);"></span>
        <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:#4a7048; font-weight:600;">{total.toLocaleString()}+ learners &middot; ages 3 to 72</span>
      </div>
      <h1 class="font-display" style="font-size:clamp(2.5rem, 6vw, 5rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--ink); max-width:62rem;">
        From <em style="color:var(--rust); font-weight:400;">their first letters</em><br/>
        to <em style="color:#5b4a92; font-weight:400;">their dissertation</em>.
      </h1>
      <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.15rem, 1.5vw, 1.4rem); line-height:1.5; color:var(--ink-500); margin:24px 0 0; max-width:48rem;">
        AquinTutor is the only platform that follows a learner across their entire life - pre-K through PhD, vocational through retirement. Same Aquin, same teachers, same record. Six interfaces that grow with the human using them.
      </p>
    </div>
  </section>

  <!-- TIMELINE -->
  <section style="background:var(--sand-100); border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:36px 28px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 22px; text-align:center;">Age timeline &middot; 3 to 72</p>
      <div style="position:relative; padding:30px 0;">
        <div style="position:absolute; left:2%; right:2%; top:50%; height:2px; background:var(--rule); border-radius:2px;"></div>
        <div style="display:grid; grid-template-columns:repeat(6, 1fr); position:relative;">
          {stages.map((s, i) => (
            <div style={'display:flex; flex-direction:column; align-items:center; gap:8px; position:relative; z-index:1;' + (s.isCurrent ? ' transform:translateY(-4px);' : '')}>
              <span style={'display:inline-flex; align-items:center; justify-content:center; width:' + (s.isCurrent ? '34px' : '24px') + '; height:' + (s.isCurrent ? '34px' : '24px') + '; border-radius:50%; background:' + (s.isCurrent ? s.color : '#fff') + '; border:' + (s.isCurrent ? '2px solid ' + s.color : '2px solid ' + s.color) + '; font-family:Fraunces,serif; font-weight:500; font-size:' + (s.isCurrent ? '13px' : '11px') + '; color:' + (s.isCurrent ? '#fff' : s.color) + ';'}>{i + 1}</span>
              <p style={'font-family:Inter Tight,sans-serif; font-size:11.5px; font-weight:600; color:' + s.color + '; text-align:center; margin:0; line-height:1.2;'}>{s.name.replace('Aquin ', '').replace('AquinTutor ', '').replace('AquinTutor', 'Undergrad')}</p>
              <p style="font-family:'JetBrains Mono',monospace; font-size:9px; letter-spacing:0.08em; color:var(--ink-500); text-align:center; margin:0;">{s.ages.replace('Ages ', '')}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- STAGE CARDS -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:48px 28px;">
      <div style="display:grid; grid-template-columns:1fr; gap:18px;" class="stage-grid">
        {stages.map((s) => (
          <article style={'background:var(--paper); border:1px solid var(--rule); border-left:5px solid ' + s.color + '; border-radius:14px; overflow:hidden; ' + (s.isCurrent ? 'box-shadow:0 0 0 1px ' + s.color + ', 0 8px 24px rgba(11,14,20,0.06);' : '')}>
            <div style={'padding:24px 24px 18px; background:' + s.soft + '; border-bottom:1px solid var(--rule);'}>
              <div style="display:flex; align-items:start; justify-content:space-between; gap:10px; margin-bottom:10px;">
                <div>
                  <p style={'font-family:JetBrains Mono,monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:' + s.color + '; font-weight:600; margin:0 0 6px;'}>{s.ages} &middot; {s.grades}</p>
                  <h2 class="font-display" style="font-size:clamp(1.45rem, 2.4vw, 1.85rem); font-weight:500; line-height:1.15; letter-spacing:-0.02em; color:var(--ink); margin:0;">{s.name}</h2>
                </div>
                {s.isCurrent && <span style={'display:inline-flex; align-items:center; padding:3px 9px; background:' + s.color + '; color:#fff; border-radius:999px; font-family:JetBrains Mono,monospace; font-size:9.5px; letter-spacing:0.14em; text-transform:uppercase; font-weight:600; white-space:nowrap;'}>You are here</span>}
              </div>
              <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.1rem; color:var(--ink); line-height:1.45; margin:0;">{s.headline}</p>
            </div>

            <div style="padding:22px 24px; display:flex; flex-direction:column; gap:14px;">
              <p style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink-500); line-height:1.6; margin:0;">{s.blurb}</p>
              <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:7px;">
                {s.pillars.map((p) => (
                  <li style="display:flex; align-items:start; gap:9px; font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink); line-height:1.5;">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke={s.color} stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>{p}</span>
                  </li>
                ))}
              </ul>
              <div style="margin-top:6px; padding-top:14px; border-top:1px solid var(--rule); display:flex; justify-content:space-between; gap:8px; font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.06em;">
                <span style="color:var(--ink); font-weight:600;">{s.cohort}</span>
                <span style="color:var(--ink-500);">{s.label}</span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTINUUM STRIP -->
  <section style="background:#0b0d10; color:#f4f1ea; position:relative; overflow:hidden;">
    <div aria-hidden="true" style="position:absolute; inset:0; background:repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(168,71,44,0.018) 3px, rgba(168,71,44,0.018) 4px); pointer-events:none;"></div>
    <div style="max-width:1200px; margin:0 auto; padding:64px 28px; position:relative; z-index:1;">
      <p style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#d97757; font-weight:600; margin:0 0 14px;">The continuum</p>
      <h2 class="font-display" style="font-size:clamp(1.85rem, 3.5vw, 2.85rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0 0 20px; color:#f4f1ea; max-width:38rem;">
        One transcript. One Aquin.<br/>
        <span style="font-style:italic; font-weight:300; color:rgba(244,241,234,0.65);">A lifetime of record.</span>
      </h2>
      <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.05rem, 1.4vw, 1.25rem); color:rgba(244,241,234,0.78); line-height:1.55; margin:0 0 32px; max-width:36rem;">A child who reads with Aquin Tots can graduate from AquinTutor Research thirty years later under the same identity, on the same platform, with every credential anchored to the same verifiable record.</p>
      <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="continuum-grid">
        {[
          { l: 'Identity', v: 'Persistent', d: 'One account from age 3 to age 72.' },
          { l: 'Aquin', v: 'Memory of you', d: 'Per-stage tuned but identity-continuous.' },
          { l: 'Record', v: 'W3C VC', d: 'Every credential verifiable, lifetime.' },
          { l: 'Faculty', v: 'Named', d: 'Real people, named, paid per cohort.' },
        ].map((s) => (
          <div style="background:#161b22; border:1px solid #21262d; border-radius:12px; padding:16px;">
            <p style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#d97757; font-weight:600; margin:0;">{s.l}</p>
            <p class="font-display" style="font-size:1.35rem; font-weight:500; margin:6px 0 0; line-height:1; color:#f4f1ea; letter-spacing:-0.02em;">{s.v}</p>
            <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:#9a8e76; line-height:1.5; margin:6px 0 0;">{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <style>
    @media (min-width: 768px) { .stage-grid { grid-template-columns: repeat(2, 1fr) !important; } .continuum-grid { grid-template-columns: repeat(2, 1fr) !important; } }
    @media (min-width: 1100px) { .stage-grid { grid-template-columns: repeat(3, 1fr) !important; } .continuum-grid { grid-template-columns: repeat(4, 1fr) !important; } }
  </style>
</AquintutorLayout>
