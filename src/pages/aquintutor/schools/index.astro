---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

let schools: any[] = [];
let deptsBySchool: Record<string, any[]> = {};
let courseCountBySchool: Record<string, number> = {};

try {
  const r = await db.execute(sql`SELECT id, slug, code, name, tagline, description, display_order FROM schools WHERE is_published = true ORDER BY display_order ASC`);
  schools = Array.isArray(r) ? r : (r?.rows || []);
} catch(_) {}

try {
  const r = await db.execute(sql`SELECT id, school_id, slug, name, tagline FROM academic_departments WHERE is_published = true ORDER BY display_order ASC`);
  const rows = (Array.isArray(r) ? r : (r?.rows || [])) as any[];
  for (const d of rows) (deptsBySchool[d.school_id] = deptsBySchool[d.school_id] || []).push(d);
} catch(_) {}

try {
  const r = await db.execute(sql`SELECT school_id, COUNT(*)::int as n FROM training_courses WHERE is_published = true AND school_id IS NOT NULL GROUP BY school_id`);
  const rows = (Array.isArray(r) ? r : (r?.rows || [])) as any[];
  for (const c of rows) courseCountBySchool[c.school_id] = c.n;
} catch(_) {}

const SCHOOL_ICONS: Record<string, string> = {
  SCR: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2zM9 22V12h6v10',
  SML: 'M12 2v20M2 12h20M4 4l16 16M20 4L4 20',
  SLA: 'M4 19h16M4 19v-7l8-5 8 5v7M8 19v-5h8v5',
  SBP: 'M3 18l5-5 4 3 8-9M15 7h5v5',
  SDC: 'M3 20L12 4l9 16M7 20l5-9 5 9',
  SOF: 'M12 3l9 4-9 4-9-4zM3 12l9 4 9-4M3 17l9 4 9-4',
};
---
<AquintutorLayout title="Schools" description="The six schools of AquinTutor - Computing, Mathematics, Liberal Arts, Business, Design, and Foundations.">

  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1280px; margin:0 auto; padding:80px 28px 40px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); font-weight:600; letter-spacing:0.04em; margin:0 0 16px;">Academic structure</p>
      <h1 class="font-display" style="font-size:clamp(2.5rem, 5vw, 4.5rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0; color:var(--ink); max-width:42rem;">Six schools, seventeen departments.</h1>
      <p style="font-family:'Inter Tight',sans-serif; font-size:clamp(1rem, 1.3vw, 1.2rem); line-height:1.55; color:var(--ink-500); margin:20px 0 0; max-width:42rem;">Each school is a working faculty: named instructors, weekly graded assessment, a private AI tutor in every enrolment, and a verifiable credential at the end of every course.</p>
    </div>
  </section>

  <section>
    <div style="max-width:1280px; margin:0 auto; padding:64px 28px;">
      <div style="display:grid; grid-template-columns:1fr; gap:16px;" class="schools-grid">
        {schools.map((s: any) => {
          const depts = deptsBySchool[s.id] || [];
          return (
            <a href={'/aquintutor/schools/' + s.slug} style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:28px; text-decoration:none; color:var(--ink); display:flex; flex-direction:column; gap:18px; transition:border-color 0.2s, box-shadow 0.2s;" onmouseover="this.style.borderColor='var(--ink)';this.style.boxShadow='0 8px 24px rgba(11,14,20,0.06)';" onmouseout="this.style.borderColor='var(--rule)';this.style.boxShadow='none';">
              <div style="display:flex; align-items:center; justify-content:space-between;">
                <span style="display:inline-flex; align-items:center; justify-content:center; width:46px; height:46px; border-radius:10px; background:var(--sand-100); border:1px solid var(--rule);">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color:var(--ink);">
                    <path d={SCHOOL_ICONS[s.code] || 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z'}/>
                  </svg>
                </span>
                <span style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600;">{s.code}</span>
              </div>
              <div>
                <h2 class="font-display" style="font-size:1.5rem; font-weight:500; margin:0 0 10px; line-height:1.2; letter-spacing:-0.015em;">{s.name}</h2>
                <p style="font-family:'Inter Tight',sans-serif; font-size:14.5px; color:var(--ink-500); line-height:1.55; margin:0;">{s.tagline}</p>
              </div>
              {depts.length > 0 && (
                <ul style="list-style:none; padding:0; margin:0; display:flex; flex-wrap:wrap; gap:6px;">
                  {depts.slice(0, 5).map((d: any) => (
                    <li style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink-500); background:var(--sand-100); border:1px solid var(--rule); padding:4px 10px; border-radius:999px;">{d.name}</li>
                  ))}
                  {depts.length > 5 && <li style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink-500); padding:4px 4px; font-style:italic;">+{depts.length - 5} more</li>}
                </ul>
              )}
              <div style="margin-top:auto; padding-top:14px; border-top:1px solid var(--rule); display:flex; justify-content:space-between; font-family:'Inter Tight',sans-serif; font-size:13px;">
                <span style="color:var(--ink-500);">{courseCountBySchool[s.id] || 0} course{courseCountBySchool[s.id] === 1 ? '' : 's'}</span>
                <span style="color:var(--rust); font-weight:600;">Visit &rarr;</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <style>
    @media (min-width: 768px) { .schools-grid { grid-template-columns: repeat(2, 1fr) !important; } }
    @media (min-width: 1024px) { .schools-grid { grid-template-columns: repeat(3, 1fr) !important; } }
  </style>
</AquintutorLayout>
