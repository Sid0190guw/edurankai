---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

let schools: any[] = [];
let deptsBySchool: Record<string, any[]> = {};
let courseCountBySchool: Record<string, number> = {};
let lessonCountBySchool: Record<string, number> = {};
let facultyBySchool: Record<string, any[]> = {};
let totalDepts = 0, totalCourses = 0, totalLessons = 0, totalFaculty = 0;

try {
  const r = await db.execute(sql`SELECT id, slug, code, name, tagline, description, display_order FROM schools WHERE is_published = true ORDER BY display_order ASC`);
  schools = Array.isArray(r) ? r : (r?.rows || []);
} catch(_) {}

try {
  const r = await db.execute(sql`SELECT id, school_id, slug, name, tagline FROM academic_departments WHERE is_published = true ORDER BY display_order ASC`);
  const rows = (Array.isArray(r) ? r : (r?.rows || [])) as any[];
  for (const d of rows) (deptsBySchool[d.school_id] = deptsBySchool[d.school_id] || []).push(d);
  totalDepts = rows.length;
} catch(_) {}

try {
  const r = await db.execute(sql`SELECT school_id, COUNT(*)::int as n FROM training_courses WHERE is_published = true AND school_id IS NOT NULL GROUP BY school_id`);
  const rows = (Array.isArray(r) ? r : (r?.rows || [])) as any[];
  for (const c of rows) { courseCountBySchool[c.school_id] = c.n; totalCourses += c.n; }
} catch(_) {}

try {
  const r = await db.execute(sql`
    SELECT c.school_id, COUNT(l.id)::int as n
    FROM training_lessons l JOIN training_courses c ON l.course_id = c.id
    WHERE c.school_id IS NOT NULL GROUP BY c.school_id
  `);
  const rows = (Array.isArray(r) ? r : (r?.rows || [])) as any[];
  for (const c of rows) { lessonCountBySchool[c.school_id] = c.n; totalLessons += c.n; }
} catch(_) {}

try {
  const r = await db.execute(sql`SELECT name, title, slug FROM training_instructors ORDER BY sort_order LIMIT 24`);
  const rows = (Array.isArray(r) ? r : (r?.rows || [])) as any[];
  totalFaculty = rows.length;
  // Match faculty to school by title text (approximate)
  for (const f of rows) {
    const t = (f.title || '').toLowerCase();
    for (const s of schools) {
      if (t.includes((s.name || '').toLowerCase())) {
        (facultyBySchool[s.id] = facultyBySchool[s.id] || []).push(f);
        break;
      }
    }
  }
} catch(_) {}

const SCHOOL_ICONS: Record<string, string> = {
  SCR: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2zM9 22V12h6v10',
  SML: 'M12 2v20M2 12h20M4 4l16 16M20 4L4 20',
  SLA: 'M4 19h16M4 19v-7l8-5 8 5v7M8 19v-5h8v5',
  SBP: 'M3 18l5-5 4 3 8-9M15 7h5v5',
  SDC: 'M3 20L12 4l9 16M7 20l5-9 5 9',
  SOF: 'M12 3l9 4-9 4-9-4zM3 12l9 4 9-4M3 17l9 4 9-4',
};

const SCHOOL_BLURBS: Record<string, string> = {
  SCR: 'Algorithms, distributed systems, machine learning, theory. Heavy on engineering practice; equally heavy on the formal foundations that don\'t age.',
  SML: 'Pure and applied mathematics: analysis, algebra, statistics, mathematical logic. Co-taught modules with Computing and Business.',
  SLA: 'Philosophy, literature, history, classics. Long-form writing, primary sources, named debate prompts. No bluffing.',
  SBP: 'Microeconomics, public policy, corporate finance, organisational design. Case-led; named protagonists; verifiable outcomes.',
  SDC: 'Visual design, type, motion, product. Critique-led tutorial pattern; deliverables shipped to a public archive.',
  SOF: 'The bridging programmes: writing, quantitative literacy, study skills. Required for many tracks; recommended for all.',
};

const governance = [
  { n: 'I', label: 'Faculty-author principle', body: 'Every course is named to a faculty member who has shipped at least one major work in the area. No anonymous syllabi.' },
  { n: 'II', label: 'Departmental autonomy', body: 'Departments set their own grading standards within school policy, and publish their grading rubric in public.' },
  { n: 'III', label: 'Cross-school modules', body: 'Roughly one in four courses is co-taught across two schools to keep the boundaries honest.' },
  { n: 'IV', label: 'Annual review', body: 'Each course is reviewed every twelve months. Material that does not hold up is rewritten or retired.' },
];
---
<AquintutorLayout title="Schools" description="The six schools of AquinTutor - Computing, Mathematics, Liberal Arts, Business, Design, and Foundations.">

  <!-- HERO -->
  <section style="border-bottom:1px solid var(--rule); position:relative; overflow:hidden;">
    <div aria-hidden="true" style="position:absolute; right:-80px; top:60px; opacity:0.06;" class="hide-mobile">
      <svg width="360" height="360" viewBox="0 0 100 100" fill="none">
        <circle cx="50" cy="50" r="48" stroke="var(--ink)" stroke-width="0.4"/>
        <circle cx="50" cy="50" r="36" stroke="var(--ink)" stroke-width="0.4"/>
        <circle cx="50" cy="50" r="24" stroke="var(--ink)" stroke-width="0.4"/>
        <circle cx="50" cy="50" r="12" stroke="var(--ink)" stroke-width="0.4"/>
        <line x1="2" y1="50" x2="98" y2="50" stroke="var(--ink)" stroke-width="0.3"/>
        <line x1="50" y1="2" x2="50" y2="98" stroke="var(--ink)" stroke-width="0.3"/>
        <line x1="15" y1="15" x2="85" y2="85" stroke="var(--ink)" stroke-width="0.3"/>
        <line x1="85" y1="15" x2="15" y2="85" stroke="var(--ink)" stroke-width="0.3"/>
      </svg>
    </div>
    <div style="max-width:1280px; margin:0 auto; padding:80px 28px 36px; position:relative; z-index:1;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); font-weight:600; letter-spacing:0.04em; margin:0 0 18px;">The academic structure</p>
      <h1 class="font-display" style="font-size:clamp(2.5rem, 6vw, 5rem); line-height:0.98; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--ink); max-width:44rem;">
        Six schools,<br/>
        <span style="font-style:italic; font-weight:300; color:var(--ink-500);">{totalDepts} departments,</span><br/>
        one charter.
      </h1>
      <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.15rem, 1.5vw, 1.4rem); line-height:1.5; color:var(--ink-500); margin:28px 0 0; max-width:38rem;">
        Each school is a working faculty: named instructors, weekly graded assessment, a private AI tutor in every enrolment, and a verifiable credential at the end of every course.
      </p>
    </div>
  </section>

  <!-- STAT BAR -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1280px; margin:0 auto; padding:32px 28px;">
      <div style="display:grid; grid-template-columns:repeat(2, 1fr); gap:12px;" class="stat-row">
        {[
          { l: 'Schools', v: schools.length },
          { l: 'Departments', v: totalDepts },
          { l: 'Courses published', v: totalCourses },
          { l: 'Lessons authored', v: totalLessons },
          { l: 'Faculty members', v: totalFaculty },
          { l: 'Enrolment fee', v: '1 CHF', accent: true },
        ].map((s) => (
          <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:16px 18px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">{s.l}</p>
            <p class="font-display" style={'font-size:1.75rem; font-weight:500; margin:0; line-height:1; letter-spacing:-0.02em; ' + (s.accent ? 'color:var(--rust);' : 'color:var(--ink);')}>{s.v}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SCHOOLS GRID -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1280px; margin:0 auto; padding:72px 28px;">
      <div style="display:flex; align-items:end; justify-content:space-between; flex-wrap:wrap; gap:14px; margin-bottom:36px;">
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">The six</p>
          <h2 class="font-display" style="font-size:clamp(1.65rem, 3vw, 2.4rem); font-weight:500; line-height:1.12; letter-spacing:-0.015em; margin:0; color:var(--ink);">Choose where you want to be taught.</h2>
        </div>
        <p style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink-500); max-width:30rem; margin:0; line-height:1.55;">School pages list every department, every course in catalogue, and the faculty who lead the work. You can sit a screening interview at any time, no commitment.</p>
      </div>

      <div style="display:grid; grid-template-columns:1fr; gap:18px;" class="schools-grid">
        {schools.map((s: any, idx: number) => {
          const depts = deptsBySchool[s.id] || [];
          const fac = facultyBySchool[s.id] || [];
          const cc = courseCountBySchool[s.id] || 0;
          const lc = lessonCountBySchool[s.id] || 0;
          return (
            <a href={'/aquintutor/schools/' + s.slug} class="school-card" style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:0; text-decoration:none; color:var(--ink); display:flex; flex-direction:column; overflow:hidden; transition:transform 0.18s, border-color 0.18s, box-shadow 0.18s;">
              <div style="display:flex; align-items:center; justify-content:space-between; padding:22px 24px 16px; border-bottom:1px solid var(--rule); background:var(--sand-100);">
                <span style="display:inline-flex; align-items:center; justify-content:center; width:48px; height:48px; border-radius:10px; background:var(--paper); border:1px solid var(--rule); color:var(--ink);">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d={SCHOOL_ICONS[s.code] || 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z'}/></svg>
                </span>
                <div style="text-align:right;">
                  <p style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.18em; color:var(--ink); font-weight:600; margin:0;">{s.code}</p>
                  <p style="font-family:'Inter Tight',sans-serif; font-size:10px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-500); margin:3px 0 0;">School {String(idx+1).padStart(2,'0')} of {String(schools.length).padStart(2,'0')}</p>
                </div>
              </div>

              <div style="padding:22px 24px; display:flex; flex-direction:column; gap:14px; flex:1;">
                <div>
                  <h3 class="font-display" style="font-size:1.45rem; font-weight:500; margin:0 0 8px; line-height:1.2; letter-spacing:-0.015em;">{s.name}</h3>
                  <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.05rem; color:var(--ink-500); line-height:1.4; margin:0;">{s.tagline}</p>
                </div>
                {SCHOOL_BLURBS[s.code] && <p style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink-500); line-height:1.6; margin:0;">{SCHOOL_BLURBS[s.code]}</p>}

                {depts.length > 0 && (
                  <div style="display:flex; flex-direction:column; gap:8px;">
                    <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0;">Departments</p>
                    <ul style="list-style:none; padding:0; margin:0; display:flex; flex-wrap:wrap; gap:5px;">
                      {depts.slice(0, 6).map((d: any) => (
                        <li style="font-family:'Inter Tight',sans-serif; font-size:11.5px; color:var(--ink-500); background:var(--sand-100); border:1px solid var(--rule); padding:4px 10px; border-radius:999px;">{d.name.replace('Department of ', '')}</li>
                      ))}
                      {depts.length > 6 && <li style="font-family:'Inter Tight',sans-serif; font-size:11.5px; color:var(--ink-500); padding:4px 4px; font-style:italic; align-self:center;">+{depts.length - 6}</li>}
                    </ul>
                  </div>
                )}

                {fac.length > 0 && (
                  <div style="display:flex; flex-direction:column; gap:6px;">
                    <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0;">Featured faculty</p>
                    <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:4px;">
                      {fac.slice(0, 2).map((f: any) => (
                        <li style="display:flex; align-items:center; gap:8px;">
                          <span style="display:inline-flex; align-items:center; justify-content:center; width:22px; height:22px; min-width:22px; border-radius:50%; background:var(--ink); color:var(--sand-50); font-family:'Fraunces',serif; font-weight:500; font-size:10px;">{(f.name || 'F').split(' ').slice(-1)[0][0]}</span>
                          <span style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink);">{f.name}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                <div style="margin-top:auto; padding-top:14px; border-top:1px solid var(--rule); display:grid; grid-template-columns:repeat(3, 1fr); gap:10px;">
                  <div>
                    <p style="font-family:'Inter Tight',sans-serif; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 3px;">Depts</p>
                    <p class="font-display" style="font-size:1.15rem; font-weight:500; margin:0; line-height:1; color:var(--ink);">{depts.length}</p>
                  </div>
                  <div>
                    <p style="font-family:'Inter Tight',sans-serif; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 3px;">Courses</p>
                    <p class="font-display" style="font-size:1.15rem; font-weight:500; margin:0; line-height:1; color:var(--ink);">{cc}</p>
                  </div>
                  <div>
                    <p style="font-family:'Inter Tight',sans-serif; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 3px;">Lessons</p>
                    <p class="font-display" style="font-size:1.15rem; font-weight:500; margin:0; line-height:1; color:var(--ink);">{lc}</p>
                  </div>
                </div>

                <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); font-weight:600; margin:0; display:flex; align-items:center; gap:6px;">Visit the school <span aria-hidden="true">&rarr;</span></p>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- GOVERNANCE PRINCIPLES -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1280px; margin:0 auto; padding:72px 28px;">
      <div style="display:grid; grid-template-columns:1fr; gap:24px; margin-bottom:36px;" class="thesis-grid">
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">Governance</p>
          <h2 class="font-display" style="font-size:clamp(1.65rem, 3vw, 2.4rem); font-weight:500; line-height:1.12; letter-spacing:-0.015em; margin:0; color:var(--ink);">
            How the schools<br/>
            <span style="font-style:italic; font-weight:300; color:var(--ink-500);">are run, in four lines.</span>
          </h2>
        </div>
        <p style="font-family:'Inter Tight',sans-serif; font-size:14.5px; color:var(--ink-500); line-height:1.65; margin:0; max-width:34rem; justify-self:end;" class="thesis-rhs">Departments are sovereign within school policy. School policy is sovereign within the AquinTutor charter. The charter is public and changes only with thirty days' notice.</p>
      </div>
      <div style="display:grid; grid-template-columns:1fr; gap:18px;" class="governance-grid">
        {governance.map((g) => (
          <div style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:24px;">
            <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px;">
              <span class="font-display" style="font-style:italic; font-weight:300; font-size:1.85rem; color:var(--rust); line-height:1; letter-spacing:-0.02em;">{g.n}</span>
              <p class="font-display" style="font-size:1.1rem; font-weight:500; margin:0; line-height:1.2; letter-spacing:-0.015em; color:var(--ink);">{g.label}</p>
            </div>
            <p style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink-500); line-height:1.6; margin:0;">{g.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section>
    <div style="max-width:1100px; margin:0 auto; padding:64px 28px 80px; text-align:center;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Next step</p>
      <h2 class="font-display" style="font-size:clamp(1.6rem, 3vw, 2.25rem); font-weight:500; line-height:1.18; letter-spacing:-0.015em; margin:0 0 22px; color:var(--ink); max-width:36rem; margin-left:auto; margin-right:auto;">Pick a school and start reading the catalogue.</h2>
      <div style="display:flex; gap:10px; flex-wrap:wrap; justify-content:center;">
        <a href="/aquintutor/courses" style="background:var(--ink); color:var(--sand-50); padding:13px 24px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Browse the catalogue</a>
        <a href="/aquintutor/interview/general-screening" style="background:transparent; color:var(--ink); padding:13px 24px; border-radius:6px; border:1px solid var(--ink); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Sit a screening interview</a>
        <a href="/aquintutor/signup" style="background:transparent; color:var(--ink); padding:13px 24px; border-radius:6px; border:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Apply &middot; 1 CHF</a>
      </div>
    </div>
  </section>

  <style>
    .school-card:hover { transform: translateY(-3px); border-color: var(--ink); box-shadow: 0 12px 32px rgba(11,14,20,0.08); }
    @media (min-width: 640px) { .stat-row { grid-template-columns: repeat(3, 1fr) !important; } }
    @media (min-width: 900px) { .stat-row { grid-template-columns: repeat(6, 1fr) !important; } .thesis-grid { grid-template-columns: 1fr 1fr !important; } .governance-grid { grid-template-columns: repeat(2, 1fr) !important; } }
    @media (min-width: 768px) { .schools-grid { grid-template-columns: repeat(2, 1fr) !important; } }
    @media (min-width: 1100px) { .schools-grid { grid-template-columns: repeat(3, 1fr) !important; } }
  </style>
</AquintutorLayout>
