---
import '@/styles/aquintutor-academy.css';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

let schools: any[] = [];
let deptsBySchool: Record<string, any[]> = {};
let courseCountBySchool: Record<string, number> = {};

try {
  const r = await db.execute(sql`SELECT id, slug, code, name, tagline, description, display_order FROM schools WHERE is_published = true ORDER BY display_order ASC`);
  schools = Array.isArray(r) ? r : (r?.rows || []);
} catch(_) {}

try {
  const r = await db.execute(sql`SELECT id, school_id, slug, name, tagline FROM academic_departments WHERE is_published = true ORDER BY display_order ASC`);
  const rows = (Array.isArray(r) ? r : (r?.rows || [])) as any[];
  for (const d of rows) (deptsBySchool[d.school_id] = deptsBySchool[d.school_id] || []).push(d);
} catch(_) {}

try {
  const r = await db.execute(sql`SELECT school_id, COUNT(*)::int as n FROM training_courses WHERE is_published = true AND school_id IS NOT NULL GROUP BY school_id`);
  const rows = (Array.isArray(r) ? r : (r?.rows || [])) as any[];
  for (const c of rows) courseCountBySchool[c.school_id] = c.n;
} catch(_) {}
---
<!doctype html>
<html lang="en" class="academy editorial">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Schools - AquinTutor</title>
  <meta name="description" content="The six schools of AquinTutor - a virtual institution by EduRankAI. Computing, Mathematics, Liberal Arts, Business, Design, and Foundations." />
  <link rel="canonical" href="https://www.edurankai.in/aquintutor/schools" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="theme-color" content="#FBFAF4" />
</head>
<body class="academy editorial grain">

  <header style="border-bottom:1px solid var(--rule); background:rgba(251,250,244,0.85); backdrop-filter:blur(6px); position:relative; z-index:20;">
    <div style="border-bottom:1px solid rgba(11,14,20,0.08);">
      <div style="max-width:1400px; margin:0 auto; padding:8px 24px; display:flex; align-items:center; justify-content:space-between;" class="numplate">
        <span style="color:var(--ink-500);">EST. MMXXVI &middot; AN INSTITUTION OF EDURANK&middot;AI</span>
        <span class="hide-mobile" style="color:var(--ink-500);">VOL. I &middot; NO. 001 &middot; A GLOBAL VIRTUAL UNIVERSITY</span>
      </div>
    </div>
    <div style="max-width:1400px; margin:0 auto; padding:20px 24px; display:flex; align-items:center; justify-content:space-between;">
      <a href="/aquintutor" style="display:flex; align-items:baseline; gap:8px; text-decoration:none; color:var(--ink);">
        <span class="font-display" style="font-size:30px; font-weight:500; letter-spacing:-0.02em;">Aquin<span style="color:var(--rust);">Tutor</span></span>
        <span class="numplate" style="color:var(--ink-300);">.ai</span>
      </a>
      <nav class="hide-mobile" style="display:flex; align-items:center; gap:32px;">
        <a href="/aquintutor/schools" class="eyebrow" style="color:var(--ink); text-decoration:none;">Schools</a>
        <a href="/aquintutor/courses" class="eyebrow" style="color:var(--ink-500); text-decoration:none;">Courses</a>
        <a href="/aquintutor/paths" class="eyebrow" style="color:var(--ink-500); text-decoration:none;">Paths</a>
        <a href="/aquintutor/instructors" class="eyebrow" style="color:var(--ink-500); text-decoration:none;">Faculty</a>
      </nav>
      <div style="display:flex; align-items:center; gap:10px;">
        <a href="/portal/login" class="eyebrow" style="color:var(--ink-500); text-decoration:none; padding:8px 12px;">Sign in</a>
        <a href="/portal/signup" class="btn-pill filled" style="padding:10px 18px; font-size:11px;">Enrol</a>
      </div>
    </div>
  </header>

  <section style="max-width:1400px; margin:0 auto; padding:64px 24px 48px; border-bottom:1px solid var(--rule);">
    <p class="eyebrow" style="color:var(--ink-500);">The Catalogue</p>
    <h1 class="font-display" style="font-size:clamp(3.5rem, 9vw, 9rem); line-height:0.92; letter-spacing:-0.025em; font-weight:500; margin:24px 0 0;">
      Six schools.<br/>
      <span style="font-style:italic; font-weight:300; color:var(--ink-500);">Dozens of departments.</span>
    </h1>
    <p class="font-serif" style="font-size:clamp(1.25rem, 2vw, 1.875rem); line-height:1.3; color:var(--ink-500); margin-top:32px; max-width:48rem;">
      Each school is a working faculty: published courses, weekly assessment, a private AI tutor in every enrolment, and a real, verifiable credential at the end.
    </p>
  </section>

  <section style="max-width:1400px; margin:0 auto; padding:64px 24px;">
    <div style="display:grid; grid-template-columns:1fr; gap:1px; background:rgba(11,14,20,0.15); border:1px solid rgba(11,14,20,0.15);" class="schools-grid">
      {schools.map((s: any, i: number) => {
        const depts = deptsBySchool[s.id] || [];
        return (
          <a href={'/aquintutor/schools/' + s.slug} class="tile" style="padding:40px 32px;">
            <div>
              <div style="display:flex; justify-content:space-between;" class="numplate">
                <span style="color:var(--ink-300);">{String(i + 1).padStart(2, '0')} / {String(schools.length).padStart(2, '0')}</span>
                <span style="color:var(--ink-300);">{s.code || ''}</span>
              </div>
              <h2 class="font-display" style="font-size:2.25rem; margin-top:20px; line-height:1.05; letter-spacing:-0.025em; font-weight:500;">{s.name}</h2>
              <p class="font-serif" style="font-size:1.25rem; font-style:italic; color:var(--ink-500); margin-top:14px; line-height:1.3;">{s.tagline}</p>
            </div>
            <div style="margin-top:32px;">
              <div style="font-size:13px; color:var(--ink-500); line-height:1.5;">
                {depts.slice(0, 4).map((d: any) => <span>{d.name}{' '}&middot;{' '}</span>)}
                {depts.length > 4 && <span style="font-style:italic;">+{depts.length - 4} more</span>}
              </div>
              <p class="arrow-hint" style="margin-top:16px;">{courseCountBySchool[s.id] || 0} courses &rarr;</p>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <footer style="border-top:1px solid var(--rule); background:var(--paper);">
    <div style="max-width:1400px; margin:0 auto; padding:32px 24px; display:flex; justify-content:space-between; flex-wrap:wrap; gap:16px;" class="numplate">
      <p style="color:var(--ink-500); margin:0;">&copy; {new Date().getFullYear()} AQUINTUTOR &middot; AN INSTITUTION OF <a href="/" style="text-decoration:underline; color:var(--ink);">EDURANK&middot;AI</a></p>
      <div style="display:flex; gap:24px; flex-wrap:wrap; color:var(--ink-500);">
        <a href="/aquintutor/courses" style="color:var(--ink-500); text-decoration:none;">COURSES</a>
        <a href="/aquintutor/paths" style="color:var(--ink-500); text-decoration:none;">PATHS</a>
        <a href="/aquintutor/instructors" style="color:var(--ink-500); text-decoration:none;">FACULTY</a>
        <a href="/about" style="color:var(--ink-500); text-decoration:none;">ABOUT</a>
        <a href="/contact" style="color:var(--ink-500); text-decoration:none;">CONTACT</a>
      </div>
    </div>
  </footer>

  <style>
    @media (min-width: 768px) { .schools-grid { grid-template-columns: repeat(2, 1fr) !important; } .hide-mobile { display: inline !important; } }
    @media (min-width: 1024px) { .schools-grid { grid-template-columns: repeat(3, 1fr) !important; } }
    @media (max-width: 767px) { .hide-mobile { display: none !important; } }
  </style>
</body>
</html>
