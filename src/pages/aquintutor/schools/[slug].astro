---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const { slug } = Astro.params;

let school: any = null;
let depts: any[] = [];
let courses: any[] = [];

try {
  const r = await db.execute(sql`SELECT id, slug, code, name, tagline, description, display_order FROM schools WHERE slug = ${slug} AND is_published = true LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  school = rows[0] || null;
} catch(_) {}

if (!school) return Astro.redirect('/aquintutor/schools');

try {
  const r = await db.execute(sql`SELECT id, slug, name, tagline, description, display_order FROM academic_departments WHERE school_id = ${school.id} AND is_published = true ORDER BY display_order ASC`);
  depts = Array.isArray(r) ? r : (r?.rows || []);
} catch(_) {}

try {
  const r = await db.execute(sql`
    SELECT c.slug, c.title, c.subtitle, c.short_desc, c.level, c.duration_weeks, c.credit_hours,
      c.course_code, c.pricing_model, c.is_free, c.department_id,
      d.name as department_name,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as lesson_count
    FROM training_courses c LEFT JOIN academic_departments d ON c.department_id = d.id
    WHERE c.school_id = ${school.id} AND c.is_published = true
    ORDER BY c.created_at DESC
  `);
  courses = Array.isArray(r) ? r : (r?.rows || []);
} catch(_) {}
---
<AquintutorLayout title={school.name} description={school.tagline || school.name}>

  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1280px; margin:0 auto; padding:64px 28px 40px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink-500); margin:0 0 14px;">
        <a href="/aquintutor/schools" style="color:var(--ink-500); text-decoration:none;">Schools</a>
        <span style="margin:0 8px; color:var(--ink-300);">/</span>
        <span style="color:var(--rust); font-weight:600;">{school.code}</span>
      </p>
      <h1 class="font-display" style="font-size:clamp(2.5rem, 5vw, 4.5rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0; color:var(--ink); max-width:48rem;">{school.name}</h1>
      {school.tagline && (
        <p style="font-family:'Inter Tight',sans-serif; font-size:clamp(1.05rem, 1.4vw, 1.3rem); line-height:1.5; color:var(--ink-500); margin:20px 0 0; max-width:42rem;">{school.tagline}</p>
      )}
      {school.description && (
        <p style="font-family:'Inter Tight',sans-serif; font-size:16px; line-height:1.6; color:var(--ink-500); margin:20px 0 0; max-width:42rem;">{school.description}</p>
      )}

      <div style="display:flex; gap:32px; flex-wrap:wrap; margin-top:36px; padding-top:24px; border-top:1px solid var(--rule);">
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); margin:0 0 4px; font-weight:600;">Departments</p>
          <p class="font-display" style="font-size:1.75rem; font-weight:500; margin:0; color:var(--ink);">{depts.length}</p>
        </div>
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); margin:0 0 4px; font-weight:600;">Courses</p>
          <p class="font-display" style="font-size:1.75rem; font-weight:500; margin:0; color:var(--ink);">{courses.length}</p>
        </div>
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); margin:0 0 4px; font-weight:600;">School code</p>
          <p class="font-display" style="font-size:1.75rem; font-weight:500; margin:0; color:var(--rust);">{school.code}</p>
        </div>
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); margin:0 0 4px; font-weight:600;">Enrolment</p>
          <p class="font-display" style="font-size:1.75rem; font-weight:500; margin:0; color:var(--ink);">1 CHF</p>
        </div>
      </div>
    </div>
  </section>

  {depts.length > 0 && (
    <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
      <div style="max-width:1280px; margin:0 auto; padding:64px 28px;">
        <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Departments</p>
        <h2 class="font-display" style="font-size:clamp(1.75rem, 3vw, 2.5rem); line-height:1.15; letter-spacing:-0.015em; font-weight:500; margin:0 0 36px; color:var(--ink);">Inside {school.name.replace('School of ', '')}.</h2>
        <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="dept-grid">
          {depts.map((d: any) => (
            <article style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:22px;">
              <h3 class="font-display" style="font-size:1.2rem; font-weight:500; margin:0 0 8px; line-height:1.25; letter-spacing:-0.01em;">{d.name}</h3>
              <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); line-height:1.5; margin:0;">{d.tagline}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {courses.length > 0 ? (
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:1280px; margin:0 auto; padding:64px 28px;">
        <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Course catalogue</p>
        <h2 class="font-display" style="font-size:clamp(1.75rem, 3vw, 2.5rem); line-height:1.15; letter-spacing:-0.015em; font-weight:500; margin:0 0 36px; color:var(--ink);">Open courses, current term.</h2>
        <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="course-grid">
          {courses.map((c: any) => (
            <a href={'/aquintutor/courses/' + c.slug} style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:22px; text-decoration:none; color:var(--ink); display:flex; flex-direction:column; gap:10px;">
              <div style="display:flex; justify-content:space-between; gap:8px;">
                <span style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink-500); font-weight:600;">{c.course_code || (c.level || 'COURSE').toUpperCase()}</span>
                <span style="font-family:'Inter Tight',sans-serif; font-size:11px; color:var(--ink-500);">{c.department_name || ''}</span>
              </div>
              <h3 class="font-display" style="font-size:1.2rem; font-weight:500; margin:0; line-height:1.25; letter-spacing:-0.01em;">{c.title}</h3>
              {(c.subtitle || c.short_desc) && (
                <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); line-height:1.5; margin:0;">{c.subtitle || c.short_desc}</p>
              )}
              <div style="margin-top:auto; display:flex; justify-content:space-between; padding-top:10px; border-top:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:12.5px;">
                <span style="color:var(--ink-500);">
                  {c.lesson_count > 0 ? c.lesson_count + 'L' : ''}
                  {c.duration_weeks > 0 ? ' · ' + c.duration_weeks + 'W' : ''}
                  {c.credit_hours > 0 ? ' · ' + c.credit_hours + 'CR' : ''}
                </span>
                <span style="color:var(--rust); font-weight:600;">{c.is_free || c.pricing_model === 'free' ? 'Included' : 'Paid'}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  ) : (
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:1280px; margin:0 auto; padding:64px 28px; text-align:center;">
        <p style="font-family:'Inter Tight',sans-serif; font-size:16px; color:var(--ink-500); margin:0 0 22px;">The first courses for {school.name} are being prepared.</p>
        <a href="/aquintutor/courses" style="display:inline-block; background:transparent; color:var(--ink); padding:14px 24px; border-radius:6px; border:1px solid var(--ink); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Browse all courses</a>
      </div>
    </section>
  )}

  <section>
    <div style="max-width:1280px; margin:0 auto; padding:64px 28px; display:grid; grid-template-columns:1fr; gap:32px; align-items:center;" class="cta-grid">
      <div>
        <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Begin a programme</p>
        <h2 class="font-display" style="font-size:clamp(1.75rem, 3vw, 2.5rem); line-height:1.15; letter-spacing:-0.015em; font-weight:500; margin:0; color:var(--ink);">Enrol in {school.name.replace('School of ', '')}.</h2>
        <p style="font-family:'Inter Tight',sans-serif; font-size:15.5px; color:var(--ink-500); line-height:1.55; margin:14px 0 0; max-width:36rem;">One enrolment opens the entire institution. Pick a course, do the work, sit the examination, receive the credential.</p>
      </div>
      <div style="display:flex; flex-direction:column; gap:10px; max-width:340px;">
        <a href="/aquintutor/signup" style="background:var(--ink); color:var(--sand-50); padding:14px 24px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none; text-align:center;">Apply &middot; 1 CHF &rarr;</a>
        <a href="/aquintutor/courses" style="background:transparent; color:var(--ink); padding:14px 24px; border-radius:6px; border:1px solid var(--ink); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none; text-align:center;">Browse the catalogue</a>
      </div>
    </div>
  </section>

  <style>
    @media (min-width: 768px) {
      .dept-grid { grid-template-columns: repeat(2, 1fr) !important; }
      .course-grid { grid-template-columns: repeat(2, 1fr) !important; }
      .cta-grid { grid-template-columns: 2fr 1fr !important; }
    }
    @media (min-width: 1024px) {
      .dept-grid { grid-template-columns: repeat(3, 1fr) !important; }
      .course-grid { grid-template-columns: repeat(3, 1fr) !important; }
    }
  </style>
</AquintutorLayout>
