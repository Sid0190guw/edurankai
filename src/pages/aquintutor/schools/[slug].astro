---
import '@/styles/aquintutor-academy.css';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const { slug } = Astro.params;

let school: any = null;
let depts: any[] = [];
let courses: any[] = [];

try {
  const r = await db.execute(sql`SELECT id, slug, code, name, tagline, description, display_order FROM schools WHERE slug = ${slug} AND is_published = true LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  school = rows[0] || null;
} catch(_) {}

if (!school) return Astro.redirect('/aquintutor/schools');

try {
  const r = await db.execute(sql`SELECT id, slug, name, tagline, description, display_order FROM academic_departments WHERE school_id = ${school.id} AND is_published = true ORDER BY display_order ASC`);
  depts = Array.isArray(r) ? r : (r?.rows || []);
} catch(_) {}

try {
  const r = await db.execute(sql`
    SELECT c.slug, c.title, c.subtitle, c.short_desc, c.level, c.duration_weeks, c.credit_hours,
      c.course_code, c.pricing_model, c.is_free, c.department_id,
      d.name as department_name,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as lesson_count
    FROM training_courses c LEFT JOIN academic_departments d ON c.department_id = d.id
    WHERE c.school_id = ${school.id} AND c.is_published = true
    ORDER BY c.created_at DESC
  `);
  courses = Array.isArray(r) ? r : (r?.rows || []);
} catch(_) {}
---
<!doctype html>
<html lang="en" class="academy editorial">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{school.name} - AquinTutor</title>
  <meta name="description" content={school.tagline || school.name + ' - AquinTutor'} />
  <link rel="canonical" href={'https://www.edurankai.in/aquintutor/schools/' + school.slug} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="theme-color" content="#FBFAF4" />
</head>
<body class="academy editorial grain">

  <header style="border-bottom:1px solid var(--rule); background:rgba(251,250,244,0.85); backdrop-filter:blur(6px); position:relative; z-index:20;">
    <div style="border-bottom:1px solid rgba(11,14,20,0.08);">
      <div style="max-width:1400px; margin:0 auto; padding:8px 24px; display:flex; align-items:center; justify-content:space-between;" class="numplate">
        <span style="color:var(--ink-500);">EST. MMXXVI &middot; AN INSTITUTION OF EDURANK&middot;AI</span>
        <span class="hide-mobile" style="color:var(--ink-500);">{school.code || 'SCHOOL'} &middot; AQUINTUTOR</span>
      </div>
    </div>
    <div style="max-width:1400px; margin:0 auto; padding:20px 24px; display:flex; align-items:center; justify-content:space-between;">
      <a href="/aquintutor" style="display:flex; align-items:baseline; gap:8px; text-decoration:none; color:var(--ink);">
        <span class="font-display" style="font-size:30px; font-weight:500; letter-spacing:-0.02em;">Aquin<span style="color:var(--rust);">Tutor</span></span>
        <span class="numplate" style="color:var(--ink-300);">.ai</span>
      </a>
      <nav class="hide-mobile" style="display:flex; align-items:center; gap:32px;">
        <a href="/aquintutor/schools" class="eyebrow" style="color:var(--ink); text-decoration:none;">Schools</a>
        <a href="/aquintutor/courses" class="eyebrow" style="color:var(--ink-500); text-decoration:none;">Courses</a>
        <a href="/aquintutor/paths" class="eyebrow" style="color:var(--ink-500); text-decoration:none;">Paths</a>
        <a href="/aquintutor/instructors" class="eyebrow" style="color:var(--ink-500); text-decoration:none;">Faculty</a>
      </nav>
      <div style="display:flex; align-items:center; gap:10px;">
        <a href="/aquintutor/login" class="eyebrow" style="color:var(--ink-500); text-decoration:none; padding:8px 12px;">Sign in</a>
        <a href="/aquintutor/signup" class="btn-pill filled" style="padding:10px 18px; font-size:11px;">Enrol</a>
      </div>
    </div>
  </header>

  <!-- Hero -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:64px 24px 48px;">
      <div style="display:flex; align-items:center; gap:16px; margin-bottom:32px;" class="numplate">
        <span style="height:1px; width:48px; background:var(--ink);"></span>
        <a href="/aquintutor/schools" style="color:var(--ink-500); text-decoration:none;">SCHOOLS</a>
        <span style="color:var(--ink-300);">/</span>
        <span style="color:var(--ink-300);">{school.code || school.slug.toUpperCase()}</span>
      </div>

      <h1 class="font-display" style="font-size:clamp(3rem, 8vw, 8rem); line-height:0.92; letter-spacing:-0.025em; font-weight:500; margin:0;">
        {school.name}
      </h1>
      {school.tagline && (
        <p class="font-serif" style="font-size:clamp(1.5rem, 2.5vw, 2rem); font-style:italic; line-height:1.3; color:var(--ink-500); margin-top:24px; max-width:48rem;">
          {school.tagline}
        </p>
      )}
      {school.description && (
        <p class="font-serif" style="font-size:1.25rem; color:var(--ink-500); margin-top:24px; max-width:48rem; line-height:1.4;">{school.description}</p>
      )}
    </div>

    <div style="border-top:1px solid var(--rule); background:var(--sand-100);">
      <div style="max-width:1400px; margin:0 auto; padding:24px; display:grid; grid-template-columns:repeat(2,1fr); gap:20px;" class="stats-grid numplate">
        <div><span class="font-display" style="display:block; color:var(--ink); font-size:24px; font-weight:500;">{depts.length}</span> <span style="color:var(--ink-500);">DEPARTMENTS</span></div>
        <div><span class="font-display" style="display:block; color:var(--ink); font-size:24px; font-weight:500;">{courses.length}</span> <span style="color:var(--ink-500);">COURSES</span></div>
        <div><span class="font-display" style="display:block; color:var(--ink); font-size:24px; font-weight:500;">{school.code || '-'}</span> <span style="color:var(--ink-500);">CODE</span></div>
        <div><span class="font-display" style="display:block; color:var(--ink); font-size:24px; font-weight:500;">1 CHF</span> <span style="color:var(--ink-500);">ENROLMENT</span></div>
      </div>
    </div>
  </section>

  <!-- Departments -->
  {depts.length > 0 && (
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:1400px; margin:0 auto; padding:96px 24px;">
        <div style="display:grid; grid-template-columns:1fr; gap:40px; margin-bottom:64px;" class="thesis-grid">
          <div>
            <p class="eyebrow">&sect; I &mdash; Structure</p>
            <p class="numplate" style="color:var(--ink-300); margin-top:8px;">{String(depts.length).padStart(3, '0')} DEPTS</p>
          </div>
          <div>
            <h2 class="font-display" style="font-size:clamp(2.5rem, 6vw, 6rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0;">
              Departments<br/>
              <span style="font-style:italic; font-weight:300; color:var(--ink-500);">of {school.name.replace('School of ', '')}</span>
            </h2>
          </div>
        </div>

        <div style="display:grid; grid-template-columns:1fr; gap:1px; background:rgba(11,14,20,0.15); border:1px solid rgba(11,14,20,0.15);" class="schools-grid">
          {depts.map((d: any, i: number) => (
            <div class="tile" style="cursor:default;">
              <div>
                <p class="numplate" style="color:var(--ink-300);">{String(i + 1).padStart(2, '0')} &middot; {school.code}</p>
                <h3 class="font-display" style="font-size:1.5rem; margin-top:16px; line-height:1.1; letter-spacing:-0.02em; font-weight:500;">{d.name}</h3>
              </div>
              <p class="font-serif" style="font-size:1.125rem; font-style:italic; color:var(--ink-500); margin-top:14px; line-height:1.3;">{d.tagline}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Courses in this school -->
  {courses.length > 0 ? (
    <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
      <div style="max-width:1400px; margin:0 auto; padding:96px 24px;">
        <div style="display:grid; grid-template-columns:1fr; gap:40px; margin-bottom:64px;" class="thesis-grid">
          <div>
            <p class="eyebrow">&sect; II &mdash; Catalogue</p>
            <p class="numplate" style="color:var(--ink-300); margin-top:8px;">{String(courses.length).padStart(3, '0')} COURSES</p>
          </div>
          <div>
            <h2 class="font-display" style="font-size:clamp(2.5rem, 6vw, 6rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0;">
              Open courses.<br/>
              <span style="font-style:italic; font-weight:300; color:var(--ink-500);">Enrol when ready.</span>
            </h2>
          </div>
        </div>

        <div style="display:grid; grid-template-columns:1fr; gap:1px; background:rgba(11,14,20,0.15); border:1px solid rgba(11,14,20,0.15);" class="schools-grid">
          {courses.map((c: any) => (
            <a href={'/aquintutor/courses/' + c.slug} class="tile" style="padding:32px;">
              <div>
                <div style="display:flex; justify-content:space-between; gap:8px;" class="numplate">
                  <span style="color:var(--ink-300);">{c.course_code || (c.level || 'GEN').toUpperCase()}</span>
                  <span style="color:var(--ink-300);">{c.department_name || ''}</span>
                </div>
                <h3 class="font-display" style="font-size:1.75rem; margin-top:16px; line-height:1.1; letter-spacing:-0.02em; font-weight:500;">{c.title}</h3>
                <p class="font-serif" style="font-size:1.125rem; font-style:italic; color:var(--ink-500); margin-top:12px; line-height:1.3;">{c.subtitle || c.short_desc || ''}</p>
              </div>
              <div style="margin-top:32px; padding-top:16px; border-top:1px solid var(--rule); display:flex; justify-content:space-between;" class="numplate">
                <span style="color:var(--ink-300);">
                  {c.lesson_count > 0 ? c.lesson_count + 'L' : ''}
                  {c.duration_weeks > 0 ? ' · ' + c.duration_weeks + 'W' : ''}
                  {c.credit_hours > 0 ? ' · ' + c.credit_hours + 'CR' : ''}
                </span>
                <span style="color:var(--ink-300);">{c.is_free || c.pricing_model === 'free' ? 'FREE' : 'PAID'}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  ) : (
    <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
      <div style="max-width:1400px; margin:0 auto; padding:96px 24px; text-align:center;">
        <p class="font-serif" style="font-size:1.5rem; font-style:italic; color:var(--ink-500); max-width:36rem; margin:0 auto;">
          The first courses of {school.name} are being prepared. Browse the full catalogue or watch for new offerings each term.
        </p>
        <div style="margin-top:32px;"><a href="/aquintutor/courses" class="btn-pill outline">Browse all courses &rarr;</a></div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="invert">
    <div style="max-width:1400px; margin:0 auto; padding:96px 24px; display:grid; grid-template-columns:1fr; gap:40px;" class="thesis-grid">
      <div>
        <p class="eyebrow" style="color:rgba(251,250,244,0.5);">Enrol</p>
        <p class="numplate" style="color:rgba(251,250,244,0.4); margin-top:8px;">{school.code}</p>
      </div>
      <div>
        <h2 class="font-display" style="font-size:clamp(2.5rem, 6vw, 6rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--sand-50);">
          Begin in<br/>
          <span style="font-style:italic; font-weight:300; color:var(--gold);">{school.name.replace('School of ', '')}.</span>
        </h2>
        <div style="margin-top:40px; display:flex; gap:14px; flex-wrap:wrap;">
          <a href="/aquintutor/courses" class="btn-pill filled" style="background:var(--sand-50); color:var(--ink); border-color:var(--sand-50);">Browse {school.code} courses &rarr;</a>
          <a href="/aquintutor/signup" class="btn-pill outline" style="color:var(--sand-50); border-color:var(--sand-50);">Enrol from 1 CHF</a>
        </div>
      </div>
    </div>
  </section>

  <footer style="border-top:1px solid var(--rule); background:var(--paper);">
    <div style="max-width:1400px; margin:0 auto; padding:32px 24px; display:flex; justify-content:space-between; flex-wrap:wrap; gap:16px;" class="numplate">
      <p style="color:var(--ink-500); margin:0;">&copy; {new Date().getFullYear()} AQUINTUTOR &middot; AN INSTITUTION OF <a href="/" style="text-decoration:underline; color:var(--ink);">EDURANK&middot;AI</a></p>
      <div style="display:flex; gap:24px; flex-wrap:wrap; color:var(--ink-500);">
        <a href="/aquintutor/schools" style="color:var(--ink-500); text-decoration:none;">SCHOOLS</a>
        <a href="/aquintutor/courses" style="color:var(--ink-500); text-decoration:none;">COURSES</a>
        <a href="/aquintutor/paths" style="color:var(--ink-500); text-decoration:none;">PATHS</a>
        <a href="/aquintutor/instructors" style="color:var(--ink-500); text-decoration:none;">FACULTY</a>
        <a href="/about" style="color:var(--ink-500); text-decoration:none;">ABOUT</a>
      </div>
    </div>
  </footer>

  <style>
    @media (min-width: 768px) { .thesis-grid { grid-template-columns: 3fr 9fr !important; } .schools-grid { grid-template-columns: repeat(2, 1fr) !important; } .stats-grid { grid-template-columns: repeat(4, 1fr) !important; } .hide-mobile { display: inline !important; } }
    @media (min-width: 1024px) { .schools-grid { grid-template-columns: repeat(3, 1fr) !important; } }
    @media (max-width: 767px) { .hide-mobile { display: none !important; } }
  </style>
</body>
</html>
