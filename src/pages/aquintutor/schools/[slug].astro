---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const { slug } = Astro.params;

let school: any = null;
let depts: any[] = [];
let courses: any[] = [];
let faculty: any[] = [];

try {
  const r = await db.execute(sql`SELECT id, slug, code, name, tagline, description, display_order FROM schools WHERE slug = ${slug} AND is_published = true LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  school = rows[0] || null;
} catch(_) {}

if (!school) return Astro.redirect('/aquintutor/schools');

try {
  const r = await db.execute(sql`SELECT id, slug, name, tagline, description, display_order FROM academic_departments WHERE school_id = ${school.id} AND is_published = true ORDER BY display_order ASC`);
  depts = Array.isArray(r) ? r : (r?.rows || []);
} catch(_) {}

try {
  const r = await db.execute(sql`
    SELECT c.slug, c.title, c.subtitle, c.short_desc, c.level, c.duration_weeks, c.credit_hours, c.duration_hours,
      c.course_code, c.pricing_model, c.is_free, c.department_id, c.instructor_name,
      d.name as department_name,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as lesson_count,
      (SELECT ROUND(AVG(rating)::numeric, 1) FROM training_reviews WHERE course_id = c.id) as avg_rating
    FROM training_courses c LEFT JOIN academic_departments d ON c.department_id = d.id
    WHERE c.school_id = ${school.id} AND c.is_published = true
    ORDER BY c.created_at DESC
  `);
  courses = Array.isArray(r) ? r : (r?.rows || []);
} catch(_) {}

try {
  const r = await db.execute(sql`
    SELECT name, title, bio, slug, specialties FROM training_instructors
    WHERE LOWER(title) LIKE ${'%' + (school.name || '').toLowerCase() + '%'}
    ORDER BY is_featured DESC, sort_order LIMIT 6
  `);
  faculty = Array.isArray(r) ? r : (r?.rows || []);
} catch(_) {}

const totalLessons = courses.reduce((s, c) => s + (c.lesson_count || 0), 0);
const totalHours = courses.reduce((s, c) => s + (c.duration_hours || 0), 0);

const SCHOOL_ICONS: Record<string, string> = {
  SCR: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2zM9 22V12h6v10',
  SML: 'M12 2v20M2 12h20M4 4l16 16M20 4L4 20',
  SLA: 'M4 19h16M4 19v-7l8-5 8 5v7M8 19v-5h8v5',
  SBP: 'M3 18l5-5 4 3 8-9M15 7h5v5',
  SDC: 'M3 20L12 4l9 16M7 20l5-9 5 9',
  SOF: 'M12 3l9 4-9 4-9-4zM3 12l9 4 9-4M3 17l9 4 9-4',
};

function initials(n: string) {
  const parts = (n || '').split(' ').filter(Boolean);
  if (parts.length === 0) return 'F';
  if (parts.length === 1) return parts[0][0];
  return parts[0][0] + parts.slice(-1)[0][0];
}
---
<AquintutorLayout title={school.name} description={school.tagline || school.name}>

  <!-- BREADCRUMB -->
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1280px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a>
      <span style="margin:0 8px;">/</span>
      <a href="/aquintutor/schools" style="color:var(--ink-500); text-decoration:none;">SCHOOLS</a>
      <span style="margin:0 8px;">/</span>
      <span style="color:var(--rust); font-weight:600;">{school.code}</span>
    </div>
  </div>

  <!-- HERO -->
  <section style="border-bottom:1px solid var(--rule); position:relative; overflow:hidden;">
    <div aria-hidden="true" style="position:absolute; right:-30px; top:60px; opacity:0.06; pointer-events:none;" class="hide-mobile">
      <svg width="300" height="300" viewBox="0 0 24 24" fill="none" stroke="var(--ink)" stroke-width="0.3"><path d={SCHOOL_ICONS[school.code] || 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z'}/></svg>
    </div>
    <div style="max-width:1280px; margin:0 auto; padding:64px 28px 40px; position:relative; z-index:1;">
      <div style="display:flex; align-items:center; gap:14px; margin-bottom:18px;">
        <span style="display:inline-flex; align-items:center; justify-content:center; width:54px; height:54px; border-radius:12px; background:var(--ink); color:var(--sand-50);">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d={SCHOOL_ICONS[school.code] || 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z'}/></svg>
        </span>
        <div>
          <p style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.18em; margin:0;">{school.code}</p>
          <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); margin:3px 0 0;">A school of AquinTutor</p>
        </div>
      </div>
      <h1 class="font-display" style="font-size:clamp(2.25rem, 5vw, 4.25rem); line-height:1.02; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--ink); max-width:46rem;">{school.name}</h1>
      {school.tagline && (
        <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.15rem, 1.5vw, 1.4rem); line-height:1.5; color:var(--ink-500); margin:22px 0 0; max-width:42rem;">{school.tagline}</p>
      )}
      {school.description && (
        <p style="font-family:'Inter Tight',sans-serif; font-size:16px; line-height:1.7; color:var(--ink-500); margin:18px 0 0; max-width:42rem;">{school.description}</p>
      )}
    </div>
  </section>

  <!-- STAT STRIP -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1280px; margin:0 auto; padding:28px 28px;">
      <div style="display:grid; grid-template-columns:repeat(2, 1fr); gap:12px;" class="stat-row">
        {[
          { l: 'Departments', v: depts.length },
          { l: 'Open courses', v: courses.length },
          { l: 'Lessons authored', v: totalLessons },
          { l: 'Faculty', v: faculty.length },
          { l: 'Hours', v: totalHours > 0 ? totalHours + 'h' : '-' },
          { l: 'Enrolment fee', v: '1 CHF', accent: true },
        ].map((s) => (
          <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px 18px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">{s.l}</p>
            <p class="font-display" style={'font-size:1.55rem; font-weight:500; margin:0; line-height:1; letter-spacing:-0.02em; ' + (s.accent ? 'color:var(--rust);' : 'color:var(--ink);')}>{s.v}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {depts.length > 0 && (
    <!-- DEPARTMENTS -->
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:1280px; margin:0 auto; padding:64px 28px;">
        <div style="display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:14px; margin-bottom:30px;">
          <div>
            <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">Departments</p>
            <h2 class="font-display" style="font-size:clamp(1.65rem, 3vw, 2.25rem); font-weight:500; line-height:1.12; letter-spacing:-0.015em; margin:0; color:var(--ink);">Inside {school.name.replace('School of ', '')}.</h2>
          </div>
          <p style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--ink-500); letter-spacing:0.1em; margin:0;">{depts.length} {depts.length === 1 ? 'DEPT' : 'DEPTS'}</p>
        </div>
        <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="dept-grid">
          {depts.map((d: any, i: number) => (
            <article style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:22px; display:flex; flex-direction:column; gap:10px;">
              <div style="display:flex; align-items:center; justify-content:space-between; gap:8px;">
                <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.16em; color:var(--ink-500); font-weight:600;">DEPT {String(i + 1).padStart(2, '0')}</span>
              </div>
              <h3 class="font-display" style="font-size:1.15rem; font-weight:500; margin:0; line-height:1.22; letter-spacing:-0.015em;">{d.name}</h3>
              {d.tagline && <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:0.98rem; color:var(--ink-500); line-height:1.4; margin:0;">{d.tagline}</p>}
              {d.description && <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink-500); line-height:1.55; margin:0;">{d.description.substring(0, 140)}{d.description.length > 140 ? '...' : ''}</p>}
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {faculty.length > 0 && (
    <!-- FACULTY -->
    <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
      <div style="max-width:1280px; margin:0 auto; padding:64px 28px;">
        <div style="display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:14px; margin-bottom:30px;">
          <div>
            <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">Faculty</p>
            <h2 class="font-display" style="font-size:clamp(1.65rem, 3vw, 2.25rem); font-weight:500; line-height:1.12; letter-spacing:-0.015em; margin:0; color:var(--ink);">Who teaches here.</h2>
          </div>
          <a href="/aquintutor/instructors" style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--rust); text-decoration:none; font-weight:500;">All faculty &rarr;</a>
        </div>
        <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="faculty-grid">
          {faculty.map((f: any) => (
            <a href={'/aquintutor/instructors/' + f.slug} style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:18px; text-decoration:none; color:var(--ink); display:flex; gap:14px; align-items:start;">
              <span style="display:inline-flex; align-items:center; justify-content:center; width:48px; height:48px; min-width:48px; border-radius:50%; background:var(--ink); color:var(--sand-50); font-family:'Fraunces',serif; font-weight:500; font-size:1.15rem;">{initials(f.name)}</span>
              <div style="min-width:0; flex:1;">
                <p class="font-display" style="font-size:1.05rem; font-weight:500; margin:0; line-height:1.2; letter-spacing:-0.015em;">{f.name}</p>
                {f.title && <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink-500); margin:3px 0 0; line-height:1.4;">{f.title}</p>}
                {f.bio && <p style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500); margin:8px 0 0; line-height:1.5;">{f.bio.substring(0, 110)}{f.bio.length > 110 ? '...' : ''}</p>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {courses.length > 0 ? (
    <!-- COURSES -->
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:1280px; margin:0 auto; padding:64px 28px;">
        <div style="display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:14px; margin-bottom:30px;">
          <div>
            <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">Course catalogue</p>
            <h2 class="font-display" style="font-size:clamp(1.65rem, 3vw, 2.25rem); font-weight:500; line-height:1.12; letter-spacing:-0.015em; margin:0; color:var(--ink);">Open courses, current term.</h2>
          </div>
          <a href={'/aquintutor/courses?school=' + school.code} style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--rust); text-decoration:none; font-weight:500;">Filter catalogue &rarr;</a>
        </div>
        <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="course-grid">
          {courses.map((c: any) => (
            <a href={'/aquintutor/courses/' + c.slug} class="course-card" style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:0; overflow:hidden; text-decoration:none; color:var(--ink); display:flex; flex-direction:column; transition:transform 0.18s, box-shadow 0.18s;">
              <div style="height:4px; background:var(--rust);"></div>
              <div style="padding:20px 22px 18px; display:flex; flex-direction:column; gap:10px; flex:1;">
                <div style="display:flex; justify-content:space-between; gap:8px; font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.12em; color:var(--ink-500); text-transform:uppercase;">
                  <span>{c.course_code || (c.level || 'COURSE')}</span>
                  <span>{c.department_name ? c.department_name.replace('Department of ', '') : ''}</span>
                </div>
                <h3 class="font-display" style="font-size:1.15rem; font-weight:500; margin:0; line-height:1.22; letter-spacing:-0.015em;">{c.title}</h3>
                {c.subtitle && <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:0.95rem; color:var(--ink-500); line-height:1.38; margin:0;">{c.subtitle}</p>}
                {c.short_desc && <p style="font-family:'Inter Tight',sans-serif; font-size:13px; line-height:1.55; color:var(--ink-500); margin:0;">{c.short_desc.substring(0, 110)}{c.short_desc.length > 110 ? '...' : ''}</p>}
                {c.instructor_name && (
                  <p style="font-family:'Inter Tight',sans-serif; font-size:11.5px; color:var(--ink-500); margin:0; display:flex; align-items:center; gap:6px;">
                    <span style="display:inline-flex; align-items:center; justify-content:center; width:18px; height:18px; min-width:18px; border-radius:50%; background:var(--ink); color:var(--sand-50); font-family:'Fraunces',serif; font-weight:500; font-size:9px;">{(c.instructor_name || 'F').split(' ').slice(-1)[0][0]}</span>
                    {c.instructor_name}
                  </p>
                )}
                <div style="margin-top:auto; padding-top:12px; border-top:1px solid var(--rule); display:flex; justify-content:space-between; gap:8px; font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink-500);">
                  <span>{c.lesson_count || 0} lessons{c.duration_weeks ? ' &middot; ' + c.duration_weeks + 'w' : ''}{c.credit_hours ? ' &middot; ' + c.credit_hours + 'cr' : ''}</span>
                  <span style="color:var(--rust); font-weight:600;">{c.is_free || c.pricing_model === 'free' ? 'Open' : 'Paid'}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  ) : (
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:1100px; margin:0 auto; padding:64px 28px; text-align:center;">
        <p class="font-display" style="font-size:1.45rem; font-weight:500; line-height:1.2; letter-spacing:-0.015em; margin:0 0 10px; color:var(--ink);">The first courses for {school.name} are being prepared.</p>
        <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1rem; color:var(--ink-500); margin:0 0 22px;">Watch this space, or browse the full catalogue while you wait.</p>
        <a href="/aquintutor/courses" style="display:inline-block; background:var(--ink); color:var(--sand-50); padding:13px 24px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Browse all courses</a>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section style="background:var(--ink); color:var(--sand-50);">
    <div style="max-width:1100px; margin:0 auto; padding:64px 28px; display:grid; grid-template-columns:1fr; gap:32px; align-items:center;" class="cta-grid">
      <div>
        <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:#d97757; font-weight:600; letter-spacing:0.04em; margin:0 0 14px;">Begin a programme</p>
        <h2 class="font-display" style="font-size:clamp(1.85rem, 3.5vw, 2.75rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0 0 14px; color:var(--sand-50);">Enrol in {school.name.replace('School of ', '')}.</h2>
        <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.05rem, 1.4vw, 1.2rem); line-height:1.55; color:rgba(251,250,244,0.78); margin:0; max-width:36rem;">One enrolment opens the entire institution. Pick a course, do the work, sit the examination, receive the credential.</p>
      </div>
      <div style="display:flex; flex-direction:column; gap:10px; max-width:300px; justify-self:end;">
        <a href="/aquintutor/signup" style="background:#d97757; color:#1a0f08; padding:13px 24px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none; text-align:center;">Apply &middot; 1 CHF &rarr;</a>
        <a href="/aquintutor/schools" style="background:transparent; color:var(--sand-50); padding:13px 24px; border-radius:6px; border:1px solid rgba(251,250,244,0.4); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none; text-align:center;">Other schools</a>
      </div>
    </div>
  </section>

  <style>
    .course-card:hover { transform: translateY(-3px); box-shadow: 0 10px 28px rgba(11,14,20,0.08); }
    @media (min-width: 640px) { .stat-row { grid-template-columns: repeat(3, 1fr) !important; } }
    @media (min-width: 900px) { .stat-row { grid-template-columns: repeat(6, 1fr) !important; } .cta-grid { grid-template-columns: 1.6fr 1fr !important; } }
    @media (min-width: 768px) { .dept-grid { grid-template-columns: repeat(2, 1fr) !important; } .course-grid { grid-template-columns: repeat(2, 1fr) !important; } .faculty-grid { grid-template-columns: repeat(2, 1fr) !important; } }
    @media (min-width: 1100px) { .dept-grid { grid-template-columns: repeat(3, 1fr) !important; } .course-grid { grid-template-columns: repeat(3, 1fr) !important; } .faculty-grid { grid-template-columns: repeat(3, 1fr) !important; } }
  </style>
</AquintutorLayout>
