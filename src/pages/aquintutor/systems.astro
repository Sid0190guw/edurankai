---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

// Wellbeing+ dimensions
const wellbeing = [
  { k: 'Mood', v: 78, c: '#4a7048', trend: '+', meta: 'gentle week' },
  { k: 'Sleep', v: 62, c: '#3b5675', trend: '↑', meta: '6h 48m avg · improving' },
  { k: 'Focus', v: 84, c: '#5b4a92', trend: '=', meta: 'steady · 4.2h deep work/day' },
  { k: 'Connection', v: 71, c: '#a8472c', trend: '+', meta: '3 new conversations · cohort' },
  { k: 'Movement', v: 55, c: '#a87526', trend: '−', meta: 'down · suggest a walk' },
];

// Hands-on / national R&D equipment portal partner instruments
const handsOn = [
  { inst: 'a national science institute', eq: 'Scanning Electron Microscope', avail: '3 slots · this week', dist: '0 km · virtual', color: '#5b4a92' },
  { inst: 'a national engineering institute', eq: 'Femtosecond laser bench', avail: 'next: Mon 10:00', dist: 'ships kits', color: '#2b577e' },
  { inst: 'a partner research lab Bangalore', eq: 'Confocal microscopy suite', avail: '6 slots open', dist: 'remote operable', color: '#4a7048' },
  { inst: 'TIFR Mumbai', eq: 'X-ray diffraction', avail: 'queue · 2 ahead', dist: 'ships samples', color: '#a8472c' },
  { inst: 'JNCASR', eq: 'Atomic Force Microscope', avail: '5 slots this week', dist: 'remote operable', color: '#a04330' },
  { inst: 'IISER Pune', eq: 'NMR spectrometer · 600MHz', avail: 'tomorrow 09:00', dist: 'ships samples', color: '#8a486b' },
];

const nptelCourses = [
  { code: 'CS-FOUND', title: 'Programming, Data Structures & Algorithms', inst: 'a national engineering institute', faculty: 'Lead faculty', dur: '12 wk', credits: 4, learners: '184k', color: '#2b577e' },
  { code: 'PHY-ADV', title: 'Quantum Field Theory · advanced', inst: 'a national engineering institute', faculty: 'Lead faculty', dur: '12 wk', credits: 4, learners: '18k', color: '#5b4a92' },
  { code: 'ME-ROB', title: 'Robotics · Mechanics & Control', inst: 'a national engineering institute', faculty: 'Lead faculty', dur: '8 wk', credits: 3, learners: '42k', color: '#946322' },
  { code: 'HS-ART', title: 'Introduction to Indian Art', inst: 'a national engineering institute', faculty: 'Lead faculty', dur: '8 wk', credits: 3, learners: '27k', color: '#a8472c' },
];

// Campus federation partners
const partners = [
  { name: 'a national engineering institute', type: 'a national engineering institute', link: 'lead · public national MOOC programme', color: '#2b577e' },
  { name: 'a national engineering institute', type: 'a national engineering institute', link: 'robotics + AI', color: '#2b577e' },
  { name: 'a national science institute', type: 'a national science institute', link: 'science core', color: '#5b4a92' },
  { name: 'BHU Varanasi', type: 'CFTI', link: 'Vedic studies', color: '#a8472c' },
  { name: 'JNU Delhi', type: 'CFTI', link: 'humanities', color: '#8a486b' },
  { name: 'Delhi Univ.', type: 'CFTI', link: 'liberal arts', color: '#8a486b' },
  { name: 'NID Ahmedabad', type: 'INI', link: 'design', color: '#a04330' },
  { name: 'NIFT', type: 'INI', link: 'fashion', color: '#a04330' },
  { name: 'a national medical institute', type: 'CFTI', link: 'medicine', color: '#a04330' },
  { name: 'a national management institute', type: 'a national management institute', link: 'business', color: '#4a7048' },
  { name: 'NLU Bangalore', type: 'CFTI', link: 'law', color: '#3b5675' },
  { name: 'Ia national engineering institute', type: 'INI', link: 'computer sci', color: '#2b577e' },
];

// Tutor authentication 6-stage gauntlet
const tutorStages = [
  { n: '01', t: 'Identity & background', blurb: 'Aadhaar / passport · biometric · police verification · social-media audit.', meta: '24h', color: '#3b5675' },
  { n: '02', t: 'Subject-matter exam', blurb: 'Domain test designed by a national engineering institute / a national science institute faculty. 90 min. Adaptive. Live-proctored.', meta: '90 min', color: '#2b577e' },
  { n: '03', t: 'Pedagogical assessment', blurb: 'Record a 12-minute lesson. Reviewed by 3 anonymous educators + Aquin rubric.', meta: '12 min', color: '#5b4a92' },
  { n: '04', t: 'Psychophysical screen', blurb: 'Licensed-psychologist interview. Big-Five + clinical screen. Confidential, court-grade.', meta: '60 min', color: '#8a486b' },
  { n: '05', t: 'Child-safety certification', blurb: 'POCSO / safeguarding training · sample-class observation · ongoing audit.', meta: 'ongoing', color: '#a04330' },
  { n: '06', t: 'Continuous review', blurb: 'Learner ratings, peer observation, attendance, audit re-test every 18 months.', meta: '18 mo loop', color: '#4a7048' },
];

// Coaching tracks
const coachingTracks = [
  { exam: 'premier engineering entrance', subj: 'Engineering · IITs', batch: '24-month foundation + final', students: '184k', faculty: 248, mocks: 320, color: '#2b577e' },
  { exam: 'medical entrance · UG', subj: 'Medical · a national medical institute · a forces medical institute', batch: '24-month full · 12-month sprint', students: '142k', faculty: 196, mocks: 280, color: '#a04330' },
  { exam: 'civil-services CSE', subj: 'Civil Services', batch: '18-month integrated', students: '48k', faculty: 124, mocks: 96, color: '#8a486b' },
  { exam: 'CAT · XAT · GMAT', subj: 'MBA admissions', batch: '12-month + crash', students: '38k', faculty: 88, mocks: 140, color: '#4a7048' },
  { exam: 'graduate aptitude', subj: 'PG engineering · PSU', batch: '12-month subject-wise', students: '62k', faculty: 116, mocks: 180, color: '#5b4a92' },
  { exam: 'law entrance · AILET', subj: 'Law schools (NLUs)', batch: '12-month integrated', students: '19k', faculty: 54, mocks: 110, color: '#3b5675' },
  { exam: 'staff-selection · Railway · Bank', subj: 'Government jobs', batch: '6-month rotating · vernacular', students: '268k', faculty: 142, mocks: 420, color: '#a87526' },
  { exam: 'central-unEuropean MOOC consortium test · UG · central-unEuropean MOOC consortium test · PG', subj: 'Central unEuropean MOOC consortium', batch: '8-month school-aligned', students: '92k', faculty: 92, mocks: 160, color: '#a8472c' },
];

// MOOC regions
const moocRegions = [
  { name: 'North America', color: '#2b577e', platforms: ['UnEuropean MOOC consortium-led MOOCs', 'Independent learning platforms', 'Open-courseware archives'] },
  { name: 'Europe', color: '#5b4a92', platforms: ['Inter-unEuropean MOOC consortium consortia', 'Open online education networks', 'National higher-ed portals'] },
  { name: 'Bharat', color: '#a8472c', platforms: ['Government open-learning portals', 'Public unEuropean MOOC consortium-led courseware', 'National digital education hubs'] },
  { name: 'East Asia', color: '#946322', platforms: ['XuetangX', 'Chinese MOOC', 'JMOOC Japan', 'K-MOOC Korea'] },
  { name: 'Latin America', color: '#a04330', platforms: ['MéxicoX', 'MiríadaX', 'UNESP Open'] },
  { name: 'Africa', color: '#4a7048', platforms: ['African Virtual UnEuropean MOOC consortium', 'continental MOOC network', 'continental open educational resources'] },
];

// IoT + teleops signals
const ioTNodes = [
  { l: 'Tele-operable arms', v: '128', sub: 'UR5 + Franka, 5G + fibre' },
  { l: '3D print farms', v: '6', sub: 'FDM + SLA + SLS, materials shipped' },
  { l: 'CNC mill suites', v: '18', sub: 'Haas VF-2 + Tormach, supervised' },
  { l: 'Sensor swarms', v: '4,200', sub: 'soil, weather, seismic, biomedical' },
  { l: 'Edge inference', v: '142', sub: 'nodes in 36 countries' },
  { l: 'Telemetry retained', v: 'Audit only', sub: 'no raw media; flagged events only' },
];

// Instrument studio
const instruments = [
  { kind: 'Piano', sub: 'MIDI · 88 keys · velocity sensing', latency: '11ms', students: '8.4k', color: '#2b577e' },
  { kind: 'Guitar', sub: '6 + 12 string · electric + classical', latency: '12ms', students: '12.1k', color: '#a04330' },
  { kind: 'Sitar', sub: 'Vedic ragas · live raga reference', latency: '14ms', students: '2.6k', color: '#a8472c' },
  { kind: 'Tabla', sub: 'Pattern recognition · ghata theka', latency: '13ms', students: '4.1k', color: '#946322' },
  { kind: 'Violin', sub: 'Bowing pressure + intonation', latency: '12ms', students: '5.8k', color: '#8a486b' },
  { kind: 'Vocal · Hindustani', sub: 'pitch tracking + raga scaffold', latency: '15ms', students: '3.4k', color: '#a87526' },
];
---
<AquintutorLayout title="Institutional systems" description="The operating layer underneath AquinTutor: wellbeing instrumentation, hands-on equipment network, public national MOOC programme integration, federation of partner institutions, tutor authentication, coaching platform, global MOOC federation, IoT and tele-operations.">

  <!-- BREADCRUMB -->
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1400px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a>
      <span style="margin:0 8px;">/</span>
      <a href="/aquintutor/campus" style="color:var(--ink-500); text-decoration:none;">CAMPUS</a>
      <span style="margin:0 8px;">/</span>
      <span style="color:var(--rust); font-weight:600;">INSTITUTIONAL SYSTEMS</span>
    </div>
  </div>

  <!-- HERO -->
  <section style="border-bottom:1px solid var(--rule); position:relative; overflow:hidden;">
    <div aria-hidden="true" style="position:absolute; right:-80px; top:0; opacity:0.05; pointer-events:none;" class="hide-mobile">
      <svg width="400" height="400" viewBox="0 0 100 100" fill="none">
        {Array.from({length: 5}).map((_, i) => <circle cx="50" cy="50" r={10 + i * 8} stroke="var(--ink)" stroke-width="0.3" fill="none"/>)}
        {Array.from({length: 8}).map((_, i) => {
          const a = (i / 8) * Math.PI * 2;
          return <line x1="50" y1="50" x2={50 + Math.cos(a) * 42} y2={50 + Math.sin(a) * 42} stroke="var(--ink)" stroke-width="0.2"/>;
        })}
      </svg>
    </div>
    <div style="max-width:1400px; margin:0 auto; padding:64px 28px 44px; position:relative; z-index:1;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); font-weight:600; letter-spacing:0.04em; margin:0 0 16px;">Institutional systems &middot; the operating layer</p>
      <h1 class="font-display" style="font-size:clamp(2.25rem, 5vw, 4.25rem); line-height:0.98; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--ink); max-width:48rem;">
        Twelve systems<br/>
        <span style="font-style:italic; font-weight:300; color:var(--ink-500);">underneath every district.</span>
      </h1>
      <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.15rem, 1.5vw, 1.4rem); line-height:1.5; color:var(--ink-500); margin:24px 0 0; max-width:42rem;">
        Wellbeing instrumentation, hands-on equipment networks with a national engineering institute and a national science institute, public national MOOC programmes integration, 1,420-institution federation, tutor authentication, coaching, global MOOC federation, IoT and tele-operations. The infrastructure that lets a single learner sit a quantum lab, then a Vedic chant chamber, then a engineering entrance mock, on the same afternoon.
      </p>
    </div>
  </section>

  <!-- WELLBEING+ -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:56px 28px; display:grid; grid-template-columns:1fr; gap:32px; align-items:start;" class="wb-grid">
      <div>
        <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.22em; text-transform:uppercase; color:#4a7048; font-weight:700; margin:0 0 8px;">Wellbeing+ &middot; system 01</p>
        <h2 class="font-display" style="font-size:clamp(1.85rem, 3.5vw, 2.85rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0 0 14px; color:var(--ink); max-width:34rem;">
          Your <em style="color:#4a7048; font-weight:400;">whole self</em> is on the report card.
        </h2>
        <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.05rem, 1.4vw, 1.2rem); color:var(--ink); line-height:1.55; margin:0 0 22px; max-width:36rem;">Universities have always treated grades as the only signal. We measure five more, with consent, with privacy, with the student in control. When something drifts, Aquin notices and offers - never demands - a course correction.</p>
        <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:8px;">
          {['Confidential 1:1 counselling · 92 licensed therapists, 38 languages', 'Daily mindfulness · sunrise yoga from a Mysore studio', 'Sleep coaching · MIT-trained chronobiologists', 'Peer support circles · trained student listeners', 'Crisis line · 24/7 · multilingual · zero stigma', 'Aquin watches for warning signs, alerts only the student'].map((t) => (
            <li style="display:flex; align-items:start; gap:10px; font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink-500); line-height:1.55;">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4a7048" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg>
              <span>{t}</span>
            </li>
          ))}
        </ul>
      </div>
      <div style="background:var(--sand-100); border:1px solid var(--rule); border-radius:14px; padding:22px;">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:18px;">
          <p style="font-family:'JetBrains Mono',monospace; font-size:9.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:700; margin:0;">Your wellbeing &middot; this week</p>
          <span style="display:inline-flex; align-items:center; padding:3px 9px; background:rgba(74,112,72,0.10); border:1px solid #4a7048; border-radius:999px; font-family:'JetBrains Mono',monospace; font-size:9.5px; letter-spacing:0.1em; text-transform:uppercase; color:#4a7048; font-weight:600;">PRIVATE TO YOU</span>
        </div>
        <div style="display:flex; flex-direction:column; gap:16px;">
          {wellbeing.map((d) => (
            <div>
              <div style="display:flex; align-items:baseline; justify-content:space-between; margin-bottom:5px;">
                <span style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink); font-weight:600;">{d.k}</span>
                <span style={'font-family:JetBrains Mono,monospace; font-size:11px; color:' + d.c + '; font-weight:600;'}>{d.v}%  <span style="color:var(--ink-500);">{d.trend}</span></span>
              </div>
              <div style="height:5px; background:var(--rule); border-radius:999px; overflow:hidden;">
                <div style={'width:' + d.v + '%; height:100%; background:' + d.c + ';'}></div>
              </div>
              <p style="font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--ink-500); margin:5px 0 0;">{d.meta}</p>
            </div>
          ))}
        </div>
        <div style="margin-top:18px; padding:12px 14px; background:rgba(74,112,72,0.08); border:1px solid #7dd3a8; border-radius:8px; display:flex; align-items:start; gap:10px;">
          <span style="display:inline-flex; align-items:center; justify-content:center; width:22px; height:22px; min-width:22px; border-radius:50%; background:#4a7048; color:#fff; font-family:'Fraunces',serif; font-weight:500; font-size:11px;">A</span>
          <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:13.5px; color:var(--ink); margin:0; line-height:1.45;">Movement is down 14% this week. Want me to suggest a 20-minute walk after Quantum class?</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ADAPTIVE ENGAGEMENT -->
  <section style="background:var(--sand-100); border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:56px 28px; display:grid; grid-template-columns:1fr; gap:32px; align-items:center;" class="ae-grid">
      <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:20px;">
        <p style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:700; margin:0 0 14px;">Engagement signal &middot; live</p>
        <svg viewBox="0 0 320 140" width="100%" style="display:block;">
          <!-- attention curve -->
          <path d="M 10 90 Q 50 60 90 70 T 170 50 T 250 78 T 310 60" stroke="#5b4a92" stroke-width="2" fill="none"/>
          <path d="M 10 90 Q 50 60 90 70 T 170 50 T 250 78 T 310 60 L 310 130 L 10 130 Z" fill="rgba(91,74,146,0.12)"/>
          <!-- gridlines -->
          {[30, 60, 90, 120].map((y) => <line x1="10" y1={y} x2="310" y2={y} stroke="var(--rule)" stroke-width="0.5" stroke-dasharray="2 3"/>)}
          <!-- ticks -->
          <text x="10" y="135" font-family="JetBrains Mono" font-size="8" fill="var(--ink-500)">00:00</text>
          <text x="160" y="135" font-family="JetBrains Mono" font-size="8" fill="var(--ink-500)" text-anchor="middle">12:00</text>
          <text x="310" y="135" font-family="JetBrains Mono" font-size="8" fill="var(--ink-500)" text-anchor="end">24:00</text>
          <!-- struggle marker -->
          <circle cx="170" cy="50" r="5" fill="#a87526"/>
          <text x="180" y="44" font-family="JetBrains Mono" font-size="9" fill="#a87526" font-weight="600">peak</text>
          <circle cx="250" cy="78" r="5" fill="#a04330"/>
          <text x="258" y="74" font-family="JetBrains Mono" font-size="9" fill="#a04330" font-weight="600">struggle</text>
        </svg>
        <div style="margin-top:12px; padding-top:12px; border-top:1px solid var(--rule); display:grid; grid-template-columns:repeat(3, 1fr); gap:10px;">
          {[{l:'Attention', v:'87%', c:'#5b4a92'}, {l:'Confusion', v:'12%', c:'#a87526'}, {l:'Frustration', v:'4%', c:'#a04330'}].map((s) => (
            <div>
              <p style="font-family:'JetBrains Mono',monospace; font-size:9px; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink-500); margin:0;">{s.l}</p>
              <p style={'font-family:JetBrains Mono,monospace; font-size:1rem; color:' + s.c + '; font-weight:700; margin:3px 0 0;'}>{s.v}</p>
            </div>
          ))}
        </div>
      </div>
      <div>
        <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.22em; text-transform:uppercase; color:#5b4a92; font-weight:700; margin:0 0 8px;">Adaptive engagement &middot; system 02</p>
        <h2 class="font-display" style="font-size:clamp(1.85rem, 3.5vw, 2.85rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0 0 14px; color:var(--ink); max-width:34rem;">
          Computer-vision attention tracking.<br/>
          <span style="font-style:italic; font-weight:300; color:var(--ink-500);">Helps the kids who don't naturally engage.</span>
        </h2>
        <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.05rem, 1.4vw, 1.2rem); color:var(--ink); line-height:1.55; margin:0 0 22px; max-width:34rem;">Optional, opt-in. Aquin reads facial micro-expressions and posture in-browser - never uploaded - to know when a student stuck or drifted. The session adapts: a simpler example, a different format, a five-minute break, a one-on-one cue. Especially valuable for ADHD, autistic, and neurodivergent learners.</p>
        <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:8px;">
          {['On-device CV · zero bytes uploaded', 'Opt-in per course, revocable at any moment', 'Calibrated per learner over 3 sessions', 'Outputs cues to Aquin, never to faculty', 'Particularly designed for neurodivergent learners', 'Independently audited by a national engineering institute safety lab'].map((t) => (
            <li style="display:flex; align-items:start; gap:10px; font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink-500); line-height:1.55;">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#5b4a92" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg>
              <span>{t}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- HANDS-ON NETWORK -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:56px 28px;">
      <div style="margin-bottom:28px;">
        <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.22em; text-transform:uppercase; color:var(--rust); font-weight:700; margin:0 0 8px;">Hands-on network &middot; system 03 &middot; powered by national R&D equipment portal</p>
        <h2 class="font-display" style="font-size:clamp(1.85rem, 3.5vw, 2.85rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0 0 14px; color:var(--ink); max-width:44rem;">
          Real instruments. <em style="color:var(--rust); font-weight:400;">Real labs.</em> No campus required.
        </h2>
        <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.05rem, 1.4vw, 1.2rem); color:var(--ink); line-height:1.55; margin:0; max-width:44rem;">Integrated with <strong style="font-style:normal;">national R&D equipment portal</strong> (India's national R&amp;D equipment portal) and partner networks across 84 institutions. Book a scanning electron microscope at a national science institute. Operate a femtosecond laser at a national engineering institute remotely. Have a partner research lab run your sample and ship results back. Every undergraduate gets the hands-on hours of a graduate student.</p>
      </div>

      <div style="display:grid; grid-template-columns:1fr; gap:12px; margin-bottom:18px;" class="handson-grid">
        {handsOn.map((f) => (
          <article style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:18px; display:flex; flex-direction:column; gap:10px; cursor:pointer;">
            <div style="display:flex; align-items:center; justify-content:space-between;">
              <span style={'font-family:JetBrains Mono,monospace; font-size:9.5px; letter-spacing:0.16em; text-transform:uppercase; color:' + f.color + '; font-weight:700;'}>{f.inst}</span>
              <span style="display:inline-flex; align-items:center; gap:4px;">
                <span style="display:inline-block; width:5px; height:5px; border-radius:50%; background:#4a7048;"></span>
                <span style="font-family:'JetBrains Mono',monospace; font-size:9.5px; color:#4a7048; letter-spacing:0.08em; font-weight:600;">{f.avail}</span>
              </span>
            </div>
            <p class="font-display" style="font-size:1.1rem; font-weight:500; line-height:1.18; color:var(--ink); margin:0;">{f.eq}</p>
            <p style="font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--ink-500); margin:0;">{f.dist}</p>
            <div style="display:flex; gap:5px; margin-top:4px;">
              <button type="button" style={'padding:6px 12px; background:' + f.color + '; color:#fff; border:none; border-radius:6px; font-family:Inter Tight,sans-serif; font-size:11px; font-weight:600; cursor:pointer;'}>Book slot</button>
              <button type="button" style="padding:6px 12px; background:transparent; color:var(--ink-500); border:1px solid var(--rule); border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:11px; font-weight:600; cursor:pointer;">See SOP</button>
            </div>
          </article>
        ))}
