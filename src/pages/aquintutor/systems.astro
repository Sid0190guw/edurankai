      .partners-grid { grid-template-columns: repeat(4, 1fr) !important; }
      .fed-features { grid-template-columns: repeat(3, 1fr) !important; }
      .tracks-grid { grid-template-columns: repeat(4, 1fr) !important; }
      .coach-primitives { grid-template-columns: repeat(4, 1fr) !important; }
      .inst-grid { grid-template-columns: repeat(3, 1fr) !important; }
      .mooc-grid { grid-template-columns: repeat(3, 1fr) !important; }
      .market-grid { grid-template-columns: repeat(3, 1fr) !important; }
