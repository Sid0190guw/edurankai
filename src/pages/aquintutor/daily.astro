---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/daily'));
---
<AquintutorLayout title="Daily challenge" description="Today's 7 cross-catalog questions.">
  <section style="border-bottom:1px solid var(--rule); background:linear-gradient(180deg,#fff8f3 0%, var(--paper) 100%);">
    <div style="max-width:760px; margin:0 auto; padding:48px 28px;">
      <p style="font-family:'Inter Tight',monospace; font-size:12px; color:var(--rust); font-weight:700; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Today's challenge</p>
      <h1 class="font-display" style="font-size:clamp(2rem,4vw,3rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500; margin:0 0 8px;">7 questions. 1 perfect = bonus XP.</h1>
      <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); line-height:1.6;">A daily mix from every catalog. 5 XP per correct. 50 bonus XP if you ace all 7. Resets at midnight.</p>
    </div>
  </section>

  <section>
    <div style="max-width:760px; margin:0 auto; padding:36px 28px 80px;">
      <div id="root">
        <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500);">Loading today's set…</p>
      </div>
    </div>
  </section>

  <script is:inline>
  (function () {
    var root = document.getElementById('root');
    var state = { idx: 0, q: null, qs: [], correct: 0, attemptId: null, answer: undefined, answered: false };

    function esc(s) { return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) { return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]; }); }
    function html(s) { var t = document.createElement('template'); t.innerHTML = s.trim(); return t.content.firstChild; }

    fetch('/api/aquintutor/daily-challenge', { credentials: 'same-origin' })
      .then(function (r) { return r.json(); })
      .then(function (d) {
        if (!d.ok || !d.questions || !d.questions.length) {
          root.innerHTML = '<p style="font-family:Inter Tight,sans-serif; font-size:14px; color:var(--ink-500);">No challenge available today. Come back tomorrow.</p>';
          return;
        }
        state.qs = d.questions; state.attemptId = d.attemptId;
        if (d.alreadyCompleted) {
          root.innerHTML = '<div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:30px;"><p style="font-family:Inter Tight,monospace; font-size:11px; text-transform:uppercase; letter-spacing:0.14em; color:var(--rust); font-weight:700;">Done for today</p><p class="font-display" style="font-size:1.6rem; font-weight:500; margin:8px 0;">You already finished today\'s challenge.</p><p style="font-family:Inter Tight,sans-serif; font-size:14px; color:var(--ink-500); line-height:1.6;">Come back tomorrow for a new set. Meanwhile, take a <a href="/aquintutor/practice/sanskrit-awareness" style="color:var(--rust); font-weight:600;">practice round</a> to keep your streak alive.</p></div>';
          return;
        }
        render();
      });

    function render() {
      if (state.idx >= state.qs.length) return summary();
      var q = state.qs[state.idx]; state.q = q;
      state.answered = false; state.answer = undefined;
      var card = document.createElement('div');
      card.style.cssText = 'background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:28px 32px;';
      var hd = '<div style="display:flex; justify-content:space-between; font-family:Inter Tight,monospace; font-size:11px; color:var(--ink-500); margin-bottom:12px;">'
        + '<span>Question ' + (state.idx + 1) + ' of ' + state.qs.length + '</span>'
        + '<span>' + esc(q.category || q.test_title || '') + '</span></div>';
      hd += '<p class="font-display" style="font-size:clamp(18px,2.4vw,24px); font-weight:500; line-height:1.35; margin-bottom:18px;">' + esc(q.question_text) + '</p>';
      card.innerHTML = hd;

      if (q.question_type === 'mcq_single' || q.question_type === 'true_false') {
        (q.options || []).forEach(function (o, i) {
          var b = html('<button type="button" data-i="' + i + '" style="display:block; width:100%; padding:12px 16px; background:var(--paper); border:2px solid var(--rule); border-radius:10px; margin-bottom:8px; text-align:left; font-family:inherit; font-size:14.5px; cursor:pointer;">' + esc(o.text || o) + '</button>');
          b.addEventListener('click', function () { if (state.answered) return; card.querySelectorAll('button[data-i]').forEach(function(x){ x.style.borderColor='var(--rule)'; x.style.background='var(--paper)'; }); b.style.borderColor='var(--rust)'; b.style.background='rgba(217,119,87,0.08)'; state.answer = i; check.disabled = false; });
          card.appendChild(b);
        });
      } else if (q.question_type === 'fill_in_blank') {
        var ti = html('<input type="text" autocomplete="off" autocorrect="off" spellcheck="false" placeholder="Type your answer…" style="width:100%; padding:14px 16px; border:2px solid var(--rule); border-radius:10px; font-family:inherit; font-size:14.5px; outline:none;" />');
        ti.addEventListener('input', function (e) { state.answer = e.target.value; check.disabled = !e.target.value; });
        card.appendChild(ti);
        setTimeout(function () { ti.focus(); }, 50);
      } else if (q.question_type === 'numeric') {
        var ti = html('<input type="number" step="any" placeholder="Enter a number…" style="width:100%; padding:14px 16px; border:2px solid var(--rule); border-radius:10px; font-family:inherit; font-size:14.5px; outline:none;" />');
        ti.addEventListener('input', function (e) { state.answer = e.target.value; check.disabled = !e.target.value; });
        card.appendChild(ti);
        setTimeout(function () { ti.focus(); }, 50);
      }

      var check = html('<button type="button" style="margin-top:16px; padding:14px; width:100%; background:var(--ink); color:#fff; border:none; border-radius:12px; font-family:inherit; font-size:14px; font-weight:700; cursor:pointer;" disabled>Check</button>');
      check.addEventListener('click', function () { submit(card); });
      card.appendChild(check);

      root.innerHTML = ''; root.appendChild(card);
    }

    function submit(card) {
      if (state.answered) return next();
      state.answered = true;
      var btn = card.querySelector('button[style*="background:var(--ink)"]');
      if (btn) { btn.disabled = true; btn.textContent = 'Checking…'; }
      fetch('/api/aquintutor/practice/answer', { method:'POST', credentials:'same-origin', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ questionId: state.q.id, answer: state.answer })})
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (!d.ok) { if (btn) { btn.disabled = false; btn.textContent = 'Check'; } state.answered = false; return; }
          var fb = document.createElement('div');
          fb.style.cssText = 'padding:14px 18px; border-radius:10px; margin-top:14px; font-size:13.5px; line-height:1.55; ' + (d.correct ? 'background:rgba(16,185,129,0.12); color:#047857;' : 'background:rgba(239,68,68,0.10); color:#991b1b;');
          fb.innerHTML = '<b style="display:block; margin-bottom:4px;">' + (d.correct ? '✓ Correct' : '✗ Not quite') + '</b>' + (d.explanation ? esc(d.explanation) : '') + (!d.correct ? '<div style="margin-top:6px;"><b>Correct:</b> ' + esc(String(d.modelAnswer||'')) + '</div>' : '');
          card.insertBefore(fb, btn);
          if (d.correct) state.correct++;
          btn.disabled = false;
          btn.textContent = state.idx === state.qs.length - 1 ? 'Finish →' : 'Continue →';
        });
    }
    function next() { state.idx++; render(); }

    function summary() {
      // Tell server we're done so it awards the bonus.
      fetch('/api/aquintutor/daily-challenge', { method:'POST', credentials:'same-origin', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ attemptId: state.attemptId, correct: state.correct, attempted: state.qs.length })})
        .then(function (r) { return r.json(); })
        .then(function (d) {
          var perfectMsg = d.perfect ? '<p style="font-family:Fraunces,serif; font-size:24px; color:#10b981; margin-top:10px;">🎯 PERFECT! +50 bonus XP</p>' : '';
          root.innerHTML = '<div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:36px 32px; text-align:center;">'
            + '<p style="font-family:Inter Tight,monospace; font-size:11px; text-transform:uppercase; letter-spacing:0.14em; color:var(--rust); font-weight:700;">Today\'s challenge complete</p>'
            + '<p class="font-display" style="font-size:56px; font-weight:600; color:var(--rust); margin:14px 0 6px;">' + state.correct + '/' + state.qs.length + '</p>'
            + perfectMsg
            + '<p style="font-family:Inter Tight,sans-serif; font-size:14.5px; color:var(--ink-500); margin-top:14px;">+' + (d.xpAwarded || 0) + ' XP added to your account.</p>'
            + '<div style="display:flex; gap:10px; justify-content:center; margin-top:22px; flex-wrap:wrap;">'
            + '<a href="/aquintutor/dashboard" style="background:var(--ink); color:#fff; padding:12px 24px; border-radius:12px; font-family:inherit; font-size:13.5px; font-weight:700; text-decoration:none;">Dashboard</a>'
            + '<a href="/aquintutor/leaderboard" style="background:var(--paper); color:var(--ink); padding:12px 24px; border-radius:12px; border:1px solid var(--rule); font-family:inherit; font-size:13.5px; font-weight:700; text-decoration:none;">🏆 Leaderboard</a>'
            + '</div></div>';
        });
    }
  })();
  </script>
</AquintutorLayout>
