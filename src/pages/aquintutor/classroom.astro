---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

const attendees = [
  { name: 'Dr. M. Iyer', role: 'host', color: '#2b577e', speaking: true, mic: true },
  { name: 'You', role: 'you', color: '#a8472c', speaking: false, mic: false },
  { name: 'Priya N.', color: '#5b4a92', speaking: false, mic: true },
  { name: 'Wei H.', color: '#4a7048', speaking: false, mic: false },
  { name: 'Sara K.', color: '#a87526', speaking: false, mic: true },
  { name: 'Diego M.', color: '#3b5675', speaking: false, mic: false },
  { name: 'Nadia O.', color: '#8a486b', speaking: false, mic: true },
];

const chat = [
  { who: 'Priya N.', t: '00:38', text: 'Got it - so we mask before softmax to keep it normalized?', color: '#5b4a92' },
  { who: 'Dr. M. Iyer', t: '00:38', text: 'Exactly. After softmax the probabilities are already locked.', color: '#2b577e', host: true },
  { who: 'Wei H.', t: '00:39', text: 'Wait, what about cross-attention in encoder-decoder?', color: '#4a7048' },
  { who: 'Aquin', t: '00:39', text: 'Cross-attention typically does not need a causal mask - the encoder sees the full source sequence.', color: '#3d6b76', ai: true },
  { who: 'Sara K.', t: '00:40', text: 'question coming - hand raised', color: '#a87526' },
  { who: 'Diego M.', t: '00:41', text: '+1 for the lab demo with PyTorch', color: '#3b5675' },
];

const qa = [
  { who: 'Sara K.', t: '00:40', text: 'Can you re-derive the softmax stability trick before moving on?', upvotes: 12, answered: false },
  { who: 'Wei H.', t: '00:35', text: 'Why do we divide attention scores by sqrt(d_k) specifically?', upvotes: 8, answered: true },
  { who: 'Priya N.', t: '00:28', text: 'How does Flash Attention change the mask interpretation?', upvotes: 5, answered: false },
];

const pollOptions = [
  { l: 'A', t: 'O(n)', pct: 7, mine: false },
  { l: 'B', t: 'O(n log n)', pct: 12, mine: false },
  { l: 'C', t: 'O(n²)', pct: 68, mine: true },
  { l: 'D', t: 'O(n² · d)', pct: 13, mine: false },
];

const resources = [
  ['Attention is All You Need · Vaswani 2017', 'PDF · 11 pages'],
  ['Slides · Lecture 6.2', 'PDF · 32 slides'],
  ['Lab notebook · masked attention', 'Jupyter'],
  ['Solution · PS3 problem 4', 'PDF · 3 pages'],
  ['Recording · Lecture 5.1', 'Video · 1h 12m'],
];

const tools = [
  { id: 'cursor', glyph: 'M3 3l7 18 3-8 8-3z' },
  { id: 'pen', glyph: 'M12 19l7-7-3-3-7 7v3z M16 12l-3-3', active: true },
  { id: 'rect', glyph: 'M4 4h16v16H4z' },
  { id: 'text', glyph: 'M4 6h16M12 6v14' },
  { id: 'laser', glyph: 'M12 2v6M12 16v6M4 12h6M14 12h6' },
  { id: 'erase', glyph: 'M18 4l4 4-10 10H6l-2-2 12-12z' },
];
---
<AquintutorLayout title="Live classroom" description="Synchronous live classroom - Transformers in Practice · AI-512 · Dr. M. Iyer">

  <!-- BREADCRUMB -->
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1400px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a>
      <span style="margin:0 8px;">/</span>
      <a href="/aquintutor/dashboard" style="color:var(--ink-500); text-decoration:none;">DASHBOARD</a>
      <span style="margin:0 8px;">/</span>
      <span style="color:#a04330; font-weight:600;">LIVE CLASSROOM · AI-512</span>
    </div>
  </div>

  <!-- LIVE HEADER -->
  <section style="background:var(--paper); border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:14px 28px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:14px;">
      <div style="display:flex; align-items:center; gap:14px; flex-wrap:wrap;">
        <div style="display:inline-flex; align-items:center; gap:8px; padding:5px 12px; background:rgba(224,122,108,0.15); border:1px solid rgba(224,122,108,0.4); border-radius:6px;">
          <span style="display:inline-block; width:7px; height:7px; border-radius:50%; background:#a04330; box-shadow:0 0 6px #a04330; animation:pulse 1.4s infinite;"></span>
          <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.16em; color:#a04330; font-weight:600;">LIVE · 00:42:18</span>
        </div>
        <span class="font-display" style="font-size:1.15rem; font-weight:500; color:var(--ink); letter-spacing:-0.015em;">Transformers in Practice &middot; Lecture 6.2</span>
        <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500); letter-spacing:0.08em;">AI-512 &middot; Dr. M. Iyer</span>
      </div>
      <div style="display:flex; align-items:center; gap:10px;">
        <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500);">117 attending</span>
        <span style="display:inline-flex; align-items:center; gap:5px; padding:3px 9px; background:rgba(125,211,168,0.10); border:1px solid #7dd3a8; border-radius:999px; font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.12em; text-transform:uppercase; color:#3f8a64; font-weight:600;"><span style="display:inline-block; width:5px; height:5px; border-radius:50%; background:#7dd3a8;"></span>NETWORK &middot; STABLE</span>
        <button type="button" style="background:transparent; color:var(--ink); padding:7px 14px; border:1px solid var(--rule); border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:12px; font-weight:600; cursor:pointer;">Captions</button>
        <button type="button" style="background:#a04330; color:#fff; padding:7px 14px; border:none; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:12px; font-weight:600; cursor:pointer;">Leave</button>
      </div>
    </div>
  </section>

  <!-- MAIN CLASSROOM GRID -->
  <section style="background:var(--sand-100); border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:20px 28px; display:grid; grid-template-columns:1fr; gap:18px;" class="cr-grid">

      <!-- LEFT: Stage + control bar -->
      <div style="display:flex; flex-direction:column; gap:14px; min-height:0;">

        <!-- STAGE -->
        <div style="background:#0a0d11; border:1px solid #1a1f28; border-radius:14px; overflow:hidden; display:grid; grid-template-columns:1fr; min-height:480px; position:relative;" class="stage-grid">

          <!-- Whiteboard area -->
          <div style="position:relative; display:flex; align-items:center; justify-content:center; min-height:480px;">

            <!-- Annotation toolbar (left rail) -->
            <div style="position:absolute; left:14px; top:50%; transform:translateY(-50%); display:flex; flex-direction:column; gap:4px; padding:6px; background:rgba(0,0,0,0.5); border:1px solid rgba(255,255,255,0.1); border-radius:8px; z-index:2;">
              {tools.map((tool) => (
                <button type="button" style={'width:32px; height:32px; background:' + (tool.active ? 'rgba(217,119,87,0.18)' : 'transparent') + '; border:1px solid ' + (tool.active ? '#d97757' : 'transparent') + '; border-radius:4px; cursor:pointer; color:' + (tool.active ? '#d97757' : 'rgba(244,241,234,0.6)') + '; display:inline-flex; align-items:center; justify-content:center;'}>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d={tool.glyph}/></svg>
                </button>
              ))}
            </div>

            <!-- Hand queue (top-right) -->
            <div style="position:absolute; top:14px; right:14px; display:inline-flex; align-items:center; gap:6px; padding:5px 11px; background:rgba(240,181,79,0.14); border:1px solid rgba(240,181,79,0.45); border-radius:999px; z-index:2;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#f0b54f" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11V5a1.5 1.5 0 013 0v6M12 11V3a1.5 1.5 0 013 0v8M15 11V5a1.5 1.5 0 013 0v9c0 3.5-2.5 7-7 7s-7-3-7-7v-3a1.5 1.5 0 013 0v3"/></svg>
              <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:#f0b54f; font-weight:600;">3 in queue</span>
            </div>

            <!-- Slide -->
            <div style="width:88%; height:88%; min-height:380px; background:#0f1216; border:1px solid #1c2230; border-radius:8px; padding:30px; position:relative;">
              <p style="font-family:'JetBrains Mono',monospace; font-size:9.5px; letter-spacing:0.16em; text-transform:uppercase; color:rgba(244,241,234,0.55); margin:0;">LECTURE 6.2 &middot; SLIDE 14</p>
              <h3 class="font-display" style="font-size:clamp(1.3rem, 2.5vw, 1.85rem); font-weight:500; line-height:1.15; letter-spacing:-0.015em; color:#f4f1ea; margin:8px 0 18px;">Why masked attention is causal</h3>

              <div style="display:grid; grid-template-columns:1fr; gap:24px; align-items:center;" class="slide-body">
                <p style="font-family:'Cormorant Garamond',serif; font-size:15px; line-height:1.65; color:rgba(244,241,234,0.85); margin:0;">
                  The lower-triangular mask <code style="font-family:'JetBrains Mono',monospace; font-size:12px; background:rgba(255,255,255,0.06); padding:2px 6px; border-radius:3px; color:#7fb3ff;">M &isin; {`{0,1}^{n×n}`}</code> ensures that token <em style="color:#f4f1ea;">i</em> attends only to positions &le; <em style="color:#f4f1ea;">i</em>. We zero out future logits <em>before</em> softmax &mdash; not after.
                </p>

                <svg viewBox="0 0 240 240" preserveAspectRatio="xMidYMid meet" style="width:100%; max-height:220px; display:block;">
                  {Array.from({length: 8}).map((_, i) => (
                    Array.from({length: 8}).map((_, j) => (
                      <rect x={j * 28 + 8} y={i * 28 + 8} width="24" height="24"
                        fill={j <= i ? 'rgba(127,179,255,0.6)' : 'rgba(255,255,255,0.04)'}
                        stroke="rgba(255,255,255,0.12)" stroke-width="0.5"/>
                    ))
                  ))}
                  <text x="120" y="234" text-anchor="middle" font-family="JetBrains Mono" font-size="9" letter-spacing="0.12em" fill="rgba(244,241,234,0.55)">CAUSAL MASK · n=8</text>
                </svg>
              </div>

              <!-- Faculty annotation -->
              <svg style="position:absolute; inset:0; pointer-events:none; width:100%; height:100%;" viewBox="0 0 600 400" preserveAspectRatio="none">
                <path d="M 480 220 Q 540 200 580 240 Q 600 260 580 280" stroke="#d97757" stroke-width="2.2" fill="none" stroke-linecap="round" opacity="0.8"/>
                <circle cx="580" cy="240" r="2.5" fill="#d97757" opacity="0.8"/>
              </svg>
            </div>

            <!-- Slide nav (bottom centre) -->
            <div style="position:absolute; bottom:14px; left:50%; transform:translateX(-50%); display:flex; align-items:center; gap:10px; padding:6px 14px; background:rgba(0,0,0,0.7); border:1px solid rgba(255,255,255,0.12); border-radius:999px; z-index:2;">
              <button type="button" style="background:transparent; border:none; color:rgba(244,241,234,0.7); cursor:pointer; font-size:14px;">&lsaquo;</button>
              <span style="font-family:'JetBrains Mono',monospace; font-size:11px; color:rgba(244,241,234,0.85); letter-spacing:0.08em;">14 / 32</span>
              <button type="button" style="background:transparent; border:none; color:rgba(244,241,234,0.7); cursor:pointer; font-size:14px;">&rsaquo;</button>
            </div>
          </div>

          <!-- Video tile rail (right of stage) -->
          <aside style="border-left:1px solid #1a1f28; padding:10px; display:grid; grid-template-columns:repeat(2, 1fr); gap:8px; overflow-y:auto; background:rgba(0,0,0,0.25); align-content:start;" class="tiles">
            {attendees.map((a) => (
              <div style={'position:relative; aspect-ratio:4/3; background:linear-gradient(180deg, ' + a.color + '30, ' + a.color + '10); border:1px solid ' + (a.speaking ? a.color : '#1c2230') + '; border-radius:6px; overflow:hidden; ' + (a.speaking ? 'box-shadow:0 0 0 1.5px ' + a.color + ', 0 0 12px ' + a.color + '99;' : '')}>
                <svg viewBox="0 0 200 150" preserveAspectRatio="xMidYMid slice" style="width:100%; height:100%;">
                  <ellipse cx="100" cy="65" rx="28" ry="34" fill={a.color + '40'}/>
                  <path d="M 50 150 Q 50 100 80 92 L 120 92 Q 150 100 150 150 Z" fill={a.color + '30'}/>
                </svg>
                <div style="position:absolute; bottom:4px; left:5px; display:flex; align-items:center; gap:4px;">
                  <span style="font-family:'Inter Tight',sans-serif; font-size:10px; color:#fff; font-weight:500; text-shadow:0 1px 2px rgba(0,0,0,0.8);">{a.name}</span>
                  {a.role === 'host' && <span style={'padding:0 4px; background:rgba(0,0,0,0.7); border:1px solid ' + a.color + '; border-radius:3px; font-family:JetBrains Mono,monospace; font-size:8px; color:' + a.color + '; letter-spacing:0.1em;'}>HOST</span>}
                </div>
                {!a.mic && (
                  <div style="position:absolute; top:4px; right:4px; width:18px; height:18px; background:rgba(0,0,0,0.7); border-radius:50%; display:flex; align-items:center; justify-content:center; color:#e07a6c;">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 3l18 18M9 9v2a3 3 0 005 2"/></svg>
                  </div>
                )}
              </div>
            ))}
            <div style="grid-column:1/-1; padding:8px; text-align:center; font-family:'JetBrains Mono',monospace; font-size:10px; color:rgba(244,241,234,0.55); border:1px dashed rgba(255,255,255,0.15); border-radius:6px; letter-spacing:0.08em;">+ 110 ATTENDEES</div>
          </aside>
        </div>

        <!-- CONTROL BAR -->
        <div style="display:flex; align-items:center; justify-content:center; gap:8px; padding:10px 14px; background:var(--paper); border:1px solid var(--rule); border-radius:12px; flex-wrap:wrap;">
          {[
            { l: 'Mic', glyph: 'M9 3a3 3 0 016 0v8a3 3 0 01-6 0zM5 11a7 7 0 0014 0M12 19v3', on: true, off: false },
            { l: 'Cam', glyph: 'M3 6h14v12H3zM17 10l4-2v8l-4-2', on: false, off: true },
            { l: 'Raise', glyph: 'M9 11V5a1.5 1.5 0 013 0v6M12 11V3a1.5 1.5 0 013 0v8M15 11V5a1.5 1.5 0 013 0v9c0 3.5-2.5 7-7 7s-7-3-7-7v-3a1.5 1.5 0 013 0v3', on: false, off: false },
            { l: 'Share', glyph: 'M3 3h18v13H3zM8 21h8M12 16v5', on: false, off: false },
            { l: 'Poll', glyph: 'M3 21h18M6 18V10M12 18V4M18 18v-6', on: false, off: false },
            { l: 'Aquin', glyph: 'M21 12c0 4.97-4.03 9-9 9-1.5 0-2.91-.36-4.15-1l-4.85 1 1-4.85A8.96 8.96 0 013 12c0-4.97 4.03-9 9-9s9 4.03 9 9z', accent: true },
            { l: 'Notes', glyph: 'M4 4h12l4 4v12H4zM14 4v6h6', on: false, off: false },
          ].map((c) => {
            const color = c.accent ? '#3d6b76' : c.on ? '#4a7048' : c.off ? '#a04330' : 'var(--ink-500)';
            const bg = (c.on || c.accent) ? color + '15' : 'transparent';
            const border = (c.on || c.accent) ? color : 'var(--rule)';
            return (
              <button type="button" style={'display:flex; flex-direction:column; align-items:center; gap:4px; padding:7px 14px; background:' + bg + '; border:1px solid ' + border + '; border-radius:8px; cursor:pointer; color:' + color + ';'}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d={c.glyph}/></svg>
                <span style="font-family:'JetBrains Mono',monospace; font-size:9px; letter-spacing:0.1em; text-transform:uppercase; font-weight:600;">{c.l}</span>
              </button>
            );
          })}
        </div>
      </div>

      <!-- RIGHT: Sidebar tabs -->
      <aside style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; display:flex; flex-direction:column; min-height:580px; overflow:hidden;">
        <!-- Tab bar -->
        <div style="display:flex; border-bottom:1px solid var(--rule);">
          {[
            { id: 'chat', label: 'Chat', count: 28, active: true },
            { id: 'qa',   label: 'Q&A', count: 6 },
            { id: 'poll', label: 'Polls', count: 2 },
            { id: 'res',  label: 'Resources' },
          ].map((t) => (
            <button type="button" data-tab={t.id} class="cr-tab" style={'flex:1; padding:12px 4px; background:' + (t.active ? 'var(--sand-100)' : 'transparent') + '; border:none; border-bottom:2px solid ' + (t.active ? 'var(--rust)' : 'transparent') + '; color:' + (t.active ? 'var(--ink)' : 'var(--ink-500)') + '; font-family:Inter Tight,sans-serif; font-size:12.5px; font-weight:600; cursor:pointer;'}>
              {t.label}{t.count != null && <span style="font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--ink-500); margin-left:4px;">{t.count}</span>}
            </button>
          ))}
        </div>

        <!-- CHAT PANEL -->
        <div id="pane-chat" class="cr-pane" style="flex:1; display:flex; flex-direction:column; min-height:0;">
          <div style="flex:1; overflow-y:auto; padding:14px; display:flex; flex-direction:column; gap:10px;">
            {chat.map((m) => (
              <div style="display:flex; flex-direction:column; gap:3px;">
                <div style="display:flex; align-items:baseline; gap:6px;">
                  <span style={'font-family:Inter Tight,sans-serif; font-size:12px; font-weight:600; color:' + m.color + ';'}>{m.who}</span>
                  {m.host && <span style={'padding:0 5px; background:rgba(43,87,126,0.12); border:1px solid rgba(43,87,126,0.35); border-radius:3px; font-family:JetBrains Mono,monospace; font-size:8px; color:#2b577e; letter-spacing:0.12em; font-weight:600;'}>HOST</span>}
                  {m.ai && <span style="padding:0 5px; background:rgba(61,107,118,0.12); border:1px solid rgba(61,107,118,0.35); border-radius:3px; font-family:'JetBrains Mono',monospace; font-size:8px; color:#3d6b76; letter-spacing:0.12em; font-weight:600;">AI</span>}
                  <span style="font-family:'JetBrains Mono',monospace; font-size:9px; color:var(--ink-500); margin-left:auto;">{m.t}</span>
                </div>
                <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink); line-height:1.45; margin:0;">{m.text}</p>
              </div>
            ))}
          </div>
          <div style="padding:10px; border-top:1px solid var(--rule); display:flex; flex-direction:column; gap:8px; background:var(--sand-100);">
            <div style="display:flex; align-items:center; gap:6px; padding:8px 12px; background:var(--paper); border:1px solid var(--rule); border-radius:8px;">
              <input placeholder="Message everyone..." style="flex:1; background:transparent; border:none; outline:none; color:var(--ink); font-family:'Inter Tight',sans-serif; font-size:13px;" />
              <button type="button" style="background:var(--rust); border:none; border-radius:6px; width:30px; height:26px; display:flex; align-items:center; justify-content:center; cursor:pointer; color:#fff;"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l18-8-8 18-2-8-8-2z"/></svg></button>
            </div>
            <div style="display:flex; gap:6px; flex-wrap:wrap;">
              {[{l:'Ask Aquin', c:'#3d6b76'},{l:'Everyone', c:'var(--ink-500)'},{l:'Host only', c:'var(--ink-500)'}].map((c) => (
                <span style={'display:inline-flex; align-items:center; padding:4px 10px; background:' + (c.c.startsWith('#') ? c.c + '14' : 'var(--sand-100)') + '; border:1px solid ' + (c.c.startsWith('#') ? c.c + '40' : 'var(--rule)') + '; border-radius:999px; font-family:JetBrains Mono,monospace; font-size:10px; letter-spacing:0.08em; color:' + c.c + ';'}>{c.l}</span>
              ))}
            </div>
          </div>
        </div>

        <!-- Q&A PANEL -->
        <div id="pane-qa" class="cr-pane" style="display:none; flex:1; overflow-y:auto; padding:14px; display:flex; flex-direction:column; gap:10px;">
          {qa.map((q) => (
            <div style={'padding:12px; background:' + (q.answered ? 'rgba(125,211,168,0.06)' : 'var(--sand-100)') + '; border:1px solid ' + (q.answered ? '#7dd3a8' : 'var(--rule)') + '; border-radius:8px;'}>
              <div style="display:flex; align-items:center; gap:6px; margin-bottom:5px;">
                <span style="font-family:'Inter Tight',sans-serif; font-size:11.5px; font-weight:600; color:var(--ink);">{q.who}</span>
                <span style="font-family:'JetBrains Mono',monospace; font-size:9px; color:var(--ink-500);">{q.t}</span>
                {q.answered && <span style="display:inline-flex; align-items:center; padding:2px 8px; background:rgba(125,211,168,0.14); border:1px solid #7dd3a8; border-radius:999px; font-family:'JetBrains Mono',monospace; font-size:9px; color:#3f8a64; letter-spacing:0.1em; text-transform:uppercase; font-weight:600;">answered</span>}
              </div>
              <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink); line-height:1.45; margin:0;">{q.text}</p>
              <div style="display:flex; align-items:center; gap:4px; margin-top:6px; font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--ink-500);">&#x25b2; {q.upvotes}</div>
            </div>
          ))}
        </div>

        <!-- POLLS PANEL -->
        <div id="pane-poll" class="cr-pane" style="display:none; flex:1; overflow-y:auto; padding:14px;">
          <div style="background:var(--sand-100); border:1px solid var(--rule); border-radius:10px; padding:18px;">
            <p style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.18em; text-transform:uppercase; color:var(--rust); font-weight:600; margin:0;">ACTIVE POLL &middot; LIVE</p>
            <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink); font-weight:500; margin:10px 0 14px;">What's the time complexity of masked attention as written?</p>
            {pollOptions.map((o) => (
              <div style="margin-bottom:10px;">
                <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:4px;">
                  <span style={'font-family:JetBrains Mono,monospace; font-size:11.5px; color:' + (o.mine ? 'var(--rust)' : 'var(--ink-500)') + ';'}><strong>{o.l}</strong> &middot; {o.t}{o.mine && <span style="margin-left:6px; color:var(--rust);">&larr; you</span>}</span>
                  <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500);">{o.pct}%</span>
                </div>
                <div style="height:5px; background:var(--rule); border-radius:999px; overflow:hidden;">
                  <div style={'width:' + o.pct + '%; height:100%; background:' + (o.mine ? 'var(--rust)' : 'var(--ink-300, #9C9A85)') + ';'}></div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- RESOURCES PANEL -->
        <div id="pane-res" class="cr-pane" style="display:none; flex:1; overflow-y:auto; padding:14px; display:flex; flex-direction:column; gap:8px;">
          {resources.map(([t, m]) => (
            <div style="padding:11px 14px; background:var(--sand-100); border:1px solid var(--rule); border-radius:8px; display:flex; align-items:center; gap:10px; cursor:pointer;">
              <span style="display:inline-block; width:7px; height:7px; border-radius:50%; background:#2b577e; flex-shrink:0;"></span>
              <div style="flex:1; min-width:0;">
                <p style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; margin:0;">{t}</p>
                <p style="font-family:'JetBrains Mono',monospace; font-size:9.5px; color:var(--ink-500); letter-spacing:0.06em; margin:2px 0 0;">{m}</p>
              </div>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--ink-500)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12M7 10l5 5 5-5M5 21h14"/></svg>
            </div>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <!-- ANCILLARY: today's schedule + faculty hours -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:48px 28px;">
      <div style="display:grid; grid-template-columns:1fr; gap:24px;" class="bottom-grid">
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">Today &middot; your schedule</p>
          <h2 class="font-display" style="font-size:clamp(1.4rem, 2.4vw, 1.85rem); font-weight:500; line-height:1.15; letter-spacing:-0.015em; margin:0 0 18px; color:var(--ink);">Remaining sessions.</h2>
          <ol style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:8px;">
            {[
              { time: '11:00', title: 'Transformers in Practice', sub: 'AI-512 · Dr. M. Iyer', now: true },
              { time: '14:00', title: 'Quantum Foundations', sub: 'QT-407 · Prof. Penrose-Hayes' },
              { time: '16:30', title: 'Ancient Indic Texts I', sub: 'VS-101 · Dr. Anjali Krishnan' },
              { time: '18:00', title: 'Office hours · Dr. Iyer', sub: 'Open · drop-in' },
            ].map((s) => (
              <li style={'display:grid; grid-template-columns:64px 1fr auto; gap:14px; align-items:center; padding:14px 18px; background:var(--paper); border:1px solid ' + (s.now ? 'var(--rust)' : 'var(--rule)') + '; border-radius:10px; ' + (s.now ? 'box-shadow:0 0 0 1px var(--rust);' : '')}>
                <span style={'font-family:JetBrains Mono,monospace; font-size:13px; font-weight:600; letter-spacing:0.04em; color:' + (s.now ? 'var(--rust)' : 'var(--ink)') + ';'}>{s.time}</span>
                <div>
                  <p style="font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; margin:0; color:var(--ink); line-height:1.3;">{s.title}</p>
                  <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500); margin:3px 0 0; letter-spacing:0.06em;">{s.sub}</p>
                </div>
                {s.now ? <span style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:var(--rust); font-weight:600;">LIVE NOW</span> : <span style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-500);">UPCOMING</span>}
              </li>
            ))}
          </ol>
        </div>

        <aside style="background:var(--sand-100); border:1px solid var(--rule); border-radius:14px; padding:24px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">Faculty office hours</p>
          <h3 class="font-display" style="font-size:1.2rem; font-weight:500; margin:0 0 16px; line-height:1.2; letter-spacing:-0.015em;">Open right now.</h3>
          <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:10px;">
            {[
              { name: 'Dr. Lila Vyas', topic: 'Distributed systems · CS-211', open: true },
              { name: 'Dr. M. Iyer', topic: 'After this lecture · AI-512', open: true },
              { name: 'Prof. Raghav Iyer', topic: 'Real analysis · MA-301', open: false },
            ].map((f) => (
              <li style="display:flex; align-items:start; gap:12px;">
                <span style="display:inline-flex; align-items:center; justify-content:center; width:34px; height:34px; min-width:34px; border-radius:50%; background:var(--ink); color:var(--sand-50); font-family:'Fraunces',serif; font-weight:500; font-size:13px;">{f.name.split(' ').slice(-1)[0][0]}</span>
                <div style="flex:1; min-width:0;">
                  <div style="display:flex; align-items:center; gap:6px;">
                    <p style="font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; margin:0; color:var(--ink); line-height:1.25;">{f.name}</p>
                    {f.open && <span style="display:inline-block; width:6px; height:6px; border-radius:50%; background:#7dd3a8; box-shadow:0 0 5px #7dd3a8;"></span>}
                  </div>
                  <p style="font-family:'Inter Tight',sans-serif; font-size:11.5px; color:var(--ink-500); margin:2px 0 0; line-height:1.4;">{f.topic}</p>
                </div>
                {f.open ? <a href="#" style="font-family:'JetBrains Mono',monospace; font-size:9.5px; letter-spacing:0.14em; text-transform:uppercase; color:var(--rust); font-weight:600; text-decoration:none; align-self:center;">JOIN &rarr;</a> : <span style="font-family:'JetBrains Mono',monospace; font-size:9.5px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-500); font-weight:600; align-self:center;">CLOSED</span>}
              </li>
            ))}
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <style>
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.45; } }
    @media (min-width: 900px) {
      .cr-grid { grid-template-columns: minmax(0, 1fr) 340px !important; }
      .stage-grid { grid-template-columns: 1fr 200px !important; }
      .tiles { grid-template-columns: 1fr !important; }
      .slide-body { grid-template-columns: 1fr 1fr !important; }
      .bottom-grid { grid-template-columns: 1.6fr 1fr !important; }
    }
  </style>

  <script is:inline>
    (function() {
      var tabs = document.querySelectorAll('.cr-tab');
      var panes = document.querySelectorAll('.cr-pane');
      tabs.forEach(function(t) {
        t.addEventListener('click', function() {
          var id = t.getAttribute('data-tab');
          tabs.forEach(function(x) {
            var active = x.getAttribute('data-tab') === id;
            x.style.background = active ? 'var(--sand-100)' : 'transparent';
            x.style.borderBottom = '2px solid ' + (active ? 'var(--rust)' : 'transparent');
            x.style.color = active ? 'var(--ink)' : 'var(--ink-500)';
          });
          panes.forEach(function(p) {
            p.style.display = p.id === ('pane-' + id) ? 'flex' : 'none';
          });
        });
      });
    })();
  </script>
</AquintutorLayout>
