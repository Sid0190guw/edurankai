---
// /aquintutor/search — Search & Discovery (Prompt 12, main surface). Server-rendered results over
// the published-kernel index; respects the viewer's access (exam-secure never surfaces). Filters by
// school / level / language. A GET form — zero client JS.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { can } from '@/lib/rbac';
import { search, logQuery, facetValues } from '@/lib/search-index';

const user = Astro.locals.user;
const url = Astro.url;
const q = (url.searchParams.get('q') || '').trim();
const filters = { school: url.searchParams.get('school') || '', level: url.searchParams.get('level') || '', language: url.searchParams.get('language') || '' };
const canEnrolled = user ? (await can(user, 'read', { type: 'KnowledgeObject', securityLabels: ['enrolled-only'] })).allow : false;
const results = await search(q, filters, { canEnrolled }, 40).catch(() => []);
if (q) await logQuery(q, user?.id ?? null, results.length).catch(() => {});
const facets = await facetValues().catch(() => ({ schools: [], levels: [], languages: [] }));

const IN = 'font-family:Inter Tight,sans-serif;font-size:14px;padding:9px 11px;border:1px solid var(--line,#e6e1d6);border-radius:9px;';
function href(d: any) { return d.type === 'CourseObject' ? '/aquintutor/lesson-index/' + d.id : d.type === 'KnowledgeObject' ? '/aquintutor/lesson/' + d.id : '#'; }
function typeLabel(t: string) { return t === 'CourseObject' ? 'Course' : t === 'KnowledgeObject' ? 'Lesson' : 'Concept'; }
---
<AquintutorLayout title={q ? 'Search: ' + q : 'Discover'}>
  <main style="max-width:820px;margin:0 auto;padding:44px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Discover</p>
    <h1 style="font-family:Fraunces,serif;font-size:32px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 18px;line-height:1.15;">Search the catalogue</h1>

    <form method="GET" style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:8px;">
      <input name="q" value={q} placeholder="Search courses, lessons, concepts…" style={IN + 'flex:1;min-width:220px;'} />
      <select name="school" style={IN}><option value="">All schools</option>{facets.schools.map((s) => <option value={s} selected={filters.school === s}>{s}</option>)}</select>
      <select name="level" style={IN}><option value="">Any level</option>{facets.levels.map((l) => <option value={l} selected={filters.level === l}>{l}</option>)}</select>
      <select name="language" style={IN}><option value="">Any language</option>{facets.languages.map((l) => <option value={l} selected={filters.language === l}>{l}</option>)}</select>
      <button type="submit" style="background:var(--ink,#1a1712);color:var(--sand-50,#fbfaf4);border:none;border-radius:9px;padding:9px 20px;font-family:'Inter Tight',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">Search</button>
    </form>

    <p style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#8a8478;margin:0 0 20px;">{q ? results.length + ' result' + (results.length === 1 ? '' : 's') + ' for "' + q + '"' : 'Browse published courses and lessons, or search above.'}</p>

    {results.length === 0 ? (
      <p style="font-family:'Inter Tight',sans-serif;font-size:15px;color:#6b6455;">Nothing found. Try a different term{filters.school || filters.level || filters.language ? ' or clear the filters' : ''}.</p>
    ) : (
      <div style="display:flex;flex-direction:column;gap:10px;">{results.map((d: any) => (
        <a href={href(d)} style="text-decoration:none;background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:12px;padding:14px 18px;">
          <span style="font-family:'Geist Mono',monospace;font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:var(--rust,#b3541e);">{typeLabel(d.type)}{d.school ? ' · ' + d.school : ''}{d.level ? ' · ' + d.level : ''}</span>
          <h2 style="font-family:Fraunces,serif;font-size:18px;font-weight:600;color:var(--ink,#1a1712);margin:5px 0 3px;line-height:1.25;">{d.title}</h2>
          {d.body ? <p style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:#6b6455;margin:0;line-height:1.5;">{String(d.body).slice(0, 160)}{String(d.body).length > 160 ? '…' : ''}</p> : null}
        </a>
      ))}</div>
    )}
  </main>
</AquintutorLayout>
