---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

let testCount = 0, courseCount = 0, lessonCount = 0, certCount = 0, enrolledCount = 0, deptCount = 0, facultyCount = 0, examAttempts = 0;
let tests: any[] = [];
let featuredCourses: any[] = [];
let schools: any[] = [];
let faculty: any[] = [];
let recentCert: any = null;
let recentAttempt: any = null;
let liveAttempts = 0;

try {
  const r = await db.execute(sql`
    SELECT t.id, t.slug, t.title, t.description, t.test_type, t.duration_mins,
      (SELECT COUNT(*)::int FROM test_questions WHERE test_id = t.id) as question_count,
      (SELECT COUNT(*)::int FROM test_attempts WHERE test_id = t.id AND status IN ('submitted','auto_submitted')) as attempt_count
    FROM tests t WHERE t.is_published = true
    ORDER BY t.created_at DESC LIMIT 4
  `);
  tests = Array.isArray(r) ? r : (r?.rows || []);
  testCount = tests.length;
  examAttempts = tests.reduce((s: any, t: any) => s + (t.attempt_count || 0), 0);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT c.slug, c.title, c.subtitle, c.short_desc, c.level, c.category, c.course_code,
      c.duration_hours, c.duration_weeks, c.credit_hours, c.is_free, c.pricing_model,
      s.name as school_name, s.code as school_code,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as lesson_count
    FROM training_courses c
    LEFT JOIN schools s ON c.school_id = s.id
    WHERE c.is_published = true AND c.access_type IN ('public', 'both')
    ORDER BY c.enrolled_count DESC NULLS LAST, c.created_at DESC LIMIT 6
  `);
  featuredCourses = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM training_courses WHERE is_published = true AND access_type IN ('public', 'both')`);
  courseCount = ((Array.isArray(r) ? r : (r?.rows || []))[0] as any)?.n || 0;
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM training_lessons l JOIN training_courses c ON l.course_id = c.id WHERE c.is_published = true`);
  lessonCount = ((Array.isArray(r) ? r : (r?.rows || []))[0] as any)?.n || 0;
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM training_certificates`);
  certCount = ((Array.isArray(r) ? r : (r?.rows || []))[0] as any)?.n || 0;
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT COUNT(DISTINCT user_id)::int as n FROM training_enrollments`);
  enrolledCount = ((Array.isArray(r) ? r : (r?.rows || []))[0] as any)?.n || 0;
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM academic_departments`);
  deptCount = ((Array.isArray(r) ? r : (r?.rows || []))[0] as any)?.n || 0;
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM training_instructors`);
  facultyCount = ((Array.isArray(r) ? r : (r?.rows || []))[0] as any)?.n || 0;
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM test_attempts WHERE status = 'in_progress' AND started_at > NOW() - INTERVAL '4 hours'`);
  liveAttempts = ((Array.isArray(r) ? r : (r?.rows || []))[0] as any)?.n || 0;
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT s.id, s.slug, s.code, s.name, s.tagline,
      (SELECT COUNT(*)::int FROM academic_departments WHERE school_id = s.id) as dept_count,
      (SELECT COUNT(*)::int FROM training_courses WHERE school_id = s.id AND is_published = true) as course_count,
      (SELECT array_agg(DISTINCT name ORDER BY name) FROM (
        SELECT name FROM academic_departments WHERE school_id = s.id ORDER BY display_order LIMIT 4
      ) sub) as dept_names
    FROM schools s WHERE s.is_published = true ORDER BY s.display_order ASC
  `);
  schools = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT name, title, bio, specialties, slug FROM training_instructors
    WHERE is_featured = true ORDER BY sort_order LIMIT 4
  `);
  faculty = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT c.certificate_number, c.issued_at, u.name as user_name, t.title as course_title
    FROM training_certificates c
    JOIN users u ON c.user_id = u.id
    JOIN training_courses t ON c.course_id = t.id
    ORDER BY c.issued_at DESC LIMIT 1
  `);
  recentCert = ((Array.isArray(r) ? r : (r?.rows || []))[0]) || null;
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT t.title, a.submitted_at, a.percentage
    FROM test_attempts a JOIN tests t ON a.test_id = t.id
    WHERE a.status IN ('submitted','auto_submitted')
    ORDER BY a.submitted_at DESC NULLS LAST LIMIT 1
  `);
  recentAttempt = ((Array.isArray(r) ? r : (r?.rows || []))[0]) || null;
} catch (_) {}

const pageDesc = 'AquinTutor is a frontier research institution by EduRank-AI. Vedic sciences, advanced computing, ASI and quantum technology. ' + courseCount + '+ active programmes, proctored examinations, verifiable credentials. By application.';
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: 'AquinTutor',
  url: 'https://www.edurankai.in/aquintutor',
  description: pageDesc,
  parentOrganization: { '@type': 'Organization', name: 'EduRankAI', url: 'https://www.edurankai.in' },
  foundingDate: '2026',
  foundingLocation: { '@type': 'Place', name: 'Bharat (India)' },
};

// SVG glyph per school - 6 distinct marks
const schoolIcon: any = {
  scr: '<path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="1.5" fill="none"/><circle cx="6" cy="6" r="1.3" fill="currentColor"/><circle cx="12" cy="12" r="1.3" fill="currentColor"/><circle cx="18" cy="18" r="1.3" fill="currentColor"/>',
  sml: '<path d="M4 20L12 4L20 20" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M7 14h10" stroke="currentColor" stroke-width="1.5"/>',
  sla: '<path d="M4 4h12a4 4 0 014 4v12H4V4z" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M8 9h8M8 13h6M8 17h4" stroke="currentColor" stroke-width="1.5"/>',
  sbp: '<circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5" fill="none"/><circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1" fill="none"/><circle cx="12" cy="12" r="0.8" fill="currentColor"/>',
  sdc: '<path d="M4 16l4-8 4 4 4-6 4 10" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M3 20h18" stroke="currentColor" stroke-width="1"/>',
  sof: '<path d="M7 4v16M17 4v16M4 12h16" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="8" r="2" stroke="currentColor" stroke-width="1.5" fill="none"/>',
};

function relDate(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'moments ago';
  if (mins < 60) return mins + ' minutes ago';
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return hrs + ' hours ago';
  const days = Math.floor(hrs / 24);
  if (days < 30) return days + ' days ago';
  return new Date(d).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day:'2-digit', month:'short' });
}

const today = new Date();
const monthLong = today.toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', month:'long' });
const yr = today.getFullYear();
const calendarItems = [
  { d: '01 Sep ' + yr, label: 'Autumn term begins', kind: 'term' },
  { d: '15 Oct ' + yr, label: 'Mid-term review week', kind: 'review' },
  { d: '01 Dec ' + yr, label: 'Spring intake applications open', kind: 'admissions' },
  { d: 'Rolling', label: 'Quantum Challenge - open weekly', kind: 'examination' },
];

const principles = [
  { n: 'I', title: 'Honest scope', body: 'We publish only what we are prepared to teach in full. No empty syllabi, no placeholder courses.' },
  { n: 'II', title: 'Frontier scope', body: 'Vedic sciences, ASI, quantum technology, advanced computing. We work on the problems institutions of the prior century cannot reach.' },
  { n: 'III', title: 'Verifiable credentials', body: 'Every credential is hosted at a public URL with structured metadata. Anyone can verify; no portal access required.' },
  { n: 'IV', title: 'Named faculty', body: 'Every course is authored by a real person with their name attached. We do not hide behind institutional anonymity.' },
];
---
<AquintutorLayout title="AquinTutor - A virtual unEuropean MOOC consortium" description={pageDesc}>
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  <!-- LIVE TICKER -->
  <div style="background:var(--ink); color:var(--sand-50); border-bottom:1px solid var(--rule); overflow:hidden;">
    <div style="display:flex; align-items:center; gap:24px; padding:8px 28px; font-family:'JetBrains Mono',monospace; font-size:11.5px; letter-spacing:0.04em; white-space:nowrap; overflow-x:auto;" class="ticker">
      <span style="display:inline-flex; align-items:center; gap:6px; flex-shrink:0;">
        <span style="display:inline-block; width:6px; height:6px; border-radius:50%; background:#7dd3a8; box-shadow:0 0 8px #7dd3a8;"></span>
        <span style="color:#7dd3a8; font-weight:600;">LIVE</span>
      </span>
      <span style="opacity:0.5;">&middot;</span>
      <span><span style="opacity:0.6;">term:</span> autumn / {yr}</span>
      <span style="opacity:0.5;">&middot;</span>
      <span><span style="opacity:0.6;">schools:</span> {schools.length}</span>
      <span style="opacity:0.5;">&middot;</span>
      <span><span style="opacity:0.6;">courses open:</span> {courseCount}</span>
      <span style="opacity:0.5;">&middot;</span>
      <span><span style="opacity:0.6;">examinations sitting now:</span> {liveAttempts}</span>
      {recentCert && <>
        <span style="opacity:0.5;">&middot;</span>
        <span><span style="opacity:0.6;">last credential issued:</span> {relDate(recentCert.issued_at)}</span>
      </>}
      {recentAttempt && <>
        <span style="opacity:0.5;">&middot;</span>
        <span><span style="opacity:0.6;">last exam submitted:</span> {relDate(recentAttempt.submitted_at)}</span>
      </>}
      <span style="opacity:0.5;">&middot;</span>
      <span style="opacity:0.6;">admission by application</span>
    </div>
  </div>

  <!-- HERO -->
  <section style="border-bottom:1px solid var(--rule); position:relative; overflow:hidden;">
    <!-- Decorative vertical mark -->
    <div aria-hidden="true" style="position:absolute; left:0; top:0; bottom:0; width:48px; display:flex; flex-direction:column; align-items:center; justify-content:space-between; padding:36px 0; font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.4em; color:var(--ink-500); writing-mode:vertical-rl; text-orientation:mixed;" class="hide-mobile">
      <span>AQUINTUTOR &middot; BHARAT</span>
      <span style="color:var(--rust);">FRONTIER RESEARCH</span>
    </div>

    <div style="max-width:1320px; margin:0 auto; padding:72px 28px 64px; display:grid; grid-template-columns:1fr; gap:48px; align-items:end;" class="hero-grid">
      <div style="position:relative;">
        <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); font-weight:600; letter-spacing:0.04em; margin:0 0 18px;">Open enrolment &middot; Autumn {yr}</p>
        <h1 class="font-display" style="font-size:clamp(2.6rem, 7vw, 5.75rem); line-height:0.96; letter-spacing:-0.028em; font-weight:500; margin:0; color:var(--ink);">
          A virtual unEuropean MOOC consortium<br/>
          <span style="font-style:italic; font-weight:300; color:var(--ink-500);">for the students the</span><br/>
          existing system never<br/>
          <span style="font-style:italic; font-weight:300; color:var(--ink-500);">had room for.</span>
        </h1>
        <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-size:clamp(1.15rem, 1.5vw, 1.4rem); line-height:1.5; font-style:italic; color:var(--ink-500); margin:30px 0 0; max-width:38rem;">
          AquinTutor is the operating institution of EduRank·AI &mdash; a frontier research unEuropean MOOC consortium working in Vedic sciences, artificial super-intelligence, quantum technology and advanced computing. {schools.length} schools, {deptCount} departments, named faculty-written curriculum, proctored examinations, and a private AI co-pilot in every enrolment.
        </p>
        <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:32px;">
          <a href="/aquintutor/signup" style="background:var(--ink); color:var(--sand-50); padding:14px 26px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Apply for admission</a>
          <a href="/aquintutor/courses" style="background:transparent; color:var(--ink); padding:14px 26px; border-radius:6px; border:1px solid var(--ink); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">View the catalogue</a>
          <a href="/aquintutor/interview/general-screening" style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); text-decoration:underline; padding:14px 8px;">Sit a 20-minute screening interview &rarr;</a>
        </div>
      </div>

      <!-- Floating stat plate -->
      <aside style="background:var(--sand-100); border:1px solid var(--rule); border-radius:14px; padding:28px 28px 22px; position:relative;" class="stat-plate">
        <div style="position:absolute; top:-12px; left:24px; background:var(--paper); border:1px solid var(--rule); border-radius:999px; padding:4px 14px; font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.2em; color:var(--rust); font-weight:600;">THE INSTITUTION TODAY</div>
        <dl style="display:grid; grid-template-columns:1fr auto; gap:14px 18px; margin:0 0 6px; font-family:'Inter Tight',sans-serif; font-size:14.5px;">
          <dt style="color:var(--ink-500); padding-top:6px;">Schools</dt><dd class="font-display" style="margin:0; font-size:1.85rem; font-weight:500; line-height:1; color:var(--ink); letter-spacing:-0.02em; text-align:right;">{schools.length}</dd>
          <dt style="color:var(--ink-500); padding-top:6px; border-top:1px dashed var(--rule);">Departments</dt><dd class="font-display" style="margin:0; font-size:1.85rem; font-weight:500; line-height:1; color:var(--ink); letter-spacing:-0.02em; text-align:right; padding-top:6px; border-top:1px dashed var(--rule);">{deptCount}</dd>
          <dt style="color:var(--ink-500); padding-top:6px; border-top:1px dashed var(--rule);">Open courses</dt><dd class="font-display" style="margin:0; font-size:1.85rem; font-weight:500; line-height:1; color:var(--ink); letter-spacing:-0.02em; text-align:right; padding-top:6px; border-top:1px dashed var(--rule);">{courseCount}</dd>
          <dt style="color:var(--ink-500); padding-top:6px; border-top:1px dashed var(--rule);">Lessons published</dt><dd class="font-display" style="margin:0; font-size:1.85rem; font-weight:500; line-height:1; color:var(--ink); letter-spacing:-0.02em; text-align:right; padding-top:6px; border-top:1px dashed var(--rule);">{lessonCount}</dd>
          <dt style="color:var(--ink-500); padding-top:6px; border-top:1px dashed var(--rule);">Live examinations</dt><dd class="font-display" style="margin:0; font-size:1.85rem; font-weight:500; line-height:1; color:var(--ink); letter-spacing:-0.02em; text-align:right; padding-top:6px; border-top:1px dashed var(--rule);">{testCount}</dd>
          <dt style="color:var(--ink-500); padding-top:6px; border-top:1px dashed var(--rule);">Research focus</dt><dd class="font-display" style="margin:0; font-size:1.35rem; font-weight:500; line-height:1.05; color:var(--rust); letter-spacing:-0.02em; text-align:right; padding-top:6px; border-top:1px dashed var(--rule); font-style:italic;">ASI &middot; quantum &middot; Vedic</dd>
        </dl>
        <p style="font-family:'Inter Tight',sans-serif; font-size:11.5px; color:var(--ink-500); margin:12px 0 0; padding-top:10px; border-top:1px solid var(--rule); line-height:1.5;">Counts refresh on every page load. The institution is open to any applicant aged 16+ worldwide.</p>
      </aside>
    </div>
  </section>

  <!-- WHAT'S NEW — feature showcase, SVG icons, editorial aesthetic -->
  <section style="border-bottom:1px solid var(--rule); background:linear-gradient(180deg, #fff8f3 0%, var(--paper) 100%); position:relative;">
    <div style="max-width:1320px; margin:0 auto; padding:56px 28px;">
      <div style="display:flex; align-items:flex-end; justify-content:space-between; gap:18px; flex-wrap:wrap; margin-bottom:32px;">
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:700; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">The learning surface</p>
          <h2 class="font-display" style="font-size:clamp(1.9rem, 3.6vw, 2.8rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500; margin:0; color:var(--ink); max-width:38ch;">
            A full learning platform — and an AI tutor that talks back.
          </h2>
          <p style="font-family:'Inter Tight',sans-serif; font-size:14.5px; color:var(--ink-500); line-height:1.65; margin:14px 0 0; max-width:60ch;">
            Daily streak, weekly leagues, XP shop, friend invites, certificates. Free practice across every test, 1 CHF official attempts, interactive lessons with mic + listening exercises, story reading, and free-form conversation practice with our AI tutor in 14 languages.
          </p>
        </div>
        <a href="/aquintutor/dashboard" style="display:inline-flex;align-items:center;gap:8px;background:var(--ink); color:var(--sand-50); padding:13px 22px; border-radius:10px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:700; text-decoration:none; flex-shrink:0;">
          Open dashboard
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>

      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(230px, 1fr)); gap:14px;">
        {[
          { href: '/aquintutor/practice/sanskrit-awareness', icon: 'target', title: 'Free practice rounds', desc: '10-question rounds across every test. Instant feedback, no record. Earn XP and keep your streak alive.' },
          { href: '/aquintutor/converse', icon: 'message', title: 'AI conversation tutor', desc: 'Free-form chat with our AI tutor in 14 languages. Voice in, voice out. Beginner / intermediate / advanced.' },
          { href: '/aquintutor/daily', icon: 'zap', title: 'Daily challenge', desc: '7 cross-catalog questions every day. 50 XP bonus for a perfect 7/7. Same set for everyone.' },
          { href: '/aquintutor/league', icon: 'swords', title: 'Weekly leagues', desc: 'Cohorts of 30 race for XP each week. Top 5 promote, bottom 5 demote. Bronze through Diamond.' },
          { href: '/aquintutor/friends', icon: 'users', title: 'Friend invites', desc: 'Eight-character invite codes. Both earn 50 XP when accepted. See each friend\'s weekly XP and streak.' },
          { href: '/aquintutor/leaderboard', icon: 'trophy', title: 'Leaderboard', desc: 'Weekly, monthly, and all-time. Your own standing always visible — even outside the top 25.' },
          { href: '/aquintutor/shop', icon: 'shop', title: 'XP shop', desc: 'Spend earned XP on streak freezes and heart refills. No real money involved.' },
          { href: '/aquintutor/achievements', icon: 'medal', title: 'Achievements', desc: '18 badges across streak, XP, tests, courses, practice. Bronze through Platinum tiers.' },
          { href: '/aquintutor/courses/sanskrit-foundations', icon: 'graduation', title: 'Interactive lessons', desc: 'Nine exercise types including listen-and-type and speak-with-mic. Certificates issued at 100%.' },
          { href: '/aquintutor/stories/sa-the-students-greeting', icon: 'book', title: 'Story reading', desc: 'Short scenes with translation and comprehension. Per-line text-to-speech. 30 XP per finished story.' },
          { href: '/aquintutor/tests', icon: 'list', title: '10 tests across topics', desc: 'Sanskrit, English, Aptitude, Indian History, Science, Geography, CS, Reasoning, Heritage. Practice is free; official is 1 CHF.' },
          { href: '/aquintutor/customize', icon: 'settings', title: 'Customise', desc: 'Twenty avatars, pick the languages you\'re learning, leaderboard privacy, certificate wallet.' },
        ].map((f) => (
          <a href={f.href} style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:18px; text-decoration:none; color:var(--ink);">
            <span style="display:inline-flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:8px;background:rgba(217,119,87,0.08);color:var(--rust);margin-bottom:12px;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={({
                target: '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/>',
                message: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
                zap: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
                swords: '<path d="M14.5 17.5L3 6V3h3l11.5 11.5"/><path d="M13 19l6-6"/><path d="M16 16l4 4"/><path d="M19 21l2-2"/><path d="M14.5 6.5L18 3l3 3-3.5 3.5"/>',
                users: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
                trophy: '<path d="M6 9a3 3 0 0 1-3-3V4h4"/><path d="M18 9a3 3 0 0 0 3-3V4h-4"/><path d="M7 4h10v7a5 5 0 0 1-10 0z"/><path d="M12 16v4"/><path d="M8 21h8"/>',
                shop: '<circle cx="9" cy="21" r="1.4"/><circle cx="17" cy="21" r="1.4"/><path d="M3 4h2l2.4 12.4a2 2 0 0 0 2 1.6h8.2a2 2 0 0 0 2-1.5L21 8H6"/>',
                medal: '<path d="M7.21 15L2.66 7.14a2 2 0 0 1 .13-2.2L4.4 2.8A2 2 0 0 1 6 2h12a2 2 0 0 1 1.6.8l1.6 2.14a2 2 0 0 1 .14 2.2L16.79 15"/><circle cx="12" cy="17" r="5"/>',
                graduation: '<path d="M22 10L12 5 2 10l10 5 10-5z"/><path d="M6 12v5c2 2 4 3 6 3s4-1 6-3v-5"/>',
                book: '<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>',
