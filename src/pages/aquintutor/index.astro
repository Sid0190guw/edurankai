---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

let tests: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT t.*,
      (SELECT COUNT(*)::int FROM test_questions WHERE test_id = t.id) as question_count,
      (SELECT COUNT(*)::int FROM test_attempts WHERE test_id = t.id AND status IN ('submitted','auto_submitted')) as attempt_count
    FROM tests t
    WHERE t.is_published = true
    ORDER BY t.created_at DESC
  `);
  tests = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

// Group by test_type
const grouped: Record<string, any[]> = {};
for (const t of tests as any[]) {
  const cat = t.test_type || 'mixed';
  if (!grouped[cat]) grouped[cat] = [];
  grouped[cat].push(t);
}

const CATEGORIES: Record<string, { label: string; emoji: string; color: string; bg: string; desc: string }> = {
  coding: { label: 'Code Lab', emoji: 'C', color: '#10b981', bg: '#0a1a14', desc: 'Solve coding challenges in real time' },
  aptitude: { label: 'Mind Gym', emoji: 'A', color: '#60a5fa', bg: '#0a1420', desc: 'Sharpen logical and quantitative skills' },
  mcq: { label: 'Quick Quiz', emoji: 'Q', color: '#FF7040', bg: '#1a0a04', desc: 'Fast multiple-choice rounds' },
  subjective: { label: 'Deep Think', emoji: 'D', color: '#a78bfa', bg: '#15102a', desc: 'Long-form questions with AI grading' },
  personality: { label: 'Self Discovery', emoji: 'P', color: '#fbbf24', bg: '#1a1408', desc: 'Understand your strengths' },
  video: { label: 'Voice Up', emoji: 'V', color: '#ef4444', bg: '#1a0808', desc: 'Record video responses' },
  mixed: { label: 'All-Star', emoji: '*', color: '#FF4F00', bg: '#1a0a00', desc: 'Mixed-format assessments' },
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Aquintutor - Learn by Playing | EduRankAI</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: #08080a;
      color: #fff;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }
    /* Animated stars background */
    .stars { position: fixed; inset: 0; pointer-events: none; z-index: 0; opacity: 0.5; }
    .star { position: absolute; background: #fff; border-radius: 50%; animation: twinkle 3s infinite; }
    @keyframes twinkle { 0%, 100% { opacity: 0.2; } 50% { opacity: 0.9; } }
    .content { position: relative; z-index: 1; }

    /* Hero */
    .hero {
      padding: 60px 24px 40px;
      text-align: center;
      background: radial-gradient(ellipse at top, rgba(255,79,0,0.15), transparent 70%);
    }
    .hero h1 {
      font-size: clamp(36px, 6vw, 64px);
      font-weight: 900;
      letter-spacing: -0.03em;
      line-height: 1.05;
      background: linear-gradient(135deg, #fff 30%, #FF7040 80%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 16px;
    }
    .hero p { font-size: 17px; color: #a8a8b3; max-width: 580px; margin: 0 auto 28px; line-height: 1.6; }
    .pill-label { font-size: 11px; font-family: monospace; color: #FF7040; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 12px; }

    /* Stats bar */
    .stats { display: flex; gap: 24px; justify-content: center; flex-wrap: wrap; }
    .stat { text-align: center; }
    .stat-num { font-size: 28px; font-weight: 800; color: #FF7040; font-family: monospace; }
    .stat-label { font-size: 10px; color: #6e6e78; text-transform: uppercase; letter-spacing: 0.15em; margin-top: 4px; }

    /* Category grid */
    .cat-section { padding: 32px 24px; max-width: 1280px; margin: 0 auto; }
    .cat-hd { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
    .cat-icon { width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 700; }
    .cat-title { font-size: 22px; font-weight: 700; color: #fff; margin: 0; letter-spacing: -0.01em; }
    .cat-desc { font-size: 12px; color: #8a8a94; margin: 2px 0 0; }

    .test-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 14px; }
    .test-card {
      background: linear-gradient(180deg, #0f0f14, #08080a);
      border: 1px solid #1a1a1f;
      border-radius: 14px;
      padding: 18px;
      cursor: pointer;
      transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
      text-decoration: none;
      display: block;
      position: relative;
      overflow: hidden;
    }
    .test-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--cat-color, #FF4F00), transparent);
      opacity: 0;
      transition: opacity 0.3s;
    }
    .test-card:hover {
      transform: translateY(-3px);
      border-color: var(--cat-color, #FF4F00);
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }
    .test-card:hover::before { opacity: 1; }

    .tc-tag { font-size: 9px; font-weight: 700; padding: 2px 8px; border-radius: 100px; text-transform: uppercase; letter-spacing: 0.08em; display: inline-block; margin-bottom: 8px; }
    .tc-title { font-size: 16px; font-weight: 700; color: #fff; margin-bottom: 4px; line-height: 1.3; }
    .tc-desc { font-size: 12px; color: #8a8a94; line-height: 1.5; margin-bottom: 14px; min-height: 18px; }
    .tc-meta { display: flex; gap: 14px; padding-top: 12px; border-top: 1px solid #1a1a1f; font-size: 10px; color: #6e6e78; }
    .tc-meta span { display: flex; align-items: center; gap: 4px; }
    .tc-meta strong { color: #d8d8de; font-weight: 600; }

    .play-cta { display: flex; align-items: center; justify-content: space-between; margin-top: 12px; padding-top: 12px; border-top: 1px solid #1a1a1f; }
    .play-btn { background: var(--cat-color, #FF4F00); color: #fff; font-size: 11px; font-weight: 700; padding: 6px 12px; border-radius: 100px; letter-spacing: 0.05em; text-transform: uppercase; display: inline-flex; align-items: center; gap: 4px; }

    .empty-state { text-align: center; padding: 48px 24px; background: #0f0f14; border: 1px dashed #1a1a1f; border-radius: 14px; }
    .empty-state p { color: #6e6e78; font-size: 13px; }

    .topbar { background: #08080a; border-bottom: 1px solid #1a1a1f; padding: 14px 24px; position: sticky; top: 0; z-index: 10; backdrop-filter: blur(10px); }
    .topbar-inner { max-width: 1280px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
    .logo { font-size: 18px; font-weight: 900; color: #fff; text-decoration: none; letter-spacing: -0.02em; }
    .logo .a { color: #FF4F00; }
  </style>
</head>
<body>
  <div class="stars" id="stars"></div>

  <nav class="topbar">
    <div class="topbar-inner">
      <a href="/" class="logo"><span class="a">Aquin</span>tutor</a>
      <div style="display:flex;gap:10px;align-items:center;">
        <a href="/portal" style="color:#8a8a94;text-decoration:none;font-size:12px;">Portal</a>
        <a href="/portal/login" style="background:#FF4F00;color:#fff;text-decoration:none;font-size:12px;font-weight:600;padding:7px 14px;border-radius:6px;">Sign in</a>
      </div>
    </div>
  </nav>

  <div class="content">
    <section class="hero">
      <p class="pill-label">By EduRankAI</p>
      <h1>Test yourself.<br/>Learn by playing.</h1>
      <p>Free assessments designed to feel like games, not exams. Coding labs, mind puzzles, and quizzes that adapt to you.</p>
      <div class="stats">
        <div class="stat">
          <p class="stat-num">{tests.length}</p>
          <p class="stat-label">Tests live</p>
        </div>
        <div class="stat">
          <p class="stat-num">{tests.reduce((s: any, t: any) => s + (t.attempt_count || 0), 0)}</p>
          <p class="stat-label">Attempts</p>
        </div>
        <div class="stat">
          <p class="stat-num">FREE</p>
          <p class="stat-label">Always</p>
        </div>
      </div>
    </section>

    {Object.keys(grouped).length === 0 && (
      <section class="cat-section">
        <div class="empty-state">
          <p style="font-size:15px;color:#fff;margin-bottom:6px;">More quests coming soon</p>
          <p>The Aquintutor lab is being stocked with quizzes, code labs, and brain puzzles. Check back shortly.</p>
        </div>
      </section>
    )}

    {Object.entries(grouped).map(([catKey, catTests]: any) => {
      const cat = (CATEGORIES as any)[catKey] || CATEGORIES.mixed;
      return (
        <section class="cat-section">
          <div class="cat-hd">
            <div class="cat-icon" style={`background:${cat.bg};color:${cat.color};border:1px solid ${cat.color}40;`}>{cat.emoji}</div>
            <div>
              <h2 class="cat-title">{cat.label}</h2>
              <p class="cat-desc">{cat.desc}</p>
            </div>
          </div>
          <div class="test-grid">
            {(catTests as any[]).map((t: any) => (
              <a href={`/aquintutor/test/${t.slug}`} class="test-card" style={`--cat-color:${cat.color};`}>
                <span class="tc-tag" style={`background:${cat.color}22;color:${cat.color};`}>{cat.label}</span>
                <h3 class="tc-title">{t.title}</h3>
                <p class="tc-desc">{t.description || 'Take this challenge and test your skills.'}</p>
                <div class="tc-meta">
                  <span>T <strong>{t.duration_mins}</strong>min</span>
                  <span>Q <strong>{t.question_count || 0}</strong>q</span>
                  <span>* <strong>{t.total_marks || 0}</strong>pts</span>
                </div>
                <div class="play-cta">
                  <span style="font-size:10px;color:#6e6e78;">{t.attempt_count || 0} attempts</span>
                  <span class="play-btn">Start -&gt;</span>
                </div>
              </a>
            ))}
          </div>
        </section>
      );
    })}

    <footer style="padding:40px 24px;text-align:center;color:#6e6e78;font-size:11px;border-top:1px solid #1a1a1f;margin-top:40px;">
      <p>Aquintutor is a free product by <a href="https://www.edurankai.in" style="color:#FF7040;text-decoration:none;">EduRankAI</a>.</p>
      <p style="margin-top:6px;">More quests, badges, and leaderboards coming soon.</p>
    </footer>
  </div>

  <script is:inline>
    // Generate twinkling stars
    var stars = document.getElementById('stars');
    for (var i = 0; i < 80; i++) {
      var s = document.createElement('div');
      s.className = 'star';
      s.style.left = Math.random() * 100 + '%';
      s.style.top = Math.random() * 100 + '%';
      s.style.width = (Math.random() * 2 + 1) + 'px';
      s.style.height = s.style.width;
      s.style.animationDelay = Math.random() * 3 + 's';
      stars.appendChild(s);
    }
  </script>
</body>
</html>
