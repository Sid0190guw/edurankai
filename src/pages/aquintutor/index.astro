            <h3 class="font-display" style="font-size:1.45rem; font-weight:500; margin:0; line-height:1.18; letter-spacing:-0.015em;">{s.name}</h3>
            {s.tagline && <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.1rem; line-height:1.4; color:var(--ink-500); margin:0;">{s.tagline}</p>}
            {Array.isArray(s.dept_names) && s.dept_names.length > 0 && (
