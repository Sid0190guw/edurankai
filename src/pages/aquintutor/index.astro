                  <span style="font-family:'Inter Tight',sans-serif; font-size:11.5px; padding:3px 9px; background:var(--sand-100); border:1px solid var(--rule); border-radius:999px; color:var(--ink-500);">{d.replace('Department of ', '')}</span>
                ))}
