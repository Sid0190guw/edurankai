  <!-- FACULTY PULL-QUOTE -->
  {faculty.length > 0 && (
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:1320px; margin:0 auto; padding:80px 28px;">
        <div style="display:grid; grid-template-columns:1fr; gap:48px; align-items:center;" class="quote-grid">
          <div>
            <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 14px;">From the faculty</p>
            <blockquote class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.5rem, 2.6vw, 2.1rem); line-height:1.35; color:var(--ink); margin:0 0 28px; max-width:38rem;">
              &ldquo;We teach the things that survive translation - the unifying ideas that hold up whether you write them in Sanskrit, Python, or Hindi. The job of the institution is to find those ideas and refuse to dilute them.&rdquo;
            </blockquote>
            <footer style="display:flex; align-items:center; gap:14px;">
              <span style="display:inline-flex; align-items:center; justify-content:center; width:56px; height:56px; border-radius:50%; background:var(--ink); color:var(--sand-50); font-family:'Fraunces',serif; font-weight:500; font-size:22px;">{(faculty[0].name || 'F').split(' ').slice(-1)[0][0]}</span>
              <div style="font-family:'Inter Tight',sans-serif;">
                <p class="font-display" style="margin:0; font-size:1.15rem; font-weight:500; color:var(--ink); letter-spacing:-0.01em;">{faculty[0].name}</p>
                <p style="margin:3px 0 0; font-size:13px; color:var(--ink-500);">{faculty[0].title}</p>
              </div>
            </footer>
