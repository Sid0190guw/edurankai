  <!-- HOW A COURSE IS DELIVERED -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1320px; margin:0 auto; padding:72px 28px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">The contract</p>
      <h2 class="font-display" style="font-size:clamp(1.85rem, 3.5vw, 2.85rem); line-height:1.08; letter-spacing:-0.02em; font-weight:500; margin:0 0 48px; color:var(--ink); max-width:36rem;">
        How a course is<br/>
        <span style="font-style:italic; font-weight:300; color:var(--ink-500);">delivered, end to end.</span>
      </h2>

      <div style="position:relative;">
        <!-- Connecting line -->
        <svg style="position:absolute; top:36px; left:0; right:0; height:2px; width:100%; pointer-events:none;" class="hide-mobile" preserveAspectRatio="none" viewBox="0 0 100 1"><line x1="6" y1="0.5" x2="94" y2="0.5" stroke="var(--rule)" stroke-width="0.5" stroke-dasharray="0.6 0.6"/></svg>
        <div style="display:grid; grid-template-columns:1fr; gap:24px; position:relative;" class="how-grid">
          {[
            { n: '01', title: 'Instruction', body: 'Faculty-written lessons in text and short video. No autoplay, no infinite scroll. Each lesson ends with a recap and three checkpoint questions.', icon: '<path d="M4 4h14a2 2 0 012 2v14H6a2 2 0 01-2-2V4z" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M8 9h10M8 13h7M8 17h4" stroke="currentColor" stroke-width="1.5"/>' },
            { n: '02', title: 'Tutorial', body: 'A private AI tutor inside the lesson - asks where you stuck, explains it differently, sets a stretch problem if you ran ahead.', icon: '<circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M4 21v-1a8 8 0 0116 0v1" stroke="currentColor" stroke-width="1.5" fill="none"/><circle cx="17" cy="6" r="2.5" fill="currentColor" opacity="0.3"/>' },
            { n: '03', title: 'Assessment', body: 'Module quizzes inside the lesson. End-of-course examinations are proctored under ATLAS: camera, mic, focus, network signals all logged as text events.', icon: '<path d="M4 5a2 2 0 012-2h12a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V5z" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M8 9l3 3 5-5" stroke="currentColor" stroke-width="1.6" fill="none"/>' },
            { n: '04', title: 'Credential', body: 'A verifiable credential at a public URL with structured metadata. Add-to-LinkedIn deep link; PDF; embed code. The credential outlives the platform.', icon: '<circle cx="12" cy="9" r="5" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M8 14l-2 7 6-3 6 3-2-7" stroke="currentColor" stroke-width="1.5" fill="none"/>' },
          ].map((step) => (
            <article style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:30px 26px; display:flex; flex-direction:column; gap:14px; position:relative;">
