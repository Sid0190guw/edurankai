---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

// ===== LIVE STATS =====
let testCount = 0, attemptCount = 0, courseCount = 0, lessonCount = 0, certCount = 0, enrolledCount = 0;
let tests: any[] = [];
let featuredCourses: any[] = [];

try {
  const r = await db.execute(sql`
    SELECT t.id, t.slug, t.title, t.description, t.test_type, t.duration_mins, t.difficulty,
      (SELECT COUNT(*)::int FROM test_questions WHERE test_id = t.id) as question_count,
      (SELECT COUNT(*)::int FROM test_attempts WHERE test_id = t.id AND status IN ('submitted','auto_submitted')) as attempt_count
    FROM tests t
    WHERE t.is_published = true
    ORDER BY t.created_at DESC
  `);
  tests = Array.isArray(r) ? r : (r?.rows || []);
  testCount = tests.length;
  attemptCount = tests.reduce((s: any, t: any) => s + (t.attempt_count || 0), 0);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT c.slug, c.title, c.short_desc, c.level, c.category, c.duration_hours, c.is_free,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as lesson_count
    FROM training_courses c
    WHERE c.is_published = true AND c.access_type IN ('public', 'both')
    ORDER BY c.enrolled_count DESC NULLS LAST, c.created_at DESC
    LIMIT 6
  `);
  featuredCourses = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM training_courses WHERE is_published = true AND access_type IN ('public', 'both')`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  courseCount = (rows[0] as any)?.n || 0;
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM training_lessons l JOIN training_courses c ON l.course_id = c.id WHERE c.is_published = true`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  lessonCount = (rows[0] as any)?.n || 0;
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM training_certificates`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  certCount = (rows[0] as any)?.n || 0;
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT COUNT(DISTINCT user_id)::int as n FROM training_enrollments`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  enrolledCount = (rows[0] as any)?.n || 0;
} catch (_) {}

// Group tests by type (kept for the Quick Assessments section at the bottom)
const grouped: Record<string, any[]> = {};
for (const t of tests as any[]) {
  const cat = t.test_type || 'mixed';
  if (!grouped[cat]) grouped[cat] = [];
  grouped[cat].push(t);
}

const TEST_CATEGORIES: Record<string, { label: string; color: string; bg: string; desc: string }> = {
  coding: { label: 'Code Lab', color: '#10b981', bg: '#0a1a14', desc: 'Live coding challenges' },
  aptitude: { label: 'Mind Gym', color: '#60a5fa', bg: '#0a1420', desc: 'Logic and quant skills' },
  mcq: { label: 'Quick Quiz', color: '#FF7040', bg: '#1a0a04', desc: 'Fast multiple-choice rounds' },
  subjective: { label: 'Deep Think', color: '#a78bfa', bg: '#15102a', desc: 'AI-graded long-form' },
  personality: { label: 'Self Discovery', color: '#fbbf24', bg: '#1a1408', desc: 'Strengths and signals' },
  video: { label: 'Voice Up', color: '#ef4444', bg: '#1a0808', desc: 'Recorded responses' },
  mixed: { label: 'All-Star', color: '#FF4F00', bg: '#1a0a00', desc: 'Mixed-format' },
};

// 6 schools (per the AquinTutor virtual-university vision)
const SCHOOLS = [
  { code: 'SCR', name: 'School of Computing & Reasoning', desc: 'Software, AI, systems, and the science of inference.', accent: '#10b981', cat: 'technology' },
  { code: 'SML', name: 'School of Mathematics & Logic', desc: 'Foundations, applied maths, formal reasoning.', accent: '#60a5fa', cat: 'mathematics' },
  { code: 'SLA', name: 'School of Liberal Arts', desc: 'Philosophy, literature, history, languages.', accent: '#a78bfa', cat: 'general' },
  { code: 'SBP', name: 'School of Business & Policy', desc: 'Strategy, economics, public policy, governance.', accent: '#fbbf24', cat: 'business' },
  { code: 'SDC', name: 'School of Design & Communication', desc: 'Visual design, typography, narrative, media.', accent: '#FF7040', cat: 'design' },
  { code: 'SOF', name: 'School of Foundations', desc: 'Interdisciplinary core curriculum across all schools.', accent: '#ef4444', cat: 'general' },
];

const PHASES = [
  { num: 'I', label: 'Now', body: 'Marketing site, course catalogue, working enrolment, gamified assessments, certificate verification.' },
  { num: 'II', label: '6-18 months', body: 'AI tutor with course-context RAG, paid premium courses, faculty profiles, admin authoring tools.' },
  { num: 'III', label: '18-36 months', body: 'In-house proctoring, interactive 3D simulations, voice tutor, mobile apps, national qualifications recognition.' },
  { num: 'IV', label: '36+ months', body: 'Degree-granting status (UGC-DEB), generative real-time labs, holographic content for select courses.' },
];

const pageDesc = 'AquinTutor is a virtual institution by EduRankAI. ' + courseCount + ' open courses, ' + testCount + ' free assessments, ' + certCount + ' verifiable certificates issued. Built in Bharat. Open to the world.';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: 'AquinTutor',
  url: 'https://www.edurankai.in/aquintutor',
  description: pageDesc,
  parentOrganization: { '@type': 'Organization', name: 'EduRankAI', url: 'https://www.edurankai.in' },
  foundingDate: '2026',
  foundingLocation: { '@type': 'Place', name: 'Bharat (India)' },
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>AquinTutor - A virtual institution by EduRankAI</title>
  <meta name="description" content={pageDesc} />
  <link rel="canonical" href="https://www.edurankai.in/aquintutor" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta property="og:title" content="AquinTutor - A virtual institution by EduRankAI" />
  <meta property="og:description" content={pageDesc} />
  <meta property="og:url" content="https://www.edurankai.in/aquintutor" />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#FF4F00" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: #08080a;
      color: #e8e8ee;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      line-height: 1.55;
    }
    a { color: inherit; text-decoration: none; }

    /* TOPBAR */
    .topbar {
      background: rgba(8,8,10,0.82);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid #1a1a1f;
      padding: 12px 24px;
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .topbar-inner { max-width: 1280px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; gap: 16px; }
    .logo { font-size: 18px; font-weight: 900; color: #fff; letter-spacing: -0.02em; }
    .logo .a { color: #FF4F00; }
    .logo-sub { font-size: 9.5px; color: #6e6e78; font-family: 'Geist Mono', monospace; letter-spacing: 0.12em; text-transform: uppercase; margin-top: 1px; display: block; }
    .topnav { display: flex; gap: 20px; align-items: center; }
    .topnav a { font-size: 13px; color: #a8a8b3; transition: color 0.15s; }
    .topnav a:hover { color: #fff; }
    .topnav a.cta { background: #FF4F00; color: #fff; font-weight: 600; padding: 8px 16px; border-radius: 8px; font-size: 12.5px; }
    .topnav a.cta:hover { background: #FF7040; color: #fff; }
    @media (max-width: 640px) {
      .topnav a:not(.cta):not(.always) { display: none; }
      .topnav { gap: 10px; }
    }

    /* HERO */
    .hero {
      padding: 60px 24px 48px;
      max-width: 1080px;
      margin: 0 auto;
      text-align: center;
      background: radial-gradient(ellipse at top, rgba(255,79,0,0.12), transparent 60%);
    }
    .eyebrow {
      font-size: 11px;
      font-family: 'Geist Mono', monospace;
      color: #FF7040;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      font-weight: 700;
      margin-bottom: 18px;
    }
    .hero h1 {
      font-size: clamp(36px, 6vw, 64px);
      font-weight: 800;
      letter-spacing: -0.025em;
      line-height: 1.05;
      color: #fff;
      margin-bottom: 18px;
    }
    .hero h1 em { font-style: italic; color: #FF7040; font-weight: 600; }
    .hero p { font-size: clamp(15px, 1.6vw, 18px); color: #a8a8b3; max-width: 640px; margin: 0 auto 28px; line-height: 1.7; }
    .hero-ctas { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }
    .btn {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 12px 22px; border-radius: 10px; font-weight: 600;
      font-size: 13.5px; min-height: 44px;
      transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
    }
    .btn-primary { background: #FF4F00; color: #fff; }
    .btn-primary:hover { background: #FF7040; transform: translateY(-1px); box-shadow: 0 10px 24px rgba(255,79,0,0.35); }
    .btn-ghost { background: rgba(255,255,255,0.05); color: #e8e8ee; border: 1px solid rgba(255,255,255,0.12); }
    .btn-ghost:hover { background: rgba(255,255,255,0.1); }

    /* SECTION wrapper */
    section.scope { max-width: 1280px; margin: 0 auto; padding: 56px 24px; }
    .section-eyebrow { font-size: 10.5px; font-family: 'Geist Mono', monospace; color: #FF7040; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 700; margin-bottom: 10px; }
    .section-title { font-size: clamp(26px, 3.5vw, 36px); font-weight: 700; color: #fff; letter-spacing: -0.02em; margin-bottom: 8px; line-height: 1.15; }
    .section-title em { font-style: italic; color: #FF7040; font-weight: 500; }
    .section-lead { font-size: 14.5px; color: #a8a8b3; max-width: 640px; line-height: 1.7; margin-bottom: 36px; }

    /* LIVE STATS */
    .stats-strip {
      max-width: 1080px; margin: 0 auto;
      padding: 0 24px 8px;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 12px;
    }
    .stat-card {
      background: linear-gradient(180deg, #0f0f14, #08080a);
      border: 1px solid #1a1a1f;
      border-radius: 14px;
      padding: 20px;
      text-align: center;
    }
    .stat-num { font-size: 28px; font-weight: 800; color: #FF7040; font-family: 'Geist Mono', monospace; line-height: 1; }
    .stat-label { font-size: 10px; color: #6e6e78; text-transform: uppercase; letter-spacing: 0.14em; margin-top: 6px; font-weight: 600; }

    /* SCHOOLS GRID */
    .schools-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 14px; }
    .school {
      background: linear-gradient(180deg, #0f0f14, #08080a);
      border: 1px solid #1a1a1f;
      border-radius: 14px;
      padding: 22px;
      display: flex;
      flex-direction: column;
      transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    }
    .school:hover { transform: translateY(-2px); border-color: var(--accent); box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
    .school-code { font-size: 10px; font-family: 'Geist Mono', monospace; letter-spacing: 0.15em; font-weight: 700; color: var(--accent); margin-bottom: 10px; }
    .school-name { font-size: 17px; font-weight: 700; color: #fff; margin-bottom: 6px; line-height: 1.3; }
    .school-desc { font-size: 13px; color: #8a8a94; line-height: 1.6; flex: 1; margin-bottom: 14px; }
    .school-link { font-size: 12px; font-weight: 600; color: var(--accent); display: inline-flex; align-items: center; gap: 6px; }

    /* COURSE CARDS */
    .courses-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 14px; }
    .course-card {
      background: linear-gradient(180deg, #0f0f14, #08080a);
      border: 1px solid #1a1a1f;
      border-radius: 14px;
      padding: 20px;
      display: flex;
      flex-direction: column;
      transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    }
    .course-card:hover { transform: translateY(-2px); border-color: #FF7040; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
    .course-tags { display: flex; gap: 6px; margin-bottom: 10px; flex-wrap: wrap; }
    .tag { font-size: 9.5px; font-weight: 700; padding: 2px 8px; border-radius: 100px; text-transform: uppercase; letter-spacing: 0.06em; border: 1px solid; }
    .tag-level { color: #FF7040; background: rgba(255,112,64,0.08); border-color: rgba(255,112,64,0.3); }
    .tag-free { color: #10b981; background: rgba(16,185,129,0.08); border-color: rgba(16,185,129,0.3); }
    .course-title { font-size: 16px; font-weight: 700; color: #fff; margin-bottom: 6px; line-height: 1.3; }
    .course-desc { font-size: 12.5px; color: #8a8a94; line-height: 1.6; flex: 1; margin-bottom: 14px; }
    .course-meta { font-size: 10.5px; color: #6e6e78; font-family: 'Geist Mono', monospace; display: flex; gap: 14px; padding-top: 12px; border-top: 1px solid #1a1a1f; }

    /* PHASE / ROADMAP */
    .phase-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px; }
    .phase {
      background: rgba(255,255,255,0.02);
      border: 1px solid #1a1a1f;
      border-radius: 14px;
      padding: 20px;
    }
    .phase-num { font-size: 28px; font-weight: 800; color: #FF7040; font-family: 'Geist Mono', monospace; line-height: 1; margin-bottom: 4px; }
    .phase-label { font-size: 10px; color: #6e6e78; text-transform: uppercase; letter-spacing: 0.14em; margin-bottom: 12px; font-weight: 700; }
    .phase-body { font-size: 12.5px; color: #a8a8b3; line-height: 1.7; }

    /* TEST GRID (kept for Quick Assessments section) */
    .test-section { padding: 32px 24px; max-width: 1280px; margin: 0 auto; }
    .test-cat-hd { display: flex; align-items: center; gap: 14px; margin-bottom: 18px; }
    .test-cat-icon { width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 700; }
    .test-cat-title { font-size: 18px; font-weight: 700; color: #fff; margin: 0; }
    .test-cat-desc { font-size: 12px; color: #8a8a94; margin: 2px 0 0; }
    .test-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 12px; }
    .test-card { background: #0f0f14; border: 1px solid #1a1a1f; border-radius: 12px; padding: 16px; transition: transform 0.2s, border-color 0.2s; display: block; }
    .test-card:hover { transform: translateY(-2px); border-color: var(--cat-color, #FF4F00); }
    .tc-title { font-size: 14px; font-weight: 700; color: #fff; margin-bottom: 4px; }
    .tc-desc { font-size: 11.5px; color: #8a8a94; line-height: 1.5; margin-bottom: 12px; min-height: 17px; }
    .tc-meta { font-size: 10px; color: #6e6e78; display: flex; gap: 12px; padding-top: 10px; border-top: 1px solid #1a1a1f; font-family: 'Geist Mono', monospace; }

    /* FOOTER */
    footer {
      border-top: 1px solid #1a1a1f;
      padding: 36px 24px;
      max-width: 1280px;
      margin: 24px auto 0;
      color: #6e6e78;
      font-size: 12px;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 16px;
    }
    footer a { color: #a8a8b3; }
    footer a:hover { color: #fff; }
  </style>
</head>
<body>

  <!-- TOPBAR -->
  <nav class="topbar">
    <div class="topbar-inner">
      <a href="/aquintutor" class="logo">
        <span class="a">Aquin</span>tutor
        <span class="logo-sub">An institution of EduRankAI</span>
      </a>
      <div class="topnav">
        <a href="/aquintutor/courses">Courses</a>
        <a href="/aquintutor/paths">Paths</a>
        <a href="/aquintutor/instructors">Faculty</a>
        <a href="#schools">Schools</a>
        <a href="#tests">Assessments</a>
        <a href="/portal/login" class="cta">Sign in</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <p class="eyebrow">Established MMXXVI - An institution of EduRankAI</p>
    <h1>A virtual institution.<br/><em>Honest, by design.</em></h1>
    <p>Open online courses, gamified assessments, verifiable credentials. Six schools across computing, mathematics, the liberal arts, business, design, and the foundational core. Free where possible. Built in Bharat.</p>
    <div class="hero-ctas">
      <a href="/aquintutor/courses" class="btn btn-primary">Browse courses -&gt;</a>
      <a href="/portal/signup" class="btn btn-ghost">Create free account</a>
    </div>
  </section>

  <!-- LIVE STATS -->
  <div class="stats-strip">
    <div class="stat-card">
      <p class="stat-num">{courseCount}</p>
      <p class="stat-label">Open Courses</p>
    </div>
    <div class="stat-card">
      <p class="stat-num">{lessonCount}</p>
      <p class="stat-label">Lessons</p>
    </div>
    <div class="stat-card">
      <p class="stat-num">{testCount}</p>
      <p class="stat-label">Live Tests</p>
    </div>
    <div class="stat-card">
      <p class="stat-num">{enrolledCount}</p>
      <p class="stat-label">Enrolled</p>
    </div>
    <div class="stat-card">
      <p class="stat-num">{certCount}</p>
      <p class="stat-label">Credentials</p>
    </div>
    <div class="stat-card">
      <p class="stat-num">FREE</p>
      <p class="stat-label">Where Possible</p>
    </div>
  </div>

  <!-- SCHOOLS -->
  <section class="scope" id="schools">
    <p class="section-eyebrow">The institution</p>
    <h2 class="section-title">Six schools, <em>one mission.</em></h2>
    <p class="section-lead">Each school is anchored by an interdisciplinary core, taught with AI-augmented tutoring, and assessed in formats that reward understanding over memorisation.</p>
    <div class="schools-grid">
      {SCHOOLS.map((s) => (
        <a href={'/aquintutor/courses?cat=' + s.cat} class="school" style={`--accent:${s.accent};`}>
          <p class="school-code">{s.code}</p>
          <h3 class="school-name">{s.name}</h3>
          <p class="school-desc">{s.desc}</p>
          <span class="school-link">Explore courses -&gt;</span>
        </a>
      ))}
    </div>
  </section>

  <!-- FEATURED COURSES -->
  {featuredCourses.length > 0 && (
    <section class="scope" id="courses">
      <p class="section-eyebrow">Featured courses</p>
      <h2 class="section-title">Start with one. <em>Stack the rest.</em></h2>
      <p class="section-lead">Hand-picked from the open catalogue. Each course issues a verifiable certificate on completion, citable at <code style="background:#15151a;padding:2px 6px;border-radius:4px;font-size:0.85em;">/credentials/...</code></p>
      <div class="courses-grid">
        {featuredCourses.map((c: any) => (
          <a href={'/aquintutor/courses/' + c.slug} class="course-card">
            <div class="course-tags">
              <span class="tag tag-level">{c.level || 'beginner'}</span>
              {c.is_free && <span class="tag tag-free">FREE</span>}
            </div>
            <h3 class="course-title">{c.title}</h3>
            <p class="course-desc">{c.short_desc || ''}</p>
            <div class="course-meta">
              <span>{c.lesson_count || 0} lessons</span>
              {c.duration_hours > 0 && <span>{c.duration_hours}h</span>}
            </div>
          </a>
        ))}
      </div>
      <div style="margin-top:24px;">
        <a href="/aquintutor/courses" class="btn btn-ghost">See all {courseCount} courses -&gt;</a>
      </div>
    </section>
  )}

  <!-- ROADMAP -->
  <section class="scope">
    <p class="section-eyebrow">Roadmap, publicly</p>
    <h2 class="section-title">What's built. <em>What's coming.</em></h2>
    <p class="section-lead">We publish the roadmap so candidates, learners, and partners can hold us to it. No mystery boxes.</p>
    <div class="phase-grid">
      {PHASES.map((p) => (
        <div class="phase">
          <p class="phase-num">{p.num}</p>
          <p class="phase-label">{p.label}</p>
          <p class="phase-body">{p.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- QUICK ASSESSMENTS (the former main content, repositioned as one section) -->
  {Object.keys(grouped).length > 0 && (
    <section class="test-section" id="tests">
      <p class="section-eyebrow">Free assessments</p>
      <h2 class="section-title">Quick skill checks. <em>Gamified.</em></h2>
      <p class="section-lead">Short, designed-to-feel-like-games tests. Useful for learners who want a temperature check before enrolling in a full course.</p>
      {Object.entries(grouped).map(([catKey, catTests]: any) => {
        const cat = (TEST_CATEGORIES as any)[catKey] || TEST_CATEGORIES.mixed;
        return (
          <div style="margin-bottom:30px;">
            <div class="test-cat-hd">
              <div class="test-cat-icon" style={`background:${cat.bg};color:${cat.color};border:1px solid ${cat.color}40;`}>{cat.label.substring(0, 1)}</div>
              <div>
                <h3 class="test-cat-title">{cat.label}</h3>
                <p class="test-cat-desc">{cat.desc}</p>
              </div>
            </div>
            <div class="test-grid">
              {(catTests as any[]).map((t: any) => (
                <a href={'/aquintutor/test/' + t.slug} class="test-card" style={`--cat-color:${cat.color};`}>
                  <h4 class="tc-title">{t.title}</h4>
                  <p class="tc-desc">{t.description || ''}</p>
                  <div class="tc-meta">
                    <span>{t.duration_mins || 0}min</span>
                    <span>{t.question_count || 0} questions</span>
                    {(t.attempt_count > 0) && <span>{t.attempt_count} attempts</span>}
                  </div>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </section>
  )}

  <!-- CHARTER / MISSION -->
