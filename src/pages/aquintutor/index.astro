---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

// ===== LIVE STATS =====
let testCount = 0, attemptCount = 0, courseCount = 0, lessonCount = 0, certCount = 0, enrolledCount = 0;
let tests: any[] = [];
let featuredCourses: any[] = [];

try {
  const r = await db.execute(sql`
    SELECT t.id, t.slug, t.title, t.description, t.test_type, t.duration_mins, t.difficulty,
      (SELECT COUNT(*)::int FROM test_questions WHERE test_id = t.id) as question_count,
      (SELECT COUNT(*)::int FROM test_attempts WHERE test_id = t.id AND status IN ('submitted','auto_submitted')) as attempt_count
    FROM tests t WHERE t.is_published = true
    ORDER BY t.created_at DESC LIMIT 6
  `);
  tests = Array.isArray(r) ? r : (r?.rows || []);
  testCount = tests.length;
  attemptCount = tests.reduce((s: any, t: any) => s + (t.attempt_count || 0), 0);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT c.slug, c.title, c.subtitle, c.short_desc, c.level, c.category, c.duration_hours, c.duration_weeks,
      c.credit_hours, c.course_code, c.is_free, c.pricing_model,
      s.name as school_name,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as lesson_count
    FROM training_courses c
    LEFT JOIN schools s ON c.school_id = s.id
    WHERE c.is_published = true AND c.access_type IN ('public', 'both')
    ORDER BY c.enrolled_count DESC NULLS LAST, c.created_at DESC LIMIT 6
  `);
  featuredCourses = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM training_courses WHERE is_published = true AND access_type IN ('public', 'both')`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  courseCount = (rows[0] as any)?.n || 0;
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM training_lessons l JOIN training_courses c ON l.course_id = c.id WHERE c.is_published = true`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  lessonCount = (rows[0] as any)?.n || 0;
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM training_certificates`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  certCount = (rows[0] as any)?.n || 0;
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT COUNT(DISTINCT user_id)::int as n FROM training_enrollments`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  enrolledCount = (rows[0] as any)?.n || 0;
} catch (_) {}

let schools: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT s.id, s.slug, s.code, s.name, s.tagline,
      (SELECT COUNT(*)::int FROM academic_departments WHERE school_id = s.id) as dept_count,
      (SELECT COUNT(*)::int FROM training_courses WHERE school_id = s.id AND is_published = true) as course_count
    FROM schools s WHERE s.is_published = true ORDER BY s.display_order ASC
  `);
  schools = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const pageDesc = 'AquinTutor is a virtual university by EduRank-AI. Six schools, ' + courseCount + '+ open courses, proctored examinations, verifiable credentials. Open enrolment from one Swiss franc.';
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: 'AquinTutor',
  url: 'https://www.edurankai.in/aquintutor',
  description: pageDesc,
  parentOrganization: { '@type': 'Organization', name: 'EduRankAI', url: 'https://www.edurankai.in' },
  foundingDate: '2026',
  foundingLocation: { '@type': 'Place', name: 'Bharat (India)' },
};

const SCHOOL_ICONS: Record<string, string> = {
  SCR: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2zM9 22V12h6v10',
  SML: 'M12 2v20M2 12h20M4 4l16 16M20 4L4 20',
  SLA: 'M4 19h16M4 19v-7l8-5 8 5v7M8 19v-5h8v5',
  SBP: 'M3 18l5-5 4 3 8-9M15 7h5v5',
  SDC: 'M3 20L12 4l9 16M7 20l5-9 5 9',
  SOF: 'M12 3l9 4-9 4-9-4zM3 12l9 4 9-4M3 17l9 4 9-4',
};
---
<AquintutorLayout title="A virtual university by EduRank-AI" description={pageDesc}>
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  <!-- HERO -->
  <section style="position:relative; border-bottom:1px solid var(--rule);">
    <div style="max-width:1280px; margin:0 auto; padding:96px 28px 64px; display:grid; grid-template-columns:1fr; gap:48px; align-items:end;" class="hero-grid">
      <div>
        <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); font-weight:600; letter-spacing:0.04em; margin:0 0 18px;">Open enrolment for the 2026 academic year</p>
        <h1 class="font-display" style="font-size:clamp(2.75rem, 6vw, 5.5rem); line-height:1.02; letter-spacing:-0.02em; font-weight:500; margin:0; color:var(--ink);">
          A virtual university built for the students the existing system never had room for.
        </h1>
        <p style="font-family:'Inter Tight',sans-serif; font-size:clamp(1rem, 1.3vw, 1.25rem); line-height:1.55; color:var(--ink-500); margin:24px 0 0; max-width:38rem;">
          AquinTutor is an operating institution by EduRank&middot;AI. Six schools, seventeen departments, faculty-written curriculum, proctored examinations, and a private AI tutor in every enrolment. Verifiable credentials from one Swiss franc.
        </p>
        <div style="display:flex; gap:12px; margin-top:32px; flex-wrap:wrap;">
          <a href="/aquintutor/signup" style="background:var(--ink); color:var(--sand-50); padding:14px 26px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Apply &middot; from 1 CHF</a>
          <a href="/aquintutor/courses" style="background:transparent; color:var(--ink); padding:14px 26px; border-radius:6px; border:1px solid var(--ink); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">View the catalogue</a>
        </div>
      </div>
      <div>
        <div style="background:var(--sand-100); border:1px solid var(--rule); border-radius:14px; padding:24px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 16px;">The institution today</p>
          <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:14px; font-family:'Inter Tight',sans-serif;">
            <li style="display:flex; justify-content:space-between; align-items:baseline; border-bottom:1px solid var(--rule); padding-bottom:12px;">
              <span style="color:var(--ink-500); font-size:14px;">Schools</span>
              <span class="font-display" style="font-size:1.5rem; font-weight:500; color:var(--ink);">{schools.length || 6}</span>
            </li>
            <li style="display:flex; justify-content:space-between; align-items:baseline; border-bottom:1px solid var(--rule); padding-bottom:12px;">
              <span style="color:var(--ink-500); font-size:14px;">Departments</span>
              <span class="font-display" style="font-size:1.5rem; font-weight:500; color:var(--ink);">{schools.reduce((s: number, x: any) => s + (x.dept_count || 0), 0) || 17}</span>
            </li>
            <li style="display:flex; justify-content:space-between; align-items:baseline; border-bottom:1px solid var(--rule); padding-bottom:12px;">
              <span style="color:var(--ink-500); font-size:14px;">Open courses</span>
              <span class="font-display" style="font-size:1.5rem; font-weight:500; color:var(--ink);">{courseCount}</span>
            </li>
            <li style="display:flex; justify-content:space-between; align-items:baseline; border-bottom:1px solid var(--rule); padding-bottom:12px;">
              <span style="color:var(--ink-500); font-size:14px;">Lessons published</span>
              <span class="font-display" style="font-size:1.5rem; font-weight:500; color:var(--ink);">{lessonCount}</span>
            </li>
            <li style="display:flex; justify-content:space-between; align-items:baseline; border-bottom:1px solid var(--rule); padding-bottom:12px;">
              <span style="color:var(--ink-500); font-size:14px;">Live examinations</span>
              <span class="font-display" style="font-size:1.5rem; font-weight:500; color:var(--ink);">{testCount}</span>
            </li>
            <li style="display:flex; justify-content:space-between; align-items:baseline;">
              <span style="color:var(--ink-500); font-size:14px;">Enrolment fee</span>
              <span class="font-display" style="font-size:1.5rem; font-weight:500; color:var(--rust);">1 CHF</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SCHOOLS -->
  <section id="schools" style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1280px; margin:0 auto; padding:80px 28px;">
      <div style="margin-bottom:48px; max-width:48rem;">
        <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Academic structure</p>
        <h2 class="font-display" style="font-size:clamp(2rem, 4vw, 3.25rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500; margin:0 0 16px; color:var(--ink);">Six schools, one institution.</h2>
        <p style="font-family:'Inter Tight',sans-serif; font-size:17px; color:var(--ink-500); line-height:1.55; margin:0;">Each school is a working faculty: named instructors, peer-reviewed curriculum, weekly graded work, and proctored end-of-term examinations.</p>
      </div>
      <div style="display:grid; grid-template-columns:1fr; gap:16px;" class="schools-grid">
        {(schools.length > 0 ? schools : [
          { slug: 'computing-reasoning', code: 'SCR', name: 'School of Computing & Reasoning', tagline: 'Software, AI, systems, and the science of inference.' },
          { slug: 'mathematics-logic', code: 'SML', name: 'School of Mathematics & Logic', tagline: 'Foundations, applied maths, formal reasoning.' },
          { slug: 'liberal-arts', code: 'SLA', name: 'School of Liberal Arts', tagline: 'Philosophy, literature, history, languages.' },
          { slug: 'business-policy', code: 'SBP', name: 'School of Business & Policy', tagline: 'Strategy, economics, public policy, governance.' },
          { slug: 'design-communication', code: 'SDC', name: 'School of Design & Communication', tagline: 'Visual design, typography, narrative, media.' },
          { slug: 'foundations', code: 'SOF', name: 'School of Foundations', tagline: 'Interdisciplinary core across all schools.' },
        ]).map((s: any) => (
          <a href={'/aquintutor/schools/' + s.slug} style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:24px; text-decoration:none; color:var(--ink); display:flex; flex-direction:column; gap:14px; transition:border-color 0.2s, box-shadow 0.2s;" onmouseover="this.style.borderColor='var(--ink)';this.style.boxShadow='0 8px 24px rgba(11,14,20,0.06)';" onmouseout="this.style.borderColor='var(--rule)';this.style.boxShadow='none';">
            <div style="display:flex; align-items:center; justify-content:space-between; gap:8px;">
              <span style="display:inline-flex; align-items:center; justify-content:center; width:42px; height:42px; border-radius:8px; background:var(--sand-100); border:1px solid var(--rule);">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color:var(--ink);">
                  <path d={SCHOOL_ICONS[s.code] || 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z'}/>
                </svg>
              </span>
              <span style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink-500); font-weight:600;">{s.code}</span>
            </div>
            <div>
              <h3 class="font-display" style="font-size:1.3rem; font-weight:500; margin:0 0 8px; line-height:1.25; letter-spacing:-0.01em;">{s.name}</h3>
              <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); line-height:1.5; margin:0;">{s.tagline}</p>
            </div>
            <div style="margin-top:auto; display:flex; justify-content:space-between; align-items:center; padding-top:12px; border-top:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500);">
              <span>{s.course_count || 0} course{s.course_count === 1 ? '' : 's'}</span>
              <span style="color:var(--rust); font-weight:600;">Visit &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1280px; margin:0 auto; padding:80px 28px;">
      <div style="margin-bottom:48px; max-width:48rem;">
        <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">How a course is delivered</p>
        <h2 class="font-display" style="font-size:clamp(2rem, 4vw, 3.25rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500; margin:0; color:var(--ink);">Four steps from enrolment to credential.</h2>
      </div>
      <div style="display:grid; grid-template-columns:1fr; gap:24px;" class="method-grid">
        {[
          ['01', 'Instruction', 'Faculty-written lessons in 15-25 minute modules. Authored by named instructors, illustrated where it earns its keep, peer-reviewed before publication.'],
          ['02', 'Tutorial', 'A private AI tutor in every enrolment, grounded in the same syllabus. Escalates to a human teaching assistant when a question is genuinely open.'],
          ['03', 'Assessment', 'Problem sets, short essays, code, and laboratory exercises returned the same week with rubric-based feedback. Mastery, not memorisation.'],
          ['04', 'Credential', 'Midterm and final examinations proctored by ATLAS. Each passing credential publishes at a permanent URL that any employer can verify.'],
        ].map(([n, t, b]) => (
          <div style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:24px;">
            <p class="font-display" style="font-size:2rem; font-weight:500; color:var(--rust); margin:0 0 12px; line-height:1;">{n}</p>
            <h3 class="font-display" style="font-size:1.25rem; font-weight:500; margin:0 0 8px; letter-spacing:-0.01em;">{t}</h3>
            <p style="font-family:'Inter Tight',sans-serif; font-size:14.5px; color:var(--ink-500); line-height:1.55; margin:0;">{b}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED COURSES -->
  {featuredCourses.length > 0 && (
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:1280px; margin:0 auto; padding:80px 28px;">
        <div style="display:flex; justify-content:space-between; align-items:flex-end; gap:24px; flex-wrap:wrap; margin-bottom:40px;">
          <div style="max-width:42rem;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Current term</p>
            <h2 class="font-display" style="font-size:clamp(2rem, 4vw, 3.25rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500; margin:0; color:var(--ink);">Featured courses, open today.</h2>
          </div>
          <a href="/aquintutor/courses" style="font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; color:var(--rust); text-decoration:none;">See full catalogue &rarr;</a>
        </div>
        <div style="display:grid; grid-template-columns:1fr; gap:16px;" class="course-grid">
          {featuredCourses.map((c: any) => (
            <a href={'/aquintutor/courses/' + c.slug} style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:24px; text-decoration:none; color:var(--ink); display:flex; flex-direction:column; gap:12px;">
              <div style="display:flex; justify-content:space-between; gap:8px;">
                <span style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink-500); font-weight:600;">{c.course_code || (c.school_name || 'COURSE').toUpperCase().replace('SCHOOL OF ', '')}</span>
                <span style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink-500); font-weight:600;">{(c.level || 'BEGINNER').toUpperCase()}</span>
              </div>
              <h3 class="font-display" style="font-size:1.25rem; font-weight:500; margin:0; line-height:1.25; letter-spacing:-0.01em;">{c.title}</h3>
              {(c.subtitle || c.short_desc) && (
                <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); line-height:1.5; margin:0;">{c.subtitle || c.short_desc}</p>
              )}
              <div style="margin-top:auto; display:flex; justify-content:space-between; padding-top:12px; border-top:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500);">
                <span>{c.duration_weeks || 12}w &middot; {c.credit_hours || 3}cr</span>
                <span style="color:var(--rust); font-weight:600;">{c.is_free || c.pricing_model === 'free' ? 'Included' : 'Paid'}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- EXAMINATIONS / ATLAS -->
  {tests.length > 0 && (
    <section style="border-bottom:1px solid var(--rule); background:var(--ink); color:var(--sand-50);">
      <div style="max-width:1280px; margin:0 auto; padding:80px 28px;">
        <div style="display:flex; justify-content:space-between; align-items:flex-end; gap:24px; flex-wrap:wrap; margin-bottom:40px;">
          <div style="max-width:42rem;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--gold); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Examinations &middot; ATLAS proctored</p>
            <h2 class="font-display" style="font-size:clamp(2rem, 4vw, 3.25rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500; margin:0 0 16px; color:var(--sand-50);">Sit a real exam.</h2>
            <p style="font-family:'Inter Tight',sans-serif; font-size:16px; color:rgba(251,250,244,0.7); line-height:1.55; margin:0;">Every credential is backed by a real, monitored examination. ATLAS watches the tab, the face, the room - and never stores a single second of video.</p>
          </div>
        </div>
        <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="course-grid">
          {tests.slice(0, 3).map((t: any) => (
            <a href={'/aquintutor/test/' + t.slug} style="background:#14181d; border:1px solid #2a3038; border-radius:12px; padding:22px; text-decoration:none; color:var(--sand-50); display:flex; flex-direction:column; gap:12px;">
              <div style="display:flex; justify-content:space-between;">
                <span style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:rgba(251,250,244,0.55); font-weight:600;">{(t.test_type || 'EXAM').toUpperCase()}</span>
                <span style="font-family:'Inter Tight',sans-serif; font-size:11px; color:var(--gold); font-weight:600;">{t.duration_mins ? t.duration_mins + ' min' : ''}</span>
              </div>
              <h3 class="font-display" style="font-size:1.4rem; font-weight:500; margin:0; line-height:1.2;">{t.title}</h3>
              {t.description && <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:rgba(251,250,244,0.65); line-height:1.55; margin:0;">{t.description}</p>}
              <div style="margin-top:auto; padding-top:12px; border-top:1px solid #2a3038; display:flex; justify-content:space-between; font-family:'Inter Tight',sans-serif; font-size:12px; color:rgba(251,250,244,0.55);">
                <span>{t.question_count || 0} questions</span>
                <span style="color:var(--gold);">Begin &rarr;</span>
              </div>
            </a>
          ))}
        </div>
        <div style="margin-top:36px; text-align:center;">
          <a href="/aquintutor/test/quantum-challenge-100" style="display:inline-block; background:var(--rust); color:#fff; padding:14px 28px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Take the Quantum Challenge &rarr;</a>
        </div>
      </div>
    </section>
  )}

  <!-- ADMISSIONS CTA -->
  <section>
    <div style="max-width:1280px; margin:0 auto; padding:80px 28px; display:grid; grid-template-columns:1fr; gap:32px; align-items:center;" class="cta-grid">
      <div>
        <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Admissions are open</p>
        <h2 class="font-display" style="font-size:clamp(2rem, 4vw, 3.25rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500; margin:0 0 16px; color:var(--ink);">Apply for the current term.</h2>
        <p style="font-family:'Inter Tight',sans-serif; font-size:16px; color:var(--ink-500); line-height:1.55; margin:0; max-width:36rem;">A single one Swiss-franc enrolment opens the entire institution - every school, every department, every course. Proctored examinations are billed separately, only for credentials you choose to sit.</p>
      </div>
      <div style="display:flex; flex-direction:column; gap:10px; max-width:340px;">
        <a href="/aquintutor/signup" style="background:var(--ink); color:var(--sand-50); padding:16px 26px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none; text-align:center;">Apply &middot; 1 CHF &rarr;</a>
        <a href="/aquintutor/courses" style="background:transparent; color:var(--ink); padding:16px 26px; border-radius:6px; border:1px solid var(--ink); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none; text-align:center;">Browse the catalogue</a>
        <a href="/aquintutor/login" style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink-500); text-decoration:underline; text-align:center; padding:8px;">Already enrolled? Sign in</a>
      </div>
    </div>
  </section>

  <style>
    @media (min-width: 768px) {
      .hero-grid { grid-template-columns: 2fr 1fr !important; }
      .schools-grid { grid-template-columns: repeat(2, 1fr) !important; }
      .course-grid { grid-template-columns: repeat(2, 1fr) !important; }
      .method-grid { grid-template-columns: repeat(2, 1fr) !important; }
      .cta-grid { grid-template-columns: 2fr 1fr !important; }
    }
    @media (min-width: 1024px) {
