---
import '@/styles/aquintutor-academy.css';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

// ===== LIVE STATS =====
let testCount = 0, attemptCount = 0, courseCount = 0, lessonCount = 0, certCount = 0, enrolledCount = 0;
let tests: any[] = [];
let featuredCourses: any[] = [];

try {
  const r = await db.execute(sql`
    SELECT t.id, t.slug, t.title, t.description, t.test_type, t.duration_mins, t.difficulty,
      (SELECT COUNT(*)::int FROM test_questions WHERE test_id = t.id) as question_count,
      (SELECT COUNT(*)::int FROM test_attempts WHERE test_id = t.id AND status IN ('submitted','auto_submitted')) as attempt_count
    FROM tests t WHERE t.is_published = true
    ORDER BY t.created_at DESC LIMIT 6
  `);
  tests = Array.isArray(r) ? r : (r?.rows || []);
  testCount = tests.length;
  attemptCount = tests.reduce((s: any, t: any) => s + (t.attempt_count || 0), 0);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT c.slug, c.title, c.short_desc, c.level, c.category, c.duration_hours, c.is_free,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as lesson_count
    FROM training_courses c
    WHERE c.is_published = true AND c.access_type IN ('public', 'both')
    ORDER BY c.enrolled_count DESC NULLS LAST, c.created_at DESC LIMIT 6
  `);
  featuredCourses = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM training_courses WHERE is_published = true AND access_type IN ('public', 'both')`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  courseCount = (rows[0] as any)?.n || 0;
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM training_lessons l JOIN training_courses c ON l.course_id = c.id WHERE c.is_published = true`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  lessonCount = (rows[0] as any)?.n || 0;
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM training_certificates`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  certCount = (rows[0] as any)?.n || 0;
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT COUNT(DISTINCT user_id)::int as n FROM training_enrollments`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  enrolledCount = (rows[0] as any)?.n || 0;
} catch (_) {}

const SCHOOLS = [
  { code: 'SCR', name: 'School of Computing & Reasoning', desc: 'Software, AI, systems, and the science of inference.', cat: 'technology' },
  { code: 'SML', name: 'School of Mathematics & Logic', desc: 'Foundations, applied maths, formal reasoning.', cat: 'mathematics' },
  { code: 'SLA', name: 'School of Liberal Arts', desc: 'Philosophy, literature, history, languages.', cat: 'general' },
  { code: 'SBP', name: 'School of Business & Policy', desc: 'Strategy, economics, public policy, governance.', cat: 'business' },
  { code: 'SDC', name: 'School of Design & Communication', desc: 'Visual design, typography, narrative, media.', cat: 'design' },
  { code: 'SOF', name: 'School of Foundations', desc: 'Interdisciplinary core across all schools.', cat: 'general' },
];

const PHASES = [
  { num: 'I', label: 'Now', body: 'Marketing site, course catalogue, working enrolment, gamified assessments, certificate verification.' },
  { num: 'II', label: '6-18 months', body: 'AI tutor with course-context grounding, paid premium courses, faculty profiles, admin authoring tools.' },
  { num: 'III', label: '18-36 months', body: 'In-house proctoring, interactive simulations, voice tutor, mobile apps, qualifications recognition.' },
  { num: 'IV', label: '36+ months', body: 'Degree-granting status (UGC-DEB), generative real-time labs, holographic content for select courses.' },
];

const pageDesc = 'AquinTutor is a virtual institution by EduRankAI. ' + courseCount + ' open courses, ' + testCount + ' free assessments, ' + certCount + ' verifiable credentials. Built in Bharat.';
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: 'AquinTutor',
  url: 'https://www.edurankai.in/aquintutor',
  description: pageDesc,
  parentOrganization: { '@type': 'Organization', name: 'EduRankAI', url: 'https://www.edurankai.in' },
  foundingDate: '2026',
  foundingLocation: { '@type': 'Place', name: 'Bharat (India)' },
};
---
<!doctype html>
<html lang="en" class="academy">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>AquinTutor - A virtual institution by EduRankAI</title>
  <meta name="description" content={pageDesc} />
  <link rel="canonical" href="https://www.edurankai.in/aquintutor" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta property="og:title" content="AquinTutor - A virtual institution by EduRankAI" />
  <meta property="og:description" content={pageDesc} />
  <meta property="og:url" content="https://www.edurankai.in/aquintutor" />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#F5F1E8" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
</head>
<body class="academy editorial grain">

  <!-- Newspaper masthead -->
  <header style="border-bottom:1px solid var(--rule); background:rgba(251,250,244,0.85); backdrop-filter:blur(6px); position:relative; z-index:20;">
    <div style="border-bottom:1px solid rgba(11,14,20,0.08);">
      <div style="max-width:1400px; margin:0 auto; padding:8px 24px; display:flex; align-items:center; justify-content:space-between;" class="numplate" >
        <span style="color:var(--ink-500);">EST. MMXXVI &middot; AN INSTITUTION OF EDURANK&middot;AI</span>
        <span class="hide-mobile" style="color:var(--ink-500);">VOL. I &middot; NO. 001 &middot; A GLOBAL VIRTUAL UNIVERSITY</span>
        <span class="hide-mobile" style="color:var(--ink-500);">EN &middot; GLOBAL</span>
      </div>
    </div>
    <div style="max-width:1400px; margin:0 auto; padding:20px 24px; display:flex; align-items:center; justify-content:space-between;">
      <a href="/aquintutor" style="display:flex; align-items:baseline; gap:8px; text-decoration:none; color:var(--ink);">
        <span class="font-display" style="font-size:30px; font-weight:500; letter-spacing:-0.02em;">Aquin<span style="color:var(--rust);">Tutor</span></span>
        <span class="numplate" style="color:var(--ink-300);">.ai</span>
      </a>
      <nav class="hide-mobile" style="display:flex; align-items:center; gap:32px;" class="eyebrow">
        <a href="#schools" class="eyebrow" style="color:var(--ink-500); text-decoration:none;">Schools</a>
        <a href="/aquintutor/courses" class="eyebrow" style="color:var(--ink-500); text-decoration:none;">Courses</a>
        <a href="/aquintutor/paths" class="eyebrow" style="color:var(--ink-500); text-decoration:none;">Paths</a>
        <a href="/aquintutor/instructors" class="eyebrow" style="color:var(--ink-500); text-decoration:none;">Faculty</a>
      </nav>
      <div style="display:flex; align-items:center; gap:10px;">
        <a href="/portal/login" class="eyebrow" style="color:var(--ink-500); text-decoration:none; padding:8px 12px;">Sign in</a>
        <a href="/portal/signup" class="btn-pill filled" style="padding:10px 18px; font-size:11px;">Enrol</a>
      </div>
    </div>
  </header>

  <!-- HERO -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:64px 24px 48px;">
      <!-- Dateline -->
      <div style="display:flex; align-items:center; gap:16px; margin-bottom:40px;" class="numplate">
        <span style="height:1px; width:48px; background:var(--ink);"></span>
        <span style="color:var(--ink-500);">A NEW UNIVERSITY &middot; OPEN ENROLMENT &middot; {new Date().toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).toUpperCase()}</span>
      </div>

      <h1 class="font-display" style="font-size:clamp(3rem,9vw,9rem); line-height:0.92; letter-spacing:-0.025em; font-weight:500; margin:0;">
        A virtual institution,<br/>
        <span style="font-style:italic; font-weight:300; color:var(--ink-500);">honest by</span>
        <span style="color:var(--rust);"> design.</span>
      </h1>

      <div style="margin-top:40px; display:grid; grid-template-columns:1fr; gap:40px; align-items:end;" class="hero-grid">
        <div>
          <p class="font-serif" style="font-size:clamp(1.25rem, 2vw, 1.875rem); line-height:1.3; color:var(--ink-500); max-width:42rem; margin:0;">
            AquinTutor is a full-scale virtual institution with six schools, dozens of departments, and a private AI tutor in every course you take. Free where it matters. Built in Bharat for the world.
          </p>
        </div>
        <div style="display:flex; flex-direction:column; gap:14px; max-width:340px;">
          <a href="/aquintutor/courses" class="btn-pill filled" style="text-align:center;">Browse the catalogue &rarr;</a>
          <a href="/portal/signup" class="btn-pill outline" style="text-align:center;">Enrol &mdash; free to start</a>
        </div>
      </div>
    </div>

    <!-- Stats strip -->
    <div style="border-top:1px solid var(--rule); background:var(--sand-100);">
      <div style="max-width:1400px; margin:0 auto; padding:24px; display:grid; grid-template-columns:repeat(2,1fr); gap:20px;" class="stats-grid numplate">
        <div><span class="font-display" style="display:block; color:var(--ink); font-size:24px; font-weight:500;">{courseCount || 6}</span> <span style="color:var(--ink-500);">SCHOOLS &amp; PATHS</span></div>
        <div><span class="font-display" style="display:block; color:var(--ink); font-size:24px; font-weight:500;">{lessonCount || '10+'}</span> <span style="color:var(--ink-500);">LESSONS</span></div>
        <div><span class="font-display" style="display:block; color:var(--ink); font-size:24px; font-weight:500;">{testCount}</span> <span style="color:var(--ink-500);">LIVE TESTS</span></div>
        <div><span class="font-display" style="display:block; color:var(--ink); font-size:24px; font-weight:500;">FREE</span> <span style="color:var(--ink-500);">TO START</span></div>
      </div>
    </div>
  </section>

  <!-- § I - Thesis -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:96px 24px; display:grid; grid-template-columns:1fr; gap:40px;" class="thesis-grid">
      <div>
        <p class="eyebrow">&sect; I &mdash; Thesis</p>
        <p class="numplate" style="color:var(--ink-300); margin-top:8px;">001 / 005</p>
      </div>
      <div>
        <h2 class="font-display" style="font-size:clamp(3rem,7vw,7rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0;">
          The university was the right idea.<br/>
          <span style="font-style:italic; font-weight:300;">The price tag was not.</span>
        </h2>
        <p class="font-serif" style="font-size:1.5rem; color:var(--ink-500); margin-top:32px; max-width:48rem; line-height:1.3;">
          For nine hundred years, universities answered three questions: <em>what to study, how to study it, and who certifies that you did.</em> AquinTutor keeps the rigour, replaces the gatekeeping, and gives every enrolled student a tutor who never sleeps, never tires, and never marks you down for asking the obvious question.
        </p>
      </div>
    </div>
  </section>

  <!-- § II - The Six Schools -->
  <section style="border-bottom:1px solid var(--rule);" id="schools">
    <div style="max-width:1400px; margin:0 auto; padding:96px 24px;">
      <div style="display:grid; grid-template-columns:1fr; gap:40px; margin-bottom:64px;" class="thesis-grid">
        <div>
          <p class="eyebrow">&sect; II &mdash; Structure</p>
          <p class="numplate" style="color:var(--ink-300); margin-top:8px;">002 / 005</p>
        </div>
        <div>
          <h2 class="font-display" style="font-size:clamp(3rem,7vw,7rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0;">
            Six schools.<br/>
            <span style="font-style:italic; font-weight:300; color:var(--ink-500);">One institution.</span>
          </h2>
        </div>
      </div>

      <div style="display:grid; grid-template-columns:1fr; gap:1px; background:rgba(11,14,20,0.15); border:1px solid rgba(11,14,20,0.15);" class="schools-grid">
        {SCHOOLS.map((s, i) => (
          <a href={'/aquintutor/courses?cat=' + s.cat} class="tile">
            <div>
              <p class="numplate" style="color:var(--ink-300);">{String(i + 1).padStart(2, '0')} / 06</p>
              <h3 class="font-display" style="font-size:1.875rem; margin-top:16px; line-height:1.1; letter-spacing:-0.02em; font-weight:500;">{s.name}</h3>
            </div>
            <div>
              <p class="font-serif" style="font-size:1.25rem; font-style:italic; color:var(--ink-500); margin:0;">{s.desc}</p>
              <p class="arrow-hint">Visit &rarr;</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- § III - How a course works -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1400px; margin:0 auto; padding:96px 24px; display:grid; grid-template-columns:1fr; gap:40px;" class="thesis-grid">
      <div>
        <p class="eyebrow">&sect; III &mdash; Method</p>
        <p class="numplate" style="color:var(--ink-300); margin-top:8px;">003 / 005</p>
      </div>
      <div>
        <h2 class="font-display" style="font-size:clamp(3rem,7vw,7rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0 0 48px;">
          How a course<br/><span style="font-style:italic; font-weight:300;">works here.</span>
        </h2>
        <div style="display:grid; grid-template-columns:1fr; gap:40px;" class="method-grid">
          <div style="border-top:2px solid var(--ink); padding-top:24px;">
            <p class="numplate" style="color:var(--ink-500);">STEP 01</p>
            <h3 class="font-display" style="font-size:1.875rem; margin-top:8px; letter-spacing:-0.02em; font-weight:500;">Read &amp; watch.</h3>
            <p class="font-serif" style="font-size:1.25rem; color:var(--ink-500); margin-top:12px; line-height:1.3;">Each lesson is a tight 15&ndash;25 minutes. Written by faculty, illustrated where it earns its keep, never longer than it must be.</p>
          </div>
          <div style="border-top:2px solid var(--ink); padding-top:24px;">
            <p class="numplate" style="color:var(--ink-500);">STEP 02</p>
            <h3 class="font-display" style="font-size:1.875rem; margin-top:8px; letter-spacing:-0.02em; font-weight:500;">Talk to the tutor.</h3>
            <p class="font-serif" style="font-size:1.25rem; color:var(--ink-500); margin-top:12px; line-height:1.3;">Every course has a private AI tutor that knows the syllabus and the questions students get stuck on. Ask anything.</p>
          </div>
          <div style="border-top:2px solid var(--ink); padding-top:24px;">
            <p class="numplate" style="color:var(--ink-500);">STEP 03</p>
            <h3 class="font-display" style="font-size:1.875rem; margin-top:8px; letter-spacing:-0.02em; font-weight:500;">Practise weekly.</h3>
            <p class="font-serif" style="font-size:1.25rem; color:var(--ink-500); margin-top:12px; line-height:1.3;">Problem sets, short essays, code, lab work &mdash; graded the same week, with feedback you can actually act on.</p>
          </div>
          <div style="border-top:2px solid var(--ink); padding-top:24px;">
            <p class="numplate" style="color:var(--ink-500);">STEP 04</p>
            <h3 class="font-display" style="font-size:1.875rem; margin-top:8px; letter-spacing:-0.02em; font-weight:500;">Sit the exams.</h3>
            <p class="font-serif" style="font-size:1.25rem; color:var(--ink-500); margin-top:12px; line-height:1.3;">Midterm and final, proctored by ATLAS. Pass them and the credential is real, verifiable, and yours.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- § IV - Featured courses -->
  {featuredCourses.length > 0 && (
    <section style="border-bottom:1px solid var(--rule);" id="courses">
      <div style="max-width:1400px; margin:0 auto; padding:96px 24px;">
        <div style="display:grid; grid-template-columns:1fr; gap:40px; margin-bottom:64px;" class="thesis-grid">
          <div>
            <p class="eyebrow">&sect; IV &mdash; Begin</p>
            <p class="numplate" style="color:var(--ink-300); margin-top:8px;">004 / 005</p>
          </div>
          <div>
            <h2 class="font-display" style="font-size:clamp(3rem,7vw,7rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0;">
              Open today.<br/>
              <span style="font-style:italic; font-weight:300; color:var(--ink-500);">Free to start.</span>
            </h2>
          </div>
        </div>

        <div style="display:grid; grid-template-columns:1fr; gap:1px; background:rgba(11,14,20,0.15); border:1px solid rgba(11,14,20,0.15);" class="schools-grid">
          {featuredCourses.map((c: any) => (
            <a href={'/aquintutor/courses/' + c.slug} class="tile" style="padding:32px;">
              <div>
                <div style="display:flex; justify-content:space-between;" class="numplate">
                  <span style="color:var(--ink-300);">{c.code || 'COURSE'}</span>
                  <span style="color:var(--ink-300);">{(c.level || 'BEGINNER').toUpperCase()}</span>
                </div>
                <h3 class="font-display" style="font-size:1.75rem; margin-top:16px; line-height:1.1; letter-spacing:-0.02em; font-weight:500;">{c.title}</h3>
                <p class="font-serif" style="font-size:1.125rem; font-style:italic; color:var(--ink-500); margin-top:12px; line-height:1.3;">{c.short_desc || ''}</p>
              </div>
              <div style="margin-top:32px; padding-top:16px; border-top:1px solid var(--rule); display:flex; justify-content:space-between;" class="numplate">
                <span style="color:var(--ink-300);">{c.lesson_count || 0}L {c.duration_hours > 0 ? '· ' + c.duration_hours + 'H' : ''}</span>
                <span style="color:var(--ink-300);">{c.is_free ? 'FREE' : 'PAID'}</span>
              </div>
            </a>
          ))}
        </div>
        <div style="margin-top:48px; text-align:center;">
          <a href="/aquintutor/courses" class="btn-pill outline">See the full catalogue &rarr;</a>
        </div>
      </div>
    </section>
  )}

  <section class="ac-section ac-container" style="border-top:1px solid var(--ac-border);">
    <div class="ac-mb-8">
      <p class="ac-eyebrow ac-mb-3">Roadmap, publicly</p>
      <h2 class="ac-display ac-mb-4">What's built. <em class="ac-em">What's coming.</em></h2>
      <p class="ac-lead" style="max-width:640px;">We publish the roadmap so candidates, learners, and partners can hold us to it. No mystery boxes.</p>
    </div>
    <div class="ac-grid-3">
      {PHASES.map((p) => (
        <div class="ac-phase">
          <p class="ac-phase-num">{p.num}</p>
          <p class="ac-phase-label">{p.label}</p>
          <p class="ac-phase-body">{p.body}</p>
        </div>
      ))}
    </div>
  </section>

  {tests.length > 0 && (
    <section class="ac-section ac-container" id="tests" style="border-top:1px solid var(--ac-border);">
      <div class="ac-mb-8">
        <p class="ac-eyebrow ac-mb-3">Free assessments</p>
        <h2 class="ac-display ac-mb-4">Quick skill checks. <em class="ac-em">Gamified.</em></h2>
        <p class="ac-lead" style="max-width:640px;">Short, designed-to-feel-like-games tests. A temperature check before enrolling in a full course.</p>
      </div>
      <div class="ac-grid-3">
        {tests.map((t: any) => (
          <a href={'/aquintutor/test/' + t.slug} class="ac-course">
            <div class="ac-flex ac-gap-2 ac-mb-3">
              <span class="ac-pill ac-pill-indigo">{t.test_type || 'mixed'}</span>
              <span class="ac-pill">{t.difficulty || 'medium'}</span>
            </div>
            <h3 class="ac-course-title">{t.title}</h3>
            <p class="ac-course-desc">{t.description || ''}</p>
            <div class="ac-course-meta">
              <span>{t.duration_mins || 0} min</span>
              <span>{t.question_count || 0} questions</span>
              {(t.attempt_count > 0) && <span>{t.attempt_count} attempts</span>}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="ac-section ac-container" style="border-top:1px solid var(--ac-border);">
    <div class="ac-mb-8">
      <p class="ac-eyebrow ac-mb-3">The charter</p>
      <h2 class="ac-display">What we believe.</h2>
    </div>
    <div class="ac-grid-2">
      <div class="ac-principle">
        <h3>Truth over polish</h3>
        <p>Real curriculum, real assessment, real grading. No marketing rounded up to "world-class". Our roadmap publishes what's not done yet.</p>
      </div>
      <div class="ac-principle">
        <h3>Free where it matters</h3>
        <p>Foundational courses and most assessments stay free. Premium tracks pay for the infrastructure - they don't gate access to learning.</p>
      </div>
      <div class="ac-principle">
        <h3>Verifiable credentials</h3>
        <p>Every certificate links to a public URL anyone can verify. No login required to check authenticity. No PDFs floating around with fake signatures.</p>
      </div>
      <div class="ac-principle">
        <h3>Built in Bharat</h3>
        <p>Bharat-first content, Indic language support on the roadmap, regulator engagement (UGC-DEB) as a multi-year plan. Open to the world from the start.</p>
      </div>
    </div>
  </section>

  <!-- § V - Join (inverted) -->
  <section class="invert">
    <div style="max-width:1400px; margin:0 auto; padding:96px 24px; display:grid; grid-template-columns:1fr; gap:40px;" class="thesis-grid">
      <div>
        <p class="eyebrow" style="color:rgba(251,250,244,0.5);">&sect; V &mdash; Join</p>
        <p class="numplate" style="color:rgba(251,250,244,0.4); margin-top:8px;">005 / 005</p>
      </div>
      <div>
        <h2 class="font-display" style="font-size:clamp(3rem,7vw,7rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--sand-50);">
          The first cohort<br/>
          <span style="font-style:italic; font-weight:300; color:var(--gold);">is forming now.</span>
        </h2>
        <p class="font-serif" style="font-size:1.5rem; color:rgba(251,250,244,0.8); margin-top:24px; max-width:42rem; line-height:1.3;">
          Sign up for free, pick a course, start the first lesson. No payment, no contract, no commitment.
        </p>
