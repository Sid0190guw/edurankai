---
import '@/styles/aquintutor-academy.css';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

// ===== LIVE STATS =====
let testCount = 0, attemptCount = 0, courseCount = 0, lessonCount = 0, certCount = 0, enrolledCount = 0;
let tests: any[] = [];
let featuredCourses: any[] = [];

try {
  const r = await db.execute(sql`
    SELECT t.id, t.slug, t.title, t.description, t.test_type, t.duration_mins, t.difficulty,
      (SELECT COUNT(*)::int FROM test_questions WHERE test_id = t.id) as question_count,
      (SELECT COUNT(*)::int FROM test_attempts WHERE test_id = t.id AND status IN ('submitted','auto_submitted')) as attempt_count
    FROM tests t WHERE t.is_published = true
    ORDER BY t.created_at DESC LIMIT 6
  `);
  tests = Array.isArray(r) ? r : (r?.rows || []);
  testCount = tests.length;
  attemptCount = tests.reduce((s: any, t: any) => s + (t.attempt_count || 0), 0);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT c.slug, c.title, c.short_desc, c.level, c.category, c.duration_hours, c.is_free,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as lesson_count
    FROM training_courses c
    WHERE c.is_published = true AND c.access_type IN ('public', 'both')
    ORDER BY c.enrolled_count DESC NULLS LAST, c.created_at DESC LIMIT 6
  `);
  featuredCourses = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM training_courses WHERE is_published = true AND access_type IN ('public', 'both')`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  courseCount = (rows[0] as any)?.n || 0;
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM training_lessons l JOIN training_courses c ON l.course_id = c.id WHERE c.is_published = true`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  lessonCount = (rows[0] as any)?.n || 0;
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM training_certificates`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  certCount = (rows[0] as any)?.n || 0;
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT COUNT(DISTINCT user_id)::int as n FROM training_enrollments`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  enrolledCount = (rows[0] as any)?.n || 0;
} catch (_) {}

const SCHOOLS = [
  { code: 'SCR', name: 'School of Computing & Reasoning', desc: 'Software, AI, systems, and the science of inference.', cat: 'technology' },
  { code: 'SML', name: 'School of Mathematics & Logic', desc: 'Foundations, applied maths, formal reasoning.', cat: 'mathematics' },
  { code: 'SLA', name: 'School of Liberal Arts', desc: 'Philosophy, literature, history, languages.', cat: 'general' },
  { code: 'SBP', name: 'School of Business & Policy', desc: 'Strategy, economics, public policy, governance.', cat: 'business' },
  { code: 'SDC', name: 'School of Design & Communication', desc: 'Visual design, typography, narrative, media.', cat: 'design' },
  { code: 'SOF', name: 'School of Foundations', desc: 'Interdisciplinary core across all schools.', cat: 'general' },
];

const PHASES = [
  { num: 'I', label: 'Now', body: 'Marketing site, course catalogue, working enrolment, gamified assessments, certificate verification.' },
  { num: 'II', label: '6-18 months', body: 'AI tutor with course-context grounding, paid premium courses, faculty profiles, admin authoring tools.' },
  { num: 'III', label: '18-36 months', body: 'In-house proctoring, interactive simulations, voice tutor, mobile apps, qualifications recognition.' },
  { num: 'IV', label: '36+ months', body: 'Degree-granting status (UGC-DEB), generative real-time labs, holographic content for select courses.' },
];

const pageDesc = 'AquinTutor is a virtual institution by EduRankAI. ' + courseCount + ' open courses, ' + testCount + ' free assessments, ' + certCount + ' verifiable credentials. Built in Bharat.';
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: 'AquinTutor',
  url: 'https://www.edurankai.in/aquintutor',
  description: pageDesc,
  parentOrganization: { '@type': 'Organization', name: 'EduRankAI', url: 'https://www.edurankai.in' },
  foundingDate: '2026',
  foundingLocation: { '@type': 'Place', name: 'Bharat (India)' },
};
---
<!doctype html>
<html lang="en" class="academy">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>AquinTutor - A virtual institution by EduRankAI</title>
  <meta name="description" content={pageDesc} />
  <link rel="canonical" href="https://www.edurankai.in/aquintutor" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta property="og:title" content="AquinTutor - A virtual institution by EduRankAI" />
  <meta property="og:description" content={pageDesc} />
  <meta property="og:url" content="https://www.edurankai.in/aquintutor" />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#F5F1E8" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
</head>
<body class="academy">

  <nav class="ac-topbar">
    <div class="ac-topbar-inner">
      <a href="/aquintutor" class="ac-logo">
        <span class="aq-mark">Aquin</span>tutor
        <span class="ac-logo-sub">An institution of EduRankAI.in</span>
      </a>
      <div class="ac-topnav">
        <a href="/aquintutor/courses">Courses</a>
        <a href="/aquintutor/paths">Paths</a>
        <a href="/aquintutor/instructors">Faculty</a>
        <a href="#schools">Schools</a>
        <a href="/portal/login" class="ac-btn ac-cta" style="padding:9px 18px;min-height:0;font-size:12.5px;">Sign in</a>
      </div>
    </div>
  </nav>

  <section class="ac-section ac-hero ac-container">
    <p class="ac-eyebrow ac-mb-6">Established MMXXVI &middot; an institution of EduRankAI.in</p>
    <h1 class="ac-display ac-mb-6">
      A virtual institution.<br/>
      <em class="ac-em">Honest, by design.</em>
    </h1>
    <p class="ac-lead ac-mb-8">
      Open online courses, gamified assessments, verifiable credentials. Six schools across computing, mathematics, the liberal arts, business, design, and a foundational core. Free where possible. Built in Bharat.
    </p>
    <div class="ac-flex ac-wrap ac-gap-3" style="justify-content:center;">
      <a href="/aquintutor/courses" class="ac-btn">Browse courses</a>
      <a href="/portal/signup" class="ac-btn ac-btn-ghost">Create free account</a>
    </div>
  </section>

  <section class="ac-container" style="padding:8px 5vw 60px;">
    <div class="ac-stats">
      <div class="ac-stat"><p class="ac-stat-num">{courseCount}</p><p class="ac-stat-label">Courses</p></div>
      <div class="ac-stat"><p class="ac-stat-num">{lessonCount}</p><p class="ac-stat-label">Lessons</p></div>
      <div class="ac-stat"><p class="ac-stat-num">{testCount}</p><p class="ac-stat-label">Live tests</p></div>
      <div class="ac-stat"><p class="ac-stat-num">{enrolledCount}</p><p class="ac-stat-label">Enrolled</p></div>
      <div class="ac-stat"><p class="ac-stat-num">{certCount}</p><p class="ac-stat-label">Credentials</p></div>
      <div class="ac-stat"><p class="ac-stat-num" style="font-size:1.6rem;">Free</p><p class="ac-stat-label">Where possible</p></div>
    </div>
  </section>

  <section class="ac-section ac-container" id="schools" style="border-top:1px solid var(--ac-border);">
    <div class="ac-mb-8">
      <p class="ac-eyebrow ac-mb-3">The institution</p>
      <h2 class="ac-display ac-mb-4">Six schools, <em class="ac-em">one mission.</em></h2>
      <p class="ac-lead" style="max-width:640px;">Each school is anchored by an interdisciplinary core, taught with AI-augmented tutoring, and assessed in formats that reward understanding over memorisation.</p>
    </div>
    <div class="ac-grid-3">
      {SCHOOLS.map((s) => (
        <a href={'/aquintutor/courses?cat=' + s.cat} class="ac-school">
          <p class="ac-school-code">{s.code}</p>
          <h3 class="ac-school-name">{s.name}</h3>
          <p class="ac-school-desc">{s.desc}</p>
          <span class="ac-school-cta">Explore -&gt;</span>
        </a>
      ))}
    </div>
  </section>

  {featuredCourses.length > 0 && (
    <section class="ac-section ac-container" id="courses" style="border-top:1px solid var(--ac-border);">
      <div class="ac-mb-8">
        <p class="ac-eyebrow ac-mb-3">Featured courses</p>
        <h2 class="ac-display ac-mb-4">Start with one. <em class="ac-em">Stack the rest.</em></h2>
        <p class="ac-lead" style="max-width:640px;">Hand-picked from the open catalogue. Every completion issues a verifiable certificate.</p>
      </div>
      <div class="ac-grid-3">
        {featuredCourses.map((c: any) => (
          <a href={'/aquintutor/courses/' + c.slug} class="ac-course">
            <div class="ac-flex ac-gap-2 ac-mb-3">
              <span class="ac-pill ac-pill-amber">{c.level || 'beginner'}</span>
              {c.is_free && <span class="ac-pill ac-pill-leaf">Free</span>}
            </div>
            <h3 class="ac-course-title">{c.title}</h3>
            <p class="ac-course-desc">{c.short_desc || ''}</p>
            <div class="ac-course-meta">
              <span>{c.lesson_count || 0} lessons</span>
              {c.duration_hours > 0 && <span>{c.duration_hours}h</span>}
            </div>
          </a>
        ))}
      </div>
      <div class="ac-mt-6">
        <a href="/aquintutor/courses" class="ac-btn ac-btn-ghost">See all {courseCount} courses -&gt;</a>
      </div>
    </section>
  )}

  <section class="ac-section ac-container" style="border-top:1px solid var(--ac-border);">
    <div class="ac-mb-8">
      <p class="ac-eyebrow ac-mb-3">Roadmap, publicly</p>
      <h2 class="ac-display ac-mb-4">What's built. <em class="ac-em">What's coming.</em></h2>
      <p class="ac-lead" style="max-width:640px;">We publish the roadmap so candidates, learners, and partners can hold us to it. No mystery boxes.</p>
    </div>
    <div class="ac-grid-3">
      {PHASES.map((p) => (
        <div class="ac-phase">
          <p class="ac-phase-num">{p.num}</p>
          <p class="ac-phase-label">{p.label}</p>
          <p class="ac-phase-body">{p.body}</p>
        </div>
      ))}
    </div>
  </section>

  {tests.length > 0 && (
    <section class="ac-section ac-container" id="tests" style="border-top:1px solid var(--ac-border);">
      <div class="ac-mb-8">
        <p class="ac-eyebrow ac-mb-3">Free assessments</p>
        <h2 class="ac-display ac-mb-4">Quick skill checks. <em class="ac-em">Gamified.</em></h2>
        <p class="ac-lead" style="max-width:640px;">Short, designed-to-feel-like-games tests. A temperature check before enrolling in a full course.</p>
      </div>
      <div class="ac-grid-3">
        {tests.map((t: any) => (
          <a href={'/aquintutor/test/' + t.slug} class="ac-course">
            <div class="ac-flex ac-gap-2 ac-mb-3">
              <span class="ac-pill ac-pill-indigo">{t.test_type || 'mixed'}</span>
              <span class="ac-pill">{t.difficulty || 'medium'}</span>
            </div>
            <h3 class="ac-course-title">{t.title}</h3>
            <p class="ac-course-desc">{t.description || ''}</p>
            <div class="ac-course-meta">
              <span>{t.duration_mins || 0} min</span>
              <span>{t.question_count || 0} questions</span>
              {(t.attempt_count > 0) && <span>{t.attempt_count} attempts</span>}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="ac-section ac-container" style="border-top:1px solid var(--ac-border);">
    <div class="ac-mb-8">
      <p class="ac-eyebrow ac-mb-3">The charter</p>
      <h2 class="ac-display">What we believe.</h2>
    </div>
    <div class="ac-grid-2">
      <div class="ac-principle">
        <h3>Truth over polish</h3>
        <p>Real curriculum, real assessment, real grading. No marketing rounded up to "world-class". Our roadmap publishes what's not done yet.</p>
      </div>
      <div class="ac-principle">
        <h3>Free where it matters</h3>
        <p>Foundational courses and most assessments stay free. Premium tracks pay for the infrastructure - they don't gate access to learning.</p>
      </div>
      <div class="ac-principle">
        <h3>Verifiable credentials</h3>
        <p>Every certificate links to a public URL anyone can verify. No login required to check authenticity. No PDFs floating around with fake signatures.</p>
      </div>
      <div class="ac-principle">
        <h3>Built in Bharat</h3>
        <p>Bharat-first content, Indic language support on the roadmap, regulator engagement (UGC-DEB) as a multi-year plan. Open to the world from the start.</p>
      </div>
    </div>
  </section>

  <section class="ac-section ac-container ac-text-center" style="border-top:1px solid var(--ac-border);">
    <h2 class="ac-display ac-mb-4">Start with <em class="ac-em">one course.</em></h2>
    <p class="ac-lead ac-mb-6" style="max-width:560px;margin-left:auto;margin-right:auto;">No payment, no contract, no commitment. Sign in, pick a course, start the first lesson. Cancel by closing the tab.</p>
    <div class="ac-flex ac-wrap ac-gap-3" style="justify-content:center;">
      <a href="/aquintutor/courses" class="ac-btn">Browse all courses</a>
      <a href="/portal/signup" class="ac-btn ac-btn-ghost">Create free account</a>
    </div>
  </section>

  <footer class="ac-footer">
    <div class="ac-footer-inner">
      <p>Copyright {new Date().getFullYear()} AquinTutor &middot; An institution of <a href="/" style="text-decoration:underline;">EduRankAI.in</a></p>
      <div class="ac-flex ac-gap-4" style="flex-wrap:wrap;">
        <a href="/aquintutor/courses">Courses</a>
        <a href="/aquintutor/paths">Paths</a>
        <a href="/aquintutor/instructors">Faculty</a>
        <a href="/about">About</a>
        <a href="/p/privacy">Privacy</a>
        <a href="/p/terms">Terms</a>
        <a href="/contact">Contact</a>
      </div>
    </div>
  </footer>

</body>
</html>
