            <div style="margin-top:auto; padding-top:14px; border-top:1px solid var(--rule); display:flex; justify-content:space-between; gap:8px; font-family:'JetBrains Mono',monospace; font-size:11.5px; color:var(--ink-500); letter-spacing:0.04em;">
              <span>{s.dept_count} depts &middot; {s.course_count} courses</span>
