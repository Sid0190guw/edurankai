            <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 16px;">Featured faculty</p>
            <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:14px;">
              {faculty.slice(0,4).map((f: any) => (
                <li>
                  <a href={'/aquintutor/instructors/' + f.slug} style="display:flex; align-items:flex-start; gap:14px; text-decoration:none; color:var(--ink);">
                    <span style="display:inline-flex; align-items:center; justify-content:center; width:36px; height:36px; min-width:36px; border-radius:50%; background:var(--sand-100); color:var(--ink); font-family:'Fraunces',serif; font-weight:500; font-size:14px; border:1px solid var(--rule);">{(f.name || 'F').split(' ').slice(-1)[0][0]}</span>
                    <div style="font-family:'Inter Tight',sans-serif; line-height:1.35;">
                      <p style="margin:0; font-size:14.5px; font-weight:600; color:var(--ink);">{f.name}</p>
                      <p style="margin:2px 0 0; font-size:12.5px; color:var(--ink-500);">{f.title}</p>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
            <a href="/aquintutor/instructors" style="display:inline-block; margin-top:18px; font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--rust); text-decoration:underline; font-weight:500;">All {facultyCount} faculty members &rarr;</a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- FEATURED COURSES -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1320px; margin:0 auto; padding:72px 28px;">
      <div style="display:flex; align-items:end; justify-content:space-between; flex-wrap:wrap; gap:14px; margin-bottom:36px;">
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">The catalogue</p>
          <h2 class="font-display" style="font-size:clamp(1.85rem, 3.5vw, 2.85rem); line-height:1.08; letter-spacing:-0.02em; font-weight:500; margin:0; color:var(--ink);">
            Featured courses<br/>
            <span style="font-style:italic; font-weight:300; color:var(--ink-500);">for the autumn intake.</span>
          </h2>
        </div>
        <a href="/aquintutor/courses" style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink); text-decoration:none; font-weight:600; border-bottom:1px solid var(--ink); padding-bottom:2px;">Browse all {courseCount} courses &rarr;</a>
      </div>

      <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="courses-grid">
        {featuredCourses.slice(0,6).map((c: any) => (
          <a href={'/aquintutor/courses/' + c.slug} style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:0; text-decoration:none; color:var(--ink); display:flex; flex-direction:column; overflow:hidden; transition:transform 0.15s, box-shadow 0.15s;" class="course-card">
            <div style="height:5px; background:var(--rust);"></div>
            <div style="padding:22px 22px 18px; display:flex; flex-direction:column; gap:12px; flex:1;">
              <div style="display:flex; justify-content:space-between; gap:8px; font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.12em; color:var(--ink-500); text-transform:uppercase;">
                <span>{c.course_code || (c.level || 'GEN')}</span>
                <span style="color:var(--rust);">{c.school_code || 'SCR'}</span>
              </div>
              <h3 class="font-display" style="font-size:1.25rem; font-weight:500; margin:0; line-height:1.2; letter-spacing:-0.015em; color:var(--ink);">{c.title}</h3>
              {c.subtitle && <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1rem; line-height:1.4; color:var(--ink-500); margin:0;">{c.subtitle}</p>}
              {c.short_desc && <p style="font-family:'Inter Tight',sans-serif; font-size:13.5px; line-height:1.55; color:var(--ink-500); margin:0;">{c.short_desc.slice(0,140)}{c.short_desc.length > 140 ? '...' : ''}</p>}
              <div style="margin-top:auto; padding-top:14px; border-top:1px solid var(--rule); display:flex; justify-content:space-between; gap:8px; font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500);">
                <span>{c.lesson_count || 0} lessons</span>
                <span>{c.credit_hours ? c.credit_hours + ' credit hrs' : (c.duration_weeks ? c.duration_weeks + ' weeks' : '')}</span>
                <span style="color:var(--rust); font-weight:600;">{c.is_free ? 'Open' : 'Selective'}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ATLAS EXAMINATIONS - DARK BAND -->
  <section style="background:#0b0d10; color:#f4f1ea; border-bottom:1px solid #1a1f26; position:relative; overflow:hidden;">
    <!-- Decorative scanlines -->
    <div aria-hidden="true" style="position:absolute; inset:0; background:repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(255,255,255,0.015) 3px, rgba(255,255,255,0.015) 4px); pointer-events:none;"></div>

    <div style="max-width:1320px; margin:0 auto; padding:80px 28px; position:relative; z-index:1;">
      <div style="display:grid; grid-template-columns:1fr; gap:48px; align-items:start;" class="atlas-grid">
        <div>
          <p style="font-family:'JetBrains Mono',monospace; font-size:11px; color:#d97757; font-weight:600; letter-spacing:0.2em; text-transform:uppercase; margin:0 0 14px;"><span style="display:inline-block; width:6px; height:6px; border-radius:50%; background:#d97757; margin-right:8px; box-shadow:0 0 10px #d97757;"></span>ATLAS &middot; proctored examinations</p>
          <h2 class="font-display" style="font-size:clamp(1.85rem, 3.5vw, 2.85rem); line-height:1.08; letter-spacing:-0.02em; font-weight:500; margin:0 0 22px; color:#f4f1ea;">
            Examinations sit under<br/>
            <span style="font-style:italic; font-weight:300; color:#c8c3b8;">a live monitoring rig.</span>
          </h2>
          <p style="font-family:'Inter Tight',sans-serif; font-size:15.5px; line-height:1.65; color:#c8c3b8; margin:0 0 22px; max-width:36rem;">A 320&times;240 video feed runs face-api locally. A microphone analyser watches for voice activity. Tab focus, copy-paste, fullscreen exits, and network drops are recorded as text events. Nothing is uploaded - the candidate's bytes never leave the browser. Only events do.</p>
          <ul style="list-style:none; padding:0; margin:0 0 28px; display:flex; flex-direction:column; gap:8px;">
            {['Face presence + multiple-face detection','Voice activity envelope (no audio stored)','Tab focus, fullscreen, copy-paste','Network state + idle thresholds','Text-only event log; auditable by candidate'].map((l) => (
              <li style="display:flex; align-items:center; gap:10px; font-family:'Inter Tight',sans-serif; font-size:14px; color:#c8c3b8;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d97757" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <span>{l}</span>
              </li>
            ))}
          </ul>
          <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <a href="/aquintutor/test/quantum-challenge-100" style="background:#d97757; color:#1a0f08; padding:13px 22px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Sit the Quantum Challenge &rarr;</a>
            <a href="/aquintutor/about" style="background:transparent; color:#f4f1ea; padding:13px 22px; border-radius:6px; border:1px solid rgba(244,241,234,0.3); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Read the proctoring policy</a>
          </div>
        </div>

        <!-- Sample question + signals mock -->
        <div style="background:#161b22; border:1px solid #30363d; border-radius:14px; padding:20px; display:flex; flex-direction:column; gap:14px;">
          <div style="display:flex; align-items:center; justify-content:space-between; font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.16em; color:#c8c3b8;">
            <span>Q. 14 / 100</span>
            <span style="color:#a78bfa;">QUANTUM &middot; EASY &middot; 1 PT</span>
            <span>14 : 22</span>
          </div>
          <div style="background:#0d1117; border:1px solid #21262d; border-radius:10px; padding:16px 18px;">
            <p style="font-family:'Cormorant Garamond',serif; font-size:18px; line-height:1.4; color:#f4f1ea; margin:0;">Who proposed that radiation energy is emitted in discrete packets called <em>quanta</em>?</p>
          </div>
          <div style="display:flex; flex-direction:column; gap:8px;">
            {['Albert Einstein','Niels Bohr','Max Planck','Werner Heisenberg'].map((opt, i) => (
              <div style={'display:flex; align-items:center; gap:12px; padding:12px 16px; border-radius:10px; ' + (i === 2 ? 'background:rgba(217,119,87,0.14); border:1px solid #d97757;' : 'background:#0d1117; border:1px solid #21262d;')}>
                <span style={'display:inline-flex; align-items:center; justify-content:center; width:28px; height:28px; min-width:28px; border-radius:6px; font-family:JetBrains Mono,monospace; font-size:11px; font-weight:600; ' + (i === 2 ? 'background:#d97757; color:#1a0f08;' : 'background:#161b22; color:#c8c3b8; border:1px solid #30363d;')}>{String.fromCharCode(65 + i)}</span>
                <span style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:#f4f1ea;">{opt}</span>
              </div>
            ))}
          </div>
          <div style="display:grid; grid-template-columns:repeat(4, 1fr); gap:6px; margin-top:6px; padding-top:14px; border-top:1px solid #21262d; font-family:'JetBrains Mono',monospace; font-size:9.5px; letter-spacing:0.1em;">
            {[
              { l: 'GAZE', v: 'STEADY', c: '#7dd3a8' },
              { l: 'AUDIO', v: 'QUIET', c: '#7dd3a8' },
              { l: 'FOCUS', v: 'IN-TAB', c: '#7dd3a8' },
              { l: 'NET', v: 'ONLINE', c: '#7dd3a8' },
            ].map((s) => (
              <div>
                <p style="margin:0 0 3px; color:#7c828e; font-weight:600;">{s.l}</p>
                <p style="margin:0; color:var(--c); font-weight:600; display:flex; align-items:center; gap:4px;" set:html={'<span style="display:inline-block; width:5px; height:5px; border-radius:50%; background:' + s.c + ';"></span>' + s.v}></p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ACADEMIC CALENDAR / PRINCIPLES -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1320px; margin:0 auto; padding:72px 28px;">
      <div style="display:grid; grid-template-columns:1fr; gap:48px;" class="cal-grid">
        <!-- Calendar -->
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Academic calendar</p>
          <h2 class="font-display" style="font-size:clamp(1.5rem, 2.5vw, 2rem); font-weight:500; line-height:1.15; letter-spacing:-0.015em; margin:0 0 24px; color:var(--ink);">Key dates &middot; {monthLong} {yr}</h2>
          <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0; border-top:1px solid var(--rule);">
            {calendarItems.map((it) => (
              <li style="display:grid; grid-template-columns:130px 1fr auto; gap:14px; padding:16px 0; border-bottom:1px solid var(--rule); align-items:center;">
                <span style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.04em;">{it.d}</span>
                <span style="font-family:'Inter Tight',sans-serif; font-size:14.5px; color:var(--ink); font-weight:500;">{it.label}</span>
                <span style="font-family:'Inter Tight',sans-serif; font-size:10.5px; padding:3px 8px; background:var(--sand-100); border:1px solid var(--rule); border-radius:999px; color:var(--ink-500); letter-spacing:0.06em; text-transform:uppercase;">{it.kind}</span>
              </li>
            ))}
          </ul>
          <a href="/aquintutor/roadmap" style="display:inline-block; margin-top:18px; font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--rust); text-decoration:underline; font-weight:500;">Full institutional roadmap &rarr;</a>
        </div>

        <!-- Principles -->
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Operating principles</p>
          <h2 class="font-display" style="font-size:clamp(1.5rem, 2.5vw, 2rem); font-weight:500; line-height:1.15; letter-spacing:-0.015em; margin:0 0 24px; color:var(--ink);">What we do, in four lines</h2>
          <ol style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:18px; counter-reset:p;">
            {principles.map((p) => (
              <li style="display:grid; grid-template-columns:42px 1fr; gap:14px;">
                <span class="font-display" style="font-style:italic; font-weight:300; font-size:1.65rem; color:var(--rust); line-height:1; letter-spacing:-0.02em;">{p.n}</span>
                <div>
                  <p class="font-display" style="font-size:1.05rem; font-weight:500; margin:0 0 4px; line-height:1.25; color:var(--ink);">{p.title}</p>
                  <p style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink-500); line-height:1.55; margin:0;">{p.body}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- APPLICATION CTA -->
  <section style="background:var(--ink); color:var(--sand-50); border-bottom:1px solid var(--ink);">
    <div style="max-width:1200px; margin:0 auto; padding:72px 28px; display:grid; grid-template-columns:1fr; gap:32px; align-items:center;" class="cta-grid">
      <div>
        <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:#d97757; font-weight:600; letter-spacing:0.04em; margin:0 0 16px;">Open enrolment &middot; Autumn {yr}</p>
        <h2 class="font-display" style="font-size:clamp(2rem, 4vw, 3.25rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0 0 18px; color:var(--sand-50);">
          The application is<br/>
          <span style="font-style:italic; font-weight:300; color:rgba(251,250,244,0.65);">a name, an email, and a question.</span>
        </h2>
        <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.05rem, 1.4vw, 1.25rem); line-height:1.55; color:rgba(251,250,244,0.75); margin:0 0 28px; max-width:34rem;">Sit a twenty-minute AI-conducted screening interview in your language, or apply directly. There is no waiting list. There is no committee. There is just the work, named faculty, and a registrar who answers her own email.</p>
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
          <a href="/aquintutor/signup" style="background:#d97757; color:#1a0f08; padding:14px 26px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Apply for admission</a>
          <a href="/aquintutor/interview/general-screening" style="background:transparent; color:var(--sand-50); padding:14px 26px; border-radius:6px; border:1px solid rgba(251,250,244,0.4); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Take the screening interview</a>
        </div>
      </div>
      <div style="background:rgba(251,250,244,0.05); border:1px solid rgba(251,250,244,0.12); border-radius:14px; padding:24px;">
        <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.2em; color:rgba(251,250,244,0.5); margin:0 0 16px; font-weight:600;">RIGHT NOW</p>
        <dl style="display:grid; grid-template-columns:1fr auto; gap:10px 18px; margin:0; font-family:'Inter Tight',sans-serif; font-size:13.5px;">
          <dt style="color:rgba(251,250,244,0.65);">Enrolled students</dt><dd style="margin:0; color:var(--sand-50); font-weight:600; text-align:right;">{enrolledCount}</dd>
          <dt style="color:rgba(251,250,244,0.65); padding-top:8px; border-top:1px solid rgba(251,250,244,0.1);">Credentials issued</dt><dd style="margin:0; padding-top:8px; border-top:1px solid rgba(251,250,244,0.1); color:var(--sand-50); font-weight:600; text-align:right;">{certCount}</dd>
          <dt style="color:rgba(251,250,244,0.65); padding-top:8px; border-top:1px solid rgba(251,250,244,0.1);">Examinations sat</dt><dd style="margin:0; padding-top:8px; border-top:1px solid rgba(251,250,244,0.1); color:var(--sand-50); font-weight:600; text-align:right;">{examAttempts}</dd>
          <dt style="color:rgba(251,250,244,0.65); padding-top:8px; border-top:1px solid rgba(251,250,244,0.1);">Lessons in catalogue</dt><dd style="margin:0; padding-top:8px; border-top:1px solid rgba(251,250,244,0.1); color:var(--sand-50); font-weight:600; text-align:right;">{lessonCount}</dd>
          <dt style="color:rgba(251,250,244,0.65); padding-top:8px; border-top:1px solid rgba(251,250,244,0.1);">Faculty</dt><dd style="margin:0; padding-top:8px; border-top:1px solid rgba(251,250,244,0.1); color:var(--sand-50); font-weight:600; text-align:right;">{facultyCount}</dd>
        </dl>
      </div>
    </div>
  </section>

  <!-- MASTHEAD CLOSING -->
  <section>
    <div style="max-width:1200px; margin:0 auto; padding:64px 28px 80px; display:grid; grid-template-columns:1fr; gap:24px; align-items:center;" class="footer-thesis">
      <div>
        <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 10px;">Correspondence</p>
        <h2 class="font-display" style="font-size:clamp(1.5rem, 2.2vw, 1.85rem); font-weight:500; line-height:1.18; letter-spacing:-0.015em; margin:0 0 14px; color:var(--ink);">Write to the registrar.</h2>
        <p style="font-family:'Inter Tight',sans-serif; font-size:14.5px; color:var(--ink-500); line-height:1.6; margin:0 0 14px; max-width:34rem;">Questions about admissions, faculty, accreditation, or institutional partnerships go to <a href="mailto:hr@edurankai.in" style="color:var(--rust); text-decoration:underline;">hr@edurankai.in</a>. We answer within five working days.</p>
      </div>
      <div style="display:flex; gap:10px; flex-wrap:wrap; justify-self:end;" class="footer-cta">
        <a href="/aquintutor/about" style="background:transparent; color:var(--ink); padding:11px 20px; border-radius:6px; border:1px solid var(--ink); font-family:'Inter Tight',sans-serif; font-size:13.5px; font-weight:600; text-decoration:none;">About</a>
        <a href="/aquintutor/roadmap" style="background:transparent; color:var(--ink); padding:11px 20px; border-radius:6px; border:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:13.5px; font-weight:600; text-decoration:none;">Roadmap</a>
        <a href="/aquintutor/universe" style="background:transparent; color:var(--ink); padding:11px 20px; border-radius:6px; border:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:13.5px; font-weight:600; text-decoration:none;">Research</a>
      </div>
    </div>
  </section>

  <style>
    .ticker::-webkit-scrollbar { display: none; }
    .ticker { scrollbar-width: none; }
    .school-tile:hover { background: var(--sand-100); }
    .course-card:hover { transform: translateY(-2px); box-shadow: 0 6px 24px rgba(11,14,20,0.08); }
    @media (min-width: 768px) {
      .hero-grid { grid-template-columns: 1.7fr 1fr !important; padding-left: 80px !important; }
      .thesis-grid { grid-template-columns: 1fr 1fr !important; }
      .thesis-rhs { justify-self: end; }
      .schools-grid { grid-template-columns: repeat(2, 1fr) !important; }
      .how-grid { grid-template-columns: repeat(4, 1fr) !important; }
      .quote-grid { grid-template-columns: 1.6fr 1fr !important; }
      .courses-grid { grid-template-columns: repeat(2, 1fr) !important; }
      .atlas-grid { grid-template-columns: 1fr 1fr !important; }
      .cal-grid { grid-template-columns: 1.3fr 1fr !important; }
      .cta-grid { grid-template-columns: 1.5fr 1fr !important; }
      .footer-thesis { grid-template-columns: 1fr auto !important; }
    }
    @media (min-width: 1100px) {
      .schools-grid { grid-template-columns: repeat(3, 1fr) !important; }
      .courses-grid { grid-template-columns: repeat(3, 1fr) !important; }
    }
  </style>
</AquintutorLayout>
