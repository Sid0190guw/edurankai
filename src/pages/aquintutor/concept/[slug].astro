---
// /aquintutor/concept/[slug] — a lightweight, deep-linkable concept visualiser.
// Any lesson, lab, or the Aquin Co-pilot can link here to open a specific topic
// as a live animation with its own controls. Powered by the SAME shared engine
// as the Animation Studio and the Co-pilot demo (public/aquintutor-animator-engine.js)
// so there is exactly one renderer to maintain. Rural-first: pure canvas, no
// libraries, adaptive canvas size, works on a low-end phone.
const { slug } = Astro.params;
const topic = (slug || '').replace(/-/g, ' ');
// Short teacher-facing explainers keyed by scene id — kept here (not fabricated
// "usage data"), just concise plain-language framing shown alongside the visual.
const EXPLAIN: Record<string, string> = {
  waves: 'Two wave sources overlap. Where crests meet crests the wave adds (constructive); where a crest meets a trough they cancel (destructive). The bright and dark bands are the interference pattern.',
  lorenz: 'A simple set of three equations produces motion that never repeats and is exquisitely sensitive to starting conditions — the classic example of deterministic chaos.',
  dblpend: 'Two pendulums joined end to end. The equations are exact, yet the motion is chaotic: a tiny change in the start leads to a completely different path (the trail).',
  mandelbrot: 'For each point c, iterate z → z² + c. Points that stay bounded are inside the set (black); the colours show how fast the rest escape. Infinite detail at every zoom.',
  julia: 'Like the Mandelbrot set but with c fixed and the starting point varied. Each c gives a different, self-similar fractal.',
  particles: 'Thousands of particles follow an invisible flow field (curl noise), tracing streamlines — a cheap, beautiful model of fluid-like motion.',
  gol: "Conway's Game of Life: four simple birth/death rules on a grid produce gliders, oscillators, and complex emergent structure from nothing.",
  tree: 'A recursive rule — a branch splits into two smaller branches at a fixed angle — repeated to many depths produces a natural-looking tree (an L-system).',
  wavepkt: 'A quantum wave packet: the real and imaginary parts of the wavefunction oscillate while |ψ|² (the probability of finding the particle) travels and spreads.',
  vector: 'A vector field assigns a little arrow to every point in space — the foundation of fluid flow, electromagnetism, and gradient descent.',
  turing: "A reaction–diffusion system (Alan Turing's morphogenesis model): two chemicals spreading and reacting spontaneously form spots and stripes like animal coats.",
  galaxy: 'Stars on nested orbits with slightly different speeds naturally wind into spiral arms — density waves, not fixed structures.',
  pendcascade: 'Pendulums of gradually increasing length swing at different rates; they briefly fall into and out of sync, producing travelling-wave patterns.',
  phyllotaxis: 'Placing each new seed at the golden angle (137.5°) from the last packs them with no gaps — exactly how sunflowers and pinecones arrange their florets.',
  mobius: 'A surface with only one side and one edge. Follow the strip and you return to the start having visited "both" faces — a first taste of topology.',
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Concept visualiser · AquinTutor</title>
  <meta name="robots" content="noindex" />
  <style>
    :root { --bg:#08080a; --panel:#0f1117; --stroke:#232633; --ink:#e8e8ee; --mut:#8a93a6; --accent:#67e8f9; }
    * { box-sizing:border-box; }
    body { margin:0; background:var(--bg); color:var(--ink); font-family:'Inter Tight',system-ui,-apple-system,sans-serif; }
    .top { display:flex; align-items:center; gap:14px; padding:12px 16px; border-bottom:1px solid var(--stroke); background:var(--panel); }
    .top a { color:var(--accent); text-decoration:none; font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.06em; }
    .top h1 { font-size:15px; font-weight:600; margin:0; }
    .top .cat { margin-left:auto; font-family:'Geist Mono',monospace; font-size:10px; text-transform:uppercase; letter-spacing:0.12em; color:var(--mut); }
    .wrap { display:grid; grid-template-columns:minmax(0,1fr) 300px; gap:0; min-height:calc(100vh - 49px); }
    .stage { position:relative; display:flex; align-items:center; justify-content:center; background:#000; overflow:hidden; }
    #cv { max-width:100%; max-height:100%; display:block; }
    .side { background:var(--panel); border-left:1px solid var(--stroke); padding:18px; overflow-y:auto; }
    .explain { font-size:13.5px; line-height:1.65; color:#cfd6df; margin:0 0 18px; }
    .h4 { font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.16em; text-transform:uppercase; color:var(--accent); font-weight:700; margin:16px 0 10px; padding-top:14px; border-top:1px solid var(--stroke); }
    .h4:first-of-type { border-top:none; padding-top:0; }
    .row { margin-bottom:13px; }
    .row label { display:flex; justify-content:space-between; font-family:'Geist Mono',monospace; font-size:10px; color:var(--mut); margin-bottom:5px; }
    .row label b { color:var(--accent); font-weight:600; }
    .row input[type=range] { width:100%; accent-color:var(--accent); }
    .btns { display:flex; gap:8px; margin-bottom:14px; }
    .btns button { flex:1; background:#1a1e29; border:1px solid var(--stroke); color:var(--ink); padding:9px; border-radius:8px; font-size:12px; font-weight:600; cursor:pointer; font-family:inherit; }
    .btns button:hover { border-color:var(--accent); color:var(--accent); }
    .pal { display:grid; grid-template-columns:repeat(6,1fr); gap:5px; }
    .sw { aspect-ratio:1; border-radius:5px; cursor:pointer; border:1px solid var(--stroke); }
    .sw.on { border:2px solid var(--accent); }
    .miss { padding:40px 18px; text-align:center; }
    .miss h2 { font-size:20px; margin:0 0 8px; }
    .miss p { color:var(--mut); font-size:13px; line-height:1.6; }
    .chip { display:inline-block; background:#12303a; border:1px solid #1c4a5a; color:var(--accent); font-size:12px; padding:5px 11px; border-radius:100px; margin:4px; cursor:pointer; text-decoration:none; }
    @media (max-width:820px){ .wrap{ grid-template-columns:1fr; } .stage{ min-height:52vh; } .side{ border-left:none; border-top:1px solid var(--stroke); } }
  </style>
</head>
<body>
  <div class="top">
    <a href="/aquintutor/labs">&larr; Labs</a>
    <h1 id="title">Concept</h1>
    <span class="cat" id="cat"></span>
  </div>

  <div class="wrap" id="root">
    <div class="stage"><canvas id="cv" width="960" height="600"></canvas></div>
    <aside class="side">
      <p class="explain" id="explain"></p>
      <div class="btns">
        <button id="playBtn">Pause</button>
        <button id="resetBtn">Restart</button>
      </div>
      <div class="h4">Parameters</div>
      <div id="controls"></div>
      <div class="h4">Palette</div>
      <div class="pal" id="pal"></div>
      <div class="h4">More concepts</div>
      <div id="more"></div>
    </aside>
  </div>

  <script is:inline src="/aquintutor-animator-engine.js"></script>
  <script is:inline define:vars={{ topic, explainMap: EXPLAIN }}>
    (function () {
      var A = window.AquinAnimator;
      var root = document.getElementById('root');
      var scene = A ? A.findScene(topic) : null;

      if (!scene) {
        root.innerHTML = '<div class="miss"><h2>No visual for &ldquo;' + (topic || '') + '&rdquo; yet</h2>'
          + '<p>This build renders ' + (A ? A.SCENES.length : 0) + ' concepts. Open one:</p><div id="chips"></div></div>';
        if (A) document.getElementById('chips').innerHTML = A.SCENES.map(function (s) {
          return '<a class="chip" href="/aquintutor/concept/' + s.keywords[0].replace(/ /g, '-') + '">' + s.label + '</a>';
        }).join('');
        return;
      }

      // Adaptive canvas: shrink render resolution on small screens / low DPR so a
      // low-end phone stays smooth (rural-first). Retina desktops get crisper.
      var cv = document.getElementById('cv');
      var small = window.matchMedia('(max-width: 820px)').matches;
      cv.width = small ? 640 : 960;
      cv.height = small ? 420 : 600;

      document.getElementById('title').textContent = scene.label;
      document.getElementById('cat').textContent = scene.cat;
      document.getElementById('explain').textContent = explainMap[scene.id] || (scene.label + ' — live procedural visualisation.');

      var ctrl = A.attach(cv, scene, { palette: 'cool', speed: 1 });

      // Parameter sliders (the scene's own controls, live)
      var cwrap = document.getElementById('controls');
      (scene.controls || []).forEach(function (c) {
        var row = document.createElement('div'); row.className = 'row';
        row.innerHTML = '<label>' + c.label + ' <b id="v_' + c.id + '">' + c.value + '</b></label>'
          + '<input type="range" id="c_' + c.id + '" min="' + c.min + '" max="' + c.max + '" step="' + c.step + '" value="' + c.value + '">';
        cwrap.appendChild(row);
        row.querySelector('input').addEventListener('input', function () {
          ctrl.setParam(c.id, parseFloat(this.value));
          document.getElementById('v_' + c.id).textContent = this.value;
        });
      });

      // Play / restart
      var playing = true;
      document.getElementById('playBtn').addEventListener('click', function () { playing = !playing; if (playing) ctrl.play(); else ctrl.pause(); this.textContent = playing ? 'Pause' : 'Play'; });
      // Accessibility (Rendering Runtime "calm-first" principle + WCAG 2.3.3): don't
      // auto-play motion for a learner who asked for reduced motion — start paused,
      // let them opt in. The concept's text explanation is already shown alongside.
      if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        ctrl.pause(); playing = false; document.getElementById('playBtn').textContent = 'Play';
      }
      document.getElementById('resetBtn').addEventListener('click', function () { ctrl.destroy(); ctrl = A.attach(cv, scene, { palette: curPal, speed: 1 }); playing = true; document.getElementById('playBtn').textContent = 'Pause'; });

      // Palette
      var curPal = 'cool';
      var pal = document.getElementById('pal');
      Object.keys(A.palettes).forEach(function (name) {
        var sw = document.createElement('div'); sw.className = 'sw' + (name === curPal ? ' on' : ''); sw.title = name;
        sw.style.background = 'linear-gradient(135deg,' + A.palettes[name].slice(0, 4).join(',') + ')';
        sw.addEventListener('click', function () { curPal = name; ctrl.setPalette(name); pal.querySelectorAll('.sw').forEach(function (x) { x.classList.remove('on'); }); sw.classList.add('on'); });
        pal.appendChild(sw);
      });

      // Related concepts
      document.getElementById('more').innerHTML = A.SCENES.filter(function (s) { return s.id !== scene.id; }).slice(0, 6).map(function (s) {
        return '<a class="chip" href="/aquintutor/concept/' + s.keywords[0].replace(/ /g, '-') + '">' + s.label + '</a>';
      }).join('');
    })();
  </script>
</body>
</html>
