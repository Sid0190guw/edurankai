---
// /aquintutor/study-calendar — a student's study calendar (Prompt 19, main surface). Real deadlines
// from enrolled courses + a personal ICS subscribe URL. Server-rendered, ultra-light.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { studentCalendar, calToken } from '@/lib/calendar';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/study-calendar');
const events = await studentCalendar(user.id).catch(() => []);
const feedUrl = new URL('/aquintutor/calendar/feed.ics?u=' + user.id + '&t=' + calToken(user.id), Astro.url.origin).toString();
function fmt(d: any) { try { return new Date(d).toLocaleString('en-IN', { weekday: 'short', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); } catch { return '-'; } }
const kindColor: Record<string, string> = { assessment: 'var(--rust,#b3541e)', exam: '#9b2c2c', lesson: '#5a5aa8' };
const CARD = 'background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:14px;padding:20px 22px;margin-bottom:16px;';
---
<AquintutorLayout title="Study calendar">
  <main style="max-width:720px;margin:0 auto;padding:44px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Calendar</p>
    <h1 style="font-family:Fraunces,serif;font-size:32px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 18px;line-height:1.15;">Your study calendar</h1>

    <div style={CARD}>
      <h2 style="font-family:Fraunces,serif;font-size:17px;font-weight:600;margin:0 0 8px;">Subscribe</h2>
      <p style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#6b6455;margin:0 0 8px;">Add this URL as a subscribed calendar in Google / Apple / Outlook to keep your deadlines in sync.</p>
      <code style="display:block;font-family:'Geist Mono',monospace;font-size:11.5px;background:#faf8f2;border:1px solid var(--line,#e6e1d6);border-radius:8px;padding:9px 12px;word-break:break-all;color:var(--ink,#1a1712);">{feedUrl}</code>
    </div>

    <div style={CARD}>
      <h2 style="font-family:Fraunces,serif;font-size:17px;font-weight:600;margin:0 0 12px;">Upcoming deadlines</h2>
      {events.length === 0 ? <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#6b6455;margin:0;">No deadlines on your enrolled courses yet.</p> :
        events.map((e: any) => (
          <div style="display:flex;align-items:center;gap:12px;padding:9px 0;border-bottom:1px solid #f0ece2;">
            <span style={'width:8px;height:8px;border-radius:50%;background:' + (kindColor[e.kind] || '#8a8478') + ';flex-shrink:0;'}></span>
            <span style="flex:1;font-family:'Inter Tight',sans-serif;font-size:14.5px;color:var(--ink,#1a1712);">{e.title}{e.course_title ? ' · ' + e.course_title : ''}</span>
            <span style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#8a8478;white-space:nowrap;">{fmt(e.due_at)}</span>
          </div>
        ))}
    </div>
  </main>
</AquintutorLayout>
