---
// /aquintutor/aes — AquinTutor Engineering Specification (AES) overview. A presentation-grade map of
// the AES volumes (from the AES-100 specification books) to the subsystems ACTUALLY shipped in the
// platform, with live links. Honest status: "Live" = realized + running; "Spec" = specified;
// "Vision" = forward architecture. Public + server-rendered (frictionless to present).
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { specStats, volumeSummary, searchModules, roman } from '@/lib/aes-spec';

const OBJECTS = ['KnowledgeObject', 'StudentObject', 'FacultyObject', 'CourseObject', 'ConceptObject', 'LaboratoryObject', 'SimulationObject', 'AnimationObject', 'AssessmentObject', 'UniversityObject', 'PlacementObject', 'ResearchObject'];

const VOLUMES = [
  { n: 'I', title: 'Educational Operating Kernel (EOK)', gist: 'Everything is an object; every subsystem talks only through the kernel — security, audit, extensibility.', status: 'Live', realized: 'Unified object kernel (kernel_objects + 12 typed objects, KernelRepository, relationships).', href: '/admin/knowledge' },
  { n: 'II', title: 'Runtime Engineering', gist: 'The educational runtime: estimate the learner, assemble the right variant, render adaptively, offline + sync.', status: 'Live', realized: 'Adaptive runtime pipeline (device/network tiers, render policy, offline packages, knowledge-delta sync).', href: '/admin/learning' },
  { n: 'III–V', title: 'Foundation, Access & Integrity', gist: 'Identity, permissions, records, backup and observability — the trustworthy substrate.', status: 'Live', realized: 'Multi-method auth, server-side RBAC + audit, academic records, backup/integrity, observability.', href: '/admin/rbac' },
  { n: 'VI', title: 'Artificial Intelligence & Cognitive Computing', gist: 'Foundation-model gateway, autonomous reasoning, knowledge engineering, human–AI collaboration.', status: 'Live', realized: 'LLM gateway (own/Claude), grounded AI tutor "Ask Aquin", speech → animation, LLM scene composition.', href: '/aquintutor/board' },
  { n: 'VII', title: 'Trust, Proctoring & Credentialing', gist: 'Verifiable learning, examination integrity, tamper-evident credentials.', status: 'Live', realized: 'ATLAS proctoring (advisory), verifiable course credentials, assessment engine.', href: '/admin/credentials' },
  { n: 'VIII', title: 'AGI, Cognitive Systems & Civilization Intelligence', gist: 'Constitutional cognitive architecture and human-level intelligence engineering.', status: 'Spec', realized: 'Realized slice: adaptive per-learner tiers + verified-learning / Socratic / productive-failure model.', href: '/aquintutor/board/live' },
  { n: 'IX', title: 'Superintelligence Infrastructure & AI Governance', gist: 'Universal intelligence operating systems, AI governance, trust engineering, global deployment.', status: 'Spec', realized: 'Realized slice: swap-ready transport/gateway/queue interfaces + governance (RBAC, audit, moderation).', href: '/aquintutor/moderate' },
  { n: 'X', title: 'Governance, Policy & Public Administration Systems', gist: 'National policy platforms, governance strategy analytics, constitutional policy engineering.', status: 'Vision', realized: 'Forward architecture. Grounded today in institution/partner governance + policy-safe platform language.', href: null },
  { n: 'XI', title: 'Space, Frontier Sciences & Future Civilization', gist: 'Space governance, interplanetary infrastructure, frontier-technology architectures.', status: 'Vision', realized: 'Forward architecture in the specification series.', href: null },
  { n: 'XII', title: 'Universal Infrastructure & Meta-Civilization Engineering', gist: 'Universal civilizational knowledge infrastructure, infinite systems engineering.', status: 'Vision', realized: 'Forward architecture in the specification series.', href: null },
];

const LIVE = [
  { name: 'Live teaching board', href: '/aquintutor/board', note: 'Parametric + WebGL scenes, speech-driven, broadcast as spec' },
  { name: 'Student live view', href: '/aquintutor/board/live', note: 'Renders locally at each learner’s quality tier' },
  { name: 'Live rooms & breakouts', href: '/portal/meet', note: 'In-huddle animation, presenter roles, class mode' },
  { name: 'Mass broadcast', href: '/aquintutor/broadcast', note: 'One teacher to many; pull player + spec fan-out' },
  { name: 'Recordings & VOD', href: '/aquintutor/vod', note: 'Replays re-render the spec timeline at your tier' },
  { name: 'Moderation & safety', href: '/aquintutor/moderate', note: 'Real-time, minor-safe, guardian alerts' },
  { name: 'Plans & billing', href: '/aquintutor/billing', note: 'Paid access gating, guardian-authorized' },
  { name: 'Language & access', href: '/aquintutor/language', note: 'i18n + RTL + WCAG AA accessibility' },
];

const chip = (s: string) => s === 'Live' ? { bg: '#eef8f1', fg: '#2f7d5b', label: 'Live in platform' } : s === 'Spec' ? { bg: '#fdf6ee', fg: '#b3541e', label: 'Specified' } : { bg: '#f2efe8', fg: '#8a8378', label: 'Vision' };
const live = VOLUMES.filter((v) => v.status === 'Live').length;

// The specification itself, parsed from the AES-100 books: every module is browsable.
const stats = specStats();
const volumes = volumeSummary();
const q = (Astro.url.searchParams.get('q') || '').trim();
const results = searchModules(q, 60);
---
<AquintutorLayout title="AquinTutor Engineering Specification">
  <main>
    <!-- hero — editorial grid: headline + stat plate, matching the institution's front page -->
    <section style="border-bottom:1px solid var(--rule); position:relative; overflow:hidden;">
      <div aria-hidden="true" style="position:absolute; left:0; top:0; bottom:0; width:48px; display:flex; flex-direction:column; align-items:center; justify-content:space-between; padding:36px 0; font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.4em; color:var(--ink-500); writing-mode:vertical-rl; text-orientation:mixed;" class="hide-mobile">
        <span>AES&middot;100</span><span>SPECIFICATION</span>
      </div>
      <div style="max-width:1320px; margin:0 auto; padding:72px 28px 64px; display:grid; grid-template-columns:1fr; gap:48px; align-items:end;" class="hero-grid">
        <div>
          <p style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.2em; text-transform:uppercase; color:var(--rust); font-weight:600; margin:0 0 20px;">The engineering specification</p>
          <h1 class="font-display" style="font-size:clamp(2.6rem, 7vw, 5.75rem); line-height:0.96; letter-spacing:-0.028em; font-weight:500; margin:0; color:var(--ink);">
            Not a course platform.<br/>
            <span style="font-style:italic; font-weight:300; color:var(--ink-500);">An educational</span><br/>
            operating system.
          </h1>
          <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-size:clamp(1.15rem, 1.5vw, 1.4rem); line-height:1.5; font-style:italic; color:var(--ink-500); margin:30px 0 0; max-width:38rem;">
            Every learning entity is an object. Every subsystem is coordinated through one kernel. This is the blueprint &mdash; and precisely how much of it is already running.
          </p>
          <div style="display:flex; gap:14px; flex-wrap:wrap; margin-top:34px;">
            <a href="#specification" style="background:var(--ink); color:var(--sand-50); padding:14px 26px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Browse all {stats.modules} modules</a>
            <a href="/aquintutor/board" style="background:transparent; color:var(--ink); padding:14px 26px; border-radius:6px; border:1px solid var(--ink); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">See it running</a>
          </div>
        </div>

        <aside style="background:var(--sand-100); border:1px solid var(--rule); border-radius:14px; padding:28px 28px 22px; position:relative;" class="stat-plate">
          <div style="position:absolute; top:-12px; left:24px; background:var(--paper); border:1px solid var(--rule); border-radius:999px; padding:4px 14px; font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.2em; color:var(--rust); font-weight:600;">THE SPECIFICATION</div>
          <dl style="display:grid; grid-template-columns:1fr auto; gap:0 18px; margin:8px 0 0; font-family:'Inter Tight',sans-serif; font-size:13.5px;">
            <dt style="color:var(--ink-500); padding-top:6px;">Volumes</dt>
            <dd class="font-display" style="margin:0; font-size:1.85rem; font-weight:500; line-height:1; color:var(--ink); letter-spacing:-0.02em; text-align:right;">12</dd>
            <dt style="color:var(--ink-500); padding-top:6px; border-top:1px dashed var(--rule);">Engineering modules</dt>
            <dd class="font-display" style="margin:0; font-size:1.85rem; font-weight:500; line-height:1; color:var(--ink); letter-spacing:-0.02em; text-align:right; padding-top:6px; border-top:1px dashed var(--rule);">{stats.modules}</dd>
            <dt style="color:var(--ink-500); padding-top:6px; border-top:1px dashed var(--rule);">Volumes realized &amp; running</dt>
            <dd class="font-display" style="margin:0; font-size:1.85rem; font-weight:500; line-height:1; color:#2f7d5b; letter-spacing:-0.02em; text-align:right; padding-top:6px; border-top:1px dashed var(--rule);">{live}</dd>
            <dt style="color:var(--ink-500); padding-top:6px; border-top:1px dashed var(--rule);">Kernel object types</dt>
            <dd class="font-display" style="margin:0; font-size:1.85rem; font-weight:500; line-height:1; color:var(--ink); letter-spacing:-0.02em; text-align:right; padding-top:6px; border-top:1px dashed var(--rule);">12</dd>
            <dt style="color:var(--ink-500); padding-top:6px; border-top:1px dashed var(--rule);">Defined fields</dt>
            <dd class="font-display" style="margin:0; font-size:1.85rem; font-weight:500; line-height:1; color:var(--ink); letter-spacing:-0.02em; text-align:right; padding-top:6px; border-top:1px dashed var(--rule);">{stats.fields.toLocaleString()}</dd>
          </dl>
          <p style="font-family:'Inter Tight',sans-serif; font-size:11.5px; color:var(--ink-500); margin:14px 0 0; padding-top:10px; border-top:1px solid var(--rule); line-height:1.5;">Parsed directly from the AES-100 books. Chapters {stats.firstChapter}&ndash;{stats.lastChapter}.</p>
        </aside>
      </div>
    </section>

    <div style="max-width:1320px;margin:0 auto;padding:0 28px 90px;">

    <!-- kernel principle -->
    <section style="padding:40px 0;border-bottom:1px solid var(--rule);">
      <p style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:#8a8378;margin:0 0 10px;">Volume I &middot; The kernel principle</p>
      <p style="font-family:Fraunces,serif;font-size:22px;color:var(--ink);margin:0 0 18px;font-style:italic;">&ldquo;Not a page. Not a PDF. Not a video. An object.&rdquo;</p>
      <div style="display:flex;flex-wrap:wrap;gap:8px;">
        {OBJECTS.map((o) => <span style="font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--ink);background:#fff;border:1px solid var(--rule);border-radius:100px;padding:6px 14px;">{o}</span>)}
      </div>
    </section>

    <!-- volumes -->
    <section style="padding:40px 0;">
      <p style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:#8a8378;margin:0 0 20px;">The volumes &middot; specification &rarr; reality</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:16px;">
        {VOLUMES.map((v) => { const c = chip(v.status); return (
          <div style="background:#fff;border:1px solid var(--rule);border-radius:16px;padding:22px 24px;display:flex;flex-direction:column;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;margin-bottom:12px;">
              <span style="font-family:Fraunces,serif;font-size:15px;color:var(--rust);font-weight:600;">Vol {v.n}</span>
              <span style={'font-family:Inter Tight,sans-serif;font-size:11px;font-weight:600;padding:4px 10px;border-radius:100px;background:' + c.bg + ';color:' + c.fg + ';'}>{c.label}</span>
            </div>
            <h3 style="font-family:Fraunces,serif;font-size:20px;font-weight:600;color:var(--ink);margin:0 0 8px;line-height:1.2;">{v.title}</h3>
            <p style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:#6b6455;margin:0 0 12px;line-height:1.5;">{v.gist}</p>
            <p style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#3a352c;margin:0 0 14px;line-height:1.5;"><span style="color:#8a8378;">Today:</span> {v.realized}</p>
            {v.href ? <a href={v.href} style="margin-top:auto;font-family:'Inter Tight',sans-serif;font-size:13px;font-weight:600;color:var(--ink);text-decoration:none;">Open the realization &rarr;</a> : <span style="margin-top:auto;font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#a89f90;">Forward architecture</span>}
          </div>
        ); })}
      </div>
    </section>

    <!-- the specification itself: every module, browsable -->
    <section style="padding:40px 0;border-top:1px solid var(--rule);">
      <p style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:#8a8378;margin:0 0 8px;">The specification &middot; {stats.modules} engineering modules</p>
      <h2 style="font-family:Fraunces,serif;font-size:26px;font-weight:600;color:var(--ink);margin:0 0 8px;">Every module, in execution order</h2>
      <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#6b6455;margin:0 0 20px;max-width:660px;line-height:1.6;">Chapters {stats.firstChapter}&ndash;{stats.lastChapter} across {stats.volumes} volumes, each with its dependency chain, engineering mission, repository structure and object model &mdash; {stats.fields.toLocaleString()} defined fields in total.</p>

      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px;">
        {volumes.map((v) => (
          <a href={'/aquintutor/aes?q=AES100-V' + v.volume + '-'} style="text-decoration:none;background:#fff;border:1px solid var(--rule);border-radius:10px;padding:10px 14px;">
            <span style="font-family:Fraunces,serif;font-size:15px;color:var(--ink);">Volume {roman(v.volume)}</span>
            <span style="display:block;font-family:'JetBrains Mono',monospace;font-size:11px;color:#8a8378;margin-top:2px;">{v.count} modules &middot; ch {v.first}&ndash;{v.last}</span>
          </a>
        ))}
      </div>

      <form method="GET" style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:18px;">
        <input type="search" name="q" value={q} placeholder="Search modules, objects or fields…" style="flex:1;min-width:220px;font-family:'Inter Tight',sans-serif;font-size:14px;padding:10px 14px;border:1px solid var(--rule);border-radius:10px;background:#fff;" />
        <button type="submit" style="background:var(--ink);color:var(--sand-50);border:none;border-radius:10px;padding:10px 20px;font-family:'Inter Tight',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">Search</button>
        {q && <a href="/aquintutor/aes" style="align-self:center;font-family:'Inter Tight',sans-serif;font-size:13px;color:#8a8378;text-decoration:none;">Clear</a>}
      </form>

      <p style="font-family:'JetBrains Mono',monospace;font-size:11.5px;color:#8a8378;margin:0 0 12px;">{q ? results.length + ' matching module' + (results.length === 1 ? '' : 's') : 'First ' + results.length + ' modules'}</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:10px;">
        {results.map((m) => (
          <a href={'/aquintutor/aes/' + m.id} style="text-decoration:none;background:#fff;border:1px solid var(--rule);border-radius:12px;padding:14px 16px;display:block;">
            <span style="font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--rust);">Vol {roman(m.volume)} &middot; Ch {m.chapter}</span>
            <span style="display:block;font-family:Fraunces,serif;font-size:15px;color:var(--ink);margin:5px 0 6px;line-height:1.3;">{m.title.length > 88 ? m.title.slice(0, 88) + '…' : m.title}</span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:10.5px;color:#8a8378;">{m.objectName || 'object'} &middot; {m.fields.length} fields{m.repository.length ? ' · ' + m.repository.length + ' dirs' : ''}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- live surfaces -->
    <section style="padding:20px 0 0;">
      <div style="background:var(--ink);border-radius:20px;padding:36px 34px;">
        <p style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:#e0a878;margin:0 0 8px;">Running today</p>
        <h2 style="font-family:Fraunces,serif;font-size:28px;font-weight:600;color:var(--sand-50);margin:0 0 6px;">The specification, made real</h2>
        <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:rgba(251,250,244,0.72);margin:0 0 24px;max-width:640px;">Every surface below is live in the platform &mdash; the animation is broadcast as a compact spec, never video, and re-renders on each learner’s device at their own quality.</p>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:12px;">
          {LIVE.map((l) => (
            <a href={l.href} style="text-decoration:none;background:rgba(251,250,244,0.05);border:1px solid rgba(251,250,244,0.12);border-radius:12px;padding:16px 18px;display:block;">
              <span style="font-family:'Inter Tight',sans-serif;font-size:15px;font-weight:600;color:var(--sand-50);">{l.name}</span>
              <span style="display:block;font-family:'Inter Tight',sans-serif;font-size:12.5px;color:rgba(251,250,244,0.6);margin-top:4px;line-height:1.45;">{l.note}</span>
            </a>
          ))}
        </div>
      </div>
      <p style="font-family:'Inter Tight',sans-serif;font-size:12px;color:var(--ink-500);margin:22px 0 0;text-align:center;">AquinTutor is the technology platform behind partner universities. Volumes VIII&ndash;XII are forward specification; Volumes I&ndash;VII are realized in the running system.</p>
    </section>
    </div>
  </main>
</AquintutorLayout>
