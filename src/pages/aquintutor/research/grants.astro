---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

// Hand-curated open grant index — generic categories, no entity names.
const GRANTS = [
  { title: 'National science research grant', field: 'STEM', stage: 'Doctoral · postdoctoral', amount: 'Up to ₹40 lakh', deadline: 'Rolling', summary: 'Open call for science research across physics, chemistry, biology, and applied mathematics. Two cycles per year.' },
  { title: 'Vernacular AI research grant', field: 'AI · NLP', stage: 'Early-career', amount: 'Up to ₹25 lakh', deadline: 'Quarterly', summary: 'Funding for projects on Indic-language LLMs, speech systems, and code-mixed NLP. Deliverables include open-source artefacts.' },
  { title: 'Climate + sustainability fellowship', field: 'Environment', stage: 'Mid-career', amount: '₹15-50 lakh', deadline: 'Annual · Sept', summary: 'For practitioners and researchers building climate adaptation tooling. 12-month fellowship with mentor pairing.' },
  { title: 'Public-interest tech grant', field: 'CS · social impact', stage: 'Any', amount: '₹5-20 lakh', deadline: 'Open', summary: 'Tooling for accessibility, language access, civic infrastructure. Solo applicants welcome.' },
  { title: 'Quantum computing seed', field: 'Quantum + HPC', stage: 'PhD + postdoc', amount: 'Up to ₹30 lakh', deadline: 'June, December', summary: 'Hardware-agnostic algorithm work or noise-mitigation research. Includes cloud-credit allowances.' },
  { title: 'Indic digital heritage', field: 'Humanities · digital', stage: 'Any', amount: '₹3-12 lakh', deadline: 'Rolling', summary: 'Digitisation of texts, transcription, OCR for Indic scripts. Sanskrit, Tamil, Bengali, Marathi prioritised.' },
  { title: 'Open biomedical data', field: 'Medicine · biology', stage: 'Doctoral', amount: 'Up to ₹35 lakh', deadline: 'Bi-annual', summary: 'Annotated datasets, model fine-tunes for diagnostics. IRB sign-off required.' },
  { title: 'Education research', field: 'Pedagogy · learning sciences', stage: 'Any', amount: '₹4-15 lakh', deadline: 'Open', summary: 'Studies of vernacular delivery, learning outcomes, special-needs support, exam-prep efficacy.' },
];
---
<AquintutorLayout title="Grant finder · Research · AquinTutor" description="Browse open research-funding calls. Filter by field, stage, deadline.">

<style>
  body { background: #FAF8F5; }
  .gr-wrap { max-width: 1180px; margin: 0 auto; padding: 24px 5vw 80px; }
  .gr-head { padding: 16px 0 24px; border-bottom: 1px solid rgba(14,11,8,0.08); margin-bottom: 24px; }
  .gr-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin: 0; }
  .gr-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 4vw, 42px); font-weight: 600; letter-spacing: -0.02em; margin: 6px 0 0; line-height: 1.1; }
  .gr-title em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .gr-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 14px; }
  .gr-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 22px; transition: all 0.2s; }
  .gr-card:hover { border-color: #FF4F00; transform: translateY(-1px); }
  .gr-card-top { display: flex; justify-content: space-between; gap: 12px; align-items: flex-start; margin-bottom: 10px; }
  .gr-card-title { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 600; margin: 0; line-height: 1.2; letter-spacing: -0.01em; }
  .gr-card-amount { font-family: 'Geist Mono', monospace; font-size: 11px; color: #FF4F00; font-weight: 700; letter-spacing: 0.04em; white-space: nowrap; }
  .gr-card-meta { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: #7A6F68; font-weight: 700; margin: 4px 0 12px; }
  .gr-card-summary { font-size: 13.5px; color: #2E2520; line-height: 1.65; margin: 0; }
  .gr-card-cta { display: flex; gap: 6px; margin-top: 14px; }
  .gr-card-cta button { background: transparent; border: 1px solid rgba(14,11,8,0.15); color: #0E0B08; padding: 6px 12px; border-radius: 6px; font-size: 11px; cursor: pointer; font-family: inherit; }
  .gr-watch-box { background: #FFF3EE; border: 1px solid #FFD4BC; border-radius: 12px; padding: 14px; margin-bottom: 16px; }
</style>

<main class="gr-wrap">
  <header class="gr-head">
    <a href="/aquintutor/research" style="font-family:'Geist Mono',monospace;font-size:11px;color:#FF4F00;text-decoration:none;letter-spacing:0.08em;">← Research</a>
    <p class="gr-eyebrow" style="margin-top:14px;">Research · Grants</p>
    <h1 class="gr-title">Open <em>funding calls</em>.</h1>
  </header>

  <div id="watchBox" class="gr-watch-box" style="display:none;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:#FF4F00;margin:0 0 6px;font-weight:700;"><span id="watchCount">0</span> in your watchlist</p>
    <div id="watchList" style="display:flex;flex-direction:column;gap:4px;font-size:13px;"></div>
  </div>

  <section class="gr-grid">
    {GRANTS.map((g, i) => (
      <article class="gr-card" data-i={i}>
        <div class="gr-card-top">
          <h2 class="gr-card-title">{g.title}</h2>
          <span class="gr-card-amount">{g.amount}</span>
        </div>
        <p class="gr-card-meta">{g.field} · {g.stage} · Deadline {g.deadline}</p>
        <p class="gr-card-summary">{g.summary}</p>
        <div class="gr-card-cta">
          <button class="watchBtn" data-title={g.title} data-deadline={g.deadline}>+ Watchlist</button>
        </div>
      </article>
    ))}
  </section>
</main>

<script is:inline>
  (function () {
    var KEY = 'era_grants_watch_v1';
    var watch = []; try { watch = JSON.parse(localStorage.getItem(KEY) || '[]'); } catch (_) {}
    function render() {
      var box = document.getElementById('watchBox'); var list = document.getElementById('watchList');
      document.getElementById('watchCount').textContent = watch.length;
      box.style.display = watch.length > 0 ? 'block' : 'none';
      list.innerHTML = watch.map(function (w, i) { return '<div style="display:flex;justify-content:space-between;"><span>' + w.title + '</span><span style="font-family:\'Geist Mono\',monospace;font-size:11px;color:#7A6F68;">' + w.deadline + ' <button data-i="' + i + '" style="background:transparent;border:none;color:#FF4F00;cursor:pointer;font-size:14px;">×</button></span></div>'; }).join('');
      list.querySelectorAll('button').forEach(function (b) { b.addEventListener('click', function () { watch.splice(+b.getAttribute('data-i'), 1); save(); render(); }); });
    }
    function save() { localStorage.setItem(KEY, JSON.stringify(watch)); }
    render();
    document.querySelectorAll('.watchBtn').forEach(function (b) {
      b.addEventListener('click', function () { watch.push({ title: b.getAttribute('data-title'), deadline: b.getAttribute('data-deadline') }); save(); render(); b.textContent = '✓ Added'; });
    });
  })();
</script>
</AquintutorLayout>
