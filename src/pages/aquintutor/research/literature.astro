---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
---
<AquintutorLayout title="Literature search · Research · AquinTutor" description="Search arXiv, Crossref, PubMed for open papers. Build a personal reading stack.">

<style>
  body { background: #FAF8F5; }
  .lt-wrap { max-width: 1180px; margin: 0 auto; padding: 24px 5vw 80px; }
  .lt-head { padding: 16px 0 24px; border-bottom: 1px solid rgba(14,11,8,0.08); margin-bottom: 24px; }
  .lt-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin: 0; }
  .lt-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 4vw, 42px); font-weight: 600; letter-spacing: -0.02em; margin: 6px 0 0; line-height: 1.1; }
  .lt-title em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .lt-form { display: flex; gap: 8px; flex-wrap: wrap; margin: 20px 0; }
  .lt-form input { flex: 1; min-width: 220px; background: #fff; border: 1px solid rgba(14,11,8,0.15); padding: 10px 14px; border-radius: 8px; font-family: inherit; font-size: 14px; }
  .lt-form select { background: #fff; border: 1px solid rgba(14,11,8,0.15); padding: 10px 14px; border-radius: 8px; font-family: inherit; font-size: 14px; }
  .lt-form button { background: #FF4F00; color: #fff; border: none; padding: 10px 22px; border-radius: 8px; font-weight: 700; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; }
  .lt-results { display: flex; flex-direction: column; gap: 10px; }
  .lt-paper { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 12px; padding: 18px; }
  .lt-paper-title { font-family: 'Cormorant Garamond', serif; font-size: 19px; font-weight: 600; color: #0E0B08; margin: 0 0 6px; line-height: 1.25; letter-spacing: -0.01em; }
  .lt-paper-meta { font-family: 'Geist Mono', monospace; font-size: 11px; color: #7A6F68; letter-spacing: 0.05em; margin: 0 0 8px; }
  .lt-paper-abs { font-size: 13.5px; color: #2E2520; line-height: 1.6; margin: 0; }
  .lt-actions { display: flex; gap: 6px; margin-top: 10px; }
  .lt-actions a, .lt-actions button { background: transparent; border: 1px solid rgba(14,11,8,0.15); color: #0E0B08; padding: 4px 12px; border-radius: 6px; font-size: 11.5px; cursor: pointer; text-decoration: none; font-family: inherit; }
  .lt-actions a:hover, .lt-actions button:hover { border-color: #FF4F00; color: #FF4F00; }
  .lt-stack { background: #FFF3EE; border: 1px solid #FFD4BC; border-radius: 12px; padding: 16px; margin-bottom: 20px; }
  .lt-stack-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
  .lt-stack-eye { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .lt-stack-clear { background: transparent; border: none; color: #FF4F00; font-family: inherit; font-size: 11px; cursor: pointer; }
  .lt-stack-list { display: flex; flex-direction: column; gap: 4px; }
  .lt-stack-item { font-size: 13px; color: #0E0B08; display: flex; justify-content: space-between; gap: 8px; }
</style>

<main class="lt-wrap">
  <header class="lt-head">
    <a href="/aquintutor/research" style="font-family:'Geist Mono',monospace;font-size:11px;color:#FF4F00;text-decoration:none;letter-spacing:0.08em;">← Research</a>
    <p class="lt-eyebrow" style="margin-top:14px;">Research · Literature</p>
    <h1 class="lt-title">Search the <em>open archive</em>.</h1>
  </header>

  <form id="searchForm" class="lt-form">
    <input id="q" type="text" placeholder="Search arXiv (default) · paper titles, authors, abstracts..." />
    <select id="src">
      <option value="arxiv">arXiv</option>
      <option value="crossref">Crossref</option>
    </select>
    <button type="submit">Search</button>
  </form>

  <div id="stackBox" class="lt-stack" style="display:none;">
    <div class="lt-stack-head">
      <span class="lt-stack-eye"><span id="stackCount">0</span> in your stack</span>
      <button class="lt-stack-clear" id="clearStack">Clear</button>
    </div>
    <div id="stackList" class="lt-stack-list"></div>
  </div>

  <div id="results" class="lt-results"></div>
  <p id="status" style="font-size:13px;color:#7A6F68;margin-top:14px;text-align:center;"></p>
</main>

<script is:inline>
  (function () {
    var STACK_KEY = 'era_lit_stack_v1';
    var stack = []; try { stack = JSON.parse(localStorage.getItem(STACK_KEY) || '[]'); } catch (_) {}

    function renderStack() {
      var box = document.getElementById('stackBox');
      var list = document.getElementById('stackList');
      var cnt = document.getElementById('stackCount');
      cnt.textContent = stack.length;
      box.style.display = stack.length > 0 ? 'block' : 'none';
      list.innerHTML = stack.map(function (p, i) { return '<div class="lt-stack-item"><span>' + escapeHtml(p.title) + '</span><button data-i="' + i + '" style="background:transparent;border:none;color:#FF4F00;cursor:pointer;font-size:14px;">×</button></div>'; }).join('');
      list.querySelectorAll('button').forEach(function (b) {
        b.addEventListener('click', function () { stack.splice(+b.getAttribute('data-i'), 1); save(); renderStack(); });
      });
    }
    function save() { localStorage.setItem(STACK_KEY, JSON.stringify(stack)); }
    function escapeHtml(s) { return (s || '').toString().replace(/[<>&"]/g, function (c) { return { '<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;' }[c]; }); }
    document.getElementById('clearStack').addEventListener('click', function () { if (confirm('Clear stack?')) { stack = []; save(); renderStack(); } });
    renderStack();

    document.getElementById('searchForm').addEventListener('submit', async function (e) {
      e.preventDefault();
      var q = document.getElementById('q').value.trim();
      if (!q) return;
      var src = document.getElementById('src').value;
      var status = document.getElementById('status');
      var results = document.getElementById('results');
      results.innerHTML = ''; status.textContent = 'Searching ' + src + '...';
      try {
        if (src === 'arxiv') {
          // arXiv has a public XML API.
          var r = await fetch('https://export.arxiv.org/api/query?search_query=all:' + encodeURIComponent(q) + '&start=0&max_results=20');
          var xml = await r.text();
          var dom = new DOMParser().parseFromString(xml, 'text/xml');
          var entries = dom.querySelectorAll('entry');
          var papers = Array.from(entries).map(function (e) {
            return {
              title: (e.querySelector('title') || {}).textContent || '',
              authors: Array.from(e.querySelectorAll('author name')).map(function (a) { return a.textContent; }).join(', '),
              abstract: (e.querySelector('summary') || {}).textContent || '',
              url: (e.querySelector('id') || {}).textContent || '',
              year: ((e.querySelector('published') || {}).textContent || '').slice(0, 4),
            };
          });
          render(papers);
          status.textContent = papers.length + ' result(s)';
        } else if (src === 'crossref') {
          var r = await fetch('https://api.crossref.org/works?query=' + encodeURIComponent(q) + '&rows=20');
          var d = await r.json();
          var papers = (d.message?.items || []).map(function (it) {
            return {
              title: (it.title || ['(no title)'])[0],
              authors: (it.author || []).map(function (a) { return (a.given || '') + ' ' + (a.family || ''); }).join(', '),
              abstract: it.abstract ? it.abstract.replace(/<[^>]+>/g, '') : 'No abstract available.',
              url: it.URL || '',
              year: ((it['published-print'] || it['published-online'] || {})['date-parts'] || [[]])[0][0] || '',
            };
          });
          render(papers);
          status.textContent = papers.length + ' result(s)';
        }
      } catch (e) { status.textContent = 'Search failed: ' + e.message; }
    });

    function render(papers) {
      var root = document.getElementById('results');
      root.innerHTML = '';
      papers.forEach(function (p) {
        var el = document.createElement('div'); el.className = 'lt-paper';
        el.innerHTML = '<h3 class="lt-paper-title">' + escapeHtml(p.title) + '</h3>'
          + '<p class="lt-paper-meta">' + escapeHtml(p.authors) + ' · ' + escapeHtml(p.year) + '</p>'
          + '<p class="lt-paper-abs">' + escapeHtml((p.abstract || '').slice(0, 600)) + '</p>'
          + '<div class="lt-actions"><a href="' + escapeHtml(p.url) + '" target="_blank">Open ↗</a><button class="add">+ Add to stack</button></div>';
        el.querySelector('.add').addEventListener('click', function () { stack.push(p); save(); renderStack(); el.querySelector('.add').textContent = '✓ Added'; });
        root.appendChild(el);
      });
    }
  })();
</script>
</AquintutorLayout>
