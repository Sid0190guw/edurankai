---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ensureCommunitySchema, listCollabPosts, createCollabPost } from '@/lib/community';

const user = Astro.locals.user;
await ensureCommunitySchema();

let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const title = (fd.get('title') as string || '').trim();
    const field = (fd.get('field') as string || '').trim();
    const kind = (fd.get('kind') as string || 'open-call').trim();
    const body = (fd.get('body') as string || '').trim();
    const skills = (fd.get('skills') as string || '').split(',').map(s => s.trim()).filter(Boolean);
    const commitment = (fd.get('commitment') as string || '').trim();
    const contactEmail = (fd.get('contact_email') as string || '').trim();
    if (title.length < 8 || body.length < 80) errMsg = 'Title (8+ chars) and body (80+ chars) required.';
    else {
      const slug = title.toLowerCase().replace(/[^a-z0-9]+/g, '-').slice(0, 80) + '-' + Math.random().toString(36).slice(2, 6);
      await createCollabPost({ slug, userId: user?.id, authorName: user?.name, title, field, kind, body, skillsWanted: skills, commitment, contactEmail });
      okMsg = 'Posted.';
    }
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 240); }
}

const url = new URL(Astro.request.url);
const filterField = url.searchParams.get('field') || undefined;
const posts = await listCollabPosts({ field: filterField });
---
<BaseLayout title="Collaboration board · Research · EduRankAI" description="Find co-authors. Post a project brief. Browse open research calls.">

<style>
  body { background: #FAF8F5; }
  .cb-wrap { max-width: 1180px; margin: 0 auto; padding: 24px 5vw 80px; }
  .cb-head { padding: 16px 0 24px; border-bottom: 1px solid rgba(14,11,8,0.08); margin-bottom: 24px; display: flex; justify-content: space-between; align-items: flex-end; gap: 14px; flex-wrap: wrap; }
  .cb-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .cb-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 4vw, 42px); font-weight: 600; letter-spacing: -0.02em; margin: 4px 0 0; line-height: 1.1; }
  .cb-title em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .cb-new-btn { background: #FF4F00; color: #fff; padding: 9px 18px; border-radius: 8px; border: none; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700; }
  .cb-grid { display: flex; flex-direction: column; gap: 12px; }
  .cb-post { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 22px; }
  .cb-post-top { display: flex; justify-content: space-between; gap: 12px; flex-wrap: wrap; align-items: flex-start; }
  .cb-post-title { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; margin: 0; line-height: 1.2; letter-spacing: -0.01em; }
  .cb-kind { font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; padding: 3px 9px; border-radius: 100px; font-weight: 700; }
  .cb-kind-open { background: #FFF3EE; color: #FF4F00; }
  .cb-kind-coauthor { background: #EBF0FF; color: #1045BB; }
  .cb-kind-mentor { background: #EBF5EF; color: #1A6B35; }
  .cb-meta { font-family: 'Geist Mono', monospace; font-size: 11px; color: #7A6F68; letter-spacing: 0.04em; margin: 6px 0 10px; }
  .cb-body { font-size: 13.5px; color: #2E2520; line-height: 1.65; margin: 0; }
  .cb-chips { display: flex; gap: 4px; flex-wrap: wrap; margin-top: 10px; }
  .cb-chip { font-family: 'Geist Mono', monospace; font-size: 10px; padding: 2px 8px; border-radius: 100px; background: #F3EFE8; color: #2E2520; }

  .cb-form { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 20px; margin-bottom: 20px; }
  .cb-form input, .cb-form select, .cb-form textarea { width: 100%; box-sizing: border-box; background: #FAF8F5; border: 1px solid rgba(14,11,8,0.15); padding: 8px 12px; border-radius: 6px; font-family: inherit; font-size: 13.5px; margin-bottom: 8px; }
</style>

<main class="cb-wrap">
  <header class="cb-head">
    <div>
      <a href="/aquintutor/research" style="font-family:'Geist Mono',monospace;font-size:11px;color:#FF4F00;text-decoration:none;letter-spacing:0.08em;">← Research</a>
      <p class="cb-eyebrow" style="margin-top:14px;">Research · Collaboration</p>
      <h1 class="cb-title">Find <em>co-authors</em>.</h1>
    </div>
    <button id="newBtn" class="cb-new-btn">+ New post</button>
  </header>

  {errMsg && <p style="color:#b91c1c;background:rgba(239,68,68,0.08);padding:10px 14px;border-radius:8px;font-size:14px;margin:0 0 16px;">{errMsg}</p>}
  {okMsg && <p style="color:#1A6B35;background:rgba(26,107,53,0.08);padding:10px 14px;border-radius:8px;font-size:14px;margin:0 0 16px;">{okMsg}</p>}

  <form id="newForm" method="POST" class="cb-form" style="display:none;">
    <p style="font-family:'Geist Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#FF4F00;font-weight:700;margin:0 0 10px;">New post</p>
    <input name="title" type="text" placeholder="Title · e.g. Looking for a co-author on Vedic-Sanskrit NLP" required maxlength="300"/>
    <select name="kind">
      <option value="open-call">Open call</option>
      <option value="coauthor">Co-author wanted</option>
      <option value="mentor">Mentor wanted</option>
      <option value="dataset">Dataset request</option>
    </select>
    <select name="field">
      <option value="">Field...</option>
      <option value="AI">AI / ML</option><option value="NLP">NLP / language</option><option value="Quantum">Quantum</option>
      <option value="HPC">HPC</option><option value="Biology">Biology</option><option value="Physics">Physics</option>
      <option value="Mathematics">Mathematics</option><option value="Humanities">Humanities</option><option value="Education">Education</option>
    </select>
    <textarea name="body" rows="5" placeholder="Project brief, scope, timeline, what kind of collaborator..." minlength="80" maxlength="5000" required></textarea>
    <input name="skills" type="text" placeholder="Skills wanted (comma-separated): e.g. PyTorch, statistics, Sanskrit"/>
    <input name="commitment" type="text" placeholder="Commitment: e.g. 5 hours/week for 8 weeks"/>
    <input name="contact_email" type="email" placeholder="Contact email"/>
    <button type="submit" style="background:#FF4F00;color:#fff;padding:9px 22px;border-radius:8px;border:none;cursor:pointer;font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.06em;text-transform:uppercase;font-weight:700;">Post</button>
  </form>

  {posts.length === 0 ? (
    <p style="text-align:center;padding:40px 20px;color:#7A6F68;font-size:14px;">No posts yet. Be the first.</p>
  ) : (
    <div class="cb-grid">
      {posts.map((p: any) => (
        <article class="cb-post">
          <div class="cb-post-top">
            <h2 class="cb-post-title">{p.title}</h2>
            <span class={'cb-kind cb-kind-' + (p.kind === 'open-call' ? 'open' : p.kind === 'coauthor' ? 'coauthor' : 'mentor')}>{p.kind}</span>
          </div>
          <p class="cb-meta">{p.author_name || 'Anonymous'} · {p.field || 'General'} · {new Date(p.created_at).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day: 'numeric', month: 'short' })}{p.commitment && (' · ' + p.commitment)}</p>
          <p class="cb-body">{p.body}</p>
          {Array.isArray(p.skills_wanted) && p.skills_wanted.length > 0 && (
            <div class="cb-chips">
              {p.skills_wanted.map((s: string) => <span class="cb-chip">{s}</span>)}
            </div>
          )}
          {p.contact_email && <p style="font-size:12px;color:#FF4F00;margin-top:10px;"><a href={'mailto:' + p.contact_email} style="color:inherit;">{p.contact_email}</a></p>}
        </article>
      ))}
    </div>
  )}
</main>

<script is:inline>
  document.getElementById('newBtn').addEventListener('click', function () {
    var f = document.getElementById('newForm');
    f.style.display = f.style.display === 'none' ? 'block' : 'none';
  });
</script>
</BaseLayout>
