---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
---
<AquintutorLayout title="Citation builder · Research · EduRankAI" description="Paste a DOI, get BibTeX / APA / MLA / Chicago / IEEE in one click.">

<style>
  body { background: #FAF8F5; }
  .ci-wrap { max-width: 980px; margin: 0 auto; padding: 24px 5vw 80px; }
  .ci-head { padding: 16px 0 24px; border-bottom: 1px solid rgba(14,11,8,0.08); margin-bottom: 24px; }
  .ci-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin: 0; }
  .ci-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 4vw, 42px); font-weight: 600; letter-spacing: -0.02em; margin: 6px 0 0; line-height: 1.1; }
  .ci-title em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .ci-input-row { display: flex; gap: 8px; flex-wrap: wrap; margin: 20px 0; }
  .ci-input-row input { flex: 1; min-width: 240px; background: #fff; border: 1px solid rgba(14,11,8,0.15); padding: 12px 14px; border-radius: 8px; font-family: inherit; font-size: 14px; }
  .ci-input-row button { background: #FF4F00; color: #fff; border: none; padding: 12px 22px; border-radius: 8px; font-weight: 700; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; }
  .ci-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 12px; padding: 16px; margin-bottom: 10px; }
  .ci-style-name { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin: 0 0 6px; }
  .ci-text { font-size: 13.5px; color: #0E0B08; line-height: 1.6; margin: 0; white-space: pre-wrap; word-wrap: break-word; font-family: ui-monospace, monospace; }
  .ci-copy { background: transparent; border: 1px solid rgba(14,11,8,0.15); color: #0E0B08; padding: 4px 10px; border-radius: 5px; font-size: 11px; cursor: pointer; margin-top: 8px; }
  .ci-bib { background: #FFF3EE; border: 1px solid #FFD4BC; border-radius: 12px; padding: 16px; margin: 20px 0; }
  .ci-bib-list { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 8px; padding: 12px; max-height: 200px; overflow-y: auto; font-family: ui-monospace, monospace; font-size: 12px; white-space: pre-wrap; }
</style>

<main class="ci-wrap">
  <header class="ci-head">
    <a href="/aquintutor/research" style="font-family:'Geist Mono',monospace;font-size:11px;color:#FF4F00;text-decoration:none;letter-spacing:0.08em;">← Research</a>
    <p class="ci-eyebrow" style="margin-top:14px;">Research · Citations</p>
    <h1 class="ci-title">From DOI to <em>any format</em>.</h1>
  </header>

  <form id="ciForm" class="ci-input-row">
    <input id="doi" type="text" placeholder="DOI · e.g. 10.1038/s41586-023-06600-9" />
    <button type="submit">Fetch</button>
  </form>

  <div id="results"></div>

  <div class="ci-bib">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:#FF4F00;margin:0 0 8px;font-weight:700;">My bibliography</p>
    <div id="bibList" class="ci-bib-list">Empty. Fetch a DOI above and click 'Add to bibliography'.</div>
    <div style="display:flex;gap:6px;margin-top:8px;">
      <button id="exportBib" style="background:#FF4F00;color:#fff;border:none;padding:6px 14px;border-radius:5px;font-size:11px;font-weight:700;cursor:pointer;font-family:'Geist Mono',monospace;letter-spacing:0.06em;text-transform:uppercase;">Export .bib</button>
      <button id="clearBib" style="background:transparent;border:1px solid rgba(14,11,8,0.15);padding:6px 14px;border-radius:5px;font-size:11px;cursor:pointer;font-family:inherit;">Clear</button>
    </div>
  </div>
  <p id="status" style="font-size:13px;color:#7A6F68;margin-top:14px;text-align:center;"></p>
</main>

<script is:inline>
  (function () {
    var BIB_KEY = 'era_bib_v1';
    var bib = []; try { bib = JSON.parse(localStorage.getItem(BIB_KEY) || '[]'); } catch (_) {}

    function renderBib() {
      document.getElementById('bibList').textContent = bib.length === 0 ? 'Empty.' : bib.map(function (b) { return b.bibtex; }).join('\n\n');
    }
    renderBib();

    document.getElementById('clearBib').addEventListener('click', function () { if (confirm('Clear bibliography?')) { bib = []; localStorage.setItem(BIB_KEY, '[]'); renderBib(); } });
    document.getElementById('exportBib').addEventListener('click', function () {
      var blob = new Blob([bib.map(function (b) { return b.bibtex; }).join('\n\n')], { type: 'text/plain' });
      var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'bibliography-' + Date.now() + '.bib'; a.click();
    });

    document.getElementById('ciForm').addEventListener('submit', async function (e) {
      e.preventDefault();
      var doi = document.getElementById('doi').value.trim().replace(/^https?:\/\/(dx\.)?doi\.org\//i, '');
      if (!doi) return;
      var status = document.getElementById('status'); var results = document.getElementById('results');
      results.innerHTML = ''; status.textContent = 'Fetching...';
      try {
        var r = await fetch('https://api.crossref.org/works/' + encodeURIComponent(doi));
        var d = await r.json();
        var work = d.message;
        if (!work) { status.textContent = 'Not found.'; return; }
        var title = (work.title || ['(no title)'])[0];
        var authors = work.author || [];
        var year = (((work['published-print'] || work['published-online'] || {})['date-parts'] || [[]])[0][0]) || 'n.d.';
        var journal = (work['container-title'] || [''])[0];
        var vol = work.volume || ''; var issue = work.issue || ''; var pages = work.page || '';

        // Style formatters
        var authorsAPA = authors.map(function (a) { return (a.family || '') + ', ' + (a.given || '').charAt(0) + '.'; }).join(', ');
        var authorsMLA = authors.map(function (a) { return (a.family || '') + ', ' + (a.given || ''); }).join(', and ');
        var authorsChicago = authors.map(function (a) { return (a.given || '') + ' ' + (a.family || ''); }).join(', ');
        var authorsIEEE = authors.map(function (a) { return (a.given || '').charAt(0) + '. ' + (a.family || ''); }).join(', ');
        var authorsBib = authors.map(function (a) { return (a.family || '') + ', ' + (a.given || ''); }).join(' and ');

        var citations = {
          'APA':     authorsAPA + ' (' + year + '). ' + title + '. *' + journal + '*' + (vol ? ', ' + vol : '') + (issue ? '(' + issue + ')' : '') + (pages ? ', ' + pages : '') + '. https://doi.org/' + doi,
          'MLA':     authorsMLA + '. "' + title + '." *' + journal + '*, vol. ' + (vol || '?') + ', no. ' + (issue || '?') + ', ' + year + ', pp. ' + (pages || '?') + '. doi:' + doi + '.',
          'Chicago': authorsChicago + '. "' + title + '." *' + journal + '* ' + vol + ', no. ' + issue + ' (' + year + '): ' + pages + '. https://doi.org/' + doi + '.',
          'IEEE':    authorsIEEE + ', "' + title + '," *' + journal + '*, vol. ' + vol + ', no. ' + issue + ', pp. ' + pages + ', ' + year + ', doi: ' + doi + '.',
          'BibTeX':  '@article{' + (authors[0]?.family || 'ref') + year + ',\n  title = {' + title + '},\n  author = {' + authorsBib + '},\n  journal = {' + journal + '},\n  year = {' + year + '},\n  volume = {' + vol + '},\n  number = {' + issue + '},\n  pages = {' + pages + '},\n  doi = {' + doi + '}\n}',
        };

        Object.keys(citations).forEach(function (style) {
          var el = document.createElement('div'); el.className = 'ci-card';
          el.innerHTML = '<p class="ci-style-name">' + style + '</p><p class="ci-text">' + escapeHtml(citations[style]) + '</p><button class="ci-copy" data-text="' + escapeHtml(citations[style]) + '">Copy</button>' + (style === 'BibTeX' ? ' <button class="ci-copy add-bib" data-bibtex="' + escapeHtml(citations[style]) + '" data-title="' + escapeHtml(title) + '">+ Add to bibliography</button>' : '');
          el.querySelectorAll('.ci-copy').forEach(function (b) {
            if (b.classList.contains('add-bib')) b.addEventListener('click', function () { bib.push({ title: b.getAttribute('data-title'), bibtex: b.getAttribute('data-bibtex') }); localStorage.setItem(BIB_KEY, JSON.stringify(bib)); renderBib(); b.textContent = '✓ Added'; });
            else b.addEventListener('click', function () { navigator.clipboard.writeText(b.getAttribute('data-text')); b.textContent = '✓'; setTimeout(function () { b.textContent = 'Copy'; }, 1200); });
          });
          results.appendChild(el);
        });
        status.textContent = '';
      } catch (e) { status.textContent = 'Failed: ' + e.message; }
    });

    function escapeHtml(s) { return (s || '').toString().replace(/[<>&"]/g, function (c) { return { '<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;' }[c]; }); }
  })();
</script>
</AquintutorLayout>
