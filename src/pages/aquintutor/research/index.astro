---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Research copilot · EduRankAI" description="Literature search, citation builder, grant finder, and collaboration boards. Browser-side research tooling.">

<style>
  body { background: #FAF8F5; }
  .rs-wrap { max-width: 1180px; margin: 0 auto; padding: 24px 5vw 80px; }
  .rs-head { padding: 24px 0 32px; }
  .rs-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .rs-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(36px, 5vw, 56px); font-weight: 600; letter-spacing: -0.025em; margin: 6px 0 12px; line-height: 1.05; }
  .rs-title em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .rs-sub { font-size: 15px; color: #2E2520; max-width: 660px; line-height: 1.65; }
  .rs-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 14px; margin-top: 26px; }
  .rs-tool { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 22px; text-decoration: none; color: inherit; transition: all 0.2s; display: block; }
  .rs-tool:hover { transform: translateY(-1px); box-shadow: 0 12px 28px rgba(14,11,8,0.06); border-color: #FF4F00; }
  .rs-icon { width: 42px; height: 42px; border-radius: 10px; background: #FFF3EE; color: #FF4F00; display: flex; align-items: center; justify-content: center; margin-bottom: 14px; }
  .rs-tool-eye { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .rs-tool-title { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; margin: 4px 0 8px; letter-spacing: -0.02em; line-height: 1.15; }
  .rs-tool-desc { font-size: 13.5px; color: #2E2520; line-height: 1.6; }
</style>

<main class="rs-wrap">
  <header class="rs-head">
    <p class="rs-eyebrow">AquinTutor · Research</p>
    <h1 class="rs-title">Research <em>copilot</em>.</h1>
    <p class="rs-sub">Literature search across open archives. Citation builder. Grant finder. Collaboration boards. All browser-side — your draft never leaves your machine until you ship it.</p>
  </header>

  <section class="rs-grid">
    <a href="/aquintutor/research/literature" class="rs-tool">
      <div class="rs-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></div>
      <p class="rs-tool-eye">Tool 1</p>
      <h2 class="rs-tool-title">Literature search</h2>
      <p class="rs-tool-desc">Search across arXiv, PubMed, Crossref, Semantic Scholar via their open APIs. Save papers to your stack. Read abstracts side-by-side.</p>
    </a>

    <a href="/aquintutor/research/citation" class="rs-tool">
      <div class="rs-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 5h13l5 5v9a2 2 0 0 1-2 2H3z"/><polyline points="14 5 14 10 19 10"/><line x1="7" y1="14" x2="14" y2="14"/></svg></div>
      <p class="rs-tool-eye">Tool 2</p>
      <h2 class="rs-tool-title">Citation builder</h2>
      <p class="rs-tool-desc">Paste a DOI or paper URL. Get BibTeX, APA, MLA, Chicago, IEEE in one click. Manage a bibliography list, export .bib file.</p>
    </a>

    <a href="/aquintutor/research/grants" class="rs-tool">
      <div class="rs-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></div>
      <p class="rs-tool-eye">Tool 3</p>
      <h2 class="rs-tool-title">Grant finder</h2>
      <p class="rs-tool-desc">Browse open funding calls. Filter by field, deadline, eligibility, amount. Stash to a watchlist. Get a calendar reminder.</p>
    </a>

    <a href="/aquintutor/research/collab" class="rs-tool">
      <div class="rs-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/></svg></div>
      <p class="rs-tool-eye">Tool 4</p>
      <h2 class="rs-tool-title">Collaboration boards</h2>
      <p class="rs-tool-desc">Find co-authors. Post a project brief. Browse open calls from other researchers. Connect via the network.</p>
    </a>
  </section>
</main>
</BaseLayout>
