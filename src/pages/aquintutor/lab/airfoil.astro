---
// /aquintutor/lab/airfoil — Airfoil / Lift virtual lab.
// Connected to the Bernoulli lesson (lift is the flagship example). REAL
// aerodynamics, not a decorative loop:
//   - lift coefficient from thin-airfoil theory  CL = 2π(α − α₀),
//   - a real stall model past the critical angle,
//   - induced + parasitic drag  CD = CD0 + CL²/(πARe),
//   - lift and drag forces  L,D = ½ρv²·A·C,  and the L/D ratio,
//   all recomputed every frame from the angle of attack, airspeed and camber
//   you set. The streamlines bend and the flow separates at stall to match.
// Honest scope: thin-airfoil theory (small-angle, incompressible) — stated in
// the "how it's computed" panel; not a full CFD solver, and it says so.
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex" />
  <title>Airfoil &amp; Lift · Virtual Lab · AquinTutor</title>
  <style>
    :root{
      --bg:#0a0e17; --bg2:#0e1420; --panel:#111a2b; --panel2:#0d1524; --card:#131d2f;
      --stroke:#1e2a40; --stroke2:#26344d; --ink:#e6ecf7; --ink2:#aab6cc; --mut:#6c7b96;
      --blue:#3b82f6; --blue2:#60a5fa; --blueDim:#1e3a5f; --green:#22c55e; --red:#ef4444; --amber:#f59e0b;
    }
    *{box-sizing:border-box;}
    html,body{margin:0;min-height:100%;}
    body{background:var(--bg);color:var(--ink);font-family:'Inter Tight',system-ui,-apple-system,sans-serif;font-size:13px;}
    a{color:inherit;text-decoration:none;}
    .top{display:flex;align-items:center;gap:12px;padding:10px 16px;background:var(--bg2);border-bottom:1px solid var(--stroke);position:sticky;top:0;z-index:20;}
    .back{display:flex;align-items:center;gap:7px;padding:6px 11px;border:1px solid var(--stroke2);border-radius:9px;color:var(--ink2);font-size:12.5px;cursor:pointer;}
    .back:hover{color:var(--ink);}
    .ttl{font-family:'Cormorant Garamond',Georgia,serif;font-size:19px;font-weight:600;}
    .ttl small{display:block;font-family:'Inter Tight',sans-serif;font-size:10.5px;color:var(--mut);font-weight:400;}
    .wrap{max-width:1120px;margin:0 auto;padding:16px;display:grid;grid-template-columns:minmax(0,1fr) 320px;gap:16px;}
    .stage{background:var(--panel);border:1px solid var(--stroke);border-radius:14px;padding:14px;}
    .stage-head{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
    .badge{font-size:9px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--blue2);background:rgba(59,130,246,0.12);padding:3px 8px;border-radius:5px;}
    #cv{width:100%;height:auto;display:block;border-radius:10px;background:#060b14;border:1px solid var(--stroke2);}
    .legend{display:flex;flex-wrap:wrap;gap:14px;margin-top:10px;font-size:11px;color:var(--ink2);}
    .legend i{display:inline-block;width:15px;height:3px;border-radius:2px;margin-right:5px;vertical-align:middle;}
    .runrow{display:flex;gap:8px;margin-top:12px;}
    .btn{flex:1;padding:10px;border-radius:9px;border:1px solid var(--stroke2);background:var(--panel2);color:var(--ink);font-family:inherit;font-size:12.5px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:7px;}
    .btn.primary{background:var(--blue);border-color:var(--blue);color:#fff;}
    .btn:hover{border-color:var(--stroke2);}
    .side{display:flex;flex-direction:column;gap:14px;}
    .ctrls,.reads,.calc{background:var(--panel);border:1px solid var(--stroke);border-radius:14px;padding:15px;}
    .hh{font-size:9px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--mut);margin-bottom:12px;}
    .field{margin-bottom:14px;} .field:last-child{margin-bottom:0;}
    .field label{display:flex;justify-content:space-between;font-size:12px;color:var(--ink2);margin-bottom:7px;}
    .field label b{color:var(--blue2);font-family:'Geist Mono',monospace;}
    input[type=range]{width:100%;-webkit-appearance:none;appearance:none;height:5px;border-radius:3px;background:var(--stroke2);outline:none;}
    input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:17px;height:17px;border-radius:50%;background:var(--blue);cursor:pointer;border:2px solid #0a0e17;}
    input[type=range]::-moz-range-thumb{width:15px;height:15px;border-radius:50%;background:var(--blue);cursor:pointer;border:2px solid #0a0e17;}
    .reads-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px;}
    .rd{background:var(--panel2);border:1px solid var(--stroke2);border-radius:9px;padding:9px 11px;}
    .rd .k{font-size:10px;color:var(--mut);}
    .rd .v{font-size:17px;font-weight:700;font-family:'Geist Mono',monospace;margin-top:3px;}
    .rd .u{font-size:10px;color:var(--ink2);font-weight:400;}
    .rd.warn{border-color:var(--red);background:rgba(239,68,68,0.08);}
    .rd.warn .v{color:#fca5a5;}
    .stall{display:none;margin-top:11px;padding:9px 11px;border-radius:9px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.35);color:#fca5a5;font-size:11.5px;line-height:1.5;}
    .stall.on{display:block;}
    .calc{font-size:12px;color:var(--ink2);line-height:1.8;}
    .calc .eq{font-family:'Geist Mono',monospace;font-size:11.5px;color:var(--ink);background:var(--panel2);border:1px solid var(--stroke2);border-radius:7px;padding:7px 9px;margin:6px 0;overflow-x:auto;white-space:nowrap;}
    .calc b{color:var(--blue2);}
    @media (max-width:820px){ .wrap{grid-template-columns:1fr;padding:12px;gap:12px;} .ttl{font-size:16px;} .ttl small{display:none;} }
  </style>
</head>
<body>
  <header class="top">
    <a class="back" href="/aquintutor/classroom/live"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>Classroom</a>
    <div class="ttl">Airfoil &amp; Lift<small>Virtual Lab · why a wing flies (Bernoulli in action)</small></div>
  </header>

  <div class="wrap">
    <section class="stage">
      <div class="stage-head">
        <span class="badge">Aerodynamics</span>
        <span style="font-size:12px;color:var(--ink2)">Air &rho; = 1.225 kg/m&sup3; · wing area 1 m&sup2; · AR 7</span>
      </div>
      <canvas id="cv" width="720" height="420"></canvas>
      <div class="legend">
        <span><i style="background:#7dd3fc"></i>Fast flow / low pressure (top)</span>
        <span><i style="background:#f87171"></i>Slow flow / high pressure (bottom)</span>
        <span><i style="background:#22c55e"></i>Lift vector</span>
      </div>
      <div class="runrow">
        <button class="btn primary" id="run"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>Pause</button>
        <button class="btn" id="reset"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>Reset</button>
      </div>
    </section>

    <aside class="side">
      <div class="ctrls">
        <div class="hh">Parameters</div>
        <div class="field">
          <label>Angle of attack &alpha; <b><span id="av">6</span>&deg;</b></label>
          <input type="range" id="alpha" min="-5" max="20" step="0.5" value="6" />
        </div>
        <div class="field">
          <label>Airspeed v <b><span id="vv">50</span> m/s</b></label>
          <input type="range" id="v" min="10" max="90" step="1" value="50" />
        </div>
        <div class="field">
          <label>Camber <b><span id="cv2">2</span>%</b></label>
          <input type="range" id="camber" min="0" max="8" step="0.5" value="2" />
        </div>
      </div>

      <div class="reads">
        <div class="hh">Computed — live aerodynamics</div>
        <div class="reads-grid">
          <div class="rd" id="rdCL"><div class="k">Lift coeff. C&#8343;</div><div class="v"><span id="rCL">0.9</span></div></div>
          <div class="rd"><div class="k">Drag coeff. C&#8332;</div><div class="v"><span id="rCD">0.05</span></div></div>
          <div class="rd"><div class="k">Lift force L</div><div class="v"><span id="rL">1.4</span> <span class="u">kN</span></div></div>
          <div class="rd"><div class="k">Drag force D</div><div class="v"><span id="rD">70</span> <span class="u">N</span></div></div>
          <div class="rd"><div class="k">L / D ratio</div><div class="v"><span id="rLD">20</span></div></div>
          <div class="rd"><div class="k">Flow</div><div class="v" style="font-size:14px;"><span id="rFlow">Attached</span></div></div>
        </div>
        <div class="stall" id="stall"><b>Stall.</b> Past the critical angle (~15&deg;) the flow separates from the upper surface, lift collapses and drag spikes — exactly what ends a real wing's climb. Reduce the angle of attack to reattach the flow.</div>
      </div>

      <div class="calc">
        <div class="hh">How it's computed</div>
        Thin-airfoil theory sets the lift coefficient:
        <div class="eq">C&#8343; = 2&pi;(&alpha; &minus; &alpha;&#8320;) = <span id="cCL">0.90</span></div>
        Lift is then dynamic pressure &times; area &times; C&#8343;:
        <div class="eq">L = &frac12;&rho;v&sup2; &middot; A &middot; C&#8343; = <span id="cL">1.4</span> kN</div>
        Air is faster over the curved top &rArr; lower pressure there (Bernoulli) &rArr; net upward lift. <b>Small-angle, incompressible model</b> — not full CFD.
      </div>
    </aside>
  </div>

  <script is:inline>
  (function(){
    var RHO=1.225, A=1.0, AR=7, e=0.8, CD0=0.02;
    var A_STALL = 15*Math.PI/180;
    var state = { alpha:6, v:50, camber:2 };
    var running = true;
    var cv=document.getElementById('cv'), ctx=cv.getContext('2d'); var W=cv.width, H=cv.height;

    function physics(){
      var aRad = state.alpha*Math.PI/180;
      var camf = state.camber/100;
      var a0 = -2*camf;                              // zero-lift angle (rad), from camber
      var clLin = 2*Math.PI*(aRad - a0);
      var cl, stalled=false;
      if (aRad <= A_STALL) cl = clLin;
      else { var clMax = 2*Math.PI*(A_STALL - a0); cl = Math.max(0.15, clMax - 5.5*(aRad - A_STALL)); stalled=true; }
      var cd = CD0 + cl*cl/(Math.PI*AR*e) + (stalled? 0.9*(aRad-A_STALL) : 0);
      var q = 0.5*RHO*state.v*state.v;               // dynamic pressure
      var L = q*A*cl, D = q*A*cd;
      return { cl:cl, cd:cd, L:L, D:D, ld:cl/cd, stalled:stalled, aRad:aRad, a0:a0 };
    }

    function updateReadouts(P){
      document.getElementById('rCL').textContent = P.cl.toFixed(2);
      document.getElementById('rCD').textContent = P.cd.toFixed(3);
      document.getElementById('rL').textContent  = (P.L/1000).toFixed(2);
      document.getElementById('rD').textContent  = P.D.toFixed(0);
      document.getElementById('rLD').textContent = isFinite(P.ld)? P.ld.toFixed(1) : '—';
      document.getElementById('rFlow').textContent = P.stalled? 'Separated' : 'Attached';
      document.getElementById('rdCL').classList.toggle('warn', P.stalled);
      document.getElementById('stall').classList.toggle('on', P.stalled);
      document.getElementById('cCL').textContent = P.cl.toFixed(2);
      document.getElementById('cL').textContent  = (P.L/1000).toFixed(2);
    }

    // airfoil surface (chord along x in [-1,1]), simple cambered thickness form
    function foilY(xc, top, camf){
      var t = 0.12;                                  // thickness ratio
      var xt = (xc+1)/2;                             // 0..1
      var thick = 5*t*(0.2969*Math.sqrt(xt) - 0.126*xt - 0.3516*xt*xt + 0.2843*xt*xt*xt - 0.1015*xt*xt*xt*xt);
      var camber = camf*4* (xt*(1-xt));              // parabolic camber line
      return (top? camber+thick : camber-thick);
    }

    var t=0;
    function draw(P){
      ctx.clearRect(0,0,W,H);
      var cx=W*0.42, cy=H*0.5, chord=W*0.34;
      var ang = -P.aRad;                             // rotate airfoil to angle of attack (screen y down)
      // streamlines L->R, deflected by the wing; compress (speed up) over the top
      var N=15;
      for (var i=0;i<N;i++){
        var y0 = H*(0.12 + i*0.052);
        ctx.beginPath();
        var over = y0 < cy;
        for (var x=0;x<=W;x+=5){
          // deflection bump centred on the wing; stronger for higher alpha & closer lines
          var dxr=(x-cx)/chord;
          var prox = Math.exp(-Math.pow(dxr/0.9,2));
          var pull = (over? -1: 0.7) * (P.cl*0.5) * prox * (1 - Math.min(1,Math.abs(y0-cy)/(H*0.34)));
          var yy = y0 + pull*40;
          // post-stall: break up the upper streamlines into a turbulent wake
          if (P.stalled && over && dxr>0) yy += Math.sin((x*0.20)+(t*3)+(i))*8*prox;
          if (x===0) ctx.moveTo(x,yy); else ctx.lineTo(x,yy);
        }
        var sp = over? 1.6 : 0.9;
        ctx.strokeStyle = over? (P.stalled? 'rgba(148,163,184,0.55)' : 'rgba(125,211,252,0.8)') : 'rgba(248,113,113,0.7)';
        ctx.lineWidth = over?1.5:1.3; ctx.stroke();
      }
      // moving flow ticks
      for (var j=0;j<N;j++){
        var yb = H*(0.12 + j*0.052); var over2 = yb<cy;
        var speed = over2? (P.stalled?0.6:2.0):1.1;
        var px = ((t*speed*90) % W);
        var dxr2=(px-cx)/chord, prox2=Math.exp(-Math.pow(dxr2/0.9,2));
        var pull2=(over2?-1:0.7)*(P.cl*0.5)*prox2*(1-Math.min(1,Math.abs(yb-cy)/(H*0.34)));
        var py=yb+pull2*40; if(P.stalled&&over2&&dxr2>0) py+=Math.sin((px*0.2)+(t*3)+j)*8*prox2;
        ctx.beginPath(); ctx.arc(px,py,1.9,0,7); ctx.fillStyle= over2? '#bae6fd':'#fca5a5'; ctx.fill();
      }

      // airfoil body (rotated)
      ctx.save(); ctx.translate(cx,cy); ctx.rotate(ang);
      ctx.beginPath();
      for (var xc=-1;xc<=1.0001;xc+=0.05){ var yy=foilY(xc,true,state.camber/100); ctx.lineTo(xc*chord/2, -yy*chord/2); }
      for (var xc2=1;xc2>=-1;xc2-=0.05){ var yy2=foilY(xc2,false,state.camber/100); ctx.lineTo(xc2*chord/2, -yy2*chord/2); }
      ctx.closePath();
      var g=ctx.createLinearGradient(0,-chord*0.1,0,chord*0.1); g.addColorStop(0,'#2b3a52'); g.addColorStop(1,'#1a2740');
      ctx.fillStyle=g; ctx.fill(); ctx.strokeStyle='#60a5fa'; ctx.lineWidth=1.6; ctx.stroke();
      // chord line
      ctx.strokeStyle='rgba(255,255,255,0.25)'; ctx.setLineDash([4,4]); ctx.beginPath(); ctx.moveTo(-chord/2,0); ctx.lineTo(chord/2,0); ctx.stroke(); ctx.setLineDash([]);
      ctx.restore();

      // lift vector (perp to freestream = straight up on screen), scaled by CL
      var lift=Math.max(0,Math.min(120, P.cl*55));
      ctx.strokeStyle='#22c55e'; ctx.lineWidth=3; ctx.beginPath(); ctx.moveTo(cx,cy); ctx.lineTo(cx,cy-lift); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(cx,cy-lift); ctx.lineTo(cx-5,cy-lift+8); ctx.lineTo(cx+5,cy-lift+8); ctx.closePath(); ctx.fillStyle='#22c55e'; ctx.fill();
      ctx.fillStyle='#4ade80'; ctx.font='600 12px Inter Tight, sans-serif'; ctx.fillText('Lift', cx+9, cy-lift+4);

      // freestream label
      ctx.fillStyle='#e5e7eb'; ctx.font='600 12px Inter Tight, sans-serif'; ctx.textAlign='left';
      ctx.fillText('v = '+state.v.toFixed(0)+' m/s  →', 14, H-16);
      ctx.textAlign='right'; ctx.fillStyle= P.stalled? '#fca5a5':'#7dd3fc';
      ctx.fillText('α = '+state.alpha.toFixed(1)+'°', W-14, H-16);
      ctx.textAlign='left';
    }

    function loop(){ if(running) t+=0.016; var P=physics(); updateReadouts(P); draw(P); requestAnimationFrame(loop); }
    requestAnimationFrame(loop);

    function bind(id,key,span,d){ var el=document.getElementById(id); el.addEventListener('input',function(){ state[key]=parseFloat(el.value); document.getElementById(span).textContent = d==null? el.value : parseFloat(el.value).toFixed(d); }); }
    bind('alpha','alpha','av',1); bind('v','v','vv',0); bind('camber','camber','cv2',1);
    document.getElementById('run').addEventListener('click',function(){ running=!running; this.innerHTML = running? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>Pause':'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>Run'; });
    document.getElementById('reset').addEventListener('click',function(){
      state={alpha:6,v:50,camber:2};
      document.getElementById('alpha').value=6; document.getElementById('av').textContent='6';
      document.getElementById('v').value=50; document.getElementById('vv').textContent='50';
      document.getElementById('camber').value=2; document.getElementById('cv2').textContent='2';
    });
  })();
  </script>
</body>
</html>
