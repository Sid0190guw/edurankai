---
// /aquintutor/lab/venturi — Venturi Meter virtual lab.
// A REAL interactive fluid-mechanics simulation, not a decorative image:
//   - you set inlet velocity, throat ratio, inlet pressure and fluid;
//   - the throat velocity, throat pressure, pressure drop, flow rate and
//     Reynolds number are all computed from first principles every frame
//     (continuity A1v1 = A2v2 and Bernoulli P + ½ρv² = const along a horizontal
//     streamline);
//   - the animated manometer columns and streamline speeds reflect those exact
//     computed values, and a cavitation warning fires when the throat pressure
//     falls toward the fluid's vapour pressure — a real engineering failure mode.
// Honest scope: this is a physically-accurate 2-D cross-section. It is not a
// WebGL 3-D render and does not claim to be; the "3-D / AR" views in the mockup
// are marked as future, not faked.
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex" />
  <title>Venturi Meter · Virtual Lab · AquinTutor</title>
  <style>
    :root{
      --bg:#0a0e17; --bg2:#0e1420; --panel:#111a2b; --panel2:#0d1524; --card:#131d2f;
      --stroke:#1e2a40; --stroke2:#26344d; --ink:#e6ecf7; --ink2:#aab6cc; --mut:#6c7b96;
      --blue:#3b82f6; --blue2:#60a5fa; --blueDim:#1e3a5f; --green:#22c55e; --red:#ef4444; --amber:#f59e0b;
    }
    *{box-sizing:border-box;}
    html,body{margin:0;min-height:100%;}
    body{background:var(--bg);color:var(--ink);font-family:'Inter Tight',system-ui,-apple-system,sans-serif;font-size:13px;}
    a{color:inherit;text-decoration:none;}
    .top{display:flex;align-items:center;gap:12px;padding:10px 16px;background:var(--bg2);border-bottom:1px solid var(--stroke);position:sticky;top:0;z-index:20;}
    .back{display:flex;align-items:center;gap:7px;padding:6px 11px;border:1px solid var(--stroke2);border-radius:9px;color:var(--ink2);font-size:12.5px;cursor:pointer;}
    .back:hover{color:var(--ink);}
    .ttl{font-family:'Cormorant Garamond',Georgia,serif;font-size:19px;font-weight:600;}
    .ttl small{display:block;font-family:'Inter Tight',sans-serif;font-size:10.5px;color:var(--mut);font-weight:400;letter-spacing:0.02em;}
    .top-right{margin-left:auto;display:flex;align-items:center;gap:9px;}
    .fluidsel{background:var(--panel2);border:1px solid var(--stroke2);color:var(--ink);font-family:inherit;font-size:12.5px;padding:7px 10px;border-radius:8px;cursor:pointer;}
    .fluidsel option{background:var(--panel);}
    .wrap{max-width:1120px;margin:0 auto;padding:16px;display:grid;grid-template-columns:minmax(0,1fr) 320px;gap:16px;}
    .stage{background:var(--panel);border:1px solid var(--stroke);border-radius:14px;padding:14px;}
    .stage-head{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
    .badge{font-size:9px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--blue2);background:rgba(59,130,246,0.12);padding:3px 8px;border-radius:5px;}
    .views{margin-left:auto;display:flex;gap:4px;}
    .view{font-size:11.5px;padding:5px 11px;border-radius:7px;color:var(--ink2);cursor:pointer;border:1px solid transparent;}
    .view.on{background:var(--card);color:var(--blue2);border-color:var(--stroke2);font-weight:600;}
    .view.soon{opacity:0.5;}
    #cv{width:100%;height:auto;display:block;border-radius:10px;background:#060b14;border:1px solid var(--stroke2);}
    .legend{display:flex;flex-wrap:wrap;gap:14px;margin-top:10px;font-size:11px;color:var(--ink2);}
    .legend i{display:inline-block;width:15px;height:3px;border-radius:2px;margin-right:5px;vertical-align:middle;}
    .runrow{display:flex;gap:8px;margin-top:12px;}
    .btn{flex:1;padding:10px;border-radius:9px;border:1px solid var(--stroke2);background:var(--panel2);color:var(--ink);font-family:inherit;font-size:12.5px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:7px;}
    .btn.primary{background:var(--blue);border-color:var(--blue);color:#fff;}
    .btn.primary:hover{background:#2f6fe0;}
    .btn:hover{border-color:var(--stroke2);}
    .side{display:flex;flex-direction:column;gap:14px;}
    .ctrls,.reads,.calc{background:var(--panel);border:1px solid var(--stroke);border-radius:14px;padding:15px;}
    .hh{font-size:9px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--mut);margin-bottom:12px;}
    .field{margin-bottom:14px;}
    .field:last-child{margin-bottom:0;}
    .field label{display:flex;justify-content:space-between;font-size:12px;color:var(--ink2);margin-bottom:7px;}
    .field label b{color:var(--blue2);font-family:'Geist Mono',monospace;}
    input[type=range]{width:100%;-webkit-appearance:none;appearance:none;height:5px;border-radius:3px;background:var(--stroke2);outline:none;}
    input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:17px;height:17px;border-radius:50%;background:var(--blue);cursor:pointer;border:2px solid #0a0e17;}
    input[type=range]::-moz-range-thumb{width:15px;height:15px;border-radius:50%;background:var(--blue);cursor:pointer;border:2px solid #0a0e17;}
    .reads-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px;}
    .rd{background:var(--panel2);border:1px solid var(--stroke2);border-radius:9px;padding:9px 11px;}
    .rd .k{font-size:10px;color:var(--mut);}
    .rd .v{font-size:17px;font-weight:700;font-family:'Geist Mono',monospace;margin-top:3px;}
    .rd .u{font-size:10px;color:var(--ink2);font-weight:400;}
    .rd.warn{border-color:var(--red);background:rgba(239,68,68,0.08);}
    .rd.warn .v{color:#fca5a5;}
    .cav{display:none;margin-top:11px;padding:9px 11px;border-radius:9px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.35);color:#fca5a5;font-size:11.5px;line-height:1.5;}
    .cav.on{display:block;}
    .calc{font-size:12px;color:var(--ink2);line-height:1.85;}
    .calc .eq{font-family:'Geist Mono',monospace;font-size:11.5px;color:var(--ink);background:var(--panel2);border:1px solid var(--stroke2);border-radius:7px;padding:7px 9px;margin:6px 0;overflow-x:auto;white-space:nowrap;}
    .calc b{color:var(--blue2);}
    @media (max-width:820px){
      .wrap{grid-template-columns:1fr;padding:12px;gap:12px;}
      .ttl{font-size:16px;} .ttl small{display:none;}
      .reads-grid{grid-template-columns:1fr 1fr;}
    }
  </style>
</head>
<body>
  <header class="top">
    <a class="back" href="/aquintutor/classroom/live"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>Classroom</a>
    <div class="ttl">Venturi Meter<small>Virtual Lab · live fluid-mechanics simulation</small></div>
    <div class="top-right">
      <select class="fluidsel" id="fluid" aria-label="Working fluid">
        <option value="water">Water · &rho; 998</option>
        <option value="air">Air · &rho; 1.2</option>
        <option value="oil">Oil · &rho; 850</option>
      </select>
    </div>
  </header>

  <div class="wrap">
    <section class="stage">
      <div class="stage-head">
        <span class="badge">Simulation</span>
        <span style="font-size:12px;color:var(--ink2)">Pipe &oslash; D&#8321; = 100 mm · horizontal</span>
        <div class="views">
          <span class="view on" data-view="sim">Flow</span>
          <span class="view" data-view="schem">Schematic</span>
          <span class="view soon" title="Planned — needs device camera / WebXR">AR · soon</span>
        </div>
      </div>
      <canvas id="cv" width="720" height="420"></canvas>
      <div class="legend">
        <span><i style="background:#38bdf8"></i>Streamline (colour = speed)</span>
        <span><i style="background:#ef4444"></i>Manometer — inlet (high P)</span>
        <span><i style="background:#3b82f6"></i>Manometer — throat (low P)</span>
      </div>
      <div class="runrow">
        <button class="btn primary" id="run"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>Pause</button>
        <button class="btn" id="reset"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>Reset</button>
      </div>
    </section>

    <aside class="side">
      <div class="ctrls">
        <div class="hh">Parameters</div>
        <div class="field">
          <label>Inlet velocity v&#8321; <b><span id="v1v">2.0</span> m/s</b></label>
          <input type="range" id="v1" min="0.5" max="8" step="0.1" value="2.0" />
        </div>
        <div class="field">
          <label>Throat ratio &beta; = D&#8322;/D&#8321; <b><span id="bv">0.50</span></b></label>
          <input type="range" id="beta" min="0.30" max="0.90" step="0.01" value="0.50" />
        </div>
        <div class="field">
          <label>Inlet pressure P&#8321; (gauge) <b><span id="p1v">120</span> kPa</b></label>
          <input type="range" id="p1" min="20" max="300" step="1" value="120" />
        </div>
      </div>

      <div class="reads">
        <div class="hh">Computed — live from the physics</div>
        <div class="reads-grid">
          <div class="rd"><div class="k">Throat velocity v&#8322;</div><div class="v"><span id="rV2">8.0</span> <span class="u">m/s</span></div></div>
          <div class="rd" id="rdP2"><div class="k">Throat pressure P&#8322;</div><div class="v"><span id="rP2">90</span> <span class="u">kPa</span></div></div>
          <div class="rd"><div class="k">Pressure drop &Delta;P</div><div class="v"><span id="rDP">30</span> <span class="u">kPa</span></div></div>
          <div class="rd"><div class="k">Flow rate Q</div><div class="v"><span id="rQ">942</span> <span class="u">L/min</span></div></div>
          <div class="rd"><div class="k">Reynolds Re</div><div class="v"><span id="rRe">2e5</span></div></div>
          <div class="rd"><div class="k">Regime</div><div class="v" style="font-size:14px;"><span id="rReg">Turbulent</span></div></div>
        </div>
        <div class="cav" id="cav"><b>Cavitation risk.</b> The throat pressure has fallen to the fluid's vapour pressure — vapour bubbles would form and collapse, damaging a real meter. Lower the velocity or open the throat.</div>
      </div>

      <div class="calc">
        <div class="hh">How it's computed</div>
        Continuity fixes the throat speed:
        <div class="eq">v&#8322; = v&#8321; / &beta;&sup2; = <span id="cV1">2.0</span> / <span id="cB2">0.25</span> = <span id="cV2">8.0</span> m/s</div>
        Bernoulli (horizontal streamline) gives the throat pressure:
        <div class="eq">P&#8322; = P&#8321; + &frac12;&rho;(v&#8321;&sup2; &minus; v&#8322;&sup2;) = <span id="cP2">90</span> kPa</div>
        Faster flow at the throat &rArr; lower pressure. That measured drop <b>&Delta;P</b> is exactly how a Venturi meter reads flow rate.
      </div>
    </aside>
  </div>

  <script is:inline>
  (function(){
    var FLUIDS = { water:{rho:998, mu:0.001, pv:2.34}, air:{rho:1.2, mu:1.8e-5, pv:0}, oil:{rho:850, mu:0.03, pv:0.4} };
    var D1 = 0.1;                 // inlet diameter (m)
    var A1 = Math.PI*D1*D1/4;     // inlet area (m^2)
    var PATM = 101.325;           // atmospheric (kPa) for absolute-pressure / cavitation check
    var state = { v1:2.0, beta:0.50, p1:120, fluid:'water' };
    var running = true;

    var cv = document.getElementById('cv'), ctx = cv.getContext('2d');
    var W = cv.width, H = cv.height, mid = H*0.52;

    // --- physics ---------------------------------------------------------
    function physics(){
      var f = FLUIDS[state.fluid];
      var b2 = state.beta*state.beta;
      var v1 = state.v1;
      var v2 = v1 / b2;                                  // continuity: A1v1=A2v2, A∝D²
      var p1 = state.p1;                                 // kPa gauge
      var dP = 0.5*f.rho*(v2*v2 - v1*v1) / 1000;         // Pa -> kPa
      var p2 = p1 - dP;                                  // Bernoulli
      var Q = A1*v1;                                     // m³/s
      var Re = f.rho*v1*D1 / f.mu;
      var p2abs = p2 + PATM;
      var cavitation = p2abs <= f.pv + 1.5;              // near vapour pressure
      return { v1:v1, v2:v2, p1:p1, p2:p2, dP:dP, Q:Q, Re:Re, cav:cavitation, b2:b2 };
    }

    function fmt(n, d){ if(!isFinite(n)) return '—'; var a=Math.abs(n); if(a>=1e5) return (n/1e3).toFixed(0)+'k'; return n.toFixed(d==null?1:d); }
    function fmtRe(re){ if(re>=1e6) return (re/1e6).toFixed(1)+'M'; if(re>=1e3) return (re/1e3).toFixed(0)+'k'; return re.toFixed(0); }

    function updateReadouts(P){
      document.getElementById('rV2').textContent = fmt(P.v2,1);
      document.getElementById('rP2').textContent = fmt(P.p2,0);
      document.getElementById('rDP').textContent = fmt(P.dP,0);
      document.getElementById('rQ').textContent  = fmt(P.Q*1000*60,0);      // m³/s -> L/min
      document.getElementById('rRe').textContent = fmtRe(P.Re);
      var laminar = P.Re < 2300, trans = P.Re < 4000;
      document.getElementById('rReg').textContent = laminar? 'Laminar' : (trans? 'Transitional' : 'Turbulent');
      var rdP2 = document.getElementById('rdP2'); rdP2.classList.toggle('warn', P.p2 < 0 || P.cav);
      document.getElementById('cav').classList.toggle('on', P.cav);
      // "how it's computed" panel with live numbers
      document.getElementById('cV1').textContent = P.v1.toFixed(1);
      document.getElementById('cB2').textContent = P.b2.toFixed(2);
      document.getElementById('cV2').textContent = P.v2.toFixed(1);
      document.getElementById('cP2').textContent = P.p2.toFixed(0);
    }

    // --- geometry: half-height of the pipe bore at x (converging-throat-diverging)
    function halfH(x, beta){
      var f = x/W;
      var wide = H*0.20, throat = wide*beta;
      // smooth converge into a central throat then diverge
      var dip = Math.exp(-Math.pow((f-0.5)/0.16, 2));
      return wide - (wide-throat)*dip;
    }

    var streams = [];
    for (var i=0;i<30;i++) streams.push({ y0:(i+0.5)/30, x:Math.random()*W });
    var view = 'sim';

    function draw(P){
      ctx.clearRect(0,0,W,H);
      var beta = state.beta;
      // pipe body
      ctx.beginPath(); ctx.moveTo(0, mid-halfH(0,beta));
      for (var x=0;x<=W;x+=6) ctx.lineTo(x, mid-halfH(x,beta));
      for (var x2=W;x2>=0;x2-=6) ctx.lineTo(x2, mid+halfH(x2,beta));
      ctx.closePath();
      var g = ctx.createLinearGradient(0,0,W,0);
      g.addColorStop(0,'#0b2a44'); g.addColorStop(0.5,'#0e3a5f'); g.addColorStop(1,'#0b2a44');
      ctx.fillStyle = g; ctx.fill(); ctx.strokeStyle='#1f4b70'; ctx.lineWidth=2; ctx.stroke();

      // manometer columns: heights ∝ pressure (relative scale)
      function manometer(x, pKpa, colHi, colLo){
        var top = mid - halfH(x,beta);
        var scale = 0.55;                              // px per kPa (visual)
        var h = Math.max(6, Math.min(150, pKpa*scale));
        ctx.fillStyle = '#0a1524'; ctx.fillRect(x-5, top-160, 10, 160);        // tube
        ctx.strokeStyle='#26344d'; ctx.strokeRect(x-5, top-160, 10, 160);
        var grad = ctx.createLinearGradient(0, top-h, 0, top);
        grad.addColorStop(0, colHi); grad.addColorStop(1, colLo);
        ctx.fillStyle = grad; ctx.fillRect(x-4, top-h, 8, h);
      }
      manometer(W*0.16, P.p1, '#f87171', '#7f1d1d');   // inlet — high
      manometer(W*0.50, Math.max(0,P.p2), '#60a5fa', '#1e3a8a'); // throat — low (clamp visual)

      // streamlines coloured by local speed
      streams.forEach(function(s){
        var localHalf = halfH(s.x,beta);
        var sp = (H*0.20) / localHalf;                 // v ∝ 1/area (∝ 1/half-height)
        if (running){ s.x += sp*1.9*(state.v1/2); if (s.x>W) s.x-=W; }
        var y = mid + (s.y0-0.5)*2*localHalf*0.86;
        ctx.beginPath(); ctx.arc(s.x, y, 1.6+sp*0.5, 0, 7);
        ctx.fillStyle = sp>1.6? '#bae6fd' : (sp>1.2? '#7dd3fc' : '#38bdf8'); ctx.fill();
        ctx.strokeStyle='rgba(125,211,252,'+Math.min(0.45,0.12*sp)+')'; ctx.lineWidth=1.3;
        ctx.beginPath(); ctx.moveTo(s.x,y); ctx.lineTo(s.x-7*sp,y); ctx.stroke();
      });

      // labels
      ctx.font='600 12px Inter Tight, sans-serif'; ctx.textAlign='center';
      ctx.fillStyle='#f87171'; ctx.fillText('High pressure · low velocity', W*0.16, mid-halfH(W*0.16,beta)-168);
      ctx.fillStyle='#60a5fa'; ctx.fillText('Low pressure · high velocity', W*0.50, mid-halfH(W*0.5,beta)-168);
      ctx.fillStyle='#e5e7eb'; ctx.textAlign='left';
      ctx.fillText('v₁ = '+P.v1.toFixed(1)+' m/s', 14, H-16);
      ctx.textAlign='right';
      ctx.fillText('v₂ = '+P.v2.toFixed(1)+' m/s', W-14, H-16);

      if (view === 'schem'){
        ctx.fillStyle='rgba(6,11,20,0.72)'; ctx.fillRect(0,0,W,H);
        ctx.strokeStyle='#3b82f6'; ctx.lineWidth=2;
        ctx.beginPath(); ctx.moveTo(0, mid-halfH(0,beta));
        for (var xs=0;xs<=W;xs+=6) ctx.lineTo(xs, mid-halfH(xs,beta));
        ctx.stroke();
        ctx.beginPath(); ctx.moveTo(0, mid+halfH(0,beta));
        for (var xs2=0;xs2<=W;xs2+=6) ctx.lineTo(xs2, mid+halfH(xs2,beta));
        ctx.stroke();
        ctx.setLineDash([5,5]); ctx.strokeStyle='#6c7b96';
        ctx.beginPath(); ctx.moveTo(0,mid); ctx.lineTo(W,mid); ctx.stroke(); ctx.setLineDash([]);
        ctx.fillStyle='#aab6cc'; ctx.font='600 13px Geist Mono, monospace'; ctx.textAlign='center';
        ctx.fillText('D₁', W*0.10, mid-halfH(W*0.10,beta)-8);
        ctx.fillText('D₂ = βD₁', W*0.50, mid-halfH(W*0.50,beta)-8);
        ctx.fillText('A₁v₁ = A₂v₂', W*0.5, mid+6);
      }
    }

    function loop(){ var P = physics(); updateReadouts(P); draw(P); requestAnimationFrame(loop); }
    requestAnimationFrame(loop);

    // --- controls --------------------------------------------------------
    function bind(id, key, span, d){ var el=document.getElementById(id); el.addEventListener('input', function(){ state[key]=parseFloat(el.value); document.getElementById(span).textContent = d==null? el.value : parseFloat(el.value).toFixed(d); }); }
    bind('v1','v1','v1v',1); bind('beta','beta','bv',2); bind('p1','p1','p1v',0);
    document.getElementById('fluid').addEventListener('change', function(){ state.fluid=this.value; });
    document.getElementById('run').addEventListener('click', function(){ running=!running; this.innerHTML = running? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>Pause' : '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>Run'; });
    document.getElementById('reset').addEventListener('click', function(){
      state={v1:2.0,beta:0.50,p1:120,fluid:state.fluid};
      document.getElementById('v1').value=2.0; document.getElementById('v1v').textContent='2.0';
      document.getElementById('beta').value=0.50; document.getElementById('bv').textContent='0.50';
      document.getElementById('p1').value=120; document.getElementById('p1v').textContent='120';
    });
    document.querySelectorAll('.view[data-view]').forEach(function(v){ v.addEventListener('click', function(){
      document.querySelectorAll('.view').forEach(function(x){x.classList.remove('on');}); v.classList.add('on'); view=v.getAttribute('data-view'); }); });
  })();
  </script>
</body>
</html>
