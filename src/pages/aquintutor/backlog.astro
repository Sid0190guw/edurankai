---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
// Backlog Recovery — the Aquin Scholars signature (Grades 11-12). A student who
// has fallen behind runs a short DIAGNOSTIC; the engine finds the EXACT
// sub-concepts they don't know and builds a HIGH-YIELD RECOVERY PATH for only
// those gaps — never "watch 12 hours of video". Goal-filtered by target so
// effort maps to marks (the ROI optimiser). Authored content, real engine, no LLM.
const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/backlog'));
---
<AquintutorLayout title="Backlog Recovery" description="Fallen behind? Run a 10-minute diagnostic and Aquin finds the exact sub-concepts you're missing, then builds a surgical recovery path — not 12 hours of video.">
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:860px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a><span style="margin:0 8px;">/</span><span style="color:var(--rust); font-weight:600;">BACKLOG RECOVERY</span>
    </div>
  </div>

  <section style="max-width:720px; margin:0 auto; padding:40px 28px 80px;">
    <p style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--rust); font-weight:700; margin:0 0 8px;">Aquin Scholars · 11-12</p>
    <h1 class="font-display" style="font-size:clamp(1.8rem,4vw,2.6rem); font-weight:500; letter-spacing:-0.01em; margin:0 0 6px; color:var(--ink);">Behind? Let's find the real gap.</h1>
    <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); line-height:1.6; margin:0 0 26px;">A backlog is never the whole topic — it's 2 or 3 sub-concepts. A ten-minute diagnostic finds exactly which, and I build a short recovery path for only those. No re-watching hours of lectures.</p>

    <div id="bkSetup" style="background:#fff; border:1.5px solid var(--rule); border-radius:16px; padding:18px;">
      <label style="display:block; font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink-500); margin-bottom:6px;">Which topic are you behind on?</label>
      <div id="bkTopics" style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:16px;"></div>
      <label style="display:block; font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink-500); margin-bottom:6px;">Your target (so I don't waste your time on low-yield questions)</label>
      <div id="bkGoals" style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:18px;">
        <button class="bk-goal on" data-g="boards">Board exam</button>
        <button class="bk-goal" data-g="nit">NIT / state</button>
        <button class="bk-goal" data-g="iit">IIT / top rank</button>
      </div>
      <button id="bkStart" type="button" style="background:var(--rust); color:#fff; border:none; font-family:'Inter Tight',sans-serif; font-size:15px; font-weight:600; padding:11px 26px; border-radius:10px; cursor:pointer;">Run the diagnostic</button>
    </div>

    <div id="bkFlow" style="display:none; margin-top:18px;"></div>
  </section>

  <style is:global>
    .bk-chip, .bk-goal { background:var(--sand-50); border:1.5px solid var(--rule); color:var(--ink); border-radius:9px; padding:8px 14px; font-family:'Inter Tight',sans-serif; font-size:13.5px; cursor:pointer; }
    .bk-chip.on, .bk-goal.on { background:var(--ink); color:var(--sand-50); border-color:var(--ink); font-weight:600; }
  </style>

  <script is:inline>
  (function(){
    // ---------- authored content ----------
    // stretch: core (everyone) · advanced (NIT+IIT) · elite (IIT only)
    var TOPICS={
      thermo:{ name:'Thermodynamics', subs:[
        { id:'firstlaw', name:'First law (ΔU = Q − W)', stretch:'core',
          dx:{ q:'A gas absorbs 200 J of heat and does 50 J of work. Its change in internal energy (J)?', a:150 },
          refresher:'First law: ΔU = Q − W. Heat added to the gas is +Q; work done BY the gas is −W. So absorbed heat raises ΔU, work done lowers it.',
          practice:[{ q:'A gas absorbs 300 J and does 120 J of work. ΔU (J)?', a:180 }] },
        { id:'processes', name:'Isothermal vs adiabatic', stretch:'core',
          dx:{ q:'In an ADIABATIC process, which quantity is zero?  1=Heat Q  2=Work W  3=ΔU  4=ΔT', a:1 },
          refresher:'Adiabatic: no heat exchange, Q = 0 (so ΔU = −W). Isothermal: temperature constant, ΔU = 0 (so Q = W). Do not confuse the two.',
          practice:[{ q:'In an ISOTHERMAL process for an ideal gas, which is zero?  1=Q  2=W  3=ΔU  4=Pressure', a:3 }] },
        { id:'carnot', name:'Carnot efficiency', stretch:'core',
          dx:{ q:'A Carnot engine works between 400 K and 300 K. Efficiency (%)?', a:25 },
          refresher:'Carnot efficiency η = 1 − Tc/Th, with temperatures in KELVIN. Here 1 − 300/400 = 0.25 = 25%.',
          practice:[{ q:'Carnot engine between 500 K and 300 K. Efficiency (%)?', a:40 }] },
        { id:'entropy', name:'Entropy change', stretch:'advanced',
          dx:{ q:'Reversible heat Q = 600 J added at constant T = 300 K. Entropy change ΔS (J/K)?', a:2 },
          refresher:'For a reversible process at constant temperature, ΔS = Q/T. Here 600/300 = 2 J/K.',
          practice:[{ q:'Q = 900 J at T = 300 K, reversible. ΔS (J/K)?', a:3 }] },
      ]},
      integration:{ name:'Integration (Calculus)', subs:[
        { id:'power', name:'Power rule', stretch:'core',
          dx:{ q:'∫ x³ dx = x⁴/n + C. What is n? (enter the number)', a:4 },
          refresher:'Power rule: ∫ xⁿ dx = xⁿ⁺¹ / (n+1) + C. Raise the power by one, divide by the new power.',
          practice:[{ q:'∫ x⁴ dx = x⁵/n + C. What is n?', a:5 }] },
        { id:'definite', name:'Definite integrals', stretch:'core',
          dx:{ q:'Evaluate ∫₀² 2x dx.', a:4 },
          refresher:'Definite integral: integrate, then plug in the upper limit minus the lower. ∫2x dx = x²; at 2 → 4, at 0 → 0; answer 4.',
          practice:[{ q:'Evaluate ∫₀³ 2x dx.', a:9 }] },
        { id:'sub', name:'Substitution', stretch:'advanced',
          dx:{ q:'For ∫ 2x·(x²+1)⁵ dx, the substitution u = x²+1 gives du = k·x dx. What is k?', a:2 },
          refresher:'Substitution: pick u so its derivative appears. u = x²+1 → du = 2x dx. The integral becomes ∫ u⁵ du.',
          practice:[{ q:'For ∫ 3x²·(x³+2)⁴ dx, u = x³+2 → du = k·x² dx. What is k?', a:3 }] },
        { id:'parts', name:'Integration by parts', stretch:'elite',
          dx:{ q:'∫ u dv = uv − ∫ v du. For ∫ x·eˣ dx, choosing u = x, what is du? (coefficient)', a:1 },
          refresher:'By parts: ∫ u dv = uv − ∫ v du. Choose u to simplify on differentiation (LIATE). For x·eˣ: u = x (du = 1·dx), dv = eˣ dx.',
          practice:[{ q:'For ∫ x·cos x dx, u = x. What is du? (coefficient)', a:1 }] },
      ]},
    };
    var STRETCH={boards:['core'], nit:['core','advanced'], iit:['core','advanced','elite']};
    var topic='thermo', goal='boards';

    var tb=document.getElementById('bkTopics');
    Object.keys(TOPICS).forEach(function(k,i){ var b=document.createElement('button'); b.className='bk-chip'+(i===0?' on':''); b.textContent=TOPICS[k].name; b.addEventListener('click',function(){ document.querySelectorAll('#bkTopics .bk-chip').forEach(function(x){x.classList.remove('on');}); b.classList.add('on'); topic=k; }); tb.appendChild(b); });
    document.querySelectorAll('.bk-goal').forEach(function(b){ b.addEventListener('click',function(){ document.querySelectorAll('.bk-goal').forEach(function(x){x.classList.remove('on');}); b.classList.add('on'); goal=b.getAttribute('data-g'); }); });

    var flow=document.getElementById('bkFlow');
    function activeSubs(){ var allow=STRETCH[goal]; return TOPICS[topic].subs.filter(function(s){ return allow.indexOf(s.stretch)>=0; }); }

    document.getElementById('bkStart').addEventListener('click', function(){
      document.getElementById('bkSetup').style.display='none';
      runDiagnostic();
    });

    function qHTML(q){ return '<p style="font-family:Inter Tight,sans-serif;font-size:15px;font-weight:600;color:var(--ink);margin:0 0 10px;line-height:1.5;">'+q.q+'</p><input class="bk-ans" inputmode="numeric" placeholder="Answer" style="width:160px;background:var(--sand-50);border:1.5px solid var(--rule);border-radius:9px;padding:10px 12px;font-size:16px;font-family:Geist Mono,monospace;color:var(--ink);outline:none;" />'; }

    function runDiagnostic(){
      var subs=activeSubs(), i=0, gaps=[];
      flow.style.display='block';
      show();
      function show(){
        if(i>=subs.length){ return results(subs,gaps); }
        var s=subs[i];
        flow.innerHTML='<div style="background:#fff;border:1.5px solid var(--rule);border-radius:16px;padding:18px;">'
          +'<div style="font-family:JetBrains Mono,monospace;font-size:10.5px;letter-spacing:0.12em;text-transform:uppercase;color:var(--rust);font-weight:700;margin-bottom:8px;">Diagnostic · '+(i+1)+' of '+subs.length+' · '+s.name+'</div>'
          +qHTML(s.dx)
          +'<div style="margin-top:14px;"><button id="bkNext" style="background:var(--rust);color:#fff;border:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;padding:10px 22px;border-radius:9px;cursor:pointer;">Next</button></div>';
        var inp=flow.querySelector('.bk-ans'); inp.focus();
        function next(){ var v=parseFloat((inp.value||'').replace(/[, ]/g,'')); if(isNaN(v)||Math.abs(v-s.dx.a)>1e-6) gaps.push(s); i++; show(); }
        document.getElementById('bkNext').addEventListener('click', next); inp.addEventListener('keydown',function(e){ if(e.key==='Enter') next(); });
      }
    }

    function results(subs, gaps){
      var known=subs.filter(function(s){ return gaps.indexOf(s)<0; });
      var mins=gaps.length*15;
      var html='<div style="background:#fff;border:1.5px solid var(--rule);border-radius:16px;padding:18px;">'
        +'<div style="font-family:JetBrains Mono,monospace;font-size:10.5px;letter-spacing:0.12em;text-transform:uppercase;color:var(--rust);font-weight:700;margin-bottom:8px;">Your real backlog</div>';
      if(gaps.length===0){ html+='<p style="font-family:Inter Tight,sans-serif;font-size:15px;color:#1c7a45;font-weight:600;margin:0;">No backlog here — you know all '+subs.length+' sub-concepts. Don\'t waste time re-studying this. Move on.</p></div>'; flow.innerHTML=html; return; }
      html+='<p style="font-family:Inter Tight,sans-serif;font-size:14.5px;color:var(--ink);line-height:1.6;margin:0 0 10px;">You already know <b>'+known.length+'</b> of '+subs.length+' sub-concepts. Your backlog is really just these <b>'+gaps.length+'</b> — a focused <b>~'+mins+' min</b> recovery, not hours of video:</p>';
      html+='<div style="display:flex;flex-direction:column;gap:6px;">';
      known.forEach(function(s){ html+='<div style="display:flex;align-items:center;gap:8px;font-family:Inter Tight,sans-serif;font-size:13px;color:var(--ink-500);"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#1c7a45" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg> '+s.name+' — solid, skipped</div>'; });
      gaps.forEach(function(s){ html+='<div style="display:flex;align-items:center;gap:8px;font-family:Inter Tight,sans-serif;font-size:13.5px;color:var(--rust);font-weight:600;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 8v4M12 16h.01M12 2a10 10 0 100 20 10 10 0 000-20z"/></svg> '+s.name+' — needs recovery</div>'; });
      html+='</div><button id="bkRecover" style="margin-top:16px;background:var(--ink);color:var(--sand-50);border:none;font-family:Inter Tight,sans-serif;font-size:15px;font-weight:600;padding:11px 24px;border-radius:10px;cursor:pointer;">Start my recovery path &rarr;</button></div>';
      flow.innerHTML=html;
      document.getElementById('bkRecover').addEventListener('click', function(){ recover(gaps); });
    }

    function recover(gaps){
      var i=0;
      step();
      function step(){
        if(i>=gaps.length){ done(); return; }
        var s=gaps[i], p=s.practice[0];
        flow.innerHTML='<div style="background:#fff;border:1.5px solid var(--rule);border-radius:16px;padding:18px;">'
          +'<div style="font-family:JetBrains Mono,monospace;font-size:10.5px;letter-spacing:0.12em;text-transform:uppercase;color:var(--rust);font-weight:700;margin-bottom:8px;">Recovery '+(i+1)+' of '+gaps.length+' · '+s.name+'</div>'
          +'<p style="font-family:Inter Tight,sans-serif;font-size:14.5px;color:var(--ink);line-height:1.7;background:rgba(43,87,126,0.06);border-left:3px solid #2b577e;border-radius:0 8px 8px 0;padding:11px 13px;margin:0 0 14px;">'+s.refresher+'</p>'
          +'<div style="font-family:JetBrains Mono,monospace;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink-500);margin-bottom:6px;">Now prove it</div>'
          +qHTML(p)
          +'<div style="margin-top:12px;display:flex;gap:8px;"><button id="bkCk" style="background:var(--rust);color:#fff;border:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;padding:10px 20px;border-radius:9px;cursor:pointer;">Check</button></div>'
          +'<p id="bkMsg" style="font-family:Inter Tight,sans-serif;font-size:13.5px;margin:12px 0 0;min-height:1em;"></p></div>';
        var inp=flow.querySelector('.bk-ans'); inp.focus();
        function ck(){ var v=parseFloat((inp.value||'').replace(/[, ]/g,'')), m=document.getElementById('bkMsg');
          if(isNaN(v)){ m.style.color='var(--rust)'; m.textContent='Type a number.'; return; }
          if(Math.abs(v-p.a)<1e-6){ m.style.color='#1c7a45'; m.textContent='Recovered. This sub-concept is repaired.';
            fetch('/api/aquintutor/learn',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'same-origin',body:JSON.stringify({action:'verify',skillId:'backlog-'+topic+'-'+s.id,verified:true})}).catch(function(){});
            i++; setTimeout(step,650);
          } else { m.style.color='var(--rust)'; m.textContent='Not yet — re-read the refresher above and try again. This is exactly the gap we\'re closing.'; }
        }
        document.getElementById('bkCk').addEventListener('click', ck); inp.addEventListener('keydown',function(e){ if(e.key==='Enter') ck(); });
      }
      function done(){
        flow.innerHTML='<div style="background:#fff;border:1.5px solid #1c7a45;border-radius:16px;padding:22px;text-align:center;">'
          +'<svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#1c7a45" stroke-width="2.5" style="margin-bottom:8px;"><path d="M20 6L9 17l-5-5"/></svg>'
          +'<h2 class="font-display" style="font-size:1.4rem;font-weight:500;color:var(--ink);margin:0 0 6px;">Backlog cleared.</h2>'
          +'<p style="font-family:Inter Tight,sans-serif;font-size:14px;color:var(--ink-500);margin:0 0 14px;">You repaired the exact gaps — surgically, not by re-studying everything. That is how you catch up without burning out.</p>'
          +'<a href="/aquintutor/backlog" style="background:var(--rust);color:#fff;text-decoration:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;padding:10px 22px;border-radius:10px;">Recover another topic</a></div>';
      }
    }
  })();
  </script>
</AquintutorLayout>
