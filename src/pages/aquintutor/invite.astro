---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { acceptInvite } from '@/lib/friends';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
const code = (new URL(Astro.request.url).searchParams.get('code') || '').trim().toUpperCase();

if (!user) {
  // Send to signup, preserve code in next param so we accept after they sign in
  return Astro.redirect('/portal/signup?next=' + encodeURIComponent('/aquintutor/invite?code=' + code));
}

let inviter: any = null;
if (code) {
  try {
    const r = await db.execute(sql`
      SELECT u.id, COALESCE(u.name, u.email) AS name
      FROM user_invite_codes ic JOIN users u ON ic.user_id = u.id
      WHERE ic.code = ${code} LIMIT 1
    `);
    const rows = Array.isArray(r) ? r : (r?.rows || []);
    inviter = rows[0] || null;
  } catch (_) {}
}

let result: any = null;
if (code && inviter && inviter.id !== user.id) {
  result = await acceptInvite(user.id, code);
}
---
<AquintutorLayout title="Invite" description="Accept a friend invitation.">
  <section style="border-bottom:1px solid var(--rule); background:linear-gradient(180deg,#fff8f3 0%, var(--paper) 100%);">
    <div style="max-width:560px; margin:0 auto; padding:64px 28px;">
      {!code && (
        <>
          <p style="font-family:'Inter Tight',monospace; font-size:12px; color:var(--rust); font-weight:700; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Invite</p>
          <h1 class="font-display" style="font-size:clamp(2rem,4vw,3rem); line-height:1.1; font-weight:500;">No invite code in this link.</h1>
          <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); margin-top:14px;">Ask the person inviting you for their 8-character code, then enter it at <a href="/aquintutor/friends" style="color:var(--rust); font-weight:600;">/aquintutor/friends</a>.</p>
        </>
      )}
      {code && !inviter && (
        <>
          <p style="font-family:'Inter Tight',monospace; font-size:12px; color:#ef4444; font-weight:700; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Not found</p>
          <h1 class="font-display" style="font-size:clamp(1.8rem,3.5vw,2.6rem); line-height:1.15; font-weight:500;">That invite code doesn't exist.</h1>
          <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); margin-top:14px;">Double-check the code with the person who shared it.</p>
        </>
      )}
      {code && inviter && inviter.id === user.id && (
        <>
          <p style="font-family:'Inter Tight',monospace; font-size:12px; color:var(--rust); font-weight:700; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">That's you</p>
          <h1 class="font-display" style="font-size:clamp(1.8rem,3.5vw,2.6rem); line-height:1.15; font-weight:500;">You can't invite yourself.</h1>
          <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); margin-top:14px;">Share <a href="/aquintutor/friends" style="color:var(--rust); font-weight:600;">your invite link</a> with others.</p>
        </>
      )}
      {result && result.ok && (
        <>
          <p style="font-family:'Inter Tight',monospace; font-size:12px; color:#10b981; font-weight:700; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Connected ✓</p>
          <h1 class="font-display" style="font-size:clamp(2rem,4vw,3rem); line-height:1.1; font-weight:500;">You're friends with {result.friendName}!</h1>
          <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); margin:14px 0 24px;">+50 XP added to your account. They got +50 XP too.</p>
          <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <a href="/aquintutor/friends" style="background:var(--rust); color:#fff; padding:12px 22px; border-radius:10px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:700; text-decoration:none;">See friends →</a>
            <a href="/aquintutor/dashboard" style="background:var(--paper); color:var(--ink); padding:12px 22px; border-radius:10px; border:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:700; text-decoration:none;">Dashboard</a>
          </div>
        </>
      )}
    </div>
  </section>
</AquintutorLayout>
