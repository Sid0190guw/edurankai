---
// /aquintutor/xp — XP, streak, badges, leaderboard from the auditable ledger (Prompt 15, main
// surface). Real actions only. Leaderboard honors opt-out (toggle here). Server-rendered.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { totalXp, gamerState, leaderboard, BADGES, evaluateBadges } from '@/lib/xp-ledger';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/xp');
const rows = (r: any): any[] => (Array.isArray(r) ? r : (r?.rows || []));
const one = async (s: any) => { try { return rows(await db.execute(s))[0]; } catch { return null; } };
const xp = await totalXp(user.id).catch(() => 0);
const state = await gamerState(user.id).catch(() => ({ streak: 0, optOut: false }));
const lessons = Number((await one(sql`SELECT COUNT(*) FILTER (WHERE completed)::int AS c FROM edu_progress WHERE user_id = ${user.id}`))?.c || 0);
const mastered = Number((await one(sql`SELECT COUNT(*)::int AS c FROM aq_mastery WHERE user_id = ${user.id} AND skill_id LIKE 'ko:%' AND (state='mastered' OR verified=true)`))?.c || 0);
const perfectPass = !!(await one(sql`SELECT 1 AS x FROM edu_attempts WHERE user_id = ${user.id} AND mode='official' AND pct >= 100 LIMIT 1`))?.x;
const earned = new Set(evaluateBadges({ lessons, mastered, streak: state.streak, perfectPass, xp }));
const board = await leaderboard(10).catch(() => []);
const CARD = 'background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:14px;padding:20px 22px;margin-bottom:16px;';
---
<AquintutorLayout title="XP & rewards">
  <main style="max-width:800px;margin:0 auto;padding:44px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Rewards</p>
    <h1 style="font-family:Fraunces,serif;font-size:32px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 18px;line-height:1.15;">Your progress rewards</h1>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-bottom:16px;">
      <div style={CARD}><p style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#8a8478;margin:0;">XP</p><p style="font-family:Fraunces,serif;font-size:30px;font-weight:600;margin:4px 0 0;color:var(--ink,#1a1712);">{xp}</p></div>
      <div style={CARD}><p style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#8a8478;margin:0;">Day streak</p><p style="font-family:Fraunces,serif;font-size:30px;font-weight:600;margin:4px 0 0;color:var(--ink,#1a1712);">{state.streak}</p></div>
      <div style={CARD}><p style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#8a8478;margin:0;">Badges</p><p style="font-family:Fraunces,serif;font-size:30px;font-weight:600;margin:4px 0 0;color:var(--ink,#1a1712);">{earned.size}<span style="font-size:15px;color:#8a8478;"> / {BADGES.length}</span></p></div>
    </div>

    <div style={CARD}>
      <h2 style="font-family:Fraunces,serif;font-size:18px;font-weight:600;margin:0 0 12px;">Badges</h2>
      <div style="display:flex;flex-wrap:wrap;gap:8px;">{BADGES.map((b) => (
        <span style={'font-family:Inter Tight,sans-serif;font-size:12.5px;border-radius:100px;padding:5px 13px;border:1px solid var(--line,#e6e1d6);' + (earned.has(b.id) ? 'background:#eef8f1;color:#1f7a4d;' : 'background:#faf8f2;color:#b0a99a;')}>{earned.has(b.id) ? 'x ' : ''}{b.label}</span>
      ))}</div>
    </div>

    <div style={CARD}>
      <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:12px;">
        <h2 style="font-family:Fraunces,serif;font-size:18px;font-weight:600;margin:0;">Leaderboard</h2>
        <label style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#6b6455;"><input type="checkbox" id="optOut" checked={state.optOut} /> Hide me from the leaderboard</label>
      </div>
      {board.length === 0 ? <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#6b6455;margin:0;">No XP earned yet — complete a lesson to appear here.</p> :
        <ol style="list-style:none;margin:0;padding:0;">{board.map((e: any, i: number) => (
          <li style={'display:flex;justify-content:space-between;padding:8px 10px;border-radius:8px;font-family:Inter Tight,sans-serif;font-size:14px;' + (e.userId === user.id ? 'background:#faf8f2;font-weight:700;' : '')}><span>{i + 1}. {e.userId === user.id ? 'You' : e.name}</span><span style="color:var(--rust,#b3541e);">{e.xp} XP</span></li>
        ))}</ol>}
    </div>
    <p style="font-family:'Inter Tight',sans-serif;font-size:12px;color:#8a8478;margin:16px 0 0;">Every point comes from a real action and is recorded once — re-doing a lesson never double-counts.</p>
  </main>

  <script is:inline>
    (function () { var el = document.getElementById('optOut'); if (!el) return; el.addEventListener('change', function () {
      fetch('/api/aquintutor/xp-optout', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ optOut: el.checked }) }).then(function () { location.reload(); });
    }); })();
  </script>
</AquintutorLayout>
