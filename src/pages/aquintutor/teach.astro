---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
const user = Astro.locals.user;
---
<AquintutorLayout title="Live teaching canvas · AquinTutor" description="Type a command and a teaching visual generates instantly — function plots, trees, graphs, sorting, matrices, geometry. A real-time visual generator for live teaching. Plus a freehand whiteboard. Pure browser.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; overflow: hidden; }
  .tv-shell { display: grid; grid-template-rows: 50px 1fr 64px; height: 100vh; }
  .tv-bar { background: #11131a; border-bottom: 1px solid #2a2a35; display: flex; align-items: center; padding: 0 16px; gap: 14px; }
  .tv-bar a { color: #67e8f9; text-decoration: none; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; }
  .tv-title { font-family: 'Cormorant Garamond', serif; font-size: 18px; color: #fff; font-weight: 600; }
  .tv-title em { color: #67e8f9; font-style: italic; }
  .tv-bar-right { margin-left: auto; display: flex; gap: 6px; }
  .tv-bbtn { background: transparent; border: 1px solid #2a2a35; color: #cfd6da; padding: 6px 14px; border-radius: 6px; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
  .tv-bbtn.active { background: #67e8f9; color: #04161b; border-color: #67e8f9; }

  .tv-stage { position: relative; background: #fbfaf7; overflow: hidden; }
  #teachCanvas { position: absolute; inset: 0; width: 100%; height: 100%; }
  #penCanvas { position: absolute; inset: 0; width: 100%; height: 100%; cursor: crosshair; }
  #penCanvas.off { pointer-events: none; }
  .tv-hint { position: absolute; top: 14px; left: 14px; font-family: 'Geist Mono', monospace; font-size: 11px; color: #7A6F68; background: rgba(255,255,255,0.7); padding: 6px 12px; border-radius: 6px; pointer-events: none; }

  .tv-cmd { background: #11131a; border-top: 1px solid #2a2a35; display: flex; align-items: center; gap: 10px; padding: 0 16px; }
  .tv-cmd input { flex: 1; background: #0a0a0c; border: 1px solid #2a2a35; color: #fff; padding: 12px 16px; border-radius: 10px; font-family: ui-monospace, monospace; font-size: 14px; }
  .tv-cmd button { background: #67e8f9; color: #04161b; border: none; padding: 12px 22px; border-radius: 10px; font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; cursor: pointer; }
  .tv-examples { position: absolute; bottom: 76px; left: 14px; display: flex; gap: 6px; flex-wrap: wrap; max-width: 70%; }
  .tv-ex { background: rgba(17,19,26,0.92); border: 1px solid #2a2a35; color: #cfd6da; padding: 5px 11px; border-radius: 100px; font-family: ui-monospace, monospace; font-size: 11px; cursor: pointer; }
  .tv-ex:hover { border-color: #67e8f9; color: #67e8f9; }
  .tv-pen-tools { position: absolute; top: 14px; right: 14px; display: flex; gap: 6px; align-items: center; background: rgba(255,255,255,0.85); padding: 6px 8px; border-radius: 8px; }
  .tv-pen-tools input[type=color] { width: 28px; height: 28px; border: none; background: none; cursor: pointer; }
  .tv-pen-tools button { background: #fff; border: 1px solid rgba(14,11,8,0.15); color: #0E0B08; padding: 5px 10px; border-radius: 5px; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 10px; font-weight: 700; }
</style>

<div class="tv-shell">
  <div class="tv-bar">
    <a href="/aquintutor/labs">&larr; Labs</a>
    <span class="tv-title">Live <em>teaching canvas</em></span>
    <span style="color:#7A6F68;font-family:'Geist Mono',monospace;font-size:11px;">Type a command &middot; a visual generates instantly</span>
    <div class="tv-bar-right">
      <button id="penToggle" class="tv-bbtn">Whiteboard</button>
      <button id="clearBtn" class="tv-bbtn">Clear</button>
      <button id="fsBtn" class="tv-bbtn">Present</button>
    </div>
  </div>

  <div class="tv-stage" id="stage">
    <canvas id="teachCanvas"></canvas>
    <canvas id="penCanvas" class="off"></canvas>
    <div class="tv-hint" id="hint">Try: <b>plot sin(x) + 0.4*cos(3*x)</b></div>
    <div class="tv-pen-tools" id="penTools" style="display:none;">
      <input id="penColor" type="color" value="#a0421e"/>
      <button id="penEraser">Eraser</button>
      <button id="penClear">Clear ink</button>
    </div>
    <div class="tv-examples" id="examples"></div>
  </div>

  <div class="tv-cmd">
    <input id="cmd" placeholder="plot x^2 - 3   ·   tree 8 3 10 1 6 14   ·   bars 5 2 8 1 9 3   ·   matrix 1 1 0 1   ·   numberline -5 5   ·   circle 3   ·   graph A-B B-C C-A"/>
    <button id="genBtn">Generate</button>
  </div>
</div>

<script is:inline>
(function () {
  var stage = document.getElementById('stage');
  var tc = document.getElementById('teachCanvas'), tx = tc.getContext('2d');
  var pc = document.getElementById('penCanvas'), px = pc.getContext('2d');
  var W, H;
  function resize() {
    var r = stage.getBoundingClientRect();
    W = r.width; H = r.height;
    [tc, pc].forEach(function (c) { c.width = W; c.height = H; });
    if (lastCmd) generate(lastCmd, true);
  }
  window.addEventListener('resize', resize);

  var lastCmd = '';
  function clearStage() { tx.fillStyle = '#fbfaf7'; tx.fillRect(0, 0, W, H); }

  // ---- math expression compiler (safe) ----
  function compile(expr) {
    var allowed = expr.replace(/\b(x|sin|cos|tan|asin|acos|atan|sqrt|abs|exp|log|ln|pi|e|pow|min|max|floor|ceil|round|sign)\b/g, '')
      .replace(/[0-9.+\-*/()^,%\s]/g, '');
    if (allowed.length) throw new Error('bad expr');
    var js = expr.replace(/\bln\b/g, 'Math.log').replace(/\b(sin|cos|tan|asin|acos|atan|sqrt|abs|exp|log|pow|min|max|floor|ceil|round|sign)\b/g, 'Math.$1')
      .replace(/\bpi\b/g, 'Math.PI').replace(/\be\b/g, 'Math.E').replace(/\^/g, '**');
    return new Function('x', 'return ' + js + ';');
  }

  // ---- generators ----
  function gPlot(expr) {
    clearStage();
    drawAxes();
    var fns = expr.split(',').map(function (s) { return s.trim(); }).filter(Boolean);
    var colors = ['#a0421e', '#1045BB', '#1A6B35', '#6B1FBE', '#946322'];
    var sx = W / 16, oy = H / 2, ox = W / 2;
    fns.forEach(function (f, fi) {
      var fn; try { fn = compile(f); } catch (e) { return; }
      tx.strokeStyle = colors[fi % colors.length]; tx.lineWidth = 3; tx.beginPath();
      var started = false;
      for (var px2 = 0; px2 <= W; px2++) {
        var xv = (px2 - ox) / sx;
        var yv = fn(xv);
        if (!isFinite(yv)) { started = false; continue; }
        var py = oy - yv * (H / 8);
        if (!started) { tx.moveTo(px2, py); started = true; } else tx.lineTo(px2, py);
      }
      tx.stroke();
      tx.fillStyle = colors[fi % colors.length]; tx.font = '600 18px Cormorant Garamond, serif';
      tx.fillText('y = ' + f, 20, 36 + fi * 26);
    });
  }
  function drawAxes() {
    var ox = W / 2, oy = H / 2, sx = W / 16, sy = H / 8;
    tx.strokeStyle = '#e3ddd0'; tx.lineWidth = 1;
    for (var gx = ox % sx; gx < W; gx += sx) { tx.beginPath(); tx.moveTo(gx, 0); tx.lineTo(gx, H); tx.stroke(); }
    for (var gy = oy % sy; gy < H; gy += sy) { tx.beginPath(); tx.moveTo(0, gy); tx.lineTo(W, gy); tx.stroke(); }
    tx.strokeStyle = '#0E0B08'; tx.lineWidth = 1.5;
    tx.beginPath(); tx.moveTo(0, oy); tx.lineTo(W, oy); tx.moveTo(ox, 0); tx.lineTo(ox, H); tx.stroke();
  }
  function gBars(nums) {
    clearStage();
    var n = nums.length, max = Math.max.apply(null, nums) || 1;
    var bw = (W - 80) / n, base = H - 60;
    nums.forEach(function (v, i) {
      var bh = (v / max) * (H - 140);
      tx.fillStyle = 'hsl(' + (200 + i * 24) + ',60%,55%)';
      tx.fillRect(40 + i * bw + 4, base - bh, bw - 8, bh);
      tx.fillStyle = '#0E0B08'; tx.font = '600 20px Cormorant Garamond, serif'; tx.textAlign = 'center';
      tx.fillText(v, 40 + i * bw + bw / 2, base + 26);
    });
    tx.textAlign = 'left'; tx.fillStyle = '#7A6F68'; tx.font = '14px ui-monospace';
    tx.fillText('array · ' + n + ' elements', 40, 40);
  }
  function gTree(nums) {
    clearStage();
    // build a BST
    var root = null;
    function ins(node, v) { if (!node) return { v: v, l: null, r: null }; if (v < node.v) node.l = ins(node.l, v); else node.r = ins(node.r, v); return node; }
    nums.forEach(function (v) { root = ins(root, v); });
    var depth = 0; (function d(n, dd){ if(!n) return; depth=Math.max(depth,dd); d(n.l,dd+1); d(n.r,dd+1); })(root, 0);
    var levelH = Math.min(120, (H - 120) / (depth + 1));
    function draw(n, x, y, dx) {
      if (!n) return;
      if (n.l) { tx.strokeStyle = '#c9c2b3'; tx.lineWidth = 2; tx.beginPath(); tx.moveTo(x, y); tx.lineTo(x - dx, y + levelH); tx.stroke(); draw(n.l, x - dx, y + levelH, dx / 1.9); }
      if (n.r) { tx.strokeStyle = '#c9c2b3'; tx.lineWidth = 2; tx.beginPath(); tx.moveTo(x, y); tx.lineTo(x + dx, y + levelH); tx.stroke(); draw(n.r, x + dx, y + levelH, dx / 1.9); }
      tx.fillStyle = '#1045BB'; tx.beginPath(); tx.arc(x, y, 22, 0, Math.PI * 2); tx.fill();
      tx.fillStyle = '#fff'; tx.font = '700 16px ui-monospace'; tx.textAlign = 'center'; tx.textBaseline = 'middle'; tx.fillText(n.v, x, y);
    }
    tx.textBaseline = 'middle';
    draw(root, W / 2, 70, W / 5);
    tx.textAlign = 'left'; tx.textBaseline = 'alphabetic'; tx.fillStyle = '#7A6F68'; tx.font = '14px ui-monospace'; tx.fillText('binary search tree', 40, 40);
  }
  function gMatrix(a, b, c, d) {
    clearStage(); drawAxes();
    var ox = W / 2, oy = H / 2, u = Math.min(W, H) / 8;
    function pt(x, y) { return { x: ox + (a * x + b * y) * u, y: oy - (c * x + d * y) * u }; }
    // unit grid transformed
    tx.strokeStyle = '#d97757'; tx.lineWidth = 1;
    for (var i = -4; i <= 4; i++) {
      var p1 = pt(i, -4), p2 = pt(i, 4); tx.beginPath(); tx.moveTo(p1.x, p1.y); tx.lineTo(p2.x, p2.y); tx.stroke();
      var p3 = pt(-4, i), p4 = pt(4, i); tx.beginPath(); tx.moveTo(p3.x, p3.y); tx.lineTo(p4.x, p4.y); tx.stroke();
    }
    function vec(x, y, col) { var p = pt(x, y); tx.strokeStyle = col; tx.lineWidth = 4; tx.beginPath(); tx.moveTo(ox, oy); tx.lineTo(p.x, p.y); tx.stroke(); tx.fillStyle = col; tx.beginPath(); tx.arc(p.x, p.y, 5, 0, 7); tx.fill(); }
    vec(1, 0, '#1045BB'); vec(0, 1, '#1A6B35');
    var det = a * d - b * c;
    tx.fillStyle = '#0E0B08'; tx.font = '600 20px Cormorant Garamond, serif';
    tx.fillText('M = [' + a + ' ' + b + '; ' + c + ' ' + d + ']   det = ' + det.toFixed(2), 20, 36);
  }
  function gNumberline(lo, hi) {
    clearStage();
    var y = H / 2, pad = 80;
    tx.strokeStyle = '#0E0B08'; tx.lineWidth = 2; tx.beginPath(); tx.moveTo(pad, y); tx.lineTo(W - pad, y); tx.stroke();
    var n = hi - lo;
    for (var i = 0; i <= n; i++) {
      var xx = pad + (W - 2 * pad) * (i / n);
      tx.beginPath(); tx.moveTo(xx, y - 10); tx.lineTo(xx, y + 10); tx.stroke();
      tx.fillStyle = '#0E0B08'; tx.font = '600 18px Cormorant Garamond, serif'; tx.textAlign = 'center'; tx.fillText(lo + i, xx, y + 34);
    }
    tx.textAlign = 'left';
  }
  function gCircle(r) {
    clearStage(); drawAxes();
    var ox = W / 2, oy = H / 2, u = Math.min(W, H) / 10;
    tx.strokeStyle = '#6B1FBE'; tx.lineWidth = 3; tx.beginPath(); tx.arc(ox, oy, r * u, 0, Math.PI * 2); tx.stroke();
    tx.strokeStyle = '#1045BB'; tx.lineWidth = 2; tx.beginPath(); tx.moveTo(ox, oy); tx.lineTo(ox + r * u * Math.cos(-0.6), oy + r * u * Math.sin(-0.6)); tx.stroke();
    tx.fillStyle = '#0E0B08'; tx.font = '600 20px Cormorant Garamond, serif';
    tx.fillText('circle r=' + r + '   area = ' + (Math.PI * r * r).toFixed(2) + '   circumference = ' + (2 * Math.PI * r).toFixed(2), 20, 36);
  }
  function gGraph(edgesStr) {
    clearStage();
    var edges = edgesStr.split(/\s+/).filter(Boolean).map(function (e) { return e.split('-'); });
    var nodes = {};
    edges.forEach(function (e) { nodes[e[0]] = 1; nodes[e[1]] = 1; });
    var keys = Object.keys(nodes); var pos = {};
    keys.forEach(function (k, i) { var a = (i / keys.length) * Math.PI * 2; pos[k] = { x: W / 2 + Math.cos(a) * Math.min(W, H) / 3.2, y: H / 2 + Math.sin(a) * Math.min(W, H) / 3.2 }; });
    edges.forEach(function (e) { var p1 = pos[e[0]], p2 = pos[e[1]]; if (!p1 || !p2) return; tx.strokeStyle = '#c9c2b3'; tx.lineWidth = 2; tx.beginPath(); tx.moveTo(p1.x, p1.y); tx.lineTo(p2.x, p2.y); tx.stroke(); });
    keys.forEach(function (k) { var p = pos[k]; tx.fillStyle = '#1A6B35'; tx.beginPath(); tx.arc(p.x, p.y, 24, 0, 7); tx.fill(); tx.fillStyle = '#fff'; tx.font = '700 16px ui-monospace'; tx.textAlign = 'center'; tx.textBaseline = 'middle'; tx.fillText(k, p.x, p.y); });
    tx.textAlign = 'left'; tx.textBaseline = 'alphabetic';
  }

  function generate(cmd, silent) {
    lastCmd = cmd;
    var parts = cmd.trim().split(/\s+/);
    var verb = (parts[0] || '').toLowerCase();
    try {
      if (verb === 'plot') gPlot(cmd.slice(4).trim());
      else if (verb === 'bars' || verb === 'sort') gBars(parts.slice(1).map(Number).filter(function (n) { return !isNaN(n); }));
      else if (verb === 'tree' || verb === 'bst') gTree(parts.slice(1).map(Number).filter(function (n) { return !isNaN(n); }));
      else if (verb === 'matrix') { var m = parts.slice(1).map(Number); gMatrix(m[0] || 1, m[1] || 0, m[2] || 0, m[3] || 1); }
      else if (verb === 'numberline' || verb === 'line') { gNumberline(Number(parts[1]) || -5, Number(parts[2]) || 5); }
      else if (verb === 'circle') gCircle(Number(parts[1]) || 3);
      else if (verb === 'graph') gGraph(parts.slice(1).join(' '));
      else { gPlot(cmd); } // assume it's an expression
      document.getElementById('hint').style.display = 'none';
    } catch (e) {
      if (!silent) { clearStage(); tx.fillStyle = '#b91c1c'; tx.font = '600 20px Cormorant Garamond, serif'; tx.fillText('Could not render: ' + e.message, 30, 50); }
    }
  }

  document.getElementById('genBtn').addEventListener('click', function () { generate(document.getElementById('cmd').value); });
  document.getElementById('cmd').addEventListener('keydown', function (e) { if (e.key === 'Enter') generate(this.value); });

  // examples
  var examples = ['plot sin(x)*exp(-0.1*x)', 'tree 50 30 70 20 40 60 80', 'bars 5 2 8 1 9 3 7', 'matrix 0 -1 1 0', 'circle 4', 'graph A-B B-C C-D D-A A-C', 'numberline -8 8', 'plot x^3 - 3*x'];
  var exWrap = document.getElementById('examples');
  examples.forEach(function (ex) { var b = document.createElement('button'); b.className = 'tv-ex'; b.textContent = ex; b.addEventListener('click', function () { document.getElementById('cmd').value = ex; generate(ex); }); exWrap.appendChild(b); });

  // ---- whiteboard pen overlay ----
  var penOn = false, drawing = false, eraser = false;
  document.getElementById('penToggle').addEventListener('click', function () {
    penOn = !penOn; this.classList.toggle('active', penOn); pc.classList.toggle('off', !penOn);
    document.getElementById('penTools').style.display = penOn ? 'flex' : 'none';
  });
  pc.addEventListener('mousedown', function (e) { drawing = true; px.beginPath(); px.moveTo(e.offsetX, e.offsetY); });
  pc.addEventListener('mousemove', function (e) { if (!drawing) return; px.lineTo(e.offsetX, e.offsetY); px.strokeStyle = eraser ? '#fbfaf7' : document.getElementById('penColor').value; px.lineWidth = eraser ? 26 : 3; px.lineCap = 'round'; px.lineJoin = 'round'; px.globalCompositeOperation = eraser ? 'destination-out' : 'source-over'; px.stroke(); });
  window.addEventListener('mouseup', function () { drawing = false; });
  document.getElementById('penEraser').addEventListener('click', function () { eraser = !eraser; this.style.background = eraser ? '#FF4F00' : '#fff'; this.style.color = eraser ? '#fff' : '#0E0B08'; });
  document.getElementById('penClear').addEventListener('click', function () { px.clearRect(0, 0, W, H); });
  document.getElementById('clearBtn').addEventListener('click', function () { clearStage(); px.clearRect(0, 0, W, H); lastCmd = ''; document.getElementById('hint').style.display = 'block'; });
  document.getElementById('fsBtn').addEventListener('click', function () { if (!document.fullscreenElement) stage.requestFullscreen && stage.requestFullscreen(); else document.exitFullscreen(); });

  resize();
  setTimeout(function () { generate('plot sin(x) + 0.4*cos(3*x)'); }, 100);
})();
</script>
</AquintutorLayout>
