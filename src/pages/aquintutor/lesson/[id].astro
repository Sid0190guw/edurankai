---
// /aquintutor/lesson/[id] — KnowledgeObject (lesson) view (Prompt 3, main surface).
// Server-side gated: unpublished drafts are visible only to staff (write capability); the
// securityLabel is enforced via can() (deny -> redirect, not merely hidden). Renders concept,
// body (markdown), equations (LaTeX), worked examples, and prerequisite links. Zero client JS.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { can } from '@/lib/rbac';
import { contentService } from '@/lib/kernel-content';
import { mdLite, latexToHtml, EQUATION_CSS } from '@/lib/content-render';

const user = Astro.locals.user;
const id = Astro.params.id!;
const view = await contentService().getUnitView(id).catch(() => null);
if (!view) return new Response('Lesson not found', { status: 404 });

const unit: any = view.unit;
const data = unit.data as any;
const labels = unit.securityLabels || ['public'];
const isStaff = (await can(user, 'write', { type: 'KnowledgeObject' })).allow;

// draft visibility: only staff may see a not-yet-published unit
if (unit.lifecycleState !== 'published' && !isStaff) return Astro.redirect('/aquintutor/courses');
// securityLabel gate (audited)
const gate = await can(user, 'read', { type: 'KnowledgeObject', securityLabels: labels });
if (!gate.allow) return Astro.redirect('/aquintutor/courses?locked=' + encodeURIComponent(labels.join(',')));

const lm = unit.learningMetadata || {};
const equations = Array.isArray(data.equations) ? data.equations : [];
const examples = Array.isArray(data.examples) ? data.examples : [];
const course = view.courses[0];
---
<AquintutorLayout title={data.title}>
  <style set:html={EQUATION_CSS}></style>
  <main style="max-width:760px;margin:0 auto;padding:44px 22px 80px;">
    {course ? <a href={'/aquintutor/lesson-index/' + course.id} style="font-family:'Inter Tight',sans-serif;font-size:13px;color:var(--rust,#b3541e);text-decoration:none;">&larr; {course.title}</a> : null}
    {unit.lifecycleState !== 'published' ? <p style="font-family:'Geist Mono',monospace;font-size:11px;color:#b3541e;margin:8px 0 0;">DRAFT &middot; {unit.lifecycleState} &middot; visible to staff only</p> : null}
    <h1 style="font-family:Fraunces,serif;font-size:32px;font-weight:600;color:var(--ink,#1a1712);margin:10px 0 8px;line-height:1.15;">{data.title}</h1>

    <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:22px;font-family:'Inter Tight',sans-serif;font-size:12px;color:#6b6455;">
      {lm.difficulty ? <span style="border:1px solid var(--line,#e6e1d6);border-radius:100px;padding:3px 11px;">{lm.difficulty}</span> : null}
      {lm.estimatedMinutes ? <span style="border:1px solid var(--line,#e6e1d6);border-radius:100px;padding:3px 11px;">{lm.estimatedMinutes} min</span> : null}
      {Array.isArray(lm.languages) && lm.languages.length ? <span style="border:1px solid var(--line,#e6e1d6);border-radius:100px;padding:3px 11px;">{lm.languages.join(' · ')}</span> : null}
      <span style="border:1px solid var(--line,#e6e1d6);border-radius:100px;padding:3px 11px;">{labels[0]}</span>
    </div>

    {view.prerequisites.length ? (
      <div style="background:#faf8f2;border:1px solid var(--line,#e6e1d6);border-radius:12px;padding:14px 18px;margin-bottom:24px;">
        <p style="font-family:'Inter Tight',sans-serif;font-size:12px;color:#6b6455;margin:0 0 6px;font-weight:600;text-transform:uppercase;letter-spacing:0.04em;">Prerequisites</p>
        <div style="display:flex;flex-wrap:wrap;gap:8px;">{view.prerequisites.map((p) => <a href={'/aquintutor/lesson/' + p.id} style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:var(--ink,#1a1712);text-decoration:none;border-bottom:1px solid var(--rust,#b3541e);">{p.title}</a>)}</div>
      </div>
    ) : null}

    {data.body ? <article class="lesson-body" set:html={mdLite(data.body)}></article> : null}

    {equations.length ? (
      <section style="margin-top:28px;">
        <h2 style="font-family:Fraunces,serif;font-size:20px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 12px;">Equations</h2>
        {equations.map((eq: any) => (
          <div style="padding:12px 16px;background:#faf8f2;border:1px solid var(--line,#e6e1d6);border-radius:10px;margin-bottom:10px;overflow-x:auto;">
            <div set:html={latexToHtml(eq.latex)}></div>
            {eq.caption ? <p style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#6b6455;margin:6px 0 0;">{eq.caption}</p> : null}
          </div>
        ))}
      </section>
    ) : null}

    {examples.length ? (
      <section style="margin-top:28px;">
        <h2 style="font-family:Fraunces,serif;font-size:20px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 12px;">Worked examples</h2>
        {examples.map((ex: any, i: number) => (
          <details style="border:1px solid var(--line,#e6e1d6);border-radius:10px;padding:12px 16px;margin-bottom:10px;">
            <summary style="font-family:'Inter Tight',sans-serif;font-size:14.5px;color:var(--ink,#1a1712);cursor:pointer;font-weight:600;">Example {i + 1}: <span set:html={mdLite(ex.prompt).replace(/^<p>|<\/p>$/g, '')}></span></summary>
            <div class="lesson-body" style="margin-top:10px;color:#3a352c;" set:html={mdLite(ex.solution)}></div>
          </details>
        ))}
      </section>
    ) : null}
  </main>

  <style is:global>
    .lesson-body{font-family:'Inter Tight',sans-serif;font-size:16px;line-height:1.7;color:#2a251d;}
    .lesson-body h2,.lesson-body h3,.lesson-body h4{font-family:Fraunces,serif;color:var(--ink,#1a1712);margin:1.4em 0 .5em;line-height:1.25;}
    .lesson-body h2{font-size:22px;} .lesson-body h3{font-size:18px;}
    .lesson-body p{margin:0 0 1em;} .lesson-body ul,.lesson-body ol{margin:0 0 1em 1.3em;} .lesson-body li{margin:.25em 0;}
    .lesson-body code{font-family:'Geist Mono',monospace;font-size:.9em;background:rgba(0,0,0,0.05);padding:2px 6px;border-radius:4px;}
    .lesson-body a{color:var(--rust,#b3541e);} .lesson-body blockquote{border-left:3px solid var(--line,#e6e1d6);margin:0 0 1em;padding:.2em 1em;color:#6b6455;}
  </style>
</AquintutorLayout>
