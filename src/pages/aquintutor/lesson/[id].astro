---
// /aquintutor/lesson/[id] — KnowledgeObject (lesson) view (Prompt 3 + Prompt 4 runtime).
// Starting the lesson runs the Educational Runtime (ordered pipeline + trace): it authorizes,
// estimates context, picks the served variant (language/accessibility), emits a render tier,
// and surfaces unmastered prerequisites. Drafts are staff-only; denied -> redirect. Zero client JS.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { contentService } from '@/lib/kernel-content';
import { startLesson } from '@/lib/edu-runtime';
import { mdLite, latexToHtml, EQUATION_CSS } from '@/lib/content-render';
import { resolveDirective, rewriteMedia, getOverride } from '@/lib/render-policy';
import { assessmentsForObject } from '@/lib/assessment';
import { can } from '@/lib/rbac';

const user = Astro.locals.user;
const id = Astro.params.id!;
const { view, assembled, isStaff } = await startLesson(user, id, Astro.request);
if (!view || !assembled) return new Response('Lesson not found', { status: 404 });

const unit: any = view.unit;
if (unit.lifecycleState !== 'published' && !isStaff) return Astro.redirect('/aquintutor/courses');
if (assembled.outcome === 'denied') return Astro.redirect('/aquintutor/courses?locked=' + encodeURIComponent((unit.securityLabels || []).join(',')));

// render the SERVED unit (a language/accessibility variant if the runtime chose one)
const servedId = assembled.servedUnitId || id;
const renderView = servedId === id ? view : ((await contentService().getUnitView(servedId).catch(() => null)) || view);
const data: any = renderView.unit.data;
const lm: any = renderView.unit.learningMetadata || {};
const equations = Array.isArray(data.equations) ? data.equations : [];
const examples = Array.isArray(data.examples) ? data.examples : [];
const course = view.courses[0];
const plan = assembled.renderPlan;
const labels = unit.securityLabels || ['public'];
const unmet = assembled.prerequisites.filter((p) => !p.mastered);
const canComplete = !!user?.id && unit.lifecycleState === 'published';
const justCompleted = Astro.url.searchParams.get('done') === '1';
const rootFont = 16 * (plan.fontScale || 1);

// Adaptive Rendering (Prompt 5): the tier + per-object override -> concrete render directives.
const override = await getOverride(servedId).catch(() => null);
const directive = resolveDirective('KnowledgeObject', plan.tier, override);
const bodyHtml = data.body ? rewriteMedia(mdLite(data.body), directive) : '';
const interactiveEquations = directive.hydrate.includes('equation-explorer') && equations.length > 0;

// Assessments attached to this KO (Prompt 8) — only published ones the student may see.
const rawAssessments = await assessmentsForObject(id, true).catch(() => []);
const assessments: any[] = [];
for (const a of rawAssessments) { if ((await can(user, 'read', { type: 'AssessmentObject', securityLabels: a.securityLabels || ['public'] })).allow) assessments.push(a); }
---
<AquintutorLayout title={data.title}>
  <style set:html={EQUATION_CSS}></style>
  <main data-render-tier={plan.tier} style={'max-width:760px;margin:0 auto;padding:44px 22px 80px;font-size:' + rootFont + 'px;' + (plan.highContrast ? 'filter:contrast(1.15);' : '')}>
    {course ? <a href={'/aquintutor/lesson-index/' + course.id} style="font-family:'Inter Tight',sans-serif;font-size:13px;color:var(--rust,#b3541e);text-decoration:none;">&larr; {course.title}</a> : null}
    {unit.lifecycleState !== 'published' ? <p style="font-family:'Geist Mono',monospace;font-size:11px;color:#b3541e;margin:8px 0 0;">DRAFT &middot; {unit.lifecycleState} &middot; visible to staff only</p> : null}
    {isStaff ? <p style="font-family:'Geist Mono',monospace;font-size:10.5px;color:#8a8478;margin:6px 0 0;">runtime: served tier <b>{plan.tier}</b>{assembled.language !== 'en' ? ' · lang ' + assembled.language : ''} · trace saved</p> : null}
    <h1 style="font-family:Fraunces,serif;font-size:32px;font-weight:600;color:var(--ink,#1a1712);margin:10px 0 8px;line-height:1.15;">{data.title}</h1>

    <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:22px;font-family:'Inter Tight',sans-serif;font-size:12px;color:#6b6455;">
      {lm.difficulty ? <span style="border:1px solid var(--line,#e6e1d6);border-radius:100px;padding:3px 11px;">{lm.difficulty}</span> : null}
      {lm.estimatedMinutes ? <span style="border:1px solid var(--line,#e6e1d6);border-radius:100px;padding:3px 11px;">{lm.estimatedMinutes} min</span> : null}
      {Array.isArray(lm.languages) && lm.languages.length ? <span style="border:1px solid var(--line,#e6e1d6);border-radius:100px;padding:3px 11px;">{lm.languages.join(' · ')}</span> : null}
      <span style="border:1px solid var(--line,#e6e1d6);border-radius:100px;padding:3px 11px;">{labels[0]}</span>
    </div>

    {unmet.length ? (
      <div style="background:#fff8ef;border:1px solid #f0d9b4;border-radius:12px;padding:14px 18px;margin-bottom:24px;">
        <p style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#8a5a1a;margin:0 0 6px;font-weight:600;">Recommended first &mdash; you haven't mastered these prerequisites yet</p>
        <div style="display:flex;flex-wrap:wrap;gap:8px;">{unmet.map((p) => <a href={'/aquintutor/lesson/' + p.id} style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:var(--ink,#1a1712);text-decoration:none;border-bottom:1px solid #d9a441;">{p.title}</a>)}</div>
      </div>
    ) : assembled.prerequisites.length ? (
      <div style="background:#faf8f2;border:1px solid var(--line,#e6e1d6);border-radius:12px;padding:14px 18px;margin-bottom:24px;">
        <p style="font-family:'Inter Tight',sans-serif;font-size:12px;color:#6b6455;margin:0 0 6px;font-weight:600;text-transform:uppercase;letter-spacing:0.04em;">Prerequisites (mastered)</p>
        <div style="display:flex;flex-wrap:wrap;gap:8px;">{assembled.prerequisites.map((p) => <a href={'/aquintutor/lesson/' + p.id} style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:var(--ink,#1a1712);text-decoration:none;border-bottom:1px solid var(--rust,#b3541e);">{p.title}</a>)}</div>
      </div>
    ) : null}

    {bodyHtml ? <article class="lesson-body" set:html={bodyHtml}></article> : null}

    {equations.length ? (
      <section style="margin-top:28px;">
        <h2 style="font-family:Fraunces,serif;font-size:20px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 12px;">Equations</h2>
        {equations.map((eq: any) => (
          <div style="padding:12px 16px;background:#faf8f2;border:1px solid var(--line,#e6e1d6);border-radius:10px;margin-bottom:10px;overflow-x:auto;">
            <div set:html={latexToHtml(eq.latex)}></div>
            {eq.caption ? <p style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#6b6455;margin:6px 0 0;">{eq.caption}</p> : null}
          </div>
        ))}
      </section>
    ) : null}

    {examples.length ? (
      <section style="margin-top:28px;">
        <h2 style="font-family:Fraunces,serif;font-size:20px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 12px;">Worked examples</h2>
        {examples.map((ex: any, i: number) => (
          <details style="border:1px solid var(--line,#e6e1d6);border-radius:10px;padding:12px 16px;margin-bottom:10px;">
            <summary style="font-family:'Inter Tight',sans-serif;font-size:14.5px;color:var(--ink,#1a1712);cursor:pointer;font-weight:600;">Example {i + 1}: <span set:html={mdLite(ex.prompt).replace(/^<p>|<\/p>$/g, '')}></span></summary>
            <div class="lesson-body" style="margin-top:10px;color:#3a352c;" set:html={mdLite(ex.solution)}></div>
          </details>
        ))}
      </section>
    ) : null}

    {assessments.length ? (
      <section style="margin-top:28px;">
        <h2 style="font-family:Fraunces,serif;font-size:20px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 12px;">Check your understanding</h2>
        <div style="display:flex;flex-direction:column;gap:8px;">
          {assessments.map((a: any) => (
            <a href={'/aquintutor/assess/' + a.id} style="display:flex;justify-content:space-between;align-items:center;gap:10px;text-decoration:none;border:1px solid var(--line,#e6e1d6);border-radius:10px;padding:12px 16px;">
              <span style="font-family:'Inter Tight',sans-serif;font-size:14.5px;font-weight:600;color:var(--ink,#1a1712);">{a.title}</span>
              <span style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:var(--rust,#b3541e);">{a.kind} &rarr;</span>
            </a>
          ))}
        </div>
      </section>
    ) : null}

    {justCompleted ? <p style="margin-top:28px;font-family:'Inter Tight',sans-serif;font-size:14px;color:#2f7d5b;background:#eef8f1;border:1px solid #bfe3cd;border-radius:10px;padding:12px 16px;">Saved &mdash; your mastery was updated and this lesson is marked complete.</p> :
      canComplete ? (
      <form method="POST" action="/api/aquintutor/lesson-progress" style="margin-top:32px;">
        <input type="hidden" name="koId" value={id} />
        <input type="hidden" name="next" value={'/aquintutor/lesson/' + id + '?done=1'} />
        <button type="submit" style="background:var(--ink,#1a1712);color:var(--sand-50,#fbfaf4);border:none;border-radius:10px;padding:12px 24px;font-family:'Inter Tight',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">Mark complete</button>
      </form>
    ) : null}

    {user ? (
      <section style="margin-top:36px;border-top:1px solid var(--line,#e6e1d6);padding-top:24px;">
        <h2 style="font-family:Fraunces,serif;font-size:20px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 4px;">Ask Aquin</h2>
        <p style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#6b6455;margin:0 0 14px;">A tutor grounded in this lesson. It won't reveal exam answers.</p>
        <div id="aqLog" style="display:flex;flex-direction:column;gap:10px;margin-bottom:12px;"></div>
        <form id="aqForm" style="display:flex;gap:8px;">
          <input id="aqInput" autocomplete="off" placeholder="Ask about this lesson…" style="flex:1;font-family:'Inter Tight',sans-serif;font-size:14.5px;padding:10px 12px;border:1px solid var(--line,#e6e1d6);border-radius:10px;" />
          <button type="submit" style="background:var(--ink,#1a1712);color:var(--sand-50,#fbfaf4);border:none;border-radius:10px;padding:10px 18px;font-family:'Inter Tight',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">Ask</button>
        </form>
      </section>
      <script is:inline define:vars={{ koId: id }}>
        (function () {
          var log = document.getElementById('aqLog'), form = document.getElementById('aqForm'), input = document.getElementById('aqInput');
          var messages = [], sessionId = koId + ':' + Date.now(), busy = false;
          function bubble(role, text) { var d = document.createElement('div'); d.style.cssText = 'font-family:Inter Tight,sans-serif;font-size:14.5px;line-height:1.6;padding:10px 14px;border-radius:12px;max-width:88%;white-space:pre-wrap;' + (role === 'user' ? 'align-self:flex-end;background:#1a1712;color:#fbfaf4;' : 'align-self:flex-start;background:#faf8f2;border:1px solid var(--line,#e6e1d6);color:#2a251d;'); d.textContent = text; log.appendChild(d); return d; }
          form.addEventListener('submit', function (e) {
            e.preventDefault(); if (busy) return; var q = input.value.trim(); if (!q) return;
            busy = true; input.value = ''; bubble('user', q); messages.push({ role: 'user', content: q });
            var a = bubble('assistant', '…');
            fetch('/api/aquintutor/ask-aquin', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ koId: koId, sessionId: sessionId, messages: messages }) })
              .then(function (r) {
                if ((r.headers.get('content-type') || '').indexOf('application/json') === 0) { return r.json().then(function (j) { a.textContent = j.error || 'The tutor is unavailable right now.'; busy = false; }); }
                var reader = r.body.getReader(), dec = new TextDecoder(), acc = '';
                a.textContent = '';
                function pump() { return reader.read().then(function (res) { if (res.done) { messages.push({ role: 'assistant', content: acc }); busy = false; return; } acc += dec.decode(res.value, { stream: true }); a.textContent = acc; log.scrollIntoView({ block: 'end' }); return pump(); }); }
                return pump();
              }).catch(function () { a.textContent = 'Network error.'; busy = false; });
          });
        })();
      </script>
    ) : null}

    {interactiveEquations ? (
      <script is:inline>
        (function () { document.querySelectorAll('.eq').forEach(function (e) { e.style.cursor = 'zoom-in'; e.style.display = 'inline-block'; e.style.transition = 'transform .15s'; e.addEventListener('click', function () { var z = e.getAttribute('data-z') === '1'; e.setAttribute('data-z', z ? '0' : '1'); e.style.transform = z ? '' : 'scale(1.6)'; }); }); })();
      </script>
    ) : null}
  </main>

  <style is:global>
    .lesson-body{font-family:'Inter Tight',sans-serif;line-height:1.7;color:#2a251d;}
    .lesson-body h2,.lesson-body h3,.lesson-body h4{font-family:Fraunces,serif;color:var(--ink,#1a1712);margin:1.4em 0 .5em;line-height:1.25;}
    .lesson-body h2{font-size:1.4em;} .lesson-body h3{font-size:1.15em;}
    .lesson-body p{margin:0 0 1em;} .lesson-body ul,.lesson-body ol{margin:0 0 1em 1.3em;} .lesson-body li{margin:.25em 0;}
    .lesson-body code{font-family:'Geist Mono',monospace;font-size:.9em;background:rgba(0,0,0,0.05);padding:2px 6px;border-radius:4px;}
    .lesson-body a{color:var(--rust,#b3541e);} .lesson-body blockquote{border-left:3px solid var(--line,#e6e1d6);margin:0 0 1em;padding:.2em 1em;color:#6b6455;}
  </style>
</AquintutorLayout>
