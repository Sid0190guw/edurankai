---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
const TRACKS = [
  { slug: 'engineering-entrance', label: 'Engineering Entrance', sub: 'Foundation + advanced', icon: 'cpu', color: '#2b577e', summary: 'Two-year structured prep for the national engineering entrance. Physics + Chemistry + Mathematics with daily problem sets, weekly mock tests, all-India rank.', sessions: '24-month foundation + final · 6-month sprint', subjects: ['Physics', 'Chemistry', 'Mathematics'], mocks: 320 },
  { slug: 'medical-entrance', label: 'Medical Entrance', sub: 'UG · PG', icon: 'heart', color: '#a04330', summary: 'Biology-led prep with NCERT-grade depth and clinical-context reasoning. Daily MCQ practice, organ-system anatomy drills, weekly full-length mock tests.', sessions: '24-month full · 12-month sprint', subjects: ['Biology', 'Chemistry', 'Physics'], mocks: 280 },
  { slug: 'civil-services', label: 'Civil Services', sub: 'Prelims + Mains + Interview', icon: 'feather', color: '#5b4a92', summary: 'General Studies, optional subjects, current affairs daily, essay practice with mentor feedback, mock interview rounds with retired civil servants.', sessions: '12-month full · 6-month revision', subjects: ['General Studies', 'Current Affairs', 'Essay', 'Optional'], mocks: 240 },
  { slug: 'graduate-aptitude', label: 'Graduate Aptitude', sub: 'Engineering · 30 streams', icon: 'grid', color: '#4a7048', summary: 'Subject-specific prep for graduate engineering aptitude. Core engineering subjects, general aptitude, mathematics. Past-paper analysis with depth.', sessions: '6-month focused · 3-month revision', subjects: ['Subject Core', 'Mathematics', 'General Aptitude'], mocks: 180 },
  { slug: 'management-entrance', label: 'Management Entrance', sub: 'MBA + executive', icon: 'briefcase', color: '#946322', summary: 'Quantitative aptitude, verbal reasoning, data interpretation, logical reasoning. Mock interviews + group discussion practice. Profile building for top schools.', sessions: '10-month full · 4-month sprint', subjects: ['QA', 'VARC', 'DI/LR'], mocks: 200 },
  { slug: 'law-entrance', label: 'Law Entrance', sub: 'UG + PG', icon: 'book-open', color: '#8a486b', summary: 'Legal aptitude, current affairs (legal angle), English language, logical reasoning, quantitative techniques. Constitutional law module included.', sessions: '12-month full · 6-month revision', subjects: ['Legal Aptitude', 'English', 'Current Affairs', 'Reasoning'], mocks: 160 },
  { slug: 'staff-selection', label: 'Staff Selection', sub: 'CGL, CHSL, MTS', icon: 'users', color: '#a8472c', summary: 'Quantitative aptitude, general intelligence, general awareness, English. Tier-I, Tier-II, descriptive paper, skill tests. Vernacular delivery available.', sessions: '8-month full · 4-month sprint', subjects: ['QA', 'GA', 'English', 'Reasoning'], mocks: 220 },
  { slug: 'banking', label: 'Banking', sub: 'PO + Clerk + RBI', icon: 'database', color: '#2b577e', summary: 'Quantitative aptitude, reasoning, English, computer awareness, banking awareness, current affairs. Prelims + Mains + Interview prep.', sessions: '6-month full · 3-month sprint', subjects: ['QA', 'Reasoning', 'English', 'Banking Awareness'], mocks: 180 },
  { slug: 'central-university', label: 'Central University Entrance', sub: 'UG + PG', icon: 'home', color: '#3b5675', summary: 'Domain-specific tests across 50+ subjects, general test, language test. School-aligned curriculum + university-level conceptual depth.', sessions: '8-month school-aligned', subjects: ['Domain', 'General Test', 'Language'], mocks: 160 },
];
---
<AquintutorLayout title="Exam preparation · 9 tracks · EduRankAI" description="Structured exam prep across 9 major national tracks. Live faculty, daily practice problems, weekly mock tests, all-India ranks, vernacular delivery.">

<style>
  body { background: #FAF8F5; }
  .ep-wrap { max-width: 1280px; margin: 0 auto; padding: 24px 5vw 80px; }
  .ep-head { padding: 24px 0 32px; border-bottom: 1px solid rgba(14,11,8,0.08); margin-bottom: 32px; }
  .ep-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .ep-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(36px, 5vw, 60px); font-weight: 600; letter-spacing: -0.03em; margin: 6px 0 14px; line-height: 1.05; }
  .ep-title em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .ep-sub { font-size: 16px; color: #2E2520; max-width: 720px; line-height: 1.6; }

  .ep-strip { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin: 24px 0 0; }
  .ep-stat { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 10px; padding: 14px 18px; }
  .ep-stat-val { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 600; color: #0E0B08; line-height: 1; letter-spacing: -0.02em; }
  .ep-stat-lbl { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: #7A6F68; margin-top: 5px; font-weight: 700; }

  .ep-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 16px; }
  .ep-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 16px; padding: 24px; text-decoration: none; color: inherit; transition: all 0.2s; display: block; }
  .ep-card:hover { transform: translateY(-2px); box-shadow: 0 12px 30px rgba(14,11,8,0.08); }
  .ep-card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 14px; }
  .ep-icon { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #fff; }
  .ep-sub-label { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: #7A6F68; font-weight: 700; text-align: right; }
  .ep-track-title { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; margin: 4px 0; letter-spacing: -0.02em; line-height: 1.15; }
  .ep-summary { font-size: 13.5px; color: #2E2520; line-height: 1.6; margin: 10px 0 14px; }
  .ep-meta { display: flex; gap: 14px; flex-wrap: wrap; padding-top: 12px; border-top: 1px solid rgba(14,11,8,0.06); font-family: 'Geist Mono', monospace; font-size: 10.5px; color: #7A6F68; letter-spacing: 0.06em; }
  .ep-meta strong { color: #FF4F00; font-weight: 700; }
  .ep-subjects { display: flex; gap: 4px; flex-wrap: wrap; margin: 8px 0 0; }
  .ep-subject-chip { font-family: 'Geist Mono', monospace; font-size: 10px; padding: 3px 8px; border-radius: 100px; background: #FFF3EE; color: #FF4F00; border: 1px solid #FFD4BC; }
</style>

<main class="ep-wrap">

  <header class="ep-head">
    <p class="ep-eyebrow">AquinTutor · Exam Prep</p>
    <h1 class="ep-title">Prep that <em>actually</em> tracks.</h1>
    <p class="ep-sub">Nine major national entrance and competitive-exam tracks. Live faculty, daily practice problems, weekly mock tests, all-India rank, vernacular delivery in 12 languages, doubt-solving in under 90 seconds by Aquin or 20 minutes by a human.</p>

    <div class="ep-strip">
      <div class="ep-stat"><p class="ep-stat-val">9</p><p class="ep-stat-lbl">Tracks</p></div>
      <div class="ep-stat"><p class="ep-stat-val">1,940+</p><p class="ep-stat-lbl">Mock tests / year</p></div>
      <div class="ep-stat"><p class="ep-stat-val">365</p><p class="ep-stat-lbl">Daily problem sets</p></div>
      <div class="ep-stat"><p class="ep-stat-val">90s</p><p class="ep-stat-lbl">Aquin doubt response</p></div>
      <div class="ep-stat"><p class="ep-stat-val">12</p><p class="ep-stat-lbl">Indic languages</p></div>
    </div>
  </header>

  <section class="ep-grid">
    {TRACKS.map((t) => (
      <a href={'/aquintutor/exam-prep/' + t.slug} class="ep-card">
        <div class="ep-card-top">
          <div class="ep-icon" style={'background:' + t.color + ';'}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              {t.icon === 'cpu' && <><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="2" x2="9" y2="4"/><line x1="15" y1="2" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="22"/><line x1="15" y1="20" x2="15" y2="22"/><line x1="20" y1="9" x2="22" y2="9"/><line x1="20" y1="15" x2="22" y2="15"/><line x1="2" y1="9" x2="4" y2="9"/><line x1="2" y1="15" x2="4" y2="15"/></>}
              {t.icon === 'heart' && <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>}
              {t.icon === 'feather' && <><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><line x1="16" y1="8" x2="2" y2="22"/><line x1="17.5" y1="15" x2="9" y2="15"/></>}
              {t.icon === 'grid' && <><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></>}
              {t.icon === 'briefcase' && <><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></>}
              {t.icon === 'book-open' && <><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></>}
              {t.icon === 'users' && <><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></>}
              {t.icon === 'database' && <><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></>}
              {t.icon === 'home' && <><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></>}
            </svg>
          </div>
          <div class="ep-sub-label">{t.sub}</div>
        </div>
        <h2 class="ep-track-title">{t.label}</h2>
        <p class="ep-summary">{t.summary}</p>
        <div class="ep-subjects">
          {t.subjects.map((s) => <span class="ep-subject-chip">{s}</span>)}
        </div>
        <div class="ep-meta">
          <span>📅 <strong>{t.sessions}</strong></span>
          <span>🎯 <strong>{t.mocks}</strong> mock tests</span>
        </div>
      </a>
    ))}
  </section>
</main>
</AquintutorLayout>
