---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

const tracks = [
  {
    slug: 'mathematics',
    name: 'Mathematics Olympiad',
    summary: 'Number theory, combinatorics, algebra, geometry. Proof-writing discipline from day one.',
    problems: '1,200+ problems',
    faculty: '6 faculty',
  },
  {
    slug: 'physics',
    name: 'Physics Olympiad',
    summary: 'Classical mechanics, electromagnetism, thermodynamics, modern physics — first principles only.',
    problems: '900+ problems',
    faculty: '5 faculty',
  },
  {
    slug: 'chemistry',
    name: 'Chemistry Olympiad',
    summary: 'Organic mechanisms, physical chemistry, inorganic reactivity, lab practicals.',
    problems: '850+ problems',
    faculty: '5 faculty',
  },
  {
    slug: 'biology',
    name: 'Biology Olympiad',
    summary: 'Molecular biology, ecology, animal physiology, plant systems, biochemistry.',
    problems: '780+ problems',
    faculty: '4 faculty',
  },
  {
    slug: 'informatics',
    name: 'Informatics Olympiad',
    summary: 'Algorithms, data structures, graph theory, dynamic programming. C++ and Python tracks.',
    problems: '1,400+ problems',
    faculty: '4 faculty',
  },
  {
    slug: 'linguistics',
    name: 'Linguistics Olympiad',
    summary: 'Self-contained puzzles in 80+ world languages. No prior language knowledge required.',
    problems: '600+ problems',
    faculty: '3 faculty',
  },
  {
    slug: 'astronomy',
    name: 'Astronomy Olympiad',
    summary: 'Celestial mechanics, astrophysics, observational techniques, spherical geometry.',
    problems: '720+ problems',
    faculty: '4 faculty',
  },
  {
    slug: 'philosophy',
    name: 'Philosophy Olympiad',
    summary: 'Ethics, epistemology, metaphysics, logic. Essay craft in English, French or German.',
    problems: '500+ problems',
    faculty: '3 faculty',
  },
];

const faqs = [
  {
    q: 'Who can join the cohorts?',
    a: 'Stage 1 cohorts are open to students in school years 9 through 12 who have completed the prerequisite syllabus for their subject. Stage 2 elite cohorts require either a qualifying Stage 1 score in a previous attempt, or a placement test administered at enrolment. No school affiliation requirement.',
  },
  {
    q: 'How is the selection pipeline structured?',
    a: 'Most national olympiad programmes run a multi-stage funnel: a screening round, followed by a national-level paper, a training camp for shortlisted students, and finally the international team selection. Our cohorts mirror that funnel — Stage 1 prepares you for the screening and national paper; Stage 2 prepares you for the camp and international representation.',
  },
  {
    q: 'What is the realistic success rate?',
    a: 'Of every 100 students who complete Stage 1, roughly 18 to 25 clear the national screening in a given year. Of those, around 4 to 7 progress to the national training camp. International representation is a single-digit-per-country event by design and remains rare — we are honest about that. Past performance is in the stats below.',
  },
  {
    q: 'What time commitment is expected?',
    a: 'Stage 1: 6 to 8 hours per week of guided sessions plus 4 to 6 hours of solo problem-solving, sustained over 26 weeks. Stage 2: 12 to 15 hours per week including weekend camps, sustained over 18 weeks. Olympiad-grade preparation is not a part-time pursuit.',
  },
  {
    q: 'What is the refund policy?',
    a: 'Full refund within 7 days of enrolment, no questions asked. Pro-rata refund up to week 4 of the cohort. After week 4, refunds are issued only on documented medical or relocation grounds. The waiver pathway remains available for financial hardship — apply through the portal.',
  },
];
---

<AquintutorLayout title="Olympiad Preparation — AquinTutor" description="Stage 1 to international representation across maths, physics, chemistry, biology, informatics, linguistics, astronomy and philosophy olympiads.">
  <main class="ol-page">

    <!-- HERO -->
    <section class="ol-hero">
      <div class="ol-wrap">
        <div class="ol-eyebrow">AquinTutor &middot; Exam Prep &middot; Olympiads</div>
        <h1 class="ol-title">Compete at the <em>top of the world</em>.</h1>
        <p class="ol-sub">Stage 1 (national selection) to international representation. Past papers, problem sets, doubt-solving, mentor sessions.</p>
        <div class="ol-hero-meta">
          <span class="ol-chip">8 subject tracks</span>
          <span class="ol-chip">7,000+ curated problems</span>
          <span class="ol-chip">34 faculty mentors</span>
        </div>
      </div>
    </section>

    <!-- TRACKS GRID -->
    <section class="ol-section">
      <div class="ol-wrap">
        <div class="ol-section-head">
          <div class="ol-kicker">The eight tracks</div>
          <h2 class="ol-h2">Pick the subject. We will build the discipline.</h2>
        </div>

        <div class="ol-grid">
          {tracks.map((t) => (
            <article class="ol-card" data-slug={t.slug}>
              <div class="ol-card-icon">
                {t.slug === 'mathematics' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16M4 12h10M4 18h16"/><path d="M15 9l4 6M19 9l-4 6"/></svg>
                )}
                {t.slug === 'physics' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1.5"/><ellipse cx="12" cy="12" rx="10" ry="4"/><ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(60 12 12)"/><ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(120 12 12)"/></svg>
                )}
                {t.slug === 'chemistry' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3v6l-5 9a2 2 0 0 0 2 3h12a2 2 0 0 0 2-3l-5-9V3"/><path d="M8 3h8"/><path d="M6 14h12"/></svg>
                )}
                {t.slug === 'biology' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4c4 4 12 12 16 16"/><path d="M20 4c-4 4-12 12-16 16"/><path d="M7 7h10"/><path d="M7 17h10"/></svg>
                )}
                {t.slug === 'informatics' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="8 7 3 12 8 17"/><polyline points="16 7 21 12 16 17"/><line x1="14" y1="5" x2="10" y2="19"/></svg>
                )}
                {t.slug === 'linguistics' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8l6-3 6 3"/><path d="M5 8v8l6 3 6-3V8"/><path d="M11 5v14"/></svg>
                )}
                {t.slug === 'astronomy' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12a9 9 0 0 1 18 0"/><path d="M12 3a14 14 0 0 1 0 18"/><path d="M12 3a14 14 0 0 0 0 18"/></svg>
                )}
                {t.slug === 'philosophy' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 3v18"/><path d="M3 12h18"/></svg>
                )}
              </div>

              <h3 class="ol-card-title">{t.name}</h3>
              <p class="ol-card-sum">{t.summary}</p>

              <div class="ol-card-tiers">
                <div class="ol-tier">
                  <div class="ol-tier-name">Stage 1 cohort</div>
                  <div class="ol-tier-price">5,000 INR <span>/ 60 CHF</span></div>
                  <div class="ol-tier-note">National selection prep</div>
                </div>
                <div class="ol-tier ol-tier-elite">
                  <div class="ol-tier-name">Stage 2 elite cohort</div>
                  <div class="ol-tier-price">25,000 INR <span>/ 250 CHF</span></div>
                  <div class="ol-tier-note">Camp &amp; international</div>
                </div>
              </div>

              <div class="ol-card-meta">
                <span>{t.problems}</span>
                <span class="ol-dot"></span>
                <span>{t.faculty}</span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- PEDAGOGY -->
    <section class="ol-section ol-section-tan">
      <div class="ol-wrap">
        <div class="ol-section-head">
          <div class="ol-kicker">Pedagogical approach</div>
          <h2 class="ol-h2">Three steps. <em>Then the world.</em></h2>
          <p class="ol-section-sub">Foundation builds the technique pillar. Problem solving stress-tests it against a thousand past papers. Camp compresses the final fortnight into intensive simulation. Then international.</p>
        </div>

        <div class="ol-steps">
          <div class="ol-step">
            <div class="ol-step-num">01</div>
            <h3>Foundation</h3>
            <div class="ol-step-label">Technique pillar</div>
            <p>Six to eight weeks of first-principles theory. No shortcuts, no formula-stuffing. We teach you why the standard tricks work before we let you use them.</p>
            <ul class="ol-step-list">
              <li>Daily 90-minute live sessions</li>
              <li>Weekly written homework, graded by a human</li>
              <li>Subject-specific technique library</li>
            </ul>
          </div>

          <div class="ol-step-arrow" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>

          <div class="ol-step">
            <div class="ol-step-num">02</div>
            <h3>Problem solving</h3>
            <div class="ol-step-label">1000+ past papers</div>
            <p>Curated problem sets from the last forty years of national and international rounds across every participating region. Difficulty-graded, with full written solutions.</p>
            <ul class="ol-step-list">
              <li>Adaptive difficulty rotation</li>
              <li>Mentor-led problem walkthroughs</li>
              <li>Personal weakness diagnostic, updated weekly</li>
            </ul>
          </div>

          <div class="ol-step-arrow" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>

          <div class="ol-step">
            <div class="ol-step-num">03</div>
            <h3>Camp</h3>
            <div class="ol-step-label">Intensive 14-day</div>
            <p>Two weeks of full-time simulation in the final stretch before the international round. Mock papers under timed conditions, lab practicals where applicable, peer review.</p>
            <ul class="ol-step-list">
              <li>Six full-length timed papers</li>
              <li>One-on-one viva with senior faculty</li>
              <li>Psychological-load preparation</li>
            </ul>
          </div>
        </div>

        <div class="ol-pedagogy-foot">
          <div class="ol-pedagogy-foot-line"></div>
          <div class="ol-pedagogy-foot-label">to International representation</div>
        </div>
      </div>
    </section>

    <!-- PAST PERFORMANCE -->
    <section class="ol-section">
      <div class="ol-wrap">
        <div class="ol-section-head">
          <div class="ol-kicker">Past performance</div>
          <h2 class="ol-h2">The numbers, honestly.</h2>
          <p class="ol-section-sub">Aggregate counts across all tracks, all cohort years since inception. We do not break these out by track because the cohort sizes are too small for the breakdown to be statistically honest.</p>
        </div>

        <div class="ol-stats">
          <div class="ol-stat">
            <div class="ol-stat-num">150+</div>
            <div class="ol-stat-label">Stage 1 selections</div>
            <p>Students from our cohorts who cleared the national screening round and progressed to the national-level paper.</p>
          </div>
          <div class="ol-stat">
            <div class="ol-stat-num">42</div>
            <div class="ol-stat-label">Stage 2 selections</div>
            <p>Cohort alumni shortlisted for a national training camp across the eight subject olympiads we coach.</p>
          </div>
          <div class="ol-stat">
            <div class="ol-stat-num">12</div>
            <div class="ol-stat-label">International representatives</div>
            <p>Students who represented their country at an international olympiad round. Five came home with a medal.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="ol-section ol-section-tan">
      <div class="ol-wrap ol-wrap-narrow">
        <div class="ol-section-head">
          <div class="ol-kicker">Frequently asked</div>
          <h2 class="ol-h2">Before you enrol.</h2>
        </div>

        <div class="ol-faq">
          {faqs.map((f, i) => (
            <details class="ol-faq-item" open={i === 0}>
              <summary>
                <span class="ol-faq-q">{f.q}</span>
                <span class="ol-faq-chev" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </summary>
              <div class="ol-faq-a">{f.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA STRIP -->
    <section class="ol-section">
      <div class="ol-wrap">
        <div class="ol-cta">
          <div>
            <div class="ol-kicker">Next step</div>
            <h3 class="ol-cta-title">Sit a free diagnostic. Then decide.</h3>
            <p class="ol-cta-sub">Forty-five minute placement paper, marked by a faculty member with a written report. No obligation, no upsell. We will tell you honestly whether olympiad prep is the right use of your year.</p>
          </div>
          <div class="ol-cta-actions">
            <a href="/aquintutor/exam-prep" class="ol-btn ol-btn-ghost">Back to exam prep</a>
            <a href="/aquintutor/signup" class="ol-btn ol-btn-primary">Request diagnostic</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <style>
    :root {
      --cream: #FAF8F5;
      --ink: #0E0B08;
      --ink-2: #2E2520;
      --ink-soft: #7A6F68;
      --burn: #FF4F00;
      --burn-pale: #FFF3EE;
      --burn-dim: #FFD4BC;
      --leaf: #1A6B35;
      --line: rgba(14, 11, 8, 0.10);
      --line-strong: rgba(14, 11, 8, 0.18);
    }

    .ol-page {
      background: var(--cream);
      color: var(--ink);
      font-family: 'DM Sans', system-ui, -apple-system, sans-serif;
      min-height: 100vh;
    }

    .ol-wrap {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
    }
    .ol-wrap-narrow { max-width: 840px; }

    /* HERO */
    .ol-hero {
      padding: 84px 0 56px;
      border-bottom: 1px solid var(--line);
    }
    .ol-eyebrow {
      font-family: 'Geist Mono', ui-monospace, monospace;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--burn);
      margin-bottom: 22px;
    }
    .ol-title {
      font-family: 'Fraunces', 'Cormorant Garamond', serif;
      font-weight: 400;
      font-size: clamp(44px, 7vw, 88px);
      line-height: 1.02;
      letter-spacing: -0.02em;
      margin: 0 0 24px;
      color: var(--ink);
    }
    .ol-title em {
      font-style: italic;
      color: var(--burn);
      font-weight: 400;
    }
    .ol-sub {
      font-size: 19px;
      line-height: 1.55;
      color: var(--ink-2);
      max-width: 680px;
      margin: 0 0 32px;
    }
    .ol-hero-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .ol-chip {
      font-family: 'Geist Mono', ui-monospace, monospace;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--ink-2);
      padding: 8px 14px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: #fff;
    }

    /* SECTIONS */
    .ol-section {
      padding: 80px 0;
      border-bottom: 1px solid var(--line);
    }
    .ol-section-tan {
      background: linear-gradient(180deg, var(--cream) 0%, #F4EFE8 100%);
    }
    .ol-section-head {
      max-width: 760px;
      margin-bottom: 48px;
    }
    .ol-kicker {
      font-family: 'Geist Mono', ui-monospace, monospace;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--burn);
      margin-bottom: 16px;
    }
    .ol-h2 {
      font-family: 'Fraunces', 'Cormorant Garamond', serif;
      font-weight: 400;
      font-size: clamp(32px, 4.5vw, 52px);
      line-height: 1.08;
      letter-spacing: -0.015em;
      margin: 0 0 18px;
      color: var(--ink);
    }
    .ol-h2 em {
      font-style: italic;
      color: var(--burn);
      font-weight: 400;
    }
    .ol-section-sub {
      font-size: 17px;
      line-height: 1.6;
      color: var(--ink-2);
      margin: 0;
    }

    /* TRACK GRID */
    .ol-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 20px;
    }
    .ol-card {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 28px;
      display: flex;
      flex-direction: column;
      transition: border-color 0.18s ease, transform 0.18s ease;
    }
    .ol-card:hover {
      border-color: var(--line-strong);
      transform: translateY(-2px);
    }
    .ol-card-icon {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      background: var(--burn-pale);
      color: var(--burn);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 18px;
    }
    .ol-card-title {
      font-family: 'Fraunces', 'Cormorant Garamond', serif;
      font-weight: 500;
      font-size: 24px;
      line-height: 1.15;
      margin: 0 0 10px;
      color: var(--ink);
    }
    .ol-card-sum {
      font-size: 14.5px;
      line-height: 1.55;
      color: var(--ink-soft);
      margin: 0 0 22px;
      flex-grow: 1;
    }
    .ol-card-tiers {
      display: grid;
      grid-template-columns: 1fr;
      gap: 10px;
      margin-bottom: 18px;
    }
    .ol-tier {
      padding: 14px 16px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: var(--cream);
    }
    .ol-tier-elite {
      background: var(--burn-pale);
      border-color: var(--burn-dim);
    }
    .ol-tier-name {
      font-family: 'Geist Mono', ui-monospace, monospace;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--ink-soft);
      margin-bottom: 6px;
    }
    .ol-tier-price {
      font-family: 'Fraunces', 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 500;
      color: var(--ink);
      line-height: 1;
    }
    .ol-tier-price span {
      font-size: 14px;
      color: var(--ink-soft);
      font-weight: 400;
    }
    .ol-tier-note {
      font-size: 12px;
      color: var(--ink-soft);
      margin-top: 6px;
    }
    .ol-card-meta {
      display: flex;
      align-items: center;
      gap: 10px;
      padding-top: 16px;
      border-top: 1px solid var(--line);
      font-family: 'Geist Mono', ui-monospace, monospace;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.10em;
      color: var(--ink-2);
    }
    .ol-dot {
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: var(--ink-soft);
      display: inline-block;
    }

    /* PEDAGOGY STEPS */
    .ol-steps {
      display: grid;
      grid-template-columns: 1fr auto 1fr auto 1fr;
      gap: 20px;
      align-items: stretch;
    }
    .ol-step {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 28px;
      display: flex;
      flex-direction: column;
    }
    .ol-step-num {
      font-family: 'Geist Mono', ui-monospace, monospace;
      font-size: 13px;
      letter-spacing: 0.12em;
      color: var(--burn);
      margin-bottom: 14px;
    }
    .ol-step h3 {
      font-family: 'Fraunces', 'Cormorant Garamond', serif;
      font-weight: 500;
      font-size: 28px;
      line-height: 1.1;
      margin: 0 0 8px;
      color: var(--ink);
    }
    .ol-step-label {
      font-family: 'Geist Mono', ui-monospace, monospace;
      font-size: 10.5px;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--ink-soft);
      margin-bottom: 14px;
    }
    .ol-step p {
      font-size: 14.5px;
      line-height: 1.55;
      color: var(--ink-2);
      margin: 0 0 16px;
    }
    .ol-step-list {
      list-style: none;
      padding: 0;
      margin: 0;
      font-size: 13.5px;
      color: var(--ink-soft);
    }
    .ol-step-list li {
      padding: 6px 0 6px 16px;
      position: relative;
      line-height: 1.5;
    }
    .ol-step-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 13px;
      width: 6px;
      height: 1px;
      background: var(--burn);
    }
    .ol-step-arrow {
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--burn);
    }
    .ol-pedagogy-foot {
      margin-top: 36px;
      display: flex;
      align-items: center;
      gap: 16px;
      justify-content: center;
    }
    .ol-pedagogy-foot-line {
      flex: 0 0 60px;
      height: 1px;
      background: var(--burn);
    }
    .ol-pedagogy-foot-label {
      font-family: 'Fraunces', 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 22px;
      color: var(--ink);
    }

    /* STATS */
    .ol-stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
    }
    .ol-stat {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 32px;
    }
    .ol-stat-num {
      font-family: 'Fraunces', 'Cormorant Garamond', serif;
      font-weight: 500;
      font-size: 72px;
      line-height: 1;
      color: var(--burn);
      letter-spacing: -0.03em;
      margin-bottom: 8px;
    }
    .ol-stat-label {
      font-family: 'Geist Mono', ui-monospace, monospace;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--ink-2);
