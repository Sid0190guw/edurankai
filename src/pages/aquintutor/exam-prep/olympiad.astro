      align-items: center;
    }
    .ol-cta .ol-kicker { color: var(--burn-dim); }
    .ol-cta-title {
      font-family: 'Fraunces', 'Cormorant Garamond', serif;
      font-weight: 400;
      font-size: clamp(28px, 3.4vw, 40px);
