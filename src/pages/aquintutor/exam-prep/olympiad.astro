      margin: 0 0 14px;
      color: var(--cream);
      letter-spacing: -0.01em;
    }
    .ol-cta-sub {
      font-size: 15.5px;
      line-height: 1.6;
      color: rgba(250, 248, 245, 0.72);
      margin: 0;
    }
    .ol-cta-actions {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .ol-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 14px 22px;
      border-radius: 10px;
      font-family: 'Geist Mono', ui-monospace, monospace;
      font-size: 12px;
      text-transform: uppercase;
