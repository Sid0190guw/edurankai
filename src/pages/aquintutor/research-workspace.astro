---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { listRefs, getThesisSteps, THESIS_STEPS, REF_STATUSES } from '@/lib/aquintutor-research';
// Research Workspace — the postgraduate tier signature. Manage your literature
// (add / tag / status / notes), export clean citations (APA, IEEE, BibTeX) from
// structured fields, and tick off thesis milestones. Server-persisted, no LLM.
const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/research-workspace'));
const [refs, steps] = await Promise.all([listRefs(user.id), getThesisSteps(user.id)]);
---
<AquintutorLayout title="Research Workspace" description="Manage your literature, export citations in APA, IEEE and BibTeX, and track your thesis from question to defence — one workspace for postgraduate research.">
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:900px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a><span style="margin:0 8px;">/</span><span style="color:var(--rust); font-weight:600;">RESEARCH</span>
    </div>
  </div>

  <section style="max-width:860px; margin:0 auto; padding:34px 24px 80px;">
    <p style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--rust); font-weight:700; margin:0 0 8px;">AquinTutor Research · Master's · PhD</p>
    <h1 class="font-display" style="font-size:clamp(1.8rem,4vw,2.5rem); font-weight:500; margin:0 0 6px; color:var(--ink);">Your literature and your thesis, in one place.</h1>
    <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); line-height:1.6; margin:0 0 26px; max-width:640px;">Capture every paper once, tag and triage it, and export a clean citation in any style with one click. Track the thesis from research question to defence so you always know what's next.</p>

    <!-- Thesis milestones -->
    <div style="background:#fff; border:1.5px solid var(--rule); border-radius:16px; padding:18px; margin-bottom:26px;">
      <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:12px;">
        <h2 class="font-display" style="font-size:1.2rem; font-weight:600; color:var(--ink); margin:0;">Thesis pipeline</h2>
        <span id="thProg" style="font-family:'JetBrains Mono',monospace; font-size:12px; font-weight:700; color:var(--rust);"></span>
      </div>
      <div style="height:8px; background:var(--sand-100); border-radius:99px; overflow:hidden; margin-bottom:14px;"><div id="thBar" style="height:100%; background:#1c7a45; width:0; transition:width .3s;"></div></div>
      <div id="thSteps" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(230px,1fr)); gap:6px;"></div>
    </div>

    <!-- Add / edit reference -->
    <div style="background:#fff; border:1.5px solid var(--rule); border-radius:16px; padding:18px; margin-bottom:22px;">
      <h2 class="font-display" style="font-size:1.2rem; font-weight:600; color:var(--ink); margin:0 0 12px;" id="refFormTitle">Add a reference</h2>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
        <input id="rTitle" placeholder="Title *" style="grid-column:1/-1; padding:10px 12px; border:1.5px solid var(--rule); border-radius:9px; font-size:14px; font-family:inherit; color:var(--ink); background:var(--sand-50); outline:none;" />
        <input id="rAuthors" placeholder="Authors — Last, First; Last, First" style="grid-column:1/-1; padding:10px 12px; border:1.5px solid var(--rule); border-radius:9px; font-size:14px; font-family:inherit; color:var(--ink); background:var(--sand-50); outline:none;" />
        <input id="rYear" type="number" placeholder="Year" style="padding:10px 12px; border:1.5px solid var(--rule); border-radius:9px; font-size:14px; font-family:inherit; color:var(--ink); background:var(--sand-50); outline:none;" />
        <input id="rVenue" placeholder="Journal / conference" style="padding:10px 12px; border:1.5px solid var(--rule); border-radius:9px; font-size:14px; font-family:inherit; color:var(--ink); background:var(--sand-50); outline:none;" />
        <input id="rUrl" placeholder="URL or DOI" style="padding:10px 12px; border:1.5px solid var(--rule); border-radius:9px; font-size:14px; font-family:inherit; color:var(--ink); background:var(--sand-50); outline:none;" />
        <input id="rTags" placeholder="Tags (comma separated)" style="padding:10px 12px; border:1.5px solid var(--rule); border-radius:9px; font-size:14px; font-family:inherit; color:var(--ink); background:var(--sand-50); outline:none;" />
        <select id="rStatus" style="padding:10px 12px; border:1.5px solid var(--rule); border-radius:9px; font-size:14px; font-family:inherit; color:var(--ink); background:var(--sand-50); outline:none;"></select>
        <textarea id="rNotes" rows="2" placeholder="Notes" style="grid-column:1/-1; padding:10px 12px; border:1.5px solid var(--rule); border-radius:9px; font-size:14px; font-family:inherit; color:var(--ink); background:var(--sand-50); outline:none;"></textarea>
      </div>
      <div style="display:flex; gap:8px; margin-top:12px; align-items:center;">
        <button id="rSave" style="background:var(--rust); color:#fff; border:none; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; padding:10px 22px; border-radius:10px; cursor:pointer;">Add reference</button>
        <button id="rCancel" style="display:none; background:transparent; border:1.5px solid var(--rule); color:var(--ink-500); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; padding:10px 16px; border-radius:10px; cursor:pointer;">Cancel</button>
        <span id="rMsg" style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust);"></span>
      </div>
    </div>

    <!-- Library -->
    <div style="display:flex; gap:10px; align-items:center; margin-bottom:12px; flex-wrap:wrap;">
      <input id="rSearch" placeholder="Search title, author or tag" style="flex:1; min-width:200px; padding:9px 12px; border:1.5px solid var(--rule); border-radius:9px; font-size:14px; font-family:inherit; color:var(--ink); background:#fff; outline:none;" />
      <span id="rCount" style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--ink-500);"></span>
    </div>
    <div id="refList"></div>
  </section>

  <style is:global>
    .rf-status { border:1px solid var(--rule); border-radius:99px; padding:2px 9px; font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.06em; text-transform:uppercase; cursor:pointer; }
    .rf-cite { background:var(--sand-50); border:1px solid var(--rule); border-radius:9px; padding:10px 12px; margin-top:8px; }
    .rf-cite pre { white-space:pre-wrap; word-break:break-word; font-family:'Geist Mono','JetBrains Mono',monospace; font-size:12px; color:var(--ink); margin:4px 0 0; }
    .rf-btn { background:transparent; border:1px solid var(--rule); border-radius:8px; padding:5px 10px; font-family:'Inter Tight',sans-serif; font-size:12px; font-weight:600; color:var(--ink-500); cursor:pointer; }
  </style>

  <script is:inline define:vars={{ refs, steps, THESIS_STEPS, REF_STATUSES }}>
  (function(){
    var STATUS_COLORS={ 'to-read':'#9a6a12', 'reading':'#2f5fa0', 'read':'#1c7a45', 'cited':'#7a3ba0' };
    var editingId=null;
    var stateRefs = (refs||[]).slice();
    var stateSteps = Object.assign({}, steps||{});

    // ----- status select -----
    var sel=document.getElementById('rStatus'); REF_STATUSES.forEach(function(s){ var o=document.createElement('option'); o.value=s; o.textContent=s; sel.appendChild(o); });

    // ----- thesis pipeline -----
    var thSteps=document.getElementById('thSteps'), thBar=document.getElementById('thBar'), thProg=document.getElementById('thProg');
    function renderSteps(){
      thSteps.innerHTML='';
      var doneN=0;
      THESIS_STEPS.forEach(function(s){
        var done=!!stateSteps[s.key]; if(done) doneN++;
        var lbl=document.createElement('label'); lbl.style.cssText='display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:8px;cursor:pointer;font-family:Inter Tight,sans-serif;font-size:13px;color:'+(done?'#1c7a45':'var(--ink)')+';';
        var cb=document.createElement('input'); cb.type='checkbox'; cb.checked=done; cb.style.cssText='width:16px;height:16px;accent-color:#1c7a45;cursor:pointer;';
        cb.addEventListener('change', function(){ stateSteps[s.key]=cb.checked; renderSteps(); post({action:'step',key:s.key,done:cb.checked}); });
        var span=document.createElement('span'); span.textContent=s.label; if(done) span.style.textDecoration='line-through';
        lbl.appendChild(cb); lbl.appendChild(span); thSteps.appendChild(lbl);
      });
      var pct=Math.round(doneN/THESIS_STEPS.length*100);
      thBar.style.width=pct+'%'; thProg.textContent=doneN+' / '+THESIS_STEPS.length+' ('+pct+'%)';
    }

    // ----- citation formatting -----
    function parseAuthors(s){ return (s||'').split(/;| and /i).map(function(a){return a.trim();}).filter(Boolean).map(function(a){
      if(a.indexOf(',')>=0){ var p=a.split(','); return {last:p[0].trim(), first:p.slice(1).join(',').trim()}; }
      var w=a.split(/\s+/); if(w.length===1) return {last:w[0], first:''}; return {last:w[w.length-1], first:w.slice(0,-1).join(' ')};
    }); }
    function inits(first){ return (first||'').split(/\s+/).filter(Boolean).map(function(x){return x[0].toUpperCase()+'.';}).join(' '); }
    function apa(r){ var a=parseAuthors(r.authors).map(function(x){return x.last+(x.first?', '+inits(x.first):'');});
      var au=a.length? (a.length===1?a[0]:a.slice(0,-1).join(', ')+', & '+a[a.length-1]) : '';
      var s=(au?au+' ':'')+'('+(r.year||'n.d.')+'). '+r.title+'.'; if(r.venue) s+=' '+r.venue+'.'; if(r.url) s+=' '+r.url; return s; }
    function ieee(r){ var a=parseAuthors(r.authors).map(function(x){return (x.first?inits(x.first)+' ':'')+x.last;});
      var s=(a.length?a.join(', ')+', ':'')+'"'+r.title+',"'; if(r.venue) s+=' '+r.venue+','; s+=' '+(r.year||'n.d.')+'.'; return s; }
    function bibtex(r){ var pa=parseAuthors(r.authors); var au=pa.map(function(x){return (x.first?x.first+' ':'')+x.last;}).join(' and ');
      var key=((pa[0]?pa[0].last:'ref').replace(/\W/g,'')||'ref').toLowerCase()+(r.year||'');
      return '@article{'+key+',\n  title={'+r.title+'},\n'+(au?'  author={'+au+'},\n':'')+(r.year?'  year={'+r.year+'},\n':'')+(r.venue?'  journal={'+r.venue+'},\n':'')+(r.url?'  url={'+r.url+'},\n':'')+'}'; }

    // ----- library render -----
    var listEl=document.getElementById('refList'), countEl=document.getElementById('rCount'), searchEl=document.getElementById('rSearch');
    function esc(s){ return (s==null?'':String(s)).replace(/[&<>"]/g,function(m){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[m];}); }
    function matches(r,q){ if(!q) return true; q=q.toLowerCase(); return (r.title+' '+r.authors+' '+r.tags).toLowerCase().indexOf(q)>=0; }
    function renderList(){
      var q=searchEl.value.trim(); var shown=stateRefs.filter(function(r){return matches(r,q);});
      countEl.textContent=shown.length+' of '+stateRefs.length;
      if(stateRefs.length===0){ listEl.innerHTML='<p style="font-family:Inter Tight,sans-serif;font-size:14px;color:var(--ink-500);padding:14px 0;">No references yet. Add your first paper above — you only ever type it once.</p>'; return; }
      listEl.innerHTML='';
      shown.forEach(function(r){
        var d=document.createElement('div'); d.style.cssText='background:#fff;border:1.5px solid var(--rule);border-radius:14px;padding:14px 16px;margin-bottom:10px;';
        var tags=(r.tags||'').split(',').map(function(t){return t.trim();}).filter(Boolean);
        d.innerHTML='<div style="display:flex;justify-content:space-between;gap:10px;align-items:flex-start;">'
          +'<div style="flex:1;"><div style="font-family:Inter Tight,sans-serif;font-size:15px;font-weight:600;color:var(--ink);line-height:1.4;">'+esc(r.title)+'</div>'
          +'<div style="font-family:Inter Tight,sans-serif;font-size:13px;color:var(--ink-500);margin-top:2px;">'+esc(r.authors||'Unknown author')+(r.year?' · '+r.year:'')+(r.venue?' · '+esc(r.venue):'')+'</div>'
          +(tags.length?'<div style="margin-top:6px;display:flex;gap:5px;flex-wrap:wrap;">'+tags.map(function(t){return '<span style="font-family:JetBrains Mono,monospace;font-size:10px;background:var(--sand-100);border-radius:5px;padding:2px 7px;color:var(--ink-500);">'+esc(t)+'</span>';}).join('')+'</div>':'')
          +'</div>'
          +'<span class="rf-status" data-id="'+r.id+'" style="color:'+(STATUS_COLORS[r.status]||'var(--ink-500)')+';border-color:'+(STATUS_COLORS[r.status]||'var(--rule)')+';">'+r.status+'</span>'
          +'</div>'
          +'<div style="display:flex;gap:6px;margin-top:10px;flex-wrap:wrap;">'
          +'<button class="rf-btn" data-act="cite" data-id="'+r.id+'">Cite</button>'
          +'<button class="rf-btn" data-act="edit" data-id="'+r.id+'">Edit</button>'
          +(r.url?'<a class="rf-btn" href="'+esc(r.url)+'" target="_blank" rel="noopener" style="text-decoration:none;">Open</a>':'')
          +'<button class="rf-btn" data-act="del" data-id="'+r.id+'" style="color:#b3271c;border-color:#e6c3bf;">Delete</button>'
          +'</div><div class="rf-cite-slot"></div>';
        listEl.appendChild(d);
      });
      Array.prototype.forEach.call(listEl.querySelectorAll('.rf-status'), function(b){ b.addEventListener('click', function(){ cycleStatus(b.getAttribute('data-id')); }); });
      Array.prototype.forEach.call(listEl.querySelectorAll('.rf-btn[data-act]'), function(b){ b.addEventListener('click', function(){ var id=b.getAttribute('data-id'), act=b.getAttribute('data-act'); if(act==='cite') toggleCite(b,id); else if(act==='edit') startEdit(id); else if(act==='del') del(id); }); });
    }
    function findRef(id){ for(var i=0;i<stateRefs.length;i++) if(stateRefs[i].id===id) return stateRefs[i]; return null; }
    function toggleCite(btn,id){ var slot=btn.closest('div').parentNode.querySelector('.rf-cite-slot'); if(slot.innerHTML){ slot.innerHTML=''; return; } var r=findRef(id); if(!r) return;
      var fmts=[['APA',apa(r)],['IEEE',ieee(r)],['BibTeX',bibtex(r)]];
      slot.innerHTML=fmts.map(function(f){ return '<div class="rf-cite"><div style="display:flex;justify-content:space-between;align-items:center;"><span style="font-family:JetBrains Mono,monospace;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--rust);font-weight:700;">'+f[0]+'</span><button class="rf-btn rf-copy" data-cite="'+esc(f[1])+'">Copy</button></div><pre>'+esc(f[1])+'</pre></div>'; }).join('');
      Array.prototype.forEach.call(slot.querySelectorAll('.rf-copy'), function(cb){ cb.addEventListener('click', function(){ var t=cb.getAttribute('data-cite'); (navigator.clipboard&&navigator.clipboard.writeText?navigator.clipboard.writeText(t):Promise.reject()).then(function(){ cb.textContent='Copied'; setTimeout(function(){cb.textContent='Copy';},1200); }).catch(function(){ cb.textContent='Copy failed'; }); }); });
    }
    function cycleStatus(id){ var r=findRef(id); if(!r) return; var i=REF_STATUSES.indexOf(r.status); r.status=REF_STATUSES[(i+1)%REF_STATUSES.length]; renderList(); post({action:'status',id:id,status:r.status}); }

    // ----- form / CRUD -----
    var f={ title:document.getElementById('rTitle'), authors:document.getElementById('rAuthors'), year:document.getElementById('rYear'), venue:document.getElementById('rVenue'), url:document.getElementById('rUrl'), tags:document.getElementById('rTags'), status:sel, notes:document.getElementById('rNotes') };
    function readForm(){ return { title:f.title.value.trim(), authors:f.authors.value.trim(), year:f.year.value?Number(f.year.value):null, venue:f.venue.value.trim(), url:f.url.value.trim(), tags:f.tags.value.trim(), status:f.status.value, notes:f.notes.value.trim() }; }
    function clearForm(){ f.title.value=f.authors.value=f.year.value=f.venue.value=f.url.value=f.tags.value=f.notes.value=''; f.status.value='to-read'; }
    function startEdit(id){ var r=findRef(id); if(!r) return; editingId=id; f.title.value=r.title; f.authors.value=r.authors; f.year.value=r.year||''; f.venue.value=r.venue; f.url.value=r.url; f.tags.value=r.tags; f.status.value=r.status; f.notes.value=r.notes||'';
      document.getElementById('refFormTitle').textContent='Edit reference'; document.getElementById('rSave').textContent='Save changes'; document.getElementById('rCancel').style.display='inline-block'; window.scrollTo({top:0,behavior:'smooth'}); }
    document.getElementById('rCancel').addEventListener('click', function(){ editingId=null; clearForm(); document.getElementById('refFormTitle').textContent='Add a reference'; document.getElementById('rSave').textContent='Add reference'; this.style.display='none'; });
    document.getElementById('rSave').addEventListener('click', function(){
      var data=readForm(), msg=document.getElementById('rMsg');
      if(!data.title){ msg.textContent='Title is required.'; return; } msg.textContent='';
      if(editingId){ var r=findRef(editingId); Object.assign(r,data); renderList(); post({action:'update',id:editingId,ref:data}); document.getElementById('rCancel').click(); }
      else { post({action:'add',ref:data}).then(function(j){ if(j&&j.ok&&j.id){ stateRefs.unshift(Object.assign({id:j.id},data)); renderList(); clearForm(); } else { msg.textContent=(j&&j.error)||'Could not save.'; } }); }
    });
    function del(id){ if(!confirm('Delete this reference?')) return; stateRefs=stateRefs.filter(function(r){return r.id!==id;}); renderList(); post({action:'delete',id:id}); }
    searchEl.addEventListener('input', renderList);

    function post(body){ return fetch('/api/aquintutor/research',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'same-origin',body:JSON.stringify(body)}).then(function(r){return r.json();}).catch(function(){return {ok:false};}); }

    renderSteps(); renderList();
  })();
  </script>
</AquintutorLayout>
