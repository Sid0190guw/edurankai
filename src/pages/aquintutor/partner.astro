---
// /aquintutor/partner — partner area (Prompt 2b, main surface). Server-side gated to the
// 'partner' role. Reads REAL published catalogue objects from the Prompt-1 kernel (public,
// published/referenced) so a partner sees what they may reference; graceful empty-state when
// nothing is published yet or the kernel is not initialised. No mock data.
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { resolvePrincipal, can } from '@/lib/rbac';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/partner');
const principal = await resolvePrincipal(user);
if (!principal.roles.includes('partner')) return Astro.redirect('/aquintutor/access');
await can(user, 'read', { type: 'partner' });   // audited role-area access

const rows = (r: any): any[] => (Array.isArray(r) ? r : (r?.rows || []));
let catalogue: any[] = [];
let total = 0;
try {
  catalogue = rows(await db.execute(sql`SELECT id, type,
      COALESCE(metadata->>'title', data->>'title', type) AS title, lifecycle_state, updated_at
    FROM kernel_objects
    WHERE lifecycle_state IN ('published','referenced') AND 'public' = ANY(security_labels)
    ORDER BY updated_at DESC LIMIT 24`));
  total = rows(await db.execute(sql`SELECT COUNT(*)::int AS c FROM kernel_objects WHERE lifecycle_state IN ('published','referenced') AND 'public' = ANY(security_labels)`))[0]?.c || 0;
} catch { catalogue = []; total = 0; }   // kernel not initialised yet -> empty-state

const CARD = 'background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:14px;padding:20px 22px;margin-bottom:14px;';
---
<AquintutorLayout title="Partner area">
  <main style="max-width:920px;margin:0 auto;padding:48px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Partner</p>
    <h1 style="font-family:Fraunces,serif;font-size:34px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 6px;line-height:1.1;">Partner area</h1>
    <p style="font-family:Inter Tight,sans-serif;font-size:15px;color:#6b6455;margin:0 0 28px;">The published catalogue you may reference. {total} public item{total === 1 ? '' : 's'} available.</p>

    {catalogue.length === 0 ? (
      <div style={CARD}>
        <p style="font-family:Inter Tight,sans-serif;font-size:15px;color:#6b6455;margin:0;">No public catalogue items are published yet. As soon as content is published to the shared catalogue, it will appear here for your reference.</p>
      </div>
    ) : (
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:12px;">
        {catalogue.map((c: any) => (
          <div style={CARD + 'margin-bottom:0;'}>
            <span style="font-family:'Geist Mono',monospace;font-size:10px;letter-spacing:0.08em;text-transform:uppercase;color:var(--rust,#b3541e);">{c.type}</span>
            <h2 style="font-family:Fraunces,serif;font-size:17px;font-weight:600;color:var(--ink,#1a1712);margin:6px 0 4px;line-height:1.25;">{c.title}</h2>
            <p style="font-family:Inter Tight,sans-serif;font-size:12.5px;color:#8a8478;margin:0;">{c.lifecycle_state}</p>
          </div>
        ))}
      </div>
    )}
  </main>
</AquintutorLayout>
