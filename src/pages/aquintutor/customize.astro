---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { getUserXp } from '@/lib/xp';
import { getCertificatesForUser } from '@/lib/certificates';
import { ic } from '@/lib/policy-icons';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/customize'));

function rows(r: any) { return Array.isArray(r) ? r : (r?.rows || []); }
let okMsg = '';
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const avatar = (fd.get('avatar') as string || '').slice(0, 40);
  const langsRaw = (fd.get('preferred_languages') as string || '').slice(0, 500);
  const langs = langsRaw ? langsRaw.split(',').map(s => s.trim()).filter(Boolean) : [];
  const show = fd.get('show_on_leaderboard') === 'on';
  try {
    await db.execute(sql`ALTER TABLE users ADD COLUMN IF NOT EXISTS avatar VARCHAR(40)`);
    await db.execute(sql`ALTER TABLE users ADD COLUMN IF NOT EXISTS preferred_languages JSONB DEFAULT '[]'::jsonb`);
    await db.execute(sql`ALTER TABLE users ADD COLUMN IF NOT EXISTS show_on_leaderboard BOOLEAN NOT NULL DEFAULT true`);
  } catch (_) {}
  await db.execute(sql`
    UPDATE users SET avatar = ${avatar || null}, preferred_languages = ${sql.raw("'" + JSON.stringify(langs).replace(/'/g, "''") + "'::jsonb")},
      show_on_leaderboard = ${show}
    WHERE id = ${user.id}
  `).catch(() => {});
  okMsg = 'Saved.';
}

let profile: any = {};
try {
  const r = await db.execute(sql`SELECT avatar, COALESCE(preferred_languages, '[]'::jsonb) AS preferred_languages, COALESCE(show_on_leaderboard, true) AS show_on_leaderboard, name, email FROM users WHERE id = ${user.id} LIMIT 1`);
  profile = rows(r)[0] || {};
} catch (_) {}

const xp = await getUserXp(user.id);
const certs = await getCertificatesForUser(user.id);

// SVG avatar keys (resolve via ic()); replaces the old emoji set. Legacy stored
// emoji avatars still render (ic passes unknown strings through) until re-picked.
const AVATARS = ['bird','cat','fish','turtle','bug','rabbit','anchor','moon','sun','flower','star','flame','zap','sparkles','gem','crown','leaf','sprout','rocket','heart'];
const LANG_OPTS = [
  { code: 'en', name: 'English' }, { code: 'hi', name: 'Hindi' }, { code: 'sa', name: 'Sanskrit' },
  { code: 'bn', name: 'Bengali' }, { code: 'ta', name: 'Tamil' }, { code: 'te', name: 'Telugu' },
  { code: 'mr', name: 'Marathi' }, { code: 'gu', name: 'Gujarati' }, { code: 'es', name: 'Spanish' },
  { code: 'fr', name: 'French' }, { code: 'de', name: 'German' }, { code: 'ja', name: 'Japanese' },
];
let prefLangs: string[] = [];
const raw = profile.preferred_languages;
if (Array.isArray(raw)) prefLangs = raw;
else if (typeof raw === 'string') { try { prefLangs = JSON.parse(raw); } catch (_) {} }
---
<AquintutorLayout title="Customize" description="Customize your AquinTutor avatar, languages, and privacy.">
  <section style="border-bottom:1px solid var(--rule); background:linear-gradient(180deg,#fff8f3 0%, var(--paper) 100%);">
    <div style="max-width:920px; margin:0 auto; padding:36px 28px;">
      <div style="display:flex; gap:24px; align-items:center; flex-wrap:wrap;">
        <span style="font-size:64px; line-height:1; display:inline-flex; color:var(--rust);" set:html={ic(profile.avatar || 'bird')}></span>
        <div>
          <p style="font-family:'Inter Tight',monospace; font-size:12px; color:var(--rust); font-weight:700; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 6px;">Customize</p>
          <h1 class="font-display" style="font-size:clamp(1.8rem,3.5vw,2.6rem); line-height:1.1; font-weight:500; margin:0;">{profile.name || profile.email}</h1>
          <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); margin-top:6px; display:flex; align-items:center; gap:6px; flex-wrap:wrap;">Level {xp.level} · {xp.totalXp.toLocaleString()} XP ·<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>{xp.streakDays} day streak ·<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>{certs.length} cert{certs.length === 1 ? '' : 's'}</p>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div style="max-width:920px; margin:0 auto; padding:32px 28px 80px;">
      {okMsg && <div style="background:rgba(16,185,129,0.10); border:1px solid rgba(16,185,129,0.3); color:#047857; font-size:13px; padding:10px 14px; border-radius:8px; margin-bottom:16px;">{okMsg}</div>}

      <form method="POST" style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:24px; margin-bottom:20px;">
        <p style="font-family:'Inter Tight',monospace; font-size:11px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-500); font-weight:700; margin:0 0 14px;">Avatar</p>
        <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(54px, 1fr)); gap:8px; margin-bottom:18px;">
          {AVATARS.map(a => {
            const sel = profile.avatar === a;
            return (
              <label style="cursor:pointer; position:relative;">
                <input type="radio" name="avatar" value={a} checked={sel} style="position:absolute; opacity:0; width:0; height:0;" />
                <span class="av-tile" style={'display:flex;align-items:center;justify-content:center;height:54px;font-size:28px;color:var(--rust);border:2px solid ' + (sel ? 'var(--rust)' : 'var(--rule)') + ';border-radius:12px;background:' + (sel ? 'rgba(217,119,87,0.10)' : 'var(--paper)') + ';'} set:html={ic(a)}></span>
              </label>
            );
          })}
        </div>

        <p style="font-family:'Inter Tight',monospace; font-size:11px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-500); font-weight:700; margin:0 0 10px;">Languages I'm learning</p>
        <div style="display:flex; flex-wrap:wrap; gap:6px; margin-bottom:12px;">
          {LANG_OPTS.map(l => {
            const checked = prefLangs.indexOf(l.code) !== -1;
            return (
              <label style={'display:inline-flex;align-items:center;gap:5px;padding:6px 12px;border:1px solid ' + (checked ? 'var(--rust)' : 'var(--rule)') + ';border-radius:100px;cursor:pointer;background:' + (checked ? 'rgba(217,119,87,0.10)' : 'var(--paper)') + ';'}>
                <input type="checkbox" checked={checked} class="lang-cb" data-code={l.code} style="display:none;" />
                <span style="font-size:13px; font-weight:600;">{l.name}</span>
              </label>
            );
          })}
        </div>
        <input type="hidden" name="preferred_languages" id="prefLangs" value={prefLangs.join(',')} />

        <p style="font-family:'Inter Tight',monospace; font-size:11px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-500); font-weight:700; margin:18px 0 8px;">Privacy</p>
        <label style="display:flex; align-items:center; gap:10px; font-size:14px;">
          <input type="checkbox" name="show_on_leaderboard" checked={profile.show_on_leaderboard !== false} />
          Show me on the public leaderboard + league
        </label>

        <button type="submit" style="margin-top:18px; background:var(--rust); color:#fff; padding:12px 22px; border:none; border-radius:10px; font-family:inherit; font-size:14px; font-weight:700; cursor:pointer;">Save customisation</button>
      </form>

      {certs.length > 0 && (
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:24px;">
          <p style="font-family:'Inter Tight',monospace; font-size:11px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-500); font-weight:700; margin:0 0 14px;">Certificates</p>
          {certs.map((c: any) => (
            <div style="display:flex; gap:14px; align-items:center; padding:12px 0; border-bottom:1px solid var(--rule);">
              <span style="display:inline-flex; color:var(--rust);"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/><path d="M22 10v6"/><path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"/></svg></span>
              <div style="flex:1;">
                <p style="font-family:'Fraunces',serif; font-size:15px; font-weight:600; margin:0;">{c.course_title}</p>
                <p style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--ink-500);">{c.cert_number} · issued {new Date(c.issued_at).toLocaleDateString()}</p>
              </div>
              <a href={'/verify/' + c.cert_number} target="_blank" style="font-size:12px; color:var(--rust); font-weight:600;">Verify →</a>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <script is:inline>
    (function () {
      document.querySelectorAll('.av-tile').forEach(function (t) {
        t.addEventListener('click', function () {
          var label = t.closest('label');
          var input = label ? label.querySelector('input[type=radio]') : null;
          if (input) input.checked = true;
          document.querySelectorAll('.av-tile').forEach(function (x) { x.style.borderColor = 'var(--rule)'; x.style.background = 'var(--paper)'; });
          t.style.borderColor = 'var(--rust)';
          t.style.background = 'rgba(217,119,87,0.10)';
        });
      });
      function syncPref() {
        var codes = [];
        document.querySelectorAll('.lang-cb').forEach(function (c) { if (c.checked) codes.push(c.getAttribute('data-code')); });
        document.getElementById('prefLangs').value = codes.join(',');
      }
      document.querySelectorAll('.lang-cb').forEach(function (c) {
        var label = c.closest('label');
        if (!label) return;
        label.addEventListener('click', function (e) {
          if (e.target.tagName !== 'INPUT') c.checked = !c.checked;
          syncPref();
          label.style.borderColor = c.checked ? 'var(--rust)' : 'var(--rule)';
          label.style.background = c.checked ? 'rgba(217,119,87,0.10)' : 'var(--paper)';
        });
      });
    })();
  </script>
</AquintutorLayout>
