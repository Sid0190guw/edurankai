---
// /aquintutor/discussion — community discussion (Prompt 20, main surface). General space; a thread
// view (?t=). Post/reply/report. Removed posts are hidden for students. Server-rendered, light.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { can } from '@/lib/rbac';
import { isMinorStage } from '@/lib/rbac/roles';
import { getProfile } from '@/lib/student-settings';
import { listThreads, getThread, threadPosts, filterVisible, canParticipate } from '@/lib/edu-community';
import { mdLite } from '@/lib/content-render';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/discussion');
const rows = (r: any): any[] => (Array.isArray(r) ? r : (r?.rows || []));
const isModerator = (await can(user, 'delete', { type: 'discussion' })).allow;
let minor = false;
try { const stage = rows(await db.execute(sql`SELECT stage FROM rbac_user_roles WHERE user_id = ${user.id} AND role_key = 'student' LIMIT 1`))[0]?.stage; minor = isMinorStage(stage); } catch {}
const consent = minor ? !!(await getProfile(user.id).catch(() => null))?.consent?.community : true;
const mayPost = canParticipate(minor, consent);

const tid = (Astro.url.searchParams.get('t') || '').trim();
const thread = tid ? await getThread(tid).catch(() => null) : null;
const posts = thread ? filterVisible(await threadPosts(tid).catch(() => []), isModerator) : [];
const threads = thread ? [] : await listThreads('general', null, 50).catch(() => []);
function fmt(d: any) { try { return new Date(d).toLocaleString('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); } catch { return '-'; } }
const CARD = 'background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:12px;padding:16px 18px;margin-bottom:12px;';
---
<AquintutorLayout title={thread ? thread.title : 'Discussion'}>
  <main style="max-width:720px;margin:0 auto;padding:44px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Community</p>
    <div id="msg" style="display:none;margin:0 0 14px;padding:9px 13px;border-radius:8px;font-size:13px;"></div>
    {!mayPost ? <p style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#8a5a1a;background:#fff8ef;border:1px solid #f0d9b4;border-radius:10px;padding:10px 14px;margin:0 0 14px;">A guardian must enable community participation for your account. You can still read.</p> : null}

    {thread ? (
      <div>
        <a href="/aquintutor/discussion" style="font-family:'Inter Tight',sans-serif;font-size:13px;color:var(--rust,#b3541e);text-decoration:none;">&larr; All discussions</a>
        <h1 style="font-family:Fraunces,serif;font-size:26px;font-weight:600;color:var(--ink,#1a1712);margin:8px 0 16px;line-height:1.2;">{thread.title}</h1>
        {posts.length === 0 ? <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#6b6455;">No posts yet.</p> :
          posts.map((p: any) => (
            <div style={CARD + (p.removed ? 'opacity:.55;' : '')}>
              <div style="display:flex;justify-content:space-between;gap:8px;margin-bottom:6px;"><span style="font-family:'Inter Tight',sans-serif;font-size:13px;font-weight:700;color:var(--ink,#1a1712);">{p.author || 'user'}{p.removed ? ' (removed)' : ''}</span><span style="font-family:'Geist Mono',monospace;font-size:10.5px;color:#8a8478;">{fmt(p.created_at)}</span></div>
              <div class="lesson-body" style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#2a251d;" set:html={mdLite(p.body)}></div>
              <button class="report" data-id={p.id} type="button" style="background:none;border:none;color:#b0a99a;font-size:11px;cursor:pointer;margin-top:6px;padding:0;">Report</button>
            </div>
          ))}
        {mayPost ? (
          <div style={CARD}><textarea id="replyBody" rows="3" placeholder="Add a reply (markdown)" style="width:100%;box-sizing:border-box;font-family:'Inter Tight',sans-serif;font-size:14px;padding:9px 11px;border:1px solid var(--line,#e6e1d6);border-radius:9px;"></textarea><button id="replyBtn" type="button" style="margin-top:8px;background:var(--ink,#1a1712);color:var(--sand-50,#fbfaf4);border:none;border-radius:9px;padding:9px 18px;font-family:'Inter Tight',sans-serif;font-size:13.5px;font-weight:600;cursor:pointer;">Post reply</button></div>
        ) : null}
      </div>
    ) : (
      <div>
        <h1 style="font-family:Fraunces,serif;font-size:30px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 16px;line-height:1.15;">Discussion</h1>
        {mayPost ? (
          <div style={CARD}><input id="ntTitle" placeholder="Start a new discussion…" style="width:100%;box-sizing:border-box;font-family:'Inter Tight',sans-serif;font-size:14.5px;padding:9px 11px;border:1px solid var(--line,#e6e1d6);border-radius:9px;margin-bottom:8px;" /><textarea id="ntBody" rows="2" placeholder="First message (optional)" style="width:100%;box-sizing:border-box;font-family:'Inter Tight',sans-serif;font-size:14px;padding:9px 11px;border:1px solid var(--line,#e6e1d6);border-radius:9px;"></textarea><button id="ntBtn" type="button" style="margin-top:8px;background:var(--ink,#1a1712);color:var(--sand-50,#fbfaf4);border:none;border-radius:9px;padding:9px 18px;font-family:'Inter Tight',sans-serif;font-size:13.5px;font-weight:600;cursor:pointer;">Start discussion</button></div>
        ) : null}
        {threads.length === 0 ? <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#6b6455;">No discussions yet.</p> :
          threads.map((t: any) => (
            <a href={'?t=' + t.id} style="display:flex;justify-content:space-between;align-items:center;gap:10px;text-decoration:none;background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:10px;padding:12px 16px;margin-bottom:8px;">
              <span><span style="display:block;font-family:'Inter Tight',sans-serif;font-size:15px;font-weight:600;color:var(--ink,#1a1712);">{t.title}</span><span style="font-family:'Inter Tight',sans-serif;font-size:12px;color:#8a8478;">by {t.author || 'user'} · {t.posts} posts</span></span>
              <span style="color:var(--rust,#b3541e);">&rarr;</span>
            </a>
          ))}
      </div>
    )}
  </main>

  <script is:inline define:vars={{ tid }}>
    (function () {
      var msg = document.getElementById('msg');
      function post(body) { return fetch('/api/aquintutor/discussion', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }).then(function (r) { return r.json(); }); }
      function flash(t, ok) { msg.style.display = 'block'; msg.textContent = t; msg.style.background = ok ? '#eef8f1' : '#fdecec'; msg.style.color = ok ? '#2f7d5b' : '#9b2c2c'; }
      var nt = document.getElementById('ntBtn'); if (nt) nt.addEventListener('click', function () { post({ action: 'newThread', title: document.getElementById('ntTitle').value, body: document.getElementById('ntBody').value }).then(function (j) { if (j.ok) location.href = '?t=' + j.id; else flash(j.error || 'Failed', false); }); });
      var rb = document.getElementById('replyBtn'); if (rb) rb.addEventListener('click', function () { post({ action: 'post', threadId: tid, body: document.getElementById('replyBody').value }).then(function (j) { if (j.ok) location.reload(); else flash(j.error || 'Failed', false); }); });
      document.querySelectorAll('.report').forEach(function (b) { b.addEventListener('click', function () { var reason = prompt('Why report this?') || ''; post({ action: 'report', postId: b.getAttribute('data-id'), reason: reason }).then(function (j) { flash(j.ok ? 'Reported — a moderator will review.' : (j.error || 'Failed'), j.ok); }); }); });
    })();
  </script>
</AquintutorLayout>
