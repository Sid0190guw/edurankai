---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import VerifiedSummary from '@/components/aquintutor/VerifiedSummary.astro';
import { getVerifiedSummary } from '@/lib/aquintutor-summary';
import { resolveShare } from '@/lib/aquintutor-share';
// Public, read-only verified-progress view for a parent or teacher. No account
// needed — the learner shared an unguessable token and can revoke it any time.
const { token } = Astro.params;
const owner = token ? await resolveShare(token) : null;
const summary = owner ? await getVerifiedSummary(owner.userId) : null;
const learnerName = (owner?.name || '').split(' ')[0] || 'This learner';
---
<AquintutorLayout title="Shared progress" description="A read-only view of a learner's verified progress on AquinTutor.">
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:820px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a><span style="margin:0 8px;">/</span><span style="color:var(--rust); font-weight:600;">SHARED PROGRESS</span>
    </div>
  </div>

  <section style="max-width:820px; margin:0 auto; padding:36px 24px 80px;">
    {(!owner || !summary) && (
      <div style="background:#fff; border:1.5px dashed var(--rule); border-radius:16px; padding:34px; text-align:center;">
        <h1 class="font-display" style="font-size:1.5rem; font-weight:600; color:var(--ink); margin:0 0 8px;">This link isn't active.</h1>
        <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); margin:0;">It may have been turned off by the learner, or the address is incomplete. Ask them to share a new link.</p>
      </div>
    )}

    {owner && summary && (
      <div>
        <p style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--rust); font-weight:700; margin:0 0 8px;">
          Read-only · shared with you{summary.profile ? ' · ' + summary.profile.tierName : ''}
        </p>
        <h1 class="font-display" style="font-size:clamp(1.8rem,4vw,2.6rem); font-weight:500; letter-spacing:-0.01em; margin:0 0 6px; color:var(--ink);">{learnerName}'s <em style="color:var(--rust); font-style:italic;">verified</em> learning.</h1>
        <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); line-height:1.6; margin:0 0 26px; max-width:620px;">Not hours watched — understanding demonstrated. Everything here was earned by passing an exit ticket, teaching it back, or logging real evidence.</p>

        {!summary.hasAnything
          ? <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.1rem; color:var(--ink-500);">No verified learning to show yet. Check back once {learnerName} has started.</p>
          : <VerifiedSummary summary={summary} readOnly={true} />}

        <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink-500); margin-top:28px; padding-top:16px; border-top:1px solid var(--rule);">You're viewing a private link shared by the learner. It shows only verified learning progress and can be turned off at any time.</p>
      </div>
    )}
  </section>
</AquintutorLayout>
