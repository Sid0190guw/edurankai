---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

const STAGES = [
  {
    n: '01',
    label: 'Stage 1',
    title: 'Qualifying Aptitude Test',
    when: 'Open registration · Online',
    fee: 'Application fee: CHF 10',
    body: 'A two-hour online assessment designed to identify high-potential candidates across the full breadth of analytical and scientific reasoning. Topics include analytical reasoning, scientific aptitude, quantitative thinking, problem solving, computational thinking. Open to students and professionals. The bar is rigorous; the bar is the same for everyone. Top performers advance to Stage 2.',
    tone: 'sky',
  },
  {
    n: '02',
    label: 'Stage 2',
    title: '30-Day Bootcamp (cohort)',
    when: 'Fixed start date · Online + live sessions',
    fee: 'Programme fee: CHF 3,000',
    body: 'A thirty-day, cohort-based intensive on Quantum Computing, Quantum Information Science, and adjacent emerging technologies. Daily structured curriculum, project work, guest seminars from researchers and field practitioners, and continuous assessment. Cohort capacity is deliberately small so feedback is personal. Need-based aid, merit-based aid, and extraordinary fellowships available — see below.',
    tone: 'burn',
  },
  {
    n: '03',
    label: 'Stage 3',
    title: 'Post-Bootcamp Test',
    when: 'Final week · Proctored',
    fee: 'Included in programme fee',
    body: 'A capstone assessment evaluating depth of conceptual understanding, ability to reason fluently in the language of the field, applied analytical skill, and capacity to operate beyond the syllabus. Proctored via our integrity stack. Performance here counts toward the final qualification ranking.',
    tone: 'gold',
  },
  {
    n: '04',
    label: 'Stage 4',
    title: 'Offline Round · Final',
    when: 'Held in person · Hosting institute (TBA)',
    fee: 'Travel may be subsidised for top tier',
    body: 'Three-day in-person final round at the hosting institute. Hands-on training, panel discussions with research scientists, group exercises, and a closing oral defence. Mirrors the cadence of an early-career research fellowship. Candidates who clear this stage receive the verifiable qualifying credential and are entered into our internship + research-affiliate pipeline.',
    tone: 'leaf',
  },
];

const AID_TIERS = [
  {
    label: 'Need-based aid',
    accent: 'sky',
    eligibility: 'Open to candidates whose household income makes the 3,000 CHF programme fee a genuine barrier. Income brackets are reviewed at the application stage; documentation is requested only after a provisional offer.',
    extent: 'Covers 30% – 100% of the programme fee depending on need, evaluated case by case.',
    process: 'Apply via the Financial Aid form in your portal after passing Stage 1. Decisions arrive within 7 business days. Aid does not affect the academic decision.',
  },
  {
    label: 'Merit-based aid',
    accent: 'gold',
    eligibility: 'Top performers on the Stage 1 Aptitude Test. Top 10% are automatically considered; no separate application is required.',
    extent: 'Covers 25% – 100% of the programme fee. Top three scorers across the global pool receive a full waiver + a small living stipend during the cohort.',
    process: 'Decisions are made within 72 hours of Stage 1 results and shown in your portal alongside your score.',
  },
  {
    label: 'Extraordinary Fellowship',
    accent: 'burn',
    eligibility: 'Reserved for candidates whose existing body of work (published research, open-source contributions, original projects) shows exceptional promise. Self-nomination + portfolio review.',
    extent: 'Full waiver of programme fee + a research stipend for the duration of the cohort + a fast-track interview into our Research Lab post-completion.',
    process: 'Apply via the Extraordinary Fellowship form in your portal at any stage. Reviewed by a panel including the Founder. Decisions take up to 3 weeks.',
  },
];
---
<AquintutorLayout title="Quantum Science & ASI Bootcamp — 30-Day Cohort · AquinTutor" description="A 30-day cohort-based bootcamp on Quantum Science and Artificial Superintelligence. Four-stage qualification: Aptitude Test → Bootcamp → Capstone Test → Offline Final. CHF 3,000 programme fee with need-based aid, merit-based aid, and Extraordinary Fellowships available.">

<section class="px-[5vw] pt-10 md:pt-16 pb-8 max-w-5xl mx-auto">
  <a href="/aquintutor" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All bootcamps</a>

  <div class="mt-5">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-3">Quantum Science &amp; ASI · 30-day cohort</p>
    <h1 class="font-display text-[clamp(2rem,5vw,3.4rem)] font-semibold text-ink leading-[1.05] tracking-tight mb-4">
      Qualify in <em class="italic text-burn font-medium">four stages.</em><br/>Then learn at the frontier.
    </h1>
    <p class="text-[1rem] text-ink-2 font-light leading-[1.85] max-w-3xl">
      A rigorous, cohort-based path into quantum science and artificial superintelligence. You qualify through a four-stage gate — aptitude, bootcamp, capstone, offline final — and the qualification itself is the credential. No participation certificates; the qualification means something only because the bar is real.
    </p>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-2 mt-8 mb-2 max-w-4xl">
    <div class="bg-white border border-ink/10 rounded-xl px-4 py-3">
      <p class="text-[0.6rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-1">Stages</p>
      <p class="font-display text-[1.5rem] font-semibold text-ink leading-none">4</p>
    </div>
    <div class="bg-white border border-ink/10 rounded-xl px-4 py-3">
      <p class="text-[0.6rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-1">Cohort length</p>
      <p class="font-display text-[1.5rem] font-semibold text-ink leading-none">30 days</p>
    </div>
    <div class="bg-white border border-ink/10 rounded-xl px-4 py-3">
      <p class="text-[0.6rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-1">Application fee</p>
      <p class="font-display text-[1.5rem] font-semibold text-ink leading-none">CHF 10</p>
      <p class="text-[0.66rem] text-ink-soft mt-0.5">waiver available</p>
    </div>
    <div class="bg-burn-pale border border-burn-dim rounded-xl px-4 py-3">
      <p class="text-[0.6rem] font-mono uppercase tracking-[0.14em] text-burn font-bold mb-1">Programme fee</p>
      <p class="font-display text-[1.5rem] font-semibold text-ink leading-none">CHF 3,000</p>
      <p class="text-[0.66rem] text-burn font-semibold mt-0.5">aid available</p>
    </div>
  </div>
</section>

{/* ============== STAGED QUALIFICATION FLOW ============== */}
<section class="px-[5vw] py-8 md:py-12 max-w-5xl mx-auto border-t border-ink/8">

  <div class="mb-8">
    <p class="eyebrow mb-2">Qualification flow</p>
    <h2 class="font-display text-[clamp(1.6rem,3.4vw,2.4rem)] font-semibold text-ink leading-[1.15] tracking-tight">
      Four stages, in order. Each one is real.
    </h2>
  </div>

  <div class="flex flex-col gap-5">
    {STAGES.map((s) => {
      const toneClasses: any = {
        sky:  'bg-sky-bg border-sky-border text-sky',
        burn: 'bg-burn-pale border-burn-dim text-burn',
        gold: 'bg-gold-bg border-gold-border text-gold-deep',
        leaf: 'bg-leaf-bg border-leaf-border text-leaf',
      };
      const accent = toneClasses[s.tone] || toneClasses.sky;
      return (
        <article class="bg-white border border-ink/10 rounded-2xl p-6 md:p-7 flex flex-col md:flex-row gap-5 md:gap-6">
          <div class={`flex-shrink-0 w-full md:w-32 rounded-xl px-4 py-3 ${accent} text-center md:text-left`}>
            <p class="font-mono text-[0.62rem] uppercase tracking-[0.14em] font-bold m-0 mb-1">{s.label}</p>
            <p class="font-display text-[1.85rem] font-semibold leading-none m-0">{s.n}</p>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex justify-between items-start gap-3 flex-wrap mb-2">
              <h3 class="font-display text-[1.25rem] font-semibold text-ink leading-tight m-0">{s.title}</h3>
              <span class="font-mono text-[0.7rem] text-ink-soft whitespace-nowrap">{s.when}</span>
            </div>
            <p class="text-[0.88rem] text-ink-2 leading-relaxed m-0 mb-3">{s.body}</p>
            <p class="font-mono text-[0.72rem] text-burn font-semibold m-0">{s.fee}</p>
          </div>
        </article>
      );
    })}
  </div>
</section>

{/* ============== FINANCIAL AID TIERS ============== */}
<section class="px-[5vw] py-12 md:py-16 max-w-5xl mx-auto border-t border-ink/8">

  <div class="mb-8 max-w-3xl">
    <p class="eyebrow mb-2">Financial access</p>
    <h2 class="font-display text-[clamp(1.6rem,3.4vw,2.4rem)] font-semibold text-ink leading-[1.15] tracking-tight mb-3">
      The fee should never be the reason you do not apply.
    </h2>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">
      Three independent channels — need-based aid, merit-based aid, and the Extraordinary Fellowship. They do not compete with each other. Apply for any or all you qualify for. The academic decision is made before any aid decision, so aid never affects whether you are admitted.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    {AID_TIERS.map((t) => {
      const cls: any = {
        sky:  'border-sky-border',
        gold: 'border-gold-border',
        burn: 'border-burn-dim',
      };
      const accentText: any = {
        sky: 'text-sky', gold: 'text-gold-deep', burn: 'text-burn',
      };
      return (
        <article class={`bg-white border ${cls[t.accent]} rounded-2xl p-6 flex flex-col`}>
          <p class={`font-mono text-[0.62rem] uppercase tracking-[0.16em] font-bold mb-2 ${accentText[t.accent]}`}>{t.label}</p>

          <div class="mb-3">
            <p class="font-mono text-[0.6rem] uppercase tracking-[0.12em] text-ink-soft font-bold mb-1">Eligibility</p>
            <p class="text-[0.84rem] text-ink-2 leading-relaxed m-0">{t.eligibility}</p>
          </div>

          <div class="mb-3">
            <p class="font-mono text-[0.6rem] uppercase tracking-[0.12em] text-ink-soft font-bold mb-1">Extent of aid</p>
            <p class="text-[0.84rem] text-ink-2 leading-relaxed m-0">{t.extent}</p>
          </div>

          <div>
            <p class="font-mono text-[0.6rem] uppercase tracking-[0.12em] text-ink-soft font-bold mb-1">How to apply</p>
            <p class="text-[0.84rem] text-ink-2 leading-relaxed m-0">{t.process}</p>
          </div>
        </article>
      );
    })}
  </div>

  <div class="bg-cream-2/60 border border-ink/10 rounded-xl px-5 py-4 mt-5 text-[0.84rem] text-ink-soft leading-relaxed">
    <p class="m-0">
      <strong class="text-ink font-semibold">Application fee waiver</strong> is also available — the 10 CHF Stage 1 fee can be waived through the same channel as our roles. <a href="/aquintutor" class="text-burn font-semibold underline underline-offset-2">Request a fee waiver →</a>
    </p>
  </div>
</section>

{/* ============== CTA ============== */}
<section class="px-[5vw] py-12 md:py-16 max-w-3xl mx-auto text-center">
  <h2 class="font-display text-[clamp(1.6rem,3.4vw,2.4rem)] font-semibold text-ink leading-[1.15] tracking-tight mb-4">
    Stage 1 starts with a <em class="italic text-burn font-medium">two-hour test.</em>
  </h2>
  <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85] mb-6">
    Register, pay the 10 CHF application fee (or request a waiver), and sit the test in your window. Top performers move to the cohort.
  </p>
  <div class="flex flex-wrap gap-3 justify-center">
    <a href="/aquintutor" class="btn-primary">Register for Stage 1 →</a>
    <a href="/aquintutor" class="btn-ghost">Request fee waiver</a>
  </div>
</section>

</AquintutorLayout>
