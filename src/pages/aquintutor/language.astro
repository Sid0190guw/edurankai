---
// /aquintutor/language — the locale switch (Prompt AP3a). Switching changes the interface strings
// live and flips to RTL for right-to-left languages. Untranslated strings fall back to English and
// are marked (in the admin coverage view). The choice persists per user.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { LOCALES, t, dir, localeInfo, coverageMerged, loadStrings, getStringOverrides } from '@/lib/i18n';

const user = Astro.locals.user;
let locale = Astro.cookies.get('locale')?.value || 'en';
if (user && locale === 'en') { try { const { getProfile } = await import('@/lib/student-settings'); locale = (await getProfile(user.id)).language || 'en'; } catch {} }
const info = localeInfo(locale);
const merged = await loadStrings(locale).catch(() => ({} as Record<string, string>));   // base + admin overrides
const tr = (k: string) => (merged[k] ?? t(k, locale));                                    // live-editable strings
const cov = coverageMerged(locale, await getStringOverrides(locale).catch(() => ({})));
const d = dir(locale);
---
<AquintutorLayout title={tr('lang.title')}>
  <main dir={d} style={'max-width:720px;margin:0 auto;padding:40px 22px 80px;text-align:' + (d === 'rtl' ? 'right' : 'left') + ';'}>
    <p style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust);margin:0 0 8px;">{info.native}</p>
    <h1 style="font-family:Fraunces,serif;font-size:30px;font-weight:600;color:var(--ink);margin:0 0 6px;">{tr('lang.title')}</h1>
    <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#6b6455;margin:0 0 6px;">{tr('lang.pick')}</p>
    {d === 'rtl' && <p style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#2f7d5b;margin:0 0 6px;">{t('lang.rtlNote', locale)}</p>}
    <p style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#8a8378;margin:0 0 20px;">{cov.pct}% {tr('lang.coverage')} · {cov.translated}/{cov.total}</p>
    <div id="msg" style="display:none;margin:0 0 14px;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:28px;">
      {LOCALES.map((l) => (
        <button class="locBtn" data-loc={l.code} style={'display:flex;justify-content:space-between;align-items:center;background:' + (l.code === locale ? 'var(--ink)' : '#fff') + ';color:' + (l.code === locale ? '#fff' : 'var(--ink)') + ';border:1px solid var(--rule);border-radius:10px;padding:12px 16px;font-family:Inter Tight,sans-serif;font-size:15px;cursor:pointer;'}>
          <span>{l.native}</span><span style="font-family:'JetBrains Mono',monospace;font-size:11px;opacity:0.7;">{l.name} · {l.dir}</span>
        </button>
      ))}
    </div>

    <div style="background:#fff;border:1px solid var(--rule);border-radius:12px;padding:18px 20px;">
      <p style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#8a8378;margin:0 0 10px;">PREVIEW</p>
      <p style="font-family:Fraunces,serif;font-size:20px;color:var(--ink);margin:0 0 6px;">{tr('access.title')}</p>
      <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#6b6455;margin:0 0 12px;">{tr('access.subtitle')}</p>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        {['nav.hub', 'nav.recordings', 'nav.settings', 'nav.search'].map((k) => (
          <span style="background:#faf9f4;border:1px solid var(--rule);border-radius:100px;padding:5px 12px;font-family:'Inter Tight',sans-serif;font-size:13px;color:var(--ink);">{tr(k)}</span>
        ))}
      </div>
    </div>
  </main>

  <script is:inline>
    document.querySelectorAll('.locBtn').forEach(function (b) {
      b.addEventListener('click', function () {
        fetch('/api/aquintutor/locale', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ locale: b.getAttribute('data-loc') }) })
          .then(function (r) { return r.json(); }).then(function (j) { if (j.ok) location.reload(); else { var m = document.getElementById('msg'); m.style.display = 'block'; m.style.background = '#fdecec'; m.style.color = '#9b2c2c'; m.textContent = j.error || 'failed'; } });
      });
    });
  </script>
</AquintutorLayout>
