---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

const seedMessages = [
  { who: 'aquin', text: "Hello. I'm Aquin - your AI tutor. I see you have a robotics IK gap on Q19. Want to spend twelve minutes closing it, or ask me anything else first?" },
  { who: 'user', text: "Why does my elbow-down solution fail on Q19?" },
  { who: 'aquin', text: "Because the workspace below z = 0.2m is reserved for tool clearance. Your math is correct, but the rubric expects the elbow-up branch. Flip the sign in θ₂ = ±arccos((r² − L₁² − L₂²) / (2L₁L₂)) and re-validate against the marker at z = 0.18m.", diagram: true },
];

const prompts = [
  'Walk me through the derivation step by step',
  'Show me a worked example',
  'Quiz me on this',
  'Compare elbow-up vs elbow-down geometrically',
  'Make three practice problems',
  'Translate this answer to Hindi',
];

const subjects = [
  { code: 'RB-330', name: 'Robotics · Inverse kinematics', color: '#946322', active: true },
  { code: 'AI-512', name: 'Transformers in Practice', color: '#2b577e' },
  { code: 'QT-407', name: 'Quantum Foundations', color: '#5b4a92' },
  { code: 'VS-101', name: 'Vedic Mathematics', color: '#a8472c' },
];

const recent = [
  { topic: 'Why does softmax need division by sqrt(d_k)?', course: 'AI-512', when: '3h ago' },
  { topic: 'Vedic sutras for cubing two-digit numbers', course: 'VS-101', when: 'yesterday' },
  { topic: 'Entanglement entropy of Bell states', course: 'QT-407', when: '2d ago' },
  { topic: 'Lagrangian for a double pendulum', course: 'PH-204', when: '4d ago' },
];

const settings = [
  { l: 'Language', v: 'English (auto)' },
  { l: 'Voice', v: 'Off' },
  { l: 'Diagram mode', v: 'SVG inline' },
  { l: 'Memory', v: 'Per course' },
];
---
<AquintutorLayout title="Aquin · your AI tutor" description="Aquin is your private AI tutor inside AquinTutor - asks where you're stuck, explains it differently, generates diagrams, sets stretch problems.">

  <!-- BREADCRUMB -->
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1400px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a>
      <span style="margin:0 8px;">/</span>
      <a href="/aquintutor/dashboard" style="color:var(--ink-500); text-decoration:none;">DASHBOARD</a>
      <span style="margin:0 8px;">/</span>
      <span style="color:#3d6b76; font-weight:600;">AQUIN · AI CO-PILOT</span>
    </div>
  </div>

  <!-- PAGE HEADER -->
  <section style="border-bottom:1px solid var(--rule); background:#f1f5f6;">
    <div style="max-width:1400px; margin:0 auto; padding:24px 28px;">
      <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:18px;">
        <div style="display:flex; align-items:center; gap:14px;">
          <span style="display:inline-flex; align-items:center; justify-content:center; width:54px; height:54px; min-width:54px; border-radius:14px; background:#3d6b76; color:#dbe7e9; font-family:'Fraunces',serif; font-weight:500; font-size:24px; letter-spacing:-0.02em;">A</span>
          <div>
            <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:#3d6b76; font-weight:600; margin:0;">AI co-pilot · AI-512</p>
            <h1 class="font-display" style="font-size:clamp(1.5rem, 2.6vw, 2rem); font-weight:500; line-height:1.15; letter-spacing:-0.02em; margin:4px 0 0; color:var(--ink);">Aquin</h1>
            <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:14.5px; color:var(--ink-500); margin:3px 0 0; line-height:1.4;">Asks where you're stuck. Explains it differently. Draws back.</p>
          </div>
        </div>
        <div style="display:flex; gap:8px; flex-wrap:wrap;">
          <button type="button" style="background:transparent; color:#3d6b76; padding:9px 16px; border:1px solid #3d6b76; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; cursor:pointer;">Session history</button>
          <button type="button" style="background:#3d6b76; color:#fff; padding:9px 16px; border:none; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; cursor:pointer;">Start new session</button>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN GRID -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:24px 28px; display:grid; grid-template-columns:1fr; gap:18px; min-height:680px;" class="aq-grid">

      <!-- CONVERSATION -->
      <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; display:flex; flex-direction:column; overflow:hidden; min-height:580px;">
        <!-- Subject pill -->
        <div style="padding:14px 20px; border-bottom:1px solid var(--rule); background:var(--sand-100); display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:8px;">
          <div style="display:inline-flex; align-items:center; gap:8px;">
            <span style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600;">Subject</span>
            <select style="background:var(--paper); border:1px solid var(--rule); border-radius:6px; padding:5px 11px; font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink); cursor:pointer; outline:none;">
              {subjects.map((s) => (<option selected={s.active}>{s.code} &middot; {s.name}</option>))}
            </select>
          </div>
          <span style="display:inline-flex; align-items:center; gap:6px; font-family:'JetBrains Mono',monospace; font-size:10.5px; color:#3f8a64; letter-spacing:0.1em;"><span style="display:inline-block; width:6px; height:6px; border-radius:50%; background:#7dd3a8; box-shadow:0 0 6px #7dd3a8;"></span>SESSION LIVE</span>
        </div>

        <!-- Session banner -->
        <div style="margin:16px 20px 0; padding:12px 16px; background:rgba(61,107,118,0.08); border:1px solid rgba(61,107,118,0.3); border-left:3px solid #3d6b76; border-radius:8px;">
          <p style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.18em; text-transform:uppercase; color:#3d6b76; font-weight:600; margin:0 0 6px;">CONTEXT &middot; FROM YOUR PROGRESS</p>
          <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:14px; color:var(--ink); line-height:1.5; margin:0;">You answered three of four IK problems on assignment RB-330 PS5; the failed one is Q19. I've loaded the rubric, your submission, and the marker constraints.</p>
        </div>

        <!-- Messages -->
        <div style="flex:1; overflow-y:auto; padding:18px 22px; display:flex; flex-direction:column; gap:14px;">
          {seedMessages.map((m) => (
            <div style={'display:flex; ' + (m.who === 'user' ? 'justify-content:flex-end;' : 'justify-content:flex-start;')}>
              <div style={'max-width:80%; padding:12px 16px; border-radius:14px; ' + (m.who === 'user'
                ? 'background:#3d6b76; color:#fff; border-radius:14px 14px 4px 14px;'
                : 'background:var(--sand-100); border:1px solid var(--rule); color:var(--ink); border-radius:14px 14px 14px 4px;')}>
                {m.who === 'aquin' && <p style="font-family:'JetBrains Mono',monospace; font-size:9.5px; letter-spacing:0.16em; text-transform:uppercase; color:#3d6b76; font-weight:600; margin:0 0 6px;">AQUIN</p>}
                <p style="font-family:'Inter Tight',sans-serif; font-size:14px; line-height:1.55; margin:0; color:inherit;">{m.text}</p>
                {m.diagram && (
                  <div style="margin-top:12px; padding:10px; background:var(--paper); border:1px solid var(--rule); border-radius:8px;">
                    <p style="font-family:'JetBrains Mono',monospace; font-size:9px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); margin:0 0 8px;">DIAGRAM &middot; ELBOW-UP VS ELBOW-DOWN</p>
                    <svg viewBox="0 0 280 160" style="width:100%; display:block;">
                      <!-- ground -->
                      <line x1="20" y1="140" x2="260" y2="140" stroke="var(--rule)" stroke-width="1"/>
                      <line x1="140" y1="20" x2="140" y2="140" stroke="var(--rule)" stroke-width="0.5" stroke-dasharray="3 3"/>
                      <!-- elbow-up arm -->
                      <line x1="140" y1="140" x2="195" y2="60" stroke="#3d6b76" stroke-width="2.5"/>
                      <line x1="195" y1="60" x2="240" y2="110" stroke="#3d6b76" stroke-width="2.5"/>
                      <circle cx="140" cy="140" r="5" fill="#3d6b76"/>
                      <circle cx="195" cy="60" r="4" fill="#3d6b76"/>
                      <circle cx="240" cy="110" r="6" fill="#3d6b76" stroke="#fff" stroke-width="1.5"/>
                      <text x="200" y="50" font-family="JetBrains Mono" font-size="9" fill="#3d6b76">elbow-up ✓</text>
                      <!-- elbow-down arm (faded) -->
                      <line x1="140" y1="140" x2="195" y2="125" stroke="#a04330" stroke-width="2" stroke-dasharray="4 3" opacity="0.6"/>
                      <line x1="195" y1="125" x2="240" y2="110" stroke="#a04330" stroke-width="2" stroke-dasharray="4 3" opacity="0.6"/>
                      <text x="195" y="148" font-family="JetBrains Mono" font-size="9" fill="#a04330">elbow-down ✗ (z &lt; 0.2)</text>
                      <text x="244" y="106" font-family="JetBrains Mono" font-size="9" fill="var(--ink)">target</text>
                    </svg>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>

        <!-- Quick prompts -->
        <div style="padding:0 22px 10px; display:flex; gap:6px; flex-wrap:wrap;">
          {prompts.map((p) => (
            <button type="button" data-prompt={p} class="aq-prompt" style="padding:6px 12px; background:rgba(61,107,118,0.06); border:1px solid rgba(61,107,118,0.3); border-radius:999px; color:#3d6b76; font-family:'Inter Tight',sans-serif; font-size:11.5px; font-weight:500; cursor:pointer; white-space:nowrap;">{p}</button>
          ))}
        </div>

        <!-- Composer -->
        <div style="padding:12px 22px 18px; border-top:1px solid var(--rule); background:var(--sand-100);">
          <div style="display:flex; flex-direction:column; gap:10px; padding:12px 14px; background:var(--paper); border:1px solid var(--rule); border-radius:12px;">
            <textarea id="aq-composer" rows="2" placeholder="Ask Aquin anything - derivations, examples, code, a quiz..." style="background:transparent; border:none; outline:none; resize:none; color:var(--ink); font-family:'Inter Tight',sans-serif; font-size:14px; line-height:1.5; width:100%;"></textarea>
            <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
              {[
                { l: 'Image', glyph: 'M3 3h18v18H3zM3 16l5-5 4 4 7-7' },
                { l: 'Voice', glyph: 'M9 3a3 3 0 016 0v8a3 3 0 01-6 0zM5 11a7 7 0 0014 0M12 19v3' },
                { l: 'Code', glyph: 'M16 6l6 6-6 6M8 6l-6 6 6 6' },
                { l: 'Whiteboard', glyph: 'M4 4h16v12H4zM2 20h20' },
              ].map((b) => (
                <button type="button" style="display:inline-flex; align-items:center; gap:5px; padding:5px 10px; background:transparent; border:1px solid var(--rule); border-radius:6px; color:var(--ink-500); font-family:'Inter Tight',sans-serif; font-size:11.5px; cursor:pointer;">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d={b.glyph}/></svg>{b.l}
                </button>
              ))}
              <span style="flex:1;"></span>
              <span style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.1em; color:var(--ink-500);">SHIFT+RETURN for newline</span>
              <button type="button" style="background:#3d6b76; color:#fff; padding:8px 18px; border:none; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:12.5px; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:6px;">
                Send <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l18-8-8 18-2-8-8-2z"/></svg>
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT RAIL -->
      <aside style="display:flex; flex-direction:column; gap:14px;">
        <!-- About Aquin -->
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:18px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:#3d6b76; font-weight:600; margin:0 0 8px;">About Aquin</p>
          <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:14.5px; color:var(--ink); line-height:1.55; margin:0 0 12px;">Aquin reads the lesson, knows the prerequisites, generates SVG diagrams in chat, and refuses to give the answer outright until you have tried.</p>
          <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:6px;">
            {['92 languages, voice or text','Inline SVG diagrams, math, code','Per-course memory; never leaks across courses','Hand-off to a human tutor if stuck'].map((l) => (
              <li style="display:flex; align-items:start; gap:8px; font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500); line-height:1.55;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#3d6b76" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg>
                <span>{l}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Recent sessions -->
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:18px;">
          <div style="display:flex; align-items:baseline; justify-content:space-between; margin-bottom:12px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0;">Recent sessions</p>
            <a href="#" style="font-family:'Inter Tight',sans-serif; font-size:11.5px; color:var(--rust); text-decoration:none; font-weight:500;">All &rarr;</a>
          </div>
          <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:10px;">
            {recent.map((r) => (
              <li style="display:flex; flex-direction:column; gap:3px; padding-bottom:10px; border-bottom:1px solid var(--rule);">
                <p style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink); margin:0; line-height:1.4;">{r.topic}</p>
                <p style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.08em; color:var(--ink-500); margin:0;">{r.course} &middot; {r.when}</p>
              </li>
            ))}
          </ul>
        </div>

        <!-- Settings -->
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:18px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 10px;">Settings</p>
          <dl style="display:grid; grid-template-columns:1fr auto; gap:8px 14px; margin:0; font-family:'Inter Tight',sans-serif; font-size:12.5px;">
            {settings.map((s) => (
              <>
                <dt style="color:var(--ink-500);">{s.l}</dt>
                <dd style="margin:0; color:var(--ink); font-weight:500;">{s.v}</dd>
              </>
            ))}
          </dl>
        </div>
      </aside>
    </div>
  </section>

  <!-- WHAT AQUIN CAN DO (taxonomy) -->
  <section style="background:var(--sand-100); border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:56px 28px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:#3d6b76; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">What Aquin does</p>
      <h2 class="font-display" style="font-size:clamp(1.65rem, 3vw, 2.4rem); font-weight:500; line-height:1.12; letter-spacing:-0.015em; margin:0 0 32px; color:var(--ink); max-width:38rem;">Six modes,<br/><span style="font-style:italic; font-weight:300; color:var(--ink-500);">depending on what you need.</span></h2>
      <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="modes-grid">
        {[
          { t: 'Derive', d: 'Step-by-step derivations with every algebraic move shown and labelled.' },
          { t: 'Visualise', d: 'On-the-fly SVG diagrams - Bloch spheres, attention maps, free-body diagrams.' },
          { t: 'Quiz', d: 'Adaptive multiple choice that branches on your wrong answers to find the gap.' },
          { t: 'Translate', d: 'Switch any answer into Hindi, Sanskrit, Mandarin, or any of 92 languages.' },
          { t: 'Critique', d: 'Reads your draft essay or code; flags weakness, asks counterquestions.' },
          { t: 'Hand off', d: 'When Aquin reaches a limit, queues you to a named human faculty member.' },
        ].map((m) => (
          <article style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:20px;">
            <h3 class="font-display" style="font-size:1.1rem; font-weight:500; margin:0 0 8px; line-height:1.2; letter-spacing:-0.015em; color:var(--ink);">{m.t}</h3>
            <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink-500); line-height:1.55; margin:0;">{m.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <style>
    @media (min-width: 900px) { .aq-grid { grid-template-columns: minmax(0, 1fr) 320px !important; } .modes-grid { grid-template-columns: repeat(3, 1fr) !important; } }
    @media (min-width: 1200px) { .modes-grid { grid-template-columns: repeat(6, 1fr) !important; } }
  </style>

  <script is:inline>
    (function() {
      var composer = document.getElementById('aq-composer');
      document.querySelectorAll('.aq-prompt').forEach(function(b) {
        b.addEventListener('click', function() {
          if (composer) { composer.value = b.getAttribute('data-prompt'); composer.focus(); }
        });
      });
    })();
  </script>
</AquintutorLayout>
