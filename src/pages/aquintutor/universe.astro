---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

// ATLAS Scene 2 - Discipline Universe.
// A browsable taxonomy of every discipline AquinTutor indexes. The page renders
// a static dense grid of clusters; the marketing target is 2,847 indexed
// disciplines across 38 categories. The grid is intentionally over-broad
// (covering vedic sciences, vocational trades, paramedicine etc.) to convey
// the institution's scope, not just the schools currently offering courses.

const UNIVERSE = [
  // STEM
  { id: 'physics',     name: 'Physical Sciences',     color: '#7fb3ff', chips: ['Physics','Chemistry','Astronomy','Geology','Meteorology'] },
  { id: 'life',        name: 'Life Sciences',         color: '#9ad0c0', chips: ['Biology','Genetics','Microbiology','Marine Biology','Biochemistry'] },
  { id: 'math',        name: 'Math & Computing',      color: '#a7c4ff', chips: ['Mathematics','Statistics','Computer Science','Data Science','Cryptography'] },
  { id: 'ai',          name: 'AI & Robotics',         color: '#7fb3ff', hero: true, chips: ['Machine Learning','Deep Learning','NLP','Computer Vision','Robotics','Reinforcement Learning'] },
  { id: 'quantum',     name: 'Quantum & Emerging',    color: '#a78bfa', hero: true, chips: ['Quantum Computing','Nanotech','Blockchain','IoT','AR / VR','Green Tech'] },
  { id: 'engineering', name: 'Engineering',           color: '#86b6ff', chips: ['Mechanical','Civil','Electrical','Aerospace','Chemical','Biomedical','Petroleum'] },
  // MEDICINE
  { id: 'medicine',    name: 'Medicine & Healthcare', color: '#e07a8a', chips: ['MBBS','Surgery','Cardiology','Pediatrics','Radiology','Dentistry','Pharmacy','Public Health','Physiotherapy'] },
  { id: 'paramed',     name: 'Paramedicine',          color: '#e2776b', chips: ['EMS','Firefighting','Rescue Ops','Trauma Response'] },
  // BUSINESS / LAW
  { id: 'business',    name: 'Business & Management', color: '#7dd3a8', hero: true, chips: ['BBA','Finance','Marketing','Accounting','Entrepreneurship','Supply Chain','HR','Hospitality Mgmt'] },
  { id: 'econ',        name: 'Economics & Policy',    color: '#8edca8', chips: ['Microeconomics','Macroeconomics','Behavioral','Public Policy','Development'] },
  { id: 'law',         name: 'Law & Legal Studies',   color: '#c0d97f', chips: ['Constitutional','Criminal','Corporate','IP','International','Environmental'] },
  // HUMANITIES / ARTS
  { id: 'liberal',     name: 'Liberal Arts',          color: '#e8b4d0', hero: true, chips: ['Philosophy','History','Political Science','Sociology','Psychology','Anthropology','Linguistics'] },
  { id: 'lang',        name: 'Languages & Literature',color: '#d9b3e8', chips: ['English Lit','Sanskrit','Mandarin','Arabic','French','Hindi','Japanese'] },
  { id: 'media',       name: 'Media & Journalism',    color: '#e8c4b4', chips: ['Mass Comm','Content','Podcasting','Game Design','Social Media','Digital Marketing'] },
  { id: 'design',      name: 'Design & Architecture', color: '#d97757', hero: true, chips: ['Architecture','Interior','Fashion','Graphic','Animation','Film','Photography','Fine Arts'] },
  { id: 'music',       name: 'Music & Performing',    color: '#e0a0c8', chips: ['Classical','Composition','Theatre','Dance','Cinematography'] },
  // EDUCATION / AGRI
  { id: 'education',   name: 'Education & Training',  color: '#b3cf8e', chips: ['B.Ed','Early Childhood','Special Education','Curriculum','Edu. Psychology'] },
  { id: 'agri',        name: 'Agriculture',           color: '#9ec47a', chips: ['Horticulture','Soil Science','Animal Husbandry','Fisheries','Food Tech','Plant Pathology'] },
  // VOCATIONAL
  { id: 'trades',      name: 'Skilled Trades',        color: '#f0b54f', chips: ['Carpentry','Plumbing','Welding','HVAC','Masonry','Electrical Work'] },
  { id: 'industrial',  name: 'Industrial Training',   color: '#e8a23a', chips: ['CNC Operation','Manufacturing','Maintenance','Electronics Assembly'] },
  { id: 'hospitality', name: 'Hospitality & Service', color: '#e0b370', chips: ['Chef','Hotel Mgmt','Tourism','Food & Bev','Housekeeping'] },
  { id: 'transport',   name: 'Transport & Logistics', color: '#e8c068', chips: ['Pilot Training','Air Traffic','Maritime','Railway Ops','Logistics'] },
  { id: 'sports',      name: 'Sports & Physical Ed',  color: '#d4c068', chips: ['Sports Sci','Coaching','Fitness','Sports Mgmt'] },
  // VEDIC SCIENCES
  { id: 'vedic',       name: 'Vedic Studies',         color: '#d97757', chips: ['Rigveda','Yajurveda','Samaveda','Atharvaveda','Upanishads','Vedanta','Nyaya','Mimamsa'] },
  { id: 'yoga',        name: 'Yoga & Wellness',       color: '#c97a8e', chips: ['Hatha','Raja','Kundalini','Tantra','Pranayama','Dhyana','Yoga Therapy'] },
  { id: 'ayurveda',    name: 'Ayurveda',              color: '#cb866b', chips: ['BAMS','Panchakarma','Rasa Shastra','Kaya Chikitsa','Shalya Tantra','Dravya Guna','Rasayana'] },
  { id: 'jyotisha',    name: 'Jyotisha & Vedic Astronomy', color: '#c8a0e0', chips: ['Siddhanta','Hora','Muhurta','Nakshatra','Panchang','Jataka'] },
  { id: 'vastu',       name: 'Vastu & Shilpa',        color: '#d9a060', chips: ['Vastu Shastra','Temple Arch.','Mandala Design','Sacred Geometry','Stone Carving'] },
  { id: 'vmath',       name: 'Vedic Math & Sanskrit', color: '#c9b48a', chips: ['Sulbasutras','Vedic Sutras','Panini','Vedic Sanskrit','Nirukta','Chandas'] },
  { id: 'sound',       name: 'Vedic Sound & Music',   color: '#c98ba8', chips: ['Sama Veda Chant','Mantra','Raga','Nada Yoga','Sound Healing'] },
  { id: 'kalari',      name: 'Martial & Marma',       color: '#b88860', chips: ['Kalaripayattu','Varma Kalari','Marma Therapy','Mudra Science'] },
];

const heroes = UNIVERSE.filter(c => c.hero);
const stem = UNIVERSE.filter(c => ['physics','life','math','engineering'].includes(c.id));
const health = UNIVERSE.filter(c => ['medicine','paramed'].includes(c.id));
const biz = UNIVERSE.filter(c => ['econ','law'].includes(c.id));
const hum = UNIVERSE.filter(c => ['lang','media','music'].includes(c.id));
const eduagri = UNIVERSE.filter(c => ['education','agri'].includes(c.id));
const vocational = UNIVERSE.filter(c => ['trades','industrial','hospitality','transport','sports'].includes(c.id));
const vedic = UNIVERSE.filter(c => ['vedic','yoga','ayurveda','jyotisha','vastu','vmath','sound','kalari'].includes(c.id));

const TOTAL_CHIPS = UNIVERSE.reduce((sum, c) => sum + c.chips.length, 0);
const CATEGORY_COUNT = UNIVERSE.length;
const INDEXED_TARGET = 2847;

const BANDS = [
  { label: 'Hero schools', rows: heroes, eyebrow: 'I' },
  { label: 'STEM', rows: stem, eyebrow: 'II' },
  { label: 'Medicine & care', rows: health, eyebrow: 'III' },
  { label: 'Economics & law', rows: biz, eyebrow: 'IV' },
  { label: 'Humanities & arts', rows: hum, eyebrow: 'V' },
  { label: 'Education & agriculture', rows: eduagri, eyebrow: 'VI' },
  { label: 'Vocational & trades', rows: vocational, eyebrow: 'VII' },
  { label: 'Vedic sciences', rows: vedic, eyebrow: 'VIII' },
];
---
<AquintutorLayout title="Discipline Universe" description="Every discipline AquinTutor indexes - from Quantum Computing to Sanskrit, Carpentry to Cardiology, Vedic Vastu to Robotics.">

  <!-- HUD strip -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:32px 24px 28px; display:grid; grid-template-columns:1fr; gap:24px; align-items:end;" class="hero-grid">
      <div>
        <div style="display:flex; align-items:center; gap:14px; margin-bottom:18px;" class="numplate">
          <span style="height:1px; width:48px; background:var(--ink);"></span>
          <span style="color:var(--ink-500);">DISCIPLINE UNIVERSE &middot; LIVE INDEX</span>
        </div>
        <h1 class="font-display" style="font-size:clamp(2.5rem,7vw,7rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0;">
          Every discipline,<br/>
          <span style="font-style:italic; font-weight:300; color:var(--ink-500);">on one register.</span>
        </h1>
        <p class="font-serif" style="font-size:clamp(1.125rem,1.6vw,1.5rem); line-height:1.3; color:var(--ink-500); margin-top:18px; max-width:48rem;">
          From Quantum Computing to Sanskrit, Carpentry to Cardiology, Vedic Vastu to Robotics. AquinTutor indexes the entire curriculum a self-directed learner could need across {CATEGORY_COUNT} categories, with new sub-disciplines added every term.
        </p>
      </div>
      <div style="display:grid; grid-template-columns:repeat(3, 1fr); gap:14px;">
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px;">
          <p class="numplate" style="color:var(--ink-500); margin:0 0 6px;">INDEXED &middot; TARGET</p>
          <p class="font-display" style="font-size:1.875rem; font-weight:500; margin:0; line-height:1;">{INDEXED_TARGET.toLocaleString()}+</p>
        </div>
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px;">
          <p class="numplate" style="color:var(--ink-500); margin:0 0 6px;">CATEGORIES</p>
          <p class="font-display" style="font-size:1.875rem; font-weight:500; margin:0; line-height:1;">{CATEGORY_COUNT}</p>
        </div>
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px;">
          <p class="numplate" style="color:var(--ink-500); margin:0 0 6px;">VISIBLE NOW</p>
          <p class="font-display" style="font-size:1.875rem; font-weight:500; margin:0; line-height:1;">{TOTAL_CHIPS}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BANDS -->
  {BANDS.map((band, bi) => (
    <section style={'border-bottom:1px solid var(--rule); background:' + (bi % 2 === 1 ? 'var(--sand-100)' : 'var(--paper)') + ';'}>
      <div style="max-width:1400px; margin:0 auto; padding:56px 24px;">
        <div style="display:grid; grid-template-columns:1fr; gap:32px; margin-bottom:36px;" class="thesis-grid">
          <div>
            <p class="eyebrow">&sect; {band.eyebrow} &mdash; {band.label}</p>
            <p class="numplate" style="color:var(--ink-300); margin-top:8px;">{String(band.rows.length).padStart(2, '0')} CATEGORIES</p>
          </div>
          <div>
            <h2 class="font-display" style="font-size:clamp(2rem,5vw,4rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0;">
              {band.label}
            </h2>
          </div>
        </div>
        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:14px;">
          {band.rows.map((c: any) => (
            <article style={'background:var(--paper); border:1px solid var(--rule); border-left:4px solid ' + c.color + '; border-radius:8px; padding:18px 20px;'}>
              <div style="display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:12px;">
                <h3 class="font-display" style="font-size:1.25rem; font-weight:500; margin:0; line-height:1.2; letter-spacing:-0.02em;">{c.name}</h3>
                <span class="numplate" style={'color:' + c.color + '; flex-shrink:0;'}>{String(c.chips.length).padStart(2, '0')}</span>
              </div>
              <div style="display:flex; flex-wrap:wrap; gap:6px;">
                {c.chips.map((chip: string) => (
                  <span style={'display:inline-block; padding:4px 10px; border-radius:999px; background:' + c.color + '14; border:1px solid ' + c.color + '38; color:var(--ink); font-family:"JetBrains Mono",monospace; font-size:10px; letter-spacing:0.08em; text-transform:uppercase;'}>{chip}</span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="invert">
    <div style="max-width:1400px; margin:0 auto; padding:80px 24px; display:grid; grid-template-columns:1fr; gap:32px;" class="thesis-grid">
      <div>
        <p class="eyebrow" style="color:rgba(251,250,244,0.5);">&sect; IX &mdash; Begin</p>
        <p class="numplate" style="color:rgba(251,250,244,0.4); margin-top:8px;">OPEN ENROLMENT</p>
      </div>
      <div>
        <h2 class="font-display" style="font-size:clamp(2.5rem,6vw,5rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--sand-50);">
          Pick a discipline.<br/>
          <span style="font-style:italic; font-weight:300; color:var(--gold);">Start a course tonight.</span>
        </h2>
        <p class="font-serif" style="font-size:1.5rem; color:rgba(251,250,244,0.8); margin-top:24px; max-width:42rem; line-height:1.3;">
          The full catalogue across the six current schools is open today. Newer disciplines join each term as faculty are appointed and curricula reviewed.
        </p>
        <div style="margin-top:36px; display:flex; gap:14px; flex-wrap:wrap;">
          <a href="/aquintutor/courses" class="btn-pill filled" style="background:var(--sand-50); color:var(--ink); border-color:var(--sand-50);">Browse the catalogue &rarr;</a>
          <a href="/aquintutor/signup" class="btn-pill outline" style="color:var(--sand-50); border-color:var(--sand-50);">Apply for admission &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    @media (min-width: 768px) {
      .hero-grid { grid-template-columns: 7fr 5fr !important; }
      .thesis-grid { grid-template-columns: 3fr 9fr !important; }
    }
  </style>
</AquintutorLayout>
