---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

// A browsable taxonomy of every discipline AquinTutor indexes. The grid is
// intentionally over-broad (covering Vedic sciences, vocational trades,
// paramedicine etc.) to convey the institution's scope, not just the schools
// currently offering courses.

const UNIVERSE = [
  { id: 'physics', name: 'Physical Sciences', color: '#7fb3ff', chips: ['Physics','Chemistry','Astronomy','Geology','Meteorology'] },
  { id: 'life', name: 'Life Sciences', color: '#9ad0c0', chips: ['Biology','Genetics','Microbiology','Marine Biology','Biochemistry'] },
  { id: 'math', name: 'Math & Computing', color: '#a7c4ff', chips: ['Mathematics','Statistics','Computer Science','Data Science','Cryptography'] },
  { id: 'ai', name: 'AI & Robotics', color: '#2b577e', hero: true, chips: ['Machine Learning','Deep Learning','NLP','Computer Vision','Robotics','Reinforcement Learning'] },
  { id: 'quantum', name: 'Quantum & Emerging', color: '#5b4a92', hero: true, chips: ['Quantum Computing','Nanotech','Blockchain','IoT','AR / VR','Green Tech'] },
  { id: 'engineering', name: 'Engineering', color: '#86b6ff', chips: ['Mechanical','Civil','Electrical','Aerospace','Chemical','Biomedical','Petroleum'] },
  { id: 'medicine', name: 'Medicine & Healthcare', color: '#a04330', chips: ['MBBS','Surgery','Cardiology','Pediatrics','Radiology','Dentistry','Pharmacy','Public Health','Physiotherapy'] },
  { id: 'paramed', name: 'Paramedicine', color: '#e2776b', chips: ['EMS','Firefighting','Rescue Ops','Trauma Response'] },
  { id: 'business', name: 'Business & Management', color: '#4a7048', hero: true, chips: ['BBA','Finance','Marketing','Accounting','Entrepreneurship','Supply Chain','HR','Hospitality Mgmt'] },
  { id: 'econ', name: 'Economics & Policy', color: '#8edca8', chips: ['Microeconomics','Macroeconomics','Behavioural','Public Policy','Development'] },
  { id: 'law', name: 'Law & Legal Studies', color: '#3b5675', chips: ['Constitutional','Criminal','Corporate','IP','International','Environmental'] },
  { id: 'liberal', name: 'Liberal Arts', color: '#8a486b', hero: true, chips: ['Philosophy','History','Political Science','Sociology','Psychology','Anthropology','Linguistics'] },
  { id: 'lang', name: 'Languages & Literature', color: '#d9b3e8', chips: ['English Lit','Sanskrit','Mandarin','Arabic','French','Hindi','Japanese'] },
  { id: 'media', name: 'Media & Journalism', color: '#e8c4b4', chips: ['Mass Comm','Content','Podcasting','Game Design','Social Media','Digital Marketing'] },
  { id: 'design', name: 'Design & Architecture', color: '#a04330', hero: true, chips: ['Architecture','Interior','Fashion','Graphic','Animation','Film','Photography','Fine Arts'] },
  { id: 'music', name: 'Music & Performing', color: '#e0a0c8', chips: ['Classical','Composition','Theatre','Dance','Cinematography'] },
  { id: 'education', name: 'Education & Training', color: '#b3cf8e', chips: ['B.Ed','Early Childhood','Special Education','Curriculum','Edu. Psychology'] },
  { id: 'agri', name: 'Agriculture', color: '#9ec47a', chips: ['Horticulture','Soil Science','Animal Husbandry','Fisheries','Food Tech','Plant Pathology'] },
  { id: 'trades', name: 'Skilled Trades', color: '#f0b54f', chips: ['Carpentry','Plumbing','Welding','HVAC','Masonry','Electrical Work'] },
  { id: 'industrial', name: 'Industrial Training', color: '#e8a23a', chips: ['CNC Operation','Manufacturing','Maintenance','Electronics Assembly'] },
  { id: 'hospitality', name: 'Hospitality & Service', color: '#e0b370', chips: ['Chef','Hotel Mgmt','Tourism','Food & Bev','Housekeeping'] },
  { id: 'transport', name: 'Transport & Logistics', color: '#e8c068', chips: ['Pilot Training','Air Traffic','Maritime','Railway Ops','Logistics'] },
  { id: 'sports', name: 'Sports & Physical Ed', color: '#d4c068', chips: ['Sports Sci','Coaching','Fitness','Sports Mgmt'] },
  { id: 'vedic', name: 'Vedic Studies', color: '#a8472c', chips: ['Rigveda','Yajurveda','Samaveda','Atharvaveda','Upanishads','Vedanta','Nyaya','Mimamsa'] },
  { id: 'yoga', name: 'Yoga & Wellness', color: '#c97a8e', chips: ['Hatha','Raja','Kundalini','Tantra','Pranayama','Dhyana','Yoga Therapy'] },
  { id: 'ayurveda', name: 'Ayurveda', color: '#cb866b', chips: ['BAMS','Panchakarma','Rasa Shastra','Kaya Chikitsa','Shalya Tantra','Dravya Guna','Rasayana'] },
  { id: 'jyotisha', name: 'Jyotisha & Vedic Astronomy', color: '#c8a0e0', chips: ['Siddhanta','Hora','Muhurta','Nakshatra','Panchang','Jataka'] },
  { id: 'vastu', name: 'Vastu & Shilpa', color: '#d9a060', chips: ['Vastu Shastra','Temple Arch.','Mandala Design','Sacred Geometry','Stone Carving'] },
  { id: 'vmath', name: 'Vedic Math & Sanskrit', color: '#c9b48a', chips: ['Sulbasutras','Vedic Sutras','Panini','Vedic Sanskrit','Nirukta','Chandas'] },
  { id: 'sound', name: 'Vedic Sound & Music', color: '#c98ba8', chips: ['Sama Veda Chant','Mantra','Raga','Nada Yoga','Sound Healing'] },
  { id: 'kalari', name: 'Martial & Marma', color: '#b88860', chips: ['Kalaripayattu','Varma Kalari','Marma Therapy','Mudra Science'] },
];

const heroes = UNIVERSE.filter(c => c.hero);
const stem = UNIVERSE.filter(c => ['physics','life','math','engineering'].includes(c.id));
const health = UNIVERSE.filter(c => ['medicine','paramed'].includes(c.id));
const biz = UNIVERSE.filter(c => ['econ','law'].includes(c.id));
const hum = UNIVERSE.filter(c => ['lang','media','music'].includes(c.id));
const eduagri = UNIVERSE.filter(c => ['education','agri'].includes(c.id));
const vocational = UNIVERSE.filter(c => ['trades','industrial','hospitality','transport','sports'].includes(c.id));
const vedic = UNIVERSE.filter(c => ['vedic','yoga','ayurveda','jyotisha','vastu','vmath','sound','kalari'].includes(c.id));

const TOTAL_CHIPS = UNIVERSE.reduce((sum, c) => sum + c.chips.length, 0);
const CATEGORY_COUNT = UNIVERSE.length;
const INDEXED_TARGET = 2847;

const BANDS = [
  { label: 'Frontier disciplines', rows: heroes, num: '01' },
  { label: 'STEM', rows: stem, num: '02' },
  { label: 'Medicine & care', rows: health, num: '03' },
  { label: 'Economics & law', rows: biz, num: '04' },
  { label: 'Humanities & arts', rows: hum, num: '05' },
  { label: 'Education & agriculture', rows: eduagri, num: '06' },
  { label: 'Vocational & trades', rows: vocational, num: '07' },
  { label: 'Vedic sciences', rows: vedic, num: '08' },
];
---
<AquintutorLayout title="Discipline Universe" description="Every discipline AquinTutor indexes - from Quantum Computing to Sanskrit, Carpentry to Cardiology, Vedic Vastu to Robotics.">

  <!-- BREADCRUMB -->
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1400px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a>
      <span style="margin:0 8px;">/</span>
      <span style="color:var(--rust); font-weight:600;">DISCIPLINE UNIVERSE</span>
    </div>
  </div>

  <!-- HERO -->
  <section style="border-bottom:1px solid var(--rule); position:relative; overflow:hidden;">
    <div aria-hidden="true" style="position:absolute; right:-60px; top:80px; opacity:0.05; pointer-events:none;" class="hide-mobile">
      <svg width="380" height="380" viewBox="0 0 100 100" fill="none">
        {Array.from({length:6}).map((_, i) => <circle cx="50" cy="50" r={10 + i * 7} stroke="var(--ink)" stroke-width="0.3" fill="none"/>)}
        {Array.from({length:8}).map((_, i) => {
          const a = (i / 8) * Math.PI * 2;
          return <line x1="50" y1="50" x2={50 + Math.cos(a) * 47} y2={50 + Math.sin(a) * 47} stroke="var(--ink)" stroke-width="0.2"/>;
        })}
      </svg>
    </div>
    <div style="max-width:1400px; margin:0 auto; padding:64px 28px 40px; display:grid; grid-template-columns:1fr; gap:32px; align-items:end; position:relative; z-index:1;" class="uni-hero">
      <div>
        <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); font-weight:600; letter-spacing:0.04em; margin:0 0 16px;">Discipline universe &middot; live index</p>
        <h1 class="font-display" style="font-size:clamp(2.5rem, 6vw, 4.75rem); line-height:0.98; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--ink); max-width:46rem;">
          Every discipline,<br/>
          <span style="font-style:italic; font-weight:300; color:var(--ink-500);">on one register.</span>
        </h1>
        <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.15rem, 1.5vw, 1.4rem); line-height:1.5; color:var(--ink-500); margin:24px 0 0; max-width:42rem;">
          From Quantum Computing to Sanskrit, Carpentry to Cardiology, Vedic Vastu to Robotics. AquinTutor indexes the entire curriculum a self-directed learner could need across {CATEGORY_COUNT} categories, with new sub-disciplines added every term.
        </p>
      </div>
      <div style="display:grid; grid-template-columns:repeat(3, 1fr); gap:12px;">
        <div style="background:var(--sand-100); border:1px solid var(--rule); border-radius:10px; padding:14px 18px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">Indexed target</p>
          <p class="font-display" style="font-size:1.45rem; font-weight:500; margin:0; line-height:1; color:var(--ink); letter-spacing:-0.02em;">{INDEXED_TARGET.toLocaleString()}+</p>
        </div>
        <div style="background:var(--sand-100); border:1px solid var(--rule); border-radius:10px; padding:14px 18px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">Categories</p>
          <p class="font-display" style="font-size:1.45rem; font-weight:500; margin:0; line-height:1; color:var(--ink); letter-spacing:-0.02em;">{CATEGORY_COUNT}</p>
        </div>
        <div style="background:var(--sand-100); border:1px solid var(--rule); border-radius:10px; padding:14px 18px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">Visible now</p>
          <p class="font-display" style="font-size:1.45rem; font-weight:500; margin:0; line-height:1; color:var(--rust); letter-spacing:-0.02em;">{TOTAL_CHIPS}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BANDS -->
  {BANDS.map((band, bi) => (
    <section style={'border-bottom:1px solid var(--rule); background:' + (bi % 2 === 1 ? 'var(--sand-100)' : 'var(--paper)') + ';'}>
      <div style="max-width:1400px; margin:0 auto; padding:56px 28px;">
        <div style="display:flex; align-items:end; justify-content:space-between; flex-wrap:wrap; gap:14px; margin-bottom:28px;">
          <div>
            <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--rust); font-weight:700; letter-spacing:0.22em; text-transform:uppercase; margin:0 0 8px;">{band.num} &middot; {band.label}</p>
            <h2 class="font-display" style="font-size:clamp(1.65rem, 3vw, 2.4rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500; margin:0; color:var(--ink);">{band.label}.</h2>
          </div>
          <p style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--ink-500); letter-spacing:0.1em;">{String(band.rows.length).padStart(2, '0')} CATEGORIES</p>
        </div>
        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:14px;">
          {band.rows.map((c: any) => (
            <article style={'background:var(--paper); border:1px solid var(--rule); border-left:4px solid ' + c.color + '; border-radius:10px; padding:18px 20px;'}>
              <div style="display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:12px;">
                <h3 class="font-display" style="font-size:1.15rem; font-weight:500; margin:0; line-height:1.2; letter-spacing:-0.015em; color:var(--ink);">{c.name}</h3>
                <span style={'font-family:JetBrains Mono,monospace; font-size:11px; letter-spacing:0.08em; color:' + c.color + '; font-weight:700; flex-shrink:0;'}>{String(c.chips.length).padStart(2, '0')}</span>
              </div>
              <div style="display:flex; flex-wrap:wrap; gap:5px;">
                {c.chips.map((chip: string) => (
                  <span style={'display:inline-block; padding:4px 10px; border-radius:999px; background:' + c.color + '14; border:1px solid ' + c.color + '38; color:var(--ink); font-family:JetBrains Mono,monospace; font-size:9.5px; letter-spacing:0.08em; text-transform:uppercase;'}>{chip}</span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section style="background:#0b0d10; color:#f4f1ea; position:relative; overflow:hidden;">
    <div aria-hidden="true" style="position:absolute; inset:0; background:repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(168,71,44,0.018) 3px, rgba(168,71,44,0.018) 4px); pointer-events:none;"></div>
    <div style="max-width:1200px; margin:0 auto; padding:72px 28px; position:relative; z-index:1;">
      <p style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.22em; text-transform:uppercase; color:#d97757; font-weight:700; margin:0 0 16px;">Open admission &middot; rolling intake</p>
      <h2 class="font-display" style="font-size:clamp(1.85rem, 3.8vw, 3rem); line-height:1.04; letter-spacing:-0.02em; font-weight:500; margin:0 0 18px; color:#f4f1ea; max-width:38rem;">
        Pick a discipline.<br/>
        <span style="font-style:italic; font-weight:300; color:rgba(244,241,234,0.65);">Start a course tonight.</span>
      </h2>
      <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.05rem, 1.4vw, 1.25rem); line-height:1.55; color:#c8c3b8; margin:0 0 28px; max-width:36rem;">
        The full catalogue across the six current schools is open today. Newer disciplines join each term as faculty are appointed and curricula reviewed.
      </p>
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <a href="/aquintutor/courses" style="background:#d97757; color:#1a0f08; padding:13px 24px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Browse the catalogue &rarr;</a>
        <a href="/aquintutor/signup" style="background:transparent; color:#f4f1ea; padding:13px 24px; border-radius:6px; border:1px solid rgba(244,241,234,0.4); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Apply for admission &rarr;</a>
      </div>
    </div>
  </section>

  <style>
    @media (min-width: 900px) { .uni-hero { grid-template-columns: 7fr 5fr !important; } }
  </style>
</AquintutorLayout>
