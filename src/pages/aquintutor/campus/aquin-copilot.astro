---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

const stats = [
  { val: '200ms', lbl: 'Median latency' },
  { val: '5', lbl: 'Modalities' },
  { val: '12', lbl: 'Indic languages' },
  { val: 'On-device', lbl: 'When possible' },
];

const capabilities = [
  {
    title: 'Live diagrams',
    body: 'Vector diagrams generated mid-sentence. Block diagrams, circuits, flow charts, organic chemistry skeletons, free-body diagrams — all rendered as SVG that can be paused, labelled, and re-played.',
    icon: '<path d="M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z"/><path d="M10 6.5h4M6.5 10v4M14 17.5h-4"/>',
  },
  {
    title: 'On-demand 3D',
    body: 'Atoms, molecules, lattice structures, proteins, planetary orbits, mechanical assemblies. Orbit with mouse, slice with key, isolate sub-structures. Pure WebGL fallback to canvas where unsupported.',
    icon: '<path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>',
  },
  {
    title: 'Math typesetting',
    body: 'Spoken equations parsed and typeset in 80ms. Greek letters, summations, integrals, bra-ket notation, tensors with super/subscripts, matrix layouts. Hand-rolled glyph layout — no MathJax dependency.',
    icon: '<path d="M5 8h14M5 16h14M9 4l-2 16M17 4l-2 16"/>',
  },
  {
    title: 'Code that runs',
    body: 'Aquin writes Python, JS, C, SQL, Verilog, QASM. Code blocks have a Run pill that executes in a sandboxed worker. Output (numeric, plot, animation) appears inline. Compatible with the campus IDE.',
    icon: '<path d="M16 18l6-6-6-6M8 6l-6 6 6 6M14.5 4l-5 16"/>',
  },
  {
    title: 'Multimodal Q&A',
    body: 'Students point a phone at a textbook page, a circuit, a botanical leaf, a Sanskrit shloka. Aquin reads, interprets, and answers in the student\'s chosen Indic language with audio + text + supporting diagram.',
    icon: '<circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3M12 17h.01"/>',
  },
  {
    title: 'Personal replay',
    body: 'Every Aquin artefact (diagram, code run, animation) is timestamped against the lecture audio. Students scrub back to "the moment Aquin drew the Bloch sphere" and step the visual frame-by-frame.',
    icon: '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>',
  },
];

const pipeline = [
  { stage: '01', name: 'Professor speaks', latency: '0ms', detail: 'Lecture mic captures audio at 48kHz. Audio stays on the lecturer\'s device — never uploaded as bytes.' },
  { stage: '02', name: 'Speech-to-text', latency: '60ms', detail: 'On-device streaming ASR. Indic-tuned acoustic model with subword decoder. Partial hypotheses emitted every 20ms.' },
  { stage: '03', name: 'Intent classification', latency: '40ms', detail: 'A small router decides: diagram | math | code | 3D | reference | Q&A. Confidence threshold 0.78, else "draft suggestion" mode.' },
  { stage: '04', name: 'Renderer', latency: '100ms', detail: 'Vector / 3D / animation / code-eval / typeset pipeline. Output appears in the side panel for the professor to preview, approve, drop into the lecture.' },
];

const liveLectures = [
  { course: 'Quantum Computing · Sem 5', topic: 'Drawing a 3-qubit GHZ state circuit', minutes: 2, region: 'Tier-1 university · South India' },
  { course: 'Org. Chem. II · Sem 4', topic: 'Mechanism of SN2 inversion at chiral centre', minutes: 1, region: 'National science institute · West India' },
  { course: 'Linear Algebra · Sem 2', topic: 'Animating column-space projection in R^3', minutes: 4, region: 'Tier-1 engineering institute · East India' },
  { course: 'Vedic Acoustics Lab', topic: 'Spectrogram of the Gayatri metre', minutes: 0, region: 'AquinTutor research campus' },
  { course: 'Deep Learning · MSc', topic: 'Rendering masked self-attention matrix', minutes: 3, region: 'Tier-1 university · West Europe' },
  { course: 'Classical Mechanics · Sem 3', topic: 'Free-body diagram for inclined-pulley system', minutes: 5, region: 'National engineering institute · North India' },
];

const facultyControls = [
  { title: 'Preview', body: 'Every Aquin output lands in a side panel first. The professor sees the artefact before the class does. Nothing auto-projects without faculty consent.' },
  { title: 'Approve', body: 'A single keypress (space / pedal) pushes the artefact to the main screen and into the student replay log.' },
  { title: 'Edit', body: 'Aquin output is editable in-place. SVGs are real elements, code is real text, math is re-typesettable. Faculty corrections become Aquin training signal.' },
  { title: 'Save to replay', body: 'Approved artefacts are stamped to the lecture timeline so any student can rewind weeks later and watch that exact diagram appear in context.' },
];

const privacyPoints = [
  { title: 'On-device transcription', body: 'Audio never leaves the lecturer\'s device. ASR runs locally on the campus rig (Apple Silicon / consumer GPU sufficient).' },
  { title: 'No media bytes uploaded', body: 'Only the transcript fragment and the renderer-output artefact (text, SVG, code) leave the device. Raw audio + raw video stay local.' },
  { title: 'Student opt-out', body: 'Students may flag a clip as private; the corresponding transcript fragment is purged from replay within 30 minutes.' },
  { title: 'Faculty owns artefacts', body: 'Diagrams Aquin draws under a faculty member\'s direction belong to that faculty member. License terms shown in the publish dialog.' },
];
---

<AquintutorLayout title="Aquin AI Co-pilot · AquinTutor" description="Real-time teaching co-pilot for the AquinTutor campus.">
  <style>
    .eyebrow { font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
    .ti { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 7vw, 84px); font-weight: 600; letter-spacing: -0.035em; line-height: 1.02; color: #0E0B08; margin: 18px 0 22px; }
    .ti em { font-style: italic; font-weight: 500; color: #FF4F00; }
    .sub { font-size: 17px; color: #2E2520; max-width: 720px; line-height: 1.7; }
    .hero { padding: 70px 5vw 50px; max-width: 1280px; margin: 0 auto; }
    .section { padding: 65px 5vw; border-bottom: 1px solid rgba(14,11,8,0.10); max-width: 1280px; margin: 0 auto; }
    .h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(30px, 4vw, 48px); font-weight: 600; letter-spacing: -0.025em; color: #0E0B08; margin-bottom: 14px; }
    .h2 em { font-style: italic; color: #FF4F00; font-weight: 500; }
    .section-sub { font-size: 16px; color: #2E2520; line-height: 1.7; max-width: 720px; margin-bottom: 36px; }

    .stat-strip { display: grid; grid-template-columns: repeat(4, 1fr); border-top: 1px solid rgba(14,11,8,0.18); border-bottom: 1px solid rgba(14,11,8,0.18); padding: 22px 0; margin-top: 38px; }
    .stat-cell { padding: 0 18px; border-left: 1px solid rgba(14,11,8,0.10); }
    .stat-cell:first-child { border-left: none; }
    .stat-val { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 600; color: #0E0B08; line-height: 1.1; }
    .stat-lbl { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #7A6F68; margin-top: 6px; }

    .grid-6 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
    .card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 22px; }
    .cap-icon { width: 42px; height: 42px; border-radius: 10px; background: #FFF1E8; color: #FF4F00; display: flex; align-items: center; justify-content: center; margin-bottom: 14px; }
    .cap-title { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; color: #0E0B08; margin-bottom: 8px; }
    .cap-body { font-size: 14px; color: #2E2520; line-height: 1.65; }

    .demo-wrap { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 18px; overflow: hidden; display: grid; grid-template-columns: 320px 1fr; min-height: 560px; }
    .demo-side { background: #F5F1EC; border-right: 1px solid rgba(14,11,8,0.10); padding: 22px; display: flex; flex-direction: column; }
    .demo-side h3 { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; margin-bottom: 4px; }
    .demo-side p { font-size: 13px; color: #6E6258; margin-bottom: 18px; line-height: 1.55; }
    .prompt-btn { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 10px; padding: 12px 14px; text-align: left; font-family: inherit; font-size: 13px; color: #0E0B08; cursor: pointer; margin-bottom: 8px; transition: all 0.12s; line-height: 1.4; }
    .prompt-btn:hover { border-color: #FF4F00; background: #FFF1E8; }
    .prompt-btn.active { background: #0E0B08; color: #fff; border-color: #0E0B08; }
    .prompt-label { font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.08em; text-transform: uppercase; color: #7A6F68; margin-bottom: 6px; }
    .prompt-input { display: flex; gap: 8px; margin-top: auto; padding-top: 14px; border-top: 1px solid rgba(14,11,8,0.10); }
    .prompt-input input { flex: 1; padding: 10px 12px; border: 1px solid rgba(14,11,8,0.20); border-radius: 8px; font-family: inherit; font-size: 13px; background: #fff; color: #0E0B08; }
    .prompt-input button { padding: 10px 14px; background: #FF4F00; color: #fff; border: none; border-radius: 8px; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; cursor: pointer; }

    .demo-stage { padding: 28px; background: #FAF8F5; position: relative; display: flex; flex-direction: column; }
    .stage-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 18px; }
    .stage-title { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 600; }
    .stage-meta { font-family: 'Geist Mono', monospace; font-size: 11px; color: #7A6F68; letter-spacing: 0.06em; }
    .stage-body { flex: 1; display: flex; align-items: center; justify-content: center; }

    .bloch-wrap { display: grid; grid-template-columns: 360px 1fr; gap: 24px; width: 100%; }
    .bloch-svg { display: block; }
    .bloch-controls { display: flex; flex-direction: column; gap: 18px; align-self: center; }
    .ctrl-row label { display: flex; justify-content: space-between; font-family: 'Geist Mono', monospace; font-size: 11px; color: #7A6F68; letter-spacing: 0.06em; margin-bottom: 6px; }
    .ctrl-row label b { color: #0E0B08; font-weight: 600; }
    .ctrl-row input[type=range] { width: 100%; }
    .bloch-state { font-family: 'Geist Mono', monospace; font-size: 13px; color: #0E0B08; background: #fff; padding: 14px; border-radius: 10px; border: 1px solid rgba(14,11,8,0.10); line-height: 1.7; }

    .attn-wrap { display: grid; grid-template-columns: 1fr 280px; gap: 24px; width: 100%; align-items: start; }
    .attn-grid { display: grid; grid-template-columns: 44px repeat(8, 1fr); grid-template-rows: 30px repeat(8, 1fr); gap: 2px; aspect-ratio: 1; max-width: 440px; }
    .attn-cell { border-radius: 3px; display: flex; align-items: center; justify-content: center; font-family: 'Geist Mono', monospace; font-size: 9px; color: rgba(14,11,8,0.55); cursor: pointer; transition: transform 0.08s; }
    .attn-cell:hover { transform: scale(1.08); z-index: 2; outline: 1px solid #0E0B08; }
    .attn-label { font-family: 'Geist Mono', monospace; font-size: 10px; color: #7A6F68; display: flex; align-items: center; justify-content: center; }
    .attn-info { background: #fff; padding: 16px; border-radius: 10px; border: 1px solid rgba(14,11,8,0.10); font-size: 13px; line-height: 1.6; color: #2E2520; }
    .attn-info b { font-family: 'Cormorant Garamond', serif; font-size: 18px; color: #0E0B08; display: block; margin-bottom: 8px; }

    .mandel-wrap { display: flex; gap: 24px; width: 100%; align-items: center; }

    .animate-wrap { display: flex; gap: 24px; width: 100%; align-items: center; }
    .animate-canvas-box { position: relative; flex-shrink: 0; }
    .animate-canvas-box canvas { width: 400px; height: 300px; border-radius: 10px; border: 1px solid rgba(14,11,8,0.10); display: block; background: #000; }
    .animate-thinking { position: absolute; inset: 0; background: rgba(250,248,245,0.94); border-radius: 10px; display: none; flex-direction: column; align-items: center; justify-content: center; gap: 8px; }
    .animate-thinking.on { display: flex; }
    .animate-dot { width: 8px; height: 8px; border-radius: 50%; background: #FF4F00; animation: aqpulse 1s infinite; }
    @keyframes aqpulse { 0%,100% { opacity: 0.3; } 50% { opacity: 1; } }
    .animate-controls { flex: 1; }
    .animate-info { font-family: 'Geist Mono', monospace; font-size: 12.5px; color: #0E0B08; background: #fff; padding: 14px; border-radius: 10px; border: 1px solid rgba(14,11,8,0.10); line-height: 1.75; margin-bottom: 12px; }
    .animate-info .miss { color: #C2410C; }
    .animate-suggest { font-size: 12px; color: #7A6F68; line-height: 1.7; }
    .animate-suggest button { background: #FFF1E8; border: 1px solid #FFD9C2; color: #C2410C; font-size: 11.5px; padding: 4px 10px; border-radius: 100px; cursor: pointer; margin: 3px 4px 0 0; font-family: inherit; }
    .animate-suggest button:hover { background: #FF4F00; color: #fff; border-color: #FF4F00; }
    .mandel-canvas { width: 400px; height: 400px; border-radius: 10px; border: 1px solid rgba(14,11,8,0.10); cursor: crosshair; display: block; }
    .mandel-controls { flex: 1; display: flex; flex-direction: column; gap: 14px; }
    .mandel-info { background: #fff; padding: 16px; border-radius: 10px; border: 1px solid rgba(14,11,8,0.10); font-family: 'Geist Mono', monospace; font-size: 12px; color: #2E2520; line-height: 1.7; }

    .pipeline-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; background: #fff; overflow: hidden; }
    .pipe-col { padding: 22px; border-right: 1px solid rgba(14,11,8,0.10); position: relative; }
    .pipe-col:last-child { border-right: none; }
    .pipe-stage { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.1em; color: #FF4F00; font-weight: 800; }
    .pipe-name { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; margin: 8px 0 4px; }
    .pipe-latency { font-family: 'Geist Mono', monospace; font-size: 12px; color: #7A6F68; margin-bottom: 12px; }
    .pipe-detail { font-size: 13.5px; color: #2E2520; line-height: 1.6; }

    .live-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .live-row { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 12px; padding: 18px 20px; display: flex; justify-content: space-between; align-items: center; gap: 18px; }
    .live-pulse { width: 8px; height: 8px; border-radius: 50%; background: #16A34A; box-shadow: 0 0 0 0 rgba(22,163,74,0.5); animation: pulse 1.6s infinite; flex-shrink: 0; }
    @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(22,163,74,0.55); } 70% { box-shadow: 0 0 0 10px rgba(22,163,74,0); } 100% { box-shadow: 0 0 0 0 rgba(22,163,74,0); } }
    .live-text { flex: 1; min-width: 0; }
    .live-course { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.1em; color: #7A6F68; text-transform: uppercase; }
    .live-topic { font-family: 'Cormorant Garamond', serif; font-size: 19px; font-weight: 600; color: #0E0B08; margin: 4px 0; }
    .live-region { font-size: 12px; color: #6E6258; }
    .live-time { font-family: 'Geist Mono', monospace; font-size: 11px; color: #FF4F00; flex-shrink: 0; }

    .ctrl-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; }
    .ctrl-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 22px; }
    .ctrl-card h4 { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; margin-bottom: 8px; }
    .ctrl-card p { font-size: 14px; color: #2E2520; line-height: 1.65; }

    .priv-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; }
    .priv-card { background: #0E0B08; color: #F5F1EC; border-radius: 14px; padding: 22px; }
    .priv-card h4 { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; color: #fff; margin-bottom: 8px; }
    .priv-card p { font-size: 14px; color: #C7BFB8; line-height: 1.65; }

    .btn-row { display: flex; gap: 12px; margin-top: 30px; flex-wrap: wrap; }
    .btn-primary { background: #FF4F00; color: #fff; padding: 14px 28px; border-radius: 10px; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; text-decoration: none; border: none; cursor: pointer; }
    .btn-ghost { background: transparent; color: #0E0B08; padding: 14px 28px; border-radius: 10px; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; text-decoration: none; border: 1px solid rgba(14,11,8,0.20); }

    @media (max-width: 900px) {
      .grid-6, .pipeline-grid, .live-grid, .ctrl-grid, .priv-grid { grid-template-columns: 1fr; }
      .stat-strip { grid-template-columns: repeat(2, 1fr); }
      .demo-wrap { grid-template-columns: 1fr; }
      .demo-side { border-right: none; border-bottom: 1px solid rgba(14,11,8,0.10); }
      .bloch-wrap, .attn-wrap, .mandel-wrap { grid-template-columns: 1fr; flex-direction: column; }
      .pipe-col { border-right: none; border-bottom: 1px solid rgba(14,11,8,0.10); }
    }
  </style>

  <main>
    <section class="hero">
      <div class="eyebrow">Campus · District · Aquin Co-pilot</div>
      <h1 class="ti">When the professor says <em>'let me show you'</em>.</h1>
      <p class="sub">Aquin is the real-time teaching co-pilot embedded into every AquinTutor lecture hall. It listens to the professor, infers intent, and generates diagrams, animations, code, and 3D models in the side panel within 200ms. The professor previews, approves, projects. Students get a perfect replay — the artefact stamped to the exact second it was conjured.</p>

      <div class="stat-strip">
        {stats.map(s => (
          <div class="stat-cell">
            <div class="stat-val">{s.val}</div>
            <div class="stat-lbl">{s.lbl}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="section">
      <h2 class="h2">What Aquin <em>does</em>.</h2>
      <p class="section-sub">Six capabilities that turn a passive whiteboard into a generative surface. None of them require the professor to leave the flow of the lecture — Aquin runs alongside, the way a skilled TA would.</p>

      <div class="grid-6">
        {capabilities.map(c => (
          <div class="card">
            <div class="cap-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" set:html={c.icon}></svg>
            </div>
            <div class="cap-title">{c.title}</div>
            <div class="cap-body">{c.body}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="section">
      <h2 class="h2">Live <em>demo</em>.</h2>
      <p class="section-sub">Click any prompt on the left. The stage on the right renders the artefact in your browser — no server roundtrip, no library. Same renderer the professors use in lecture.</p>

      <div class="demo-wrap">
        <aside class="demo-side">
          <h3>Aquin prompts</h3>
          <p>Pick a prompt to see Aquin's renderer fire. Each one exercises a different generative path.</p>

          <div class="prompt-label">Mathematics</div>
          <button class="prompt-btn active" data-demo="bloch">Draw a Bloch sphere with controls for theta and phi</button>

          <div class="prompt-label" style="margin-top:14px;">Machine learning</div>
          <button class="prompt-btn" data-demo="attn">Show me masked self-attention on an 8-token sequence</button>

          <div class="prompt-label" style="margin-top:14px;">Dynamics</div>
          <button class="prompt-btn" data-demo="mandel">Render the Mandelbrot set, let me zoom</button>

          <div class="prompt-label" style="margin-top:14px;">Type a topic — this one is real</div>
          <button class="prompt-btn" data-demo="animate" data-topic="wave interference">Show me wave interference</button>
          <button class="prompt-btn" data-topic="lorenz attractor chaos" data-demo="animate">Animate the Lorenz attractor</button>
          <button class="prompt-btn" data-topic="double pendulum" data-demo="animate">What does a double pendulum look like</button>

          <div class="prompt-input">
            <input type="text" id="aquinAsk" placeholder="e.g. sunflower spiral, quantum wave packet, fractal tree..." />
            <button type="button" id="aquinAskBtn">send</button>
          </div>
        </aside>

        <div class="demo-stage">
          <div class="stage-head">
            <div class="stage-title" id="stage-title">Bloch sphere</div>
            <div class="stage-meta" id="stage-meta">Renderer: SVG vector · Latency: 84ms</div>
          </div>
          <div class="stage-body">

            <div class="bloch-wrap" data-stage="bloch">
              <svg class="bloch-svg" width="340" height="340" viewBox="-180 -180 360 360" id="bloch-svg">
                <defs>
                  <radialGradient id="sphereGrad" cx="0.3" cy="0.3">
                    <stop offset="0%" stop-color="#FFF1E8"/>
                    <stop offset="100%" stop-color="#F5F1EC"/>
                  </radialGradient>
                </defs>
                <circle cx="0" cy="0" r="140" fill="url(#sphereGrad)" stroke="#0E0B08" stroke-width="1.5" opacity="0.95"/>
                <ellipse cx="0" cy="0" rx="140" ry="40" fill="none" stroke="#0E0B08" stroke-width="1" opacity="0.45"/>
                <ellipse cx="0" cy="0" rx="40" ry="140" fill="none" stroke="#0E0B08" stroke-width="1" opacity="0.25" stroke-dasharray="3,3"/>
                <line x1="-160" y1="0" x2="160" y2="0" stroke="#7A6F68" stroke-width="0.8"/>
                <line x1="0" y1="-160" x2="0" y2="160" stroke="#7A6F68" stroke-width="0.8"/>
                <line x1="80" y1="80" x2="-80" y2="-80" stroke="#7A6F68" stroke-width="0.8" stroke-dasharray="2,3"/>
                <text x="160" y="-6" font-family="Geist Mono, monospace" font-size="11" fill="#0E0B08">x</text>
                <text x="-78" y="-78" font-family="Geist Mono, monospace" font-size="11" fill="#0E0B08">y</text>
                <text x="6" y="-160" font-family="Geist Mono, monospace" font-size="11" fill="#0E0B08">|0⟩</text>
                <text x="6" y="172" font-family="Geist Mono, monospace" font-size="11" fill="#0E0B08">|1⟩</text>
                <line id="bloch-vec" x1="0" y1="0" x2="0" y2="-140" stroke="#FF4F00" stroke-width="3" stroke-linecap="round"/>
                <circle id="bloch-tip" cx="0" cy="-140" r="6" fill="#FF4F00"/>
                <path id="bloch-arc" d="" fill="none" stroke="#FF4F00" stroke-width="1.5" stroke-dasharray="2,2" opacity="0.7"/>
              </svg>
              <div class="bloch-controls">
                <div class="ctrl-row">
                  <label>theta (polar) <b id="theta-val">0.00 rad</b></label>
                  <input type="range" id="theta-r" min="0" max="314" value="0" />
                </div>
                <div class="ctrl-row">
                  <label>phi (azimuth) <b id="phi-val">0.00 rad</b></label>
                  <input type="range" id="phi-r" min="0" max="628" value="0" />
                </div>
                <div class="bloch-state" id="bloch-state">
                  |psi&gt; = 1.000 |0&gt; + 0.000 |1&gt;<br/>
                  ⟨X⟩ = 0.000  ⟨Y⟩ = 0.000  ⟨Z⟩ = 1.000
                </div>
              </div>
            </div>

            <div class="attn-wrap" data-stage="attn" style="display:none;">
              <div>
                <div class="attn-grid" id="attn-grid"></div>
                <div style="font-family:'Geist Mono',monospace;font-size:10.5px;color:#7A6F68;margin-top:14px;text-align:center;letter-spacing:0.08em;">QUERY (rows) attends to KEY (cols)</div>
              </div>
              <div class="attn-info" id="attn-info">
                <b>Masked attention</b>
                Each query position can only attend to itself and to earlier positions in the sequence (the upper-right triangle is masked to negative infinity, then softmax sends those weights to zero). Hover any cell to see (q,k) and the weight.
                <div style="margin-top:14px;font-family:'Geist Mono',monospace;font-size:11px;color:#0E0B08;" id="attn-hover">hover a cell</div>
              </div>
            </div>

            <div class="mandel-wrap" data-stage="mandel" style="display:none;">
              <canvas class="mandel-canvas" id="mandel" width="400" height="400"></canvas>
              <div class="mandel-controls">
                <div class="mandel-info" id="mandel-info">
                  centre: (-0.5000, 0.0000)<br/>
                  zoom: 1.00x<br/>
                  iterations: 80<br/>
                  rendered in: -- ms
                </div>
                <button class="btn-primary" id="mandel-reset" style="padding:11px 20px;font-size:11px;">Reset view</button>
                <button class="btn-ghost" id="mandel-iter" style="padding:11px 20px;font-size:11px;">Iterations: 80</button>
                <div style="font-family:'Geist Mono',monospace;font-size:11px;color:#7A6F68;line-height:1.7;">
                  click canvas: zoom 2.5x at point<br/>
                  right-click: zoom out
                </div>
              </div>
            </div>

            <div class="animate-wrap" data-stage="animate" style="display:none;">
              <div class="animate-canvas-box">
                <canvas id="aquinCanvas" width="400" height="300"></canvas>
                <div class="animate-thinking" id="aquinThinking"><div class="animate-dot"></div><span style="font-family:'Geist Mono',monospace;font-size:10.5px;color:#7A6F68;">Aquin is composing…</span></div>
              </div>
              <div class="animate-controls">
                <div class="animate-info" id="aquinInfo">Type a topic on the left, or click one. Aquin matches it to a renderer and animates it live — in your browser, no server.</div>
                <div class="animate-suggest" id="aquinSuggest"></div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <h2 class="h2">The <em>pipeline</em>.</h2>
      <p class="section-sub">From lecturer's lips to projected artefact in roughly 200 milliseconds. Each stage runs on the lecturer's local rig where possible, with a stateless fallback if the on-device renderer can't handle the artefact.</p>

      <div class="pipeline-grid">
        {pipeline.map(p => (
          <div class="pipe-col">
            <div class="pipe-stage">{p.stage}</div>
            <div class="pipe-name">{p.name}</div>
            <div class="pipe-latency">budget: {p.latency}</div>
            <div class="pipe-detail">{p.detail}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="section">
      <h2 class="h2">Faculty <em>controls</em>.</h2>
      <p class="section-sub">Aquin never bypasses the professor. Every artefact lands in a preview pane; the faculty member decides what reaches the class. Edits flow back as training signal so Aquin improves with the faculty member's style.</p>

      <div class="ctrl-grid">
        {facultyControls.map(c => (
          <div class="ctrl-card">
            <h4>{c.title}</h4>
            <p>{c.body}</p>
          </div>
        ))}
      </div>

      <div class="btn-row">
        <a class="btn-primary" href="/aquintutor/campus">Back to campus districts</a>
        <a class="btn-ghost" href="/aquintutor/labs">Try the labs</a>
      </div>
    </section>

    <section class="section">
      <h2 class="h2"><em>Privacy</em> by default.</h2>
      <p class="section-sub">No audio, no video, no raw classroom media leaves the room. Aquin earns its keep by being a guest in the lecture hall — not a surveillance device.</p>

      <div class="priv-grid">
        {privacyPoints.map(p => (
          <div class="priv-card">
            <h4>{p.title}</h4>
            <p>{p.body}</p>
          </div>
        ))}
      </div>
    </section>
  </main>

  <script is:inline src="/aquintutor-animator-engine.js"></script>
  <script is:inline>
    (function() {
      // ---------- demo switcher ----------
      const stages = {
        bloch: { title: 'Bloch sphere', meta: 'Renderer: SVG vector · Latency: 84ms' },
        attn:  { title: 'Masked self-attention', meta: 'Renderer: SVG heatmap · Latency: 71ms' },
        mandel:{ title: 'Mandelbrot set', meta: 'Renderer: Canvas2D escape-time · Latency: ~110ms' },
        animate:{ title: 'Live animation', meta: 'Renderer: AquinAnimator · topic → scene' }
      };
      const titleEl = document.getElementById('stage-title');
      const metaEl  = document.getElementById('stage-meta');
      const stageNodes = document.querySelectorAll('[data-stage]');
      const btns = document.querySelectorAll('.prompt-btn[data-demo]');
      btns.forEach(b => {
        b.addEventListener('click', () => {
          btns.forEach(x => x.classList.remove('active'));
          b.classList.add('active');
          const k = b.getAttribute('data-demo');
          titleEl.textContent = stages[k].title;
          metaEl.textContent = stages[k].meta;
          stageNodes.forEach(n => {
            n.style.display = (n.getAttribute('data-stage') === k) ? '' : 'none';
          });
          if (k === 'mandel') renderMandel();
          if (k === 'animate') { var topic = b.getAttribute('data-topic'); if (topic) aquinGenerate(topic); }
        });
      });

      // ---------- Live topic -> animation (the real one) ----------
      var aquinCtrl = null;
      function aquinGenerate(topic) {
        var canvas = document.getElementById('aquinCanvas');
        var info = document.getElementById('aquinInfo');
        var thinking = document.getElementById('aquinThinking');
        var suggest = document.getElementById('aquinSuggest');
        if (!canvas || !window.AquinAnimator) return;
        var t0 = performance.now();
        thinking.classList.add('on');
        // brief "composing" beat so the intent step is legible in a live demo
        setTimeout(function () {
          var scene = AquinAnimator.findScene(topic);
          thinking.classList.remove('on');
          if (aquinCtrl) { aquinCtrl.destroy(); aquinCtrl = null; }
          if (!scene) {
            var ctx = canvas.getContext('2d'); ctx.fillStyle = '#08080a'; ctx.fillRect(0, 0, canvas.width, canvas.height);
            info.innerHTML = '<span class="miss">No renderer matched "' + escapeH(topic) + '" yet.</span><br>Aquin covers ' + AquinAnimator.SCENES.length + ' generative topics in this build. Try one:';
            suggest.innerHTML = AquinAnimator.SCENES.slice(0, 8).map(function (s) {
              return '<button data-s="' + s.keywords[0] + '">' + s.label + '</button>';
            }).join('');
            suggest.querySelectorAll('button').forEach(function (bb) { bb.addEventListener('click', function () { aquinGenerate(bb.getAttribute('data-s')); }); });
            return;
          }
          aquinCtrl = AquinAnimator.attach(canvas, scene, { palette: 'cool', speed: 1 });
          var ms = Math.round(performance.now() - t0);
          metaEl.textContent = 'Renderer: AquinAnimator · matched "' + scene.label + '" in ' + ms + 'ms';
          info.innerHTML = '<b style="font-family:Cormorant Garamond,serif;font-size:17px;color:#0E0B08;">' + scene.label + '</b> &middot; ' + scene.cat
            + '<br><span style="color:#7A6F68;">Intent matched from your words &rarr; live procedural render. Same engine the labs use.</span>';
          suggest.innerHTML = 'Related: ' + AquinAnimator.SCENES.filter(function (s) { return s.cat === scene.cat && s.id !== scene.id; }).slice(0, 4).map(function (s) {
            return '<button data-s="' + s.keywords[0] + '">' + s.label + '</button>';
          }).join('');
          suggest.querySelectorAll('button').forEach(function (bb) { bb.addEventListener('click', function () { aquinGenerate(bb.getAttribute('data-s')); }); });
        }, 450);
      }
      function escapeH(s) { return (s || '').replace(/[&<>]/g, function (c) { return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' })[c]; }); }
      var askInput = document.getElementById('aquinAsk');
      var askBtn = document.getElementById('aquinAskBtn');
      function doAsk() { var v = (askInput.value || '').trim(); if (!v) return; document.querySelectorAll('.prompt-btn[data-demo]').forEach(function (x) { x.classList.remove('active'); }); titleEl.textContent = 'Live animation'; metaEl.textContent = 'Renderer: AquinAnimator'; stageNodes.forEach(function (n) { n.style.display = (n.getAttribute('data-stage') === 'animate') ? '' : 'none'; }); aquinGenerate(v); }
      if (askBtn) askBtn.addEventListener('click', doAsk);
      if (askInput) askInput.addEventListener('keydown', function (e) { if (e.key === 'Enter') doAsk(); });

      // ---------- Bloch sphere ----------
      const thetaR = document.getElementById('theta-r');
      const phiR   = document.getElementById('phi-r');
      const tVal   = document.getElementById('theta-val');
      const pVal   = document.getElementById('phi-val');
      const vec    = document.getElementById('bloch-vec');
      const tip    = document.getElementById('bloch-tip');
      const arc    = document.getElementById('bloch-arc');
      const stateBox = document.getElementById('bloch-state');
      const R = 140;
      function updateBloch() {
        const theta = parseInt(thetaR.value, 10) / 100;
        const phi   = parseInt(phiR.value, 10) / 100;
        tVal.textContent = theta.toFixed(2) + ' rad';
        pVal.textContent = phi.toFixed(2) + ' rad';
        // bloch sphere coords: x=sin(t)cos(p), y=sin(t)sin(p), z=cos(t)
        const x3 = Math.sin(theta) * Math.cos(phi);
        const y3 = Math.sin(theta) * Math.sin(phi);
        const z3 = Math.cos(theta);
        // project to 2D with simple oblique: screen-x = x - 0.4*y, screen-y = -(z - 0.4*y)
        const sx = R * (x3 - 0.4 * y3);
        const sy = R * (-(z3 - 0.4 * y3));
        vec.setAttribute('x2', sx.toFixed(2));
        vec.setAttribute('y2', sy.toFixed(2));
        tip.setAttribute('cx', sx.toFixed(2));
        tip.setAttribute('cy', sy.toFixed(2));
        // arc from |0⟩ pole to tip (small visual arc projecting through equator)
        const arcEndX = sx;
        const arcEndY = sy;
        arc.setAttribute('d', `M 0 -${R} Q ${(sx*0.5).toFixed(1)} ${((sy-R)*0.5).toFixed(1)} ${arcEndX.toFixed(1)} ${arcEndY.toFixed(1)}`);
        // amplitudes
        const a = Math.cos(theta/2);
        const bMag = Math.sin(theta/2);
        const expX = Math.sin(theta) * Math.cos(phi);
        const expY = Math.sin(theta) * Math.sin(phi);
        const expZ = Math.cos(theta);
        stateBox.innerHTML = '|psi&gt; = ' + a.toFixed(3) + ' |0&gt; + ' + bMag.toFixed(3) + '·e^(i·' + phi.toFixed(2) + ') |1&gt;<br/>'
          + '&#10216;X&#10217; = ' + expX.toFixed(3) + '  &#10216;Y&#10217; = ' + expY.toFixed(3) + '  &#10216;Z&#10217; = ' + expZ.toFixed(3);
      }
      thetaR.addEventListener('input', updateBloch);
      phiR.addEventListener('input', updateBloch);
      updateBloch();

      // ---------- attention heatmap ----------
      const grid = document.getElementById('attn-grid');
      const N = 8;
      const tokens = ['the', 'cat', 'sat', 'on', 'the', 'mat', 'all', 'day'];
      const weights = [];
      // deterministic pseudo-attention: prefer recent tokens, sprinkle structure
      for (let q = 0; q < N; q++) {
        const row = [];
        let total = 0;
        for (let k = 0; k < N; k++) {
          if (k > q) { row.push(0); continue; }
          // raw score: distance bias + a few learnt-style peaks
          const dist = q - k;
          let s = Math.exp(-dist * 0.35);
          // pretend "the" (idx 0, 4) attends to nouns "cat"(1), "mat"(5)
          if (q === 0 && k === 1) s *= 2.2;
          if (q === 4 && k === 5) s *= 2.4;
          if (q === 7 && k === 6) s *= 1.8;
          if (q === 2 && k === 1) s *= 1.6;
          row.push(s);
          total += s;
        }
        for (let k = 0; k < N; k++) row[k] = total > 0 ? row[k] / total : 0;
        weights.push(row);
      }
      // build grid: empty corner + col labels, then row label + cells
      const colHeader = document.createElement('div');
      colHeader.className = 'attn-label';
      grid.appendChild(colHeader);
      for (let k = 0; k < N; k++) {
        const c = document.createElement('div');
        c.className = 'attn-label';
        c.textContent = tokens[k];
        grid.appendChild(c);
      }
      for (let q = 0; q < N; q++) {
        const rowL = document.createElement('div');
        rowL.className = 'attn-label';
        rowL.textContent = tokens[q];
        grid.appendChild(rowL);
        for (let k = 0; k < N; k++) {
          const cell = document.createElement('div');
          cell.className = 'attn-cell';
          const w = weights[q][k];
          // colour: burn orange intensity for active, near-white grey for masked
          if (k > q) {
            cell.style.background = 'repeating-linear-gradient(45deg,#E8E2DC,#E8E2DC 3px,#F5F1EC 3px,#F5F1EC 6px)';
            cell.title = 'masked';
          } else {
            const t = Math.min(1, w * 1.4);
            // mix from cream (#FAF8F5) to burn (#FF4F00)
            const r = Math.round(250 + (255 - 250) * t);
            const g = Math.round(248 + (79 - 248) * t);
            const bl = Math.round(245 + (0 - 245) * t);
            cell.style.background = 'rgb(' + r + ',' + g + ',' + bl + ')';
            cell.textContent = w.toFixed(2);
            if (t > 0.55) cell.style.color = '#fff';
          }
          cell.dataset.q = String(q);
          cell.dataset.k = String(k);
          cell.dataset.w = w.toFixed(4);
          cell.addEventListener('mouseenter', () => {
            const hover = document.getElementById('attn-hover');
            if (k > q) {
              hover.textContent = '(' + tokens[q] + ' -> ' + tokens[k] + ') MASKED · w = 0.0000';
            } else {
              hover.textContent = '(' + tokens[q] + ' -> ' + tokens[k] + ') · w = ' + w.toFixed(4);
            }
          });
          grid.appendChild(cell);
        }
      }

      // ---------- Mandelbrot ----------
      const cvs = document.getElementById('mandel');
      const ctx = cvs.getContext('2d');
      const mInfo = document.getElementById('mandel-info');
      const mReset = document.getElementById('mandel-reset');
      const mIterBtn = document.getElementById('mandel-iter');
      let cx = -0.5, cy = 0.0, scale = 1.0, maxIter = 80;
      function renderMandel() {
        const W = cvs.width, H = cvs.height;
        const t0 = performance.now();
        const img = ctx.createImageData(W, H);
        const data = img.data;
        const span = 3.0 / scale; // viewport span at scale=1 is 3 units
        const xmin = cx - span / 2;
        const ymin = cy - span / 2;
        const dx = span / W;
        const dy = span / H;
        for (let py = 0; py < H; py++) {
          const y0 = ymin + py * dy;
          for (let px = 0; px < W; px++) {
            const x0 = xmin + px * dx;
            let x = 0, y = 0, iter = 0;
            while (x*x + y*y <= 4 && iter < maxIter) {
              const xt = x*x - y*y + x0;
              y = 2 * x * y + y0;
              x = xt;
              iter++;
            }
            const idx = (py * W + px) * 4;
            if (iter === maxIter) {
              // inside set: ink
              data[idx] = 14; data[idx+1] = 11; data[idx+2] = 8; data[idx+3] = 255;
            } else {
              // smooth colouring -> cream-to-burn gradient
              const log_zn = Math.log(x*x + y*y) / 2;
              const nu = Math.log(log_zn / Math.LN2) / Math.LN2;
              let smooth = iter + 1 - nu;
              if (!isFinite(smooth)) smooth = iter;
              const t = Math.min(1, smooth / maxIter);
              // palette: cream -> burn -> ink loop
              const phase = (t * 2) % 1;
              let r, g, b;
              if (t < 0.5) {
                r = Math.round(250 + (255 - 250) * phase);
                g = Math.round(248 + (79  - 248) * phase);
                b = Math.round(245 + (0   - 245) * phase);
              } else {
                r = Math.round(255 + (14  - 255) * phase);
                g = Math.round(79  + (11  - 79 ) * phase);
                b = Math.round(0   + (8   - 0  ) * phase);
              }
              data[idx]=r; data[idx+1]=g; data[idx+2]=b; data[idx+3]=255;
            }
          }
        }
        ctx.putImageData(img, 0, 0);
        const ms = (performance.now() - t0).toFixed(0);
        mInfo.innerHTML = 'centre: (' + cx.toFixed(4) + ', ' + cy.toFixed(4) + ')<br/>'
          + 'zoom: ' + scale.toFixed(2) + 'x<br/>'
          + 'iterations: ' + maxIter + '<br/>'
          + 'rendered in: ' + ms + ' ms';
      }
      cvs.addEventListener('click', (e) => {
        const rect = cvs.getBoundingClientRect();
        const px = (e.clientX - rect.left) / rect.width;
        const py = (e.clientY - rect.top) / rect.height;
        const span = 3.0 / scale;
        cx = (cx - span / 2) + px * span;
        cy = (cy - span / 2) + py * span;
        scale *= 2.5;
        renderMandel();
      });
      cvs.addEventListener('contextmenu', (e) => {
        e.preventDefault();
        scale = Math.max(0.25, scale / 2.5);
        renderMandel();
      });
      mReset.addEventListener('click', () => {
        cx = -0.5; cy = 0.0; scale = 1.0; maxIter = 80;
        mIterBtn.textContent = 'Iterations: ' + maxIter;
        renderMandel();
      });
      mIterBtn.addEventListener('click', () => {
        const opts = [40, 80, 160, 320, 640];
        const i = opts.indexOf(maxIter);
        maxIter = opts[(i + 1) % opts.length];
        mIterBtn.textContent = 'Iterations: ' + maxIter;
        renderMandel();
      });
      // first render queued for when user opens that demo, but draw initial state too
      renderMandel();
    })();
  </script>
</AquintutorLayout>
