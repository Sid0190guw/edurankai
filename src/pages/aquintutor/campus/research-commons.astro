---
import BaseLayout from '@/layouts/BaseLayout.astro';

const stats = [
  { val: '2,400', lbl: 'Active labs' },
  { val: '3,200', lbl: 'Graduate researchers' },
  { val: '142', lbl: 'Principal investigators' },
  { val: '4,200', lbl: 'Papers / year' },
  { val: '28', lbl: 'Active journals' },
  { val: '6', lbl: 'Open archives' },
];

const fields = ['All', 'AI', 'Quantum', 'Biology', 'Chemistry', 'Physics', 'Mathematics', 'CS', 'Humanities', 'Vedic Sciences', 'Climate'];

const labs = [
  { name: 'Vedic Computation Lab', field: 'Vedic Sciences', pi: 'Lead PI · Computational Sanskrit', open: 4, paper: 'Pāṇinian grammar as a typed lambda calculus', updated: '6 days ago' },
  { name: 'Quantum Foundations Group', field: 'Quantum', pi: 'Lead PI · Foundations', open: 3, paper: 'Contextuality bounds on non-Markovian processes', updated: '2 weeks ago' },
  { name: 'Ancient DNA Lab', field: 'Biology', pi: 'Lead PI · Archaeogenetics', open: 2, paper: 'Holocene migration corridors across the Deccan', updated: '11 days ago' },
  { name: 'Mechanistic Interpretability Group', field: 'AI', pi: 'Lead PI · Alignment', open: 6, paper: 'Sparse autoencoders for circuit discovery in 70B models', updated: '3 days ago' },
  { name: 'Topological Materials Lab', field: 'Physics', pi: 'Lead PI · Condensed Matter', open: 2, paper: 'Edge currents in twisted bilayer graphene at 1.1 deg', updated: '1 month ago' },
  { name: 'Synthetic Biology Foundry', field: 'Biology', pi: 'Lead PI · Synthetic Biology', open: 5, paper: 'Designed riboswitches for in-vivo logic circuits', updated: '4 days ago' },
  { name: 'Catalysis & Green Chemistry', field: 'Chemistry', pi: 'Lead PI · Catalysis', open: 3, paper: 'Single-atom Ru on N-doped carbon for ammonia synthesis', updated: '8 days ago' },
  { name: 'Analytic Number Theory Seminar', field: 'Mathematics', pi: 'Lead PI · Number Theory', open: 1, paper: 'Bounds on zero-density estimates near the critical line', updated: '17 days ago' },
  { name: 'Distributed Systems Group', field: 'CS', pi: 'Lead PI · Systems', open: 4, paper: 'Crash-tolerant consensus with sub-quadratic message complexity', updated: '5 days ago' },
  { name: 'Atmospheric Modelling Lab', field: 'Climate', pi: 'Lead PI · Climate Dynamics', open: 3, paper: 'Subseasonal monsoon prediction with mixture-of-experts', updated: '9 days ago' },
  { name: 'Bharatanatyam Cognition Lab', field: 'Humanities', pi: 'Lead PI · Performance Studies', open: 2, paper: 'Embodied memory in classical Indian dance corpora', updated: '13 days ago' },
  { name: 'Cold-Atom Quantum Simulator', field: 'Quantum', pi: 'Lead PI · AMO Physics', open: 3, paper: 'Hubbard-model phase diagram in optical lattices at 50nK', updated: '2 days ago' },
  { name: 'Vedic Mathematics Algorithms Lab', field: 'Vedic Sciences', pi: 'Lead PI · Algorithms', open: 2, paper: 'Vedic multiplication as Karatsuba precursor', updated: '21 days ago' },
  { name: 'Glacier Mass Balance Group', field: 'Climate', pi: 'Lead PI · Cryosphere', open: 1, paper: 'Karakoram anomaly in 40 years of remote-sensing data', updated: '1 month ago' },
  { name: 'Cryo-EM Structural Biology', field: 'Biology', pi: 'Lead PI · Structural Bio', open: 4, paper: 'Conformational ensemble of a viral RdRp at 2.1 A', updated: '6 days ago' },
  { name: 'Quantum Error Correction Group', field: 'Quantum', pi: 'Lead PI · QEC', open: 5, paper: 'Surface-code thresholds under correlated biased noise', updated: '4 days ago' },
  { name: 'Algebraic Geometry Group', field: 'Mathematics', pi: 'Lead PI · Algebraic Geometry', open: 1, paper: 'Moduli of stable curves with marked tangent vectors', updated: '3 weeks ago' },
  { name: 'Computational Linguistics & Indic NLP', field: 'CS', pi: 'Lead PI · NLP', open: 4, paper: 'Sandhi-aware tokenisation for 22 Indic languages', updated: '7 days ago' },
  { name: 'Soft Matter Physics Lab', field: 'Physics', pi: 'Lead PI · Soft Matter', open: 2, paper: 'Active nematics on curved substrates: defect dynamics', updated: '12 days ago' },
  { name: 'Electrochemical Energy Storage', field: 'Chemistry', pi: 'Lead PI · Electrochemistry', open: 3, paper: 'Sodium-ion cathodes with O3 layered oxides', updated: '10 days ago' },
  { name: 'AI Safety Evaluations Group', field: 'AI', pi: 'Lead PI · Evals', open: 4, paper: 'Adversarial sandbagging detection via gradient signatures', updated: '1 day ago' },
  { name: 'Ayurveda Pharmacognosy Lab', field: 'Vedic Sciences', pi: 'Lead PI · Pharmacognosy', open: 3, paper: 'Active phytochemicals in Withania somnifera at varietal scale', updated: '14 days ago' },
  { name: 'Robotics Manipulation Lab', field: 'CS', pi: 'Lead PI · Robotics', open: 5, paper: 'Diffusion policies for contact-rich assembly', updated: '5 days ago' },
  { name: 'Philosophy of Mind Reading Group', field: 'Humanities', pi: 'Lead PI · Philosophy', open: 2, paper: 'Higher-order theories of consciousness: a critical survey', updated: '19 days ago' },
  { name: 'High-Energy Astrophysics Group', field: 'Physics', pi: 'Lead PI · Astrophysics', open: 2, paper: 'Multi-messenger constraints on neutron star equations of state', updated: '9 days ago' },
  { name: 'Programming Languages Lab', field: 'CS', pi: 'Lead PI · PL Theory', open: 2, paper: 'Refinement types for dependent linear sessions', updated: '15 days ago' },
];

const journals = [
  { name: 'Indic Sciences Review', cadence: 'Quarterly', editorial: 'Open peer review · 90-day decision SLA', scope: 'Vedic mathematics, computational Sanskrit, traditional medicine, archaeoastronomy' },
  { name: 'AI Safety Quarterly', cadence: 'Quarterly', editorial: 'Triple-blind · 60-day decision SLA', scope: 'Alignment, interpretability, evaluations, governance, red-teaming' },
  { name: 'Frontier Quantum', cadence: 'Bi-monthly', editorial: 'Single-blind · 75-day decision SLA', scope: 'Foundations, error correction, hardware, algorithms, simulation' },
  { name: 'Journal of Reproducible Biology', cadence: 'Monthly', editorial: 'Open data mandate · 45-day decision SLA', scope: 'Wet-lab biology with code + data + reagent registration before submission' },
  { name: 'Climate Systems Letters', cadence: 'Bi-weekly', editorial: 'Rapid-track · 21-day decision SLA', scope: 'Earth-system modelling, attribution, climate services, adaptation' },
  { name: 'Mathematical Foundations', cadence: 'Quarterly', editorial: 'Open peer review · 120-day decision SLA', scope: 'Pure mathematics, logic, foundations, history of mathematics' },
];

const archives = [
  { name: 'Preprint Archive', count: '48,200', scope: 'All fields' },
  { name: 'Code Vault', count: '11,400', scope: 'Reproducible computational artefacts' },
  { name: 'Data Commons', count: '6,800', scope: 'Datasets with persistent DOIs' },
  { name: 'Thesis Repository', count: '14,300', scope: 'Graduate dissertations · open access' },
  { name: 'Pre-registration Registry', count: '3,100', scope: 'Study designs locked before data collection' },
  { name: 'Replication Reports', count: '910', scope: 'Independent verification studies' },
];

const grants = [
  { call: 'Frontier Compute Allocation', amount: 'Up to 50,000 H100-hours', deadline: '2026-07-15', area: 'AI · Quantum simulation' },
  { call: 'Indic Heritage Sciences Grant', amount: 'INR 25,00,000 per project', deadline: '2026-06-30', area: 'Vedic sciences · Manuscripts' },
  { call: 'Early-Career Investigator Award', amount: 'INR 80,00,000 over 3 years', deadline: '2026-08-01', area: 'Any field · Within 6 years of PhD' },
  { call: 'Climate Resilience Challenge', amount: 'INR 1,20,00,000 consortium grant', deadline: '2026-09-10', area: 'Climate · Earth systems' },
  { call: 'Open-Source Tools for Science', amount: 'INR 18,00,000 + 12-month residency', deadline: '2026-07-01', area: 'Scientific software' },
  { call: 'High-Risk High-Reward Pilot', amount: 'INR 12,00,000 seed', deadline: '2026-06-20', area: 'Any field · 12-month exploratory' },
  { call: 'Reproducibility Replication Grant', amount: 'INR 8,00,000 per study', deadline: 'Rolling', area: 'Any field · Verify a published result' },
  { call: 'Field Work & Expedition Fund', amount: 'INR 6,00,000 per expedition', deadline: '2026-07-25', area: 'Biology · Climate · Archaeology' },
];

const seminars = [
  { day: 'Mon', time: '16:00', title: 'Mechanistic interpretability of attention heads', speaker: 'Visiting Fellow · Tier-1 university (North America)', attendees: 84 },
  { day: 'Tue', time: '11:00', title: 'Hubbard model phase diagram from cold-atom data', speaker: 'Lead PI · AMO Physics', attendees: 52 },
  { day: 'Tue', time: '17:30', title: 'Bharatanatyam as embodied epistemology', speaker: 'Lead PI · Performance Studies', attendees: 38 },
  { day: 'Wed', time: '14:00', title: 'Sandhi-aware tokenisation across Indic languages', speaker: 'Lead PI · NLP', attendees: 71 },
  { day: 'Wed', time: '16:30', title: 'Surface-code thresholds with biased noise', speaker: 'Visiting Fellow · Tier-1 university (Europe)', attendees: 64 },
  { day: 'Thu', time: '11:30', title: 'Subseasonal monsoon prediction', speaker: 'Lead PI · Climate Dynamics', attendees: 47 },
  { day: 'Thu', time: '15:00', title: 'Pāṇinian grammar formalisation', speaker: 'Lead PI · Computational Sanskrit', attendees: 56 },
  { day: 'Fri', time: '14:00', title: 'Diffusion policies for contact-rich assembly', speaker: 'Lead PI · Robotics', attendees: 62 },
  { day: 'Fri', time: '17:00', title: 'Open peer review: a year of data', speaker: 'Editorial board · Indic Sciences Review', attendees: 41 },
];

const ethics = [
  { name: 'Institutional Review Board (IRB)', remit: 'Human subjects research, behavioural studies, surveys, interviews. Convened review for greater-than-minimal risk, expedited review for low-risk protocols.', cadence: 'Convenes weekly · 7-day expedited turnaround', members: 12 },
  { name: 'Institutional Animal Care & Use Committee (IACUC)', remit: 'Vertebrate animal research protocols, housing standards, surgical procedures, welfare audits. Mandatory training prerequisite for all PIs.', cadence: 'Convenes bi-weekly · 14-day protocol review', members: 9 },
  { name: 'Data Ethics Committee', remit: 'AI training data provenance, dataset bias audits, sensitive-attribute handling, model release decisions, dual-use risk assessment, deployment guardrails.', cadence: 'Convenes weekly · 10-day model-card review', members: 11 },
  { name: 'Indigenous Knowledge Committee', remit: 'Research involving traditional knowledge systems, community consent, benefit-sharing agreements, repatriation, sacred sites, language documentation ethics.', cadence: 'Convenes monthly · community-led review panel', members: 14 },
];
---

<BaseLayout title="Research Commons - AquinTutor Campus" description="The Research Commons district: 2,400 labs, 3,200 graduate researchers, 28 active journals, 8 active grants, 4 ethics committees.">
<style>
  body { background: #FAF8F5; color: #0E0B08; font-family: 'Inter', system-ui, sans-serif; }
  .hero { padding: 70px 5vw 60px; max-width: 1280px; margin: 0 auto; }
  .crumb { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.14em; color: #7A6F68; text-transform: uppercase; margin-bottom: 18px; display: flex; gap: 8px; align-items: center; }
  .crumb a { color: #7A6F68; text-decoration: none; }
  .crumb a:hover { color: #FF4F00; }
  .eyebrow { font-family: 'Geist Mono', monospace; font-size: 11.5px; letter-spacing: 0.18em; color: #FF4F00; font-weight: 700; text-transform: uppercase; margin-bottom: 22px; }
  .title { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 7vw, 84px); font-weight: 600; letter-spacing: -0.035em; line-height: 1.02; color: #0E0B08; margin: 0 0 24px; }
  .title em { font-style: italic; color: #FF4F00; font-weight: 500; }
  .sub { font-size: 17px; color: #2E2520; max-width: 720px; line-height: 1.7; margin: 0 0 36px; }
  .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }
  .btn { background: #FF4F00; color: #fff; padding: 13px 28px; border-radius: 10px; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; text-decoration: none; border: none; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; }
  .btn-ghost { background: transparent; color: #0E0B08; border: 1px solid rgba(14,11,8,0.18); }

  .stats { display: grid; grid-template-columns: repeat(6, 1fr); gap: 20px; padding: 36px 5vw; border-top: 1px solid rgba(14,11,8,0.10); border-bottom: 1px solid rgba(14,11,8,0.10); max-width: 1280px; margin: 0 auto; }
  .stat-val { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 600; letter-spacing: -0.02em; }
  .stat-lbl { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.1em; color: #7A6F68; text-transform: uppercase; margin-top: 4px; }
  @media (max-width: 880px) { .stats { grid-template-columns: repeat(2, 1fr); } }

  section { padding: 70px 5vw; border-bottom: 1px solid rgba(14,11,8,0.10); }
  .sec-inner { max-width: 1280px; margin: 0 auto; }
  .sec-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 24px; margin-bottom: 30px; flex-wrap: wrap; }
  .sec-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.16em; color: #FF4F00; font-weight: 700; text-transform: uppercase; margin-bottom: 10px; }
  .sec-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 4.2vw, 46px); font-weight: 600; letter-spacing: -0.025em; margin: 0; }
  .sec-title em { font-style: italic; color: #FF4F00; font-weight: 500; }
  .sec-desc { font-size: 15px; color: #4A3F38; max-width: 560px; line-height: 1.6; }

  .card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 22px; }
  .card-title { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; margin: 0 0 8px; letter-spacing: -0.01em; }
  .card-sub { font-family: 'Geist Mono', monospace; font-size: 11px; color: #7A6F68; letter-spacing: 0.06em; text-transform: uppercase; }
  .card-body { font-size: 14px; color: #2E2520; line-height: 1.6; margin-top: 12px; }
  .pill { display: inline-block; padding: 4px 10px; border-radius: 999px; font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 700; }
  .pill-burn { background: rgba(255,79,0,0.10); color: #FF4F00; }
  .pill-ink { background: rgba(14,11,8,0.08); color: #2E2520; }
  .pill-green { background: rgba(46,125,50,0.12); color: #2E7D32; }

  /* Filter */
  .filter-row { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px; align-items: center; }
  .filter-chip { padding: 8px 14px; border-radius: 999px; border: 1px solid rgba(14,11,8,0.14); background: #fff; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 700; color: #2E2520; cursor: pointer; transition: all 0.15s; }
  .filter-chip.active { background: #0E0B08; color: #fff; border-color: #0E0B08; }
  .search-box { flex: 1; min-width: 240px; padding: 10px 14px; border: 1px solid rgba(14,11,8,0.14); border-radius: 10px; background: #fff; font-family: 'Inter', sans-serif; font-size: 14px; }

  .lab-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 16px; }
  .lab-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 20px; display: flex; flex-direction: column; gap: 12px; transition: border-color 0.15s, transform 0.15s; }
  .lab-card:hover { border-color: rgba(255,79,0,0.4); transform: translateY(-2px); }
  .lab-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; }
  .lab-name { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 600; margin: 0; line-height: 1.2; }
  .lab-pi { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.08em; color: #7A6F68; text-transform: uppercase; }
  .lab-paper { font-size: 13px; color: #2E2520; line-height: 1.5; font-style: italic; border-left: 2px solid #FF4F00; padding-left: 10px; }
  .lab-foot { display: flex; justify-content: space-between; align-items: center; font-family: 'Geist Mono', monospace; font-size: 10.5px; color: #7A6F68; padding-top: 8px; border-top: 1px solid rgba(14,11,8,0.06); }

  /* Grad portal */
  .portal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 880px) { .portal-grid { grid-template-columns: 1fr; } }
  .form-row { display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px; }
  .form-row label { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.08em; text-transform: uppercase; color: #7A6F68; }
  .form-row input, .form-row textarea, .form-row select { padding: 10px 12px; border: 1px solid rgba(14,11,8,0.14); border-radius: 8px; background: #FAF8F5; font-family: 'Inter', sans-serif; font-size: 14px; color: #0E0B08; }
  .form-row textarea { resize: vertical; min-height: 80px; }

  /* Journals */
  .journal-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 16px; }
  .journal-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 22px; }
  .journal-name { font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 600; margin: 0 0 6px; }
  .journal-cad { font-family: 'Geist Mono', monospace; font-size: 11px; color: #FF4F00; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700; }
  .journal-ed { font-size: 13px; color: #4A3F38; margin: 12px 0; line-height: 1.5; }
  .journal-scope { font-size: 13px; color: #2E2520; margin-bottom: 14px; line-height: 1.5; }
  .journal-actions { display: flex; gap: 8px; }
  .btn-sm { padding: 8px 14px; font-size: 10.5px; }

  .archive-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-top: 30px; }
  @media (max-width: 760px) { .archive-grid { grid-template-columns: 1fr; } }
  .archive-card { background: #FAF8F5; border: 1px solid rgba(14,11,8,0.10); border-radius: 12px; padding: 18px; }
  .archive-count { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 600; color: #FF4F00; }
  .archive-name { font-family: 'Geist Mono', monospace; font-size: 11.5px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700; margin: 6px 0; }
  .archive-scope { font-size: 12.5px; color: #4A3F38; line-height: 1.5; }

  /* Grants */
  .grant-list { display: flex; flex-direction: column; gap: 12px; }
  .grant-row { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 20px 22px; display: grid; grid-template-columns: 2fr 1.4fr 1fr 1fr auto; gap: 16px; align-items: center; }
  @media (max-width: 980px) { .grant-row { grid-template-columns: 1fr; } }
  .grant-call { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 600; }
  .grant-area { font-size: 12.5px; color: #4A3F38; margin-top: 4px; }
  .grant-amount { font-family: 'Geist Mono', monospace; font-size: 11.5px; font-weight: 700; color: #0E0B08; }
  .grant-deadline { font-family: 'Geist Mono', monospace; font-size: 11.5px; color: #FF4F00; }

  /* Seminars */
  .seminar-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; }
  @media (max-width: 960px) { .seminar-grid { grid-template-columns: 1fr; } }
  .day-col { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 12px; padding: 16px; display: flex; flex-direction: column; gap: 10px; min-height: 240px; }
  .day-label { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 700; color: #FF4F00; border-bottom: 1px solid rgba(255,79,0,0.2); padding-bottom: 8px; margin-bottom: 4px; }
  .seminar-block { background: #FAF8F5; border-left: 2px solid #FF4F00; padding: 10px 12px; border-radius: 0 8px 8px 0; }
  .seminar-time { font-family: 'Geist Mono', monospace; font-size: 10px; color: #7A6F68; letter-spacing: 0.06em; }
  .seminar-title { font-family: 'Cormorant Garamond', serif; font-size: 16px; font-weight: 600; line-height: 1.25; margin: 4px 0; }
  .seminar-speaker { font-size: 11.5px; color: #4A3F38; line-height: 1.3; }
  .seminar-foot { font-family: 'Geist Mono', monospace; font-size: 10px; color: #7A6F68; margin-top: 6px; }

  /* Reproducibility */
  .repro-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
  @media (max-width: 980px) { .repro-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .repro-grid { grid-template-columns: 1fr; } }
  .repro-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 22px; }
  .repro-num { font-family: 'Cormorant Garamond', serif; font-size: 40px; font-weight: 600; color: #FF4F00; letter-spacing: -0.03em; line-height: 1; }
  .repro-title { font-family: 'Cormorant Garamond', serif; font-size: 19px; font-weight: 600; margin: 10px 0 8px; }
  .repro-body { font-size: 13px; color: #4A3F38; line-height: 1.55; }

  /* Ethics */
  .ethics-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  @media (max-width: 880px) { .ethics-grid { grid-template-columns: 1fr; } }
  .ethics-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 24px; }
  .ethics-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; margin-bottom: 10px; }
  .ethics-name { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; margin: 0; line-height: 1.2; }
  .ethics-remit { font-size: 14px; color: #2E2520; line-height: 1.6; margin: 12px 0; }
  .ethics-meta { display: flex; gap: 16px; font-family: 'Geist Mono', monospace; font-size: 11px; color: #7A6F68; letter-spacing: 0.06em; text-transform: uppercase; padding-top: 12px; border-top: 1px solid rgba(14,11,8,0.06); }

  .icon { width: 24px; height: 24px; stroke: currentColor; stroke-width: 2; fill: none; flex-shrink: 0; }
  .icon-sm { width: 16px; height: 16px; stroke: currentColor; stroke-width: 2; fill: none; }
  .empty { padding: 40px; text-align: center; color: #7A6F68; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; }
</style>

<main>
  <div class="hero">
    <div class="crumb">
      <a href="/aquintutor">AquinTutor</a>
      <span>/</span>
      <a href="/aquintutor/campus">Campus</a>
      <span>/</span>
      <span>Research Commons</span>
    </div>
    <div class="eyebrow">Campus · District · Research Commons</div>
    <h1 class="title">Where the <em>frontier</em> lives.</h1>
    <p class="sub">Two thousand four hundred labs. Three thousand two hundred graduate researchers. One hundred forty-two principal investigators. The Research Commons is the district where the day's open problems get cut open — from Vedic computation to quantum foundations, from ancient DNA to mechanistic interpretability. Peer review on a 60-day SLA. Grant office in the same corridor. Twenty-eight active journals. Six open archives. Reproducibility is non-negotiable.</p>
    <div class="hero-actions">
      <a class="btn" href="#labs">
        <svg class="icon-sm" viewBox="0 0 24 24"><path d="M9 3h6m-3 0v6l-4 11h14L18 9V3"/></svg>
        Browse labs
      </a>
      <a class="btn btn-ghost" href="#grants">
        <svg class="icon-sm" viewBox="0 0 24 24"><path d="M12 2v20m-6-8h12M6 6h12M6 18h12"/></svg>
        Active grants
      </a>
      <a class="btn btn-ghost" href="#seminars">
        <svg class="icon-sm" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
        This week
      </a>
    </div>
  </div>

  <div class="stats">
    {stats.map(s => (
      <div>
        <div class="stat-val">{s.val}</div>
        <div class="stat-lbl">{s.lbl}</div>
      </div>
    ))}
  </div>

  <!-- LAB CATALOGUE -->
  <section id="labs">
    <div class="sec-inner">
      <div class="sec-head">
        <div>
          <div class="sec-eyebrow">01 · Lab Catalogue</div>
          <h2 class="sec-title">Twenty-four <em>labs</em>, ten fields.</h2>
        </div>
        <p class="sec-desc">Every lab is open to graduate researchers and visiting scholars. Filter by field, search by keyword, click into a lab page to see the full publication record and open positions.</p>
      </div>

      <div class="filter-row">
        {fields.map((f, i) => (
          <button class={`filter-chip ${i === 0 ? 'active' : ''}`} data-field={f}>{f}</button>
        ))}
        <input class="search-box" id="lab-search" placeholder="Search labs, papers, principal investigators..." />
      </div>

      <div class="lab-grid" id="lab-grid">
        {labs.map(lab => (
          <article class="lab-card" data-field={lab.field} data-search={`${lab.name} ${lab.pi} ${lab.paper} ${lab.field}`.toLowerCase()}>
            <div class="lab-head">
              <h3 class="lab-name">{lab.name}</h3>
              <span class="pill pill-burn">{lab.field}</span>
            </div>
            <div class="lab-pi">{lab.pi}</div>
            <div class="lab-paper">{lab.paper}</div>
            <div class="lab-foot">
              <span>{lab.open} open positions</span>
              <span>Updated {lab.updated}</span>
            </div>
          </article>
        ))}
      </div>
      <div class="empty" id="lab-empty" style="display:none">No labs match this filter.</div>
    </div>
  </section>

  <!-- GRAD STUDENT PORTAL -->
  <section id="portal">
    <div class="sec-inner">
      <div class="sec-head">
        <div>
          <div class="sec-eyebrow">02 · Graduate Researchers</div>
          <h2 class="sec-title">The <em>collab</em> portal.</h2>
        </div>
        <p class="sec-desc">Three thousand two hundred researchers across cohorts. The portal is where active calls go up, current cohort messages run, and applications come in.</p>
      </div>

      <div class="portal-grid">
        <div class="card">
          <h3 class="card-title">Active calls this week</h3>
          <div class="card-body">
            <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:14px;">
              <li style="display:flex; justify-content:space-between; padding-bottom:12px; border-bottom:1px solid rgba(14,11,8,0.06);">
                <div>
                  <div style="font-weight:600;">Mechanistic Interpretability — 6 positions</div>
                  <div style="font-size:12.5px; color:#7A6F68; margin-top:2px;">Sparse autoencoders, attention circuits, evals</div>
                </div>
                <span class="pill pill-burn">AI</span>
              </li>
              <li style="display:flex; justify-content:space-between; padding-bottom:12px; border-bottom:1px solid rgba(14,11,8,0.06);">
                <div>
                  <div style="font-weight:600;">Synthetic Biology Foundry — 5 positions</div>
                  <div style="font-size:12.5px; color:#7A6F68; margin-top:2px;">Riboswitch design, in-vivo logic, mass spec</div>
                </div>
                <span class="pill pill-burn">Biology</span>
              </li>
              <li style="display:flex; justify-content:space-between; padding-bottom:12px; border-bottom:1px solid rgba(14,11,8,0.06);">
                <div>
                  <div style="font-weight:600;">Quantum Error Correction — 5 positions</div>
                  <div style="font-size:12.5px; color:#7A6F68; margin-top:2px;">Surface codes, biased-noise threshold theorems</div>
                </div>
                <span class="pill pill-burn">Quantum</span>
              </li>
              <li style="display:flex; justify-content:space-between;">
                <div>
                  <div style="font-weight:600;">Robotics Manipulation Lab — 5 positions</div>
                  <div style="font-size:12.5px; color:#7A6F68; margin-top:2px;">Diffusion policies, contact-rich tasks, sim2real</div>
                </div>
                <span class="pill pill-burn">CS</span>
              </li>
            </ul>
            <a class="btn btn-sm btn-ghost" href="/portal/research/collab" style="margin-top:18px;">Open the collab portal</a>
          </div>
        </div>

        <div class="card">
          <h3 class="card-title">Express interest</h3>
          <p class="card-sub">Cohort intake · rolling · 14-day response SLA</p>
          <form id="grad-form" style="margin-top:16px;">
            <div class="form-row">
              <label for="g-name">Full name</label>
              <input id="g-name" required />
            </div>
            <div class="form-row">
              <label for="g-email">Email</label>
              <input id="g-email" type="email" required />
            </div>
            <div class="form-row">
              <label for="g-field">Field</label>
              <select id="g-field" required>
                {fields.filter(f => f !== 'All').map(f => <option value={f}>{f}</option>)}
              </select>
            </div>
            <div class="form-row">
              <label for="g-stage">Career stage</label>
              <select id="g-stage" required>
                <option value="undergrad">Undergraduate · final year</option>
                <option value="masters">Masters / pre-doctoral</option>
                <option value="phd">PhD candidate</option>
                <option value="postdoc">Post-doctoral fellow</option>
              </select>
            </div>
            <div class="form-row">
              <label for="g-pitch">Why this lab (250 chars)</label>
              <textarea id="g-pitch" maxlength="250" required></textarea>
            </div>
            <button class="btn" type="submit">
              <svg class="icon-sm" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              Submit interest
            </button>
          </form>
          <div id="grad-toast" style="display:none; margin-top:12px; padding:10px 14px; background:rgba(46,125,50,0.12); color:#2E7D32; border-radius:8px; font-family:'Geist Mono',monospace; font-size:11.5px;"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- JOURNALS + ARCHIVE -->
  <section id="journals">
    <div class="sec-inner">
      <div class="sec-head">
        <div>
          <div class="sec-eyebrow">03 · Journals & Archives</div>
          <h2 class="sec-title">Twenty-eight journals. <em>Six</em> archives.</h2>
        </div>
        <p class="sec-desc">Six are flagship publications run by our editorial board. The remaining twenty-two are partner-of-record journals in adjacent fields. Every paper accepted requires a data + code release before publication.</p>
      </div>

      <div class="journal-grid">
        {journals.map(j => (
          <article class="journal-card">
            <h3 class="journal-name">{j.name}</h3>
            <div class="journal-cad">{j.cadence}</div>
            <div class="journal-ed">{j.editorial}</div>
            <div class="journal-scope">{j.scope}</div>
            <div class="journal-actions">
              <button class="btn btn-sm">Subscribe</button>
              <button class="btn btn-sm btn-ghost">Submit</button>
            </div>
          </article>
        ))}
      </div>

      <h3 style="font-family:'Cormorant Garamond',serif; font-size:26px; font-weight:600; margin:40px 0 4px;">Open archives</h3>
      <p style="font-size:14px; color:#4A3F38;">Preprints, code, data, dissertations, pre-registrations, and replication reports — every artefact gets a persistent DOI.</p>
      <div class="archive-grid">
        {archives.map(a => (
          <div class="archive-card">
            <div class="archive-count">{a.count}</div>
            <div class="archive-name">{a.name}</div>
            <div class="archive-scope">{a.scope}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GRANT OFFICE -->
  <section id="grants">
    <div class="sec-inner">
      <div class="sec-head">
        <div>
          <div class="sec-eyebrow">04 · Grant Office</div>
          <h2 class="sec-title">Eight <em>active</em> calls.</h2>
        </div>
        <p class="sec-desc">The grant office is co-located with the Research Commons admin block. PIs walk in, applications get reviewed by a standing panel, decisions ship in 30 days for seed grants and 90 days for multi-year awards.</p>
      </div>

      <div class="grant-list">
        {grants.map(g => (
          <div class="grant-row">
            <div>
              <div class="grant-call">{g.call}</div>
              <div class="grant-area">{g.area}</div>
            </div>
            <div class="grant-amount">{g.amount}</div>
            <div>
              <div class="grant-deadline">Deadline</div>
              <div style="font-family:'Geist Mono',monospace; font-size:11.5px;">{g.deadline}</div>
            </div>
            <span class="pill pill-green">Open</span>
            <a class="btn btn-sm" href="/aquintutor/research/grants">Apply</a>
          </div>
        ))}
      </div>

      <div style="margin-top:24px; padding:18px 22px; background:#fff; border:1px dashed rgba(14,11,8,0.18); border-radius:12px; display:flex; gap:16px; align-items:center;">
        <svg class="icon" viewBox="0 0 24 24" style="color:#FF4F00;"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="10"/></svg>
        <div style="flex:1;">
          <div style="font-family:'Cormorant Garamond',serif; font-size:18px; font-weight:600;">Office hours</div>
          <div style="font-size:13px; color:#4A3F38;">Tuesdays 14:00-17:00 · Thursdays 10:00-12:00 · Walk-ins welcome · Or book a slot online.</div>
        </div>
        <a class="btn btn-sm btn-ghost" href="/aquintutor/research/grants">Full grants page</a>
      </div>
    </div>
  </section>

  <!-- SEMINAR SERIES -->
  <section id="seminars">
    <div class="sec-inner">
      <div class="sec-head">
        <div>
          <div class="sec-eyebrow">05 · Seminars</div>
          <h2 class="sec-title">This <em>week</em> on the schedule.</h2>
        </div>
        <p class="sec-desc">Nine talks across five days. Public — sign in at the door. Streamed to the Common Room and recorded for the archive. Click any talk to RSVP and add to your calendar.</p>
      </div>

      <div class="seminar-grid">
        {['Mon','Tue','Wed','Thu','Fri'].map(day => (
          <div class="day-col">
            <div class="day-label">{day}</div>
            {seminars.filter(s => s.day === day).map(s => (
              <div class="seminar-block">
                <div class="seminar-time">{s.time}</div>
                <div class="seminar-title">{s.title}</div>
                <div class="seminar-speaker">{s.speaker}</div>
                <div class="seminar-foot">{s.attendees} RSVP'd</div>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- REPRODUCIBILITY -->
  <section id="reproducibility">
    <div class="sec-inner">
      <div class="sec-head">
        <div>
          <div class="sec-eyebrow">06 · Reproducibility</div>
          <h2 class="sec-title">Code <em>and</em> data, with every paper.</h2>
        </div>
        <p class="sec-desc">A paper is not done when the text is done. A paper is done when an independent reader can reproduce the result on their own hardware. The Research Commons enforces this with four standing policies.</p>
      </div>

      <div class="repro-grid">
        <div class="repro-card">
          <div class="repro-num">01</div>
          <div class="repro-title">Code Vault submission</div>
          <div class="repro-body">Every accepted paper deposits the full code (training scripts, evaluation harness, plotting) to the Code Vault with a persistent DOI. Reviewers verify it builds on a fresh container before acceptance.</div>
        </div>
        <div class="repro-card">
          <div class="repro-num">02</div>
          <div class="repro-title">Data Commons release</div>
          <div class="repro-body">Datasets used (or generated) are released to the Data Commons under a documented licence with a datasheet (provenance, demographics, known limitations). Sensitive data gets a controlled-access tier with IRB review.</div>
        </div>
        <div class="repro-card">
          <div class="repro-num">03</div>
          <div class="repro-title">Pre-registration option</div>
          <div class="repro-body">For confirmatory studies, authors may pre-register the analysis plan with the Pre-registration Registry before data collection. Pre-registered papers carry a badge and get expedited review.</div>
        </div>
        <div class="repro-card">
          <div class="repro-num">04</div>
          <div class="repro-title">Replication reports welcome</div>
          <div class="repro-body">Independent replications are accepted as first-class submissions. A small grant funds the replication itself. Both successful and failed replications are published — null results are not buried.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ETHICS COMMITTEES -->
  <section id="ethics">
    <div class="sec-inner">
      <div class="sec-head">
        <div>
          <div class="sec-eyebrow">07 · Ethics</div>
          <h2 class="sec-title">Four standing <em>committees</em>.</h2>
        </div>
        <p class="sec-desc">No research project starts without the relevant committee's review. Every committee includes external members (community representatives, ethicists, domain experts from outside the institute) so the review is not a rubber stamp.</p>
      </div>

      <div class="ethics-grid">
        {ethics.map(e => (
          <article class="ethics-card">
            <div class="ethics-head">
              <h3 class="ethics-name">{e.name}</h3>
              <span class="pill pill-ink">{e.members} members</span>
            </div>
            <div class="ethics-remit">{e.remit}</div>
            <div class="ethics-meta">
              <span>{e.cadence}</span>
            </div>
          </article>
        ))}
      </div>

      <div style="margin-top:30px; padding:20px 24px; background:#0E0B08; color:#FAF8F5; border-radius:14px; display:flex; gap:20px; align-items:center; flex-wrap:wrap;">
        <svg class="icon" viewBox="0 0 24 24" style="color:#FF4F00;"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        <div style="flex:1; min-width:240px;">
          <div style="font-family:'Cormorant Garamond',serif; font-size:22px; font-weight:600;">Submit a protocol</div>
          <div style="font-size:13.5px; color:#A89E97; margin-top:4px;">Any project involving humans, animals, sensitive data, or traditional knowledge must be approved before work begins.</div>
        </div>
        <a class="btn" href="/aquintutor/research/ethics">Open the ethics portal</a>
      </div>
    </div>
  </section>
</main>

<script is:inline>
  (function() {
    const chips = document.querySelectorAll('.filter-chip');
    const grid = document.getElementById('lab-grid');
    const search = document.getElementById('lab-search');
    const empty = document.getElementById('lab-empty');
    let activeField = 'All';
    let query = '';

    function applyFilter() {
      const cards = grid.querySelectorAll('.lab-card');
      let visible = 0;
      cards.forEach(c => {
        const field = c.getAttribute('data-field');
        const text = c.getAttribute('data-search') || '';
        const fieldMatch = activeField === 'All' || field === activeField;
        const queryMatch = !query || text.indexOf(query) !== -1;
        const show = fieldMatch && queryMatch;
        c.style.display = show ? 'flex' : 'none';
        if (show) visible++;
      });
      empty.style.display = visible === 0 ? 'block' : 'none';
    }

    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        chips.forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        activeField = chip.getAttribute('data-field') || 'All';
        applyFilter();
      });
    });

    if (search) {
      search.addEventListener('input', e => {
        query = (e.target.value || '').toLowerCase().trim();
        applyFilter();
      });
    }

    const form = document.getElementById('grad-form');
    const toast = document.getElementById('grad-toast');
    if (form) {
      form.addEventListener('submit', e => {
        e.preventDefault();
        const name = document.getElementById('g-name').value;
        toast.style.display = 'block';
        toast.textContent = 'Interest registered for ' + name + '. The cohort office will reply within 14 days.';
        form.reset();
        setTimeout(() => { toast.style.display = 'none'; }, 6000);
      });
    }
  })();
</script>
</BaseLayout>
