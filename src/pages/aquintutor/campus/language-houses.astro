<BaseLayout title="Language Houses · Campus District · AquinTutor" description="92 language houses, 24-hour conversation circles, native speakers and cultural exchange — move to Tokyo without a visa.">

<style>
  :root {
    --ink: #0E0B08;
    --ink-2: #2E2520;
    --ink-3: #7A6F68;
    --paper: #FAF8F5;
    --paper-2: #F3EFE8;
    --burn: #FF4F00;
    --line: rgba(14,11,8,0.10);
    --line-2: rgba(14,11,8,0.06);
  }
  body { background: var(--paper); color: var(--ink); }
  main { font-family: 'Inter', system-ui, sans-serif; }
  .wrap { max-width: 1280px; margin: 0 auto; padding: 0 5vw; }

  /* Hero */
  .hero { padding: 80px 5vw 60px; max-width: 1280px; margin: 0 auto; }
  .eyebrow { font-family: 'Geist Mono', monospace; font-size: 11.5px; letter-spacing: 0.18em; color: var(--burn); font-weight: 700; text-transform: uppercase; }
  .hero h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 7vw, 84px); font-weight: 600; letter-spacing: -0.035em; line-height: 1.02; margin: 14px 0 22px; }
  .hero h1 em { color: var(--burn); font-style: italic; font-weight: 500; }
  .hero .sub { font-size: 17px; color: var(--ink-2); max-width: 720px; line-height: 1.7; }

  /* Stats strip */
  .stats { border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); display: grid; grid-template-columns: repeat(5, 1fr); padding: 26px 5vw; max-width: 1280px; margin: 30px auto 0; gap: 18px; }
  .stat-val { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 600; letter-spacing: -0.02em; }
  .stat-lbl { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.1em; color: var(--ink-3); text-transform: uppercase; margin-top: 4px; }
  @media (max-width: 760px) { .stats { grid-template-columns: repeat(2, 1fr); } }

  /* Sections */
  section.block { padding: 60px 5vw 70px; max-width: 1280px; margin: 0 auto; border-bottom: 1px solid var(--line); }
  .sec-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11.5px; letter-spacing: 0.18em; color: var(--burn); font-weight: 700; text-transform: uppercase; }
  .sec-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(30px, 4.4vw, 52px); font-weight: 600; letter-spacing: -0.025em; margin: 12px 0 14px; }
  .sec-sub { font-size: 16px; color: var(--ink-2); line-height: 1.65; max-width: 760px; }

  /* Region filter bar */
  .region-bar { display: flex; flex-wrap: wrap; gap: 8px; margin: 26px 0 22px; }
  .region-chip { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; padding: 8px 14px; border: 1px solid var(--line); border-radius: 999px; background: #fff; cursor: pointer; color: var(--ink-2); transition: all 0.15s; }
  .region-chip:hover { border-color: var(--ink); }
  .region-chip.active { background: var(--ink); color: #fff; border-color: var(--ink); }

  /* Search */
  .search-row { display: flex; gap: 10px; align-items: center; margin: 16px 0 8px; }
  .search-input { flex: 1; padding: 12px 16px; border: 1px solid var(--line); border-radius: 10px; background: #fff; font-family: 'Inter', sans-serif; font-size: 14px; color: var(--ink); }
  .search-input:focus { outline: none; border-color: var(--burn); }
  .count-badge { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--ink-3); }

  /* Language grid */
  .lang-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 14px; }
  .lang-card { background: #fff; border: 1px solid var(--line); border-radius: 14px; padding: 18px 18px 16px; cursor: pointer; transition: all 0.18s; position: relative; }
  .lang-card:hover { border-color: var(--ink); transform: translateY(-2px); box-shadow: 0 6px 24px rgba(14,11,8,0.06); }
  .lang-card .script { font-family: 'Noto Sans Devanagari','Noto Sans Tamil','Noto Sans Telugu','Noto Sans Bengali','Noto Sans Gurmukhi','Noto Sans Oriya','Noto Sans JP','Noto Sans KR','Noto Sans SC','Noto Sans Arabic','Noto Sans Hebrew','Noto Sans Thai','Noto Sans Myanmar','Noto Sans Khmer','Noto Sans Lao','Noto Sans Ethiopic','Noto Sans Georgian','Noto Sans Armenian','Noto Serif Tibetan',serif; font-size: 26px; line-height: 1.1; color: var(--ink); margin-bottom: 6px; min-height: 30px; }
  .lang-card .name { font-family: 'Cormorant Garamond', serif; font-size: 21px; font-weight: 600; letter-spacing: -0.01em; }
  .lang-card .meta { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.06em; color: var(--ink-3); text-transform: uppercase; margin-top: 8px; display: flex; justify-content: space-between; align-items: center; }
  .lang-card .live-pill { display: inline-flex; align-items: center; gap: 5px; padding: 3px 7px; background: rgba(255,79,0,0.08); color: var(--burn); border-radius: 6px; font-weight: 700; }
  .live-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--burn); animation: pulse 2s infinite; }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

  /* House amenities */
  .amen-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 30px; }
  @media (max-width: 920px) { .amen-grid { grid-template-columns: repeat(2, 1fr); } }
  .amen-card { background: #fff; border: 1px solid var(--line); border-radius: 14px; padding: 22px; }
  .amen-icon { width: 44px; height: 44px; border-radius: 10px; background: var(--paper-2); display: flex; align-items: center; justify-content: center; margin-bottom: 14px; color: var(--burn); }
  .amen-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; letter-spacing: -0.01em; margin-bottom: 6px; }
  .amen-card p { font-size: 14px; line-height: 1.6; color: var(--ink-2); }

  /* Live circles table */
  .table-wrap { background: #fff; border: 1px solid var(--line); border-radius: 14px; overflow: hidden; margin-top: 22px; }
  table.circles { width: 100%; border-collapse: collapse; }
  table.circles th { text-align: left; font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.08em; color: var(--ink-3); text-transform: uppercase; padding: 14px 18px; border-bottom: 1px solid var(--line); background: var(--paper-2); }
  table.circles td { padding: 16px 18px; border-bottom: 1px solid var(--line-2); font-size: 14px; vertical-align: middle; }
  table.circles tr:last-child td { border-bottom: none; }
  table.circles .lang-cell { display: flex; flex-direction: column; gap: 2px; }
  table.circles .lang-cell .lang-script { font-family: 'Noto Sans Devanagari','Noto Sans Tamil','Noto Sans Telugu','Noto Sans Bengali','Noto Sans Arabic','Noto Sans JP','Noto Sans KR','Noto Sans SC',serif; font-size: 17px; }
  table.circles .lang-cell .lang-en { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.06em; color: var(--ink-3); text-transform: uppercase; }
  .level-pill { display: inline-block; padding: 3px 8px; background: var(--paper-2); border-radius: 6px; font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.05em; color: var(--ink-2); }
  .join-btn { background: var(--ink); color: #fff; border: none; padding: 8px 14px; border-radius: 8px; font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700; cursor: pointer; }
  .join-btn:hover { background: var(--burn); }
  @media (max-width: 760px) { .live-hide-mobile { display: none; } }

  /* Form */
  .form-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; margin-top: 22px; max-width: 760px; }
  @media (max-width: 720px) { .form-grid { grid-template-columns: 1fr; } }
  .form-grid label { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.06em; color: var(--ink-3); text-transform: uppercase; margin-bottom: 6px; display: block; }
  .form-grid input, .form-grid select, .form-grid textarea { width: 100%; padding: 12px 14px; border: 1px solid var(--line); border-radius: 10px; background: #fff; font-family: 'Inter', sans-serif; font-size: 14px; color: var(--ink); }
  .form-grid input:focus, .form-grid select:focus, .form-grid textarea:focus { outline: none; border-color: var(--burn); }
  .form-grid .span-2 { grid-column: span 2; }
  @media (max-width: 720px) { .form-grid .span-2 { grid-column: span 1; } }
  .btn-primary { background: var(--burn); color: #fff; border: none; padding: 14px 28px; border-radius: 10px; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; cursor: pointer; margin-top: 14px; }
  .btn-primary:hover { background: #E04600; }
  .form-msg { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--burn); margin-top: 12px; }

  /* Indic spotlight cards */
  .indic-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-top: 26px; }
  @media (max-width: 920px) { .indic-grid { grid-template-columns: repeat(2, 1fr); } }
  .indic-card { background: linear-gradient(180deg, #fff 0%, var(--paper-2) 100%); border: 1px solid var(--line); border-radius: 14px; padding: 22px; }
  .indic-card .greet { font-family: 'Noto Sans Devanagari','Noto Sans Tamil','Noto Sans Telugu','Noto Sans Bengali','Noto Sans Gurmukhi','Noto Sans Oriya', serif; font-size: 30px; line-height: 1.2; color: var(--ink); margin-bottom: 8px; }
  .indic-card .name { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; }
  .indic-card .speakers { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.06em; color: var(--ink-3); text-transform: uppercase; margin-top: 8px; }

  /* Residency */
  .residency-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 30px; align-items: start; }
  @media (max-width: 920px) { .residency-grid { grid-template-columns: 1fr; } }
  .residency-card { background: var(--ink); color: #fff; border-radius: 14px; padding: 32px; }
  .residency-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 600; letter-spacing: -0.02em; margin-bottom: 14px; }
  .residency-card h3 em { color: var(--burn); font-style: italic; font-weight: 500; }
  .residency-card p { font-size: 14.5px; line-height: 1.7; color: rgba(255,255,255,0.78); margin-bottom: 14px; }
  .residency-card ul { list-style: none; padding: 0; margin-top: 18px; }
  .residency-card li { display: flex; gap: 10px; padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.08); font-size: 13.5px; }
  .residency-card li:last-child { border-bottom: none; }
  .residency-card li .num { font-family: 'Geist Mono', monospace; color: var(--burn); font-weight: 700; min-width: 28px; font-size: 11px; letter-spacing: 0.06em; }

  /* Modal */
  .modal-backdrop { display: none; position: fixed; inset: 0; background: rgba(14,11,8,0.65); z-index: 100; align-items: center; justify-content: center; padding: 20px; }
  .modal-backdrop.open { display: flex; }
  .modal { background: var(--paper); border-radius: 18px; padding: 36px; max-width: 520px; width: 100%; }
  .modal .script-big { font-family: 'Noto Sans Devanagari','Noto Sans Tamil','Noto Sans Telugu','Noto Sans Bengali','Noto Sans Gurmukhi','Noto Sans Oriya','Noto Sans Arabic','Noto Sans JP','Noto Sans KR','Noto Sans SC',serif; font-size: 56px; line-height: 1.1; margin-bottom: 14px; }
  .modal h2 { font-family: 'Cormorant Garamond', serif; font-size: 36px; font-weight: 600; letter-spacing: -0.02em; margin-bottom: 8px; }
  .modal .modal-meta { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; color: var(--ink-3); text-transform: uppercase; margin-bottom: 18px; }
  .modal p { font-size: 14.5px; line-height: 1.65; color: var(--ink-2); margin-bottom: 12px; }
  .modal .close-btn { background: var(--ink); color: #fff; border: none; padding: 12px 22px; border-radius: 10px; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700; cursor: pointer; margin-top: 16px; }
</style>

<main>
  <!-- HERO -->
  <section class="hero">
    <div class="eyebrow">Campus · District · Language Houses</div>
    <h1>Move to <em>Tokyo</em>. Without a visa.</h1>
    <p class="sub">Ninety-two living traditions, each with a house of their own. Twenty-four hour conversation circles. Kitchens cooking the literature of a region. Cinema rooms with subtitles you can pause. Native speakers ready to read poetry with you at four in the morning. The world, walkable.</p>
  </section>

  <!-- STATS -->
  <div class="stats">
    <div><div class="stat-val">92</div><div class="stat-lbl">Languages</div></div>
    <div><div class="stat-val">24h</div><div class="stat-lbl">Conversation</div></div>
    <div><div class="stat-val">1,400</div><div class="stat-lbl">Native Speakers</div></div>
    <div><div class="stat-val">340</div><div class="stat-lbl">Live Circles Now</div></div>
    <div><div class="stat-val">12</div><div class="stat-lbl">Indic First-Class</div></div>
  </div>

  <!-- 92 LANGUAGES -->
  <section class="block">
    <div class="sec-eyebrow">Section 01 · The Ninety-Two</div>
    <h2 class="sec-title">A house for every tradition.</h2>
    <p class="sec-sub">Filter by region. Search by name. Each tile is a living house — open the door to see what is being read tonight, who is cooking what, and which conversation circle is presently in session.</p>

    <div class="search-row">
      <input id="langSearch" class="search-input" placeholder="Search by language name, script, or region…" />
      <span class="count-badge" id="langCount">{LANGS.length} of {LANGS.length}</span>
    </div>

    <div class="region-bar" id="regionBar">
      <button class="region-chip active" data-region="all">All Regions</button>
      {regions.map(r => <button class="region-chip" data-region={r}>{r}</button>)}
    </div>

    <div class="lang-grid" id="langGrid">
      {LANGS.map(l => (
        <div class="lang-card" data-region={l.region} data-name={l.name.toLowerCase()} data-script={l.script}
             data-greeting={l.greeting} data-speakers={l.speakers} data-circles={String(l.circles)}>
          <div class="script">{l.script}</div>
          <div class="name">{l.name}</div>
          <div class="meta">
            <span>{l.region} · {l.speakers}</span>
            <span class="live-pill"><span class="live-dot"></span>{l.circles} live</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- HOUSE STRUCTURE -->
  <section class="block">
    <div class="sec-eyebrow">Section 02 · The House Itself</div>
    <h2 class="sec-title">Four rooms in every house.</h2>
    <p class="sec-sub">Each language has more than a classroom. It has a hearth — and the hearth is composed of four spaces, each pulling the language into one of its essential dimensions: dialogue, taste, image, and friendship.</p>

    <div class="amen-grid">
      <div class="amen-card">
        <div class="amen-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
        </div>
        <h3>Conversation circle</h3>
        <p>Open twenty-four hours, drop in any time. Five tables for five levels. A native host always present. No registration — pull up a chair.</p>
      </div>
      <div class="amen-card">
        <div class="amen-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 11h18M6 11V7a3 3 0 0 1 3-3h6a3 3 0 0 1 3 3v4M5 11l1 9h12l1-9"/>
          </svg>
        </div>
        <h3>Cooking studio</h3>
        <p>The grammar of a region in spice and bread. Weekly cook-along sessions where literature is read aloud while a regional dish takes shape on the stove.</p>
      </div>
      <div class="amen-card">
        <div class="amen-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="3" width="20" height="14" rx="2"/>
            <path d="M8 21h8M12 17v4"/>
          </svg>
        </div>
        <h3>Cinema room</h3>
        <p>Curated retrospectives. Subtitles in three languages, pause-and-discuss controls, transcripts on the side. From silent-era classics to current festival circuits.</p>
      </div>
      <div class="amen-card">
        <div class="amen-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <h3>Cultural exchange partners</h3>
        <p>A matched tandem: you teach yours, they teach theirs. Weekly meetings, structured prompts, a long-running notebook you keep in common.</p>
      </div>
    </div>
  </section>

  <!-- LIVE CIRCLES -->
  <section class="block">
    <div class="sec-eyebrow">Section 03 · In Session, Right Now</div>
    <h2 class="sec-title">Twelve circles you could walk into.</h2>
    <p class="sec-sub">A snapshot of the live floor. These are the conversations underway as this page loaded — refresh in five minutes and the topics will have moved on.</p>

    <div class="table-wrap">
      <table class="circles">
        <thead>
          <tr>
            <th>Language</th>
            <th>Level</th>
            <th>Topic tonight</th>
            <th class="live-hide-mobile">Host</th>
            <th class="live-hide-mobile">Attending</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {LIVE_CIRCLES.map(c => (
            <tr>
              <td>
                <div class="lang-cell">
                  <span class="lang-script">{c.lang_script}</span>
                  <span class="lang-en">{c.lang}</span>
                </div>
              </td>
              <td><span class="level-pill">{c.level}</span></td>
              <td>{c.topic}</td>
              <td class="live-hide-mobile">{c.host}</td>
              <td class="live-hide-mobile">{c.attendees}</td>
              <td><button class="join-btn" data-circle={c.lang}>Join</button></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- TANDEM PARTNER FORM -->
  <section class="block">
    <div class="sec-eyebrow">Section 04 · Tandem</div>
    <h2 class="sec-title">Request a one-to-one partner.</h2>
    <p class="sec-sub">Tell us the language you are studying and the language you offer in exchange. We match within forty-eight hours from the speaker pool, pairing on time-zone overlap, level fit, and shared interest area.</p>

    <form class="form-grid" id="tandemForm">
      <div>
        <label for="t-target">Target language</label>
        <select id="t-target" name="target_language" required>
          <option value="">Select a language…</option>
          {LANGS.map(l => <option value={l.name}>{l.name}</option>)}
        </select>
      </div>
      <div>
        <label for="t-native">Your native language</label>
        <input id="t-native" name="your_native_language" required placeholder="e.g. Hindi, English, Tamil" />
      </div>
      <div>
        <label for="t-level">Your current level</label>
        <select id="t-level" name="level" required>
          <option value="">Select level…</option>
          <option>Absolute beginner</option>
          <option>A1 / Elementary</option>
          <option>A2 / Pre-intermediate</option>
          <option>B1 / Intermediate</option>
          <option>B2 / Upper-intermediate</option>
          <option>C1 / Advanced</option>
          <option>C2 / Near-native</option>
          <option>Heritage speaker</option>
        </select>
      </div>
      <div>
        <label for="t-times">Preferred meeting times</label>
        <input id="t-times" name="preferred_times" required placeholder="e.g. Weekday evenings IST 19:00-22:00" />
      </div>
      <div class="span-2">
        <label for="t-interest">Shared interest area (optional)</label>
        <input id="t-interest" name="interest" placeholder="Literature · cinema · cooking · history · cricket · music…" />
      </div>
      <div class="span-2">
        <button type="submit" class="btn-primary">Find me a partner</button>
        <div class="form-msg" id="tandemMsg"></div>
      </div>
    </form>
  </section>

  <!-- INDIC SPOTLIGHT -->
  <section class="block">
    <div class="sec-eyebrow">Section 05 · Indic Spotlight</div>
    <h2 class="sec-title">Twelve mother-tongues, first-class.</h2>
    <p class="sec-sub">Every Indic language house operates at the same standard as Tokyo or Paris — full staffing, full kitchen, full library. Heritage speakers welcomed without testing; beginners welcomed without apology.</p>

    <div class="indic-grid">
      {INDIC.map(l => (
        <div class="indic-card">
          <div class="greet">{l.greeting}</div>
          <div class="name">{l.name} <span style="color:var(--ink-3);font-size:14px;">· {l.script}</span></div>
          <div class="speakers">{l.speakers} speakers · {l.circles} live circles</div>
        </div>
      ))}
    </div>
  </section>

  <!-- RESIDENCY -->
  <section class="block">
    <div class="sec-eyebrow">Section 06 · Quarterly Residency</div>
    <h2 class="sec-title">Three months. One language. Total immersion.</h2>
    <p class="sec-sub">Four times a year we open twelve residency slots per language house. You move into the district, eat at the house kitchen, sleep above the cinema room, and spend ninety days inside the language. No English permitted on the floor.</p>

    <div class="residency-grid">
      <div class="residency-card">
        <h3>What the <em>residency</em> includes.</h3>
        <p>A single-room dormitory above the language house. Three meals a day in the house kitchen — same cuisine, every meal. Daily conversation hours with rotating native partners. Weekly cinema night, literature reading, calligraphy or script class. End-of-residency public recital or essay defence.</p>
        <ul>
          <li><span class="num">01</span>Ninety-day on-site stay in the language house dormitory</li>
          <li><span class="num">02</span>One-on-one tutor assigned for full duration, daily session</li>
          <li><span class="num">03</span>Three rotating conversation partners per week, levelled up</li>
          <li><span class="num">04</span>Weekly cooking lab tied to a piece of regional literature</li>
          <li><span class="num">05</span>Closing public recital, essay, or screen-test in target language</li>
          <li><span class="num">06</span>Certificate of residency, with named host and a written assessment</li>
        </ul>
      </div>

      <form class="form-grid" id="residencyForm" style="margin-top:0;">
        <div class="span-2">
          <label for="r-lang">Target language for residency</label>
          <select id="r-lang" name="target_language" required>
            <option value="">Select a language…</option>
            {LANGS.map(l => <option value={l.name}>{l.name}</option>)}
          </select>
        </div>
        <div>
          <label for="r-name">Full name</label>
          <input id="r-name" name="applicant_name" required />
        </div>
        <div>
          <label for="r-email">Email</label>
          <input id="r-email" name="applicant_email" type="email" required />
        </div>
        <div>
          <label for="r-quarter">Preferred quarter</label>
          <select id="r-quarter" name="quarter" required>
            <option value="">Select quarter…</option>
            <option>Q1 — January to March</option>
            <option>Q2 — April to June</option>
            <option>Q3 — July to September</option>
            <option>Q4 — October to December</option>
          </select>
        </div>
        <div>
          <label for="r-level">Current proficiency</label>
          <select id="r-level" name="level" required>
            <option value="">Select…</option>
            <option>Absolute beginner</option>
            <option>Some study (A1-A2)</option>
            <option>Intermediate (B1-B2)</option>
            <option>Advanced (C1+)</option>
            <option>Heritage speaker</option>
          </select>
        </div>
        <div class="span-2">
          <label for="r-why">Why this language, why now? (300 words)</label>
          <textarea id="r-why" name="motivation" rows="5" required></textarea>
        </div>
        <div class="span-2">
          <button type="submit" class="btn-primary">Apply for residency</button>
          <div class="form-msg" id="residencyMsg"></div>
        </div>
      </form>
    </div>
  </section>

  <!-- MODAL -->
  <div class="modal-backdrop" id="langModal">
    <div class="modal">
      <div class="script-big" id="m-greet"></div>
      <h2 id="m-name"></h2>
      <div class="modal-meta" id="m-meta"></div>
      <p id="m-text"></p>
      <button class="close-btn" id="m-close">Close</button>
    </div>
  </div>
</main>

<script is:inline>
  // -------- Search + region filter --------
  const grid = document.getElementById('langGrid');
  const cards = Array.from(grid.querySelectorAll('.lang-card'));
  const search = document.getElementById('langSearch');
  const countBadge = document.getElementById('langCount');
  const regionBar = document.getElementById('regionBar');
  const totalCount = cards.length;
  let activeRegion = 'all';

  function applyFilter() {
    const q = (search.value || '').toLowerCase().trim();
    let visible = 0;
    cards.forEach(c => {
      const name = c.dataset.name;
      const script = (c.dataset.script || '').toLowerCase();
      const region = c.dataset.region;
      const matchRegion = activeRegion === 'all' || region === activeRegion;
      const matchSearch = !q || name.includes(q) || script.includes(q) || region.toLowerCase().includes(q);
      const show = matchRegion && matchSearch;
      c.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    countBadge.textContent = visible + ' of ' + totalCount;
  }

  search.addEventListener('input', applyFilter);

  regionBar.addEventListener('click', e => {
    const btn = e.target.closest('.region-chip');
    if (!btn) return;
    regionBar.querySelectorAll('.region-chip').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeRegion = btn.dataset.region;
    applyFilter();
  });

  // -------- Modal --------
  const modal = document.getElementById('langModal');
  const mGreet = document.getElementById('m-greet');
  const mName = document.getElementById('m-name');
  const mMeta = document.getElementById('m-meta');
  const mText = document.getElementById('m-text');
  document.getElementById('m-close').addEventListener('click', () => modal.classList.remove('open'));
  modal.addEventListener('click', e => { if (e.target === modal) modal.classList.remove('open'); });

  cards.forEach(c => {
    c.addEventListener('click', () => {
      const name = c.querySelector('.name').textContent;
      const script = c.dataset.script;
      const greeting = c.dataset.greeting;
      const speakers = c.dataset.speakers;
      const circles = c.dataset.circles;
      const region = c.dataset.region;
      mGreet.textContent = greeting;
      mName.textContent = name + ' · ' + script;
      mMeta.textContent = region + ' · ' + speakers + ' speakers · ' + circles + ' live circles';
      mText.textContent = 'The ' + name + ' house keeps a twenty-four hour conversation circle, a cooking studio paired weekly with a piece of regional literature, a cinema room, and a tandem-partner registry of native speakers. Walk in any time — no booking needed for drop-in conversation.';
      modal.classList.add('open');
    });
  });

  // -------- Join button --------
  document.querySelectorAll('.join-btn').forEach(b => {
    b.addEventListener('click', () => {
      const c = b.dataset.circle;
      b.textContent = 'Joined';
      b.style.background = '#FF4F00';
      setTimeout(() => {
        b.textContent = 'In session';
      }, 900);
    });
  });

  // -------- Tandem form --------
  const tForm = document.getElementById('tandemForm');
  const tMsg = document.getElementById('tandemMsg');
  tForm.addEventListener('submit', e => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(tForm).entries());
    tMsg.textContent = 'Request received. We will match you with a partner in ' + data.target_language + ' within 48 hours and write to your email.';
    setTimeout(() => { tForm.reset(); }, 200);
  });

  // -------- Residency form --------
  const rForm = document.getElementById('residencyForm');
  const rMsg = document.getElementById('residencyMsg');
  rForm.addEventListener('submit', e => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(rForm).entries());
    rMsg.textContent = 'Application received for ' + data.target_language + ' · ' + data.quarter + '. The residency committee meets every fortnight; you will hear within thirty days.';
    setTimeout(() => { rForm.reset(); }, 200);
  });

  applyFilter();
</script>

</BaseLayout>
