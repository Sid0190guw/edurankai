const esportsLeagues = [
  'Strategy League', 'Tactical Shooter Cup', 'Fighting Game Open',
  'Rhythm & Music Series', 'Puzzle Sprint League', 'Sandbox Build-Off',
  'Card Tactics Bracket', 'Co-op Speedrun', 'Indie Title Showcase',
  'Sim Racing Championship', 'Real-time Tactics Ladder', 'Open Format Friendlies'
];

const counsellingLanguages = [
  'English', 'Hindi', 'Sanskrit', 'Tamil', 'Telugu', 'Kannada',
  'Marathi', 'Bengali', 'Gujarati', 'French', 'Spanish', 'Mandarin'
];

const counsellingTopics = [
  'General wellbeing', 'Academic pressure', 'Anxiety',
  'Low mood / depression', 'Grief & loss', 'Relationships',
  'Family conflict', 'Identity & belonging', 'Body image',
  'Sleep concerns', 'Financial stress', 'Career uncertainty'
];

// Generate next 14 days of slot options
const today = new Date();
const slotDays: { iso: string; label: string }[] = [];
for (let i = 0; i < 14; i++) {
  const d = new Date(today.getTime() + i * 24 * 60 * 60 * 1000);
  const iso = d.toISOString().slice(0, 10);
  const label = d.toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', weekday: 'short', day: 'numeric', month: 'short' });
  slotDays.push({ iso, label });
}
const slotHours = ['09:00', '10:00', '11:00', '13:00', '14:00', '15:00', '16:00', '17:00', '18:00', '19:00'];

const stats = [
  { v: '1:1', l: 'Confidential counselling' },
  { v: '24/7', l: 'Crisis line · always on' },
  { v: '6', l: 'Yoga schools represented' },
  { v: '18', l: 'Sports clubs' },
  { v: '12', l: 'Esports leagues' },
  { v: '4.2/5', l: 'Wellbeing index · 90-day' },
];

// Radar axes (axis index for SVG generator)
const radarAxes = [
  { key: 'sleep', label: 'Sleep', value: 4.1 },
  { key: 'stress', label: 'Stress', value: 3.2 },
  { key: 'mood', label: 'Mood', value: 4.4 },
  { key: 'social', label: 'Social', value: 3.8 },
  { key: 'activity', label: 'Activity', value: 4.0 },
  { key: 'nutrition', label: 'Nutrition', value: 3.5 },
  { key: 'focus', label: 'Focus', value: 4.3 },
];

const sleepProgramSteps = [
  { n: '01', title: 'Two-week sleep diary', body: 'A nightly two-minute log: in-bed time, wake time, sleep latency, awakenings, caffeine, screen-off, dream recall. We compute your sleep efficiency and chronotype.' },
  { n: '02', title: 'Chronotype assessment', body: 'A short Munich Chrono-type style questionnaire estimates your midpoint of sleep and whether you are lark-leaning, neutral, or owl-leaning. No moral judgement attached.' },
  { n: '03', title: 'Personal light schedule', body: 'A daily plan of when to seek bright light and when to dim. We anchor your circadian phase rather than push you against it.' },
  { n: '04', title: 'Weekly 1:1 with a coach', body: '30 minutes a week with a trained sleep coach who reviews your diary, adjusts the plan, and answers the things you did not know how to ask.' },
  { n: '05', title: 'Caffeine, exercise, meal-timing', body: 'Caffeine half-life is ~5 hours. We map your last-cup window. Exercise and meal-timing windows tuned to your chronotype.' },
  { n: '06', title: 'CBT-I worksheets (optional)', body: 'If insomnia patterns appear, we walk you through structured Cognitive Behavioural Therapy for Insomnia worksheets over 6 weeks, with a coach.' },
];

const wellbeingPillars = [
  { letter: 'S', name: 'Sleep', body: 'Duration, regularity, perceived restfulness. Weighted 22%.' },
  { letter: 'T', name: 'Stress', body: 'Self-rated load + rumination markers. Inversely scored. Weighted 14%.' },
  { letter: 'M', name: 'Mood', body: '4-question PHQ-style screen (validated). Weighted 18%.' },
  { letter: 'C', name: 'Social', body: 'Quality of connection, not count. Weighted 12%.' },
  { letter: 'A', name: 'Activity', body: 'Minutes of moderate movement + steps. Weighted 14%.' },
  { letter: 'N', name: 'Nutrition', body: 'Regular meals, hydration, plant intake. Weighted 10%.' },
  { letter: 'F', name: 'Focus', body: 'Self-rated attention + study quality. Weighted 10%.' },
];

const crisisOptions = [
  { l: 'Call the line', d: 'You will reach a human in under 90 seconds. Available 24/7 in 6 languages.', cta: 'Open call panel', kind: 'call' },
  { l: 'Text-line option', d: 'Texting feels safer for many. The same crisis team answers. Two-way SMS or in-app chat.', cta: 'Start a text', kind: 'text' },
  { l: 'Tell a counsellor I cannot say it', d: 'Send a one-line note. A counsellor reaches out within 4 hours. You set the next step.', cta: 'Send a quiet note', kind: 'quiet' },
];
---

<BaseLayout title="Wellness Quarter · Campus · AquinTutor" description="Confidential 1:1 counselling, daily yoga and meditation, chronobiology-based sleep coaching, 18 sports clubs and 12 esports leagues. The Wellness Quarter tracks wellbeing alongside grades.">

<style>
  body { background: #FAF8F5; color: #0E0B08; font-family: 'Inter', system-ui, sans-serif; }
  .wq-wrap { max-width: 1280px; margin: 0 auto; }
  .wq-section { padding: 60px 5vw; border-bottom: 1px solid rgba(14,11,8,0.10); }
  .wq-hero { padding: 70px 5vw 50px; position: relative; overflow: hidden; }
  .wq-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .wq-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 7vw, 84px); font-weight: 600; letter-spacing: -0.035em; line-height: 1.02; margin: 14px 0 18px; color: #0E0B08; }
  .wq-title em { color: #FF4F00; font-weight: 500; font-style: italic; }
  .wq-sub { font-size: 17px; line-height: 1.7; color: #2E2520; max-width: 720px; margin: 0 0 26px; }
  .wq-h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 4vw, 44px); font-weight: 600; letter-spacing: -0.025em; line-height: 1.1; margin: 0 0 8px; color: #0E0B08; }
  .wq-h2 em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .wq-kicker { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin-bottom: 10px; }
  .wq-lead { font-size: 16px; line-height: 1.7; color: #2E2520; max-width: 680px; }

  .wq-stats { display: grid; grid-template-columns: repeat(6, 1fr); gap: 0; border-top: 1px solid rgba(14,11,8,0.10); border-bottom: 1px solid rgba(14,11,8,0.10); }
  @media (max-width: 880px) { .wq-stats { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 480px) { .wq-stats { grid-template-columns: repeat(2, 1fr); } }
  .wq-stat { padding: 22px 18px; border-right: 1px solid rgba(14,11,8,0.10); }
  .wq-stat:last-child { border-right: none; }
  .wq-stat-val { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 600; color: #0E0B08; letter-spacing: -0.02em; }
  .wq-stat-lbl { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #7A6F68; margin-top: 6px; line-height: 1.4; }

  .wq-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 22px; }

  .wq-btn { display: inline-flex; align-items: center; gap: 8px; background: #FF4F00; color: #fff; padding: 13px 26px; border-radius: 10px; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; border: none; cursor: pointer; text-decoration: none; transition: transform 0.12s, box-shadow 0.12s; }
  .wq-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(255,79,0,0.28); }
  .wq-btn.ghost { background: transparent; color: #0E0B08; border: 1px solid rgba(14,11,8,0.20); }
  .wq-btn.ghost:hover { box-shadow: 0 6px 18px rgba(14,11,8,0.10); }

  .wq-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
  @media (max-width: 900px) { .wq-grid-2 { grid-template-columns: 1fr; } }
  .wq-grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  @media (max-width: 900px) { .wq-grid-3 { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .wq-grid-3 { grid-template-columns: 1fr; } }
  .wq-grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
  @media (max-width: 900px) { .wq-grid-4 { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 540px) { .wq-grid-4 { grid-template-columns: 1fr; } }

  /* COUNSELLING FORM */
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin: 12px 0; }
  @media (max-width: 700px) { .form-row { grid-template-columns: 1fr; } }
  .form-lbl { display: block; font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase; color: #5C504A; font-weight: 700; margin-bottom: 6px; }
  .form-inp, .form-sel, .form-area { width: 100%; background: #FAF8F5; border: 1px solid rgba(14,11,8,0.16); border-radius: 10px; padding: 12px 14px; font-family: 'Inter', sans-serif; font-size: 14px; color: #0E0B08; transition: border-color 0.12s, background 0.12s; }
  .form-inp:focus, .form-sel:focus, .form-area:focus { outline: none; border-color: #FF4F00; background: #fff; }
  .form-area { min-height: 84px; resize: vertical; line-height: 1.5; }
  .anon-toggle { display: flex; align-items: center; gap: 10px; padding: 12px 14px; background: #FAF8F5; border: 1px solid rgba(14,11,8,0.16); border-radius: 10px; cursor: pointer; user-select: none; }
  .anon-toggle input { accent-color: #FF4F00; width: 18px; height: 18px; }
  .anon-note { font-size: 12.5px; color: #5C504A; line-height: 1.55; }

  /* SLOT PICKER */
  .slot-cal { background: #FAF8F5; border: 1px solid rgba(14,11,8,0.10); border-radius: 12px; padding: 14px; }
  .slot-days { display: flex; gap: 6px; overflow-x: auto; padding-bottom: 6px; margin-bottom: 12px; }
  .slot-day { flex: 0 0 auto; padding: 9px 12px; background: #fff; border: 1px solid rgba(14,11,8,0.12); border-radius: 10px; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11px; color: #2E2520; transition: background 0.12s, color 0.12s, border-color 0.12s; }
  .slot-day:hover { border-color: #FF4F00; }
  .slot-day.sel { background: #0E0B08; color: #fff; border-color: #0E0B08; }
  .slot-hours { display: grid; grid-template-columns: repeat(5, 1fr); gap: 6px; }
  @media (max-width: 560px) { .slot-hours { grid-template-columns: repeat(3, 1fr); } }
  .slot-hr { padding: 9px 8px; text-align: center; background: #fff; border: 1px solid rgba(14,11,8,0.12); border-radius: 8px; font-family: 'Geist Mono', monospace; font-size: 11.5px; color: #2E2520; cursor: pointer; transition: background 0.12s, color 0.12s, border-color 0.12s; }
  .slot-hr:hover { border-color: #FF4F00; }
  .slot-hr.sel { background: #FF4F00; color: #fff; border-color: #FF4F00; }
  .slot-summary { margin-top: 12px; padding: 10px 12px; background: rgba(255,79,0,0.06); border: 1px solid rgba(255,79,0,0.16); border-radius: 8px; font-family: 'Geist Mono', monospace; font-size: 11px; color: #FF4F00; min-height: 18px; }

  /* YOGA SCHEDULE */
  .yoga-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 14px; }
  .yoga-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 12px; padding: 16px 18px; position: relative; transition: transform 0.12s, box-shadow 0.12s; }
  .yoga-card:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(14,11,8,0.08); }
  .yoga-bar { position: absolute; left: 0; top: 0; bottom: 0; width: 4px; border-radius: 12px 0 0 12px; }
  .yoga-time { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.1em; color: #7A6F68; font-weight: 700; }
  .yoga-name { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; letter-spacing: -0.015em; line-height: 1.15; margin: 4px 0 8px; }
  .yoga-meta { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px; }
  .yoga-tag { font-family: 'Geist Mono', monospace; font-size: 9.5px; padding: 3px 8px; background: rgba(14,11,8,0.06); color: #2E2520; border-radius: 999px; letter-spacing: 0.04em; text-transform: uppercase; font-weight: 700; }
  .yoga-who { font-size: 13px; color: #5C504A; margin-top: 4px; }
  .yoga-filter-row { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 18px; }
  .yoga-chip { padding: 8px 14px; background: #fff; border: 1px solid rgba(14,11,8,0.12); border-radius: 999px; font-family: 'Geist Mono', monospace; font-size: 11px; color: #2E2520; cursor: pointer; transition: background 0.12s, color 0.12s, border-color 0.12s; letter-spacing: 0.04em; }
  .yoga-chip:hover { border-color: #FF4F00; }
  .yoga-chip.on { background: #0E0B08; color: #fff; border-color: #0E0B08; }

  /* SPORTS GRID */
  .sport-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 12px; padding: 18px; display: flex; flex-direction: column; gap: 10px; transition: transform 0.12s, box-shadow 0.12s; }
  .sport-card:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(14,11,8,0.08); }
  .sport-ic { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; background: rgba(14,11,8,0.06); color: #0E0B08; }
  .sport-name { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; letter-spacing: -0.015em; }
  .sport-meta { font-size: 13px; color: #5C504A; line-height: 1.5; }
  .sport-row { display: flex; justify-content: space-between; align-items: center; gap: 8px; padding-top: 8px; border-top: 1px solid rgba(14,11,8,0.08); font-family: 'Geist Mono', monospace; font-size: 10.5px; color: #7A6F68; text-transform: uppercase; letter-spacing: 0.06em; }
  .sport-row b { color: #0E0B08; font-weight: 700; }

  /* RADAR */
  .radar-wrap { display: grid; grid-template-columns: 1.1fr 1fr; gap: 28px; align-items: center; }
  @media (max-width: 880px) { .radar-wrap { grid-template-columns: 1fr; } }
  .radar-svg { width: 100%; max-width: 460px; aspect-ratio: 1; display: block; margin: 0 auto; }
  .radar-axis { stroke: rgba(14,11,8,0.18); stroke-width: 1; }
  .radar-ring { fill: none; stroke: rgba(14,11,8,0.10); stroke-width: 1; }
  .radar-fill { fill: rgba(255,79,0,0.18); stroke: #FF4F00; stroke-width: 2; stroke-linejoin: round; }
  .radar-dot { fill: #FF4F00; }
  .radar-lbl { font-family: 'Geist Mono', monospace; font-size: 10.5px; fill: #2E2520; text-anchor: middle; letter-spacing: 0.08em; }

  .pillar { display: grid; grid-template-columns: 36px 1fr; gap: 12px; padding: 12px 0; border-bottom: 1px dashed rgba(14,11,8,0.10); }
  .pillar:last-child { border-bottom: none; }
  .pillar-letter { width: 36px; height: 36px; border-radius: 8px; background: #FFEFE6; color: #FF4F00; display: flex; align-items: center; justify-content: center; font-family: 'Cormorant Garamond', serif; font-weight: 700; font-size: 18px; }
  .pillar-name { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; }
  .pillar-body { font-size: 13.5px; color: #2E2520; line-height: 1.55; margin-top: 2px; }

  /* SLEEP COACHING */
  .sleep-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 28px; }
  @media (max-width: 880px) { .sleep-grid { grid-template-columns: 1fr; } }
  .sleep-step { display: grid; grid-template-columns: 48px 1fr; gap: 14px; padding: 16px 0; border-bottom: 1px solid rgba(14,11,8,0.08); }
  .sleep-step:last-child { border-bottom: none; }
  .sleep-num { font-family: 'Geist Mono', monospace; font-size: 14px; color: #FF4F00; font-weight: 800; letter-spacing: 0.06em; }
  .sleep-title { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; letter-spacing: -0.015em; margin-bottom: 4px; }
  .sleep-body { font-size: 14px; color: #2E2520; line-height: 1.6; }

  /* CRISIS BANNER */
  .crisis { background: linear-gradient(135deg, #2a1208, #0E0B08); color: #fff; border-radius: 18px; padding: 36px 32px; position: relative; overflow: hidden; }
  .crisis::before { content: ''; position: absolute; right: -120px; top: -120px; width: 320px; height: 320px; border-radius: 50%; background: radial-gradient(circle, rgba(255,79,0,0.30), transparent 70%); pointer-events: none; }
  .crisis-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF8A5C; font-weight: 700; }
  .crisis-h { font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 4vw, 44px); font-weight: 600; letter-spacing: -0.025em; line-height: 1.1; margin: 10px 0 12px; color: #fff; }
