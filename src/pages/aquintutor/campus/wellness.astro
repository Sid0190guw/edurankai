---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

function rows(r: any) { return Array.isArray(r) ? r : (r?.rows || []); }

// Self-bootstrap counselling_requests table
try {
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS counselling_requests (
      id           uuid PRIMARY KEY DEFAULT gen_random_uuid(),
      anonymous    boolean NOT NULL DEFAULT true,
      display_name text,
      contact      text,
      language     text NOT NULL DEFAULT 'English',
      topic        text,
      urgency      text NOT NULL DEFAULT 'standard',
      preferred_slot timestamptz,
      notes        text,
      status       text NOT NULL DEFAULT 'pending',
      created_at   timestamptz NOT NULL DEFAULT now()
    )
  `);
} catch (_) {}

try {
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS sleep_program_signups (
      id           uuid PRIMARY KEY DEFAULT gen_random_uuid(),
      display_name text,
      contact      text,
      timezone     text,
      chronotype   text,
      bedtime      text,
      waketime     text,
      goals        text,
      created_at   timestamptz NOT NULL DEFAULT now()
    )
  `);
} catch (_) {}

// Counts (defensive, default to zeros if table missing)
let counsellingCount = 0;
let sleepCount = 0;
try {
  const a = rows(await db.execute(sql`SELECT count(*)::int AS n FROM counselling_requests`));
  counsellingCount = Number(a?.[0]?.n || 0);
} catch (_) {}
try {
  const b = rows(await db.execute(sql`SELECT count(*)::int AS n FROM sleep_program_signups`));
  sleepCount = Number(b?.[0]?.n || 0);
} catch (_) {}

