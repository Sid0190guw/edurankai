              <!-- rings -->
              {[1, 2, 3, 4, 5].map(r => (
                <circle class="radar-ring" cx="0" cy="0" r={r * 40} />
              ))}
              <!-- axes & labels -->
              {radarAxes.map((a, i) => {
                const angle = -Math.PI / 2 + (i * 2 * Math.PI) / radarAxes.length;
                const x = Math.cos(angle) * 200;
                const y = Math.sin(angle) * 200;
                const lx = Math.cos(angle) * 232;
                const ly = Math.sin(angle) * 232;
                return (
                  <g>
                    <line class="radar-axis" x1="0" y1="0" x2={x} y2={y} />
                    <text class="radar-lbl" x={lx} y={ly + 4}>{a.label.toUpperCase()}</text>
                  </g>
                );
              })}
              <!-- filled polygon -->
              <polygon class="radar-fill" points={radarAxes.map((a, i) => {
                const angle = -Math.PI / 2 + (i * 2 * Math.PI) / radarAxes.length;
                const r = (a.value / 5) * 200;
                return `${(Math.cos(angle) * r).toFixed(1)},${(Math.sin(angle) * r).toFixed(1)}`;
              }).join(' ')} />
              <!-- dots -->
              {radarAxes.map((a, i) => {
                const angle = -Math.PI / 2 + (i * 2 * Math.PI) / radarAxes.length;
                const r = (a.value / 5) * 200;
                return (<circle class="radar-dot" cx={Math.cos(angle) * r} cy={Math.sin(angle) * r} r="5" />);
              })}
            </svg>
          </div>

          <div>
            <div class="wq-kicker" style="margin-bottom:14px;">Seven axes &middot; weighting</div>
            {wellbeingPillars.map(p => (
              <div class="pillar">
                <div class="pillar-letter">{p.letter}</div>
                <div>
                  <div class="pillar-name">{p.name}</div>
                  <div class="pillar-body">{p.body}</div>
                </div>
              </div>
            ))}
            <div style="margin-top:14px; padding:12px 14px; background:#FFEFE6; border-radius:10px; font-size:13px; color:#2E2520; line-height:1.55;">
              <b style="font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.08em; text-transform:uppercase; color:#FF4F00;">Privacy note &middot;</b>
              The radar is stored under a self-token. Faculty and assessors cannot see it. We may show <em>aggregate, anonymised</em> cohort trends, never individual ones.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CRISIS -->
  <section id="crisis" class="wq-section" style="border-bottom:none;">
    <div class="wq-wrap">
      <div class="crisis">
        <div class="crisis-eye">06 &middot; Crisis support &middot; always on</div>
        <h2 class="crisis-h">If tonight is hard, <em>we are here right now</em>.</h2>
        <p class="crisis-sub">
          A real human answers within ninety seconds. Six languages live. You do not need an account; you do not need to identify yourself. If calling feels like too much, text the same line and the same team responds.
        </p>
        <div class="crisis-row">
          {crisisOptions.map(c => (
            <div class="crisis-card">
              <h4>{c.l}</h4>
              <p>{c.d}</p>
              <button type="button" class="crisis-btn" data-crisis={c.kind}>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                {c.cta}
              </button>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</main>

<div class="toast" id="toast">Saved.</div>

<script is:inline define:vars={{ slotDays, slotHours }}>
(() => {
  // ========== Toast ==========
  const toast = document.getElementById('toast');
  function showToast(msg) {
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 2600);
  }

  // ========== Anonymous toggle ==========
  const anonChk = document.getElementById('anonChk');
  const cName = document.getElementById('cName');
  if (anonChk && cName) {
    anonChk.addEventListener('change', () => {
      if (anonChk.checked) {
        cName.value = '';
        cName.disabled = true;
        cName.placeholder = 'Leave blank to stay anonymous';
      } else {
        cName.disabled = false;
        cName.placeholder = 'Name or handle you choose';
        cName.focus();
      }
    });
  }

  // ========== Urgency buttons ==========
  document.querySelectorAll('.urgency-btn').forEach(b => {
    b.addEventListener('click', () => {
      document.querySelectorAll('.urgency-btn').forEach(x => x.classList.remove('on', 'urgent'));
      b.classList.add('on');
      if (b.getAttribute('data-urg') === 'urgent') b.classList.add('urgent');
    });
  });

  // ========== Slot picker ==========
  let selDay = slotDays[0]?.iso || '';
  let selHour = '';
  const slotSummary = document.getElementById('slotSummary');

  function refreshSummary() {
    if (!slotSummary) return;
    if (selDay && selHour) {
      const dObj = slotDays.find(d => d.iso === selDay);
      slotSummary.textContent = `Selected · ${dObj ? dObj.label : selDay} at ${selHour} IST`;
    } else {
      slotSummary.textContent = 'Pick a date and an hour above.';
    }
  }

  document.querySelectorAll('#slotDays .slot-day').forEach(d => {
    d.addEventListener('click', () => {
      document.querySelectorAll('#slotDays .slot-day').forEach(x => x.classList.remove('sel'));
      d.classList.add('sel');
      selDay = d.getAttribute('data-iso') || '';
      refreshSummary();
    });
  });
  document.querySelectorAll('#slotHours .slot-hr').forEach(h => {
    h.addEventListener('click', () => {
      document.querySelectorAll('#slotHours .slot-hr').forEach(x => x.classList.remove('sel'));
      h.classList.add('sel');
      selHour = h.getAttribute('data-hr') || '';
      refreshSummary();
    });
  });

  // ========== Counselling form ==========
  const cForm = document.getElementById('counsellingForm');
  if (cForm) {
    cForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const anon = anonChk ? anonChk.checked : true;
      const name = anon ? '' : (cName ? cName.value.trim() : '');
      const contact = document.getElementById('cContact')?.value.trim() || '';
      const lang = document.getElementById('cLang')?.value || 'English';
      const topic = document.getElementById('cTopic')?.value || '';
      const notes = document.getElementById('cNotes')?.value.trim() || '';
      const urg = document.querySelector('.urgency-btn.on')?.getAttribute('data-urg') || 'standard';
      if (!selDay || !selHour) {
        showToast('Pick a date and an hour first.');
        return;
      }
      try {
        const res = await fetch('/api/aquintutor/wellness/counselling', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            anonymous: anon, display_name: name, contact, language: lang,
            topic, urgency: urg, preferred_slot: `${selDay}T${selHour}:00+05:30`, notes
          })
        });
        if (res.ok) {
          showToast('Request sent. A counsellor will confirm within an hour.');
          cForm.reset();
          if (anonChk) anonChk.checked = true;
          if (cName) { cName.disabled = true; cName.value = ''; }
          document.querySelectorAll('.urgency-btn').forEach(x => x.classList.remove('on', 'urgent'));
          document.querySelector('.urgency-btn[data-urg="standard"]')?.classList.add('on');
          document.querySelectorAll('#slotHours .slot-hr').forEach(x => x.classList.remove('sel'));
          selHour = '';
          refreshSummary();
        } else {
          showToast('Could not send right now. Please try again.');
        }
      } catch (_) {
        showToast('Network hiccup. Try again in a moment.');
      }
    });
  }

  // ========== Sleep form ==========
  const sForm = document.getElementById('sleepForm');
  if (sForm) {
    sForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const payload = {
        display_name: document.getElementById('sName')?.value.trim() || '',
        contact: document.getElementById('sContact')?.value.trim() || '',
        timezone: document.getElementById('sTz')?.value || '',
        chronotype: document.getElementById('sChrono')?.value || '',
        bedtime: document.getElementById('sBed')?.value || '',
        waketime: document.getElementById('sWake')?.value || '',
        goals: document.getElementById('sGoals')?.value.trim() || ''
      };
      if (!payload.contact) {
        showToast('Add an email or phone so your coach can reach you.');
        return;
      }
      try {
        const res = await fetch('/api/aquintutor/wellness/sleep-signup', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload)
        });
        if (res.ok) {
          showToast('Signed up. We will email your sleep diary today.');
          sForm.reset();
        } else {
          showToast('Could not sign up right now. Try again.');
        }
      } catch (_) {
        showToast('Network hiccup. Try again in a moment.');
      }
    });
  }

  // ========== Yoga filter ==========
  document.querySelectorAll('#yogaFilters .yoga-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('#yogaFilters .yoga-chip').forEach(x => x.classList.remove('on'));
      chip.classList.add('on');
      const filter = chip.getAttribute('data-school') || 'all';
      document.querySelectorAll('#yogaGrid .yoga-card').forEach(card => {
        const s = card.getAttribute('data-school') || '';
        card.style.display = (filter === 'all' || s === filter) ? '' : 'none';
      });
    });
  });

  // ========== Crisis buttons ==========
  document.querySelectorAll('[data-crisis]').forEach(b => {
    b.addEventListener('click', () => {
      const kind = b.getAttribute('data-crisis');
      if (kind === 'call') {
        showToast('Connecting · 24/7 crisis line · please hold.');
      } else if (kind === 'text') {
        showToast('Text-line opening. A counsellor will message you in under 2 minutes.');
      } else {
        showToast('Note sent. A counsellor will reach out within 4 hours.');
      }
    });
  });
})();
</script>

</BaseLayout>
