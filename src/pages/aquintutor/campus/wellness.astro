  { t: '21:00', name: 'Meditation: Loving-Kindness', who: 'Coach M.', level: 'All levels', mins: 20, lang: 'EN', school: 'Mindfulness', tone: '#4a7048' },
  { t: '22:30', name: 'Sleep-Prep Body Scan', who: 'Coach Y.', level: 'All levels', mins: 20, lang: 'EN', school: 'Nidra', tone: '#3d6b76' },
