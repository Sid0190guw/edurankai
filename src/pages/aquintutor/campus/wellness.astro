  { name: 'Football', members: 412, sessions: '4× weekly', tone: '#4a7048' },
  { name: 'Cricket', members: 286, sessions: '3× weekly', tone: '#946322' },
  { name: 'Tennis', members: 158, sessions: 'Daily court slots', tone: '#5b4a92' },
