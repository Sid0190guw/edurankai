  { name: 'Karate', members: 138, sessions: '3× weekly', tone: '#946322' },
  { name: 'Judo', members: 86, sessions: '2× weekly', tone: '#5b4a92' },
  { name: 'Kalaripayattu', members: 64, sessions: '2× weekly', tone: '#a8472c' },
