    </div>
  </section>

  <!-- ATLAS PROCTORING -->
  <section class="tc-section">
    <div class="tc-sec-top">
      <div>
        <div class="tc-sec-eye">Integrity envelope &middot; ATLAS proctoring</div>
        <h2 class="tc-sec-title">Four layers of <em>quiet enforcement</em>.</h2>
        <p class="tc-sec-sub">Every session is wrapped in ATLAS. Findings are advisory — flags go to a human reviewer, never to automated penalty. Read the full spec at <a href="/aquintutor/exams" style="color:#FF4F00;">/products/atlas-proctoring</a>.</p>
      </div>
    </div>

