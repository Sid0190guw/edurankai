      <div class="tc-atlas-card">
        <div class="tc-atlas-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21v-2a4 4 0 0 1 4-4h8a4 4 0 0 1 4 4v2"/></svg>
        </div>
        <h3 class="tc-atlas-h">Identity verification</h3>
