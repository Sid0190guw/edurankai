---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

function rows(r: any) { return Array.isArray(r) ? r : (r?.rows || []); }

// Self-bootstrap the bookings table
try {
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS test_bookings (
      id SERIAL PRIMARY KEY,
      test_id TEXT NOT NULL,
      test_name TEXT,
      candidate_name TEXT NOT NULL,
      candidate_email TEXT,
      slot TIMESTAMP NOT NULL,
      special_accommodations TEXT,
      tier TEXT DEFAULT 'standard',
      status TEXT DEFAULT 'pending',
      created_at TIMESTAMP DEFAULT NOW()
    )
  `);
} catch (e) {
  // table exists or DB unavailable
}

// Pull current booking count for the strip
let bookingsToday = 0;
try {
  const r = await db.execute(sql`SELECT COUNT(*)::int AS c FROM test_bookings WHERE created_at > NOW() - INTERVAL '24 hours'`);
  bookingsToday = rows(r)[0]?.c || 0;
} catch (e) {}

