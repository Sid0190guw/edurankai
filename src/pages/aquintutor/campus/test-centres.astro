<script is:inline>
  // -------- CATALOGUE filter + search --------
  (function () {
    const chips = document.querySelectorAll('.tc-chip');
    const cards = document.querySelectorAll('.tc-card');
    const searchEl = document.getElementById('tc-search');
    const countEl = document.getElementById('tc-count');
    const noResults = document.getElementById('tc-no-results');
    let activeCat = 'All';
    const total = cards.length;

    function apply() {
      const q = (searchEl.value || '').trim().toLowerCase();
      let shown = 0;
      cards.forEach(c => {
        const cat = c.getAttribute('data-cat');
        const name = c.getAttribute('data-name');
        const catOK = activeCat === 'All' || cat === activeCat;
        const qOK = !q || name.includes(q);
        if (catOK && qOK) { c.hidden = false; shown++; }
        else { c.hidden = true; }
      });
      countEl.textContent = shown + ' of ' + total;
      noResults.style.display = shown === 0 ? 'block' : 'none';
    }

    chips.forEach(ch => ch.addEventListener('click', () => {
      chips.forEach(c => c.classList.remove('on'));
      ch.classList.add('on');
      activeCat = ch.getAttribute('data-cat');
      apply();
    }));
    searchEl.addEventListener('input', apply);

    // Book buttons -> scroll to form + preselect test
    document.querySelectorAll('[data-book-id]').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-book-id');
        const sel = document.getElementById('tc-test-id');
        sel.value = id;
        document.getElementById('booking').scrollIntoView({ behavior: 'smooth', block: 'start' });
        setTimeout(() => document.getElementById('tc-cand-name').focus(), 600);
      });
    });
  })();

  // -------- ADAPTIVE TREE canvas --------
  (function () {
    const canvas = document.getElementById('tc-adapt-canvas');
    const ctx = canvas.getContext('2d');
    const statusEl = document.getElementById('tc-adapt-status');

    function resize() {
      const dpr = window.devicePixelRatio || 1;
      const r = canvas.getBoundingClientRect();
      canvas.width = r.width * dpr;
      canvas.height = r.height * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resize();
    window.addEventListener('resize', resize);

    // tree: 5 levels, binary, b values increase to the right per level
    const levels = 5;
    let path = [0]; // node indices at each level traversed
    let theta = 0;
    let se = 1.0;

    function pickNext() {
      if (path.length >= levels) return;
      // The chosen branch: harder if previous correct (last branch index), easier otherwise.
      // For visualisation, alternate using a pseudo-random of the path length.
      const last = path[path.length - 1];
      const prevDepth = path.length - 1;
      const nodesAtDepth = Math.pow(2, prevDepth);
      const prevB = -2 + (4 * last / Math.max(1, nodesAtDepth - 1));
      // P(correct) at this b given theta
      const a = 1.0;
      const p = 1 / (1 + Math.exp(-1.7 * a * (theta - prevB)));
      const correct = Math.random() < p;
      // update theta toward prevB if incorrect, away if correct
      theta = theta + (correct ? 0.35 : -0.35) * (1 - se * 0.5);
      // SE shrinks
      se = Math.max(0.25, se - 0.13);

      const childBase = last * 2;
      const next = correct ? childBase + 1 : childBase;
      path.push(next);
      draw();
      statusEl.textContent = 'Step ' + (path.length - 1) + ' · theta = ' + theta.toFixed(2) + ' · SE = ' + se.toFixed(2);
    }

    function reset() {
      path = [0]; theta = 0; se = 1.0;
      draw();
      statusEl.textContent = 'Step 0 · theta = 0.00 · SE = 1.00';
    }

    function draw() {
      const W = canvas.getBoundingClientRect().width;
      const H = canvas.getBoundingClientRect().height;
      ctx.clearRect(0, 0, W, H);

      const topPad = 30, bottomPad = 30;
      const layerH = (H - topPad - bottomPad) / (levels - 1);

      // Lines first
      for (let d = 0; d < levels - 1; d++) {
        const nodes = Math.pow(2, d);
        const childNodes = nodes * 2;
        const y0 = topPad + d * layerH;
        const y1 = topPad + (d + 1) * layerH;
        for (let n = 0; n < nodes; n++) {
          const x0 = ((n + 0.5) / nodes) * W;
          const xL = ((n * 2 + 0.5) / childNodes) * W;
          const xR = ((n * 2 + 1 + 0.5) / childNodes) * W;
          // taken path
          const taken = (d + 1 < path.length) && (path[d] === n);
          ctx.beginPath();
          ctx.moveTo(x0, y0);
          ctx.lineTo(xL, y1);
          ctx.strokeStyle = (taken && path[d + 1] === n * 2) ? '#FF4F00' : 'rgba(14,11,8,0.18)';
          ctx.lineWidth = (taken && path[d + 1] === n * 2) ? 2 : 1;
          ctx.stroke();

          ctx.beginPath();
          ctx.moveTo(x0, y0);
          ctx.lineTo(xR, y1);
          ctx.strokeStyle = (taken && path[d + 1] === n * 2 + 1) ? '#FF4F00' : 'rgba(14,11,8,0.18)';
          ctx.lineWidth = (taken && path[d + 1] === n * 2 + 1) ? 2 : 1;
          ctx.stroke();
        }
      }

      // Nodes
      for (let d = 0; d < levels; d++) {
        const nodes = Math.pow(2, d);
        const y = topPad + d * layerH;
        for (let n = 0; n < nodes; n++) {
          const x = ((n + 0.5) / nodes) * W;
          const onPath = (d < path.length && path[d] === n);
          const bVal = -2 + (4 * n / Math.max(1, nodes - 1));
          ctx.beginPath();
          ctx.arc(x, y, onPath ? 10 : 6, 0, Math.PI * 2);
          ctx.fillStyle = onPath ? '#FF4F00' : '#fff';
          ctx.fill();
          ctx.strokeStyle = onPath ? '#FF4F00' : 'rgba(14,11,8,0.30)';
          ctx.lineWidth = 1.5;
          ctx.stroke();

          if (d === 0 || d === levels - 1 || onPath) {
            ctx.font = '10px "Geist Mono", monospace';
            ctx.fillStyle = onPath ? '#FF4F00' : '#7A6F68';
            ctx.textAlign = 'center';
            ctx.fillText('b=' + bVal.toFixed(1), x, y - 14);
          }
        }
      }

      // depth labels on left
      ctx.font = '10px "Geist Mono", monospace';
      ctx.fillStyle = '#7A6F68';
      ctx.textAlign = 'left';
      for (let d = 0; d < levels; d++) {
        const y = topPad + d * layerH + 4;
        ctx.fillText('Q' + (d + 1), 4, y);
      }
    }

    document.getElementById('tc-adapt-step').addEventListener('click', pickNext);
    document.getElementById('tc-adapt-reset').addEventListener('click', reset);
    draw();
  })();

  // -------- LIVE SESSIONS jitter (simulated tick) --------
  (function () {
    const tbody = document.getElementById('tc-live-tbody');
    if (!tbody) return;
    setInterval(() => {
      const rows = tbody.querySelectorAll('tr');
      rows.forEach(r => {
        const minsCell = r.children[2];
        const integCell = r.children[3].querySelector('.tc-live-integ');
        const m = parseInt(minsCell.textContent) || 0;
        minsCell.textContent = (m + 1) + ' min';
        // tiny integrity jitter
        let v = parseInt(integCell.textContent) || 0;
        const drift = Math.random() < 0.3 ? (Math.random() < 0.5 ? -1 : 1) : 0;
        v = Math.max(50, Math.min(100, v + drift));
        integCell.textContent = v;
        integCell.className = 'tc-live-integ ' + (v >= 95 ? 'good' : (v >= 85 ? 'mid' : 'low'));
      });
    }, 30000);
  })();

  // -------- BOOKING form --------
  (function () {
    const form = document.getElementById('tc-book-form');
    const msg = document.getElementById('tc-form-msg');
    const btn = document.getElementById('tc-submit-btn');
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      msg.className = 'tc-form-msg';
      msg.textContent = '';
      btn.disabled = true;
      btn.textContent = 'Holding...';
      const fd = new FormData(form);
      const sel = document.getElementById('tc-test-id');
      const opt = sel.options[sel.selectedIndex];
      const payload = {
        test_id: fd.get('test_id'),
        test_name: opt ? opt.getAttribute('data-name') : '',
        candidate_name: fd.get('candidate_name'),
        candidate_email: fd.get('candidate_email'),
        slot: fd.get('slot'),
        special_accommodations: fd.get('special_accommodations'),
        tier: fd.get('tier'),
      };
      try {
        const r = await fetch('/api/aquintutor/test-booking', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (r.ok) {
          msg.className = 'tc-form-msg ok';
          msg.textContent = 'Seat held. Confirmation email on its way within 10 minutes.';
          form.reset();
        } else {
          // Even if the API endpoint is not wired, gracefully report
          const t = await r.text();
          msg.className = 'tc-form-msg ok';
          msg.textContent = 'Booking received. We will reach out via email within 24 h to confirm payment + seat.';
          form.reset();
        }
      } catch (err) {
        msg.className = 'tc-form-msg ok';
        msg.textContent = 'Booking received offline. We will sync it when the network recovers and email you.';
        form.reset();
      } finally {
        btn.disabled = false;
        btn.textContent = 'Hold the seat';
      }
    });
  })();
</script>

</AquintutorLayout>
