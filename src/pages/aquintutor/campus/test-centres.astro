---
<AquintutorLayout title="Test centres · Campus district · AquinTutor" description="148 testing systems: language proficiency, higher-ed entry, professional licensure, aptitude and subject mastery — all run through ATLAS proctoring with adaptive routing.">

<style>
  body { background: #FAF8F5; color: #0E0B08; }
  .tc-wrap { max-width: 1280px; margin: 0 auto; }
  .tc-hero { padding: 80px 5vw 50px; }
  .tc-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .tc-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 7vw, 84px); font-weight: 600; letter-spacing: -0.035em; line-height: 1.02; margin: 14px 0 18px; }
  .tc-title em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .tc-sub { font-size: 17px; color: #2E2520; max-width: 720px; line-height: 1.7; }

  .tc-stats { border-top: 1px solid rgba(14,11,8,0.10); border-bottom: 1px solid rgba(14,11,8,0.10); display: grid; grid-template-columns: repeat(6, 1fr); padding: 22px 5vw; max-width: 1280px; margin: 0 auto; gap: 14px; }
  @media (max-width: 820px) { .tc-stats { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 480px) { .tc-stats { grid-template-columns: repeat(2, 1fr); } }
  .tc-stat-val { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 600; letter-spacing: -0.02em; }
  .tc-stat-lbl { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #7A6F68; margin-top: 4px; }

  .tc-section { padding: 65px 5vw; border-bottom: 1px solid rgba(14,11,8,0.10); max-width: 1280px; margin: 0 auto; }
  .tc-sec-top { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 12px; margin-bottom: 24px; }
  .tc-sec-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .tc-sec-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 4.5vw, 44px); font-weight: 600; letter-spacing: -0.025em; margin: 6px 0 0; }
  .tc-sec-title em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .tc-sec-sub { font-size: 15.5px; color: #2E2520; max-width: 580px; line-height: 1.65; margin-top: 6px; }

  /* Catalogue */
  .tc-filter-bar { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 22px; align-items: center; }
  .tc-chip { background: #FAF8F5; border: 1px solid rgba(14,11,8,0.16); padding: 9px 16px; border-radius: 999px; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11.5px; letter-spacing: 0.06em; text-transform: uppercase; color: #2E2520; font-weight: 700; transition: all 0.15s; }
  .tc-chip:hover { border-color: #FF4F00; color: #FF4F00; }
  .tc-chip.on { background: #0E0B08; color: #fff; border-color: #0E0B08; }
  .tc-search { background: #fff; border: 1px solid rgba(14,11,8,0.16); padding: 11px 16px; border-radius: 10px; font-family: inherit; font-size: 14px; min-width: 280px; color: #0E0B08; }
  .tc-search:focus { outline: 2px solid #FF4F00; outline-offset: -1px; border-color: transparent; }
  .tc-count-pill { font-family: 'Geist Mono', monospace; font-size: 11px; color: #7A6F68; margin-left: auto; letter-spacing: 0.08em; text-transform: uppercase; }

  .tc-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 14px; }
  .tc-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 22px; display: flex; flex-direction: column; gap: 10px; transition: transform 0.12s, border-color 0.12s; position: relative; }
  .tc-card:hover { transform: translateY(-2px); border-color: rgba(14,11,8,0.25); }
  .tc-card[hidden] { display: none; }
  .tc-card-cat { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .tc-card-name { font-family: 'Cormorant Garamond', serif; font-size: 21px; font-weight: 600; letter-spacing: -0.02em; line-height: 1.2; color: #0E0B08; }
  .tc-card-desc { font-size: 13.5px; color: #4A4038; line-height: 1.55; }
  .tc-card-meta { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 4px; }
  .tc-meta-pill { font-family: 'Geist Mono', monospace; font-size: 10.5px; padding: 4px 10px; border-radius: 999px; background: #FAF8F5; border: 1px solid rgba(14,11,8,0.10); color: #2E2520; letter-spacing: 0.04em; }
  .tc-meta-pill.adapt { background: rgba(255,79,0,0.08); border-color: rgba(255,79,0,0.30); color: #FF4F00; font-weight: 700; }
  .tc-card-foot { display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 14px; border-top: 1px dashed rgba(14,11,8,0.10); }
  .tc-card-fee { font-family: 'Geist Mono', monospace; font-size: 12px; color: #2E2520; }
  .tc-card-fee strong { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; letter-spacing: -0.01em; color: #0E0B08; }
  .tc-book-btn { background: #FF4F00; color: #fff; padding: 10px 18px; border-radius: 8px; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; border: none; cursor: pointer; }
  .tc-book-btn:hover { background: #d94300; }
  .tc-no-results { padding: 40px; text-align: center; font-family: 'Cormorant Garamond', serif; font-size: 22px; color: #7A6F68; grid-column: 1 / -1; }

  /* ATLAS grid */
  .tc-atlas-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
  @media (max-width: 920px) { .tc-atlas-grid { grid-template-columns: repeat(2, 1fr); } }
