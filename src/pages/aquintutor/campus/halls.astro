---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

function rows(r: any) { return Array.isArray(r) ? r : (r?.rows || []); }

// Self-bootstrap hall_bookings table
try {
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS hall_bookings (
      id SERIAL PRIMARY KEY,
      hall_id TEXT NOT NULL,
      organiser TEXT NOT NULL,
      booking_date DATE NOT NULL,
      slot TEXT NOT NULL,
      purpose TEXT NOT NULL,
      expected_attendance INTEGER NOT NULL DEFAULT 0,
      created_at TIMESTAMPTZ DEFAULT NOW()
    )
  `);
} catch (e) { /* ignore bootstrap errors */ }

// Handle form POST
let bookingSuccess = false;
let bookingError = '';
if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();
    const hall_id = String(form.get('hall_id') || '').trim();
    const organiser = String(form.get('organiser') || '').trim();
    const booking_date = String(form.get('booking_date') || '').trim();
    const slot = String(form.get('slot') || '').trim();
    const purpose = String(form.get('purpose') || '').trim();
    const expected_attendance = parseInt(String(form.get('expected_attendance') || '0'), 10) || 0;
    if (hall_id && organiser && booking_date && slot && purpose) {
      await db.execute(sql`
        INSERT INTO hall_bookings (hall_id, organiser, booking_date, slot, purpose, expected_attendance)
        VALUES (${hall_id}, ${organiser}, ${booking_date}, ${slot}, ${purpose}, ${expected_attendance})
      `);
      bookingSuccess = true;
    } else {
      bookingError = 'Please fill in every required field.';
    }
  } catch (e: any) {
    bookingError = 'Could not record booking. Please retry.';
  }
}

// Recent bookings
let recentBookings: any[] = [];
try {
  const r = await db.execute(sql`SELECT * FROM hall_bookings ORDER BY created_at DESC LIMIT 6`);
  recentBookings = rows(r);
} catch (e) { recentBookings = []; }

// Live now (mock data — minutes-ago computed on client)
const liveNow = [
  { id: 1, cat: 'Quantum', title: 'Many-body entanglement and tensor networks', faculty: 'Lead faculty', attendees: 412, mins: 14, hall: 'Bhaskara Hall' },
  { id: 2, cat: 'Philosophy', title: 'Phenomenology of attention in classical Indic darshana', faculty: 'Lead faculty', attendees: 268, mins: 32, hall: 'Hypatia Hall' },
  { id: 3, cat: 'Law', title: 'Comparative constitutional design for plurinational states', faculty: 'Lead faculty', attendees: 521, mins: 9, hall: 'Vidya Hall' },
  { id: 4, cat: 'Medicine', title: 'Single-cell atlases of the developing cortex', faculty: 'Lead faculty', attendees: 188, mins: 21, hall: 'Sushruta Hall' },
  { id: 5, cat: 'Arts', title: 'Material grammars of the Indus glyph', faculty: 'Lead faculty', attendees: 144, mins: 6, hall: 'Mira Hall' },
  { id: 6, cat: 'Mathematics', title: 'Geometric Langlands — a working seminar', faculty: 'Lead faculty', attendees: 96, mins: 47, hall: 'Ramanujan Hall' },
  { id: 7, cat: 'Computer Science', title: 'Compiler optimisations for sparse tensor kernels', faculty: 'Lead faculty', attendees: 305, mins: 18, hall: 'Turing Hall' },
  { id: 8, cat: 'Astronomy', title: 'Gravitational wave signatures from primordial black holes', faculty: 'Lead faculty', attendees: 227, mins: 3, hall: 'Aryabhata Hall' },
];

// Venues
const venues = [
  { id: 'vidya',     name: 'Vidya Hall',     cap: 800,  spec: 'Plenary keynotes, public lectures',          gear: ['Volumetric capture (32 cam)', 'Spatial audio 7.1.4', 'Hand tracking'],          layout: 'amphi' },
  { id: 'hypatia',   name: 'Hypatia Hall',   cap: 1200, spec: 'Philosophy, classical languages',            gear: ['Volumetric capture (28 cam)', 'Whisper-array audio', '6-DOF tracking'],          layout: 'amphi' },
  { id: 'bhaskara',  name: 'Bhaskara Hall',  cap: 600,  spec: 'Mathematics, theoretical physics',           gear: ['Volumetric capture (24 cam)', 'Chalkboard depth-scan', 'Spatial Q&A heatmap'],  layout: 'fan' },
  { id: 'sushruta',  name: 'Sushruta Hall',  cap: 420,  spec: 'Medicine, anatomy AR',                       gear: ['Volumetric capture (20 cam)', 'Body-rig motion capture', '4K loupe overlays'],   layout: 'theatre' },
  { id: 'mira',      name: 'Mira Hall',      cap: 280,  spec: 'Fine arts, poetry, music',                   gear: ['Cinematic capture (12 cam)', 'Ambisonic audio', 'Skylight bias rig'],            layout: 'studio' },
  { id: 'ramanujan', name: 'Ramanujan Hall', cap: 220,  spec: 'Pure mathematics seminars',                  gear: ['Volumetric capture (14 cam)', 'Live LaTeX overlay', 'Roundtable mic'],           layout: 'round' },
  { id: 'turing',    name: 'Turing Hall',    cap: 540,  spec: 'Computer science, systems',                  gear: ['Volumetric capture (22 cam)', 'Code overlay layer', 'Spatial Q&A'],              layout: 'fan' },
  { id: 'aryabhata', name: 'Aryabhata Hall', cap: 900,  spec: 'Astronomy, cosmology',                       gear: ['Planetarium dome', 'Volumetric capture (30 cam)', '12k starfield projector'],     layout: 'dome' },
  { id: 'ibnsina',   name: 'Ibn Sina Hall',  cap: 360,  spec: 'Medical ethics, public health',              gear: ['Volumetric capture (18 cam)', 'Multi-translation feed', 'Hand tracking'],        layout: 'theatre' },
  { id: 'gargi',     name: 'Gargi Hall',     cap: 460,  spec: 'Vedic sciences, Sanskrit philology',         gear: ['Volumetric capture (18 cam)', 'Manuscript loupe rig', 'Spatial Q&A'],            layout: 'amphi' },
  { id: 'kepler',    name: 'Kepler Hall',    cap: 720,  spec: 'Physics, optics, instruments',               gear: ['Volumetric capture (26 cam)', 'Laser-safe AR overlay', '6-DOF tracking'],        layout: 'amphi' },
  { id: 'maitreyi',  name: 'Maitreyi Hall',  cap: 340,  spec: 'Comparative literature, law moots',          gear: ['Cinematic capture (14 cam)', 'Bench-cam multi-angle', 'Live transcript wall'],   layout: 'court' },
];

// Mock calendar bookings — date-agnostic, indexed by (dayOffset, hour)
const calendarMock = [
  { day: 0, hour: 9,  duration: 2, hall: 'Vidya Hall',     title: 'Opening plenary' },
  { day: 0, hour: 14, duration: 1, hall: 'Bhaskara Hall',  title: 'Topology seminar' },
  { day: 1, hour: 10, duration: 2, hall: 'Hypatia Hall',   title: 'Phenomenology series' },
  { day: 1, hour: 15, duration: 1, hall: 'Turing Hall',    title: 'Systems reading group' },
  { day: 2, hour: 8,  duration: 1, hall: 'Aryabhata Hall', title: 'Dawn observation lab' },
  { day: 2, hour: 11, duration: 2, hall: 'Sushruta Hall',  title: 'Anatomy AR clinic' },
  { day: 2, hour: 16, duration: 1, hall: 'Mira Hall',      title: 'Poetry recital' },
  { day: 3, hour: 9,  duration: 1, hall: 'Ramanujan Hall', title: 'Number theory' },
  { day: 3, hour: 13, duration: 2, hall: 'Kepler Hall',    title: 'Optics demo' },
  { day: 3, hour: 17, duration: 1, hall: 'Gargi Hall',     title: 'Sanskrit recitation' },
  { day: 4, hour: 10, duration: 1, hall: 'Ibn Sina Hall',  title: 'Public health forum' },
  { day: 4, hour: 14, duration: 2, hall: 'Maitreyi Hall',  title: 'Moot court finals' },
  { day: 5, hour: 11, duration: 2, hall: 'Vidya Hall',     title: 'Keynote · climate' },
  { day: 5, hour: 16, duration: 1, hall: 'Hypatia Hall',   title: 'Ethics roundtable' },
  { day: 6, hour: 10, duration: 3, hall: 'Aryabhata Hall', title: 'Cosmology workshop' },
];
---
<BaseLayout title="Holographic Lecture Halls" description="Twenty-four holographic lecture halls. Volumetric capture, spatial Q&A, sub-30ms latency, replay in VR.">

<style>
  :root {
    --paper: #FAF8F5;
    --ink: #0E0B08;
    --ink-2: #2E2520;
    --muted: #7A6F68;
    --burn: #FF4F00;
    --line: rgba(14,11,8,0.10);
    --line-2: rgba(14,11,8,0.06);
    --white: #ffffff;
  }
  body { background: var(--paper); color: var(--ink); }
  .wrap { max-width: 1280px; margin: 0 auto; }

  /* Hero */
  .hero { padding: 80px 5vw 60px; }
  .eyebrow { font-family: 'Geist Mono', monospace; font-size: 11.5px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--burn); font-weight: 700; margin-bottom: 22px; display: inline-flex; align-items: center; gap: 10px; }
  .eyebrow .dot { width: 6px; height: 6px; background: var(--burn); border-radius: 50%; box-shadow: 0 0 0 4px rgba(255,79,0,0.18); animation: pulse 2.2s infinite ease-in-out; }
  @keyframes pulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.55; transform: scale(0.85); } }
  .title { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 7vw, 84px); font-weight: 600; letter-spacing: -0.035em; line-height: 1.02; margin: 0 0 22px; max-width: 980px; }
  .title em { font-style: italic; color: var(--burn); font-weight: 500; }
  .sub { font-size: 17px; color: var(--ink-2); max-width: 720px; line-height: 1.7; margin: 0; }

  /* Stat strip */
  .stats { padding: 28px 5vw; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .stats-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 24px; max-width: 1280px; margin: 0 auto; }
  .stat-val { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 600; color: var(--ink); letter-spacing: -0.02em; line-height: 1; }
  .stat-lbl { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-top: 8px; }
  @media (max-width: 800px) { .stats-grid { grid-template-columns: repeat(3, 1fr); row-gap: 28px; } }

  /* Section common */
  .section { padding: 70px 5vw; border-bottom: 1px solid var(--line); }
  .section-head { display: flex; align-items: end; justify-content: space-between; max-width: 1280px; margin: 0 auto 36px; gap: 24px; flex-wrap: wrap; }
  .section-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--burn); font-weight: 700; margin-bottom: 12px; }
  .section-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(30px, 4.5vw, 50px); font-weight: 600; letter-spacing: -0.025em; line-height: 1.05; margin: 0; max-width: 720px; }
  .section-title em { font-style: italic; color: var(--burn); font-weight: 500; }
  .section-aside { font-size: 14px; color: var(--muted); max-width: 320px; line-height: 1.55; }

  /* Live grid */
  .live-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; max-width: 1280px; margin: 0 auto; }
  .live-card { background: var(--white); border: 1px solid var(--line); border-radius: 14px; padding: 22px; display: flex; flex-direction: column; gap: 14px; transition: transform 0.18s ease, border-color 0.18s ease; }
  .live-card:hover { transform: translateY(-2px); border-color: rgba(14,11,8,0.22); }
  .chip { display: inline-flex; align-items: center; gap: 6px; padding: 5px 10px; border-radius: 999px; font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700; background: rgba(255,79,0,0.10); color: var(--burn); align-self: flex-start; }
  .chip .live-dot { width: 6px; height: 6px; background: var(--burn); border-radius: 50%; animation: pulse 1.6s infinite ease-in-out; }
  .live-title { font-family: 'Cormorant Garamond', serif; font-size: 21px; font-weight: 600; line-height: 1.25; letter-spacing: -0.01em; color: var(--ink); margin: 0; }
  .live-meta { font-size: 13px; color: var(--ink-2); display: flex; flex-direction: column; gap: 4px; }
  .live-meta b { font-weight: 600; color: var(--ink); }
  .live-bottom { display: flex; align-items: center; justify-content: space-between; margin-top: 4px; }
  .live-attendees { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--muted); letter-spacing: 0.04em; }
  .btn { background: var(--burn); color: #fff; padding: 11px 18px; border-radius: 10px; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; border: 0; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; transition: filter 0.15s ease; }
  .btn:hover { filter: brightness(1.08); }
  .btn-lg { padding: 14px 28px; font-size: 12px; }
  .btn-ghost { background: transparent; color: var(--ink); border: 1px solid var(--line); }
  .btn-ghost:hover { background: var(--ink); color: #fff; }

  /* Venues */
  .venue-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 18px; max-width: 1280px; margin: 0 auto; }
  .venue-card { background: var(--white); border: 1px solid var(--line); border-radius: 14px; padding: 24px; display: flex; flex-direction: column; gap: 16px; }
  .venue-head { display: flex; justify-content: space-between; align-items: start; gap: 16px; }
  .venue-name { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 600; letter-spacing: -0.015em; line-height: 1.1; margin: 0; }
  .venue-cap { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.08em; color: var(--muted); text-transform: uppercase; margin-top: 6px; }
  .venue-spec { font-size: 13.5px; color: var(--ink-2); line-height: 1.55; }
  .venue-layout-svg { width: 100%; height: 110px; background: #FCFAF7; border: 1px solid var(--line-2); border-radius: 8px; padding: 8px; }
  .gear-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 6px; }
  .gear-list li { display: flex; align-items: center; gap: 8px; font-size: 12.5px; color: var(--ink-2); }
  .gear-list svg { width: 14px; height: 14px; color: var(--burn); flex-shrink: 0; }

  /* Tech grid */
  .tech-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; max-width: 1280px; margin: 0 auto; }
  .tech-card { background: var(--white); border: 1px solid var(--line); border-radius: 14px; padding: 28px; display: flex; flex-direction: column; gap: 14px; }
  .tech-icon { width: 48px; height: 48px; border-radius: 12px; background: rgba(255,79,0,0.10); display: inline-flex; align-items: center; justify-content: center; color: var(--burn); }
  .tech-icon svg { width: 24px; height: 24px; }
  .tech-title { font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 600; line-height: 1.15; letter-spacing: -0.015em; margin: 0; }
  .tech-body { font-size: 14px; color: var(--ink-2); line-height: 1.65; margin: 0; }
  .tech-list { list-style: none; padding: 0; margin: 8px 0 0; display: flex; flex-direction: column; gap: 6px; font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--muted); letter-spacing: 0.03em; }
  .tech-list li:before { content: "—"; color: var(--burn); margin-right: 6px; }

  /* Booking */
  .booking-layout { display: grid; grid-template-columns: 1.2fr 0.9fr; gap: 28px; max-width: 1280px; margin: 0 auto; }
  @media (max-width: 900px) { .booking-layout { grid-template-columns: 1fr; } }
  .form-card { background: var(--white); border: 1px solid var(--line); border-radius: 14px; padding: 32px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
  @media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }
  .form-field { display: flex; flex-direction: column; gap: 6px; }
  .form-field.full { grid-column: 1 / -1; }
  label { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); font-weight: 700; }
  input, select, textarea { font-family: inherit; font-size: 14px; color: var(--ink); padding: 12px 14px; border: 1px solid var(--line); border-radius: 9px; background: #FCFAF7; outline: none; transition: border-color 0.15s ease; }
  input:focus, select:focus, textarea:focus { border-color: var(--burn); }
  textarea { resize: vertical; min-height: 90px; }
  .recent-card { background: var(--white); border: 1px solid var(--line); border-radius: 14px; padding: 24px; }
  .recent-title { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; margin: 0 0 16px; }
  .recent-item { display: flex; flex-direction: column; gap: 4px; padding: 12px 0; border-bottom: 1px solid var(--line-2); }
  .recent-item:last-child { border-bottom: none; }
  .recent-item .h { font-size: 14px; font-weight: 600; color: var(--ink); }
  .recent-item .m { font-family: 'Geist Mono', monospace; font-size: 10.5px; color: var(--muted); letter-spacing: 0.04em; }
  .ok-banner { background: rgba(20,150,80,0.08); border: 1px solid rgba(20,150,80,0.30); color: #145032; padding: 12px 16px; border-radius: 10px; font-size: 13.5px; margin-bottom: 18px; }
  .err-banner { background: rgba(200,40,40,0.08); border: 1px solid rgba(200,40,40,0.30); color: #8a1f1f; padding: 12px 16px; border-radius: 10px; font-size: 13.5px; margin-bottom: 18px; }

  /* Calendar */
  .cal-card { background: var(--white); border: 1px solid var(--line); border-radius: 14px; padding: 20px; max-width: 1280px; margin: 0 auto; overflow-x: auto; }
  .cal-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; flex-wrap: wrap; gap: 12px; }
  .cal-key { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; color: var(--muted); text-transform: uppercase; }
  .cal-grid { display: grid; grid-template-columns: 56px repeat(7, minmax(110px, 1fr)); border-top: 1px solid var(--line-2); border-left: 1px solid var(--line-2); }
  .cal-cell { border-right: 1px solid var(--line-2); border-bottom: 1px solid var(--line-2); height: 30px; position: relative; font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--muted); }
  .cal-cell.hour-lbl { display: flex; align-items: start; justify-content: end; padding: 4px 6px 0 0; height: 30px; background: #FCFAF7; }
  .cal-cell.day-head { display: flex; align-items: center; justify-content: center; height: 36px; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink); background: #FCFAF7; font-weight: 700; }
  .cal-cell.empty-corner { background: #FCFAF7; height: 36px; }
  .cal-event { position: absolute; left: 3px; right: 3px; top: 2px; background: var(--burn); color: #fff; border-radius: 6px; padding: 4px 6px; font-size: 10.5px; line-height: 1.2; overflow: hidden; cursor: pointer; box-shadow: 0 1px 0 rgba(0,0,0,0.05); }
  .cal-event b { display: block; font-family: 'Geist Mono', monospace; font-size: 9px; letter-spacing: 0.05em; text-transform: uppercase; font-weight: 700; opacity: 0.9; }
  .cal-event span { font-family: 'Cormorant Garamond', serif; font-size: 12.5px; font-weight: 600; }

  .closing { padding: 80px 5vw; text-align: center; }
  .closing h3 { font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 4vw, 44px); font-weight: 600; letter-spacing: -0.025em; margin: 0 0 14px; }
  .closing h3 em { font-style: italic; color: var(--burn); font-weight: 500; }
  .closing p { font-size: 15.5px; color: var(--ink-2); max-width: 540px; margin: 0 auto 26px; line-height: 1.7; }
</style>

<main>
  <!-- HERO -->
  <section class="hero wrap">
    <div class="eyebrow"><span class="dot"></span> Campus · District · Halls</div>
    <h1 class="title">Holographic <em>lecture halls</em>.</h1>
    <p class="sub">Twenty-four venues wired for volumetric capture, spatial audio, and sub-thirty-millisecond AR/VR delivery. Lectures stream live from physical rooms into a synthetic seat next to you — raise your hand from a paddyfield, a tea-shop, a hostel bunk; the rostrum sees the heatmap in real time.</p>
  </section>

  <!-- STAT STRIP -->
  <section class="stats">
    <div class="stats-grid">
      <div><div class="stat-val">24</div><div class="stat-lbl">Venues</div></div>
      <div><div class="stat-val">12,400</div><div class="stat-lbl">Combined capacity</div></div>
      <div><div class="stat-val" id="liveAttendees">2,140</div><div class="stat-lbl">Attending right now</div></div>
      <div><div class="stat-val">142</div><div class="stat-lbl">Volumetric cameras</div></div>
      <div><div class="stat-val">6-DOF</div><div class="stat-lbl">Tracking standard</div></div>
      <div><div class="stat-val">&lt;30 ms</div><div class="stat-lbl">End-to-end latency</div></div>
    </div>
  </section>

  <!-- LIVE NOW -->
  <section class="section">
    <div class="section-head">
      <div>
        <div class="section-eyebrow">Streaming this moment</div>
        <h2 class="section-title">Live <em>now</em>, across the halls.</h2>
      </div>
      <div class="section-aside">Eight of the venues are broadcasting at this instant. Join a stream and a synthetic seat — yours alone — is allocated inside the hall.</div>
    </div>
    <div class="live-grid">
      {liveNow.map(l => (
        <article class="live-card">
          <div style="display:flex; justify-content:space-between; align-items:start; gap:10px;">
            <div class="chip"><span class="live-dot"></span> {l.cat}</div>
            <div class="live-attendees">{l.attendees} in-hall</div>
          </div>
          <h3 class="live-title">{l.title}</h3>
          <div class="live-meta">
            <span><b>{l.faculty}</b></span>
            <span>{l.hall} · started <span data-mins-ago={l.mins}>{l.mins} min</span> ago</span>
          </div>
          <div class="live-bottom">
            <span class="live-attendees">Synthetic seats open</span>
            <a class="btn" href="/portal/liveclass">Join
              <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- THE VENUES -->
  <section class="section">
    <div class="section-head">
      <div>
        <div class="section-eyebrow">The District</div>
        <h2 class="section-title">Twelve principal <em>venues</em>.</h2>
      </div>
      <div class="section-aside">Each hall is named for a teacher in the long lineage of human inquiry — astronomy to anatomy, syntax to sound. Specialisation drives the rigging, not the architecture.</div>
    </div>
    <div class="venue-grid">
      {venues.map(v => (
        <article class="venue-card">
          <div class="venue-head">
            <div>
              <h3 class="venue-name">{v.name}</h3>
              <div class="venue-cap">{v.cap.toLocaleString()} seats · {v.layout}</div>
            </div>
            <svg width="32" height="32" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" style="color: var(--burn); opacity: 0.65;">
              <path d="M3 21h18M5 21V8l7-4 7 4v13M9 21V12h6v9"/>
            </svg>
          </div>
          <div class="venue-spec">{v.spec}</div>
          <svg class="venue-layout-svg" viewBox="0 0 200 90" preserveAspectRatio="xMidYMid meet">
            {v.layout === 'amphi' && (
              <g stroke="#0E0B08" stroke-width="0.8" fill="none">
                <rect x="80" y="6" width="40" height="8" fill="#FF4F00" stroke="none"/>
                {[18, 28, 38, 48, 58, 68, 78].map((y, i) => (
                  <path d={`M ${20 + i*2} ${y} Q 100 ${y + (10 - i)} ${180 - i*2} ${y}`} />
                ))}
              </g>
            )}
            {v.layout === 'fan' && (
              <g stroke="#0E0B08" stroke-width="0.8" fill="none">
                <rect x="85" y="78" width="30" height="6" fill="#FF4F00" stroke="none"/>
                {[0,1,2,3,4,5].map(r => (
                  <path d={`M ${30 - r*4} ${70 - r*10} L ${100} ${74 - r*10} L ${170 + r*4} ${70 - r*10}`} />
                ))}
              </g>
            )}
            {v.layout === 'theatre' && (
              <g stroke="#0E0B08" stroke-width="0.8" fill="none">
                <rect x="70" y="6" width="60" height="8" fill="#FF4F00" stroke="none"/>
                {[22, 32, 42, 52, 62, 72].map(y => (
                  <line x1="20" y1={y} x2="180" y2={y} />
                ))}
                {Array.from({length: 12}).map((_, i) => (
                  <line x1={20 + i*15} y1="22" x2={20 + i*15} y2="72" stroke-dasharray="1 2"/>
                ))}
              </g>
            )}
            {v.layout === 'studio' && (
              <g stroke="#0E0B08" stroke-width="0.8" fill="none">
                <circle cx="100" cy="45" r="32" fill="#FF4F00" opacity="0.18"/>
                <circle cx="100" cy="45" r="22" stroke-dasharray="2 3"/>
                <circle cx="100" cy="45" r="12"/>
                <circle cx="100" cy="45" r="3" fill="#FF4F00" stroke="none"/>
              </g>
            )}
            {v.layout === 'round' && (
              <g stroke="#0E0B08" stroke-width="0.8" fill="none">
                <ellipse cx="100" cy="45" rx="50" ry="22" fill="#FF4F00" opacity="0.16"/>
                <ellipse cx="100" cy="45" rx="38" ry="14"/>
                {Array.from({length: 16}).map((_, i) => {
                  const a = (i / 16) * Math.PI * 2;
                  const cx = 100 + Math.cos(a) * 60;
                  const cy = 45 + Math.sin(a) * 30;
                  return <circle cx={cx} cy={cy} r="2.5" fill="#0E0B08" stroke="none"/>;
                })}
              </g>
            )}
            {v.layout === 'dome' && (
              <g stroke="#0E0B08" stroke-width="0.8" fill="none">
                <path d="M20 70 A 80 50 0 0 1 180 70 Z" fill="#FF4F00" opacity="0.12"/>
                <path d="M20 70 A 80 50 0 0 1 180 70" />
                {[5,4,3,2,1].map(r => (
                  <ellipse cx="100" cy="70" rx={r*15} ry={r*4} />
                ))}
              </g>
            )}
            {v.layout === 'court' && (
              <g stroke="#0E0B08" stroke-width="0.8" fill="none">
                <rect x="80" y="8" width="40" height="10" fill="#FF4F00" stroke="none"/>
                <rect x="30" y="28" width="55" height="10"/>
                <rect x="115" y="28" width="55" height="10"/>
                {[48, 58, 68, 78].map(y => (<line x1="20" y1={y} x2="180" y2={y}/>))}
              </g>
            )}
          </svg>
          <ul class="gear-list">
            {v.gear.map(g => (
              <li>
                <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><circle cx="12" cy="12" r="3"/><path d="M12 1v6M12 17v6M4.22 4.22l4.24 4.24M15.54 15.54l4.24 4.24M1 12h6M17 12h6M4.22 19.78l4.24-4.24M15.54 8.46l4.24-4.24"/></svg>
                {g}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <!-- TECHNOLOGY -->
  <section class="section">
    <div class="section-head">
      <div>
        <div class="section-eyebrow">Under the hood</div>
        <h2 class="section-title">How the <em>holography</em> actually works.</h2>
      </div>
      <div class="section-aside">Custom rig, custom codec, custom delivery network. Built room-up so that a learner four time-zones away sees the chalk-dust settle.</div>
    </div>
    <div class="tech-grid">
      <article class="tech-card">
        <div class="tech-icon"><svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M23 7l-7 5 7 5V7zM1 5h15v14H1z"/></svg></div>
        <h3 class="tech-title">Volumetric capture pipeline</h3>
        <p class="tech-body">A circumference of 24–32 synchronised RGB-D cameras frames each rostrum. Depth maps are fused, meshed, and progressively textured into a streaming point-cloud at 60 frames per second.</p>
        <ul class="tech-list">
          <li>NeRF-derived view interpolation</li>
          <li>2.4 Gbps raw → 28 Mbps delivered</li>
          <li>Time-of-flight + structured light hybrid</li>
        </ul>
      </article>
      <article class="tech-card">
        <div class="tech-icon"><svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8zM6 1v3M10 1v3M14 1v3"/></svg></div>
        <h3 class="tech-title">Spatial Q&amp;A</h3>
        <p class="tech-body">Raise your hand from your seat — physical or synthetic — and a soft heatmap blooms above the rostrum where the lecturer can see it. They call on you by gaze; your audio routes to the spatial audio array.</p>
        <ul class="tech-list">
          <li>Per-seat directional capture</li>
          <li>Heatmap update at 8 Hz</li>
          <li>Whisper-pass for private answers</li>
        </ul>
      </article>
      <article class="tech-card">
        <div class="tech-icon"><svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
        <h3 class="tech-title">Replay in VR</h3>
        <p class="tech-body">Every lecture is archived as a six-degree-of-freedom recording. Walk around the rostrum after the fact, scrub a timeline, bookmark a board-fill, leave a margin note that future viewers can read.</p>
        <ul class="tech-list">
          <li>Frame-accurate seeking</li>
          <li>Bookmark + shared-thread annotations</li>
          <li>Per-board OCR for text search</li>
        </ul>
      </article>
      <article class="tech-card">
        <div class="tech-icon"><svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg></div>
        <h3 class="tech-title">Accessibility, by default</h3>
        <p class="tech-body">Live captions in eleven languages. A sign-language interpreter floats at the lower-right of the AR view. Full transcripts download as searchable text or richly-formatted notes the moment the lecture closes.</p>
        <ul class="tech-list">
          <li>11 caption languages</li>
          <li>Sign-language overlay</li>
          <li>Transcript + slide bundle download</li>
        </ul>
      </article>
    </div>
  </section>

  <!-- BOOKING -->
  <section class="section">
    <div class="section-head">
      <div>
        <div class="section-eyebrow">Reserve a hall</div>
        <h2 class="section-title">Book a <em>private</em> session.</h2>
      </div>
      <div class="section-aside">Faculty, doctoral cohorts, and visiting fellows may reserve a venue for closed sessions. Bookings are confirmed by the District Warden within one working day.</div>
    </div>
    <div class="booking-layout">
      <div class="form-card">
        {bookingSuccess && <div class="ok-banner">Booking recorded. The District Warden will confirm within one working day.</div>}
        {bookingError && <div class="err-banner">{bookingError}</div>}
        <form method="POST">
          <div class="form-row">
            <div class="form-field">
              <label for="hall_id">Hall</label>
              <select id="hall_id" name="hall_id" required>
                <option value="">— select a venue —</option>
                {venues.map(v => <option value={v.id}>{v.name} · {v.cap.toLocaleString()} seats</option>)}
              </select>
            </div>
            <div class="form-field">
              <label for="organiser">Organiser</label>
              <input id="organiser" name="organiser" type="text" placeholder="Full name or cohort label" required />
            </div>
          </div>
          <div class="form-row">
            <div class="form-field">
              <label for="booking_date">Date</label>
              <input id="booking_date" name="booking_date" type="date" required />
            </div>
            <div class="form-field">
              <label for="slot">Slot</label>
              <select id="slot" name="slot" required>
                <option value="">— select a slot —</option>
                <option value="08:00-10:00">08:00 – 10:00</option>
                <option value="10:00-12:00">10:00 – 12:00</option>
                <option value="13:00-15:00">13:00 – 15:00</option>
                <option value="15:00-17:00">15:00 – 17:00</option>
                <option value="17:00-19:00">17:00 – 19:00</option>
                <option value="19:00-21:00">19:00 – 21:00</option>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-field full">
              <label for="purpose">Purpose</label>
              <textarea id="purpose" name="purpose" placeholder="Working seminar, doctoral defence, public lecture..." required></textarea>
            </div>
          </div>
          <div class="form-row">
            <div class="form-field">
              <label for="expected_attendance">Expected attendance</label>
              <input id="expected_attendance" name="expected_attendance" type="number" min="1" max="1500" value="80" required />
            </div>
            <div class="form-field" style="justify-content: end;">
              <button class="btn btn-lg" type="submit" style="margin-top: 20px;">Reserve hall
                <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </button>
            </div>
          </div>
        </form>
      </div>
      <aside class="recent-card">
        <h3 class="recent-title">Recent reservations</h3>
        {recentBookings.length === 0 && (
          <div style="font-size: 13px; color: var(--muted); line-height: 1.6;">No bookings recorded yet. Be the first cohort to claim a hall.</div>
        )}
        {recentBookings.map((b: any) => (
          <div class="recent-item">
            <span class="h">{b.organiser} · {b.hall_id}</span>
            <span class="m">{String(b.booking_date).slice(0, 10)} · {b.slot} · {b.expected_attendance} expected</span>
          </div>
        ))}
      </aside>
    </div>
  </section>

  <!-- CALENDAR -->
  <section class="section">
    <div class="section-head">
      <div>
        <div class="section-eyebrow">Week ahead</div>
        <h2 class="section-title">The District's <em>calendar</em>.</h2>
      </div>
      <div class="section-aside">A seven-day, twenty-four-hour view of confirmed sessions. Click any block for hall, organiser, and joining instructions.</div>
    </div>
    <div class="cal-card">
      <div class="cal-head">
        <div>
          <div style="font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600;" id="calWeekLabel">This week</div>
          <div class="cal-key">Each block: <span style="color: var(--burn); font-weight: 700;">orange</span> = confirmed booking</div>
        </div>
        <div style="display: flex; gap: 10px;">
          <button class="btn btn-ghost" id="calPrev">Prev week</button>
          <button class="btn btn-ghost" id="calNext">Next week</button>
        </div>
      </div>
      <div class="cal-grid" id="calGrid"></div>
    </div>
    <script type="application/json" id="calData" set:html={JSON.stringify(calendarMock)}></script>
  </section>

  <!-- CLOSING -->
  <section class="closing wrap">
    <h3>The classroom is now <em>everywhere</em>.</h3>
    <p>A learner in a fishing village, a research scholar in a borrowed garage, a clinician between rounds — all seated, simultaneously, in the same hall. The lecture is no longer scarce.</p>
    <a class="btn btn-lg" href="/portal/liveclass">Visit the live portal
      <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    </a>
  </section>
</main>

<script is:inline>
  // Live "started X minutes ago" — bump every 30s
  function bumpLiveTimes() {
    document.querySelectorAll('[data-mins-ago]').forEach(function(el) {
      var n = parseInt(el.getAttribute('data-mins-ago') || '0', 10);
      el.textContent = n + ' min';
    });
  }
  bumpLiveTimes();
  setInterval(function() {
    document.querySelectorAll('[data-mins-ago]').forEach(function(el) {
      var n = parseInt(el.getAttribute('data-mins-ago') || '0', 10) + 1;
      el.setAttribute('data-mins-ago', String(n));
      el.textContent = n + ' min';
    });
  }, 30000);

  // Live attendees ticker — small random walk
  (function() {
    var node = document.getElementById('liveAttendees');
    if (!node) return;
    var n = 2140;
    setInterval(function() {
      n += Math.round((Math.random() - 0.45) * 18);
      if (n < 1900) n = 1900;
      if (n > 2400) n = 2400;
      node.textContent = n.toLocaleString();
    }, 4000);
  })();

  // Calendar rendering
  (function() {
    var grid = document.getElementById('calGrid');
    var weekLbl = document.getElementById('calWeekLabel');
    var prevBtn = document.getElementById('calPrev');
    var nextBtn = document.getElementById('calNext');
    var dataNode = document.getElementById('calData');
    if (!grid || !dataNode) return;
    var events;
    try { events = JSON.parse(dataNode.textContent || '[]'); } catch (e) { events = []; }

    var weekOffset = 0;
    var DAY_NAMES = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];

    function startOfWeek(d) {
      var x = new Date(d);
      var day = x.getDay();
      var diff = (day === 0 ? -6 : 1 - day);
      x.setDate(x.getDate() + diff);
      x.setHours(0, 0, 0, 0);
      return x;
    }

    function fmtDate(d) {
      return d.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
    }

    function render() {
      grid.innerHTML = '';
      var base = startOfWeek(new Date());
      base.setDate(base.getDate() + weekOffset * 7);
      var endDate = new Date(base);
      endDate.setDate(endDate.getDate() + 6);
      weekLbl.textContent = 'Week of ' + fmtDate(base) + ' — ' + fmtDate(endDate);

      // Header row
      var corner = document.createElement('div');
      corner.className = 'cal-cell empty-corner';
      grid.appendChild(corner);
      for (var d = 0; d < 7; d++) {
        var head = document.createElement('div');
        head.className = 'cal-cell day-head';
        var dt = new Date(base); dt.setDate(dt.getDate() + d);
        head.textContent = DAY_NAMES[d] + ' · ' + dt.getDate();
        grid.appendChild(head);
      }

      // Hour rows 7:00 to 21:00
      for (var h = 7; h <= 21; h++) {
        var lbl = document.createElement('div');
        lbl.className = 'cal-cell hour-lbl';
        var hh = (h < 10 ? '0' : '') + h;
        lbl.textContent = hh + ':00';
        grid.appendChild(lbl);
        for (var dd = 0; dd < 7; dd++) {
          var cell = document.createElement('div');
          cell.className = 'cal-cell';
          // Only render the event in its starting cell (this week only)
          if (weekOffset === 0) {
            for (var i = 0; i < events.length; i++) {
              var ev = events[i];
              if (ev.day === dd && ev.hour === h) {
                var box = document.createElement('div');
                box.className = 'cal-event';
                box.style.height = ((ev.duration * 30) - 4) + 'px';
                box.innerHTML = '<b>' + ev.hall + '</b><span>' + ev.title + '</span>';
                box.title = ev.hall + ' — ' + ev.title;
                box.addEventListener('click', function(e) {
                  var t = e.currentTarget;
                  alert('Hall: ' + (t && t.title ? t.title : 'session'));
                });
                cell.appendChild(box);
              }
            }
          }
          grid.appendChild(cell);
        }
      }
    }

    prevBtn.addEventListener('click', function() { weekOffset--; render(); });
    nextBtn.addEventListener('click', function() { weekOffset++; render(); });
    render();
  })();
</script>

</BaseLayout>
