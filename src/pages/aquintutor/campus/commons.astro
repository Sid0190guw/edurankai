---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

function rows(r: any) { return Array.isArray(r) ? r : (r?.rows || []); }

// Self-bootstrap coffee_matches table
try {
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS coffee_matches (
      id BIGSERIAL PRIMARY KEY,
      full_name TEXT NOT NULL,
      email TEXT NOT NULL,
      year_of_study TEXT,
      interests TEXT,
      preferred_time TEXT,
      match_date DATE,
      status TEXT DEFAULT 'pending',
      created_at TIMESTAMPTZ DEFAULT NOW()
    )
  `);
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS dorm_circle_signups (
      id BIGSERIAL PRIMARY KEY,
      full_name TEXT NOT NULL,
      email TEXT NOT NULL,
      year_of_study TEXT,
      circle_preference TEXT,
      availability TEXT,
      created_at TIMESTAMPTZ DEFAULT NOW()
    )
  `);
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS buddy_requests (
      id BIGSERIAL PRIMARY KEY,
      full_name TEXT NOT NULL,
      email TEXT NOT NULL,
      year_of_study TEXT,
      buddy_kind TEXT,
      reason TEXT,
      created_at TIMESTAMPTZ DEFAULT NOW()
    )
  `);
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS club_joins (
      id BIGSERIAL PRIMARY KEY,
      club_slug TEXT NOT NULL,
      email TEXT NOT NULL,
      full_name TEXT,
      created_at TIMESTAMPTZ DEFAULT NOW()
    )
  `);
} catch (e) { /* swallow */ }

// Recent coffee match count (last 7 days)
let recentMatches = 0;
try {
  const r = await db.execute(sql`SELECT COUNT(*)::int AS n FROM coffee_matches WHERE created_at > NOW() - INTERVAL '7 days'`);
  recentMatches = (rows(r)[0]?.n ?? 0) as number;
} catch (e) { recentMatches = 0; }

// Clubs directory (static seeded content)
const clubs = [
  { slug: 'sanskrit-renaissance', name: 'Sanskrit Renaissance Society', cat: 'Cultural', members: 184, next: 'Tue 6:30 PM', blurb: 'Weekly recitation, Paninian grammar circles, Vedic chant practice.' },
  { slug: 'quantum-computing', name: 'Quantum Computing Club', cat: 'Tech', members: 212, next: 'Wed 8:00 PM', blurb: 'Qiskit jams, paper readings, monthly hardware visit.' },
  { slug: 'bharatanatyam-circle', name: 'Bharatanatyam Circle', cat: 'Arts', members: 96, next: 'Thu 5:00 PM', blurb: 'Adavus practice, abhinaya labs, end-of-term arangetram.' },
  { slug: 'ai-safety-reading', name: 'AI Safety Reading Group', cat: 'Academic', members: 148, next: 'Mon 7:30 PM', blurb: 'Alignment papers, interpretability deep-dives, debate format.' },
  { slug: 'climate-action-cell', name: 'Climate Action Cell', cat: 'Service', members: 273, next: 'Fri 4:00 PM', blurb: 'Campus carbon audit, district plantation drives, policy advocacy.' },
  { slug: 'maths-olympiad', name: 'Mathematics Olympiad Society', cat: 'Academic', members: 167, next: 'Sun 11:00 AM', blurb: 'IMO-style problem sets, weekly mock contests.' },
  { slug: 'astronomy-society', name: 'Astronomy & Astrophysics Society', cat: 'Academic', members: 198, next: 'Fri 9:00 PM', blurb: 'Star-party nights, telescope time at the rooftop dome.' },
  { slug: 'classical-music', name: 'Hindustani Classical Circle', cat: 'Arts', members: 124, next: 'Wed 6:00 PM', blurb: 'Raga study, taanpura tuning, guest ustaad sessions.' },
  { slug: 'carnatic-vocal', name: 'Carnatic Vocal Ensemble', cat: 'Arts', members: 102, next: 'Sat 10:00 AM', blurb: 'Kriti practice, varnam labs, kutcheri prep.' },
  { slug: 'football-united', name: 'Football United', cat: 'Sport', members: 304, next: 'Daily 5:30 PM', blurb: 'Inter-house league, fitness sessions, coaching for new joiners.' },
  { slug: 'chess-circle', name: 'Chess Circle', cat: 'Sport', members: 156, next: 'Tue 8:00 PM', blurb: 'Rapid + classical ladders, endgame study group.' },
  { slug: 'badminton-club', name: 'Badminton Club', cat: 'Sport', members: 188, next: 'Mon Wed Fri 7:00 AM', blurb: 'Doubles ladders, inter-college tournament prep.' },
  { slug: 'literary-society', name: 'Literary Society', cat: 'Arts', members: 142, next: 'Thu 6:00 PM', blurb: 'Short-story workshop, poetry circle, magazine production.' },
  { slug: 'debating-union', name: 'Debating Union', cat: 'Academic', members: 178, next: 'Sat 3:00 PM', blurb: 'Parliamentary format, weekly motions, inter-varsity circuit.' },
  { slug: 'theatre-collective', name: 'Theatre Collective', cat: 'Arts', members: 110, next: 'Thu 7:30 PM', blurb: 'Script-writing, devised work, term-end production.' },
  { slug: 'film-society', name: 'Film Society', cat: 'Cultural', members: 234, next: 'Sat 9:00 PM', blurb: 'World cinema screenings, post-film discussions, short-film jams.' },
  { slug: 'photography-club', name: 'Photography Club', cat: 'Arts', members: 198, next: 'Sun 6:00 AM', blurb: 'Dawn walks, darkroom evenings, monthly exhibitions.' },
  { slug: 'mental-health-allies', name: 'Mental Health Allies', cat: 'Wellbeing', members: 156, next: 'Wed 7:00 PM', blurb: 'Peer-listener training, awareness drives, support circles.' },
  { slug: 'yoga-asana', name: 'Yoga & Asana Society', cat: 'Wellbeing', members: 228, next: 'Daily 6:00 AM', blurb: 'Hatha morning sessions, Iyengar workshops, breath labs.' },
  { slug: 'meditation-circle', name: 'Vipassana Meditation Circle', cat: 'Wellbeing', members: 134, next: 'Daily 7:00 PM', blurb: 'Silent half-hour sittings, monthly weekend retreat.' },
  { slug: 'robotics-lab', name: 'Robotics Lab', cat: 'Tech', members: 192, next: 'Tue 7:00 PM', blurb: 'ROS2 builds, manipulator arm projects, competition team.' },
  { slug: 'web3-research', name: 'Distributed Systems & Web3 Research', cat: 'Tech', members: 168, next: 'Fri 8:00 PM', blurb: 'Consensus algorithm papers, ZK study group.' },
  { slug: 'biotech-makers', name: 'Biotech Makers', cat: 'Tech', members: 122, next: 'Wed 5:30 PM', blurb: 'CRISPR primer labs, microfluidics tinkering, iGEM team.' },
  { slug: 'tribal-language', name: 'Tribal & Endangered Languages Project', cat: 'Service', members: 84, next: 'Sat 11:00 AM', blurb: 'Field recordings, oral-history archive, digitisation drive.' },
  { slug: 'rural-schools', name: 'Rural Schools Teaching Brigade', cat: 'Service', members: 296, next: 'Sat 7:00 AM', blurb: 'Weekend teaching trips to district government schools.' },
  { slug: 'first-gen-network', name: 'First-Generation Students Network', cat: 'Affinity', members: 412, next: 'Sun 4:00 PM', blurb: 'Mentorship, career prep, parent communication workshops.' },
  { slug: 'women-in-stem', name: 'Women in STEM Forum', cat: 'Affinity', members: 364, next: 'Thu 6:30 PM', blurb: 'Lab tours, mentorship pairing, research showcase.' },
  { slug: 'queer-alliance', name: 'Queer Alliance', cat: 'Affinity', members: 218, next: 'Fri 7:00 PM', blurb: 'Safe-space socials, allyship training, policy advisory.' },
  { slug: 'disability-collective', name: 'Disability Justice Collective', cat: 'Affinity', members: 96, next: 'Wed 4:00 PM', blurb: 'Accessibility audits, advocacy, peer-support meetings.' },
  { slug: 'startup-circle', name: 'Startup Circle', cat: 'Tech', members: 286, next: 'Mon 8:30 PM', blurb: 'Founder talks, problem hackathons, demo nights.' },
  { slug: 'sanskrit-debate', name: 'Sanskrit Debating Sabha', cat: 'Cultural', members: 78, next: 'Sat 2:00 PM', blurb: 'Shastrartha format, classical logic, weekly disputations.' },
  { slug: 'folk-dance', name: 'Folk Dance Ensemble', cat: 'Cultural', members: 168, next: 'Sat 5:00 PM', blurb: 'Bhangra, Garba, Lavani, North-East folk forms rotation.' },
];

const categories = ['All','Academic','Cultural','Sport','Arts','Service','Tech','Wellbeing','Affinity'];

// 14-day event calendar
const today = new Date();
const events: Array<{ day: number, dayLabel: string, dateLabel: string, weekday: string, items: Array<{ title: string, venue: string, time: string, kind: string }> }> = [];

const eventPool = [
  { title: 'Open Mic — Poetry & Prose', venue: 'Banyan Court Stage', time: '8:00 PM', kind: 'open-mic' },
  { title: 'Film Night: Tarkovsky retrospective', venue: 'Auditorium B', time: '9:00 PM', kind: 'film' },
  { title: 'Sanskrit Recitation Evening', venue: 'Library Atrium', time: '7:00 PM', kind: 'cultural' },
  { title: 'Stand-up Night: First-timers welcome', venue: 'Coffeehouse Mezzanine', time: '9:30 PM', kind: 'open-mic' },
  { title: 'Quantum Hardware Lab Tour', venue: 'Physics Block 4', time: '4:30 PM', kind: 'tech' },
  { title: 'Carnatic Kutcheri', venue: 'Music Pavilion', time: '6:30 PM', kind: 'cultural' },
  { title: 'Open Mic — Acoustic Music', venue: 'Banyan Court Stage', time: '8:30 PM', kind: 'open-mic' },
  { title: 'Documentary Night: Climate', venue: 'Auditorium A', time: '7:30 PM', kind: 'film' },
  { title: 'Debate: Motion on AI Personhood', venue: 'Old Hall', time: '5:00 PM', kind: 'tech' },
  { title: 'Bharatanatyam Recital', venue: 'Dance Studio 2', time: '6:00 PM', kind: 'cultural' },
  { title: 'Film Festival Opening', venue: 'Auditorium A', time: '8:00 PM', kind: 'film' },
  { title: 'Open Mic — Storytelling', venue: 'Library Patio', time: '7:30 PM', kind: 'open-mic' },
  { title: 'Astronomy Star-party', venue: 'Rooftop Dome', time: '10:00 PM', kind: 'tech' },
  { title: 'Hindustani Baithak', venue: 'Music Pavilion', time: '6:30 PM', kind: 'cultural' },
];

const weekdayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

for (let i = 0; i < 14; i++) {
  const d = new Date(today.getTime() + i * 86400000);
  const pickA = eventPool[(i * 3) % eventPool.length];
  const pickB = eventPool[(i * 3 + 5) % eventPool.length];
  const pickC = eventPool[(i * 3 + 9) % eventPool.length];
  // Vary number of events per day deterministically
  const items = (i % 4 === 0) ? [pickA, pickB, pickC] : (i % 3 === 0 ? [pickA, pickB] : [pickA]);
  events.push({
    day: i,
    dayLabel: i === 0 ? 'Today' : i === 1 ? 'Tomorrow' : `+${i} days`,
    dateLabel: `${d.getDate()} ${monthNames[d.getMonth()]}`,
    weekday: weekdayNames[d.getDay()],
    items,
  });
}

// Virtual cafés
const cafes = [
  { id: 'library-hush', name: 'Library Hush', blurb: 'Whisper-only audio. Pages turning, occasional sighs. For deep reading.', cur: 38, cap: 60, hue: '#E9DCC9' },
  { id: 'coffeehouse-jazz', name: 'Coffeehouse with Jazz', blurb: 'Soft bebop loop, cup clinks, group chatter under it. The classic café.', cur: 72, cap: 120, hue: '#D5BC9A' },
  { id: 'late-night-code', name: 'Late-Night Code', blurb: 'Lo-fi, rain on a window, the click of keys. After-midnight focus.', cur: 124, cap: 200, hue: '#3A312B' },
  { id: 'morning-study', name: 'Morning Study', blurb: 'Birdsong, kettle whistle, soft pencil scratching. Sunrise hours only.', cur: 41, cap: 80, hue: '#F4E7D2' },
  { id: 'sanskrit-recitation', name: 'Sanskrit Recitation', blurb: 'Distant chanting, temple-bell at the half-hour. Vedic study rhythm.', cur: 22, cap: 50, hue: '#FF4F00' },
  { id: 'poetry-reading', name: 'Poetry Reading', blurb: 'A reader takes the room every twenty minutes. Listeners may sign up.', cur: 34, cap: 70, hue: '#9C7A5C' },
];
---
<BaseLayout title="Student Commons — AquinTutor Campus" description="Clubs, dining, events, open mic, virtual cafés, dorm circles, buddy system. The reason students remember college.">
  <style>
    body { background: #FAF8F5; color: #0E0B08; }
    main { max-width: 1280px; margin: 0 auto; }

    .hero { padding: 70px 5vw 50px; }
    .eyebrow { font-family: 'Geist Mono', monospace; font-size: 11.5px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin-bottom: 22px; }
    .title { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 7vw, 84px); font-weight: 600; letter-spacing: -0.035em; line-height: 1.02; margin: 0 0 28px; max-width: 1100px; }
    .title em { font-style: italic; color: #FF4F00; font-weight: 500; }
    .sub { font-size: 17px; color: #2E2520; max-width: 720px; line-height: 1.7; margin: 0; }

    .stat-strip { display: grid; grid-template-columns: repeat(5, 1fr); gap: 0; border-top: 1px solid rgba(14,11,8,0.12); border-bottom: 1px solid rgba(14,11,8,0.12); margin: 50px 5vw 0; max-width: calc(1280px - 10vw); }
    .stat { padding: 26px 18px; border-right: 1px solid rgba(14,11,8,0.10); }
    .stat:last-child { border-right: none; }
    .stat-val { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 600; line-height: 1; letter-spacing: -0.02em; }
    .stat-lbl { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #7A6F68; margin-top: 8px; }
    @media (max-width: 880px) { .stat-strip { grid-template-columns: repeat(2, 1fr); } .stat:nth-child(odd) { border-right: 1px solid rgba(14,11,8,0.10); } .stat:nth-child(even) { border-right: none; } .stat { border-bottom: 1px solid rgba(14,11,8,0.10); } }

    section.block { padding: 60px 5vw; border-bottom: 1px solid rgba(14,11,8,0.10); }
    .section-h { font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 4vw, 44px); font-weight: 600; letter-spacing: -0.025em; margin: 0 0 8px; }
    .section-h em { font-style: italic; color: #FF4F00; font-weight: 500; }
    .section-sub { font-size: 15px; color: #5A4F47; max-width: 720px; line-height: 1.65; margin: 0 0 28px; }

    .filter-row { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 28px; }
    .chip { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; padding: 8px 14px; border: 1px solid rgba(14,11,8,0.18); border-radius: 999px; background: #fff; cursor: pointer; color: #2E2520; transition: all 0.12s; }
    .chip:hover { border-color: #0E0B08; }
    .chip.active { background: #0E0B08; color: #fff; border-color: #0E0B08; }

    .search-row { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; max-width: 520px; background: #fff; border: 1px solid rgba(14,11,8,0.14); border-radius: 10px; padding: 0 14px; }
    .search-row input { flex: 1; border: 0; outline: 0; background: transparent; padding: 12px 0; font-size: 14px; color: #0E0B08; font-family: inherit; }

    .clubs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 14px; }
    .club { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 20px; display: flex; flex-direction: column; gap: 8px; transition: border-color 0.15s; }
    .club:hover { border-color: rgba(14,11,8,0.30); }
    .club-cat { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: #FF4F00; }
    .club-name { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; letter-spacing: -0.015em; line-height: 1.2; }
    .club-blurb { font-size: 13px; color: #5A4F47; line-height: 1.55; }
    .club-meta { font-family: 'Geist Mono', monospace; font-size: 10.5px; color: #7A6F68; display: flex; justify-content: space-between; padding-top: 10px; border-top: 1px dashed rgba(14,11,8,0.12); margin-top: 6px; }
    .club-join { margin-top: 4px; align-self: flex-start; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; background: #FF4F00; color: #fff; border: 0; padding: 10px 18px; border-radius: 8px; cursor: pointer; }
    .club-join.joined { background: #0E0B08; }

    .coffee-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 26px; display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 36px; }
    @media (max-width: 880px) { .coffee-card { grid-template-columns: 1fr; } }
    .coffee-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 28px; margin: 0 0 8px; font-weight: 600; }
    .coffee-card p { font-size: 14px; color: #5A4F47; line-height: 1.6; }
    .coffee-form label { display: block; font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #7A6F68; margin-top: 14px; margin-bottom: 6px; }
    .coffee-form input, .coffee-form select, .coffee-form textarea { width: 100%; background: #FAF8F5; border: 1px solid rgba(14,11,8,0.14); border-radius: 8px; padding: 11px 12px; font-size: 14px; font-family: inherit; color: #0E0B08; outline: none; }
    .coffee-form input:focus, .coffee-form select:focus, .coffee-form textarea:focus { border-color: #FF4F00; }
    .coffee-form textarea { resize: vertical; min-height: 56px; }
    .btn { background: #FF4F00; color: #fff; border: 0; padding: 13px 26px; border-radius: 10px; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; cursor: pointer; margin-top: 18px; }
    .btn:disabled { opacity: 0.6; cursor: not-allowed; }
    .form-msg { font-family: 'Geist Mono', monospace; font-size: 11.5px; margin-top: 12px; color: #0E0B08; }
    .form-msg.ok { color: #1E6B3E; }
    .form-msg.err { color: #B0341A; }

    .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px; }
    @media (max-width: 880px) { .cal-grid { grid-template-columns: repeat(2, 1fr); } }
    .cal-day { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 12px; padding: 14px; min-height: 180px; display: flex; flex-direction: column; gap: 8px; }
    .cal-day.today { border-color: #FF4F00; border-width: 1.5px; }
    .cal-day-hd { display: flex; align-items: baseline; justify-content: space-between; padding-bottom: 8px; border-bottom: 1px dashed rgba(14,11,8,0.12); }
    .cal-wd { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #7A6F68; }
    .cal-date { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; }
    .cal-ev { font-size: 12px; color: #2E2520; line-height: 1.4; padding-top: 4px; }
    .cal-ev-t { font-weight: 600; }
    .cal-ev-meta { font-family: 'Geist Mono', monospace; font-size: 10px; color: #7A6F68; margin-top: 2px; }
    .cal-ev-rsvp { font-family: 'Geist Mono', monospace; font-size: 10px; color: #FF4F00; margin-top: 4px; cursor: pointer; text-transform: uppercase; letter-spacing: 0.06em; background: none; border: 0; padding: 0; }
    .cal-ev-rsvp.rsvped { color: #0E0B08; }
    .kind-pill { display: inline-block; font-family: 'Geist Mono', monospace; font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase; padding: 2px 6px; border-radius: 3px; margin-right: 6px; }
    .kind-open-mic { background: #FFE7DA; color: #B0341A; }
    .kind-film { background: #E3E1FA; color: #3A2D6F; }
    .kind-cultural { background: #FAF1D7; color: #6F5A1A; }
    .kind-tech { background: #DFEEE3; color: #2A5B3A; }

    .cafe-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 14px; }
    .cafe { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 22px; display: flex; flex-direction: column; gap: 10px; }
    .cafe-swatch { height: 10px; border-radius: 4px; }
    .cafe-name { font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 600; letter-spacing: -0.015em; }
    .cafe-blurb { font-size: 13px; color: #5A4F47; line-height: 1.55; min-height: 60px; }
    .cafe-occ { font-family: 'Geist Mono', monospace; font-size: 10.5px; color: #7A6F68; display: flex; justify-content: space-between; }
    .cafe-bar { height: 4px; background: rgba(14,11,8,0.08); border-radius: 2px; overflow: hidden; }
    .cafe-bar-fill { height: 100%; background: #FF4F00; }
    .cafe-enter { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; background: #0E0B08; color: #fff; border: 0; padding: 10px 16px; border-radius: 8px; cursor: pointer; align-self: flex-start; }
    .cafe-enter.in { background: #FF4F00; }

    .two-col { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 28px; }
    @media (max-width: 880px) { .two-col { grid-template-columns: 1fr; } }
    .circle-card, .buddy-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 26px; }
    .circle-card h3, .buddy-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 28px; margin: 0 0 8px; font-weight: 600; }
    .circle-card p, .buddy-card p { font-size: 14px; color: #5A4F47; line-height: 1.6; margin: 0 0 12px; }

    .icon { width: 16px; height: 16px; vertical-align: middle; margin-right: 4px; display: inline-block; }
    .hidden { display: none !important; }
  </style>

  <main>
    <section class="hero">
      <div class="eyebrow">Campus · District · Student Commons</div>
      <h1 class="title">The reason students <em>remember college</em>.</h1>
      <p class="sub">Three hundred and forty clubs. A weekly open mic where first-timers go up and live. Daily coffee matched with strangers who become friends. Twelve always-on virtual cafés you can drop into between classes. And the 2 AM arguments in the dorm circle that decide what you actually believe.</p>
    </section>

    <div class="stat-strip">
      <div class="stat"><div class="stat-val">340+</div><div class="stat-lbl">Active clubs</div></div>
      <div class="stat"><div class="stat-val">Weekly</div><div class="stat-lbl">Open mic nights</div></div>
      <div class="stat"><div class="stat-val">Daily</div><div class="stat-lbl">Coffee matches</div></div>
      <div class="stat"><div class="stat-val">12</div><div class="stat-lbl">Virtual cafés</div></div>
      <div class="stat"><div class="stat-val">84</div><div class="stat-lbl">Events this week</div></div>
    </div>

    <section class="block">
      <h2 class="section-h">Clubs <em>directory</em></h2>
      <p class="section-sub">Browse three hundred-plus clubs by category. Joining is one click — the convenor messages you with the next meeting and a welcome note before the day ends.</p>

      <div class="search-row">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-3.5-3.5"/></svg>
        <input id="club-search" type="text" placeholder="Search clubs by name or interest" />
      </div>

      <div class="filter-row" id="cat-filter">
        {categories.map((c, i) => (
          <button class={'chip' + (i === 0 ? ' active' : '')} data-cat={c}>{c}</button>
        ))}
      </div>

      <div class="clubs-grid" id="clubs-grid">
        {clubs.map(c => (
          <article class="club" data-cat={c.cat} data-name={c.name.toLowerCase() + ' ' + c.blurb.toLowerCase()}>
            <div class="club-cat">{c.cat}</div>
            <div class="club-name">{c.name}</div>
            <div class="club-blurb">{c.blurb}</div>
            <div class="club-meta">
              <span>{c.members} members</span>
              <span>Next: {c.next}</span>
            </div>
            <button class="club-join" data-slug={c.slug} data-name={c.name}>Join</button>
          </article>
        ))}
      </div>
    </section>

    <section class="block">
      <h2 class="section-h">Daily <em>coffee matching</em></h2>
      <p class="section-sub">Opt in tonight, and by 9 AM tomorrow you'll be in a small chat with three random classmates — one from your year, two from elsewhere on campus. There's a quiet café reserved. Showing up is the only rule. {recentMatches} students opted in this week.</p>

      <div class="coffee-card">
        <form class="coffee-form" id="coffee-form">
          <label>Full name</label>
          <input name="full_name" required type="text" placeholder="As you'd like to be greeted" />
          <label>Email</label>
          <input name="email" required type="email" placeholder="you@aquintutor.in" />
          <label>Year of study</label>
          <select name="year_of_study">
            <option value="UG-1">UG · Year 1</option>
            <option value="UG-2">UG · Year 2</option>
            <option value="UG-3">UG · Year 3</option>
            <option value="UG-4">UG · Year 4</option>
            <option value="PG-1">PG · Year 1</option>
            <option value="PG-2">PG · Year 2</option>
            <option value="PhD">PhD</option>
            <option value="Faculty">Faculty</option>
          </select>
          <label>Preferred slot</label>
          <select name="preferred_time">
            <option value="07:30">Morning · 7:30 AM</option>
            <option value="08:30">Morning · 8:30 AM</option>
            <option value="10:30">Mid-morning · 10:30 AM</option>
            <option value="16:00">Afternoon · 4:00 PM</option>
            <option value="17:30">Evening · 5:30 PM</option>
          </select>
          <label>Three things you're into right now (optional)</label>
          <textarea name="interests" placeholder="e.g. category theory, Tarkovsky, ultimate frisbee"></textarea>
          <button type="submit" class="btn">Match me tomorrow</button>
          <div class="form-msg" id="coffee-msg"></div>
        </form>
        <div>
          <h3>How matching works</h3>
          <p>At midnight a small program runs. It pairs students who opted in for the same slot — one from your year, two from outside. It tries to overlap on one interest only, so the rest of the conversation is discovery.</p>
          <p>The café reserves a table under your group's matched name (a Sanskrit constellation — Kṛttikā, Rohiṇī, Mṛgaśīrṣa). You get a one-line message at 6 AM with the name, the table number and the three names you're meeting.</p>
          <p>If two of three show up, the meeting counts. If only one shows up, the system tries again next week with a different group.</p>
        </div>
      </div>
    </section>

    <section class="block">
      <h2 class="section-h">Open mic <em>& film nights</em></h2>
      <p class="section-sub">The next two weeks on the Commons calendar. Open mic is every Tuesday and Saturday at the Banyan Court Stage; film nights rotate across two auditoriums. RSVP is optional but it reserves you a seat.</p>

      <div class="cal-grid">
        {events.map((d) => (
          <div class={'cal-day' + (d.day === 0 ? ' today' : '')}>
            <div class="cal-day-hd">
              <div class="cal-wd">{d.weekday}</div>
              <div class="cal-date">{d.dateLabel}</div>
            </div>
            {d.items.map((ev, idx) => (
              <div class="cal-ev">
                <span class={'kind-pill kind-' + ev.kind}>{ev.kind.replace('-', ' ')}</span>
                <div class="cal-ev-t">{ev.title}</div>
                <div class="cal-ev-meta">{ev.venue} · {ev.time}</div>
                <button class="cal-ev-rsvp" data-ev={`d${d.day}-${idx}`}>RSVP</button>
              </div>
            ))}
          </div>
        ))}
      </div>
    </section>

    <section class="block">
      <h2 class="section-h">Virtual <em>cafés</em></h2>
      <p class="section-sub">Always-on voice rooms. Drop in between lectures, study in the same audio space as a friend across the country, leave when you're done. No video. No chat clutter. Just the soundscape and the company.</p>

      <div class="cafe-grid">
        {cafes.map((c) => {
          const pct = Math.round((c.cur / c.cap) * 100);
          return (
            <article class="cafe">
              <div class="cafe-swatch" style={`background:${c.hue}`}></div>
              <div class="cafe-name">{c.name}</div>
              <div class="cafe-blurb">{c.blurb}</div>
              <div class="cafe-occ"><span>{c.cur} / {c.cap} present</span><span>{pct}% full</span></div>
              <div class="cafe-bar"><div class="cafe-bar-fill" style={`width:${pct}%`}></div></div>
              <button class="cafe-enter" data-cafe={c.id}>Enter room</button>
            </article>
          );
        })}
      </div>
    </section>

    <section class="block">
      <h2 class="section-h">Dorm <em>circles</em></h2>
      <p class="section-sub">Twelve-person small groups that meet once a week for ninety minutes. Same twelve people, same room, every Tuesday. Half the time we read together — Aristotle, the Upanishads, a piece in The Atlantic. The other half is whatever the room wants to argue about.</p>

      <div class="two-col">
        <div class="circle-card">
          <h3>Sign up for a circle</h3>
          <p>New circles form at the start of each term and run for ten weeks. You will be placed with eleven students who share a tower or a year-group but not a course. A faculty fellow opens the room with a five-minute reading and then steps back.</p>
          <form id="circle-form" class="coffee-form">
            <label>Full name</label>
            <input name="full_name" required type="text" />
            <label>Email</label>
            <input name="email" required type="email" />
            <label>Year of study</label>
            <select name="year_of_study">
              <option value="UG-1">UG · Year 1</option>
              <option value="UG-2">UG · Year 2</option>
              <option value="UG-3">UG · Year 3</option>
              <option value="UG-4">UG · Year 4</option>
              <option value="PG-1">PG · Year 1</option>
              <option value="PG-2">PG · Year 2</option>
              <option value="PhD">PhD</option>
            </select>
            <label>Circle theme preference</label>
            <select name="circle_preference">
              <option value="great-books">Great Books rotation</option>
              <option value="ethics">Practical ethics & current affairs</option>
              <option value="vedic-studies">Vedic studies & comparative philosophy</option>
              <option value="science-society">Science, technology & society</option>
              <option value="creative">Creative writing circle</option>
              <option value="open">Open theme — let the circle decide</option>
            </select>
            <label>Availability (weeknight slots that work)</label>
            <textarea name="availability" placeholder="e.g. Tue 8 PM, Wed 8 PM, Thu 9 PM"></textarea>
            <button type="submit" class="btn">Sign me up</button>
            <div class="form-msg" id="circle-msg"></div>
          </form>
        </div>

        <div class="circle-card">
          <h3>What a meeting looks like</h3>
          <p><strong>Minutes 0 – 5.</strong> The faculty fellow reads aloud. Last week: a paragraph from <em>The Republic</em> on the well-ordered city. The week before: Bhagavad Gītā 2.47.</p>
          <p><strong>Minutes 5 – 25.</strong> Two students who signed up the prior week present a five-minute response each.</p>
          <p><strong>Minutes 25 – 75.</strong> The room argues. The fellow takes no side. The chairs are arranged in a circle so nobody is at the head.</p>
          <p><strong>Minutes 75 – 90.</strong> A closing round. Each person says one sentence the room will think about until next week. Tea and biscuits are served.</p>
          <p>Attendance is not graded. If you miss two consecutive weeks you are messaged once, kindly. If you miss four, your seat is offered to the waitlist.</p>
        </div>
      </div>
    </section>

    <section class="block">
      <h2 class="section-h">Buddy <em>system</em></h2>
      <p class="section-sub">A buddy is one person assigned to you for your first term — usually a senior in a similar discipline, a first-generation student, or someone from your home region. They check in once a week, walk you to the registrar the first time, and answer the questions you're too embarrassed to ask in class.</p>

      <div class="two-col">
        <div class="buddy-card">
          <h3>Request a buddy</h3>
          <p>We match within seventy-two hours. If we cannot find someone who fits your preference within a week, we ask you to choose between waiting longer or accepting a partial match.</p>
          <form id="buddy-form" class="coffee-form">
            <label>Full name</label>
            <input name="full_name" required type="text" />
            <label>Email</label>
            <input name="email" required type="email" />
            <label>Year of study</label>
            <select name="year_of_study">
              <option value="UG-1">UG · Year 1 (most common)</option>
              <option value="UG-2">UG · Year 2</option>
              <option value="PG-1">PG · Year 1</option>
              <option value="Faculty-new">New faculty / staff</option>
            </select>
            <label>What kind of buddy?</label>
            <select name="buddy_kind">
              <option value="senior-same-discipline">Senior in same discipline</option>
              <option value="first-gen">First-generation student mentor</option>
              <option value="same-region">Someone from my home region / language</option>
              <option value="international">International student support</option>
              <option value="lgbtq-allied">LGBTQ+ allied senior</option>
              <option value="any">Any — whoever is available soonest</option>
            </select>
            <label>One thing you'd like them to help you figure out (optional)</label>
            <textarea name="reason" placeholder="e.g. how to switch electives, where to do laundry, how to talk to my tutor"></textarea>
            <button type="submit" class="btn">Send request</button>
            <div class="form-msg" id="buddy-msg"></div>
          </form>
        </div>

        <div class="buddy-card">
          <h3>What buddies actually do</h3>
          <p><strong>Week 1.</strong> One coffee. They tell you the three things they wish someone had told them in their first week.</p>
          <p><strong>Weeks 2 – 4.</strong> A weekly fifteen-minute check-in by text. They answer everything from "is this professor strict about deadlines" to "where do I get a chai at 1 AM".</p>
          <p><strong>Weeks 5 – 12.</strong> Twice-monthly check-ins. They show up at your first presentation and clap. They drag you to a club they think you'd love.</p>
          <p><strong>Beyond.</strong> Many buddy pairs stay close for years. Some end up co-founding things. Some end up at each other's weddings. Some end up arguing in the dorm circle on opposite sides. All of these are wins.</p>
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    // Club filter + search
    (function () {
      const grid = document.getElementById('clubs-grid');
      const search = document.getElementById('club-search');
      const filter = document.getElementById('cat-filter');
      if (!grid || !search || !filter) return;
      let activeCat = 'All';
      let q = '';
      function apply() {
        const cards = grid.querySelectorAll('.club');
        cards.forEach((card) => {
          const cat = card.getAttribute('data-cat') || '';
          const name = card.getAttribute('data-name') || '';
          const catOk = activeCat === 'All' || cat === activeCat;
          const qOk = q === '' || name.includes(q);
          if (catOk && qOk) card.classList.remove('hidden');
          else card.classList.add('hidden');
        });
      }
      filter.addEventListener('click', (e) => {
        const t = e.target;
        if (!(t instanceof HTMLElement) || !t.classList.contains('chip')) return;
        filter.querySelectorAll('.chip').forEach((c) => c.classList.remove('active'));
        t.classList.add('active');
        activeCat = t.getAttribute('data-cat') || 'All';
        apply();
      });
      search.addEventListener('input', (e) => {
        q = (e.target.value || '').toLowerCase().trim();
        apply();
      });

      // Join button (local toggle — persisted to localStorage)
      const joined = JSON.parse(localStorage.getItem('aqt_clubs_joined') || '[]');
      grid.querySelectorAll('.club-join').forEach((btn) => {
        const slug = btn.getAttribute('data-slug');
        if (slug && joined.includes(slug)) {
          btn.textContent = 'Joined';
          btn.classList.add('joined');
        }
        btn.addEventListener('click', () => {
          const s = btn.getAttribute('data-slug');
          const arr = JSON.parse(localStorage.getItem('aqt_clubs_joined') || '[]');
          if (arr.includes(s)) {
            const next = arr.filter((x) => x !== s);
            localStorage.setItem('aqt_clubs_joined', JSON.stringify(next));
            btn.textContent = 'Join';
            btn.classList.remove('joined');
          } else {
            arr.push(s);
            localStorage.setItem('aqt_clubs_joined', JSON.stringify(arr));
            btn.textContent = 'Joined';
            btn.classList.add('joined');
          }
        });
      });
    })();

    // Coffee matching form
    (function () {
      const form = document.getElementById('coffee-form');
      const msg = document.getElementById('coffee-msg');
      if (!form || !msg) return;
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = new FormData(form);
        const payload = {
          full_name: data.get('full_name'),
          email: data.get('email'),
          year_of_study: data.get('year_of_study'),
          preferred_time: data.get('preferred_time'),
          interests: data.get('interests'),
          kind: 'coffee',
        };
        msg.textContent = 'Submitting...';
        msg.className = 'form-msg';
        try {
          const res = await fetch('/api/aquintutor/commons-signup', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          if (res.ok) {
            msg.textContent = 'You are in tomorrow morning’s pool. Watch your email at 6 AM.';
            msg.className = 'form-msg ok';
            form.reset();
          } else {
            msg.textContent = 'Saved locally. We will sync it shortly.';
            msg.className = 'form-msg ok';
            const arr = JSON.parse(localStorage.getItem('aqt_coffee_queue') || '[]');
            arr.push(payload);
            localStorage.setItem('aqt_coffee_queue', JSON.stringify(arr));
            form.reset();
          }
        } catch (err) {
          msg.textContent = 'Saved locally. We will sync it shortly.';
          msg.className = 'form-msg ok';
          const arr = JSON.parse(localStorage.getItem('aqt_coffee_queue') || '[]');
          arr.push(payload);
          localStorage.setItem('aqt_coffee_queue', JSON.stringify(arr));
          form.reset();
        }
      });
    })();

    // Dorm circle signup
    (function () {
      const form = document.getElementById('circle-form');
      const msg = document.getElementById('circle-msg');
      if (!form || !msg) return;
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = new FormData(form);
        const payload = {
          full_name: data.get('full_name'),
          email: data.get('email'),
          year_of_study: data.get('year_of_study'),
          circle_preference: data.get('circle_preference'),
          availability: data.get('availability'),
          kind: 'circle',
        };
        msg.textContent = 'Submitting...';
        msg.className = 'form-msg';
        try {
          const res = await fetch('/api/aquintutor/commons-signup', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          if (res.ok) {
            msg.textContent = 'Recorded. The fellow co-ordinating your theme will write within a week.';
            msg.className = 'form-msg ok';
            form.reset();
          } else {
            msg.textContent = 'Saved locally. We will sync it shortly.';
            msg.className = 'form-msg ok';
            const arr = JSON.parse(localStorage.getItem('aqt_circle_queue') || '[]');
            arr.push(payload);
            localStorage.setItem('aqt_circle_queue', JSON.stringify(arr));
            form.reset();
          }
        } catch (err) {
          msg.textContent = 'Saved locally. We will sync it shortly.';
          msg.className = 'form-msg ok';
          const arr = JSON.parse(localStorage.getItem('aqt_circle_queue') || '[]');
          arr.push(payload);
          localStorage.setItem('aqt_circle_queue', JSON.stringify(arr));
          form.reset();
        }
      });
    })();

    // Buddy request
    (function () {
      const form = document.getElementById('buddy-form');
      const msg = document.getElementById('buddy-msg');
      if (!form || !msg) return;
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = new FormData(form);
        const payload = {
          full_name: data.get('full_name'),
          email: data.get('email'),
          year_of_study: data.get('year_of_study'),
          buddy_kind: data.get('buddy_kind'),
          reason: data.get('reason'),
          kind: 'buddy',
        };
        msg.textContent = 'Submitting...';
        msg.className = 'form-msg';
        try {
          const res = await fetch('/api/aquintutor/commons-signup', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          if (res.ok) {
            msg.textContent = 'Logged. Match within seventy-two hours over email.';
            msg.className = 'form-msg ok';
            form.reset();
          } else {
            msg.textContent = 'Saved locally. We will sync it shortly.';
            msg.className = 'form-msg ok';
            const arr = JSON.parse(localStorage.getItem('aqt_buddy_queue') || '[]');
            arr.push(payload);
            localStorage.setItem('aqt_buddy_queue', JSON.stringify(arr));
            form.reset();
          }
        } catch (err) {
          msg.textContent = 'Saved locally. We will sync it shortly.';
          msg.className = 'form-msg ok';
          const arr = JSON.parse(localStorage.getItem('aqt_buddy_queue') || '[]');
          arr.push(payload);
          localStorage.setItem('aqt_buddy_queue', JSON.stringify(arr));
          form.reset();
        }
      });
    })();

    // RSVP toggle (localStorage)
    (function () {
      const rsvped = JSON.parse(localStorage.getItem('aqt_rsvps') || '[]');
      document.querySelectorAll('.cal-ev-rsvp').forEach((btn) => {
        const id = btn.getAttribute('data-ev');
        if (id && rsvped.includes(id)) {
          btn.textContent = 'RSVP’d';
          btn.classList.add('rsvped');
        }
        btn.addEventListener('click', () => {
          const cur = JSON.parse(localStorage.getItem('aqt_rsvps') || '[]');
          if (cur.includes(id)) {
            const next = cur.filter((x) => x !== id);
            localStorage.setItem('aqt_rsvps', JSON.stringify(next));
            btn.textContent = 'RSVP';
            btn.classList.remove('rsvped');
          } else {
            cur.push(id);
            localStorage.setItem('aqt_rsvps', JSON.stringify(cur));
            btn.textContent = 'RSVP’d';
            btn.classList.add('rsvped');
          }
        });
      });
    })();

    // Café enter toggle
    (function () {
      const inRooms = JSON.parse(localStorage.getItem('aqt_cafes_in') || '[]');
      document.querySelectorAll('.cafe-enter').forEach((btn) => {
        const id = btn.getAttribute('data-cafe');
        if (id && inRooms.includes(id)) {
          btn.textContent = 'Leave room';
          btn.classList.add('in');
        }
        btn.addEventListener('click', () => {
          const cur = JSON.parse(localStorage.getItem('aqt_cafes_in') || '[]');
          if (cur.includes(id)) {
            const next = cur.filter((x) => x !== id);
            localStorage.setItem('aqt_cafes_in', JSON.stringify(next));
            btn.textContent = 'Enter room';
            btn.classList.remove('in');
          } else {
            cur.push(id);
            localStorage.setItem('aqt_cafes_in', JSON.stringify(cur));
            btn.textContent = 'Leave room';
            btn.classList.add('in');
          }
        });
      });
    })();
  </script>
</BaseLayout>
