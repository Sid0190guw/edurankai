---
import BaseLayout from '@/layouts/BaseLayout.astro';

const stats = [
  { val: '4.2M', lbl: 'Total Sources' },
  { val: '1.4M', lbl: 'Peer-Reviewed Papers' },
  { val: '8,400', lbl: 'Vedic Primary Texts' },
  { val: '47,000', lbl: 'Open Datasets' },
  { val: '410,000', lbl: 'Patent Records' },
  { val: '24/7', lbl: 'Catalogue Access' },
];

const collections = [
  {
    name: 'Western Sciences Archive',
    size: '1.4M papers',
    oldest: '1665 (Phil. Trans.)',
    desc: 'Peer-reviewed STEM and social-science journals from the founding of the scholarly journal to current pre-prints.',
    fields: ['Physics', 'Chemistry', 'Biology', 'Mathematics', 'CS', 'Economics'],
    href: '/portal/library?collection=western-sciences',
  },
  {
    name: 'Vedic Sciences Primary',
    size: '8,400 manuscripts',
    oldest: 'c. 1500 BCE (Rigveda samhita)',
    desc: 'Devanagari + transliterated source texts of the four Vedas, Upanishads, Brahmanas, Aranyakas, Sulvasutras, jyotisha and ayurveda treatises.',
    fields: ['Samhitas', 'Brahmanas', 'Aranyakas', 'Upanishads', 'Vedangas', 'Smriti'],
    href: '/portal/library?collection=vedic-primary',
  },
  {
    name: 'Indic Manuscripts',
    size: '116,000 folios',
    oldest: 'c. 200 BCE (Charaka palm-leaf)',
    desc: 'High-resolution scans of palm-leaf, birch-bark and paper manuscripts in Sanskrit, Tamil, Pali, Prakrit, Sharada and Grantha scripts.',
    fields: ['Palm-leaf', 'Birch-bark', 'Paper', 'Sharada', 'Grantha', 'Tamil'],
    href: '/portal/library?collection=indic-manuscripts',
  },
  {
    name: 'Patent Records',
    size: '410,000 filings',
    oldest: '1474 (Venetian Patent Statute)',
    desc: 'Granted utility patents and design patents from regional patent offices, fully searchable by claim text, classification and assignee.',
    fields: ['Utility', 'Design', 'PCT', 'Lapsed', 'Active', 'Litigated'],
    href: '/portal/library?collection=patents',
  },
  {
    name: 'Open Datasets',
    size: '47,000 corpora',
    oldest: '1801 (planetary tables)',
    desc: 'Numerical, time-series, image, text and graph datasets with provenance metadata, citation handles and DOI registration.',
    fields: ['Tabular', 'Time-series', 'Image', 'Text', 'Graph', 'Audio'],
    href: '/portal/library?collection=datasets',
  },
  {
    name: 'Audio Archives',
    size: '94,000 hours',
    oldest: '1902 (cylinder recordings)',
    desc: 'Field recordings of oral traditions, musical performances, dialect samples, lectures and conference proceedings.',
    fields: ['Oral history', 'Music', 'Dialect', 'Lecture', 'Proceedings', 'Field'],
    href: '/portal/library?collection=audio',
  },
  {
    name: 'Visual Archives',
    size: '2.1M items',
    oldest: '1827 (heliograph)',
    desc: 'Photographs, lithographs, scientific illustrations, microscope plates, telescope plates and architectural drawings.',
    fields: ['Photo', 'Print', 'Plate', 'Drawing', 'Diagram', 'Map'],
    href: '/portal/library?collection=visual',
  },
  {
    name: 'Personal Papers',
    size: '720 collections',
    oldest: '1812 (correspondence)',
    desc: 'Notebooks, correspondence, lab books and unpublished drafts donated by scholars and their estates.',
    fields: ['Notebooks', 'Letters', 'Drafts', 'Lab books', 'Diaries', 'Marginalia'],
    href: '/portal/library?collection=personal-papers',
  },
];

const vedicTexts = [
  { title: 'Rigveda Samhitas', script: 'Devanagari · Sharada', folios: '10 mandalas · 1,028 hymns', period: 'c. 1500-1200 BCE', focus: 'Cosmology, hymns, deity invocation, ritual praxis' },
  { title: 'Yajurveda', script: 'Devanagari · Grantha', folios: '40 chapters · Shukla and Krishna recensions', period: 'c. 1200-900 BCE', focus: 'Sacrificial procedure, geometry of altar construction' },
  { title: 'Samaveda', script: 'Devanagari', folios: '1,875 mantras · musical notation', period: 'c. 1200-900 BCE', focus: 'Melodic chant, swara, acoustics of ritual song' },
  { title: 'Atharvaveda', script: 'Devanagari · Sharada', folios: '20 books · 730 hymns', period: 'c. 1000 BCE', focus: 'Medicine, plant biology, civic ethics, statecraft' },
  { title: 'Principal Upanishads', script: 'Devanagari', folios: '13 principal · 108 minor', period: 'c. 800-500 BCE', focus: 'Brahman, atman, consciousness, epistemology' },
  { title: 'Brahmanas', script: 'Devanagari', folios: 'Aitareya, Shatapatha, Taittiriya and others', period: 'c. 900-700 BCE', focus: 'Ritual exegesis, cosmogenesis, year-cycle astronomy' },
  { title: 'Aranyakas', script: 'Devanagari', folios: 'Forest treatises bridging karma to jnana', period: 'c. 800-600 BCE', focus: 'Contemplative practice, internal sacrifice' },
  { title: 'Sulvasutras', script: 'Devanagari', folios: 'Baudhayana, Apastamba, Katyayana, Manava', period: 'c. 800-500 BCE', focus: 'Geometric construction, Pythagorean relation, irrational approximations' },
  { title: 'Charaka Samhita', script: 'Devanagari · Sharada', folios: '8 sthanas · 120 chapters', period: 'c. 300 BCE', focus: 'Internal medicine, physiology, pharmacology, ethics' },
  { title: 'Susruta Samhita', script: 'Devanagari · Grantha', folios: '6 sthanas · 184 chapters', period: 'c. 600 BCE compiled later', focus: 'Surgery, anatomy, instruments, plastic reconstruction' },
  { title: 'Aryabhatiya', script: 'Devanagari', folios: '4 padas · 121 verses', period: '499 CE', focus: 'Trigonometry, sine table, planetary motion, algorithms' },
  { title: 'Surya Siddhanta', script: 'Devanagari', folios: '14 chapters · 500 verses', period: 'c. 400-500 CE', focus: 'Astronomy, precession, eclipse computation, time units' },
];

const readingRooms = [
  { name: 'Quiet Stacks', seats: 120, occupancy: 38, theme: 'Silent reading, no devices', color: '#0E0B08' },
  { name: 'Manuscript Hall', seats: 24, occupancy: 9, theme: 'Climate-controlled, white-glove viewing', color: '#7A2E00' },
  { name: 'Periodicals Lounge', seats: 60, occupancy: 22, theme: 'Current journals, daily papers', color: '#2E2520' },
  { name: 'Maps & Plates', seats: 36, occupancy: 14, theme: 'Large-format flat tables', color: '#FF4F00' },
  { name: 'Audio Booths', seats: 18, occupancy: 7, theme: 'Acoustic listening pods, transcription', color: '#1A4D2E' },
  { name: 'Seminar Carrels', seats: 48, occupancy: 31, theme: 'Bookable 4-hr blocks for thesis work', color: '#3D2E5C' },
];

const aiSamples = [
  { role: 'user', text: 'Compare the iterative sine approximation in Aryabhatiya with the modern Taylor series.' },
  { role: 'assistant', text: 'Aryabhatiya verse Ganitapada 12 gives a finite-difference recurrence for sine values at intervals of 225 minutes of arc. The modern Taylor expansion of sine around zero converges with cubic error. Aryabhata\'s table is accurate to roughly four decimal places at most arguments. See: Aryabhatiya Ganitapada 11-12, and Plofker H., "Mathematics in India" (primary reference 1).' },
  { role: 'user', text: 'Which datasets cover monsoon precipitation over the Western Ghats from 1980 onward?' },
  { role: 'assistant', text: 'Three datasets in the open datasets collection match: a daily gauge composite (1901-present, 21,915 days), a satellite re-analysis grid at 0.25 degrees (1979-present), and a station-level hourly archive (1990-present, 47 stations). DOI handles attached for citation. Want me to draft a comparative methodology section?' },
];
---

<BaseLayout title="Library and Archives - AquinTutor Campus" description="District library at AquinTutor: 4.2 million sources spanning peer-reviewed papers, Vedic primary texts, manuscripts, datasets, patents and personal papers.">
  <style>
    body { background: #FAF8F5; color: #0E0B08; font-family: 'Inter', system-ui, sans-serif; }
    main { max-width: 1280px; margin: 0 auto; }

    .hero { padding: 70px 5vw 50px; }
    .eyebrow { font-family: 'Geist Mono', monospace; font-size: 11.5px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
    .title { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 7vw, 84px); font-weight: 600; letter-spacing: -0.035em; line-height: 1.04; margin: 18px 0 22px; }
    .title em { color: #FF4F00; font-style: italic; font-weight: 500; }
    .sub { font-size: 17px; color: #2E2520; max-width: 720px; line-height: 1.7; }

    .stat-strip { display: grid; grid-template-columns: repeat(6, 1fr); gap: 0; border-top: 1px solid rgba(14,11,8,0.10); border-bottom: 1px solid rgba(14,11,8,0.10); margin: 50px 5vw 0; max-width: 1280px; }
    .stat-strip > div { padding: 24px 18px; border-right: 1px solid rgba(14,11,8,0.10); }
    .stat-strip > div:last-child { border-right: none; }
    .stat-val { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 600; letter-spacing: -0.02em; }
    .stat-lbl { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #7A6F68; margin-top: 6px; }

    section.block { padding: 60px 5vw; border-bottom: 1px solid rgba(14,11,8,0.10); }
    .sec-head { display: flex; justify-content: space-between; align-items: end; gap: 24px; margin-bottom: 32px; }
    .sec-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 4vw, 44px); font-weight: 600; letter-spacing: -0.03em; line-height: 1.1; max-width: 720px; }
    .sec-title em { font-style: italic; color: #FF4F00; }
    .sec-aside { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: #7A6F68; }

    /* Search bar */
    .search-shell { background: white; border: 1px solid rgba(14,11,8,0.10); border-radius: 18px; padding: 28px; box-shadow: 0 1px 0 rgba(14,11,8,0.04); }
    .search-form { display: grid; grid-template-columns: 1fr 220px 220px 150px; gap: 12px; align-items: stretch; }
    .search-form input, .search-form select { font: 14px/1.5 'Inter', sans-serif; padding: 14px 16px; border: 1px solid rgba(14,11,8,0.18); border-radius: 10px; background: #FAF8F5; color: #0E0B08; }
    .search-form input:focus, .search-form select:focus { outline: 2px solid #FF4F00; outline-offset: -1px; }
    .btn-primary { background: #FF4F00; color: white; border: none; cursor: pointer; padding: 14px 26px; border-radius: 10px; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; }
    .btn-primary:hover { background: #E63A00; }
    .search-tags { margin-top: 18px; display: flex; flex-wrap: wrap; gap: 8px; }
    .tag { font-family: 'Geist Mono', monospace; font-size: 10.5px; padding: 6px 10px; border-radius: 999px; background: rgba(14,11,8,0.06); color: #2E2520; letter-spacing: 0.04em; }

    /* Collection cards */
    .col-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(330px, 1fr)); gap: 18px; }
    .col-card { background: white; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 24px; display: flex; flex-direction: column; gap: 14px; transition: transform 0.18s, box-shadow 0.18s; }
    .col-card:hover { transform: translateY(-2px); box-shadow: 0 14px 34px rgba(14,11,8,0.08); }
    .col-card .num { font-family: 'Geist Mono', monospace; font-size: 11px; color: #7A6F68; letter-spacing: 0.1em; }
    .col-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 600; letter-spacing: -0.02em; line-height: 1.15; }
    .col-card .meta { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; padding: 12px 0; border-top: 1px solid rgba(14,11,8,0.08); border-bottom: 1px solid rgba(14,11,8,0.08); }
    .col-card .meta div .k { font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.08em; text-transform: uppercase; color: #7A6F68; }
    .col-card .meta div .v { font-size: 13.5px; color: #0E0B08; margin-top: 2px; font-weight: 500; }
    .col-card .desc { font-size: 13.5px; line-height: 1.62; color: #2E2520; }
    .col-card .fields { display: flex; flex-wrap: wrap; gap: 6px; }
    .col-card .fld { font-family: 'Geist Mono', monospace; font-size: 10px; padding: 4px 8px; background: rgba(255,79,0,0.08); color: #7A2E00; border-radius: 6px; letter-spacing: 0.04em; }
    .col-card a { margin-top: auto; font-family: 'Geist Mono', monospace; font-size: 11.5px; letter-spacing: 0.08em; text-transform: uppercase; color: #0E0B08; text-decoration: none; padding: 11px 14px; border: 1px solid rgba(14,11,8,0.18); border-radius: 8px; text-align: center; font-weight: 700; }
    .col-card a:hover { background: #0E0B08; color: white; }

    /* Vedic spotlight */
    .vedic-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(310px, 1fr)); gap: 14px; }
    .vedic-card { background: linear-gradient(180deg, #FAF8F5 0%, #F5EFE6 100%); border: 1px solid rgba(122,46,0,0.18); border-radius: 12px; padding: 22px; position: relative; }
    .vedic-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, #7A2E00, #FF4F00); border-radius: 12px 12px 0 0; }
    .vedic-card .pp { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: #7A2E00; }
    .vedic-card h4 { font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 600; margin: 6px 0 10px; letter-spacing: -0.02em; }
    .vedic-card .meta-row { font-size: 12.5px; color: #2E2520; margin: 4px 0; }
    .vedic-card .meta-row strong { font-family: 'Geist Mono', monospace; font-size: 9.5px; text-transform: uppercase; color: #7A6F68; letter-spacing: 0.08em; font-weight: 700; display: block; }
    .vedic-card .focus { margin-top: 10px; padding-top: 10px; border-top: 1px solid rgba(122,46,0,0.18); font-size: 13px; color: #0E0B08; line-height: 1.55; font-style: italic; }

    /* AI assistant chat */
    .chat-shell { background: #0E0B08; color: #FAF8F5; border-radius: 18px; padding: 28px; max-width: 920px; margin: 0 auto; }
    .chat-head { display: flex; align-items: center; gap: 14px; padding-bottom: 18px; border-bottom: 1px solid rgba(255,255,255,0.10); margin-bottom: 18px; }
    .chat-head .dot { width: 10px; height: 10px; border-radius: 50%; background: #1A4D2E; box-shadow: 0 0 0 4px rgba(26,77,46,0.18); }
    .chat-head h4 { font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 600; letter-spacing: -0.02em; }
    .chat-head .tag { background: rgba(255,79,0,0.2); color: #FF855E; }
    .msg { padding: 14px 18px; border-radius: 12px; margin-bottom: 12px; font-size: 14px; line-height: 1.6; max-width: 82%; }
    .msg.user { background: rgba(255,79,0,0.16); color: #FFB59E; margin-left: auto; font-family: 'Geist Mono', monospace; font-size: 12.5px; }
    .msg.assist { background: rgba(255,255,255,0.06); color: #FAF8F5; }
    .chat-input-row { margin-top: 18px; display: flex; gap: 10px; }
    .chat-input-row input { flex: 1; padding: 14px 18px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); color: #FAF8F5; border-radius: 10px; font: 14px 'Inter', sans-serif; }
    .chat-input-row input::placeholder { color: rgba(250,248,245,0.45); }
    .chat-input-row a { background: #FF4F00; color: white; text-decoration: none; padding: 14px 22px; border-radius: 10px; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; display: flex; align-items: center; gap: 8px; }

    /* Reading rooms */
    .rooms-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 18px; }
    .room-card { background: white; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 22px; position: relative; overflow: hidden; }
    .room-color { position: absolute; top: 0; left: 0; right: 0; height: 4px; }
    .room-card h4 { font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 600; letter-spacing: -0.02em; margin-bottom: 4px; padding-top: 6px; }
    .room-card .theme { font-size: 13px; color: #2E2520; font-style: italic; margin-bottom: 16px; }
    .occ-bar { background: rgba(14,11,8,0.08); height: 8px; border-radius: 999px; overflow: hidden; margin: 10px 0 6px; }
    .occ-fill { height: 100%; border-radius: 999px; transition: width 0.4s; }
    .occ-meta { display: flex; justify-content: space-between; font-family: 'Geist Mono', monospace; font-size: 10.5px; color: #7A6F68; letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 14px; }
    .room-actions { display: flex; gap: 8px; }
    .room-actions button { flex: 1; background: transparent; border: 1px solid rgba(14,11,8,0.18); padding: 10px 12px; border-radius: 8px; font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.08em; text-transform: uppercase; color: #0E0B08; cursor: pointer; font-weight: 700; }
    .room-actions button:hover { background: #0E0B08; color: white; border-color: #0E0B08; }

    /* Citation tile */
    .cite-tile { background: linear-gradient(135deg, #FAF8F5 0%, #F0E6D8 100%); border: 1px solid rgba(122,46,0,0.18); border-radius: 18px; padding: 36px; display: grid; grid-template-columns: 2fr 1fr; gap: 32px; align-items: center; }
    .cite-tile h3 { font-family: 'Cormorant Garamond', serif; font-size: 36px; font-weight: 600; letter-spacing: -0.03em; line-height: 1.15; margin-bottom: 12px; }
    .cite-tile h3 em { color: #FF4F00; font-style: italic; }
    .cite-tile p { font-size: 15px; color: #2E2520; line-height: 1.65; margin-bottom: 16px; }
    .cite-styles { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 18px; }
    .cite-style { font-family: 'Geist Mono', monospace; font-size: 10.5px; padding: 6px 10px; background: white; border: 1px solid rgba(14,11,8,0.10); border-radius: 6px; letter-spacing: 0.04em; }
    .cite-tile a { background: #0E0B08; color: white; text-decoration: none; padding: 14px 26px; border-radius: 10px; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; display: inline-block; }
    .cite-preview { background: #0E0B08; color: #FAF8F5; padding: 22px; border-radius: 14px; font-family: 'Geist Mono', monospace; font-size: 12px; line-height: 1.7; }
    .cite-preview .lbl { color: #FF855E; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; }

    /* ILL form */
    .ill-shell { background: white; border: 1px solid rgba(14,11,8,0.10); border-radius: 18px; padding: 36px; max-width: 860px; margin: 0 auto; }
    .ill-shell h3 { font-family: 'Cormorant Garamond', serif; font-size: 32px; font-weight: 600; letter-spacing: -0.03em; margin-bottom: 8px; }
    .ill-shell .lead { font-size: 14.5px; color: #2E2520; margin-bottom: 22px; line-height: 1.6; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-grid .full { grid-column: 1 / -1; }
    .form-grid label { display: block; }
    .form-grid label .lk { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.08em; text-transform: uppercase; color: #7A6F68; margin-bottom: 6px; display: block; font-weight: 700; }
    .form-grid input, .form-grid select, .form-grid textarea { width: 100%; padding: 12px 14px; border: 1px solid rgba(14,11,8,0.18); border-radius: 8px; background: #FAF8F5; color: #0E0B08; font: 14px 'Inter', sans-serif; }
    .form-grid textarea { min-height: 90px; resize: vertical; }
    .ill-shell button { margin-top: 22px; }
    .ill-note { margin-top: 14px; font-family: 'Geist Mono', monospace; font-size: 10.5px; color: #7A6F68; letter-spacing: 0.05em; line-height: 1.6; }

    /* Inline icon */
    .ic { width: 18px; height: 18px; stroke: currentColor; stroke-width: 2; fill: none; vertical-align: middle; }

    @media (max-width: 880px) {
      .stat-strip { grid-template-columns: repeat(3, 1fr); }
      .stat-strip > div:nth-child(3n) { border-right: none; }
      .stat-strip > div:nth-child(n+4) { border-top: 1px solid rgba(14,11,8,0.10); }
      .search-form { grid-template-columns: 1fr; }
      .cite-tile { grid-template-columns: 1fr; }
      .form-grid { grid-template-columns: 1fr; }
      .sec-head { flex-direction: column; align-items: flex-start; }
    }
  </style>

  <main>

    <!-- HERO -->
    <header class="hero">
      <div class="eyebrow">Campus · District · Library &amp; Archives</div>
      <h1 class="title">Four million <em>sources.</em></h1>
      <p class="sub">A working district library: peer-reviewed papers, primary Vedic manuscripts, indic palm-leaf folios, patent records, open datasets, audio and visual archives, and personal papers donated by scholars. Searchable, citable, and open to every learner on the platform.</p>
    </header>

    <!-- STATS -->
    <div class="stat-strip">
      {stats.map((s) => (
        <div>
          <div class="stat-val">{s.val}</div>
          <div class="stat-lbl">{s.lbl}</div>
        </div>
      ))}
    </div>

    <!-- SEARCH -->
    <section class="block">
      <div class="sec-head">
        <h2 class="sec-title">Search the <em>catalogue</em>.</h2>
        <div class="sec-aside">Indexed every 90 sec · 4.2M handles</div>
      </div>
      <div class="search-shell">
        <form class="search-form" method="POST" action="/portal/library">
          <input type="text" name="q" placeholder="Search title, author, claim, DOI, manuscript folio..." autocomplete="off" />
          <select name="collection">
            <option value="">All collections</option>
            <option value="western-sciences">Western Sciences</option>
            <option value="vedic-primary">Vedic Primary</option>
            <option value="indic-manuscripts">Indic Manuscripts</option>
            <option value="patents">Patent Records</option>
            <option value="datasets">Open Datasets</option>
            <option value="audio">Audio Archives</option>
            <option value="visual">Visual Archives</option>
            <option value="personal-papers">Personal Papers</option>
          </select>
          <select name="kind">
            <option value="">Any kind</option>
            <option value="article">Article</option>
            <option value="book">Book</option>
            <option value="manuscript">Manuscript</option>
            <option value="dataset">Dataset</option>
            <option value="patent">Patent</option>
            <option value="thesis">Thesis</option>
            <option value="audio">Audio</option>
          </select>
          <button type="submit" class="btn-primary">
            <svg class="ic" viewBox="0 0 24 24" style="margin-right:6px"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/></svg>
            Search
          </button>
        </form>
        <div class="search-tags">
          <span class="tag">trending: monsoon precipitation</span>
          <span class="tag">trending: aryabhata sine table</span>
          <span class="tag">trending: graph neural network</span>
          <span class="tag">trending: charaka rasayana</span>
          <span class="tag">trending: superconducting qubit</span>
          <span class="tag">trending: brahmagupta zero</span>
        </div>
      </div>
    </section>

    <!-- COLLECTIONS -->
    <section class="block">
      <div class="sec-head">
        <h2 class="sec-title">Eight <em>collections</em>.</h2>
        <div class="sec-aside">Each catalogued with provenance + handle</div>
      </div>
      <div class="col-grid">
        {collections.map((c, i) => {
          const idx = String(i + 1).padStart(2, '0');
          return (
            <div class="col-card">
              <div class="num">Collection {idx}</div>
              <h3>{c.name}</h3>
              <div class="meta">
                <div><div class="k">Size</div><div class="v">{c.size}</div></div>
                <div><div class="k">Oldest item</div><div class="v">{c.oldest}</div></div>
              </div>
              <p class="desc">{c.desc}</p>
              <div class="fields">
                {c.fields.map((f) => <span class="fld">{f}</span>)}
              </div>
              <a href={c.href}>Browse collection</a>
            </div>
          );
        })}
      </div>
    </section>

    <!-- VEDIC SPOTLIGHT -->
    <section class="block" style="background: linear-gradient(180deg, #FAF8F5 0%, #F5EFE6 100%);">
      <div class="sec-head">
        <h2 class="sec-title">Vedic <em>primary</em> spotlight.</h2>
        <div class="sec-aside">8,400 source folios · 12 cornerstone texts</div>
      </div>
      <div class="vedic-grid">
        {vedicTexts.map((t) => (
          <div class="vedic-card">
            <div class="pp">{t.period}</div>
            <h4>{t.title}</h4>
            <div class="meta-row"><strong>Script</strong>{t.script}</div>
            <div class="meta-row"><strong>Volume</strong>{t.folios}</div>
            <div class="focus">{t.focus}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- AI ASSISTANT -->
    <section class="block">
      <div class="sec-head">
        <h2 class="sec-title">Ask the <em>research assistant</em>.</h2>
        <div class="sec-aside">Grounded in our catalogue · cites every claim</div>
      </div>
      <div class="chat-shell">
        <div class="chat-head">
          <div class="dot"></div>
          <h4>Research Assistant</h4>
          <span class="tag" style="background:rgba(255,79,0,0.2);color:#FF855E;font-family:'Geist Mono',monospace;font-size:10px;padding:4px 10px;border-radius:999px;letter-spacing:0.08em;">retrieval grounded</span>
        </div>
        {aiSamples.map((m) => (
          <div class={`msg ${m.role === 'user' ? 'user' : 'assist'}`}>{m.text}</div>
        ))}
        <div class="chat-input-row">
          <input type="text" placeholder="Ask about a paper, manuscript, dataset, or open question..." />
          <a href="/aquintutor/research/literature">
            <svg class="ic" viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
            Open
          </a>
        </div>
      </div>
    </section>

    <!-- READING ROOMS -->
    <section class="block">
      <div class="sec-head">
        <h2 class="sec-title">Six themed <em>reading rooms</em>.</h2>
        <div class="sec-aside">Live occupancy · bookable in 30 min slots</div>
      </div>
      <div class="rooms-grid">
        {readingRooms.map((r) => {
          const pct = Math.round((r.occupancy / r.seats) * 100);
          const isLow = pct < 50;
          const isMid = pct >= 50 && pct < 80;
          const fillColor = isLow ? '#1A4D2E' : (isMid ? '#B8732D' : '#C42626');
          return (
            <div class="room-card">
              <div class="room-color" style={`background:${r.color}`}></div>
              <h4>{r.name}</h4>
              <div class="theme">{r.theme}</div>
              <div class="occ-bar"><div class="occ-fill" style={`width:${pct}%;background:${fillColor}`}></div></div>
              <div class="occ-meta">
                <span>{r.occupancy} / {r.seats} seats</span>
                <span>{pct}% full</span>
              </div>
              <div class="room-actions">
                <button data-room={r.name}>Reserve seat</button>
                <button data-room={r.name}>Tour 360</button>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- CITATION MANAGER -->
    <section class="block">
      <div class="cite-tile">
        <div>
          <div class="eyebrow" style="margin-bottom:14px">Tool · Citation Manager</div>
          <h3>Cite everything <em>correctly</em>.</h3>
          <p>Persistent BibTeX library shared across your courses, theses, and group projects. Export to nine styles, sync with the catalogue search, attach your own annotations and page references.</p>
          <div class="cite-styles">
            <span class="cite-style">APA 7</span>
            <span class="cite-style">MLA 9</span>
            <span class="cite-style">Chicago 17</span>
            <span class="cite-style">Harvard</span>
            <span class="cite-style">Vancouver</span>
            <span class="cite-style">IEEE</span>
            <span class="cite-style">AMA</span>
            <span class="cite-style">Nature</span>
            <span class="cite-style">BibTeX</span>
          </div>
          <a href="/aquintutor/research/citation">Open citation manager</a>
        </div>
        <div class="cite-preview">
          <div class="lbl">// preview · APA 7</div>
          <div style="margin-top:8px">Plofker, K. (2009).<br/><em style="color:#FF855E">Mathematics in India</em>.<br/>Princeton University Press.</div>
          <div class="lbl" style="margin-top:14px">// preview · BibTeX</div>
          <div style="margin-top:8px">@book{`{`}plofker2009math,<br/>&nbsp;&nbsp;title={`{`}Mathematics in India{`}`},<br/>&nbsp;&nbsp;author={`{`}Plofker, K.{`}`},<br/>&nbsp;&nbsp;year={`{`}2009{`}`}<br/>{`}`}</div>
        </div>
      </div>
    </section>

    <!-- INTER-LIBRARY LOAN -->
    <section class="block">
      <div class="sec-head">
        <h2 class="sec-title">Inter-library <em>loan</em>.</h2>
        <div class="sec-aside">Median fulfilment 8 working days</div>
      </div>
      <div class="ill-shell">
        <h3>Request a physical book</h3>
        <p class="lead">If the item is held by a partner library and not available in our stacks or digital catalogue, we will request a physical copy on your behalf. Most loans are returned to you within two weeks; rare materials may require viewing on-site at our manuscript hall.</p>
        <form class="form-grid" method="POST" action="/api/aquintutor/library/ill-request" id="illForm">
          <label class="full">
            <span class="lk">Title (required)</span>
            <input type="text" name="title" required placeholder="Full title of the book or item" />
          </label>
          <label>
            <span class="lk">Author / Editor</span>
            <input type="text" name="author" placeholder="Surname, given name" />
          </label>
          <label>
            <span class="lk">Year</span>
            <input type="text" name="year" placeholder="e.g. 1998" />
          </label>
          <label>
            <span class="lk">Publisher</span>
            <input type="text" name="publisher" placeholder="If known" />
          </label>
          <label>
            <span class="lk">ISBN / DOI / handle</span>
            <input type="text" name="ident" placeholder="If known" />
          </label>
          <label>
            <span class="lk">Format preference</span>
            <select name="format">
              <option value="any">Either physical or scan</option>
              <option value="physical">Physical only</option>
              <option value="scan">Scan / digital only</option>
            </select>
          </label>
          <label>
            <span class="lk">Needed by</span>
            <input type="date" name="needed_by" />
          </label>
          <label class="full">
            <span class="lk">Reason / context (helps the librarian locate edition)</span>
            <textarea name="reason" placeholder="e.g. chapter 4 on lattice gauge theory, first edition has different equation set..."></textarea>
          </label>
          <button type="submit" class="btn-primary full">Submit request</button>
        </form>
        <p class="ill-note">By submitting you agree to library borrowing rules. Late returns incur platform credit deductions. Rare and manuscript items are non-circulating: viewing slots will be offered in the manuscript hall instead.</p>
      </div>
    </section>

  </main>

  <script is:inline>
    document.querySelectorAll('[data-room]').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const room = e.currentTarget.getAttribute('data-room');
        const label = e.currentTarget.textContent.trim();
        if (label.toLowerCase().indexOf('reserve') === 0) {
          alert('Seat reservation in ' + room + ' will open in your portal. Slots are 30 minutes, renewable.');
        } else {
          alert('360 tour of ' + room + ' is available on a WebXR-capable browser. Open the campus XR hub for the immersive viewer.');
        }
      });
    });

    const ill = document.getElementById('illForm');
    if (ill) {
      ill.addEventListener('submit', (e) => {
        const title = ill.querySelector('input[name="title"]').value.trim();
        if (!title) {
          e.preventDefault();
          alert('Please enter the title of the item.');
          return;
        }
        e.preventDefault();
        alert('Inter-library loan request received for "' + title + '". A librarian will reply within two working days.');
      });
    }
  </script>
</BaseLayout>
