  <script is:inline define:vars={{ vrData: vrCatalogue }}>
    // ===== mini-skylines for each VR thumbnail (hand-drawn canvas) =====
    function paintSkyline(ctx, w, h, seed, palette) {
      ctx.fillStyle = '#0E0B08';
      ctx.fillRect(0, 0, w, h);
      // sky gradient
      const sky = ctx.createLinearGradient(0, 0, 0, h);
      sky.addColorStop(0, palette[0]);
      sky.addColorStop(1, palette[1]);
      ctx.fillStyle = sky;
      ctx.fillRect(0, 0, w, h);
      // stars
      for (let i = 0; i < 18; i++) {
        const x = ((seed * 37 + i * 91) % w);
        const y = ((seed * 13 + i * 53) % (h * 0.55));
        ctx.fillStyle = 'rgba(255,255,255,' + (0.3 + (i % 5) * 0.12) + ')';
        ctx.fillRect(x, y, 1.2, 1.2);
      }
      // moon
      ctx.fillStyle = 'rgba(255,230,200,0.92)';
      ctx.beginPath();
      ctx.arc(w * 0.78, h * 0.28, 12, 0, Math.PI * 2);
      ctx.fill();
      // horizon
      ctx.fillStyle = 'rgba(0,0,0,0.55)';
      ctx.fillRect(0, h * 0.78, w, h * 0.22);
      // silhouette
      ctx.fillStyle = '#000';
      ctx.beginPath();
      ctx.moveTo(0, h);
      let x = 0;
      const baseY = h * 0.78;
      let r = seed;
      while (x < w) {
        const step = 8 + ((r >> 3) % 14);
        r = (r * 9301 + 49297) % 233280;
        const peakH = ((r >> 5) % Math.floor(h * 0.35)) + h * 0.08;
        const peakX = x + step / 2;
        ctx.lineTo(x, baseY);
        ctx.lineTo(peakX - step * 0.3, baseY - peakH * 0.6);
        ctx.lineTo(peakX, baseY - peakH);
        ctx.lineTo(peakX + step * 0.3, baseY - peakH * 0.6);
        ctx.lineTo(x + step, baseY);
        x += step;
        r = (r * 9301 + 49297) % 233280;
      }
      ctx.lineTo(w, h);
      ctx.lineTo(0, h);
      ctx.closePath();
      ctx.fill();
      // accent line
      ctx.strokeStyle = palette[2];
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(0, h - 14);
      ctx.lineTo(w, h - 14);
      ctx.stroke();
    }

    const palettes = [
      ['#1a1410', '#2a1a14', '#FF4F00'],
      ['#0e1a2a', '#1a2a4a', '#7AB0FF'],
      ['#1a0e1a', '#3a1a3a', '#FF7AFF'],
      ['#0e1a0e', '#1a3a1a', '#7AFFAA'],
      ['#2a1a0e', '#4a2a1a', '#FFAA4F'],
      ['#1a1a0e', '#3a3a1a', '#FFFF7A'],
    ];

    document.querySelectorAll('[data-vr-canvas]').forEach(c => {
      const i = parseInt(c.getAttribute('data-vr-canvas'), 10);
      const ctx = c.getContext('2d');
      const w = c.width, h = c.height;
      const p = palettes[i % palettes.length];
      paintSkyline(ctx, w, h, i * 17 + 99, p);
    });

    // ===== modal =====
    const modal = document.getElementById('vrModal');
    const mClose = document.getElementById('vrModalClose');
    const mCanvas = document.getElementById('mCanvas');
    const mTitle = document.getElementById('mTitle');
    const mDetail = document.getElementById('mDetail');
    const mEra = document.getElementById('mEra');
    const mRegion = document.getElementById('mRegion');
    const mMinutes = document.getElementById('mMinutes');
    const mKicker = document.getElementById('mKicker');

    document.querySelectorAll('[data-vr]').forEach(el => {
      el.addEventListener('click', () => {
        const i = parseInt(el.getAttribute('data-vr'), 10);
        const v = vrData[i];
        mTitle.textContent = v.name;
        mKicker.textContent = 'Reconstruction · ' + v.kind;
        mDetail.textContent = v.detail + ' This reconstruction was rebuilt from a combination of photogrammetric data, published period survey, and our own site visits where access permitted. The room runs in walkable VR at 90 Hz; a non-VR fallback browser view is provided.';
        mEra.textContent = ' ' + v.era;
        mRegion.textContent = ' ' + v.region;
        mMinutes.textContent = ' ' + v.minutes + ' minutes';
        const ctx = mCanvas.getContext('2d');
        paintSkyline(ctx, mCanvas.width, mCanvas.height, i * 41 + 7, palettes[i % palettes.length]);
        // overlay title in canvas
        ctx.fillStyle = 'rgba(255,255,255,0.92)';
        ctx.font = '20px "Cormorant Garamond", serif';
        ctx.fillText(v.name, 20, mCanvas.height - 28);
        ctx.font = '11px "Geist Mono", monospace';
        ctx.fillStyle = 'rgba(255,79,0,0.95)';
        ctx.fillText(v.era.toUpperCase(), 20, mCanvas.height - 12);
        modal.classList.add('open');
      });
    });
    mClose.addEventListener('click', () => modal.classList.remove('open'));
    modal.addEventListener('click', e => { if (e.target === modal) modal.classList.remove('open'); });

    // ===== toast =====
    const toast = document.getElementById('toast');
    function showToast(msg) {
      toast.textContent = msg;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 2400);
    }

    document.getElementById('mEnter').addEventListener('click', () => {
      showToast('Headset bay 3 reserved. Walk-in within 20 minutes.');
    });
    document.getElementById('mNotes').addEventListener('click', () => {
      showToast('Conservation notes downloaded as PDF stub.');
    });

    // ===== calendar filters =====
    const calRows = document.querySelectorAll('#calList .cal-row');
    const calSearch = document.getElementById('calSearch');
    let activeFilter = 'all';

    function applyCalFilters() {
      const q = calSearch.value.trim().toLowerCase();
      calRows.forEach(r => {
        const kind = r.getAttribute('data-kind');
        const text = r.getAttribute('data-text');
        const kindOk = activeFilter === 'all' || kind === activeFilter;
        const textOk = !q || text.includes(q);
        r.style.display = (kindOk && textOk) ? '' : 'none';
      });
    }
    calSearch.addEventListener('input', applyCalFilters);
    document.querySelectorAll('.cal-filter').forEach(b => {
      b.addEventListener('click', () => {
        document.querySelectorAll('.cal-filter').forEach(x => x.classList.remove('active'));
        b.classList.add('active');
        activeFilter = b.getAttribute('data-filter');
        applyCalFilters();
      });
    });

    // ===== literacy track form =====
    const litForm = document.getElementById('litForm');
    litForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const fd = new FormData(litForm);
      if (!fd.get('fullName') || !fd.get('email') || !fd.get('year') || !fd.get('track')) {
        showToast('Please complete all required fields.');
        return;
      }
      const key = 'aquin_cultural_literacy_apps';
      let arr = [];
      try { arr = JSON.parse(localStorage.getItem(key) || '[]'); } catch (e) {}
      arr.push({
        ts: new Date().toISOString(),
        name: fd.get('fullName'),
        email: fd.get('email'),
        year: fd.get('year'),
        track: fd.get('track'),
        reason: fd.get('reason'),
      });
      localStorage.setItem(key, JSON.stringify(arr));
      litForm.reset();
      showToast('Application received. We will write back within five working days.');
    });
  </script>
</AquintutorLayout>
