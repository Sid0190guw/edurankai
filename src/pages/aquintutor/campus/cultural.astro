---

<AquintutorLayout title="Cultural Pavilions — AquinTutor Campus" description="Six cultural pavilions, archaeological VR catalogue, live performance residencies and a twelve-week cultural literacy track at AquinTutor.">
  <style>
    :root {
      --cream: #FAF8F5;
      --ink: #0E0B08;
      --burn: #FF4F00;
      --paper: #FFFFFF;
      --rule: rgba(14,11,8,0.10);
      --mute: #2E2520;
      --mute-2: #7A6F68;
    }
    body { background: var(--cream); color: var(--ink); font-family: 'Geist', 'Inter', system-ui, sans-serif; }
    main.cultural { display: block; }

    .hero { padding: 70px 5vw 50px; max-width: 1280px; margin: 0 auto; }
    .crumb { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--mute-2); margin-bottom: 26px; display: flex; gap: 10px; align-items: center; }
    .crumb a { color: var(--mute-2); text-decoration: none; }
    .crumb a:hover { color: var(--burn); }
    .eyebrow { font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--burn); font-weight: 700; margin-bottom: 18px; }
    .title { font-family: 'Cormorant Garamond', 'Fraunces', serif; font-size: clamp(40px, 7vw, 84px); font-weight: 600; letter-spacing: -0.035em; line-height: 1.02; margin: 0 0 24px; max-width: 1100px; }
    .title em { font-style: italic; color: var(--burn); font-weight: 500; }
    .sub { font-size: 17px; color: var(--mute); max-width: 720px; line-height: 1.7; margin-bottom: 38px; }
    .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }
    .btn { background: var(--burn); color: #fff; padding: 14px 28px; border-radius: 10px; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; border: none; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 10px; }
    .btn:hover { filter: brightness(0.94); }
    .btn-ghost { background: var(--paper); color: var(--ink); border: 1px solid var(--rule); }

    .stat-strip { border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); display: grid; grid-template-columns: repeat(4, 1fr); max-width: 1280px; margin: 0 auto; }
    .stat { padding: 26px 5vw; border-right: 1px solid var(--rule); }
    .stat:last-child { border-right: none; }
    .stat-val { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 600; line-height: 1; margin-bottom: 8px; }
    .stat-lbl { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--mute-2); }

    section.block { padding: 70px 5vw; border-bottom: 1px solid var(--rule); max-width: 1280px; margin: 0 auto; }
    .block-head { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 36px; flex-wrap: wrap; gap: 20px; }
    .h-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--burn); font-weight: 700; margin-bottom: 12px; }
    .h-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(30px, 4.4vw, 50px); font-weight: 600; letter-spacing: -0.025em; line-height: 1.08; margin: 0; max-width: 760px; }
    .h-sub { font-size: 14.5px; color: var(--mute); max-width: 460px; line-height: 1.65; }

    /* Pavilions grid */
    .pav-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 26px; }
    .pav { background: var(--paper); border: 1px solid var(--rule); border-radius: 14px; padding: 28px; position: relative; overflow: hidden; }
    .pav::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: var(--accent); }
    .pav-name { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 6px; }
    .pav-kicker { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mute-2); margin-bottom: 16px; }
    .pav-desc { font-size: 14.5px; color: var(--mute); line-height: 1.7; margin-bottom: 18px; }
    .pav-now { background: var(--cream); border-radius: 10px; padding: 14px 16px; margin-bottom: 18px; border-left: 3px solid var(--accent); }
    .pav-now-lbl { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mute-2); margin-bottom: 4px; }
    .pav-now-title { font-family: 'Cormorant Garamond', serif; font-size: 19px; font-weight: 600; line-height: 1.25; margin-bottom: 6px; }
    .pav-now-note { font-size: 13px; color: var(--mute); line-height: 1.5; }
    .pav-meta { display: flex; gap: 16px; padding-top: 14px; border-top: 1px solid var(--rule); margin-bottom: 18px; }
    .pav-meta div { flex: 1; }
    .pav-meta-v { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 600; line-height: 1; margin-bottom: 4px; }
    .pav-meta-l { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--mute-2); }
    .pav-cta { display: inline-flex; align-items: center; gap: 8px; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); text-decoration: none; font-weight: 800; }
    .pav-cta:hover { gap: 12px; }

    /* Calendar */
    .cal-tools { display: flex; gap: 14px; align-items: center; flex-wrap: wrap; margin-bottom: 24px; }
    .cal-search { background: var(--paper); border: 1px solid var(--rule); border-radius: 10px; padding: 11px 16px; font-family: 'Geist Mono', monospace; font-size: 12px; min-width: 240px; }
    .cal-filter { background: var(--paper); border: 1px solid var(--rule); border-radius: 10px; padding: 10px 16px; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer; }
    .cal-filter.active { background: var(--ink); color: var(--cream); }
    .cal { background: var(--paper); border: 1px solid var(--rule); border-radius: 14px; overflow: hidden; }
    .cal-row { display: grid; grid-template-columns: 110px 110px 1fr 200px 140px 140px; gap: 0; padding: 18px 22px; border-top: 1px solid var(--rule); align-items: center; transition: background 0.15s; }
    .cal-row:first-child { border-top: none; }
    .cal-row:hover { background: var(--cream); }
    .cal-day { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mute-2); }
    .cal-day strong { display: block; font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; color: var(--ink); letter-spacing: -0.01em; margin-top: 2px; }
    .cal-time { font-family: 'Geist Mono', monospace; font-size: 13px; font-weight: 700; color: var(--ink); }
    .cal-title { font-family: 'Cormorant Garamond', serif; font-size: 19px; font-weight: 600; line-height: 1.3; }
    .cal-who { font-size: 13px; color: var(--mute); }
    .cal-pavilion { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mute-2); }
    .cal-kind { display: inline-flex; padding: 5px 10px; border-radius: 20px; background: var(--cream); font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 700; color: var(--ink); justify-self: end; }
    .cal-kind.midnight { background: var(--ink); color: var(--burn); }

    /* VR catalogue */
    .vr-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
    .vr { background: var(--paper); border: 1px solid var(--rule); border-radius: 12px; padding: 18px; cursor: pointer; transition: transform 0.2s, border-color 0.2s; position: relative; }
    .vr:hover { transform: translateY(-2px); border-color: var(--burn); }
    .vr-canvas-wrap { background: var(--ink); border-radius: 8px; overflow: hidden; height: 120px; margin-bottom: 14px; position: relative; }
    .vr canvas { display: block; width: 100%; height: 100%; }
    .vr-name { font-family: 'Cormorant Garamond', serif; font-size: 19px; font-weight: 600; line-height: 1.2; margin-bottom: 4px; }
    .vr-region { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mute-2); margin-bottom: 6px; }
    .vr-era { font-size: 12.5px; color: var(--mute); margin-bottom: 8px; font-style: italic; }
    .vr-detail { font-size: 12px; color: var(--mute); line-height: 1.5; margin-bottom: 12px; }
    .vr-foot { display: flex; justify-content: space-between; align-items: center; padding-top: 10px; border-top: 1px solid var(--rule); }
    .vr-foot-time { font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; color: var(--burn); }
    .vr-foot-kind { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--mute-2); }

    /* Residencies */
    .res-model { background: var(--paper); border: 1px solid var(--rule); border-radius: 14px; padding: 28px; margin-bottom: 30px; display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 28px; }
    .res-model h4 { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; margin: 0 0 10px; letter-spacing: -0.01em; }
    .res-model p { font-size: 14px; color: var(--mute); line-height: 1.65; margin: 0; }
    .res-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
    .res { background: var(--paper); border: 1px solid var(--rule); border-radius: 12px; padding: 18px; }
    .res-avatar { width: 48px; height: 48px; border-radius: 24px; background: var(--burn); display: flex; align-items: center; justify-content: center; color: #fff; font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; margin-bottom: 14px; }
    .res-name { font-family: 'Cormorant Garamond', serif; font-size: 19px; font-weight: 600; margin: 0 0 4px; }
    .res-disc { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mute-2); margin-bottom: 10px; }
    .res-from { font-size: 12.5px; color: var(--mute); margin-bottom: 6px; font-style: italic; }
    .res-term { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--ink); font-weight: 700; margin-bottom: 10px; }
    .res-proj { font-size: 12.5px; color: var(--mute); line-height: 1.55; padding-top: 10px; border-top: 1px solid var(--rule); }

    /* Literacy track */
    .lit-wrap { display: grid; grid-template-columns: 1.6fr 1fr; gap: 32px; }
    .lit-list { background: var(--paper); border: 1px solid var(--rule); border-radius: 14px; overflow: hidden; }
    .lit-row { display: grid; grid-template-columns: 60px 1fr 1fr; gap: 0; padding: 16px 20px; border-top: 1px solid var(--rule); align-items: center; }
    .lit-row:first-child { border-top: none; }
    .lit-row:hover { background: var(--cream); }
    .lit-week { font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 800; color: var(--burn); }
    .lit-topic { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; line-height: 1.25; }
    .lit-read { font-size: 12.5px; color: var(--mute); font-style: italic; }
    .lit-form { background: var(--paper); border: 1px solid var(--rule); border-radius: 14px; padding: 26px; height: fit-content; position: sticky; top: 20px; }
    .lit-form h4 { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 600; margin: 0 0 8px; letter-spacing: -0.02em; }
    .lit-form p { font-size: 13.5px; color: var(--mute); line-height: 1.6; margin: 0 0 22px; }
    .lit-form label { display: block; font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mute-2); margin: 14px 0 6px; font-weight: 700; }
    .lit-form input, .lit-form select, .lit-form textarea { width: 100%; background: var(--cream); border: 1px solid var(--rule); border-radius: 8px; padding: 11px 14px; font-family: 'Geist', sans-serif; font-size: 14px; color: var(--ink); box-sizing: border-box; }
    .lit-form textarea { min-height: 80px; resize: vertical; font-family: 'Geist', sans-serif; }
    .lit-form button { width: 100%; margin-top: 20px; }
    .lit-form-meta { display: flex; justify-content: space-between; padding: 14px 0 0; margin-top: 14px; border-top: 1px solid var(--rule); font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--mute-2); }

    /* VR detail modal */
    .vr-modal { position: fixed; inset: 0; background: rgba(14,11,8,0.55); display: none; align-items: center; justify-content: center; z-index: 9999; padding: 5vw; }
    .vr-modal.open { display: flex; }
    .vr-modal-inner { background: var(--paper); border-radius: 16px; max-width: 720px; width: 100%; padding: 36px; max-height: 88vh; overflow-y: auto; position: relative; }
    .vr-modal-close { position: absolute; top: 18px; right: 18px; background: var(--cream); border: 1px solid var(--rule); border-radius: 8px; padding: 8px 10px; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11px; }
    .vr-modal h3 { font-family: 'Cormorant Garamond', serif; font-size: 36px; font-weight: 600; margin: 0 0 8px; letter-spacing: -0.02em; }
    .vr-modal .m-kicker { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--burn); margin-bottom: 16px; }
    .vr-modal-canvas { background: var(--ink); border-radius: 12px; height: 280px; margin: 18px 0; }
    .vr-modal-canvas canvas { display: block; width: 100%; height: 100%; }
    .vr-modal-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 18px; padding: 18px 0; border-top: 1px solid var(--rule); margin-top: 12px; }
    .vr-modal-row div { font-size: 13px; }
    .vr-modal-row b { display: block; font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mute-2); font-weight: 700; margin-bottom: 4px; }

    /* Toast */
    .toast { position: fixed; bottom: 24px; right: 24px; background: var(--ink); color: var(--cream); padding: 14px 22px; border-radius: 10px; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.06em; transform: translateY(120%); transition: transform 0.3s; z-index: 9999; max-width: 360px; }
    .toast.show { transform: translateY(0); }

    .svg-i { width: 16px; height: 16px; }

    @media (max-width: 900px) {
      .pav-grid, .vr-grid, .res-grid { grid-template-columns: repeat(2, 1fr); }
      .res-model { grid-template-columns: 1fr; }
      .lit-wrap { grid-template-columns: 1fr; }
