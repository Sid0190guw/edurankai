---
// /aquintutor/accessibility — student accessibility settings (Prompt AP4b). Reduced motion (static
// animations), high contrast, larger text, and screen-reader mode. Saved to the account and applied
// immediately. Reduced motion also switches the animation engine to a static render.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/accessibility');
let a: any = {};
try { const { getProfile } = await import('@/lib/student-settings'); a = (await getProfile(user.id)).accessibility || {}; } catch {}
const opts = [
  { key: 'reduceMotion', label: 'Reduce motion', desc: 'Animations render as a still image instead of moving.' },
  { key: 'highContrast', label: 'High contrast', desc: 'Stronger borders and darker text for readability.' },
  { key: 'screenReader', label: 'Screen-reader mode', desc: 'Extra labels and a simpler reading order for assistive tech.' },
];
---
<AquintutorLayout title="Accessibility">
  <main style="max-width:680px;margin:0 auto;padding:40px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Accessibility</p>
    <h1 style="font-family:Fraunces,serif;font-size:30px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 6px;">Make it work for you</h1>
    <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#6b6455;margin:0 0 24px;">These apply across the platform and are saved to your account. Reduced motion also makes the animation board render as a still image.</p>
    <div id="msg" role="status" aria-live="polite" style="display:none;margin:0 0 14px;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <form id="a11yForm" style="display:flex;flex-direction:column;gap:14px;">
      {opts.map((o) => (
        <label style="display:flex;gap:12px;align-items:flex-start;background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:12px;padding:14px 16px;cursor:pointer;">
          <input type="checkbox" name={o.key} checked={!!a[o.key]} style="margin-top:3px;width:18px;height:18px;" />
          <span><span style="font-family:'Inter Tight',sans-serif;font-size:15px;font-weight:600;color:var(--ink,#1a1712);">{o.label}</span><br><span style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#6b6455;">{o.desc}</span></span>
        </label>
      ))}
      <label style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:12px;padding:14px 16px;">
        <span style="font-family:'Inter Tight',sans-serif;font-size:15px;font-weight:600;color:var(--ink,#1a1712);">Text size</span><br>
        <input type="range" name="textScale" min="1" max="1.6" step="0.1" value={a.textScale || 1} style="width:100%;margin-top:8px;" aria-label="Text size" />
      </label>
      <button type="submit" style="align-self:flex-start;background:var(--ink,#1a1712);color:#fff;border:none;border-radius:9px;padding:11px 22px;font-family:'Inter Tight',sans-serif;font-size:15px;font-weight:600;cursor:pointer;">Save</button>
    </form>
  </main>

  <script is:inline>
    document.getElementById('a11yForm').addEventListener('submit', function (e) {
      e.preventDefault(); var f = e.target, msg = document.getElementById('msg');
      var body = { reduceMotion: f.reduceMotion.checked, highContrast: f.highContrast.checked, screenReader: f.screenReader.checked, textScale: Number(f.textScale.value) };
      fetch('/api/aquintutor/a11y', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
        .then(function (r) { return r.json(); }).then(function (j) { msg.style.display = 'block'; if (j.ok) { msg.style.background = '#eef8f1'; msg.style.color = '#2f7d5b'; msg.textContent = 'Saved. Applying…'; setTimeout(function () { location.reload(); }, 600); } else { msg.style.background = '#fdecec'; msg.style.color = '#9b2c2c'; msg.textContent = j.error || 'Failed'; } });
    });
  </script>
</AquintutorLayout>
