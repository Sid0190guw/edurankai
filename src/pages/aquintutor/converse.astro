---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { isFeatureEnabled } from '@/lib/feature-flags';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/converse'));
// Hidden until verified functional — admin toggles at /admin/feature-flags.
if (!(await isFeatureEnabled('aiTutor'))) return Astro.redirect('/aquintutor/dashboard');

const url = new URL(Astro.request.url);
const language = url.searchParams.get('lang') || 'en';
const topic = url.searchParams.get('topic') || '';
const level = url.searchParams.get('level') || 'beginner';

const LANGS = [
  { code: 'en', name: 'English', tts: 'en-IN' },
  { code: 'hi', name: 'Hindi', tts: 'hi-IN' },
  { code: 'sa', name: 'Sanskrit', tts: 'hi-IN' },
  { code: 'bn', name: 'Bengali', tts: 'bn-IN' },
  { code: 'ta', name: 'Tamil', tts: 'ta-IN' },
  { code: 'te', name: 'Telugu', tts: 'te-IN' },
  { code: 'mr', name: 'Marathi', tts: 'mr-IN' },
  { code: 'gu', name: 'Gujarati', tts: 'gu-IN' },
  { code: 'es', name: 'Spanish', tts: 'es-ES' },
  { code: 'fr', name: 'French', tts: 'fr-FR' },
  { code: 'de', name: 'German', tts: 'de-DE' },
  { code: 'ja', name: 'Japanese', tts: 'ja-JP' },
  { code: 'zh', name: 'Mandarin', tts: 'zh-CN' },
  { code: 'ar', name: 'Arabic', tts: 'ar-SA' },
];

const TOPICS = ['Introduce yourself', 'Order food at a restaurant', 'Talk about your weekend', 'Discuss a movie you watched', 'Plan a trip', 'Job interview practice', 'Negotiate a price', 'Argue your favourite philosophy'];
---
<AquintutorLayout title="AI Tutor — Conversation Practice" description="Practise any language by chatting with an AI tutor.">
  <section style="border-bottom:1px solid var(--rule); background:linear-gradient(180deg,#fff8f3 0%, var(--paper) 100%);">
    <div style="max-width:920px; margin:0 auto; padding:36px 28px 24px;">
      <p style="font-family:'Inter Tight',monospace; font-size:12px; color:var(--rust); font-weight:700; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">AI Tutor</p>
      <h1 class="font-display" style="font-size:clamp(1.8rem,3.5vw,2.6rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500; margin:0 0 8px;">Talk to your tutor.</h1>
      <p style="font-family:'Inter Tight',sans-serif; font-size:14.5px; color:var(--ink-500); line-height:1.6;">Pick a language, set a topic. Type or speak — the tutor replies in your target language with translation hints at beginner level. Each turn earns 4 XP.</p>
    </div>
  </section>

  <section>
    <div style="max-width:920px; margin:0 auto; padding:20px 28px 80px;">
      <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-bottom:14px;" class="cfg-grid">
        <div>
          <label style="font-family:'Inter Tight',monospace; font-size:10px; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink-500); font-weight:700;">Language</label>
          <select id="lang" style="width:100%; margin-top:5px; padding:10px 12px; border:1px solid var(--rule); border-radius:8px; font-family:inherit; font-size:14px; background:var(--paper);">
            {LANGS.map(l => <option value={l.code} selected={l.code === language} data-tts={l.tts}>{l.name}</option>)}
          </select>
        </div>
        <div>
          <label style="font-family:'Inter Tight',monospace; font-size:10px; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink-500); font-weight:700;">Level</label>
          <select id="level" style="width:100%; margin-top:5px; padding:10px 12px; border:1px solid var(--rule); border-radius:8px; font-family:inherit; font-size:14px; background:var(--paper);">
            <option value="beginner" selected={level === 'beginner'}>Beginner (with English hints)</option>
            <option value="intermediate" selected={level === 'intermediate'}>Intermediate</option>
            <option value="advanced" selected={level === 'advanced'}>Advanced</option>
          </select>
        </div>
        <div>
          <label style="font-family:'Inter Tight',monospace; font-size:10px; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink-500); font-weight:700;">Topic</label>
          <select id="topic" style="width:100%; margin-top:5px; padding:10px 12px; border:1px solid var(--rule); border-radius:8px; font-family:inherit; font-size:14px; background:var(--paper);">
            <option value="">Open conversation</option>
            {TOPICS.map(t => <option value={t} selected={t === topic}>{t}</option>)}
          </select>
        </div>
      </div>

      <div id="chat" style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:18px; height:480px; overflow-y:auto; margin-bottom:14px;">
        <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink-500); text-align:center; padding:40px 14px;">Type a message below to start. Your tutor will greet you in the language you picked.</p>
      </div>

      <div style="display:flex; gap:8px;">
        <button type="button" id="micBtn" title="Speak" style="background:var(--paper); color:var(--ink); border:1px solid var(--rule); padding:0 14px; border-radius:10px; font-size:18px; cursor:pointer;">🎤</button>
        <input type="text" id="msg" placeholder="Type a message…" autocomplete="off" style="flex:1; padding:14px 16px; border:1px solid var(--rule); border-radius:10px; font-family:inherit; font-size:15px; outline:none;" />
        <button type="button" id="sendBtn" style="background:var(--rust); color:#fff; padding:0 22px; border:none; border-radius:10px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:700; cursor:pointer;">Send →</button>
      </div>
      <p id="micStatus" style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--ink-500); margin:8px 0 0; min-height:14px;"></p>
    </div>
  </section>

  <script is:inline>
  (function () {
    var chatEl = document.getElementById('chat');
    var input = document.getElementById('msg');
    var sendBtn = document.getElementById('sendBtn');
    var micBtn = document.getElementById('micBtn');
    var micStatus = document.getElementById('micStatus');
    var langSel = document.getElementById('lang');
    var levelSel = document.getElementById('level');
    var topicSel = document.getElementById('topic');
    var conversationId = null;
    function esc(s) { return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) { return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]; }); }
    function ttsLang() { var sel = langSel.options[langSel.selectedIndex]; return sel && sel.getAttribute('data-tts') || 'en-IN'; }
    function speak(text) {
      try { if ('speechSynthesis' in window) { window.speechSynthesis.cancel(); var u = new SpeechSynthesisUtterance(text); u.lang = ttsLang(); u.rate = 0.9; window.speechSynthesis.speak(u); } } catch (_) {}
    }
    function bubble(role, text) {
      if (chatEl.children.length === 1 && chatEl.firstElementChild.tagName === 'P') chatEl.innerHTML = '';
      var div = document.createElement('div');
      div.style.cssText = 'display:flex;justify-content:' + (role === 'user' ? 'flex-end' : 'flex-start') + ';margin-bottom:10px;';
      var inner = document.createElement('div');
      inner.style.cssText = 'max-width:78%;padding:11px 16px;border-radius:14px;font-family:inherit;font-size:14.5px;line-height:1.55;' + (role === 'user' ? 'background:var(--ink);color:#fff;' : 'background:var(--sand-100);color:var(--ink);border:1px solid var(--rule);');
      inner.textContent = text;
      if (role === 'assistant') {
        var b = document.createElement('button');
        b.textContent = '🔊';
        b.style.cssText = 'margin-top:6px;background:none;border:1px solid var(--rule);padding:3px 8px;border-radius:6px;cursor:pointer;font-size:11px;';
        b.addEventListener('click', function () { speak(text); });
        inner.appendChild(document.createElement('br'));
        inner.appendChild(b);
      }
      div.appendChild(inner);
      chatEl.appendChild(div);
      chatEl.scrollTop = chatEl.scrollHeight;
    }
    function send() {
      var msg = input.value.trim();
      if (!msg) return;
      input.value = ''; sendBtn.disabled = true;
      bubble('user', msg);
      var typing = document.createElement('div');
      typing.id = 'typing'; typing.style.cssText = 'display:flex;justify-content:flex-start;margin-bottom:10px;';
      typing.innerHTML = '<div style="padding:11px 16px;background:var(--sand-100);border:1px solid var(--rule);border-radius:14px;font-family:inherit;font-size:14px;color:var(--ink-500);">…</div>';
      chatEl.appendChild(typing); chatEl.scrollTop = chatEl.scrollHeight;
      fetch('/api/aquintutor/converse', { method:'POST', credentials:'same-origin', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ conversationId: conversationId, language: langSel.value, level: levelSel.value, topic: topicSel.value, message: msg })})
        .then(function (r) { return r.json(); })
        .then(function (d) {
          typing.remove();
          sendBtn.disabled = false;
          if (!d.ok) { bubble('assistant', '⚠ ' + (d.error || 'something went wrong')); return; }
          conversationId = d.conversationId;
          bubble('assistant', d.reply);
          speak(d.reply);
        }).catch(function () { typing.remove(); sendBtn.disabled = false; bubble('assistant', '⚠ network error'); });
    }
    sendBtn.addEventListener('click', send);
    input.addEventListener('keydown', function (e) { if (e.key === 'Enter') send(); });

    // Speech recognition for the mic button
    var SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SR) { micBtn.disabled = true; micBtn.title = 'Speech recognition not supported in this browser'; }
    else {
      var rec = null, listening = false;
      micBtn.addEventListener('click', function () {
        if (listening && rec) { rec.stop(); return; }
        rec = new SR();
        rec.lang = ttsLang();
        rec.continuous = false; rec.interimResults = true;
        rec.onresult = function (e) {
          var partial = ''; for (var i = e.resultIndex; i < e.results.length; i++) partial += e.results[i][0].transcript;
          input.value = partial;
        };
        rec.onstart = function () { listening = true; micBtn.textContent = '🔴'; micStatus.textContent = 'Listening in ' + langSel.options[langSel.selectedIndex].text + '…'; };
        rec.onend = function () { listening = false; micBtn.textContent = '🎤'; micStatus.textContent = ''; };
        rec.onerror = function (e) { micStatus.textContent = 'Mic error: ' + e.error; };
        try { rec.start(); } catch (_) {}
      });
    }
  })();
  </script>
</AquintutorLayout>
