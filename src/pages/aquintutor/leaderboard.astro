---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/leaderboard'));

const url = new URL(Astro.request.url);
const period = (url.searchParams.get('period') || 'week').toLowerCase();
---
<AquintutorLayout title="Leaderboard" description="Weekly + all-time XP rankings.">
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:880px; margin:0 auto; padding:48px 28px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:700; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Leaderboard</p>
      <h1 class="font-display" style="font-size:clamp(2rem,4vw,3rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500; margin:0 0 6px;">
        Who's putting in the work.
      </h1>
      <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); line-height:1.6;">XP earned across practice rounds, official tests, and lessons. Reset weekly + monthly. Be nice; this is a learning community.</p>

      <div style="display:flex; gap:6px; margin-top:24px;">
        {['week','month','all'].map(p => (
          <a href={'?period=' + p} style={'padding:8px 16px; border-radius:8px; font-family:Inter Tight,sans-serif; font-size:13px; font-weight:600; text-decoration:none; ' + (p === period ? 'background:var(--ink); color:#fff;' : 'background:var(--sand-100); color:var(--ink-500); border:1px solid var(--rule);')}>
            {p === 'week' ? 'This week' : p === 'month' ? 'This month' : 'All time'}
          </a>
        ))}
      </div>

      <div id="lb" style="margin-top:28px;">
        <p style="font-size:14px; color:var(--ink-500); font-family:'Inter Tight',sans-serif;">Loading…</p>
      </div>

      <p style="font-size:12.5px; color:var(--ink-500); margin-top:22px;">Names shown as first name + last initial. Sign in is required to appear.</p>
    </div>
  </section>

  <script is:inline define:vars={{ period }}>
    (function () {
      var box = document.getElementById('lb');
      fetch('/api/aquintutor/leaderboard?period=' + period + '&limit=25', { credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (!d.ok || !d.leaderboard || !d.leaderboard.length) {
            box.innerHTML = '<p style="font-family:Inter Tight,sans-serif; font-size:14px; color:var(--ink-500);">No XP earned in this period yet. Be the first — take a practice round.</p>';
            return;
          }
          var html = '<div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; overflow:hidden;">';
          d.leaderboard.forEach(function (r) {
            var mc = { 1: ['#facc15', '#b8860b'], 2: ['#cbd5e1', '#64748b'], 3: ['#d97706', '#b45309'] }[r.rank];
            var medal = mc ? '<span style="display:inline-flex;align-items:center;justify-content:center;width:26px;height:26px;border-radius:50%;background:' + mc[0] + '33;color:' + mc[1] + ';font-size:12px;font-weight:800;">' + r.rank + '</span>' : '';
            html += '<div style="display:grid; grid-template-columns:50px 1fr 100px; gap:14px; align-items:center; padding:14px 18px; border-bottom:1px solid var(--rule); ' + (r.isMe ? 'background:rgba(217,119,87,0.07);' : '') + '">'
              + '<span style="font-family:JetBrains Mono,monospace; font-size:14px; font-weight:700; color:var(--ink); text-align:right;">' + (medal || ('#' + r.rank)) + '</span>'
              + '<span style="font-family:Inter Tight,sans-serif; font-size:15px; font-weight:' + (r.isMe ? '700;color:var(--rust)' : '500;color:var(--ink)') + ';">' + r.name + (r.isMe ? ' · you' : '') + '</span>'
              + '<span style="font-family:JetBrains Mono,monospace; font-size:14px; font-weight:700; color:var(--rust); text-align:right;">' + r.xp.toLocaleString() + ' XP</span>'
              + '</div>';
          });
          html += '</div>';
          if (d.myRank && d.leaderboard.findIndex(function(r) { return r.isMe; }) < 0) {
            html += '<div style="margin-top:18px; padding:12px 18px; background:rgba(217,119,87,0.07); border:1px dashed rgba(217,119,87,0.4); border-radius:10px; font-family:Inter Tight,sans-serif; font-size:14px;"><b>Your standing:</b> #' + d.myRank.rank + ' with ' + d.myRank.xp.toLocaleString() + ' XP</div>';
          }
          box.innerHTML = html;
        }).catch(function () {
          box.innerHTML = '<p style="font-family:Inter Tight,sans-serif; font-size:14px; color:var(--ink-500);">Could not load — try again.</p>';
        });
    })();
  </script>
</AquintutorLayout>
