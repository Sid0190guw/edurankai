---
// /aquintutor/admission — applicant application + screening interview + status (Prompt 16, main).
// Applicants see only their own. Honest: the screening interview is an aid, not accreditation.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { myApplication, INTERVIEW_QUESTIONS, isEnrolmentEligible } from '@/lib/admissions';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/admission');
const app = await myApplication(user.id).catch(() => null);
const phase = !app || app.status === 'rejected' && false ? 'apply' : (app.status === 'submitted' || app.status === 'interviewing') ? 'interview' : 'status';
const CARD = 'background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:14px;padding:22px 24px;margin-bottom:16px;';
const IN = 'font-family:Inter Tight,sans-serif;font-size:14px;padding:9px 11px;border:1px solid var(--line,#e6e1d6);border-radius:9px;width:100%;box-sizing:border-box;';
const statusColor: Record<string, string> = { accepted: '#1f7a4d', waitlisted: '#8a5a1a', rejected: '#9b2c2c', interviewed: '#5a5aa8', submitted: '#6b6455' };
---
<AquintutorLayout title="Admission">
  <main style="max-width:680px;margin:0 auto;padding:44px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Admission</p>
    <h1 style="font-family:Fraunces,serif;font-size:32px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 8px;line-height:1.15;">Apply to a programme</h1>
    <p style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:#6b6455;margin:0 0 20px;">The screening interview helps us understand your goals. It is an aid to the registrar's review — not an accreditation decision.</p>
    <div id="msg" style="display:none;margin:0 0 16px;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    {!app ? (
      <div style={CARD}>
        <h2 style="font-family:Fraunces,serif;font-size:18px;font-weight:600;margin:0 0 12px;">Your application</h2>
        <label style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:var(--ink,#1a1712);">Programme<br/><input id="fProgram" placeholder="e.g. Foundations of Data Science" style={IN + 'margin:4px 0 12px;'} /></label>
        <label style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:var(--ink,#1a1712);">Your background &amp; goals<br/><textarea id="fBackground" rows="4" placeholder="A few lines about your background and what you want to achieve." style={IN + 'margin:4px 0 12px;'}></textarea></label>
        <button id="submitBtn" type="button" style="background:var(--ink,#1a1712);color:var(--sand-50,#fbfaf4);border:none;border-radius:10px;padding:11px 22px;font-family:'Inter Tight',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">Submit application</button>
      </div>
    ) : phase === 'interview' ? (
      <div style={CARD}>
        <h2 style="font-family:Fraunces,serif;font-size:18px;font-weight:600;margin:0 0 4px;">Screening interview</h2>
        <p style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#6b6455;margin:0 0 14px;">Programme: <b>{app.program}</b>. Answer in your own words.</p>
        {INTERVIEW_QUESTIONS.map((qn, i) => (
          <label style="display:block;font-family:'Inter Tight',sans-serif;font-size:14px;color:var(--ink,#1a1712);margin-bottom:14px;">{i + 1}. {qn}<br/><textarea class="ans" rows="3" style={IN + 'margin-top:5px;'}></textarea></label>
        ))}
        <button id="interviewBtn" type="button" style="background:var(--ink,#1a1712);color:var(--sand-50,#fbfaf4);border:none;border-radius:10px;padding:11px 22px;font-family:'Inter Tight',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">Submit interview</button>
      </div>
    ) : (
      <div style={CARD}>
        <h2 style="font-family:Fraunces,serif;font-size:18px;font-weight:600;margin:0 0 6px;">Application status</h2>
        <p style="font-family:'Inter Tight',sans-serif;font-size:14px;margin:0 0 6px;">Programme: <b>{app.program}</b></p>
        <p style="font-family:'Inter Tight',sans-serif;font-size:15px;font-weight:700;margin:0 0 6px;color:{statusColor[app.status] || '#6b6455'};"><span style={'color:' + (statusColor[app.status] || '#6b6455')}>{app.status}</span></p>
        {app.score != null ? <p style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#6b6455;margin:0 0 6px;">Interview score: {app.score}/100 (an aid to review)</p> : null}
        {app.decision_reason ? <p style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:#4a453c;margin:8px 0 0;">Registrar note: {app.decision_reason}</p> : null}
        {isEnrolmentEligible(app.status) ? <p style="margin-top:14px;"><a href="/aquintutor/enrol" style="text-decoration:none;background:#eef8f1;color:#1f7a4d;border:1px solid #bfe3cd;border-radius:9px;padding:10px 16px;font-family:'Inter Tight',sans-serif;font-size:13.5px;font-weight:600;">You're accepted — continue to enrolment &rarr;</a></p> : null}
      </div>
    )}
  </main>

  <script is:inline>
    (function () {
      var msg = document.getElementById('msg');
      function post(body) { return fetch('/api/aquintutor/admissions', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }).then(function (r) { return r.json(); }); }
      function flash(t, ok) { msg.style.display = 'block'; msg.textContent = t; msg.style.background = ok ? '#eef8f1' : '#fdecec'; msg.style.color = ok ? '#2f7d5b' : '#9b2c2c'; }
      var s = document.getElementById('submitBtn'); if (s) s.addEventListener('click', function () { post({ action: 'submit', program: document.getElementById('fProgram').value, profile: { background: document.getElementById('fBackground').value } }).then(function (j) { if (j.ok) location.reload(); else flash(j.error || 'Failed', false); }); });
      var iv = document.getElementById('interviewBtn'); if (iv) iv.addEventListener('click', function () { var answers = Array.prototype.slice.call(document.querySelectorAll('.ans')).map(function (t) { return t.value; }); post({ action: 'interview', answers: answers }).then(function (j) { if (j.ok) location.reload(); else flash(j.error || 'Failed', false); }); });
    })();
  </script>
</AquintutorLayout>
