---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const sessionId = new URL(Astro.request.url).searchParams.get('session') || '';
let session: any = null;
let turnCount = 0;
let flagCount = 0;
if (sessionId) {
  try {
    const r = await db.execute(sql`
      SELECT s.id, s.candidate_name, s.language, s.started_at, s.ended_at, s.status, t.title
      FROM ai_interview_sessions s JOIN ai_interview_templates t ON s.template_id = t.id
      WHERE s.id = ${sessionId} LIMIT 1
    `);
    const rows = Array.isArray(r) ? r : (r?.rows || []);
    session = rows[0] || null;
  } catch (_) {}
  if (session) {
    try {
      const r1 = await db.execute(sql`SELECT COUNT(*)::int as n FROM ai_interview_transcript WHERE session_id = ${sessionId} AND role = 'candidate'`);
      const r1rows = Array.isArray(r1) ? r1 : (r1?.rows || []);
      turnCount = (r1rows[0] as any)?.n || 0;
      const r2 = await db.execute(sql`SELECT COUNT(*)::int as n FROM ai_interview_events WHERE session_id = ${sessionId} AND severity IN ('warn','flag')`);
      const r2rows = Array.isArray(r2) ? r2 : (r2?.rows || []);
      flagCount = (r2rows[0] as any)?.n || 0;
    } catch (_) {}
  }
}
---
<BaseLayout title="Interview complete" description="Your AI interview has been recorded. Our team will follow up." noindex={true}>
  <section class="px-[5vw] py-12 md:py-20 max-w-xl mx-auto text-center">

    <div style="width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,#10b981,#34d399);margin:0 auto 18px;display:flex;align-items:center;justify-content:center;font-size:34px;color:#fff;font-weight:900;">&#10003;</div>

    <h1 class="font-display text-[clamp(1.8rem,4vw,2.4rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-3">Interview complete.</h1>
    <p class="text-[0.95rem] text-ink-2 leading-relaxed mb-7">Thanks, {session?.candidate_name || 'candidate'}. We have your transcript on file. Our team will review and follow up with the next step.</p>

    {session && (
      <div class="bg-white border border-ink/10 rounded-2xl p-5 mb-7 text-left inline-block w-full max-w-md mx-auto">
        <p class="text-[0.72rem] font-mono uppercase tracking-wider text-ink-soft font-bold mb-3">Session record</p>
        <div class="flex flex-col gap-1.5 text-[0.88rem] text-ink-2">
          <p><strong>Interview:</strong> {session.title}</p>
          <p><strong>Session id:</strong> <span class="font-mono text-[0.78rem]">{session.id}</span></p>
          <p><strong>Language:</strong> {session.language}</p>
          <p><strong>Your turns:</strong> {turnCount}</p>
          {flagCount > 0 && <p><strong>Flagged events:</strong> {flagCount}</p>}
        </div>
      </div>
    )}

    <p class="text-[0.82rem] text-ink-soft">
      Questions? <a href="mailto:hr@edurankai.in" class="text-burn font-semibold hover:underline">hr@edurankai.in</a>
    </p>

    <p class="text-[0.78rem] text-ink-soft mt-5">
      <a href="/aquintutor" class="text-burn font-semibold hover:underline">&larr; Back to Aquintutor</a>
    </p>
  </section>
</BaseLayout>
