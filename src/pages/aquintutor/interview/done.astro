---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const sessionId = new URL(Astro.request.url).searchParams.get('session') || '';
let session: any = null;
let turnCount = 0;
let flagCount = 0;
if (sessionId) {
  try {
    const r = await db.execute(sql`
      SELECT s.id, s.candidate_name, s.language, s.started_at, s.ended_at, s.status, t.title
      FROM ai_interview_sessions s JOIN ai_interview_templates t ON s.template_id = t.id
      WHERE s.id = ${sessionId} LIMIT 1
    `);
    const rows = Array.isArray(r) ? r : (r?.rows || []);
    session = rows[0] || null;
  } catch (_) {}
  if (session) {
    try {
      const r1 = await db.execute(sql`SELECT COUNT(*)::int as n FROM ai_interview_transcript WHERE session_id = ${sessionId} AND role = 'candidate'`);
      const r1rows = Array.isArray(r1) ? r1 : (r1?.rows || []);
      turnCount = (r1rows[0] as any)?.n || 0;
      const r2 = await db.execute(sql`SELECT COUNT(*)::int as n FROM ai_interview_events WHERE session_id = ${sessionId} AND severity IN ('warn','flag')`);
      const r2rows = Array.isArray(r2) ? r2 : (r2?.rows || []);
      flagCount = (r2rows[0] as any)?.n || 0;
    } catch (_) {}
  }
}
function ago(d: any) {
  if (!d) return '-';
  try { return new Date(d).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }); } catch { return ''; }
}
---
<AquintutorLayout title="Interview complete" description="Your AI interview has been recorded." noindex={true}>

  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:840px; margin:0 auto; padding:64px 28px 48px;">
      <div style="display:inline-flex; align-items:center; justify-content:center; width:48px; height:48px; border-radius:50%; background:rgba(125,211,168,0.15); border:1px solid #7dd3a8; color:#4ea87c; margin-bottom:20px;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); font-weight:600; letter-spacing:0.04em; margin:0 0 14px;">Interview complete</p>
      <h1 class="font-display" style="font-size:clamp(2rem, 4vw, 3.25rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500; margin:0; color:var(--ink); max-width:38rem;">Thank you, {session?.candidate_name || 'candidate'}.</h1>
      <p style="font-family:'Inter Tight',sans-serif; font-size:16.5px; line-height:1.6; color:var(--ink-500); margin:20px 0 0; max-width:38rem;">Your transcript is on file with the admissions office. A member of the team will review it within five working days and contact you about the next step.</p>
    </div>
  </section>

  {session && (
    <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
      <div style="max-width:840px; margin:0 auto; padding:48px 28px;">
        <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 14px;">Session record</p>
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:22px;">
          <dl style="display:grid; grid-template-columns:1fr 2fr; gap:12px 24px; margin:0; font-family:'Inter Tight',sans-serif; font-size:14.5px;">
            <dt style="color:var(--ink-500); font-weight:600;">Interview</dt><dd style="color:var(--ink); margin:0;">{session.title}</dd>
            <dt style="color:var(--ink-500); font-weight:600;">Session id</dt><dd style="color:var(--ink); margin:0; font-family:'JetBrains Mono',monospace; font-size:12.5px;">{session.id}</dd>
            <dt style="color:var(--ink-500); font-weight:600;">Language</dt><dd style="color:var(--ink); margin:0;">{session.language}</dd>
            <dt style="color:var(--ink-500); font-weight:600;">Started</dt><dd style="color:var(--ink); margin:0;">{ago(session.started_at)}</dd>
            <dt style="color:var(--ink-500); font-weight:600;">Ended</dt><dd style="color:var(--ink); margin:0;">{ago(session.ended_at)}</dd>
            <dt style="color:var(--ink-500); font-weight:600;">Your answers</dt><dd style="color:var(--ink); margin:0;">{turnCount}</dd>
            {flagCount > 0 && (<>
              <dt style="color:var(--ink-500); font-weight:600;">Flagged events</dt><dd style="color:var(--rust); margin:0;">{flagCount}</dd>
            </>)}
          </dl>
        </div>
      </div>
    </section>
  )}

  <section>
    <div style="max-width:840px; margin:0 auto; padding:48px 28px 80px;">
      <div style="display:flex; gap:12px; flex-wrap:wrap;">
        <a href="/aquintutor/dashboard" style="background:var(--ink); color:var(--sand-50); padding:14px 24px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">My dashboard &rarr;</a>
        <a href="/aquintutor/courses" style="background:transparent; color:var(--ink); padding:14px 24px; border-radius:6px; border:1px solid var(--ink); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Browse the catalogue</a>
        <a href="mailto:hr@edurankai.in" style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink-500); text-decoration:underline; padding:14px 12px;">Questions? hr@edurankai.in</a>
      </div>
    </div>
  </section>

</AquintutorLayout>
