---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const { slug } = Astro.params;
const sessionId = new URL(Astro.request.url).searchParams.get('session') || '';
if (!sessionId) return Astro.redirect('/aquintutor/interview/' + slug);

let session: any = null;
try {
  const r = await db.execute(sql`
    SELECT s.id, s.candidate_name, s.candidate_email, s.language, s.status, s.preflight_passed,
      t.title, t.slug as template_slug, t.proctor_level, t.require_face_enroll,
      t.require_fullscreen, t.enable_object_detection, t.max_strikes, t.max_tab_switches
    FROM ai_interview_sessions s JOIN ai_interview_templates t ON s.template_id = t.id
    WHERE s.id = ${sessionId} LIMIT 1
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  session = rows[0] || null;
} catch (_) {}

if (!session) return Astro.redirect('/aquintutor/interview/' + slug);
if (session.status !== 'in_progress') return Astro.redirect('/aquintutor/interview/done?session=' + sessionId);
if (session.preflight_passed) {
  return Astro.redirect('/aquintutor/interview/' + slug + '/run?session=' + sessionId);
}

const requireFace = session.require_face_enroll !== false;
const requireFs = !!session.require_fullscreen;
const proctorLevel = session.proctor_level || 'standard';
const maxStrikes = session.max_strikes || 5;
const maxTabSw = session.max_tab_switches || 3;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Preflight checks — {session.title}</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,500&family=JetBrains+Mono:wght@400;500;600&display=swap" />
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{background:#0b0d10;color:#f4f1ea;min-height:100vh;font-family:'Inter Tight',-apple-system,BlinkMacSystemFont,system-ui,sans-serif}
    .wrap{max-width:880px;margin:0 auto;padding:40px 22px 80px}
    .h{font-family:'Fraunces',serif;font-size:clamp(28px,3.6vw,40px);font-weight:500;letter-spacing:-0.02em;line-height:1.15;margin-bottom:14px}
    .sub{font-size:14.5px;color:#8a8579;line-height:1.6;margin-bottom:30px;max-width:48ch}
    .lvl{display:inline-block;font-size:10px;font-family:'JetBrains Mono',monospace;letter-spacing:0.14em;text-transform:uppercase;padding:3px 9px;border-radius:100px;font-weight:700;margin-bottom:18px}
    .lvl.relaxed{background:rgba(16,185,129,0.18);color:#6ee7b7;border:1px solid #10b98155}
    .lvl.standard{background:rgba(217,119,87,0.18);color:#f0b48f;border:1px solid #d9775755}
    .lvl.strict{background:rgba(239,68,68,0.18);color:#fca5a5;border:1px solid #ef444455}
    .step{background:#14181d;border:1px solid #2a3038;border-radius:14px;padding:18px 22px;margin-bottom:14px;display:flex;gap:18px;align-items:flex-start}
    .step .ic{flex-shrink:0;width:38px;height:38px;border-radius:50%;background:#1c2128;border:1px solid #2a3038;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:700;color:#8a8579}
    .step.ok .ic{background:rgba(16,185,129,0.18);border-color:#10b981;color:#10b981}
    .step.bad .ic{background:rgba(239,68,68,0.18);border-color:#ef4444;color:#fca5a5}
    .step.busy .ic{background:rgba(217,119,87,0.18);border-color:#d97757;color:#d97757}
    .step .body{flex:1;min-width:0}
    .step h3{font-size:15px;font-weight:600;margin-bottom:4px;color:#f4f1ea}
    .step p{font-size:13px;color:#8a8579;line-height:1.55}
    .step .act{margin-top:10px}
    .btn{background:#d97757;border:none;color:#1a0f08;font-family:inherit;font-size:12px;font-weight:700;padding:8px 16px;border-radius:6px;cursor:pointer;letter-spacing:0.02em}
    .btn:hover{background:#b85e3f}
    .btn:disabled{opacity:.45;cursor:not-allowed}
    .btn.secondary{background:transparent;color:#f4f1ea;border:1px solid #2a3038}
    .preview{display:flex;gap:14px;margin-top:12px;align-items:center}
    .preview video{width:108px;height:80px;border-radius:8px;object-fit:cover;transform:scaleX(-1);background:#0d1117;border:1px solid #2a3038}
    .meter{width:140px;height:8px;background:#1c2128;border-radius:100px;overflow:hidden;border:1px solid #2a3038}
    .meter > div{height:100%;background:linear-gradient(90deg,#10b981,#fbbf24,#ef4444);width:0%;transition:width .12s}
    .rules{background:rgba(217,119,87,0.06);border:1px solid #d9775733;border-radius:12px;padding:16px 20px;margin-bottom:22px}
    .rules h2{font-family:'Fraunces',serif;font-size:18px;font-weight:500;margin-bottom:10px;color:#f0b48f}
    .rules ul{list-style:none;padding:0;margin:0}
    .rules li{font-size:13px;color:#c8c3b8;line-height:1.7;padding-left:20px;position:relative}
    .rules li::before{content:'·';position:absolute;left:6px;top:-2px;color:#d97757;font-size:18px}
    .start-bar{margin-top:24px;padding:18px 0;border-top:1px solid #2a3038;display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap}
    .start-bar .progress{font-size:11.5px;color:#8a8579;font-family:'JetBrains Mono',monospace}
    .err{color:#fca5a5;font-size:12px;margin-top:6px}
  </style>
</head>
<body>
  <div class="wrap">
    <span class={`lvl ${proctorLevel}`}>{proctorLevel} proctoring</span>
    <h1 class="h">Pre-flight checks</h1>
    <p class="sub">A few quick verifications before we start your interview. Nothing is uploaded — these run in your browser only. The interview will not start until every step is green.</p>

    <div class="rules">
      <h2>Session rules</h2>
      <ul>
        <li>Stay alone in a quiet, well-lit room with a clear view of the camera.</li>
        <li>No phones, notes, books, secondary monitors, or other people in frame.</li>
        <li>{`Switching tabs or leaving the window more than ${maxTabSw} times will end the session.`}</li>
        <li>{`Accumulating ${maxStrikes} strikes (multiple faces, phone detected, etc.) will end the session.`}</li>
        {requireFs && <li>The session must remain in fullscreen throughout.</li>}
        <li>Your transcript and event log are stored as text only. No audio or video recording.</li>
      </ul>
    </div>

    <div class="step" id="stepBrowser">
      <div class="ic">1</div>
      <div class="body">
        <h3>Browser support</h3>
        <p id="stepBrowserDesc">Checking your browser for speech, camera, and fullscreen APIs.</p>
      </div>
    </div>

    <div class="step" id="stepNet">
      <div class="ic">2</div>
      <div class="body">
        <h3>Network connection</h3>
        <p id="stepNetDesc">Verifying connectivity.</p>
      </div>
    </div>

    <div class="step" id="stepCam">
      <div class="ic">3</div>
      <div class="body">
        <h3>Camera</h3>
        <p id="stepCamDesc">We need to see your face clearly for proctoring.</p>
        <div class="preview" id="camPreview" style="display:none;">
          <video id="camVid" autoplay muted playsinline></video>
          <p style="font-size:11.5px;color:#8a8579;">Camera ready.</p>
        </div>
        <div class="act"><button class="btn" id="camBtn" type="button">Grant camera access</button></div>
        <p class="err" id="camErr" style="display:none;"></p>
      </div>
    </div>

    <div class="step" id="stepMic">
      <div class="ic">4</div>
      <div class="body">
        <h3>Microphone</h3>
        <p id="stepMicDesc">Speak normally so we can confirm the mic is picking you up.</p>
        <div class="preview" id="micPreview" style="display:none;">
          <div class="meter"><div id="micBar"></div></div>
          <p style="font-size:11.5px;color:#8a8579;" id="micStatus">Listening...</p>
        </div>
      </div>
    </div>

    {requireFace && (
      <div class="step" id="stepFace">
        <div class="ic">5</div>
        <div class="body">
          <h3>Identity reference</h3>
          <p>Look straight at the camera. We'll capture a one-time face reference (a 128-number vector — no photo) to verify it's you throughout.</p>
          <div class="act"><button class="btn" id="faceBtn" type="button" disabled>Capture face reference</button></div>
          <p class="err" id="faceErr" style="display:none;"></p>
        </div>
      </div>
    )}

    <div class="step" id="stepEnv">
      <div class="ic">{requireFace ? '6' : '5'}</div>
      <div class="body">
        <h3>Environment</h3>
        <p id="stepEnvDesc">Checking display, monitors, and system info.</p>
      </div>
    </div>

    {requireFs && (
      <div class="step" id="stepFs">
        <div class="ic">{requireFace ? '7' : '6'}</div>
        <div class="body">
          <h3>Fullscreen</h3>
          <p>The session must run in fullscreen. Click below to enable it now.</p>
          <div class="act"><button class="btn" id="fsBtn" type="button">Enter fullscreen</button></div>
        </div>
      </div>
    )}

    <div class="start-bar">
      <p class="progress" id="progressLine">0 of 5 checks complete</p>
      <button class="btn" id="startBtn" disabled type="button">Begin interview &rarr;</button>
    </div>
    <p class="err" id="startErr" style="display:none;margin-top:10px;"></p>
  </div>

  <script is:inline define:vars={{ sessionId, slug, requireFace, requireFs }}>
  (function () {
    var checks = { browser: false, net: false, cam: false, mic: false, face: !requireFace, env: false, fs: !requireFs };
    var stream = null;
    var faceDescriptor = null;
    var faceapi = null;

    function mark(id, state, desc) {
      var el = document.getElementById(id);
      if (!el) return;
      el.classList.remove('ok', 'bad', 'busy');
      if (state) el.classList.add(state);
      if (desc) {
        var p = el.querySelector('.body p');
        if (p && !p.querySelector('div, button')) p.textContent = desc;
      }
      updateProgress();
    }
    function updateProgress() {
      var total = Object.keys(checks).length - (requireFace ? 0 : 1) - (requireFs ? 0 : 1);
      var done = 0;
      Object.keys(checks).forEach(function (k) {
        if (k === 'face' && !requireFace) return;
        if (k === 'fs' && !requireFs) return;
        if (checks[k]) done++;
      });
      document.getElementById('progressLine').textContent = done + ' of ' + total + ' checks complete';
      var allDone = done >= total;
      document.getElementById('startBtn').disabled = !allDone;
    }

    // 1. Browser check
    var hasGUM = !!(navigator.mediaDevices && navigator.mediaDevices.getUserMedia);
    var hasSTT = !!(window.SpeechRecognition || window.webkitSpeechRecognition);
    var hasTTS = !!window.speechSynthesis;
    var hasFs = !!(document.documentElement.requestFullscreen || document.documentElement.webkitRequestFullscreen);
    if (hasGUM && hasTTS && hasFs) {
      checks.browser = true;
      mark('stepBrowser', 'ok', hasSTT ? 'Browser supports camera, mic, speech-to-text, text-to-speech, and fullscreen.' : 'Browser supports camera + mic. Speech-to-text is limited — type-fallback will be available.');
    } else {
      mark('stepBrowser', 'bad', 'Your browser is missing required APIs. Please use Chrome or Edge.');
    }

    // 2. Network
    function checkNet() {
      if (!navigator.onLine) { mark('stepNet', 'bad', 'You are offline. Reconnect and refresh.'); checks.net = false; return; }
      checks.net = true;
      mark('stepNet', 'ok', 'Online via ' + ((navigator.connection && navigator.connection.effectiveType) || 'unknown') + '.');
    }
    checkNet();
    window.addEventListener('online', checkNet);
    window.addEventListener('offline', checkNet);

    // 3. Camera
    document.getElementById('camBtn').addEventListener('click', async function () {
      mark('stepCam', 'busy');
      try {
        stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: 320, height: 240 }, audio: true });
        document.getElementById('camPreview').style.display = 'flex';
        document.getElementById('camVid').srcObject = stream;
        document.getElementById('camBtn').style.display = 'none';
        checks.cam = true;
        mark('stepCam', 'ok');
        if (requireFace) document.getElementById('faceBtn').disabled = false;
        startMicMeter(stream);
      } catch (e) {
        var err = document.getElementById('camErr');
        err.textContent = 'Camera/mic access denied. Allow it in browser permissions and try again.';
        err.style.display = 'block';
        mark('stepCam', 'bad');
      }
    });

    // 4. Mic meter
    function startMicMeter(s) {
      try {
        var AC = window.AudioContext || window.webkitAudioContext;
        if (!AC) return;
        var ctx = new AC();
        var src = ctx.createMediaStreamSource(s);
        var an = ctx.createAnalyser();
        an.fftSize = 512;
        src.connect(an);
        var buf = new Uint8Array(an.fftSize);
        document.getElementById('micPreview').style.display = 'flex';
        var loudCount = 0;
        var loop = setInterval(function () {
          an.getByteTimeDomainData(buf);
          var sum = 0;
          for (var i = 0; i < buf.length; i++) { var v = (buf[i] - 128) / 128; sum += v * v; }
          var rms = Math.sqrt(sum / buf.length);
          var pct = Math.min(100, Math.round(rms * 800));
          document.getElementById('micBar').style.width = pct + '%';
          if (pct > 12) loudCount++;
          if (loudCount > 6 && !checks.mic) {
            checks.mic = true;
            mark('stepMic', 'ok');
            document.getElementById('micStatus').textContent = 'Mic working — picked up your voice.';
          }
        }, 100);
        setTimeout(function () {
          if (!checks.mic) {
            checks.mic = true;
            mark('stepMic', 'ok');
            document.getElementById('micStatus').textContent = 'Mic stream active (no speech detected yet — that’s fine).';
          }
        }, 6000);
      } catch (e) {}
    }

    // 5. Face enroll
    function loadFaceApi() {
      return new Promise(function (resolve, reject) {
        if (window.faceapi) return resolve();
        var s = document.createElement('script');
        s.src = 'https://cdn.jsdelivr.net/npm/@vladmandic/face-api@1.7.13/dist/face-api.min.js';
        s.onload = function () { resolve(); };
        s.onerror = function () { reject(new Error('face-api load failed')); };
        document.head.appendChild(s);
      });
    }
    if (requireFace) {
      document.getElementById('faceBtn').addEventListener('click', async function () {
        var btn = this; var err = document.getElementById('faceErr'); err.style.display = 'none';
        btn.disabled = true; btn.textContent = 'Loading model...';
        try {
          await loadFaceApi();
          try { if (faceapi && faceapi.tf && faceapi.tf.setBackend) await window.faceapi.tf.setBackend('webgl'); } catch (_) {}
          var MODEL = 'https://cdn.jsdelivr.net/npm/@vladmandic/face-api@latest/model';
          btn.textContent = 'Detecting...';
          await window.faceapi.nets.tinyFaceDetector.loadFromUri(MODEL);
          await window.faceapi.nets.faceLandmark68Net.loadFromUri(MODEL);
          await window.faceapi.nets.faceRecognitionNet.loadFromUri(MODEL);
          var v = document.getElementById('camVid');
          var det = await window.faceapi.detectSingleFace(v, new window.faceapi.TinyFaceDetectorOptions({ inputSize: 320, scoreThreshold: 0.5 })).withFaceLandmarks().withFaceDescriptor();
          if (!det || !det.descriptor) throw new Error('Could not detect your face. Look at the camera with good light and try again.');
          faceDescriptor = Array.from(det.descriptor);
          btn.textContent = 'Uploading...';
          await fetch('/api/aquintutor/interview/enroll-face', {
            method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              sessionId: sessionId, descriptor: faceDescriptor,
              fingerprint: collectFingerprint(),
            }),
          });
          checks.face = true;
          mark('stepFace', 'ok');
          var p = document.querySelector('#stepFace .body p');
          if (p) p.textContent = 'Identity reference captured. You can begin.';
          btn.style.display = 'none';
        } catch (e) {
          err.textContent = (e && e.message) || 'Face capture failed.';
          err.style.display = 'block';
          btn.disabled = false; btn.textContent = 'Capture face reference';
          mark('stepFace', 'bad');
        }
      });
    }

    // 6. Environment + fingerprint
    function collectFingerprint() {
      try {
        return {
          ua: navigator.userAgent.slice(0, 400),
          platform: navigator.platform,
          lang: navigator.language,
          tz: Intl.DateTimeFormat().resolvedOptions().timeZone,
          screen: { w: screen.width, h: screen.height, availW: screen.availWidth, availH: screen.availHeight, dpr: window.devicePixelRatio || 1 },
          inner: { w: window.innerWidth, h: window.innerHeight },
          colors: screen.colorDepth,
          touchPoints: navigator.maxTouchPoints || 0,
          cores: navigator.hardwareConcurrency || 0,
          memGb: navigator.deviceMemory || null,
          online: navigator.onLine,
        };
      } catch (e) { return { ua: navigator.userAgent.slice(0, 400) }; }
    }
    var multiMon = (screen.width > window.innerWidth * 1.6) || (screen.availWidth - screen.width > 200);
    checks.env = true;
    mark('stepEnv', multiMon ? 'busy' : 'ok',
      multiMon
        ? 'Multiple monitors detected. That is allowed but will be flagged in the activity log.'
        : (screen.width + '×' + screen.height + ', ' + (Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC') + ', ' + navigator.language));

    // 7. Fullscreen
    if (requireFs) {
      document.getElementById('fsBtn').addEventListener('click', function () {
        var el = document.documentElement;
        var req = el.requestFullscreen || el.webkitRequestFullscreen;
        if (req) req.call(el);
      });
      document.addEventListener('fullscreenchange', function () {
        if (document.fullscreenElement) { checks.fs = true; mark('stepFs', 'ok'); }
        else { checks.fs = false; mark('stepFs', 'bad'); }
      });
    }

    // Start
    document.getElementById('startBtn').addEventListener('click', function () {
      var allDone = Object.keys(checks).every(function (k) {
        if (k === 'face' && !requireFace) return true;
        if (k === 'fs' && !requireFs) return true;
        return checks[k];
      });
      if (!allDone) return;
      // Stream is handed off to the runner — keep it alive across navigation by stopping here and re-requesting there.
      if (stream) try { stream.getTracks().forEach(function (t) { t.stop(); }); } catch (_) {}
      window.location.href = '/aquintutor/interview/' + slug + '/run?session=' + encodeURIComponent(sessionId);
    });
  })();
  </script>
</body>
</html>
