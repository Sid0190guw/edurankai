---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const { slug } = Astro.params;
const sessionId = new URL(Astro.request.url).searchParams.get('session') || '';
if (!sessionId) return Astro.redirect('/aquintutor/interview/' + slug);

let session: any = null;
let template: any = null;
let firstTurn: any = null;
try {
  const r = await db.execute(sql`
    SELECT s.id, s.template_id, s.candidate_name, s.candidate_email, s.language, s.status, s.started_at,
      t.title, t.slug as template_slug, t.max_minutes
    FROM ai_interview_sessions s JOIN ai_interview_templates t ON s.template_id = t.id
    WHERE s.id = ${sessionId} LIMIT 1
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  session = rows[0] || null;
} catch (_) {}

if (!session) return Astro.redirect('/aquintutor/interview/' + slug);
if (session.status !== 'in_progress') return Astro.redirect('/aquintutor/interview/done?session=' + sessionId);

try {
  const r = await db.execute(sql`
    SELECT turn_index, role, text, lang, is_follow_up FROM ai_interview_transcript
    WHERE session_id = ${sessionId} ORDER BY turn_index ASC LIMIT 1
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  firstTurn = rows[0] || null;
} catch (_) {}

const lang = session.language || 'en-IN';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{session.title} - AI Interview</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: #08080a; color: #fff; min-height: 100vh;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    }
    .top { background: rgba(0,0,0,0.5); border-bottom: 1px solid rgba(255,255,255,0.05); padding: 12px 18px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
    .top .title { font-size: 14px; font-weight: 700; }
    .top .meta { font-size: 11px; color: #8a8a94; font-family: ui-monospace, monospace; }
    .wrap { max-width: 880px; margin: 0 auto; padding: 24px 20px 140px; }

    .q-card { background: linear-gradient(135deg, rgba(255,79,0,0.16), rgba(255,79,0,0.04)); border: 1px solid rgba(255,79,0,0.35); border-radius: 16px; padding: 22px 24px; margin-bottom: 18px; }
    .q-label { font-size: 11px; color: #FF7040; font-family: ui-monospace, monospace; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 8px; font-weight: 700; }
    .q-text { font-size: 19px; line-height: 1.5; color: #fff; font-weight: 500; }
    .q-controls { display: flex; gap: 8px; margin-top: 16px; flex-wrap: wrap; }
    .q-btn { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12); color: #fff; font-size: 12px; font-weight: 600; padding: 7px 14px; border-radius: 8px; cursor: pointer; }
    .q-btn:hover { background: rgba(255,255,255,0.14); }

    .live-card { background: #0f0f14; border: 1px solid #1a1a1f; border-radius: 16px; padding: 18px 22px; margin-bottom: 18px; }
    .live-card h3 { font-size: 11px; color: #8a8a94; text-transform: uppercase; letter-spacing: 0.12em; font-family: ui-monospace, monospace; margin-bottom: 10px; }
    .live-text { font-size: 16px; color: #d8d8de; min-height: 80px; line-height: 1.6; }
    .live-text .partial { color: rgba(255,255,255,0.55); font-style: italic; }
    .live-controls { display: flex; gap: 10px; margin-top: 14px; flex-wrap: wrap; }
    .submit-btn { background: linear-gradient(135deg, #FF4F00, #FF7040); border: none; color: #fff; font-size: 14px; font-weight: 700; padding: 11px 20px; border-radius: 10px; cursor: pointer; }
    .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .end-btn { background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; font-size: 13px; font-weight: 600; padding: 10px 16px; border-radius: 10px; cursor: pointer; }

    .transcript { background: #0f0f14; border: 1px solid #1a1a1f; border-radius: 16px; padding: 16px 20px; }
    .transcript h3 { font-size: 11px; color: #8a8a94; text-transform: uppercase; letter-spacing: 0.12em; font-family: ui-monospace, monospace; margin-bottom: 10px; }
    .turn { padding: 8px 0; border-bottom: 1px solid #15151a; }
    .turn:last-child { border: 0; }
    .turn .role { font-size: 10px; font-family: ui-monospace, monospace; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 4px; }
    .turn.ai .role { color: #FF7040; }
    .turn.candidate .role { color: #10b981; }
    .turn .text { font-size: 13.5px; color: #d8d8de; line-height: 1.55; }

    #monitorPill { position: fixed; bottom: 14px; right: 14px; background: rgba(0,0,0,0.85); border: 1px solid rgba(255,255,255,0.15); border-radius: 12px; padding: 6px 8px; z-index: 55; display: flex; align-items: center; gap: 8px; }
    #monitorPill video { width: 52px; height: 52px; border-radius: 8px; object-fit: cover; transform: scaleX(-1); background: #000; }
    #monitorPill .live { color: #10b981; font-size: 10px; font-weight: 700; }
    #monitorPill .sub { color: rgba(255,255,255,0.6); font-size: 9px; }

    .toast { position: fixed; top: 16px; left: 50%; transform: translateX(-50%); background: rgba(0,0,0,0.92); border: 1px solid rgba(255,255,255,0.15); color: #fff; font-size: 13px; padding: 10px 18px; border-radius: 100px; z-index: 60; }
    .toast.warn { border-color: #fbbf24; color: #fbbf24; }
    .toast.err { border-color: #ef4444; color: #fca5a5; }

    .stt-status { font-size: 11px; color: #8a8a94; margin-top: 8px; font-family: ui-monospace, monospace; }
    .stt-status .dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #6e6e78; margin-right: 6px; vertical-align: middle; }
    .stt-status.live .dot { background: #10b981; animation: pulse 1.2s infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
  </style>
</head>
<body>
  <div class="top">
    <div>
      <p class="title">{session.title}</p>
      <p class="meta">{session.candidate_name || session.candidate_email || 'anonymous'} &middot; lang {lang} &middot; session {session.id.slice(0, 8)}</p>
    </div>
    <p class="meta" id="timerEl">--:--</p>
  </div>

  <div class="wrap">
    <div class="q-card">
      <p class="q-label" id="qLabel">Question 1</p>
      <p class="q-text" id="qText">{firstTurn ? firstTurn.text : '...'}</p>
      <div class="q-controls">
        <button class="q-btn" id="replayBtn" type="button">&#9655; Replay question</button>
      </div>
    </div>

    <div class="live-card">
      <h3>Your answer (live transcript)</h3>
      <div class="live-text" id="liveText"></div>
      <p class="stt-status" id="sttStatus"><span class="dot"></span> Mic ready - speak when you're ready</p>
      <div class="live-controls">
        <button class="submit-btn" id="submitAnswerBtn" type="button">Submit answer</button>
        <button class="end-btn" id="endBtn" type="button">End interview</button>
      </div>
    </div>

    <div class="transcript" id="transcriptList">
      <h3>Conversation so far</h3>
      <p style="font-size:12px;color:#6e6e78;font-style:italic;">Each AI question and your answer will be appended here as the interview progresses.</p>
    </div>
  </div>

  <div id="monitorPill">
    <video id="monitorVideo" autoplay muted playsinline></video>
    <div>
      <p class="live">&#9679; LIVE</p>
      <p class="sub">monitored - no recording</p>
    </div>
  </div>

  <script is:inline define:vars={{
    sessionId: session.id,
    sessionLang: lang,
    templateSlug: slug,
    firstQuestion: firstTurn ? { text: firstTurn.text, lang: firstTurn.lang || lang, isFollowUp: firstTurn.is_follow_up || false, turnIndex: 0 } : null,
    maxMinutes: session.max_minutes || 30,
    startedAt: session.started_at
  }}>
  (function() {
    var currentSeedIndex = 0;
    var currentQuestion = firstQuestion;
    var ended = false;

    var qLabel = document.getElementById('qLabel');
    var qText = document.getElementById('qText');
    var liveText = document.getElementById('liveText');
    var submitBtn = document.getElementById('submitAnswerBtn');
    var endBtn = document.getElementById('endBtn');
    var replayBtn = document.getElementById('replayBtn');
    var sttStatus = document.getElementById('sttStatus');
    var transcriptList = document.getElementById('transcriptList');
    var timerEl = document.getElementById('timerEl');

    // ===== Toast helper =====
    function toast(msg, type) {
      var t = document.createElement('div');
      t.className = 'toast' + (type ? ' ' + type : '');
      t.textContent = msg;
      document.body.appendChild(t);
      setTimeout(function() { t.remove(); }, 3500);
    }

    // ===== Proctoring event buffer (same shape as test runner) =====
    var eventBuffer = [];
    function logEvent(type, severity, detail) {
      if (ended) return;
      eventBuffer.push({ type: type, severity: severity || 'info', detail: detail || {}, clientTs: new Date().toISOString() });
      if (eventBuffer.length >= 12 || severity === 'flag') flushEvents();
    }
    function flushEvents() {
      if (eventBuffer.length === 0) return;
      var batch = eventBuffer.splice(0);
      try {
        var payload = JSON.stringify({ sessionId: sessionId, events: batch });
        if (navigator.sendBeacon) {
          navigator.sendBeacon('/api/aquintutor/interview/log-event', new Blob([payload], { type: 'application/json' }));
        } else {
          fetch('/api/aquintutor/interview/log-event', {
            method: 'POST', credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' }, body: payload, keepalive: true,
          }).catch(function() { eventBuffer = batch.concat(eventBuffer); });
        }
      } catch (_) { eventBuffer = batch.concat(eventBuffer); }
    }
    setInterval(flushEvents, 4000);
    window.addEventListener('beforeunload', flushEvents);

    // ===== Window / tab / clipboard monitoring =====
    document.addEventListener('visibilitychange', function() { if (document.hidden) { logEvent('tab_hidden', 'warn', {}); toast('Stay in this tab', 'warn'); } else { logEvent('tab_visible', 'info', {}); } });
    window.addEventListener('blur', function() { logEvent('window_blur', 'warn', {}); });
    window.addEventListener('focus', function() { logEvent('window_focus', 'info', {}); });
    document.addEventListener('contextmenu', function(e) { e.preventDefault(); logEvent('right_click_blocked', 'warn', {}); });
    document.addEventListener('copy', function() { logEvent('copy', 'info', {}); });
    document.addEventListener('paste', function() { logEvent('paste', 'info', {}); });
    window.addEventListener('offline', function() { logEvent('network_offline', 'warn', {}); toast('You went offline', 'err'); });
    window.addEventListener('online', function() { logEvent('network_online', 'info', {}); });

    var BLOCKED = [{k:'F12',l:'F12'},{k:'I',c:true,s:true,l:'Ctrl+Shift+I'},{k:'U',c:true,l:'Ctrl+U'}];
    document.addEventListener('keydown', function(e) {
      for (var i = 0; i < BLOCKED.length; i++) {
        var b = BLOCKED[i];
        if (e.key === b.k && (!b.c || e.ctrlKey || e.metaKey) && (!b.s || e.shiftKey)) {
          e.preventDefault();
          logEvent('keyboard_shortcut_blocked', 'flag', { shortcut: b.l });
          toast('Shortcut blocked: ' + b.l, 'warn');
          return;
        }
      }
    });

    // ===== Camera + mic =====
    var faceLastCount = 1;
    var awaySince = 0;
    var voicing = false;
    var voiceSince = 0;
    var stream = null;

    async function startMedia() {
      try {
        stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: 320, height: 240 }, audio: true });
        logEvent('media_consent_granted', 'info', { video: true, audio: true });
        document.getElementById('monitorVideo').srcObject = stream;
        stream.getTracks().forEach(function(t) { t.addEventListener('ended', function() { logEvent('media_lost', 'flag', { kind: t.kind }); }); });
        startFaceMonitor();
        // Mic is also used for STT, so the mic stream pull happens via SpeechRecognition
      } catch (e) {
        logEvent('media_consent_denied', 'flag', { error: e.name || 'denied' });
        toast('Camera + mic permission denied. Session is flagged.', 'err');
      }
    }

    function loadFaceApi() {
      return new Promise(function(resolve, reject) {
        if (window.faceapi) return resolve();
        var s = document.createElement('script');
        s.src = 'https://cdn.jsdelivr.net/npm/@vladmandic/face-api@1.7.13/dist/face-api.min.js';
        s.onload = function() { resolve(); };
        s.onerror = function() { reject(new Error('face-api load failed')); };
        document.head.appendChild(s);
      });
    }

    async function startFaceMonitor() {
      try {
        await loadFaceApi();
        var URL = 'https://cdn.jsdelivr.net/npm/@vladmandic/face-api@latest/model';
        await faceapi.nets.tinyFaceDetector.loadFromUri(URL);
        await faceapi.nets.faceLandmark68TinyNet.loadFromUri(URL);
      } catch (e) {
        logEvent('media_lost', 'warn', { reason: 'face_model_load_failed' });
        return;
      }
      var v = document.getElementById('monitorVideo');
      setInterval(async function() {
        if (ended || v.readyState < 2) return;
        try {
          var dets = await faceapi.detectAllFaces(v, new faceapi.TinyFaceDetectorOptions({ inputSize: 224, scoreThreshold: 0.5 })).withFaceLandmarks(true);
          var n = dets.length;
          if (n === 0 && faceLastCount > 0) { logEvent('face_lost', 'warn', {}); toast('Face not visible', 'warn'); }
          else if (n > 0 && faceLastCount === 0) { logEvent('face_visible', 'info', { count: n }); }
          if (n > 1 && faceLastCount <= 1) { logEvent('multiple_faces', 'flag', { count: n }); toast('Multiple faces detected', 'warn'); }
          faceLastCount = n;
          if (n === 1 && dets[0].landmarks) {
            var lm = dets[0].landmarks;
            var le = lm.getLeftEye(); var re = lm.getRightEye(); var nose = lm.getNose();
            if (le && re && nose && nose.length > 3) {
              var mid = (le[0].x + re[3].x) / 2;
              var off = (nose[3].x - mid) / Math.max(1, Math.abs(re[3].x - le[0].x));
              if (Math.abs(off) > 0.25) { if (!awaySince) awaySince = Date.now(); else if (Date.now() - awaySince > 2000) { logEvent('looking_away', 'warn', { off: off.toFixed(2) }); awaySince = Date.now() + 4000; } }
              else awaySince = 0;
            }
          }
        } catch(_) {}
      }, 1500);
    }

    startMedia();

    // ===== Speech synthesis (AI asks question aloud) =====
    function speak(text, lang) {
      if (!('speechSynthesis' in window)) return;
      try { window.speechSynthesis.cancel(); } catch(_) {}
      var u = new SpeechSynthesisUtterance(text);
      u.lang = lang || sessionLang;
      u.rate = 0.95;
      u.pitch = 1.0;
      window.speechSynthesis.speak(u);
    }

    // ===== Speech recognition (transcribe candidate) =====
    var SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    var rec = null;
    var finalTranscript = '';
    var lastFinalAt = 0;

    function startSTT() {
      if (!SR) { sttStatus.innerHTML = '<span class="dot"></span> Speech recognition not supported - type your answer below (use Chrome/Edge for full experience)'; addManualInput(); return; }
      rec = new SR();
      rec.lang = sessionLang;
      rec.continuous = true;
      rec.interimResults = true;
      rec.onresult = function(e) {
        var partial = '';
        for (var i = e.resultIndex; i < e.results.length; i++) {
          var r = e.results[i];
          if (r.isFinal) { finalTranscript += r[0].transcript + ' '; lastFinalAt = Date.now(); }
          else partial += r[0].transcript;
        }
        renderLive(finalTranscript, partial);
      };
      rec.onerror = function(e) {
        if (e.error === 'no-speech') return;
        sttStatus.innerHTML = '<span class="dot"></span> STT error: ' + e.error;
      };
      rec.onend = function() {
        if (ended) return;
        try { rec.start(); } catch(_) {}
      };
      try { rec.start(); sttStatus.className = 'stt-status live'; sttStatus.innerHTML = '<span class="dot"></span> Listening in ' + sessionLang; } catch(e) { sttStatus.innerHTML = '<span class="dot"></span> Could not start mic: ' + e.message; }
    }

    function addManualInput() {
      // Fallback for browsers without STT
      var ta = document.createElement('textarea');
      ta.id = 'manualAnswer';
      ta.placeholder = 'Type your answer here...';
      ta.style.cssText = 'width:100%;background:#15151a;border:1px solid #1a1a1f;color:#fff;border-radius:8px;padding:10px 12px;font-size:14px;font-family:inherit;outline:none;resize:vertical;min-height:90px;margin-top:8px;';
      liveText.parentNode.insertBefore(ta, liveText.nextSibling);
      ta.addEventListener('input', function() { finalTranscript = ta.value; });
    }

    function renderLive(final, partial) {
      liveText.innerHTML = '<span>' + escapeHtml(final) + '</span><span class="partial">' + escapeHtml(partial) + '</span>';
    }
    function escapeHtml(s) { return String(s == null ? '' : s).replace(/[&<>"']/g, function(c) { return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]; }); }

    // Speak the first question + start STT
    if (currentQuestion) {
      qText.textContent = currentQuestion.text;
      setTimeout(function() { speak(currentQuestion.text, currentQuestion.lang); startSTT(); }, 400);
    }
    logEvent('session_listeners_attached', 'info', { ua: navigator.userAgent.slice(0, 200), lang: sessionLang });

    replayBtn.addEventListener('click', function() { if (currentQuestion) speak(currentQuestion.text, currentQuestion.lang); });

    // ===== Submit answer =====
    function appendTurn(role, text, lang) {
      var d = document.createElement('div');
      d.className = 'turn ' + role;
      d.innerHTML = '<p class="role">' + (role === 'ai' ? 'AI Interviewer' : 'You') + (lang ? ' &middot; ' + lang : '') + '</p><p class="text">' + escapeHtml(text) + '</p>';
      transcriptList.appendChild(d);
      transcriptList.scrollTop = transcriptList.scrollHeight;
    }

    function submitAnswer() {
      if (!currentQuestion || ended) return;
      var manual = document.getElementById('manualAnswer');
      var text = (manual ? manual.value : finalTranscript).trim();
      if (!text) { toast('Please speak (or type) your answer first', 'warn'); return; }
      submitBtn.disabled = true; submitBtn.textContent = 'Sending...';

      // Append AI question + candidate answer to history view
      appendTurn('ai', currentQuestion.text, currentQuestion.lang);
      appendTurn('candidate', text, sessionLang);

      fetch('/api/aquintutor/interview/turn', {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          sessionId: sessionId, transcript: text, lang: sessionLang,
          currentSeedIndex: currentSeedIndex, justAnsweredFollowUp: !!currentQuestion.isFollowUp,
        }),
      }).then(function(r) { return r.json(); }).then(function(d) {
        submitBtn.disabled = false; submitBtn.textContent = 'Submit answer';
        if (!d.ok) { toast(d.error || 'Could not save answer', 'err'); return; }
        if (d.done) { endInterview(true); return; }
        currentSeedIndex = d.currentSeedIndex;
        currentQuestion = d.next;
        qText.textContent = currentQuestion.text;
        qLabel.textContent = currentQuestion.isFollowUp ? 'Follow-up' : 'Question ' + (currentSeedIndex + 1);
        finalTranscript = '';
        if (manual) manual.value = '';
        renderLive('', '');
        speak(currentQuestion.text, currentQuestion.lang);
      }).catch(function() {
        submitBtn.disabled = false; submitBtn.textContent = 'Submit answer';
        toast('Network error', 'err');
      });
    }
    submitBtn.addEventListener('click', submitAnswer);

    function endInterview(auto) {
      if (ended) return;
      ended = true;
      try { window.speechSynthesis.cancel(); } catch(_) {}
      try { if (rec) rec.stop(); } catch(_) {}
      flushEvents();
      fetch('/api/aquintutor/interview/end', {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sessionId: sessionId }),
      }).then(function(r) { return r.json(); }).then(function(d) {
        var loc = (d && d.redirect) || ('/aquintutor/interview/done?session=' + encodeURIComponent(sessionId));
        window.location.href = loc;
      }).catch(function() { window.location.href = '/aquintutor/interview/done?session=' + encodeURIComponent(sessionId); });
    }
    endBtn.addEventListener('click', function() { if (confirm('End the interview now? You won\\'t be able to add more answers.')) endInterview(false); });

    // ===== Timer =====
    var endsAt = new Date(startedAt).getTime() + maxMinutes * 60 * 1000;
    setInterval(function() {
      if (ended) return;
      var rem = Math.max(0, Math.floor((endsAt - Date.now()) / 1000));
      var m = Math.floor(rem / 60); var s = rem % 60;
      timerEl.textContent = (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
      if (rem === 0) endInterview(true);
    }, 500);
  })();
  </script>
</body>
</html>
