---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const { slug } = Astro.params;
const sessionId = new URL(Astro.request.url).searchParams.get('session') || '';
if (!sessionId) return Astro.redirect('/aquintutor/interview/' + slug);

let session: any = null;
let firstTurn: any = null;
try {
  const r = await db.execute(sql`
    SELECT s.id, s.template_id, s.candidate_name, s.candidate_email, s.language, s.status, s.started_at,
      s.preflight_passed, s.face_descriptor,
      t.title, t.slug as template_slug, t.max_minutes,
      COALESCE(t.proctor_level, 'standard') AS proctor_level,
      COALESCE(t.require_face_enroll, true) AS require_face_enroll,
      COALESCE(t.block_tab_switch, true) AS block_tab_switch,
      COALESCE(t.max_tab_switches, 3) AS max_tab_switches,
      COALESCE(t.max_strikes, 5) AS max_strikes,
      COALESCE(t.require_fullscreen, false) AS require_fullscreen,
      COALESCE(t.enable_object_detection, false) AS enable_object_detection,
      COALESCE(t.allow_paste, false) AS allow_paste
    FROM ai_interview_sessions s JOIN ai_interview_templates t ON s.template_id = t.id
    WHERE s.id = ${sessionId} LIMIT 1
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  session = rows[0] || null;
} catch (_) {}

if (!session) return Astro.redirect('/aquintutor/interview/' + slug);
if (session.status !== 'in_progress') return Astro.redirect('/aquintutor/interview/done?session=' + sessionId);
if (!session.preflight_passed) return Astro.redirect('/aquintutor/interview/' + slug + '/preflight?session=' + sessionId);

try {
  const r = await db.execute(sql`
    SELECT turn_index, role, text, lang, is_follow_up FROM ai_interview_transcript
    WHERE session_id = ${sessionId} ORDER BY turn_index ASC LIMIT 1
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  firstTurn = rows[0] || null;
} catch (_) {}

const lang = session.language || 'en-IN';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{session.title} - AI Interview</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,500&family=JetBrains+Mono:wght@400;500;600&display=swap" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: #0b0d10; color: #f4f1ea; min-height: 100vh;
      font-family: 'Inter Tight', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    }
    .top { background: #14181d; border-bottom: 1px solid #2a3038; padding: 14px 22px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
    .top .title { font-family: 'Fraunces', serif; font-size: 17px; font-weight: 500; letter-spacing: -0.01em; }
    .top .meta { font-size: 11px; color: #8a8579; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.06em; }
    .wrap { max-width: 880px; margin: 0 auto; padding: 32px 22px 140px; }

    .q-card { background: linear-gradient(135deg, rgba(217,119,87,0.14), rgba(217,119,87,0.03)); border: 1px solid rgba(217,119,87,0.4); border-radius: 14px; padding: 28px 30px; margin-bottom: 18px; }
    .q-label { font-size: 11px; color: #d97757; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.16em; text-transform: uppercase; margin-bottom: 12px; font-weight: 600; }
    .q-text { font-family: 'Fraunces', serif; font-size: clamp(20px, 2.4vw, 28px); line-height: 1.35; color: #f4f1ea; font-weight: 400; }
    .q-controls { display: flex; gap: 8px; margin-top: 18px; flex-wrap: wrap; }
    .q-btn { background: rgba(244,241,234,0.08); border: 1px solid rgba(244,241,234,0.12); color: #f4f1ea; font-size: 12px; font-weight: 600; padding: 8px 14px; border-radius: 6px; cursor: pointer; font-family: 'Inter Tight', sans-serif; }
    .q-btn:hover { background: rgba(244,241,234,0.14); }

    .live-card { background: #14181d; border: 1px solid #2a3038; border-radius: 14px; padding: 22px; margin-bottom: 18px; }
    .live-card h3 { font-size: 11px; color: #8a8579; text-transform: uppercase; letter-spacing: 0.16em; font-family: 'JetBrains Mono', monospace; margin-bottom: 12px; font-weight: 600; }
    .live-text { font-size: 16px; color: #c8c3b8; min-height: 80px; line-height: 1.6; }
    .live-text .partial { color: rgba(244,241,234,0.5); font-style: italic; }
    .live-controls { display: flex; gap: 10px; margin-top: 16px; flex-wrap: wrap; }
    .submit-btn { background: #d97757; border: none; color: #1a0f08; font-family: 'Inter Tight', sans-serif; font-size: 13px; font-weight: 600; letter-spacing: 0.02em; padding: 12px 22px; border-radius: 6px; cursor: pointer; box-shadow: 0 0 18px rgba(217,119,87,0.32); }
    .submit-btn:hover { background: #b85e3f; }
    .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; box-shadow: none; }
    .end-btn { background: rgba(224,122,108,0.12); border: 1px solid rgba(224,122,108,0.32); color: #e07a6c; font-family: 'Inter Tight', sans-serif; font-size: 13px; font-weight: 600; padding: 11px 18px; border-radius: 6px; cursor: pointer; }

    .transcript { background: #14181d; border: 1px solid #2a3038; border-radius: 14px; padding: 20px 22px; }
    .transcript h3 { font-size: 11px; color: #8a8579; text-transform: uppercase; letter-spacing: 0.16em; font-family: 'JetBrains Mono', monospace; margin-bottom: 12px; font-weight: 600; }
    .turn { padding: 10px 0; border-bottom: 1px solid #2a3038; }
    .turn:last-child { border: 0; }
    .turn .role { font-size: 10px; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 5px; font-weight: 600; }
    .turn.ai .role { color: #d97757; }
    .turn.candidate .role { color: #7dd3a8; }
    .turn .text { font-size: 14px; color: #c8c3b8; line-height: 1.6; }

    #monitorPill { position: fixed; bottom: 14px; right: 14px; background: rgba(0,0,0,0.85); border: 1px solid rgba(255,255,255,0.15); border-radius: 12px; padding: 6px 8px; z-index: 55; display: flex; align-items: center; gap: 8px; }
    #monitorPill video { width: 52px; height: 52px; border-radius: 8px; object-fit: cover; transform: scaleX(-1); background: #000; }
    #monitorPill .live { color: #10b981; font-size: 10px; font-weight: 700; }
    #monitorPill .sub { color: rgba(255,255,255,0.6); font-size: 9px; }

    .toast { position: fixed; top: 16px; left: 50%; transform: translateX(-50%); background: rgba(0,0,0,0.92); border: 1px solid rgba(255,255,255,0.15); color: #fff; font-size: 13px; padding: 10px 18px; border-radius: 100px; z-index: 60; }
    .toast.warn { border-color: #fbbf24; color: #fbbf24; }
    .toast.err { border-color: #ef4444; color: #fca5a5; }

    .stt-status { font-size: 11px; color: #8a8a94; margin-top: 8px; font-family: ui-monospace, monospace; }
    .stt-status .dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #6e6e78; margin-right: 6px; vertical-align: middle; }
    .stt-status.live .dot { background: #10b981; animation: pulse 1.2s infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
    .proctor-bar { background: #11141a; border-bottom: 1px solid #1d2128; padding: 8px 14px; display: flex; gap: 8px; flex-wrap: wrap; align-items: center; font-size: 10.5px; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.03em; color: #8a8579; overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
    .proctor-bar::-webkit-scrollbar { display: none; }
    .proctor-bar .chip { display: inline-flex; gap: 5px; align-items: center; padding: 3px 7px; border-radius: 100px; background: #15191f; border: 1px solid #2a3038; flex-shrink: 0; white-space: nowrap; }
    .proctor-bar .chip b { color: #f4f1ea; font-weight: 700; }
    @media (max-width: 760px) {
      .proctor-bar { flex-wrap: nowrap; padding: 6px 12px; gap: 6px; font-size: 10px; }
      .proctor-bar .chip { padding: 2px 6px; }
    }
    .proctor-bar .chip.warn { border-color: #fbbf24; color: #fde68a; }
    .proctor-bar .chip.bad  { border-color: #ef4444; color: #fca5a5; }
    .proctor-bar .chip.ok   { border-color: #10b981; color: #6ee7b7; }
    .term-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.94); display: none; align-items: center; justify-content: center; z-index: 100; padding: 22px; }
    .term-overlay.show { display: flex; }
    .term-box { max-width: 460px; background: #11141a; border: 1px solid #ef4444; border-radius: 16px; padding: 30px; text-align: center; }
    .term-box h2 { font-family: 'Fraunces', serif; font-size: 24px; color: #fca5a5; margin-bottom: 10px; font-weight: 500; }
    .term-box p { font-size: 14px; color: #c8c3b8; line-height: 1.6; margin-bottom: 18px; }
    .term-box code { background: #0d1117; padding: 2px 7px; border-radius: 4px; font-size: 12px; color: #f0b48f; }
  </style>
</head>
<body>
  <div class="top">
    <div>
      <p class="title">{session.title}</p>
      <p class="meta">{session.candidate_name || session.candidate_email || 'anonymous'} &middot; lang {lang} &middot; session {session.id.slice(0, 8)}</p>
    </div>
    <p class="meta" id="timerEl">--:--</p>
  </div>

  <div class="proctor-bar">
    <span class="chip" id="proctorLevelChip"><b>Proctor</b> {session.proctor_level || 'standard'}</span>
    <span class="chip" id="riskChip"><b>Risk</b> <span id="riskVal">0</span>/100</span>
    <span class="chip" id="strikeChip"><b>Strikes</b> <span id="strikeVal">0</span>/{session.max_strikes}</span>
    <span class="chip" id="tabChip"><b>Tab</b> <span id="tabVal">0</span>/{session.max_tab_switches}</span>
    <span class="chip" id="faceChip"><b>Identity</b> <span id="faceVal">checking…</span></span>
    {session.enable_object_detection && <span class="chip" id="objChip"><b>Objects</b> <span id="objVal">scanning…</span></span>}
    {session.require_fullscreen && <span class="chip" id="fsChip"><b>FS</b> <span id="fsVal">on</span></span>}
  </div>

  <div class="term-overlay" id="termOverlay">
    <div class="term-box">
      <h2>Session ended</h2>
      <p id="termReason">The proctoring system has ended this session.</p>
      <p style="font-size:12px;color:#8a8579;">You will be redirected in a moment. The activity log has been saved.</p>
    </div>
  </div>

  <div class="wrap">
    <div class="q-card">
      <p class="q-label" id="qLabel">Question 1</p>
      <p class="q-text" id="qText">{firstTurn ? firstTurn.text : '...'}</p>
      <div class="q-controls">
        <button class="q-btn" id="replayBtn" type="button">&#9655; Replay question</button>
      </div>
    </div>

    <div class="live-card">
      <h3>Your answer (live transcript)</h3>
      <div class="live-text" id="liveText"></div>
      <p class="stt-status" id="sttStatus"><span class="dot"></span> Mic ready - speak when you're ready</p>
      <div class="live-controls">
        <button class="submit-btn" id="submitAnswerBtn" type="button">Submit answer</button>
        <button class="end-btn" id="endBtn" type="button">End interview</button>
      </div>
    </div>

    <div class="transcript" id="transcriptList">
      <h3>Conversation so far</h3>
      <p style="font-size:12px;color:#6e6e78;font-style:italic;">Each AI question and your answer will be appended here as the interview progresses.</p>
    </div>
  </div>

  <div id="monitorPill">
    <video id="monitorVideo" autoplay muted playsinline></video>
    <div>
      <p class="live">&#9679; LIVE</p>
      <p class="sub">monitored - no recording</p>
    </div>
  </div>

  <script is:inline define:vars={{
    sessionId: session.id,
    sessionLang: lang,
    templateSlug: slug,
    firstQuestion: firstTurn ? { text: firstTurn.text, lang: firstTurn.lang || lang, isFollowUp: firstTurn.is_follow_up || false, turnIndex: 0 } : null,
    maxMinutes: session.max_minutes || 30,
    startedAt: session.started_at,
    proctorCfg: {
      level: session.proctor_level,
      requireFaceEnroll: !!session.require_face_enroll,
      blockTabSwitch: !!session.block_tab_switch,
      maxTabSwitches: session.max_tab_switches,
      maxStrikes: session.max_strikes,
      requireFullscreen: !!session.require_fullscreen,
      enableObjectDetection: !!session.enable_object_detection,
      allowPaste: !!session.allow_paste,
    },
    enrolledDescriptor: session.face_descriptor || null
  }}>
  (function() {
    var currentSeedIndex = 0;
    var currentQuestion = firstQuestion;
    var ended = false;

    var qLabel = document.getElementById('qLabel');
    var qText = document.getElementById('qText');
    var liveText = document.getElementById('liveText');
    var submitBtn = document.getElementById('submitAnswerBtn');
    var endBtn = document.getElementById('endBtn');
    var replayBtn = document.getElementById('replayBtn');
    var sttStatus = document.getElementById('sttStatus');
    var transcriptList = document.getElementById('transcriptList');
    var timerEl = document.getElementById('timerEl');

    // ===== Toast helper =====
    function toast(msg, type) {
      var t = document.createElement('div');
      t.className = 'toast' + (type ? ' ' + type : '');
      t.textContent = msg;
      document.body.appendChild(t);
      setTimeout(function() { t.remove(); }, 3500);
    }

    // ===== Proctoring event buffer =====
    var eventBuffer = [];
    var riskVal = document.getElementById('riskVal');
    var strikeVal = document.getElementById('strikeVal');
    var strikeChip = document.getElementById('strikeChip');
    var riskChip = document.getElementById('riskChip');
    var tabVal = document.getElementById('tabVal');
    var tabChip = document.getElementById('tabChip');
    var fsChipVal = document.getElementById('fsVal');
    var fsChip = document.getElementById('fsChip');
    function paintRisk(s) {
      if (!riskChip || !riskVal) return;
      riskVal.textContent = s;
      riskChip.classList.remove('ok','warn','bad');
      if (s <= 5) riskChip.classList.add('ok');
      else if (s <= 45) riskChip.classList.add('warn');
      else riskChip.classList.add('bad');
    }
    function paintStrikes(n) {
      if (!strikeVal) return;
      strikeVal.textContent = n;
      var max = proctorCfg.maxStrikes || 5;
      strikeChip.classList.remove('ok','warn','bad');
      if (n === 0) strikeChip.classList.add('ok');
      else if (n < max) strikeChip.classList.add('warn');
      else strikeChip.classList.add('bad');
    }
    function paintTabs(n) {
      if (!tabVal) return;
      tabVal.textContent = n;
      var max = proctorCfg.maxTabSwitches || 3;
      tabChip.classList.remove('ok','warn','bad');
      if (n === 0) tabChip.classList.add('ok');
      else if (n < max) tabChip.classList.add('warn');
      else tabChip.classList.add('bad');
    }
    function logEvent(type, severity, detail) {
      if (ended) return;
      eventBuffer.push({ type: type, severity: severity || 'info', detail: detail || {}, clientTs: new Date().toISOString() });
      if (eventBuffer.length >= 8 || severity === 'flag') flushEvents();
    }
    function flushEvents() {
      if (eventBuffer.length === 0) return;
      var batch = eventBuffer.splice(0);
      try {
        var payload = JSON.stringify({ sessionId: sessionId, events: batch });
        fetch('/api/aquintutor/interview/log-event', {
          method: 'POST', credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' }, body: payload, keepalive: true,
        }).then(function (r) { return r.json(); }).then(function (d) {
          if (!d || !d.ok) return;
          paintRisk(d.riskScore || 0);
          paintStrikes(d.strikes || 0);
          paintTabs(d.tabSwitches || 0);
          if (d.autoTerminated && !ended) {
            handleAutoTerm(d.autoTerminatedReason || 'policy_violation');
          }
        }).catch(function () { eventBuffer = batch.concat(eventBuffer); });
      } catch (_) { eventBuffer = batch.concat(eventBuffer); }
    }
    setInterval(function () { if (!document.hidden) flushEvents(); }, 5000);
    document.addEventListener('visibilitychange', function () { if (!document.hidden) flushEvents(); });
    window.addEventListener('beforeunload', flushEvents);

    function handleAutoTerm(reason) {
      if (ended) return;
      ended = true;
      var labels = {
        max_strikes_exceeded: 'Maximum strikes exceeded — the proctoring system has flagged enough serious events to end the session.',
        tab_switch_limit_exceeded: 'Too many tab/window switches — the session was set to end after exceeding the allowed limit.',
        risk_score_critical: 'Risk score reached the critical threshold (90/100). The session has been ended.',
        policy_violation: 'A serious policy violation ended this session.',
      };
      try { if (rec) rec.stop(); } catch (_) {}
      try { window.speechSynthesis.cancel(); } catch (_) {}
      var ov = document.getElementById('termOverlay');
      var rs = document.getElementById('termReason');
      if (rs) rs.innerHTML = (labels[reason] || labels.policy_violation) + ' <br><br>Reason code: <code>' + reason + '</code>';
      if (ov) ov.classList.add('show');
      flushEvents();
      setTimeout(function () {
        fetch('/api/aquintutor/interview/end', {
          method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ sessionId: sessionId }),
        }).finally(function () {
          window.location.href = '/aquintutor/interview/done?session=' + encodeURIComponent(sessionId);
        });
      }, 4000);
    }

    // ===== Window / tab / clipboard monitoring =====
    document.addEventListener('visibilitychange', function() { if (document.hidden) { logEvent('tab_hidden', 'warn', {}); toast('Stay in this tab', 'warn'); } else { logEvent('tab_visible', 'info', {}); } });
    window.addEventListener('blur', function() { logEvent('window_blur', 'warn', {}); });
    window.addEventListener('focus', function() { logEvent('window_focus', 'info', {}); });
    document.addEventListener('contextmenu', function(e) { e.preventDefault(); logEvent('right_click_blocked', 'warn', {}); });
    document.addEventListener('copy', function() { logEvent('copy', 'info', {}); });
    document.addEventListener('paste', function() { logEvent('paste', 'info', {}); });
    window.addEventListener('offline', function() { logEvent('network_offline', 'warn', {}); toast('You went offline', 'err'); });
    window.addEventListener('online', function() { logEvent('network_online', 'info', {}); });

    var BLOCKED = [
      {k:'F12',l:'F12',t:'devtools_suspected'},
      {k:'I',c:true,s:true,l:'Ctrl+Shift+I',t:'devtools_suspected'},
      {k:'J',c:true,s:true,l:'Ctrl+Shift+J',t:'devtools_suspected'},
      {k:'C',c:true,s:true,l:'Ctrl+Shift+C',t:'devtools_suspected'},
      {k:'U',c:true,l:'Ctrl+U',t:'keyboard_shortcut_blocked'},
      {k:'p',c:true,l:'Ctrl+P',t:'print_blocked'},
      {k:'P',c:true,l:'Ctrl+P',t:'print_blocked'},
      {k:'s',c:true,l:'Ctrl+S',t:'save_blocked'},
      {k:'S',c:true,l:'Ctrl+S',t:'save_blocked'},
      {k:'PrintScreen',l:'PrintScreen',t:'print_blocked'},
    ];
    document.addEventListener('keydown', function(e) {
      for (var i = 0; i < BLOCKED.length; i++) {
        var b = BLOCKED[i];
        if (e.key === b.k && (!b.c || e.ctrlKey || e.metaKey) && (!b.s || e.shiftKey)) {
          e.preventDefault();
          logEvent(b.t || 'keyboard_shortcut_blocked', 'flag', { shortcut: b.l });
          toast('Blocked: ' + b.l, 'warn');
          return;
        }
      }
    });

    // ===== Print / beforeprint =====
    window.addEventListener('beforeprint', function () { logEvent('print_blocked', 'flag', { via: 'beforeprint' }); });

    // ===== Paste policy =====
    if (!proctorCfg.allowPaste) {
      document.addEventListener('paste', function (e) {
        // The default click on a transcript area is allowed by browser; we just flag it.
        logEvent('paste', 'warn', {});
      }, true);
    }

    // ===== Idle detection =====
    var lastInputAt = Date.now();
    ['mousemove','keydown','click','touchstart'].forEach(function (ev) {
      window.addEventListener(ev, function () { lastInputAt = Date.now(); }, { passive: true });
    });
    setInterval(function () {
      if (ended) return;
      var idleMs = Date.now() - lastInputAt;
      if (idleMs > 120000 && !window.__idleLoggedAt) {
        logEvent('idle_long', 'warn', { idleMs: idleMs });
        window.__idleLoggedAt = Date.now();
      } else if (idleMs < 5000) {
        window.__idleLoggedAt = 0;
      }
    }, 15000);

    // ===== Multi-monitor & display sanity =====
    function checkDisplay() {
      var multi = (screen.width > window.innerWidth * 1.6) || (screen.availWidth - screen.width > 200);
      if (multi && !window.__monLogged) {
        logEvent('multi_monitor_detected', 'warn', { sw: screen.width, sa: screen.availWidth, iw: window.innerWidth });
        window.__monLogged = true;
      }
    }
    checkDisplay();
    window.addEventListener('resize', checkDisplay);
    var initialDpr = window.devicePixelRatio || 1;
    setInterval(function () {
      var dpr = window.devicePixelRatio || 1;
      if (Math.abs(dpr - initialDpr) > 0.05) {
        logEvent('devicepixel_change', 'info', { from: initialDpr, to: dpr });
        initialDpr = dpr;
      }
    }, 8000);

    // ===== Fullscreen enforcement =====
    if (proctorCfg.requireFullscreen) {
      document.addEventListener('fullscreenchange', function () {
        if (document.fullscreenElement) {
          logEvent('fullscreen_enter', 'info', {});
          if (fsChipVal) { fsChipVal.textContent = 'on'; fsChip.classList.remove('bad'); fsChip.classList.add('ok'); }
        } else {
          logEvent('fullscreen_exit', 'warn', {});
          if (fsChipVal) { fsChipVal.textContent = 'off'; fsChip.classList.remove('ok'); fsChip.classList.add('bad'); }
          // Re-prompt with a warning toast
          toast('Fullscreen required — click anywhere to re-enter.', 'err');
          var enforce = function () {
            try { var el = document.documentElement; (el.requestFullscreen || el.webkitRequestFullscreen).call(el); } catch (_) {}
            document.removeEventListener('click', enforce);
          };
          document.addEventListener('click', enforce, { once: true });
          // If they refuse for >12s, escalate
          setTimeout(function () {
            if (!document.fullscreenElement && !ended) logEvent('fullscreen_required_violation', 'flag', {});
          }, 12000);
        }
      });
    }

    // ===== Camera + mic =====
    var faceLastCount = 1;
    var awaySince = 0;
    var voicing = false;
    var voiceSince = 0;
    var stream = null;

    async function startMedia() {
      try {
        stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: 320, height: 240 }, audio: true });
        logEvent('media_consent_granted', 'info', { video: true, audio: true });
        document.getElementById('monitorVideo').srcObject = stream;
        stream.getTracks().forEach(function(t) { t.addEventListener('ended', function() { logEvent('media_lost', 'flag', { kind: t.kind }); }); });
        startFaceMonitor();
        // Mic is also used for STT, so the mic stream pull happens via SpeechRecognition
      } catch (e) {
        logEvent('media_consent_denied', 'flag', { error: e.name || 'denied' });
        toast('Camera + mic permission denied. Session is flagged.', 'err');
      }
    }

    function loadFaceApi() {
      return new Promise(function(resolve, reject) {
        if (window.faceapi) return resolve();
        var s = document.createElement('script');
        s.src = 'https://cdn.jsdelivr.net/npm/@vladmandic/face-api@1.7.13/dist/face-api.min.js';
        s.onload = function() { resolve(); };
        s.onerror = function() { reject(new Error('face-api load failed')); };
        document.head.appendChild(s);
      });
    }

    var enrolledF32 = null;
    if (enrolledDescriptor && Array.isArray(enrolledDescriptor) && enrolledDescriptor.length === 128) {
      enrolledF32 = new Float32Array(enrolledDescriptor);
    }
    var faceChipEl = document.getElementById('faceVal');
    var faceChipBox = document.getElementById('faceChip');
    function paintFace(state, label) {
      if (!faceChipEl || !faceChipBox) return;
      faceChipEl.textContent = label;
      faceChipBox.classList.remove('ok','warn','bad');
      if (state === 'ok') faceChipBox.classList.add('ok');
      else if (state === 'warn') faceChipBox.classList.add('warn');
      else if (state === 'bad') faceChipBox.classList.add('bad');
    }

    function l2(a, b) {
      var s = 0;
      for (var i = 0; i < a.length; i++) { var d = a[i] - b[i]; s += d * d; }
      return Math.sqrt(s);
    }

    async function startFaceMonitor() {
      try {
        await loadFaceApi();
        try { if (window.faceapi && faceapi.tf && faceapi.tf.setBackend) await window.faceapi.tf.setBackend('webgl'); } catch (_) {}
        var URL = 'https://cdn.jsdelivr.net/npm/@vladmandic/face-api@latest/model';
        await faceapi.nets.tinyFaceDetector.loadFromUri(URL);
        await faceapi.nets.faceLandmark68Net.loadFromUri(URL);
        if (enrolledF32) await faceapi.nets.faceRecognitionNet.loadFromUri(URL);
      } catch (e) {
        logEvent('media_lost', 'warn', { reason: 'face_model_load_failed' });
        paintFace('warn', 'model load failed');
        return;
      }
      var v = document.getElementById('monitorVideo');
      var mismatchSince = 0;
      var isMobile = window.matchMedia('(max-width: 760px)').matches;
      // Cheap mode: smaller input, slower cadence, identity check every 3rd frame.
      var FACE_INTERVAL = isMobile ? 2400 : 1600;
      var FACE_INPUT_SIZE = isMobile ? 224 : 320;
      var identityCounter = 0;
      var IDENTITY_EVERY = 3; // run descriptor compare every 3rd cycle
      async function faceTick() {
        if (ended) return;
        if (document.hidden || v.readyState < 2) { setTimeout(faceTick, FACE_INTERVAL); return; }
        try {
          identityCounter++;
          var doIdentity = enrolledF32 && (identityCounter % IDENTITY_EVERY === 0);
          var detector = faceapi.detectAllFaces(v, new faceapi.TinyFaceDetectorOptions({ inputSize: FACE_INPUT_SIZE, scoreThreshold: 0.5 })).withFaceLandmarks();
          if (doIdentity) detector = detector.withFaceDescriptors();
          var dets = await detector;
          var n = dets.length;
          if (n === 0 && faceLastCount > 0) { logEvent('face_lost', 'warn', {}); toast('Face not visible', 'warn'); paintFace('warn', 'face lost'); }
          else if (n > 0 && faceLastCount === 0) { logEvent('face_visible', 'info', { count: n }); paintFace('ok', 'visible'); }
          if (n > 1 && faceLastCount <= 1) { logEvent('multiple_faces', 'flag', { count: n }); toast('Multiple faces detected', 'warn'); paintFace('bad', n + ' faces'); }
          faceLastCount = n;
          if (n === 1) {
            var det = dets[0];
            var lm = det.landmarks;
            // Identity match (only when descriptor was computed this cycle)
            if (enrolledF32 && det.descriptor) {
              var dist = l2(enrolledF32, det.descriptor);
              if (dist < 0.45) {
                if (mismatchSince) { logEvent('face_match', 'info', { dist: dist.toFixed(3) }); paintFace('ok', 'verified'); mismatchSince = 0; }
                else paintFace('ok', 'verified');
              } else if (dist < 0.65) {
                paintFace('warn', 'similar (' + dist.toFixed(2) + ')');
              } else {
                if (!mismatchSince) mismatchSince = Date.now();
                else if (Date.now() - mismatchSince > 4000) {
                  logEvent('face_mismatch', 'flag', { dist: dist.toFixed(3) });
                  paintFace('bad', 'mismatch (' + dist.toFixed(2) + ')');
                  toast('Identity mismatch — confirm camera shows you', 'err');
                  mismatchSince = Date.now() + 30000;
                }
              }
            } else if (!enrolledF32) {
              paintFace('warn', 'no reference');
            }
            // Gaze / yaw
            if (lm) {
              var le = lm.getLeftEye(); var re = lm.getRightEye(); var nose = lm.getNose();
              if (le && re && nose && nose.length > 3) {
                var mid = (le[0].x + re[3].x) / 2;
                var off = (nose[3].x - mid) / Math.max(1, Math.abs(re[3].x - le[0].x));
                if (Math.abs(off) > 0.25) {
                  if (!awaySince) awaySince = Date.now();
                  else if (Date.now() - awaySince > 2000) {
                    logEvent('looking_away', 'warn', { off: off.toFixed(2) });
                    awaySince = Date.now() + 4000;
                  }
                } else { if (awaySince) logEvent('gaze_restored', 'info', {}); awaySince = 0; }
              }
            }
          }
        } catch(_) {}
        setTimeout(faceTick, FACE_INTERVAL);
      }
      faceTick();

      if (proctorCfg.enableObjectDetection) startObjectDetector(v);
    }

    // ===== Object detection (coco-ssd) — gated by template config =====
    function loadCocoSsd() {
      return new Promise(function (resolve, reject) {
        if (window.cocoSsd) return resolve();
        // coco-ssd needs window.tf; piggyback on face-api's bundled tensorflow.
        try { if (window.faceapi && faceapi.tf && !window.tf) window.tf = faceapi.tf; } catch (_) {}
        var s = document.createElement('script');
        s.src = 'https://cdn.jsdelivr.net/npm/@tensorflow-models/coco-ssd@2.2.3/dist/coco-ssd.min.js';
        s.onload = function () { resolve(); };
        s.onerror = function () { reject(new Error('coco-ssd load failed')); };
        document.head.appendChild(s);
      });
    }
    async function startObjectDetector(v) {
      var objChipEl = document.getElementById('objVal');
      try {
        await loadCocoSsd();
        var model = await window.cocoSsd.load({ base: 'lite_mobilenet_v2' });
        if (objChipEl) objChipEl.textContent = 'scanning';
        var lastSeen = {};
        var EVT_FOR = { 'cell phone': 'cell_phone_detected', 'book': 'book_detected', 'laptop': 'laptop_detected', 'tv': 'tv_detected', 'remote': 'remote_detected' };
        var SEV_FOR  = { 'cell phone': 'flag', 'book': 'warn', 'laptop': 'flag', 'tv': 'warn', 'remote': 'warn' };
        var isMobileObj = window.matchMedia('(max-width: 760px)').matches;
        var OBJ_INTERVAL = isMobileObj ? 4500 : 2800;
        async function objTick() {
          if (ended) return;
          if (document.hidden || v.readyState < 2) { setTimeout(objTick, OBJ_INTERVAL); return; }
          try {
            var preds = await model.detect(v);
            var seen = {};
            var personCount = 0;
            for (var i = 0; i < preds.length; i++) {
              var p = preds[i];
              if (p.class === 'person') { personCount++; continue; }
              if (p.score < 0.55) continue;
              if (!(p.class in EVT_FOR)) continue;
              seen[p.class] = true;
              if (!lastSeen[p.class]) {
                logEvent(EVT_FOR[p.class], SEV_FOR[p.class] || 'warn', { score: p.score.toFixed(2) });
                lastSeen[p.class] = Date.now();
              }
            }
            if (personCount > 1 && !lastSeen['__extra_person']) {
              logEvent('extra_person_detected', 'flag', { count: personCount });
              lastSeen['__extra_person'] = Date.now();
            }
            // Clear notifications when objects leave
            Object.keys(lastSeen).forEach(function (k) {
              if (!seen[k] && k !== '__extra_person' && Date.now() - lastSeen[k] > 6000) {
                logEvent('object_cleared', 'info', { what: k });
                delete lastSeen[k];
              }
            });
            if (objChipEl) {
              var keys = Object.keys(seen);
              objChipEl.textContent = keys.length ? keys.join(', ') : 'clear';
            }
          } catch (_) {}
          setTimeout(objTick, OBJ_INTERVAL);
        }
        objTick();
      } catch (e) {
        if (objChipEl) objChipEl.textContent = 'unavailable';
      }
    }

    // Demo / presentation kill-switch — skip all camera proctoring when paused
    // (?proctor=off / ?proctor=on sticks for the session; or localStorage 'era_proctor_off').
    function proctorOff() {
      try {
        var s = (location.search || '');
        if (s.indexOf('proctor=off') >= 0) { try { localStorage.setItem('era_proctor_off', '1'); } catch (e) {} }
        if (s.indexOf('proctor=on') >= 0) { try { localStorage.removeItem('era_proctor_off'); } catch (e) {} }
        if (window.ERA_PROCTOR_OFF) return true;
        if (localStorage.getItem('era_proctor_off') === '1') return true;
      } catch (e) {}
      return false;
    }
    if (proctorOff()) { logEvent('proctoring_paused_demo', 'info', {}); }
    else { startMedia(); }

    // ===== Speech synthesis (AI asks question aloud) =====
    function speak(text, lang) {
      if (!('speechSynthesis' in window)) return;
      try { window.speechSynthesis.cancel(); } catch(_) {}
      var u = new SpeechSynthesisUtterance(text);
      u.lang = lang || sessionLang;
      u.rate = 0.95;
      u.pitch = 1.0;
      window.speechSynthesis.speak(u);
    }

    // ===== Speech recognition (transcribe candidate) =====
    var SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    var rec = null;
    var finalTranscript = '';
    var lastFinalAt = 0;

    function startSTT() {
      if (!SR) { sttStatus.innerHTML = '<span class="dot"></span> Speech recognition not supported - type your answer below (use Chrome/Edge for full experience)'; addManualInput(); return; }
      rec = new SR();
      rec.lang = sessionLang;
      rec.continuous = true;
      rec.interimResults = true;
      rec.onresult = function(e) {
        var partial = '';
        for (var i = e.resultIndex; i < e.results.length; i++) {
          var r = e.results[i];
          if (r.isFinal) { finalTranscript += r[0].transcript + ' '; lastFinalAt = Date.now(); }
          else partial += r[0].transcript;
        }
        renderLive(finalTranscript, partial);
      };
      rec.onerror = function(e) {
        if (e.error === 'no-speech') return;
        sttStatus.innerHTML = '<span class="dot"></span> STT error: ' + e.error;
      };
      rec.onend = function() {
        if (ended) return;
        try { rec.start(); } catch(_) {}
      };
      try { rec.start(); sttStatus.className = 'stt-status live'; sttStatus.innerHTML = '<span class="dot"></span> Listening in ' + sessionLang; } catch(e) { sttStatus.innerHTML = '<span class="dot"></span> Could not start mic: ' + e.message; }
    }

    function addManualInput() {
      // Fallback for browsers without STT
      var ta = document.createElement('textarea');
      ta.id = 'manualAnswer';
      ta.placeholder = 'Type your answer here...';
      ta.style.cssText = 'width:100%;background:#15151a;border:1px solid #1a1a1f;color:#fff;border-radius:8px;padding:10px 12px;font-size:14px;font-family:inherit;outline:none;resize:vertical;min-height:90px;margin-top:8px;';
      liveText.parentNode.insertBefore(ta, liveText.nextSibling);
      ta.addEventListener('input', function() { finalTranscript = ta.value; });
    }

    function renderLive(final, partial) {
      liveText.innerHTML = '<span>' + escapeHtml(final) + '</span><span class="partial">' + escapeHtml(partial) + '</span>';
    }
    function escapeHtml(s) { return String(s == null ? '' : s).replace(/[&<>"']/g, function(c) { return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]; }); }

    // Speak the first question + start STT
    if (currentQuestion) {
      qText.textContent = currentQuestion.text;
      setTimeout(function() { speak(currentQuestion.text, currentQuestion.lang); startSTT(); }, 400);
    }
    logEvent('session_listeners_attached', 'info', { ua: navigator.userAgent.slice(0, 200), lang: sessionLang });

    replayBtn.addEventListener('click', function() { if (currentQuestion) speak(currentQuestion.text, currentQuestion.lang); });

    // ===== Submit answer =====
    function appendTurn(role, text, lang) {
      var d = document.createElement('div');
      d.className = 'turn ' + role;
      d.innerHTML = '<p class="role">' + (role === 'ai' ? 'AI Interviewer' : 'You') + (lang ? ' &middot; ' + lang : '') + '</p><p class="text">' + escapeHtml(text) + '</p>';
      transcriptList.appendChild(d);
      transcriptList.scrollTop = transcriptList.scrollHeight;
    }

    function submitAnswer() {
      if (!currentQuestion || ended) return;
      var manual = document.getElementById('manualAnswer');
      var text = (manual ? manual.value : finalTranscript).trim();
      if (!text) { toast('Please speak (or type) your answer first', 'warn'); return; }
      submitBtn.disabled = true; submitBtn.textContent = 'Sending...';

      // Append AI question + candidate answer to history view
      appendTurn('ai', currentQuestion.text, currentQuestion.lang);
      appendTurn('candidate', text, sessionLang);

      fetch('/api/aquintutor/interview/turn', {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          sessionId: sessionId, transcript: text, lang: sessionLang,
          currentSeedIndex: currentSeedIndex, justAnsweredFollowUp: !!currentQuestion.isFollowUp,
        }),
      }).then(function(r) { return r.json(); }).then(function(d) {
        submitBtn.disabled = false; submitBtn.textContent = 'Submit answer';
        if (!d.ok) { toast(d.error || 'Could not save answer', 'err'); return; }
        if (d.done) { endInterview(true); return; }
        currentSeedIndex = d.currentSeedIndex;
        currentQuestion = d.next;
        qText.textContent = currentQuestion.text;
        qLabel.textContent = currentQuestion.isFollowUp ? 'Follow-up' : 'Question ' + (currentSeedIndex + 1);
        finalTranscript = '';
        if (manual) manual.value = '';
        renderLive('', '');
        speak(currentQuestion.text, currentQuestion.lang);
      }).catch(function() {
        submitBtn.disabled = false; submitBtn.textContent = 'Submit answer';
        toast('Network error', 'err');
      });
    }
    submitBtn.addEventListener('click', submitAnswer);

    function endInterview(auto) {
      if (ended) return;
      ended = true;
      try { window.speechSynthesis.cancel(); } catch(_) {}
      try { if (rec) rec.stop(); } catch(_) {}
      flushEvents();
      fetch('/api/aquintutor/interview/end', {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sessionId: sessionId }),
      }).then(function(r) { return r.json(); }).then(function(d) {
        var loc = (d && d.redirect) || ('/aquintutor/interview/done?session=' + encodeURIComponent(sessionId));
        window.location.href = loc;
      }).catch(function() { window.location.href = '/aquintutor/interview/done?session=' + encodeURIComponent(sessionId); });
    }
    endBtn.addEventListener('click', function() { if (confirm("End the interview now? You won't be able to add more answers.")) endInterview(false); });

    // ===== Timer =====
    var endsAt = new Date(startedAt).getTime() + maxMinutes * 60 * 1000;
    setInterval(function() {
      if (ended) return;
      var rem = Math.max(0, Math.floor((endsAt - Date.now()) / 1000));
      var m = Math.floor(rem / 60); var s = rem % 60;
      timerEl.textContent = (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
      if (rem === 0) endInterview(true);
    }, 500);
  })();
  </script>
</body>
</html>
