---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const { slug } = Astro.params;
const user = Astro.locals.user;

let template: any = null;
let seedCount = 0;

try {
  const r = await db.execute(sql`
    SELECT id, slug, title, description, language_default, max_minutes, is_published
    FROM ai_interview_templates WHERE slug = ${slug} LIMIT 1
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  template = rows[0] || null;
} catch (_) {}

if (!template) return Astro.redirect('/aquintutor');
if (!template.is_published) return Astro.redirect('/aquintutor');

try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM ai_interview_seeds WHERE template_id = ${template.id} AND is_active = true`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  seedCount = (rows[0] as any)?.n || 0;
} catch (_) {}

const LANGS = [
  ['en-IN', 'English (India)'],
  ['en-US', 'English (United States)'],
  ['en-GB', 'English (United Kingdom)'],
  ['hi-IN', 'हिन्दी / Hindi'],
  ['bn-IN', 'বাংলা / Bengali'],
  ['ta-IN', 'தமிழ் / Tamil'],
  ['te-IN', 'తెలుగు / Telugu'],
  ['mr-IN', 'मराठी / Marathi'],
  ['gu-IN', 'ગુજરાતી / Gujarati'],
  ['kn-IN', 'ಕನ್ನಡ / Kannada'],
  ['ml-IN', 'മലയാളം / Malayalam'],
  ['pa-IN', 'ਪੰਜਾਬੀ / Punjabi'],
  ['ur-IN', 'اردو / Urdu'],
  ['es-ES', 'Español / Spanish'],
  ['fr-FR', 'Français / French'],
  ['de-DE', 'Deutsch / German'],
  ['it-IT', 'Italiano / Italian'],
  ['pt-BR', 'Português (Brasil)'],
  ['ru-RU', 'Русский / Russian'],
  ['ja-JP', '日本語 / Japanese'],
  ['ko-KR', '한국어 / Korean'],
  ['zh-CN', '中文 (简体) / Mandarin Simplified'],
  ['zh-TW', '中文 (繁體) / Mandarin Traditional'],
  ['ar-SA', 'العربية / Arabic'],
  ['tr-TR', 'Türkçe / Turkish'],
];
---
<BaseLayout title={template.title + ' - AI Interview'} description={'Begin the ' + template.title + ' AI interview - multilingual, in-browser, no audio or video stored.'} noindex={true}>
  <section class="px-[5vw] py-10 md:py-16 max-w-2xl mx-auto">

    <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-3">AI Interview</p>
    <h1 class="font-display text-[clamp(1.8rem,4vw,2.6rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-3">{template.title}</h1>
    {template.description && <p class="text-[0.95rem] text-ink-2 leading-relaxed mb-6">{template.description}</p>}

    <div class="bg-cream-2 border border-ink/10 rounded-2xl p-5 mb-6">
      <p class="text-[0.72rem] font-mono uppercase tracking-wider text-ink-soft font-bold mb-3">How it works</p>
      <ul class="text-[0.88rem] text-ink-2 leading-relaxed list-none p-0 m-0 flex flex-col gap-2">
        <li>&rsaquo; <strong>{seedCount} questions</strong> &middot; up to <strong>{template.max_minutes} min</strong></li>
        <li>&rsaquo; AI speaks each question aloud in your chosen language</li>
        <li>&rsaquo; You answer by speaking; the browser transcribes your voice live</li>
        <li>&rsaquo; Camera + mic stay on for live proctoring &mdash; <strong>nothing is recorded or saved as video / audio</strong></li>
        <li>&rsaquo; Only your text transcript and activity events land in our database</li>
        <li>&rsaquo; Best in Chrome or Edge (Web Speech API is most accurate there)</li>
      </ul>
    </div>

    <form id="startForm" class="bg-white border border-ink/10 rounded-2xl p-5 md:p-6 flex flex-col gap-4">
      {!user && (
        <>
          <div>
            <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Your name</label>
            <input type="text" name="candidateName" required maxlength="200" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.95rem] outline-none focus:border-burn bg-cream-2" />
          </div>
          <div>
            <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Your email</label>
            <input type="email" name="candidateEmail" required maxlength="255" placeholder="you@example.com" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.95rem] outline-none focus:border-burn bg-cream-2" />
          </div>
        </>
      )}

      <div>
        <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Interview language</label>
        <select name="language" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.95rem] outline-none focus:border-burn bg-cream-2">
          {LANGS.map(([code, label]) => (
            <option value={code} selected={code === template.language_default}>{label}</option>
          ))}
        </select>
        <p class="text-[0.72rem] text-ink-soft mt-1.5">The AI will speak and listen in this language.</p>
      </div>

      <button type="submit" id="startBtn" class="bg-burn hover:bg-burn/90 text-white font-semibold py-3 px-6 rounded-lg text-[0.95rem] mt-2">
        Start the interview
      </button>
      <div id="startErr" style="display:none;background:#fee2e2;border:1px solid #fca5a5;color:#991b1b;padding:11px 14px;border-radius:8px;font-size:13px;"></div>
    </form>

    <p class="text-[0.78rem] text-ink-soft mt-5 text-center">
      By starting, you consent to live face + voice monitoring during the interview. We do not save any audio or video.
    </p>

  </section>

  <script is:inline define:vars={{ slug }}>
    document.getElementById('startForm').addEventListener('submit', function(e) {
      e.preventDefault();
      var fd = new FormData(e.target);
      var btn = document.getElementById('startBtn');
      var err = document.getElementById('startErr');
      btn.disabled = true; var prev = btn.textContent; btn.textContent = 'Starting...';
      err.style.display = 'none';

      var body = {
        templateSlug: slug,
        language: fd.get('language') || '',
        candidateName: fd.get('candidateName') || '',
        candidateEmail: fd.get('candidateEmail') || ''
      };
      fetch('/api/aquintutor/interview/start', {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      }).then(function(r) { return r.json(); }).then(function(d) {
        if (!d.ok) {
          btn.disabled = false; btn.textContent = prev;
          err.textContent = d.error || 'Could not start the interview.';
          err.style.display = 'block';
          return;
        }
        try { sessionStorage.setItem('era_interview_' + d.sessionId, JSON.stringify(d)); } catch(_) {}
        window.location.href = '/aquintutor/interview/' + slug + '/run?session=' + encodeURIComponent(d.sessionId);
      }).catch(function() {
        btn.disabled = false; btn.textContent = prev;
        err.textContent = 'Network error - try again.';
        err.style.display = 'block';
      });
    });
  </script>
</BaseLayout>
