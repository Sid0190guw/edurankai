---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const { slug } = Astro.params;
const user = Astro.locals.user;

let template: any = null;
let seedCount = 0;

try {
  const r = await db.execute(sql`
    SELECT id, slug, title, description, language_default, max_minutes, is_published
    FROM ai_interview_templates WHERE slug = ${slug} LIMIT 1
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  template = rows[0] || null;
} catch (_) {}

if (!template || !template.is_published) return Astro.redirect('/aquintutor');

try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as n FROM ai_interview_seeds WHERE template_id = ${template.id} AND is_active = true`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  seedCount = (rows[0] as any)?.n || 0;
} catch (_) {}

const LANGUAGES = [
  { code: 'en-IN', label: 'English (India)' },
  { code: 'en-US', label: 'English (United States)' },
  { code: 'en-GB', label: 'English (United Kingdom)' },
  { code: 'hi-IN', label: 'Hindi' },
  { code: 'bn-IN', label: 'Bengali' },
  { code: 'ta-IN', label: 'Tamil' },
  { code: 'te-IN', label: 'Telugu' },
  { code: 'mr-IN', label: 'Marathi' },
  { code: 'gu-IN', label: 'Gujarati' },
  { code: 'kn-IN', label: 'Kannada' },
  { code: 'ml-IN', label: 'Malayalam' },
  { code: 'pa-IN', label: 'Punjabi' },
  { code: 'es-ES', label: 'Spanish' },
  { code: 'fr-FR', label: 'French' },
  { code: 'de-DE', label: 'German' },
  { code: 'ar-SA', label: 'Arabic' },
  { code: 'zh-CN', label: 'Mandarin' },
  { code: 'ja-JP', label: 'Japanese' },
];
---
<AquintutorLayout title={template.title} description={template.description || 'A conversational AI-conducted interview.'} noindex={true}>

  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1024px; margin:0 auto; padding:64px 28px 40px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); font-weight:600; letter-spacing:0.04em; margin:0 0 14px;">AI-conducted interview</p>
      <h1 class="font-display" style="font-size:clamp(2rem, 4.5vw, 3.5rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500; margin:0; color:var(--ink); max-width:48rem;">{template.title}</h1>
      {template.description && (
        <p style="font-family:'Inter Tight',sans-serif; font-size:clamp(1rem, 1.3vw, 1.15rem); line-height:1.6; color:var(--ink-500); margin:18px 0 0; max-width:42rem;">{template.description}</p>
      )}
      <div style="display:flex; gap:32px; flex-wrap:wrap; margin-top:28px; padding-top:18px; border-top:1px solid var(--rule);">
        <div><p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); margin:0 0 4px; font-weight:600;">Questions</p><p class="font-display" style="font-size:1.6rem; font-weight:500; margin:0;">{seedCount}</p></div>
        <div><p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); margin:0 0 4px; font-weight:600;">Estimated minutes</p><p class="font-display" style="font-size:1.6rem; font-weight:500; margin:0;">~{template.max_minutes || 20}</p></div>
        <div><p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); margin:0 0 4px; font-weight:600;">Format</p><p class="font-display" style="font-size:1.6rem; font-weight:500; margin:0;">Voice + text</p></div>
      </div>
    </div>
  </section>

  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1024px; margin:0 auto; padding:48px 28px;">
      <div style="display:grid; grid-template-columns:1fr; gap:24px;" class="how-grid">
        <div>
          <h3 class="font-display" style="font-size:1.15rem; font-weight:500; margin:0 0 8px;">How it works</h3>
          <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); line-height:1.55; margin:0;">The AI speaks each question aloud in your chosen language. You answer by speaking (we transcribe live), or by typing. Each answer is saved as text only - no audio or video is stored.</p>
        </div>
        <div>
          <h3 class="font-display" style="font-size:1.15rem; font-weight:500; margin:0 0 8px;">No recording</h3>
          <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); line-height:1.55; margin:0;">We use your microphone in your browser for real-time speech-to-text only. Nothing is uploaded; the institution sees a text transcript and a small proctoring event log.</p>
        </div>
        <div>
          <h3 class="font-display" style="font-size:1.15rem; font-weight:500; margin:0 0 8px;">Best in Chrome / Edge</h3>
          <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); line-height:1.55; margin:0;">Browser speech-to-text and text-to-speech rely on the Web Speech API, which is most reliable in Chromium browsers. Safari + Firefox work but coverage of some languages is partial.</p>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div style="max-width:1024px; margin:0 auto; padding:48px 28px 80px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 14px;">Begin</p>
      <h2 class="font-display" style="font-size:clamp(1.5rem, 2.5vw, 2rem); font-weight:500; margin:0 0 22px; line-height:1.2;">Pick a language. Start the interview.</h2>

      <form id="startForm" style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:24px; display:flex; flex-direction:column; gap:16px; max-width:42rem;">
        <div>
          <label for="lang" style="display:block; font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); margin-bottom:6px; font-weight:600;">Interview language</label>
          <select id="lang" name="language" style="width:100%; padding:11px 14px; border:1px solid var(--rule); border-radius:8px; background:var(--paper); font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink); outline:none;">
            {LANGUAGES.map((l) => <option value={l.code} selected={l.code === template.language_default}>{l.label}</option>)}
          </select>
        </div>
        {!user && (
          <>
            <div>
              <label for="name" style="display:block; font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); margin-bottom:6px; font-weight:600;">Your name (optional)</label>
              <input id="name" type="text" maxlength="200" placeholder="As you would like to be addressed" style="width:100%; padding:11px 14px; border:1px solid var(--rule); border-radius:8px; background:var(--paper); font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink); outline:none;" />
            </div>
            <div>
              <label for="email" style="display:block; font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); margin-bottom:6px; font-weight:600;">Email (optional - for follow-up)</label>
              <input id="email" type="email" maxlength="255" placeholder="you@example.com" style="width:100%; padding:11px 14px; border:1px solid var(--rule); border-radius:8px; background:var(--paper); font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink); outline:none;" />
            </div>
          </>
        )}
        <button type="submit" id="startBtn" style="background:var(--ink); color:var(--sand-50); padding:14px 26px; border:none; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; cursor:pointer; margin-top:6px;">Start the interview &rarr;</button>
        <p id="startErr" style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); margin:0; display:none;"></p>
      </form>
    </div>
  </section>

  <script is:inline define:vars={{ templateSlug: slug, isUser: !!user }}>
    var form = document.getElementById('startForm');
    var btn = document.getElementById('startBtn');
    var errEl = document.getElementById('startErr');
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      btn.disabled = true; var prev = btn.textContent; btn.textContent = 'Starting...';
      errEl.style.display = 'none';
      var body = { templateSlug: templateSlug, language: document.getElementById('lang').value };
      if (!isUser) {
        body.candidateName = (document.getElementById('name') || {}).value || '';
        body.candidateEmail = (document.getElementById('email') || {}).value || '';
      }
      fetch('/api/aquintutor/interview/start', {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      }).then(function(r) { return r.json(); }).then(function(d) {
        btn.disabled = false; btn.textContent = prev;
        if (d.ok && d.sessionId) {
          window.location.href = '/aquintutor/interview/' + templateSlug + '/run?session=' + encodeURIComponent(d.sessionId);
        } else {
          errEl.textContent = d.error || 'Could not start interview.';
          errEl.style.display = 'block';
        }
      }).catch(function() {
        btn.disabled = false; btn.textContent = prev;
        errEl.textContent = 'Network error - try again.';
        errEl.style.display = 'block';
      });
    });
  </script>

  <style>
    @media (min-width: 768px) { .how-grid { grid-template-columns: repeat(3, 1fr) !important; } }
  </style>
</AquintutorLayout>
