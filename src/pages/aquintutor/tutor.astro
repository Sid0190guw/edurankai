---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
---
<BaseLayout title="Aquin · AI tutor (vernacular)" description="EduRankAI's vernacular AI tutor — speak, type, or write to Aquin in 12 Indic languages. Devanagari, Tamil, Telugu, Bengali, Marathi, Kannada, Malayalam, Gujarati, Punjabi, Odia + Hinglish. Browser voice in/out.">

<style>
  body { background: #FAF8F5; color: #0E0B08; margin: 0; }
  .tu-wrap { max-width: 980px; margin: 0 auto; padding: 24px 16px 100px; display: grid; grid-template-rows: auto 1fr auto; min-height: calc(100vh - 200px); }
  .tu-top { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 14px; padding: 16px 0 18px; border-bottom: 1px solid rgba(14,11,8,0.08); }
  .tu-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin: 0; }
  .tu-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 4vw, 42px); font-weight: 600; letter-spacing: -0.02em; margin: 4px 0 0; }
  .tu-title em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .tu-sub { font-size: 14px; color: #7A6F68; margin-top: 4px; max-width: 580px; line-height: 1.55; }

  .tu-lang { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }
  .tu-lang select { background: #fff; border: 1px solid rgba(14,11,8,0.15); color: #0E0B08; padding: 8px 14px; border-radius: 8px; font-family: inherit; font-size: 13px; cursor: pointer; }

  .tu-stream { padding: 24px 0; display: flex; flex-direction: column; gap: 12px; }
  .tu-bubble { max-width: 75%; padding: 12px 16px; border-radius: 14px; line-height: 1.55; word-wrap: break-word; }
  .tu-bubble.user { align-self: flex-end; background: #FF4F00; color: #fff; }
  .tu-bubble.aquin { align-self: flex-start; background: #fff; border: 1px solid rgba(14,11,8,0.10); }
  .tu-bubble.aquin .tu-meta { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin-bottom: 4px; }
  .tu-bubble.aquin .tu-body { font-size: 14.5px; color: #0E0B08; }
  .tu-bubble.user .tu-body { font-size: 14.5px; }
  .tu-bubble.system { align-self: center; background: rgba(14,11,8,0.04); color: #7A6F68; font-size: 12px; font-style: italic; padding: 6px 12px; border-radius: 100px; }

  .tu-input-wrap { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 12px; display: grid; grid-template-columns: 36px 1fr 36px 90px; gap: 8px; align-items: center; position: sticky; bottom: 16px; box-shadow: 0 8px 24px rgba(14,11,8,0.06); }
  .tu-input { width: 100%; background: transparent; border: none; outline: none; font-family: inherit; font-size: 14.5px; padding: 8px 4px; color: #0E0B08; resize: none; min-height: 30px; max-height: 200px; }
  .tu-mic, .tu-volume { background: transparent; border: 1px solid rgba(14,11,8,0.15); color: #0E0B08; width: 36px; height: 36px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 16px; }
  .tu-mic.recording { background: #FF4F00; color: #fff; border-color: #FF4F00; animation: pulse 1.4s infinite; }
  @keyframes pulse { 0%,100% { box-shadow: 0 0 0 0 rgba(255,79,0,0.4); } 50% { box-shadow: 0 0 0 8px rgba(255,79,0,0); } }
  .tu-send { background: #FF4F00; color: #fff; border: none; padding: 10px 18px; border-radius: 10px; font-weight: 700; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; }

  .tu-script { font-family: 'Noto Sans Devanagari', 'Noto Sans Tamil', 'Noto Sans Telugu', 'Noto Sans Bengali', 'Noto Sans Gurmukhi', 'Noto Sans Oriya', 'Noto Sans Gujarati', 'Noto Sans Kannada', 'Noto Sans Malayalam', sans-serif; }

  .tu-suggestions { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 10px; }
  .tu-suggest { background: #fff; border: 1px solid rgba(14,11,8,0.10); padding: 6px 12px; border-radius: 100px; font-size: 12.5px; cursor: pointer; color: #2E2520; }
  .tu-suggest:hover { background: #FFF3EE; border-color: #FF4F00; color: #FF4F00; }
</style>

<main class="tu-wrap">

  <header class="tu-top">
    <div>
      <p class="tu-eyebrow">AquinTutor · AI Tutor</p>
      <h1 class="tu-title">Talk to <em>Aquin</em>.</h1>
      <p class="tu-sub">Type, speak, or paste in any of 12 Indic languages. Aquin reads the script you write in and replies in the same. Voice input + speech output run through your browser.</p>
    </div>
    <div class="tu-lang">
      <label style="font-family:'Geist Mono',monospace;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:#7A6F68;">Language</label>
      <select id="langSel">
        <option value="en-IN">English</option>
        <option value="hi-IN" data-script="dev">हिन्दी · Hindi</option>
        <option value="ta-IN" data-script="tam">தமிழ் · Tamil</option>
        <option value="te-IN" data-script="tel">తెలుగు · Telugu</option>
        <option value="bn-IN" data-script="ben">বাংলা · Bengali</option>
        <option value="mr-IN" data-script="dev">मराठी · Marathi</option>
        <option value="kn-IN" data-script="kan">ಕನ್ನಡ · Kannada</option>
        <option value="ml-IN" data-script="mal">മലയാളം · Malayalam</option>
        <option value="gu-IN" data-script="guj">ગુજરાતી · Gujarati</option>
        <option value="pa-IN" data-script="gur">ਪੰਜਾਬੀ · Punjabi</option>
        <option value="or-IN" data-script="ori">ଓଡ଼ିଆ · Odia</option>
        <option value="sa-IN" data-script="dev">संस्कृतम् · Sanskrit</option>
        <option value="hinglish">Hinglish (Hindi + English)</option>
      </select>
    </div>
  </header>

  <section class="tu-stream tu-script" id="stream">
    <div class="tu-bubble aquin">
      <p class="tu-meta">Aquin · Ready</p>
      <p class="tu-body" id="welcomeMsg">Hello. I'm Aquin, your tutor. Ask me anything — pick a language above to switch. Click the mic to speak.</p>
    </div>
  </section>

  <div>
    <div class="tu-suggestions tu-script" id="suggestions"></div>
    <div class="tu-input-wrap">
      <button id="micBtn" class="tu-mic" title="Voice input"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg></button>
      <textarea id="msg" class="tu-input tu-script" placeholder="Type or speak..." rows="1"></textarea>
      <button id="volBtn" class="tu-volume" title="Toggle voice output"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19 5a9 9 0 0 1 0 14"/><path d="M15 9a5 5 0 0 1 0 6"/></svg></button>
      <button id="sendBtn" class="tu-send">Send</button>
    </div>
  </div>
</main>

<script is:inline>
  /* ============================================================
     Aquin vernacular tutor.
     - 12 Indic languages + Hinglish + English
     - Native browser SpeechRecognition (input)
     - Native browser SpeechSynthesis (output)
     - POST chat to /api/ai/chat with lang context
     - Native script via 'Noto Sans X' fallback chain in CSS
     ============================================================ */
  (function () {
    var L10N = {
      'en-IN':    { welcome: "Hello. I'm Aquin, your tutor. Ask me anything.", placeholder: "Type or speak...", you: 'You', aquin: 'Aquin', suggestions: ['Explain Newton\'s third law', 'What is a qubit?', 'Help me solve x² + 5x + 6 = 0'] },
      'hi-IN':    { welcome: "नमस्ते। मैं Aquin हूँ, आपका शिक्षक। आप मुझसे कुछ भी पूछ सकते हैं।", placeholder: "लिखें या बोलें...", you: 'आप', aquin: 'Aquin', suggestions: ['न्यूटन का तीसरा नियम समझाओ', 'क्यूबिट क्या है?', 'x² + 5x + 6 = 0 हल करो'] },
      'ta-IN':    { welcome: "வணக்கம். நான் Aquin, உங்கள் ஆசிரியர். எதையும் கேளுங்கள்.", placeholder: "எழுதவும் அல்லது பேசவும்...", you: 'நீங்கள்', aquin: 'Aquin', suggestions: ['நியூட்டனின் மூன்றாம் விதியை விளக்குங்கள்', 'குபிட் என்றால் என்ன?', 'x² + 5x + 6 = 0 தீர்க்கவும்'] },
      'te-IN':    { welcome: "నమస్కారం. నేను Aquin, మీ ఉపాధ్యాయుడు. ఏదైనా అడగండి.", placeholder: "టైప్ చేయండి లేదా మాట్లాడండి...", you: 'మీరు', aquin: 'Aquin', suggestions: ['న్యూటన్ మూడవ నియమాన్ని వివరించండి', 'క్యూబిట్ అంటే ఏమిటి?', 'x² + 5x + 6 = 0 పరిష్కరించండి'] },
      'bn-IN':    { welcome: "নমস্কার। আমি Aquin, আপনার শিক্ষক। কিছু জিজ্ঞাসা করুন।", placeholder: "লিখুন বা কথা বলুন...", you: 'আপনি', aquin: 'Aquin', suggestions: ['নিউটনের তৃতীয় সূত্র ব্যাখ্যা করুন', 'কিউবিট কি?', 'x² + 5x + 6 = 0 সমাধান করুন'] },
      'mr-IN':    { welcome: "नमस्कार. मी Aquin, तुमचा शिक्षक. काहीही विचारा.", placeholder: "टाइप करा किंवा बोला...", you: 'तुम्ही', aquin: 'Aquin', suggestions: ['न्यूटनचा तिसरा नियम समजावा', 'क्युबिट म्हणजे काय?', 'x² + 5x + 6 = 0 सोडवा'] },
      'kn-IN':    { welcome: "ನಮಸ್ಕಾರ. ನಾನು Aquin, ನಿಮ್ಮ ಶಿಕ್ಷಕ. ಏನಾದರೂ ಕೇಳಿ.", placeholder: "ಟೈಪ್ ಮಾಡಿ ಅಥವಾ ಮಾತನಾಡಿ...", you: 'ನೀವು', aquin: 'Aquin', suggestions: ['ನ್ಯೂಟನ್ ಮೂರನೇ ನಿಯಮ ವಿವರಿಸಿ', 'ಕ್ಯೂಬಿಟ್ ಎಂದರೇನು?', 'x² + 5x + 6 = 0 ಪರಿಹರಿಸಿ'] },
      'ml-IN':    { welcome: "നമസ്കാരം. ഞാൻ Aquin ആണ്, നിങ്ങളുടെ അധ്യാപകൻ. എന്തും ചോദിക്കൂ.", placeholder: "ടൈപ്പ് ചെയ്യുകയോ സംസാരിക്കുകയോ ചെയ്യൂ...", you: 'നിങ്ങൾ', aquin: 'Aquin', suggestions: ['ന്യൂട്ടന്റെ മൂന്നാം നിയമം വിശദീകരിക്കുക', 'ക്യൂബിറ്റ് എന്നാൽ എന്ത്?', 'x² + 5x + 6 = 0 പരിഹരിക്കുക'] },
      'gu-IN':    { welcome: "નમસ્તે. હું Aquin છું, તમારો શિક્ષક. કંઈપણ પૂછો.", placeholder: "ટાઇપ કરો અથવા બોલો...", you: 'તમે', aquin: 'Aquin', suggestions: ['ન્યૂટનનો ત્રીજો નિયમ સમજાવો', 'ક્યુબિટ શું છે?', 'x² + 5x + 6 = 0 ઉકેલો'] },
      'pa-IN':    { welcome: "ਸਤ ਸ੍ਰੀ ਅਕਾਲ। ਮੈਂ Aquin ਹਾਂ, ਤੁਹਾਡਾ ਅਧਿਆਪਕ। ਕੁਝ ਵੀ ਪੁੱਛੋ।", placeholder: "ਟਾਈਪ ਕਰੋ ਜਾਂ ਬੋਲੋ...", you: 'ਤੁਸੀਂ', aquin: 'Aquin', suggestions: ['ਨਿਊਟਨ ਦਾ ਤੀਜਾ ਨਿਯਮ ਸਮਝਾਓ', 'ਕਿਊਬਿਟ ਕੀ ਹੈ?', 'x² + 5x + 6 = 0 ਹੱਲ ਕਰੋ'] },
      'or-IN':    { welcome: "ନମସ୍କାର। ମୁଁ Aquin, ତୁମର ଶିକ୍ଷକ। କିଛି ପଚାର।", placeholder: "ଟାଇପ୍ କରନ୍ତୁ କିମ୍ବା କଥା ହୁଅନ୍ତୁ...", you: 'ତୁମେ', aquin: 'Aquin', suggestions: ['ନ୍ୟୁଟନର ତୃତୀୟ ନିୟମ ବ୍ୟାଖ୍ୟା କର', 'କ୍ୟୁବିଟ୍ କଣ?', 'x² + 5x + 6 = 0 ସମାଧାନ କର'] },
      'sa-IN':    { welcome: "नमस्ते। अहम् Aquin अस्मि, भवतः शिक्षकः। किमपि पृच्छतु।", placeholder: "लिखतु अथवा वदतु...", you: 'भवान्', aquin: 'Aquin', suggestions: ['न्यूटनस्य तृतीयं नियमं वदतु', 'क्यूबिट् किम्?', 'x² + 5x + 6 = 0 परिहर'] },
      'hinglish': { welcome: "Hi! Main Aquin hoon. Kuchh bhi pucho — Hindi mein, English mein, ya dono mix karke.", placeholder: "Type ya bolo...", you: 'You', aquin: 'Aquin', suggestions: ['Newton ka third law samjhao', 'Qubit kya hota hai?', 'x² + 5x + 6 = 0 ko solve karo'] },
    };

    var langSel = document.getElementById('langSel');
    var stream = document.getElementById('stream');
    var msgBox = document.getElementById('msg');
    var sendBtn = document.getElementById('sendBtn');
    var micBtn = document.getElementById('micBtn');
    var volBtn = document.getElementById('volBtn');
    var welcomeMsg = document.getElementById('welcomeMsg');
    var suggestionsEl = document.getElementById('suggestions');
    var voiceOn = true;
    var history = []; // for context

    function applyLang() {
      var lang = langSel.value;
      var l = L10N[lang] || L10N['en-IN'];
      welcomeMsg.textContent = l.welcome;
      msgBox.placeholder = l.placeholder;
      suggestionsEl.innerHTML = '';
      l.suggestions.forEach(function (s) {
        var el = document.createElement('button');
        el.className = 'tu-suggest tu-script';
        el.textContent = s;
        el.addEventListener('click', function () { msgBox.value = s; msgBox.focus(); });
        suggestionsEl.appendChild(el);
      });
    }
    langSel.addEventListener('change', applyLang);
    applyLang();

    function addBubble(role, text) {
      var el = document.createElement('div');
      el.className = 'tu-bubble ' + role + ' tu-script';
      if (role === 'aquin') el.innerHTML = '<p class="tu-meta">Aquin</p><p class="tu-body">' + escapeHtml(text) + '</p>';
      else if (role === 'user') el.innerHTML = '<p class="tu-body">' + escapeHtml(text) + '</p>';
      else el.textContent = text;
      stream.appendChild(el);
      stream.parentElement.scrollIntoView({ behavior: 'smooth', block: 'end' });
      window.scrollTo(0, document.body.scrollHeight);
      return el;
    }
    function escapeHtml(s) { return (s || '').toString().replace(/[<>&]/g, function (c) { return { '<':'&lt;','>':'&gt;','&':'&amp;' }[c]; }); }

    function speak(text) {
      if (!voiceOn || !window.speechSynthesis) return;
      try {
        var u = new SpeechSynthesisUtterance(text);
        u.lang = (langSel.value === 'hinglish') ? 'hi-IN' : langSel.value;
        u.rate = 0.95;
        window.speechSynthesis.cancel();
        window.speechSynthesis.speak(u);
      } catch (_) {}
    }

    async function send() {
      var text = msgBox.value.trim();
      if (!text) return;
      addBubble('user', text);
      history.push({ role: 'user', content: text });
      msgBox.value = '';
      msgBox.style.height = 'auto';
      var loading = addBubble('system', '...');
      try {
        var lang = langSel.value;
        var prompt = text;
        var sys = 'You are Aquin, an EduRankAI tutor. The student is writing in ' + (lang === 'hinglish' ? 'Hinglish (mixed Hindi and English)' : lang) + '. Reply concisely in the SAME language and script. Use natural, warm, educational tone. Show steps for math/physics problems.';
        var r = await fetch('/api/ai/chat', {
          method: 'POST', credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: history.slice(-10), system: sys, lang: lang }),
        });
        var d = await r.json();
        loading.remove();
        var reply = d.reply || d.message || d.content || (d.choices && d.choices[0] && d.choices[0].message && d.choices[0].message.content) || 'Sorry, I could not generate a reply. Please try again.';
        addBubble('aquin', reply);
        history.push({ role: 'assistant', content: reply });
        speak(reply);
      } catch (e) {
        loading.remove();
        addBubble('aquin', 'Network error. Please try again.');
      }
    }

    sendBtn.addEventListener('click', send);
    msgBox.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); }
    });
    msgBox.addEventListener('input', function () { msgBox.style.height = 'auto'; msgBox.style.height = Math.min(200, msgBox.scrollHeight) + 'px'; });

    // ============ Voice input (SpeechRecognition) ============
    var Recog = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (Recog) {
      var rec = new Recog(); rec.continuous = false; rec.interimResults = true;
      var recording = false;
      micBtn.addEventListener('click', function () {
        if (recording) { rec.stop(); return; }
        try {
          rec.lang = (langSel.value === 'hinglish') ? 'hi-IN' : langSel.value;
          rec.start();
          recording = true; micBtn.classList.add('recording');
        } catch (e) { alert('Voice not available: ' + e.message); }
      });
      rec.onresult = function (e) {
        var t = '';
        for (var i = e.resultIndex; i < e.results.length; i++) t += e.results[i][0].transcript;
        msgBox.value = t;
      };
      rec.onend = function () { recording = false; micBtn.classList.remove('recording'); };
      rec.onerror = function () { recording = false; micBtn.classList.remove('recording'); };
    } else {
      micBtn.style.opacity = '0.3'; micBtn.title = 'Voice input not supported in this browser';
    }

    volBtn.addEventListener('click', function () { voiceOn = !voiceOn; volBtn.style.background = voiceOn ? 'transparent' : 'rgba(14,11,8,0.06)'; });
  })();
</script>
</BaseLayout>
