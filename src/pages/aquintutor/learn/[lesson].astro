---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const { lesson } = Astro.params;
const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/learn/' + lesson));

let info: any = null;
try {
  const r = await db.execute(sql`
    SELECT l.id, l.title, l.course_id, c.slug AS course_slug, c.title AS course_title
    FROM training_lessons l LEFT JOIN training_courses c ON l.course_id = c.id
    WHERE l.id = ${lesson} LIMIT 1
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  info = rows[0] || null;
} catch (_) {}
if (!info) return Astro.redirect('/aquintutor/courses');
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{info.title} — AquinTutor</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&display=swap" />
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{background:#fafaf7;color:#1c1d22;min-height:100vh;font-family:'Inter Tight',-apple-system,BlinkMacSystemFont,system-ui,sans-serif}
    .top{background:#fff;border-bottom:1px solid #e6e3da;padding:14px 22px;display:flex;align-items:center;gap:14px;position:sticky;top:0;z-index:5;}
    .quit{background:none;border:none;font-size:18px;cursor:pointer;color:#5b5b5b;}
    .pbar{flex:1;height:14px;background:#e6e3da;border-radius:100px;overflow:hidden;border:1px solid #d8d4c8;}
    .pbar > div{height:100%;background:linear-gradient(90deg,#d97757,#f97316);transition:width .35s cubic-bezier(.4,.0,.2,1);}
    .heart{font-size:18px;color:#ef4444;font-weight:700;font-family:'JetBrains Mono',monospace;font-size:14px;}
    .wrap{max-width:680px;margin:0 auto;padding:28px 22px 140px;}
    .card{background:#fff;border:1px solid #e6e3da;border-radius:18px;padding:28px 32px;box-shadow:0 6px 24px rgba(0,0,0,0.04);}
    .prompt{font-family:'Fraunces',serif;font-size:clamp(20px,2.8vw,28px);font-weight:500;line-height:1.35;margin-bottom:24px;color:#1c1d22;}
    .opt{display:block;width:100%;padding:16px 20px;background:#fff;border:2px solid #e6e3da;border-radius:14px;margin-bottom:10px;font-family:inherit;font-size:16px;cursor:pointer;text-align:left;transition:all .12s;}
    .opt:hover{border-color:#c8c3b8;background:#faf8f3;}
    .opt.selected{border-color:#d97757;background:rgba(217,119,87,0.08);}
    .opt.correct{border-color:#10b981;background:rgba(16,185,129,0.12);color:#047857;}
    .opt.wrong{border-color:#ef4444;background:rgba(239,68,68,0.10);color:#991b1b;}
    .opt:disabled{cursor:default;}
    .ti{width:100%;padding:16px 20px;border:2px solid #e6e3da;border-radius:14px;font-family:inherit;font-size:16px;outline:none;background:#fff;}
    .ti:focus{border-color:#d97757;}
    .check-btn{width:100%;padding:18px;background:#d97757;color:#fff;border:none;border-radius:14px;font-family:inherit;font-size:16px;font-weight:700;cursor:pointer;letter-spacing:0.02em;box-shadow:0 4px 14px rgba(217,119,87,0.3);margin-top:18px;}
    .check-btn:hover{background:#b85e3f;}
    .check-btn:disabled{background:#c8c3b8;cursor:not-allowed;box-shadow:none;}
    .check-btn.right{background:#10b981;box-shadow:0 4px 14px rgba(16,185,129,0.35);}
    .check-btn.wrong{background:#ef4444;}
    .feedback{padding:16px 20px;border-radius:14px;margin-top:14px;font-size:14px;line-height:1.55;}
    .feedback.ok{background:rgba(16,185,129,0.12);border-left:4px solid #10b981;color:#047857;}
    .feedback.bad{background:rgba(239,68,68,0.10);border-left:4px solid #ef4444;color:#991b1b;}
    .feedback b{display:block;font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:6px;}
    .pairs{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:18px;}
    .pair-tile{padding:14px 16px;background:#fff;border:2px solid #e6e3da;border-radius:12px;cursor:pointer;font-family:inherit;font-size:14.5px;text-align:left;}
    .pair-tile.active{border-color:#d97757;background:rgba(217,119,87,0.08);}
    .pair-tile.matched{background:rgba(16,185,129,0.12);border-color:#10b981;color:#047857;cursor:default;}
    .pair-tile:disabled{cursor:default;}
    .xp-pop{position:fixed;right:22px;bottom:22px;background:#d97757;color:#fff;padding:10px 18px;border-radius:100px;font-family:monospace;font-weight:700;font-size:14px;box-shadow:0 8px 24px rgba(217,119,87,0.4);transform:translateY(80px);opacity:0;transition:all .35s;z-index:30;}
    .xp-pop.show{transform:translateY(0);opacity:1;}
    .summary{text-align:center;padding:36px 30px;}
    .summary .big{font-family:'Fraunces',serif;font-size:64px;font-weight:600;color:#d97757;line-height:1;}
    .summary .sub{font-size:15px;color:#5b5b5b;margin-top:12px;}
    .summary-actions{display:flex;gap:10px;justify-content:center;margin-top:24px;flex-wrap:wrap;}
    .summary-actions a, .summary-actions button{padding:14px 26px;border-radius:14px;font-family:inherit;font-size:14px;font-weight:700;text-decoration:none;cursor:pointer;border:none;}
    .summary-actions .primary{background:#d97757;color:#fff;box-shadow:0 4px 14px rgba(217,119,87,0.3);}
    .summary-actions .secondary{background:#fff;color:#1c1d22;border:2px solid #e6e3da;}
  </style>
</head>
<body>
  <header class="top">
    <button type="button" class="quit" onclick={'window.location.href=\'/aquintutor/courses/' + info.course_slug + '\''} aria-label="Quit">✕</button>
    <div class="pbar"><div id="pfill" style="width:0%;"></div></div>
    <span class="heart" style="display:inline-flex;align-items:center;gap:5px;"><svg width="17" height="17" viewBox="0 0 24 24" fill="#ef4444" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg><span id="hearts">5</span></span>
  </header>

  <div class="wrap">
    <p style="font-family:'Inter Tight',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:#5b5b5b;font-weight:700;margin-bottom:14px;">{info.course_title}</p>
    <div id="root"></div>
  </div>

  <div class="xp-pop" id="xpPop">+0 XP</div>

  <script is:inline define:vars={{ lessonId: info.id, courseSlug: info.course_slug }}>
  (function () {
    var root = document.getElementById('root');
    var pfill = document.getElementById('pfill');
    var heartsEl = document.getElementById('hearts');
    var xpPop = document.getElementById('xpPop');
    var state = { idx: 0, exs: [], correct: 0, hearts: 5, totalXp: 0, answer: undefined, answered: false, isRight: false, courseSlug: courseSlug };

    function esc(s) { return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) { return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]; }); }
    function html(s) { var t = document.createElement('template'); t.innerHTML = s.trim(); return t.content.firstChild; }

    fetch('/api/aquintutor/learn/start?lesson=' + lessonId, { credentials: 'same-origin' })
      .then(function (r) { return r.json(); })
      .then(function (d) {
        if (!d.ok || !d.exercises || !d.exercises.length) {
          root.innerHTML = '<div class="card"><p style="font-family:Fraunces,serif;font-size:18px;">No exercises in this lesson yet.</p></div>';
          return;
        }
        state.exs = d.exercises;
        render();
      });

    function render() {
      if (state.idx >= state.exs.length || state.hearts <= 0) return summary();
      pfill.style.width = (state.idx / state.exs.length * 100) + '%';
      var ex = state.exs[state.idx];
      state.answer = undefined; state.answered = false; state.isRight = false;
      var card = document.createElement('div');
      card.className = 'card';
      var pType = ex.type;
      var head = '<p style="font-family:Inter Tight,monospace;font-size:10.5px;letter-spacing:0.14em;text-transform:uppercase;color:#d97757;font-weight:700;margin-bottom:10px;">' + pType.replace(/_/g,' ') + '</p>';
      head += '<p class="prompt">' + esc(ex.prompt) + '</p>';
      card.innerHTML = head;

      if (pType === 'image_choice') {
        // Like MCQ but each option has an image (URL) + label
        var opts = (ex.payload && ex.payload.options) || [];
        var grid = html('<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:6px;"></div>');
        opts.forEach(function (o, i) {
          var src = typeof o === 'object' ? (o.image_url || o.image || '') : '';
          var label = typeof o === 'object' ? (o.text || o.label || '') : String(o);
          var b = html('<button type="button" class="opt" data-i="' + i + '" style="padding:14px;display:flex;flex-direction:column;align-items:center;gap:10px;">' +
            (src ? '<img src="' + esc(src) + '" alt="" style="width:100%;max-height:140px;object-fit:contain;border-radius:8px;background:#fff;" />' : '<span style="font-size:42px;line-height:1;">' + esc(label) + '</span>') +
            (src ? '<span style="font-size:13.5px;font-weight:600;">' + esc(label) + '</span>' : '') +
            '</button>');
          b.addEventListener('click', function () {
            if (state.answered) return;
            grid.querySelectorAll('.opt').forEach(function (x) { x.classList.remove('selected'); });
            b.classList.add('selected');
            state.answer = i; checkBtnEnable();
          });
          grid.appendChild(b);
        });
        card.appendChild(grid);
      } else if (pType === 'order_words') {
        // Tap words in correct order to build a sentence. Payload.words is the
        // shuffled bank; correct_answer is the array of indices into the bank
        // in the correct order. The user's answer is the order they tapped.
        var bank = (ex.payload && ex.payload.words) || [];
        // Render answer row + bank row.
        var rowAns = html('<div style="min-height:54px;padding:10px;border:2px dashed var(--rule, #e6e3da);border-radius:12px;display:flex;flex-wrap:wrap;gap:8px;margin-bottom:12px;background:#fafaf7;"></div>');
        var rowBank = html('<div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:6px;"></div>');
        state.answer = [];
        bank.forEach(function (w, i) {
          var b = html('<button type="button" data-i="' + i + '" style="padding:10px 14px;background:#fff;border:2px solid #e6e3da;border-radius:10px;font-family:inherit;font-size:15px;font-weight:600;cursor:pointer;">' + esc(w) + '</button>');
          b.addEventListener('click', function () {
            if (state.answered) return;
            if (b.dataset.placed === '1') {
              // remove from answer
              var idx = parseInt(b.getAttribute('data-i'), 10);
              state.answer = state.answer.filter(function (x) { return x !== idx; });
              b.style.display = ''; b.dataset.placed = '';
              // remove from answer row
              var clone = rowAns.querySelector('button[data-i="' + idx + '"]');
              if (clone) clone.remove();
            } else {
              var idx = parseInt(b.getAttribute('data-i'), 10);
              state.answer.push(idx);
              b.style.display = 'none'; b.dataset.placed = '1';
              var clone = html('<button type="button" data-i="' + idx + '" style="padding:10px 14px;background:rgba(217,119,87,0.10);border:2px solid #d97757;color:#d97757;border-radius:10px;font-family:inherit;font-size:15px;font-weight:600;cursor:pointer;">' + esc(w) + '</button>');
              clone.addEventListener('click', function () {
                if (state.answered) return;
                state.answer = state.answer.filter(function (x) { return x !== idx; });
                clone.remove();
                b.style.display = ''; b.dataset.placed = '';
                checkBtnEnable();
              });
              rowAns.appendChild(clone);
            }
            checkBtnEnable();
          });
          rowBank.appendChild(b);
        });
        card.appendChild(rowAns);
        card.appendChild(rowBank);
      } else if (pType === 'speak_word') {
        // Mic-driven: speak the target phrase aloud; we transcribe via Web
        // Speech Recognition and grade by similarity against accepted answers.
        var spLang = (ex.payload && ex.payload.lang) || 'en-IN';
        var target = (ex.payload && ex.payload.target) || ex.prompt;
        var speakBtn = html('<button type="button" style="display:inline-flex;align-items:center;gap:8px;background:rgba(217,119,87,0.10);border:2px solid var(--rust);border-radius:14px;padding:14px 18px;font-family:inherit;font-size:14px;font-weight:700;color:var(--rust);cursor:pointer;margin-bottom:12px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>Hear the phrase</button>');
        speakBtn.addEventListener('click', function () { try { var u = new SpeechSynthesisUtterance(target); u.lang = spLang; u.rate = 0.85; window.speechSynthesis.speak(u); } catch (_) {} });
        card.appendChild(speakBtn);
        var phraseEl = html('<p style="font-family:Fraunces,serif;font-size:24px;text-align:center;margin:8px 0 14px;color:var(--rust);">' + esc(target) + '</p>');
        card.appendChild(phraseEl);
        var micBtn = html('<button type="button" style="display:inline-flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:18px;background:#ef4444;color:#fff;border:none;border-radius:14px;font-family:inherit;font-size:15px;font-weight:700;cursor:pointer;margin-bottom:10px;"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>Tap to speak</button>');
        var status = html('<p style="font-family:JetBrains Mono,monospace;font-size:11px;color:var(--ink-500);text-align:center;min-height:14px;margin-bottom:10px;"></p>');
        var heard = html('<input type="text" class="ti" readonly placeholder="What you said will appear here…" />');
        var SR = window.SpeechRecognition || window.webkitSpeechRecognition;
        micBtn.addEventListener('click', function () {
          if (!SR) { status.textContent = 'Browser does not support speech recognition. Use Chrome / Edge.'; return; }
          try {
            var rec = new SR(); rec.lang = spLang; rec.continuous = false; rec.interimResults = true;
            rec.onstart = function () { status.textContent = 'Listening…'; micBtn.style.background = '#dc2626'; };
            rec.onresult = function (e) { var s = ''; for (var i = e.resultIndex; i < e.results.length; i++) s += e.results[i][0].transcript; heard.value = s; state.answer = s; checkBtnEnable(); };
            rec.onend = function () { status.textContent = ''; micBtn.style.background = '#ef4444'; };
            rec.onerror = function (e) { status.textContent = 'Mic error: ' + e.error; micBtn.style.background = '#ef4444'; };
            rec.start();
          } catch (_) {}
        });
        card.appendChild(micBtn); card.appendChild(status); card.appendChild(heard);
        // also allow typing as fallback
        heard.removeAttribute('readonly');
        heard.addEventListener('input', function (e) { state.answer = e.target.value; checkBtnEnable(); });
      } else if (pType === 'listen_type') {
        // TTS-driven: speak the prompt + ask the learner to type what they heard.
        var langCode = (ex.payload && ex.payload.lang) || 'en-IN';
        var speakBtn = html('<button type="button" style="display:flex;align-items:center;gap:10px;background:rgba(217,119,87,0.10);border:2px solid var(--rust);border-radius:14px;padding:16px 20px;font-family:inherit;font-size:15px;font-weight:700;color:var(--rust);cursor:pointer;margin-bottom:14px;"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>Play again</button>');
        function speak() {
          try {
            if ('speechSynthesis' in window) {
              window.speechSynthesis.cancel();
              var u = new SpeechSynthesisUtterance((ex.payload && ex.payload.spoken) || ex.prompt);
              u.lang = langCode; u.rate = 0.85;
              window.speechSynthesis.speak(u);
            }
          } catch (_) {}
        }
        speakBtn.addEventListener('click', speak);
        card.appendChild(speakBtn);
        var ti = html('<input type="text" class="ti" autocomplete="off" autocorrect="off" spellcheck="false" placeholder="Type what you heard…" />');
        ti.addEventListener('input', function (e) { state.answer = e.target.value; checkBtnEnable(); });
        card.appendChild(ti);
        setTimeout(function () { ti.focus(); speak(); }, 100);
      } else if (pType === 'choose_meaning' || pType === 'choose_script' || pType === 'true_false') {
        var opts = (ex.payload && ex.payload.options) || [];
        opts.forEach(function (o, i) {
          var b = html('<button type="button" class="opt" data-i="' + i + '">' + esc(o) + '</button>');
          b.addEventListener('click', function () {
            if (state.answered) return;
            card.querySelectorAll('.opt').forEach(function (x) { x.classList.remove('selected'); });
            b.classList.add('selected');
            state.answer = i; checkBtnEnable();
          });
          card.appendChild(b);
        });
      } else if (pType === 'fill_blank') {
        var ti = html('<input type="text" class="ti" autocomplete="off" autocorrect="off" spellcheck="false" placeholder="Type your answer…" />');
        ti.addEventListener('input', function (e) { state.answer = e.target.value; checkBtnEnable(); });
        card.appendChild(ti);
        setTimeout(function () { ti.focus(); }, 50);
      } else if (pType === 'match_pairs') {
        var pairs = (ex.payload && ex.payload.pairs) || [];
        var lefts = pairs.map(function (p, i) { return { text: p[0], origIdx: i }; });
        var rightsArr = pairs.map(function (p, i) { return { text: p[1], origIdx: i }; });
        // shuffle rights deterministically per render
        rightsArr.sort(function () { return Math.random() - 0.5; });
        var matched = {};
        state.answer = {};
        var sel = { side: null, idx: null };
        var grid = html('<div class="pairs"></div>');
        lefts.forEach(function (L, i) {
          var b = html('<button type="button" class="pair-tile" data-side="L" data-i="' + L.origIdx + '">' + esc(L.text) + '</button>');
          b.addEventListener('click', function () { onTile(b, 'L', L.origIdx); });
          grid.appendChild(b);
          var rdat = rightsArr[i];
          var rb = html('<button type="button" class="pair-tile" data-side="R" data-i="' + rdat.origIdx + '">' + esc(rdat.text) + '</button>');
          rb.addEventListener('click', function () { onTile(rb, 'R', rdat.origIdx); });
          grid.appendChild(rb);
        });
        card.appendChild(grid);
        function onTile(el, side, idx) {
          if (matched[idx] || state.answered) return;
          if (sel.side === side) {
            // switch selection on same side
            card.querySelectorAll('.pair-tile.active').forEach(function (x) { x.classList.remove('active'); });
            el.classList.add('active');
            sel = { side: side, idx: idx, el: el };
            return;
          }
          if (!sel.side) {
            el.classList.add('active');
            sel = { side: side, idx: idx, el: el };
            return;
          }
          // two different sides; record the mapping; both sides correspond to same orig idx?
          var L = side === 'L' ? idx : sel.idx;
          var R = side === 'R' ? idx : sel.idx;
          state.answer[L] = R;
          matched[L] = true; matched[R] = true;
          // visually pair them green if origIdx matches (correct), red otherwise
          var isCorrect = L === R;
          el.classList.remove('active'); el.classList.add('matched');
          sel.el.classList.remove('active'); sel.el.classList.add('matched');
          el.disabled = true; sel.el.disabled = true;
          if (!isCorrect) { el.style.background = 'rgba(239,68,68,0.10)'; el.style.borderColor = '#ef4444'; el.style.color = '#991b1b'; sel.el.style.background = el.style.background; sel.el.style.borderColor = el.style.borderColor; sel.el.style.color = el.style.color; }
          sel = { side: null, idx: null };
          if (Object.keys(state.answer).length === lefts.length) checkBtnEnable();
        }
      }

      var btn = html('<button type="button" class="check-btn" disabled>Check</button>');
      btn.addEventListener('click', function () { onCheck(card, ex, btn); });
      card.appendChild(btn);

      root.innerHTML = '';
      root.appendChild(card);
    }

    function checkBtnEnable() {
      var btn = root.querySelector('.check-btn');
      if (!btn) return;
      var has = state.answer !== undefined && state.answer !== '' && !(typeof state.answer === 'object' && Object.keys(state.answer).length === 0);
      btn.disabled = !has || state.answered;
    }

    function onCheck(card, ex, btn) {
      if (state.answered) return advance();
      state.answered = true;
      btn.disabled = true; btn.textContent = 'Checking…';

      fetch('/api/aquintutor/learn/answer', { method:'POST', credentials:'same-origin', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ exerciseId: ex.id, answer: state.answer })})
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (!d.ok) { btn.disabled = false; btn.textContent = 'Check'; state.answered = false; return; }
          state.isRight = d.correct;
          var fb = document.createElement('div');
          fb.className = 'feedback ' + (d.correct ? 'ok' : 'bad');
          var modelLine = d.correct ? '' : ('<div style="margin-top:6px;"><b>Correct answer:</b> ' + esc(String(d.modelAnswer||'')) + '</div>');
          fb.innerHTML = '<b>' + (d.correct ? '✓ Correct' : '✗ Not quite') + '</b>' + (d.explanation ? esc(d.explanation) : '') + modelLine;
          card.insertBefore(fb, btn);
          if (d.correct) {
            state.correct++;
            state.totalXp += d.xpDelta || 0;
            xpPop.textContent = '+' + (d.xpDelta || 0) + ' XP';
            xpPop.classList.add('show');
            setTimeout(function () { xpPop.classList.remove('show'); }, 1200);
            btn.classList.add('right');
            card.querySelectorAll('.opt.selected').forEach(function (o) { o.classList.add('correct'); });
          } else {
            state.hearts -= 1;
            heartsEl.textContent = state.hearts;
            btn.classList.add('wrong');
            card.querySelectorAll('.opt.selected').forEach(function (o) { o.classList.add('wrong'); });
          }
          card.querySelectorAll('.opt, .ti, .pair-tile').forEach(function (o) { o.disabled = true; });
          btn.textContent = state.idx === state.exs.length - 1 ? 'Finish →' : 'Continue →';
          btn.disabled = false;
        });
    }

    function advance() {
      if (state.hearts <= 0) return summary();
      state.idx++;
      render();
    }

    function summary() {
      pfill.style.width = '100%';
      var pct = state.exs.length ? Math.round(state.correct / state.exs.length * 100) : 0;
      var perfect = state.correct === state.exs.length;
      var outOfHearts = state.hearts <= 0;
      // Notify backend to mark the lesson complete (issues cert at course end + bonus XP).
      if (!outOfHearts) {
        fetch('/api/aquintutor/lesson-complete', { method:'POST', credentials:'same-origin', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ courseId: '', lessonId: lessonId })}).catch(function(){});
      }
      var inner = '<div class="card summary">'
        + '<p style="font-family:Inter Tight,monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.14em;color:#d97757;font-weight:700;">' + (outOfHearts ? 'Out of hearts' : 'Lesson complete') + '</p>'
        + '<p class="big">' + state.correct + '/' + state.exs.length + '</p>'
        + '<p class="sub">' + (perfect ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-2px;margin-right:4px;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>Perfect run! ' : '') + '+' + state.totalXp + ' XP earned</p>'
        + '<div class="summary-actions">'
          + '<a class="primary" href="/aquintutor/courses/' + courseSlug + '">Course home →</a>'
          + (outOfHearts ? '<a class="secondary" href="/aquintutor/shop">Refill hearts</a>' : '<button class="secondary" onclick="window.location.reload()">Retry</button>')
          + '<a class="secondary" href="/aquintutor/dashboard">Dashboard</a>'
        + '</div>'
        + '</div>';
      root.innerHTML = inner;
    }
  })();
  </script>
</body>
</html>
