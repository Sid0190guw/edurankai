---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
const user = Astro.locals.user;

let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const name = (fd.get('name') as string || '').trim();
    const email = (fd.get('email') as string || '').trim();
    const target_level = fd.get('target_level') as string || 'masters';
    const target_countries = (fd.get('target_countries') as string || '').trim();
    const target_intake = (fd.get('target_intake') as string || '').trim();
    const target_field = (fd.get('target_field') as string || '').trim();
    const budget_inr = parseInt(fd.get('budget_inr') as string, 10) || 0;
    const profile_summary = (fd.get('profile_summary') as string || '').trim();
    if (!name || !email || profile_summary.length < 60) errMsg = 'Profile summary must be at least 60 characters.';
    else {
      const { db } = await import('@/lib/db');
      const { sql } = await import('drizzle-orm');
      await db.execute(sql`CREATE TABLE IF NOT EXISTS study_abroad_requests (
        id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
        user_id UUID, name VARCHAR(200), email VARCHAR(200),
        target_level VARCHAR(20), target_countries TEXT, target_intake VARCHAR(40), target_field VARCHAR(200),
        budget_inr INT, profile_summary TEXT, status VARCHAR(20) DEFAULT 'open', created_at TIMESTAMPTZ DEFAULT NOW())`);
      await db.execute(sql`INSERT INTO study_abroad_requests (user_id, name, email, target_level, target_countries, target_intake, target_field, budget_inr, profile_summary)
        VALUES (${user?.id || null}, ${name}, ${email}, ${target_level}, ${target_countries}, ${target_intake}, ${target_field}, ${budget_inr}, ${profile_summary})`);
      okMsg = 'Application received. An advisor will reach out within 3 business days with a curated programme shortlist.';
    }
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 240); }
}
---
<AquintutorLayout title="Study abroad · CareerFlow · AquinTutor" description="End-to-end study abroad support: shortlisting, applications, scholarships, visa, landing.">

<section class="px-[5vw] pt-12 md:pt-16 pb-6 max-w-3xl mx-auto">
  <a href="/aquintutor/careerflow" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← CareerFlow</a>
  <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2 mt-5">CareerFlow · Study abroad</p>
  <h1 class="font-display text-[clamp(2.2rem,5vw,3.6rem)] font-semibold text-ink leading-[1.05] mb-4">Study abroad, <em class="italic text-burn font-medium">end-to-end</em>.</h1>
  <p class="text-[1rem] text-ink-2 font-light leading-[1.85] max-w-2xl">Country shortlist. Programme shortlist. Application strategy. Letter of recommendation reviews. Scholarship matching. Visa interview prep. Post-arrival landing. We don't outsource any of it.</p>
</section>

<section class="px-[5vw] pb-10 max-w-3xl mx-auto">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
    <div class="bg-white border border-ink/10 rounded-xl p-4">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-burn font-bold mb-2">Shortlist</p>
      <p class="text-[0.85rem] text-ink-2">Programmes matched to your profile, budget, and goals — not search-engine rankings.</p>
    </div>
    <div class="bg-white border border-ink/10 rounded-xl p-4">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-burn font-bold mb-2">Apply</p>
      <p class="text-[0.85rem] text-ink-2">Essays, recommendations, video interviews, financial documents — all reviewed and refined.</p>
    </div>
    <div class="bg-white border border-ink/10 rounded-xl p-4">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-burn font-bold mb-2">Land</p>
      <p class="text-[0.85rem] text-ink-2">Visa, accommodation, banking, SIM, first-week orientation. Phone-a-friend in your destination city.</p>
    </div>
  </div>
</section>

<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  {okMsg && (<div class="bg-leaf-bg border border-leaf-border rounded-2xl px-5 py-5 mb-5"><p class="font-display text-[1.1rem] font-semibold text-leaf m-0">{okMsg}</p></div>)}
  {errMsg && <div class="bg-burn-pale border border-burn-dim rounded-xl px-4 py-3 mb-4 text-[0.88rem] text-burn font-semibold">{errMsg}</div>}

  {!okMsg && (
    <form method="POST" class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-burn font-bold m-0">Tell us about your goals</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Full name <span class="text-burn">*</span></label><input name="name" required maxlength="200" value={user?.name || ''} class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"/></div>
        <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Email <span class="text-burn">*</span></label><input name="email" type="email" required value={user?.email || ''} class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"/></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Target level</label><select name="target_level" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"><option value="bachelors">Bachelor's</option><option value="masters">Master's</option><option value="phd">PhD</option><option value="exchange">Exchange / semester</option></select></div>
        <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Target intake</label><input name="target_intake" maxlength="40" placeholder="e.g. Fall 2026" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"/></div>
        <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Budget (INR)</label><input name="budget_inr" type="number" min="0" max="100000000" placeholder="e.g. 4000000" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"/></div>
      </div>
      <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Target field</label><input name="target_field" maxlength="200" placeholder="e.g. AI, quantum, public policy" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"/></div>
      <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Target countries</label><input name="target_countries" maxlength="200" placeholder="e.g. US, UK, Germany, Switzerland, Singapore" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"/></div>
      <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Profile summary <span class="text-burn">*</span></label><textarea name="profile_summary" rows="5" minlength="60" maxlength="3000" required placeholder="Current education / work, key achievements, why this programme, financial situation" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] font-body resize-y"></textarea></div>
      <button type="submit" class="btn-primary">Send to advisor →</button>
      <p class="text-[0.78rem] text-ink-soft m-0">First consult is free. Programme + scholarship shortlist in 5 business days.</p>
    </form>
  )}
</section>
</AquintutorLayout>
