---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
---
<BaseLayout title="On-demand advisory · CareerFlow · EduRankAI" description="10-minute live consults with vetted advisors. Match in 5 min, pay per call, talk on Google Meet.">

<style>
  body { background: #FAF8F5; }
  .ad-hero { padding: 60px 5vw 40px; max-width: 980px; margin: 0 auto; }
  .ad-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin: 0; }
  .ad-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 5.5vw, 64px); font-weight: 600; letter-spacing: -0.025em; margin: 8px 0 10px; line-height: 1.05; }
  .ad-title em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .ad-sub { font-size: 16px; color: #2E2520; max-width: 660px; line-height: 1.65; }

  .ad-topics { padding: 0 5vw 30px; max-width: 980px; margin: 0 auto; }
  .ad-topics h2 { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin: 20px 0 12px; }
  .ad-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 8px; }
  .ad-topic { background: #fff; border: 1px solid rgba(14,11,8,0.10); padding: 14px 16px; border-radius: 12px; cursor: pointer; transition: all 0.15s; }
  .ad-topic:hover { border-color: #FF4F00; transform: translateY(-1px); }
  .ad-topic-title { font-weight: 700; font-size: 14px; color: #0E0B08; }
  .ad-topic-sub { font-size: 12px; color: #7A6F68; margin-top: 4px; }

  .ad-cta { padding: 30px 5vw 80px; max-width: 980px; margin: 0 auto; }
  .ad-call { background: linear-gradient(135deg, #FF4F00, #FF7040); color: #fff; padding: 32px; border-radius: 16px; }
  .ad-call h3 { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 600; margin: 0; letter-spacing: -0.02em; }
  .ad-call p { font-size: 15px; line-height: 1.65; margin: 10px 0 16px; opacity: 0.9; }
  .ad-call-btn { background: #fff; color: #FF4F00; padding: 12px 22px; border-radius: 10px; text-decoration: none; font-weight: 800; display: inline-block; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; }

  .ad-meta-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px; margin-top: 24px; }
  .ad-meta { background: rgba(255,255,255,0.15); padding: 12px 14px; border-radius: 10px; }
  .ad-meta-val { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; margin: 0; }
  .ad-meta-lbl { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.85; margin-top: 3px; }
</style>

<main>
  <section class="ad-hero">
    <a href="/aquintutor/careerflow" style="font-family:'Geist Mono',monospace;font-size:11px;color:#FF4F00;text-decoration:none;letter-spacing:0.08em;">← CareerFlow</a>
    <p class="ad-eyebrow" style="margin-top:18px;">CareerFlow · On-demand advisory</p>
    <h1 class="ad-title">Talk to an advisor <em>in 5 minutes</em>.</h1>
    <p class="ad-sub">Pick a topic. We match you with a vetted advisor. Pay per call. Talk on Google Meet. Walk away with a clear next step. Blinkit-fast career help.</p>
  </section>

  <section class="ad-topics">
    <h2>Pick a topic</h2>
    <div class="ad-grid">
      <a href="/portal/hr-support?topic=career-strategy" class="ad-topic"><p class="ad-topic-title">Career strategy</p><p class="ad-topic-sub">What's the right next move?</p></a>
      <a href="/portal/hr-support?topic=salary-negotiation" class="ad-topic"><p class="ad-topic-title">Salary negotiation</p><p class="ad-topic-sub">Counter-offer in hand. Now what?</p></a>
      <a href="/portal/hr-support?topic=interview-prep" class="ad-topic"><p class="ad-topic-title">Interview prep</p><p class="ad-topic-sub">Tomorrow's interview. Make it count.</p></a>
      <a href="/portal/hr-support?topic=resume-review" class="ad-topic"><p class="ad-topic-title">Résumé review</p><p class="ad-topic-sub">15-minute deep audit.</p></a>
      <a href="/portal/hr-support?topic=offer-evaluation" class="ad-topic"><p class="ad-topic-title">Offer evaluation</p><p class="ad-topic-sub">Two offers in hand. Which fits?</p></a>
      <a href="/portal/hr-support?topic=transition" class="ad-topic"><p class="ad-topic-title">Industry transition</p><p class="ad-topic-sub">Pivot to AI / quantum / climate.</p></a>
      <a href="/portal/hr-support?topic=academic-to-industry" class="ad-topic"><p class="ad-topic-title">Academia → industry</p><p class="ad-topic-sub">PhD/postdoc to industry research.</p></a>
      <a href="/portal/hr-support?topic=founder-coach" class="ad-topic"><p class="ad-topic-title">Founder coaching</p><p class="ad-topic-sub">Pre-seed / seed founders.</p></a>
      <a href="/portal/hr-support?topic=visa-help" class="ad-topic"><p class="ad-topic-title">Visa + relocation</p><p class="ad-topic-sub">Sponsorship, timelines, alternatives.</p></a>
    </div>
  </section>

  <section class="ad-cta">
    <div class="ad-call">
      <h3>Ready? Book a 10-minute slot.</h3>
      <p>Standard rate: 25 CHF for 10 minutes. Longer calls: 25 CHF per additional 10-minute block. Cancel free up to 1 hour before.</p>
      <a href="/portal/hr-support" class="ad-call-btn">Book now →</a>
      <div class="ad-meta-row">
        <div class="ad-meta"><p class="ad-meta-val">5 min</p><p class="ad-meta-lbl">Match SLA</p></div>
        <div class="ad-meta"><p class="ad-meta-val">10 min</p><p class="ad-meta-lbl">Standard call</p></div>
        <div class="ad-meta"><p class="ad-meta-val">25 CHF</p><p class="ad-meta-lbl">Per session</p></div>
        <div class="ad-meta"><p class="ad-meta-val">24/7</p><p class="ad-meta-lbl">Coverage</p></div>
      </div>
    </div>
  </section>
</main>
</BaseLayout>
