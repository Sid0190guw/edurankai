---
import BaseLayout from '@/layouts/BaseLayout.astro';
const SERVICES = [
  { slug: 'placement', label: 'Senior placement', sub: 'For 8+ year experienced', color: '#2b577e', icon: 'briefcase', summary: 'Job-discovery, profile audit, salary benchmarking, interview coaching, offer negotiation. Specifically tuned for senior engineers, executives, and academic faculty.' },
  { slug: 'study-abroad', label: 'Study abroad', sub: 'UG · PG · Doctoral', color: '#5b4a92', icon: 'globe', summary: 'Country + programme shortlisting, application strategy, recommendations, scholarship matching, visa interview prep, post-arrival landing support.' },
  { slug: 'network', label: 'Professional network', sub: 'Individuals · orgs · services', color: '#4a7048', icon: 'users', summary: 'Search and connect with verified individuals, organisations, and service providers. Profile-led, no algorithmic noise.' },
  { slug: 'advisory', label: 'On-demand advisory', sub: 'Blinkit-fast · live', color: '#a8472c', icon: 'zap', summary: '10-minute live consults with vetted advisors. Pick your topic, get matched in under 5 minutes, talk on Google Meet. Pay per call.' },
];
---
<BaseLayout title="CareerFlow · EduRankAI" description="Real-time career support: senior placement, study abroad, professional network, blinkit-fast advisory. One surface.">

<style>
  body { background: #FAF8F5; }
  .cf-hero { padding: 60px 5vw 40px; max-width: 1280px; margin: 0 auto; }
  .cf-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin: 0; }
  .cf-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 6vw, 72px); font-weight: 600; letter-spacing: -0.03em; margin: 8px 0 12px; line-height: 1; }
  .cf-title em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .cf-sub { font-size: 17px; color: #2E2520; max-width: 700px; line-height: 1.65; }

  .cf-strip { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px; margin: 32px 0 0; }
  .cf-stat { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 10px; padding: 14px 16px; }
  .cf-stat-val { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 600; color: #0E0B08; line-height: 1; letter-spacing: -0.02em; }
  .cf-stat-lbl { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: #7A6F68; margin-top: 5px; font-weight: 700; }

  .cf-grid { padding: 40px 5vw 80px; max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 16px; }
  .cf-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 16px; padding: 28px; text-decoration: none; color: inherit; transition: all 0.2s; display: block; }
  .cf-card:hover { transform: translateY(-2px); box-shadow: 0 14px 32px rgba(14,11,8,0.08); }
  .cf-card-icon { width: 52px; height: 52px; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: #fff; margin-bottom: 18px; }
  .cf-card-sub { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin: 0; }
  .cf-card-title { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 600; margin: 6px 0 10px; letter-spacing: -0.02em; line-height: 1.15; }
  .cf-card-summary { font-size: 14px; color: #2E2520; line-height: 1.65; }
  .cf-card-cta { display: inline-flex; align-items: center; gap: 6px; margin-top: 16px; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
</style>

<main>
  <section class="cf-hero">
    <p class="cf-eyebrow">AquinTutor · CareerFlow</p>
    <h1 class="cf-title">Career support, <em>blinkit-fast</em>.</h1>
    <p class="cf-sub">Real-time advisory, senior placement, study abroad, professional networking — in one surface. Built for people who actually need help now, not next month.</p>

    <div class="cf-strip">
      <div class="cf-stat"><p class="cf-stat-val">5 min</p><p class="cf-stat-lbl">Advisor match SLA</p></div>
      <div class="cf-stat"><p class="cf-stat-val">10 min</p><p class="cf-stat-lbl">Live consult length</p></div>
      <div class="cf-stat"><p class="cf-stat-val">24/7</p><p class="cf-stat-lbl">Advisory coverage</p></div>
      <div class="cf-stat"><p class="cf-stat-val">12</p><p class="cf-stat-lbl">Indic languages</p></div>
    </div>
  </section>

  <section class="cf-grid">
    {SERVICES.map((s) => (
      <a href={'/aquintutor/careerflow/' + s.slug} class="cf-card">
        <div class="cf-card-icon" style={'background:' + s.color + ';'}>
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            {s.icon === 'briefcase' && <><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></>}
            {s.icon === 'globe' && <><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></>}
            {s.icon === 'users' && <><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></>}
            {s.icon === 'zap' && <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>}
          </svg>
        </div>
        <p class="cf-card-sub">{s.sub}</p>
        <h2 class="cf-card-title">{s.label}</h2>
        <p class="cf-card-summary">{s.summary}</p>
        <span class="cf-card-cta">Open service →</span>
      </a>
    ))}
  </section>
</main>
</BaseLayout>
