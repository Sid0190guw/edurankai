---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ensureNetworkSchema, listProfiles } from '@/lib/network';

await ensureNetworkSchema();
const url = new URL(Astro.request.url);
const kind = url.searchParams.get('kind') || '';
const q = url.searchParams.get('q') || '';
const openTo = url.searchParams.get('open_to') || '';
const profiles = await listProfiles({ kind: kind || undefined, q: q || undefined, openTo: openTo || undefined });
---
<BaseLayout title="Network · CareerFlow · EduRankAI" description="Verified professional network — individuals, organisations, and services. Profile-led, no algorithmic noise.">

<style>
  body { background: #FAF8F5; }
  .n-wrap { max-width: 1280px; margin: 0 auto; padding: 24px 5vw 80px; }
  .n-head { padding: 16px 0 24px; border-bottom: 1px solid rgba(14,11,8,0.08); margin-bottom: 24px; }
  .n-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin: 0; }
  .n-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(32px, 4.5vw, 52px); font-weight: 600; letter-spacing: -0.025em; margin: 6px 0; line-height: 1.05; }
  .n-title em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .n-sub { font-size: 15px; color: #2E2520; max-width: 640px; line-height: 1.55; }

  .n-filters { display: flex; gap: 8px; flex-wrap: wrap; margin: 20px 0 28px; }
  .n-filters input, .n-filters select { background: #fff; border: 1px solid rgba(14,11,8,0.15); padding: 8px 14px; border-radius: 8px; font-family: inherit; font-size: 13px; }
  .n-filters button { background: #FF4F00; color: #fff; border: none; padding: 8px 18px; border-radius: 8px; font-weight: 700; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; }

  .n-tabs { display: flex; gap: 6px; margin-bottom: 18px; }
  .n-tab { background: #fff; border: 1px solid rgba(14,11,8,0.10); color: #2E2520; padding: 8px 16px; border-radius: 100px; text-decoration: none; font-size: 13px; font-weight: 600; }
  .n-tab.active { background: #FF4F00; color: #fff; border-color: #FF4F00; }

  .n-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 12px; }
  .n-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 18px; text-decoration: none; color: inherit; transition: all 0.2s; }
  .n-card:hover { transform: translateY(-1px); box-shadow: 0 10px 24px rgba(14,11,8,0.06); }
  .n-card-top { display: flex; gap: 10px; align-items: flex-start; }
  .n-avatar { width: 48px; height: 48px; border-radius: 50%; background: #FFF3EE; color: #FF4F00; display: flex; align-items: center; justify-content: center; font-family: 'Cormorant Garamond', serif; font-weight: 600; font-size: 22px; flex-shrink: 0; }
  .n-name { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; color: #0E0B08; line-height: 1.2; }
  .n-tagline { font-size: 12.5px; color: #7A6F68; margin-top: 2px; }
  .n-bio { font-size: 13px; color: #2E2520; line-height: 1.55; margin: 12px 0 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .n-chips { display: flex; gap: 4px; flex-wrap: wrap; margin-top: 10px; }
  .n-chip { font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.06em; padding: 2px 7px; border-radius: 100px; background: #F3EFE8; color: #2E2520; }
  .n-kind-chip { font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.08em; text-transform: uppercase; padding: 2px 8px; border-radius: 100px; font-weight: 700; }
  .n-kind-individual { background: #FFF3EE; color: #FF4F00; }
  .n-kind-organisation { background: #EBF0FF; color: #1045BB; }
  .n-kind-service { background: #EBF5EF; color: #1A6B35; }
  .n-verified { color: #1A6B35; font-size: 11px; font-weight: 700; margin-left: 6px; }
</style>

<main class="n-wrap">

  <div class="n-head">
    <p class="n-eyebrow">CareerFlow · Network</p>
    <h1 class="n-title">A network <em>that earns its place</em>.</h1>
    <p class="n-sub">Individuals, organisations, services. Profile-led. Verified-first. No feed algorithm — you find people by what they actually do.</p>
  </div>

  <div class="n-tabs">
    <a href="/aquintutor/careerflow/network" class={'n-tab' + (!kind ? ' active' : '')}>All</a>
    <a href="/aquintutor/careerflow/network?kind=individual" class={'n-tab' + (kind === 'individual' ? ' active' : '')}>Individuals</a>
    <a href="/aquintutor/careerflow/network?kind=organisation" class={'n-tab' + (kind === 'organisation' ? ' active' : '')}>Organisations</a>
    <a href="/aquintutor/careerflow/network?kind=service" class={'n-tab' + (kind === 'service' ? ' active' : '')}>Services</a>
  </div>

  <form method="GET" class="n-filters">
    {kind && <input type="hidden" name="kind" value={kind}/>}
    <input type="text" name="q" placeholder="Search by name, headline, bio..." value={q} style="flex:1;min-width:200px;"/>
    <select name="open_to">
      <option value="">Open to anything</option>
      <option value="placement" selected={openTo==='placement'}>Placement</option>
      <option value="mentoring" selected={openTo==='mentoring'}>Mentoring</option>
      <option value="consulting" selected={openTo==='consulting'}>Consulting</option>
      <option value="collaboration" selected={openTo==='collaboration'}>Collaboration</option>
      <option value="hiring" selected={openTo==='hiring'}>Hiring</option>
    </select>
    <button type="submit">Filter</button>
  </form>

  {profiles.length === 0 ? (
    <div style="background:rgba(255,79,0,0.06);border:1px solid rgba(255,79,0,0.2);border-radius:14px;padding:32px;text-align:center;">
      <p style="font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:600;margin:0 0 8px;">No profiles match yet.</p>
      <p style="font-size:14px;color:#7A6F68;margin:0 0 18px;">Be the first to publish a profile in this category.</p>
      <a href="/portal/profile?network=1" style="display:inline-block;background:#FF4F00;color:#fff;padding:10px 22px;border-radius:8px;text-decoration:none;font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.08em;text-transform:uppercase;font-weight:700;">Publish your profile →</a>
    </div>
  ) : (
    <div class="n-grid">
      {profiles.map((p: any) => (
        <a href={'/u/' + p.slug} class="n-card">
          <div class="n-card-top">
            <div class="n-avatar">{p.display_name?.charAt(0)?.toUpperCase() || '?'}</div>
            <div style="min-width:0;flex:1;">
              <p class="n-name">{p.display_name}{p.is_verified && <span class="n-verified">✓</span>}</p>
              {p.tagline && <p class="n-tagline">{p.tagline}</p>}
              <div style="margin-top:4px;display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
                <span class={'n-kind-chip n-kind-' + (p.kind || 'individual')}>{p.kind}</span>
                {p.seniority && <span class="n-chip">{p.seniority}</span>}
                {p.location && <span class="n-chip">{p.location}</span>}
              </div>
            </div>
          </div>
          {p.bio && <p class="n-bio">{p.bio}</p>}
          {Array.isArray(p.skills) && p.skills.length > 0 && (
            <div class="n-chips">{p.skills.slice(0, 5).map((s: string) => <span class="n-chip">{s}</span>)}</div>
          )}
        </a>
      ))}
    </div>
  )}
</main>
</BaseLayout>
