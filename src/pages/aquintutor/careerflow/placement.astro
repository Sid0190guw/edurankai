---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;

let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const name = (fd.get('name') as string || '').trim();
    const email = (fd.get('email') as string || '').trim();
    const years = parseInt(fd.get('years') as string, 10) || 0;
    const current_role = (fd.get('current_role') as string || '').trim();
    const target_role = (fd.get('target_role') as string || '').trim();
    const linkedin = (fd.get('linkedin') as string || '').trim();
    const cv_url = (fd.get('cv_url') as string || '').trim();
    if (!name || !email || years < 8) errMsg = 'Senior placement requires 8+ years of experience plus name + email.';
    else {
      const { db } = await import('@/lib/db');
      const { sql } = await import('drizzle-orm');
      await db.execute(sql`CREATE TABLE IF NOT EXISTS senior_placement_requests (
        id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
        user_id UUID, name VARCHAR(200), email VARCHAR(200), years_experience INT,
        current_role VARCHAR(300), target_role VARCHAR(300), linkedin_url TEXT, cv_url TEXT,
        status VARCHAR(20) NOT NULL DEFAULT 'open', created_at TIMESTAMPTZ DEFAULT NOW())`);
      await db.execute(sql`INSERT INTO senior_placement_requests (user_id, name, email, years_experience, current_role, target_role, linkedin_url, cv_url)
        VALUES (${user?.id || null}, ${name}, ${email}, ${years}, ${current_role}, ${target_role}, ${linkedin || null}, ${cv_url || null})`);
      okMsg = 'Request received. A senior placement strategist will reach out within 2 business days.';
    }
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 240); }
}
---
<BaseLayout title="Senior placement · CareerFlow · EduRankAI" description="White-glove placement service for engineers, executives, and academic faculty with 8+ years of experience.">

<section class="px-[5vw] pt-12 md:pt-16 pb-6 max-w-3xl mx-auto">
  <a href="/aquintutor/careerflow" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← CareerFlow</a>
  <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2 mt-5">CareerFlow · Senior placement</p>
  <h1 class="font-display text-[clamp(2.2rem,5vw,3.6rem)] font-semibold text-ink leading-[1.05] mb-4">For people with <em class="italic text-burn font-medium">eight or more years</em>.</h1>
  <p class="text-[1rem] text-ink-2 font-light leading-[1.85] max-w-2xl">White-glove placement for senior engineers, executives, and academic faculty. Discreet, fast, and outcome-oriented. We do not post your CV to job boards. We negotiate on your behalf.</p>
</section>

<section class="px-[5vw] pb-10 max-w-3xl mx-auto">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
    <div class="bg-white border border-ink/10 rounded-2xl p-5">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-burn font-bold mb-2">What you get</p>
      <ul class="space-y-1.5 text-[0.88rem] text-ink-2 m-0 pl-4 list-disc leading-relaxed">
        <li>Profile audit + repositioning</li>
        <li>Salary benchmarking across 8 markets</li>
        <li>Curated role list — only what fits</li>
        <li>Interview coaching with senior practitioners</li>
        <li>Compensation negotiation on your behalf</li>
        <li>Discretion. No public listing.</li>
      </ul>
    </div>
    <div class="bg-white border border-ink/10 rounded-2xl p-5">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-burn font-bold mb-2">Who we work with</p>
      <ul class="space-y-1.5 text-[0.88rem] text-ink-2 m-0 pl-4 list-disc leading-relaxed">
        <li>Senior engineers · staff and above</li>
        <li>Engineering managers · directors</li>
        <li>Executives · VP and C-suite</li>
        <li>Academic faculty seeking industry transition</li>
        <li>Founders between ventures</li>
      </ul>
    </div>
  </div>
</section>

<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  {okMsg && (
    <div class="bg-leaf-bg border border-leaf-border rounded-2xl px-5 py-5 mb-5">
      <p class="font-display text-[1.1rem] font-semibold text-leaf m-0">{okMsg}</p>
    </div>
  )}
  {errMsg && <div class="bg-burn-pale border border-burn-dim rounded-xl px-4 py-3 mb-4 text-[0.88rem] text-burn font-semibold">{errMsg}</div>}

  {!okMsg && (
    <form method="POST" class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-burn font-bold m-0">Request a confidential consult</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Full name <span class="text-burn">*</span></label><input name="name" required maxlength="200" value={user?.name || ''} class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"/></div>
        <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Email <span class="text-burn">*</span></label><input name="email" type="email" required maxlength="200" value={user?.email || ''} class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"/></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Years experience <span class="text-burn">*</span></label><input name="years" type="number" min="8" max="60" required class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"/></div>
        <div class="md:col-span-2"><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Current role + company</label><input name="current_role" maxlength="300" placeholder="e.g. Director of Engineering, [stealth]" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"/></div>
      </div>
      <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Target role / outcome</label><input name="target_role" maxlength="300" placeholder="e.g. VP Engineering at a Series B+ AI infra company" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"/></div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">LinkedIn URL</label><input name="linkedin" type="url" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"/></div>
        <div><label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">CV URL (Drive / public)</label><input name="cv_url" type="url" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"/></div>
      </div>
      <button type="submit" class="btn-primary">Request consult →</button>
      <p class="text-[0.78rem] text-ink-soft m-0">Reviewed within 2 business days. Discretion guaranteed.</p>
    </form>
  )}
</section>
</BaseLayout>
