---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { seedDeck, getDue, getStats, DECKS } from '@/lib/aquintutor-srs';
// Recall — the AquinTutor (undergraduate) signature: a spaced-repetition engine
// that decides WHAT to revise and WHEN. Genuine SM-2 (Anki-style) scheduling,
// server-persisted so the schedule follows the learner across devices. SSR seeds
// the deck and hands the due queue to the client, which grades each card and
// reschedules it via the API. No LLM.
const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/recall'));
const deckId = (Astro.url.searchParams.get('deck') || 'cs-core');
const validDeck = DECKS.some((d) => d.id === deckId) ? deckId : 'cs-core';
await seedDeck(user.id, validDeck);
const [due, stats] = await Promise.all([getDue(user.id, validDeck), getStats(user.id, validDeck)]);
const deckMeta = DECKS.find((d) => d.id === validDeck)!;
---
<AquintutorLayout title="Recall" description="A spaced-repetition engine that schedules exactly what to revise and when, using proven SM-2 scheduling — so nothing you learn quietly fades before your exam.">
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:760px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a><span style="margin:0 8px;">/</span><span style="color:var(--rust); font-weight:600;">RECALL</span>
    </div>
  </div>

  <section style="max-width:680px; margin:0 auto; padding:34px 24px 80px;">
    <p style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--rust); font-weight:700; margin:0 0 8px;">AquinTutor · Undergraduate</p>
    <h1 class="font-display" style="font-size:clamp(1.8rem,4vw,2.5rem); font-weight:500; margin:0 0 6px; color:var(--ink);">Revise what's fading — not everything.</h1>
    <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); line-height:1.6; margin:0 0 22px;">{deckMeta.blurb} This engine tracks how well you recall each fact and schedules it to come back right before you'd forget it. Rate your honest recall; it does the timing.</p>

    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom:20px;">
      <div style="flex:1; min-width:120px; background:#fff; border:1.5px solid var(--rule); border-radius:12px; padding:12px 14px;">
        <div style="font-family:'Fraunces',Georgia,serif; font-size:1.7rem; font-weight:600; color:var(--rust); line-height:1;" id="stDue">{stats.due}</div>
        <div style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:var(--ink-500); margin-top:2px;">Due now</div>
      </div>
      <div style="flex:1; min-width:120px; background:#fff; border:1.5px solid var(--rule); border-radius:12px; padding:12px 14px;">
        <div style="font-family:'Fraunces',Georgia,serif; font-size:1.7rem; font-weight:600; color:var(--ink); line-height:1;">{stats.total}</div>
        <div style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:var(--ink-500); margin-top:2px;">In this deck</div>
      </div>
      <div style="flex:1; min-width:120px; background:#fff; border:1.5px solid var(--rule); border-radius:12px; padding:12px 14px;">
        <div style="font-family:'Fraunces',Georgia,serif; font-size:1.7rem; font-weight:600; color:var(--ink); line-height:1;">{stats.learning}</div>
        <div style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:var(--ink-500); margin-top:2px;">New</div>
      </div>
    </div>

    <div id="rcCard"></div>
  </section>

  <style is:global>
    .rc-grade { border:none; border-radius:11px; cursor:pointer; font-family:'Inter Tight',sans-serif; font-weight:600; padding:11px 6px; display:flex; flex-direction:column; align-items:center; gap:2px; transition:transform .08s; }
    .rc-grade:active { transform:scale(0.95); }
    .rc-grade small { font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:400; opacity:0.85; }
  </style>

  <script is:inline define:vars={{ due, deckId: validDeck, nextDueAt: stats.nextDueAt }}>
  (function(){
    // Pure scheduler mirror of src/lib/aquintutor-srs.ts:schedule — for button previews.
    var EASE_DELTA={0:-0.20,3:-0.15,4:0,5:0.15};
    function schedule(ease,reps,interval,grade){
      var q=[0,3,4,5].indexOf(grade)>=0?grade:4; var e=ease+(EASE_DELTA[q]||0); if(e<1.3)e=1.3; if(e>3)e=3;
      if(q<3) return {ease:e,reps:0,interval:1};
      var base=reps===0?1:reps===1?6:Math.round(interval*ease); var iv=base;
      if(q===3) iv=Math.max(1,Math.round(base*0.6)); else if(q===5) iv=Math.round(base*1.4);
      return {ease:e,reps:reps+1,interval:Math.max(1,iv)};
    }
    function fmt(d){ if(d<=1) return '1d'; if(d<21) return d+'d'; if(d<60) return Math.round(d/7)+'w'; return Math.round(d/30)+'mo'; }
    function fmtLong(iso){ if(!iso) return null; var days=Math.round((new Date(iso)-Date.now())/86400000); if(days<=0) return 'today'; if(days===1) return 'tomorrow'; if(days<21) return 'in '+days+' days'; if(days<60) return 'in '+Math.round(days/7)+' weeks'; return 'in '+Math.round(days/30)+' months'; }

    var queue = (due||[]).slice(); // {id,front,back,ease,intervalDays,reps}
    var box=document.getElementById('rcCard'), stDue=document.getElementById('stDue');
    var reviewed=0;
    var GRADES=[
      {q:0,label:'Again',bg:'#f6e3e0',fg:'#b3271c'},
      {q:3,label:'Hard',bg:'#f4ecdd',fg:'#9a6a12'},
      {q:4,label:'Good',bg:'#e6f0ea',fg:'#1c7a45'},
      {q:5,label:'Easy',bg:'#e5edf6',fg:'#2f5fa0'},
    ];

    function render(){
      if(queue.length===0){ return done(); }
      var c=queue[0];
      box.innerHTML='<div style="background:#fff;border:1.5px solid var(--rule);border-radius:16px;padding:22px;min-height:150px;">'
        +'<div style="font-family:JetBrains Mono,monospace;font-size:10.5px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-500);margin-bottom:12px;">'+queue.length+' left today</div>'
        +'<p style="font-family:Inter Tight,sans-serif;font-size:19px;font-weight:600;color:var(--ink);line-height:1.5;margin:0;">'+esc(c.front)+'</p>'
        +'<div id="rcBack" style="display:none;margin-top:16px;padding-top:16px;border-top:1px solid var(--rule);"><p style="font-family:Inter Tight,sans-serif;font-size:16px;color:var(--ink);line-height:1.6;margin:0;">'+esc(c.back)+'</p></div>'
        +'</div>'
        +'<div id="rcActions" style="margin-top:14px;"></div>';
      var actions=document.getElementById('rcActions');
      actions.innerHTML='<button id="rcShow" style="width:100%;background:var(--ink);color:var(--sand-50);border:none;border-radius:12px;padding:13px;font-family:Inter Tight,sans-serif;font-size:16px;font-weight:600;cursor:pointer;">Show answer</button>';
      document.getElementById('rcShow').addEventListener('click', reveal);
    }
    function reveal(){
      var c=queue[0]; document.getElementById('rcBack').style.display='block';
      var actions=document.getElementById('rcActions');
      var html='<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;">';
      GRADES.forEach(function(g){ var s=schedule(c.ease,c.reps,c.intervalDays,g.q); html+='<button class="rc-grade" data-q="'+g.q+'" style="background:'+g.bg+';color:'+g.fg+';">'+g.label+'<small>'+fmt(s.interval)+'</small></button>'; });
      html+='</div>';
      actions.innerHTML=html;
      Array.prototype.forEach.call(actions.querySelectorAll('.rc-grade'), function(b){ b.addEventListener('click', function(){ grade(Number(b.getAttribute('data-q'))); }); });
    }
    function grade(q){
      var c=queue.shift();
      // optimistic advance; persist in background
      fetch('/api/aquintutor/srs',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'same-origin',body:JSON.stringify({action:'grade',cardId:c.id,grade:q})}).catch(function(){});
      if(q<3){ // relearn this session: re-queue near the end
        var again=Object.assign({},c); again.reps=0; again.intervalDays=1; queue.push(again);
      } else { reviewed++; }
      var remaining=queue.filter(function(x){return true;}).length;
      stDue.textContent=Math.max(0,remaining);
      render();
    }
    function done(){
      box.innerHTML='<div style="background:#eef3ee;border:1.5px solid #1c7a45;border-radius:16px;padding:24px;text-align:center;">'
        +'<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#1c7a45" stroke-width="2.5" style="margin-bottom:8px;"><path d="M20 6L9 17l-5-5"/></svg>'
        +'<h2 class="font-display" style="font-size:1.5rem;font-weight:600;color:var(--ink);margin:0 0 6px;">Caught up.</h2>'
        +'<p style="font-family:Inter Tight,sans-serif;font-size:14.5px;color:var(--ink-500);margin:0 0 6px;">You reviewed '+reviewed+' card'+(reviewed===1?'':'s')+'. Each one is now scheduled to return right before you\'d forget it.</p>'
        +'<p style="font-family:JetBrains Mono,monospace;font-size:12px;color:var(--rust);margin:0;">'+(nextReview())+'</p>'
        +'<a href="/aquintutor/recall" style="display:inline-block;margin-top:14px;background:var(--rust);color:#fff;text-decoration:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;padding:10px 22px;border-radius:10px;">Refresh</a></div>';
    }
    function nextReview(){ var t=fmtLong(nextDueAt); return t? ('Next cards due '+t+'.') : 'Come back tomorrow to keep the streak.'; }
    function esc(s){ return (s==null?'':String(s)).replace(/[&<>"]/g,function(m){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[m];}); }

    if(queue.length===0){ done(); } else { render(); }
  })();
  </script>
</AquintutorLayout>
