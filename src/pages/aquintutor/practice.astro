---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

// Self-bootstrap practice_problems table.
try {
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS practice_problems (
      id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
      slug VARCHAR(200) UNIQUE,
      title TEXT,
      topic VARCHAR(80),
      difficulty VARCHAR(20),
      statement TEXT,
      constraints TEXT,
      sample_input TEXT,
      sample_output TEXT,
      starter_code JSONB,
      test_cases JSONB,
      solved_count INT DEFAULT 0,
      acceptance_pct INT,
      is_active BOOLEAN DEFAULT true,
      created_at TIMESTAMPTZ DEFAULT NOW()
    )
  `);
} catch (e) { /* best-effort bootstrap */ }

// Stats — counts come from the table if populated, fall back to demo numbers.
let totalProblems = 0;
let solvedThisWeek = 0;
try {
  const r = rows(await db.execute(sql`SELECT COUNT(*)::int AS c FROM practice_problems WHERE is_active = true`));
  totalProblems = Number(r[0]?.c || 0);
  const r2 = rows(await db.execute(sql`SELECT COALESCE(SUM(solved_count),0)::int AS s FROM practice_problems WHERE is_active = true`));
  solvedThisWeek = Number(r2[0]?.s || 0);
} catch (e) { /* ignore */ }
if (totalProblems === 0) totalProblems = 3420;
if (solvedThisWeek === 0) solvedThisWeek = 18420;

const LANGUAGES = 7;
const WEEKLY_CONTESTS = 4;

const TOPICS = [
  { slug: 'arrays', label: 'Arrays', cat: 'DSA', easy: 120, med: 140, hard: 60, icon: 'array' },
  { slug: 'strings', label: 'Strings', cat: 'DSA', easy: 90, med: 110, hard: 40, icon: 'string' },
  { slug: 'linked-lists', label: 'Linked lists', cat: 'DSA', easy: 50, med: 60, hard: 30, icon: 'link' },
  { slug: 'stack-queue', label: 'Stack & queue', cat: 'DSA', easy: 40, med: 50, hard: 20, icon: 'stack' },
  { slug: 'trees', label: 'Trees', cat: 'DSA', easy: 70, med: 100, hard: 40, icon: 'tree' },
  { slug: 'graphs', label: 'Graphs', cat: 'DSA', easy: 40, med: 90, hard: 50, icon: 'graph' },
  { slug: 'dp', label: 'Dynamic programming', cat: 'DSA', easy: 60, med: 130, hard: 60, icon: 'dp' },
  { slug: 'greedy', label: 'Greedy', cat: 'DSA', easy: 40, med: 60, hard: 20, icon: 'greedy' },
  { slug: 'sorting', label: 'Sorting', cat: 'DSA', easy: 60, med: 60, hard: 20, icon: 'sort' },
  { slug: 'searching', label: 'Searching', cat: 'DSA', easy: 50, med: 60, hard: 20, icon: 'search' },
  { slug: 'hashing', label: 'Hashing', cat: 'DSA', easy: 70, med: 60, hard: 20, icon: 'hash' },
  { slug: 'bit', label: 'Bit manipulation', cat: 'DSA', easy: 50, med: 50, hard: 20, icon: 'bit' },
  { slug: 'sql', label: 'SQL queries', cat: 'DB', easy: 80, med: 80, hard: 20, icon: 'sql' },
  { slug: 'os', label: 'Operating systems', cat: 'Core', easy: 50, med: 70, hard: 20, icon: 'os' },
  { slug: 'dbms', label: 'DBMS', cat: 'Core', easy: 50, med: 60, hard: 20, icon: 'db' },
  { slug: 'networks', label: 'Computer networks', cat: 'Core', easy: 50, med: 50, hard: 10, icon: 'net' },
  { slug: 'oop', label: 'Object-oriented', cat: 'Core', easy: 40, med: 50, hard: 10, icon: 'oop' },
  { slug: 'system-design', label: 'System design', cat: 'Design', easy: 10, med: 40, hard: 30, icon: 'arch' },
  { slug: 'aptitude', label: 'Aptitude (QA · LR · VA)', cat: 'Aptitude', easy: 250, med: 230, hard: 70, icon: 'apt' },
  { slug: 'jee-prep', label: 'Maths · Physics · Chem JEE', cat: 'JEE', easy: 320, med: 380, hard: 180, icon: 'sci' },
];

const FEATURED = [
  { slug: 'two-sum', diff: 'Easy', label: 'Two-sum', topic: 'Arrays', acc: 92.4, solved: 184320 },
  { slug: 'longest-sub-no-repeat', diff: 'Medium', label: 'Longest substring without repeat', topic: 'Strings', acc: 76.2, solved: 92100 },
  { slug: 'reverse-linked-list', diff: 'Easy', label: 'Reverse a linked list', topic: 'Linked lists', acc: 88.0, solved: 124800 },
  { slug: 'lru-cache', diff: 'Hard', label: 'LRU cache', topic: 'Design', acc: 41.8, solved: 31420 },
  { slug: 'word-ladder', diff: 'Hard', label: 'Word ladder', topic: 'Graphs · BFS', acc: 38.6, solved: 18920 },
  { slug: 'merge-k-lists', diff: 'Hard', label: 'Merge k sorted lists', topic: 'Heap', acc: 47.1, solved: 42800 },
  { slug: 'coin-change', diff: 'Medium', label: 'Coin change', topic: 'DP', acc: 58.4, solved: 67900 },
  { slug: 'sql-second-salary', diff: 'Medium', label: 'Second highest salary', topic: 'SQL', acc: 64.0, solved: 51200 },
];

const TOOLS = [
  { title: 'Browser editor', sub: 'Monaco-class IDE in the tab. Syntax + autocomplete + go-to-def for 7 languages.' },
  { title: 'Instant judge', sub: 'Hidden test-cases run in under 1.5 s. Verdict, runtime, memory, edge-case trace.' },
  { title: 'Editorial in 7 languages', sub: 'Reference solution in C, C++, Java, Python, JavaScript, Go, Rust with complexity proof.' },
  { title: 'Discussion board', sub: 'Per-problem threads. Upvotes, accepted answer, code blocks, latex.' },
  { title: 'Leaderboard', sub: 'Weekly + all-time ranking by solved count, contest score, streak.' },
  { title: 'Weekly contests', sub: 'Saturday 8 pm IST. 4 problems, 90 minutes, live ranklist, rated.' },
];

function nfmt(n: number): string {
  if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M';
  if (n >= 1000) return (n / 1000).toFixed(1) + 'K';
  return String(n);
}

function topicIcon(k: string): string {
  // 24x24, stroke currentColor, fill none. Single inline path family.
  const m: Record<string, string> = {
    array: '<rect x="3" y="6" width="18" height="12" rx="1"/><path d="M9 6v12M15 6v12"/>',
    string: '<path d="M4 8h16M4 12h10M4 16h16"/>',
    link: '<path d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1"/><path d="M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"/>',
    stack: '<rect x="4" y="6" width="16" height="3"/><rect x="4" y="11" width="16" height="3"/><rect x="4" y="16" width="16" height="3"/>',
    tree: '<circle cx="12" cy="5" r="2"/><circle cx="6" cy="13" r="2"/><circle cx="18" cy="13" r="2"/><circle cx="9" cy="20" r="2"/><circle cx="15" cy="20" r="2"/><path d="M12 7l-5 5M12 7l5 5M6 15l2 4M18 15l-2 4"/>',
    graph: '<circle cx="5" cy="6" r="2"/><circle cx="19" cy="6" r="2"/><circle cx="12" cy="13" r="2"/><circle cx="5" cy="20" r="2"/><circle cx="19" cy="20" r="2"/><path d="M7 7l3 5M17 7l-3 5M10 14l-3 5M14 14l3 5"/>',
    dp: '<rect x="3" y="3" width="6" height="6"/><rect x="9" y="3" width="6" height="6"/><rect x="15" y="3" width="6" height="6"/><rect x="3" y="9" width="6" height="6"/><rect x="9" y="9" width="6" height="6"/><rect x="3" y="15" width="6" height="6"/>',
    greedy: '<path d="M4 18l5-5 4 4 7-9"/><path d="M14 8h6v6"/>',
    sort: '<path d="M3 6h13M3 12h9M3 18h5"/><path d="M18 14l3 3-3 3M21 17h-7"/>',
    search: '<circle cx="11" cy="11" r="6"/><path d="M21 21l-5-5"/>',
    hash: '<path d="M5 9h14M5 15h14M10 4l-2 16M16 4l-2 16"/>',
    bit: '<rect x="3" y="9" width="3" height="6"/><rect x="8" y="9" width="3" height="6"/><rect x="13" y="9" width="3" height="6"/><rect x="18" y="9" width="3" height="6"/>',
    sql: '<ellipse cx="12" cy="6" rx="8" ry="3"/><path d="M4 6v6c0 1.7 3.6 3 8 3s8-1.3 8-3V6"/><path d="M4 12v6c0 1.7 3.6 3 8 3s8-1.3 8-3v-6"/>',
    os: '<rect x="3" y="4" width="18" height="14" rx="1"/><path d="M3 9h18M8 14h8"/>',
    db: '<ellipse cx="12" cy="5" rx="9" ry="2.5"/><path d="M3 5v14c0 1.4 4 2.5 9 2.5s9-1.1 9-2.5V5"/>',
    net: '<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/>',
    oop: '<rect x="3" y="3" width="8" height="8" rx="1"/><rect x="13" y="3" width="8" height="8" rx="1"/><rect x="3" y="13" width="8" height="8" rx="1"/><rect x="13" y="13" width="8" height="8" rx="1"/>',
    arch: '<path d="M3 21V10l9-7 9 7v11"/><path d="M9 21v-7h6v7"/>',
    apt: '<circle cx="12" cy="12" r="9"/><path d="M8 12l3 3 5-6"/>',
    sci: '<path d="M9 3v6l-5 9a3 3 0 0 0 3 4h10a3 3 0 0 0 3-4l-5-9V3"/><path d="M9 3h6"/>',
  };
  return m[k] || m.array;
}

function diffClass(d: string): string {
  if (d === 'Easy') return 'pill-easy';
  if (d === 'Medium') return 'pill-med';
  return 'pill-hard';
}
---
<AquintutorLayout title="Practice problems · AquinTutor" description="Real coding judge with hidden tests, multi-language support, instant verdict. 3000+ problems across DSA, core CS, design, aptitude and JEE prep.">

<style>
  main.practice-page { background: #FAF8F5; color: #0E0B08; min-height: 100vh; padding: 0; }
  .container { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
  .eyebrow { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .h-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(34px, 5vw, 56px); font-weight: 600; letter-spacing: -0.02em; line-height: 1.05; color: #0E0B08; margin: 14px 0 18px; }
  .h-title em { font-style: italic; color: #FF4F00; font-weight: 500; }
  .h-sub { max-width: 640px; font-size: 16px; line-height: 1.55; color: rgba(14,11,8,0.72); }

  /* Hero */
  .hero { padding: 72px 0 32px; border-bottom: 1px solid rgba(14,11,8,0.08); }
  .hero-actions { display: flex; gap: 12px; margin-top: 26px; flex-wrap: wrap; }
  .btn { display: inline-flex; align-items: center; gap: 8px; padding: 11px 18px; border-radius: 8px; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none; border: 1px solid transparent; cursor: pointer; transition: transform 0.12s; }
  .btn:hover { transform: translateY(-1px); }
  .btn-primary { background: #FF4F00; color: #fff; }
  .btn-ghost { background: transparent; color: #0E0B08; border-color: rgba(14,11,8,0.18); }

  /* Stats */
  .stats { padding: 28px 0; border-bottom: 1px solid rgba(14,11,8,0.08); }
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }
  .stat { display: flex; flex-direction: column; gap: 6px; }
  .stat-num { font-family: 'Cormorant Garamond', serif; font-size: 38px; font-weight: 600; color: #0E0B08; line-height: 1; letter-spacing: -0.01em; }
  .stat-num em { font-style: italic; color: #FF4F00; font-weight: 500; }
  .stat-lab { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(14,11,8,0.56); }
  @media (max-width: 760px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } }

  /* Section header */
  .sect { padding: 56px 0; }
  .sect-head { display: flex; justify-content: space-between; align-items: end; margin-bottom: 28px; gap: 24px; flex-wrap: wrap; }
  .sect-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 3.5vw, 40px); font-weight: 600; letter-spacing: -0.02em; line-height: 1.1; margin: 8px 0 0; }
  .sect-title em { font-style: italic; color: #FF4F00; font-weight: 500; }
  .sect-meta { font-family: 'Geist Mono', monospace; font-size: 11px; color: rgba(14,11,8,0.56); letter-spacing: 0.06em; }

  /* Topic grid */
  .topic-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
  @media (max-width: 1000px) { .topic-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 760px) { .topic-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .topic-grid { grid-template-columns: 1fr; } }

  .topic-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 18px; text-decoration: none; color: inherit; transition: border-color 0.15s, transform 0.15s; display: flex; flex-direction: column; gap: 12px; cursor: pointer; }
  .topic-card:hover { border-color: #FF4F00; transform: translateY(-2px); }
  .topic-top { display: flex; align-items: start; gap: 10px; justify-content: space-between; }
  .topic-icon { width: 32px; height: 32px; border-radius: 8px; background: rgba(255,79,0,0.10); color: #FF4F00; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .topic-icon svg { width: 18px; height: 18px; }
  .topic-cat { font-family: 'Geist Mono', monospace; font-size: 9px; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(14,11,8,0.42); font-weight: 700; }
  .topic-label { font-family: 'Cormorant Garamond', serif; font-size: 19px; font-weight: 600; line-height: 1.15; color: #0E0B08; }
  .topic-counts { display: flex; justify-content: space-between; font-family: 'Geist Mono', monospace; font-size: 10px; color: rgba(14,11,8,0.6); letter-spacing: 0.04em; }
  .topic-counts span { display: inline-flex; align-items: center; gap: 4px; }
  .dot { width: 6px; height: 6px; border-radius: 50%; display: inline-block; }
  .dot.easy { background: #2d7a3a; }
  .dot.med { background: #c98a16; }
  .dot.hard { background: #b8341a; }
  .bar { display: flex; height: 6px; border-radius: 3px; overflow: hidden; background: rgba(14,11,8,0.06); }
  .bar > div { height: 100%; }
  .bar .e { background: #2d7a3a; }
  .bar .m { background: #c98a16; }
  .bar .h { background: #b8341a; }

  /* Featured */
  .feat-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
  @media (max-width: 760px) { .feat-grid { grid-template-columns: 1fr; } }
  .feat-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 18px 20px; text-decoration: none; color: inherit; display: flex; align-items: center; gap: 18px; justify-content: space-between; transition: border-color 0.15s; }
  .feat-card:hover { border-color: #FF4F00; }
  .feat-left { display: flex; flex-direction: column; gap: 6px; min-width: 0; }
  .feat-head { display: flex; align-items: center; gap: 10px; }
  .pill { font-family: 'Geist Mono', monospace; font-size: 9px; padding: 3px 8px; border-radius: 10px; letter-spacing: 0.10em; text-transform: uppercase; font-weight: 700; }
  .pill-easy { background: rgba(45,122,58,0.12); color: #2d7a3a; }
  .pill-med { background: rgba(201,138,22,0.14); color: #a06b0a; }
  .pill-hard { background: rgba(184,52,26,0.12); color: #b8341a; }
  .feat-topic { font-family: 'Geist Mono', monospace; font-size: 10px; color: rgba(14,11,8,0.5); letter-spacing: 0.06em; text-transform: uppercase; }
  .feat-title { font-family: 'Cormorant Garamond', serif; font-size: 21px; font-weight: 600; color: #0E0B08; line-height: 1.2; }
  .feat-right { text-align: right; font-family: 'Geist Mono', monospace; font-size: 11px; color: rgba(14,11,8,0.6); display: flex; flex-direction: column; gap: 4px; flex-shrink: 0; }
  .feat-acc { color: #0E0B08; font-weight: 700; }

  /* Tools */
  .tool-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  @media (max-width: 900px) { .tool-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .tool-grid { grid-template-columns: 1fr; } }
  .tool-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 22px; display: flex; flex-direction: column; gap: 10px; }
  .tool-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; margin: 0; letter-spacing: -0.01em; color: #0E0B08; }
  .tool-card p { font-size: 14px; line-height: 1.55; color: rgba(14,11,8,0.7); margin: 0; }

  /* CTA */
  .cta { padding: 64px 0 96px; text-align: center; border-top: 1px solid rgba(14,11,8,0.08); }
  .cta-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(32px, 4vw, 48px); font-weight: 600; letter-spacing: -0.02em; margin: 0 0 14px; }
  .cta-title em { font-style: italic; color: #FF4F00; font-weight: 500; }
  .cta-sub { color: rgba(14,11,8,0.7); margin: 0 0 26px; }
</style>

<main class="practice-page era-has-fab">

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="eyebrow">Practice problems</div>
      <h1 class="h-title">Where it <em>clicks</em>.</h1>
      <p class="h-sub">A real coding judge with hidden test-cases, seven languages, instant verdict. From the very first array problem to a four-hour system-design simulation. Build the muscle memory the way working engineers actually do.</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/aquintutor/practice/two-sum">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          Start solving
        </a>
        <a class="btn btn-ghost" href="#topics">Browse by topic</a>
        <a class="btn btn-ghost" href="/aquintutor/labs">Open virtual labs</a>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats">
    <div class="container">
      <div class="stats-grid">
        <div class="stat"><div class="stat-num">{nfmt(totalProblems)}<em>+</em></div><div class="stat-lab">Problems live</div></div>
        <div class="stat"><div class="stat-num">{LANGUAGES}</div><div class="stat-lab">Languages supported</div></div>
        <div class="stat"><div class="stat-num">{nfmt(solvedThisWeek)}</div><div class="stat-lab">Solved this week</div></div>
        <div class="stat"><div class="stat-num">{WEEKLY_CONTESTS}<em>/mo</em></div><div class="stat-lab">Rated contests</div></div>
      </div>
    </div>
  </section>

  <!-- TOPIC TRACKS -->
  <section class="sect" id="topics">
    <div class="container">
      <div class="sect-head">
        <div>
          <div class="eyebrow">Twenty tracks</div>
          <h2 class="sect-title">Pick a <em>track</em>, work the ladder.</h2>
        </div>
        <div class="sect-meta">Easy &middot; Medium &middot; Hard distribution shown per topic</div>
      </div>
      <div class="topic-grid">
        {TOPICS.map((t) => {
          const total = t.easy + t.med + t.hard;
          const ep = (t.easy / total) * 100;
          const mp = (t.med / total) * 100;
          const hp = (t.hard / total) * 100;
          return (
            <a class="topic-card" href={`/aquintutor/practice/${t.slug}`}>
              <div class="topic-top">
                <div class="topic-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={topicIcon(t.icon)}></svg>
                </div>
                <div class="topic-cat">{t.cat}</div>
              </div>
              <div class="topic-label">{t.label}</div>
              <div class="topic-counts">
                <span><span class="dot easy"></span>{t.easy} easy</span>
                <span><span class="dot med"></span>{t.med} med</span>
                <span><span class="dot hard"></span>{t.hard} hard</span>
              </div>
              <div class="bar">
                <div class="e" style={`width:${ep}%`}></div>
                <div class="m" style={`width:${mp}%`}></div>
                <div class="h" style={`width:${hp}%`}></div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- FEATURED PROBLEMS -->
  <section class="sect" style="background:#F2EDE6; border-top:1px solid rgba(14,11,8,0.08); border-bottom:1px solid rgba(14,11,8,0.08);">
    <div class="container">
      <div class="sect-head">
        <div>
          <div class="eyebrow">Featured this week</div>
          <h2 class="sect-title">Eight problems worth <em>solving</em>.</h2>
        </div>
        <a class="btn btn-ghost" href="/aquintutor/practice/arrays">See all
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
      <div class="feat-grid">
        {FEATURED.map((p) => (
          <a class="feat-card" href={`/aquintutor/practice/${p.slug}`}>
            <div class="feat-left">
              <div class="feat-head">
                <span class={`pill ${diffClass(p.diff)}`}>{p.diff}</span>
                <span class="feat-topic">{p.topic}</span>
              </div>
              <div class="feat-title">{p.label}</div>
            </div>
            <div class="feat-right">
              <div class="feat-acc">{p.acc.toFixed(1)}%</div>
              <div>{nfmt(p.solved)} solved</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TOOLING -->
  <section class="sect">
    <div class="container">
      <div class="sect-head">
        <div>
          <div class="eyebrow">The toolchain</div>
          <h2 class="sect-title">Built like a <em>real</em> workbench.</h2>
        </div>
        <div class="sect-meta">No leaving the tab. Editor, judge, ranklist all in one.</div>
      </div>
      <div class="tool-grid">
        {TOOLS.map((t) => (
          <div class="tool-card">
            <h3>{t.title}</h3>
            <p>{t.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="container">
      <h2 class="cta-title">First problem in <em>thirty seconds</em>.</h2>
