---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/dashboard'));

let enrollments: any[] = [];
let recentAttempts: any[] = [];
let upcomingTests: any[] = [];
let myCertificates: any[] = [];
let liveAttempt: any = null;

try {
  const r = await db.execute(sql`
    SELECT e.id, e.progress_pct, e.last_lesson_id, e.enrolled_at,
      c.slug, c.title, c.subtitle, c.short_desc, c.course_code, c.duration_weeks,
      c.credit_hours, c.level, c.is_free, c.pricing_model,
      s.name as school_name, s.slug as school_slug,
      d.name as department_name,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as total_lessons
    FROM training_enrollments e
    LEFT JOIN training_courses c ON e.course_id = c.id
    LEFT JOIN schools s ON c.school_id = s.id
    LEFT JOIN academic_departments d ON c.department_id = d.id
    WHERE e.user_id = ${user.id}
    ORDER BY e.enrolled_at DESC LIMIT 24
  `);
  enrollments = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT a.id, a.percentage, a.status, a.started_at, a.submitted_at, a.total_score, a.max_score,
      t.slug as test_slug, t.title as test_title, t.test_type, t.duration_mins
    FROM test_attempts a
    LEFT JOIN tests t ON a.test_id = t.id
    WHERE a.candidate_id = ${user.id}
    ORDER BY a.started_at DESC NULLS LAST LIMIT 10
  `);
  recentAttempts = Array.isArray(r) ? r : (r?.rows || []);
  liveAttempt = recentAttempts.find((a: any) => a.status === 'in_progress') || null;
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT t.slug, t.title, t.test_type, t.duration_mins, t.is_premium, t.currency, t.price_inr_paise,
      (SELECT COUNT(*)::int FROM test_questions WHERE test_id = t.id) as question_count
    FROM tests t
    WHERE t.is_published = true
      AND NOT EXISTS (SELECT 1 FROM test_attempts WHERE test_id = t.id AND candidate_id = ${user.id} AND status IN ('submitted','auto_submitted'))
    ORDER BY t.created_at DESC LIMIT 4
  `);
  upcomingTests = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT certificate_number as credential_number,
      (SELECT title FROM training_courses WHERE id = c.course_id) as course_title,
      c.issued_at
    FROM training_certificates c
    WHERE c.user_id = ${user.id}
    ORDER BY c.issued_at DESC LIMIT 4
  `);
  myCertificates = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const firstName = (user.name || '').split(' ')[0] || 'student';
const hour = new Date().getHours();
const greeting = hour < 5 ? 'Good evening' : hour < 12 ? 'Good morning' : hour < 17 ? 'Good afternoon' : 'Good evening';

function ago(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins + 'm ago';
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return hrs + 'h ago';
  const days = Math.floor(hrs / 24);
  if (days < 7) return days + 'd ago';
  return new Date(d).toLocaleDateString('en-IN', { day: '2-digit', month: 'short' });
}
function priceLabel(t: any) {
  if (!t.is_premium) return 'Included';
  const cur = (t.currency || 'INR').toUpperCase();
  const major = Math.max(1, Math.round((t.price_inr_paise || 0) / 100));
  return cur + ' ' + major;
}
---
<AquintutorLayout title="Dashboard" description="Your AquinTutor dashboard - enrolled courses, recent attempts, credentials.">

  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1200px; margin:0 auto; padding:64px 28px 40px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); font-weight:600; letter-spacing:0.04em; margin:0 0 14px;">Your register &middot; {new Date().toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })}</p>
      <h1 class="font-display" style="font-size:clamp(2rem, 4.5vw, 3.5rem); line-height:1.08; letter-spacing:-0.02em; font-weight:500; margin:0; color:var(--ink);">{greeting}, {firstName}.</h1>
      <p style="font-family:'Inter Tight',sans-serif; font-size:clamp(1rem, 1.3vw, 1.15rem); line-height:1.6; color:var(--ink-500); margin:18px 0 0; max-width:42rem;">
        {enrollments.length > 0
          ? <>You are enrolled in {enrollments.length} {enrollments.length === 1 ? 'course' : 'courses'}. Pick up where you left off, sit a proctored examination, or browse the catalogue for what to take next.</>
          : <>Your enrolment is active. Open the catalogue below and pick the first course of your term.</>}
      </p>

      {liveAttempt && (
        <div style="margin-top:26px; background:var(--ink); color:var(--sand-50); border-radius:12px; padding:18px 22px; display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap;">
          <div>
            <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:rgba(251,250,244,0.65); margin:0 0 6px; font-weight:600;">Examination in progress</p>
            <p style="font-family:'Inter Tight',sans-serif; font-size:17px; font-weight:600; margin:0;">{liveAttempt.test_title}</p>
            <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:rgba(251,250,244,0.7); margin:3px 0 0;">Started {ago(liveAttempt.started_at)} &mdash; your seat is held; finish before the timer expires.</p>
          </div>
          <a href={'/aquintutor/test/' + liveAttempt.test_slug + '/run?resume=1'} style="background:var(--sand-50); color:var(--ink); padding:11px 20px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13.5px; font-weight:600; text-decoration:none;">Resume examination &rarr;</a>
        </div>
      )}
    </div>
  </section>

  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1200px; margin:0 auto; padding:48px 28px;">
      <div style="display:flex; justify-content:space-between; align-items:baseline; flex-wrap:wrap; gap:12px; margin-bottom:24px;">
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 8px;">Your courses</p>
          <h2 class="font-display" style="font-size:clamp(1.5rem, 2.5vw, 2rem); font-weight:500; margin:0; line-height:1.15; letter-spacing:-0.015em; color:var(--ink);">Active enrolments</h2>
        </div>
        <a href="/aquintutor/courses" style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--rust); text-decoration:none; font-weight:500;">Browse the catalogue &rarr;</a>
      </div>

      {enrollments.length === 0 ? (
        <div style="background:var(--paper); border:1px dashed var(--rule); border-radius:12px; padding:40px; text-align:center;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:15.5px; color:var(--ink-500); margin:0 0 18px;">You have not enrolled in any courses yet.</p>
          <a href="/aquintutor/courses" style="background:var(--ink); color:var(--sand-50); padding:12px 22px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none; display:inline-block;">Browse the catalogue &rarr;</a>
        </div>
      ) : (
        <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="cards-grid">
          {enrollments.map((c: any) => (
            <a href={'/aquintutor/courses/' + c.slug} style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:22px; text-decoration:none; color:var(--ink); display:flex; flex-direction:column; gap:14px;">
              <div style="display:flex; justify-content:space-between; gap:10px; font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink-500); font-weight:600;">
                <span>{c.course_code || (c.level || 'GEN').toUpperCase()}</span>
                <span>{c.progress_pct || 0}% complete</span>
              </div>
              <h3 class="font-display" style="font-size:1.25rem; margin:0; line-height:1.2; letter-spacing:-0.015em; font-weight:500; color:var(--ink);">{c.title}</h3>
              {c.subtitle && <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); margin:0; line-height:1.45;">{c.subtitle}</p>}
              <div style="margin-top:auto; padding-top:12px; border-top:1px solid var(--rule); display:flex; justify-content:space-between; gap:6px; font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink-500);">
                <span>{c.school_name ? c.school_name.replace('School of ', '') : 'Foundations'}</span>
                <span>{c.total_lessons || 0} lessons</span>
              </div>
              <div style="height:3px; background:var(--rule); border-radius:2px; overflow:hidden;">
                <div style={'width:' + Math.min(100, c.progress_pct || 0) + '%; height:100%; background:var(--rust);'}></div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  {recentAttempts.length > 0 && (
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:1200px; margin:0 auto; padding:48px 28px;">
        <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 8px;">Assessments</p>
        <h2 class="font-display" style="font-size:clamp(1.5rem, 2.5vw, 2rem); font-weight:500; margin:0 0 22px; line-height:1.15; letter-spacing:-0.015em; color:var(--ink);">Recent examinations</h2>

        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; overflow:hidden;">
          {recentAttempts.map((a: any, i: number) => (
            <a href={a.status === 'in_progress' ? ('/aquintutor/test/' + a.test_slug + '/run?resume=1') : ('/aquintutor/test/' + a.test_slug + '/result?attempt=' + a.id)} style={'display:flex; align-items:center; justify-content:space-between; gap:14px; padding:16px 22px; text-decoration:none; color:var(--ink); flex-wrap:wrap; ' + (i < recentAttempts.length - 1 ? 'border-bottom:1px solid var(--rule);' : '')}>
              <div style="min-width:0; flex:1;">
                <p style="font-family:'Inter Tight',sans-serif; font-size:15px; font-weight:600; margin:0; line-height:1.3;">{a.test_title}</p>
                <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink-500); margin:3px 0 0; letter-spacing:0.02em;">{(a.test_type || 'EXAM').toUpperCase()} &middot; {ago(a.started_at)} &middot; {a.status}</p>
              </div>
              <div style="display:flex; align-items:baseline; gap:14px;">
                <span class="font-display" style="font-size:1.4rem; color:var(--rust); font-variant-numeric:tabular-nums; letter-spacing:-0.015em; font-weight:500;">{a.percentage != null ? Math.round(a.percentage) + '%' : '-'}</span>
                <span style="font-family:'Inter Tight',sans-serif; color:var(--ink-500); font-size:14px;">&rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {upcomingTests.length > 0 && (
    <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
      <div style="max-width:1200px; margin:0 auto; padding:48px 28px;">
        <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 8px;">To sit</p>
        <h2 class="font-display" style="font-size:clamp(1.5rem, 2.5vw, 2rem); font-weight:500; margin:0 0 22px; line-height:1.15; letter-spacing:-0.015em; color:var(--ink);">Examinations you have not sat</h2>

        <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="cards-grid">
          {upcomingTests.map((t: any) => (
            <a href={'/aquintutor/test/' + t.slug} style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:22px; text-decoration:none; color:var(--ink); display:flex; flex-direction:column; gap:12px;">
              <div style="display:flex; justify-content:space-between; gap:6px; font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink-500); font-weight:600;">
                <span>{(t.test_type || 'EXAM').toUpperCase()}</span>
                <span style="color:var(--rust);">{priceLabel(t)}</span>
              </div>
              <h3 class="font-display" style="font-size:1.2rem; margin:0; line-height:1.2; letter-spacing:-0.015em; font-weight:500;">{t.title}</h3>
              <div style="margin-top:auto; padding-top:12px; border-top:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink-500);">
                {t.duration_mins > 0 ? t.duration_mins + ' min' : ''}
                {t.question_count > 0 ? ' &middot; ' + t.question_count + ' questions' : ''}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {myCertificates.length > 0 && (
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:1200px; margin:0 auto; padding:48px 28px;">
        <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 8px;">Credentials</p>
        <h2 class="font-display" style="font-size:clamp(1.5rem, 2.5vw, 2rem); font-weight:500; margin:0 0 22px; line-height:1.15; letter-spacing:-0.015em; color:var(--ink);">Verifiable credentials</h2>

        <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="cards-grid">
          {myCertificates.map((cert: any) => (
            <a href={'/credentials/' + cert.credential_number} style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:22px; text-decoration:none; color:var(--ink); display:flex; flex-direction:column; gap:12px;">
              <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--rust); font-weight:600; margin:0;">Certificate of completion</p>
              <h3 class="font-display" style="font-size:1.15rem; margin:0; line-height:1.2; letter-spacing:-0.015em; font-weight:500;">{cert.course_title}</h3>
              <div style="margin-top:auto; padding-top:12px; border-top:1px solid var(--rule); display:flex; justify-content:space-between; font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--ink-500);">
                <span style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap; max-width:60%;">{cert.credential_number}</span>
                <span>{ago(cert.issued_at)}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section>
    <div style="max-width:1200px; margin:0 auto; padding:48px 28px 80px;">
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <a href="/aquintutor/courses" style="background:var(--ink); color:var(--sand-50); padding:12px 22px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Browse the catalogue</a>
        <a href="/aquintutor/schools" style="background:transparent; color:var(--ink); padding:12px 22px; border-radius:6px; border:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Browse schools</a>
        <a href="/aquintutor/rewards" style="background:transparent; color:var(--ink); padding:12px 22px; border-radius:6px; border:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Rewards &amp; rank</a>
        <a href="/aquintutor/test/quantum-challenge-100" style="background:transparent; color:var(--ink); padding:12px 22px; border-radius:6px; border:1px solid var(--ink); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Sit the Quantum Challenge &rarr;</a>
      </div>
    </div>
  </section>

  <style>
    @media (min-width: 640px) { .cards-grid { grid-template-columns: repeat(2, 1fr) !important; } }
    @media (min-width: 1000px) { .cards-grid { grid-template-columns: repeat(3, 1fr) !important; } }
  </style>
</AquintutorLayout>
