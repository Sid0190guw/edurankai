---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/dashboard'));

let enrollments: any[] = [];
let recentAttempts: any[] = [];
let upcomingTests: any[] = [];
let myCertificates: any[] = [];
let liveAttempt: any = null;
let lastInterview: any = null;
let stats = { totalLessons: 0, completedLessons: 0, totalAttempts: 0, passedAttempts: 0, daysActive: 0 };
let weeklySparkline: number[] = [0,0,0,0,0,0,0];

try {
  const r = await db.execute(sql`
    SELECT e.id, e.progress_pct, e.last_lesson_id, e.enrolled_at,
      c.slug, c.title, c.subtitle, c.short_desc, c.course_code, c.duration_weeks,
      c.credit_hours, c.level, c.is_free, c.pricing_model, c.instructor_name,
      s.name as school_name, s.slug as school_slug, s.code as school_code,
      d.name as department_name,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as total_lessons
    FROM training_enrollments e
    LEFT JOIN training_courses c ON e.course_id = c.id
    LEFT JOIN schools s ON c.school_id = s.id
    LEFT JOIN academic_departments d ON c.department_id = d.id
    WHERE e.user_id = ${user.id}
    ORDER BY e.enrolled_at DESC LIMIT 12
  `);
  enrollments = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT a.id, a.percentage, a.status, a.started_at, a.submitted_at, a.total_score, a.max_score, a.is_passed,
      t.slug as test_slug, t.title as test_title, t.test_type, t.duration_mins
    FROM test_attempts a
    LEFT JOIN tests t ON a.test_id = t.id
    WHERE a.candidate_id = ${user.id}
    ORDER BY a.started_at DESC NULLS LAST LIMIT 10
  `);
  recentAttempts = Array.isArray(r) ? r : (r?.rows || []);
  liveAttempt = recentAttempts.find((a: any) => a.status === 'in_progress') || null;
  stats.totalAttempts = recentAttempts.filter((a: any) => a.status !== 'in_progress').length;
  stats.passedAttempts = recentAttempts.filter((a: any) => a.is_passed).length;
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT t.slug, t.title, t.test_type, t.duration_mins, t.is_premium, t.currency, t.price_inr_paise, t.total_questions,
      (SELECT COUNT(*)::int FROM test_questions WHERE test_id = t.id) as question_count
    FROM tests t
    WHERE t.is_published = true
      AND NOT EXISTS (SELECT 1 FROM test_attempts WHERE test_id = t.id AND candidate_id = ${user.id} AND status IN ('submitted','auto_submitted'))
    ORDER BY t.created_at DESC LIMIT 4
  `);
  upcomingTests = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT c.certificate_number as credential_number,
      tc.title as course_title, tc.slug as course_slug,
      c.issued_at
    FROM training_certificates c
    JOIN training_courses tc ON c.course_id = tc.id
    WHERE c.user_id = ${user.id}
    ORDER BY c.issued_at DESC LIMIT 4
  `);
  myCertificates = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT s.id, s.status, s.started_at, s.ended_at, s.language, t.title as template_title
    FROM ai_interview_sessions s
    JOIN ai_interview_templates t ON s.template_id = t.id
    WHERE s.candidate_id = ${user.id}
    ORDER BY s.started_at DESC LIMIT 1
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  lastInterview = rows[0] || null;
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT
      (SELECT COALESCE(SUM(total_lessons),0)::int FROM training_courses WHERE id IN (SELECT course_id FROM training_enrollments WHERE user_id = ${user.id})) as total_lessons,
      (SELECT COUNT(DISTINCT DATE(started_at))::int FROM test_attempts WHERE candidate_id = ${user.id} AND started_at IS NOT NULL) as days_active
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  if (rows[0]) {
    stats.totalLessons = (rows[0] as any).total_lessons || 0;
    stats.daysActive = (rows[0] as any).days_active || 0;
  }
  stats.completedLessons = enrollments.reduce((s, e: any) => s + Math.round(((e.progress_pct || 0) / 100) * (e.total_lessons || 0)), 0);
} catch (_) {}

try {
  // weekly attempt counts for the last 7 days
  const r = await db.execute(sql`
    SELECT EXTRACT(DOW FROM started_at)::int as dow, COUNT(*)::int as n
    FROM test_attempts
    WHERE candidate_id = ${user.id} AND started_at > NOW() - INTERVAL '7 days'
    GROUP BY dow
  `);
  const rows = (Array.isArray(r) ? r : (r?.rows || [])) as any[];
  const map: any = {};
  rows.forEach((row) => { map[row.dow] = row.n; });
  // align with today as the rightmost bar
  const todayDow = new Date().getDay();
  for (let i = 0; i < 7; i++) {
    const dow = (todayDow - 6 + i + 7) % 7;
    weeklySparkline[i] = map[dow] || 0;
  }
} catch (_) {}

const firstName = (user.name || '').split(' ')[0] || 'student';
const hour = new Date().getHours();
const greeting = hour < 5 ? 'Good evening' : hour < 12 ? 'Good morning' : hour < 17 ? 'Good afternoon' : 'Good evening';
const xpEstimate = stats.completedLessons * 10 + stats.passedAttempts * 100 + myCertificates.length * 250;
const level = Math.max(1, Math.floor(Math.sqrt(xpEstimate / 50)) + 1);
const xpToNext = (level * level) * 50 - xpEstimate;
const streak = Math.min(stats.daysActive, 30);

function ago(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins + 'm ago';
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return hrs + 'h ago';
  const days = Math.floor(hrs / 24);
  if (days < 7) return days + 'd ago';
  return new Date(d).toLocaleDateString('en-IN', { day: '2-digit', month: 'short' });
}
function priceLabel(t: any) {
  if (!t.is_premium) return 'Included';
  const cur = (t.currency || 'INR').toUpperCase();
  const major = Math.max(1, Math.round((t.price_inr_paise || 0) / 100));
  return cur + ' ' + major;
}

// Build unified activity feed
const activity: any[] = [];
enrollments.forEach((e: any) => activity.push({ kind: 'enrolled', when: e.enrolled_at, title: 'Enrolled in ' + e.title, href: '/aquintutor/courses/' + e.slug, badge: e.school_code || 'COURSE', tone: 'rust' }));
recentAttempts.forEach((a: any) => {
  if (a.submitted_at) activity.push({ kind: 'exam', when: a.submitted_at, title: 'Submitted ' + a.test_title, sub: a.percentage != null ? Math.round(a.percentage) + '%' : null, href: '/aquintutor/test/' + a.test_slug + '/result?attempt=' + a.id, badge: a.is_passed ? 'PASSED' : 'ATTEMPTED', tone: a.is_passed ? 'green' : 'ink' });
});
myCertificates.forEach((c: any) => activity.push({ kind: 'credential', when: c.issued_at, title: 'Credential issued: ' + c.course_title, href: '/credentials/' + c.credential_number, badge: 'CREDENTIAL', tone: 'rust' }));
if (lastInterview) activity.push({ kind: 'interview', when: lastInterview.started_at, title: 'Screening interview &mdash; ' + lastInterview.template_title, href: '/aquintutor/dashboard', badge: 'INTERVIEW', tone: 'ink' });
activity.sort((a, b) => new Date(b.when).getTime() - new Date(a.when).getTime());

// Badge taxonomy (computed)
const badges = [
  { id: 'first-enrol', label: 'First enrolment', desc: 'Pick the first course of your term.', unlocked: enrollments.length > 0, glyph: 'M12 2l3 7h7l-5.5 4 2 7L12 16l-6.5 4 2-7L2 9h7z' },
  { id: 'first-exam', label: 'First examination', desc: 'Sit any proctored examination.', unlocked: stats.totalAttempts > 0, glyph: 'M4 5a2 2 0 012-2h12a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2zm4 4l3 3 5-5' },
  { id: 'first-pass', label: 'Above the cut', desc: 'Pass an examination at the published cut-mark.', unlocked: stats.passedAttempts > 0, glyph: 'M5 12l5 5L20 7' },
  { id: 'credential', label: 'First credential', desc: 'Earn a verifiable credential.', unlocked: myCertificates.length > 0, glyph: 'M12 4l-7 4v6c0 4 3 7 7 8 4-1 7-4 7-8V8z' },
  { id: 'interview', label: 'Screened', desc: 'Sit the screening interview.', unlocked: !!lastInterview, glyph: 'M21 12c0 4.97-4.03 9-9 9-1.5 0-2.91-.36-4.15-1l-4.85 1 1-4.85A8.96 8.96 0 013 12c0-4.97 4.03-9 9-9s9 4.03 9 9z' },
  { id: 'streak-7', label: 'Seven-day streak', desc: 'Sit a question every day for seven days.', unlocked: streak >= 7, glyph: 'M13 2L3 14h9l-1 8 10-12h-9z' },
];

const today = new Date();
const termStart = new Date(today.getFullYear(), 8, 1);
const dayOfTerm = Math.max(1, Math.floor((today.getTime() - termStart.getTime()) / 86400000));
const weekOfTerm = Math.max(1, Math.ceil(dayOfTerm / 7));

const sparkMax = Math.max(1, ...weeklySparkline);
const sparkLabels = ['M', 'T', 'W', 'T', 'F', 'S', 'S'];
---
<AquintutorLayout title="Dashboard" description="Your AquinTutor dashboard - enrolled courses, recent attempts, credentials.">

  <!-- TICKER -->
  <div style="background:var(--ink); color:var(--sand-50); border-bottom:1px solid var(--rule); overflow:hidden;">
    <div style="display:flex; align-items:center; gap:20px; padding:8px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.06em; white-space:nowrap; overflow-x:auto;">
      <span style="display:inline-flex; align-items:center; gap:6px; flex-shrink:0;">
        <span style="display:inline-block; width:6px; height:6px; border-radius:50%; background:#7dd3a8; box-shadow:0 0 8px #7dd3a8;"></span>
        <span style="color:#7dd3a8; font-weight:600;">YOU &middot; SIGNED IN</span>
      </span>
      <span style="opacity:0.5;">&middot;</span>
      <span><span style="opacity:0.6;">term:</span> autumn / {today.getFullYear()}</span>
      <span style="opacity:0.5;">&middot;</span>
      <span><span style="opacity:0.6;">week:</span> {weekOfTerm}</span>
      <span style="opacity:0.5;">&middot;</span>
      <span><span style="opacity:0.6;">level:</span> {level}</span>
      <span style="opacity:0.5;">&middot;</span>
      <span><span style="opacity:0.6;">enrolments:</span> {enrollments.length}</span>
      <span style="opacity:0.5;">&middot;</span>
      <span><span style="opacity:0.6;">credentials:</span> {myCertificates.length}</span>
      {liveAttempt && <>
        <span style="opacity:0.5;">&middot;</span>
        <span style="color:#d97757; font-weight:600;">EXAMINATION IN PROGRESS</span>
      </>}
    </div>
  </div>

  <!-- HERO -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1320px; margin:0 auto; padding:56px 28px 40px;">
      <div style="display:grid; grid-template-columns:1fr; gap:36px;" class="hero-grid">
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); font-weight:600; letter-spacing:0.04em; margin:0 0 14px;">Your register &middot; {today.toLocaleDateString('en-GB', { weekday:'long', day: '2-digit', month: 'short', year: 'numeric' })}</p>
          <h1 class="font-display" style="font-size:clamp(2.25rem, 5vw, 4rem); line-height:1.02; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--ink);">
            {greeting},<br/>
            <span style="font-style:italic; font-weight:300; color:var(--ink-500);">{firstName}.</span>
          </h1>
          <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.05rem, 1.4vw, 1.3rem); line-height:1.5; color:var(--ink-500); margin:20px 0 0; max-width:36rem;">
            {enrollments.length > 0
              ? <>You're {stats.completedLessons > 0 ? stats.completedLessons + ' lessons into ' : 'enrolled in '} {enrollments.length} {enrollments.length === 1 ? 'course' : 'courses'}. Pick up where you left off, sit a proctored examination, or browse the catalogue for what to take next.</>
              : <>Your enrolment is active. Open the catalogue below and pick the first course of your term.</>}
          </p>
        </div>

        <aside style="background:var(--sand-100); border:1px solid var(--rule); border-radius:14px; padding:24px; position:relative;">
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:18px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0;">Your standing</p>
            <span style="display:inline-flex; align-items:center; gap:5px; padding:3px 10px; border-radius:999px; background:var(--paper); border:1px solid var(--rule); font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:600; color:var(--rust);">LV {level}</span>
          </div>
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:18px;">
            <div>
              <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">Experience</p>
              <p class="font-display" style="font-size:1.45rem; font-weight:500; margin:0; line-height:1; color:var(--ink); letter-spacing:-0.02em;">{xpEstimate}<span style="font-size:0.7em; color:var(--ink-500); margin-left:3px;">XP</span></p>
              <p style="font-family:'Inter Tight',sans-serif; font-size:11px; color:var(--ink-500); margin:5px 0 0;">{xpToNext} XP to LV {level + 1}</p>
            </div>
            <div>
              <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">Streak</p>
              <p class="font-display" style="font-size:1.45rem; font-weight:500; margin:0; line-height:1; color:var(--rust); letter-spacing:-0.02em;">{streak}<span style="font-size:0.7em; color:var(--ink-500); margin-left:3px;">days</span></p>
              <p style="font-family:'Inter Tight',sans-serif; font-size:11px; color:var(--ink-500); margin:5px 0 0;">{stats.daysActive} days active</p>
            </div>
          </div>

          <!-- 7-day sparkline -->
          <div style="padding-top:14px; border-top:1px solid var(--rule);">
            <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 10px;">Last seven days</p>
            <div style="display:grid; grid-template-columns:repeat(7, 1fr); gap:6px; align-items:end; height:54px;">
              {weeklySparkline.map((v: number, i: number) => (
                <div style="display:flex; flex-direction:column; align-items:center; gap:4px; height:100%;">
                  <div style="flex:1; display:flex; align-items:end; width:100%;">
                    <div style={'width:100%; background:' + (v > 0 ? 'var(--rust)' : 'var(--rule)') + '; border-radius:3px 3px 0 0; height:' + Math.max(8, (v / sparkMax) * 100) + '%;'} title={v + ' attempts'}></div>
                  </div>
                  <span style="font-family:'JetBrains Mono',monospace; font-size:9px; color:var(--ink-500); letter-spacing:0.08em;">{sparkLabels[i]}</span>
                </div>
              ))}
            </div>
          </div>
        </aside>
      </div>

      {liveAttempt && (
        <div style="margin-top:28px; background:#0b0d10; color:#f4f1ea; border-radius:12px; padding:18px 22px; display:flex; align-items:center; justify-content:space-between; gap:14px; flex-wrap:wrap; border:1px solid #d97757;">
          <div style="display:flex; align-items:center; gap:14px;">
            <span style="display:inline-flex; align-items:center; gap:7px; padding:5px 10px; border-radius:999px; background:#d97757; color:#1a0f08; font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.16em; font-weight:600;"><span style="display:inline-block; width:6px; height:6px; border-radius:50%; background:#1a0f08; animation:pulse 1.4s ease-in-out infinite;"></span>LIVE</span>
            <div>
              <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:rgba(244,241,234,0.65); margin:0 0 4px; font-weight:600;">Examination in progress</p>
              <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:18px; margin:0; color:#f4f1ea;">{liveAttempt.test_title}</p>
              <p style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:rgba(244,241,234,0.7); margin:4px 0 0;">Started {ago(liveAttempt.started_at)} - your seat is held; finish before the timer.</p>
            </div>
          </div>
          <a href={'/aquintutor/test/' + liveAttempt.test_slug + '/run?resume=1'} style="background:#d97757; color:#1a0f08; padding:12px 22px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13.5px; font-weight:600; text-decoration:none;">Resume examination &rarr;</a>
        </div>
      )}
    </div>
  </section>

  <!-- ENROLMENTS + ACTIVITY FEED two-col -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1320px; margin:0 auto; padding:56px 28px;">
      <div style="display:grid; grid-template-columns:1fr; gap:32px;" class="main-split">

        <!-- LEFT: Continue learning -->
        <div>
          <div style="display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:10px; margin-bottom:22px;">
            <div>
              <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 8px;">Continue</p>
              <h2 class="font-display" style="font-size:clamp(1.4rem, 2.3vw, 1.85rem); font-weight:500; margin:0; line-height:1.15; letter-spacing:-0.015em; color:var(--ink);">Active enrolments</h2>
            </div>
            <a href="/aquintutor/courses" style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--rust); text-decoration:none; font-weight:500;">Browse catalogue &rarr;</a>
          </div>

          {enrollments.length === 0 ? (
            <div style="background:var(--paper); border:1px dashed var(--rule); border-radius:12px; padding:36px; text-align:center;">
              <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.15rem; color:var(--ink-500); margin:0 0 18px;">You have not enrolled in any courses yet.</p>
              <a href="/aquintutor/courses" style="background:var(--ink); color:var(--sand-50); padding:12px 22px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none; display:inline-block;">Browse the catalogue &rarr;</a>
            </div>
          ) : (
            <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="enrol-grid">
              {enrollments.map((c: any) => {
                const pct = Math.min(100, c.progress_pct || 0);
                const done = Math.round((pct / 100) * (c.total_lessons || 0));
                return (
                  <a href={'/aquintutor/courses/' + c.slug} class="enrol-card" style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:0; overflow:hidden; text-decoration:none; color:var(--ink); display:flex; flex-direction:column; transition:transform 0.15s, box-shadow 0.15s;">
                    <div style="height:4px; background:var(--rust);"></div>
                    <div style="padding:18px 20px 16px;">
                      <div style="display:flex; justify-content:space-between; gap:8px; font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.14em; color:var(--ink-500); margin-bottom:10px;">
                        <span>{(c.course_code || c.school_code || 'GEN').toUpperCase()}</span>
                        <span style="color:var(--rust); font-weight:600;">{pct}%</span>
                      </div>
                      <h3 class="font-display" style="font-size:1.18rem; font-weight:500; margin:0 0 6px; line-height:1.2; letter-spacing:-0.015em;">{c.title}</h3>
                      {c.subtitle && <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:0.95rem; color:var(--ink-500); margin:0 0 12px; line-height:1.35;">{c.subtitle}</p>}
                      <div style="height:5px; background:var(--rule); border-radius:3px; overflow:hidden; margin-bottom:10px;">
                        <div style={'width:' + pct + '%; height:100%; background:var(--rust);'}></div>
                      </div>
                      <div style="display:flex; justify-content:space-between; gap:8px; font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink-500);">
                        <span>{done} of {c.total_lessons || 0} lessons</span>
                        <span>{c.school_name ? c.school_name.replace('School of ', '') : 'Foundations'}</span>
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>
          )}
        </div>

        <!-- RIGHT: Activity feed -->
        <aside>
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 8px;">Activity</p>
          <h2 class="font-display" style="font-size:1.5rem; font-weight:500; margin:0 0 22px; line-height:1.15; letter-spacing:-0.015em; color:var(--ink);">Recent record</h2>
          {activity.length === 0 ? (
            <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1rem; color:var(--ink-500); margin:0;">No activity yet. Your enrolments, examinations, and credentials will appear here as you go.</p>
          ) : (
            <ol style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0; background:var(--paper); border:1px solid var(--rule); border-radius:14px; overflow:hidden;">
              {activity.slice(0, 8).map((a: any, i: number) => (
                <li>
                  <a href={a.href} style={'display:grid; grid-template-columns:auto 1fr auto; gap:12px; align-items:center; padding:14px 18px; text-decoration:none; color:var(--ink); ' + (i < activity.slice(0,8).length - 1 ? 'border-bottom:1px solid var(--rule);' : '')}>
                    <span style={'display:inline-block; padding:3px 9px; border-radius:999px; font-family:JetBrains Mono,monospace; font-size:9.5px; letter-spacing:0.16em; font-weight:600; ' + (a.tone === 'green' ? 'background:rgba(125,211,168,0.18); color:#3f8a64; border:1px solid #7dd3a8;' : a.tone === 'rust' ? 'background:rgba(160,66,30,0.10); color:var(--rust); border:1px solid rgba(160,66,30,0.3);' : 'background:var(--sand-100); color:var(--ink-500); border:1px solid var(--rule);')}>{a.badge}</span>
                    <div style="min-width:0;">
                      <p style="font-family:'Inter Tight',sans-serif; font-size:13.5px; font-weight:500; margin:0; line-height:1.35; color:var(--ink); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" set:html={a.title}></p>
                      <p style="font-family:'Inter Tight',sans-serif; font-size:11.5px; color:var(--ink-500); margin:2px 0 0;">{ago(a.when)}{a.sub ? ' &middot; ' + a.sub : ''}</p>
                    </div>
                    <span style="font-family:'Inter Tight',sans-serif; color:var(--ink-500); font-size:13px;" aria-hidden="true">&rarr;</span>
                  </a>
                </li>
              ))}
            </ol>
          )}
        </aside>
      </div>
    </div>
  </section>

  <!-- BADGES STRIP -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1320px; margin:0 auto; padding:56px 28px;">
      <div style="display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:10px; margin-bottom:22px;">
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 8px;">Achievements</p>
          <h2 class="font-display" style="font-size:clamp(1.4rem, 2.3vw, 1.85rem); font-weight:500; margin:0; line-height:1.15; letter-spacing:-0.015em; color:var(--ink);">Badge cabinet</h2>
        </div>
        <a href="/aquintutor/rewards" style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--rust); text-decoration:none; font-weight:500;">Full rewards page &rarr;</a>
      </div>
      <div style="display:grid; grid-template-columns:repeat(2, 1fr); gap:12px;" class="badges-grid">
        {badges.map((b) => (
          <div style={'background:' + (b.unlocked ? 'var(--paper)' : 'var(--sand-100)') + '; border:1px solid var(--rule); border-radius:12px; padding:18px; display:flex; flex-direction:column; align-items:center; gap:10px; text-align:center; ' + (b.unlocked ? '' : 'opacity:0.55;')}>
            <span style={'display:inline-flex; align-items:center; justify-content:center; width:46px; height:46px; border-radius:50%; ' + (b.unlocked ? 'background:var(--ink); color:var(--sand-50);' : 'background:var(--sand-100); border:1px dashed var(--rule); color:var(--ink-500);')}>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d={b.glyph}/></svg>
            </span>
            <p class="font-display" style="font-size:0.95rem; font-weight:500; margin:0; line-height:1.15; letter-spacing:-0.01em; color:var(--ink);">{b.label}</p>
            <p style="font-family:'Inter Tight',sans-serif; font-size:11.5px; color:var(--ink-500); line-height:1.4; margin:0;">{b.desc}</p>
            {b.unlocked
              ? <span style="font-family:'JetBrains Mono',monospace; font-size:9.5px; letter-spacing:0.16em; color:#3f8a64; font-weight:600; margin-top:auto;">UNLOCKED</span>
              : <span style="font-family:'JetBrains Mono',monospace; font-size:9.5px; letter-spacing:0.16em; color:var(--ink-500); font-weight:600; margin-top:auto;">LOCKED</span>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EXAM HISTORY + UPCOMING -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1320px; margin:0 auto; padding:56px 28px;">
      <div style="display:grid; grid-template-columns:1fr; gap:36px;" class="exam-split">

        {/* History */}
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 8px;">Examinations</p>
          <h2 class="font-display" style="font-size:clamp(1.4rem, 2.3vw, 1.85rem); font-weight:500; margin:0 0 22px; line-height:1.15; letter-spacing:-0.015em; color:var(--ink);">Recent attempts</h2>
          {recentAttempts.length === 0 ? (
            <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1rem; color:var(--ink-500); margin:0;">You haven't sat an examination yet.</p>
          ) : (
            <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; overflow:hidden;">
              {recentAttempts.slice(0, 6).map((a: any, i: number) => {
                const pct = a.percentage != null ? Math.round(a.percentage) : null;
                const tone = a.is_passed ? '#3f8a64' : (pct != null ? 'var(--rust)' : 'var(--ink-500)');
                return (
                  <a href={a.status === 'in_progress' ? ('/aquintutor/test/' + a.test_slug + '/run?resume=1') : ('/aquintutor/test/' + a.test_slug + '/result?attempt=' + a.id)} style={'display:flex; align-items:center; gap:14px; padding:14px 20px; text-decoration:none; color:var(--ink); ' + (i < recentAttempts.slice(0, 6).length - 1 ? 'border-bottom:1px solid var(--rule);' : '')}>
                    <div style="min-width:0; flex:1;">
                      <p style="font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:500; margin:0; line-height:1.3; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{a.test_title}</p>
                      <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500); margin:3px 0 0; letter-spacing:0.06em;">{(a.test_type || 'EXAM').toUpperCase()} &middot; {ago(a.started_at)} &middot; {a.status}</p>
                    </div>
                    <span class="font-display" style={'font-size:1.4rem; color:' + tone + '; font-variant-numeric:tabular-nums; letter-spacing:-0.015em; font-weight:500; min-width:60px; text-align:right;'}>{pct != null ? pct + '%' : '-'}</span>
                  </a>
                );
              })}
            </div>
          )}
        </div>

        {/* Upcoming */}
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 8px;">Open</p>
          <h2 class="font-display" style="font-size:clamp(1.4rem, 2.3vw, 1.85rem); font-weight:500; margin:0 0 22px; line-height:1.15; letter-spacing:-0.015em; color:var(--ink);">To sit next</h2>
          {upcomingTests.length === 0 ? (
            <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1rem; color:var(--ink-500); margin:0;">You've covered every published examination. Watch this space.</p>
          ) : (
            <div style="display:flex; flex-direction:column; gap:10px;">
              {upcomingTests.map((t: any) => (
                <a href={'/aquintutor/test/' + t.slug} style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:16px 18px; text-decoration:none; color:var(--ink); display:flex; flex-direction:column; gap:6px;">
                  <div style="display:flex; justify-content:space-between; gap:8px; font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.12em; color:var(--ink-500);">
                    <span>{(t.test_type || 'EXAM').toUpperCase()}</span>
                    <span style="color:var(--rust); font-weight:600;">{priceLabel(t)}</span>
                  </div>
                  <p style="font-family:'Inter Tight',sans-serif; font-size:14.5px; font-weight:500; margin:0; line-height:1.3;">{t.title}</p>
                  <p style="font-family:'Inter Tight',sans-serif; font-size:11.5px; color:var(--ink-500); margin:0;">{t.duration_mins ? t.duration_mins + ' min' : ''}{t.question_count ? ' &middot; ' + t.question_count + ' questions' : ''}</p>
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- CREDENTIALS + TUTOR CARD -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1320px; margin:0 auto; padding:56px 28px;">
      <div style="display:grid; grid-template-columns:1fr; gap:32px;" class="cred-split">

        <div>
          <div style="display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:10px; margin-bottom:22px;">
            <div>
              <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 8px;">Credentials</p>
              <h2 class="font-display" style="font-size:clamp(1.4rem, 2.3vw, 1.85rem); font-weight:500; margin:0; line-height:1.15; letter-spacing:-0.015em; color:var(--ink);">Verifiable credentials</h2>
            </div>
            {myCertificates.length > 0 && <p style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--ink-500); letter-spacing:0.1em; margin:0;">{myCertificates.length} ISSUED</p>}
          </div>
          {myCertificates.length === 0 ? (
            <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1rem; color:var(--ink-500); margin:0;">No credentials yet. Pass any course examination to receive your first.</p>
          ) : (
            <div style="display:grid; grid-template-columns:1fr; gap:12px;" class="cred-grid">
              {myCertificates.map((cert: any) => (
                <a href={'/credentials/' + cert.credential_number} style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:18px 20px; text-decoration:none; color:var(--ink); display:flex; flex-direction:column; gap:10px;">
                  <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.16em; color:var(--rust); font-weight:600; margin:0;">CERTIFICATE OF COMPLETION</p>
                  <h3 class="font-display" style="font-size:1.1rem; font-weight:500; margin:0; line-height:1.2; letter-spacing:-0.015em;">{cert.course_title}</h3>
                  <div style="margin-top:auto; padding-top:10px; border-top:1px solid var(--rule); display:flex; justify-content:space-between; gap:8px; font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500);">
                    <span style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap; max-width:60%;">{cert.credential_number}</span>
                    <span>{ago(cert.issued_at)}</span>
                  </div>
                </a>
              ))}
            </div>
          )}
        </div>

        <aside style="background:var(--ink); color:var(--sand-50); border-radius:14px; padding:28px; display:flex; flex-direction:column; gap:14px; position:relative; overflow:hidden;">
          <div aria-hidden="true" style="position:absolute; right:-30px; bottom:-30px; opacity:0.1;">
            <svg width="180" height="180" viewBox="0 0 100 100"><circle cx="50" cy="50" r="40" stroke="var(--sand-50)" stroke-width="0.4" fill="none"/><circle cx="50" cy="50" r="28" stroke="var(--sand-50)" stroke-width="0.4" fill="none"/><circle cx="50" cy="50" r="16" stroke="var(--sand-50)" stroke-width="0.4" fill="none"/></svg>
          </div>
          <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:#d97757; font-weight:600; margin:0; position:relative; z-index:1;">Your AI tutor</p>
          <h3 class="font-display" style="font-size:1.5rem; font-weight:500; margin:0; line-height:1.18; letter-spacing:-0.015em; color:var(--sand-50); position:relative; z-index:1;">Private tutor inside every enrolment.</h3>
          <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.05rem; line-height:1.5; color:rgba(251,250,244,0.78); margin:0; position:relative; z-index:1;">Stuck on a concept? Open any lesson and ask. The tutor reads the lesson, knows the prerequisites, and will not move on until you have the answer.</p>
          <a href="/aquintutor/courses" style="background:#d97757; color:#1a0f08; padding:11px 20px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13.5px; font-weight:600; text-decoration:none; align-self:flex-start; position:relative; z-index:1;">Open a lesson &rarr;</a>
        </aside>
      </div>
    </div>
  </section>

  <!-- CTA RAIL -->
  <section>
    <div style="max-width:1320px; margin:0 auto; padding:48px 28px 80px;">
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <a href="/aquintutor/courses" style="background:var(--ink); color:var(--sand-50); padding:13px 22px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Browse the catalogue</a>
        <a href="/aquintutor/schools" style="background:transparent; color:var(--ink); padding:13px 22px; border-radius:6px; border:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Browse schools</a>
        <a href="/aquintutor/instructors" style="background:transparent; color:var(--ink); padding:13px 22px; border-radius:6px; border:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Faculty</a>
        <a href="/aquintutor/rewards" style="background:transparent; color:var(--ink); padding:13px 22px; border-radius:6px; border:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Rewards &amp; rank</a>
        <a href="/aquintutor/profile" style="background:transparent; color:var(--ink); padding:13px 22px; border-radius:6px; border:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Profile</a>
        <a href="/aquintutor/test/quantum-challenge-100" style="background:transparent; color:var(--ink); padding:13px 22px; border-radius:6px; border:1px solid var(--ink); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Quantum Challenge &rarr;</a>
      </div>
    </div>
  </section>

  <style>
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }
    .enrol-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(11,14,20,0.08); }
    @media (min-width: 768px) {
      .hero-grid { grid-template-columns: 1.5fr 1fr !important; }
      .enrol-grid { grid-template-columns: repeat(2, 1fr) !important; }
      .badges-grid { grid-template-columns: repeat(3, 1fr) !important; }
      .main-split { grid-template-columns: 1.6fr 1fr !important; }
      .exam-split { grid-template-columns: 1.4fr 1fr !important; }
      .cred-split { grid-template-columns: 2fr 1fr !important; }
      .cred-grid { grid-template-columns: repeat(2, 1fr) !important; }
    }
    @media (min-width: 1100px) {
      .badges-grid { grid-template-columns: repeat(6, 1fr) !important; }
      .enrol-grid { grid-template-columns: repeat(3, 1fr) !important; }
    }
  </style>
</AquintutorLayout>
