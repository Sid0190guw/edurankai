---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/dashboard'));

let enrollments: any[] = [];
let recentAttempts: any[] = [];
let upcomingTests: any[] = [];
let myCertificates: any[] = [];
let liveAttempt: any = null;

try {
  const r = await db.execute(sql`
    SELECT e.id, e.progress_pct, e.last_lesson_id, e.enrolled_at,
      c.slug, c.title, c.subtitle, c.short_desc, c.course_code, c.duration_weeks,
      c.credit_hours, c.level, c.is_free, c.pricing_model,
      s.name as school_name, s.slug as school_slug,
      d.name as department_name,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as total_lessons
    FROM training_enrollments e
    LEFT JOIN training_courses c ON e.course_id = c.id
    LEFT JOIN schools s ON c.school_id = s.id
    LEFT JOIN academic_departments d ON c.department_id = d.id
    WHERE e.user_id = ${user.id}
    ORDER BY e.enrolled_at DESC LIMIT 24
  `);
  enrollments = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT a.id, a.percentage, a.status, a.started_at, a.submitted_at, a.total_score, a.max_score,
      t.slug as test_slug, t.title as test_title, t.test_type, t.duration_mins
    FROM test_attempts a
    LEFT JOIN tests t ON a.test_id = t.id
    WHERE a.candidate_id = ${user.id}
    ORDER BY a.started_at DESC NULLS LAST LIMIT 10
  `);
  recentAttempts = Array.isArray(r) ? r : (r?.rows || []);
  liveAttempt = recentAttempts.find((a: any) => a.status === 'in_progress') || null;
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT t.slug, t.title, t.test_type, t.duration_mins, t.is_premium, t.currency, t.price_inr_paise,
      (SELECT COUNT(*)::int FROM test_questions WHERE test_id = t.id) as question_count
    FROM tests t
    WHERE t.is_published = true
      AND NOT EXISTS (SELECT 1 FROM test_attempts WHERE test_id = t.id AND candidate_id = ${user.id} AND status IN ('submitted','auto_submitted'))
    ORDER BY t.created_at DESC LIMIT 4
  `);
  upcomingTests = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT credential_number, course_title, issued_at
    FROM training_certificates
    WHERE user_id = ${user.id}
    ORDER BY issued_at DESC LIMIT 4
  `);
  myCertificates = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const firstName = (user.name || '').split(' ')[0] || 'student';
const hour = new Date().getHours();
const greeting = hour < 5 ? 'Good evening' : hour < 12 ? 'Good morning' : hour < 17 ? 'Good afternoon' : 'Good evening';

function ago(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins + 'm ago';
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return hrs + 'h ago';
  const days = Math.floor(hrs / 24);
  if (days < 7) return days + 'd ago';
  return new Date(d).toLocaleDateString('en-IN', { day: '2-digit', month: 'short' });
}
function priceLabel(t: any) {
  if (!t.is_premium) return 'INCLUDED';
  const cur = (t.currency || 'INR').toUpperCase();
  const major = Math.max(1, Math.round((t.price_inr_paise || 0) / 100));
  return cur + ' ' + major;
}
---
<AquintutorLayout title="Dashboard" description="Your AquinTutor dashboard - enrolled courses, recent attempts, credentials.">

  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:48px 24px 32px;">
      <div style="display:flex; align-items:center; gap:14px; margin-bottom:18px;" class="numplate">
        <span style="height:1px; width:48px; background:var(--ink);"></span>
        <span style="color:var(--ink-500);">YOUR REGISTER &middot; {new Date().toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).toUpperCase()}</span>
      </div>
      <h1 class="font-display" style="font-size:clamp(2.5rem, 6vw, 5rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0;">
        {greeting}, <span style="font-style:italic; font-weight:300; color:var(--ink-500);">{firstName}.</span>
      </h1>
      <p class="font-serif" style="font-size:clamp(1.125rem, 1.6vw, 1.5rem); color:var(--ink-500); margin-top:18px; max-width:42rem; line-height:1.4;">
        {enrollments.length > 0
          ? <>You are enrolled in {enrollments.length} {enrollments.length === 1 ? 'course' : 'courses'}. Pick up where you left off, sit a proctored examination, or browse the catalogue for what to take next.</>
          : <>Your enrolment is active. Open the catalogue below and pick the first course of your term.</>}
      </p>

      {liveAttempt && (
        <div style="margin-top:28px; background:var(--ink); color:var(--sand-50); border-radius:14px; padding:18px 22px; display:flex; align-items:center; justify-content:space-between; gap:14px; flex-wrap:wrap; box-shadow:0 0 32px rgba(217,119,87,0.18);">
          <div>
            <p class="numplate" style="color:var(--gold); margin:0 0 4px;">EXAMINATION IN PROGRESS</p>
            <p class="font-serif" style="font-size:1.5rem; margin:0; color:var(--sand-50);"><em>{liveAttempt.test_title}</em></p>
            <p style="font-size:13px; color:rgba(251,250,244,0.7); margin:4px 0 0;">Started {ago(liveAttempt.started_at)} - your seat is held; finish before the timer.</p>
          </div>
          <a href={'/aquintutor/test/' + liveAttempt.test_slug + '/run?resume=1'} class="btn-pill filled" style="background:var(--gold); color:var(--ink); border-color:var(--gold);">Resume examination &rarr;</a>
        </div>
      )}
    </div>
  </section>

  <!-- Enrolments -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:64px 24px;">
      <div style="display:grid; grid-template-columns:1fr; gap:32px; margin-bottom:36px;" class="thesis-grid">
        <div>
          <p class="eyebrow">&sect; I &mdash; Your courses</p>
          <p class="numplate" style="color:var(--ink-300); margin-top:8px;">{String(enrollments.length).padStart(3, '0')} ENROLLED</p>
        </div>
        <div>
          <h2 class="font-display" style="font-size:clamp(2rem, 5vw, 4rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0;">
            Active enrolments.<br/>
            <span style="font-style:italic; font-weight:300; color:var(--ink-500);">Resume where you left off.</span>
          </h2>
        </div>
      </div>

      {enrollments.length === 0 ? (
        <div style="background:var(--paper); border:1px dashed var(--rule); border-radius:14px; padding:48px; text-align:center;">
          <p class="font-serif" style="font-size:1.5rem; font-style:italic; color:var(--ink-500); margin:0 0 22px;">You have not enrolled in any courses yet.</p>
          <a href="/aquintutor/courses" class="btn-pill filled">Browse the catalogue &rarr;</a>
        </div>
      ) : (
        <div style="display:grid; grid-template-columns:1fr; gap:1px; background:rgba(11,14,20,0.15); border:1px solid rgba(11,14,20,0.15);" class="schools-grid">
          {enrollments.map((c: any) => (
            <a href={'/aquintutor/courses/' + c.slug} class="tile" style="padding:28px;">
              <div>
                <div style="display:flex; justify-content:space-between; gap:8px;" class="numplate">
                  <span style="color:var(--ink-300);">{c.course_code || (c.level || 'GEN').toUpperCase()}</span>
                  <span style="color:var(--ink-300);">{c.progress_pct || 0}%</span>
                </div>
                <h3 class="font-display" style="font-size:1.5rem; margin-top:14px; line-height:1.1; letter-spacing:-0.02em; font-weight:500;">{c.title}</h3>
                {c.subtitle && <p class="font-serif" style="font-size:1.05rem; font-style:italic; color:var(--ink-500); margin-top:10px; line-height:1.3;">{c.subtitle}</p>}
              </div>
              <div style="margin-top:24px; padding-top:14px; border-top:1px solid var(--rule); display:flex; justify-content:space-between; gap:6px;" class="numplate">
                <span style="color:var(--ink-300);">{c.school_name ? c.school_name.replace('School of ', '') : 'Foundations'}</span>
                <span style="color:var(--ink-300);">{c.total_lessons || 0} lessons</span>
              </div>
              <div style="margin-top:10px; height:3px; background:var(--rule); border-radius:2px; overflow:hidden;">
                <div style={'width:' + Math.min(100, c.progress_pct || 0) + '%; height:100%; background:var(--rust);'}></div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Recent test attempts -->
  {recentAttempts.length > 0 && (
    <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
      <div style="max-width:1400px; margin:0 auto; padding:64px 24px;">
        <div style="display:grid; grid-template-columns:1fr; gap:32px; margin-bottom:36px;" class="thesis-grid">
          <div>
            <p class="eyebrow">&sect; II &mdash; Assessments</p>
            <p class="numplate" style="color:var(--ink-300); margin-top:8px;">{String(recentAttempts.length).padStart(3, '0')} ATTEMPTS</p>
          </div>
          <div>
            <h2 class="font-display" style="font-size:clamp(2rem, 5vw, 4rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0;">
              Recent examinations.<br/>
              <span style="font-style:italic; font-weight:300; color:var(--ink-500);">Proctored, recorded, yours.</span>
            </h2>
          </div>
        </div>

        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; overflow:hidden;">
          {recentAttempts.map((a: any) => (
            <a href={a.status === 'in_progress' ? ('/aquintutor/test/' + a.test_slug + '/run?resume=1') : ('/aquintutor/test/' + a.test_slug + '/result?attempt=' + a.id)} style="display:flex; align-items:center; justify-content:space-between; gap:14px; padding:16px 22px; border-bottom:1px solid var(--rule); text-decoration:none; color:var(--ink); flex-wrap:wrap;">
              <div style="min-width:0; flex:1;">
                <p class="font-display" style="font-size:1.25rem; margin:0; line-height:1.2; letter-spacing:-0.01em;">{a.test_title}</p>
                <p class="numplate" style="color:var(--ink-500); margin:4px 0 0;">{(a.test_type || 'EXAM').toUpperCase()} &middot; {ago(a.started_at)} &middot; {a.status}</p>
              </div>
              <div style="display:flex; align-items:baseline; gap:14px;">
                <span class="font-display" style="font-size:1.75rem; color:var(--rust); font-variant-numeric:tabular-nums;">{a.percentage != null ? Math.round(a.percentage) + '%' : '-'}</span>
                <span class="numplate" style="color:var(--ink-300);">&rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Upcoming tests -->
  {upcomingTests.length > 0 && (
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:1400px; margin:0 auto; padding:64px 24px;">
        <div style="display:grid; grid-template-columns:1fr; gap:32px; margin-bottom:36px;" class="thesis-grid">
          <div>
            <p class="eyebrow">&sect; III &mdash; To sit</p>
            <p class="numplate" style="color:var(--ink-300); margin-top:8px;">{String(upcomingTests.length).padStart(3, '0')} OPEN</p>
          </div>
          <div>
            <h2 class="font-display" style="font-size:clamp(2rem, 5vw, 4rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0;">
              Examinations<br/>
              <span style="font-style:italic; font-weight:300; color:var(--ink-500);">you have not sat.</span>
            </h2>
          </div>
        </div>

        <div style="display:grid; grid-template-columns:1fr; gap:1px; background:rgba(11,14,20,0.15); border:1px solid rgba(11,14,20,0.15);" class="schools-grid">
          {upcomingTests.map((t: any) => (
            <a href={'/aquintutor/test/' + t.slug} class="tile" style="padding:28px;">
              <div>
                <div style="display:flex; justify-content:space-between; gap:6px;" class="numplate">
                  <span style="color:var(--ink-300);">{(t.test_type || 'EXAM').toUpperCase()}</span>
                  <span style="color:var(--rust);">{priceLabel(t)}</span>
                </div>
                <h3 class="font-display" style="font-size:1.4rem; margin-top:14px; line-height:1.1; letter-spacing:-0.02em; font-weight:500;">{t.title}</h3>
              </div>
              <div style="margin-top:24px; padding-top:14px; border-top:1px solid var(--rule);" class="numplate">
                <span style="color:var(--ink-300);">
                  {t.duration_mins > 0 ? t.duration_mins + 'M' : ''}
                  {t.question_count > 0 ? ' &middot; ' + t.question_count + 'Q' : ''}
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Credentials -->
  {myCertificates.length > 0 && (
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:1400px; margin:0 auto; padding:64px 24px;">
        <div style="display:grid; grid-template-columns:1fr; gap:32px; margin-bottom:36px;" class="thesis-grid">
          <div>
            <p class="eyebrow">&sect; IV &mdash; Credentials</p>
            <p class="numplate" style="color:var(--ink-300); margin-top:8px;">{String(myCertificates.length).padStart(3, '0')} ISSUED</p>
          </div>
          <div>
            <h2 class="font-display" style="font-size:clamp(2rem, 5vw, 4rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0;">
              Verifiable<br/>
              <span style="font-style:italic; font-weight:300; color:var(--ink-500);">credentials.</span>
            </h2>
          </div>
        </div>

        <div style="display:grid; grid-template-columns:1fr; gap:1px; background:rgba(11,14,20,0.15); border:1px solid rgba(11,14,20,0.15);" class="schools-grid">
          {myCertificates.map((cert: any) => (
            <a href={'/credentials/' + cert.credential_number} class="tile" style="padding:24px;">
              <div>
                <p class="numplate" style="color:var(--gold);">CERTIFICATE OF COMPLETION</p>
                <h3 class="font-display" style="font-size:1.3rem; margin-top:12px; line-height:1.15; letter-spacing:-0.02em; font-weight:500;">{cert.course_title}</h3>
              </div>
              <div style="margin-top:20px; padding-top:12px; border-top:1px solid var(--rule); display:flex; justify-content:space-between;" class="numplate">
                <span style="color:var(--ink-300);">{cert.credential_number}</span>
                <span style="color:var(--ink-300);">{ago(cert.issued_at)}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Footer CTAs -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:64px 24px; display:flex; gap:14px; flex-wrap:wrap; justify-content:center;">
      <a href="/aquintutor/courses" class="btn-pill outline">Browse the catalogue &rarr;</a>
      <a href="/aquintutor/schools" class="btn-pill outline">Browse schools</a>
      <a href="/aquintutor/rewards" class="btn-pill outline">View rewards &amp; rank</a>
      <a href="/aquintutor/test/quantum-challenge-100" class="btn-pill filled">Sit the Quantum Challenge &rarr;</a>
    </div>
  </section>

</AquintutorLayout>
