---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Function Plotter — AquinTutor Labs" description="Real-time mathematical function plotter with derivatives, integrals, and critical-point detection.">
<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; font-family: 'Inter', system-ui, sans-serif; }
  main { max-width: 1400px; margin: 0 auto; padding: 28px 22px 80px; }
  .eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; }
  h1 { font-family: 'Cormorant Garamond', serif; font-size: 34px; font-weight: 600; letter-spacing: -0.02em; margin: 6px 0 4px; }
  h1 em { color: #67e8f9; font-weight: 500; font-style: italic; }
  .lede { color: #9aa1ad; max-width: 720px; font-size: 14px; line-height: 1.55; margin-bottom: 22px; }
  .layout { display: grid; grid-template-columns: 1fr 340px; gap: 18px; align-items: start; }
  @media (max-width: 980px) { .layout { grid-template-columns: 1fr; } }
  .panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 16px; }
  .panel h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 12px; }
  .field { margin-bottom: 12px; }
  .field label { display: block; font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: #9aa1ad; margin-bottom: 5px; }
  input[type="text"], input[type="number"] { background: #0a0a0c; border: 1px solid #2a2a35; color: #fff; padding: 7px 10px; border-radius: 5px; font-family: 'Geist Mono', monospace; font-size: 12px; width: 100%; box-sizing: border-box; }
  input[type="range"] { width: 100%; accent-color: #67e8f9; }
  .row { display: flex; gap: 8px; align-items: center; }
  .row > * { flex: 1; }
  .btn { background: #67e8f9; color: #04161b; padding: 9px 14px; border-radius: 6px; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; border: none; cursor: pointer; }
  .btn:hover { background: #a5f3fc; }
  .btn.ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
  .btn.ghost:hover { border-color: #67e8f9; color: #67e8f9; }
  .btn-row { display: flex; gap: 6px; flex-wrap: wrap; }
  .preset-btn { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; padding: 6px 10px; border-radius: 5px; font-family: 'Geist Mono', monospace; font-size: 10px; cursor: pointer; }
  .preset-btn:hover { border-color: #67e8f9; color: #67e8f9; }
  .canvas-wrap { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 10px; overflow: hidden; position: relative; touch-action: none; }
  svg.plot { display: block; width: 100%; height: auto; cursor: grab; }
  svg.plot:active { cursor: grabbing; }
  .hud { position: absolute; top: 10px; left: 12px; font-family: 'Geist Mono', monospace; font-size: 11px; color: #9aa1ad; background: rgba(10,10,12,0.85); padding: 6px 9px; border-radius: 5px; border: 1px solid #2a2a35; pointer-events: none; }
  .legend { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 10px; font-family: 'Geist Mono', monospace; font-size: 11px; }
  .legend-item { display: flex; align-items: center; gap: 6px; color: #cfd6da; }
  .sw { width: 14px; height: 3px; border-radius: 2px; }
  .toggles { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 10px; }
  .tog { background: transparent; color: #9aa1ad; border: 1px solid #2a2a35; padding: 5px 9px; border-radius: 4px; font-family: 'Geist Mono', monospace; font-size: 10px; cursor: pointer; letter-spacing: 0.06em; text-transform: uppercase; }
  .tog.on { background: #67e8f9; color: #04161b; border-color: #67e8f9; font-weight: 700; }
  table { width: 100%; border-collapse: collapse; font-family: 'Geist Mono', monospace; font-size: 11px; }
  th { text-align: left; padding: 5px 6px; color: #67e8f9; font-weight: 700; border-bottom: 1px solid #2a2a35; }
  td { padding: 4px 6px; color: #cfd6da; border-bottom: 1px solid rgba(42,42,53,0.5); }
  .stat { display: flex; justify-content: space-between; padding: 5px 0; font-family: 'Geist Mono', monospace; font-size: 11px; color: #cfd6da; border-bottom: 1px solid rgba(42,42,53,0.5); }
  .stat strong { color: #67e8f9; font-weight: 700; }
  .err { background: #2a1014; border: 1px solid #7a1d28; color: #fca5a5; font-family: 'Geist Mono', monospace; font-size: 11px; padding: 7px 10px; border-radius: 5px; margin-top: 6px; }
  .err.hidden { display: none; }
  .mode-tabs { display: flex; gap: 4px; margin-bottom: 12px; border-bottom: 1px solid #2a2a35; }
  .mode-tab { background: transparent; color: #9aa1ad; border: none; padding: 8px 12px; font-family: 'Geist Mono', monospace; font-size: 11px; cursor: pointer; letter-spacing: 0.08em; text-transform: uppercase; border-bottom: 2px solid transparent; }
  .mode-tab.on { color: #67e8f9; border-bottom-color: #67e8f9; font-weight: 700; }
  small.hint { color: #67737f; font-family: 'Geist Mono', monospace; font-size: 10px; display: block; margin-top: 4px; }
  .crit-list { max-height: 140px; overflow-y: auto; font-family: 'Geist Mono', monospace; font-size: 10px; color: #cfd6da; }
  .crit-item { padding: 3px 0; border-bottom: 1px solid rgba(42,42,53,0.5); display: flex; gap: 8px; }
  .crit-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; margin-top: 4px; }
  .table-wrap { max-height: 220px; overflow-y: auto; }
</style>

<main>
  <div class="eyebrow">AquinTutor / Virtual Labs</div>
  <h1>Function <em>plotter</em></h1>
  <p class="lede">Real expression parser, RK-quality numerical derivatives, trapezoidal integration over ~1000 segments, and automatic detection of zero crossings, local maxima, and local minima. Pan with drag, zoom with wheel. Comma-separate functions for overlay. Parametric mode for Lissajous-style curves.</p>

  <div class="layout">
    <div class="canvas-wrap" id="canvasWrap">
      <div class="hud" id="hud">x: 0.000   y: 0.000   scale: 50 px/unit</div>
      <svg class="plot" id="plot" viewBox="0 0 800 600" preserveAspectRatio="xMidYMid meet"></svg>
    </div>

    <div>
      <div class="panel">
        <h3>Function input</h3>
        <div class="mode-tabs">
          <button class="mode-tab on" data-mode="cartesian" id="tabCart">y = f(x)</button>
          <button class="mode-tab" data-mode="parametric" id="tabParam">Parametric</button>
        </div>

        <div id="cartFields">
          <div class="field">
            <label>f(x) (comma-separated)</label>
            <input type="text" id="fxInput" value="sin(x), x^2/4" />
            <small class="hint">e.g. sin(x), exp(-x^2), 1/x, log(x)</small>
            <div class="err hidden" id="fxErr"></div>
          </div>
        </div>

        <div id="paramFields" style="display:none">
          <div class="field">
            <label>x(t)</label>
            <input type="text" id="pxInput" value="sin(3*t)" />
          </div>
          <div class="field">
            <label>y(t)</label>
            <input type="text" id="pyInput" value="cos(5*t)" />
          </div>
          <div class="row">
            <div class="field">
              <label>t min</label>
              <input type="number" id="tMin" value="0" step="0.1" />
            </div>
            <div class="field">
              <label>t max</label>
              <input type="number" id="tMax" value="6.283" step="0.1" />
            </div>
          </div>
          <div class="err hidden" id="pErr"></div>
        </div>

        <div class="btn-row" style="margin-top:8px">
          <button class="btn" id="plotBtn">Plot</button>
          <button class="btn ghost" id="resetBtn">Reset view</button>
        </div>
      </div>

      <div class="panel" style="margin-top:14px">
        <h3>Presets</h3>
        <div class="btn-row">
          <button class="preset-btn" data-p="sin(x)">sin x</button>
          <button class="preset-btn" data-p="x^2">x^2</button>
          <button class="preset-btn" data-p="exp(-x^2)">Gaussian</button>
          <button class="preset-btn" data-p="1/x">1/x</button>
          <button class="preset-btn" data-p="log(x)">log x</button>
          <button class="preset-btn" data-p="tan(x)">tan x</button>
          <button class="preset-btn" data-p="sin(x)/x">sinc</button>
          <button class="preset-btn" data-p="sin(x), cos(x)">sin &amp; cos</button>
          <button class="preset-btn" data-p="x^3 - 3*x">cubic</button>
          <button class="preset-btn" id="presetLissajous">Lissajous</button>
        </div>
      </div>

      <div class="panel" style="margin-top:14px">
        <h3>Calculus overlays</h3>
        <div class="toggles">
          <button class="tog" id="togDeriv">Derivative</button>
          <button class="tog" id="togInteg">Integral</button>
          <button class="tog on" id="togCrit">Critical pts</button>
          <button class="tog on" id="togGrid">Grid</button>
        </div>
        <div id="integralCtrl" style="display:none">
          <div class="field">
            <label>a (lower) <span id="aVal" style="color:#67e8f9">-2.00</span></label>
            <input type="range" id="aSlider" min="-10" max="10" step="0.05" value="-2" />
          </div>
          <div class="field">
            <label>b (upper) <span id="bVal" style="color:#67e8f9">2.00</span></label>
            <input type="range" id="bSlider" min="-10" max="10" step="0.05" value="2" />
          </div>
          <div class="stat"><span>&int;<sub>a</sub><sup>b</sup> f(x) dx</span><strong id="integVal">0.0000</strong></div>
        </div>
      </div>

      <div class="panel" style="margin-top:14px">
        <h3>Critical points</h3>
        <div class="crit-list" id="critList">Plot a function to detect zeros, maxima, minima.</div>
      </div>

      <div class="panel" style="margin-top:14px">
        <h3>Table of values</h3>
        <div class="row" style="margin-bottom:8px">
          <div class="field" style="margin:0">
            <label>x step</label>
            <input type="number" id="stepInput" value="0.5" step="0.1" min="0.05" />
          </div>
          <div class="field" style="margin:0">
            <label>count</label>
            <input type="number" id="countInput" value="20" min="3" max="100" />
          </div>
        </div>
        <div class="table-wrap">
          <table id="valTable">
            <thead><tr><th>x</th><th>f(x)</th><th>f'(x)</th></tr></thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <div class="legend" id="legend"></div>
</main>

<script is:inline>
(function () {
  'use strict';

  // ---------- Expression Parser ----------
  // Whitelist of allowed identifiers
  const SAFE_GLOBALS = {
    sin: Math.sin, cos: Math.cos, tan: Math.tan,
    asin: Math.asin, acos: Math.acos, atan: Math.atan, atan2: Math.atan2,
    sinh: Math.sinh, cosh: Math.cosh, tanh: Math.tanh,
    log: Math.log10 || function (v) { return Math.log(v) / Math.LN10; },
    ln: Math.log, log2: Math.log2,
    exp: Math.exp, sqrt: Math.sqrt, cbrt: Math.cbrt,
    abs: Math.abs, sign: Math.sign,
    floor: Math.floor, ceil: Math.ceil, round: Math.round,
    min: Math.min, max: Math.max, pow: Math.pow,
    pi: Math.PI, e: Math.E, tau: Math.PI * 2
  };

  // Convert "^" to "**" and validate / compile
  function compile(expr, vars) {
    // Replace ^ with ** (but not **)
    let src = String(expr).replace(/\*\*/g, '@@POW@@').replace(/\^/g, '**').replace(/@@POW@@/g, '**');
    // Strip whitespace
    src = src.trim();
    if (!src) throw new Error('empty expression');
    // Whitelist check: only allow [0-9.+\-*/()%, ] and identifiers from SAFE_GLOBALS or vars
    const ident = src.match(/[A-Za-z_][A-Za-z0-9_]*/g) || [];
    const allowed = Object.assign({}, SAFE_GLOBALS);
    for (const v of vars) allowed[v] = true;
    for (const id of ident) {
      if (!(id in allowed)) {
        throw new Error('unknown identifier: ' + id);
      }
    }
    // Build the body
    const params = vars.join(',');
    const globalsList = Object.keys(SAFE_GLOBALS);
    const argList = globalsList.join(',');
    // The function is constructed in isolation; we pass values for safe globals
    const fn = new Function(params + ',' + argList, 'return (' + src + ');');
    const safeValues = globalsList.map(k => SAFE_GLOBALS[k]);
    return function () {
      const args = Array.prototype.slice.call(arguments).concat(safeValues);
      return fn.apply(null, args);
    };
  }

  // ---------- State ----------
  const state = {
    mode: 'cartesian',
    functions: [],     // [{src, fn, color}]
    colors: ['#67e8f9', '#fca5a5', '#a7f3d0', '#fde68a', '#c4b5fd', '#fdba74'],
    cx: 0, cy: 0,      // world-space center
    scale: 50,         // pixels per unit
    width: 800, height: 600,
    showDeriv: false, showInteg: false, showCrit: true, showGrid: true,
    a: -2, b: 2, integValue: 0,
    paramFn: null, paramErr: '',
    critPoints: [] // [{type, x, y, color}]
  };

  // ---------- DOM ----------
  const $ = (id) => document.getElementById(id);
  const svg = $('plot');
  const wrap = $('canvasWrap');
  const hud = $('hud');
  const legend = $('legend');
  const critList = $('critList');

  const SVG_NS = 'http://www.w3.org/2000/svg';
  function el(name, attrs, parent) {
    const n = document.createElementNS(SVG_NS, name);
    if (attrs) for (const k in attrs) n.setAttribute(k, attrs[k]);
    if (parent) parent.appendChild(n);
    return n;
  }

  // ---------- World ↔ Screen ----------
  function w2sx(x) { return state.width / 2 + (x - state.cx) * state.scale; }
  function w2sy(y) { return state.height / 2 - (y - state.cy) * state.scale; }
  function s2wx(px) { return state.cx + (px - state.width / 2) / state.scale; }
  function s2wy(py) { return state.cy - (py - state.height / 2) / state.scale; }

  // ---------- Renderer ----------
  function render() {
    while (svg.firstChild) svg.removeChild(svg.firstChild);

    const W = state.width, H = state.height;
    // Background
    el('rect', { x: 0, y: 0, width: W, height: H, fill: '#0a0a0c' }, svg);

    if (state.showGrid) drawGrid();
    drawAxes();

    if (state.mode === 'cartesian') {
      drawCartesian();
    } else {
      drawParametric();
    }

    drawHudListener();
  }

  function niceStep(rangeUnits) {
    // Choose a major step so that ~6-12 majors fit
    const target = rangeUnits / 8;
    const pow = Math.pow(10, Math.floor(Math.log10(target)));
    const n = target / pow;
    let step;
    if (n < 1.5) step = 1;
    else if (n < 3.5) step = 2;
    else if (n < 7.5) step = 5;
    else step = 10;
    return step * pow;
  }

  function drawGrid() {
    const W = state.width, H = state.height;
    const xMin = s2wx(0), xMax = s2wx(W);
    const yMin = s2wy(H), yMax = s2wy(0);
    const majX = niceStep(xMax - xMin);
    const majY = niceStep(yMax - yMin);

    // Minor lines (5 subdivisions)
    const minX = majX / 5;
    const minY = majY / 5;

    const xStart = Math.floor(xMin / minX) * minX;
    for (let x = xStart; x <= xMax; x += minX) {
      const isMajor = Math.abs(x / majX - Math.round(x / majX)) < 1e-9;
      el('line', {
        x1: w2sx(x), y1: 0, x2: w2sx(x), y2: H,
        stroke: isMajor ? '#1a1d26' : '#13151c', 'stroke-width': isMajor ? 1 : 0.5
      }, svg);
    }
    const yStart = Math.floor(yMin / minY) * minY;
    for (let y = yStart; y <= yMax; y += minY) {
      const isMajor = Math.abs(y / majY - Math.round(y / majY)) < 1e-9;
      el('line', {
        x1: 0, y1: w2sy(y), x2: W, y2: w2sy(y),
        stroke: isMajor ? '#1a1d26' : '#13151c', 'stroke-width': isMajor ? 1 : 0.5
      }, svg);
    }

    // Axis labels at major grid
    const labelColor = '#5a6470';
    const labelFont = '10px Geist Mono, monospace';
    for (let x = Math.ceil(xMin / majX) * majX; x <= xMax; x += majX) {
      if (Math.abs(x) < 1e-9) continue;
      const t = el('text', {
        x: w2sx(x), y: w2sy(0) + 12,
        fill: labelColor, 'font-family': 'Geist Mono, monospace',
        'font-size': 10, 'text-anchor': 'middle'
      }, svg);
      t.textContent = fmtNum(x);
    }
    for (let y = Math.ceil(yMin / majY) * majY; y <= yMax; y += majY) {
      if (Math.abs(y) < 1e-9) continue;
      const t = el('text', {
        x: w2sx(0) + 4, y: w2sy(y) + 3,
        fill: labelColor, 'font-family': 'Geist Mono, monospace',
        'font-size': 10
      }, svg);
      t.textContent = fmtNum(y);
    }
  }

  function fmtNum(v) {
    if (Math.abs(v) < 1e-9) return '0';
    if (Math.abs(v) >= 10000 || Math.abs(v) < 0.001) return v.toExponential(1);
    return parseFloat(v.toFixed(3)).toString();
  }

  function drawAxes() {
    const W = state.width, H = state.height;
    const ax = w2sx(0), ay = w2sy(0);
    el('line', { x1: 0, y1: ay, x2: W, y2: ay, stroke: '#3a414e', 'stroke-width': 1.2 }, svg);
    el('line', { x1: ax, y1: 0, x2: ax, y2: H, stroke: '#3a414e', 'stroke-width': 1.2 }, svg);
    const xl = el('text', { x: W - 12, y: ay - 6, fill: '#9aa1ad', 'font-family': 'Cormorant Garamond, serif', 'font-style': 'italic', 'font-size': 14, 'text-anchor': 'end' }, svg);
    xl.textContent = 'x';
    const yl = el('text', { x: ax + 8, y: 14, fill: '#9aa1ad', 'font-family': 'Cormorant Garamond, serif', 'font-style': 'italic', 'font-size': 14 }, svg);
    yl.textContent = 'y';
  }

  function drawCartesian() {
    const W = state.width;
    const xMin = s2wx(0), xMax = s2wx(W);
    const STEPS = 1200;
    const dx = (xMax - xMin) / STEPS;
    state.critPoints = [];

    // Integral shading
    if (state.showInteg && state.functions[0]) {
      drawIntegral(state.functions[0]);
    }

    for (let fi = 0; fi < state.functions.length; fi++) {
      const f = state.functions[fi];
      let path = '';
      let prevY = null, prevValid = false;
      const ys = new Array(STEPS + 1);

      for (let i = 0; i <= STEPS; i++) {
        const x = xMin + i * dx;
        let y;
        try { y = f.fn(x); } catch (e) { y = NaN; }
        if (!isFinite(y) || Math.abs(y) > 1e9) {
          ys[i] = NaN;
          prevValid = false;
          continue;
        }
        ys[i] = y;
        const sx = w2sx(x), sy = w2sy(y);
        // Discontinuity guard: jump > screen height
        if (prevValid && Math.abs(y - prevY) > (state.height / state.scale) * 1.5) {
          path += ' M ' + sx + ' ' + sy;
        } else {
          path += (prevValid ? ' L ' : ' M ') + sx + ' ' + sy;
        }
        prevY = y; prevValid = true;
      }
      el('path', { d: path, fill: 'none', stroke: f.color, 'stroke-width': 2, 'stroke-linejoin': 'round' }, svg);

      // Derivative overlay (numerical, central difference)
      if (state.showDeriv) {
        let dpath = '';
        let dPrevValid = false;
        const h = dx;
        for (let i = 1; i < STEPS; i++) {
          const x = xMin + i * dx;
          let yp;
          try {
            const y1 = f.fn(x + h);
            const y0 = f.fn(x - h);
            yp = (y1 - y0) / (2 * h);
          } catch (e) { yp = NaN; }
          if (!isFinite(yp) || Math.abs(yp) > 1e6) { dPrevValid = false; continue; }
          const sx = w2sx(x), sy = w2sy(yp);
          dpath += (dPrevValid ? ' L ' : ' M ') + sx + ' ' + sy;
          dPrevValid = true;
        }
        el('path', { d: dpath, fill: 'none', stroke: f.color, 'stroke-width': 1.2, 'stroke-dasharray': '4 3', opacity: 0.7 }, svg);
      }

      // Critical points: zeros + extrema (only first function for clarity)
      if (state.showCrit && fi === 0) {
        detectCritical(f, ys, xMin, dx, STEPS);
      }
    }

    // Draw critical-point markers
    for (const cp of state.critPoints) {
      const sx = w2sx(cp.x), sy = w2sy(cp.y);
      el('circle', { cx: sx, cy: sy, r: 4.5, fill: cp.color, stroke: '#0a0a0c', 'stroke-width': 1.5 }, svg);
      const lbl = el('text', {
        x: sx + 7, y: sy - 7,
        fill: cp.color, 'font-family': 'Geist Mono, monospace',
        'font-size': 9
      }, svg);
      lbl.textContent = cp.type + ' (' + fmtNum(cp.x) + ', ' + fmtNum(cp.y) + ')';
    }
  }

  function detectCritical(f, ys, xMin, dx, STEPS) {
    // Zero crossings: sign change between consecutive samples → bisection refine
    for (let i = 1; i <= STEPS; i++) {
      if (!isFinite(ys[i - 1]) || !isFinite(ys[i])) continue;
      if (ys[i - 1] * ys[i] < 0) {
        let lo = xMin + (i - 1) * dx, hi = xMin + i * dx;
        for (let k = 0; k < 40; k++) {
          const m = (lo + hi) / 2;
          const fm = f.fn(m);
          if (!isFinite(fm)) break;
          if (fm * f.fn(lo) < 0) hi = m; else lo = m;
        }
        const xr = (lo + hi) / 2;
        state.critPoints.push({ type: 'zero', x: xr, y: 0, color: '#fde68a' });
      }
    }
    // Extrema: derivative sign change (using numerical f')
    const h = dx;
    const der = new Array(STEPS + 1);
    for (let i = 0; i <= STEPS; i++) {
      const x = xMin + i * dx;
      try {
        der[i] = (f.fn(x + h) - f.fn(x - h)) / (2 * h);
      } catch (e) { der[i] = NaN; }
    }
    for (let i = 1; i < STEPS; i++) {
      if (!isFinite(der[i - 1]) || !isFinite(der[i + 1])) continue;
      if (der[i - 1] * der[i + 1] < 0) {
        const x = xMin + i * dx;
        let y;
        try { y = f.fn(x); } catch (e) { continue; }
        if (!isFinite(y)) continue;
        const isMax = der[i - 1] > 0 && der[i + 1] < 0;
        state.critPoints.push({
          type: isMax ? 'max' : 'min',
          x, y,
          color: isMax ? '#a7f3d0' : '#fca5a5'
        });
      }
    }
    // Cap at 40 to avoid clutter
    if (state.critPoints.length > 40) state.critPoints = state.critPoints.slice(0, 40);
    renderCritList();
  }

  function renderCritList() {
    if (!state.critPoints.length) {
      critList.innerHTML = '<span style="color:#67737f">No critical points in current view.</span>';
      return;
    }
    let html = '';
    for (const cp of state.critPoints) {
      html += '<div class="crit-item"><div class="crit-dot" style="background:' + cp.color + '"></div>';
      html += '<div>' + cp.type.toUpperCase() + ' at x = ' + fmtNum(cp.x) + ',&nbsp; y = ' + fmtNum(cp.y) + '</div></div>';
    }
    critList.innerHTML = html;
  }

  function drawIntegral(f) {
    const a = Math.min(state.a, state.b);
    const b = Math.max(state.a, state.b);
    const N = 1000;
    const dx = (b - a) / N;
    let path = 'M ' + w2sx(a) + ' ' + w2sy(0);
    let sum = 0;
    for (let i = 0; i <= N; i++) {
      const x = a + i * dx;
      let y; try { y = f.fn(x); } catch (e) { y = NaN; }
      if (!isFinite(y)) y = 0;
      path += ' L ' + w2sx(x) + ' ' + w2sy(y);
      if (i > 0) {
        let yp; try { yp = f.fn(a + (i - 1) * dx); } catch (e) { yp = NaN; }
        if (!isFinite(yp)) yp = 0;
        sum += (y + yp) * 0.5 * dx;
      }
    }
    path += ' L ' + w2sx(b) + ' ' + w2sy(0) + ' Z';
    el('path', { d: path, fill: '#67e8f9', opacity: 0.18, stroke: '#67e8f9', 'stroke-width': 1 }, svg);
    state.integValue = sum;
    $('integVal').textContent = sum.toFixed(4);
  }

  function drawParametric() {
    if (!state.paramFn) return;
    const { fx, fy, tMin, tMax } = state.paramFn;
    const N = 2000;
    const dt = (tMax - tMin) / N;
    let path = '';
    let prevValid = false;
    for (let i = 0; i <= N; i++) {
      const t = tMin + i * dt;
      let x, y;
      try { x = fx(t); y = fy(t); } catch (e) { prevValid = false; continue; }
      if (!isFinite(x) || !isFinite(y)) { prevValid = false; continue; }
      const sx = w2sx(x), sy = w2sy(y);
      path += (prevValid ? ' L ' : ' M ') + sx + ' ' + sy;
      prevValid = true;
    }
    el('path', { d: path, fill: 'none', stroke: '#67e8f9', 'stroke-width': 1.5 }, svg);
  }

  // ---------- HUD on hover ----------
  let hudListenerAttached = false;
  function drawHudListener() {
    if (hudListenerAttached) return;
    hudListenerAttached = true;
    svg.addEventListener('mousemove', (e) => {
      const r = svg.getBoundingClientRect();
      const px = (e.clientX - r.left) * (state.width / r.width);
      const py = (e.clientY - r.top) * (state.height / r.height);
      const wx = s2wx(px), wy = s2wy(py);
      let extra = '';
      if (state.mode === 'cartesian' && state.functions[0]) {
        try {
          const fy = state.functions[0].fn(wx);
          if (isFinite(fy)) extra = '   f(x): ' + fy.toFixed(4);
        } catch (e) { /* */ }
      }
      hud.textContent = 'x: ' + wx.toFixed(3) + '   y: ' + wy.toFixed(3) + '   scale: ' + state.scale.toFixed(0) + ' px/unit' + extra;
    });
  }

  // ---------- Pan & Zoom ----------
  let dragging = false, dragStart = null, dragCenter = null;
  svg.addEventListener('mousedown', (e) => {
    dragging = true;
    dragStart = { x: e.clientX, y: e.clientY };
    dragCenter = { cx: state.cx, cy: state.cy };
  });
  window.addEventListener('mousemove', (e) => {
    if (!dragging) return;
    const r = svg.getBoundingClientRect();
    const dx = (e.clientX - dragStart.x) * (state.width / r.width);
    const dy = (e.clientY - dragStart.y) * (state.height / r.height);
    state.cx = dragCenter.cx - dx / state.scale;
    state.cy = dragCenter.cy + dy / state.scale;
    render();
  });
  window.addEventListener('mouseup', () => { dragging = false; });

  svg.addEventListener('wheel', (e) => {
    e.preventDefault();
    const r = svg.getBoundingClientRect();
    const px = (e.clientX - r.left) * (state.width / r.width);
    const py = (e.clientY - r.top) * (state.height / r.height);
    const wxBefore = s2wx(px), wyBefore = s2wy(py);
    const factor = e.deltaY < 0 ? 1.15 : 1 / 1.15;
    state.scale *= factor;
    state.scale = Math.max(2, Math.min(2000, state.scale));
    // Keep cursor anchored
    const wxAfter = s2wx(px), wyAfter = s2wy(py);
    state.cx += wxBefore - wxAfter;
    state.cy += wyBefore - wyAfter;
    render();
  }, { passive: false });

  // Touch (pinch)
  let pinchDist = null, pinchScale = null, pinchCenter = null;
  svg.addEventListener('touchstart', (e) => {
    if (e.touches.length === 2) {
      pinchDist = touchDist(e.touches);
      pinchScale = state.scale;
      const r = svg.getBoundingClientRect();
      pinchCenter = {
        px: ((e.touches[0].clientX + e.touches[1].clientX) / 2 - r.left) * (state.width / r.width),
        py: ((e.touches[0].clientY + e.touches[1].clientY) / 2 - r.top) * (state.height / r.height)
      };
      pinchCenter.wx = s2wx(pinchCenter.px);
      pinchCenter.wy = s2wy(pinchCenter.py);
    } else if (e.touches.length === 1) {
      dragging = true;
      dragStart = { x: e.touches[0].clientX, y: e.touches[0].clientY };
      dragCenter = { cx: state.cx, cy: state.cy };
    }
  });
  svg.addEventListener('touchmove', (e) => {
    e.preventDefault();
    if (e.touches.length === 2 && pinchDist) {
      const d = touchDist(e.touches);
      state.scale = Math.max(2, Math.min(2000, pinchScale * (d / pinchDist)));
      const wxAfter = s2wx(pinchCenter.px), wyAfter = s2wy(pinchCenter.py);
      state.cx += pinchCenter.wx - wxAfter;
      state.cy += pinchCenter.wy - wyAfter;
      render();
    } else if (e.touches.length === 1 && dragging) {
      const r = svg.getBoundingClientRect();
      const dx = (e.touches[0].clientX - dragStart.x) * (state.width / r.width);
      const dy = (e.touches[0].clientY - dragStart.y) * (state.height / r.height);
      state.cx = dragCenter.cx - dx / state.scale;
      state.cy = dragCenter.cy + dy / state.scale;
      render();
    }
  }, { passive: false });
  svg.addEventListener('touchend', () => { dragging = false; pinchDist = null; });
  function touchDist(ts) { const dx = ts[0].clientX - ts[1].clientX, dy = ts[0].clientY - ts[1].clientY; return Math.sqrt(dx * dx + dy * dy); }

  // ---------- Inputs ----------
  function parseFunctions() {
    const raw = $('fxInput').value;
    const parts = raw.split(',').map(s => s.trim()).filter(Boolean);
    const out = [];
    for (let i = 0; i < parts.length; i++) {
      try {
        const fn = compile(parts[i], ['x']);
        // Sanity check
        const t = fn(1);
        if (typeof t !== 'number') throw new Error('not a number');
        out.push({ src: parts[i], fn, color: state.colors[i % state.colors.length] });
      } catch (e) {
        $('fxErr').textContent = 'Error in "' + parts[i] + '": ' + e.message;
        $('fxErr').classList.remove('hidden');
        return null;
      }
    }
    $('fxErr').classList.add('hidden');
    return out;
  }

  function parseParametric() {
    try {
      const fx = compile($('pxInput').value, ['t']);
      const fy = compile($('pyInput').value, ['t']);
      const tMin = parseFloat($('tMin').value);
      const tMax = parseFloat($('tMax').value);
      // sanity
      fx(0); fy(0);
      $('pErr').classList.add('hidden');
      return { fx, fy, tMin, tMax };
    } catch (e) {
      $('pErr').textContent = 'Error: ' + e.message;
      $('pErr').classList.remove('hidden');
      return null;
    }
  }

  function renderLegend() {
    legend.innerHTML = '';
    if (state.mode === 'parametric') {
      legend.innerHTML = '<div class="legend-item"><div class="sw" style="background:#67e8f9"></div>parametric (x(t), y(t))</div>';
      return;
    }
    for (const f of state.functions) {
      const item = document.createElement('div');
      item.className = 'legend-item';
      item.innerHTML = '<div class="sw" style="background:' + f.color + '"></div>y = ' + escapeHtml(f.src);
      legend.appendChild(item);
    }
    if (state.showDeriv) {
      const item = document.createElement('div');
      item.className = 'legend-item';
      item.innerHTML = '<div class="sw" style="background:#67e8f9;height:1px;border-top:2px dashed #67e8f9"></div>derivative f\'(x)';
      legend.appendChild(item);
    }
    if (state.showCrit) {
      legend.innerHTML += '<div class="legend-item"><div class="sw" style="background:#fde68a;border-radius:50%;width:8px;height:8px"></div>zero</div>';
      legend.innerHTML += '<div class="legend-item"><div class="sw" style="background:#a7f3d0;border-radius:50%;width:8px;height:8px"></div>max</div>';
      legend.innerHTML += '<div class="legend-item"><div class="sw" style="background:#fca5a5;border-radius:50%;width:8px;height:8px"></div>min</div>';
    }
  }
  function escapeHtml(s) { return String(s).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]); }

  function renderTable() {
    const tbody = $('valTable').querySelector('tbody');
    tbody.innerHTML = '';
    if (state.mode !== 'cartesian' || !state.functions[0]) return;
    const step = parseFloat($('stepInput').value) || 0.5;
    const count = Math.min(100, Math.max(3, parseInt($('countInput').value) || 20));
    const f = state.functions[0].fn;
    const x0 = state.cx - (count * step) / 2;
    const h = Math.max(1e-6, step * 0.01);
    for (let i = 0; i < count; i++) {
      const x = x0 + i * step;
      let y, yp;
      try { y = f(x); yp = (f(x + h) - f(x - h)) / (2 * h); } catch (e) { y = NaN; yp = NaN; }
      const tr = document.createElement('tr');
      tr.innerHTML = '<td>' + fmtNum(x) + '</td><td>' + (isFinite(y) ? y.toFixed(4) : '—') + '</td><td>' + (isFinite(yp) ? yp.toFixed(4) : '—') + '</td>';
      tbody.appendChild(tr);
    }
  }

  function doPlot() {
    if (state.mode === 'cartesian') {
      const fns = parseFunctions();
      if (!fns) return;
      state.functions = fns;
    } else {
      const p = parseParametric();
      if (!p) return;
      state.paramFn = p;
    }
    render();
    renderLegend();
    renderTable();
  }

  function reset() {
    state.cx = 0; state.cy = 0; state.scale = 50;
    render();
  }

  // ---------- Wire UI ----------
  $('plotBtn').addEventListener('click', doPlot);
  $('resetBtn').addEventListener('click', reset);
  $('fxInput').addEventListener('keydown', (e) => { if (e.key === 'Enter') doPlot(); });
  $('pxInput').addEventListener('keydown', (e) => { if (e.key === 'Enter') doPlot(); });
  $('pyInput').addEventListener('keydown', (e) => { if (e.key === 'Enter') doPlot(); });

  document.querySelectorAll('.preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const p = btn.getAttribute('data-p');
      if (p) {
        switchMode('cartesian');
        $('fxInput').value = p;
        doPlot();
      }
    });
  });
  $('presetLissajous').addEventListener('click', () => {
    switchMode('parametric');
    $('pxInput').value = 'sin(3*t)';
    $('pyInput').value = 'cos(5*t)';
    $('tMin').value = '0';
    $('tMax').value = '6.283';
    doPlot();
  });

  function switchMode(m) {
    state.mode = m;
    $('tabCart').classList.toggle('on', m === 'cartesian');
    $('tabParam').classList.toggle('on', m === 'parametric');
    $('cartFields').style.display = m === 'cartesian' ? '' : 'none';
    $('paramFields').style.display = m === 'parametric' ? '' : 'none';
  }
  $('tabCart').addEventListener('click', () => { switchMode('cartesian'); doPlot(); });
  $('tabParam').addEventListener('click', () => { switchMode('parametric'); doPlot(); });

  function bindTog(id, key, after) {
    $(id).addEventListener('click', () => {
      state[key] = !state[key];
      $(id).classList.toggle('on', state[key]);
      if (after) after();
      render(); renderLegend();
    });
  }
  bindTog('togDeriv', 'showDeriv');
  bindTog('togInteg', 'showInteg', () => { $('integralCtrl').style.display = state.showInteg ? '' : 'none'; });
  bindTog('togCrit', 'showCrit');
  bindTog('togGrid', 'showGrid');

  $('aSlider').addEventListener('input', () => { state.a = parseFloat($('aSlider').value); $('aVal').textContent = state.a.toFixed(2); render(); });
  $('bSlider').addEventListener('input', () => { state.b = parseFloat($('bSlider').value); $('bVal').textContent = state.b.toFixed(2); render(); });
  $('stepInput').addEventListener('input', renderTable);
  $('countInput').addEventListener('input', renderTable);

  // Initial
  doPlot();
})();
</script>
</BaseLayout>
