---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Function grapher — plots up to three y=f(x) expressions (whitelisted parser),
// with a live crosshair trace, zoom, and glow-line rendering on a depth-lit
// high-DPI canvas. No libraries.
---
<BaseLayout title="Grapher lab · Virtual Labs · AquinTutor" description="Type y = f(x) and watch it draw — up to three functions, a live trace, zoom, and glow-line rendering.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1320px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:18px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:300px minmax(0,1fr); gap:18px; } @media(max-width:900px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:16px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 12px; }
  .fn-row{ display:flex; align-items:center; gap:8px; margin-bottom:9px; }
  .fn-dot{ width:12px; height:12px; border-radius:3px; flex-shrink:0; }
  .fn-in{ flex:1; background:#080a12; border:1px solid #1e2740; color:#fff; padding:8px 10px; border-radius:6px; font-size:13px; font-family:'Geist Mono',monospace; outline:none; }
  .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.1em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; }
  .lb-row label span{ color:#5ee7ff; } .lb-row input[type=range]{ width:100%; accent-color:#5ee7ff; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); }
  .lb-stage canvas{ display:block; width:100%; height:auto; cursor:crosshair; }
  .hint{ font-family:'Inter Tight',sans-serif; font-size:11.5px; color:#8ea0be; line-height:1.5; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">Maths · Functions</p>
      <h1 class="lb-title">Function <em>grapher</em>.</h1>
    </div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>y = f(x)</h3>
        <div class="fn-row"><span class="fn-dot" style="background:#5ee7ff;"></span><input class="fn-in fn" data-i="0" value="sin(x)"/></div>
        <div class="fn-row"><span class="fn-dot" style="background:#fbbf24;"></span><input class="fn-in fn" data-i="1" value="0.2*x^2 - 2"/></div>
        <div class="fn-row"><span class="fn-dot" style="background:#f472b6;"></span><input class="fn-in fn" data-i="2" value=""/></div>
        <p class="hint" style="margin-top:8px;">Use x, +, −, *, /, ^, ( ). Functions: sin cos tan exp log sqrt abs. Constants: pi, e.</p>
      </div>
      <div class="lb-panel"><h3>View</h3><div class="lb-row">
        <label>Zoom (x-range ±) <span id="zV">6.3</span></label><input id="z" type="range" min="1" max="40" step="0.5" value="6.3"/>
      </div>
      <div style="margin-top:10px;font-family:'Geist Mono',monospace;font-size:12px;color:#cfd6da;" id="trace">move over the graph to trace</div>
      </div>
    </aside>
    <section><div class="lb-stage"><canvas id="scene" width="900" height="620"></canvas></div></section>
  </div>
</main>
<script is:inline>
(function(){
  var COLORS=['#5ee7ff','#fbbf24','#f472b6']; var fns=[null,null,null], errs=[false,false,false];
  function compile(expr){ if(!expr.trim()) return null; var e=expr.toLowerCase().replace(/\^/g,'**');
    var stripped=e.replace(/\b(sin|cos|tan|asin|acos|atan|sinh|cosh|tanh|exp|log|log10|log2|sqrt|cbrt|abs|sign|floor|ceil|round|pow|min|max|atan2|pi|e)\b/g,'').replace(/\*\*/g,'');
    if(/[^0-9x+\-*/(). ,\s]/.test(stripped)) throw new Error('bad');
    return new Function('x','with(Math){ return ('+e+'); }'); }
  function build(){ document.querySelectorAll('.fn').forEach(function(inp){ var i=+inp.getAttribute('data-i'); try{ fns[i]=compile(inp.value); errs[i]=false; inp.style.borderColor='#1e2740'; }catch(err){ fns[i]=null; errs[i]=true; inp.style.borderColor='#7a2f2f'; } }); }
  document.querySelectorAll('.fn').forEach(function(inp){ inp.addEventListener('input',build); }); build();
  document.getElementById('z').addEventListener('input',function(){ document.getElementById('zV').textContent=(+this.value).toFixed(1); });

  var cv=document.getElementById('scene'), mouse=null;
  cv.addEventListener('mousemove',function(e){ var r=cv.getBoundingClientRect(); mouse={x:(e.clientX-r.left)/r.width, y:(e.clientY-r.top)/r.height}; });
  cv.addEventListener('mouseleave',function(){ mouse=null; document.getElementById('trace').textContent='move over the graph to trace'; });
  function hidpi(c){ var r=c.getBoundingClientRect(), d=window.devicePixelRatio||1; var w=r.width||c.width, h=(c.height/c.width)*w; c.width=Math.round(w*d); c.height=Math.round(h*d); var ctx=c.getContext('2d'); ctx.setTransform(d,0,0,d,0,0); return {ctx:ctx,w:w,h:h}; }
  function draw(){ var s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h; var rx=+document.getElementById('z').value; var ry=rx*H/W;
    var bg=ctx.createLinearGradient(0,0,0,H); bg.addColorStop(0,'#0b1020'); bg.addColorStop(1,'#06080f'); ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    function X(x){ return (x+rx)/(2*rx)*W; } function Y(y){ return H-(y+ry)/(2*ry)*H; } function invX(px){ return px/W*2*rx-rx; }
    // grid
    var stepX=niceStep(rx); ctx.font="10px 'Geist Mono',monospace";
    for(var gx=Math.ceil(-rx/stepX)*stepX; gx<=rx; gx+=stepX){ ctx.strokeStyle=Math.abs(gx)<1e-9?'#38507a':'rgba(94,231,255,0.07)'; ctx.lineWidth=Math.abs(gx)<1e-9?1.5:1; ctx.beginPath(); ctx.moveTo(X(gx),0); ctx.lineTo(X(gx),H); ctx.stroke(); if(Math.abs(gx)>1e-9){ ctx.fillStyle='#5f7597'; ctx.fillText(gx.toFixed(stepX<1?1:0),X(gx)+3,Y(0)+12); } }
    var stepY=niceStep(ry); for(var gy=Math.ceil(-ry/stepY)*stepY; gy<=ry; gy+=stepY){ ctx.strokeStyle=Math.abs(gy)<1e-9?'#38507a':'rgba(94,231,255,0.07)'; ctx.lineWidth=Math.abs(gy)<1e-9?1.5:1; ctx.beginPath(); ctx.moveTo(0,Y(gy)); ctx.lineTo(W,Y(gy)); ctx.stroke(); if(Math.abs(gy)>1e-9){ ctx.fillStyle='#5f7597'; ctx.fillText(gy.toFixed(stepY<1?1:0),X(0)+4,Y(gy)-3); } }
    // functions
    fns.forEach(function(fn,idx){ if(!fn) return; ctx.save(); ctx.shadowColor=COLORS[idx]; ctx.shadowBlur=8; ctx.strokeStyle=COLORS[idx]; ctx.lineWidth=2; ctx.beginPath(); var pen=false, prevY=null;
      for(var px=0;px<=W;px++){ var x=invX(px); var y; try{ y=fn(x); }catch(e){ y=NaN; } if(!isFinite(y)){ pen=false; continue; } var py=Y(y);
        if(pen && Math.abs(py-prevY)>H){ pen=false; } // discontinuity guard
        if(!pen){ ctx.moveTo(px,py); pen=true; } else ctx.lineTo(px,py); prevY=py; } ctx.stroke(); ctx.restore(); });
    // trace
    if(mouse){ var tx=mouse.x*2*rx-rx; ctx.strokeStyle='rgba(255,255,255,0.25)'; ctx.setLineDash([4,4]); ctx.beginPath(); ctx.moveTo(X(tx),0); ctx.lineTo(X(tx),H); ctx.stroke(); ctx.setLineDash([]);
      var out='x = '+tx.toFixed(3); fns.forEach(function(fn,idx){ if(!fn) return; var yv; try{ yv=fn(tx); }catch(e){ yv=NaN; } if(isFinite(yv)){ ctx.save(); ctx.shadowColor=COLORS[idx]; ctx.shadowBlur=12; ctx.fillStyle=COLORS[idx]; ctx.beginPath(); ctx.arc(X(tx),Y(yv),5,0,7); ctx.fill(); ctx.restore(); out+='   f'+(idx+1)+'='+yv.toFixed(3); } }); document.getElementById('trace').textContent=out; }
  }
  function niceStep(range){ var raw=range/6, mag=Math.pow(10,Math.floor(Math.log(raw)/Math.LN10)), n=raw/mag; var m=n<1.5?1:n<3?2:n<7?5:10; return m*mag; }
  function loop(){ draw(); requestAnimationFrame(loop); } requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
