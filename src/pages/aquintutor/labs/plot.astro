---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Analysis grapher (advanced level). Beyond drawing y=f(x): it computes and
// overlays the numerical first and second derivatives (central differences),
// the cumulative integral F(x)=∫f with the signed area shaded, and it locates
// roots (bisection on sign changes), extrema (f'=0) and inflection points
// (f''=0) automatically. A movable expansion point builds the TAYLOR polynomial
// of adjustable order (derivatives via central-difference stencils up to 6th),
// overlaid so its convergence to f is visible. Whitelisted expression parser,
// no libraries.
---
<BaseLayout title="Analysis Grapher · Virtual Labs · AquinTutor" description="Advanced calculus: numerical derivatives f' and f'', the cumulative integral with signed area, automatic root/extremum/inflection detection, and an interactive Taylor-series approximation of adjustable order. Built from scratch.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1340px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:16px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:310px minmax(0,1fr); gap:18px; } @media(max-width:960px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:15px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 11px; }
  .fn-row{ display:flex; align-items:center; gap:8px; margin-bottom:8px; } .fn-dot{ width:12px; height:12px; border-radius:3px; flex-shrink:0; } .fn-in{ flex:1; background:#080a12; border:1px solid #1e2740; color:#fff; padding:8px 10px; border-radius:6px; font-size:13px; font-family:'Geist Mono',monospace; outline:none; }
  .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.1em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; } .lb-row label span{ color:#5ee7ff; } .lb-row input[type=range]{ width:100%; accent-color:#5ee7ff; }
  .lb-tog{ display:flex; flex-wrap:wrap; gap:6px; } .lb-tog button{ background:#0b1020; border:1px solid #26314f; color:#8ea0be; border-radius:7px; padding:5px 9px; font-family:'Geist Mono',monospace; font-size:10px; cursor:pointer; } .lb-tog button.on{ color:#04161b; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); } .lb-stage canvas{ display:block; width:100%; height:auto; cursor:crosshair; }
  .hint{ font-family:'Inter Tight',sans-serif; font-size:11.5px; color:#8ea0be; line-height:1.5; } .lb-read{ font-family:'Geist Mono',monospace; font-size:12px; color:#cfd6da; line-height:1.7; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">Mathematics · Real analysis</p>
      <h1 class="lb-title">Analysis <em>grapher</em>.</h1>
    </div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>y = f(x)</h3>
        <div class="fn-row"><span class="fn-dot" style="background:#5ee7ff;"></span><input class="fn-in fn" data-i="0" value="sin(x) + 0.3*x"/></div>
        <div class="fn-row"><span class="fn-dot" style="background:#f472b6;"></span><input class="fn-in fn" data-i="1" value=""/></div>
        <p class="hint" style="margin-top:6px;">x, +−*/^(), and sin cos tan exp log sqrt abs · pi e. Click the graph to set the Taylor centre a.</p>
      </div>
      <div class="lb-panel"><h3>Analysis overlays</h3>
        <div class="lb-tog" id="tog">
          <button data-k="d1" style="border-color:#34d399;">f′(x)</button>
          <button data-k="d2" style="border-color:#fbbf24;">f″(x)</button>
          <button data-k="int" style="border-color:#a78bfa;">∫ F(x) + area</button>
          <button data-k="crit" style="border-color:#67e8f9;" class="on">roots/extrema/infl.</button>
          <button data-k="taylor" style="border-color:#f472b6;" class="on">Taylor</button>
        </div>
        <div class="lb-row" style="margin-top:11px;"><label>Taylor centre a <span id="aV">0.0</span></label><input id="ta" type="range" min="-10" max="10" step="0.1" value="0"/>
          <label>Taylor order n <span id="onV">3</span></label><input id="ordr" type="range" min="1" max="6" step="1" value="3"/></div>
      </div>
      <div class="lb-panel"><h3>View</h3><div class="lb-row"><label>Zoom (x-range ±) <span id="zV">7.0</span></label><input id="z" type="range" min="1" max="40" step="0.5" value="7"/></div>
        <div class="lb-read" id="read" style="margin-top:10px;">move over the graph…</div>
      </div>
    </aside>
    <section><div class="lb-stage"><canvas id="scene" width="960" height="620"></canvas></div></section>
  </div>
</main>
<script is:inline>
(function(){
  var COLORS=['#5ee7ff','#f472b6']; var fns=[null,null];
  var ON={d1:false,d2:false,int:false,crit:true,taylor:true};
  function compile(expr){ if(!expr.trim()) return null; var e=expr.toLowerCase().replace(/\^/g,'**');
    var stripped=e.replace(/\b(sin|cos|tan|asin|acos|atan|sinh|cosh|tanh|exp|log|log10|log2|sqrt|cbrt|abs|sign|floor|ceil|round|pow|min|max|atan2|pi|e)\b/g,'').replace(/\*\*/g,'');
    if(/[^0-9x+\-*/(). ,\s]/.test(stripped)) throw new Error('bad');
    return new Function('x','with(Math){ return ('+e+'); }'); }
  function build(){ document.querySelectorAll('.fn').forEach(function(inp){ var i=+inp.getAttribute('data-i'); try{ fns[i]=compile(inp.value); inp.style.borderColor='#1e2740'; }catch(err){ fns[i]=null; inp.style.borderColor='#7a2f2f'; } }); }
  document.querySelectorAll('.fn').forEach(function(inp){ inp.addEventListener('input',build); }); build();
  document.getElementById('z').addEventListener('input',function(){ document.getElementById('zV').textContent=(+this.value).toFixed(1); });
  document.getElementById('ta').addEventListener('input',function(){ document.getElementById('aV').textContent=(+this.value).toFixed(1); });
  document.getElementById('ordr').addEventListener('input',function(){ document.getElementById('onV').textContent=this.value; });
  document.querySelectorAll('#tog button').forEach(function(b){ var k=b.getAttribute('data-k'); if(ON[k]){ b.classList.add('on'); b.style.background=b.style.borderColor; }
    b.addEventListener('click',function(){ ON[k]=!ON[k]; b.classList.toggle('on'); b.style.background=ON[k]?b.style.borderColor:'#0b1020'; b.style.color=ON[k]?'#04161b':'#8ea0be'; }); });

  // numerical calculus
  function d1(f,x){ var h=1e-4*(1+Math.abs(x)); return (f(x+h)-f(x-h))/(2*h); }
  function d2(f,x){ var h=1e-3*(1+Math.abs(x)); return (f(x+h)-2*f(x)+f(x-h))/(h*h); }
  // k-th derivative via central-difference stencils (k=1..6)
  var STEN={1:[[-1,-0.5],[1,0.5]],2:[[-1,1],[0,-2],[1,1]],3:[[-2,-0.5],[-1,1],[1,-1],[2,0.5]],4:[[-2,1],[-1,-4],[0,6],[1,-4],[2,1]],5:[[-3,-0.5],[-2,2],[-1,-2.5],[1,2.5],[2,-2],[3,0.5]],6:[[-3,1],[-2,-6],[-1,15],[0,-20],[1,15],[2,-6],[3,1]]};
  function nderiv(f,a,k,h){ var s=0; STEN[k].forEach(function(c){ s+=c[1]*f(a+c[0]*h); }); return s/Math.pow(h,k); }
  function taylorCoeffs(f,a,n){ var h=0.25, c=[f(a)], fact=1; for(var k=1;k<=n;k++){ fact*=k; c.push(nderiv(f,a,k,h)/fact); } return c; }
  function taylorEval(c,a,x){ var s=0,p=1,dx=x-a; for(var k=0;k<c.length;k++){ s+=c[k]*p; p*=dx; } return s; }

  var cv=document.getElementById('scene'), mouse=null;
  cv.addEventListener('mousemove',function(e){ var r=cv.getBoundingClientRect(); mouse={x:(e.clientX-r.left)/r.width}; });
  cv.addEventListener('mouseleave',function(){ mouse=null; });
  cv.addEventListener('click',function(e){ var r=cv.getBoundingClientRect(); var rx=+document.getElementById('z').value; var xw=(e.clientX-r.left)/r.width*2*rx-rx; document.getElementById('ta').value=xw.toFixed(1); document.getElementById('aV').textContent=xw.toFixed(1); });
  function hidpi(c){ var r=c.getBoundingClientRect(), dp=window.devicePixelRatio||1; var w=r.width||c.width, h=(c.height/c.width)*w; c.width=Math.round(w*dp); c.height=Math.round(h*dp); var ctx=c.getContext('2d'); ctx.setTransform(dp,0,0,dp,0,0); return {ctx:ctx,w:w,h:h}; }
  function niceStep(range){ var raw=range/6, mag=Math.pow(10,Math.floor(Math.log(raw)/Math.LN10)), nn=raw/mag; var m=nn<1.5?1:nn<3?2:nn<7?5:10; return m*mag; }

  function draw(){ var s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h; var rx=+document.getElementById('z').value, ry=rx*H/W;
    var bg=ctx.createLinearGradient(0,0,0,H); bg.addColorStop(0,'#0b1020'); bg.addColorStop(1,'#06080f'); ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    function X(x){ return (x+rx)/(2*rx)*W; } function Y(y){ return H-(y+ry)/(2*ry)*H; } function invX(px){ return px/W*2*rx-rx; }
    var sX=niceStep(rx); ctx.font="10px 'Geist Mono',monospace";
    for(var gx=Math.ceil(-rx/sX)*sX; gx<=rx; gx+=sX){ ctx.strokeStyle=Math.abs(gx)<1e-9?'#38507a':'rgba(94,231,255,0.06)'; ctx.lineWidth=Math.abs(gx)<1e-9?1.5:1; ctx.beginPath(); ctx.moveTo(X(gx),0); ctx.lineTo(X(gx),H); ctx.stroke(); if(Math.abs(gx)>1e-9){ ctx.fillStyle='#5f7597'; ctx.fillText(gx.toFixed(sX<1?1:0),X(gx)+3,Y(0)+12); } }
    var sY=niceStep(ry); for(var gy=Math.ceil(-ry/sY)*sY; gy<=ry; gy+=sY){ ctx.strokeStyle=Math.abs(gy)<1e-9?'#38507a':'rgba(94,231,255,0.06)'; ctx.lineWidth=Math.abs(gy)<1e-9?1.5:1; ctx.beginPath(); ctx.moveTo(0,Y(gy)); ctx.lineTo(W,Y(gy)); ctx.stroke(); }
    var f=fns[0];
    // integral area shading + cumulative F
    if(f && ON.int){ ctx.fillStyle='rgba(167,139,250,0.14)'; for(var px=0;px<=W;px+=2){ var x=invX(px), y; try{y=f(x);}catch(e){y=NaN;} if(isFinite(y)){ ctx.fillRect(px,Math.min(Y(0),Y(y)),2,Math.abs(Y(y)-Y(0))); } }
      // cumulative F from left edge (trapezoid)
      var Fv=0, prevY=null, prevx=invX(0), pts=[]; for(var px=0;px<=W;px+=1){ var x=invX(px), y; try{y=f(x);}catch(e){y=NaN;} if(isFinite(y)){ if(prevY!==null){ Fv+=(y+prevY)/2*(x-prevx); } prevY=y; prevx=x; pts.push([px,Y(Fv)]); } }
      ctx.save(); ctx.strokeStyle='#a78bfa'; ctx.lineWidth=1.6; ctx.setLineDash([5,3]); ctx.beginPath(); pts.forEach(function(p,i){ i?ctx.lineTo(p[0],p[1]):ctx.moveTo(p[0],p[1]); }); ctx.stroke(); ctx.setLineDash([]); ctx.restore(); }
    // derivative overlays
    function plotG(g,col,wd){ ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=6; ctx.strokeStyle=col; ctx.lineWidth=wd||1.6; ctx.beginPath(); var pen=false,pv=null; for(var px=0;px<=W;px++){ var x=invX(px),y; try{y=g(x);}catch(e){y=NaN;} if(!isFinite(y)){pen=false;continue;} var py=Y(y); if(pen&&Math.abs(py-pv)>H){pen=false;} if(!pen){ctx.moveTo(px,py);pen=true;}else ctx.lineTo(px,py); pv=py; } ctx.stroke(); ctx.restore(); }
    if(f && ON.d1) plotG(function(x){return d1(f,x);},'#34d399');
    if(f && ON.d2) plotG(function(x){return d2(f,x);},'#fbbf24');
    // functions
    fns.forEach(function(fn,idx){ if(!fn) return; plotG(fn,COLORS[idx],2.2); });
    // Taylor overlay
    if(f && ON.taylor){ var a=+document.getElementById('ta').value, n=+document.getElementById('ordr').value; var c; try{ c=taylorCoeffs(f,a,n); }catch(e){ c=null; }
      if(c){ ctx.save(); ctx.strokeStyle='#f472b6'; ctx.lineWidth=1.7; ctx.setLineDash([6,4]); ctx.beginPath(); var pen=false,pv=null; for(var px=0;px<=W;px++){ var x=invX(px), y=taylorEval(c,a,x); var py=Y(y); if(Math.abs(py-pv)>H&&pen){pen=false;} if(!pen){ctx.moveTo(px,py);pen=true;}else ctx.lineTo(px,py); pv=py; } ctx.stroke(); ctx.setLineDash([]); ctx.restore();
        var fa; try{fa=f(a);}catch(e){fa=NaN;} if(isFinite(fa)){ ctx.fillStyle='#f472b6'; ctx.beginPath(); ctx.arc(X(a),Y(fa),4,0,7); ctx.fill(); } } }
    // critical points
    if(f && ON.crit){ var lastR=null,lastE=null,lastI=null;
      for(var px=1;px<W;px++){ var x0=invX(px-1),x1=invX(px); var y0,y1; try{y0=f(x0);y1=f(x1);}catch(e){continue;} if(!isFinite(y0)||!isFinite(y1))continue;
        if(y0*y1<0){ var xr=x0-y0*(x1-x0)/(y1-y0); ctx.fillStyle='#5ee7ff'; ctx.beginPath(); ctx.arc(X(xr),Y(0),3.5,0,7); ctx.fill(); }
        var g0=d1(f,x0),g1=d1(f,x1); if(g0*g1<0){ var xe=(x0+x1)/2; ctx.fillStyle='#34d399'; ctx.beginPath(); ctx.arc(X(xe),Y(f(xe)),4,0,7); ctx.fill(); }
        var h0=d2(f,x0),h1=d2(f,x1); if(h0*h1<0 && Math.abs(h0)<1e4){ var xi=(x0+x1)/2; ctx.strokeStyle='#fbbf24'; ctx.lineWidth=1.5; ctx.beginPath(); ctx.arc(X(xi),Y(f(xi)),4,0,7); ctx.stroke(); } } }
    // trace + readout
    if(mouse && f){ var tx=mouse.x*2*rx-rx; var fv,fp,fpp; try{fv=f(tx);fp=d1(f,tx);fpp=d2(f,tx);}catch(e){}
      ctx.strokeStyle='rgba(255,255,255,0.22)'; ctx.setLineDash([4,4]); ctx.beginPath(); ctx.moveTo(X(tx),0); ctx.lineTo(X(tx),H); ctx.stroke(); ctx.setLineDash([]);
      if(isFinite(fv)){ ctx.fillStyle='#5ee7ff'; ctx.beginPath(); ctx.arc(X(tx),Y(fv),5,0,7); ctx.fill();
        // tangent line
        ctx.strokeStyle='rgba(52,211,153,0.6)'; ctx.lineWidth=1.2; ctx.beginPath(); ctx.moveTo(X(tx-rx),Y(fv+fp*(-rx))); ctx.lineTo(X(tx+rx),Y(fv+fp*(rx))); ctx.stroke(); }
      // definite integral over visible range (Simpson)
      var Iab=simpson(f,-rx,rx,400);
      document.getElementById('read').innerHTML='x = '+tx.toFixed(3)+'<br>f = '+num(fv)+'  f′ = '+num(fp)+'  f″ = '+num(fpp)+'<br>∫₋ᵣᵁ f dx = '+num(Iab); }
  }
  function simpson(f,a,b,n){ if(n%2)n++; var h=(b-a)/n,s=0; try{ s=f(a)+f(b); }catch(e){return NaN;} for(var i=1;i<n;i++){ var x=a+i*h,y; try{y=f(x);}catch(e){y=0;} if(!isFinite(y))y=0; s+=(i%2?4:2)*y; } return s*h/3; }
  function num(x){ return isFinite(x)?x.toFixed(3):'—'; }
  function loop(){ draw(); requestAnimationFrame(loop); } requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
