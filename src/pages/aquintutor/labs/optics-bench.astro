---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Optical Bench · Virtual Labs · AquinTutor" description="Slide lenses and mirrors on an optical rail, trace rays, and watch the image form with real thin-lens physics.">
<style>
  .obx { background:#08080b; color:#e8e8ee; min-height:100vh; font-family:'Geist Mono',ui-monospace,'SF Mono',Menlo,monospace; }
  .obx .wrap { max-width:1320px; margin:0 auto; padding:34px 22px 90px; }
  .obx .back { display:inline-flex; align-items:center; gap:7px; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:#9aa0aa; text-decoration:none; margin-bottom:22px; }
  .obx .back:hover { color:#67e8f9; }
  .obx .eyebrow { font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin-bottom:11px; }
  .obx h1 { font-family:'Cormorant Garamond',serif; font-size:40px; font-weight:600; letter-spacing:-0.02em; line-height:1.1; margin:0 0 12px; color:#f3f3f8; }
  .obx h1 em { color:#a78bfa; font-style:italic; }
  .obx .lede { color:#9aa0aa; max-width:880px; font-size:13.5px; line-height:1.65; margin-bottom:24px; }

  .obx .layout { display:grid; grid-template-columns:minmax(0,1fr) 340px; gap:18px; align-items:start; }
  @media (max-width:1040px) { .obx .layout { grid-template-columns:1fr; } }

  .obx .panel { background:#11131a; border:1px solid #2a2a35; border-radius:12px; padding:16px; }
  .obx .panel h3 { font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin:0 0 13px; display:flex; align-items:center; gap:7px; }
  .obx canvas { display:block; width:100%; background:#06070a; border:1px solid #232330; border-radius:10px; cursor:grab; touch-action:none; }
  .obx canvas.dragging { cursor:grabbing; }

  .obx .benchhint { font-size:10.5px; color:#7a808c; margin-top:9px; line-height:1.55; }
  .obx .benchhint b { color:#cfd6da; }

  .obx .toolbar { display:flex; gap:7px; flex-wrap:wrap; margin-bottom:13px; }
  .obx .btn { background:#0c0e14; border:1px solid #2a2a35; color:#bcc2cc; padding:7px 11px; border-radius:8px; font-size:10.5px; letter-spacing:0.05em; font-weight:600; cursor:pointer; font-family:inherit; transition:all .14s; display:inline-flex; align-items:center; gap:6px; }
  .obx .btn:hover { border-color:#3f4452; color:#f3f3f8; }
  .obx .btn.acc { border-color:#a78bfa; color:#c4b5fd; }
  .obx .btn.acc:hover { background:#1a1626; }
  .obx .btn svg { width:13px; height:13px; }

  .obx .pcol { display:flex; flex-direction:column; gap:14px; }

  .obx .presets { display:grid; grid-template-columns:1fr; gap:6px; }
  .obx .pre { text-align:left; background:#0c0e14; border:1px solid #2a2a35; color:#bcc2cc; padding:9px 11px; border-radius:8px; font-size:11px; cursor:pointer; font-family:inherit; transition:all .14s; line-height:1.4; }
  .obx .pre:hover { border-color:#67e8f9; color:#f3f3f8; background:#0e1118; }
  .obx .pre b { color:#f3f3f8; display:block; font-size:11.5px; margin-bottom:1px; }
  .obx .pre span { color:#7a808c; font-size:10px; }

  .obx .row { display:flex; gap:9px; align-items:center; margin-bottom:11px; flex-wrap:wrap; }
  .obx .row > label { font-size:10px; letter-spacing:0.08em; text-transform:uppercase; color:#9aa0aa; min-width:84px; }
  .obx .row .val { font-size:11px; color:#fbbf24; min-width:52px; text-align:right; font-weight:600; }
  .obx input[type=range] { -webkit-appearance:none; appearance:none; background:#0a0a0c; border:1px solid #2a2a35; height:6px; border-radius:4px; flex:1; min-width:90px; }
  .obx input[type=range]::-webkit-slider-thumb { -webkit-appearance:none; appearance:none; width:14px; height:14px; border-radius:50%; background:#a78bfa; cursor:pointer; border:none; }
  .obx input[type=range]::-moz-range-thumb { width:14px; height:14px; border-radius:50%; background:#a78bfa; cursor:pointer; border:none; }

  .obx .elemlist { display:flex; flex-direction:column; gap:6px; max-height:230px; overflow:auto; }
  .obx .elem { background:#0c0e14; border:1px solid #2a2a35; border-radius:8px; padding:9px 10px; transition:all .14s; }
  .obx .elem.sel { border-color:#a78bfa; background:#12101c; }
  .obx .elem .ehead { display:flex; align-items:center; gap:8px; cursor:pointer; }
  .obx .elem .dot { width:9px; height:9px; border-radius:2px; flex-shrink:0; }
  .obx .elem .enm { font-size:11px; color:#e8e8ee; font-weight:600; flex:1; }
  .obx .elem .ex { font-size:13px; color:#6b7280; cursor:pointer; padding:0 3px; line-height:1; }
  .obx .elem .ex:hover { color:#f87171; }
  .obx .elem .ebody { margin-top:8px; display:none; }
  .obx .elem.sel .ebody { display:block; }
  .obx .elem .mini { display:flex; gap:7px; align-items:center; margin-top:6px; }
  .obx .elem .mini label { font-size:9px; letter-spacing:0.06em; text-transform:uppercase; color:#828892; min-width:46px; }
  .obx .elem .mini .mv { font-size:10px; color:#fbbf24; min-width:46px; text-align:right; }

  .obx .addbar { display:flex; gap:5px; flex-wrap:wrap; margin-bottom:12px; }
  .obx .add { background:#0c0e14; border:1px dashed #3a3f4c; color:#9aa0aa; padding:6px 9px; border-radius:7px; font-size:10px; cursor:pointer; font-family:inherit; transition:all .14s; }
  .obx .add:hover { border-color:#67e8f9; color:#67e8f9; border-style:solid; }

  .obx .readout { display:grid; grid-template-columns:1fr 1fr; gap:8px 14px; }
  .obx .ro { display:flex; flex-direction:column; gap:2px; }
  .obx .ro .k { font-size:9px; letter-spacing:0.1em; text-transform:uppercase; color:#828892; }
  .obx .ro .v { font-size:14px; color:#f3f3f8; font-weight:600; }
  .obx .ro .v.real { color:#34d399; }
  .obx .ro .v.virt { color:#fbbf24; }
  .obx .ro .v.muted { color:#6b7280; font-size:12px; }

  .obx .badge { display:inline-block; font-size:9px; letter-spacing:0.08em; text-transform:uppercase; padding:2px 7px; border-radius:5px; font-weight:700; }
  .obx .badge.real { background:#0c2b22; color:#34d399; border:1px solid #134e3a; }
  .obx .badge.virt { background:#2b240c; color:#fbbf24; border:1px solid #4e4313; }

  .obx .stagewrap { position:relative; }
  .obx .formula { font-size:11px; color:#9aa0aa; line-height:1.7; margin-top:11px; padding-top:11px; border-top:1px solid #1c1c26; }
  .obx .formula b { color:#c4b5fd; }
  .obx .formula .eq { color:#fbbf24; }

  .obx .toggle { display:flex; align-items:center; gap:8px; font-size:10.5px; color:#9aa0aa; cursor:pointer; margin-bottom:9px; }
  .obx .toggle input { accent-color:#a78bfa; }
  .obx .chips { display:flex; gap:6px; flex-wrap:wrap; margin-top:4px; }
</style>

<main class="obx">
  <div class="wrap">
    <a class="back" href="/aquintutor/labs">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Virtual Labs
    </a>
    <div class="eyebrow">Optics · Geometrical Optics</div>
    <h1>Optical <em>Bench</em></h1>
    <p class="lede">An optical rail with sliding mounts. Place an illuminated object, converging and diverging lenses, curved mirrors, and a screen, then drag them along the centimetre rail. Rays are traced through every element with the real thin-lens and mirror equations, the image forms live, and you read off distance, magnification, and orientation just like a real bench experiment.</p>

    <div class="layout">
      <div class="pcol">
        <div class="panel stagewrap">
          <h3>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#67e8f9" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/></svg>
            Optical Rail
          </h3>
          <div class="toolbar">
            <button class="btn" id="ob-zoomin"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M11 8v6M8 11h6M21 21l-4-4"/></svg>Zoom in</button>
            <button class="btn" id="ob-zoomout"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M8 11h6M21 21l-4-4"/></svg>Zoom out</button>
            <button class="btn" id="ob-fit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7V3h4M21 7V3h-4M3 17v4h4M21 17v4h-4"/></svg>Fit</button>
            <button class="btn acc" id="ob-snapscreen"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M8 21h8M12 18v3"/></svg>Screen to image</button>
          </div>
          <canvas id="ob-canvas" width="900" height="540"></canvas>
          <div class="benchhint">
            <b>Drag</b> any mount left/right along the rail to slide it. <b>Click</b> a mount to select it. Distances are in centimetres on the rail scale. The image is drawn <b>solid &amp; inverted</b> when real, <b>dashed</b> when virtual; the screen shows a sharp image only when it sits at the image plane.
          </div>
        </div>

        <div class="panel">
          <h3>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#67e8f9" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            Measurement Readout
          </h3>
          <div class="readout" id="ob-readout"></div>
          <div class="formula">
            Thin lens: <span class="eq">1/v &minus; 1/u = 1/f</span> &nbsp;&middot;&nbsp; Mirror: <span class="eq">1/v + 1/u = 1/f</span> &nbsp;&middot;&nbsp; Magnification <span class="eq">m = v / u</span>.
            <br>Sign convention: distances measured from the element along the rail, light travels left&#8594;right, real object distance <b>u</b> is negative, <b>f &gt; 0</b> for a converging lens / concave mirror.
          </div>
        </div>
      </div>

      <div class="pcol">
        <div class="panel">
          <h3>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#67e8f9" stroke-width="2"><path d="M4 4h16v4H4zM4 12h10v4H4z"/></svg>
            Presets
          </h3>
          <div class="presets" id="ob-presets"></div>
        </div>

        <div class="panel">
          <h3>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#67e8f9" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
            Add to rail
          </h3>
          <div class="addbar" id="ob-addbar"></div>
          <div class="row">
            <label>Object height</label>
            <input type="range" id="ob-objh" min="1" max="6" step="0.2" value="3">
            <span class="val" id="ob-objh-v">3.0 cm</span>
          </div>
          <div class="row">
            <label>Ray count</label>
            <input type="range" id="ob-rays" min="3" max="9" step="2" value="3">
            <span class="val" id="ob-rays-v">3</span>
          </div>
          <label class="toggle"><input type="checkbox" id="ob-grid" checked> Show focal markers (F, 2F)</label>
          <label class="toggle"><input type="checkbox" id="ob-extend" checked> Extend virtual rays (dashed)</label>
        </div>

        <div class="panel">
          <h3>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#67e8f9" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
            Mounts on rail
          </h3>
          <div class="elemlist" id="ob-elemlist"></div>
        </div>
      </div>
    </div>
  </div>
</main>

<script is:inline>
(function () {
  'use strict';

  // ============================================================
  // Optical Bench — geometric ray-optics engine + skeuomorphic
  // rail rendering on a single Canvas2D. ES5 IIFE, no deps.
  // ------------------------------------------------------------
  // Coordinate systems
  //   * Rail coordinate x (centimetres): the position of a mount
  //     along the physical rail. Increases to the right.
  //   * y (centimetres): height above the optical axis. Up is +.
  //   * World->screen mapping handled by view {x0,scale,axisY}.
  //
  // Optics sign convention (consistent throughout)
  //   * Light travels left -> right.
  //   * For an element at rail position xe, an object/source at
  //     rail position xo to its LEFT has object distance
  //         u = xo - xe   (negative for a real object on the left)
  //   * Thin lens:   1/v - 1/u = 1/f      => image at xe + v
  //   * Mirror:      1/v + 1/u = 1/f      (v measured back along
  //         the incoming direction; image at xe - v in rail x
  //         because a mirror folds light back to the left).
  //   * f > 0 : converging lens / concave mirror.
  //   * f < 0 : diverging lens / convex mirror.
  //   * Magnification m = v/u (lens) or m = -v/u (mirror, with the
  //     fold already applied) — see computeSystem for the exact
  //     bookkeeping that keeps both consistent in rail space.
  // ============================================================

  var canvas = document.getElementById('ob-canvas');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');

  // ----- model state ------------------------------------------------
  // Each element: { id, type, x (cm on rail), f (cm), h (cm, object),
  //                 height (cm, screen/aperture), ... }
  var state = {
    objectHeight: 3.0,
    rayCount: 3,
    showMarkers: true,
    extendVirtual: true,
    selected: null,
    elements: []
  };

  var nextId = 1;
  function uid() { return nextId++; }

  // Element type registry -----------------------------------------
  var TYPES = {
    object: { label: 'Object (illuminated arrow)', color: '#fbbf24', kind: 'object' },
    convex: { label: 'Convex lens (converging)', color: '#67e8f9', kind: 'lens', defF: 10 },
    concave: { label: 'Concave lens (diverging)', color: '#a78bfa', kind: 'lens', defF: -12 },
    cmirror: { label: 'Concave mirror', color: '#5eead4', kind: 'mirror', defF: 12 },
    xmirror: { label: 'Convex mirror', color: '#f472b6', kind: 'mirror', defF: -12 },
    screen: { label: 'Screen', color: '#e8e8ee', kind: 'screen' },
    aperture: { label: 'Aperture / slit', color: '#94a3b8', kind: 'aperture' }
  };

  // ----- view (pan/zoom) ------------------------------------------
  var view = { x0: 0, scale: 6.2, axisY: 0 };
  // scale = pixels per centimetre. x0 = rail-cm at left padding.

  var PAD_L = 54, PAD_R = 24;
  function W() { return canvas.width; }
  function H() { return canvas.height; }

  function cmToPx(xcm) { return PAD_L + (xcm - view.x0) * view.scale; }
  function pxToCm(px) { return view.x0 + (px - PAD_L) / view.scale; }
  function cmToPxY(ycm) { return view.axisY - ycm * view.scale; }
  function pxToCmY(py) { return (view.axisY - py) / view.scale; }

  // ============================================================
  //  OPTICS CORE
  // ============================================================

  // Solve a single thin lens: given object distance u (cm, signed,
  // negative for real object on the left) and focal length f.
  // Returns {v, m} with 1/v - 1/u = 1/f, m = v/u.
  function thinLens(u, f) {
    // 1/v = 1/f + 1/u
    var invV = 1 / f + 1 / u;
    var v, m;
    if (Math.abs(invV) < 1e-9) { v = Infinity; m = Infinity; }
    else { v = 1 / invV; m = v / u; }
    return { v: v, m: m };
  }

  // Solve a single mirror: 1/v + 1/u = 1/f.
  // Using the same object-distance sign as the lens (u negative for
  // a real object), we get 1/v = 1/f - 1/u. The image distance v is
  // then measured along the reflected (leftward) direction.
  function mirror(u, f) {
    var invV = 1 / f - 1 / u;
    var v, m;
    if (Math.abs(invV) < 1e-9) { v = Infinity; m = Infinity; }
    else { v = 1 / invV; m = v / u; }
    return { v: v, m: m };
  }

  // Compute the full multi-element system left-to-right.
  // Returns an array of "stages", one per optical element (lens/
  // mirror), each describing the object & image used at that element
  // in RAIL coordinates so the renderer can draw everything.
  //
  // Each stage:
  //   { el, dir (+1 right / -1 left), objX, objH, imgX, imgH,
  //     u, v, f, m, real (bool), magTotal }
  function computeSystem() {
    var els = sortedOptical();
    var objEl = findOne('object');
    if (!objEl) return { stages: [], objEl: null };

    // Travelling state: where the current "object" is and its height
    // and the running magnification. dir = direction light travels.
    var curX = objEl.x;
    var curH = state.objectHeight;
    var dir = 1;            // light starts travelling to the right
    var magTotal = 1;
    var stages = [];

    for (var i = 0; i < els.length; i++) {
      var el = els[i];
      var t = TYPES[el.type];
      if (!(t.kind === 'lens' || t.kind === 'mirror')) continue;

      // Only act on elements that the light actually reaches in the
      // current travel direction (to the right of curX if dir>0).
      if (dir > 0 && el.x <= curX + 1e-6) continue;
      if (dir < 0 && el.x >= curX - 1e-6) continue;

      // object distance along the rail toward the element:
      // u = (object position) - (element position), but signed by
      // travel direction so that a real object gives u<0.
      var u, v, m, imgX, f = el.f;

      if (t.kind === 'lens') {
        u = dir * (curX - el.x);            // negative for real object
        var r = thinLens(u, f);
        v = r.v; m = r.m;
        // image sits at element + dir*v along the rail
        imgX = el.x + dir * v;
        // direction unchanged through a lens
        var newDir = dir;
        var imgH = curH * m;
        stages.push({
          el: el, kind: 'lens', dir: dir, newDir: newDir,
          objX: curX, objH: curH, imgX: imgX, imgH: imgH,
          u: u, v: v, f: f, m: m,
          real: (v > 0), magTotal: magTotal * m
        });
        curX = imgX; curH = imgH; magTotal *= m; dir = newDir;
      } else {
        // mirror: reflects, so travel direction flips.
        u = dir * (curX - el.x);            // negative for real object
        var rm = mirror(u, f);
        v = rm.v; m = rm.m;
        // reflected image is on the SAME side the light came from,
        // so in rail-x it is at element - dir*v (light folded back).
        imgX = el.x - dir * v;
        var newDir2 = -dir;
        var imgH2 = curH * m;
        stages.push({
          el: el, kind: 'mirror', dir: dir, newDir: newDir2,
          objX: curX, objH: curH, imgX: imgX, imgH: imgH2,
          u: u, v: v, f: f, m: m,
          real: (v > 0), magTotal: magTotal * m
        });
        curX = imgX; curH = imgH2; magTotal *= m; dir = newDir2;
      }
    }
    return { stages: stages, objEl: objEl };
  }

  function sortedOptical() {
    var a = state.elements.slice();
    a.sort(function (p, q) { return p.x - q.x; });
    return a;
  }
  function findOne(type) {
    for (var i = 0; i < state.elements.length; i++)
      if (state.elements[i].type === type) return state.elements[i];
    return null;
  }
  function findScreen() {
    for (var i = 0; i < state.elements.length; i++)
      if (state.elements[i].type === 'screen') return state.elements[i];
    return null;
  }

  // ============================================================
  //  RAY TRACING (for drawing). We trace individual rays from the
  //  object tip through each lens/mirror using the principal-ray
  //  rules, but we anchor them to the computed image so the cartoon
  //  rays and the analytic image always agree.
  // ============================================================

  // Build a list of ray polylines (each a list of {x,y} in cm) plus
  // dashed virtual extensions. We trace from the object tip.
  function traceRays(sys) {
    var rays = [];
    if (!sys.objEl) return rays;
    var els = sortedOptical().filter(function (e) {
      var k = TYPES[e.type].kind; return k === 'lens' || k === 'mirror';
    });

    var tipX = sys.objEl.x;
    var tipY = state.objectHeight;

    // We trace a fan of rays. For each ray we follow it segment by
    // segment. Between elements a ray is a straight line; at an
    // element we apply the matrix/principal mapping that sends the
    // object point to the image point computed in computeSystem.
    var n = state.rayCount;
    var fan = [];
    // pick a spread of initial directions toward the first element
    var firstEl = els[0];
    if (!firstEl) {
      // no optics: rays just go straight right
      for (var s = 0; s < n; s++) {
        var ang = (s - (n - 1) / 2) * 0.06;
        rays.push({ pts: [{ x: tipX, y: tipY }, { x: tipX + 40, y: tipY + 40 * Math.tan(ang) }], dashed: false });
      }
      return rays;
    }

    // For each principal ray we know its behaviour, but to support
    // arbitrary multi-element systems we use the generic approach:
    // model each lens/mirror as a mapping of (y, angle) and trace.
    // For robustness & visual correctness we trace 3..9 rays using
    // the object->image anchoring per stage.
    for (var s2 = 0; s2 < n; s2++) {
      var frac = n === 1 ? 0.5 : s2 / (n - 1);
      rays.push(traceOne(sys, tipX, tipY, frac, els));
    }
    return rays;
  }

  // Trace one ray from the tip toward the first element at a chosen
  // aperture fraction, then through every stage by anchoring to the
  // stage image point (object tip image). This guarantees rays
  // converge exactly at the computed image, including virtual cases.
  function traceOne(sys, tipX, tipY, frac, els) {
    var pts = [{ x: tipX, y: tipY }];
    var virtualSegs = [];
    var curX = tipX, curY = tipY;
    var dir = 1;
    var stageIdx = 0;

    for (var i = 0; i < els.length; i++) {
      var el = els[i];
      var st = stageForElement(sys, el);
      if (!st) continue;
      if (dir > 0 && el.x <= curX + 1e-6) continue;
      if (dir < 0 && el.x >= curX - 1e-6) continue;

      // Aperture point on the element: spread across its half-height.
      var apH = elementHalfHeight(el);
      var yHit = (frac - 0.5) * 2 * apH;       // -apH..+apH
      // Straight segment from current point to the element plane.
      pts.push({ x: el.x, y: yHit });

      // After the element, the ray must pass through the image point
      // (tip image) of this stage. Determine that image point.
      var imgX = st.imgX, imgY = st.imgH;
      var newDir = st.newDir;

      if (st.real) {
        // real image: ray actually continues to (imgX,imgY)
        pts.push({ x: imgX, y: imgY });
        curX = imgX; curY = imgY; dir = newDir;
      } else {
        // virtual image: the outgoing ray DIVERGES, but its backward
        // extension passes through (imgX,imgY). Draw a forward
        // segment in the new direction and a dashed back-extension.
        // Outgoing direction is the line from (imgX,imgY) through
        // (el.x,yHit) continued forward.
        var dx = (el.x - imgX), dy = (yHit - imgY);
        // forward extent
        var ext = 22 * newDir; // cm forward
        var L = Math.sqrt(dx * dx + dy * dy) || 1;
        var ux = dx / L, uy = dy / L;
        // ensure travel direction matches newDir
        if ((ux > 0) !== (newDir > 0)) { ux = -ux; uy = -uy; }
        var fx = el.x + ux * Math.abs(ext);
        var fy = yHit + uy * Math.abs(ext);
        pts.push({ x: fx, y: fy });
        // dashed back-extension to the virtual image
        virtualSegs.push([{ x: el.x, y: yHit }, { x: imgX, y: imgY }]);
        curX = el.x; curY = yHit; dir = newDir;
        // After a virtual image, subsequent elements would treat the
        // virtual image as their object — handled by computeSystem;
        // for tracing we stop principal rays here for clarity.
        return { pts: pts, dashed: false, virtual: virtualSegs };
      }
    }
    // final straight continuation past the last image
    var lastDir = dir;
    var lx = curX + lastDir * 20;
    var ly = curY + (curY - pts[pts.length - 2].y) /
      Math.max(0.001, (curX - pts[pts.length - 2].x)) * (lx - curX);
    if (isFinite(ly)) pts.push({ x: lx, y: ly });
    return { pts: pts, dashed: false, virtual: virtualSegs };
  }

  function stageForElement(sys, el) {
    for (var i = 0; i < sys.stages.length; i++)
      if (sys.stages[i].el === el) return sys.stages[i];
    return null;
  }
  function elementHalfHeight(el) {
    var t = TYPES[el.type];
    if (t.kind === 'lens') return 4.2;
    if (t.kind === 'mirror') return 4.0;
    return 4.0;
  }

  // ============================================================
  //  RENDER
  // ============================================================
  function render() {
    var w = W(), h = H();
    ctx.clearRect(0, 0, w, h);

    // background bench
    var g = ctx.createLinearGradient(0, 0, 0, h);
    g.addColorStop(0, '#070809');
    g.addColorStop(1, '#0c0d11');
    ctx.fillStyle = g;
    ctx.fillRect(0, 0, w, h);

    view.axisY = Math.round(h * 0.52);

    drawRail();
    drawAxis();
    if (state.showMarkers) drawFocalMarkers();

    var sys = computeSystem();

    // rays under elements
    drawRays(sys);

    // images (analytic)
    drawImages(sys);

    // elements (mounts) on top
    var els = state.elements.slice().sort(function (a, b) { return a.x - b.x; });
    for (var i = 0; i < els.length; i++) drawElement(els[i]);

    drawScale();
    updateReadout(sys);
    updateElemList();
  }

  // The physical rail: a metal bar with mounting slots + cm ticks
  function drawRail() {
    var w = W();
    var railY = view.axisY;
    var railTop = railY + 64;
    // rail bar
    var rg = ctx.createLinearGradient(0, railTop, 0, railTop + 26);
    rg.addColorStop(0, '#3a3f49');
    rg.addColorStop(0.5, '#23262e');
    rg.addColorStop(1, '#15171c');
    ctx.fillStyle = rg;
    roundRect(PAD_L - 10, railTop, w - PAD_L - PAD_R + 20, 26, 5);
    ctx.fill();
    // top highlight
    ctx.strokeStyle = 'rgba(255,255,255,0.08)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(PAD_L - 8, railTop + 2); ctx.lineTo(w - PAD_R + 8, railTop + 2); ctx.stroke();
    // central T-slot
    ctx.fillStyle = '#0a0b0e';
    roundRect(PAD_L - 6, railTop + 10, w - PAD_L - PAD_R + 12, 6, 3); ctx.fill();

    // cm ticks on the rail
    var startCm = Math.ceil(view.x0 / 5) * 5;
    ctx.fillStyle = '#5a606c';
    ctx.font = '9px ui-monospace, monospace';
    ctx.textAlign = 'center';
    for (var cm = startCm; ; cm += 1) {
      var px = cmToPx(cm);
      if (px > w - PAD_R + 4) break;
      if (px < PAD_L - 4) continue;
      var major = (cm % 10 === 0);
      var med = (cm % 5 === 0);
      ctx.strokeStyle = major ? '#6b7280' : (med ? '#4a4f59' : '#33373f');
      ctx.lineWidth = 1;
      var tickLen = major ? 9 : (med ? 6 : 3);
      ctx.beginPath();
      ctx.moveTo(px, railTop - tickLen);
      ctx.lineTo(px, railTop);
      ctx.stroke();
      if (major) {
        ctx.fillStyle = '#7a808c';
        ctx.fillText(cm + '', px, railTop - 12);
      }
    }
    // "cm" unit tag
    ctx.fillStyle = '#5a606c';
    ctx.textAlign = 'left';
    ctx.fillText('cm', PAD_L - 44, railTop + 4);
  }

  function drawAxis() {
    var w = W();
    ctx.save();
    ctx.strokeStyle = 'rgba(120,130,150,0.32)';
    ctx.lineWidth = 1;
    ctx.setLineDash([5, 5]);
    ctx.beginPath();
    ctx.moveTo(PAD_L - 10, view.axisY);
    ctx.lineTo(w - PAD_R, view.axisY);
    ctx.stroke();
    ctx.setLineDash([]);
    // axis label
    ctx.fillStyle = 'rgba(120,130,150,0.55)';
    ctx.font = '9px ui-monospace, monospace';
    ctx.textAlign = 'right';
    ctx.fillText('optical axis', w - PAD_R - 2, view.axisY - 5);
    ctx.restore();
  }

  function drawFocalMarkers() {
    var els = state.elements;
    for (var i = 0; i < els.length; i++) {
      var el = els[i];
      var t = TYPES[el.type];
      if (!(t.kind === 'lens' || t.kind === 'mirror')) continue;
      var fAbs = Math.abs(el.f);
      var marks = [
        { d: fAbs, label: 'F' },
        { d: 2 * fAbs, label: '2F' }
      ];
      for (var s = -1; s <= 1; s += 2) {
        for (var k = 0; k < marks.length; k++) {
          var mx = el.x + s * marks[k].d;
          var px = cmToPx(mx);
          if (px < PAD_L - 5 || px > W() - PAD_R + 5) continue;
          ctx.save();
          ctx.strokeStyle = 'rgba(167,139,250,0.45)';
          ctx.fillStyle = 'rgba(167,139,250,0.85)';
          ctx.lineWidth = 1;
          // small cross on the axis
          ctx.beginPath();
          ctx.moveTo(px, view.axisY - 5);
          ctx.lineTo(px, view.axisY + 5);
          ctx.stroke();
          ctx.font = '9px ui-monospace, monospace';
          ctx.textAlign = 'center';
          ctx.fillText(marks[k].label, px, view.axisY + 18);
          ctx.restore();
        }
      }
    }
  }

  // colored rays
  var RAY_COLORS = ['#fbbf24', '#34d399', '#60a5fa', '#f472b6', '#a78bfa', '#5eead4', '#fb923c', '#f87171', '#c084fc'];
  function drawRays(sys) {
    var rays = traceRays(sys);
    for (var r = 0; r < rays.length; r++) {
      var ray = rays[r];
      var col = RAY_COLORS[r % RAY_COLORS.length];
      // solid path
      ctx.save();
      ctx.strokeStyle = col;
      ctx.globalAlpha = 0.92;
      ctx.lineWidth = 1.4;
      ctx.beginPath();
      var pts = ray.pts;
      for (var i = 0; i < pts.length; i++) {
        var px = cmToPx(pts[i].x), py = cmToPxY(pts[i].y);
        if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
      }
      ctx.stroke();
      // virtual dashed extensions
      if (state.extendVirtual && ray.virtual) {
        ctx.setLineDash([4, 4]);
        ctx.globalAlpha = 0.5;
        ctx.lineWidth = 1;
        for (var v = 0; v < ray.virtual.length; v++) {
          var seg = ray.virtual[v];
          ctx.beginPath();
          ctx.moveTo(cmToPx(seg[0].x), cmToPxY(seg[0].y));
          ctx.lineTo(cmToPx(seg[1].x), cmToPxY(seg[1].y));
          ctx.stroke();
        }
        ctx.setLineDash([]);
      }
      ctx.restore();
    }
  }

  // Draw the analytic image arrow for the final stage (and faint
  // intermediate images for multi-element systems).
  function drawImages(sys) {
    if (!sys.stages.length) return;
    for (var i = 0; i < sys.stages.length; i++) {
      var st = sys.stages[i];
      var isFinal = (i === sys.stages.length - 1);
      if (!isFinite(st.imgX) || !isFinite(st.imgH)) continue;
      var alpha = isFinal ? 1 : 0.42;
      var col = st.real ? '#34d399' : '#fbbf24';
      drawArrow(st.imgX, st.imgH, col, !st.real, alpha, isFinal ? 'image' : '');
    }
  }

  // Draw an upright/inverted arrow at rail position x with height h
  // (cm, signed). dashed=true for virtual.
  function drawArrow(xcm, hcm, color, dashed, alpha, label) {
    var px = cmToPx(xcm);
    var baseY = cmToPxY(0);
    var tipY = cmToPxY(hcm);
    ctx.save();
    ctx.globalAlpha = alpha == null ? 1 : alpha;
    ctx.strokeStyle = color;
    ctx.fillStyle = color;
    ctx.lineWidth = 2.4;
    if (dashed) ctx.setLineDash([5, 4]);
    ctx.beginPath();
    ctx.moveTo(px, baseY);
    ctx.lineTo(px, tipY);
    ctx.stroke();
    ctx.setLineDash([]);
    // arrowhead pointing away from axis
    var dirUp = hcm >= 0 ? -1 : 1; // screen up is -y px
    var ah = 8;
    ctx.beginPath();
    ctx.moveTo(px, tipY);
    ctx.lineTo(px - 5, tipY - dirUp * ah);
    ctx.lineTo(px + 5, tipY - dirUp * ah);
    ctx.closePath();
    ctx.fill();
    if (label) {
      ctx.globalAlpha = (alpha == null ? 1 : alpha) * 0.9;
      ctx.font = '9px ui-monospace, monospace';
      ctx.textAlign = 'center';
      ctx.fillText(label, px, tipY + (hcm >= 0 ? -14 : 16));
    }
    ctx.restore();
  }

  // ----- draw each mount -------------------------------------------
  function drawElement(el) {
    var t = TYPES[el.type];
    var px = cmToPx(el.x);
    var railTop = view.axisY + 64;
    var sel = (state.selected === el.id);

    // mount post from rail up to element
    ctx.save();
    var pg = ctx.createLinearGradient(px - 6, 0, px + 6, 0);
    pg.addColorStop(0, '#23262e');
    pg.addColorStop(0.5, '#3a3f49');
    pg.addColorStop(1, '#23262e');
    ctx.fillStyle = pg;
    var postTop = view.axisY - 46;
    roundRect(px - 5, postTop, 10, railTop - postTop, 3); ctx.fill();
    // mounting clamp on rail
    ctx.fillStyle = sel ? '#4b4564' : '#2c303a';
    roundRect(px - 11, railTop - 4, 22, 12, 3); ctx.fill();
    ctx.strokeStyle = sel ? '#a78bfa' : 'rgba(255,255,255,0.06)';
    ctx.lineWidth = sel ? 1.6 : 1;
    roundRect(px - 11, railTop - 4, 22, 12, 3); ctx.stroke();
    // clamp knob
    ctx.fillStyle = sel ? '#a78bfa' : '#5a606c';
    ctx.beginPath(); ctx.arc(px, railTop + 2, 3, 0, Math.PI * 2); ctx.fill();
    ctx.restore();

    if (t.kind === 'lens') drawLens(el, px, sel);
    else if (t.kind === 'mirror') drawMirror(el, px, sel);
    else if (t.kind === 'object') drawObject(el, px, sel);
    else if (t.kind === 'screen') drawScreen(el, px, sel);
    else if (t.kind === 'aperture') drawAperture(el, px, sel);

    // selection highlight ring
    if (sel) {
      ctx.save();
      ctx.strokeStyle = 'rgba(167,139,250,0.5)';
      ctx.lineWidth = 1;
      ctx.setLineDash([3, 3]);
      var hh = elementHalfHeight(el) * view.scale + 14;
      ctx.strokeRect(px - 20, view.axisY - hh, 40, 2 * hh);
      ctx.setLineDash([]);
      ctx.restore();
    }

    // label + focal length
    ctx.save();
    ctx.fillStyle = sel ? '#f3f3f8' : '#9aa0aa';
    ctx.font = (sel ? 'bold ' : '') + '10px ui-monospace, monospace';
    ctx.textAlign = 'center';
    var lab = labelFor(el);
    ctx.fillText(lab, px, view.axisY - elementHalfHeight(el) * view.scale - 22);
    ctx.restore();
  }

  function labelFor(el) {
    var t = TYPES[el.type];
    if (t.kind === 'lens') return (el.type === 'convex' ? 'Convex' : 'Concave') + ' f=' + el.f + 'cm';
    if (t.kind === 'mirror') return (el.type === 'cmirror' ? 'Concave M' : 'Convex M') + ' f=' + el.f + 'cm';
    if (t.kind === 'object') return 'Object';
    if (t.kind === 'screen') return 'Screen';
    if (t.kind === 'aperture') return 'Aperture';
    return '';
  }

  function drawLens(el, px, sel) {
    var half = 4.2 * view.scale;
    var top = view.axisY - half, bot = view.axisY + half;
    var bulge = (el.type === 'convex') ? 11 : -9;
    ctx.save();
    // glass body
    var lg = ctx.createLinearGradient(px - 14, 0, px + 14, 0);
    lg.addColorStop(0, 'rgba(103,232,249,0.05)');
    lg.addColorStop(0.5, el.type === 'convex' ? 'rgba(103,232,249,0.22)' : 'rgba(167,139,250,0.18)');
    lg.addColorStop(1, 'rgba(103,232,249,0.05)');
    ctx.fillStyle = lg;
    ctx.beginPath();
    if (el.type === 'convex') {
      // biconvex
      ctx.moveTo(px, top);
      ctx.quadraticCurveTo(px + bulge, view.axisY, px, bot);
      ctx.quadraticCurveTo(px - bulge, view.axisY, px, top);
    } else {
      // biconcave: two inward arcs joined by short edges
      var ew = 7;
      ctx.moveTo(px - ew, top);
      ctx.quadraticCurveTo(px + bulge, view.axisY, px - ew, bot);
      ctx.lineTo(px + ew, bot);
      ctx.quadraticCurveTo(px - bulge, view.axisY, px + ew, top);
      ctx.closePath();
    }
    ctx.fill();
    ctx.strokeStyle = el.type === 'convex' ? '#67e8f9' : '#a78bfa';
    ctx.lineWidth = sel ? 2.2 : 1.6;
    ctx.stroke();
    // schematic double-headed arrow line through centre (lens symbol)
    ctx.strokeStyle = el.type === 'convex' ? 'rgba(103,232,249,0.55)' : 'rgba(167,139,250,0.55)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(px, top - 4); ctx.lineTo(px, bot + 4); ctx.stroke();
    // arrowheads (convex outward, concave inward)
    var ah = 5, sgn = el.type === 'convex' ? 1 : -1;
    ctx.beginPath();
    ctx.moveTo(px, top - 4);
    ctx.lineTo(px - sgn * ah, top - 4 + ah);
    ctx.moveTo(px, top - 4);
    ctx.lineTo(px + sgn * ah, top - 4 + ah);
    ctx.moveTo(px, bot + 4);
    ctx.lineTo(px - sgn * ah, bot + 4 - ah);
    ctx.moveTo(px, bot + 4);
    ctx.lineTo(px + sgn * ah, bot + 4 - ah);
    ctx.stroke();
    ctx.restore();
  }

  function drawMirror(el, px, sel) {
    var half = 4.0 * view.scale;
    var top = view.axisY - half, bot = view.axisY + half;
    ctx.save();
    var concave = (el.type === 'cmirror');
    var bulge = concave ? -13 : 13;
    // reflective surface (curved bar)
    ctx.strokeStyle = el.type === 'cmirror' ? '#5eead4' : '#f472b6';
    ctx.lineWidth = sel ? 3.4 : 2.6;
    ctx.beginPath();
    ctx.moveTo(px, top);
    ctx.quadraticCurveTo(px + bulge, view.axisY, px, bot);
    ctx.stroke();
    // hatched back (the silvered side)
    ctx.strokeStyle = el.type === 'cmirror' ? 'rgba(94,234,212,0.4)' : 'rgba(244,114,182,0.4)';
    ctx.lineWidth = 1;
    for (var y = top; y <= bot; y += 7) {
      var hx = px + bulge * (1 - Math.pow((y - view.axisY) / half, 2));
      ctx.beginPath();
      ctx.moveTo(hx, y);
      ctx.lineTo(hx + (concave ? -7 : 7), y - 5);
      ctx.stroke();
    }
    ctx.restore();
  }

  function drawObject(el, px, sel) {
    drawArrow(el.x, state.objectHeight, '#fbbf24', false, 1, 'object');
    // little lamp/illuminator glyph at base
    ctx.save();
    var baseY = cmToPxY(0);
    ctx.fillStyle = 'rgba(251,191,36,0.18)';
    ctx.beginPath();
    ctx.arc(px, cmToPxY(state.objectHeight), 6, 0, Math.PI * 2);
    ctx.fill();
    ctx.restore();
  }

  function drawScreen(el, px, sel) {
    var half = 5.2 * view.scale;
    var top = view.axisY - half, bot = view.axisY + half;
    ctx.save();
    // frame
    ctx.fillStyle = '#e8e8ee';
    roundRect(px - 3, top, 6, bot - top, 2); ctx.fill();
    ctx.fillStyle = '#cfd6da';
    ctx.fillRect(px - 2, top, 4, bot - top);
    // screen surface (matte)
    ctx.fillStyle = 'rgba(232,232,238,0.10)';
    ctx.fillRect(px - 1, top, 22, bot - top);
    ctx.strokeStyle = 'rgba(232,232,238,0.3)';
    ctx.lineWidth = 1;
    ctx.strokeRect(px - 1, top, 22, bot - top);

    // If an image lands on this screen, paint the projected image.
    var sys = computeSystem();
    var fin = sys.stages.length ? sys.stages[sys.stages.length - 1] : null;
    if (fin && fin.real && isFinite(fin.imgX)) {
      var dist = Math.abs(fin.imgX - el.x);
      var sharp = Math.max(0, 1 - dist / 4); // sharp within 4 cm
      if (sharp > 0.02) {
        var imgPxH = Math.abs(fin.imgH) * view.scale;
        var cy = view.axisY;
        ctx.save();
        ctx.globalAlpha = 0.35 + 0.55 * sharp;
        // blurred if off-plane
        var blur = (1 - sharp) * 6;
        ctx.shadowColor = '#fbbf24';
        ctx.shadowBlur = blur;
        ctx.strokeStyle = '#fbbf24';
        ctx.lineWidth = 2.4;
        var dirUp = fin.imgH >= 0 ? -1 : 1;
        ctx.beginPath();
        ctx.moveTo(px + 10, cy);
        ctx.lineTo(px + 10, cy + dirUp * imgPxH);
        ctx.stroke();
        // head
        ctx.beginPath();
        ctx.moveTo(px + 10, cy + dirUp * imgPxH);
        ctx.lineTo(px + 6, cy + dirUp * (imgPxH - 7));
        ctx.lineTo(px + 14, cy + dirUp * (imgPxH - 7));
        ctx.closePath();
        ctx.fillStyle = '#fbbf24';
        ctx.fill();
        ctx.restore();
        // "in focus" tag
        if (sharp > 0.85) {
          ctx.fillStyle = '#34d399';
          ctx.font = '9px ui-monospace, monospace';
          ctx.textAlign = 'center';
          ctx.fillText('in focus', px + 10, top - 6);
        }
      }
    }
    ctx.restore();
  }

  function drawAperture(el, px, sel) {
    var half = 5.0 * view.scale;
    var slit = 1.2 * view.scale;
    ctx.save();
    ctx.fillStyle = '#1c2029';
    ctx.strokeStyle = '#94a3b8';
    ctx.lineWidth = 1.2;
    // top blade
    roundRect(px - 4, view.axisY - half, 8, half - slit, 2); ctx.fill(); ctx.stroke();
    // bottom blade
    roundRect(px - 4, view.axisY + slit, 8, half - slit, 2); ctx.fill(); ctx.stroke();
    ctx.restore();
  }

  // cm-scale strip across the very bottom for measurement
  function drawScale() {
    // (rail already carries the scale; this is a thin reference rule)
  }

  // ============================================================
  //  READOUT
  // ============================================================
  function updateReadout(sys) {
    var box = document.getElementById('ob-readout');
    if (!box) return;
    if (!sys.stages.length) {
      box.innerHTML = '<div class="ro" style="grid-column:1/3"><div class="k">Status</div>' +
        '<div class="v muted">Add an object and at least one lens or mirror to the rail.</div></div>';
      return;
    }
    var fin = sys.stages[sys.stages.length - 1];
    var u = fin.u, v = fin.v, f = fin.f, m = fin.magTotal;
    var real = fin.real;
    var erect = (m > 0);
    var mag = Math.abs(m);
    var enlarge = mag > 1.0001 ? 'enlarged' : (mag < 0.9999 ? 'diminished' : 'same size');

    function fmt(x, u2) {
      if (!isFinite(x)) return '&#8734;';
      return (Math.round(x * 100) / 100) + (u2 || '');
    }

    // object distance reported as a positive magnitude with a note
    var uMag = Math.abs(u);
    var vMag = Math.abs(v);

    box.innerHTML =
      ro('Object distance |u|', fmt(uMag, ' cm')) +
      ro('Image distance |v|', fmt(vMag, ' cm')) +
      ro('Focal length f', fmt(f, ' cm')) +
      ro('Magnification m', (isFinite(m) ? (Math.round(m * 1000) / 1000) : '&#8734;') + '&times;') +
      roCls('Image type', real ? 'real' : 'virtual', real ? 'real' : 'virt') +
      roCls('Orientation', erect ? 'erect' : 'inverted', '') +
      ro('Size', enlarge) +
      ro('Elements in path', sys.stages.length + '');
  }
  function ro(k, v) {
    return '<div class="ro"><div class="k">' + k + '</div><div class="v">' + v + '</div></div>';
  }
  function roCls(k, v, cls) {
    return '<div class="ro"><div class="k">' + k + '</div><div class="v ' + cls + '">' + v + '</div></div>';
  }

  // ============================================================
  //  ELEMENT LIST (sidebar)
  // ============================================================
  function updateElemList() {
    var list = document.getElementById('ob-elemlist');
    if (!list) return;
    var els = state.elements.slice().sort(function (a, b) { return a.x - b.x; });
    if (!els.length) {
      list.innerHTML = '<div style="font-size:10.5px;color:#6b7280;padding:6px;">No mounts yet. Use a preset or the buttons above.</div>';
      return;
    }
    var html = '';
    for (var i = 0; i < els.length; i++) {
      var el = els[i];
      var t = TYPES[el.type];
      var sel = state.selected === el.id ? ' sel' : '';
      html += '<div class="elem' + sel + '" data-id="' + el.id + '">';
      html += '<div class="ehead" data-sel="' + el.id + '">';
      html += '<span class="dot" style="background:' + t.color + '"></span>';
      html += '<span class="enm">' + labelFor(el) + ' @ ' + (Math.round(el.x * 10) / 10) + 'cm</span>';
      html += '<span class="ex" data-del="' + el.id + '">&times;</span>';
      html += '</div>';
      html += '<div class="ebody">';
      html += miniRow('Position', el.id, 'x', el.x, ' cm');
      if (t.kind === 'lens' || t.kind === 'mirror') {
        html += miniRow('Focal len', el.id, 'f', el.f, ' cm');
      }
      html += '</div></div>';
    }
    list.innerHTML = html;

    // wire interactions
    var heads = list.querySelectorAll('[data-sel]');
    for (var a = 0; a < heads.length; a++) {
      heads[a].addEventListener('click', function (e) {
        if (e.target.getAttribute('data-del')) return;
        var id = +this.getAttribute('data-sel');
        state.selected = (state.selected === id ? null : id);
        render();
      });
    }
    var dels = list.querySelectorAll('[data-del]');
    for (var d = 0; d < dels.length; d++) {
      dels[d].addEventListener('click', function (e) {
        e.stopPropagation();
        var id = +this.getAttribute('data-del');
        removeElement(id);
      });
    }
    var ranges = list.querySelectorAll('input[type=range]');
    for (var r = 0; r < ranges.length; r++) {
      ranges[r].addEventListener('input', function () {
        var id = +this.getAttribute('data-id');
        var key = this.getAttribute('data-key');
        var el = byId(id);
        if (!el) return;
        el[key] = parseFloat(this.value);
        render();
      });
    }
  }

  function miniRow(label, id, key, value, unit) {
    var min, max, step;
    if (key === 'x') { min = 0; max = 140; step = 0.5; }
    else { min = -40; max = 40; step = 1; }
    var h = '<div class="mini">';
    h += '<label>' + label + '</label>';
    h += '<input type="range" data-id="' + id + '" data-key="' + key + '" min="' + min + '" max="' + max + '" step="' + step + '" value="' + value + '">';
    h += '<span class="mv">' + (Math.round(value * 10) / 10) + unit + '</span>';
    h += '</div>';
    return h;
  }

  function byId(id) {
    for (var i = 0; i < state.elements.length; i++)
      if (state.elements[i].id === id) return state.elements[i];
    return null;
  }
  function removeElement(id) {
    state.elements = state.elements.filter(function (e) { return e.id !== id; });
    if (state.selected === id) state.selected = null;
    render();
  }

  // ============================================================
  //  ADD / PRESETS
  // ============================================================
  function addElement(type, x, f) {
    var t = TYPES[type];
    // only one object / one screen at a time? allow multiples except object
    if (type === 'object') {
      var ex = findOne('object');
      if (ex) { ex.x = x; state.selected = ex.id; render(); return ex; }
    }
    var el = { id: uid(), type: type, x: x };
    if (t.kind === 'lens' || t.kind === 'mirror') el.f = (f != null ? f : t.defF);
    state.elements.push(el);
    state.selected = el.id;
    render();
    return el;
  }

  function buildAddBar() {
    var bar = document.getElementById('ob-addbar');
    var defs = [
      ['object', 'Object'],
      ['convex', 'Convex lens'],
      ['concave', 'Concave lens'],
      ['cmirror', 'Concave mirror'],
      ['xmirror', 'Convex mirror'],
      ['screen', 'Screen'],
      ['aperture', 'Aperture']
    ];
    var html = '';
    for (var i = 0; i < defs.length; i++)
      html += '<button class="add" data-add="' + defs[i][0] + '">+ ' + defs[i][1] + '</button>';
    bar.innerHTML = html;
    var btns = bar.querySelectorAll('[data-add]');
    for (var b = 0; b < btns.length; b++) {
      btns[b].addEventListener('click', function () {
        var type = this.getAttribute('data-add');
        // place at a sensible default spot
        var x;
        if (type === 'object') x = 10;
        else {
          // place to the right of the rightmost element
          var maxX = 30;
          for (var i = 0; i < state.elements.length; i++) maxX = Math.max(maxX, state.elements[i].x + 20);
          x = Math.min(maxX, 130);
        }
        addElement(type, x);
      });
    }
  }

  var PRESETS = [
    {
      name: 'Convex lens · object beyond 2F',
      desc: 'Real, inverted, diminished image',
      build: function () {
        clearAll();
        addElement('object', 10);
        addElement('convex', 50, 10);
        // object u = -40, f=10 -> v = 13.33, m = -0.33
        addElement('screen', 50 + 13.33);
        fitView();
      }
    },
    {
      name: 'Object between F and 2F',
      desc: 'Real, inverted, magnified image',
      build: function () {
        clearAll();
        addElement('object', 35);
        addElement('convex', 50, 10);
        // u=-15, f=10 -> v=30, m=-2
        addElement('screen', 80);
        fitView();
      }
    },
    {
      name: 'Object inside F (magnifier)',
      desc: 'Virtual, erect, magnified image',
      build: function () {
        clearAll();
        addElement('object', 44);
        addElement('convex', 50, 10);
        // u=-6, f=10 -> v=-15, m=2.5 (virtual, erect)
        fitView();
      }
    },
    {
      name: 'Concave (diverging) lens',
      desc: 'Always virtual, erect, diminished',
      build: function () {
        clearAll();
        addElement('object', 15);
        addElement('concave', 55, -12);
        // u=-40, f=-12 -> v=-9.2, m=0.23 virtual erect diminished
        fitView();
      }
    },
    {
      name: 'Two-lens compound system',
      desc: 'Objective + eyepiece relay',
      build: function () {
        clearAll();
        addElement('object', 8);
        addElement('convex', 40, 8);   // objective, u=-32 -> v=10.67
        addElement('convex', 75, 6);   // eyepiece
        addElement('screen', 110);
        fitView();
      }
    },
    {
      name: 'Concave mirror · image formation',
      desc: 'Real inverted image (object beyond C)',
      build: function () {
        clearAll();
        addElement('object', 10);
        addElement('cmirror', 80, 12);
        // u=-70, f=12 -> v=14.5, image folds back to the left
        fitView();
      }
    }
  ];

  function buildPresets() {
    var box = document.getElementById('ob-presets');
    var html = '';
    for (var i = 0; i < PRESETS.length; i++) {
      html += '<button class="pre" data-pre="' + i + '"><b>' + (i + 1) + '. ' + PRESETS[i].name + '</b><span>' + PRESETS[i].desc + '</span></button>';
    }
    box.innerHTML = html;
    var btns = box.querySelectorAll('[data-pre]');
    for (var b = 0; b < btns.length; b++) {
      btns[b].addEventListener('click', function () {
        PRESETS[+this.getAttribute('data-pre')].build();
      });
    }
  }

  function clearAll() {
    state.elements = [];
    state.selected = null;
    nextId = 1;
  }

  // ============================================================
  //  VIEW FITTING
  // ============================================================
  function fitView() {
    if (!state.elements.length) { view.x0 = 0; view.scale = 6.2; render(); return; }
    var minX = 1e9, maxX = -1e9;
    for (var i = 0; i < state.elements.length; i++) {
      minX = Math.min(minX, state.elements[i].x);
      maxX = Math.max(maxX, state.elements[i].x);
    }
    // include images
    var sys = computeSystem();
    for (var s = 0; s < sys.stages.length; s++) {
      if (isFinite(sys.stages[s].imgX)) {
        minX = Math.min(minX, sys.stages[s].imgX);
        maxX = Math.max(maxX, sys.stages[s].imgX);
      }
    }
    var span = Math.max(40, (maxX - minX) + 30);
    var usable = W() - PAD_L - PAD_R;
    view.scale = usable / span;
    view.scale = Math.max(2.2, Math.min(12, view.scale));
    view.x0 = minX - 15;
    render();
  }

  // ============================================================
  //  CANVAS INTERACTION (drag mounts / select)
  // ============================================================
  var drag = { active: false, id: null, moved: false };

  function elementAt(px, py) {
    // hit test mounts: within ~16px horizontally and roughly along
    // the post/element vertical extent
    var best = null, bestDx = 18;
    for (var i = 0; i < state.elements.length; i++) {
      var el = state.elements[i];
      var ex = cmToPx(el.x);
      var dx = Math.abs(px - ex);
      if (dx < bestDx) { bestDx = dx; best = el; }
    }
    return best;
  }

  function pointerPos(e) {
    var rect = canvas.getBoundingClientRect();
    var sx = canvas.width / rect.width;
    var sy = canvas.height / rect.height;
    var cx = (e.touches ? e.touches[0].clientX : e.clientX) - rect.left;
    var cy = (e.touches ? e.touches[0].clientY : e.clientY) - rect.top;
    return { x: cx * sx, y: cy * sy };
  }

  function onDown(e) {
    var p = pointerPos(e);
    var el = elementAt(p.x, p.y);
    if (el) {
      drag.active = true; drag.id = el.id; drag.moved = false;
      state.selected = el.id;
      canvas.classList.add('dragging');
      render();
      e.preventDefault();
    } else {
      // empty space: start a pan
      drag.active = true; drag.id = null; drag.panStart = p.x; drag.x0 = view.x0;
      canvas.classList.add('dragging');
    }
  }
  function onMove(e) {
    if (!drag.active) {
      // hover cursor feedback
      return;
    }
    var p = pointerPos(e);
    if (drag.id != null) {
      var el = byId(drag.id);
      if (el) {
        var newCm = pxToCm(p.x);
        newCm = Math.max(0, Math.min(180, newCm));
        el.x = Math.round(newCm * 2) / 2;
        drag.moved = true;
        render();
      }
    } else {
      // pan
      var dxCm = (p.x - drag.panStart) / view.scale;
      view.x0 = drag.x0 - dxCm;
      render();
    }
    if (e.cancelable) e.preventDefault();
  }
  function onUp() {
    drag.active = false; drag.id = null;
    canvas.classList.remove('dragging');
  }

  canvas.addEventListener('mousedown', onDown);
  window.addEventListener('mousemove', onMove);
  window.addEventListener('mouseup', onUp);
  canvas.addEventListener('touchstart', onDown, { passive: false });
  canvas.addEventListener('touchmove', onMove, { passive: false });
  window.addEventListener('touchend', onUp);

  // mouse wheel zoom around cursor
  canvas.addEventListener('wheel', function (e) {
    e.preventDefault();
    var p = pointerPos(e);
    var cmAt = pxToCm(p.x);
    var factor = e.deltaY < 0 ? 1.12 : 1 / 1.12;
    view.scale = Math.max(2.0, Math.min(16, view.scale * factor));
    // keep cmAt under cursor
    view.x0 = cmAt - (p.x - PAD_L) / view.scale;
    render();
  }, { passive: false });

  // ============================================================
  //  TOOLBAR + GLOBAL CONTROLS
  // ============================================================
  function zoom(factor) {
    var centerCm = pxToCm(W() / 2);
    view.scale = Math.max(2.0, Math.min(16, view.scale * factor));
    view.x0 = centerCm - (W() / 2 - PAD_L) / view.scale;
    render();
  }
  document.getElementById('ob-zoomin').addEventListener('click', function () { zoom(1.18); });
  document.getElementById('ob-zoomout').addEventListener('click', function () { zoom(1 / 1.18); });
  document.getElementById('ob-fit').addEventListener('click', fitView);

  document.getElementById('ob-snapscreen').addEventListener('click', function () {
    var sc = findScreen();
    var sys = computeSystem();
    var fin = sys.stages.length ? sys.stages[sys.stages.length - 1] : null;
    if (!fin || !isFinite(fin.imgX)) return;
    if (!sc) { addElement('screen', fin.imgX); }
    else { sc.x = Math.round(fin.imgX * 2) / 2; render(); }
  });

  // object height slider
  var objh = document.getElementById('ob-objh');
  objh.addEventListener('input', function () {
    state.objectHeight = parseFloat(this.value);
    document.getElementById('ob-objh-v').textContent = state.objectHeight.toFixed(1) + ' cm';
    render();
  });
  var raysEl = document.getElementById('ob-rays');
  raysEl.addEventListener('input', function () {
    state.rayCount = parseInt(this.value, 10);
    document.getElementById('ob-rays-v').textContent = state.rayCount + '';
    render();
  });
  document.getElementById('ob-grid').addEventListener('change', function () {
    state.showMarkers = this.checked; render();
  });
  document.getElementById('ob-extend').addEventListener('change', function () {
    state.extendVirtual = this.checked; render();
  });

  // ============================================================
  //  UTIL
  // ============================================================
  function roundRect(x, y, w, h, r) {
    if (w < 2 * r) r = w / 2;
    if (h < 2 * r) r = h / 2;
    ctx.beginPath();
    ctx.moveTo(x + r, y);
    ctx.arcTo(x + w, y, x + w, y + h, r);
    ctx.arcTo(x + w, y + h, x, y + h, r);
    ctx.arcTo(x, y + h, x, y, r);
    ctx.arcTo(x, y, x + w, y, r);
    ctx.closePath();
  }

  // ============================================================
  //  SELF-TEST (console): verify the physics on load.
  //   convex f=10, object at u=-30 (30cm to the left) => v=15, m=-0.5
  // ============================================================
  (function selfTest() {
    var t1 = thinLens(-30, 10);  // expect v=15, m=-0.5
    var ok1 = Math.abs(t1.v - 15) < 1e-6 && Math.abs(t1.m + 0.5) < 1e-6;
    var t2 = thinLens(-6, 10);   // inside F: v=-15, m=2.5 virtual erect
    var ok2 = Math.abs(t2.v + 15) < 1e-6 && Math.abs(t2.m - 2.5) < 1e-6;
    var t3 = thinLens(-40, -12); // concave: v=-9.23, m=0.23 virtual
    var ok3 = Math.abs(t3.v - (-120 / 13)) < 1e-3;
    var t4 = mirror(-70, 12);    // concave mirror: 1/v = 1/12 - 1/(-70)
    var ok4 = isFinite(t4.v);
    if (window && window.console) {
      console.log('[optics-bench] self-test:',
        'lens f10 u30 ->', 'v=' + t1.v.toFixed(2), 'm=' + t1.m.toFixed(2), ok1 ? 'PASS' : 'FAIL', '|',
        'inside-F', ok2 ? 'PASS' : 'FAIL', '|',
        'concave-lens', ok3 ? 'PASS' : 'FAIL', '|',
        'concave-mirror', ok4 ? 'PASS' : 'FAIL');
    }
  })();

  // ============================================================
  //  INIT
  // ============================================================
  buildPresets();
  buildAddBar();
  // load default preset 1
  PRESETS[0].build();
  // ensure readout/list painted
  render();

  // responsive: keep canvas crisp on resize
  function fitCanvasDPR() {
    // keep logical 900x540 internal; CSS stretches. Re-render only.
    render();
  }
  window.addEventListener('resize', function () { fitCanvasDPR(); });

})();
</script>
</BaseLayout>
