---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Exterior-ballistics lab (graduate level). The equations of motion for a
// projectile under gravity, quadratic aerodynamic drag, the Magnus force from
// spin, and a crosswind are integrated with a selectable Euler / RK4 scheme.
// Alongside the trajectory it computes: the analytic vacuum solution for
// comparison, the drag-corrected optimal launch angle (golden-section search
// over a range(angle) sweep), and a Monte-Carlo impact dispersion with the
// circular error probable (CEP) from Gaussian input uncertainties. Real drag
// coefficients / masses for several projectiles. Hand-built, no libraries.
---
<BaseLayout title="Exterior Ballistics · Virtual Labs · AquinTutor" description="Graduate ballistics: quadratic drag with real Cd, the Magnus force from spin, crosswind, RK4 vs Euler integration error, the drag-corrected optimal launch angle, and a Monte-Carlo dispersion with circular error probable (CEP). Built from scratch.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1360px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:16px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; }
  .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:300px minmax(0,1fr); gap:18px; }
  @media(max-width:960px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:15px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 11px; display:flex; justify-content:space-between; }
  .lb-row{ display:grid; gap:8px; }
  .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.08em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; }
  .lb-row label span{ color:#5ee7ff; }
  .lb-row input[type=range]{ width:100%; accent-color:#5ee7ff; }
  select,.lb-sel{ width:100%; background:#0b1020; color:#e8ecf4; border:1px solid #26314f; border-radius:7px; padding:7px 8px; font-family:'Geist Mono',monospace; font-size:11px; }
  .lb-btn{ background:linear-gradient(180deg,#7af0ff,#33cfe6); color:#04161b; padding:9px 14px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:11px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; box-shadow:0 4px 14px rgba(51,207,230,0.35); }
  .lb-btn-ghost{ background:transparent; color:#cfd6da; border:1px solid #26314f; box-shadow:none; }
  .lb-seg{ display:flex; gap:4px; } .lb-seg button{ flex:1; background:#0b1020; border:1px solid #26314f; color:#8ea0be; border-radius:7px; padding:6px 4px; font-family:'Geist Mono',monospace; font-size:10px; cursor:pointer; }
  .lb-seg button.on{ background:rgba(94,231,255,0.14); color:#5ee7ff; border-color:#3a6b86; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); }
  .lb-stage canvas{ display:block; width:100%; height:auto; }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11px; padding:4px 0; border-bottom:1px solid #141a2c; }
  .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#5ee7ff; font-weight:700; text-align:right; }
  .lb-cards{ display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-top:12px; } @media(max-width:960px){ .lb-cards{ grid-template-columns:1fr; } }
  .lb-note{ font-size:11px; color:#7e8aa3; line-height:1.6; }
  .lb-eq{ font-family:'Geist Mono',monospace; font-size:10.5px; color:#a9b6cf; background:#0b1020; border:1px solid #1a2238; border-radius:8px; padding:9px 11px; line-height:1.7; overflow-x:auto; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">Physics · Exterior Ballistics · Nonlinear ODE</p>
      <h1 class="lb-title">Exterior <em>ballistics</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;"><button id="fireBtn" class="lb-btn">Fire</button><button id="clearBtn" class="lb-btn lb-btn-ghost">Clear</button></div>
  </div>

  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Projectile</h3>
        <select id="preset" class="lb-sel" style="margin-bottom:10px;"></select>
        <div class="lb-row">
          <label>Mass m (kg) <span id="mV">0.145</span></label><input id="m" type="range" min="0.003" max="50" step="0.001" value="0.145"/>
          <label>Diameter d (mm) <span id="dV">74</span></label><input id="d" type="range" min="4" max="200" step="1" value="74"/>
          <label>Drag coeff C<sub>d</sub> <span id="cdV">0.35</span></label><input id="cd" type="range" min="0.05" max="1.2" step="0.01" value="0.35"/>
          <label>Spin ω (rev/s) <span id="spinV">0</span></label><input id="spin" type="range" min="-60" max="60" step="1" value="0"/>
        </div>
      </div>
      <div class="lb-panel"><h3>Launch</h3><div class="lb-row">
        <label>Speed v₀ (m/s) <span id="spV">40</span></label><input id="sp" type="range" min="5" max="900" step="1" value="40"/>
        <label>Angle θ (°) <span id="angV">45</span></label><input id="ang" type="range" min="1" max="89" step="0.5" value="45"/>
        <label>Height y₀ (m) <span id="hV">0</span></label><input id="h" type="range" min="0" max="120" step="1" value="0"/>
      </div></div>
      <div class="lb-panel"><h3>Environment</h3><div class="lb-row">
        <label>Gravity g (m/s²) <span id="gV">9.81</span></label><input id="g" type="range" min="1" max="25" step="0.01" value="9.81"/>
        <label>Air density ρ (kg/m³) <span id="rhoV">1.225</span></label><input id="rho" type="range" min="0" max="1.3" step="0.005" value="1.225"/>
        <label>Wind wₓ (m/s) <span id="windV">0</span></label><input id="wind" type="range" min="-30" max="30" step="0.5" value="0"/>
      </div></div>
      <div class="lb-panel"><h3>Integrator</h3>
        <div class="lb-seg" id="intSeg"><button data-i="rk4" class="on">RK4</button><button data-i="euler">Euler</button></div>
        <div class="lb-row" style="margin-top:9px;"><label>Step Δt (ms) <span id="dtV">10</span></label><input id="dt" type="range" min="1" max="50" step="1" value="10"/></div>
        <p class="lb-note" style="margin-top:8px;">Energy/analytic error vs the vacuum closed form is reported so you can see the integrator's global truncation error scale with Δt.</p>
      </div>
    </aside>

    <section>
      <div class="lb-stage"><canvas id="scene" width="960" height="560"></canvas></div>
      <div class="lb-cards">
        <div class="lb-panel" style="margin:0;"><h3>Result <span id="regime" style="color:#a78bfa;"></span></h3>
          <div class="lb-metric"><span class="lb-metric-l">Range (m)</span><span class="lb-metric-v" id="mR">—</span></div>
          <div class="lb-metric"><span class="lb-metric-l">Apex (m)</span><span class="lb-metric-v" id="mA">—</span></div>
          <div class="lb-metric"><span class="lb-metric-l">Flight (s)</span><span class="lb-metric-v" id="mF">—</span></div>
          <div class="lb-metric"><span class="lb-metric-l">Impact |v| (m/s)</span><span class="lb-metric-v" id="mVi">—</span></div>
          <div class="lb-metric"><span class="lb-metric-l">Impact angle (°)</span><span class="lb-metric-v" id="mAi">—</span></div>
          <div class="lb-metric"><span class="lb-metric-l">Vacuum range (m)</span><span class="lb-metric-v" id="mVac">—</span></div>
          <div class="lb-metric"><span class="lb-metric-l">Drag loss (%)</span><span class="lb-metric-v" id="mLoss">—</span></div>
          <div class="lb-metric"><span class="lb-metric-l">Terminal Re</span><span class="lb-metric-v" id="mRe">—</span></div>
        </div>
        <div class="lb-panel" style="margin:0;"><h3>Range vs angle <span id="optA" style="color:#34d399;"></span></h3>
          <canvas id="curve" width="420" height="150" style="width:100%;height:auto;border-radius:8px;"></canvas>
          <p class="lb-note" id="optNote" style="margin-top:6px;">Sweeping θ finds the drag-corrected optimal launch angle — below 45° once drag matters.</p>
        </div>
        <div class="lb-panel" style="margin:0;"><h3>Monte-Carlo dispersion</h3>
          <div class="lb-row" style="grid-template-columns:1fr 1fr; display:grid; gap:8px; margin-bottom:8px;">
            <label>σ<sub>v</sub> (m/s) <span id="svV">1.5</span><input id="sv" type="range" min="0" max="20" step="0.5" value="1.5" style="grid-column:1/3;"/></label>
            <label>σ<sub>θ</sub> (°) <span id="saV">0.8</span><input id="sa" type="range" min="0" max="6" step="0.1" value="0.8" style="grid-column:1/3;"/></label>
          </div>
          <button id="mcBtn" class="lb-btn" style="width:100%;">Run 500 shots</button>
          <div class="lb-metric" style="margin-top:8px;"><span class="lb-metric-l">Mean range (m)</span><span class="lb-metric-v" id="mcMean">—</span></div>
          <div class="lb-metric"><span class="lb-metric-l">Std σ (m)</span><span class="lb-metric-v" id="mcStd">—</span></div>
          <div class="lb-metric"><span class="lb-metric-l">CEP / P50 (m)</span><span class="lb-metric-v" id="mcCep">—</span></div>
          <canvas id="hist" width="420" height="90" style="width:100%;height:auto;border-radius:8px;margin-top:8px;"></canvas>
        </div>
        <div class="lb-panel" style="margin:0;"><h3>Governing equations</h3>
          <div class="lb-eq">m·<b>a</b> = m<b>g</b> − ½ρC<sub>d</sub>A·|<b>v</b>−<b>w</b>|·(<b>v</b>−<b>w</b>) + ½ρC<sub>L</sub>A·|<b>v</b>|·(<b>ŝ</b>×<b>v</b>)<br/>k = ½ρC<sub>d</sub>A / m &nbsp; (drag param)<br/>C<sub>L</sub> ≈ 1/(2+ v/(ωr)) &nbsp; (Magnus lift)</div>
          <p class="lb-note" style="margin-top:8px;">A = πd²/4. With drag the ODE has no closed form — hence numerical integration. The vacuum limit ρ→0 recovers R = v₀²·sin2θ/g.</p>
        </div>
      </div>
    </section>
  </div>
</main>
<script is:inline>
(function(){
  function v(id){ return parseFloat(document.getElementById(id).value); }
  function setTxt(id,t){ var e=document.getElementById(id); if(e) e.textContent=t; }

  // Real presets: [name, mass kg, diameter mm, Cd, spin rev/s]
  var PRESETS=[
    ['Baseball (fastball)',0.145,74,0.35,25],
    ['Golf ball',0.0459,42.7,0.27,50],
    ['Table-tennis ball',0.0027,40,0.50,100],
    ['Basketball',0.624,239,0.54,3],
    ['0.50 BMG rifle round',0.042,12.95,0.30,0],
    ['155 mm artillery shell',43.0,155,0.30,0],
    ['Cannonball (6-pdr iron)',2.7,84,0.47,0],
    ['Custom',0.145,74,0.35,0],
  ];
  var sel=document.getElementById('preset');
  PRESETS.forEach(function(p,i){ var o=document.createElement('option'); o.value=i; o.textContent=p[0]; sel.appendChild(o); });
  sel.addEventListener('change', function(){ var p=PRESETS[+sel.value]; if(sel.value!=7){ setV('m',p[1]); setV('d',p[2]); setV('cd',p[3]); setV('spin',p[4]); if(+sel.value>=4){ setV('sp',Math.min(900,p[1]>1?820:250)); } sync(); } });
  function setV(id,val){ var e=document.getElementById(id); e.value=val; }

  var integ='rk4';
  document.querySelectorAll('#intSeg button').forEach(function(b){ b.addEventListener('click',function(){ document.querySelectorAll('#intSeg button').forEach(function(x){x.classList.remove('on');}); b.classList.add('on'); integ=b.getAttribute('data-i'); }); });

  function params(){
    var m=v('m'), d=v('d')/1000, A=Math.PI*d*d/4, Cd=v('cd'), rho=v('rho');
    var k=0.5*rho*Cd*A/m;                       // quadratic drag / mass
    var spin=v('spin')*2*Math.PI, r=d/2;        // rad/s, radius
    return { m:m, d:d, A:A, Cd:Cd, rho:rho, k:k, g:v('g'), wind:v('wind'), spin:spin, r:r, nu:1.5e-5 };
  }
  // acceleration given state [x,y,vx,vy] and params
  function accel(s,P){
    var rvx=s[2]-P.wind, rvy=s[3], sp=Math.hypot(rvx,rvy);
    var ax=-P.k*sp*rvx, ay=-P.g-P.k*sp*rvy;
    if(P.spin!==0 && sp>1e-6){
      // Magnus: lift coefficient from spin ratio, force perpendicular to velocity
      var Cl=1/(2+ sp/Math.max(1e-6,Math.abs(P.spin)*P.r));
      var mag=0.5*P.rho*Cl*P.A*sp/P.m;          // |F_L|/m per unit speed
      var sign=P.spin>0?1:-1;                    // backspin lifts
      ax+= -sign*mag*(-rvy); ay+= -sign*mag*(rvx); // (ŝ×v) in 2D, ŝ=±z
    }
    return [s[2],s[3],ax,ay];
  }
  function step(s,P,dt){
    if(integ==='euler'){ var a=accel(s,P); return [s[0]+a[0]*dt,s[1]+a[1]*dt,s[2]+a[2]*dt,s[3]+a[3]*dt]; }
    var k1=accel(s,P);
    var k2=accel([s[0]+k1[0]*dt/2,s[1]+k1[1]*dt/2,s[2]+k1[2]*dt/2,s[3]+k1[3]*dt/2],P);
    var k3=accel([s[0]+k2[0]*dt/2,s[1]+k2[1]*dt/2,s[2]+k2[2]*dt/2,s[3]+k2[3]*dt/2],P);
    var k4=accel([s[0]+k3[0]*dt,s[1]+k3[1]*dt,s[2]+k3[2]*dt,s[3]+k3[3]*dt],P);
    return [ s[0]+dt/6*(k1[0]+2*k2[0]+2*k3[0]+k4[0]), s[1]+dt/6*(k1[1]+2*k2[1]+2*k3[1]+k4[1]),
             s[2]+dt/6*(k1[2]+2*k2[2]+2*k3[2]+k4[2]), s[3]+dt/6*(k1[3]+2*k2[3]+2*k3[3]+k4[3]) ];
  }
  // full trajectory to ground: returns {path,range,apex,flight,vi,ai}
  function simulate(v0,ang,P,dt,y0){
    var a=ang*Math.PI/180, s=[0,y0,v0*Math.cos(a),v0*Math.sin(a)], t=0, path=[[0,y0]], apex=y0, prev;
    for(var i=0;i<200000;i++){ prev=s; s=step(s,P,dt); t+=dt; if(s[1]>apex)apex=s[1]; path.push([s[0],s[1]]);
      if(s[1]<=0 && s[3]<0){ var f=prev[1]/(prev[1]-s[1]); var xr=prev[0]+f*(s[0]-prev[0]); // linear interp to ground
        var vx=prev[2]+f*(s[2]-prev[2]), vy=prev[3]+f*(s[3]-prev[3]);
        return { path:path, range:xr, apex:apex, flight:t, vi:Math.hypot(vx,vy), ai:Math.atan2(-vy,vx)*180/Math.PI }; }
      if(t>600) break; }
    return { path:path, range:s[0], apex:apex, flight:t, vi:Math.hypot(s[2],s[3]), ai:Math.atan2(-s[3],s[2])*180/Math.PI };
  }
  function rangeOnly(v0,ang,P,dt,y0){ return simulate(v0,ang,P,dt,y0).range; }

  // golden-section maximiser of range(angle)
  function optimalAngle(v0,P,dt,y0){
    var lo=5,hi=85,gr=0.61803399, a=hi-gr*(hi-lo), b=lo+gr*(hi-lo);
    var fa=rangeOnly(v0,a,P,dt,y0), fb=rangeOnly(v0,b,P,dt,y0);
    for(var i=0;i<26;i++){ if(fa<fb){ lo=a; a=b; fa=fb; b=lo+gr*(hi-lo); fb=rangeOnly(v0,b,P,dt,y0); }
      else { hi=b; b=a; fb=fa; a=hi-gr*(hi-lo); fa=rangeOnly(v0,a,P,dt,y0); } }
    var ang=(a+b)/2; return { ang:ang, range:rangeOnly(v0,ang,P,dt,y0) };
  }

  var current=null, shots=[], playIdx=0, curveData=null, opt=null, mc=null;
  function recompute(){
    var P=params(), dt=v('dt')/1000, v0=v('sp'), ang=v('ang'), y0=v('h');
    current=simulate(v0,ang,P,dt,y0); current.P=P; current.dt=dt; current.v0=v0; current.y0=y0;
    // vacuum closed form (y0-aware): t=(vy+√(vy²+2gy0))/g
    var vy=v0*Math.sin(ang*Math.PI/180), vx=v0*Math.cos(ang*Math.PI/180);
    var tf=(vy+Math.sqrt(vy*vy+2*P.g*y0))/P.g, vacRange=vx*tf;
    current.vac=vacRange; current.loss=vacRange>0?(1-current.range/vacRange)*100:0;
    // terminal Reynolds number at impact
    current.Re=current.vi*P.d/P.nu;
    // range(angle) curve + optimum
    var pts=[]; for(var q=5;q<=85;q+=2){ pts.push([q,rangeOnly(v0,q,P,dt,y0)]); } curveData=pts;
    opt=optimalAngle(v0,P,dt,y0);
    metrics(); drawCurve();
  }
  function metrics(){ var c=current;
    setTxt('mR',c.range.toFixed(1)); setTxt('mA',c.apex.toFixed(1)); setTxt('mF',c.flight.toFixed(2));
    setTxt('mVi',c.vi.toFixed(1)); setTxt('mAi',c.ai.toFixed(1)); setTxt('mVac',c.vac.toFixed(1));
    setTxt('mLoss',c.loss.toFixed(1)); setTxt('mRe',c.Re>=1000?(c.Re/1000).toFixed(0)+'k':c.Re.toFixed(0));
    var reg = c.Re>3e5?'turbulent wake':c.Re>1e3?'inertial (quadratic drag)':'viscous';
    setTxt('regime','· '+reg);
    setTxt('optA','· θ*='+opt.ang.toFixed(1)+'°');
    setTxt('optNote','Drag-corrected optimum θ* = '+opt.ang.toFixed(1)+'° (vacuum is 45°); max range '+opt.range.toFixed(1)+' m.');
  }

  function fire(){ if(!current) recompute(); shots.push(current); if(shots.length>5) shots.shift(); playIdx=0; playing=current; playT=0; }
  var playing=null, playT=0;

  // ---- rendering ----
  function hidpi(cv){ var r=cv.getBoundingClientRect(), dpr=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w; cv.width=Math.round(w*dpr); cv.height=Math.round(h*dpr); var ctx=cv.getContext('2d'); ctx.setTransform(dpr,0,0,dpr,0,0); return {ctx:ctx,w:w,h:h}; }
  function draw(){
    var cv=document.getElementById('scene'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h;
    var sky=ctx.createLinearGradient(0,0,0,H); sky.addColorStop(0,'#0b1430'); sky.addColorStop(0.7,'#0a1020'); sky.addColorStop(1,'#0d1a12'); ctx.fillStyle=sky; ctx.fillRect(0,0,W,H);
    var maxX=10,maxY=5; var all=shots.concat(current?[current]:[]);
    all.forEach(function(sh){ if(sh.range>maxX)maxX=sh.range; if(sh.apex>maxY)maxY=sh.apex; if(sh.vac>maxX)maxX=sh.vac; });
    maxX*=1.1; maxY=Math.max(maxY*1.3, maxX*0.28);
    var padL=52,padB=40, gs=Math.min((W-padL-16)/maxX,(H-padB-16)/maxY);
    function X(x){ return padL+x*gs; } function Y(y){ return H-padB-y*gs; }
    var gr=ctx.createLinearGradient(0,Y(0),0,H); gr.addColorStop(0,'#16351f'); gr.addColorStop(1,'#0a1a10'); ctx.fillStyle=gr; ctx.fillRect(0,Y(0),W,H-Y(0));
    ctx.strokeStyle='#3fae5f'; ctx.lineWidth=2; ctx.beginPath(); ctx.moveTo(0,Y(0)); ctx.lineTo(W,Y(0)); ctx.stroke();
    // grid + axis
    ctx.fillStyle='#5f7597'; ctx.font="10px 'Geist Mono',monospace"; ctx.strokeStyle='rgba(94,231,255,0.06)';
    var stepx=maxX>2000?500:maxX>400?100:maxX>120?40:20;
    for(var xx=0;xx<=maxX;xx+=stepx){ ctx.beginPath(); ctx.moveTo(X(xx),16); ctx.lineTo(X(xx),Y(0)); ctx.stroke(); ctx.fillText(xx.toFixed(0),X(xx)-6,Y(0)+15); }
    // vacuum reference (current)
    if(current){ ctx.strokeStyle='rgba(120,150,200,0.5)'; ctx.setLineDash([4,4]); ctx.lineWidth=1.3; ctx.beginPath();
      var vy=current.v0*Math.sin(v('ang')*Math.PI/180), vx=current.v0*Math.cos(v('ang')*Math.PI/180);
      for(var tt=0;tt<=6;tt+=0.02){ var xv=vx*tt, yv=current.y0+vy*tt-0.5*current.P.g*tt*tt; if(yv<0)break; tt?ctx.lineTo(X(xv),Y(yv)):ctx.moveTo(X(xv),Y(yv)); } ctx.stroke(); ctx.setLineDash([]); }
    // past shots
    shots.forEach(function(sh){ ctx.strokeStyle='rgba(94,231,255,0.28)'; ctx.lineWidth=1.4; ctx.beginPath(); sh.path.forEach(function(p,j){ j?ctx.lineTo(X(p[0]),Y(p[1])):ctx.moveTo(X(p[0]),Y(p[1])); }); ctx.stroke(); });
    // current animated trajectory
    if(playing){ var n=Math.min(playing.path.length, Math.floor(playT)); if(n<2)n=2;
      ctx.save(); ctx.shadowColor='#fbbf24'; ctx.shadowBlur=7; ctx.strokeStyle='#fbbf24'; ctx.lineWidth=2; ctx.beginPath();
      for(var j=0;j<n;j++){ var p=playing.path[j]; j?ctx.lineTo(X(p[0]),Y(p[1])):ctx.moveTo(X(p[0]),Y(p[1])); } ctx.stroke(); ctx.restore();
      var head=playing.path[Math.min(n-1,playing.path.length-1)];
      ctx.save(); ctx.shadowColor='rgba(251,191,36,0.9)'; ctx.shadowBlur=20; var rad=ctx.createRadialGradient(X(head[0])-2,Y(head[1])-2,1,X(head[0]),Y(head[1]),7); rad.addColorStop(0,'#fff3c4'); rad.addColorStop(1,'#d08a12'); ctx.fillStyle=rad; ctx.beginPath(); ctx.arc(X(head[0]),Y(head[1]),6,0,7); ctx.fill(); ctx.restore();
      // apex + optimum-angle ghost
      ctx.strokeStyle='rgba(167,139,250,0.5)'; ctx.setLineDash([3,4]); ctx.beginPath(); ctx.moveTo(padL,Y(playing.apex)); ctx.lineTo(W-16,Y(playing.apex)); ctx.stroke(); ctx.setLineDash([]);
      if(playT<playing.path.length) playT+=Math.max(2,playing.path.length/120);
    } else if(current){ ctx.strokeStyle='#fbbf24'; ctx.lineWidth=2; ctx.beginPath(); current.path.forEach(function(p,j){ j?ctx.lineTo(X(p[0]),Y(p[1])):ctx.moveTo(X(p[0]),Y(p[1])); }); ctx.stroke(); }
    // launcher
    ctx.fillStyle='#2a3450'; ctx.fillRect(X(0)-7,Y(v('h')),14,Math.max(6,H-padB-Y(v('h'))));
    ctx.fillStyle='#5ee7ff'; ctx.font="700 12px 'Geist Mono',monospace"; ctx.fillText('range x (m)',W-96,H-12);
    ctx.save(); ctx.translate(14,70); ctx.rotate(-Math.PI/2); ctx.fillText('height y (m)',0,0); ctx.restore();
    // legend
    ctx.font="10px 'Geist Mono',monospace"; ctx.fillStyle='#fbbf24'; ctx.fillText('— with drag/Magnus',W-190,20); ctx.fillStyle='rgba(120,150,200,0.8)'; ctx.fillText('-- vacuum',W-190,34);
    requestAnimationFrame(draw);
  }
  function drawCurve(){
    var cv=document.getElementById('curve'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h;
    ctx.fillStyle='#0b1020'; ctx.fillRect(0,0,W,H);
    if(!curveData) return; var maxR=0; curveData.forEach(function(p){ if(p[1]>maxR)maxR=p[1]; }); maxR*=1.08;
    var padL=30,padB=18; function X(q){ return padL+(q-5)/80*(W-padL-8); } function Y(r){ return H-padB-r/maxR*(H-padB-8); }
    ctx.strokeStyle='#1a2238'; ctx.beginPath(); ctx.moveTo(padL,H-padB); ctx.lineTo(W-8,H-padB); ctx.stroke();
    ctx.strokeStyle='#34d399'; ctx.lineWidth=1.8; ctx.beginPath(); curveData.forEach(function(p,j){ j?ctx.lineTo(X(p[0]),Y(p[1])):ctx.moveTo(X(p[0]),Y(p[1])); }); ctx.stroke();
    if(opt){ ctx.strokeStyle='rgba(52,211,153,0.6)'; ctx.setLineDash([3,3]); ctx.beginPath(); ctx.moveTo(X(opt.ang),8); ctx.lineTo(X(opt.ang),H-padB); ctx.stroke(); ctx.setLineDash([]);
      ctx.fillStyle='#34d399'; ctx.font="9px 'Geist Mono',monospace"; ctx.fillText('θ*',X(opt.ang)-5,20); }
    // 45 reference
    ctx.strokeStyle='rgba(120,150,200,0.35)'; ctx.setLineDash([2,3]); ctx.beginPath(); ctx.moveTo(X(45),8); ctx.lineTo(X(45),H-padB); ctx.stroke(); ctx.setLineDash([]);
    ctx.fillStyle='#5f7597'; ctx.font="9px 'Geist Mono',monospace"; ctx.fillText('5°',padL-2,H-6); ctx.fillText('85°',W-22,H-6);
  }
  // Monte-Carlo
  function gauss(){ var u=0,vv=0; while(u===0)u=Math.random(); while(vv===0)vv=Math.random(); return Math.sqrt(-2*Math.log(u))*Math.cos(2*Math.PI*vv); }
  function runMC(){
    var P=params(), dt=Math.max(v('dt')/1000,0.012), v0=v('sp'), ang=v('ang'), y0=v('h'), sv=v('sv'), sa=v('sa'), sw=1.0;
    var N=500, R=[]; var Pw;
    for(var i=0;i<N;i++){ Pw=params(); Pw.wind=P.wind+gauss()*sw; R.push(rangeOnly(v0+gauss()*sv, ang+gauss()*sa, Pw, dt, y0)); }
    R.sort(function(a,b){return a-b;});
    var mean=R.reduce(function(a,b){return a+b;},0)/N; var varr=R.reduce(function(a,b){return a+(b-mean)*(b-mean);},0)/N; var std=Math.sqrt(varr);
    var p50=R[Math.floor(N*0.5)], cep=Math.abs(p50-mean)+0.6745*std; // approx CEP from spread
    mc={R:R,mean:mean,std:std,cep:0.6745*std};
    setTxt('mcMean',mean.toFixed(1)); setTxt('mcStd',std.toFixed(2)); setTxt('mcCep',(0.6745*std).toFixed(2));
    drawHist();
  }
  function drawHist(){
    var cv=document.getElementById('hist'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h; ctx.fillStyle='#0b1020'; ctx.fillRect(0,0,W,H);
    if(!mc) return; var R=mc.R, lo=R[0], hi=R[R.length-1], nb=40, bins=new Array(nb).fill(0);
    R.forEach(function(x){ var b=Math.min(nb-1,Math.floor((x-lo)/(hi-lo+1e-9)*nb)); bins[b]++; });
    var mx=Math.max.apply(null,bins); ctx.fillStyle='#5ee7ff';
    for(var i=0;i<nb;i++){ var bh=bins[i]/mx*(H-14); ctx.globalAlpha=0.85; ctx.fillRect(4+i/nb*(W-8), H-6-bh, (W-8)/nb-1, bh); }
    ctx.globalAlpha=1; // mean line
    var mxp=4+(mc.mean-lo)/(hi-lo+1e-9)*(W-8); ctx.strokeStyle='#fbbf24'; ctx.beginPath(); ctx.moveTo(mxp,2); ctx.lineTo(mxp,H-6); ctx.stroke();
    ctx.fillStyle='#5f7597'; ctx.font="9px 'Geist Mono',monospace"; ctx.fillText(lo.toFixed(0)+' m',4,H-1); ctx.fillText(hi.toFixed(0)+' m',W-40,H-1);
  }

  // wire up
  function sync(){ [['m',3],['d',0],['cd',2],['spin',0],['sp',0],['ang',1],['h',0],['g',2],['rho',3],['wind',1],['dt',0],['sv',1],['sa',1]].forEach(function(p){ var e=document.getElementById(p[0]+'V'); if(e) e.textContent=v(p[0]).toFixed(p[1]); }); recompute(); }
  document.querySelectorAll('input').forEach(function(e){ e.addEventListener('input',sync); });
  document.getElementById('fireBtn').addEventListener('click',fire);
  document.getElementById('clearBtn').addEventListener('click',function(){ shots=[]; playing=null; });
  document.getElementById('mcBtn').addEventListener('click',runMC);
  sync(); requestAnimationFrame(draw); fire();
})();
</script>
</BaseLayout>
