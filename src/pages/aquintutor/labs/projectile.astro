---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Projectile lab — launch dynamics with optional quadratic drag, integrated
// numerically, rendered on a depth-lit high-DPI canvas: sky gradient, ground,
// launcher, glowing shell with motion-blur trail, apex marker, range ruler.
---
<BaseLayout title="Projectile lab · Virtual Labs · AquinTutor" description="Launch angle, speed, gravity and air drag — watch the trajectory, apex and range in real time on a depth-lit canvas.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1320px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:18px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; }
  .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:290px minmax(0,1fr); gap:18px; }
  @media(max-width:900px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:16px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 12px; }
  .lb-row{ display:grid; gap:9px; }
  .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.1em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; }
  .lb-row label span{ color:#5ee7ff; }
  .lb-row input[type=range]{ width:100%; accent-color:#5ee7ff; }
  .lb-btn{ background:linear-gradient(180deg,#7af0ff,#33cfe6); color:#04161b; padding:9px 16px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:11px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; box-shadow:0 4px 14px rgba(51,207,230,0.35); }
  .lb-btn-ghost{ background:transparent; color:#cfd6da; border:1px solid #26314f; box-shadow:none; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); }
  .lb-stage canvas{ display:block; width:100%; height:auto; }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11.5px; padding:5px 0; border-bottom:1px solid #141a2c; }
  .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#5ee7ff; font-weight:700; text-align:right; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">Physics · Kinematics</p>
      <h1 class="lb-title">Projectile <em>motion</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;"><button id="fireBtn" class="lb-btn">Fire</button><button id="clearBtn" class="lb-btn lb-btn-ghost">Clear</button></div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Launch</h3><div class="lb-row">
        <label>Speed (m/s) <span id="spV">30</span></label><input id="sp" type="range" min="5" max="80" step="1" value="30"/>
        <label>Angle (°) <span id="angV">45</span></label><input id="ang" type="range" min="1" max="89" step="1" value="45"/>
        <label>Height (m) <span id="hV">0</span></label><input id="h" type="range" min="0" max="50" step="1" value="0"/>
        <label>Gravity (m/s²) <span id="gV">9.81</span></label><input id="g" type="range" min="1" max="25" step="0.1" value="9.81"/>
        <label>Air drag <span id="drV">0.00</span></label><input id="dr" type="range" min="0" max="0.06" step="0.002" value="0"/>
      </div></div>
      <div class="lb-panel"><h3>Live &amp; result</h3>
        <div class="lb-metric"><span class="lb-metric-l">t (s)</span><span class="lb-metric-v" id="mT">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">x (m)</span><span class="lb-metric-v" id="mX">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">y (m)</span><span class="lb-metric-v" id="mY">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">|v| (m/s)</span><span class="lb-metric-v" id="mV">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Range (m)</span><span class="lb-metric-v" id="mR">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Apex (m)</span><span class="lb-metric-v" id="mA">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Flight (s)</span><span class="lb-metric-v" id="mF">—</span></div>
      </div>
    </aside>
    <section><div class="lb-stage"><canvas id="scene" width="900" height="560"></canvas></div></section>
  </div>
</main>
<script is:inline>
(function(){
  function v(id){ return parseFloat(document.getElementById(id).value); }
  var shots=[], live=null, result={range:0,apex:0,flight:0};
  function sync(){ ['sp','ang','h','g','dr'].forEach(function(id){ var el=document.getElementById(id+'V'); if(el) el.textContent = id==='g'?v(id).toFixed(2):(id==='dr'?v(id).toFixed(3):v(id).toFixed(0)); }); }
  document.querySelectorAll('input').forEach(function(e){ e.addEventListener('input',sync); }); sync();
  function fire(){ var sp=v('sp'), a=v('ang')*Math.PI/180; live={ x:0, y:v('h'), vx:sp*Math.cos(a), vy:sp*Math.sin(a), g:v('g'), dr:v('dr'), t:0, path:[], apex:v('h') }; }
  document.getElementById('fireBtn').addEventListener('click',fire);
  document.getElementById('clearBtn').addEventListener('click',function(){ shots=[]; live=null; });
  function integrate(s,dt){ var sp=Math.hypot(s.vx,s.vy); var ax=-s.dr*sp*s.vx, ay=-s.g-s.dr*sp*s.vy; s.vx+=ax*dt; s.vy+=ay*dt; s.x+=s.vx*dt; s.y+=s.vy*dt; s.t+=dt; if(s.y>s.apex) s.apex=s.y; s.path.push([s.x,s.y]); }
  function hidpi(cv){ var r=cv.getBoundingClientRect(), d=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w; cv.width=Math.round(w*d); cv.height=Math.round(h*d); var ctx=cv.getContext('2d'); ctx.setTransform(d,0,0,d,0,0); return {ctx:ctx,w:w,h:h}; }
  function draw(){
    var cv=document.getElementById('scene'), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h;
    var sky=ctx.createLinearGradient(0,0,0,H); sky.addColorStop(0,'#0b1430'); sky.addColorStop(0.7,'#0a1020'); sky.addColorStop(1,'#0d1a12'); ctx.fillStyle=sky; ctx.fillRect(0,0,W,H);
    var maxX=40, maxY=25; shots.concat(live?[live]:[]).forEach(function(sh){ sh.path.forEach(function(pt){ if(pt[0]>maxX)maxX=pt[0]; if(pt[1]>maxY)maxY=pt[1]; }); if(sh.x>maxX)maxX=sh.x; });
    maxX*=1.12; maxY=Math.max(maxY*1.25, maxX*0.35);
    var padL=48, padB=42, gx=(W-padL-16)/maxX, gy=(H-padB-16)/maxY, gs=Math.min(gx,gy);
    function X(x){ return padL + x*gs; } function Y(y){ return H-padB - y*gs; }
    var gr=ctx.createLinearGradient(0,Y(0),0,H); gr.addColorStop(0,'#16351f'); gr.addColorStop(1,'#0a1a10'); ctx.fillStyle=gr; ctx.fillRect(0,Y(0),W,H-Y(0));
    ctx.strokeStyle='#3fae5f'; ctx.lineWidth=2; ctx.beginPath(); ctx.moveTo(0,Y(0)); ctx.lineTo(W,Y(0)); ctx.stroke();
    ctx.strokeStyle='rgba(94,231,255,0.08)'; ctx.fillStyle='#5f7597'; ctx.font="10px 'Geist Mono',monospace";
    for(var xx=0; xx<=maxX; xx+= (maxX>120?40:maxX>60?20:10)){ ctx.beginPath(); ctx.moveTo(X(xx),Y(0)); ctx.lineTo(X(xx),16); ctx.stroke(); ctx.fillText(xx.toFixed(0),X(xx)-6,Y(0)+16); }
    ctx.fillStyle='#2a3450'; ctx.fillRect(X(0)-8,Y(v('h')),16,Math.max(6,H-padB-Y(v('h'))));
    shots.forEach(function(sh){ ctx.strokeStyle='rgba(120,150,200,0.5)'; ctx.lineWidth=1.4; ctx.beginPath(); sh.path.forEach(function(pt,j){ j?ctx.lineTo(X(pt[0]),Y(pt[1])):ctx.moveTo(X(pt[0]),Y(pt[1])); }); ctx.stroke(); });
    if(live){ ctx.save(); ctx.shadowColor='#fbbf24'; ctx.shadowBlur=6; ctx.strokeStyle='#fbbf24'; ctx.lineWidth=2; ctx.beginPath(); live.path.forEach(function(pt,j){ j?ctx.lineTo(X(pt[0]),Y(pt[1])):ctx.moveTo(X(pt[0]),Y(pt[1])); }); ctx.stroke(); ctx.restore();
      live.path.slice(-30).forEach(function(pt,i){ ctx.fillStyle='rgba(251,191,36,'+(i/30*0.5).toFixed(3)+')'; ctx.beginPath(); ctx.arc(X(pt[0]),Y(pt[1]),2,0,7); ctx.fill(); });
      ctx.save(); ctx.shadowColor='rgba(251,191,36,0.9)'; ctx.shadowBlur=22; var rad=ctx.createRadialGradient(X(live.x)-2,Y(live.y)-2,1,X(live.x),Y(live.y),7); rad.addColorStop(0,'#fff3c4'); rad.addColorStop(1,'#d08a12'); ctx.fillStyle=rad; ctx.beginPath(); ctx.arc(X(live.x),Y(live.y),7,0,7); ctx.fill(); ctx.restore();
      ctx.strokeStyle='rgba(167,139,250,0.6)'; ctx.setLineDash([3,4]); ctx.beginPath(); ctx.moveTo(padL,Y(live.apex)); ctx.lineTo(W-16,Y(live.apex)); ctx.stroke(); ctx.setLineDash([]);
    }
    ctx.fillStyle='#5ee7ff'; ctx.font="700 12px 'Geist Mono',monospace"; ctx.fillText('x (m)',W-56,H-14); ctx.save(); ctx.translate(14,64); ctx.rotate(-Math.PI/2); ctx.fillText('height (m)',0,0); ctx.restore();
  }
  function metrics(){ var s=live;
    document.getElementById('mT').textContent = s? s.t.toFixed(2):'—';
    document.getElementById('mX').textContent = s? s.x.toFixed(1):'—';
    document.getElementById('mY').textContent = s? Math.max(0,s.y).toFixed(1):'—';
    document.getElementById('mV').textContent = s? Math.hypot(s.vx,s.vy).toFixed(1):'—';
    document.getElementById('mR').textContent = result.range.toFixed(1);
    document.getElementById('mA').textContent = result.apex.toFixed(1);
    document.getElementById('mF').textContent = result.flight.toFixed(2);
  }
  function loop(){ if(live){ for(var i=0;i<3;i++){ integrate(live,0.016); if(live.y<=0 && live.vy<0){ live.y=0; result={range:live.x,apex:live.apex,flight:live.t}; shots.push(live); if(shots.length>6) shots.shift(); live=null; break; } } }
    draw(); metrics(); requestAnimationFrame(loop); }
  fire(); requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
