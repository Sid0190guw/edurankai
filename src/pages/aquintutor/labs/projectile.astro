---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Projectile Motion Lab — AquinTutor" description="Real-physics projectile simulator with quadratic air drag and RK4 integration.">
<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; }
  .wrap { max-width: 1400px; margin: 0 auto; padding: 28px 22px 80px; }
  .crumbs { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #67e8f9; opacity: 0.7; }
  .crumbs a { color: inherit; text-decoration: none; }
  .eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 14px 0 6px; }
  h1 { font-family: 'Cormorant Garamond', serif; font-size: 34px; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 6px; color: #e8e8ee; }
  h1 em { font-style: italic; color: #67e8f9; font-weight: 500; }
  .sub { color: #a0a8b4; max-width: 720px; line-height: 1.55; font-size: 14px; margin: 0 0 24px; }
  .grid { display: grid; grid-template-columns: 320px 1fr 280px; gap: 16px; align-items: start; }
  @media (max-width: 1100px) { .grid { grid-template-columns: 1fr; } }
  .panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 16px; }
  .panel h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 12px; }
  .ctrl { margin-bottom: 14px; }
  .ctrl label { display: flex; justify-content: space-between; font-family: 'Geist Mono', monospace; font-size: 11px; color: #cfd6da; margin-bottom: 4px; }
  .ctrl label span.val { color: #67e8f9; }
  .ctrl input[type=range] { width: 100%; accent-color: #67e8f9; }
  .btnrow { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; }
  button.btn { background: #67e8f9; color: #04161b; border: 0; padding: 9px 14px; border-radius: 6px; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; cursor: pointer; }
  button.btn.ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
  button.btn:hover { filter: brightness(1.1); }
  .stagebox { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 10px; padding: 8px; }
  svg.stage { width: 100%; height: auto; display: block; background: #06070a; border-radius: 6px; }
  .metric { display: flex; justify-content: space-between; font-family: 'Geist Mono', monospace; font-size: 11px; padding: 6px 0; border-bottom: 1px dashed #1f2028; }
  .metric:last-child { border-bottom: 0; }
  .metric .k { color: #a0a8b4; }
  .metric .v { color: #67e8f9; font-weight: 700; }
  .legend { display: flex; gap: 14px; font-family: 'Geist Mono', monospace; font-size: 10px; color: #cfd6da; margin-top: 8px; }
  .legend .sw { display: inline-block; width: 14px; height: 2px; vertical-align: middle; margin-right: 5px; }
  .pill { display: inline-block; padding: 2px 8px; font-family: 'Geist Mono', monospace; font-size: 10px; border: 1px solid #2a2a35; border-radius: 999px; color: #cfd6da; margin-right: 6px; }
  .pill.on { background: #67e8f9; color: #04161b; border-color: #67e8f9; }
  .formula { font-family: 'Geist Mono', monospace; font-size: 10px; color: #6b7280; padding: 8px; background: #0a0a0c; border: 1px solid #1f2028; border-radius: 6px; line-height: 1.7; margin-top: 10px; }
</style>
<main class="wrap">
  <div class="crumbs"><a href="/aquintutor">AquinTutor</a> &nbsp;/&nbsp; <a href="/aquintutor/labs">Virtual Labs</a> &nbsp;/&nbsp; Projectile Motion</div>
  <div class="eyebrow">Classical mechanics &middot; Lab 03</div>
  <h1>Projectile motion with <em>quadratic drag</em></h1>
  <p class="sub">Newton's equations integrated with fourth-order Runge&ndash;Kutta at dt = 10 ms. The drag force scales with the square of speed: F_d = &frac12;&middot;&rho;&middot;C_d&middot;A&middot;v&middot;|v|. Compare the live trajectory against the analytic vacuum prediction to see how air resistance reshapes range, apex and time of flight.</p>

  <div class="grid">
    <!-- LEFT: controls -->
    <section class="panel">
      <h3>Initial conditions</h3>
      <div class="ctrl"><label>Initial velocity v<sub>0</sub> <span class="val" id="lblV0">40.0 m/s</span></label><input id="v0" type="range" min="0" max="80" step="0.5" value="40" /></div>
      <div class="ctrl"><label>Launch angle &theta; <span class="val" id="lblTh">45&deg;</span></label><input id="th" type="range" min="0" max="90" step="1" value="45" /></div>
      <h3 style="margin-top:18px">Environment</h3>
      <div class="ctrl"><label>Gravity g <span class="val" id="lblG">9.81 m/s&sup2;</span></label><input id="g" type="range" min="1" max="25" step="0.01" value="9.81" /></div>
      <div class="ctrl"><label>Air density &rho; <span class="val" id="lblRho">1.225 kg/m&sup3;</span></label><input id="rho" type="range" min="0" max="2" step="0.001" value="1.225" /></div>
      <h3 style="margin-top:18px">Projectile</h3>
      <div class="ctrl"><label>Mass m <span class="val" id="lblM">1.00 kg</span></label><input id="m" type="range" min="0.1" max="10" step="0.05" value="1.0" /></div>
      <div class="ctrl"><label>Drag coeff. C<sub>d</sub> <span class="val" id="lblCd">0.47</span></label><input id="cd" type="range" min="0" max="1.5" step="0.01" value="0.47" /></div>
      <div class="ctrl"><label>Cross-section A <span class="val" id="lblA">0.010 m&sup2;</span></label><input id="a" type="range" min="0.001" max="0.1" step="0.001" value="0.01" /></div>
      <div class="btnrow">
        <button class="btn" id="bFire">Fire</button>
        <button class="btn ghost" id="bPause">Pause</button>
        <button class="btn ghost" id="bReset">Reset</button>
      </div>
      <div class="btnrow" style="margin-top:6px">
        <button class="btn ghost" id="bVac">Vacuum ref: <span id="vacPill" class="pill on">ON</span></button>
      </div>
      <div class="formula">
        a<sub>x</sub> = -k&middot;v<sub>x</sub>&middot;|v|<br>
        a<sub>y</sub> = -g - k&middot;v<sub>y</sub>&middot;|v|<br>
        k = &frac12;&middot;&rho;&middot;C<sub>d</sub>&middot;A / m
      </div>
    </section>

    <!-- CENTER: stage -->
    <section class="panel">
      <h3>Trajectory</h3>
      <div class="stagebox">
        <svg class="stage" viewBox="0 0 1000 600" id="stage" preserveAspectRatio="xMidYMid meet">
          <defs>
            <marker id="arrhead" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
              <path d="M 0 0 L 10 5 L 0 10 z" fill="#fde047"/>
            </marker>
          </defs>
          <g id="grid"></g>
          <line id="ground" x1="40" y1="560" x2="980" y2="560" stroke="#3a3a48" stroke-width="1.5"/>
          <path id="vacTrail" fill="none" stroke="#6b7280" stroke-width="1.4" stroke-dasharray="5 4" opacity="0.85"/>
          <path id="trail" fill="none" stroke="#67e8f9" stroke-width="1.8"/>
          <line id="vvec" x1="0" y1="0" x2="0" y2="0" stroke="#fde047" stroke-width="2" marker-end="url(#arrhead)"/>
          <circle id="ball" cx="60" cy="560" r="6" fill="#fde047" stroke="#a16207" stroke-width="1"/>
          <text id="axisX" x="970" y="585" fill="#6b7280" font-family="Geist Mono, monospace" font-size="10" text-anchor="end">x (m)</text>
          <text id="axisY" x="30" y="50" fill="#6b7280" font-family="Geist Mono, monospace" font-size="10" text-anchor="end">y (m)</text>
        </svg>
      </div>
      <div class="legend">
        <span><span class="sw" style="background:#67e8f9"></span>With drag</span>
        <span><span class="sw" style="background:#6b7280"></span>Vacuum reference</span>
        <span><span class="sw" style="background:#fde047"></span>Velocity vector</span>
      </div>
    </section>

    <!-- RIGHT: metrics -->
    <section class="panel">
      <h3>Live state</h3>
      <div class="metric"><span class="k">t</span><span class="v" id="mT">0.000 s</span></div>
      <div class="metric"><span class="k">x</span><span class="v" id="mX">0.0 m</span></div>
      <div class="metric"><span class="k">y</span><span class="v" id="mY">0.0 m</span></div>
      <div class="metric"><span class="k">v<sub>x</sub></span><span class="v" id="mVx">0.0 m/s</span></div>
      <div class="metric"><span class="k">v<sub>y</sub></span><span class="v" id="mVy">0.0 m/s</span></div>
      <div class="metric"><span class="k">|v|</span><span class="v" id="mV">0.0 m/s</span></div>
      <h3 style="margin-top:16px">Energy</h3>
      <div class="metric"><span class="k">KE</span><span class="v" id="mKe">0.0 J</span></div>
      <div class="metric"><span class="k">PE</span><span class="v" id="mPe">0.0 J</span></div>
      <div class="metric"><span class="k">E total</span><span class="v" id="mEt">0.0 J</span></div>
      <h3 style="margin-top:16px">Flight summary</h3>
      <div class="metric"><span class="k">Range R</span><span class="v" id="mR">&mdash;</span></div>
      <div class="metric"><span class="k">Apex</span><span class="v" id="mApex">&mdash;</span></div>
      <div class="metric"><span class="k">Time of flight</span><span class="v" id="mTof">&mdash;</span></div>
      <div class="metric"><span class="k">Vacuum range</span><span class="v" id="mVacR">&mdash;</span></div>
      <div class="metric"><span class="k">Drag loss</span><span class="v" id="mLoss">&mdash;</span></div>
    </section>
  </div>
</main>

<script is:inline>
(function(){
  // ===== DOM =====
  var $ = function(id){ return document.getElementById(id); };
  var stage = $('stage');
  var ball = $('ball'), trail = $('trail'), vacTrail = $('vacTrail'), vvec = $('vvec');
  var grid = $('grid');
  var inputs = {
    v0: $('v0'), th: $('th'), g: $('g'), m: $('m'),
    cd: $('cd'), a: $('a'), rho: $('rho')
  };
  var lbls = { v0: $('lblV0'), th: $('lblTh'), g: $('lblG'), m: $('lblM'), cd: $('lblCd'), a: $('lblA'), rho: $('lblRho') };
  var mT = $('mT'), mX = $('mX'), mY = $('mY'), mVx = $('mVx'), mVy = $('mVy'), mV = $('mV');
  var mKe = $('mKe'), mPe = $('mPe'), mEt = $('mEt');
  var mR = $('mR'), mApex = $('mApex'), mTof = $('mTof'), mVacR = $('mVacR'), mLoss = $('mLoss');
  var bFire = $('bFire'), bPause = $('bPause'), bReset = $('bReset'), bVac = $('bVac'), vacPill = $('vacPill');

  // ===== world =====
  var W = 1000, H = 600, MARGIN_L = 40, MARGIN_R = 20, MARGIN_T = 20, MARGIN_B = 40;
  var GROUND_Y_SVG = H - MARGIN_B; // 560

  var params = readParams();
  var state = { t: 0, x: 0, y: 0, vx: 0, vy: 0, alive: false };
  var traj = []; // {x,y} in physics units
  var vacTraj = [];
  var apexY = 0;
  var rangeR = null, tofT = null;
  var paused = false, showVac = true;
  var lastFrame = 0;
  var scaleX = 10, scaleY = 10; // pixels per metre, recomputed per launch
  var maxX_m = 80, maxY_m = 40;

  function readParams(){
    return {
      v0: +inputs.v0.value,
      th: +inputs.th.value * Math.PI / 180,
      g:  +inputs.g.value,
      m:  +inputs.m.value,
      cd: +inputs.cd.value,
      A:  +inputs.a.value,
      rho:+inputs.rho.value
    };
  }
  function updateLbls(){
    lbls.v0.textContent = (+inputs.v0.value).toFixed(1) + ' m/s';
    lbls.th.textContent = (+inputs.th.value).toFixed(0) + '°';
    lbls.g.textContent  = (+inputs.g.value).toFixed(2) + ' m/s²';
    lbls.m.textContent  = (+inputs.m.value).toFixed(2) + ' kg';
    lbls.cd.textContent = (+inputs.cd.value).toFixed(2);
    lbls.a.textContent  = (+inputs.a.value).toFixed(3) + ' m²';
    lbls.rho.textContent= (+inputs.rho.value).toFixed(3) + ' kg/m³';
  }

  // ===== physics =====
  // returns derivative [dx, dy, dvx, dvy]
  function deriv(s, p){
    var v = Math.sqrt(s.vx*s.vx + s.vy*s.vy);
    var k = 0.5 * p.rho * p.cd * p.A / p.m;
    var ax = -k * s.vx * v;
    var ay = -p.g - k * s.vy * v;
    return { dx: s.vx, dy: s.vy, dvx: ax, dvy: ay };
  }
  function rk4(s, p, dt){
    var k1 = deriv(s, p);
    var s2 = { x:s.x + k1.dx*dt/2, y:s.y + k1.dy*dt/2, vx:s.vx + k1.dvx*dt/2, vy:s.vy + k1.dvy*dt/2 };
    var k2 = deriv(s2, p);
    var s3 = { x:s.x + k2.dx*dt/2, y:s.y + k2.dy*dt/2, vx:s.vx + k2.dvx*dt/2, vy:s.vy + k2.dvy*dt/2 };
    var k3 = deriv(s3, p);
    var s4 = { x:s.x + k3.dx*dt, y:s.y + k3.dy*dt, vx:s.vx + k3.dvx*dt, vy:s.vy + k3.dvy*dt };
    var k4 = deriv(s4, p);
    return {
      x:  s.x  + dt*(k1.dx  + 2*k2.dx  + 2*k3.dx  + k4.dx ) / 6,
      y:  s.y  + dt*(k1.dy  + 2*k2.dy  + 2*k3.dy  + k4.dy ) / 6,
      vx: s.vx + dt*(k1.dvx + 2*k2.dvx + 2*k3.dvx + k4.dvx) / 6,
      vy: s.vy + dt*(k1.dvy + 2*k2.dvy + 2*k3.dvy + k4.dvy) / 6
    };
  }

  // pre-compute the entire vacuum trajectory analytically
  function computeVacuum(p){
    var out = [];
    var vx0 = p.v0 * Math.cos(p.th);
    var vy0 = p.v0 * Math.sin(p.th);
    var T = (p.g > 0) ? 2 * vy0 / p.g : 0;
    if (T <= 0) { return { pts: [{x:0,y:0}], range: 0, tof: 0, apex: 0 }; }
    var N = 200;
    for (var i=0;i<=N;i++){
      var t = T * i / N;
      var x = vx0 * t;
      var y = vy0 * t - 0.5 * p.g * t * t;
      if (y < 0) y = 0;
      out.push({x:x, y:y});
    }
    var range = vx0 * T;
    var apex  = (vy0*vy0)/(2*p.g);
    return { pts: out, range: range, tof: T, apex: apex };
  }

  // pre-compute the entire drag trajectory once (so we can fit the viewport before animating)
  function precomputeDrag(p){
    var s = { x:0, y:0, vx: p.v0*Math.cos(p.th), vy: p.v0*Math.sin(p.th) };
    var pts = [{x:0,y:0}];
    var t = 0, dt = 0.01;
    var maxY = 0;
    while (t < 60) {
      s = rk4(s, p, dt);
      t += dt;
      if (s.y > maxY) maxY = s.y;
      pts.push({x:s.x, y:s.y});
      if (s.y <= 0 && t > dt*2) {
        // linear interpolate to ground for clean impact
        var prev = pts[pts.length-2];
        var cur  = pts[pts.length-1];
        if (cur.y < 0 && prev.y > 0){
          var alpha = prev.y / (prev.y - cur.y);
          var xi = prev.x + alpha*(cur.x - prev.x);
          pts[pts.length-1] = {x: xi, y: 0};
        }
        break;
      }
    }
    return { pts: pts, range: pts[pts.length-1].x, tof: t, apex: maxY };
  }

  // ===== rendering =====
  function fitView(maxXm, maxYm){
    var padX = Math.max(maxXm * 0.08, 2);
    var padY = Math.max(maxYm * 0.18, 2);
    maxX_m = maxXm + padX;
    maxY_m = Math.max(maxYm + padY, 5);
    var availW = W - MARGIN_L - MARGIN_R;
    var availH = GROUND_Y_SVG - MARGIN_T;
    scaleX = availW / maxX_m;
    scaleY = availH / maxY_m;
    drawGrid();
  }
  function toSvg(xm, ym){
    return { sx: MARGIN_L + xm*scaleX, sy: GROUND_Y_SVG - ym*scaleY };
  }
  function drawGrid(){
    var html = '';
    // pick reasonable step
    function niceStep(maxV){
      var raw = maxV / 8;
      var pow10 = Math.pow(10, Math.floor(Math.log10(raw)));
      var n = raw / pow10;
      var k = n < 1.5 ? 1 : n < 3.5 ? 2 : n < 7.5 ? 5 : 10;
      return k * pow10;
    }
    var dx = niceStep(maxX_m);
    var dy = niceStep(maxY_m);
    for (var x=0; x<=maxX_m; x+=dx){
      var p = toSvg(x, 0);
      html += '<line x1="'+p.sx+'" y1="'+MARGIN_T+'" x2="'+p.sx+'" y2="'+GROUND_Y_SVG+'" stroke="#1a1c24" stroke-width="1"/>';
      html += '<text x="'+p.sx+'" y="'+(GROUND_Y_SVG+14)+'" fill="#5a6270" font-family="Geist Mono, monospace" font-size="9" text-anchor="middle">'+x.toFixed(dx<1?1:0)+'</text>';
    }
    for (var y=0; y<=maxY_m; y+=dy){
      var p2 = toSvg(0, y);
      html += '<line x1="'+MARGIN_L+'" y1="'+p2.sy+'" x2="'+(W-MARGIN_R)+'" y2="'+p2.sy+'" stroke="#1a1c24" stroke-width="1"/>';
      html += '<text x="'+(MARGIN_L-6)+'" y="'+(p2.sy+3)+'" fill="#5a6270" font-family="Geist Mono, monospace" font-size="9" text-anchor="end">'+y.toFixed(dy<1?1:0)+'</text>';
    }
    grid.innerHTML = html;
  }
  function pathFromPoints(pts){
    if (!pts.length) return '';
    var d = '';
    for (var i=0;i<pts.length;i++){
      var p = toSvg(pts[i].x, pts[i].y);
      d += (i?'L':'M') + p.sx.toFixed(2) + ' ' + p.sy.toFixed(2);
    }
    return d;
  }

  // ===== simulation control =====
  var precomputed = null; // pts of drag trajectory (for reference) — we also live-step
  function fire(){
    params = readParams();
    var vac = computeVacuum(params);
    vacTraj = vac.pts;
    var dragPre = precomputeDrag(params);
    var fitX = Math.max(vac.range, dragPre.range, 1);
    var fitY = Math.max(vac.apex,  dragPre.apex,  1);
    fitView(fitX, fitY);
    state = { t: 0, x: 0, y: 0, vx: params.v0*Math.cos(params.th), vy: params.v0*Math.sin(params.th), alive: true };
    traj = [{x:0,y:0}];
    apexY = 0;
    rangeR = null; tofT = null;
    vacTrail.setAttribute('d', showVac ? pathFromPoints(vacTraj) : '');
    mVacR.textContent = vac.range.toFixed(2) + ' m';
    paused = false; bPause.textContent = 'Pause';
    // ball size scales with mass (log scale so it stays sane)
    var r = 4 + Math.min(10, Math.log10(1 + params.m * 9) * 4);
    ball.setAttribute('r', r.toFixed(2));
    lastFrame = performance.now();
    requestAnimationFrame(loop);
  }

  function loop(now){
    if (!state.alive) { drawFrame(); return; }
    if (paused) { lastFrame = now; requestAnimationFrame(loop); return; }
    var elapsed = (now - lastFrame) / 1000;
    if (elapsed > 0.05) elapsed = 0.05; // clamp big tab-switch gaps
    lastFrame = now;
    // step at fixed dt=0.01, scaled to real time (1x); accumulate
    var steps = Math.max(1, Math.floor(elapsed / 0.01));
    var dt = 0.01;
    for (var i=0;i<steps && state.alive;i++){
      var ns = rk4(state, params, dt);
      ns.t = state.t + dt;
      // ground impact?
      if (ns.y <= 0 && state.y > 0){
        var alpha = state.y / (state.y - ns.y);
        var xi = state.x + alpha*(ns.x - state.x);
        var tImp = state.t + alpha*dt;
        traj.push({x: xi, y: 0});
        state = { x: xi, y: 0, vx: ns.vx, vy: ns.vy, t: tImp, alive: false };
        rangeR = xi; tofT = tImp;
        break;
      }
      state.x = ns.x; state.y = ns.y; state.vx = ns.vx; state.vy = ns.vy; state.t = ns.t;
      if (state.y > apexY) apexY = state.y;
      traj.push({x: state.x, y: state.y});
    }
    drawFrame();
    requestAnimationFrame(loop);
  }

  function drawFrame(){
    trail.setAttribute('d', pathFromPoints(traj));
    var p = toSvg(state.x, state.y);
    ball.setAttribute('cx', p.sx.toFixed(2));
    ball.setAttribute('cy', p.sy.toFixed(2));
    // velocity vector — scale 1 m/s to N px so it stays visible
    var vmag = Math.sqrt(state.vx*state.vx + state.vy*state.vy);
    if (vmag > 0.05){
      var pxPerMs = 0.6; // tweakable
      var vx_px = state.vx * pxPerMs * scaleX / 10;
      var vy_px = -state.vy * pxPerMs * scaleY / 10;
      // clamp shaft length to something readable
      var L = Math.hypot(vx_px, vy_px);
      var maxLen = 80;
      if (L > maxLen){ vx_px *= maxLen/L; vy_px *= maxLen/L; }
      vvec.setAttribute('x1', p.sx.toFixed(2));
      vvec.setAttribute('y1', p.sy.toFixed(2));
      vvec.setAttribute('x2', (p.sx + vx_px).toFixed(2));
      vvec.setAttribute('y2', (p.sy + vy_px).toFixed(2));
      vvec.style.display = '';
    } else {
      vvec.style.display = 'none';
    }
    // metrics
    mT.textContent  = state.t.toFixed(3) + ' s';
    mX.textContent  = state.x.toFixed(2) + ' m';
    mY.textContent  = state.y.toFixed(2) + ' m';
    mVx.textContent = state.vx.toFixed(2) + ' m/s';
    mVy.textContent = state.vy.toFixed(2) + ' m/s';
    mV.textContent  = vmag.toFixed(2) + ' m/s';
    var ke = 0.5 * params.m * vmag * vmag;
    var pe = params.m * params.g * state.y;
    mKe.textContent = ke.toFixed(2) + ' J';
    mPe.textContent = pe.toFixed(2) + ' J';
    mEt.textContent = (ke + pe).toFixed(2) + ' J';
    if (rangeR !== null){
      mR.textContent    = rangeR.toFixed(2) + ' m';
      mApex.textContent = apexY.toFixed(2) + ' m';
      mTof.textContent  = tofT.toFixed(3) + ' s';
      var vacR_text = mVacR.textContent.replace(' m','');
      var vr = parseFloat(vacR_text);
      if (!isNaN(vr) && vr > 0){
        var loss = (1 - rangeR / vr) * 100;
        mLoss.textContent = loss.toFixed(1) + ' %';
      } else {
        mLoss.textContent = '0.0 %';
      }
    } else {
      mR.textContent    = '—';
      mApex.textContent = apexY > 0 ? apexY.toFixed(2) + ' m (live)' : '—';
      mTof.textContent  = '—';
      mLoss.textContent = '—';
    }
  }

  function reset(){
    state = { t: 0, x: 0, y: 0, vx: 0, vy: 0, alive: false };
    traj = [];
    vacTraj = [];
    apexY = 0; rangeR = null; tofT = null;
    trail.setAttribute('d','');
    vacTrail.setAttribute('d','');
    vvec.style.display = 'none';
    var p0 = toSvg(0, 0);
    ball.setAttribute('cx', p0.sx); ball.setAttribute('cy', p0.sy);
    mT.textContent = '0.000 s'; mX.textContent = '0.0 m'; mY.textContent = '0.0 m';
    mVx.textContent = '0.0 m/s'; mVy.textContent = '0.0 m/s'; mV.textContent = '0.0 m/s';
    mKe.textContent = '0.0 J'; mPe.textContent = '0.0 J'; mEt.textContent = '0.0 J';
    mR.textContent = '—'; mApex.textContent = '—'; mTof.textContent = '—';
    mVacR.textContent = '—'; mLoss.textContent = '—';
  }

  // ===== events =====
  Object.keys(inputs).forEach(function(k){
    inputs[k].addEventListener('input', function(){ updateLbls(); });
  });
  bFire.addEventListener('click', fire);
  bReset.addEventListener('click', reset);
  bPause.addEventListener('click', function(){
    if (!state.alive) return;
    paused = !paused;
    bPause.textContent = paused ? 'Play' : 'Pause';
  });
  bVac.addEventListener('click', function(){
    showVac = !showVac;
    vacPill.textContent = showVac ? 'ON' : 'OFF';
    vacPill.classList.toggle('on', showVac);
    vacTrail.setAttribute('d', showVac && vacTraj.length ? pathFromPoints(vacTraj) : '');
  });

  // ===== init =====
  updateLbls();
  fitView(80, 40);
  reset();
  // auto-fire once so the lab is alive on first paint
  setTimeout(fire, 250);
})();
</script>

