---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Data Structures & Algorithms · Virtual Labs · AquinTutor" description="Interactive BST/AVL, heaps, hash tables, linked lists, stacks/queues and graph traversal with live operations.">
<style>
  .dsx { background:#0a0a0c; color:#e8e8ee; min-height:100vh; font-family:'Geist Mono',ui-monospace,monospace; }
  .dsx .wrap { max-width:1240px; margin:0 auto; padding:36px 22px 90px; }
  .dsx .back { display:inline-flex; align-items:center; gap:7px; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:#9aa0aa; text-decoration:none; margin-bottom:26px; }
  .dsx .back:hover { color:#67e8f9; }
  .dsx .eyebrow { font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin-bottom:12px; }
  .dsx h1 { font-family:'Cormorant Garamond',serif; font-size:40px; font-weight:600; letter-spacing:-0.02em; line-height:1.1; margin:0 0 12px; color:#f3f3f8; }
  .dsx h1 em { color:#a78bfa; font-style:italic; }
  .dsx .lede { color:#9aa0aa; max-width:820px; font-size:13.5px; line-height:1.65; margin-bottom:26px; }

  .dsx .shell { display:grid; grid-template-columns:248px minmax(0,1fr); gap:20px; align-items:start; }
  @media (max-width:900px) { .dsx .shell { grid-template-columns:1fr; } }

  .dsx .sidebar { background:#11131a; border:1px solid #2a2a35; border-radius:12px; padding:12px; position:sticky; top:18px; }
  .dsx .sidebar .stitle { font-size:9px; letter-spacing:0.18em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin:4px 6px 10px; }
  .dsx .exp-item { display:flex; gap:9px; align-items:flex-start; padding:9px 10px; border-radius:8px; cursor:pointer; border:1px solid transparent; transition:all .14s; margin-bottom:3px; }
  .dsx .exp-item:hover { background:#161922; }
  .dsx .exp-item.on { background:#161922; border-color:#a78bfa; }
  .dsx .exp-item .num { font-size:10px; color:#a78bfa; font-weight:700; min-width:14px; }
  .dsx .exp-item .nm { font-size:11px; color:#cfd6da; line-height:1.4; }
  .dsx .exp-item.on .nm { color:#f3f3f8; }

  .dsx .main { min-width:0; }
  .dsx .exp-head { font-family:'Cormorant Garamond',serif; font-size:27px; font-weight:600; color:#f3f3f8; margin:0 0 4px; }
  .dsx .exp-sub { font-size:11px; color:#9aa0aa; letter-spacing:0.04em; margin-bottom:16px; }

  .dsx .secbar { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:18px; border-bottom:1px solid #2a2a35; padding-bottom:12px; }
  .dsx .secbar .stab { background:#11131a; border:1px solid #2a2a35; color:#9aa0aa; padding:7px 12px; border-radius:8px; font-size:10px; letter-spacing:0.08em; text-transform:uppercase; font-weight:700; cursor:pointer; transition:all .14s; }
  .dsx .secbar .stab:hover { border-color:#3a3a48; color:#e8e8ee; }
  .dsx .secbar .stab.on { background:#161922; border-color:#67e8f9; color:#67e8f9; }

  .dsx .exp { display:none; }
  .dsx .exp.on { display:block; }
  .dsx .sec { display:none; }
  .dsx .sec.on { display:block; }

  .dsx .prose { font-size:13px; color:#c4c8d0; line-height:1.72; max-width:840px; }
  .dsx .prose b { color:#f3f3f8; }
  .dsx .prose p { margin:0 0 12px; }
