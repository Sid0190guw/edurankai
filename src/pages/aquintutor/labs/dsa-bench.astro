        ctx.fillText(nd.label, nd.x, nd.y);
        if (nd.id === src) { ctx.fillStyle = COL.accent; ctx.font = '9px monospace'; ctx.textBaseline = 'alphabetic'; ctx.fillText('SRC', nd.x, nd.y - 24); }
        if (visited[nd.id]) { var oi = order.indexOf(nd.id); if (oi >= 0) { ctx.fillStyle = COL.good; ctx.font = '9px monospace'; ctx.textBaseline = 'alphabetic'; ctx.fillText('#' + (oi + 1), nd.x, nd.y + 30); } }
      }
      ctx.textBaseline = 'alphabetic';
    }
    function setEnabled(on) { ['grBFS', 'grDFS', 'grClear', 'grSample'].forEach(function (id) { $(id).disabled = !on; }); }

    async function runBFS() {
      if (busy) return; clearRun(); busy = true; setEnabled(false);
      $('grMode').textContent = 'BFS running';
      var q = [src]; visited[src] = true; frontier = q.slice();
      treeEdges = {};
      refresh(); await sleep(delayFor(speed));
      while (q.length) {
        var u = q.shift(); curId = u; order.push(u); frontier = q.slice();
        refresh(); await sleep(delayFor(speed));
        var nbrs = adj[u].slice().sort(function (a, b) { var ba = byId(a), bb = byId(b); return (ba ? ba.label : '') < (bb ? bb.label : '') ? -1 : 1; });
        for (var i = 0; i < nbrs.length; i++) {
          var w = nbrs[i];
          if (!visited[w]) {
            visited[w] = true;
            if (!treeEdges[u]) treeEdges[u] = []; if (!treeEdges[w]) treeEdges[w] = [];
            treeEdges[u].push(w); treeEdges[w].push(u);
            q.push(w); frontier = q.slice();
            refresh(); await sleep(delayFor(speed));
          }
        }
      }
      curId = -1; frontier = []; $('grMode').textContent = 'BFS done';
      logTo($('grLog'), 'BFS from <b>' + byId(src).label + '</b> &mdash; visited ' + order.length + ' vertices');
      refresh(); busy = false; setEnabled(true);
    }
    async function runDFS() {
      if (busy) return; clearRun(); busy = true; setEnabled(false);
      $('grMode').textContent = 'DFS running';
      var stack = [src]; treeEdges = {}; frontier = stack.slice();
      refresh(); await sleep(delayFor(speed));
      while (stack.length) {
        var u = stack.pop(); frontier = stack.slice();
        if (visited[u]) { refresh(); continue; }
        visited[u] = true; curId = u; order.push(u);
        refresh(); await sleep(delayFor(speed));
        var nbrs = adj[u].slice().sort(function (a, b) { var ba = byId(a), bb = byId(b); return (ba ? ba.label : '') > (bb ? bb.label : '') ? -1 : 1; });
        for (var i = 0; i < nbrs.length; i++) {
          var w = nbrs[i];
          if (!visited[w]) {
            if (!treeEdges[u]) treeEdges[u] = []; if (!treeEdges[w]) treeEdges[w] = [];
            // record tree edge tentatively from u (parent) — only keep first discovery
            stack.push(w);
          }
        }
        // build discovery edges: connect u to each unvisited child actually expanded later — simpler: record parent on first pop
        frontier = stack.slice(); refresh(); await sleep(delayFor(speed) / 2);
      }
      // recompute clean DFS tree edges via recursion for correctness of green tree
      treeEdges = {}; var seen = {};
      (function dfsTree(u) {
        seen[u] = true;
        var nb = adj[u].slice().sort(function (a, b) { var ba = byId(a), bb = byId(b); return (ba ? ba.label : '') < (bb ? bb.label : '') ? -1 : 1; });
        for (var i = 0; i < nb.length; i++) { var w = nb[i]; if (!seen[w]) { if (!treeEdges[u]) treeEdges[u] = []; if (!treeEdges[w]) treeEdges[w] = []; treeEdges[u].push(w); treeEdges[w].push(u); dfsTree(w); } }
      })(src);
      curId = -1; frontier = []; $('grMode').textContent = 'DFS done';
      logTo($('grLog'), 'DFS from <b>' + byId(src).label + '</b> &mdash; visited ' + order.length + ' vertices');
      refresh(); busy = false; setEnabled(true);
    }

    function hitVertex(x, y) { for (var i = 0; i < V.length; i++) { var d = Math.hypot(V[i].x - x, V[i].y - y); if (d < 20) return V[i]; } return null; }
    function cvCoords(ev) {
      var r = cv.getBoundingClientRect();
      var sx = LW / r.width, sy = LH / r.height;
      return { x: (ev.clientX - r.left) * sx, y: (ev.clientY - r.top) * sy };
    }
    cv.addEventListener('mousedown', function (ev) {
      if (busy) return;
      var p = cvCoords(ev); var hit = hitVertex(p.x, p.y);
      if (clickMode === 'node') { if (!hit) { addVertex(p.x, p.y); refresh(); } }
      else if (clickMode === 'src') { if (hit) { src = hit.id; $('grSrc').value = src; clearRun(); } }
      else { if (hit) { dragFrom = hit.id; mouse = p; } }
    });
    cv.addEventListener('mousemove', function (ev) { if (dragFrom !== -1) { mouse = cvCoords(ev); draw(); } });
    cv.addEventListener('mouseup', function (ev) {
      if (dragFrom !== -1) { var p = cvCoords(ev); var hit = hitVertex(p.x, p.y); if (hit && hit.id !== dragFrom) { addEdge(dragFrom, hit.id); logTo($('grLog'), 'edge ' + byId(dragFrom).label + ' &mdash; ' + hit.label); } dragFrom = -1; mouse = null; clearRun(); }
    });
    cv.addEventListener('mouseleave', function () { dragFrom = -1; mouse = null; draw(); });

    $('grBFS').addEventListener('click', runBFS);
    $('grDFS').addEventListener('click', runDFS);
    $('grClear').addEventListener('click', function () { if (!busy) { clearRun(); $('grMode').textContent = 'view'; } });
    $('grSample').addEventListener('click', function () { if (!busy) sample(); });
    $('grSrc').addEventListener('change', function () { src = parseInt(this.value, 10); clearRun(); });
    bindSpeed('grSpd', 'grSpdv', function (v) { speed = v; });
    var cSeg = $('grClick').querySelectorAll('.opt');
    for (var ci = 0; ci < cSeg.length; ci++) {
      cSeg[ci].addEventListener('click', function () {
        for (var a = 0; a < cSeg.length; a++) cSeg[a].classList.remove('on');
        this.classList.add('on'); clickMode = this.getAttribute('data-c');
        $('grMode').textContent = clickMode === 'edge' ? 'add edge (drag)' : (clickMode === 'node' ? 'add node (click)' : 'pick source (click)');
      });
    }

    function sample() {
      V = []; adj = {}; idc = 0;
      var cx = LW / 2, cy = LH / 2;
      var pts = [[cx, 70], [cx - 170, 160], [cx + 170, 160], [cx - 230, 320], [cx - 60, 330], [cx + 90, 340], [cx + 240, 310]];
      var ids = [];
      for (var i = 0; i < pts.length; i++) ids.push(addVertex(pts[i][0], pts[i][1]));
      addEdge(ids[0], ids[1]); addEdge(ids[0], ids[2]); addEdge(ids[1], ids[3]); addEdge(ids[1], ids[4]);
      addEdge(ids[2], ids[5]); addEdge(ids[2], ids[6]); addEdge(ids[4], ids[5]); addEdge(ids[3], ids[4]);
      src = ids[0]; rebuildSrc(); clearRun(); $('grMode').textContent = 'view';
    }
    sample();
    REDRAW['7'] = function () { ctx = makeCtx(cv, LW, LH); refresh(); };
  })();

  // ===================================================================
  // SELF-ASSESSMENT — real, checkable MCQs
  // ===================================================================
  var QUIZZES = {
    '1': [
      { q: 'An in-order traversal of a binary search tree always yields the keys:',
        o: ['In insertion order', 'In sorted (ascending) order', 'In reverse sorted order', 'In random order'], a: 1,
        e: 'Left-node-right visiting order emits smaller keys before larger ones — i.e. sorted.' },
      { q: 'Searching for a key in a BST costs, in terms of the tree height h:',
        o: ['O(1)', 'O(h)', 'O(n log n)', 'O(n squared)'], a: 1,
        e: 'You descend one node per level, so the cost is proportional to the path length h.' },
      { q: 'To delete a node with two children, a BST replaces it with its:',
        o: ['Left child', 'Root', 'In-order successor (or predecessor)', 'Deepest leaf'], a: 2,
        e: 'The in-order successor (smallest key in the right subtree) preserves the ordering.' },
      { q: 'Inserting already-sorted keys 1,2,3,4,5 into a plain BST produces:',
        o: ['A perfectly balanced tree', 'A degenerate chain of height n', 'An empty tree', 'A heap'], a: 1,
        e: 'Each key is larger, so it always goes right — the tree degenerates into a linked list.' }
    ],
    '2': [
      { q: 'The balance factor of an AVL node is defined as:',
        o: ['left subtree size minus right subtree size', 'height(left) minus height(right)', 'number of children', 'depth from the root'], a: 1,
        e: 'AVL uses the difference of subtree heights, kept within minus-one to plus-one.' },
      { q: 'Inserting 10, 20, 30 in order triggers which single rotation at the root?',
        o: ['Right rotation (LL)', 'Left rotation (RR)', 'LR double rotation', 'No rotation'], a: 1,
        e: 'The right-heavy RR case is fixed by one left rotation; 20 becomes the new root.' },
      { q: 'An LR imbalance is repaired by:',
        o: ['One right rotation only', 'One left rotation only', 'Left on the child, then right on the node', 'Two right rotations'], a: 2,
        e: 'The double rotation first left-rotates the left child, then right-rotates the node.' },
      { q: 'Compared with a plain BST, an AVL tree guarantees operations in:',
        o: ['O(n)', 'O(log n) always', 'O(1)', 'O(n log n)'], a: 1,
        e: 'Height is bounded at about 1.44 log n, so search/insert/delete are O(log n).' }
    ],
    '3': [
      { q: 'In a min-heap, extract-root always returns the:',
        o: ['Largest key', 'Smallest key', 'Last inserted key', 'Median key'], a: 1,
        e: 'The min-heap property keeps the smallest key at the root, so extraction returns it.' },
      { q: 'For the node at array index i, its children sit at indices:',
        o: ['i-1 and i+1', '2i and 2i+1', '2i+1 and 2i+2', 'i/2 and i/2+1'], a: 2,
        e: 'In a 0-indexed array heap, children are 2i+1 and 2i+2; the parent is (i-1)/2.' },
      { q: 'After inserting a key at the end, the heap restores order by:',
        o: ['Sifting it down', 'Sifting it up toward the root', 'Re-sorting the whole array', 'Doing nothing'], a: 1,
        e: 'A newly appended key bubbles up, swapping with its parent until the property holds.' },
      { q: 'Build-heap on an arbitrary array of n keys runs in:',
        o: ['O(n log n)', 'O(n)', 'O(log n)', 'O(n squared)'], a: 1,
        e: 'A tight analysis of sifting down from the last parent up gives O(n), not O(n log n).' }
    ],
    '4': [
      { q: 'The load factor of a hash table is defined as:',
        o: ['buckets / keys (m / n)', 'keys / buckets (n / m)', 'collisions / keys', 'probes / search'], a: 1,
        e: 'Load factor alpha equals the number of keys n divided by the number of buckets m.' },
      { q: 'Separate chaining resolves a collision by:',
        o: ['Probing the next slot', 'Appending to a linked list at that bucket', 'Doubling the table', 'Rejecting the key'], a: 1,
        e: 'Each bucket holds a chain; colliding keys are simply added to that bucket\'s list.' },
      { q: 'Linear probing can suffer from:',
        o: ['Primary clustering of occupied slots', 'Unbounded memory per bucket', 'Sorted output', 'Negative load factor'], a: 0,
        e: 'Contiguous runs of filled slots grow and merge, lengthening future probe sequences.' },
      { q: 'Deleting under linear probing leaves a tombstone so that:',
        o: ['The table looks fuller', 'Later keys on the same probe chain remain findable', 'Memory is freed', 'The key can be undeleted'], a: 1,
        e: 'A true empty would stop a search early; a tombstone keeps the probe chain intact.' }
    ],
    '5': [
      { q: 'A stack provides which access discipline?',
        o: ['FIFO (first-in-first-out)', 'LIFO (last-in-first-out)', 'Random access', 'Sorted access'], a: 1,
        e: 'Push and pop both act on the top, so the last item pushed is the first popped.' },
      { q: 'Attempting to dequeue from an empty queue is an:',
        o: ['Overflow', 'Underflow', 'Out-of-memory error', 'No-op that returns zero'], a: 1,
        e: 'Removing from an empty structure is underflow; adding to a full one is overflow.' },
      { q: 'A circular queue of capacity C advances its rear pointer as:',
        o: ['rear + 1 (unbounded)', '(rear + 1) mod C', 'rear - 1', 'front + C'], a: 1,
        e: 'Modular arithmetic wraps the rear back to slot 0, reusing freed space.' },
      { q: 'The circular queue is full when:',
        o: ['front equals rear', '(rear + 1) mod C equals front', 'rear equals C', 'front equals -1'], a: 1,
        e: 'When the next rear slot would collide with front, the ring is full (one-slot convention or a size counter).' }
    ],
    '6': [
      { q: 'Inserting a new node at the head of a singly linked list is:',
        o: ['O(n)', 'O(1)', 'O(log n)', 'O(n log n)'], a: 1,
        e: 'You just point the new node at the old head and move head — constant time.' },
      { q: 'Reaching position k in a linked list costs:',
        o: ['O(1) random access', 'O(k) — you must walk there', 'O(log k)', 'O(1) with a prev pointer'], a: 1,
        e: 'Linked lists have no random access; you traverse k links to reach position k.' },
      { q: 'The extra pointer in a doubly linked list mainly enables:',
        o: ['Sorting in O(n)', 'Backward traversal and O(1) deletion of a known node', 'Random access', 'Hashing'], a: 1,
        e: 'The prev pointer lets you move backward and unlink a known node without scanning.' },
      { q: 'Reversing a singly linked list in place runs in:',
        o: ['O(1) time', 'O(n) time, O(1) extra space', 'O(n log n)', 'O(n) extra space'], a: 1,
        e: 'One pass flips each next pointer to the previous node — linear time, constant space.' }
    ],
    '7': [
      { q: 'Breadth-first search manages its frontier with a:',
        o: ['Stack (LIFO)', 'Queue (FIFO)', 'Priority queue', 'Hash table'], a: 1,
        e: 'BFS dequeues in FIFO order, expanding vertices in rings of increasing distance.' },
      { q: 'On an unweighted graph, BFS from a source finds:',
        o: ['Maximum spanning tree', 'Shortest paths in number of edges', 'A topological order', 'The minimum cut'], a: 1,
        e: 'Visiting in distance layers means the first time BFS reaches a vertex is via a shortest path.' },
      { q: 'Depth-first search explores by:',
        o: ['Spreading evenly in all directions', 'Going as deep as possible before backtracking', 'Visiting the closest vertex first', 'Random jumps'], a: 1,
        e: 'DFS follows one branch to its end (using a stack / recursion) before backtracking.' },
      { q: 'Using adjacency lists, both BFS and DFS run in time:',
        o: ['O(V)', 'O(E)', 'O(V + E)', 'O(V times E)'], a: 2,
        e: 'Each vertex and each edge is examined a constant number of times, giving O(V + E).' }
    ]
  };

  function buildQuiz(host) {
    var qid = host.getAttribute('data-quiz');
    var qs = QUIZZES[qid]; if (!qs) return;
    for (var i = 0; i < qs.length; i++) {
      (function (item, idx) {
        var card = document.createElement('div');
        card.className = 'q';
        var qt = document.createElement('div');
        qt.className = 'qt';
        qt.innerHTML = '<b>Q' + (idx + 1) + '.</b> ' + item.q;
        card.appendChild(qt);
        var answered = false;
        var opts = [];
        for (var j = 0; j < item.o.length; j++) {
          (function (optIdx) {
            var op = document.createElement('div');
            op.className = 'opt-a';
            op.textContent = item.o[optIdx];
            op.addEventListener('click', function () {
              if (answered) return;
              answered = true;
              for (var m = 0; m < opts.length; m++) {
                if (m === item.a) opts[m].classList.add('correct');
                else if (m === optIdx) opts[m].classList.add('wrong');
              }
              var expl = card.querySelector('.expl');
              expl.classList.add('show');
              if (optIdx !== item.a) card.classList.add('bad');
            });
            opts.push(op);
            card.appendChild(op);
          })(j);
        }
        var expl = document.createElement('div');
        expl.className = 'expl';
        expl.innerHTML = '<b>Answer:</b> ' + item.o[item.a] + '. ' + item.e;
        card.appendChild(expl);
        host.appendChild(card);
      })(qs[i], i);
    }
  }
  var quizHosts = document.querySelectorAll('.dsx .quiz');
  for (var qh = 0; qh < quizHosts.length; qh++) buildQuiz(quizHosts[qh]);

  // initial draw of experiment 1
  if (REDRAW['1']) { try { REDRAW['1'](); } catch (e) {} }
  window.addEventListener('resize', function () {
    var onExp = document.querySelector('.dsx .exp.on');
    if (onExp) { var n = onExp.id.split('-')[1]; if (REDRAW[n]) { try { REDRAW[n](); } catch (e) {} } }
  });
})();
</script>
