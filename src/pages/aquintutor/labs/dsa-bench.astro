  .dsx ol.steps li { margin-bottom:9px; }
  .dsx ol.steps li b { color:#f3f3f8; }
  .dsx ul.refs { list-style:none; padding:0; max-width:840px; }
  .dsx ul.refs li { font-size:12px; color:#9aa0aa; line-height:1.6; padding:8px 0; border-bottom:1px solid #1a1a24; }
  .dsx ul.refs li b { color:#cfd6da; }

  .dsx .layout { display:grid; grid-template-columns:minmax(0,1fr) 320px; gap:18px; align-items:start; }
  @media (max-width:980px) { .dsx .layout { grid-template-columns:1fr; } }
  .dsx .panel { background:#11131a; border:1px solid #2a2a35; border-radius:12px; padding:16px; }
  .dsx .panel h3 { font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin:0 0 13px; }
  .dsx canvas { display:block; width:100%; background:#08080b; border:1px solid #232330; border-radius:10px; }
  .dsx .row { display:flex; gap:9px; align-items:center; margin-bottom:11px; flex-wrap:wrap; }
  .dsx .row > label { font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:#9aa0aa; min-width:64px; }
  .dsx input[type=range] { -webkit-appearance:none; appearance:none; background:#0a0a0c; border:1px solid #2a2a35; height:6px; border-radius:4px; flex:1; min-width:90px; }
  .dsx input[type=range]::-webkit-slider-thumb { -webkit-appearance:none; appearance:none; width:14px; height:14px; border-radius:50%; background:#a78bfa; cursor:pointer; border:none; }
  .dsx input[type=range]::-moz-range-thumb { width:14px; height:14px; border-radius:50%; background:#a78bfa; cursor:pointer; border:none; }
  .dsx input[type=number], .dsx input[type=text] { background:#0a0a0c; border:1px solid #2a2a35; color:#e8e8ee; padding:7px 9px; border-radius:6px; font-family:inherit; font-size:12px; width:78px; }
  .dsx select { background:#0a0a0c; border:1px solid #2a2a35; color:#e8e8ee; padding:7px 9px; border-radius:6px; font-family:inherit; font-size:11.5px; flex:1; }
  .dsx .val { font-size:11.5px; color:#a78bfa; min-width:52px; text-align:right; }
  .dsx .btn { background:#a78bfa; color:#16091f; padding:9px 13px; border:none; border-radius:7px; font-family:inherit; font-size:10.5px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; cursor:pointer; }
  .dsx .btn:hover { background:#bda3ff; }
  .dsx .btn:disabled { opacity:0.4; cursor:not-allowed; }
  .dsx .btn.ghost { background:transparent; color:#cfd6da; border:1px solid #2a2a35; }
  .dsx .btn.ghost:hover { border-color:#a78bfa; color:#a78bfa; }
  .dsx .btn.cyan { background:#67e8f9; color:#04161b; }
  .dsx .btn.cyan:hover { background:#8af0ff; }
  .dsx .btn.amber { background:#fbbf24; color:#1c1402; }
  .dsx .btn.amber:hover { background:#fcd34d; }
  .dsx .btn.red { background:#fca5a5; color:#260808; }
  .dsx .btn.red:hover { background:#fda4af; }
  .dsx .btns { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:6px; }
  .dsx .btns.three { grid-template-columns:1fr 1fr 1fr; }
  .dsx .btns .full { grid-column:1/-1; }
  .dsx .stats { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:13px; }
  .dsx .stat { background:#0a0a0c; border:1px solid #232330; border-radius:7px; padding:8px 10px; }
  .dsx .stat .k { font-size:9px; letter-spacing:0.12em; text-transform:uppercase; color:#9aa0aa; }
  .dsx .stat .v { font-size:16px; color:#67e8f9; font-weight:700; margin-top:3px; word-break:break-word; }
  .dsx .stat .v.sm { font-size:12px; }
  .dsx .help { font-size:10.5px; color:#9aa0aa; line-height:1.65; margin-top:11px; }
  .dsx .help b { color:#e8e8ee; }
  .dsx .help code { color:#fbbf24; background:#0a0a0c; padding:1px 5px; border-radius:3px; }
  .dsx .badge { display:inline-block; font-size:9px; padding:2px 7px; border-radius:4px; background:#1a1a25; color:#86efac; letter-spacing:0.1em; margin-left:6px; }
  .dsx .badge.warn { color:#fbbf24; }
  .dsx .badge.bad { color:#fca5a5; }
  .dsx .seg { display:flex; gap:6px; }
  .dsx .seg .opt { flex:1; text-align:center; background:#0a0a0c; border:1px solid #2a2a35; color:#9aa0aa; padding:7px 0; border-radius:6px; font-size:10px; letter-spacing:0.08em; text-transform:uppercase; cursor:pointer; }
  .dsx .seg .opt.on { border-color:#fbbf24; color:#fbbf24; }
  .dsx .log { background:#0a0a0c; border:1px solid #232330; border-radius:8px; padding:9px 11px; margin-top:13px; max-height:128px; overflow-y:auto; font-size:11px; color:#9aa0aa; line-height:1.7; }
  .dsx .log .ln { border-bottom:1px solid #14141c; padding:2px 0; }
  .dsx .log .ln:last-child { border-bottom:none; }
  .dsx .log .ln b { color:#67e8f9; }
  .dsx .cplx { display:inline-block; font-size:10px; color:#fbbf24; background:#0a0a0c; border:1px solid #232330; border-radius:5px; padding:3px 8px; margin-top:11px; }
