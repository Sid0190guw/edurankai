<script is:inline>
(function () {
  'use strict';
  function $(id) { return document.getElementById(id); }
  function rnd(a, b) { return a + Math.floor(Math.random() * (b - a + 1)); }
  function delayFor(spd) { return Math.max(40, 520 - spd * 48); }
  function sleep(ms) { return new Promise(function (res) { setTimeout(res, ms); }); }
  var DPR = Math.min(window.devicePixelRatio || 1, 2);

  // canvas sizing: keep logical coords = attribute width/height, scale for DPR + CSS width
  function makeCtx(cv, logicalW, logicalH) {
    var cssW = cv.clientWidth || logicalW;
    var scale = cssW / logicalW;
    cv.width = Math.round(logicalW * DPR * scale);
    cv.height = Math.round(logicalH * DPR * scale);
    cv.style.height = (logicalH * scale) + 'px';
    var ctx = cv.getContext('2d');
    ctx.setTransform(DPR * scale, 0, 0, DPR * scale, 0, 0);
    return ctx;
  }

  var COL = {
    bg: '#08080b', node: '#1b2030', nodeStroke: '#3a4459', text: '#e8e8ee',
    edge: '#3a4054', path: '#67e8f9', good: '#86efac', warn: '#fbbf24',
    bad: '#fca5a5', accent: '#a78bfa', dim: '#6b7280'
  };

  function logTo(el, html) {
    var ln = document.createElement('div');
    ln.className = 'ln';
    ln.innerHTML = html;
    el.insertBefore(ln, el.firstChild);
    while (el.children.length > 30) el.removeChild(el.lastChild);
  }

  // ---------- EXPERIMENT (sidebar) SWITCHING ----------
  var items = document.querySelectorAll('.dsx .exp-item');
  for (var t = 0; t < items.length; t++) {
    items[t].addEventListener('click', function () {
      var n = this.getAttribute('data-exp');
      var all = document.querySelectorAll('.dsx .exp-item');
      for (var i = 0; i < all.length; i++) all[i].classList.remove('on');
      this.classList.add('on');
      var exps = document.querySelectorAll('.dsx .exp');
      for (var j = 0; j < exps.length; j++) exps[j].classList.remove('on');
      $('exp-' + n).classList.add('on');
      window.scrollTo({ top: 0, behavior: 'smooth' });
      if (REDRAW[n]) { try { REDRAW[n](); } catch (e) {} }
    });
  }

  // ---------- SECTION (tab) SWITCHING ----------
  var REDRAW = {};
  var secbars = document.querySelectorAll('.dsx .secbar');
  for (var s = 0; s < secbars.length; s++) {
    (function (bar) {
      var stabs = bar.querySelectorAll('.stab');
      var expEl = bar.parentNode;
      for (var k = 0; k < stabs.length; k++) {
        stabs[k].addEventListener('click', function () {
          var name = this.getAttribute('data-sec');
          for (var a = 0; a < stabs.length; a++) stabs[a].classList.remove('on');
          this.classList.add('on');
          var secs = expEl.querySelectorAll('.sec');
          for (var b = 0; b < secs.length; b++) secs[b].classList.remove('on');
          var target = expEl.querySelector('.sec.' + name);
          if (target) target.classList.add('on');
          if (name === 'sim') {
            var enr = expEl.id.split('-')[1];
            if (REDRAW[enr]) { try { REDRAW[enr](); } catch (e) {} }
          }
        });
      }
    })(secbars[s]);
  }

  function bindSpeed(slId, vId, set) {
    var sl = $(slId);
    sl.addEventListener('input', function () { $(vId).textContent = sl.value + 'x'; set(parseInt(sl.value, 10)); });
  }

  // ===================================================================
  // EXPERIMENT 1 — BINARY SEARCH TREE
  // ===================================================================
  (function BST() {
    var cv = $('bstCv'); if (!cv) return;
    var ctx = makeCtx(cv, 660, 460);
    var LW = 660, LH = 460;
    var root = null, count = 0, speed = 5, busy = false;
    var hl = {};           // id -> highlight color
    var flashId = -1;
    var idc = 0;

    function node(v) { return { v: v, l: null, r: null, id: idc++, x: 0, y: 0 }; }

    function insert(v) {
      if (root === null) { root = node(v); count++; return [root.id]; }
      var cur = root, path = [];
      while (true) {
        path.push(cur.id);
        if (v === cur.v) return path; // dup
        if (v < cur.v) { if (cur.l) cur = cur.l; else { cur.l = node(v); count++; path.push(cur.l.id); return path; } }
        else { if (cur.r) cur = cur.r; else { cur.r = node(v); count++; path.push(cur.r.id); return path; } }
      }
    }
    function searchPath(v) {
      var cur = root, path = [], found = false;
      while (cur) { path.push(cur.id); if (v === cur.v) { found = true; break; } cur = v < cur.v ? cur.l : cur.r; }
      return { path: path, found: found };
    }
    function minNode(n) { while (n.l) n = n.l; return n; }
    function del(nd, v, path) {
      if (!nd) return null;
      path.push(nd.id);
      if (v < nd.v) nd.l = del(nd.l, v, path);
      else if (v > nd.v) nd.r = del(nd.r, v, path);
      else {
        if (!nd.l) { count--; return nd.r; }
        if (!nd.r) { count--; return nd.l; }
        var succ = minNode(nd.r);
        nd.v = succ.v;
        nd.r = del(nd.r, succ.v, []);
      }
      return nd;
    }
    function height(n) { return n ? 1 + Math.max(height(n.l), height(n.r)) : 0; }
    function isBal(n) {
      if (!n) return true;
      var lh = height(n.l), rh = height(n.r);
      if (Math.abs(lh - rh) > 1) return false;
      return isBal(n.l) && isBal(n.r);
    }
    function inorder(n, a) { if (!n) return; inorder(n.l, a); a.push(n.v); inorder(n.r, a); }
    function preorder(n, a) { if (!n) return; a.push(n.v); preorder(n.l, a); preorder(n.r, a); }
    function postorder(n, a) { if (!n) return; postorder(n.l, a); postorder(n.r, a); a.push(n.v); }

    function layout() {
      var xc = { i: 0 };
      var h = Math.max(1, height(root));
      var vgap = Math.min(72, (LH - 70) / h);
      function rec(n, depth) {
        if (!n) return;
        rec(n.l, depth + 1);
        n.x = 36 + xc.i * ((LW - 72) / Math.max(1, count - 1 || 1));
        if (count === 1) n.x = LW / 2;
        n.y = 44 + depth * vgap;
        xc.i++;
        rec(n.r, depth + 1);
      }
      rec(root, 0);
    }

    function draw() {
      layout();
      ctx.clearRect(0, 0, LW, LH);
      ctx.fillStyle = COL.bg; ctx.fillRect(0, 0, LW, LH);
      if (!root) { ctx.fillStyle = COL.dim; ctx.font = '14px monospace'; ctx.textAlign = 'center'; ctx.fillText('empty tree — insert a key', LW / 2, LH / 2); return; }
      // edges
      ctx.lineWidth = 2;
      (function edges(n) {
        if (!n) return;
        [n.l, n.r].forEach(function (c) {
          if (c) {
            var lit = hl[n.id] && hl[c.id];
            ctx.strokeStyle = lit ? COL.path : COL.edge;
            ctx.beginPath(); ctx.moveTo(n.x, n.y); ctx.lineTo(c.x, c.y); ctx.stroke();
          }
        });
        edges(n.l); edges(n.r);
      })(root);
      // nodes
      (function nodes(n) {
        if (!n) return;
        var r = 17;
        var c = hl[n.id] || null;
        ctx.beginPath(); ctx.arc(n.x, n.y, r, 0, Math.PI * 2);
        ctx.fillStyle = n.id === flashId ? COL.good : (c ? '#142533' : COL.node);
        ctx.fill();
        ctx.lineWidth = 2; ctx.strokeStyle = c || COL.nodeStroke; ctx.stroke();
        ctx.fillStyle = n.id === flashId ? '#0a0a0c' : COL.text; ctx.font = 'bold 12px monospace'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(String(n.v), n.x, n.y);
        nodes(n.l); nodes(n.r);
      })(root);
      ctx.textBaseline = 'alphabetic';
    }

    function refresh() {
      var a = []; inorder(root, a);
      var pr = []; preorder(root, pr);
      var po = []; postorder(root, po);
      $('bstIn').textContent = a.length ? a.join(', ') : '--';
      $('bstPre').textContent = pr.length ? pr.join(', ') : '--';
      $('bstPost').textContent = po.length ? po.join(', ') : '--';
      $('bstN').textContent = count;
      $('bstH').textContent = height(root);
      var bal = isBal(root);
      $('bstBal').textContent = bal ? 'balanced' : 'unbalanced';
      $('bstBal').className = bal ? 'badge' : 'badge bad';
      $('bstMM').textContent = a.length ? (a[0] + ' / ' + a[a.length - 1]) : '--';
      draw();
    }

    async function animPath(path, color) {
      hl = {};
      var cmp = 0;
      for (var i = 0; i < path.length; i++) {
        hl[path[i]] = color;
        cmp++;
        $('bstCmp').textContent = cmp;
        draw();
        await sleep(delayFor(speed));
      }
      return cmp;
    }

    async function doInsert(v) {
      if (busy) return; busy = true; setEnabled(false);
      var path = insert(v);
      await animPath(path, COL.path);
      flashId = path[path.length - 1];
      refresh();
      await sleep(delayFor(speed));
      flashId = -1; hl = {}; refresh();
      $('bstStatus').textContent = 'inserted ' + v;
      logTo($('bstLog'), 'insert <b>' + v + '</b> &mdash; ' + path.length + ' comparisons');
      busy = false; setEnabled(true);
    }
    async function doSearch(v) {
      if (busy) return; busy = true; setEnabled(false);
      var r = searchPath(v);
      await animPath(r.path, r.found ? COL.good : COL.warn);
      if (r.found) { flashId = r.path[r.path.length - 1]; draw(); }
      $('bstStatus').textContent = r.found ? 'found ' + v : v + ' not found';
      logTo($('bstLog'), 'search <b>' + v + '</b> &mdash; ' + (r.found ? 'found' : 'not found') + ' in ' + r.path.length + ' steps');
      await sleep(delayFor(speed) * 2);
      flashId = -1; hl = {}; refresh();
      busy = false; setEnabled(true);
    }
    async function doDelete(v) {
      if (busy) return; busy = true; setEnabled(false);
      var r = searchPath(v);
      if (!r.found) {
        await animPath(r.path, COL.warn);
        $('bstStatus').textContent = v + ' not in tree';
        logTo($('bstLog'), 'delete <b>' + v + '</b> &mdash; not found');
        await sleep(delayFor(speed)); hl = {}; refresh();
        busy = false; setEnabled(true); return;
      }
      var path = [];
      await animPath(r.path, COL.bad);
      root = del(root, v, path);
      $('bstStatus').textContent = 'deleted ' + v;
      logTo($('bstLog'), 'delete <b>' + v + '</b> &mdash; spliced / successor-replaced');
      hl = {}; refresh();
      busy = false; setEnabled(true);
    }

    function setEnabled(on) {
      ['bstIns', 'bstSrch', 'bstDel', 'bstRand', 'bstReset'].forEach(function (id) { $(id).disabled = !on; });
    }

    $('bstIns').addEventListener('click', function () { var v = parseInt($('bstKey').value, 10); if (!isNaN(v)) doInsert(v); });
    $('bstSrch').addEventListener('click', function () { var v = parseInt($('bstKey').value, 10); if (!isNaN(v)) doSearch(v); });
    $('bstDel').addEventListener('click', function () { var v = parseInt($('bstKey').value, 10); if (!isNaN(v)) doDelete(v); });
    $('bstRand').addEventListener('click', function () { if (busy) return; var v = rnd(1, 99); $('bstKey').value = v; doInsert(v); });
    $('bstReset').addEventListener('click', function () { if (busy) return; root = null; count = 0; idc = 0; hl = {}; flashId = -1; $('bstCmp').textContent = 0; seed(); $('bstStatus').textContent = 'reset'; });
    bindSpeed('bstSpd', 'bstSpdv', function (v) { speed = v; });

    function seed() {
      [50, 30, 70, 20, 40, 60, 80, 35].forEach(function (v) { insert(v); });
      refresh();
    }
    seed();
    REDRAW['1'] = function () { ctx = makeCtx(cv, LW, LH); refresh(); };
  })();

  // ===================================================================
  // EXPERIMENT 2 — AVL TREE
  // ===================================================================
  (function AVL() {
    var cv = $('avlCv'); if (!cv) return;
    var ctx = makeCtx(cv, 660, 460);
    var LW = 660, LH = 460;
    var root = null, count = 0, rotations = 0, speed = 5, busy = false, idc = 0;
    var hl = {}, flashId = -1, lastRot = '--';

    function node(v) { return { v: v, l: null, r: null, h: 1, id: idc++, x: 0, y: 0 }; }
    function h(n) { return n ? n.h : 0; }
    function bf(n) { return n ? h(n.l) - h(n.r) : 0; }
    function upd(n) { n.h = 1 + Math.max(h(n.l), h(n.r)); }

    var rotLog = [];
    function rotRight(y) { var x = y.l, t = x.r; x.r = y; y.l = t; upd(y); upd(x); rotations++; return x; }
    function rotLeft(x) { var y = x.r, t = y.l; y.l = x; x.r = t; upd(x); upd(y); rotations++; return y; }

    function insert(n, v) {
      if (!n) { count++; return node(v); }
      if (v === n.v) return n;
      if (v < n.v) n.l = insert(n.l, v); else n.r = insert(n.r, v);
      upd(n);
      var b = bf(n);
      if (b > 1 && v < n.l.v) { rotLog.push('LL @' + n.v); return rotRight(n); }
      if (b < -1 && v > n.r.v) { rotLog.push('RR @' + n.v); return rotLeft(n); }
      if (b > 1 && v > n.l.v) { rotLog.push('LR @' + n.v); n.l = rotLeft(n.l); return rotRight(n); }
      if (b < -1 && v < n.r.v) { rotLog.push('RL @' + n.v); n.r = rotRight(n.r); return rotLeft(n); }
      return n;
    }
    function minNode(n) { while (n.l) n = n.l; return n; }
    function del(n, v) {
      if (!n) return null;
      if (v < n.v) n.l = del(n.l, v);
      else if (v > n.v) n.r = del(n.r, v);
      else {
        if (!n.l || !n.r) { count--; return n.l ? n.l : n.r; }
        var s = minNode(n.r); n.v = s.v; n.r = del2(n.r, s.v);
      }
      upd(n);
      var b = bf(n);
      if (b > 1 && bf(n.l) >= 0) { rotLog.push('LL @' + n.v); return rotRight(n); }
      if (b > 1 && bf(n.l) < 0) { rotLog.push('LR @' + n.v); n.l = rotLeft(n.l); return rotRight(n); }
      if (b < -1 && bf(n.r) <= 0) { rotLog.push('RR @' + n.v); return rotLeft(n); }
      if (b < -1 && bf(n.r) > 0) { rotLog.push('RL @' + n.v); n.r = rotRight(n.r); return rotLeft(n); }
      return n;
    }
    // delete successor without double-decrementing count
    function del2(n, v) {
      if (!n) return null;
      if (v < n.v) n.l = del2(n.l, v);
      else if (v > n.v) n.r = del2(n.r, v);
      else { count--; if (!n.l || !n.r) return n.l ? n.l : n.r; var s = minNode(n.r); n.v = s.v; count++; n.r = del2(n.r, s.v); }
      upd(n); var b = bf(n);
      if (b > 1 && bf(n.l) >= 0) { rotLog.push('LL'); return rotRight(n); }
      if (b > 1 && bf(n.l) < 0) { rotLog.push('LR'); n.l = rotLeft(n.l); return rotRight(n); }
      if (b < -1 && bf(n.r) <= 0) { rotLog.push('RR'); return rotLeft(n); }
      if (b < -1 && bf(n.r) > 0) { rotLog.push('RL'); n.r = rotRight(n.r); return rotLeft(n); }
      return n;
    }
    function searchPath(v) {
      var cur = root, path = [], found = false;
      while (cur) { path.push(cur.id); if (v === cur.v) { found = true; break; } cur = v < cur.v ? cur.l : cur.r; }
      return { path: path, found: found };
    }
    function inorder(n, a) { if (!n) return; inorder(n.l, a); a.push(n.v); inorder(n.r, a); }

    function layout() {
      var xc = { i: 0 };
      var ht = Math.max(1, h(root));
      var vgap = Math.min(72, (LH - 80) / ht);
      function rec(n, depth) {
        if (!n) return;
        rec(n.l, depth + 1);
        n.x = 40 + xc.i * ((LW - 80) / Math.max(1, count - 1 || 1));
        if (count === 1) n.x = LW / 2;
        n.y = 50 + depth * vgap;
        xc.i++;
        rec(n.r, depth + 1);
      }
      rec(root, 0);
    }
    function draw() {
      layout();
      ctx.clearRect(0, 0, LW, LH);
      ctx.fillStyle = COL.bg; ctx.fillRect(0, 0, LW, LH);
      if (!root) { ctx.fillStyle = COL.dim; ctx.font = '14px monospace'; ctx.textAlign = 'center'; ctx.fillText('empty — try inserting 10, 20, 30', LW / 2, LH / 2); return; }
      ctx.lineWidth = 2;
      (function edges(n) {
        if (!n) return;
        [n.l, n.r].forEach(function (c) {
          if (c) {
            ctx.strokeStyle = (hl[n.id] && hl[c.id]) ? COL.path : COL.edge;
            ctx.beginPath(); ctx.moveTo(n.x, n.y); ctx.lineTo(c.x, c.y); ctx.stroke();
          }
        });
        edges(n.l); edges(n.r);
      })(root);
      (function nodes(n) {
        if (!n) return;
        var c = hl[n.id] || null;
        ctx.beginPath(); ctx.arc(n.x, n.y, 17, 0, Math.PI * 2);
        ctx.fillStyle = n.id === flashId ? COL.good : (c ? '#142533' : COL.node); ctx.fill();
        ctx.lineWidth = 2; ctx.strokeStyle = c || COL.nodeStroke; ctx.stroke();
        ctx.fillStyle = n.id === flashId ? '#0a0a0c' : COL.text; ctx.font = 'bold 12px monospace'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(String(n.v), n.x, n.y);
        var b = bf(n);
        ctx.fillStyle = Math.abs(b) > 1 ? COL.bad : COL.warn; ctx.font = '10px monospace'; ctx.textBaseline = 'alphabetic';
        ctx.fillText((b > 0 ? '+' : '') + b, n.x + 22, n.y - 14);
        nodes(n.l); nodes(n.r);
      })(root);
      ctx.textBaseline = 'alphabetic';
    }
    function refresh() {
      var a = []; inorder(root, a);
      $('avlIn').textContent = a.length ? a.join(', ') : '--';
      $('avlN').textContent = count;
      $('avlH').textContent = h(root);
      $('avlRot').textContent = rotations;
      $('avlLast').textContent = lastRot;
      var ok = isAVL(root);
      $('avlBal').textContent = ok ? 'AVL ok' : 'violated';
      $('avlBal').className = ok ? 'badge' : 'badge bad';
      draw();
    }
    function isAVL(n) { if (!n) return true; if (Math.abs(bf(n)) > 1) return false; return isAVL(n.l) && isAVL(n.r); }

    async function animPath(path, color) {
      hl = {};
      for (var i = 0; i < path.length; i++) { hl[path[i]] = color; draw(); await sleep(delayFor(speed)); }
    }
    function setEnabled(on) { ['avlIns', 'avlSrch', 'avlDel', 'avlRand', 'avlReset'].forEach(function (id) { $(id).disabled = !on; }); }

    async function doInsert(v) {
      if (busy) return; busy = true; setEnabled(false);
      var sp = searchPath(v);
      if (!sp.found) await animPath(sp.path, COL.path);
