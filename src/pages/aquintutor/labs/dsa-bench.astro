                <canvas id="heapArr" width="660" height="86" style="margin-top:8px;"></canvas>
                <div class="cplx">insert / extract: <b>O(log n)</b> &middot; build-heap: <b>O(n)</b></div>
              </div>
              <div>
                <div class="panel">
