---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Linear transformation lab — a live 2x2 matrix warps the plane: transformed
// grid, basis vectors, the unit-square parallelogram whose signed area is the
// determinant, and real eigenvectors/values. Animatable identity->matrix.
// Depth-lit high-DPI canvas, no libraries.
---
<BaseLayout title="Linear algebra lab · Virtual Labs · AquinTutor" description="Warp the plane with a 2x2 matrix — watch the grid, basis vectors, determinant area and eigenvectors respond in real time.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1320px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:18px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:300px minmax(0,1fr); gap:18px; } @media(max-width:900px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:16px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 12px; }
  .mat{ display:grid; grid-template-columns:1fr 1fr; gap:10px; }
  .mat .cell label{ font-family:'Geist Mono',monospace; font-size:9.5px; color:#8ea0be; display:flex; justify-content:space-between; }
  .mat .cell label span{ color:#5ee7ff; } .mat input[type=range]{ width:100%; accent-color:#5ee7ff; }
  .lb-btn{ background:linear-gradient(180deg,#7af0ff,#33cfe6); color:#04161b; padding:9px 14px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:10.5px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; }
  .lb-btn-ghost{ background:transparent; color:#cfd6da; border:1px solid #26314f; }
  .preset{ background:#080a12; border:1px solid #1e2740; color:#cfd6da; padding:6px 10px; border-radius:6px; font-family:'Geist Mono',monospace; font-size:11px; cursor:pointer; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); }
  .lb-stage canvas{ display:block; width:100%; height:auto; }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11.5px; padding:5px 0; border-bottom:1px solid #141a2c; }
  .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#5ee7ff; font-weight:700; text-align:right; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">Maths · Linear algebra</p>
      <h1 class="lb-title">Linear <em>transform</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;"><button id="animBtn" class="lb-btn">Animate</button><button id="idBtn" class="lb-btn lb-btn-ghost">Identity</button></div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Matrix A</h3><div class="mat">
        <div class="cell"><label>a <span id="aV">1.0</span></label><input id="a" type="range" min="-3" max="3" step="0.05" value="1"/></div>
        <div class="cell"><label>b <span id="bV">0.0</span></label><input id="b" type="range" min="-3" max="3" step="0.05" value="0"/></div>
        <div class="cell"><label>c <span id="cV">0.0</span></label><input id="c" type="range" min="-3" max="3" step="0.05" value="0"/></div>
        <div class="cell"><label>d <span id="dV">1.0</span></label><input id="d" type="range" min="-3" max="3" step="0.05" value="1"/></div>
      </div>
      <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:12px;">
        <button class="preset" data-m="0,-1,1,0">Rotate 90°</button><button class="preset" data-m="-1,0,0,1">Reflect</button><button class="preset" data-m="1,1,0,1">Shear</button><button class="preset" data-m="2,0,0,0.5">Scale</button>
      </div></div>
      <div class="lb-panel"><h3>Invariants</h3>
        <div class="lb-metric"><span class="lb-metric-l">det A</span><span class="lb-metric-v" id="mDet">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">trace</span><span class="lb-metric-v" id="mTr">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">λ₁, λ₂</span><span class="lb-metric-v" id="mEig">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">area scale |det|</span><span class="lb-metric-v" id="mArea">—</span></div>
      </div>
    </aside>
    <section><div class="lb-stage"><canvas id="scene" width="900" height="620"></canvas></div></section>
  </div>
</main>
<script is:inline>
(function(){
  function v(id){ return parseFloat(document.getElementById(id).value); }
  var t=1, animating=false;
  function sync(){ ['a','b','c','d'].forEach(function(id){ document.getElementById(id+'V').textContent=v(id).toFixed(2); }); }
  document.querySelectorAll('.mat input').forEach(function(e){ e.addEventListener('input',function(){ sync(); }); }); sync();
  document.getElementById('idBtn').addEventListener('click',function(){ ['a','d'].forEach(function(id){ document.getElementById(id).value=1; }); ['b','c'].forEach(function(id){ document.getElementById(id).value=0; }); sync(); });
  document.querySelectorAll('.preset').forEach(function(b){ b.addEventListener('click',function(){ var m=b.getAttribute('data-m').split(','); ['a','b','c','d'].forEach(function(id,i){ document.getElementById(id).value=m[i]; }); sync(); t=0; animating=true; }); });
  document.getElementById('animBtn').addEventListener('click',function(){ t=0; animating=true; });

  function hidpi(c){ var r=c.getBoundingClientRect(), d=window.devicePixelRatio||1; var w=r.width||c.width, h=(c.height/c.width)*w; c.width=Math.round(w*d); c.height=Math.round(h*d); var ctx=c.getContext('2d'); ctx.setTransform(d,0,0,d,0,0); return {ctx:ctx,w:w,h:h}; }
  function draw(){ var cv=document.getElementById('scene'), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h;
    var bg=ctx.createLinearGradient(0,0,0,H); bg.addColorStop(0,'#0b1020'); bg.addColorStop(1,'#06080f'); ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    var cx=W/2, cy=H/2, sc=Math.min(W,H)/11;
    var a=v('a'),b=v('b'),c=v('c'),d=v('d');
    var A=(1-t)+t*a, B=t*b, C=t*c, D=(1-t)+t*d; // interpolate from identity
    function M(x,y){ return [A*x+B*y, C*x+D*y]; }
    function P(x,y){ return [cx+x*sc, cy-y*sc]; }
    // faint original grid
    ctx.strokeStyle='rgba(90,110,150,0.10)'; ctx.lineWidth=1;
    for(var i=-5;i<=5;i++){ var p1=P(i,-5),p2=P(i,5),p3=P(-5,i),p4=P(5,i); ctx.beginPath(); ctx.moveTo(p1[0],p1[1]); ctx.lineTo(p2[0],p2[1]); ctx.moveTo(p3[0],p3[1]); ctx.lineTo(p4[0],p4[1]); ctx.stroke(); }
    // transformed grid (glow)
    ctx.save(); ctx.shadowColor='#5ee7ff'; ctx.shadowBlur=5; ctx.strokeStyle='rgba(94,231,255,0.35)'; ctx.lineWidth=1;
    for(var i=-5;i<=5;i++){ ctx.beginPath(); for(var j=-5;j<=5;j++){ var m=M(i,j), p=P(m[0],m[1]); j===-5?ctx.moveTo(p[0],p[1]):ctx.lineTo(p[0],p[1]); } ctx.stroke();
      ctx.beginPath(); for(var j=-5;j<=5;j++){ var m=M(j,i), p=P(m[0],m[1]); j===-5?ctx.moveTo(p[0],p[1]):ctx.lineTo(p[0],p[1]); } ctx.stroke(); }
    ctx.restore();
    // determinant parallelogram (unit square image)
    var o=P(0,0), i1=M(1,0), j1=M(0,1); var pi=P(i1[0],i1[1]), pj=P(j1[0],j1[1]), pij=P(i1[0]+j1[0], i1[1]+j1[1]);
    ctx.fillStyle='rgba(251,191,36,0.14)'; ctx.beginPath(); ctx.moveTo(o[0],o[1]); ctx.lineTo(pi[0],pi[1]); ctx.lineTo(pij[0],pij[1]); ctx.lineTo(pj[0],pj[1]); ctx.closePath(); ctx.fill();
    // axes
    ctx.strokeStyle='#38507a'; ctx.lineWidth=1.5; ctx.beginPath(); ctx.moveTo(0,cy); ctx.lineTo(W,cy); ctx.moveTo(cx,0); ctx.lineTo(cx,H); ctx.stroke();
    // basis vectors
    function vec(from,to,col){ ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=10; ctx.strokeStyle=col; ctx.fillStyle=col; ctx.lineWidth=3; ctx.beginPath(); ctx.moveTo(from[0],from[1]); ctx.lineTo(to[0],to[1]); ctx.stroke(); var ang=Math.atan2(to[1]-from[1],to[0]-from[0]); ctx.beginPath(); ctx.moveTo(to[0],to[1]); ctx.lineTo(to[0]-10*Math.cos(ang-0.4),to[1]-10*Math.sin(ang-0.4)); ctx.lineTo(to[0]-10*Math.cos(ang+0.4),to[1]-10*Math.sin(ang+0.4)); ctx.closePath(); ctx.fill(); ctx.restore(); }
    vec(o,pi,'#f472b6'); vec(o,pj,'#34d399');
    // eigenvectors (real)
    var det=a*d-b*c, tr=a+d, disc=tr*tr-4*det;
    if(disc>=0 && t>0.98){ var s1=(tr+Math.sqrt(disc))/2, s2=(tr-Math.sqrt(disc))/2; [s1,s2].forEach(function(lam){ var vx,vy; if(Math.abs(b)>1e-6){ vx=b; vy=lam-a; } else if(Math.abs(c)>1e-6){ vx=lam-d; vy=c; } else { vx=1; vy=0; } var n=Math.hypot(vx,vy)||1; vx/=n; vy/=n; var e1=P(vx*5,vy*5), e2=P(-vx*5,-vy*5); ctx.save(); ctx.setLineDash([6,5]); ctx.strokeStyle='rgba(255,255,255,0.5)'; ctx.lineWidth=1.5; ctx.beginPath(); ctx.moveTo(e2[0],e2[1]); ctx.lineTo(e1[0],e1[1]); ctx.stroke(); ctx.restore(); }); }
    // metrics
    document.getElementById('mDet').textContent=det.toFixed(2); document.getElementById('mTr').textContent=tr.toFixed(2);
    document.getElementById('mEig').textContent = disc>=0 ? (((tr+Math.sqrt(disc))/2).toFixed(2)+', '+((tr-Math.sqrt(disc))/2).toFixed(2)) : 'complex';
    document.getElementById('mArea').textContent=Math.abs(det).toFixed(2);
  }
  function loop(){ if(animating){ t+=0.02; if(t>=1){ t=1; animating=false; } } draw(); requestAnimationFrame(loop); } requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
