---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Linear Algebra Visualiser — AquinTutor Labs" description="2D linear-transformation playground with live eigen-decomposition, determinant, inverse and animated identity-to-M interpolation.">
<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; }
  .wrap { max-width: 1280px; margin: 0 auto; padding: 32px 24px 80px; }
  .eyebrow { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; }
  h1 { font-family: 'Cormorant Garamond', serif; font-size: 34px; font-weight: 600; letter-spacing: -0.02em; margin: 6px 0 6px; line-height: 1.15; }
  h1 em { font-style: italic; color: #67e8f9; font-weight: 500; }
  .sub { color: #9aa0a6; max-width: 720px; font-size: 14px; line-height: 1.55; margin: 0 0 28px; }
  .grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 18px; }
  @media (max-width: 980px) { .grid { grid-template-columns: 1fr; } }
  .panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 16px; }
  .panel h3 { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 12px; }
  canvas { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 10px; display: block; }
  .sliders { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px 16px; margin: 8px 0 12px; }
  .slider-row { display: flex; flex-direction: column; gap: 4px; }
  .slider-row label { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #cfd6da; display: flex; justify-content: space-between; }
  .slider-row label span { color: #67e8f9; }
  input[type=range] { width: 100%; accent-color: #67e8f9; }
  .presets { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; margin: 10px 0 0; }
  .btn { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; padding: 7px 9px; border-radius: 5px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; font-weight: 600; letter-spacing: 0.04em; cursor: pointer; text-transform: uppercase; }
  .btn:hover { border-color: #67e8f9; color: #67e8f9; }
  .btn.primary { background: #67e8f9; color: #04161b; border-color: #67e8f9; font-weight: 700; padding: 9px 16px; font-size: 11px; letter-spacing: 0.06em; }
  .row { display: flex; gap: 8px; align-items: center; margin-top: 12px; flex-wrap: wrap; }
  .matrix { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 13px; color: #e8e8ee; line-height: 1.55; }
  .matrix .br { display: inline-block; vertical-align: middle; font-size: 28px; font-weight: 200; color: #67e8f9; line-height: 1; }
  .matrix table { display: inline-table; border-collapse: collapse; margin: 0 4px; }
  .matrix td { padding: 2px 8px; text-align: right; min-width: 48px; }
  .kv { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12px; color: #cfd6da; margin: 4px 0; }
  .kv strong { color: #67e8f9; font-weight: 700; margin-right: 6px; }
  .pill { display: inline-block; padding: 2px 8px; border-radius: 4px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 700; }
  .pill.ok { background: rgba(103,232,249,0.12); color: #67e8f9; border: 1px solid rgba(103,232,249,0.35); }
  .pill.warn { background: rgba(244,114,182,0.12); color: #f472b6; border: 1px solid rgba(244,114,182,0.35); }
  .legend { display: flex; flex-wrap: wrap; gap: 12px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; color: #9aa0a6; margin-top: 10px; text-transform: uppercase; letter-spacing: 0.06em; }
  .legend span { display: inline-flex; align-items: center; gap: 6px; }
  .legend i { width: 14px; height: 2px; display: inline-block; }
  .back { display: inline-flex; align-items: center; gap: 6px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #9aa0a6; text-decoration: none; margin-bottom: 18px; letter-spacing: 0.08em; text-transform: uppercase; }
  .back:hover { color: #67e8f9; }
  .t-anim { display: flex; align-items: center; gap: 10px; margin-top: 8px; }
  .t-anim input { flex: 1; }
  .t-anim span { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #67e8f9; min-width: 80px; text-align: right; }
  .checkrow { display: flex; flex-wrap: wrap; gap: 8px 14px; margin-top: 10px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; color: #cfd6da; text-transform: uppercase; letter-spacing: 0.06em; }
  .checkrow label { display: inline-flex; align-items: center; gap: 6px; cursor: pointer; }
  .checkrow input { accent-color: #67e8f9; }
</style>
<main class="wrap">
  <a href="/aquintutor/labs" class="back">
    <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    Back to Labs
  </a>
  <div class="eyebrow">Lab &middot; Linear Algebra</div>
  <h1>Two-dimensional linear <em>transformations</em></h1>
  <p class="sub">Drag the four entries of a 2&times;2 matrix M and watch the plane warp in real time. Basis vectors &icirc; and &jcirc;, a sample shape, and the unit grid are pushed through Mv. Eigenvalues come from the characteristic polynomial &lambda;&sup2; &minus; tr(M)&lambda; + det(M) = 0; eigenvectors solve (M &minus; &lambda;I)v = 0. The animation slider linearly interpolates I &rarr; M.</p>

  <div class="grid">
    <div class="panel">
      <h3>Canvas &middot; the warped plane</h3>
      <canvas id="cv" width="900" height="640"></canvas>
      <div class="legend">
        <span><i style="background:#1e3a5f"></i> Original grid</span>
        <span><i style="background:#ff8a3d"></i> Transformed grid</span>
        <span><i style="background:#67e8f9"></i> &icirc; basis</span>
        <span><i style="background:#a78bfa"></i> &jcirc; basis</span>
        <span><i style="background:#f472b6"></i> Sample shape</span>
        <span><i style="background:#facc15"></i> Eigenvector spans</span>
      </div>
      <div class="t-anim">
        <label style="font-family:'Geist Mono',monospace;font-size:11px;color:#cfd6da;">t</label>
        <input type="range" id="t" min="0" max="1" step="0.001" value="1" />
        <span id="tval">1.000</span>
        <button class="btn" id="play">Play</button>
      </div>
      <div class="checkrow">
        <label><input type="checkbox" id="showGrid" checked /> Grid</label>
        <label><input type="checkbox" id="showShape" checked /> Sample shape</label>
        <label><input type="checkbox" id="showEig" checked /> Eigen-spans</label>
        <label><input type="checkbox" id="showDet" checked /> Det parallelogram</label>
      </div>
    </div>

    <div>
      <div class="panel">
        <h3>Matrix entries</h3>
        <div class="sliders">
          <div class="slider-row"><label>a <span id="aval">1.00</span></label><input type="range" id="a" min="-3" max="3" step="0.01" value="1" /></div>
          <div class="slider-row"><label>b <span id="bval">0.00</span></label><input type="range" id="b" min="-3" max="3" step="0.01" value="0" /></div>
          <div class="slider-row"><label>c <span id="cval">0.00</span></label><input type="range" id="c" min="-3" max="3" step="0.01" value="0" /></div>
          <div class="slider-row"><label>d <span id="dval">1.00</span></label><input type="range" id="d" min="-3" max="3" step="0.01" value="1" /></div>
        </div>
        <div class="row" style="margin-top:4px;">
          <button class="btn primary" id="reset">Reset to I</button>
        </div>
      </div>

      <div class="panel" style="margin-top:14px;">
        <h3>Presets</h3>
        <div class="presets">
          <button class="btn" data-preset="identity">Identity</button>
          <button class="btn" data-preset="rot90">Rotate 90&deg;</button>
          <button class="btn" data-preset="rot180">Rotate 180&deg;</button>
          <button class="btn" data-preset="rot-custom">Rotate 45&deg;</button>
          <button class="btn" data-preset="shearx">Shear X</button>
          <button class="btn" data-preset="sheary">Shear Y</button>
          <button class="btn" data-preset="reflectx">Reflect X-axis</button>
          <button class="btn" data-preset="reflecty">Reflect Y-axis</button>
          <button class="btn" data-preset="reflectyx">Reflect y=x</button>
          <button class="btn" data-preset="scale">Scale 2&times;</button>
          <button class="btn" data-preset="scalex">Scale X</button>
          <button class="btn" data-preset="scaley">Scale Y</button>
          <button class="btn" data-preset="rotate-t">Rotate &middot; animate</button>
          <button class="btn" data-preset="singular">Singular (det=0)</button>
          <button class="btn" data-preset="proj">Project &rarr; x-axis</button>
        </div>
      </div>

      <div class="panel" style="margin-top:14px;">
        <h3>Analytics</h3>
        <div class="matrix">
          M = <span class="br">[</span>
          <table><tr><td id="mA">1.00</td><td id="mB">0.00</td></tr><tr><td id="mC">0.00</td><td id="mD">1.00</td></tr></table>
          <span class="br">]</span>
        </div>
        <div class="kv"><strong>det(M)</strong><span id="kDet">1.0000</span> <span id="detPill" class="pill ok" style="margin-left:8px;">Invertible</span></div>
        <div class="kv"><strong>tr(M)</strong><span id="kTrace">2.0000</span></div>
        <div class="kv"><strong>&lambda;&#8321;, &lambda;&#8322;</strong><span id="kEig">1, 1</span></div>
        <div class="kv"><strong>v&#8321;, v&#8322;</strong><span id="kVec">(1,0), (0,1)</span></div>
        <div class="kv" style="margin-top:10px;"><strong>M&#8315;&sup1;</strong></div>
        <div class="matrix" id="invBlock">
          <span class="br">[</span>
          <table><tr><td id="iA">1.00</td><td id="iB">0.00</td></tr><tr><td id="iC">0.00</td><td id="iD">1.00</td></tr></table>
          <span class="br">]</span>
        </div>
        <div class="kv" style="margin-top:8px;color:#9aa0a6;">Area-scale &equiv; |det|. Sign flip &equiv; orientation reversed. Complex eigenvalues &equiv; pure rotation component.</div>
      </div>
    </div>
  </div>
</main>

<script is:inline>
(function () {
  var cv = document.getElementById('cv');
  var ctx = cv.getContext('2d');

  // ---------- Resize for DPR ----------
  function resize() {
    var rect = cv.getBoundingClientRect();
    var dpr = window.devicePixelRatio || 1;
    cv.width = Math.floor(rect.width * dpr);
    cv.height = Math.floor(rect.height * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }
  window.addEventListener('resize', function () { resize(); render(); });

  // ---------- State ----------
  var state = { a: 1, b: 0, c: 0, d: 1, t: 1, animRot: null, animStart: 0 };
  var opts = { grid: true, shape: true, eig: true, det: true };
  var playing = false;
  var playStart = 0;

  // ---------- Math helpers ----------
  function mul(M, v) { return [M[0]*v[0] + M[1]*v[1], M[2]*v[0] + M[3]*v[1]]; }
  function det(M) { return M[0]*M[3] - M[1]*M[2]; }
  function trace(M) { return M[0] + M[3]; }
  function inv(M) {
    var dt = det(M);
    if (Math.abs(dt) < 1e-9) return null;
    return [M[3]/dt, -M[1]/dt, -M[2]/dt, M[0]/dt];
  }
  // Lerp between I and M by t in [0,1]
  function lerpI(M, t) {
    return [1 + (M[0]-1)*t, M[1]*t, M[2]*t, 1 + (M[3]-1)*t];
  }
  // Eigenvalues + vectors of 2x2 (returns array of {real, imag, vx, vy})
  function eig(M) {
    var tr = trace(M), dt = det(M);
    var disc = tr*tr - 4*dt;
    var out = [];
    if (disc >= 0) {
      var s = Math.sqrt(disc);
      var l1 = (tr + s) / 2;
      var l2 = (tr - s) / 2;
      out.push(makeEig(M, l1));
      out.push(makeEig(M, l2));
    } else {
      var s2 = Math.sqrt(-disc);
      out.push({ real: tr/2, imag: s2/2, vx: null, vy: null });
      out.push({ real: tr/2, imag: -s2/2, vx: null, vy: null });
    }
    return out;
  }
  function makeEig(M, lam) {
    // Solve (M - lam I) v = 0
    var a = M[0] - lam, b = M[1], c = M[2], d = M[3] - lam;
    var vx, vy;
    // Try first row: a*vx + b*vy = 0 => vy = -a/b * vx (if b nonzero)
    if (Math.abs(b) > 1e-9) { vx = 1; vy = -a / b; }
    else if (Math.abs(a) > 1e-9) { vx = 0; vy = 1; }
    else if (Math.abs(d) > 1e-9) { vx = 1; vy = 0; }
    else if (Math.abs(c) > 1e-9) { vx = -d / c; vy = 1; }
    else { vx = 1; vy = 0; }
    var mag = Math.hypot(vx, vy);
    if (mag > 1e-9) { vx /= mag; vy /= mag; }
    return { real: lam, imag: 0, vx: vx, vy: vy };
  }

  // ---------- Coordinate system ----------
  // World units: 1 unit = `scale` pixels. Origin at canvas centre.
  function worldScale() {
    var rect = cv.getBoundingClientRect();
    return Math.min(rect.width, rect.height) / 12;  // ~6 units each side
  }
  function W2S(p) {
    var rect = cv.getBoundingClientRect();
    var s = worldScale();
    return [rect.width/2 + p[0]*s, rect.height/2 - p[1]*s];
  }

  // ---------- Drawing ----------
  function drawGrid(M, t) {
    var rect = cv.getBoundingClientRect();
    var range = 8;
    // Original (faint blue) — only at t=0; otherwise we just draw transformed
    if (opts.grid) {
      ctx.strokeStyle = 'rgba(30,58,95,0.55)';
      ctx.lineWidth = 1;
      for (var i = -range; i <= range; i++) {
        ctx.beginPath();
        var a = W2S([i, -range]), b = W2S([i, range]);
        ctx.moveTo(a[0], a[1]); ctx.lineTo(b[0], b[1]); ctx.stroke();
        ctx.beginPath();
        var c = W2S([-range, i]), d = W2S([range, i]);
        ctx.moveTo(c[0], c[1]); ctx.lineTo(d[0], d[1]); ctx.stroke();
      }
    }
    // Transformed grid (apply current interpolated matrix to gridline endpoints)
    var Mt = lerpI(M, t);
    ctx.strokeStyle = 'rgba(255,138,61,0.55)';
    ctx.lineWidth = 1;
    for (var i2 = -range; i2 <= range; i2++) {
      // vertical line x = i2 -> two endpoints (i2,-range),(i2,range)
      var p1 = mul(Mt, [i2, -range]);
      var p2 = mul(Mt, [i2, range]);
      var s1 = W2S(p1), s2 = W2S(p2);
      ctx.beginPath(); ctx.moveTo(s1[0], s1[1]); ctx.lineTo(s2[0], s2[1]); ctx.stroke();
      var q1 = mul(Mt, [-range, i2]);
      var q2 = mul(Mt, [range, i2]);
      var t1 = W2S(q1), t2 = W2S(q2);
      ctx.beginPath(); ctx.moveTo(t1[0], t1[1]); ctx.lineTo(t2[0], t2[1]); ctx.stroke();
    }
    // Axes — solid heavier through origin (in original frame)
    ctx.strokeStyle = '#3a3a45';
    ctx.lineWidth = 1.2;
    var ax1 = W2S([-range, 0]), ax2 = W2S([range, 0]);
    var ay1 = W2S([0, -range]), ay2 = W2S([0, range]);
    ctx.beginPath(); ctx.moveTo(ax1[0], ax1[1]); ctx.lineTo(ax2[0], ax2[1]); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(ay1[0], ay1[1]); ctx.lineTo(ay2[0], ay2[1]); ctx.stroke();
  }
  function drawArrow(from, to, color, label) {
    var f = W2S(from), t = W2S(to);
    ctx.strokeStyle = color;
    ctx.fillStyle = color;
    ctx.lineWidth = 2.4;
    ctx.beginPath();
    ctx.moveTo(f[0], f[1]); ctx.lineTo(t[0], t[1]); ctx.stroke();
    // arrowhead
    var ang = Math.atan2(t[1]-f[1], t[0]-f[0]);
    var ah = 9;
    ctx.beginPath();
    ctx.moveTo(t[0], t[1]);
    ctx.lineTo(t[0] - ah*Math.cos(ang - Math.PI/7), t[1] - ah*Math.sin(ang - Math.PI/7));
    ctx.lineTo(t[0] - ah*Math.cos(ang + Math.PI/7), t[1] - ah*Math.sin(ang + Math.PI/7));
    ctx.closePath(); ctx.fill();
    if (label) {
      ctx.font = "600 12px 'Geist Mono', monospace";
      ctx.fillStyle = color;
      ctx.fillText(label, t[0] + 8, t[1] - 6);
    }
  }
  // Sample shape: a tiny house, points in world coords
  var HOUSE = [
    [0.2, 0.2], [0.8, 0.2], [0.8, 0.8], [0.5, 1.1], [0.2, 0.8], [0.2, 0.2]
  ];
  function drawShape(M, t, color) {
    var Mt = lerpI(M, t);
    ctx.strokeStyle = color;
    ctx.lineWidth = 2;
    ctx.fillStyle = color.replace('hsl', 'hsla').replace(')', ',0.10)');
    if (color.indexOf('#') === 0) ctx.fillStyle = color + '22';
    ctx.beginPath();
    for (var i = 0; i < HOUSE.length; i++) {
      var p = mul(Mt, HOUSE[i]);
      var s = W2S(p);
      if (i === 0) ctx.moveTo(s[0], s[1]); else ctx.lineTo(s[0], s[1]);
    }
    ctx.closePath();
    ctx.fill();
    ctx.stroke();
  }
  function drawDetParallelogram(M, t) {
    var Mt = lerpI(M, t);
    var i = mul(Mt, [1, 0]);
    var j = mul(Mt, [0, 1]);
    var o = [0, 0];
    var ij = [i[0]+j[0], i[1]+j[1]];
    var pts = [o, i, ij, j];
    ctx.beginPath();
    for (var k = 0; k < pts.length; k++) {
      var s = W2S(pts[k]);
      if (k === 0) ctx.moveTo(s[0], s[1]); else ctx.lineTo(s[0], s[1]);
    }
    ctx.closePath();
    var dt = det(Mt);
    ctx.fillStyle = dt >= 0 ? 'rgba(103,232,249,0.10)' : 'rgba(244,114,182,0.14)';
    ctx.strokeStyle = dt >= 0 ? 'rgba(103,232,249,0.55)' : 'rgba(244,114,182,0.65)';
    ctx.lineWidth = 1.5;
    ctx.fill();
    ctx.stroke();
  }
  function drawEigSpan(vx, vy, color) {
    // extend the line through origin in direction (vx, vy)
    var s = 100;
    var f = W2S([-vx*s, -vy*s]);
    var t = W2S([vx*s, vy*s]);
    ctx.save();
    ctx.setLineDash([6, 5]);
    ctx.strokeStyle = color;
    ctx.lineWidth = 1.5;
    ctx.beginPath(); ctx.moveTo(f[0], f[1]); ctx.lineTo(t[0], t[1]); ctx.stroke();
    ctx.restore();
  }

  // ---------- Render ----------
  function render() {
    var rect = cv.getBoundingClientRect();
    ctx.clearRect(0, 0, rect.width, rect.height);
    var M = [state.a, state.b, state.c, state.d];
    var t = state.t;

    drawGrid(M, t);

    if (opts.det) drawDetParallelogram(M, t);

    if (opts.eig) {
      var es = eig(M);
      var colors = ['#facc15', '#fb923c'];
      for (var i = 0; i < es.length; i++) {
        var e = es[i];
        if (e.vx !== null) drawEigSpan(e.vx, e.vy, colors[i] + 'cc');
      }
    }

    if (opts.shape) {
      // original house (faint)
      ctx.save();
      ctx.globalAlpha = 0.25;
      ctx.strokeStyle = '#f472b6';
      ctx.lineWidth = 1.2;
      ctx.beginPath();
      for (var hi = 0; hi < HOUSE.length; hi++) {
        var hs = W2S(HOUSE[hi]);
        if (hi === 0) ctx.moveTo(hs[0], hs[1]); else ctx.lineTo(hs[0], hs[1]);
      }
      ctx.closePath(); ctx.stroke();
      ctx.restore();
      drawShape(M, t, '#f472b6');
    }

    // basis vectors
    var Mt = lerpI(M, t);
    drawArrow([0,0], mul(Mt, [1,0]), '#67e8f9', 'î');
    drawArrow([0,0], mul(Mt, [0,1]), '#a78bfa', 'ĵ');

    updatePanel(M);
  }

  function fmt(x) {
    if (!isFinite(x)) return '∞';
    return (Math.abs(x) < 1e-9 ? 0 : x).toFixed(2);
  }
  function fmt4(x) {
    if (!isFinite(x)) return '∞';
    return (Math.abs(x) < 1e-9 ? 0 : x).toFixed(4);
  }
  function updatePanel(M) {
    document.getElementById('mA').textContent = fmt(M[0]);
    document.getElementById('mB').textContent = fmt(M[1]);
    document.getElementById('mC').textContent = fmt(M[2]);
    document.getElementById('mD').textContent = fmt(M[3]);
    var dt = det(M), tr = trace(M);
    document.getElementById('kDet').textContent = fmt4(dt);
    document.getElementById('kTrace').textContent = fmt4(tr);
    var pill = document.getElementById('detPill');
    if (Math.abs(dt) < 1e-6) { pill.textContent = 'Singular'; pill.className = 'pill warn'; }
    else { pill.textContent = dt > 0 ? 'Invertible' : 'Orientation flipped'; pill.className = 'pill ok'; }

    var es = eig(M);
    var es0 = es[0], es1 = es[1];
    var eigStr;
    if (es0.imag === 0 && es1.imag === 0) {
      eigStr = fmt4(es0.real) + ',  ' + fmt4(es1.real);
    } else {
      eigStr = fmt(es0.real) + (es0.imag >= 0 ? ' + ' : ' − ') + fmt(Math.abs(es0.imag)) + 'i,  ' +
               fmt(es1.real) + (es1.imag >= 0 ? ' + ' : ' − ') + fmt(Math.abs(es1.imag)) + 'i';
    }
    document.getElementById('kEig').textContent = eigStr;

    var vecStr;
    if (es0.vx !== null && es1.vx !== null) {
      vecStr = '(' + fmt(es0.vx) + ',' + fmt(es0.vy) + '),  (' + fmt(es1.vx) + ',' + fmt(es1.vy) + ')';
    } else {
      vecStr = 'complex — no real eigenvectors';
    }
    document.getElementById('kVec').textContent = vecStr;

    var Minv = inv(M);
    var invBlock = document.getElementById('invBlock');
    if (Minv) {
      invBlock.style.opacity = '1';
      document.getElementById('iA').textContent = fmt(Minv[0]);
      document.getElementById('iB').textContent = fmt(Minv[1]);
      document.getElementById('iC').textContent = fmt(Minv[2]);
      document.getElementById('iD').textContent = fmt(Minv[3]);
    } else {
      invBlock.style.opacity = '0.35';
      document.getElementById('iA').textContent = '—';
      document.getElementById('iB').textContent = '—';
      document.getElementById('iC').textContent = '—';
      document.getElementById('iD').textContent = '—';
    }
  }

  // ---------- Inputs ----------
  function bindSlider(id, prop) {
    var el = document.getElementById(id);
    var lab = document.getElementById(id + 'val');
    el.addEventListener('input', function () {
      state[prop] = parseFloat(el.value);
      lab.textContent = state[prop].toFixed(2);
      render();
    });
  }
  bindSlider('a', 'a');
  bindSlider('b', 'b');
  bindSlider('c', 'c');
  bindSlider('d', 'd');
  function syncSliders() {
    var ids = ['a','b','c','d'];
    for (var i = 0; i < ids.length; i++) {
      var id = ids[i];
      document.getElementById(id).value = state[id];
      document.getElementById(id+'val').textContent = state[id].toFixed(2);
    }
  }

  document.getElementById('t').addEventListener('input', function (e) {
    state.t = parseFloat(e.target.value);
    document.getElementById('tval').textContent = state.t.toFixed(3);
    render();
  });

  document.getElementById('reset').addEventListener('click', function () {
    state.a = 1; state.b = 0; state.c = 0; state.d = 1;
    syncSliders(); render();
  });

  ['showGrid','showShape','showEig','showDet'].forEach(function (id) {
    document.getElementById(id).addEventListener('change', function (e) {
      var key = id.replace('show','').toLowerCase();
      opts[key] = e.target.checked;
      render();
    });
  });

  // ---------- Presets ----------
  var PRESETS = {
    'identity':   [1,0,0,1],
    'rot90':      [0,-1,1,0],
    'rot180':     [-1,0,0,-1],
    'rot-custom': [Math.cos(Math.PI/4),-Math.sin(Math.PI/4),Math.sin(Math.PI/4),Math.cos(Math.PI/4)],
    'shearx':     [1,1,0,1],
    'sheary':     [1,0,1,1],
    'reflectx':   [1,0,0,-1],
    'reflecty':   [-1,0,0,1],
    'reflectyx':  [0,1,1,0],
    'scale':      [2,0,0,2],
    'scalex':     [2,0,0,1],
    'scaley':     [1,0,0,2],
    'singular':   [1,2,2,4],
    'proj':       [1,0,0,0]
  };
  document.querySelectorAll('[data-preset]').forEach(function (b) {
    b.addEventListener('click', function () {
      var key = b.getAttribute('data-preset');
      if (key === 'rotate-t') { startRotateAnim(); return; }
      state.animRot = null;
      var M = PRESETS[key];
      state.a = M[0]; state.b = M[1]; state.c = M[2]; state.d = M[3];
      state.t = 0;
      document.getElementById('t').value = 0;
      document.getElementById('tval').textContent = '0.000';
      syncSliders();
      playing = true; playStart = performance.now();
      requestAnimationFrame(tick);
    });
  });

  function startRotateAnim() {
    state.animRot = performance.now();
    requestAnimationFrame(tick);
  }

  // ---------- Animation loop ----------
  document.getElementById('play').addEventListener('click', function () {
    state.animRot = null;
    state.t = 0;
    document.getElementById('t').value = 0;
    playing = true; playStart = performance.now();
    requestAnimationFrame(tick);
  });

  function tick(now) {
    if (state.animRot !== null) {
      var dt = (now - state.animRot) / 1000;
      var theta = dt * 0.8;
      state.a = Math.cos(theta); state.b = -Math.sin(theta);
      state.c = Math.sin(theta); state.d = Math.cos(theta);
      state.t = 1;
      document.getElementById('t').value = 1;
      document.getElementById('tval').textContent = '1.000';
      syncSliders();
      render();
      requestAnimationFrame(tick);
      return;
    }
    if (!playing) return;
    var elapsed = (now - playStart) / 1500;
    state.t = Math.min(1, elapsed);
    document.getElementById('t').value = state.t;
    document.getElementById('tval').textContent = state.t.toFixed(3);
    render();
    if (state.t < 1) requestAnimationFrame(tick);
    else playing = false;
  }

  // ---------- Boot ----------
  resize();
  render();
})();
</script>
</BaseLayout>
