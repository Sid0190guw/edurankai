---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Matrix-decompositions lab (graduate level). A live 2x2 map A warps the plane,
// but the focus is the geometry of the decompositions that first-year courses
// only state: the SINGULAR VALUE DECOMPOSITION (unit circle -> ellipse whose
// semi-axes are the singular values along the left singular vectors), the
// EIGENDECOMPOSITION (real invariant directions, or a rotation-scaling for a
// complex pair), the POLAR decomposition A = QP (rotation x symmetric stretch),
// the condition number kappa = s1/s2, and the rank / null space. Closed-form
// 2x2 SVD, no libraries.
---
<BaseLayout title="Matrix Decompositions · Virtual Labs · AquinTutor" description="Graduate linear algebra: the SVD as unit-circle-to-ellipse with singular values and singular vectors, eigendecomposition (real and complex), polar decomposition, condition number and rank — computed live from a 2x2 matrix. Built from scratch.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1340px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:16px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:310px minmax(0,1fr); gap:18px; } @media(max-width:960px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:15px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 11px; }
  .mat{ display:grid; grid-template-columns:1fr 1fr; gap:9px; }
  .mat .cell label{ font-family:'Geist Mono',monospace; font-size:9.5px; color:#8ea0be; display:flex; justify-content:space-between; }
  .mat .cell label span{ color:#5ee7ff; } .mat input[type=range]{ width:100%; accent-color:#5ee7ff; }
  .lb-btn{ background:linear-gradient(180deg,#7af0ff,#33cfe6); color:#04161b; padding:9px 14px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:10.5px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; }
  .lb-btn-ghost{ background:transparent; color:#cfd6da; border:1px solid #26314f; }
  .preset{ background:#080a12; border:1px solid #1e2740; color:#cfd6da; padding:6px 9px; border-radius:6px; font-family:'Geist Mono',monospace; font-size:10.5px; cursor:pointer; }
  .lb-seg{ display:flex; gap:4px; flex-wrap:wrap; } .lb-seg button{ flex:1; background:#0b1020; border:1px solid #26314f; color:#8ea0be; border-radius:7px; padding:6px 4px; font-family:'Geist Mono',monospace; font-size:10px; cursor:pointer; }
  .lb-seg button.on{ background:rgba(94,231,255,0.14); color:#5ee7ff; border-color:#3a6b86; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); }
  .lb-stage canvas{ display:block; width:100%; height:auto; }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11px; padding:4px 0; border-bottom:1px solid #141a2c; }
  .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#5ee7ff; font-weight:700; text-align:right; }
  .lb-eq{ font-family:'Geist Mono',monospace; font-size:10.5px; color:#a9b6cf; background:#0b1020; border:1px solid #1a2238; border-radius:8px; padding:9px 11px; line-height:1.8; }
  .lb-eq b{ color:#5ee7ff; } .lb-note{ font-size:11px; color:#7e8aa3; line-height:1.6; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">Mathematics · Matrix decompositions</p>
      <h1 class="lb-title">SVD, eigen &amp; <em>polar</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;"><button id="animBtn" class="lb-btn">Animate</button><button id="idBtn" class="lb-btn lb-btn-ghost">Identity</button></div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Matrix A</h3><div class="mat">
        <div class="cell"><label>a₁₁ <span id="aV">1.00</span></label><input id="a" type="range" min="-3" max="3" step="0.02" value="1"/></div>
        <div class="cell"><label>a₁₂ <span id="bV">0.50</span></label><input id="b" type="range" min="-3" max="3" step="0.02" value="0.5"/></div>
        <div class="cell"><label>a₂₁ <span id="cV">0.00</span></label><input id="c" type="range" min="-3" max="3" step="0.02" value="0"/></div>
        <div class="cell"><label>a₂₂ <span id="dV">1.50</span></label><input id="d" type="range" min="-3" max="3" step="0.02" value="1.5"/></div>
      </div>
      <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:11px;">
        <button class="preset" data-m="0,-1,1,0">Rotate</button><button class="preset" data-m="-1,0,0,1">Reflect</button><button class="preset" data-m="1,1,0,1">Shear</button>
        <button class="preset" data-m="2,0,0,0.5">Scale</button><button class="preset" data-m="1,1,1,1">Rank-1</button><button class="preset" data-m="1,0.9,0.9,1">Ill-cond.</button>
      </div></div>
      <div class="lb-panel"><h3>View</h3>
        <div class="lb-seg" id="viewSeg"><button data-v="svd" class="on">SVD</button><button data-v="eigen">Eigen</button><button data-v="polar">Polar</button></div>
        <p class="lb-note" id="viewNote" style="margin-top:9px;">Unit circle → ellipse. Semi-axes are the singular values σ₁,σ₂ along the left singular vectors u₁,u₂.</p>
      </div>
      <div class="lb-panel"><h3>Invariants</h3>
        <div class="lb-metric"><span class="lb-metric-l">det A</span><span class="lb-metric-v" id="mDet">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">trace</span><span class="lb-metric-v" id="mTr">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">rank</span><span class="lb-metric-v" id="mRank">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">λ₁, λ₂</span><span class="lb-metric-v" id="mEig">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">σ₁, σ₂</span><span class="lb-metric-v" id="mSig">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">κ = σ₁/σ₂</span><span class="lb-metric-v" id="mCond">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">‖A‖<sub>F</sub></span><span class="lb-metric-v" id="mFro">—</span></div>
      </div>
    </aside>
    <section>
      <div class="lb-stage"><canvas id="scene" width="960" height="640"></canvas></div>
      <div class="lb-panel" style="margin-top:12px;"><h3>Decomposition <span id="decLbl" style="color:#a78bfa;"></span></h3>
        <div class="lb-eq" id="decEq">—</div>
        <p class="lb-note" id="decNote" style="margin-top:8px;"></p>
      </div>
    </section>
  </div>
</main>
<script is:inline>
(function(){
  function v(id){ return parseFloat(document.getElementById(id).value); }
  function setTxt(id,t){ var e=document.getElementById(id); if(e) e.textContent=t; }
  var t=1, animating=false, view='svd';
  function sync(){ ['a','b','c','d'].forEach(function(id){ setTxt(id+'V',v(id).toFixed(2)); }); }
  document.querySelectorAll('.mat input').forEach(function(e){ e.addEventListener('input',sync); }); sync();
  document.getElementById('idBtn').addEventListener('click',function(){ ['a','d'].forEach(function(id){ document.getElementById(id).value=1; }); ['b','c'].forEach(function(id){ document.getElementById(id).value=0; }); sync(); t=0; animating=true; });
  document.querySelectorAll('.preset').forEach(function(b){ b.addEventListener('click',function(){ var m=b.getAttribute('data-m').split(','); ['a','b','c','d'].forEach(function(id,i){ document.getElementById(id).value=m[i]; }); sync(); t=0; animating=true; }); });
  document.getElementById('animBtn').addEventListener('click',function(){ t=0; animating=true; });
  var NOTES={ svd:'Unit circle → ellipse. Semi-axes are the singular values σ₁,σ₂ along the left singular vectors u₁,u₂; the right singular vectors v₁,v₂ (domain) are the pre-images.', eigen:'Eigenvectors are directions the map only stretches (Av=λv). A complex pair means no real invariant line — the map rotates.', polar:'A = Q·P: first a symmetric positive stretch P (its axes are the right singular vectors), then a pure rotation Q by angle θ_Q.' };
  document.querySelectorAll('#viewSeg button').forEach(function(b){ b.addEventListener('click',function(){ document.querySelectorAll('#viewSeg button').forEach(function(x){x.classList.remove('on');}); b.classList.add('on'); view=b.getAttribute('data-v'); setTxt('viewNote',NOTES[view]); }); });

  // ---- closed-form 2x2 SVD (E,F,G,H method). A = U(theta) Σ V(phi)^T ----
  function svd2(a,b,c,d){
    var E=(a+d)/2, F=(a-d)/2, G=(c+b)/2, Hh=(c-b)/2;
    var Q=Math.hypot(E,Hh), R=Math.hypot(F,G);
    var s1=Q+R, s2=Math.abs(Q-R);
    var a1=Math.atan2(G,F), a2=Math.atan2(Hh,E);
    var theta=(a2+a1)/2, phi=(a2-a1)/2;
    return { s1:s1, s2:s2, theta:theta, phi:phi };
  }
  function eig2(a,b,c,d){
    var tr=a+d, det=a*d-b*c, disc=tr*tr-4*det;
    if(disc>=0){ var r=Math.sqrt(disc); var l1=(tr+r)/2, l2=(tr-r)/2;
      function evec(l){ var vx,vy; if(Math.abs(b)>1e-9){ vx=b; vy=l-a; } else if(Math.abs(c)>1e-9){ vx=l-d; vy=c; } else { vx=(Math.abs(a-l)<1e-9)?1:0; vy=(Math.abs(d-l)<1e-9)?1:0; } var n=Math.hypot(vx,vy)||1; return [vx/n,vy/n]; }
      return { real:true, l1:l1, l2:l2, v1:evec(l1), v2:evec(l2) };
    }
    return { real:false, re:tr/2, im:Math.sqrt(-disc)/2 };
  }

  function hidpi(c){ var r=c.getBoundingClientRect(), dp=window.devicePixelRatio||1; var w=r.width||c.width, h=(c.height/c.width)*w; c.width=Math.round(w*dp); c.height=Math.round(h*dp); var ctx=c.getContext('2d'); ctx.setTransform(dp,0,0,dp,0,0); return {ctx:ctx,w:w,h:h}; }
  function draw(){
    var cv=document.getElementById('scene'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h;
    var bg=ctx.createLinearGradient(0,0,0,H); bg.addColorStop(0,'#0b1020'); bg.addColorStop(1,'#06080f'); ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    var cx=W/2, cy=H/2, sc=Math.min(W,H)/9.5;
    var a=v('a'),b=v('b'),c=v('c'),d=v('d');
    var A=(1-t)+t*a, B=t*b, C=t*c, D=(1-t)+t*d;
    function M(x,y){ return [A*x+B*y, C*x+D*y]; }
    function P(x,y){ return [cx+x*sc, cy-y*sc]; }
    // faint identity grid
    ctx.strokeStyle='rgba(90,110,150,0.09)'; ctx.lineWidth=1;
    for(var i=-4;i<=4;i++){ var p1=P(i,-4),p2=P(i,4),p3=P(-4,i),p4=P(4,i); ctx.beginPath(); ctx.moveTo(p1[0],p1[1]); ctx.lineTo(p2[0],p2[1]); ctx.moveTo(p3[0],p3[1]); ctx.lineTo(p4[0],p4[1]); ctx.stroke(); }
    // transformed grid
    ctx.save(); ctx.shadowColor='#5ee7ff'; ctx.shadowBlur=4; ctx.strokeStyle='rgba(94,231,255,0.28)'; ctx.lineWidth=1;
    for(var i=-4;i<=4;i++){ ctx.beginPath(); for(var j=-4;j<=4;j++){ var m=M(i,j),p=P(m[0],m[1]); j===-4?ctx.moveTo(p[0],p[1]):ctx.lineTo(p[0],p[1]); } ctx.stroke(); ctx.beginPath(); for(var j=-4;j<=4;j++){ var m=M(j,i),p=P(m[0],m[1]); j===-4?ctx.moveTo(p[0],p[1]):ctx.lineTo(p[0],p[1]); } ctx.stroke(); } ctx.restore();
    // axes
    ctx.strokeStyle='#38507a'; ctx.lineWidth=1.4; ctx.beginPath(); ctx.moveTo(0,cy); ctx.lineTo(W,cy); ctx.moveTo(cx,0); ctx.lineTo(cx,H); ctx.stroke();
    function vec(fx,fy,tx,ty,col,wd){ ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=9; ctx.strokeStyle=col; ctx.fillStyle=col; ctx.lineWidth=wd||3; var f=P(fx,fy),tp=P(tx,ty); ctx.beginPath(); ctx.moveTo(f[0],f[1]); ctx.lineTo(tp[0],tp[1]); ctx.stroke(); var ang=Math.atan2(tp[1]-f[1],tp[0]-f[0]); ctx.beginPath(); ctx.moveTo(tp[0],tp[1]); ctx.lineTo(tp[0]-10*Math.cos(ang-0.4),tp[1]-10*Math.sin(ang-0.4)); ctx.lineTo(tp[0]-10*Math.cos(ang+0.4),tp[1]-10*Math.sin(ang+0.4)); ctx.closePath(); ctx.fill(); ctx.restore(); }

    var sv=svd2(a,b,c,d), eg=eig2(a,b,c,d);
    // unit circle (domain, faint)
    ctx.strokeStyle='rgba(120,150,200,0.30)'; ctx.setLineDash([4,4]); ctx.lineWidth=1.2; ctx.beginPath(); for(var k=0;k<=64;k++){ var th=k/64*2*Math.PI, p=P(Math.cos(th),Math.sin(th)); k?ctx.lineTo(p[0],p[1]):ctx.moveTo(p[0],p[1]); } ctx.stroke(); ctx.setLineDash([]);
    // image ellipse (unit circle -> A·circle), glow
    ctx.save(); ctx.shadowColor='#fbbf24'; ctx.shadowBlur=8; ctx.strokeStyle='#fbbf24'; ctx.lineWidth=2; ctx.beginPath(); for(var k=0;k<=96;k++){ var th=k/96*2*Math.PI, m=M(Math.cos(th),Math.sin(th)), p=P(m[0],m[1]); k?ctx.lineTo(p[0],p[1]):ctx.moveTo(p[0],p[1]); } ctx.stroke(); ctx.restore();

    if(view==='svd'){
      // right singular vectors v1,v2 (domain, dashed) and left u1,u2·σ (image)
      var v1=[Math.cos(sv.phi),Math.sin(sv.phi)], v2=[-Math.sin(sv.phi),Math.cos(sv.phi)];
      var u1=[Math.cos(sv.theta),Math.sin(sv.theta)], u2=[-Math.sin(sv.theta),Math.cos(sv.theta)];
      ctx.save(); ctx.setLineDash([5,4]); vec(0,0,v1[0],v1[1],'rgba(167,139,250,0.9)',2); vec(0,0,v2[0],v2[1],'rgba(167,139,250,0.6)',2); ctx.restore();
      vec(0,0,u1[0]*sv.s1,u1[1]*sv.s1,'#34d399',3); vec(0,0,u2[0]*sv.s2,u2[1]*sv.s2,'#f472b6',3);
    } else if(view==='eigen'){
      if(eg.real){ [[eg.v1,'#34d399',eg.l1],[eg.v2,'#f472b6',eg.l2]].forEach(function(e){ var vv=e[0]; var e1=P(vv[0]*4,vv[1]*4),e2=P(-vv[0]*4,-vv[1]*4); ctx.strokeStyle=e[1]; ctx.setLineDash([7,5]); ctx.lineWidth=1.6; ctx.beginPath(); ctx.moveTo(e2[0],e2[1]); ctx.lineTo(e1[0],e1[1]); ctx.stroke(); ctx.setLineDash([]); vec(0,0,vv[0]*e[2],vv[1]*e[2],e[1],3); }); }
      else { ctx.fillStyle='#a78bfa'; ctx.font="12px 'Geist Mono',monospace"; ctx.fillText('complex eigenpair — no real invariant line (rotation-scaling)', 20, 28); }
    } else { // polar: draw stretch axes (V) then rotation
      var v1=[Math.cos(sv.phi),Math.sin(sv.phi)], v2=[-Math.sin(sv.phi),Math.cos(sv.phi)];
      vec(0,0,v1[0]*sv.s1,v1[1]*sv.s1,'#34d399',3); vec(0,0,v2[0]*sv.s2,v2[1]*sv.s2,'#f472b6',3);
      var qAng=sv.theta-sv.phi; ctx.strokeStyle='rgba(251,191,36,0.7)'; ctx.lineWidth=2; ctx.beginPath(); ctx.arc(cx,cy,sc*1.2,-0, -qAng, qAng>0); ctx.stroke();
    }
    // basis image
    vec(0,0,M(1,0)[0],M(1,0)[1],'rgba(94,231,255,0.55)',2); vec(0,0,M(0,1)[0],M(0,1)[1],'rgba(94,231,255,0.4)',2);

    // metrics
    var det=a*d-b*c, tr=a+d, fro=Math.hypot(a,b,c,d);
    setTxt('mDet',det.toFixed(2)); setTxt('mTr',tr.toFixed(2)); setTxt('mFro',fro.toFixed(2));
    setTxt('mRank', sv.s2>1e-4 ? '2 (full)' : (sv.s1>1e-4?'1 (singular)':'0'));
    setTxt('mEig', eg.real ? (eg.l1.toFixed(2)+', '+eg.l2.toFixed(2)) : (eg.re.toFixed(2)+' ± '+eg.im.toFixed(2)+'i'));
    setTxt('mSig', sv.s1.toFixed(2)+', '+sv.s2.toFixed(2));
    setTxt('mCond', sv.s2>1e-6 ? (sv.s1/sv.s2).toFixed(2) : '∞ (singular)');
    // decomposition card
    var deg=function(r){ return (r*180/Math.PI).toFixed(1)+'°'; };
    if(view==='svd'){ setTxt('decLbl','· A = U Σ Vᵀ'); document.getElementById('decEq').innerHTML='<b>U</b> = R('+deg(sv.theta)+') &nbsp; <b>Σ</b> = diag('+sv.s1.toFixed(3)+', '+sv.s2.toFixed(3)+') &nbsp; <b>Vᵀ</b> = R(-'+deg(sv.phi)+')<br/>κ = σ₁/σ₂ = '+(sv.s2>1e-6?(sv.s1/sv.s2).toFixed(2):'∞'); setTxt('decNote','A rotation Vᵀ, a scaling by the singular values, then a rotation U. Every real matrix has this form.'); }
    else if(view==='eigen'){ setTxt('decLbl','· A = P Λ P⁻¹'); if(eg.real){ document.getElementById('decEq').innerHTML='<b>λ₁</b>='+eg.l1.toFixed(3)+' → v₁=('+eg.v1[0].toFixed(2)+', '+eg.v1[1].toFixed(2)+')<br/><b>λ₂</b>='+eg.l2.toFixed(3)+' → v₂=('+eg.v2[0].toFixed(2)+', '+eg.v2[1].toFixed(2)+')'; setTxt('decNote','Two real eigen-directions: the map only stretches along them. Diagonalisable when they are independent.'); } else { document.getElementById('decEq').innerHTML='<b>λ</b> = '+eg.re.toFixed(3)+' ± '+eg.im.toFixed(3)+'i &nbsp; (|λ| = '+Math.hypot(eg.re,eg.im).toFixed(3)+', arg = '+deg(Math.atan2(eg.im,eg.re))+')'; setTxt('decNote','Complex conjugate pair: the map spirals. Modulus |λ| is the per-step scaling, argument is the rotation angle.'); } }
    else { setTxt('decLbl','· A = Q P'); document.getElementById('decEq').innerHTML='<b>Q</b> = R('+deg(sv.theta-sv.phi)+') (rotation) &nbsp; <b>P</b> = V·diag('+sv.s1.toFixed(2)+','+sv.s2.toFixed(2)+')·Vᵀ (SPD stretch)'; setTxt('decNote','Polar form: a symmetric positive-definite stretch P followed by a rigid rotation Q. P = √(AᵀA).'); }

    requestAnimationFrame(draw);
  }
  function tick(){ if(animating){ t+=0.025; if(t>=1){ t=1; animating=false; } } requestAnimationFrame(tick); }
  requestAnimationFrame(draw); requestAnimationFrame(tick);
})();
</script>
</BaseLayout>
