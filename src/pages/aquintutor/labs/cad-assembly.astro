---
import BaseLayout from '@/layouts/BaseLayout.astro';
// CAD Assembly (Phase 3 of the CAD-grade programme). Place multiple part
// instances in one scene, position/orient each, and run a real INTERFERENCE
// CHECK: broad-phase AABB overlap + narrow-phase Monte-Carlo volume estimate
// (points sampled in the overlap region, tested inside both solids by ray
// parity). Exploded view, assembly mass roll-up + centre of mass, STL export.
// Hand-rolled WebGL + geometry, no libraries. Works offline.
---
<BaseLayout title="CAD Assembly · Virtual Labs · AquinTutor" description="Multi-part CAD assembly with real interference detection (AABB + Monte-Carlo clash volume), exploded view, assembly mass roll-up and centre of mass, STL export. Hand-rolled WebGL, no libraries.">

<style is:global>
  body { background:#08080a; color:#e8e8ee; margin:0; }
  .era-fab { display:none !important; }
  .ca-wrap { display:grid; grid-template-rows:52px 1fr; height:100vh; height:100dvh; }
  .ca-bar { background:#11131a; border-bottom:1px solid #2a2a35; display:flex; align-items:center; padding:0 14px; gap:10px; font-family:'Geist Mono',monospace; font-size:11px; color:#cfd6da; flex-wrap:wrap; }
  .ca-bar a { color:#FF9066; text-decoration:none; }
  .ca-title { font-family:'Cormorant Garamond',Georgia,serif; font-size:17px; color:#fff; font-weight:600; }
  .ca-title em { color:#FF7040; font-style:italic; }
  .ca-bar-right { margin-left:auto; display:flex; gap:6px; align-items:center; flex-wrap:wrap; }
  .ca-btn { background:transparent; border:1px solid #2a2a35; color:#cfd6da; padding:6px 11px; border-radius:6px; cursor:pointer; font-family:inherit; font-size:10.5px; letter-spacing:0.04em; text-transform:uppercase; font-weight:700; }
  .ca-btn:hover { background:#1a1a25; }
  .ca-btn.on { background:#FF4F00; color:#fff; border-color:#FF4F00; }
  .ca-sel { background:#11131a; color:#e8e8ee; border:1px solid #2a2a35; border-radius:6px; padding:6px 8px; font-family:inherit; font-size:10.5px; }
  .ca-main { display:grid; grid-template-columns:250px 1fr 260px; overflow:hidden; }
  @media (max-width:900px){ .ca-main { grid-template-columns:1fr; grid-template-rows:auto 1fr auto; } .ca-left,.ca-right { max-height:30vh; overflow-y:auto; } }
  .ca-left, .ca-right { background:#0c0e14; overflow-y:auto; padding:12px; }
  .ca-left { border-right:1px solid #2a2a35; } .ca-right { border-left:1px solid #2a2a35; }
  .ca-cat { font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.18em; text-transform:uppercase; color:#FF9066; font-weight:700; margin:6px 0 8px; }
  .ca-inst { display:flex; align-items:center; gap:8px; padding:8px 10px; border:1px solid #2a2a35; border-radius:8px; margin-bottom:5px; cursor:pointer; font-size:11.5px; color:#cfd6da; }
  .ca-inst.on { border-color:#FF4F00; background:#151018; color:#fff; }
  .ca-inst.clash { border-color:#e5484d; }
  .ca-swatch { width:12px; height:12px; border-radius:3px; flex-shrink:0; }
  .ca-inst .del { margin-left:auto; color:#788; background:none; border:0; cursor:pointer; font-size:13px; }
  .ca-param { margin:7px 0 2px; }
  .ca-param label { display:flex; justify-content:space-between; font-family:'Geist Mono',monospace; font-size:10px; color:#9aa; margin-bottom:2px; }
  .ca-param label b { color:#d9f9e8; }
  .ca-param input[type=range] { width:100%; accent-color:#FF4F00; }
  .ca-view { position:relative; overflow:hidden; background:#0b0d13; }
  #caCanvas { position:absolute; inset:0; width:100%; height:100%; display:block; touch-action:none; cursor:grab; }
  .ca-hint { position:absolute; left:12px; bottom:10px; font-family:'Geist Mono',monospace; font-size:10px; color:#89a; pointer-events:none; text-shadow:0 1px 2px #000; }
  .ca-explode { position:absolute; right:12px; top:12px; background:rgba(10,10,14,0.8); border:1px solid #2a2a35; border-radius:8px; padding:8px 12px; font-family:'Geist Mono',monospace; font-size:10px; color:#9aa; }
  .ca-explode input { width:120px; accent-color:#FF4F00; display:block; margin-top:5px; }
  .ca-right h3 { font-family:'Cormorant Garamond',Georgia,serif; font-size:15px; color:#fff; margin:0 0 8px; font-weight:600; }
  .ca-kv { display:flex; justify-content:space-between; font-family:'Geist Mono',monospace; font-size:11px; color:#cfd6da; padding:3px 0; border-bottom:1px dashed rgba(120,130,150,0.12); }
  .ca-kv b { color:#d9f9e8; }
  .ca-right select { width:100%; background:#11131a; color:#e8e8ee; border:1px solid #2a2a35; border-radius:6px; padding:6px; font-size:11px; margin-bottom:8px; }
  .ca-clashbox { margin-top:12px; border-top:1px solid #2a2a35; padding-top:10px; }
  .ca-clash-row { font-family:'Geist Mono',monospace; font-size:10.5px; padding:6px 8px; border-radius:7px; margin-bottom:5px; }
  .ca-clash-row.hit { background:rgba(229,72,77,0.12); color:#f2a5a8; border:1px solid rgba(229,72,77,0.4); }
  .ca-clash-row.ok { background:rgba(70,167,88,0.1); color:#8fd3a3; border:1px solid rgba(70,167,88,0.35); }
  .ca-note { font-size:10px; color:#788; line-height:1.7; border-top:1px solid #2a2a35; margin-top:10px; padding-top:8px; }
</style>

<div class="ca-wrap">
  <div class="ca-bar">
    <a href="/aquintutor/labs">&larr; LABS</a>
    <span class="ca-title">CAD <em>Assembly</em></span>
    <span style="opacity:0.5;">INTERFERENCE CHECK · PHASE 3</span>
    <div class="ca-bar-right">
      <select id="caAdd" class="ca-sel">
        <option value="">Add part…</option>
        <option value="plate">Plate</option>
        <option value="pin">Pin / shaft</option>
        <option value="bracket">L-bracket</option>
        <option value="washer">Washer / ring</option>
        <option value="housing">Housing block</option>
      </select>
      <button type="button" class="ca-btn" id="caCheck">Interference check</button>
      <button type="button" class="ca-btn" id="caStl">STL</button>
      <button type="button" class="ca-btn" id="caFit">Fit</button>
    </div>
  </div>
  <div class="ca-main">
    <div class="ca-left">
      <div class="ca-cat">Assembly tree</div>
      <div id="caTree"></div>
      <div class="ca-cat" style="margin-top:12px;">Selected part</div>
      <div id="caParams" style="font-size:11px;color:#788;">Add a part, then select it to position it.</div>
    </div>
    <div class="ca-view">
      <canvas id="caCanvas"></canvas>
      <div class="ca-explode">EXPLODE<input type="range" id="caExplode" min="0" max="200" value="0" /></div>
      <div class="ca-hint">drag: rotate · wheel/pinch: zoom · shift-drag: pan</div>
    </div>
    <div class="ca-right">
      <h3>Assembly mass</h3>
      <select id="caMat">
        <option value="2810">Aluminium 7075 (2810)</option>
        <option value="2700">Aluminium 6061 (2700)</option>
        <option value="4430">Titanium (4430)</option>
        <option value="7850">Steel 4130 (7850)</option>
        <option value="1600">Carbon composite (1600)</option>
      </select>
      <div class="ca-kv"><span>Parts</span><b id="mParts">0</b></div>
      <div class="ca-kv"><span>Total volume</span><b id="mVol">—</b></div>
      <div class="ca-kv"><span>Total mass</span><b id="mMass">—</b></div>
      <div class="ca-kv"><span>Centre of mass</span><b id="mCg">—</b></div>
      <div class="ca-kv"><span>Triangles</span><b id="mTris">—</b></div>
      <div class="ca-clashbox">
        <h3>Interference</h3>
        <div id="caClash" style="font-size:11px;color:#788;">Run a check to detect clashing parts.</div>
      </div>
      <div class="ca-note">Interference = AABB broad-phase, then a Monte-Carlo estimate: points sampled in the overlap box, tested inside both solids by ray-parity. Clash volume is an estimate (denser sampling = tighter). Mass by the divergence theorem over each transformed part.</div>
    </div>
  </div>
</div>

<script is:inline>
(function(){
'use strict';
// ---------- math ----------
function vSub(a,b){return[a[0]-b[0],a[1]-b[1],a[2]-b[2]];}
function vAdd(a,b){return[a[0]+b[0],a[1]+b[1],a[2]+b[2]];}
function vCross(a,b){return[a[1]*b[2]-a[2]*b[1],a[2]*b[0]-a[0]*b[2],a[0]*b[1]-a[1]*b[0]];}
function vDot(a,b){return a[0]*b[0]+a[1]*b[1]+a[2]*b[2];}
function vLen(a){return Math.sqrt(vDot(a,a));}
function vNorm(a){var l=vLen(a)||1;return[a[0]/l,a[1]/l,a[2]/l];}
function mPersp(f,asp,n,fa){var t=1/Math.tan(f/2);return[t/asp,0,0,0,0,t,0,0,0,0,(fa+n)/(n-fa),-1,0,0,2*fa*n/(n-fa),0];}
function mLook(e,c,u){var z=vNorm(vSub(e,c)),x=vNorm(vCross(u,z)),y=vCross(z,x);return[x[0],y[0],z[0],0,x[1],y[1],z[1],0,x[2],y[2],z[2],0,-vDot(x,e),-vDot(y,e),-vDot(z,e),1];}
function mMul(a,b){var o=new Array(16);for(var r=0;r<4;r++)for(var c=0;c<4;c++){var s=0;for(var k=0;k<4;k++)s+=a[k*4+c]*b[r*4+k];o[r*4+c]=s;}return o;}
function rot(p,rx,ry,rz){var c,s,x=p[0],y=p[1],z=p[2],t;c=Math.cos(rx);s=Math.sin(rx);t=y;y=t*c-z*s;z=t*s+z*c;c=Math.cos(ry);s=Math.sin(ry);t=x;x=t*c+z*s;z=-t*s+z*c;c=Math.cos(rz);s=Math.sin(rz);t=x;x=t*c-y*s;y=t*s+y*c;return[x,y,z];}

// ---------- earclip (concave-safe caps) ----------
function earClip(loop){var idx=loop.map(function(_,i){return i;}),tris=[],g=0;
  function cnv(a,b,c){return(loop[b][0]-loop[a][0])*(loop[c][1]-loop[a][1])-(loop[b][1]-loop[a][1])*(loop[c][0]-loop[a][0])>0;}
  function inT(p,a,b,c){function sg(p1,p2,p3){return(p1[0]-p3[0])*(p2[1]-p3[1])-(p2[0]-p3[0])*(p1[1]-p3[1]);}var d1=sg(p,loop[a],loop[b]),d2=sg(p,loop[b],loop[c]),d3=sg(p,loop[c],loop[a]);return!(((d1<0)||(d2<0)||(d3<0))&&((d1>0)||(d2>0)||(d3>0)));}
  while(idx.length>3&&g++<900){var clip=false;for(var i=0;i<idx.length;i++){var a=idx[(i+idx.length-1)%idx.length],b=idx[i],c=idx[(i+1)%idx.length];if(!cnv(a,b,c))continue;var ear=true;for(var k=0;k<idx.length;k++){var m=idx[k];if(m===a||m===b||m===c)continue;if(inT(loop[m],a,b,c)){ear=false;break;}}if(ear){tris.push([a,b,c]);idx.splice(i,1);clip=true;break;}}if(!clip)break;}
  if(idx.length===3)tris.push([idx[0],idx[1],idx[2]]);return tris;}
// extrude a 2D loop (in XZ plane) by height along Y -> closed tri soup
function extrude(loop,h){var tris=[],n=loop.length;
  for(var i=0;i<n;i++){var a=loop[i],b=loop[(i+1)%n];var A0=[a[0],0,a[1]],B0=[b[0],0,b[1]],A1=[a[0],h,a[1]],B1=[b[0],h,b[1]];tris.push([A0,B0,B1],[A0,B1,A1]);}
  var caps=earClip(loop);caps.forEach(function(t){tris.push([[loop[t[0]][0],h,loop[t[0]][1]],[loop[t[1]][0],h,loop[t[1]][1]],[loop[t[2]][0],h,loop[t[2]][1]]]);tris.push([[loop[t[2]][0],0,loop[t[2]][1]],[loop[t[1]][0],0,loop[t[1]][1]],[loop[t[0]][0],0,loop[t[0]][1]]]);});
  return tris;}
// ---------- parts (closed manifolds, mm; local origin centred where sensible) ----------
function pBox(w,h,d){var x=w/2,z=d/2;return extrude([[-x,-z],[x,-z],[x,z],[-x,z]],h).map(function(t){return t.map(function(p){return[p[0],p[1]-h/2,p[2]];});});}
function pCyl(r,h,seg){seg=seg||24;var o=[],top=[],bot=[];for(var i=0;i<seg;i++){var a1=i/seg*2*Math.PI,a2=(i+1)/seg*2*Math.PI;var p1=[r*Math.cos(a1),0,r*Math.sin(a1)],p2=[r*Math.cos(a2),0,r*Math.sin(a2)];o.push([[p1[0],-h/2,p1[2]],[p2[0],-h/2,p2[2]],[p2[0],h/2,p2[2]]]);o.push([[p1[0],-h/2,p1[2]],[p2[0],h/2,p2[2]],[p1[0],h/2,p1[2]]]);top.push([r*Math.cos(a1),h/2,r*Math.sin(a1)]);bot.push([r*Math.cos(-a1),-h/2,r*Math.sin(-a1)]);}
  for(var i=1;i<seg-1;i++){o.push([top[0],top[i],top[i+1]]);o.push([bot[0],bot[i],bot[i+1]]);}return o;}
function pTube(ro,ri,h,seg){seg=seg||24;var o=[];function ring(y,r){var p=[];for(var i=0;i<seg;i++){var a=i/seg*2*Math.PI;p.push([r*Math.cos(a),y,r*Math.sin(a)]);}return p;}
  var oT=ring(h/2,ro),oB=ring(-h/2,ro),iT=ring(h/2,ri),iB=ring(-h/2,ri);
  for(var i=0;i<seg;i++){var j=(i+1)%seg;o.push([oB[i],oB[j],oT[j]],[oB[i],oT[j],oT[i]]);o.push([iB[j],iB[i],iT[i]],[iB[j],iT[i],iT[j]]);o.push([oT[i],oT[j],iT[j]],[oT[i],iT[j],iT[i]]);o.push([oB[j],oB[i],iB[i]],[oB[j],iB[i],iB[j]]);}return o;}
function pLBracket(){var a=60,b=60,t=12;var loop=[[0,0],[a,0],[a,t],[t,t],[t,b],[0,b]];return extrude(loop.map(function(p){return[p[0]-t/2,p[1]-t/2];}),40);}
var PARTS={
  plate:function(){return pBox(120,10,80);},
  pin:function(){return pCyl(8,60,24);},
  bracket:function(){return pLBracket();},
  washer:function(){return pTube(18,9,6,28);},
  housing:function(){return pBox(70,50,70);},
};
var PART_LABEL={plate:'Plate',pin:'Pin',bracket:'L-bracket',washer:'Washer',housing:'Housing'};
var COLORS=['#FF7040','#67e8f9','#a78bfa','#34d399','#fbbf24','#f472b6','#60a5fa'];

// ---------- instances ----------
var IID=1, insts=[], selected=null;
function addPart(type){var mesh=PARTS[type]();insts.push({id:IID++,type:type,name:PART_LABEL[type]+' '+IID,mesh:mesh,pos:[insts.length*30-40,0,0],rot:[0,0,0],color:COLORS[insts.length%COLORS.length],clash:false});selected=insts[insts.length-1].id;rebuild();drawTree();drawParams();}
document.getElementById('caAdd').addEventListener('change',function(){if(this.value){addPart(this.value);this.value='';}});

function instTris(inst){var ex=explodeVec(inst);return inst.mesh.map(function(t){return t.map(function(p){return vAdd(vAdd(rot(p,inst.rot[0],inst.rot[1],inst.rot[2]),inst.pos),ex);});});}
function explodeVec(inst){if(!EXPLODE)return[0,0,0];var c=inst.pos;var d=vLen(c)||1;return[c[0]/d*EXPLODE,c[1]/d*EXPLODE+ (c[0]===0&&c[2]===0?EXPLODE:0),c[2]/d*EXPLODE];}
var EXPLODE=0;
document.getElementById('caExplode').addEventListener('input',function(){EXPLODE=Number(this.value);rebuild();});

// ---------- mass ----------
function triVol(t){return vDot(t[0],vCross(t[1],t[2]))/6;}
function massProps(){var vol=0,cg=[0,0,0],ntri=0;insts.forEach(function(inst){inst.mesh.forEach(function(tl){var t=tl.map(function(p){return vAdd(rot(p,inst.rot[0],inst.rot[1],inst.rot[2]),inst.pos);});var v=triVol(t);vol+=v;cg=vAdd(cg,[(t[0][0]+t[1][0]+t[2][0])/4*v,(t[0][1]+t[1][1]+t[2][1])/4*v,(t[0][2]+t[1][2]+t[2][2])/4*v]);ntri++;});});
  vol=Math.abs(vol);var c=vol?[cg[0]/(triVolSum()||1),0,0]:[0,0,0];
  // recompute cg properly
  var cg2=[0,0,0],vs=0;insts.forEach(function(inst){inst.mesh.forEach(function(tl){var t=tl.map(function(p){return vAdd(rot(p,inst.rot[0],inst.rot[1],inst.rot[2]),inst.pos);});var v=triVol(t);vs+=v;cg2=vAdd(cg2,[(t[0][0]+t[1][0]+t[2][0])/4*v,(t[0][1]+t[1][1]+t[2][1])/4*v,(t[0][2]+t[1][2]+t[2][2])/4*v]);});});
  var cgf=vs?[cg2[0]/vs,cg2[1]/vs,cg2[2]/vs]:[0,0,0];
  var dens=Number(document.getElementById('caMat').value);var mass=vol*1e-9*dens;
  document.getElementById('mParts').textContent=insts.length;
  document.getElementById('mVol').textContent=(vol/1000).toFixed(1)+' cm³';
  document.getElementById('mMass').textContent=mass>=1?mass.toFixed(2)+' kg':(mass*1000).toFixed(0)+' g';
  document.getElementById('mCg').textContent=cgf.map(function(x){return x.toFixed(0);}).join(', ');
  var nt=0;insts.forEach(function(i){nt+=i.mesh.length;});document.getElementById('mTris').textContent=nt;
}
function triVolSum(){var s=0;insts.forEach(function(inst){inst.mesh.forEach(function(tl){var t=tl.map(function(p){return vAdd(rot(p,inst.rot[0],inst.rot[1],inst.rot[2]),inst.pos);});s+=triVol(t);});});return s;}
document.getElementById('caMat').addEventListener('change',massProps);

// ---------- interference: AABB + monte-carlo ----------
function aabb(tris){var mn=[1e9,1e9,1e9],mx=[-1e9,-1e9,-1e9];tris.forEach(function(t){t.forEach(function(p){for(var k=0;k<3;k++){mn[k]=Math.min(mn[k],p[k]);mx[k]=Math.max(mx[k],p[k]);}});});return{mn:mn,mx:mx};}
function overlap(a,b){for(var k=0;k<3;k++){if(a.mx[k]<b.mn[k]||b.mx[k]<a.mn[k])return null;}return{mn:[Math.max(a.mn[0],b.mn[0]),Math.max(a.mn[1],b.mn[1]),Math.max(a.mn[2],b.mn[2])],mx:[Math.min(a.mx[0],b.mx[0]),Math.min(a.mx[1],b.mx[1]),Math.min(a.mx[2],b.mx[2])]};}
function inside(pt,tris){var cnt=0;var ox=pt[0],oy=pt[1],oz=pt[2];for(var i=0;i<tris.length;i++){var t=tris[i];var a=t[0],b=t[1],c=t[2];
  // ray +X: does triangle cross the ray at y=oy,z=oz with x>ox ? solve in yz plane barycentric
  var d00=b[1]-a[1],d01=b[2]-a[2],d10=c[1]-a[1],d11=c[2]-a[2],d20=oy-a[1],d21=oz-a[2];var den=d00*d11-d10*d01;if(Math.abs(den)<1e-9)continue;var w1=(d20*d11-d10*d21)/den,w2=(d00*d21-d20*d01)/den,w0=1-w1-w2;if(w0<0||w1<0||w2<0)continue;var xh=a[0]*w0+b[0]*w1+c[0]*w2;if(xh>ox)cnt++;}
  return(cnt&1)===1;}
function checkInterference(){var tset=insts.map(instTris),boxes=tset.map(aabb);var rows=[],anyPairs=false;
  insts.forEach(function(i){i.clash=false;});
  for(var i=0;i<insts.length;i++)for(var j=i+1;j<insts.length;j++){anyPairs=true;var ov=overlap(boxes[i],boxes[j]);if(!ov){rows.push({a:insts[i].name,b:insts[j].name,hit:false});continue;}
    var N=2600,hit=0;var sx=ov.mx[0]-ov.mn[0],sy=ov.mx[1]-ov.mn[1],sz=ov.mx[2]-ov.mn[2];
    for(var s=0;s<N;s++){var p=[ov.mn[0]+Math.random()*sx,ov.mn[1]+Math.random()*sy,ov.mn[2]+Math.random()*sz];if(inside(p,tset[i])&&inside(p,tset[j]))hit++;}
    var vol=(sx*sy*sz)*(hit/N)/1000; // cm3
    if(hit>0){insts[i].clash=true;insts[j].clash=true;}
    rows.push({a:insts[i].name,b:insts[j].name,hit:hit>0,vol:vol});}
  var host=document.getElementById('caClash');
  if(!anyPairs){host.innerHTML='<span style="color:#788;">Add at least two parts.</span>';return;}
  var clashes=rows.filter(function(r){return r.hit;});
  host.innerHTML=(clashes.length?('<div style="color:#f2a5a8;font-weight:700;margin-bottom:6px;">'+clashes.length+' interference'+(clashes.length>1?'s':'')+' found</div>'):'<div style="color:#8fd3a3;font-weight:700;margin-bottom:6px;">No interference — clearance OK</div>')+
    rows.map(function(r){return'<div class="ca-clash-row '+(r.hit?'hit':'ok')+'">'+r.a+' ↔ '+r.b+(r.hit?(' · ~'+r.vol.toFixed(2)+' cm³'):' · clear')+'</div>';}).join('');
  drawTree();rebuild();
}
document.getElementById('caCheck').addEventListener('click',checkInterference);

// ---------- WebGL ----------
var cv=document.getElementById('caCanvas');var gl=cv.getContext('webgl',{antialias:true,depth:true});
var W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);
function compile(s,k){var sh=gl.createShader(k);gl.shaderSource(sh,s);gl.compileShader(sh);return sh;}
var prog=gl.createProgram();
gl.attachShader(prog,compile('attribute vec3 aP;attribute vec3 aN;uniform mat4 uMVP;varying vec3 vN;varying vec3 vP;void main(){vN=aN;vP=aP;gl_Position=uMVP*vec4(aP,1.0);}',gl.VERTEX_SHADER));
gl.attachShader(prog,compile('precision mediump float;varying vec3 vN;varying vec3 vP;uniform vec3 uEye;uniform vec3 uCol;void main(){vec3 n=normalize(vN);vec3 sun=normalize(vec3(0.5,0.8,0.4));vec3 hd=normalize(uEye-vP);float l=0.3+0.5*max(0.0,dot(n,sun))+0.25*max(0.0,dot(n,hd));gl_FragColor=vec4(uCol*l,1.0);}',gl.FRAGMENT_SHADER));
gl.linkProgram(prog);gl.useProgram(prog);
var aP=gl.getAttribLocation(prog,'aP'),aN=gl.getAttribLocation(prog,'aN'),uMVP=gl.getUniformLocation(prog,'uMVP'),uEye=gl.getUniformLocation(prog,'uEye'),uCol=gl.getUniformLocation(prog,'uCol');
gl.enable(gl.DEPTH_TEST);
var buffers=[];
function hex(c){return[parseInt(c.slice(1,3),16)/255,parseInt(c.slice(3,5),16)/255,parseInt(c.slice(5,7),16)/255];}
function rebuild(){buffers.forEach(function(b){gl.deleteBuffer(b.buf);});buffers=[];
  insts.forEach(function(inst){var tris=instTris(inst);var arr=new Float32Array(tris.length*18),o=0;tris.forEach(function(t){var n=vNorm(vCross(vSub(t[1],t[0]),vSub(t[2],t[0])));t.forEach(function(p){arr[o++]=p[0];arr[o++]=p[1];arr[o++]=p[2];arr[o++]=n[0];arr[o++]=n[1];arr[o++]=n[2];});});
    var bf=gl.createBuffer();gl.bindBuffer(gl.ARRAY_BUFFER,bf);gl.bufferData(gl.ARRAY_BUFFER,arr,gl.STATIC_DRAW);buffers.push({buf:bf,n:tris.length*3,col:inst.clash?[0.9,0.28,0.3]:hex(inst.color),id:inst.id});});
  massProps();render();}
var yaw=0.7,pitch=0.5,dist=420,target=[0,0,0];
function eye(){var cp=Math.cos(pitch);return vAdd(target,[dist*cp*Math.sin(yaw),dist*Math.sin(pitch),dist*cp*Math.cos(yaw)]);}
function render(){if(!W)return;gl.viewport(0,0,cv.width,cv.height);gl.clearColor(0.043,0.051,0.075,1);gl.clear(gl.COLOR_BUFFER_BIT|gl.DEPTH_BUFFER_BIT);
  var e=eye();var mvp=mMul(mPersp(0.9,W/H,1,8000),mLook(e,target,[0,1,0]));gl.uniformMatrix4fv(uMVP,false,new Float32Array(mvp));gl.uniform3fv(uEye,new Float32Array(e));
  buffers.forEach(function(b){gl.bindBuffer(gl.ARRAY_BUFFER,b.buf);gl.enableVertexAttribArray(aP);gl.vertexAttribPointer(aP,3,gl.FLOAT,false,24,0);gl.enableVertexAttribArray(aN);gl.vertexAttribPointer(aN,3,gl.FLOAT,false,24,12);
    var c=b.col;if(selected===b.id){c=[Math.min(1,c[0]*1.3+0.1),Math.min(1,c[1]*1.3+0.1),Math.min(1,c[2]*1.3+0.1)];}gl.uniform3fv(uCol,new Float32Array(c));gl.drawArrays(gl.TRIANGLES,0,b.n);});}
function resize(){W=cv.clientWidth;H=cv.clientHeight;cv.width=W*DPR;cv.height=H*DPR;render();}
window.addEventListener('resize',resize);
function fit(){var all=[];insts.forEach(function(i){instTris(i).forEach(function(t){t.forEach(function(p){all.push(p);});});});if(!all.length){target=[0,0,0];dist=420;render();return;}var mn=[1e9,1e9,1e9],mx=[-1e9,-1e9,-1e9];all.forEach(function(p){for(var k=0;k<3;k++){mn[k]=Math.min(mn[k],p[k]);mx[k]=Math.max(mx[k],p[k]);}});target=[(mn[0]+mx[0])/2,(mn[1]+mx[1])/2,(mn[2]+mx[2])/2];dist=Math.max(mx[0]-mn[0],mx[1]-mn[1],mx[2]-mn[2])*2.2+80;render();}
document.getElementById('caFit').addEventListener('click',fit);
var drag=null;
cv.addEventListener('pointerdown',function(e){drag={x:e.clientX,y:e.clientY,pan:e.shiftKey};cv.setPointerCapture(e.pointerId);cv.style.cursor='grabbing';});
cv.addEventListener('pointermove',function(e){if(!drag)return;var dx=e.clientX-drag.x,dy=e.clientY-drag.y;drag.x=e.clientX;drag.y=e.clientY;if(drag.pan){var r=[Math.cos(yaw),0,-Math.sin(yaw)];target=vAdd(target,[r[0]*-dx*dist*0.0016,dy*dist*0.0016,r[2]*-dx*dist*0.0016]);}else{yaw-=dx*0.008;pitch=Math.max(-1.5,Math.min(1.5,pitch+dy*0.008));}render();});
cv.addEventListener('pointerup',function(){drag=null;cv.style.cursor='grab';});
cv.addEventListener('wheel',function(e){e.preventDefault();dist*=1+Math.sign(e.deltaY)*0.09;dist=Math.max(40,Math.min(6000,dist));render();},{passive:false});
var pinch=null;cv.addEventListener('touchstart',function(e){if(e.touches.length===2)pinch=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);},{passive:true});
cv.addEventListener('touchmove',function(e){if(pinch&&e.touches.length===2){var d=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);dist*=pinch/d;dist=Math.max(40,Math.min(6000,dist));pinch=d;render();}},{passive:true});
cv.addEventListener('touchend',function(){pinch=null;},{passive:true});

// ---------- tree + params ----------
function drawTree(){var host=document.getElementById('caTree');host.innerHTML='';if(!insts.length){host.innerHTML='<span style="font-size:11px;color:#788;">Empty. Add a part above.</span>';return;}
  insts.forEach(function(inst){var d=document.createElement('div');d.className='ca-inst'+(selected===inst.id?' on':'')+(inst.clash?' clash':'');
    d.innerHTML='<span class="ca-swatch" style="background:'+inst.color+'"></span><span>'+inst.name+'</span><button type="button" class="del">×</button>';
    d.addEventListener('click',function(e){if(e.target.classList.contains('del')){insts=insts.filter(function(x){return x.id!==inst.id;});if(selected===inst.id)selected=null;rebuild();drawTree();drawParams();return;}selected=inst.id;drawTree();drawParams();render();});
    host.appendChild(d);});}
function drawParams(){var host=document.getElementById('caParams');var inst=insts.find(function(x){return x.id===selected;});if(!inst){host.innerHTML='Add a part, then select it to position it.';return;}host.innerHTML='';
  [['pos',0,'Pos X',-200,200,1],['pos',1,'Pos Y',-200,200,1],['pos',2,'Pos Z',-200,200,1],['rot',0,'Rot X',-180,180,5],['rot',1,'Rot Y',-180,180,5],['rot',2,'Rot Z',-180,180,5]].forEach(function(d){
    var isRot=d[0]==='rot';var val=isRot?Math.round(inst.rot[d[1]]*180/Math.PI):inst.pos[d[1]];
    var w=document.createElement('div');w.className='ca-param';w.innerHTML='<label>'+d[2]+' <b data-v>'+val+'</b></label>';
    var r=document.createElement('input');r.type='range';r.min=d[3];r.max=d[4];r.step=d[5];r.value=val;
    r.addEventListener('input',function(){w.querySelector('[data-v]').textContent=r.value;if(isRot)inst.rot[d[1]]=Number(r.value)*Math.PI/180;else inst.pos[d[1]]=Number(r.value);inst.clash=false;rebuild();});
    w.appendChild(r);host.appendChild(w);});}

// ---------- STL of the whole assembly ----------
document.getElementById('caStl').addEventListener('click',function(){var out=['solid edurankai_assembly'];insts.forEach(function(inst){instTris(inst).forEach(function(t){var n=vNorm(vCross(vSub(t[1],t[0]),vSub(t[2],t[0])));out.push(' facet normal '+n.map(function(x){return x.toFixed(6);}).join(' '));out.push('  outer loop');t.forEach(function(p){out.push('   vertex '+p.map(function(x){return x.toFixed(4);}).join(' '));});out.push('  endloop',' endfacet');});});out.push('endsolid edurankai_assembly');
  var a=document.createElement('a');a.href=URL.createObjectURL(new Blob([out.join('\n')],{type:'model/stl'}));a.download='assembly.stl';document.body.appendChild(a);a.click();setTimeout(function(){URL.revokeObjectURL(a.href);a.remove();},400);});

// seed a small demo assembly (plate + pin + washer)
addPart('plate');addPart('pin');insts[1].pos=[0,25,0];insts[1].rot=[0,0,0];addPart('washer');insts[2].pos=[0,14,0];
rebuild();drawTree();drawParams();resize();fit();
})();
</script>

</BaseLayout>
