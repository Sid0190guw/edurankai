---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Signals & Systems · Virtual Labs · AquinTutor" description="Seven computing experiments — signal generation, even/odd decomposition, time transformations, animated convolution, Fourier-series reconstruction with Gibbs ringing, sampling and aliasing, and LTI response. Hand-rolled math on Canvas2D, no libraries.">
<style>
  .ss { background:#0a0a0c; color:#e8e8ee; min-height:100vh; font-family:'Geist Mono',ui-monospace,monospace; }
  .ss .wrap { max-width:1240px; margin:0 auto; padding:34px 22px 90px; }
  .ss .back { display:inline-flex; align-items:center; gap:7px; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:#9aa0aa; text-decoration:none; margin-bottom:24px; }
  .ss .back:hover { color:#67e8f9; }
  .ss .eyebrow { font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin-bottom:12px; }
  .ss h1 { font-family:'Cormorant Garamond',serif; font-size:42px; font-weight:600; letter-spacing:-0.02em; line-height:1.08; margin:0 0 12px; color:#f3f3f8; }
  .ss h1 em { color:#a78bfa; font-style:italic; }
  .ss .lede { color:#9aa0aa; max-width:840px; font-size:13.5px; line-height:1.66; margin-bottom:26px; }

  .ss .shell { display:grid; grid-template-columns:252px minmax(0,1fr); gap:20px; align-items:start; }
  @media (max-width:920px) { .ss .shell { grid-template-columns:1fr; } }

  .ss .sidebar { background:#11131a; border:1px solid #2a2a35; border-radius:12px; padding:12px; position:sticky; top:16px; }
  .ss .sidebar .stitle { font-size:9px; letter-spacing:0.18em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin:4px 6px 10px; }
  .ss .exp-item { display:flex; gap:9px; align-items:flex-start; padding:9px 10px; border-radius:8px; cursor:pointer; border:1px solid transparent; transition:all .14s; margin-bottom:3px; }
  .ss .exp-item:hover { background:#161922; }
  .ss .exp-item.on { background:#161922; border-color:#a78bfa; }
  .ss .exp-item .num { font-size:10px; color:#a78bfa; font-weight:700; min-width:14px; }
  .ss .exp-item .nm { font-size:11px; color:#cfd6da; line-height:1.4; }
  .ss .exp-item.on .nm { color:#f3f3f8; }

  .ss .main { min-width:0; }
  .ss .exp-head { font-family:'Cormorant Garamond',serif; font-size:28px; font-weight:600; color:#f3f3f8; margin:0 0 4px; }
  .ss .exp-sub { font-size:11px; color:#9aa0aa; letter-spacing:0.04em; margin-bottom:16px; }

  .ss .secbar { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:18px; border-bottom:1px solid #2a2a35; padding-bottom:12px; }
  .ss .secbar .stab { background:#11131a; border:1px solid #2a2a35; color:#9aa0aa; padding:7px 12px; border-radius:8px; font-size:10px; letter-spacing:0.08em; text-transform:uppercase; font-weight:700; cursor:pointer; transition:all .14s; }
  .ss .secbar .stab:hover { border-color:#3a3a48; color:#e8e8ee; }
  .ss .secbar .stab.on { background:#161922; border-color:#67e8f9; color:#67e8f9; }

  .ss .exp { display:none; }
  .ss .exp.on { display:block; }
  .ss .sec { display:none; }
  .ss .sec.on { display:block; }

  .ss .prose { font-size:13px; color:#c4c8d0; line-height:1.72; max-width:850px; }
  .ss .prose b { color:#f3f3f8; }
  .ss .prose p { margin:0 0 12px; }
  .ss .eq { color:#fbbf24; background:#0a0a0c; border:1px solid #1c1c26; padding:2px 6px; border-radius:4px; font-size:12px; }
  .ss .eqblock { background:#0a0a0c; border:1px solid #232330; border-radius:9px; padding:13px 15px; margin:13px 0; font-size:12.5px; color:#fbbf24; line-height:2; }
  .ss ol.steps { font-size:13px; color:#c4c8d0; line-height:1.7; max-width:830px; padding-left:20px; }
  .ss ol.steps li { margin-bottom:9px; }
  .ss ol.steps li b { color:#f3f3f8; }
  .ss ul.refs { list-style:none; padding:0; max-width:850px; }
  .ss ul.refs li { font-size:12px; color:#9aa0aa; line-height:1.6; padding:8px 0; border-bottom:1px solid #1a1a24; }
  .ss ul.refs li b { color:#cfd6da; }

  .ss .layout { display:grid; grid-template-columns:minmax(0,1fr) 320px; gap:18px; align-items:start; }
  @media (max-width:1000px) { .ss .layout { grid-template-columns:1fr; } }
  .ss .panel { background:#11131a; border:1px solid #2a2a35; border-radius:12px; padding:16px; }
  .ss .panel h3 { font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin:0 0 13px; }
  .ss canvas { display:block; width:100%; background:#08080b; border:1px solid #232330; border-radius:10px; }
  .ss .row { display:flex; gap:9px; align-items:center; margin-bottom:11px; flex-wrap:wrap; }
  .ss .row > label { font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:#9aa0aa; min-width:78px; }
  .ss input[type=range] { -webkit-appearance:none; appearance:none; background:#0a0a0c; border:1px solid #2a2a35; height:6px; border-radius:4px; flex:1; min-width:90px; }
  .ss input[type=range]::-webkit-slider-thumb { -webkit-appearance:none; appearance:none; width:14px; height:14px; border-radius:50%; background:#a78bfa; cursor:pointer; border:none; }
  .ss input[type=range]::-moz-range-thumb { width:14px; height:14px; border-radius:50%; background:#a78bfa; cursor:pointer; border:none; }
  .ss input[type=number] { background:#0a0a0c; border:1px solid #2a2a35; color:#e8e8ee; padding:7px 9px; border-radius:6px; font-family:inherit; font-size:12px; width:78px; }
  .ss select { background:#0a0a0c; border:1px solid #2a2a35; color:#e8e8ee; padding:7px 9px; border-radius:6px; font-family:inherit; font-size:11.5px; flex:1; min-width:120px; }
  .ss .val { font-size:11.5px; color:#a78bfa; min-width:62px; text-align:right; }
  .ss .btn { background:#a78bfa; color:#16091f; padding:9px 13px; border:none; border-radius:7px; font-family:inherit; font-size:10.5px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; cursor:pointer; }
  .ss .btn:hover { background:#bda3ff; }
  .ss .btn:disabled { opacity:0.4; cursor:not-allowed; }
  .ss .btn.ghost { background:transparent; color:#cfd6da; border:1px solid #2a2a35; }
  .ss .btn.ghost:hover { border-color:#a78bfa; color:#a78bfa; }
  .ss .btn.cyan { background:#67e8f9; color:#04161b; }
  .ss .btn.cyan:hover { background:#8af0ff; }
  .ss .btn.amber { background:#fbbf24; color:#1c1402; }
  .ss .btn.amber:hover { background:#fcd34d; }
  .ss .btns { display:flex; gap:8px; margin-top:6px; flex-wrap:wrap; }
  .ss .btns .btn { flex:1; }
  .ss .stats { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:13px; }
  .ss .stat { background:#0a0a0c; border:1px solid #232330; border-radius:7px; padding:8px 10px; }
  .ss .stat .k { font-size:9px; letter-spacing:0.12em; text-transform:uppercase; color:#9aa0aa; }
  .ss .stat .v { font-size:15px; color:#67e8f9; font-weight:700; margin-top:3px; word-break:break-word; }
  .ss .stat .v.sm { font-size:12px; }
  .ss .help { font-size:10.5px; color:#9aa0aa; line-height:1.66; margin-top:11px; }
  .ss .help b { color:#e8e8ee; }
  .ss .legend { display:flex; gap:14px; flex-wrap:wrap; font-size:10px; color:#9aa0aa; margin-top:10px; }
  .ss .legend span { display:inline-flex; align-items:center; gap:6px; }
  .ss .legend i { width:14px; height:3px; border-radius:2px; display:inline-block; }

  .ss .quiz { max-width:850px; }
  .ss .q { background:#11131a; border:1px solid #2a2a35; border-radius:10px; padding:14px 16px; margin-bottom:13px; }
  .ss .q .qt { font-size:13px; color:#f3f3f8; line-height:1.55; margin-bottom:11px; }
  .ss .q .qt b { color:#a78bfa; }
  .ss .opt-a { display:block; padding:9px 12px; border:1px solid #2a2a35; border-radius:7px; margin-bottom:7px; font-size:12.5px; color:#cfd6da; cursor:pointer; transition:all .12s; }
  .ss .opt-a:hover { border-color:#3a3a48; }
  .ss .opt-a.sel { border-color:#67e8f9; color:#67e8f9; }
  .ss .opt-a.correct { border-color:#86efac; background:rgba(134,239,172,0.08); color:#86efac; }
  .ss .opt-a.wrong { border-color:#fca5a5; background:rgba(252,165,165,0.08); color:#fca5a5; }
  .ss .q .expl { font-size:11.5px; color:#9aa0aa; line-height:1.6; margin-top:8px; padding-top:8px; border-top:1px solid #1c1c26; display:none; }
  .ss .q .expl.show { display:block; }
  .ss .q .expl b { color:#86efac; }
  .ss .q.bad .expl b { color:#fca5a5; }
  .ss .quizfoot { display:flex; gap:12px; align-items:center; margin-top:6px; }
  .ss .quizfoot .score { font-size:12px; color:#fbbf24; }
</style>

<main class="ss">
  <div class="wrap">
    <a class="back" href="/aquintutor/labs">&#8592; All virtual labs</a>
    <div class="eyebrow">Signals &amp; Systems &middot; Virtual lab</div>
    <h1>Generation, transforms, <em>convolution &amp; spectra</em></h1>
    <p class="lede">Seven self-contained experiments, each a genuinely computing simulation written in plain JavaScript &mdash; no libraries, every pixel drawn from the real equation. Generate the standard signals, split a waveform into even and odd parts, shift and scale time, watch convolution flip-and-slide an overlap area into the output, rebuild a square wave harmonic by harmonic and see Gibbs ringing, sample a sinusoid below Nyquist and watch it alias, and push an input through an LTI system. Pick an experiment, then move through Aim, Theory, Procedure, the live Simulation, a graded Self-assessment, and References.</p>

    <div class="shell">
      <aside class="sidebar">
        <div class="stitle">Experiments</div>
        <div class="exp-item on" data-exp="1"><span class="num">1</span><span class="nm">Signal generator &amp; complex exponential</span></div>
        <div class="exp-item" data-exp="2"><span class="num">2</span><span class="nm">Even / odd decomposition</span></div>
        <div class="exp-item" data-exp="3"><span class="num">3</span><span class="nm">Time transformations</span></div>
        <div class="exp-item" data-exp="4"><span class="num">4</span><span class="nm">Convolution &mdash; flip and slide</span></div>
        <div class="exp-item" data-exp="5"><span class="num">5</span><span class="nm">Fourier series &amp; Gibbs</span></div>
        <div class="exp-item" data-exp="6"><span class="num">6</span><span class="nm">Sampling &amp; aliasing</span></div>
        <div class="exp-item" data-exp="7"><span class="num">7</span><span class="nm">LTI system response</span></div>
      </aside>

      <div class="main">

        <!-- ============ EXPERIMENT 1 ============ -->
        <section class="exp on" id="exp-1">
          <h2 class="exp-head">1 &middot; Signal generator &amp; complex exponential</h2>
          <div class="exp-sub">Sine, square, triangle, sawtooth, impulse, unit step, exponential and e^(j&omega;t)</div>
          <div class="secbar">
            <button class="stab on" data-sec="aim">Aim</button>
            <button class="stab" data-sec="theory">Theory</button>
            <button class="stab" data-sec="proc">Procedure</button>
            <button class="stab" data-sec="sim">Simulation</button>
            <button class="stab" data-sec="quiz">Self-assessment</button>
            <button class="stab" data-sec="ref">References</button>
          </div>

          <div class="sec aim on"><div class="prose">To synthesise the standard continuous-time test signals from their defining formulae and to study the complex exponential e^(j&omega;t), observing how its real and imaginary parts are a cosine and a sine of the same frequency, while amplitude, frequency and phase controls reshape the waveform.</div></div>

          <div class="sec theory"><div class="prose">
            <p>Every signal here is computed point-by-point from an explicit formula of time t. A <b>sinusoid</b> is x(t) = A&middot;sin(&omega;t + &phi;) where &omega; = 2&pi;f is angular frequency and &phi; the phase. The <b>square</b>, <b>triangle</b> and <b>sawtooth</b> are periodic non-sinusoids built from the fractional part of ft. The <b>unit impulse</b> &delta;(t) is the idealised spike with unit area; here it is drawn as a single tall sample at t = 0. The <b>unit step</b> u(t) is 0 for t below 0 and 1 thereafter. The <b>exponential</b> is x(t) = A&middot;e^(&sigma;t).</p>
            <p>The <b>complex exponential</b> ties them together. By Euler's identity:</p>
            <div class="eqblock">e^(j&omega;t) = cos(&omega;t) + j&middot;sin(&omega;t)<br>Re = A&middot;cos(&omega;t + &phi;) &nbsp;&nbsp; Im = A&middot;sin(&omega;t + &phi;)<br>magnitude = A (constant) &nbsp;&nbsp; phase advances at rate &omega;</div>
            <p>The trajectory in the complex plane is a circle of radius A traced at angular rate &omega; &mdash; the rotating phasor whose horizontal shadow is a cosine and vertical shadow a sine. This is the atom from which Fourier analysis builds every signal.</p>
          </div></div>

          <div class="sec proc"><ol class="steps">
            <li>Open the <b>Simulation</b> tab and pick a waveform from the dropdown.</li>
            <li>Drag <b>amplitude</b>, <b>frequency</b> and <b>phase</b> and watch the live plot recompute.</li>
            <li>Select <b>Complex exp e^(j&omega;t)</b> to see the real (cyan) and imaginary (purple) parts plotted together, plus the rotating phasor on the right.</li>
            <li>For the <b>exponential</b>, set frequency to the decay rate &sigma; and observe growth versus decay as the sign flips.</li>
            <li>Read the measured peak, RMS and period in the stats panel and confirm RMS = A/&radic;2 for a pure sine.</li>
          </ol></div>

          <div class="sec sim">
            <div class="layout">
              <div class="panel">
                <h3>Signal x(t)</h3>
                <canvas id="g1Cv" width="660" height="300"></canvas>
                <div class="legend">
                  <span><i style="background:#67e8f9"></i> x(t) / Re</span>
                  <span id="g1ImLeg" style="display:none"><i style="background:#a78bfa"></i> Im</span>
                </div>
                <h3 id="g1PhTitle" style="margin-top:16px;display:none;">Phasor in the complex plane</h3>
                <canvas id="g1Ph" width="660" height="240" style="display:none;"></canvas>
                <div class="help"><b>Tip:</b> the impulse is shown as one unit-area sample at t=0; the step jumps from 0 to 1 there.</div>
              </div>
              <div>
                <div class="panel">
                  <h3>Controls</h3>
                  <div class="row"><label>Waveform</label>
                    <select id="g1Wave">
                      <option value="sine">Sine</option>
                      <option value="square">Square</option>
                      <option value="triangle">Triangle</option>
                      <option value="saw">Sawtooth</option>
                      <option value="impulse">Unit impulse</option>
                      <option value="step">Unit step</option>
                      <option value="exp">Exponential e^(&sigma;t)</option>
                      <option value="cexp">Complex exp e^(j&omega;t)</option>
                    </select>
                  </div>
                  <div class="row"><label>Amplitude A</label><input type="range" id="g1A" min="0.1" max="2" step="0.05" value="1"><span class="val" id="g1Av">1.00</span></div>
                  <div class="row"><label>Frequency f</label><input type="range" id="g1F" min="0.2" max="4" step="0.05" value="1"><span class="val" id="g1Fv">1.00 Hz</span></div>
                  <div class="row"><label>Phase &phi;</label><input type="range" id="g1P" min="-180" max="180" step="5" value="0"><span class="val" id="g1Pv">0&deg;</span></div>
                  <div class="row"><label>Animate</label><input type="range" id="g1Sp" min="0" max="6" step="0.2" value="1.5"><span class="val" id="g1Spv">1.5x</span></div>
                  <div class="btns"><button class="btn cyan" id="g1Play">Pause</button><button class="btn ghost" id="g1Reset">Reset</button></div>
                  <div class="stats">
                    <div class="stat"><div class="k">Peak</div><div class="v" id="g1Peak">--</div></div>
                    <div class="stat"><div class="k">RMS</div><div class="v" id="g1Rms">--</div></div>
                    <div class="stat"><div class="k">Period</div><div class="v sm" id="g1Per">--</div></div>
                    <div class="stat"><div class="k">&omega; rad/s</div><div class="v sm" id="g1Om">--</div></div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="sec quiz"><div class="quiz" data-quiz="1"></div></div>

          <div class="sec ref"><ul class="refs">
            <li><b>Oppenheim, Willsky &amp; Nawab</b> &mdash; Signals and Systems, 2nd ed., Ch. 1. Prentice Hall.</li>
            <li><b>Haykin &amp; Van Veen</b> &mdash; Signals and Systems, 2nd ed., Ch. 1. Wiley.</li>
            <li><b>Virtual Labs (IIT)</b> &mdash; Signals and Systems: Basic Signals, vlab.co.in.</li>
          </ul></div>
        </section>

        <!-- ============ EXPERIMENT 2 ============ -->
        <section class="exp" id="exp-2">
          <h2 class="exp-head">2 &middot; Even / odd decomposition</h2>
          <div class="exp-sub">x(t) = xe(t) + xo(t), with xe = (x(t)+x(-t))/2 and xo = (x(t)-x(-t))/2</div>
          <div class="secbar">
            <button class="stab on" data-sec="aim">Aim</button>
            <button class="stab" data-sec="theory">Theory</button>
            <button class="stab" data-sec="proc">Procedure</button>
            <button class="stab" data-sec="sim">Simulation</button>
            <button class="stab" data-sec="quiz">Self-assessment</button>
            <button class="stab" data-sec="ref">References</button>
          </div>

          <div class="sec aim on"><div class="prose">To split an arbitrary signal into its even and odd components using the reflection x(-t), to verify that the two parts add back to the original, and to confirm that the even part is symmetric about t=0 while the odd part is antisymmetric.</div></div>

          <div class="sec theory"><div class="prose">
            <p>Any real signal can be uniquely written as the sum of an <b>even</b> part (mirror-symmetric, like a cosine) and an <b>odd</b> part (point-symmetric through the origin, like a sine). The construction uses only the signal and its time reversal x(-t):</p>
            <div class="eqblock">xe(t) = (x(t) + x(-t)) / 2 &nbsp;&nbsp; (even: xe(-t) = xe(t))<br>xo(t) = (x(t) - x(-t)) / 2 &nbsp;&nbsp; (odd: xo(-t) = -xo(t))<br>x(t) = xe(t) + xo(t)</div>
            <p>The proof is direct: add the two definitions and the x(-t) terms cancel, leaving x(t). Replacing t by -t in xe leaves it unchanged because x(t) and x(-t) swap roles; the same swap flips the sign of xo. A signal that is already even has zero odd part, and vice versa. The decomposition is useful because the Fourier transform of an even real signal is purely real and even, while an odd real signal transforms to a purely imaginary odd spectrum.</p>
          </div></div>

          <div class="sec proc"><ol class="steps">
            <li>Open the <b>Simulation</b> and choose a base signal. A pure asymmetric shape such as the shifted Gaussian shows the effect best.</li>
            <li>Adjust the <b>shift</b> and <b>asymmetry</b> sliders to make the signal lopsided about t=0.</li>
            <li>Read the top plot x(t), the middle plot xe(t) and the bottom plot xo(t).</li>
            <li>Confirm xe is mirror-symmetric and xo is point-symmetric, then check the <b>reconstruction error</b> stat is essentially zero &mdash; xe + xo reproduces x.</li>
            <li>Try the cosine (pure even, xo vanishes) and sine (pure odd, xe vanishes) to verify the limiting cases.</li>
          </ol></div>

          <div class="sec sim">
            <div class="layout">
              <div class="panel">
                <h3>Three plots</h3>
                <canvas id="eoCv" width="660" height="460"></canvas>
                <div class="legend">
                  <span><i style="background:#67e8f9"></i> x(t)</span>
                  <span><i style="background:#86efac"></i> xe(t) even</span>
                  <span><i style="background:#fbbf24"></i> xo(t) odd</span>
                  <span><i style="background:#fca5a5"></i> xe+xo</span>
                </div>
              </div>
              <div>
                <div class="panel">
                  <h3>Base signal</h3>
                  <div class="row"><label>Signal</label>
                    <select id="eoWave">
                      <option value="gauss">Shifted Gaussian</option>
                      <option value="exp">One-sided exponential</option>
                      <option value="ramp">Ramp pulse</option>
                      <option value="cos">Cosine (even)</option>
                      <option value="sin">Sine (odd)</option>
                    </select>
                  </div>
                  <div class="row"><label>Shift t0</label><input type="range" id="eoShift" min="-3" max="3" step="0.1" value="1.2"><span class="val" id="eoShiftv">1.2</span></div>
                  <div class="row"><label>Width / freq</label><input type="range" id="eoW" min="0.3" max="3" step="0.1" value="1"><span class="val" id="eoWv">1.0</span></div>
                  <div class="row"><label>Asymmetry</label><input type="range" id="eoAsym" min="0" max="1" step="0.05" value="0.5"><span class="val" id="eoAsymv">0.50</span></div>
                  <div class="stats">
                    <div class="stat"><div class="k">Even energy</div><div class="v sm" id="eoEe">--</div></div>
                    <div class="stat"><div class="k">Odd energy</div><div class="v sm" id="eoEo">--</div></div>
                    <div class="stat"><div class="k">Recon error</div><div class="v sm" id="eoErr">--</div></div>
                    <div class="stat"><div class="k">Symmetry</div><div class="v sm" id="eoSym">--</div></div>
                  </div>
                  <div class="help">Energy splits cleanly: total energy = even energy + odd energy (the cross term integrates to zero).</div>
                </div>
              </div>
            </div>
          </div>

          <div class="sec quiz"><div class="quiz" data-quiz="2"></div></div>

          <div class="sec ref"><ul class="refs">
            <li><b>Oppenheim, Willsky &amp; Nawab</b> &mdash; Signals and Systems, 2nd ed., Sec. 1.2.3. Prentice Hall.</li>
            <li><b>Lathi</b> &mdash; Linear Systems and Signals, 2nd ed., Ch. 1. Oxford.</li>
            <li><b>Virtual Labs (IIT)</b> &mdash; Signals and Systems: Even and Odd Components, vlab.co.in.</li>
          </ul></div>
        </section>

        <!-- ============ EXPERIMENT 3 ============ -->
        <section class="exp" id="exp-3">
          <h2 class="exp-head">3 &middot; Time transformations</h2>
          <div class="exp-sub">Shifting x(t - t0), scaling x(at) and reversal x(-t)</div>
          <div class="secbar">
            <button class="stab on" data-sec="aim">Aim</button>
            <button class="stab" data-sec="theory">Theory</button>
            <button class="stab" data-sec="proc">Procedure</button>
            <button class="stab" data-sec="sim">Simulation</button>
            <button class="stab" data-sec="quiz">Self-assessment</button>
            <button class="stab" data-sec="ref">References</button>
          </div>

          <div class="sec aim on"><div class="prose">To apply the three independent operations on the time axis &mdash; shifting, scaling and reversal &mdash; in a controlled order, and to see how each reshapes the signal by comparing the original against the transformed waveform on the same axes.</div></div>

          <div class="sec theory"><div class="prose">
            <p>Operations on the time variable move and stretch a signal without touching its amplitude. For a general transform y(t) = x(a&middot;t - t0) the rules are:</p>
            <div class="eqblock">Shift: y(t) = x(t - t0) &mdash; t0 &gt; 0 delays (moves right)<br>Scale: y(t) = x(a&middot;t) &mdash; |a| &gt; 1 compresses, |a| &lt; 1 stretches<br>Reversal: y(t) = x(-t) &mdash; mirror about t = 0</div>
            <p>Order matters. The combined form y(t) = x(a(t - b)) first scales then shifts by b, whereas x(at - t0) shifts by t0/a after scaling. Here the engine evaluates the composite argument g(t) = a&middot;t - t0 (with the reversal toggle negating a), so you read off the transformed value as x(g(t)). A negative a both reverses and scales. The transformations are the geometric backbone of convolution, where one signal is reversed and shifted across another.</p>
          </div></div>

          <div class="sec proc"><ol class="steps">
            <li>Open the <b>Simulation</b> and choose a base pulse with a clear shape so changes are visible.</li>
            <li>Drag <b>shift t0</b> &mdash; positive values delay the signal to the right.</li>
            <li>Drag <b>scale a</b> &mdash; values above 1 compress in time, below 1 stretch it.</li>
            <li>Toggle <b>reversal</b> to mirror about the origin; combine it with a scale to see x(-a t).</li>
            <li>The faint grey curve is the original; the cyan curve is the transformed result. The <b>argument</b> readout shows the live mapping a&middot;t - t0.</li>
          </ol></div>

          <div class="sec sim">
            <div class="layout">
              <div class="panel">
                <h3>Original vs transformed</h3>
                <canvas id="ttCv" width="660" height="320"></canvas>
                <div class="legend">
                  <span><i style="background:#3a4054"></i> x(t) original</span>
                  <span><i style="background:#67e8f9"></i> y(t) transformed</span>
                </div>
                <div class="help"><b>Mapping:</b> <span id="ttMap" style="color:#fbbf24">y(t) = x(t)</span></div>
              </div>
              <div>
                <div class="panel">
                  <h3>Transform</h3>
                  <div class="row"><label>Base x(t)</label>
                    <select id="ttWave">
                      <option value="pulse">Asymmetric pulse</option>
                      <option value="tri">Triangle pulse</option>
                      <option value="gauss">Gaussian</option>
                      <option value="sin">Sine burst</option>
                    </select>
                  </div>
                  <div class="row"><label>Shift t0</label><input type="range" id="ttShift" min="-4" max="4" step="0.1" value="0"><span class="val" id="ttShiftv">0.0</span></div>
                  <div class="row"><label>Scale a</label><input type="range" id="ttScale" min="0.25" max="3" step="0.05" value="1"><span class="val" id="ttScalev">1.00</span></div>
                  <div class="row"><label>Reverse</label>
                    <select id="ttRev"><option value="0">Off</option><option value="1">On (x(-t))</option></select>
                  </div>
                  <div class="btns"><button class="btn ghost" id="ttReset">Reset</button></div>
                  <div class="stats">
                    <div class="stat"><div class="k">Effective a</div><div class="v sm" id="ttAeff">1.00</div></div>
                    <div class="stat"><div class="k">Delay</div><div class="v sm" id="ttDel">0.0</div></div>
                    <div class="stat"><div class="k">Action</div><div class="v sm" id="ttAct">none</div></div>
                    <div class="stat"><div class="k">Peak at t</div><div class="v sm" id="ttPk">--</div></div>
                  </div>
                </div>
              </div>
            </div>
          </div>

