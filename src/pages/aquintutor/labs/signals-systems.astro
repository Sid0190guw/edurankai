  // ===================================================================
  // EXPERIMENT 5 — FOURIER SERIES & GIBBS
  // ===================================================================
  (function FS() {
    var cv = $('fsCv'); if (!cv) return;
    var ctx = makeCtx(cv, 660, 300);
    var spCv = $('fsSp');
    var sctx = makeCtx(spCv, 660, 170);
    var LW = 660, LH = 300, SW = 660, SH = 170;
    var sweeping = false, last = 0, sweepN = 1;

    function coeff(n, kind) {
      if (kind === 'square') return (n % 2 === 1) ? 4 / (n * Math.PI) : 0;
      if (kind === 'saw') return 2 * Math.pow(-1, n + 1) / (n * Math.PI);
      if (kind === 'triangle') return (n % 2 === 1) ? 8 / (n * n * Math.PI * Math.PI) * Math.pow(-1, (n - 1) / 2) : 0;
      return 0;
    }
    function target(x, kind) {
      x = ((x % (2 * Math.PI)) + 2 * Math.PI) % (2 * Math.PI);
      if (kind === 'square') return x < Math.PI ? 1 : -1;
      if (kind === 'saw') return 1 - x / Math.PI;
      if (kind === 'triangle') return x < Math.PI ? -1 + 2 * x / Math.PI : 3 - 2 * x / Math.PI;
      return 0;
    }
    function partial(x, N, kind) {
      var s = 0;
      for (var n = 1; n <= N; n++) s += coeff(n, kind) * Math.sin(n * x);
      return s;
    }
    function read() {
      var N = parseInt($('fsN').value, 10);
      $('fsNv').textContent = N;
      return { N: N, kind: $('fsWave').value, show: $('fsShow').value === '1' };
    }
    function draw() {
      var c = read();
      clearBg(ctx, LW, LH);
      var m = makeMap(LW, LH, -Math.PI, 3 * Math.PI, 1.5, 30, 12, 12, 22);
      // grid (custom: vertical at multiples of pi)
      ctx.strokeStyle = COL.grid; ctx.lineWidth = 1;
      for (var k = -1; k <= 3; k++) { var xp = m.sx(k * Math.PI); ctx.beginPath(); ctx.moveTo(xp, m.y0); ctx.lineTo(xp, m.y1); ctx.stroke(); }
      for (var h = -1; h <= 1; h++) { var yp = m.midY - h * ((m.y1 - m.y0) / 2); ctx.beginPath(); ctx.moveTo(m.x0, yp); ctx.lineTo(m.x1, yp); ctx.stroke(); }
      ctx.strokeStyle = COL.axis; ctx.lineWidth = 1.2; ctx.beginPath(); ctx.moveTo(m.x0, m.midY); ctx.lineTo(m.x1, m.midY); ctx.stroke();
      ctx.fillStyle = COL.text; ctx.font = '10px Geist Mono'; ctx.textAlign = 'left';
      ctx.fillText(c.kind + ' wave, N=' + c.N, m.x0 + 4, m.y0 + 11);

      // target
      ctx.setLineDash([4, 3]);
      plotFn(ctx, m, function (x) { return target(x, c.kind); }, '#9aa0aa', 1.4, 1200);
      ctx.setLineDash([]);
      // individual sinusoids
      if (c.show) {
        for (var n = 1; n <= c.N; n++) {
          var b = coeff(n, c.kind); if (Math.abs(b) < 1e-6) continue;
          var hue = (n * 53) % 360;
          plotFn(ctx, m, function (x) { return b * Math.sin(n * x); }, 'hsla(' + hue + ',70%,62%,0.4)', 0.8, 900);
        }
      }
      // partial sum
      plotFn(ctx, m, function (x) { return partial(x, c.N, c.kind); }, COL.amber, 2.4, 1400);

      // spectrum
      clearBg(sctx, SW, SH);
      var base = SH - 22, maxB = 0;
      for (var nn = 1; nn <= 60; nn++) maxB = Math.max(maxB, Math.abs(coeff(nn, c.kind)));
      sctx.strokeStyle = COL.axis; sctx.beginPath(); sctx.moveTo(28, base); sctx.lineTo(SW - 10, base); sctx.stroke();
      for (var n2 = 1; n2 <= 60; n2++) {
        var bb = Math.abs(coeff(n2, c.kind)); if (bb < 1e-7) continue;
        var bx = 30 + (n2 - 1) * (SW - 46) / 59;
        var bh = bb / maxB * (base - 14);
        sctx.fillStyle = (n2 <= c.N) ? COL.cyan : '#2a2a35';
        sctx.fillRect(bx - 2.5, base - bh, 5, bh);
      }
      sctx.fillStyle = COL.text; sctx.font = '10px Geist Mono'; sctx.textAlign = 'left';
      sctx.fillText('harmonic n -> amplitude |b_n|', 30, 13);

      // stats: overshoot = max partial - target plateau near jump
      var nT = 0; for (var q = 1; q <= c.N; q++) if (Math.abs(coeff(q, c.kind)) > 1e-6) nT++;
      $('fsTerms').textContent = nT;
      // sample partial near a jump for overshoot (square/saw jump at x=pi-)
      var over = 0, rms = 0, ns = 1500;
      var maxv = -1e9;
      for (var i = 0; i < ns; i++) {
        var x = -Math.PI + 4 * Math.PI * i / ns;
        var pv = partial(x, c.N, c.kind), tv = target(x, c.kind);
        rms += (pv - tv) * (pv - tv);
        if (pv > maxv) maxv = pv;
      }
      rms = Math.sqrt(rms / ns);
      if (c.kind === 'triangle') { over = Math.max(0, (maxv - 1)) * 100; }
      else { over = Math.max(0, (maxv - 1)) * 100; } // jump height = 2, plateau=1
      $('fsOver').textContent = (c.kind === 'triangle') ? '~0%' : over.toFixed(1) + '%';
      $('fsErr').textContent = rms.toFixed(3);
      $('fsRoll').textContent = (c.kind === 'triangle') ? '1/n^2' : '1/n';
    }
    ['fsWave', 'fsN', 'fsShow'].forEach(function (id) {
      $(id).addEventListener('input', draw); $(id).addEventListener('change', draw);
    });
    $('fsReset').addEventListener('click', function () { $('fsN').value = 5; $('fsWave').value = 'square'; $('fsShow').value = '0'; sweeping = false; draw(); });
    $('fsAnim').addEventListener('click', function () { sweeping = !sweeping; this.textContent = sweeping ? 'Stop' : 'Sweep N'; if (sweeping) sweepN = 1; });

