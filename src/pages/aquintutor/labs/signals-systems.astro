        e: 'Near a discontinuity the partial sum overshoots by about 9 percent however many terms are added.' },
      { q: 'A continuous triangle wave converges faster than a square wave because its coefficients decay as:',
        o: ['1/n', '1/n^2', 'constant', '1/sqrt(n)'], a: 1,
        e: 'No discontinuity means smoother content, so coefficients fall off as 1/n^2 instead of 1/n.' },
      { q: 'At an exact jump, the Fourier series converges to:',
        o: ['The upper value', 'The lower value', 'The midpoint of the two values', 'Infinity'], a: 2,
        e: 'At a finite discontinuity the series converges to the average of the left and right limits.' }
    ],
    '6': [
      { q: 'The Nyquist criterion for a signal of maximum frequency f requires:',
        o: ['fs > f', 'fs >= 2 f', 'fs = f / 2', 'fs >= 4 f'], a: 1,
        e: 'You must sample at least twice the highest frequency to avoid aliasing.' },
      { q: 'A 7 Hz sine sampled at 10 Hz appears as a sine of frequency:',
        o: ['7 Hz', '3 Hz', '10 Hz', '17 Hz'], a: 1,
        e: 'The alias is |7 - 10| = 3 Hz, the fold of 7 Hz about the sampling rate.' },
      { q: 'The Nyquist frequency is:',
        o: ['Twice fs', 'fs / 2', 'Equal to f', 'fs times f'], a: 1,
        e: 'Half the sampling rate is the highest frequency that can be represented without aliasing.' },
      { q: 'Aliasing in undersampled signals is best prevented by:',
        o: ['Increasing the amplitude', 'An anti-alias low-pass filter before sampling', 'Adding noise', 'Sampling slower'], a: 1,
        e: 'Band-limiting the signal below fs/2 before sampling removes the frequencies that would fold.' }
    ],
    '7': [
      { q: 'An LTI system is completely characterised by its:',
        o: ['Step input', 'Impulse response h(t)', 'Maximum amplitude', 'Sampling rate'], a: 1,
        e: 'Knowing h(t) lets you find the output for any input by convolution.' },
      { q: 'The output of an LTI system is:',
        o: ['x(t) + h(t)', 'x(t) times h(t)', 'x(t) convolved with h(t)', 'h(t) only'], a: 2,
        e: 'Output equals the convolution of the input with the impulse response, y = x * h.' },
      { q: 'A system with h(t) = e^(-a t) u(t) acts as a:',
        o: ['Differentiator', 'Smoothing low-pass (leaky integrator)', 'Pure delay', 'Frequency multiplier'], a: 1,
        e: 'A decaying-exponential response averages recent input, smoothing and lagging it.' },
      { q: 'An LTI system is BIBO stable if its impulse response is:',
        o: ['Always positive', 'Absolutely integrable (integral of |h| finite)', 'Periodic', 'Zero at t = 0'], a: 1,
        e: 'A finite integral of |h(t)| guarantees a bounded output for any bounded input.' }
    ]
  };

  function buildQuiz(host) {
    var qid = host.getAttribute('data-quiz');
    var qs = QUIZZES[qid]; if (!qs) return;
    var cards = [];
    for (var i = 0; i < qs.length; i++) {
      (function (item, idx) {
        var card = document.createElement('div');
        card.className = 'q';
        var qt = document.createElement('div');
        qt.className = 'qt';
        qt.innerHTML = '<b>Q' + (idx + 1) + '.</b> ' + item.q;
        card.appendChild(qt);
        var sel = -1, opts = [];
        for (var j = 0; j < item.o.length; j++) {
          (function (optIdx) {
            var op = document.createElement('div');
            op.className = 'opt-a';
            op.textContent = item.o[optIdx];
            op.addEventListener('click', function () {
              if (card.getAttribute('data-done') === '1') return;
              for (var m = 0; m < opts.length; m++) opts[m].classList.remove('sel');
              op.classList.add('sel'); sel = optIdx;
            });
            opts.push(op);
            card.appendChild(op);
          })(j);
        }
        var expl = document.createElement('div');
        expl.className = 'expl';
        expl.innerHTML = '<b>Answer:</b> ' + item.o[item.a] + '. ' + item.e;
        card.appendChild(expl);
        host.appendChild(card);
        cards.push({ card: card, opts: opts, item: item, getSel: function () { return sel; } });
      })(qs[i], i);
    }
    // footer: Check button + score
    var foot = document.createElement('div');
    foot.className = 'quizfoot';
    var btn = document.createElement('button');
    btn.className = 'btn amber'; btn.textContent = 'Check answers';
    var score = document.createElement('span');
    score.className = 'score';
    foot.appendChild(btn); foot.appendChild(score);
    host.appendChild(foot);
    btn.addEventListener('click', function () {
      var correct = 0;
      for (var c = 0; c < cards.length; c++) {
        var cd = cards[c]; cd.card.setAttribute('data-done', '1');
        var s = cd.getSel();
        for (var m = 0; m < cd.opts.length; m++) {
          if (m === cd.item.a) cd.opts[m].classList.add('correct');
          else if (m === s) cd.opts[m].classList.add('wrong');
        }
        cd.card.querySelector('.expl').classList.add('show');
        if (s !== cd.item.a) cd.card.classList.add('bad');
        if (s === cd.item.a) correct++;
      }
      score.textContent = correct + ' / ' + cards.length + ' correct';
    });
  }
  var quizHosts = document.querySelectorAll('.ss .quiz');
  for (var qh = 0; qh < quizHosts.length; qh++) buildQuiz(quizHosts[qh]);

})();
</script>

