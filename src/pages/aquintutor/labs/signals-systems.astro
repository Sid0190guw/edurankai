      requestAnimationFrame(loop);
    }
    draw(); requestAnimationFrame(loop);
  })();

  // ===================================================================
  // EXPERIMENT 6 — SAMPLING & ALIASING
  // ===================================================================
  (function SAMP() {
    var cv = $('saCv'); if (!cv) return;
    var ctx = makeCtx(cv, 660, 320);
    var LW = 660, LH = 320;
    var tmin = 0, tmax = 2; // seconds

    function read() {
      var f = parseFloat($('saF').value);
      var fs = parseFloat($('saFs').value);
      $('saFv').textContent = f.toFixed(1) + ' Hz';
      $('saFsv').textContent = fs.toFixed(1) + ' Hz';
      return { f: f, fs: fs, rec: $('saRec').value === '1' };
    }
    function aliasFreq(f, fs) {
      var k = Math.round(f / fs);
      return Math.abs(f - k * fs);
    }
    function draw() {
      var c = read();
      clearBg(ctx, LW, LH);
      var m = makeMap(LW, LH, tmin, tmax, 1.4, 34, 12, 12, 22);
      // custom time grid
      ctx.strokeStyle = COL.grid; ctx.lineWidth = 1;
      for (var g = 0; g <= 2; g += 0.25) { var xg = m.sx(g); ctx.beginPath(); ctx.moveTo(xg, m.y0); ctx.lineTo(xg, m.y1); ctx.stroke(); }
      for (var hh = -1; hh <= 1; hh++) { var yg = m.midY - hh * ((m.y1 - m.y0) / 2); ctx.beginPath(); ctx.moveTo(m.x0, yg); ctx.lineTo(m.x1, yg); ctx.stroke(); }
      ctx.strokeStyle = COL.axis; ctx.lineWidth = 1.2; ctx.beginPath(); ctx.moveTo(m.x0, m.midY); ctx.lineTo(m.x1, m.midY); ctx.stroke();

      // true signal
      plotFn(ctx, m, function (t) { return Math.sin(2 * Math.PI * c.f * t); }, '#9aa0aa', 1.6, 1400);

      // samples
      var T = 1 / c.fs;
      var samples = [];
      ctx.fillStyle = COL.cyan; ctx.strokeStyle = COL.cyan; ctx.lineWidth = 1.4;
      for (var t = 0; t <= tmax + 1e-9; t += T) {
        var v = Math.sin(2 * Math.PI * c.f * t);
        samples.push({ t: t, v: v });
        var px = m.sx(t), py = m.sy(v);
        ctx.beginPath(); ctx.moveTo(px, m.midY); ctx.lineTo(px, py); ctx.stroke();
        ctx.beginPath(); ctx.arc(px, py, 3.2, 0, 2 * Math.PI); ctx.fill();
      }

      // sinc reconstruction from samples
      if (c.rec) {
        plotFn(ctx, m, function (t) {
          var sum = 0;
          for (var i = 0; i < samples.length; i++) {
            var arg = Math.PI * (t - samples[i].t) / T;
            var sinc = (Math.abs(arg) < 1e-6) ? 1 : Math.sin(arg) / arg;
            sum += samples[i].v * sinc;
          }
          return sum;
        }, COL.amber, 2.2, 1400);
      }

      // stats
      var nyq = c.fs / 2;
      var alias = aliasFreq(c.f, c.fs);
      var ok = c.fs >= 2 * c.f - 1e-6;
      $('saNyq').textContent = nyq.toFixed(2) + ' Hz';
      $('saSpr').textContent = c.fs.toFixed(1);
      $('saAlias').textContent = (ok ? c.f.toFixed(2) : alias.toFixed(2)) + ' Hz';
      $('saRatio').textContent = (c.fs / (2 * c.f)).toFixed(2);
      var vEl = $('saVerdict');
      if (ok) { vEl.textContent = 'fs >= 2f  ->  no aliasing, reconstruction matches'; vEl.style.color = COL.green; }
      else { vEl.textContent = 'fs < 2f  ->  ALIASING: appears as ' + alias.toFixed(2) + ' Hz'; vEl.style.color = COL.red; }
    }
