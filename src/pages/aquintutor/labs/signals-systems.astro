      $(id).addEventListener('input', draw); $(id).addEventListener('change', draw);
    });
    $('saReset').addEventListener('click', function () { $('saF').value = 2; $('saFs').value = 10; $('saRec').value = '1'; draw(); });
    REDRAW['6'] = function () { ctx = makeCtx(cv, 660, 320); draw(); };
    draw();
  })();

  // ===================================================================
  // EXPERIMENT 7 — LTI SYSTEM RESPONSE
  // ===================================================================
  (function LTI() {
    var cv = $('ltCv'); if (!cv) return;
    var ctx = makeCtx(cv, 660, 380);
    var LW = 660, LH = 380;
    var tmin = -1, tmax = 8, dt = 0.02;

    function read() {
      var a = parseFloat($('ltA').value);
      var w = parseFloat($('ltW').value);
      $('ltAv').textContent = a.toFixed(1);
      $('ltWv').textContent = w.toFixed(1);
      return { a: a, w: w, x: $('ltX').value, h: $('ltH').value };
    }
    function xfn(t, c) {
      switch (c.x) {
        case 'pulse': return (t >= 0 && t <= c.w) ? 1 : 0;
        case 'step': return t >= 0 ? 1 : 0;
        case 'sin': return (t >= 0 && t <= 6) ? Math.sin(2 * Math.PI * (c.w * 0.5) * t) : 0;
        case 'impulse': return (Math.abs(t) < dt) ? (1 / dt) : 0;
        default: return 0;
      }
    }
    function hfn(t, c) {
      switch (c.h) {
        case 'exp': return t >= 0 ? c.a * Math.exp(-c.a * t) : 0; // unit-area integrator-ish
        case 'rect': return (t >= 0 && t <= c.w) ? 1 / c.w : 0;   // moving average, unit area
        case 'damp': return t >= 0 ? Math.exp(-c.a * t * 0.5) * Math.cos(2 * Math.PI * c.w * t) : 0;
        case 'diff': { // approximate derivative: tight +/- pair
          if (t >= 0 && t < dt) return 1 / dt;
          if (t >= dt && t < 2 * dt) return -1 / dt;
          return 0;
        }
        default: return 0;
      }
    }
    function draw() {
      var c = read();
      clearBg(ctx, LW, LH);
      // sample x and h
      var ts = [], xs = [], hs = [];
      for (var t = tmin; t <= tmax + 1e-9; t += dt) { ts.push(t); xs.push(xfn(t, c)); hs.push(hfn(t, c)); }
      // discrete convolution y[n] = sum xs[k] hs[n-k] * dt
      var ys = new Array(ts.length);
      for (var n = 0; n < ts.length; n++) {
        var sum = 0;
        for (var k = 0; k < ts.length; k++) {
          var idx = n - k + Math.round(-tmin / dt); // align so output time = ts[n]
          if (idx >= 0 && idx < ts.length) sum += xs[k] * hs[idx] * dt;
        }
        ys[n] = sum;
      }
      // ranges for plotting
      var ymaxTop = 1.4;
      var hmax = 0.1, ymaxOut = 0.1;
      for (var i = 0; i < ts.length; i++) { hmax = Math.max(hmax, Math.abs(hs[i])); ymaxOut = Math.max(ymaxOut, Math.abs(ys[i])); }

      var H3 = LH / 3;
      // panel 1: input
      var m1 = makeMap(LW, H3, tmin, tmax, ymaxTop, 34, 12, 8, 14);
      drawGrid(ctx, m1, LW, H3, 'x(t) input');
      plotArr(ctx, m1, xs.map(function (v) { return Math.min(v, 1.35); }), ts, COL.cyan, 2.2);

      ctx.save(); ctx.translate(0, H3);
      var m2 = makeMap(LW, H3, tmin, tmax, hmax * 1.2, 34, 12, 8, 14);
      drawGrid(ctx, m2, LW, H3, 'h(t) impulse response');
      plotArr(ctx, m2, hs, ts, COL.purple, 2.2);
      ctx.restore();

      ctx.save(); ctx.translate(0, 2 * H3);
      var m3 = makeMap(LW, H3, tmin, tmax, ymaxOut * 1.2, 34, 12, 8, 14);
      drawGrid(ctx, m3, LW, H3, 'y(t) = x * h  output');
      plotArr(ctx, m3, ys, ts, COL.amber, 2.4);
      ctx.restore();

      // stats
      var eIn = 0, eOut = 0, dcH = 0, absH = 0, pkY = -1e9, pkT = 0, pkXt = 0, pkXv = -1e9;
      for (var j = 0; j < ts.length; j++) {
        eIn += xs[j] * xs[j] * dt; eOut += ys[j] * ys[j] * dt;
        dcH += hs[j] * dt; absH += Math.abs(hs[j]) * dt;
        if (ys[j] > pkY) { pkY = ys[j]; pkT = ts[j]; }
        if (xs[j] > pkXv) { pkXv = xs[j]; pkXt = ts[j]; }
      }
      $('ltGain').textContent = eIn > 1e-9 ? (eOut / eIn).toFixed(3) : '--';
      $('ltDelay').textContent = (pkT - pkXt).toFixed(2) + ' s';
      $('ltDC').textContent = dcH.toFixed(3);
      $('ltStable').textContent = (absH < 50) ? 'yes (BIBO)' : 'marginal';
    }
    ['ltX', 'ltH', 'ltA', 'ltW'].forEach(function (id) {
      $(id).addEventListener('input', draw); $(id).addEventListener('change', draw);
    });
    $('ltReset').addEventListener('click', function () {
      $('ltX').value = 'pulse'; $('ltH').value = 'exp'; $('ltA').value = 1.5; $('ltW').value = 1.2; draw();
    });
    REDRAW['7'] = function () { ctx = makeCtx(cv, 660, 380); draw(); };
    draw();
  })();

