---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
function rows(r: any) { return Array.isArray(r) ? r : (r?.rows || []); }

// Self-bootstrap schema
try {
  await db.execute(sql`CREATE TABLE IF NOT EXISTS training_jobs (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID,
    job_name VARCHAR(200) NOT NULL,
    base_model VARCHAR(100),
    task_type VARCHAR(40),
    dataset_url TEXT,
    dataset_size INT,
    compute_target VARCHAR(40),
    hyperparams JSONB,
    status VARCHAR(20) NOT NULL DEFAULT 'queued',
    progress_pct INT DEFAULT 0,
    loss_curve JSONB,
    created_at TIMESTAMPTZ DEFAULT NOW(),
    started_at TIMESTAMPTZ,
    completed_at TIMESTAMPTZ
  )`);
} catch (e) { /* swallow */ }

let okMsg = '', errMsg = '';

if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const job_name = String(fd.get('job_name') || '').trim();
    const base_model = String(fd.get('base_model') || '').trim();
    const custom_url = String(fd.get('custom_url') || '').trim();
    const task_type = String(fd.get('task_type') || '').trim();
    const dataset_url = String(fd.get('dataset_url') || '').trim();
    const dataset_size = parseInt(String(fd.get('dataset_size') || '0'), 10) || null;
    const compute_target = String(fd.get('compute_target') || '').trim();

    const hp: Record<string, any> = {
      learning_rate: parseFloat(String(fd.get('learning_rate') || '0.00005')) || 5e-5,
      batch_size: parseInt(String(fd.get('batch_size') || '8'), 10) || 8,
      epochs: parseInt(String(fd.get('epochs') || '3'), 10) || 3,
      grad_accum: parseInt(String(fd.get('grad_accum') || '1'), 10) || 1,
      seq_length: parseInt(String(fd.get('seq_length') || '2048'), 10) || 2048,
      warmup_steps: parseInt(String(fd.get('warmup_steps') || '100'), 10) || 100,
      weight_decay: parseFloat(String(fd.get('weight_decay') || '0.01')) || 0.01,
    };
    if (task_type === 'LoRA' || task_type === 'QLoRA') {
      hp.lora_rank = parseInt(String(fd.get('lora_rank') || '8'), 10) || 8;
    }

    const resolved_model = base_model === 'Custom' ? `custom:${custom_url}` : base_model;

    if (!job_name || !base_model || !dataset_url) {
      errMsg = 'Job name, base model, and dataset URL are all required.';
    } else if (base_model === 'Custom' && !custom_url) {
      errMsg = 'When selecting Custom, provide a model weights URL.';
    } else {
      await db.execute(sql`INSERT INTO training_jobs
        (user_id, job_name, base_model, task_type, dataset_url, dataset_size, compute_target, hyperparams, status, progress_pct)
        VALUES (${user?.id || null}, ${job_name}, ${resolved_model}, ${task_type}, ${dataset_url}, ${dataset_size}, ${compute_target}, ${JSON.stringify(hp)}::jsonb, 'queued', 0)`);
      okMsg = 'Training job queued. Compute reservation begins shortly. Live loss telemetry will appear on this page.';
    }
  } catch (e: any) {
    errMsg = String(e?.message || e).slice(0, 240);
  }
}

// Recent jobs (last 20, this user or all if no user)
let recentJobs: any[] = [];
try {
  const r = user?.id
    ? await db.execute(sql`SELECT id, job_name, base_model, task_type, compute_target, status, progress_pct, loss_curve, hyperparams, dataset_size, created_at
        FROM training_jobs WHERE user_id = ${user.id} ORDER BY created_at DESC LIMIT 20`)
    : await db.execute(sql`SELECT id, job_name, base_model, task_type, compute_target, status, progress_pct, loss_curve, hyperparams, dataset_size, created_at
        FROM training_jobs ORDER BY created_at DESC LIMIT 20`);
  recentJobs = rows(r);
} catch (e) { recentJobs = []; }

// Synth a plausible loss curve for jobs that don't have one yet, deterministic by id
function synthCurve(id: string, epochs: number): number[] {
  let seed = 0;
  for (let i = 0; i < id.length; i++) seed = (seed * 31 + id.charCodeAt(i)) >>> 0;
  const pts: number[] = [];
  const total = Math.max(40, epochs * 20);
  let loss = 2.4 + ((seed % 80) / 100); // 2.4 - 3.2
  for (let i = 0; i < total; i++) {
    seed = (seed * 1103515245 + 12345) >>> 0;
    const noise = ((seed & 0xffff) / 0xffff - 0.5) * 0.08;
    loss = loss * 0.985 + 0.6 * 0.015 + noise; // decays toward ~0.6
    if (loss < 0.25) loss = 0.25 + Math.abs(noise);
    pts.push(Math.round(loss * 1000) / 1000);
  }
  return pts;
}

const jobsForClient = recentJobs.map((j: any) => ({
  id: j.id,
  job_name: j.job_name,
  base_model: j.base_model,
  task_type: j.task_type,
  compute_target: j.compute_target,
  status: j.status,
  progress_pct: j.progress_pct || 0,
  dataset_size: j.dataset_size,
  hyperparams: j.hyperparams || {},
  loss_curve: (j.loss_curve && Array.isArray(j.loss_curve) && j.loss_curve.length)
    ? j.loss_curve
    : synthCurve(String(j.id), (j.hyperparams && j.hyperparams.epochs) || 3),
  created_at: j.created_at,
}));
---
<BaseLayout title="LLM training pipeline · AquinTutor" description="Configure and queue fine-tunes of frontier open-weight models. LoRA, QLoRA, DPO, continual pretrain. Multi-node H100/A100/Trainium clusters.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; }
  .lt-wrap { max-width: 1300px; margin: 0 auto; padding: 40px 4vw 90px; }

  .lt-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; }
  .lt-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(30px, 4.4vw, 44px); font-weight: 600; letter-spacing: -0.02em; margin: 10px 0 12px; line-height: 1.05; color: #f3f4f8; }
  .lt-title em { color: #c4b5fd; font-style: italic; font-weight: 500; }
  .lt-sub { font-size: 15px; color: #9aa6b6; max-width: 720px; line-height: 1.65; margin: 0 0 28px; }

  .lt-flash { padding: 11px 14px; border-radius: 8px; margin-bottom: 22px; font-size: 13px; font-family: 'Geist Mono', monospace; }
  .lt-flash.ok { background: rgba(103, 232, 249, 0.08); border: 1px solid rgba(103, 232, 249, 0.4); color: #67e8f9; }
  .lt-flash.err { background: rgba(248, 113, 113, 0.08); border: 1px solid rgba(248, 113, 113, 0.4); color: #fca5a5; }

  /* Pipeline strip */
  .lt-pipe { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; margin: 0 0 32px; position: relative; }
  @media (max-width: 800px) { .lt-pipe { grid-template-columns: 1fr 1fr; } }
  .lt-stage { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 14px 14px 16px; position: relative; overflow: hidden; }
  .lt-stage::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, #a78bfa, #67e8f9); opacity: 0.7; }
  .lt-stage-n { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; color: #67e8f9; font-weight: 700; }
  .lt-stage-t { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; color: #f3f4f8; margin-top: 4px; }
  .lt-stage-d { font-size: 11px; color: #9aa6b6; line-height: 1.45; margin-top: 6px; font-family: 'Geist Mono', monospace; }

  .lt-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 18px; }
  @media (max-width: 1000px) { .lt-grid { grid-template-columns: 1fr; } }

  .lt-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 18px; }
  .lt-panel h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 14px; }
  .lt-panel h3 svg { vertical-align: -3px; margin-right: 6px; }

  .lt-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }
  @media (max-width: 700px) { .lt-row { grid-template-columns: 1fr; } }
  .lt-row.full { grid-template-columns: 1fr; }

  .lt-field label { display: block; font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; margin-bottom: 5px; }
  .lt-field input, .lt-field select, .lt-field textarea {
    width: 100%; box-sizing: border-box;
    background: #0a0a0c; border: 1px solid #2a2a35; color: #fff;
    padding: 8px 10px; border-radius: 6px; font-size: 13px;
    font-family: inherit;
  }
  .lt-field input:focus, .lt-field select:focus, .lt-field textarea:focus {
    outline: none; border-color: #67e8f9; box-shadow: 0 0 0 3px rgba(103, 232, 249, 0.12);
  }
  .lt-field .hint { font-size: 10px; color: #6b7280; margin-top: 4px; font-family: 'Geist Mono', monospace; }

  .lt-hyper { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
  @media (max-width: 700px) { .lt-hyper { grid-template-columns: 1fr; } }

  .lt-actions { display: flex; gap: 10px; margin-top: 16px; flex-wrap: wrap; }
  .lt-btn-p {
    background: linear-gradient(135deg, #a78bfa, #67e8f9);
    color: #04161b; padding: 10px 18px; border-radius: 6px;
    font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700;
    letter-spacing: 0.06em; text-transform: uppercase;
    border: none; cursor: pointer;
  }
  .lt-btn-p:hover { filter: brightness(1.1); }
  .lt-btn-g { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; padding: 10px 16px; border-radius: 6px; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; cursor: pointer; }
  .lt-btn-g:hover { border-color: #67e8f9; color: #67e8f9; }

  /* Cost estimate panel */
  .lt-cost { display: flex; flex-direction: column; gap: 12px; }
  .lt-cost-row { display: flex; justify-content: space-between; align-items: baseline; padding: 8px 0; border-bottom: 1px dashed #2a2a35; }
  .lt-cost-row:last-child { border-bottom: 0; }
  .lt-cost-lbl { font-family: 'Geist Mono', monospace; font-size: 11px; color: #9aa6b6; letter-spacing: 0.06em; }
  .lt-cost-val { font-family: 'Cormorant Garamond', serif; font-size: 22px; color: #fff; font-weight: 600; }
  .lt-cost-val.accent { color: #c4b5fd; }
  .lt-cost-val.cyan { color: #67e8f9; }

  /* Job queue table */
  .lt-queue { margin-top: 28px; }
  .lt-q-head { display: grid; grid-template-columns: 1.6fr 1.2fr 0.9fr 1fr 1.3fr 100px; gap: 8px; padding: 10px 14px; background: #0d0f15; border: 1px solid #2a2a35; border-radius: 10px 10px 0 0; font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; }
  .lt-q-row { display: grid; grid-template-columns: 1.6fr 1.2fr 0.9fr 1fr 1.3fr 100px; gap: 8px; padding: 12px 14px; background: #11131a; border: 1px solid #2a2a35; border-top: 0; font-size: 12px; align-items: center; }
  .lt-q-row:last-of-type { border-radius: 0 0 10px 10px; }
  .lt-q-row .name { color: #f3f4f8; font-weight: 600; }
  .lt-q-row .name small { display: block; font-family: 'Geist Mono', monospace; font-size: 9px; color: #6b7280; letter-spacing: 0.06em; margin-top: 2px; }
  .lt-q-row .model { color: #cfd6da; font-family: 'Geist Mono', monospace; font-size: 11px; }
  .lt-q-row .task { color: #c4b5fd; font-family: 'Geist Mono', monospace; font-size: 11px; }
  .lt-q-row .compute { color: #67e8f9; font-family: 'Geist Mono', monospace; font-size: 11px; }
  .lt-q-row .status-cell { display: flex; flex-direction: column; gap: 4px; }
  .lt-pill { display: inline-block; padding: 2px 8px; border-radius: 10px; font-family: 'Geist Mono', monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 700; width: fit-content; }
  .lt-pill.queued { background: rgba(156, 163, 175, 0.15); color: #d1d5db; border: 1px solid rgba(156, 163, 175, 0.4); }
  .lt-pill.running { background: rgba(103, 232, 249, 0.12); color: #67e8f9; border: 1px solid rgba(103, 232, 249, 0.4); }
  .lt-pill.done { background: rgba(134, 239, 172, 0.12); color: #86efac; border: 1px solid rgba(134, 239, 172, 0.4); }
  .lt-pill.failed { background: rgba(248, 113, 113, 0.12); color: #fca5a5; border: 1px solid rgba(248, 113, 113, 0.4); }
  .lt-bar { height: 6px; background: #0a0a0c; border-radius: 3px; overflow: hidden; }
  .lt-bar-fill { height: 100%; background: linear-gradient(90deg, #a78bfa, #67e8f9); transition: width 0.5s; }
  .lt-q-row .actions button { background: transparent; border: 1px solid #2a2a35; color: #67e8f9; padding: 5px 9px; border-radius: 5px; font-family: 'Geist Mono', monospace; font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer; }
  .lt-q-row .actions button:hover { border-color: #67e8f9; background: rgba(103, 232, 249, 0.05); }

  .lt-curve-row { grid-column: 1 / -1; background: #0d0f15; border: 1px solid #2a2a35; border-top: 0; padding: 14px 18px 18px; display: none; }
  .lt-curve-row.open { display: block; }
  .lt-curve-row h4 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 10px; }
  .lt-curve-row canvas { width: 100%; height: 180px; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; display: block; }
  .lt-curve-meta { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 8px; margin-top: 10px; }
  .lt-curve-meta-i { background: #11131a; border: 1px solid #2a2a35; border-radius: 6px; padding: 8px 10px; }
  .lt-curve-meta-l { font-family: 'Geist Mono', monospace; font-size: 9px; color: #9aa6b6; letter-spacing: 0.1em; text-transform: uppercase; }
  .lt-curve-meta-v { font-family: 'Cormorant Garamond', serif; font-size: 18px; color: #fff; font-weight: 600; }

  .lt-empty { padding: 30px; text-align: center; background: #11131a; border: 1px dashed #2a2a35; border-radius: 10px; color: #6b7280; font-family: 'Geist Mono', monospace; font-size: 12px; }

  @media (max-width: 900px) {
    .lt-q-head { display: none; }
    .lt-q-row { grid-template-columns: 1fr; gap: 6px; padding: 14px; }
    .lt-q-row .actions { justify-self: start; }
  }
</style>

<main class="lt-wrap">
  <div class="lt-eye">Lab · LLM Training Orchestrator</div>
  <h1 class="lt-title">Fine-tune frontier open-weight models on <em>reserved</em> compute</h1>
  <p class="lt-sub">Configure a training job &mdash; base model, dataset, task type, hyperparameters, and compute target &mdash; and submit it to the AquinTutor scheduler. Pipeline stages are tracked end-to-end. Loss curves stream back as the run progresses.</p>

  {okMsg && <div class="lt-flash ok">{okMsg}</div>}
  {errMsg && <div class="lt-flash err">{errMsg}</div>}

  <!-- Five-stage pipeline visualization -->
  <div class="lt-pipe">
    <div class="lt-stage">
      <div class="lt-stage-n">Stage 01</div>
      <div class="lt-stage-t">Data prep</div>
      <div class="lt-stage-d">Tokenisation, packing, deduplication, train/val split.</div>
    </div>
    <div class="lt-stage">
      <div class="lt-stage-n">Stage 02</div>
      <div class="lt-stage-t">Compute reserve</div>
      <div class="lt-stage-d">GPU allocation, container build, weight checkpoint pull.</div>
    </div>
    <div class="lt-stage">
      <div class="lt-stage-n">Stage 03</div>
      <div class="lt-stage-t">Train</div>
      <div class="lt-stage-d">Optimisation loop, gradient sync, checkpoint every N steps.</div>
    </div>
    <div class="lt-stage">
      <div class="lt-stage-n">Stage 04</div>
      <div class="lt-stage-t">Eval</div>
      <div class="lt-stage-d">Held-out perplexity, instruction win-rate, safety probes.</div>
    </div>
    <div class="lt-stage">
      <div class="lt-stage-n">Stage 05</div>
      <div class="lt-stage-t">Deploy</div>
      <div class="lt-stage-d">Endpoint provisioning or hub upload of merged weights.</div>
    </div>
  </div>

  <div class="lt-grid">
    <form method="POST" class="lt-panel" id="ltForm">
      <h3>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
        New training job
      </h3>

      <div class="lt-row full">
        <div class="lt-field">
          <label>Job name</label>
          <input type="text" name="job_name" required placeholder="e.g. legal-precedent-summariser-v2" />
        </div>
      </div>

      <div class="lt-row">
        <div class="lt-field">
          <label>Base model</label>
          <select name="base_model" id="baseModelSel" required>
            <option value="">Select a base model</option>
            <optgroup label="Llama 3">
              <option value="Llama 3 1B">Llama 3 1B</option>
              <option value="Llama 3 8B">Llama 3 8B</option>
              <option value="Llama 3 70B">Llama 3 70B</option>
              <option value="Llama 3 405B">Llama 3 405B</option>
            </optgroup>
            <optgroup label="Mistral">
              <option value="Mistral 7B">Mistral 7B</option>
              <option value="Mixtral 8x7B">Mixtral 8x7B (MoE)</option>
            </optgroup>
            <optgroup label="Qwen">
              <option value="Qwen 2.5 7B">Qwen 2.5 7B</option>
              <option value="Qwen 2.5 72B">Qwen 2.5 72B</option>
            </optgroup>
            <optgroup label="Other">
              <option value="Gemma 2 9B">Gemma 2 9B</option>
              <option value="Phi-3 mini">Phi-3 mini</option>
              <option value="Phi-3 medium">Phi-3 medium</option>
              <option value="DeepSeek V3">DeepSeek V3</option>
              <option value="Aya 8B Indic">Aya 8B Indic</option>
              <option value="Custom">Custom (URL)</option>
            </optgroup>
          </select>
        </div>
        <div class="lt-field">
          <label>Task type</label>
          <select name="task_type" id="taskTypeSel" required>
            <option value="Instruct">Instruct fine-tune</option>
            <option value="Chat">Chat fine-tune</option>
            <option value="Continual">Continual pretrain</option>
            <option value="DPO">DPO (preference)</option>
            <option value="LoRA">LoRA</option>
            <option value="QLoRA">QLoRA (4-bit)</option>
          </select>
        </div>
      </div>

      <div class="lt-row full" id="customRow" style="display: none;">
        <div class="lt-field">
          <label>Custom weights URL</label>
          <input type="url" name="custom_url" placeholder="https://hub.example/your-org/your-model" />
          <div class="hint">HF-format directory, GGUF, or safetensors archive.</div>
        </div>
      </div>

      <div class="lt-row">
        <div class="lt-field">
          <label>Dataset URL</label>
          <input type="url" name="dataset_url" required placeholder="s3://... or https://..." />
          <div class="hint">Parquet, JSONL, or HF dataset URI.</div>
        </div>
        <div class="lt-field">
          <label>Dataset size (rows)</label>
          <input type="number" name="dataset_size" min="100" step="1000" placeholder="50000" />
          <div class="hint">Approximate row count, used for cost preview.</div>
        </div>
      </div>

      <div class="lt-row full">
        <div class="lt-field">
          <label>Compute target</label>
          <select name="compute_target" id="computeSel" required>
            <option value="4x H100">4x H100 (single-node)</option>
            <option value="8x H100" selected>8x H100 (single-node)</option>
            <option value="32x H100">32x H100 (4-node)</option>
            <option value="8x A100">8x A100 (single-node)</option>
            <option value="16x Trainium">16x Trainium</option>
            <option value="CPU debug">CPU debug (tiny runs only)</option>
          </select>
        </div>
      </div>

      <h3 style="margin-top: 22px;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        Hyperparameters
      </h3>

      <div class="lt-hyper">
        <div class="lt-field">
          <label>Learning rate</label>
          <input type="number" name="learning_rate" step="0.000001" min="0.0000001" value="0.00005" />
        </div>
        <div class="lt-field">
          <label>Batch size</label>
          <input type="number" name="batch_size" min="1" step="1" value="8" />
        </div>
        <div class="lt-field">
          <label>Epochs</label>
          <input type="number" name="epochs" min="1" max="50" step="1" value="3" />
        </div>
        <div class="lt-field">
          <label>Gradient accumulation</label>
          <input type="number" name="grad_accum" min="1" step="1" value="1" />
        </div>
        <div class="lt-field">
          <label>Sequence length</label>
          <input type="number" name="seq_length" min="128" step="128" value="2048" />
        </div>
        <div class="lt-field">
          <label>Warmup steps</label>
          <input type="number" name="warmup_steps" min="0" step="10" value="100" />
        </div>
        <div class="lt-field">
          <label>Weight decay</label>
          <input type="number" name="weight_decay" step="0.001" min="0" value="0.01" />
        </div>
        <div class="lt-field" id="loraRow" style="display: none;">
          <label>LoRA rank</label>
          <input type="number" name="lora_rank" min="1" max="256" step="1" value="8" />
          <div class="hint">Typical: 8&ndash;64 for LoRA; 16&ndash;32 for QLoRA.</div>
        </div>
      </div>

      <div class="lt-actions">
        <button type="submit" class="lt-btn-p">Queue training job</button>
        <button type="button" class="lt-btn-g" id="ltReset">Reset form</button>
      </div>
    </form>

    <aside class="lt-panel" id="ltCost">
      <h3>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        Cost &amp; time estimate
      </h3>
      <div class="lt-cost">
        <div class="lt-cost-row">
          <span class="lt-cost-lbl">Wall-clock estimate</span>
          <span class="lt-cost-val cyan" id="estTime">&mdash;</span>
        </div>
        <div class="lt-cost-row">
          <span class="lt-cost-lbl">Tokens processed</span>
          <span class="lt-cost-val" id="estTokens">&mdash;</span>
        </div>
        <div class="lt-cost-row">
          <span class="lt-cost-lbl">GPU-hours billed</span>
          <span class="lt-cost-val accent" id="estGpuHrs">&mdash;</span>
        </div>
        <div class="lt-cost-row">
          <span class="lt-cost-lbl">Effective batch size</span>
          <span class="lt-cost-val" id="estEffBatch">&mdash;</span>
        </div>
        <div class="lt-cost-row">
          <span class="lt-cost-lbl">Memory footprint</span>
          <span class="lt-cost-val" id="estMem">&mdash;</span>
        </div>
      </div>
      <p style="font-size: 11px; color: #6b7280; margin: 14px 0 0; line-height: 1.55; font-family: 'Geist Mono', monospace;">
        Heuristic preview only. Real billing reflects actual GPU-second consumption after the run completes.
      </p>
    </aside>
  </div>

  <!-- Job queue -->
  <section class="lt-queue">
    <h3 style="font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 12px;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: -3px; margin-right: 6px;"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
      Recent jobs
    </h3>

    {jobsForClient.length === 0 ? (
      <div class="lt-empty">No jobs yet. Submit the form above to queue your first training run.</div>
    ) : (
      <div>
        <div class="lt-q-head">
          <div>Job</div><div>Base model</div><div>Task</div><div>Compute</div><div>Status</div><div></div>
        </div>
        {jobsForClient.map((j) => (
          <>
            <div class="lt-q-row" data-job-id={j.id}>
              <div class="name">{j.job_name}<small>{new Date(j.created_at).toLocaleString()}</small></div>
              <div class="model">{j.base_model}</div>
              <div class="task">{j.task_type}</div>
              <div class="compute">{j.compute_target}</div>
              <div class="status-cell">
                <span class={`lt-pill ${j.status === 'completed' ? 'done' : (j.status === 'running' ? 'running' : (j.status === 'failed' ? 'failed' : 'queued'))}`}>{j.status}</span>
                <div class="lt-bar"><div class="lt-bar-fill" style={`width: ${j.progress_pct}%`}></div></div>
              </div>
              <div class="actions"><button type="button" class="lt-toggle-curve" data-target={`curve-${j.id}`}>Loss curve</button></div>
            </div>
            <div class="lt-curve-row" id={`curve-${j.id}`}>
              <h4>Training loss &mdash; {j.job_name}</h4>
              <canvas data-curve={JSON.stringify(j.loss_curve)} data-hp={JSON.stringify(j.hyperparams)}></canvas>
              <div class="lt-curve-meta">
                <div class="lt-curve-meta-i"><div class="lt-curve-meta-l">Initial loss</div><div class="lt-curve-meta-v">{j.loss_curve[0]?.toFixed(3) ?? '-'}</div></div>
                <div class="lt-curve-meta-i"><div class="lt-curve-meta-l">Final loss</div><div class="lt-curve-meta-v">{j.loss_curve[j.loss_curve.length - 1]?.toFixed(3) ?? '-'}</div></div>
                <div class="lt-curve-meta-i"><div class="lt-curve-meta-l">Steps</div><div class="lt-curve-meta-v">{j.loss_curve.length}</div></div>
                <div class="lt-curve-meta-i"><div class="lt-curve-meta-l">Final perplexity</div><div class="lt-curve-meta-v">{Math.exp(j.loss_curve[j.loss_curve.length - 1] || 0).toFixed(2)}</div></div>
                <div class="lt-curve-meta-i"><div class="lt-curve-meta-l">LR</div><div class="lt-curve-meta-v">{(j.hyperparams?.learning_rate ?? 0).toExponential(1)}</div></div>
              </div>
            </div>
          </>
        ))}
      </div>
    )}
  </section>
</main>

<script is:inline>
(function () {
  // ---- Form: toggle Custom URL row + LoRA rank row + cost estimator ----
  var baseSel = document.getElementById('baseModelSel');
  var taskSel = document.getElementById('taskTypeSel');
  var computeSel = document.getElementById('computeSel');
  var customRow = document.getElementById('customRow');
  var loraRow = document.getElementById('loraRow');
  var form = document.getElementById('ltForm');
  var resetBtn = document.getElementById('ltReset');

  // Model parameter counts (billions) for cost estimation
  var MODEL_PARAMS_B = {
    'Llama 3 1B': 1.0, 'Llama 3 8B': 8.0, 'Llama 3 70B': 70.0, 'Llama 3 405B': 405.0,
    'Mistral 7B': 7.0, 'Mixtral 8x7B': 47.0,
    'Qwen 2.5 7B': 7.0, 'Qwen 2.5 72B': 72.0,
    'Gemma 2 9B': 9.0, 'Phi-3 mini': 3.8, 'Phi-3 medium': 14.0,
    'DeepSeek V3': 671.0, 'Aya 8B Indic': 8.0, 'Custom': 7.0
  };
  // Effective TFLOPs per second for compute targets (FP16, with utilisation)
  var COMPUTE_TFLOPS = {
    '4x H100': 4 * 989 * 0.45, '8x H100': 8 * 989 * 0.45, '32x H100': 32 * 989 * 0.40,
    '8x A100': 8 * 312 * 0.45, '16x Trainium': 16 * 380 * 0.40,
    'CPU debug': 0.5
  };
  var GPU_PER_HOUR = {
    '4x H100': 4 * 3.5, '8x H100': 8 * 3.5, '32x H100': 32 * 3.5,
    '8x A100': 8 * 2.0, '16x Trainium': 16 * 1.3, 'CPU debug': 0.05
  };

  function readNum(name, def) {
    var el = form && form.querySelector('[name="' + name + '"]');
    if (!el) return def;
    var v = parseFloat(el.value);
    return isNaN(v) ? def : v;
  }
  function fmtHrs(h) {
    if (h < 1 / 60) return (h * 3600).toFixed(0) + ' s';
    if (h < 1) return (h * 60).toFixed(1) + ' min';
    if (h < 48) return h.toFixed(1) + ' h';
    return (h / 24).toFixed(1) + ' d';
  }
  function fmtTokens(n) {
    if (n < 1e6) return (n / 1e3).toFixed(1) + 'K';
    if (n < 1e9) return (n / 1e6).toFixed(2) + 'M';
    if (n < 1e12) return (n / 1e9).toFixed(2) + 'B';
    return (n / 1e12).toFixed(2) + 'T';
  }

  function recalc() {
    if (!form) return;
    var model = (baseSel && baseSel.value) || '';
    var task = (taskSel && taskSel.value) || 'Instruct';
    var compute = (computeSel && computeSel.value) || '8x H100';
    var rows = readNum('dataset_size', 50000);
    var seq = readNum('seq_length', 2048);
    var bs = readNum('batch_size', 8);
    var ga = readNum('grad_accum', 1);
    var epochs = readNum('epochs', 3);
    var lora = readNum('lora_rank', 8);

    var pB = MODEL_PARAMS_B[model] || 7;
    var tflops = COMPUTE_TFLOPS[compute] || 1;
    var perHour = GPU_PER_HOUR[compute] || 1;

    var tokens = rows * seq * epochs;
    // FLOPs/token  approx  6 * P (full FT), 2 * P (forward only / LoRA-ish factor)
    var paramScale = (task === 'LoRA' || task === 'QLoRA') ? (lora / 64) : 1.0;
    var flopsPerToken = 6 * pB * 1e9 * paramScale;
    var totalFlops = tokens * flopsPerToken;
    var seconds = totalFlops / (tflops * 1e12);
    var hours = seconds / 3600;

    // Memory: weights bytes (fp16 = 2 B/param), grads + optimiser ~4x for AdamW (full FT), ~1.2x for LoRA
    var memMult = (task === 'LoRA') ? 1.4 : (task === 'QLoRA' ? 0.6 : 4.0);
    var memGB = pB * 2 * memMult;

    var effBatch = bs * ga;
    var cost = hours * perHour;

    var elTime = document.getElementById('estTime');
    var elTok = document.getElementById('estTokens');
    var elGpu = document.getElementById('estGpuHrs');
    var elBatch = document.getElementById('estEffBatch');
    var elMem = document.getElementById('estMem');
    if (elTime) elTime.textContent = fmtHrs(hours);
    if (elTok) elTok.textContent = fmtTokens(tokens);
    if (elGpu) elGpu.textContent = hours.toFixed(2) + ' h';
    if (elBatch) elBatch.textContent = effBatch + ' samples';
    if (elMem) elMem.textContent = memGB.toFixed(1) + ' GB';
  }

  function syncToggles() {
    if (customRow) customRow.style.display = (baseSel && baseSel.value === 'Custom') ? '' : 'none';
    if (loraRow) loraRow.style.display = (taskSel && (taskSel.value === 'LoRA' || taskSel.value === 'QLoRA')) ? '' : 'none';
    recalc();
  }

  if (form) {
    form.addEventListener('input', recalc);
    form.addEventListener('change', syncToggles);
    syncToggles();
  }
  if (resetBtn) resetBtn.addEventListener('click', function () { form.reset(); syncToggles(); });

  // ---- Loss curve canvases ----
  function drawCurve(canvas) {
    var raw = canvas.getAttribute('data-curve');
    if (!raw) return;
    var pts;
    try { pts = JSON.parse(raw); } catch (e) { return; }
    if (!pts || !pts.length) return;
    var dpr = window.devicePixelRatio || 1;
    var rect = canvas.getBoundingClientRect();
    var W = Math.max(300, Math.floor(rect.width));
    var H = 180;
    canvas.width = W * dpr; canvas.height = H * dpr;
    canvas.style.height = H + 'px';
    var ctx = canvas.getContext('2d');
    ctx.scale(dpr, dpr);
    ctx.fillStyle = '#0a0a0c';
    ctx.fillRect(0, 0, W, H);

    var pad = { l: 44, r: 14, t: 14, b: 26 };
    var pw = W - pad.l - pad.r;
    var ph = H - pad.t - pad.b;
    var minL = Math.min.apply(null, pts);
    var maxL = Math.max.apply(null, pts);
    var span = Math.max(0.05, maxL - minL);
    minL -= span * 0.1; maxL += span * 0.1;
    span = maxL - minL;

    // grid
    ctx.strokeStyle = '#1c1e26'; ctx.lineWidth = 1;
    ctx.font = "10px 'Geist Mono', monospace"; ctx.fillStyle = '#6b7280';
    for (var i = 0; i <= 4; i++) {
      var y = pad.t + (ph * i) / 4;
      ctx.beginPath(); ctx.moveTo(pad.l, y); ctx.lineTo(W - pad.r, y); ctx.stroke();
      var v = maxL - (span * i) / 4;
      ctx.fillText(v.toFixed(2), 6, y + 3);
    }
    for (var k = 0; k <= 4; k++) {
      var x = pad.l + (pw * k) / 4;
      ctx.beginPath(); ctx.moveTo(x, pad.t); ctx.lineTo(x, H - pad.b); ctx.stroke();
      var step = Math.round((pts.length * k) / 4);
      ctx.fillText(String(step), x - 8, H - 8);
    }

    // axis labels
    ctx.fillStyle = '#9aa6b6'; ctx.font = "9px 'Geist Mono', monospace";
    ctx.fillText('LOSS', 8, 16);
    ctx.fillText('STEP', W - pad.r - 28, H - 8);

    // gradient fill under curve
    var grad = ctx.createLinearGradient(0, pad.t, 0, H - pad.b);
    grad.addColorStop(0, 'rgba(103, 232, 249, 0.25)');
    grad.addColorStop(1, 'rgba(167, 139, 250, 0)');
    ctx.fillStyle = grad;
    ctx.beginPath();
    for (var j = 0; j < pts.length; j++) {
      var px = pad.l + (pw * j) / (pts.length - 1);
      var py = pad.t + ph * (1 - (pts[j] - minL) / span);
      if (j === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
    }
    ctx.lineTo(pad.l + pw, H - pad.b);
    ctx.lineTo(pad.l, H - pad.b);
    ctx.closePath(); ctx.fill();

    // line stroke
    ctx.strokeStyle = '#67e8f9'; ctx.lineWidth = 1.6;
    ctx.beginPath();
    for (var m = 0; m < pts.length; m++) {
      var qx = pad.l + (pw * m) / (pts.length - 1);
      var qy = pad.t + ph * (1 - (pts[m] - minL) / span);
      if (m === 0) ctx.moveTo(qx, qy); else ctx.lineTo(qx, qy);
    }
    ctx.stroke();

    // smoothed (EMA) overlay
    ctx.strokeStyle = '#a78bfa'; ctx.lineWidth = 1.2; ctx.setLineDash([4, 3]);
    ctx.beginPath();
    var ema = pts[0]; var alpha = 0.15;
    for (var n = 0; n < pts.length; n++) {
      ema = alpha * pts[n] + (1 - alpha) * ema;
      var rx = pad.l + (pw * n) / (pts.length - 1);
      var ry = pad.t + ph * (1 - (ema - minL) / span);
      if (n === 0) ctx.moveTo(rx, ry); else ctx.lineTo(rx, ry);
    }
    ctx.stroke(); ctx.setLineDash([]);
  }

  // Expand/collapse loss curve
  var toggles = document.querySelectorAll('.lt-toggle-curve');
  toggles.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var tid = btn.getAttribute('data-target');
      var row = document.getElementById(tid);
      if (!row) return;
      var nowOpen = !row.classList.contains('open');
      row.classList.toggle('open');
      btn.textContent = nowOpen ? 'Hide' : 'Loss curve';
      if (nowOpen) {
        var canvas = row.querySelector('canvas');
        if (canvas) setTimeout(function () { drawCurve(canvas); }, 30);
      }
    });
  });

  // Redraw any open curves on resize
  window.addEventListener('resize', function () {
    document.querySelectorAll('.lt-curve-row.open canvas').forEach(drawCurve);
  });
})();
</script>

</BaseLayout>
