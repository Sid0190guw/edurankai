---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;

let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const job_name = (fd.get('job_name') as string || '').trim();
    const base_model = (fd.get('base_model') as string || '').trim();
    const dataset_url = (fd.get('dataset_url') as string || '').trim();
    const task_type = (fd.get('task_type') as string || '').trim();
    const epochs = parseInt(fd.get('epochs') as string, 10) || 3;
    const learning_rate = parseFloat(fd.get('learning_rate') as string) || 5e-5;
    const batch_size = parseInt(fd.get('batch_size') as string, 10) || 8;
    const compute_target = (fd.get('compute_target') as string || '').trim();
    if (!job_name || !base_model || !dataset_url) errMsg = 'Job name, base model, and dataset URL required.';
    else {
      const { db } = await import('@/lib/db');
      const { sql } = await import('drizzle-orm');
      await db.execute(sql`CREATE TABLE IF NOT EXISTS training_jobs (
        id UUID PRIMARY KEY DEFAULT gen_random_uuid(), user_id UUID, job_name VARCHAR(200),
        base_model VARCHAR(200), dataset_url TEXT, task_type VARCHAR(40),
        epochs INT, learning_rate DECIMAL(10,8), batch_size INT, compute_target VARCHAR(40),
        status VARCHAR(20) DEFAULT 'queued', progress_pct INT DEFAULT 0,
        created_at TIMESTAMPTZ DEFAULT NOW())`);
      await db.execute(sql`INSERT INTO training_jobs (user_id, job_name, base_model, dataset_url, task_type, epochs, learning_rate, batch_size, compute_target)
        VALUES (${user?.id || null}, ${job_name}, ${base_model}, ${dataset_url}, ${task_type}, ${epochs}, ${learning_rate}, ${batch_size}, ${compute_target})`);
      okMsg = 'Training job queued. Compute provisioning begins within 15 minutes. You will be notified when it starts.';
    }
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 240); }
}
---
<BaseLayout title="LLM training · AquinTutor" description="Fine-tune your own large language model on EduRankAI compute. LoRA + full fine-tunes, mixture-of-experts, multi-node training.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; }
  .tr-wrap { max-width: 1280px; margin: 0 auto; padding: 24px 4vw 80px; }
  .tr-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .tr-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 6vw, 72px); font-weight: 600; letter-spacing: -0.03em; margin: 8px 0 14px; line-height: 1; }
  .tr-title em { background: linear-gradient(135deg, #FF4F00, #fbbf24); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; font-style: italic; font-weight: 500; }
  .tr-sub { font-size: 17px; color: #9aa6b6; max-width: 720px; line-height: 1.65; }

  .tr-strip { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 10px; margin: 30px 0 40px; }
  .tr-stat { background: #11131a; border: 1px solid #2a2a35; border-radius: 10px; padding: 16px 18px; }
  .tr-stat-val { font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 600; color: #fff; line-height: 1; }
  .tr-stat-lbl { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: #9aa6b6; margin-top: 5px; font-weight: 700; }

  .tr-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-bottom: 32px; }
  @media (max-width: 900px) { .tr-grid { grid-template-columns: 1fr; } }
  .tr-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 14px; padding: 22px; }
  .tr-panel h3 { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin: 0 0 14px; }
  .tr-panel h2 { font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 600; margin: 0 0 8px; letter-spacing: -0.02em; line-height: 1.2; }
  .tr-panel p { font-size: 13.5px; color: #cfd6da; line-height: 1.65; margin: 0 0 12px; }

  .tr-chip { font-family: 'Geist Mono', monospace; font-size: 10.5px; padding: 4px 10px; border-radius: 100px; background: rgba(255,79,0,0.15); color: #FF4F00; border: 1px solid rgba(255,79,0,0.3); font-weight: 600; display: inline-block; margin: 2px; }

  .tr-form { background: #11131a; border: 1px solid #2a2a35; border-radius: 14px; padding: 24px; }
  .tr-form input, .tr-form select, .tr-form textarea { width: 100%; box-sizing: border-box; background: #0a0a0c; border: 1px solid #2a2a35; color: #fff; padding: 9px 12px; border-radius: 6px; font-family: inherit; font-size: 13px; margin-bottom: 10px; }
  .tr-form label { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; margin-bottom: 5px; display: block; }
  .tr-form button { background: #FF4F00; color: #fff; padding: 11px 26px; border-radius: 8px; border: none; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700; }

  .tr-pipeline { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 10px; margin-top: 20px; }
  .tr-stage { background: #1a1a25; border: 1px solid #2a2a35; border-radius: 10px; padding: 14px; }
  .tr-stage-n { font-family: 'Geist Mono', monospace; font-size: 22px; color: #FF4F00; font-weight: 700; line-height: 1; }
  .tr-stage-t { font-family: 'Cormorant Garamond', serif; font-size: 17px; color: #fff; margin: 6px 0 4px; font-weight: 600; }
  .tr-stage-d { font-size: 12px; color: #9aa6b6; line-height: 1.55; }
</style>

<main class="tr-wrap">

  <header>
    <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#FF4F00;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
    <p class="tr-eye" style="margin-top:14px;">AquinTutor · LLM training</p>
    <h1 class="tr-title">Train your own <em>model</em>.</h1>
    <p class="tr-sub">Fine-tune your own large language model on EduRankAI compute infrastructure. LoRA or full fine-tunes. Vision-language. Speech. Up to 70B parameters on shared multi-node clusters, larger on dedicated bookings.</p>
  </header>

  <div class="tr-strip">
    <div class="tr-stat"><p class="tr-stat-val">256</p><p class="tr-stat-lbl">GPUs in pool</p></div>
    <div class="tr-stat"><p class="tr-stat-val">70B</p><p class="tr-stat-lbl">Max shared</p></div>
    <div class="tr-stat"><p class="tr-stat-val">405B</p><p class="tr-stat-lbl">Max dedicated</p></div>
    <div class="tr-stat"><p class="tr-stat-val">15 min</p><p class="tr-stat-lbl">Cold-start SLA</p></div>
    <div class="tr-stat"><p class="tr-stat-val">98.7%</p><p class="tr-stat-lbl">Uptime</p></div>
  </div>

  <div class="tr-grid">
    <article class="tr-panel">
      <h3>What we provide</h3>
      <h2>Production training stack.</h2>
      <p>Multi-node training out of the box. Mixed precision (fp16/bf16). Gradient checkpointing. Optimizer states off-loaded to CPU. Tensor + pipeline parallelism for models above 8B.</p>
      <div style="margin-top:10px;">
        <span class="tr-chip">LoRA / QLoRA</span><span class="tr-chip">Full fine-tune</span><span class="tr-chip">DPO + RLHF</span>
        <span class="tr-chip">MoE training</span><span class="tr-chip">Continual pre-training</span><span class="tr-chip">Vision-language</span>
        <span class="tr-chip">Speech / ASR</span><span class="tr-chip">Text-to-speech</span>
      </div>
    </article>

    <article class="tr-panel">
      <h3>Supported base models</h3>
      <h2>Bring any open model.</h2>
      <p>Llama 3 (1B-405B), Mistral, Mixtral, Qwen, Gemma, Phi-3, DeepSeek, Yi, Aya, plus Indic-language base models. Bring your own weights via Hugging Face Hub or a private bucket.</p>
      <div style="margin-top:10px;">
        <span class="tr-chip">Llama 3 · all sizes</span><span class="tr-chip">Mistral / Mixtral</span><span class="tr-chip">Qwen 2.5</span>
        <span class="tr-chip">Gemma 2</span><span class="tr-chip">Phi-3</span><span class="tr-chip">DeepSeek-V3</span>
        <span class="tr-chip">Aya · Indic</span><span class="tr-chip">Your weights</span>
      </div>
    </article>
  </div>

  <article class="tr-panel" style="margin-bottom:32px;">
    <h3>Training pipeline</h3>
    <h2>Five-stage workflow.</h2>
    <div class="tr-pipeline">
      <div class="tr-stage"><p class="tr-stage-n">01</p><p class="tr-stage-t">Data prep</p><p class="tr-stage-d">Upload JSONL / parquet. Auto-validate schema. Dedup. PII scrub. Tokenise.</p></div>
      <div class="tr-stage"><p class="tr-stage-n">02</p><p class="tr-stage-t">Compute reserve</p><p class="tr-stage-d">Pick H100 / A100 / Trainium. Slot booked or spot-priced.</p></div>
      <div class="tr-stage"><p class="tr-stage-n">03</p><p class="tr-stage-t">Train</p><p class="tr-stage-d">Live loss + gradient + GPU utilisation. WandB-style dashboards.</p></div>
      <div class="tr-stage"><p class="tr-stage-n">04</p><p class="tr-stage-t">Eval</p><p class="tr-stage-d">Auto MMLU / Hellaswag / GSM-8k / your held-out set.</p></div>
      <div class="tr-stage"><p class="tr-stage-n">05</p><p class="tr-stage-t">Deploy</p><p class="tr-stage-d">One-click inference endpoint. Optional quantise + serve.</p></div>
    </div>
  </article>

  {okMsg && <div style="background:rgba(134,239,172,0.08);border:1px solid #86efac;padding:14px 18px;border-radius:10px;margin-bottom:14px;"><p style="color:#86efac;font-weight:600;margin:0;">{okMsg}</p></div>}
  {errMsg && <div style="background:rgba(248,113,113,0.08);border:1px solid #f87171;padding:14px 18px;border-radius:10px;margin-bottom:14px;"><p style="color:#f87171;font-weight:600;margin:0;">{errMsg}</p></div>}

  {!okMsg && (
    <form method="POST" class="tr-form">
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:600;margin:0 0 14px;letter-spacing:-0.02em;color:#fff;">Queue a training <em style="color:#FF4F00;font-style:italic;">job</em>.</h2>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div><label>Job name *</label><input name="job_name" required maxlength="200" placeholder="e.g. sanskrit-llama3-8b-lora-v3"/></div>
        <div><label>Base model *</label><select name="base_model" required>
          <option value="llama-3-1b">Llama 3 · 1B</option>
          <option value="llama-3-8b">Llama 3 · 8B</option>
          <option value="llama-3-70b">Llama 3 · 70B</option>
          <option value="mistral-7b">Mistral · 7B</option>
          <option value="mixtral-8x7b">Mixtral · 8x7B (MoE)</option>
          <option value="qwen-2.5-7b">Qwen 2.5 · 7B</option>
          <option value="qwen-2.5-32b">Qwen 2.5 · 32B</option>
          <option value="gemma-2-9b">Gemma 2 · 9B</option>
          <option value="phi-3-mini">Phi-3 · Mini</option>
          <option value="deepseek-v3">DeepSeek V3</option>
          <option value="aya-23-8b">Aya 23 · 8B (Indic)</option>
          <option value="custom">Custom (paste weights URL)</option>
        </select></div>
      </div>
      <label>Dataset URL (HuggingFace / private bucket / S3 / GCS) *</label>
      <input name="dataset_url" type="url" required placeholder="hf://username/dataset OR s3://bucket/key"/>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;">
        <div><label>Task type</label><select name="task_type"><option value="instruct">Instruct fine-tune</option><option value="chat">Chat fine-tune</option><option value="continual_pretrain">Continual pre-training</option><option value="dpo">DPO preference</option><option value="lora">LoRA adapter</option><option value="qlora">QLoRA 4-bit</option></select></div>
        <div><label>Epochs</label><input name="epochs" type="number" min="1" max="20" value="3"/></div>
        <div><label>Learning rate</label><input name="learning_rate" type="number" step="0.000001" value="0.00005"/></div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div><label>Batch size (per device)</label><input name="batch_size" type="number" min="1" max="64" value="8"/></div>
        <div><label>Compute target</label><select name="compute_target">
          <option value="h100_4x">4× H100 (shared)</option><option value="h100_8x">8× H100 (shared)</option>
          <option value="h100_32x">32× H100 (dedicated)</option><option value="a100_8x">8× A100</option>
          <option value="trainium_16x">16× Trainium</option><option value="cpu">CPU (debug)</option>
        </select></div>
      </div>
      <button type="submit" style="margin-top:6px;">Queue job</button>
      <p style="font-family:'Geist Mono',monospace;font-size:10.5px;color:#9aa6b6;margin-top:10px;letter-spacing:0.04em;">Estimated cost shown after queue. Spot pricing available — your job may be pre-empted between epochs but checkpoints survive.</p>
    </form>
  )}

</main>
</BaseLayout>
