---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Kinetic gas lab — N molecules with elastic wall + pairwise collisions,
// temperature/pressure emergent from the dynamics, and a live speed histogram
// that relaxes to the Maxwell-Boltzmann distribution. Depth-lit high-DPI canvas.
---
<BaseLayout title="Molecular motion lab · Virtual Labs · AquinTutor" description="A box of molecules in elastic motion — watch temperature, pressure and the Maxwell-Boltzmann speed distribution emerge from the collisions themselves.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1320px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:18px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; }
  .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:290px minmax(0,1fr); gap:18px; }
  @media(max-width:900px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:16px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 12px; }
  .lb-row{ display:grid; gap:9px; }
  .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.1em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; }
  .lb-row label span{ color:#5ee7ff; } .lb-row input[type=range]{ width:100%; accent-color:#5ee7ff; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); }
  .lb-stage canvas{ display:block; width:100%; height:auto; }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11.5px; padding:5px 0; border-bottom:1px solid #141a2c; }
  .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#5ee7ff; font-weight:700; text-align:right; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">Chemistry · Kinetic theory</p>
      <h1 class="lb-title">Molecular <em>motion</em>.</h1>
    </div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Gas</h3><div class="lb-row">
        <label>Molecules <span id="nV">120</span></label><input id="n" type="range" min="20" max="220" step="10" value="120"/>
        <label>Temperature <span id="tV">300</span></label><input id="temp" type="range" min="60" max="900" step="10" value="300"/>
        <label>Molecule radius <span id="rV">4</span></label><input id="rad" type="range" min="2" max="8" step="0.5" value="4"/>
      </div></div>
      <div class="lb-panel"><h3>Emergent state</h3>
        <div class="lb-metric"><span class="lb-metric-l">⟨KE⟩ ∝ T</span><span class="lb-metric-v" id="mKE">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Pressure (a.u.)</span><span class="lb-metric-v" id="mP">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">v_rms</span><span class="lb-metric-v" id="mVr">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Collisions/s</span><span class="lb-metric-v" id="mC">—</span></div>
      </div>
    </aside>
    <section><div class="lb-stage"><canvas id="scene" width="900" height="560"></canvas></div></section>
  </div>
</main>
<script is:inline>
(function(){
  function v(id){ return parseFloat(document.getElementById(id).value); }
  var mol=[], pressAcc=0, collCount=0, tPrev=0;
  var Wm=560, Hm=380; // world box
  function sync(){ document.getElementById('nV').textContent=v('n').toFixed(0); document.getElementById('tV').textContent=v('temp').toFixed(0); document.getElementById('rV').textContent=v('rad').toFixed(1); }
  function speedForT(){ return Math.sqrt(v('temp'))*0.9; }
  function init(){ mol=[]; var N=v('n'), sp=speedForT(); for(var i=0;i<N;i++){ var a=Math.random()*7; mol.push({ x:20+Math.random()*(Wm-40), y:20+Math.random()*(Hm-40), vx:Math.cos(a)*sp*(0.5+Math.random()), vy:Math.sin(a)*sp*(0.5+Math.random()), tr:[] }); } }
  document.getElementById('n').addEventListener('change',function(){ sync(); init(); });
  document.getElementById('temp').addEventListener('input',function(){ sync(); var target=speedForT(); var cur=Math.sqrt(mol.reduce(function(s,m){return s+m.vx*m.vx+m.vy*m.vy;},0)/Math.max(1,mol.length)); var k=target/(cur+1e-6); mol.forEach(function(m){ m.vx*=k; m.vy*=k; }); });
  document.getElementById('rad').addEventListener('input',sync);
  sync(); init();

  function hidpi(cv){ var r=cv.getBoundingClientRect(), d=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w; cv.width=Math.round(w*d); cv.height=Math.round(h*d); var ctx=cv.getContext('2d'); ctx.setTransform(d,0,0,d,0,0); return {ctx:ctx,w:w,h:h}; }
  function step(dt){ var r=v('rad');
    for(var i=0;i<mol.length;i++){ var m=mol[i]; m.x+=m.vx*dt; m.y+=m.vy*dt;
      if(m.x<r){ m.x=r; m.vx=Math.abs(m.vx); pressAcc+=Math.abs(m.vx); } else if(m.x>Wm-r){ m.x=Wm-r; m.vx=-Math.abs(m.vx); pressAcc+=Math.abs(m.vx); }
      if(m.y<r){ m.y=r; m.vy=Math.abs(m.vy); pressAcc+=Math.abs(m.vy); } else if(m.y>Hm-r){ m.y=Hm-r; m.vy=-Math.abs(m.vy); pressAcc+=Math.abs(m.vy); }
      m.tr.push([m.x,m.y]); if(m.tr.length>6) m.tr.shift();
    }
    // pairwise elastic collisions (equal mass)
    for(var a=0;a<mol.length;a++){ for(var b=a+1;b<mol.length;b++){ var p=mol[a],q=mol[b]; var dx=q.x-p.x, dy=q.y-p.y, d2=dx*dx+dy*dy, rr=2*r;
      if(d2<rr*rr && d2>1e-6){ var d=Math.sqrt(d2), nx=dx/d, ny=dy/d; var dv=(p.vx-q.vx)*nx+(p.vy-q.vy)*ny; if(dv>0){ p.vx-=dv*nx; p.vy-=dv*ny; q.vx+=dv*nx; q.vy+=dv*ny; collCount++; } var overlap=(rr-d)/2; p.x-=nx*overlap; p.y-=ny*overlap; q.x+=nx*overlap; q.y+=ny*overlap; } } }
  }
  function colorFor(sp,mx){ var t=Math.min(1,sp/mx); var r=Math.round(80+175*t), g=Math.round(180-120*t), b=Math.round(255-160*t); return 'rgb('+r+','+g+','+b+')'; }
  function draw(){ var cv=document.getElementById('scene'), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h;
    var bg=ctx.createLinearGradient(0,0,0,H); bg.addColorStop(0,'#0c1226'); bg.addColorStop(1,'#06080f'); ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    var boxW=W*0.66, sx=(boxW)/Wm, boxH=Hm*sx, ox=16, oy=(H-boxH)/2;
    // box
    ctx.save(); ctx.shadowColor='#5ee7ff'; ctx.shadowBlur=14; ctx.strokeStyle='#2a3f5f'; ctx.lineWidth=3; ctx.strokeRect(ox,oy,boxW,boxH); ctx.restore();
    var rms=Math.sqrt(mol.reduce(function(a,m){return a+m.vx*m.vx+m.vy*m.vy;},0)/Math.max(1,mol.length)); var mx=rms*2.4+1, r=v('rad')*sx;
    mol.forEach(function(m){ var sp=Math.hypot(m.vx,m.vy), col=colorFor(sp,mx); var px=ox+m.x*sx, py=oy+m.y*sx;
      ctx.strokeStyle=col; ctx.globalAlpha=0.25; ctx.lineWidth=1; ctx.beginPath(); m.tr.forEach(function(t,i){ var tx=ox+t[0]*sx, ty=oy+t[1]*sx; i?ctx.lineTo(tx,ty):ctx.moveTo(tx,ty); }); ctx.stroke(); ctx.globalAlpha=1;
      ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=8; ctx.fillStyle=col; ctx.beginPath(); ctx.arc(px,py,r,0,7); ctx.fill(); ctx.restore(); });
    // histogram panel
    var hx=ox+boxW+22, hw=W-hx-16, hy=oy, hh=boxH; ctx.fillStyle='#070a12'; ctx.fillRect(hx,hy,hw,hh); ctx.strokeStyle='#1a2340'; ctx.strokeRect(hx,hy,hw,hh);
    ctx.fillStyle='#8ea0be'; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText('speed distribution', hx+8, hy+16);
    var nb=22, bins=new Array(nb).fill(0), mxs=mx*1.3; mol.forEach(function(m){ var sp=Math.hypot(m.vx,m.vy); var k=Math.min(nb-1,Math.floor(sp/mxs*nb)); bins[k]++; });
    var mb=Math.max.apply(null,bins)||1; for(var i=0;i<nb;i++){ var bh2=bins[i]/mb*(hh-40); var bx=hx+8+i/nb*(hw-16), bw=(hw-16)/nb-2; var g=ctx.createLinearGradient(0,hy+hh-20-bh2,0,hy+hh-20); g.addColorStop(0,'#7af0ff'); g.addColorStop(1,'#2b7de0'); ctx.fillStyle=g; ctx.fillRect(bx,hy+hh-20-bh2,bw,bh2); }
    // v_rms marker
    ctx.strokeStyle='#fbbf24'; ctx.setLineDash([3,3]); var vm=hx+8+(rms/mxs)*(hw-16); ctx.beginPath(); ctx.moveTo(vm,hy+20); ctx.lineTo(vm,hy+hh-20); ctx.stroke(); ctx.setLineDash([]); ctx.fillStyle='#fbbf24'; ctx.fillText('v_rms', vm-14, hy+30);
    // metrics
    var ke=0.5*rms*rms; document.getElementById('mKE').textContent=ke.toFixed(1); document.getElementById('mVr').textContent=rms.toFixed(1);
    var now=performance.now(); if(now-tPrev>500){ var dtS=(now-tPrev)/1000; document.getElementById('mP').textContent=(pressAcc/dtS/1000).toFixed(1); document.getElementById('mC').textContent=(collCount/dtS).toFixed(0); pressAcc=0; collCount=0; tPrev=now; }
  }
  var last=0; function loop(ts){ if(!last) last=ts; var dt=Math.min(2,(ts-last)/16); last=ts; for(var i=0;i<2;i++) step(dt*0.5); draw(); requestAnimationFrame(loop); }
  requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
