---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Molecular Viewer" description="Real 3D ball-and-stick molecular visualisation with depth-sorted painter algorithm rendering — hand-written perspective projection, no third-party libraries.">
<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; font-family: 'Inter', system-ui, sans-serif; }
  .wrap { max-width: 1280px; margin: 0 auto; padding: 32px 24px 80px; }
  .eyebrow { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin-bottom: 10px; }
  h1 { font-family: 'Cormorant Garamond', serif; font-size: 34px; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 8px; color: #f5f5fa; }
  h1 em { color: #67e8f9; font-weight: 500; font-style: italic; }
  .lede { color: #9da4ad; font-size: 14px; max-width: 720px; line-height: 1.55; margin-bottom: 24px; }
  .grid { display: grid; grid-template-columns: 1fr 320px; gap: 18px; align-items: start; }
  @media (max-width: 960px) { .grid { grid-template-columns: 1fr; } }
  .panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 16px; }
  .panel h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 12px; }
  .stage { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 10px; overflow: hidden; position: relative; }
  canvas#stage { width: 100%; display: block; touch-action: none; cursor: grab; background: radial-gradient(ellipse at center, #0f1218 0%, #050608 100%); }
  canvas#stage:active { cursor: grabbing; }
  .overlay-top { position: absolute; top: 12px; left: 12px; right: 12px; display: flex; justify-content: space-between; align-items: flex-start; pointer-events: none; gap: 12px; flex-wrap: wrap; }
  .badge { background: rgba(10,10,12,0.78); border: 1px solid #2a2a35; padding: 6px 10px; border-radius: 6px; font-family: 'Geist Mono', monospace; font-size: 10px; color: #9da4ad; letter-spacing: 0.06em; }
  .badge b { color: #67e8f9; font-weight: 700; }
  .overlay-bot { position: absolute; bottom: 12px; left: 12px; right: 12px; display: flex; gap: 8px; pointer-events: none; flex-wrap: wrap; }
  .pill { background: rgba(10,10,12,0.78); border: 1px solid #2a2a35; padding: 6px 10px; border-radius: 999px; font-family: 'Geist Mono', monospace; font-size: 10px; color: #cfd6da; letter-spacing: 0.06em; pointer-events: auto; cursor: pointer; user-select: none; transition: all 0.15s; }
  .pill:hover { border-color: #67e8f9; color: #67e8f9; }
  .pill.on { background: #67e8f9; color: #04161b; border-color: #67e8f9; font-weight: 700; }
  .btn { background: #67e8f9; color: #04161b; padding: 9px 16px; border: none; border-radius: 6px; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; cursor: pointer; }
  .btn.ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
  .btn.ghost:hover { border-color: #67e8f9; color: #67e8f9; }
  select, input[type="range"] { background: #0a0a0c; border: 1px solid #2a2a35; color: #fff; padding: 7px 10px; border-radius: 5px; font-family: 'Geist Mono', monospace; font-size: 11px; width: 100%; }
  .row { display: flex; gap: 8px; margin-bottom: 10px; align-items: center; }
  .row label { font-family: 'Geist Mono', monospace; font-size: 10px; color: #9da4ad; letter-spacing: 0.08em; text-transform: uppercase; min-width: 60px; }
  .mol-list { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-top: 8px; }
  .mol-list button { background: #0a0a0c; border: 1px solid #2a2a35; color: #cfd6da; padding: 8px 6px; border-radius: 5px; font-family: 'Geist Mono', monospace; font-size: 10px; cursor: pointer; text-align: left; letter-spacing: 0.04em; transition: all 0.15s; }
  .mol-list button:hover { border-color: #67e8f9; color: #67e8f9; }
  .mol-list button.active { background: #67e8f9; color: #04161b; border-color: #67e8f9; font-weight: 700; }
  .formula-box { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; padding: 14px; margin-bottom: 12px; }
  .formula-box .name { font-family: 'Cormorant Garamond', serif; font-size: 20px; color: #f5f5fa; font-style: italic; margin-bottom: 4px; }
  .formula-box .formula { font-family: 'Geist Mono', monospace; font-size: 14px; color: #67e8f9; letter-spacing: 0.08em; font-weight: 700; }
  .stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 10px; }
  .stat { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 6px; padding: 8px 10px; }
  .stat .k { font-family: 'Geist Mono', monospace; font-size: 9px; color: #67e8f9; letter-spacing: 0.12em; text-transform: uppercase; }
  .stat .v { font-family: 'Geist Mono', monospace; font-size: 16px; color: #f5f5fa; font-weight: 700; margin-top: 2px; }
  .legend { display: grid; grid-template-columns: repeat(2, 1fr); gap: 5px; margin-top: 10px; }
  .legend-item { display: flex; align-items: center; gap: 6px; font-family: 'Geist Mono', monospace; font-size: 10px; color: #cfd6da; }
  .dot { width: 12px; height: 12px; border-radius: 50%; border: 1px solid rgba(255,255,255,0.2); }
  .selected-atom { background: #0a0a0c; border: 1px solid #67e8f9; border-radius: 8px; padding: 10px; margin-top: 10px; font-family: 'Geist Mono', monospace; font-size: 11px; color: #f5f5fa; }
  .selected-atom b { color: #67e8f9; }
  .note { font-family: 'Geist Mono', monospace; font-size: 9px; color: #6a7080; line-height: 1.55; margin-top: 14px; letter-spacing: 0.04em; }
  .controls { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
  svg.icon { width: 16px; height: 16px; stroke: currentColor; stroke-width: 2; fill: none; vertical-align: middle; }
  .back { display: inline-flex; align-items: center; gap: 6px; color: #67e8f9; text-decoration: none; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 18px; }
  .back:hover { color: #fff; }
</style>

<main class="wrap">
  <a href="/aquintutor/labs" class="back"><svg class="icon" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg> Labs index</a>
  <div class="eyebrow">Virtual lab &mdash; 3D structural chemistry</div>
  <h1>Molecular <em>viewer</em></h1>
  <p class="lede">Real ball-and-stick 3D rendering with hand-written perspective projection and painter-algorithm depth sorting. Drag to rotate, scroll or pinch to zoom, click any atom to interrogate. Ten preset molecules from H<sub>2</sub>O up to short DNA helices and an alpha helix protein backbone.</p>

  <div class="grid">
    <div class="panel" style="padding: 8px;">
      <div class="stage">
        <canvas id="stage" width="900" height="640"></canvas>
        <div class="overlay-top">
          <div class="badge">FOV <b id="ovFov">52&deg;</b> &nbsp; ZOOM <b id="ovZoom">1.00x</b></div>
          <div class="badge">ATOMS <b id="ovAtoms">0</b> &nbsp; BONDS <b id="ovBonds">0</b></div>
        </div>
        <div class="overlay-bot">
          <button class="pill" id="pillAuto">AUTO ROTATE</button>
          <button class="pill on" id="pillH">SHOW H</button>
          <button class="pill" id="pillLbl">BOND LABELS</button>
          <button class="pill" id="pillReset">RESET VIEW</button>
        </div>
      </div>
    </div>

    <div>
      <div class="panel" style="margin-bottom: 14px;">
        <h3>Specimen</h3>
        <div class="formula-box">
          <div class="name" id="molName">Water</div>
          <div class="formula" id="molFormula">H&#8322;O</div>
        </div>
        <div class="stat-grid">
          <div class="stat"><div class="k">Atoms</div><div class="v" id="statAtoms">3</div></div>
          <div class="stat"><div class="k">Bonds</div><div class="v" id="statBonds">2</div></div>
          <div class="stat"><div class="k">MW (g/mol)</div><div class="v" id="statMW">18.02</div></div>
          <div class="stat"><div class="k">Heavy</div><div class="v" id="statHeavy">1</div></div>
        </div>
        <div id="selectedBox"></div>
      </div>

      <div class="panel" style="margin-bottom: 14px;">
        <h3>Catalogue</h3>
        <div class="mol-list" id="molList"></div>
      </div>

      <div class="panel">
        <h3>CPK colour key</h3>
        <div class="legend">
          <div class="legend-item"><span class="dot" style="background:#222"></span> Carbon</div>
          <div class="legend-item"><span class="dot" style="background:#f5f5fa"></span> Hydrogen</div>
          <div class="legend-item"><span class="dot" style="background:#3050f8"></span> Nitrogen</div>
          <div class="legend-item"><span class="dot" style="background:#ff0d0d"></span> Oxygen</div>
          <div class="legend-item"><span class="dot" style="background:#ffff30"></span> Sulphur</div>
          <div class="legend-item"><span class="dot" style="background:#ff8000"></span> Phosphorus</div>
        </div>
        <div class="note">Rendering = manual 3&times;3 Rx&middot;Ry rotation &rarr; perspective divide by (z<sub>cam</sub>&minus;z<sub>w</sub>) &rarr; painter sort by mean z. Bonds drawn as trapezoidal quads between projected sphere edges. Specular highlight = single offset white disc per sphere. No WebGL, no Three.js.</div>
      </div>
    </div>
  </div>
</main>

<script is:inline>
(function () {
  'use strict';

  // ===== ATOMIC DATA =====
  const ATOM = {
    H:  { c: '#ffffff', r: 0.31, m: 1.008,  l: '#bdbdbd' },
    C:  { c: '#303030', r: 0.70, m: 12.011, l: '#5a5a5a' },
    N:  { c: '#3050f8', r: 0.65, m: 14.007, l: '#6080ff' },
    O:  { c: '#ff0d0d', r: 0.66, m: 15.999, l: '#ff5050' },
    S:  { c: '#ffff30', r: 1.04, m: 32.06,  l: '#ffff80' },
    P:  { c: '#ff8000', r: 1.07, m: 30.974, l: '#ffa040' },
    Fe: { c: '#e06633', r: 1.32, m: 55.845, l: '#ff9966' },
  };
  const elInfo = (s) => ATOM[s] || { c:'#a0a0a0', r:0.7, m:0, l:'#cccccc' };

  // ===== MOLECULES =====
  // Each molecule: { name, formula, atoms: [[x,y,z,sym], ...], bonds: [[i,j,order], ...] }
  const MOL = {
    water: {
      name: 'Water', formula: 'H₂O',
      atoms: [[0,0,0,'O'], [0.757,0.586,0,'H'], [-0.757,0.586,0,'H']],
      bonds: [[0,1,1],[0,2,1]]
    },
    methane: {
      name: 'Methane', formula: 'CH₄',
      atoms: [[0,0,0,'C'], [0.629,0.629,0.629,'H'], [-0.629,-0.629,0.629,'H'], [-0.629,0.629,-0.629,'H'], [0.629,-0.629,-0.629,'H']],
      bonds: [[0,1,1],[0,2,1],[0,3,1],[0,4,1]]
    },
    ammonia: {
      name: 'Ammonia', formula: 'NH₃',
      atoms: [[0,0,0,'N'], [0.94,-0.32,0,'H'], [-0.47,-0.32,0.81,'H'], [-0.47,-0.32,-0.81,'H']],
      bonds: [[0,1,1],[0,2,1],[0,3,1]]
    },
    ethane: {
      name: 'Ethane', formula: 'C₂H₆',
      atoms: [
        [-0.77,0,0,'C'], [0.77,0,0,'C'],
        [-1.16,1.02,0,'H'], [-1.16,-0.51,0.88,'H'], [-1.16,-0.51,-0.88,'H'],
        [1.16,-1.02,0,'H'], [1.16,0.51,0.88,'H'], [1.16,0.51,-0.88,'H']
      ],
      bonds: [[0,1,1],[0,2,1],[0,3,1],[0,4,1],[1,5,1],[1,6,1],[1,7,1]]
    },
    ethylene: {
      name: 'Ethylene', formula: 'C₂H₄',
      atoms: [
        [-0.67,0,0,'C'], [0.67,0,0,'C'],
        [-1.24,0.93,0,'H'], [-1.24,-0.93,0,'H'],
        [1.24,0.93,0,'H'], [1.24,-0.93,0,'H']
      ],
      bonds: [[0,1,2],[0,2,1],[0,3,1],[1,4,1],[1,5,1]]
    },
    ethyne: {
      name: 'Ethyne', formula: 'C₂H₂',
      atoms: [[-0.6,0,0,'C'],[0.6,0,0,'C'],[-1.66,0,0,'H'],[1.66,0,0,'H']],
      bonds: [[0,1,3],[0,2,1],[1,3,1]]
    },
    benzene: (function () {
      const atoms = []; const bonds = [];
      const R = 1.39;
      for (let i = 0; i < 6; i++) {
        const a = i * Math.PI / 3;
        atoms.push([R * Math.cos(a), R * Math.sin(a), 0, 'C']);
      }
      for (let i = 0; i < 6; i++) {
        const a = i * Math.PI / 3;
        atoms.push([2.49 * Math.cos(a), 2.49 * Math.sin(a), 0, 'H']);
      }
      for (let i = 0; i < 6; i++) bonds.push([i, (i + 1) % 6, i % 2 === 0 ? 2 : 1]);
      for (let i = 0; i < 6; i++) bonds.push([i, i + 6, 1]);
      return { name: 'Benzene', formula: 'C₆H₆', atoms, bonds };
    })(),
    glucose: {
      name: 'Glucose (β-D)', formula: 'C₆H₁₂O₆',
      atoms: [
        // pyranose ring C1..C5 + ring O
        [1.32,-0.20,0.35,'C'],   // 0 C1
        [1.34,1.30,0.10,'C'],    // 1 C2
        [0.07,1.95,-0.50,'C'],   // 2 C3
        [-1.22,1.40,0.10,'C'],   // 3 C4
        [-1.20,-0.12,0.00,'C'],  // 4 C5
        [0.05,-0.74,0.55,'O'],   // 5 ring O
        // CH2OH branch
        [-2.40,-0.78,0.65,'C'],  // 6 C6
        [-2.42,-2.20,0.45,'O'],  // 7 O6
        // hydroxyls
        [2.45,-0.72,-0.30,'O'],  // 8 O1
        [2.50,1.78,-0.60,'O'],   // 9 O2
        [0.10,3.40,-0.20,'O'],   // 10 O3
        [-2.35,1.92,-0.55,'O'],  // 11 O4
        // hydrogens (omitted some for clarity, ring + key positions)
        [1.36,-0.34,1.45,'H'], [1.42,1.50,1.18,'H'],
        [0.04,1.83,-1.60,'H'], [-1.32,1.61,1.18,'H'],
        [-1.20,-0.36,-1.10,'H'],
        [-2.40,-0.55,1.74,'H'], [-3.30,-0.34,0.22,'H'],
        [-3.25,-2.50,0.78,'H'],
        [3.22,-0.30,0.10,'H'], [3.30,1.32,-0.30,'H'],
        [0.90,3.70,-0.55,'H'], [-3.20,1.55,-0.30,'H']
      ],
      bonds: [
        [0,1,1],[1,2,1],[2,3,1],[3,4,1],[4,5,1],[5,0,1],
        [4,6,1],[6,7,1],
        [0,8,1],[1,9,1],[2,10,1],[3,11,1],
        [0,12,1],[1,13,1],[2,14,1],[3,15,1],[4,16,1],
        [6,17,1],[6,18,1],[7,19,1],
        [8,20,1],[9,21,1],[10,22,1],[11,23,1]
      ]
    },
    caffeine: {
      name: 'Caffeine', formula: 'C₈H₁₀N₄O₂',
      atoms: [
        // purine fused-ring scaffold (approximate planar)
        [0.00, 0.00, 0,'N'],  // 0 N1
        [1.35, 0.00, 0,'C'],  // 1 C2
        [2.10, 1.20, 0,'N'],  // 2 N3
        [1.35, 2.40, 0,'C'],  // 3 C4
        [0.00, 2.40, 0,'C'],  // 4 C5
        [-0.75,1.20, 0,'C'],  // 5 C6
        [-0.65,3.55, 0,'N'],  // 6 N7
        [0.50, 4.30, 0,'C'],  // 7 C8
        [1.70, 3.65, 0,'N'],  // 8 N9
        // carbonyls
        [2.00,-1.05, 0,'O'],  // 9 O on C2
        [-2.00,1.20, 0,'O'],  // 10 O on C6
        // methyl Cs
        [-0.75,-1.20,0,'C'],  // 11 CH3 on N1
        [3.55, 1.20,0,'C'],   // 12 CH3 on N3
        [2.95, 4.30,0,'C'],   // 13 CH3 on N9
        // a few hydrogens
        [0.50, 5.40, 0,'H'],
        [-0.30,-2.10, 0.85,'H'],[-0.30,-2.10,-0.85,'H'],[-1.85,-1.20,0,'H'],
        [4.05, 2.15, 0,'H'],[4.05,0.25,0,'H'],[3.90,1.30,-0.95,'H'],
        [3.30, 5.30,0,'H'],[3.40,3.80,0.85,'H'],[3.40,3.80,-0.85,'H']
      ],
      bonds: [
        [0,1,1],[1,2,2],[2,3,1],[3,4,2],[4,5,1],[5,0,1],
        [4,6,1],[6,7,2],[7,8,1],[8,3,1],
        [1,9,2],[5,10,2],
        [0,11,1],[2,12,1],[8,13,1],
        [7,14,1],
        [11,15,1],[11,16,1],[11,17,1],
        [12,18,1],[12,19,1],[12,20,1],
        [13,21,1],[13,22,1],[13,23,1]
      ]
    },
    dna: (function () {
      // Short fragment of B-form DNA double helix backbone (sugar-phosphate spine)
      // Idealised: each strand is a helix of P-O-C5'-C4'-C3'-O3'- repeating, simplified to P + sugar + N base anchor
      const atoms = []; const bonds = [];
      const R = 1.0;  // helix radius
      const rise = 0.34 * 2.0; // exaggerated for visibility (0.34 nm in reality, drawn larger)
      const turn = Math.PI / 5; // 10 bp per turn
      const N = 8; // base-pairs
      for (let i = 0; i < N; i++) {
        const a1 = i * turn;
        const z = i * rise;
        const px = R * Math.cos(a1), py = R * Math.sin(a1);
        // P atom strand A
        atoms.push([px * 1.6, py * 1.6, z, 'P']);
        // O sugar oxygen (link)
        atoms.push([px * 1.25, py * 1.25, z + 0.3, 'O']);
        // C sugar carbon
        atoms.push([px, py, z + 0.5, 'C']);
        // N base nitrogen toward axis
        atoms.push([px * 0.3, py * 0.3, z + 0.5, 'N']);

        // strand B (opposite, antiparallel)
        const a2 = a1 + Math.PI;
        const bx = R * Math.cos(a2), by = R * Math.sin(a2);
        atoms.push([bx * 1.6, by * 1.6, z, 'P']);
        atoms.push([bx * 1.25, by * 1.25, z + 0.3, 'O']);
        atoms.push([bx, by, z + 0.5, 'C']);
        atoms.push([bx * 0.3, by * 0.3, z + 0.5, 'N']);
      }
      // Bonds within each base-pair "rung" + along the spine
      for (let i = 0; i < N; i++) {
        const o = i * 8;
        bonds.push([o, o + 1, 1]);   // P-O
        bonds.push([o + 1, o + 2, 1]); // O-C
        bonds.push([o + 2, o + 3, 1]); // C-N
        bonds.push([o + 4, o + 5, 1]);
        bonds.push([o + 5, o + 6, 1]);
        bonds.push([o + 6, o + 7, 1]);
        bonds.push([o + 3, o + 7, 1]); // base-pair H-bond (drawn as bond)
        if (i < N - 1) {
          bonds.push([o, o + 8, 1]);     // spine A
          bonds.push([o + 4, o + 12, 1]); // spine B
        }
      }
      // Centre vertically
      const cz = (N - 1) * rise / 2;
      for (const a of atoms) a[2] -= cz;
      return { name: 'DNA duplex (8 bp)', formula: 'fragment', atoms, bonds };
    })(),
    helix: (function () {
      // Alpha-helix protein backbone: N-Cα-C-N-Cα-C- ... ~10 residues
      const atoms = []; const bonds = [];
      const N = 10;
      const rise = 1.5 / 3;  // 1.5 angstrom per residue along axis (drawn larger)
      const turn = 2 * Math.PI / 3.6; // 3.6 residues per turn
      const R = 2.3;
      for (let i = 0; i < N; i++) {
        const a = i * turn;
        const z = (i * rise) * 2; // scale axis spacing
        // Three atoms per residue: N, Calpha, C
        const ang0 = a, ang1 = a + 0.4, ang2 = a + 0.8;
        atoms.push([R * Math.cos(ang0), R * Math.sin(ang0), z, 'N']);
        atoms.push([R * Math.cos(ang1), R * Math.sin(ang1), z + rise * 0.66, 'C']);
        atoms.push([R * Math.cos(ang2), R * Math.sin(ang2), z + rise * 1.32, 'C']);
        // Carbonyl O off the C
        atoms.push([R * Math.cos(ang2) * 1.4, R * Math.sin(ang2) * 1.4, z + rise * 1.32 + 0.3, 'O']);
      }
      for (let i = 0; i < N; i++) {
        const o = i * 4;
        bonds.push([o, o + 1, 1]);
        bonds.push([o + 1, o + 2, 1]);
        bonds.push([o + 2, o + 3, 2]);
        if (i < N - 1) bonds.push([o + 2, o + 4, 1]); // peptide bond C->N(next)
      }
      const cz = (N - 1) * rise + rise * 1.32;
      for (const a of atoms) a[2] -= cz / 2;
      return { name: 'Alpha-helix backbone', formula: '(N-Cα-C-O)₁₀', atoms, bonds };
    })()
  };

  // ===== STATE =====
  const cv = document.getElementById('stage');
  const ctx = cv.getContext('2d');
  let DPR = window.devicePixelRatio || 1;
  let W = 900, H = 640;

  function resize() {
    const rect = cv.getBoundingClientRect();
    W = Math.max(300, Math.floor(rect.width));
    H = Math.max(300, Math.floor(rect.height || 640));
    DPR = window.devicePixelRatio || 1;
    cv.width = W * DPR;
    cv.height = H * DPR;
    ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
  }
  window.addEventListener('resize', resize);

  let currentKey = 'water';
  let mol = MOL.water;
  let rotX = -0.35, rotY = 0.4;
  let zoom = 1.0;
  let showH = true;
  let showLabels = false;
  let auto = false;
  let selected = -1;

  function bondingAtoms(m) {
    if (showH) return m.atoms.map((a, i) => ({ a, i }));
    return m.atoms.map((a, i) => ({ a, i })).filter(x => x.a[3] !== 'H');
  }

  function visibleBonds(m) {
    if (showH) return m.bonds;
    return m.bonds.filter(b => m.atoms[b[0]][3] !== 'H' && m.atoms[b[1]][3] !== 'H');
  }

  // ===== MATRIX MATH =====
  function rotate3D(p, rx, ry) {
    // Apply Rx then Ry
    let x = p[0], y = p[1], z = p[2];
    // Rx
    const cy = Math.cos(rx), sy = Math.sin(rx);
    let y2 = y * cy - z * sy;
    let z2 = y * sy + z * cy;
    y = y2; z = z2;
    // Ry
    const cx = Math.cos(ry), sx = Math.sin(ry);
    let x2 = x * cx + z * sx;
    z2 = -x * sx + z * cx;
    x = x2; z = z2;
    return [x, y, z];
  }

  const Z_CAM = 12;
  const FOCAL_BASE = 280;

  function project(p) {
    const r = rotate3D(p, rotX, rotY);
    const focal = FOCAL_BASE * zoom;
    const dz = Z_CAM - r[2];
    if (dz <= 0.01) return null;
    const sx = W / 2 + (r[0] / dz) * focal;
    const sy = H / 2 - (r[1] / dz) * focal;
    const scale = focal / dz;
    return { x: sx, y: sy, z: r[2], s: scale };
  }

  // ===== DRAW =====
  function recenterMol(m) {
    let cx = 0, cy = 0, cz = 0;
    for (const a of m.atoms) { cx += a[0]; cy += a[1]; cz += a[2]; }
    const n = m.atoms.length;
    cx /= n; cy /= n; cz /= n;
    return m.atoms.map(a => [a[0] - cx, a[1] - cy, a[2] - cz, a[3]]);
  }
  let centered = recenterMol(mol);

  function draw() {
    ctx.clearRect(0, 0, W, H);

    // Background subtle grid for depth feel
    ctx.strokeStyle = 'rgba(103, 232, 249, 0.04)';
    ctx.lineWidth = 1;
    const gridStep = 60;
    for (let x = (W/2) % gridStep; x < W; x += gridStep) {
      ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();
    }
    for (let y = (H/2) % gridStep; y < H; y += gridStep) {
      ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
    }

    // Project all atoms
    const proj = centered.map(a => {
      const p = project([a[0], a[1], a[2]]);
      return p ? { p, sym: a[3], idx: 0 } : null;
    });
    proj.forEach((p, i) => { if (p) p.idx = i; });

    // Build render list of primitives: atoms + bonds
    const items = [];

    // Atoms (filtered)
    for (let i = 0; i < proj.length; i++) {
      if (!proj[i]) continue;
      if (!showH && proj[i].sym === 'H') continue;
      items.push({ kind: 'atom', z: proj[i].p.z, p: proj[i] });
    }

    // Bonds (filtered)
    const bonds = visibleBonds(mol);
    for (const b of bonds) {
      const a = proj[b[0]], c = proj[b[1]];
      if (!a || !c) continue;
      const zMid = (a.p.z + c.p.z) / 2 - 0.001; // slightly behind atoms at same z
      items.push({ kind: 'bond', z: zMid, a: a, c: c, order: b[2] });
    }

    // Painter sort: farthest first
    items.sort((u, v) => u.z - v.z);

    // Draw
    for (const it of items) {
      if (it.kind === 'bond') drawBond(it);
      else drawAtom(it);
    }

    // Selected halo
    if (selected >= 0 && proj[selected] && (showH || proj[selected].sym !== 'H')) {
      const p = proj[selected].p;
      const sym = proj[selected].sym;
      const info = elInfo(sym);
      const r = info.r * 35 * p.s / 8;
      ctx.strokeStyle = '#67e8f9';
      ctx.lineWidth = 2.5;
      ctx.beginPath();
      ctx.arc(p.x, p.y, r + 6, 0, Math.PI * 2);
      ctx.stroke();
      ctx.fillStyle = '#67e8f9';
      ctx.font = 'bold 13px "Geist Mono", monospace';
      ctx.textAlign = 'left';
      ctx.fillText(`${sym}${selected}`, p.x + r + 10, p.y - r - 6);
    }
  }

  function drawAtom(item) {
    const p = item.p.p;
    const sym = item.p.sym;
    const info = elInfo(sym);
    const r = Math.max(3, info.r * 35 * p.s / 8);

    // Sphere body radial gradient (manual)
    const g = ctx.createRadialGradient(p.x - r * 0.35, p.y - r * 0.35, r * 0.1, p.x, p.y, r);
    g.addColorStop(0, info.l);
    g.addColorStop(0.5, info.c);
    g.addColorStop(1, sym === 'H' ? '#777' : '#0a0a0c');
    ctx.fillStyle = g;
    ctx.beginPath();
    ctx.arc(p.x, p.y, r, 0, Math.PI * 2);
    ctx.fill();

    // Edge rim
    ctx.strokeStyle = 'rgba(0,0,0,0.5)';
    ctx.lineWidth = 1;
    ctx.stroke();

    // Specular highlight
    ctx.fillStyle = 'rgba(255,255,255,0.55)';
    ctx.beginPath();
    ctx.arc(p.x - r * 0.4, p.y - r * 0.4, r * 0.22, 0, Math.PI * 2);
    ctx.fill();

    // Label for non-H if large enough
    if (r > 10 && sym !== 'H' && (showLabels || mol.atoms.length < 12)) {
      ctx.fillStyle = sym === 'C' ? '#fff' : '#0a0a0c';
      if (sym === 'O' || sym === 'N' || sym === 'P') ctx.fillStyle = '#fff';
      ctx.font = `bold ${Math.floor(r * 0.85)}px "Geist Mono", monospace`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(sym, p.x, p.y + 1);
    }
  }

  function drawBond(item) {
    const a = item.a.p, c = item.c.p;
    const dx = c.x - a.x, dy = c.y - a.y;
    const len = Math.hypot(dx, dy);
    if (len < 1) return;
    const nx = -dy / len, ny = dx / len;
    const order = item.order;
    const wA = Math.max(2, 6 * a.s / 8);
    const wC = Math.max(2, 6 * c.s / 8);

    // For multi-bonds, offset
    const offsets = order === 1 ? [0] : order === 2 ? [-1, 1] : [-1.7, 0, 1.7];
    for (const off of offsets) {
      const offPx = off * 4;
      const ax = a.x + nx * offPx, ay = a.y + ny * offPx;
      const cx = c.x + nx * offPx, cy = c.y + ny * offPx;
      // Trapezoid widening with distance (perspective)
      const aSide = wA * 0.5;
      const cSide = wC * 0.5;
      const tnx = -((cy - ay) / Math.hypot(cx - ax, cy - ay) || 0);
      const tny = ((cx - ax) / Math.hypot(cx - ax, cy - ay) || 0);

      // Half each colour: from a-colour to c-colour
      const halfX = (ax + cx) / 2;
      const halfY = (ay + cy) / 2;
      const cA = elInfo(item.a.sym).c;
      const cC = elInfo(item.c.sym).c;
      // First half
      ctx.fillStyle = cA;
      ctx.beginPath();
      ctx.moveTo(ax + tnx * aSide, ay + tny * aSide);
      ctx.lineTo(halfX + tnx * ((aSide + cSide) / 2), halfY + tny * ((aSide + cSide) / 2));
      ctx.lineTo(halfX - tnx * ((aSide + cSide) / 2), halfY - tny * ((aSide + cSide) / 2));
      ctx.lineTo(ax - tnx * aSide, ay - tny * aSide);
      ctx.closePath();
      ctx.fill();
      // Second half
      ctx.fillStyle = cC;
      ctx.beginPath();
      ctx.moveTo(halfX + tnx * ((aSide + cSide) / 2), halfY + tny * ((aSide + cSide) / 2));
      ctx.lineTo(cx + tnx * cSide, cy + tny * cSide);
      ctx.lineTo(cx - tnx * cSide, cy - tny * cSide);
      ctx.lineTo(halfX - tnx * ((aSide + cSide) / 2), halfY - tny * ((aSide + cSide) / 2));
      ctx.closePath();
      ctx.fill();
      // Outline
      ctx.strokeStyle = 'rgba(0,0,0,0.45)';
      ctx.lineWidth = 0.7;
      ctx.beginPath();
      ctx.moveTo(ax + tnx * aSide, ay + tny * aSide);
      ctx.lineTo(cx + tnx * cSide, cy + tny * cSide);
      ctx.moveTo(ax - tnx * aSide, ay - tny * aSide);
      ctx.lineTo(cx - tnx * cSide, cy - tny * cSide);
      ctx.stroke();
    }

    if (showLabels && order > 1) {
      ctx.fillStyle = '#67e8f9';
      ctx.font = 'bold 10px "Geist Mono", monospace';
      ctx.textAlign = 'center';
      const lx = (a.x + c.x) / 2;
      const ly = (a.y + c.y) / 2 - 8;
      ctx.fillText(order === 2 ? '=' : '≡', lx, ly);
    }
  }

  // ===== STATS PANEL =====
  function updatePanel() {
    document.getElementById('molName').textContent = mol.name;
    document.getElementById('molFormula').innerHTML = mol.formula;

    const counts = {};
    let mw = 0; let heavy = 0;
    for (const a of mol.atoms) {
      counts[a[3]] = (counts[a[3]] || 0) + 1;
      mw += (elInfo(a[3]).m || 0);
      if (a[3] !== 'H') heavy++;
    }
    document.getElementById('statAtoms').textContent = mol.atoms.length;
    document.getElementById('statBonds').textContent = mol.bonds.length;
    document.getElementById('statMW').textContent = mw.toFixed(2);
    document.getElementById('statHeavy').textContent = heavy;

    document.getElementById('ovAtoms').textContent = mol.atoms.length;
    document.getElementById('ovBonds').textContent = mol.bonds.length;
    document.getElementById('ovZoom').textContent = zoom.toFixed(2) + 'x';

    const sel = document.getElementById('selectedBox');
    if (selected >= 0 && mol.atoms[selected]) {
      const a = mol.atoms[selected];
      const info = elInfo(a[3]);
      sel.innerHTML = `<div class="selected-atom"><b>Atom #${selected}</b> &middot; ${a[3]}<br>` +
        `xyz = (${a[0].toFixed(2)}, ${a[1].toFixed(2)}, ${a[2].toFixed(2)}) &Aring;<br>` +
        `mass = ${info.m} u &middot; radius = ${info.r} &Aring;</div>`;
    } else {
      sel.innerHTML = '';
    }
  }

  // ===== INTERACTION =====
  let drag = false, lastX = 0, lastY = 0;
  let pinching = false; let lastPinch = 0;

  cv.addEventListener('mousedown', (e) => {
    drag = true; lastX = e.offsetX; lastY = e.offsetY;
    const hit = hitAtom(e.offsetX, e.offsetY);
    if (hit !== -1) { selected = hit; updatePanel(); }
  });
  window.addEventListener('mouseup', () => { drag = false; });
  window.addEventListener('mousemove', (e) => {
    if (!drag) return;
    const rect = cv.getBoundingClientRect();
    const x = e.clientX - rect.left, y = e.clientY - rect.top;
    const dx = x - lastX, dy = y - lastY;
    rotY += dx * 0.01;
    rotX += dy * 0.01;
    lastX = x; lastY = y;
    draw();
  });
  cv.addEventListener('wheel', (e) => {
    e.preventDefault();
    zoom *= (e.deltaY > 0) ? 0.92 : 1.08;
    zoom = Math.max(0.3, Math.min(4, zoom));
    updatePanel(); draw();
  }, { passive: false });

  cv.addEventListener('touchstart', (e) => {
    if (e.touches.length === 1) {
      drag = true; lastX = e.touches[0].clientX; lastY = e.touches[0].clientY;
      const rect = cv.getBoundingClientRect();
      const hit = hitAtom(lastX - rect.left, lastY - rect.top);
      if (hit !== -1) { selected = hit; updatePanel(); draw(); }
    } else if (e.touches.length === 2) {
      pinching = true;
      lastPinch = Math.hypot(
        e.touches[0].clientX - e.touches[1].clientX,
        e.touches[0].clientY - e.touches[1].clientY
      );
    }
  }, { passive: true });
  cv.addEventListener('touchmove', (e) => {
    e.preventDefault();
    if (pinching && e.touches.length === 2) {
      const d = Math.hypot(
        e.touches[0].clientX - e.touches[1].clientX,
        e.touches[0].clientY - e.touches[1].clientY
      );
      const r = d / (lastPinch || d);
      zoom *= r;
      zoom = Math.max(0.3, Math.min(4, zoom));
      lastPinch = d;
      updatePanel(); draw();
    } else if (drag && e.touches.length === 1) {
      const dx = e.touches[0].clientX - lastX;
      const dy = e.touches[0].clientY - lastY;
      rotY += dx * 0.01; rotX += dy * 0.01;
      lastX = e.touches[0].clientX; lastY = e.touches[0].clientY;
      draw();
    }
  }, { passive: false });
  cv.addEventListener('touchend', () => { drag = false; pinching = false; });

  function hitAtom(x, y) {
    // Re-project and pick the front-most atom under cursor
    let best = -1; let bestZ = -1e9;
    for (let i = 0; i < centered.length; i++) {
      const a = centered[i];
      if (!showH && a[3] === 'H') continue;
      const p = project([a[0], a[1], a[2]]);
      if (!p) continue;
      const r = Math.max(3, elInfo(a[3]).r * 35 * p.s / 8);
      const d = Math.hypot(x - p.x, y - p.y);
      if (d <= r && p.z > bestZ) { best = i; bestZ = p.z; }
    }
    return best;
  }

  // ===== UI WIRING =====
  function loadMol(key) {
    currentKey = key;
    mol = MOL[key];
    centered = recenterMol(mol);
    selected = -1;
    zoom = (mol.atoms.length > 25) ? 0.7 : 1.0;
    document.querySelectorAll('#molList button').forEach(b => {
      b.classList.toggle('active', b.dataset.key === key);
    });
    updatePanel(); draw();
  }

  const list = document.getElementById('molList');
  const keys = ['water','methane','ammonia','ethane','ethylene','ethyne','benzene','glucose','caffeine','dna','helix'];
  for (const k of keys) {
    const btn = document.createElement('button');
    btn.dataset.key = k;
    btn.textContent = MOL[k].name;
    btn.addEventListener('click', () => loadMol(k));
    list.appendChild(btn);
  }

  document.getElementById('pillAuto').addEventListener('click', function () {
    auto = !auto; this.classList.toggle('on', auto);
  });
  document.getElementById('pillH').addEventListener('click', function () {
    showH = !showH; this.classList.toggle('on', showH); updatePanel(); draw();
  });
  document.getElementById('pillLbl').addEventListener('click', function () {
    showLabels = !showLabels; this.classList.toggle('on', showLabels); draw();
  });
  document.getElementById('pillReset').addEventListener('click', function () {
    rotX = -0.35; rotY = 0.4; zoom = 1.0; selected = -1; updatePanel(); draw();
  });

  // ===== ANIMATION LOOP =====
  let last = performance.now();
  function loop(t) {
    const dt = (t - last) / 1000; last = t;
    if (auto) {
      rotY += dt * 0.5;
      draw();
    }
    requestAnimationFrame(loop);
  }

  // ===== BOOT =====
  resize();
  loadMol('water');
  draw();
  requestAnimationFrame(loop);

  // Resize observer fallback
  let ro;
  if (window.ResizeObserver) {
    ro = new ResizeObserver(() => { resize(); draw(); });
    ro.observe(cv.parentElement);
  }
})();
</script>

<div id="demoHint" style="position:fixed;left:16px;bottom:16px;max-width:330px;background:#11131a;color:#e8e8ee;border:1px solid #FF4F00;border-radius:12px;padding:14px 16px;z-index:9999;box-shadow:0 12px 34px rgba(0,0,0,0.45);">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:7px;gap:10px;">
    <span style="font-family:'Geist Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#FF4F00;font-weight:700;">Try this &middot; demo</span>
    <button onclick="this.closest('#demoHint').remove()" style="background:transparent;border:none;color:#9aa6b6;cursor:pointer;font-size:18px;line-height:1;padding:0;">&times;</button>
  </div>
  <p style="margin:0;font-size:12.5px;line-height:1.55;color:#cfd6da;font-family:'Inter Tight',sans-serif,system-ui;">Pick <b>Caffeine</b> from the molecule list, then drag on the model to rotate it in 3D. Click an atom to highlight it; the molecular weight is computed live.</p>
</div>

</BaseLayout>
