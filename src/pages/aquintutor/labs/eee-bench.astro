---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Analog Electronics Workbench · Virtual Labs · AquinTutor" description="Hands-on breadboard: place resistors, LEDs, a battery and switches, wire them, and probe voltages and currents with a multimeter.">

<style>
  body { background: #14100c; color: #efe7da; margin: 0; }
  .wb-wrap { max-width: 1640px; margin: 0 auto; padding: 16px 2.2vw 70px; }
  .wb-top { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 12px; margin-bottom: 6px; }
  .wb-back { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #f0b76b; text-decoration: none; letter-spacing: 0.08em; }
  .wb-eye { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #f0b76b; font-weight: 700; margin: 10px 0 0; }
  .wb-title { font-family: 'Cormorant Garamond', 'Fraunces', serif; font-size: 33px; font-weight: 600; margin: 4px 0 0; letter-spacing: -0.02em; color: #f7efe2; }
  .wb-title em { color: #f0b76b; font-style: italic; font-weight: 500; }
  .wb-lede { color: #b8a88f; font-size: 13.5px; line-height: 1.55; max-width: 920px; margin: 9px 0 16px; }

  /* the desk */
  .wb-desk {
    position: relative;
    border-radius: 16px;
    padding: 14px;
    background:
      repeating-linear-gradient(91deg, rgba(0,0,0,0.10) 0px, rgba(0,0,0,0.10) 2px, rgba(255,255,255,0.018) 2px, rgba(255,255,255,0.018) 5px),
      linear-gradient(180deg, #3a2a1a 0%, #2c2013 60%, #241a10 100%);
    box-shadow: inset 0 2px 0 rgba(255,255,255,0.05), inset 0 -30px 60px rgba(0,0,0,0.5), 0 18px 40px rgba(0,0,0,0.5);
    border: 1px solid #1a130b;
  }

  .wb-grid { display: grid; grid-template-columns: 232px minmax(0,1fr) 252px; gap: 14px; align-items: start; }
  @media (max-width: 1180px) { .wb-grid { grid-template-columns: 1fr; } }

  .wb-rack {
    background: linear-gradient(180deg, #211913 0%, #1a130d 100%);
    border: 1px solid #4a3621;
    border-radius: 12px;
    padding: 12px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
  }
  .wb-rack h3 {
    font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9.5px; letter-spacing: 0.16em;
    text-transform: uppercase; color: #f0b76b; font-weight: 700; margin: 2px 2px 10px;
  }
  .wb-rack h3.mt { margin-top: 18px; }

  /* palette parts */
  .wb-pal { display: grid; grid-template-columns: 1fr 1fr; gap: 7px; }
  .wb-chip {
    background: #2a2014; border: 1px solid #4a3621; border-radius: 9px; padding: 7px 6px 5px;
    cursor: grab; text-align: center; color: #e8dcc6; transition: border-color .12s, transform .06s;
    user-select: none;
  }
  .wb-chip:hover { border-color: #f0b76b; }
  .wb-chip:active { transform: scale(0.97); }
  .wb-chip svg { display: block; margin: 0 auto 3px; }
  .wb-chip .nm { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9px; letter-spacing: 0.04em; color: #c9b896; }

  .wb-presets { display: flex; flex-direction: column; gap: 6px; }
  .wb-pbtn {
    font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10.5px; font-weight: 700;
    text-align: left; padding: 8px 9px; border-radius: 8px; border: 1px solid #4a3621;
    background: #2a2014; color: #e8dcc6; cursor: pointer; letter-spacing: 0.02em; line-height: 1.3;
  }
  .wb-pbtn:hover { border-color: #f0b76b; background: #33271a; }
  .wb-pbtn b { color: #f0b76b; }

  /* canvas / board area */
  .wb-stagewrap {
    background: #181109; border: 1px solid #3a2a1a; border-radius: 12px; padding: 8px;
    box-shadow: inset 0 2px 8px rgba(0,0,0,0.5);
  }
  .wb-toolbar {
    display: flex; flex-wrap: wrap; gap: 6px; align-items: center; margin-bottom: 8px;
    padding: 6px; background: #1f1810; border: 1px solid #3a2a1a; border-radius: 9px;
  }
  .wb-tool {
    font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9.5px; font-weight: 700;
    letter-spacing: 0.05em; text-transform: uppercase; padding: 6px 10px; border-radius: 7px;
    border: 1px solid #4a3621; background: #2a2014; color: #c9b896; cursor: pointer;
  }
  .wb-tool.active { background: #f0b76b; color: #2a1c08; border-color: #f0b76b; }
  .wb-tool.danger.active { background: #e06b5b; border-color: #e06b5b; color: #2a0c08; }
  .wb-toolsep { width: 1px; align-self: stretch; background: #4a3621; margin: 0 2px; }

  svg.wb-stage, canvas.wb-stage { width: 100%; display: block; border-radius: 8px; touch-action: none; }
  .wb-hint {
    font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; color: #9a8a70;
    margin-top: 7px; line-height: 1.5; min-height: 14px;
  }
  .wb-hint b { color: #f0b76b; }

  /* right column: DMM + readouts */
  .wb-dmm {
    background: linear-gradient(180deg, #b8341f 0%, #8e2616 100%);
    border: 1px solid #5a160c; border-radius: 14px; padding: 12px 12px 14px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.18), 0 6px 16px rgba(0,0,0,0.4);
  }
  .wb-dmm .brand { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 8.5px; letter-spacing: 0.2em; color: #ffd9cf; text-transform: uppercase; margin-bottom: 6px; display: flex; justify-content: space-between; }
  .wb-lcd {
    background: #16241a; border: 2px solid #0d160f; border-radius: 7px; padding: 10px 12px;
    box-shadow: inset 0 0 18px rgba(0,0,0,0.6);
  }
  .wb-lcd .read {
    font-family: 'Geist Mono', ui-monospace, monospace; font-size: 30px; font-weight: 700;
    color: #6dffb0; text-align: right; letter-spacing: 0.02em; line-height: 1;
    text-shadow: 0 0 8px rgba(109,255,176,0.6);
  }
  .wb-lcd .unit { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12px; color: #5fe6a0; text-align: right; margin-top: 4px; }
  .wb-lcd .mode { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 8.5px; color: #4fcf90; text-transform: uppercase; letter-spacing: 0.1em; }
  .wb-modes { display: flex; gap: 5px; margin-top: 9px; }
  .wb-mode {
    flex: 1; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9px; font-weight: 700;
    padding: 6px 0; border-radius: 6px; border: 1px solid #5a160c; background: #6e1d10; color: #ffd9cf; cursor: pointer;
    text-transform: uppercase; letter-spacing: 0.03em;
  }
  .wb-mode.active { background: #ffe7b0; color: #5a160c; border-color: #ffe7b0; }
  .wb-probe { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9px; color: #ffd9cf; margin-top: 8px; line-height: 1.45; }

  .wb-card {
    background: linear-gradient(180deg, #211913 0%, #1a130d 100%);
    border: 1px solid #4a3621; border-radius: 12px; padding: 12px; margin-top: 12px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
  }
  .wb-card h3 {
    font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9.5px; letter-spacing: 0.16em;
    text-transform: uppercase; color: #f0b76b; font-weight: 700; margin: 0 0 9px;
  }
  .wb-rt { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10.5px; width: 100%; border-collapse: collapse; }
  .wb-rt th { text-align: left; color: #9a8a70; padding: 3px 5px; border-bottom: 1px solid #4a3621; font-size: 8.5px; text-transform: uppercase; letter-spacing: 0.05em; }
  .wb-rt td { padding: 3px 5px; border-bottom: 1px solid #2a2014; color: #d8c8a8; }
  .wb-rt td.v { color: #88e6ff; text-align: right; font-weight: 700; }
  .wb-rt td.i { color: #ffd36b; text-align: right; font-weight: 700; }
  .wb-rt td.p { color: #c9a8ff; text-align: right; font-weight: 700; }

  .wb-stat { display: flex; justify-content: space-between; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; padding: 4px 2px; border-bottom: 1px solid #2a2014; }
  .wb-stat .k { color: #9a8a70; }
  .wb-stat .vv { color: #6dffb0; font-weight: 700; }

  /* battery supply control */
  .wb-supply { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
  .wb-knob {
    font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9px; color: #c9b896; text-align: center; flex: 0 0 auto;
  }
  .wb-knob .kv { color: #f0b76b; font-size: 13px; font-weight: 700; display: block; }
  .wb-range { width: 100%; }
  input[type=range] { width: 100%; accent-color: #f0b76b; }
  .wb-fld { display: flex; align-items: center; gap: 7px; margin: 6px 0; }
  .wb-fld label { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9.5px; color: #c9b896; flex: 0 0 64px; }
  .wb-fld input[type=number] { background: #14100a; border: 1px solid #4a3621; color: #efe7da; border-radius: 6px; padding: 5px 7px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; width: 100%; box-sizing: border-box; }
  .wb-fld .u { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9.5px; color: #9a8a70; }

  .wb-sel { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9px; color: #c9b896; padding: 6px 0 2px; line-height: 1.5; min-height: 14px; }
  .wb-sel b { color: #f0b76b; }

  .wb-instr {
    font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; color: #b8a88f; line-height: 1.65;
    background: #1f1810; border: 1px solid #3a2a1a; border-radius: 10px; padding: 10px 12px; margin-top: 10px;
  }
  .wb-instr b { color: #f0b76b; }
  .wb-instr ol { margin: 6px 0 0; padding-left: 18px; }
  .wb-instr li { margin-bottom: 3px; }
</style>

<main class="wb-wrap">
  <div class="wb-top">
    <div>
      <a class="wb-back" href="/aquintutor/labs/eee">&larr; back to EEE labs</a>
      <p class="wb-eye">Analog Electronics &middot; Virtual Labs</p>
      <h1 class="wb-title">The <em>Breadboard</em> Workbench</h1>
    </div>
  </div>
  <p class="wb-lede">
    A hands-on bench. Drag components from the rack onto the breadboard, wire pin-to-pin, dial the supply,
    and probe the circuit with the digital multimeter. The simulator solves the network with real nodal
    analysis every time you change anything &mdash; node voltages, branch currents, LED glow and lamp brightness
    are all computed, not faked.
  </p>

  <div class="wb-desk">
    <div class="wb-grid">

      <!-- LEFT RACK: supply + palette + presets -->
      <div class="wb-rack">
        <h3>DC Power Supply</h3>
        <div class="wb-supply">
          <div class="wb-knob">V<span class="kv" id="wbVlabel">6.0</span></div>
          <input class="wb-range" id="wbV" type="range" min="0" max="12" step="0.1" value="6">
        </div>
        <div class="wb-sel" id="wbSupplyNote">Supply terminals sit on the breadboard rails (red = +, blue = &minus;).</div>

        <h3 class="mt">Components</h3>
        <div class="wb-pal" id="wbPalette"></div>

        <h3 class="mt">Selected Part</h3>
        <div id="wbInspector" class="wb-sel">Click a part on the board to edit its value.</div>

        <h3 class="mt">Preset Experiments</h3>
        <div class="wb-presets" id="wbPresets"></div>
      </div>

      <!-- CENTER: board -->
      <div class="wb-stagewrap">
        <div class="wb-toolbar">
          <button class="wb-tool active" data-tool="select" id="wbToolSelect">Move</button>
          <button class="wb-tool" data-tool="wire" id="wbToolWire">Wire</button>
          <button class="wb-tool danger" data-tool="delete" id="wbToolDelete">Delete</button>
          <div class="wb-toolsep"></div>
          <button class="wb-tool" id="wbClear">Clear board</button>
          <span style="flex:1"></span>
          <span id="wbProbeBadge" style="font-family:'Geist Mono',monospace;font-size:9px;color:#9a8a70;"></span>
        </div>
        <svg class="wb-stage" id="wbStage" viewBox="0 0 980 620" xmlns="http://www.w3.org/2000/svg"></svg>
        <div class="wb-hint" id="wbHint">Try a preset on the left, or drag a component onto the board.</div>
        <div class="wb-instr">
          <b>How to use this bench</b>
          <ol>
            <li>Drag parts from the rack onto the breadboard, or load a <b>preset</b>.</li>
            <li>Pick the <b>Wire</b> tool, click one pin then another to connect them. Holes in the same breadboard column are already joined internally.</li>
            <li>Turn the supply knob; switches, pots and resistor values all update the circuit live.</li>
            <li>Choose <b>V / A / Ohm</b> on the multimeter, then click two pins to measure. In Move mode, drag parts to reposition (wires follow).</li>
          </ol>
        </div>
      </div>

      <!-- RIGHT: DMM + live readouts -->
      <div>
        <div class="wb-dmm">
          <div class="brand"><span>AQT-117 TRUE RMS</span><span>DMM</span></div>
          <div class="wb-lcd">
            <div class="mode" id="wbDmmMode">VOLTS DC</div>
            <div class="read" id="wbDmmRead">0.00</div>
            <div class="unit" id="wbDmmUnit">V</div>
          </div>
          <div class="wb-modes">
            <button class="wb-mode active" data-meter="V">V</button>
            <button class="wb-mode" data-meter="A">A</button>
            <button class="wb-mode" data-meter="R">&Omega;</button>
          </div>
          <div class="wb-probe" id="wbDmmProbe">Probes: click the red pin, then the black pin on the board.</div>
        </div>

        <div class="wb-card">
          <h3>Circuit Summary</h3>
          <div class="wb-stat"><span class="k">Supply</span><span class="vv" id="wbSumV">6.00 V</span></div>
          <div class="wb-stat"><span class="k">Total current</span><span class="vv" id="wbSumI">0.00 mA</span></div>
          <div class="wb-stat"><span class="k">Total power</span><span class="vv" id="wbSumP">0.0 mW</span></div>
          <div class="wb-stat"><span class="k">Nodes / branches</span><span class="vv" id="wbSumN">0 / 0</span></div>
        </div>

        <div class="wb-card">
          <h3>Node Voltages</h3>
          <table class="wb-rt"><thead><tr><th>Node</th><th style="text-align:right">V (volts)</th></tr></thead>
          <tbody id="wbNodeTbody"><tr><td colspan="2" style="color:#9a8a70">No circuit yet.</td></tr></tbody></table>
        </div>

        <div class="wb-card">
          <h3>Branch Currents</h3>
          <table class="wb-rt"><thead><tr><th>Element</th><th style="text-align:right">I</th><th style="text-align:right">P</th></tr></thead>
          <tbody id="wbBranchTbody"><tr><td colspan="3" style="color:#9a8a70">No circuit yet.</td></tr></tbody></table>
        </div>
      </div>

    </div>
  </div>
</main>

<script is:inline>
(function () {
  'use strict';

  var SVGNS = 'http://www.w3.org/2000/svg';
  var stage = document.getElementById('wbStage');

  // ---------- geometry: breadboard layout ----------
  // Breadboard occupies a region. Columns of 5 holes (top half) and 5 holes (bottom half),
  // split by a central trough. Power rails (+ and -) along top and bottom.
  var BB = {
    x: 70, y: 120, w: 840, h: 360,
    cols: 50,            // tie-point columns
    pitch: 16,           // hole spacing
    rowGap: 16
  };
  // We snap parts to a coarse grid; tie-point connectivity is computed by column membership.

  // ---------- state ----------
  var parts = [];   // {id,type,x,y,value,state, pins:[{dx,dy}], ...}
  var wires = [];   // {id, a:{kind,ref}, b:{kind,ref}}  endpoints reference a pin
  var nextId = 1;
  var tool = 'select';
  var meterMode = 'V';
  var supplyV = 6.0;

  var pendingWire = null;     // first clicked pin while wiring
  var pendingProbe = null;    // first clicked pin while metering
  var selectedPart = null;
  var dragInfo = null;        // {part, ox, oy} during move

  // solved results cached for hit lookups
  var solved = { nodeV: {}, ok: false, groups: [], pinNode: {} };

  function uid(p) { return (p || 'n') + (nextId++); }

  // ---------- component definitions ----------
  // Each part defines its two (or more) terminal pins as offsets from the part origin.
  // Battery is the supply: terminal + and -.
  function makePart(type, x, y) {
    var p = { id: uid('P'), type: type, x: x, y: y, value: 0, state: 1, pos: 0.5 };
    if (type === 'resistor') { p.value = 1000; p.pins = [{ dx: -34, dy: 0 }, { dx: 34, dy: 0 }]; }
    else if (type === 'led') { p.value = 1.9; p.pins = [{ dx: -28, dy: 0 }, { dx: 28, dy: 0 }]; p.color = '#ff5544'; }
    else if (type === 'switch') { p.value = 0; p.state = 0; p.pins = [{ dx: -30, dy: 0 }, { dx: 30, dy: 0 }]; }
    else if (type === 'pot') { p.value = 10000; p.pos = 0.5; p.pins = [{ dx: -36, dy: 0 }, { dx: 0, dy: -30 }, { dx: 36, dy: 0 }]; }
    else if (type === 'cap') { p.value = 0.0000001; p.pins = [{ dx: -26, dy: 0 }, { dx: 26, dy: 0 }]; }
    else if (type === 'lamp') { p.value = 100; p.pins = [{ dx: -26, dy: 0 }, { dx: 26, dy: 0 }]; }
    else if (type === 'battery') { p.value = supplyV; p.pins = [{ dx: -30, dy: 0 }, { dx: 30, dy: 0 }]; p.term = ['+', '-']; }
    return p;
  }

  function pinPos(part, i) {
    return { x: part.x + part.pins[i].dx, y: part.y + part.pins[i].dy };
  }

  // ---------- ELECTRICAL MODEL ----------
  // We map every pin to a coordinate. Pins connected directly by wires, OR sitting on the
  // same breadboard tie-column, share an electrical node. We union-find all pins.
  // Sources (battery, supply) impose fixed node voltages; resistive elements contribute
  // conductances; LEDs/lamps/pots are resistive (LED via linearized diode model).

  function colOfX(x) {
    // tie-point column index from x (only meaningful inside board), -1 outside
    if (x < BB.x - 4 || x > BB.x + BB.w + 4) return -1;
    return Math.round((x - BB.x) / BB.pitch);
  }
  function halfOfY(y) {
    // -2 top rail, -1 top tie-half, 1 bottom tie-half, 2 bottom rail, 0 = trough/none
    var midTop = BB.y + 70, midBot = BB.y + BB.h - 70;
    if (y < BB.y + 30) return -2;               // top + rail region
    if (y > BB.y + BB.h - 30) return 2;          // bottom - rail region
    if (y < (BB.y + BB.h / 2)) return -1;
    return 1;
  }

  // Build an identifier for the tie-group a pin sits on (breadboard internal connection).
  // Returns null if the pin is "floating" (not on a recognized tie point).
  function tieGroupOf(px, py) {
    var half = halfOfY(py);
    if (half === -2) return 'RAILP';   // top positive rail (one long node)
    if (half === 2) return 'RAILN';    // bottom negative rail (one long node)
    var col = colOfX(px);
    if (col < 0) return null;
    // Each column in a half is a node: e.g. "C12T" (column 12 top) / "C12B"
    return 'C' + col + (half < 0 ? 'T' : 'B');
  }

  // Union-Find over a dynamic key space (pin keys + tie group keys).
  function UF() {
    var parent = {};
    function find(k) {
      if (parent[k] === undefined) parent[k] = k;
      while (parent[k] !== k) { parent[k] = parent[parent[k]]; k = parent[k]; }
      return k;
    }
    function union(a, b) {
      var ra = find(a), rb = find(b);
      if (ra !== rb) parent[ra] = rb;
    }
    return { find: find, union: union, parent: parent };
  }

  function pinKey(partId, i) { return 'P' + partId + '_' + i; }

  // Assemble electrical graph -> returns {nodeOf:{pinKey->nodeId}, nodes:[...], ...}
  function buildGraph() {
    var uf = UF();
    var i, p, k, g;

    // 1) tie every pin to its breadboard tie-group (if any)
    for (i = 0; i < parts.length; i++) {
      p = parts[i];
      for (var j = 0; j < p.pins.length; j++) {
        var pk = pinKey(p.id, j);
        var pp = pinPos(p, j);
        var tg = tieGroupOf(pp.x, pp.y);
        uf.find(pk);
        if (tg) uf.union(pk, 'TIE_' + tg);
      }
    }
    // 2) explicit wires union their endpoints
    for (i = 0; i < wires.length; i++) {
      var w = wires[i];
      uf.union(epKey(w.a), epKey(w.b));
    }
    // 3) switches that are CLOSED short their two pins
    for (i = 0; i < parts.length; i++) {
      p = parts[i];
      if (p.type === 'switch' && p.state === 1) {
        uf.union(pinKey(p.id, 0), pinKey(p.id, 1));
      }
    }

    // collect canonical node ids
    var nodeIndex = {}; var nodeList = []; var pinNode = {};
    function nodeIdFor(key) {
      var r = uf.find(key);
      if (nodeIndex[r] === undefined) { nodeIndex[r] = nodeList.length; nodeList.push(r); }
      return nodeIndex[r];
    }
    for (i = 0; i < parts.length; i++) {
      p = parts[i];
      for (var jj = 0; jj < p.pins.length; jj++) {
        pinNode[pinKey(p.id, jj)] = nodeIdFor(pinKey(p.id, jj));
      }
    }

    return { uf: uf, nodeCount: nodeList.length, nodeList: nodeList, pinNode: pinNode, nodeIdFor: nodeIdFor };
  }

  function epKey(ep) {
    // endpoint references a pin: {part:id, pin:i}
    return pinKey(ep.part, ep.pin);
  }

  // ---------- linear algebra: Gaussian elimination ----------
  function solveLinear(A, b) {
    var n = b.length, i, j, k;
    // make a copy augmented
    var M = [];
    for (i = 0; i < n; i++) { M[i] = A[i].slice(); M[i].push(b[i]); }
    for (i = 0; i < n; i++) {
      // partial pivot
      var piv = i;
      for (k = i + 1; k < n; k++) if (Math.abs(M[k][i]) > Math.abs(M[piv][i])) piv = k;
      if (Math.abs(M[piv][i]) < 1e-12) {
        // singular row -> ground this node (set var to 0) to keep solver stable
        M[i][i] = 1; // weak fallback handled by caller via grounding; continue
        continue;
      }
      var tmp = M[i]; M[i] = M[piv]; M[piv] = tmp;
      var inv = 1 / M[i][i];
      for (j = i; j <= n; j++) M[i][j] *= inv;
      for (k = 0; k < n; k++) {
        if (k === i) continue;
        var f = M[k][i];
        if (f === 0) continue;
        for (j = i; j <= n; j++) M[k][j] -= f * M[i][j];
      }
    }
    var x = [];
    for (i = 0; i < n; i++) x[i] = M[i][n];
    return x;
  }

  // ---------- iterative nodal solve (handles LED diode model) ----------
  // Modified Nodal Analysis with voltage sources via the "supernode + branch current" approach.
  // We support fixed voltage sources (battery). Strategy:
  //   - Build node list.
  //   - Treat battery as a 0-ohm voltage source: add a current unknown per source (MNA).
  //   - Resistive elements add conductance stamps.
  //   - LEDs are linearized each iteration (companion model): I = Is*(exp(V/Vt)-1).
  // For robustness, we ground the most-negative supply terminal node as reference 0.

  function conductanceOf(part) {
    // returns linear conductance for a 2-terminal resistive element (siemens)
    if (part.type === 'resistor') return 1 / Math.max(part.value, 1e-6);
    if (part.type === 'lamp') return 1 / Math.max(part.value, 1e-6);
    if (part.type === 'cap') return 1e-12; // open at DC (tiny leak for stability)
    if (part.type === 'pot') {
      // pot modeled as two-terminal between pins 0 and 2 with wiper at pin1.
      return null; // handled specially
    }
    return null;
  }

  function simulate() {
    var graph = buildGraph();
    var N = graph.nodeCount;
    var pinNode = graph.pinNode;
    solved.pinNode = pinNode;
    solved.nodeListKeys = graph.nodeList;

    if (N === 0) { solved.ok = false; solved.nodeV = []; solved.branches = []; return solved; }

    // Identify voltage sources (batteries). Each contributes one extra unknown (its current).
    var vsources = [];
    var i, p;
    for (i = 0; i < parts.length; i++) {
      p = parts[i];
      if (p.type === 'battery') {
        var nA = pinNode[pinKey(p.id, 0)]; // + terminal
        var nB = pinNode[pinKey(p.id, 1)]; // - terminal
        vsources.push({ part: p, np: nA, nn: nB, V: supplyV });
      }
    }

    // diode (LED) list for iterative linearization
    var diodes = [];
    for (i = 0; i < parts.length; i++) {
      p = parts[i];
      if (p.type === 'led') {
        var a = pinNode[pinKey(p.id, 0)]; // anode
        var c = pinNode[pinKey(p.id, 1)]; // cathode
        diodes.push({ part: p, na: a, nc: c, V: 0, I: 0 });
      }
    }

    var M = N + vsources.length; // MNA matrix size
    // pick a ground reference: the - terminal node of the first battery, else node 0
    var gnd = vsources.length ? vsources[0].nn : 0;

    // iterate to converge diodes
    var Vt = 0.045, Is = 1e-12;       // LED-ish: ~1.8-2.0V knee
    var nodeV = new Array(N);
    for (i = 0; i < N; i++) nodeV[i] = 0;

    var iter, lastV = null;
    for (iter = 0; iter < 60; iter++) {
      var A = [], b = [], r, c2;
      for (r = 0; r < M; r++) { A[r] = []; for (c2 = 0; c2 < M; c2++) A[r][c2] = 0; b[r] = 0; }

      // stamp linear resistive 2-terminal elements
      for (i = 0; i < parts.length; i++) {
        p = parts[i];
        if (p.type === 'resistor' || p.type === 'lamp' || p.type === 'cap') {
          var gg = conductanceOf(p);
          var n1 = pinNode[pinKey(p.id, 0)], n2 = pinNode[pinKey(p.id, 1)];
          stampG(A, n1, n2, gg);
        } else if (p.type === 'pot') {
          // wiper splits resistance: R top = value*pos between pin0..wiper, R bot between wiper..pin2
          var n0 = pinNode[pinKey(p.id, 0)], nw = pinNode[pinKey(p.id, 1)], n2b = pinNode[pinKey(p.id, 2)];
          var rTop = Math.max(p.value * p.pos, 0.5);
          var rBot = Math.max(p.value * (1 - p.pos), 0.5);
          stampG(A, n0, nw, 1 / rTop);
          stampG(A, nw, n2b, 1 / rBot);
        }
      }

      // stamp diodes (companion model around current operating point)
      for (i = 0; i < diodes.length; i++) {
        var d = diodes[i];
        var vd = nodeV[d.na] - nodeV[d.nc];
        if (vd > 0.85) vd = 0.85 + (vd - 0.85) * 0.05; // clamp exp blowup
        var ex = Math.exp(vd / Vt);
        var Id = Is * (ex - 1);
        var gd = (Is / Vt) * ex; if (gd < 1e-9) gd = 1e-9;
        var Ieq = Id - gd * vd;
        stampG(A, d.na, d.nc, gd);
        // current source Ieq from na->nc means inject -Ieq at na, +Ieq at nc
        b[d.na] -= Ieq;
        b[d.nc] += Ieq;
        d.gd = gd; d.vd = vd;
      }

      // stamp voltage sources (MNA branch rows)
      for (i = 0; i < vsources.length; i++) {
        var vs = vsources[i];
        var row = N + i;
        // KCL: branch current enters np, leaves nn
        A[vs.np][row] += 1;
        A[vs.nn][row] -= 1;
        A[row][vs.np] += 1;
        A[row][vs.nn] -= 1;
        b[row] = vs.V;
      }

      // ground reference: force node 'gnd' = 0 by overwriting its row
      for (c2 = 0; c2 < M; c2++) A[gnd][c2] = 0;
      A[gnd][gnd] = 1; b[gnd] = 0;

      // also guard fully-isolated nodes (no stamps) -> pin them to 0 to avoid singularity
      for (r = 0; r < N; r++) {
        var allZero = true;
        for (c2 = 0; c2 < M; c2++) { if (A[r][c2] !== 0) { allZero = false; break; } }
        if (allZero) { A[r][r] = 1; b[r] = 0; }
      }

      var x = solveLinear(A, b);

      var maxd = 0;
      for (r = 0; r < N; r++) {
        var nv = x[r];
        if (!isFinite(nv)) nv = 0;
        maxd = Math.max(maxd, Math.abs(nv - nodeV[r]));
        nodeV[r] = nv;
      }
      // record source currents
      for (i = 0; i < vsources.length; i++) vsources[i].I = x[N + i];

      if (maxd < 1e-7 && iter > 0) break;
      lastV = x;
    }

    // finalize diode currents
    for (i = 0; i < diodes.length; i++) {
      var dd = diodes[i];
      var vdf = nodeV[dd.na] - nodeV[dd.nc];
      var vclamp = vdf; if (vclamp > 0.85) vclamp = 0.85 + (vclamp - 0.85) * 0.05;
      dd.I = Is * (Math.exp(vclamp / Vt) - 1);
      dd.V = vdf;
    }

    // compute branch results for every element
    var branches = [];
    var totalSourceI = 0;
    for (i = 0; i < vsources.length; i++) totalSourceI += Math.abs(vsources[i].I);

    for (i = 0; i < parts.length; i++) {
      p = parts[i];
      var v1, v2, I = 0, R = 0, label = '';
      if (p.type === 'resistor' || p.type === 'lamp' || p.type === 'cap') {
        v1 = nodeV[pinNode[pinKey(p.id, 0)]]; v2 = nodeV[pinNode[pinKey(p.id, 1)]];
        R = p.type === 'cap' ? Infinity : p.value;
        I = p.type === 'cap' ? 0 : (v1 - v2) / Math.max(p.value, 1e-9);
        label = p.type;
      } else if (p.type === 'pot') {
        v1 = nodeV[pinNode[pinKey(p.id, 0)]]; v2 = nodeV[pinNode[pinKey(p.id, 2)]];
        var rTot = p.value;
        I = (v1 - v2) / Math.max(rTot, 1e-9);
        label = 'pot';
      } else if (p.type === 'led') {
        var dref = null;
        for (var q = 0; q < diodes.length; q++) if (diodes[q].part === p) dref = diodes[q];
        v1 = nodeV[pinNode[pinKey(p.id, 0)]]; v2 = nodeV[pinNode[pinKey(p.id, 1)]];
        I = dref ? dref.I : 0;
        label = 'LED';
      } else if (p.type === 'switch') {
        v1 = nodeV[pinNode[pinKey(p.id, 0)]]; v2 = nodeV[pinNode[pinKey(p.id, 1)]];
        I = 0; label = 'switch';
      } else if (p.type === 'battery') {
        var vsRef = null;
        for (var s = 0; s < vsources.length; s++) if (vsources[s].part === p) vsRef = vsources[s];
        v1 = nodeV[pinNode[pinKey(p.id, 0)]]; v2 = nodeV[pinNode[pinKey(p.id, 1)]];
        I = vsRef ? vsRef.I : 0; label = 'battery';
      }
      var Pw = (typeof v1 === 'number' && typeof v2 === 'number') ? Math.abs((v1 - v2) * I) : 0;
      p._I = I; p._V1 = v1; p._V2 = v2; p._P = Pw;
      branches.push({ part: p, label: label, V1: v1, V2: v2, I: I, P: Pw });
    }

    solved.ok = true;
    solved.nodeV = nodeV;
    solved.branches = branches;
    solved.vsources = vsources;
    solved.diodes = diodes;
    solved.totalI = totalSourceI;
    solved.nodeCount = N;
    solved.gnd = gnd;
    return solved;
  }

  function stampG(A, n1, n2, g) {
    if (!isFinite(g) || g <= 0) return;
    A[n1][n1] += g;
    A[n2][n2] += g;
    A[n1][n2] -= g;
    A[n2][n1] -= g;
  }

  // ---------- node voltage lookup for a pin ----------
  function voltageAtPin(part, i) {
    if (!solved.ok) return null;
    var nk = solved.pinNode[pinKey(part.id, i)];
    if (nk === undefined) return null;
    return solved.nodeV[nk];
  }
  function nodeOfPin(part, i) {
    if (!solved.ok) return null;
    return solved.pinNode[pinKey(part.id, i)];
  }

  // ============================================================
  //  RENDERING (SVG)
  // ============================================================
  function el(tag, attrs) {
    var e = document.createElementNS(SVGNS, tag);
    if (attrs) for (var k in attrs) e.setAttribute(k, attrs[k]);
    return e;
  }
  function clear(node) { while (node.firstChild) node.removeChild(node.firstChild); }

  function render() {
    simulate();
    clear(stage);

    // desk shadow under board
    stage.appendChild(el('rect', { x: 0, y: 0, width: 980, height: 620, fill: 'none' }));

    drawBreadboard();
    drawWires();
    for (var i = 0; i < parts.length; i++) drawPart(parts[i]);
    drawProbeMarkers();

    updateReadouts();
    updateDmm();
  }

  function drawBreadboard() {
    var g = el('g', {});
    // body
    g.appendChild(el('rect', { x: BB.x - 26, y: BB.y - 44, width: BB.w + 52, height: BB.h + 88, rx: 12,
      fill: '#e9e3d4', stroke: '#bdb59f', 'stroke-width': 2 }));
    // subtle plastic shading
    g.appendChild(el('rect', { x: BB.x - 26, y: BB.y - 44, width: BB.w + 52, height: 14, rx: 8, fill: 'rgba(255,255,255,0.5)' }));
    g.appendChild(el('rect', { x: BB.x - 26, y: BB.y + BB.h + 30, width: BB.w + 52, height: 14, rx: 8, fill: 'rgba(0,0,0,0.06)' }));

    // central trough
    g.appendChild(el('rect', { x: BB.x - 20, y: BB.y + BB.h / 2 - 9, width: BB.w + 40, height: 18, rx: 4, fill: '#d8d1bf' }));
    g.appendChild(el('rect', { x: BB.x - 20, y: BB.y + BB.h / 2 - 9, width: BB.w + 40, height: 4, fill: 'rgba(0,0,0,0.07)' }));

    // power rails: top + (red), bottom - (blue)
    drawRail(g, BB.y - 34, '#cf3a2a', '+');         // top positive
    drawRail(g, BB.y + BB.h + 14, '#2a6acf', '−'); // bottom negative

    // tie-point holes (two halves of 5)
    var topRowStart = BB.y + 20, botRowStart = BB.y + BB.h / 2 + 24;
    var c, row;
    for (c = 2; c < BB.cols - 2; c++) {
      var hx = BB.x + c * BB.pitch;
      for (row = 0; row < 5; row++) {
        g.appendChild(hole(hx, topRowStart + row * BB.rowGap));
        g.appendChild(hole(hx, botRowStart + row * BB.rowGap));
      }
    }
    // column number labels every 5
    for (c = 5; c < BB.cols - 2; c += 5) {
      var lx = BB.x + c * BB.pitch;
      var t = el('text', { x: lx, y: BB.y + 12, fill: '#a59a7c', 'font-size': 8, 'text-anchor': 'middle', 'font-family': 'monospace' });
      t.textContent = c; g.appendChild(t);
    }
    stage.appendChild(g);
  }

  function drawRail(g, y, col, sym) {
    // rail strip background line
    g.appendChild(el('line', { x1: BB.x - 4, y1: y, x2: BB.x + BB.w + 4, y2: y, stroke: col, 'stroke-width': 2, opacity: 0.55 }));
    var s1 = el('text', { x: BB.x - 16, y: y + 4, fill: col, 'font-size': 13, 'font-weight': 700, 'text-anchor': 'middle', 'font-family': 'monospace' });
    s1.textContent = sym; g.appendChild(s1);
    var s2 = el('text', { x: BB.x + BB.w + 16, y: y + 4, fill: col, 'font-size': 13, 'font-weight': 700, 'text-anchor': 'middle', 'font-family': 'monospace' });
    s2.textContent = sym; g.appendChild(s2);
    for (var c = 3; c < BB.cols - 2; c++) {
      if (c % 6 === 0) continue;
      g.appendChild(hole(BB.x + c * BB.pitch, y));
    }
  }

  function hole(x, y) {
    var c = el('circle', { cx: x, cy: y, r: 2.6, fill: '#3a3528', stroke: '#fff', 'stroke-width': 0.6 });
    return c;
  }

  // ---------- wires ----------
  function endpointPos(ep) {
    var p = findPart(ep.part);
    if (!p) return { x: 0, y: 0 };
    return pinPos(p, ep.pin);
  }
  function drawWires() {
    for (var i = 0; i < wires.length; i++) {
      var w = wires[i];
      var a = endpointPos(w.a), b = endpointPos(w.b);
      var midx = (a.x + b.x) / 2;
      var sag = Math.min(40, Math.abs(b.x - a.x) * 0.18 + 8);
      var d = 'M' + a.x + ',' + a.y + ' Q' + midx + ',' + ((a.y + b.y) / 2 + sag) + ' ' + b.x + ',' + b.y;
      var path = el('path', { d: d, fill: 'none', stroke: w.color || '#1f9d55', 'stroke-width': 4, 'stroke-linecap': 'round', opacity: 0.92 });
      path.style.cursor = 'pointer';
      path.setAttribute('data-wire', w.id);
      (function (wid) {
        path.addEventListener('click', function (ev) {
          ev.stopPropagation();
          if (tool === 'delete') { deleteWire(wid); render(); setHint('Wire deleted.'); }
        });
      })(w.id);
      // shadow
      stage.appendChild(el('path', { d: d, fill: 'none', stroke: 'rgba(0,0,0,0.25)', 'stroke-width': 6, 'stroke-linecap': 'round', transform: 'translate(1,2)' }));
      stage.appendChild(path);
      // endpoint solder dots
      stage.appendChild(el('circle', { cx: a.x, cy: a.y, r: 3, fill: w.color || '#1f9d55' }));
      stage.appendChild(el('circle', { cx: b.x, cy: b.y, r: 3, fill: w.color || '#1f9d55' }));
    }
  }

  // ---------- pin (clickable) ----------
  function drawPin(group, part, i) {
    var pp = pinPos(part, i);
    var ring = el('circle', { cx: pp.x, cy: pp.y, r: 6.5, fill: 'rgba(240,183,107,0.0)', stroke: 'none' });
    ring.style.cursor = 'crosshair';
    var dot = el('circle', { cx: pp.x, cy: pp.y, r: 3.4, fill: '#d8d8c0', stroke: '#7a7458', 'stroke-width': 1 });
    var isPending = pendingWire && pendingWire.part === part.id && pendingWire.pin === i;
    var isProbe = pendingProbe && pendingProbe.part === part.id && pendingProbe.pin === i;
    if (isPending) dot.setAttribute('fill', '#f0b76b');
    if (isProbe) dot.setAttribute('fill', '#6dffb0');
    function onClick(ev) {
      ev.stopPropagation();
      handlePinClick(part, i);
    }
    ring.addEventListener('click', onClick);
    dot.addEventListener('click', onClick);
    group.appendChild(ring);
    group.appendChild(dot);
  }

  // ============================================================
  //  PART RENDERERS (skeuomorphic)
  // ============================================================
  function drawPart(part) {
    var g = el('g', { transform: 'translate(0,0)' });
    g.setAttribute('data-part', part.id);
    if (part.type === 'resistor') drawResistor(g, part);
    else if (part.type === 'led') drawLED(g, part);
    else if (part.type === 'switch') drawSwitch(g, part);
    else if (part.type === 'pot') drawPot(g, part);
    else if (part.type === 'cap') drawCap(g, part);
    else if (part.type === 'lamp') drawLamp(g, part);
    else if (part.type === 'battery') drawBattery(g, part);

    // pins (drawn last so they sit on top)
    for (var i = 0; i < part.pins.length; i++) drawPin(g, part, i);

    // selection highlight
    if (selectedPart === part) {
      var bb = part.pins;
      var minx = 9999, miny = 9999, maxx = -9999, maxy = -9999;
      for (var j = 0; j < bb.length; j++) {
        var pp = pinPos(part, j);
        minx = Math.min(minx, pp.x); maxx = Math.max(maxx, pp.x);
        miny = Math.min(miny, pp.y); maxy = Math.max(maxy, pp.y);
      }
      g.insertBefore(el('rect', { x: minx - 14, y: miny - 22, width: (maxx - minx) + 28, height: (maxy - miny) + 44, rx: 8,
        fill: 'none', stroke: '#f0b76b', 'stroke-width': 1.4, 'stroke-dasharray': '4 3', opacity: 0.85 }), g.firstChild);
    }

    // make body draggable in select mode
    g.addEventListener('mousedown', function (ev) { startDrag(ev, part); });
    g.addEventListener('touchstart', function (ev) { startDrag(ev, part); }, { passive: false });
    g.addEventListener('click', function (ev) {
      // clicking the body (not a pin) selects / deletes the part
      if (ev.target.tagName === 'circle' && ev.target.getAttribute('r') && parseFloat(ev.target.getAttribute('r')) <= 6.5 && ev.target.style.cursor === 'crosshair') return;
      ev.stopPropagation();
      if (tool === 'delete') { deletePart(part.id); render(); setHint('Part removed.'); return; }
      selectPart(part);
    });
    stage.appendChild(g);
  }

  function leadLine(g, x1, y1, x2, y2) {
    g.appendChild(el('line', { x1: x1, y1: y1, x2: x2, y2: y2, stroke: '#9a9a9a', 'stroke-width': 2.4 }));
  }

  function drawResistor(g, p) {
    var x = p.x, y = p.y;
    leadLine(g, x - 34, y, x - 16, y);
    leadLine(g, x + 16, y, x + 34, y);
    // beige body
    g.appendChild(el('rect', { x: x - 18, y: y - 8, width: 36, height: 16, rx: 7, fill: '#d8c79a', stroke: '#8c7a4a', 'stroke-width': 1 }));
    g.appendChild(el('ellipse', { cx: x - 18, cy: y, rx: 4, ry: 8, fill: '#c9b888' }));
    g.appendChild(el('ellipse', { cx: x + 18, cy: y, rx: 4, ry: 8, fill: '#c9b888' }));
    // color bands from resistance
    var bands = resistorBands(p.value);
    var bx = x - 11;
    for (var i = 0; i < bands.length; i++) {
      g.appendChild(el('rect', { x: bx + i * 6, y: y - 8, width: 3, height: 16, fill: bands[i] }));
    }
    var t = el('text', { x: x, y: y + 22, fill: '#d8c8a8', 'font-size': 9, 'text-anchor': 'middle', 'font-family': 'monospace' });
    t.textContent = fmtOhm(p.value);
    g.appendChild(t);
    if (solved.ok) {
      var I = Math.abs(p._I || 0);
      var ti = el('text', { x: x, y: y - 14, fill: '#ffd36b', 'font-size': 8, 'text-anchor': 'middle', 'font-family': 'monospace' });
      ti.textContent = fmtA(I); g.appendChild(ti);
    }
  }

  function drawLED(g, p) {
    var x = p.x, y = p.y;
    leadLine(g, x - 28, y, x - 9, y + 2);
    leadLine(g, x + 9, y, x + 28, y);
    var on = solved.ok && p._I > 0.00015;
    var glow = 0;
    if (on) glow = Math.min(1, Math.log(1 + p._I * 1500) / 4);
    // glow halo
    if (glow > 0.02) {
      g.appendChild(el('circle', { cx: x, cy: y, r: 16 + glow * 14, fill: p.color, opacity: 0.18 + glow * 0.35 }));
    }
    // dome
    var body = el('path', { d: 'M' + (x - 9) + ',' + (y + 9) + ' L' + (x - 9) + ',' + (y - 3) + ' Q' + x + ',' + (y - 16) + ' ' + (x + 9) + ',' + (y - 3) + ' L' + (x + 9) + ',' + (y + 9) + ' Z',
      fill: on ? lighten(p.color, glow) : '#7a3030', stroke: '#5a1a1a', 'stroke-width': 1, opacity: 0.95 });
    g.appendChild(body);
    // shine
    g.appendChild(el('ellipse', { cx: x - 3, cy: y - 4, rx: 2.4, ry: 4, fill: 'rgba(255,255,255,' + (on ? 0.8 : 0.3) + ')' }));
    // flat side mark on cathode
    g.appendChild(el('line', { x1: x + 9, y1: y + 2, x2: x + 9, y2: y + 9, stroke: '#3a0c0c', 'stroke-width': 2 }));
    var t = el('text', { x: x, y: y + 22, fill: on ? '#ffd36b' : '#9a8a70', 'font-size': 8.5, 'text-anchor': 'middle', 'font-family': 'monospace' });
    t.textContent = on ? ('ON  ' + fmtA(p._I)) : 'LED off';
    g.appendChild(t);
  }

  function drawSwitch(g, p) {
    var x = p.x, y = p.y;
    leadLine(g, x - 30, y, x - 16, y);
    leadLine(g, x + 16, y, x + 30, y);
    // base
    g.appendChild(el('rect', { x: x - 17, y: y - 9, width: 34, height: 18, rx: 4, fill: '#2b2b30', stroke: '#555', 'stroke-width': 1 }));
    g.appendChild(el('circle', { cx: x - 12, cy: y, r: 2.4, fill: '#bbb' }));
    g.appendChild(el('circle', { cx: x + 12, cy: y, r: 2.4, fill: '#bbb' }));
    if (p.state === 1) {
      g.appendChild(el('line', { x1: x - 12, y1: y, x2: x + 12, y2: y, stroke: '#cfa44a', 'stroke-width': 3, 'stroke-linecap': 'round' }));
    } else {
      g.appendChild(el('line', { x1: x - 12, y1: y, x2: x + 8, y2: y - 9, stroke: '#cfa44a', 'stroke-width': 3, 'stroke-linecap': 'round' }));
    }
    var t = el('text', { x: x, y: y + 22, fill: p.state ? '#6dffb0' : '#9a8a70', 'font-size': 8.5, 'text-anchor': 'middle', 'font-family': 'monospace' });
    t.textContent = p.state ? 'CLOSED' : 'OPEN';
    g.appendChild(t);
    // toggling via double behaviour: clicking body toggles when select tool
    g.style.cursor = 'pointer';
  }

  function drawPot(g, p) {
    var x = p.x, y = p.y;
    leadLine(g, x - 36, y, x - 18, y);
    leadLine(g, x + 36, y, x + 18, y);
    leadLine(g, x, y - 30, x, y - 14);
    g.appendChild(el('rect', { x: x - 19, y: y - 11, width: 38, height: 22, rx: 5, fill: '#2a2f3a', stroke: '#5a6270', 'stroke-width': 1 }));
    // dial
    var ang = -120 + p.pos * 240;
    var rad = ang * Math.PI / 180;
    g.appendChild(el('circle', { cx: x, cy: y, r: 9, fill: '#c8c8d0', stroke: '#888', 'stroke-width': 1 }));
    g.appendChild(el('line', { x1: x, y1: y, x2: x + Math.cos(rad) * 8, y2: y + Math.sin(rad) * 8, stroke: '#222', 'stroke-width': 2 }));
    var t = el('text', { x: x, y: y + 24, fill: '#d8c8a8', 'font-size': 8.5, 'text-anchor': 'middle', 'font-family': 'monospace' });
    t.textContent = 'POT ' + fmtOhm(p.value) + '  ' + Math.round(p.pos * 100) + '%';
    g.appendChild(t);
  }

  function drawCap(g, p) {
    var x = p.x, y = p.y;
    leadLine(g, x - 26, y, x - 5, y);
    leadLine(g, x + 5, y, x + 26, y);
    g.appendChild(el('line', { x1: x - 5, y1: y - 11, x2: x - 5, y2: y + 11, stroke: '#cfcfcf', 'stroke-width': 3 }));
    g.appendChild(el('path', { d: 'M' + (x + 5) + ',' + (y - 11) + ' Q' + (x + 12) + ',' + y + ' ' + (x + 5) + ',' + (y + 11), fill: 'none', stroke: '#cfcfcf', 'stroke-width': 3 }));
    var t = el('text', { x: x, y: y + 24, fill: '#9a8a70', 'font-size': 8.5, 'text-anchor': 'middle', 'font-family': 'monospace' });
    t.textContent = fmtFarad(p.value);
    g.appendChild(t);
  }

  function drawLamp(g, p) {
    var x = p.x, y = p.y;
    leadLine(g, x - 26, y, x - 12, y);
    leadLine(g, x + 26, y, x + 12, y);
    var bright = 0;
    if (solved.ok) bright = Math.min(1, (p._P || 0) / 0.5);
    if (bright > 0.02) g.appendChild(el('circle', { cx: x, cy: y - 2, r: 13 + bright * 8, fill: '#ffe08a', opacity: 0.15 + bright * 0.4 }));
    g.appendChild(el('circle', { cx: x, cy: y - 2, r: 11, fill: bright > 0.02 ? lighten('#ffcc44', bright) : '#5a5236', stroke: '#8c7a4a', 'stroke-width': 1 }));
    // filament
    g.appendChild(el('path', { d: 'M' + (x - 5) + ',' + y + ' L' + (x - 2) + ',' + (y - 6) + ' L' + (x + 2) + ',' + y + ' L' + (x + 5) + ',' + (y - 6), fill: 'none', stroke: bright > 0.1 ? '#fff3b0' : '#3a3522', 'stroke-width': 1.3 }));
    g.appendChild(el('rect', { x: x - 5, y: y + 8, width: 10, height: 5, fill: '#999' }));
    var t = el('text', { x: x, y: y + 26, fill: bright > 0.02 ? '#ffd36b' : '#9a8a70', 'font-size': 8.5, 'text-anchor': 'middle', 'font-family': 'monospace' });
    t.textContent = solved.ok ? fmtW(p._P || 0) : 'lamp';
    g.appendChild(t);
  }

  function drawBattery(g, p) {
    var x = p.x, y = p.y;
    leadLine(g, x - 30, y, x - 16, y);
    leadLine(g, x + 16, y, x + 30, y);
    // cell symbol: long line (+) short line (-)
    g.appendChild(el('rect', { x: x - 16, y: y - 16, width: 32, height: 32, rx: 5, fill: '#2a2014', stroke: '#f0b76b', 'stroke-width': 1.4 }));
    g.appendChild(el('line', { x1: x - 6, y1: y - 11, x2: x - 6, y2: y + 11, stroke: '#f0b76b', 'stroke-width': 3 }));   // + plate (long)
    g.appendChild(el('line', { x1: x + 5, y1: y - 6, x2: x + 5, y2: y + 6, stroke: '#cfcfcf', 'stroke-width': 3 }));     // - plate (short)
    var tp = el('text', { x: x - 22, y: y - 8, fill: '#cf3a2a', 'font-size': 11, 'font-weight': 700, 'text-anchor': 'middle', 'font-family': 'monospace' });
    tp.textContent = '+'; g.appendChild(tp);
    var tn = el('text', { x: x + 22, y: y - 8, fill: '#88aaff', 'font-size': 13, 'font-weight': 700, 'text-anchor': 'middle', 'font-family': 'monospace' });
    tn.textContent = '−'; g.appendChild(tn);
    var t = el('text', { x: x, y: y + 28, fill: '#f0b76b', 'font-size': 9, 'text-anchor': 'middle', 'font-family': 'monospace' });
    t.textContent = supplyV.toFixed(1) + ' V';
    g.appendChild(t);
  }

  // ---------- probe markers ----------
  function drawProbeMarkers() {
    if (pendingProbe) {
      var p = findPart(pendingProbe.part);
      if (p) {
        var pp = pinPos(p, pendingProbe.pin);
        stage.appendChild(el('circle', { cx: pp.x, cy: pp.y, r: 8, fill: 'none', stroke: '#cf3a2a', 'stroke-width': 2 }));
      }
    }
  }

  // ============================================================
  //  helpers: formatting & colors
  // ============================================================
  function fmtOhm(r) {
    if (r >= 1e6) return (r / 1e6).toFixed(r % 1e6 ? 1 : 0) + 'MΩ';
    if (r >= 1e3) return (r / 1e3).toFixed(r % 1e3 ? 1 : 0) + 'kΩ';
    return r.toFixed(0) + 'Ω';
  }
  function fmtV(v) {
    if (v === null || v === undefined || !isFinite(v)) return '--';
    return v.toFixed(Math.abs(v) >= 10 ? 1 : 3) + ' V';
  }
  function fmtA(a) {
    a = Math.abs(a);
    if (a < 1e-6) return (a * 1e9).toFixed(0) + ' nA';
    if (a < 1e-3) return (a * 1e6).toFixed(a * 1e6 >= 100 ? 0 : 1) + ' µA';
    if (a < 1) return (a * 1e3).toFixed(a * 1e3 >= 100 ? 0 : 1) + ' mA';
    return a.toFixed(2) + ' A';
  }
  function fmtW(w) {
    w = Math.abs(w);
    if (w < 1e-3) return (w * 1e6).toFixed(0) + ' µW';
    if (w < 1) return (w * 1e3).toFixed(1) + ' mW';
    return w.toFixed(2) + ' W';
  }
  function fmtFarad(f) {
    if (f >= 1e-6) return (f * 1e6).toFixed(1) + ' µF';
    if (f >= 1e-9) return (f * 1e9).toFixed(0) + ' nF';
    return (f * 1e12).toFixed(0) + ' pF';
  }

  var BAND = ['#000000', '#7a3b10', '#cf3a2a', '#e08a2a', '#e0d030', '#2f9e3f', '#2a5acf', '#7a3bbf', '#888888', '#eeeeee'];
  function resistorBands(r) {
    // four-band: two sig figs + multiplier + tolerance(gold)
    if (r <= 0) return ['#000000', '#000000', '#000000', '#cfa44a'];
    var exp = 0, val = r;
    while (val >= 100) { val /= 10; exp++; }
    while (val < 10 && val > 0) { val *= 10; exp--; }
    var d1 = Math.floor(val / 10) % 10;
    var d2 = Math.floor(val) % 10;
    var mult = Math.max(0, Math.min(9, exp));
    return [BAND[d1] || '#000', BAND[d2] || '#000', BAND[mult] || '#000', '#cfa44a'];
  }

  function lighten(hex, amt) {
    var c = hexToRgb(hex);
    var r = Math.min(255, c.r + (255 - c.r) * amt * 0.9);
    var g = Math.min(255, c.g + (255 - c.g) * amt * 0.9);
    var b = Math.min(255, c.b + (255 - c.b) * amt * 0.9);
    return 'rgb(' + (r | 0) + ',' + (g | 0) + ',' + (b | 0) + ')';
  }
  function hexToRgb(h) {
    h = h.replace('#', '');
    return { r: parseInt(h.substr(0, 2), 16), g: parseInt(h.substr(2, 2), 16), b: parseInt(h.substr(4, 2), 16) };
  }

  // ============================================================
  //  interaction
  // ============================================================
  function findPart(id) { for (var i = 0; i < parts.length; i++) if (parts[i].id === id) return parts[i]; return null; }

  function svgPoint(ev) {
    var rect = stage.getBoundingClientRect();
    var cx = (ev.touches ? ev.touches[0].clientX : ev.clientX);
    var cy = (ev.touches ? ev.touches[0].clientY : ev.clientY);
    var vb = stage.viewBox.baseVal;
    return {
      x: (cx - rect.left) / rect.width * vb.width,
      y: (cy - rect.top) / rect.height * vb.height
    };
  }

  function startDrag(ev, part) {
    if (tool !== 'select') return;
    // toggle switch directly if clicking a switch body (not a pin)
    if (ev.target && ev.target.style && ev.target.style.cursor === 'crosshair') return;
    ev.preventDefault();
    var pt = svgPoint(ev);
    dragInfo = { part: part, ox: pt.x - part.x, oy: pt.y - part.y, moved: false };
    selectPart(part);
  }

  function onMove(ev) {
    if (!dragInfo) return;
    var pt = svgPoint(ev);
    dragInfo.part.x = snap(pt.x - dragInfo.ox, BB.pitch / 2);
    dragInfo.part.y = snap(pt.y - dragInfo.oy, BB.rowGap / 2);
    dragInfo.moved = true;
    render();
  }
  function onUp(ev) {
    if (dragInfo) {
      if (!dragInfo.moved && dragInfo.part.type === 'switch') {
        dragInfo.part.state = dragInfo.part.state ? 0 : 1;
        render();
      }
      dragInfo = null;
    }
  }
  function snap(v, step) { return Math.round(v / step) * step; }

  window.addEventListener('mousemove', onMove);
  window.addEventListener('mouseup', onUp);
  window.addEventListener('touchmove', function (e) { if (dragInfo) { e.preventDefault(); onMove(e); } }, { passive: false });
  window.addEventListener('touchend', onUp);

  // click on empty stage clears selection / pending
  stage.addEventListener('click', function (ev) {
    if (ev.target === stage) {
      selectedPart = null; pendingWire = null; pendingProbe = null;
      updateInspector(); render();
    }
  });

  function handlePinClick(part, i) {
    if (tool === 'wire') {
      if (!pendingWire) { pendingWire = { part: part.id, pin: i }; setHint('First pin chosen. Click a second pin to connect.'); render(); }
      else {
        if (pendingWire.part === part.id && pendingWire.pin === i) { pendingWire = null; render(); return; }
        addWire(pendingWire, { part: part.id, pin: i });
        pendingWire = null; render(); setHint('Wire added.');
      }
      return;
    }
    if (tool === 'delete') {
      // delete a wire touching this pin if any
      for (var w = 0; w < wires.length; w++) {
        if (samePin(wires[w].a, part, i) || samePin(wires[w].b, part, i)) { deleteWire(wires[w].id); render(); setHint('Wire deleted.'); return; }
      }
      return;
    }
    // select / metering mode: treat pin clicks as probe taps
    probeClick(part, i);
  }
  function samePin(ep, part, i) { return ep.part === part.id && ep.pin === i; }

  function probeClick(part, i) {
    if (!pendingProbe) { pendingProbe = { part: part.id, pin: i }; updateDmm(); render(); setHint('First probe placed. Click a second pin to measure.'); return; }
    if (pendingProbe.part === part.id && pendingProbe.pin === i) { pendingProbe = null; updateDmm(); render(); return; }
    // measure between pendingProbe and this pin
    var a = pendingProbe, b = { part: part.id, pin: i };
    measure(a, b);
    pendingProbe = null;
    render();
  }

  var lastMeasure = null;
  function measure(a, b) {
    var pa = findPart(a.part), pb = findPart(b.part);
    if (!pa || !pb) return;
    if (meterMode === 'V') {
      var va = voltageAtPin(pa, a.pin), vb = voltageAtPin(pb, b.pin);
      if (va === null || vb === null) { lastMeasure = { txt: 'OL', unit: 'V' }; }
      else lastMeasure = { val: va - vb, unit: 'V' };
    } else if (meterMode === 'A') {
      // ammeter: report the current through a branch element if both pins belong to ONE element.
      var I = branchCurrentBetween(a, b);
      if (I === null) lastMeasure = { txt: 'OL', unit: 'A' };
      else lastMeasure = { val: I, unit: 'A' };
    } else { // ohmmeter
      var R = resistanceBetween(pa, pb);
      lastMeasure = (R === null) ? { txt: 'OL', unit: 'Ω' } : { val: R, unit: 'Ω' };
    }
    updateDmm();
  }

  function branchCurrentBetween(a, b) {
    // if a,b are the two pins of the same element, return its current
    if (a.part === b.part) {
      var p = findPart(a.part);
      if (p && typeof p._I === 'number') return p._I;
    }
    // else: report supply branch current if probing across a battery node pair
    if (solved.ok && solved.vsources) {
      for (var i = 0; i < solved.vsources.length; i++) {
        var vs = solved.vsources[i];
        var na = nodeOfPin(findPart(a.part), a.pin), nb = nodeOfPin(findPart(b.part), b.pin);
        if ((na === vs.np && nb === vs.nn) || (na === vs.nn && nb === vs.np)) return vs.I;
      }
    }
    return null;
  }

  function resistanceBetween(pa, pb) {
    // simple: if same 2-terminal resistive element, return its R; else estimate via series chain best-effort
    if (pa === pb) return 0;
    // direct element?
    for (var i = 0; i < parts.length; i++) {
      var p = parts[i];
      if ((p.type === 'resistor' || p.type === 'lamp' || p.type === 'pot')) {
        // both probe pins on this element
        if (pa.id === p.id && pb.id === p.id) {
          if (p.type === 'pot') return p.value;
          return p.value;
        }
      }
    }
    // fall back: if probing the same node -> 0, else unknown
    var na = nodeOfPin(pa, 0), nb = nodeOfPin(pb, 0);
    if (na !== null && na === nb) return 0;
    return null;
  }

  // ---------- wire ops ----------
  var WCOLORS = ['#1f9d55', '#cf3a2a', '#2a6acf', '#d99a1f', '#7a3bbf', '#1aa7b5'];
  function addWire(a, b) {
    // prevent duplicate
    for (var i = 0; i < wires.length; i++) {
      var w = wires[i];
      if ((samePinEp(w.a, a) && samePinEp(w.b, b)) || (samePinEp(w.a, b) && samePinEp(w.b, a))) return;
    }
    wires.push({ id: uid('W'), a: a, b: b, color: WCOLORS[wires.length % WCOLORS.length] });
  }
  function samePinEp(x, y) { return x.part === y.part && x.pin === y.pin; }
  function deleteWire(id) { for (var i = 0; i < wires.length; i++) if (wires[i].id === id) { wires.splice(i, 1); return; } }
  function deletePart(id) {
    for (var i = wires.length - 1; i >= 0; i--) if (wires[i].a.part === id || wires[i].b.part === id) wires.splice(i, 1);
    for (var j = 0; j < parts.length; j++) if (parts[j].id === id) { parts.splice(j, 1); break; }
    if (selectedPart && selectedPart.id === id) { selectedPart = null; updateInspector(); }
  }

  function selectPart(part) {
    selectedPart = part;
    updateInspector();
    render();
  }

  // ============================================================
  //  inspector (edit selected part)
  // ============================================================
  var inspector = document.getElementById('wbInspector');
  function updateInspector() {
    var p = selectedPart;
    if (!p) { inspector.innerHTML = 'Click a part on the board to edit its value.'; return; }
    var html = '';
    if (p.type === 'resistor') {
      html += '<div class="wb-fld"><label>Resistance</label><input type="number" id="insVal" min="1" step="1" value="' + p.value + '"><span class="u">Ω</span></div>';
      html += quickR();
    } else if (p.type === 'led') {
      html += '<div class="wb-fld"><label>Vf (knee)</label><input type="number" id="insVal" min="1.4" max="3.4" step="0.05" value="' + p.value + '"><span class="u">V</span></div>';
      html += '<div class="wb-fld"><label>Colour</label></div>' + ledColorBtns();
    } else if (p.type === 'switch') {
      html += '<button class="wb-pbtn" id="insToggle"><b>' + (p.state ? 'CLOSED' : 'OPEN') + '</b> &mdash; click to toggle</button>';
    } else if (p.type === 'pot') {
      html += '<div class="wb-fld"><label>Max R</label><input type="number" id="insVal" min="100" step="100" value="' + p.value + '"><span class="u">Ω</span></div>';
      html += '<div class="wb-fld"><label>Wiper</label><input type="range" id="insPos" min="0" max="1" step="0.01" value="' + p.pos + '"></div>';
    } else if (p.type === 'cap') {
      html += '<div class="wb-fld"><label>Capacitance</label><input type="number" id="insVal" min="0.000000001" step="0.00000001" value="' + p.value + '"><span class="u">F</span></div>';
    } else if (p.type === 'lamp') {
      html += '<div class="wb-fld"><label>Resistance</label><input type="number" id="insVal" min="1" step="1" value="' + p.value + '"><span class="u">Ω</span></div>';
    } else if (p.type === 'battery') {
      html += '<div class="wb-sel">This cell follows the supply knob (' + supplyV.toFixed(1) + ' V).</div>';
    }
    html += '<button class="wb-pbtn" id="insDel" style="margin-top:8px;color:#e0a59a;"><b>Remove</b> this part</button>';
    inspector.innerHTML = html;

    var iv = document.getElementById('insVal');
    if (iv) iv.addEventListener('input', function () { var v = parseFloat(iv.value); if (isFinite(v) && v > 0) { p.value = v; render(); } });
    var ip = document.getElementById('insPos');
    if (ip) ip.addEventListener('input', function () { p.pos = parseFloat(ip.value); render(); });
    var it = document.getElementById('insToggle');
    if (it) it.addEventListener('click', function () { p.state = p.state ? 0 : 1; updateInspector(); render(); });
    var idd = document.getElementById('insDel');
    if (idd) idd.addEventListener('click', function () { deletePart(p.id); selectedPart = null; updateInspector(); render(); });
    bindQuickR(p); bindLedColors(p);
  }

  function quickR() {
    var vals = [220, 330, 1000, 4700, 10000, 100000];
    var s = '<div style="display:flex;flex-wrap:wrap;gap:4px;margin-top:4px;">';
    for (var i = 0; i < vals.length; i++) s += '<button class="wb-tool qr" data-r="' + vals[i] + '">' + fmtOhm(vals[i]) + '</button>';
    return s + '</div>';
  }
  function bindQuickR(p) {
    var qs = inspector.querySelectorAll('.qr');
    for (var i = 0; i < qs.length; i++) {
      (function (btn) { btn.addEventListener('click', function () { p.value = parseFloat(btn.getAttribute('data-r')); updateInspector(); render(); }); })(qs[i]);
    }
  }
  function ledColorBtns() {
    var cols = [['#ff5544', 'red'], ['#3acf4a', 'green'], ['#3a8aff', 'blue'], ['#ffd23a', 'yellow']];
    var s = '<div style="display:flex;gap:5px;margin-top:2px;">';
    for (var i = 0; i < cols.length; i++) s += '<button class="wb-tool lc" data-c="' + cols[i][0] + '" style="background:' + cols[i][0] + ';color:#1a1209;">' + cols[i][1] + '</button>';
    return s + '</div>';
  }
  function bindLedColors(p) {
    var qs = inspector.querySelectorAll('.lc');
    for (var i = 0; i < qs.length; i++) {
      (function (btn) { btn.addEventListener('click', function () { p.color = btn.getAttribute('data-c'); render(); }); })(qs[i]);
    }
  }

  // ============================================================
  //  palette (drag to drop) + click to add at center
  // ============================================================
  var PALETTE = [
    { type: 'resistor', name: 'Resistor', icon: palResistor },
    { type: 'led', name: 'LED', icon: palLED },
    { type: 'switch', name: 'Switch', icon: palSwitch },
    { type: 'pot', name: 'Potentiometer', icon: palPot },
    { type: 'cap', name: 'Capacitor', icon: palCap },
    { type: 'lamp', name: 'Lamp', icon: palLamp },
    { type: 'battery', name: 'Battery', icon: palBattery }
  ];
  function buildPalette() {
    var host = document.getElementById('wbPalette');
    for (var i = 0; i < PALETTE.length; i++) {
      (function (def) {
        var chip = document.createElement('div');
        chip.className = 'wb-chip';
        chip.setAttribute('draggable', 'true');
        chip.innerHTML = def.icon() + '<div class="nm">' + def.name + '</div>';
        chip.addEventListener('dragstart', function (e) { e.dataTransfer.setData('text/plain', def.type); });
        chip.addEventListener('click', function () { addPartAt(def.type, BB.x + BB.w / 2, BB.y + BB.h / 2 - 40); });
        host.appendChild(chip);
      })(PALETTE[i]);
    }
    stage.addEventListener('dragover', function (e) { e.preventDefault(); });
    stage.addEventListener('drop', function (e) {
      e.preventDefault();
      var t = e.dataTransfer.getData('text/plain');
      if (!t) return;
      var pt = svgPoint(e);
      addPartAt(t, snap(pt.x, BB.pitch / 2), snap(pt.y, BB.rowGap / 2));
    });
  }
  function addPartAt(type, x, y) {
    var p = makePart(type, x, y);
    parts.push(p);
    selectPart(p);
    render();
    setHint('Placed a ' + type + '. Use the Wire tool to connect it.');
  }

  // tiny palette icons (SVG markup strings)
  function palResistor() { return '<svg width="44" height="20" viewBox="0 0 44 20"><line x1="2" y1="10" x2="10" y2="10" stroke="#9a9a9a" stroke-width="2"/><rect x="10" y="5" width="24" height="10" rx="4" fill="#d8c79a" stroke="#8c7a4a"/><rect x="15" y="5" width="2" height="10" fill="#cf3a2a"/><rect x="19" y="5" width="2" height="10" fill="#e08a2a"/><rect x="23" y="5" width="2" height="10" fill="#7a3b10"/><line x1="34" y1="10" x2="42" y2="10" stroke="#9a9a9a" stroke-width="2"/></svg>'; }
  function palLED() { return '<svg width="44" height="20" viewBox="0 0 44 20"><line x1="4" y1="12" x2="14" y2="12" stroke="#9a9a9a" stroke-width="2"/><path d="M14,16 L14,7 Q22,0 30,7 L30,16 Z" fill="#ff5544" stroke="#5a1a1a"/><line x1="30" y1="12" x2="40" y2="12" stroke="#9a9a9a" stroke-width="2"/></svg>'; }
  function palSwitch() { return '<svg width="44" height="20" viewBox="0 0 44 20"><line x1="3" y1="10" x2="14" y2="10" stroke="#9a9a9a" stroke-width="2"/><circle cx="14" cy="10" r="2.4" fill="#bbb"/><line x1="14" y1="10" x2="30" y2="4" stroke="#cfa44a" stroke-width="3"/><circle cx="30" cy="10" r="2.4" fill="#bbb"/><line x1="30" y1="10" x2="41" y2="10" stroke="#9a9a9a" stroke-width="2"/></svg>'; }
  function palPot() { return '<svg width="44" height="22" viewBox="0 0 44 22"><line x1="3" y1="14" x2="13" y2="14" stroke="#9a9a9a" stroke-width="2"/><line x1="31" y1="14" x2="41" y2="14" stroke="#9a9a9a" stroke-width="2"/><line x1="22" y1="2" x2="22" y2="8" stroke="#9a9a9a" stroke-width="2"/><rect x="13" y="8" width="18" height="12" rx="3" fill="#2a2f3a" stroke="#5a6270"/><circle cx="22" cy="14" r="5" fill="#c8c8d0"/></svg>'; }
  function palCap() { return '<svg width="44" height="20" viewBox="0 0 44 20"><line x1="4" y1="10" x2="19" y2="10" stroke="#9a9a9a" stroke-width="2"/><line x1="19" y1="3" x2="19" y2="17" stroke="#cfcfcf" stroke-width="3"/><path d="M25,3 Q31,10 25,17" fill="none" stroke="#cfcfcf" stroke-width="3"/><line x1="25" y1="10" x2="40" y2="10" stroke="#9a9a9a" stroke-width="2"/></svg>'; }
  function palLamp() { return '<svg width="44" height="22" viewBox="0 0 44 22"><line x1="4" y1="11" x2="13" y2="11" stroke="#9a9a9a" stroke-width="2"/><circle cx="22" cy="10" r="8" fill="#5a5236" stroke="#8c7a4a"/><path d="M18,12 L20,7 L24,12 L26,7" fill="none" stroke="#3a3522" stroke-width="1.2"/><line x1="31" y1="11" x2="40" y2="11" stroke="#9a9a9a" stroke-width="2"/></svg>'; }
  function palBattery() { return '<svg width="44" height="22" viewBox="0 0 44 22"><line x1="4" y1="11" x2="14" y2="11" stroke="#9a9a9a" stroke-width="2"/><rect x="14" y="3" width="16" height="16" rx="3" fill="#2a2014" stroke="#f0b76b"/><line x1="20" y1="6" x2="20" y2="16" stroke="#f0b76b" stroke-width="2"/><line x1="25" y1="8" x2="25" y2="14" stroke="#cfcfcf" stroke-width="2"/><line x1="30" y1="11" x2="40" y2="11" stroke="#9a9a9a" stroke-width="2"/></svg>'; }

  // ============================================================
  //  readouts (right column tables)
  // ============================================================
  function updateReadouts() {
    var sumV = document.getElementById('wbSumV');
    var sumI = document.getElementById('wbSumI');
    var sumP = document.getElementById('wbSumP');
    var sumN = document.getElementById('wbSumN');
    sumV.textContent = supplyV.toFixed(2) + ' V';

    var totI = solved.ok ? (solved.totalI || 0) : 0;
    sumI.textContent = fmtA(totI);
    var totP = 0;
    if (solved.ok) for (var i = 0; i < solved.branches.length; i++) { var br = solved.branches[i]; if (br.label !== 'battery') totP += Math.abs(br.P || 0); }
    sumP.textContent = fmtW(totP);
    sumN.textContent = (solved.ok ? solved.nodeCount : 0) + ' / ' + wires.length;

    // node voltages: present each distinct electrical node once, named N0..
    var nodeBody = document.getElementById('wbNodeTbody');
    nodeBody.innerHTML = '';
    if (!solved.ok || solved.nodeCount === 0) {
      nodeBody.innerHTML = '<tr><td colspan="2" style="color:#9a8a70">No circuit yet.</td></tr>';
    } else {
      // only show nodes that have at least one component pin attached & not the same as too many
      var shown = {};
      for (var n = 0; n < solved.nodeCount; n++) {
        var nm = (n === solved.gnd) ? 'GND' : ('N' + n);
        var tr = document.createElement('tr');
        tr.innerHTML = '<td>' + nm + '</td><td class="v">' + fmtVnum(solved.nodeV[n]) + '</td>';
        tr.style.cursor = 'pointer';
        (function (idx) { tr.addEventListener('mouseenter', function () {}); })(n);
        nodeBody.appendChild(tr);
        if (n > 18) { var more = document.createElement('tr'); more.innerHTML = '<td colspan="2" style="color:#9a8a70">...</td>'; nodeBody.appendChild(more); break; }
      }
    }

    // branch currents
    var brBody = document.getElementById('wbBranchTbody');
    brBody.innerHTML = '';
    if (!solved.ok || solved.branches.length === 0) {
      brBody.innerHTML = '<tr><td colspan="3" style="color:#9a8a70">No circuit yet.</td></tr>';
    } else {
      var any = false;
      for (var b = 0; b < solved.branches.length; b++) {
        var brc = solved.branches[b];
        if (brc.label === 'switch' || brc.label === 'cap') continue;
        any = true;
        var nm2 = brc.label + ' ' + shortId(brc.part.id);
        var tr2 = document.createElement('tr');
        tr2.innerHTML = '<td>' + nm2 + '</td><td class="i">' + fmtA(brc.I) + '</td><td class="p">' + fmtW(brc.P) + '</td>';
        brBody.appendChild(tr2);
      }
      if (!any) brBody.innerHTML = '<tr><td colspan="3" style="color:#9a8a70">No conducting elements.</td></tr>';
    }
  }
  function fmtVnum(v) { if (!isFinite(v)) return '--'; return v.toFixed(Math.abs(v) >= 10 ? 1 : 3); }
  function shortId(id) { return id.replace('P', '#'); }

  // ============================================================
  //  DMM display
  // ============================================================
  function updateDmm() {
    var modeLbl = document.getElementById('wbDmmMode');
    var readEl = document.getElementById('wbDmmRead');
    var unitEl = document.getElementById('wbDmmUnit');
    var probeEl = document.getElementById('wbDmmProbe');
    var modeNames = { V: 'VOLTS DC', A: 'AMPERES DC', R: 'RESISTANCE' };
    modeLbl.textContent = modeNames[meterMode];

    if (pendingProbe) { probeEl.textContent = 'Red probe placed. Click the black-probe pin to read.'; }
    else { probeEl.textContent = 'Probes: click two pins on the board to measure.'; }

    if (!lastMeasure) { readEl.textContent = '0.00'; unitEl.textContent = meterMode === 'R' ? 'Ω' : (meterMode === 'A' ? 'mA' : 'V'); return; }
    if (lastMeasure.txt) { readEl.textContent = lastMeasure.txt; unitEl.textContent = lastMeasure.unit; return; }

    var v = lastMeasure.val;
    if (lastMeasure.unit === 'V') {
      readEl.textContent = (Math.abs(v) < 0.0005 ? '0.000' : v.toFixed(Math.abs(v) >= 10 ? 2 : 3));
      unitEl.textContent = 'V';
    } else if (lastMeasure.unit === 'A') {
      var a = Math.abs(v), disp, u;
      if (a < 1e-3) { disp = (v * 1e6); u = 'µA'; }
      else if (a < 1) { disp = (v * 1e3); u = 'mA'; }
      else { disp = v; u = 'A'; }
      readEl.textContent = disp.toFixed(Math.abs(disp) >= 100 ? 1 : 3);
      unitEl.textContent = u;
    } else {
      var r = Math.abs(v), dr, ur;
      if (r >= 1e6) { dr = r / 1e6; ur = 'MΩ'; }
      else if (r >= 1e3) { dr = r / 1e3; ur = 'kΩ'; }
      else { dr = r; ur = 'Ω'; }
      readEl.textContent = dr.toFixed(dr >= 100 ? 0 : 2);
      unitEl.textContent = ur;
    }
  }

  // ============================================================
  //  tools & controls
  // ============================================================
  function setTool(t) {
    tool = t;
    pendingWire = null; pendingProbe = null;
    var btns = document.querySelectorAll('.wb-tool[data-tool]');
    for (var i = 0; i < btns.length; i++) btns[i].classList.toggle('active', btns[i].getAttribute('data-tool') === t);
    var badge = document.getElementById('wbProbeBadge');
    if (t === 'wire') badge.textContent = 'Wiring: click pin to pin';
    else if (t === 'delete') badge.textContent = 'Delete: click a part or wire';
    else badge.textContent = 'Move: drag parts / click pins to probe';
    render();
  }
  function setHint(s) { document.getElementById('wbHint').innerHTML = s; }

  document.querySelectorAll('.wb-tool[data-tool]').forEach(function (b) {
    b.addEventListener('click', function () { setTool(b.getAttribute('data-tool')); });
  });
  document.getElementById('wbClear').addEventListener('click', function () {
    parts = []; wires = []; selectedPart = null; pendingWire = null; pendingProbe = null; lastMeasure = null;
    updateInspector(); setHint('Board cleared.'); render();
  });

  // meter mode buttons
  document.querySelectorAll('.wb-mode').forEach(function (b) {
    b.addEventListener('click', function () {
      meterMode = b.getAttribute('data-meter');
      document.querySelectorAll('.wb-mode').forEach(function (x) { x.classList.toggle('active', x === b); });
      lastMeasure = null; pendingProbe = null; updateDmm(); render();
    });
  });

  // supply knob
  var vSlider = document.getElementById('wbV');
  vSlider.addEventListener('input', function () {
    supplyV = parseFloat(vSlider.value);
    document.getElementById('wbVlabel').textContent = supplyV.toFixed(1);
    for (var i = 0; i < parts.length; i++) if (parts[i].type === 'battery') parts[i].value = supplyV;
    if (selectedPart && selectedPart.type === 'battery') updateInspector();
    render();
  });

  // ============================================================
  //  PRESETS  (auto-build working circuits)
  // ============================================================
  function px(col) { return BB.x + col * BB.pitch; }
  function topRowY(r) { return BB.y + 20 + r * BB.rowGap; }
  function botRowY(r) { return BB.y + BB.h / 2 + 24 + r * BB.rowGap; }
  var railP_Y = BB.y - 34, railN_Y = BB.y + BB.h + 14;

  // helper to place a 2-terminal part horizontally so its pins land on given columns/rows
  function placeH(type, leftCol, rightCol, y) {
    var p = makePart(type, 0, 0);
    var span = (rightCol - leftCol) * BB.pitch;
    // center between the two columns; recompute pin offsets to land exactly
    var cx = (px(leftCol) + px(rightCol)) / 2;
    p.x = cx; p.y = y;
    p.pins[0].dx = px(leftCol) - cx; p.pins[0].dy = 0;
    p.pins[p.pins.length - 1].dx = px(rightCol) - cx; p.pins[p.pins.length - 1].dy = 0;
    parts.push(p);
    return p;
  }

  function resetBoard() {
    parts = []; wires = []; selectedPart = null; pendingWire = null; pendingProbe = null; lastMeasure = null;
    updateInspector();
  }

  function presetOhm() {
    resetBoard(); supplyV = 6; syncSupply();
    // battery between top rail (+) and bottom rail (-)
    var bat = makePart('battery', px(4), topRowY(2)); bat.value = supplyV;
    bat.pins[0].dx = 0; bat.pins[0].dy = railP_Y - topRowY(2);   // + to top rail
    bat.pins[1].dx = 0; bat.pins[1].dy = railN_Y - topRowY(2);   // - to bottom rail
    parts.push(bat);
    // resistor from top rail down to bottom rail via a column
    var r = placeH('resistor', 16, 28, topRowY(2)); r.value = 1000;
    // wire top rail to resistor left, resistor right to bottom rail
    var batId = bat.id;
    addWire({ part: batId, pin: 0 }, { part: r.id, pin: 0 });   // + rail tie -> via tie-group anyway
    // connect resistor ends to rails explicitly:
    wireToRail(r, 0, 'P'); wireToRail(r, 1, 'N');
    setTool('select'); meterMode = 'A';
    syncMeterButtons();
    render();
    setHint('<b>Ohm’s law.</b> Vary V or R and watch I = V/R on the ammeter. Probe the resistor’s two pins in A mode.');
  }

  function presetDivider() {
    resetBoard(); supplyV = 6; syncSupply();
    var r1 = placeH('resistor', 8, 18, topRowY(1)); r1.value = 1000;
    var r2 = placeH('resistor', 18, 28, topRowY(1)); r2.value = 1000;
    var led = placeH('led', 28, 36, topRowY(3)); led.value = 1.9;
    var rs = placeH('resistor', 36, 44, topRowY(3)); rs.value = 330;
    // R1 left to + rail; R2 bottom to - rail. R1.pin1 and R2.pin0 share column 18 (the MIDPOINT).
    wireToRail(r1, 0, 'P');
    wireToRail(r2, 1, 'N');                                  // bottom of divider to ground
    addWire({ part: r1.id, pin: 1 }, { part: r2.id, pin: 0 }); // tie the divider midpoint explicitly
    // Tap the midpoint into the LED + series resistor down to - rail (separate load branch)
    addWire({ part: r1.id, pin: 1 }, { part: led.id, pin: 0 }); // LED anode from midpoint
    addWire({ part: led.id, pin: 1 }, { part: rs.id, pin: 0 });
    wireToRail(rs, 1, 'N');
    placeSupply();
    setTool('select'); meterMode = 'V'; syncMeterButtons();
    render();
    setHint('<b>Voltage divider.</b> Two 1k resistors halve 6 V to 3 V; the LED branch lights from the midpoint. Probe the midpoint in V mode.');
  }

  function presetParallel() {
    resetBoard(); supplyV = 6; syncSupply();
    var ra = placeH('resistor', 12, 36, topRowY(1)); ra.value = 1000;
    var rb = placeH('resistor', 12, 36, topRowY(3)); rb.value = 2000;
    var rc = placeH('resistor', 12, 36, botRowY(1)); rc.value = 3000;
    wireToRail(ra, 0, 'P'); wireToRail(ra, 1, 'N');
    wireToRail(rb, 0, 'P'); wireToRail(rb, 1, 'N');
    wireToRail(rc, 0, 'P'); wireToRail(rc, 1, 'N');
    placeSupply();
    setTool('select'); meterMode = 'A'; syncMeterButtons();
    render();
    setHint('<b>Parallel resistors.</b> 1k, 2k and 3k all across 6 V. Total current is the sum of each branch (6mA + 3mA + 2mA = 11mA).');
  }

  function presetPotDim() {
    resetBoard(); supplyV = 6; syncSupply();
    var pot = makePart('pot', px(16), topRowY(1));
    pot.value = 10000; pot.pos = 0.6;
    pot.pins[0].dx = px(10) - px(16); pot.pins[0].dy = 0;
    pot.pins[1].dx = 0; pot.pins[1].dy = topRowY(3) - topRowY(1); // wiper down a column
    pot.pins[2].dx = px(22) - px(16); pot.pins[2].dy = 0;
    parts.push(pot);
    var led = placeH('led', 28, 36, topRowY(3)); led.value = 1.9;
    var rs = placeH('resistor', 36, 44, topRowY(3)); rs.value = 220;
    wireToRail(pot, 0, 'P');     // top of pot to +
    wireToRail(pot, 2, 'N');     // bottom of pot to -
    addWire({ part: pot.id, pin: 1 }, { part: led.id, pin: 0 }); // wiper to LED
    addWire({ part: led.id, pin: 1 }, { part: rs.id, pin: 0 });
    wireToRail(rs, 1, 'N');
    placeSupply();
    setTool('select'); meterMode = 'V'; syncMeterButtons();
    render();
    setHint('<b>Potentiometer dimmer.</b> Select the pot and drag its wiper slider &mdash; the LED brightens and dims as the tapped voltage changes.');
  }

  function presetBridge() {
    resetBoard(); supplyV = 6; syncSupply();
    // Wheatstone bridge: + rail -> (R1,R2) left arm to node A ; (R3,R4) right arm to node B; DMM across A-B
    var r1 = placeH('resistor', 10, 20, topRowY(1)); r1.value = 1000;  // + to A
    var r2 = placeH('resistor', 10, 20, topRowY(3)); r2.value = 1000;  // A to -
    var r3 = placeH('resistor', 30, 40, topRowY(1)); r3.value = 1000;  // + to B
    var r4 = placeH('resistor', 30, 40, topRowY(3)); r4.value = 1000;  // B to -
    // top of each upper arm to +, bottom of each lower arm to -
    wireToRail(r1, 0, 'P');
    wireToRail(r3, 0, 'P');
    wireToRail(r2, 1, 'N');
    wireToRail(r4, 1, 'N');
    // R1 bottom joins R2 top = node A (col 20). R3 bottom joins R4 top = node B (col 40).
    addWire({ part: r1.id, pin: 1 }, { part: r2.id, pin: 0 });
    addWire({ part: r3.id, pin: 1 }, { part: r4.id, pin: 0 });
    placeSupply();
    setTool('select'); meterMode = 'V'; syncMeterButtons();
    render();
    setHint('<b>Wheatstone bridge.</b> Use the DMM (V) as galvanometer across nodes A and B. With all arms equal it reads ~0 V (null). Change one resistor to unbalance.');
  }

  // place a visible battery glyph wired to the rails so the supply is on-board
  function placeSupply() {
    var bat = makePart('battery', px(2), topRowY(2)); bat.value = supplyV;
    bat.pins[0].dx = 0; bat.pins[0].dy = railP_Y - topRowY(2);
    bat.pins[1].dx = 0; bat.pins[1].dy = railN_Y - topRowY(2);
    parts.push(bat);
  }

  // wire a part pin to the + or - power rail by adding a short wire to a rail hole
  function wireToRail(part, pinIdx, which) {
    // create an invisible helper? Instead, we rely on tie-groups: drop a tiny jumper part is overkill.
    // We add a wire whose other endpoint is a battery rail pin. To keep model simple, we add a
    // dedicated rail anchor part (a zero-size node sitting on the rail) and wire to it.
    var anchor = ensureRailAnchor(which);
    addWire({ part: part.id, pin: pinIdx }, { part: anchor.id, pin: 0 });
  }
  var railAnchors = {};
  function ensureRailAnchor(which) {
    if (railAnchors[which] && findPart(railAnchors[which].id)) return railAnchors[which];
    // a tiny node part sitting on the rail; its single pin is on the rail tie-group
    var y = which === 'P' ? railP_Y : railN_Y;
    var col = which === 'P' ? 6 : 6;
    var a = { id: uid('A'), type: 'anchor', x: px(col), y: y, value: 0, pins: [{ dx: 0, dy: 0 }] };
    parts.push(a);
    railAnchors[which] = a;
    return a;
  }

  function syncSupply() {
    vSlider.value = supplyV;
    document.getElementById('wbVlabel').textContent = supplyV.toFixed(1);
  }
  function syncMeterButtons() {
    document.querySelectorAll('.wb-mode').forEach(function (x) { x.classList.toggle('active', x.getAttribute('data-meter') === meterMode); });
    updateDmm();
  }

  // anchor parts must render as nothing (they only carry a node). Patch drawPart:
  var _origDrawPart = drawPart;
  // (drawPart already only handles known types; 'anchor' falls through and just draws its pin)

  var PRESETS = [
    { name: '1 &middot; Ohm’s law (V, R, I)', fn: presetOhm },
    { name: '2 &middot; Series divider + LED', fn: presetDivider },
    { name: '3 &middot; Parallel resistors', fn: presetParallel },
    { name: '4 &middot; Pot dimming an LED', fn: presetPotDim },
    { name: '5 &middot; Wheatstone bridge', fn: presetBridge }
  ];
  function buildPresets() {
    var host = document.getElementById('wbPresets');
    for (var i = 0; i < PRESETS.length; i++) {
      (function (pr) {
        var b = document.createElement('button');
        b.className = 'wb-pbtn';
        b.innerHTML = pr.name;
        b.addEventListener('click', function () { railAnchors = {}; pr.fn(); });
        host.appendChild(b);
      })(PRESETS[i]);
    }
  }

  // anchor pins should be tiny/hidden — override drawPin for anchors by drawing nothing visible.
  // We accomplish this in drawPart: anchors have type 'anchor' which has no body renderer,
  // and we want their pin invisible. Add a guard:
  var _drawPinReal = drawPin;
  drawPin = function (group, part, i) {
    if (part.type === 'anchor') {
      // invisible but still electrically a tie point; draw a faint marker
      var pp = pinPos(part, i);
      group.appendChild(el('circle', { cx: pp.x, cy: pp.y, r: 3, fill: part === null ? '#000' : 'rgba(207,58,42,0.0)' }));
      return;
    }
    _drawPinReal(group, part, i);
  };

  // ============================================================
  //  init
  // ============================================================
  buildPalette();
  buildPresets();
  setTool('select');
  presetOhm();   // start with a working circuit
  syncMeterButtons();
  render();

})();
</script>

</BaseLayout>
