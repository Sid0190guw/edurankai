---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Pipelined RISC CPU — a cycle-accurate 5-stage (IF/ID/EX/MEM/WB) in-order
// pipeline for a small MIPS-like ISA, with full data forwarding, load-use
// stalls, and a branch penalty, executed functionally for correctness and drawn
// as a live space-time (instruction x cycle) diagram with forwarding paths,
// bubbles and flushes. Graduate computer-architecture depth, hand-rolled.
---
<BaseLayout title="Pipelined CPU · Virtual Labs · AquinTutor" description="A cycle-accurate 5-stage pipelined RISC processor with forwarding, load-use stalls and branch flush — assemble a program and watch it flow through IF/ID/EX/MEM/WB in a live space-time diagram.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1340px; margin:0 auto; padding:20px 3vw 70px; }
  .lb-top{ margin-bottom:10px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#f0a35e; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#f0a35e; font-style:italic; font-weight:500; }
  .lb-sub{ font-family:'Inter Tight',sans-serif; font-size:13.5px; color:#8ea0be; max-width:66ch; line-height:1.55; margin:8px 0 16px; }
  .lb-grid{ display:grid; grid-template-columns:320px minmax(0,1fr); gap:18px; } @media(max-width:960px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#1a1409,#120d06); border:1px solid #40311e; border-radius:14px; padding:16px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#f0a35e; font-weight:700; margin:0 0 10px; }
  .asm{ width:100%; height:200px; background:#0d0a05; border:1px solid #40311e; color:#ffd9a8; padding:10px 12px; border-radius:8px; font-family:'Geist Mono',monospace; font-size:12.5px; line-height:1.6; outline:none; resize:vertical; }
  .lb-btn{ background:linear-gradient(180deg,#f0c088,#e0954e); color:#1a1409; padding:9px 16px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:11px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; }
  .lb-btn-ghost{ background:transparent; color:#cfd6da; border:1px solid #40311e; }
  .kv{ display:grid; grid-template-columns:repeat(2,1fr); gap:5px 12px; font-family:'Geist Mono',monospace; font-size:11.5px; } .kv .k{ color:#8ea0be; } .kv b{ color:#f0a35e; }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11.5px; padding:5px 0; border-bottom:1px solid #2a2113; } .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#f0a35e; font-weight:700; }
  .lb-stage{ width:100%; border-radius:14px; overflow:auto; border:1px solid #40311e; box-shadow:inset 0 0 40px rgba(0,0,0,0.5); }
  .lb-stage canvas{ display:block; }
  .err{ color:#f87171; font-family:'Geist Mono',monospace; font-size:12px; }
</style>
<main class="lb">
  <div class="lb-top">
    <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#f0a35e;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
    <p class="lb-eye" style="margin-top:10px;">Semiconductor / Embedded · Postgraduate · Computer architecture</p>
    <h1 class="lb-title">Pipelined <em>CPU</em>.</h1>
    <p class="lb-sub">A cycle-accurate five-stage in-order pipeline (fetch, decode, execute, memory, write-back) for a MIPS-like ISA. It executes your program correctly, forwards results between stages, stalls one cycle on a load-use hazard, and pays a branch penalty on a taken branch — then draws the whole thing as a space-time diagram so you can read the hazards straight off the pipeline.</p>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Program</h3>
        <textarea id="asm" class="asm" spellcheck="false"></textarea>
        <div style="display:flex;gap:6px;margin-top:10px;flex-wrap:wrap;"><button id="runBtn" class="lb-btn">Assemble &amp; run</button><button id="fwd" class="lb-btn lb-btn-ghost">Forwarding: ON</button></div>
        <div id="err" class="err" style="margin-top:8px;"></div>
        <p style="font-family:'Geist Mono',monospace;font-size:10.5px;color:#8ea0be;margin:10px 0 0;line-height:1.6;">ISA: add sub and or slt, addi, lw/sw off(rs), beq rs rt off, nop. Regs r0..r7 (r0=0).</p>
      </div>
      <div class="lb-panel"><h3>Registers</h3><div class="kv" id="regs"></div></div>
      <div class="lb-panel"><h3>Pipeline metrics</h3>
        <div class="lb-metric"><span class="lb-metric-l">Instructions</span><span class="lb-metric-v" id="mI">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Cycles</span><span class="lb-metric-v" id="mC">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">CPI</span><span class="lb-metric-v" id="mCPI">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Forwards</span><span class="lb-metric-v" id="mF">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Load-use stalls</span><span class="lb-metric-v" id="mS">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Branch bubbles</span><span class="lb-metric-v" id="mB">—</span></div>
      </div>
    </aside>
    <section><div class="lb-stage"><canvas id="diag" width="1000" height="600"></canvas></div></section>
  </div>
</main>
<script is:inline>
(function(){
  var DEFAULT=[
    'addi r1, r0, 5',
    'addi r2, r0, 3',
    'add  r3, r1, r2   ; needs r1,r2 -> forwarded',
    'lw   r4, 0(r0)    ; load',
    'add  r5, r4, r3   ; load-use on r4 -> 1 stall',
    'sub  r6, r3, r2',
    'beq  r6, r0, 2    ; not taken (r6=5)',
    'addi r7, r0, 9',
    'sw   r7, 4(r0)'
  ].join('\n');
  document.getElementById('asm').value=DEFAULT;
  var forwarding=true;
  document.getElementById('fwd').addEventListener('click',function(){ forwarding=!forwarding; this.textContent='Forwarding: '+(forwarding?'ON':'OFF'); });

  function reg(t){ if(!/^r[0-7]$/.test(t)) throw 'bad register '+t; return +t.slice(1); }
  function parse(src){ var out=[]; src.split('\n').forEach(function(raw,ln){ var line=raw.replace(/;.*/,'').trim(); if(!line) return;
    var m=line.replace(/,/g,' ').split(/\s+/); var op=m[0].toLowerCase(); var I={op:op,ln:ln,txt:line,dst:-1,s1:-1,s2:-1,imm:0};
    if(['add','sub','and','or','slt'].indexOf(op)>=0){ I.dst=reg(m[1]); I.s1=reg(m[2]); I.s2=reg(m[3]); }
    else if(op==='addi'){ I.dst=reg(m[1]); I.s1=reg(m[2]); I.imm=+m[3]; }
    else if(op==='lw'){ I.dst=reg(m[1]); var mm=/(-?\d+)\(r([0-7])\)/.exec(m.slice(2).join('')); if(!mm) throw 'bad lw'; I.imm=+mm[1]; I.s1=+mm[2]; }
    else if(op==='sw'){ I.s2=reg(m[1]); var mm=/(-?\d+)\(r([0-7])\)/.exec(m.slice(2).join('')); if(!mm) throw 'bad sw'; I.imm=+mm[1]; I.s1=+mm[2]; }
    else if(op==='beq'){ I.s1=reg(m[1]); I.s2=reg(m[2]); I.imm=+m[3]; }
    else if(op==='nop'){ }
    else throw 'unknown op "'+op+'" (line '+(ln+1)+')';
    out.push(I); }); return out; }
  function srcs(I){ var s=[]; if(['add','sub','and','or','slt'].indexOf(I.op)>=0){ s=[I.s1,I.s2]; } else if(I.op==='addi'||I.op==='lw'){ s=[I.s1]; } else if(I.op==='sw'){ s=[I.s1,I.s2]; } else if(I.op==='beq'){ s=[I.s1,I.s2]; } return s.filter(function(x){return x>0;}); }
  function writes(I){ return (['add','sub','and','or','slt','addi','lw'].indexOf(I.op)>=0)?I.dst:-1; }

  function execute(prog){ var R=[0,0,0,0,0,0,0,0], MEM={}; MEM[0]=42; MEM[4]=0; var trace=[], pc=0, guard=0;
    while(pc>=0 && pc<prog.length && guard++<200){ var I=prog[pc]; var taken=false;
      if(I.op==='beq'){ taken = (R[I.s1]===R[I.s2]); }
      trace.push({i:pc,taken:taken});
      switch(I.op){ case 'add': R[I.dst]=R[I.s1]+R[I.s2]; break; case 'sub': R[I.dst]=R[I.s1]-R[I.s2]; break; case 'and': R[I.dst]=R[I.s1]&R[I.s2]; break; case 'or': R[I.dst]=R[I.s1]|R[I.s2]; break; case 'slt': R[I.dst]=R[I.s1]<R[I.s2]?1:0; break; case 'addi': R[I.dst]=R[I.s1]+I.imm; break; case 'lw': R[I.dst]=MEM[R[I.s1]+I.imm]||0; break; case 'sw': MEM[R[I.s1]+I.imm]=R[I.s2]; break; }
      R[0]=0; if(I.op==='beq' && taken){ pc=pc+1+I.imm; } else pc++; }
    return {R:R, trace:trace}; }

  // schedule the dynamic trace on a 5-stage pipeline
  function schedule(prog, trace){ var rows=[], forwards=0, stalls=0, bubbles=0; var ifc=1, prev=null;
    for(var t=0;t<trace.length;t++){ var idx=trace[t].i, I=prog[idx]; var extra=0, fwdMarks=[], stallHere=false;
      if(t>0){ var pT=trace[t-1], pI=prog[pT.i];
        // branch penalty
        if(pI.op==='beq' && pT.taken){ extra+=2; bubbles+=2; }
        // load-use: prev is lw and this reads its dest
        if(pI.op==='lw' && srcs(I).indexOf(pI.dst)>=0){ extra+=1; stalls+=1; stallHere=true; }
      }
      // forwarding marks (distance 1 and 2 producers within trace)
      srcs(I).forEach(function(s){ for(var k=t-1;k>=Math.max(0,t-2);k--){ var pw=writes(prog[trace[k].i]); if(pw===s){ if(forwarding){ forwards++; fwdMarks.push({from:k, reg:s, dist:t-k}); } break; } } });
      ifc = (t===0?1: rows[t-1].IF + 1 + extra);
      var IF=ifc, ID=IF+1, EX=ID+1, MEM=EX+1, WB=MEM+1;
      rows.push({idx:idx, txt:I.txt, IF:IF, ID:ID, EX:EX, MEM:MEM, WB:WB, stall:stallHere, fwd:fwdMarks, taken:(I.op==='beq'&&trace[t].taken)});
    }
    var cycles = rows.length? rows[rows.length-1].WB : 0;
    return {rows:rows, cycles:cycles, forwards:forwards, stalls:stalls, bubbles:bubbles}; }

  var STAGE={IF:'#5ee7ff',ID:'#a78bfa',EX:'#f0a35e',MEM:'#f472b6',WB:'#34d399'};
  function draw(sched){ var cv=document.getElementById('diag'); var d=window.devicePixelRatio||1;
    var n=sched.rows.length, maxC=sched.cycles; var cw=44, rh=34, padL=250, padT=44;
    var W=padL+ (maxC+1)*cw + 20, H=padT+ n*rh + 30; cv.style.width=W+'px'; cv.width=W*d; cv.height=H*d; var ctx=cv.getContext('2d'); ctx.setTransform(d,0,0,d,0,0);
    ctx.fillStyle='#0c0a06'; ctx.fillRect(0,0,W,H);
    // cycle headers
    ctx.font="10px 'Geist Mono',monospace"; ctx.fillStyle='#8ea0be'; ctx.textAlign='center';
    for(var c=1;c<=maxC;c++){ ctx.fillText('c'+c, padL+(c-0.5)*cw, padT-14); ctx.strokeStyle='rgba(240,163,94,0.06)'; ctx.beginPath(); ctx.moveTo(padL+(c-1)*cw,padT-8); ctx.lineTo(padL+(c-1)*cw,H-20); ctx.stroke(); }
    ctx.textAlign='left';
    function stageAt(row,cy){ if(cy===row.IF) return 'IF'; if(cy===row.ID) return 'ID'; if(cy===row.EX) return 'EX'; if(cy===row.MEM) return 'MEM'; if(cy===row.WB) return 'WB'; return null; }
    sched.rows.forEach(function(row,r){ var y=padT+r*rh;
      ctx.fillStyle='#ffd9a8'; ctx.font="11px 'Geist Mono',monospace"; ctx.fillText((r+1)+'. '+row.txt.slice(0,30), 10, y+rh*0.62);
      // stall bubble between ID and EX (if load-use pushed EX by 1, show bubble at EX-1)
      for(var c=1;c<=maxC;c++){ var st=stageAt(row,c); if(!st) continue; var x=padL+(c-1)*cw+2, col=STAGE[st];
        ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=8; var g=ctx.createLinearGradient(0,y+4,0,y+rh-4); g.addColorStop(0,col); g.addColorStop(1,'rgba(0,0,0,0.35)'); ctx.fillStyle=g; ctx.fillRect(x,y+4,cw-4,rh-8); ctx.restore();
        ctx.fillStyle='#0c0a06'; ctx.font="700 11px 'Geist Mono',monospace"; ctx.textAlign='center'; ctx.fillText(st, x+(cw-4)/2, y+rh*0.62); ctx.textAlign='left'; }
      if(row.stall){ var bx=padL+(row.EX-2)*cw+2; ctx.strokeStyle='#f87171'; ctx.setLineDash([3,3]); ctx.strokeRect(bx,y+4,cw-4,rh-8); ctx.setLineDash([]); ctx.fillStyle='#f87171'; ctx.font="9px 'Geist Mono',monospace"; ctx.textAlign='center'; ctx.fillText('stall',bx+(cw-4)/2,y+rh*0.62); ctx.textAlign='left'; }
      // forwarding arrows: from producer's EX/MEM (end) to this EX
      row.fwd.forEach(function(f){ var pr=sched.rows[f.from]; var fromCy=(f.dist===1?pr.EX:pr.MEM); var x1=padL+(fromCy)*cw-2, y1=padT+f.from*rh+rh/2; var x2=padL+(row.EX-1)*cw+2, y2=y+rh/2;
        ctx.save(); ctx.strokeStyle='rgba(52,211,153,0.8)'; ctx.lineWidth=1.6; ctx.setLineDash([2,3]); ctx.beginPath(); ctx.moveTo(x1,y1); ctx.bezierCurveTo(x1+18,y1,x2-18,y2,x2,y2); ctx.stroke(); ctx.setLineDash([]); ctx.fillStyle='#34d399'; ctx.beginPath(); ctx.arc(x2,y2,3,0,7); ctx.fill(); ctx.restore(); });
      if(row.taken){ ctx.fillStyle='#f87171'; ctx.font="9px 'Geist Mono',monospace"; ctx.fillText('branch → flush next 2', padL+(row.EX)*cw+4, y+rh*0.62); }
    });
    // legend
    var lx=10, ly=H-14; Object.keys(STAGE).forEach(function(k){ ctx.fillStyle=STAGE[k]; ctx.fillRect(lx,ly-9,10,10); ctx.fillStyle='#cfd6da'; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText(k,lx+13,ly); lx+=48; });
    ctx.fillStyle='#34d399'; ctx.fillText('— forwarding path', lx+6, ly);
  }

  function run(){ document.getElementById('err').textContent=''; var prog;
    try{ prog=parse(document.getElementById('asm').value); }catch(e){ document.getElementById('err').textContent='Error: '+e; return; }
    if(!prog.length){ document.getElementById('err').textContent='empty program'; return; }
    var ex; try{ ex=execute(prog); }catch(e){ document.getElementById('err').textContent='Runtime: '+e; return; }
    var sched=schedule(prog, ex.trace);
    document.getElementById('regs').innerHTML = ex.R.map(function(v,i){ return '<span class="k">r'+i+'</span><b>'+v+'</b>'; }).join('');
    document.getElementById('mI').textContent=sched.rows.length; document.getElementById('mC').textContent=sched.cycles;
    document.getElementById('mCPI').textContent=(sched.cycles/Math.max(1,sched.rows.length)).toFixed(2);
    document.getElementById('mF').textContent=sched.forwards; document.getElementById('mS').textContent=sched.stalls; document.getElementById('mB').textContent=sched.bubbles;
    draw(sched);
  }
  document.getElementById('runBtn').addEventListener('click',run); run();
})();
</script>
</BaseLayout>
