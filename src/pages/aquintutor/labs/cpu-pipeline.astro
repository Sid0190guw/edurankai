---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Pipelined RISC CPU — a classic 5-stage (IF/ID/EX/MEM/WB) in-order pipeline
// with data forwarding, load-use stalls and predict-not-taken branch flushes.
// Runs a real program, shows the cycle-by-cycle pipeline diagram, datapath
// occupancy per cycle, hazards, CPI, and final register state. Postgraduate
// computer-architecture depth, hand-rolled, no libraries.
---
<BaseLayout title="Pipelined CPU · Virtual Labs · AquinTutor" description="A 5-stage in-order RISC pipeline with forwarding, load-use stalls and branch flushes — run a real program and watch instructions flow through IF/ID/EX/MEM/WB cycle by cycle, with hazards and CPI.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1320px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#fbbf24; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#fbbf24; font-style:italic; font-weight:500; }
  .lb-sub{ font-family:'Inter Tight',sans-serif; font-size:13.5px; color:#8ea0be; max-width:70ch; line-height:1.55; margin:8px 0 14px; }
  .lb-grid{ display:grid; grid-template-columns:300px minmax(0,1fr); gap:18px; } @media(max-width:940px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#161206,#0c0a05); border:1px solid #3a2f14; border-radius:14px; padding:16px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#fbbf24; font-weight:700; margin:0 0 12px; }
  .lb-btn{ background:linear-gradient(180deg,#fcd34d,#eab308); color:#1a1405; padding:9px 16px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:11px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; }
  .lb-btn-ghost{ background:transparent; color:#cfd6da; border:1px solid #3a2f14; }
  .asm{ font-family:'Geist Mono',monospace; font-size:11.5px; line-height:1.7; color:#cfd6da; white-space:pre; overflow-x:auto; }
  .asm .lbl{ color:#fbbf24; } .asm .op{ color:#5ee7ff; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #3a2f14; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); }
  .lb-stage canvas{ display:block; width:100%; height:auto; }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11.5px; padding:5px 0; border-bottom:1px solid #241d0d; }
  .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#fbbf24; font-weight:700; text-align:right; }
  .regs{ display:grid; grid-template-columns:repeat(2,1fr); gap:4px 10px; font-family:'Geist Mono',monospace; font-size:12px; }
  .regs div{ display:flex; justify-content:space-between; padding:2px 0; } .regs .rn{ color:#8ea0be; } .regs .rv{ color:#fcd34d; font-weight:700; }
</style>
<main class="lb">
  <div>
    <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#fbbf24;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
    <p class="lb-eye" style="margin-top:10px;">Semiconductor · Postgraduate · Computer architecture</p>
    <h1 class="lb-title">Pipelined <em>CPU</em>.</h1>
    <p class="lb-sub">A real 5-stage in-order RISC pipeline — Fetch, Decode, Execute, Memory, Write-back — with operand <b>forwarding</b>, <b>load-use stalls</b> and <b>predict-not-taken</b> branch flushes. The program sums an array in a loop; step the cycles and watch each instruction advance one stage per clock, where hazards force bubbles, and how that drives cycles-per-instruction.</p>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Program</h3><div class="asm" id="asm"></div></div>
      <div class="lb-panel"><h3>Controls</h3>
        <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px;"><button id="stepBtn" class="lb-btn">Step cycle</button><button id="playBtn" class="lb-btn lb-btn-ghost">Run</button><button id="resetBtn" class="lb-btn lb-btn-ghost">Reset</button></div>
        <div class="lb-metric"><span class="lb-metric-l">Cycle</span><span class="lb-metric-v" id="mCyc">0 / 0</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Instructions</span><span class="lb-metric-v" id="mIns">0</span></div>
        <div class="lb-metric"><span class="lb-metric-l">CPI</span><span class="lb-metric-v" id="mCpi">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Load-use stalls</span><span class="lb-metric-v" id="mStall">0</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Branch flushes</span><span class="lb-metric-v" id="mFlush">0</span></div>
      </div>
      <div class="lb-panel"><h3>Registers (final)</h3><div class="regs" id="regs"></div></div>
    </aside>
    <section>
      <div class="lb-stage" style="margin-bottom:12px;"><canvas id="datapath" width="900" height="150"></canvas></div>
      <div class="lb-stage"><canvas id="diagram" width="900" height="470"></canvas></div>
    </section>
  </div>
</main>
<script is:inline>
(function(){
  var P = [
    {op:'ADDI',rd:5,rs:0,imm:100,t:'ADDI r5, r0, 100'},
    {op:'ADDI',rd:1,rs:0,imm:0,t:'ADDI r1, r0, 0'},
    {op:'ADDI',rd:2,rs:0,imm:0,t:'ADDI r2, r0, 0'},
    {op:'ADDI',rd:3,rs:0,imm:2,t:'ADDI r3, r0, 2'},
    {op:'LW',  rt:4,rs:5,imm:0,t:'LW   r4, 0(r5)', label:'loop'},
    {op:'ADD', rd:1,rs:1,rt:4,t:'ADD  r1, r1, r4'},
    {op:'ADDI',rd:5,rs:5,imm:4,t:'ADDI r5, r5, 4'},
    {op:'ADDI',rd:2,rs:2,imm:1,t:'ADDI r2, r2, 1'},
    {op:'BEQ', rs:2,rt:3,imm:10,t:'BEQ  r2, r3, end'},
    {op:'BEQ', rs:0,rt:0,imm:4, t:'BEQ  r0, r0, loop'},
    {op:'NOP', t:'NOP', label:'end'}
  ];
  document.getElementById('asm').innerHTML = P.map(function(I){ var lab=(I.label?(I.label+':'):''); while(lab.length<6) lab+=' '; return '<span class="lbl">'+lab+'</span>'+I.t.replace(/^(\w+)/,'<span class="op">$1</span>'); }).join('\n');

  function run(){
    var regs=[0,0,0,0,0,0,0,0], mem={100:7,104:5}, pc=0, dyn=[], taken=[], guard=0;
    while(pc<P.length && guard++<400){
      var I=P[pc]; dyn.push(pc); var t=false;
      if(I.op==='ADDI'){ regs[I.rd]=regs[I.rs]+I.imm; pc++; }
      else if(I.op==='ADD'){ regs[I.rd]=regs[I.rs]+regs[I.rt]; pc++; }
      else if(I.op==='SUB'){ regs[I.rd]=regs[I.rs]-regs[I.rt]; pc++; }
      else if(I.op==='LW'){ regs[I.rt]=(mem[regs[I.rs]+I.imm]||0); pc++; }
      else if(I.op==='SW'){ mem[regs[I.rs]+I.imm]=regs[I.rt]; pc++; }
      else if(I.op==='BEQ'){ if(regs[I.rs]===regs[I.rt]){ t=true; pc=I.imm; } else pc++; }
      else pc++;
      regs[0]=0; taken.push(t);
    }
    return {regs:regs, dyn:dyn, taken:taken};
  }
  function schedule(dyn, taken){
    var rows=[], issue=1, stalls=0, flushes=0;
    for(var k=0;k<dyn.length;k++){
      var I=P[dyn[k]];
      if(k>0){ var prev=P[dyn[k-1]]; var pd=(prev.op==='LW')?prev.rt:undefined;
        if(pd!==undefined && pd!==0 && (I.rs===pd || I.rt===pd || I.rd===pd)){ issue+=1; stalls++; } }
      rows.push({ I:I, IF:issue, ID:issue+1, EX:issue+2, MEM:issue+3, WB:issue+4 });
      issue+=1;
      if(I.op==='BEQ' && taken[k]){ issue+=2; flushes++; }
    }
    return { rows:rows, total:rows.length?rows[rows.length-1].WB:0, stalls:stalls, flushes:flushes };
  }
  var R=run(), S=schedule(R.dyn, R.taken), cur=0;
  var STAGES=['IF','ID','EX','MEM','WB'], SC={ IF:'#5ee7ff', ID:'#a78bfa', EX:'#fbbf24', MEM:'#f472b6', WB:'#34d399' };
  document.getElementById('regs').innerHTML = R.regs.map(function(v,i){ return '<div><span class="rn">r'+i+'</span><span class="rv">'+v+'</span></div>'; }).join('');
  document.getElementById('mIns').textContent = S.rows.length;
  document.getElementById('mStall').textContent = S.stalls;
  document.getElementById('mFlush').textContent = S.flushes;
  document.getElementById('mCpi').textContent = (S.total/Math.max(1,S.rows.length)).toFixed(2);

  function hidpi(cv){ var r=cv.getBoundingClientRect(), d=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w; cv.width=Math.round(w*d); cv.height=Math.round(h*d); var ctx=cv.getContext('2d'); ctx.setTransform(d,0,0,d,0,0); return {ctx:ctx,w:w,h:h}; }
  function rr(ctx,x,y,w,h,r){ ctx.beginPath(); ctx.moveTo(x+r,y); ctx.arcTo(x+w,y,x+w,y+h,r); ctx.arcTo(x+w,y+h,x,y+h,r); ctx.arcTo(x,y+h,x,y,r); ctx.arcTo(x,y,x+w,y,r); ctx.closePath(); }
  function stageAt(cyc){ var occ={}; for(var k=0;k<S.rows.length;k++){ var r=S.rows[k]; STAGES.forEach(function(st){ if(r[st]===cyc) occ[st]=k; }); } return occ; }
  function drawDatapath(){
    var cv=document.getElementById('datapath'), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h;
    var bg=ctx.createLinearGradient(0,0,0,H); bg.addColorStop(0,'#120e05'); bg.addColorStop(1,'#08060a'); ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    var occ=stageAt(cur), n=5, gap=12, bw=(W-16-gap*(n-1))/n, y=34, bh=H-58;
    STAGES.forEach(function(st,i){ var x=8+i*(bw+gap); var active=occ[st]!==undefined; var col=SC[st];
      ctx.save(); if(active){ ctx.shadowColor=col; ctx.shadowBlur=16; } ctx.strokeStyle=active?col:'#3a2f14'; ctx.lineWidth=2; ctx.fillStyle=active?(col+'22'):'rgba(255,255,255,0.02)'; rr(ctx,x,y,bw,bh,10); ctx.fill(); ctx.stroke(); ctx.restore();
      ctx.fillStyle=active?col:'#6b5f3a'; ctx.font="700 13px 'Geist Mono',monospace"; ctx.textAlign='center'; ctx.fillText(st, x+bw/2, y-10);
      ctx.fillStyle=active?'#e8ecf4':'#3a2f14'; ctx.font=(active?'11px':'10px')+" 'Geist Mono',monospace"; ctx.fillText(active?S.rows[occ[st]].I.t:'—', x+bw/2, y+bh/2);
      if(i<n-1){ ctx.strokeStyle='#4a3d1a'; ctx.lineWidth=2; ctx.beginPath(); ctx.moveTo(x+bw,y+bh/2); ctx.lineTo(x+bw+gap,y+bh/2); ctx.stroke(); }
    });
    ctx.textAlign='left';
  }
  function drawDiagram(){
    var cv=document.getElementById('diagram'), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h;
    ctx.fillStyle='#08060a'; ctx.fillRect(0,0,W,H);
    var gutter=150, top=26, nCyc=S.total, nRow=S.rows.length;
    var cellW=Math.max(20,(W-gutter-10)/nCyc), cellH=Math.min(26,(H-top-8)/Math.max(1,nRow));
    ctx.font="10px 'Geist Mono',monospace"; ctx.textAlign='center';
    for(var c=1;c<=nCyc;c++){ ctx.fillStyle=(c===cur)?'#fbbf24':'#6b5f3a'; ctx.fillText(String(c), gutter+(c-0.5)*cellW, 16); }
    if(cur>=1 && cur<=nCyc){ ctx.fillStyle='rgba(251,191,36,0.10)'; ctx.fillRect(gutter+(cur-1)*cellW, top, cellW, cellH*nRow); }
    ctx.textAlign='left';
    for(var k=0;k<nRow;k++){ var r=S.rows[k], y=top+k*cellH;
      ctx.fillStyle='#8ea0be'; ctx.font="10.5px 'Geist Mono',monospace"; ctx.fillText(r.I.t.slice(0,20), 6, y+cellH*0.68);
      STAGES.forEach(function(st){ var c=r[st], x=gutter+(c-1)*cellW, col=SC[st];
        ctx.save(); if(c===cur){ ctx.shadowColor=col; ctx.shadowBlur=8; } ctx.fillStyle=col+(c===cur?'':'cc'); rr(ctx,x+1,y+1,cellW-2,cellH-2,4); ctx.fill(); ctx.restore();
        ctx.fillStyle='#0a0806'; ctx.font="700 9px 'Geist Mono',monospace"; ctx.textAlign='center'; ctx.fillText(st, x+cellW/2, y+cellH*0.66); ctx.textAlign='left';
      });
    }
    ctx.fillStyle='#6b5f3a'; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText('rows = instructions (execution order) · columns = clock cycles · a gap = a pipeline bubble', 6, H-6);
  }
  function render(){ document.getElementById('mCyc').textContent = cur + ' / ' + S.total; drawDatapath(); drawDiagram(); }
  document.getElementById('stepBtn').addEventListener('click', function(){ if(cur<S.total) cur++; render(); });
  document.getElementById('resetBtn').addEventListener('click', function(){ cur=0; playing=false; clearInterval(timer); document.getElementById('playBtn').textContent='Run'; render(); });
  var playing=false, timer=null;
  document.getElementById('playBtn').addEventListener('click', function(){ playing=!playing; this.textContent=playing?'Pause':'Run';
    if(playing){ timer=setInterval(function(){ if(cur<S.total) cur++; else { playing=false; document.getElementById('playBtn').textContent='Run'; clearInterval(timer); } render(); }, 480); } else clearInterval(timer); });
  window.addEventListener('resize', function(){ clearTimeout(window._t); window._t=setTimeout(render,150); });
  render();
})();
</script>
</BaseLayout>
