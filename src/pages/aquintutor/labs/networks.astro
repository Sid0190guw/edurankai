          '<td class="mono">' + ipToStr(subNet) + '/' + newP + '</td>' +
          '<td>' + ipToStr(f) + ' - ' + ipToStr(l) + '</td>' +
          '<td class="mono">' + ipToStr(subBc) + '</td>';
        tb.appendChild(tr);
      }
    }

