    }

    function compute() {
      var err = $('ipErr'); err.textContent = '';
      var v = parseIp(addrEl.value);
      var p = parseInt(pfxEl.value, 10);
      if (v === null) { err.textContent = 'Invalid IPv4 address — use four octets 0..255.'; return null; }
      if (isNaN(p) || p < 0 || p > 32) { err.textContent = 'Prefix must be 0..32.'; return null; }
      var mask = maskFor(p);
      var net = networkOf(v, p);
      var bc = broadcastOf(v, p);
      var total = (p >= 32) ? 1 : Math.pow(2, 32 - p);
      var usable, first, last;
      if (p >= 31) {
        usable = (p === 32) ? 1 : 2;   // /31 point-to-point (RFC 3021), /32 single host
        first = net; last = bc;
      } else {
        usable = total - 2;
        first = (net + 1) >>> 0; last = (bc - 1) >>> 0;
      }
      show32(v, p);
      $('ipClass').textContent = ipClass(v);
      $('ipUsable').textContent = usable.toLocaleString();
      $('ipBlock').textContent = total.toLocaleString();

      var rows = [
        ['Address', ipToStr(v) + '  /' + p],
        ['Subnet mask', ipToStr(mask)],
        ['Wildcard', ipToStr((~mask) >>> 0)],
        ['Network', ipToStr(net)],
        ['Broadcast', ipToStr(bc)],
        ['First host', ipToStr(first)],
        ['Last host', ipToStr(last)],
        ['Total addresses', total.toLocaleString()],
        ['Usable hosts', usable.toLocaleString()]
      ];
      var tb = $('ipMainTbl').querySelector('tbody');
      tb.innerHTML = '';
      for (var i = 0; i < rows.length; i++) {
        var tr = document.createElement('tr');
        tr.innerHTML = '<td>' + rows[i][0] + '</td><td class="mono">' + rows[i][1] + '</td>';
        tb.appendChild(tr);
      }
      return { v: v, p: p, net: net, bc: bc };
    }

    function subnet() {
      var r = compute();
      if (!r) return;
      var n = parseInt($('ipSplit').value, 10);
      var bits = Math.ceil(Math.log(n) / Math.log(2));
      var newP = r.p + bits;
      if (newP > 32) { $('ipErr').textContent = 'Cannot split — not enough host bits for ' + n + ' subnets.'; return; }
      var perBits = 32 - newP;
      var stride = (perBits >= 32) ? Math.pow(2, 32) : Math.pow(2, perBits);
      var per = (newP >= 31) ? ((newP === 32) ? 1 : 2) : (Math.pow(2, perBits) - 2);
      $('ipNewPfx').textContent = '/' + newP;
      $('ipPerSub').textContent = per.toLocaleString();

      var tb = $('ipSubTbl').querySelector('tbody');
      tb.innerHTML = '';
      var base = r.net >>> 0;
      for (var i = 0; i < n; i++) {
        var subNet = (base + i * stride) >>> 0;
