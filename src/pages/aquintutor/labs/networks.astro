        ctx.textAlign = 'left';
        var lbl = (r.kind === 'ack' ? 'ACK' : (r.retx ? 'RTX' : 'F')) + r.seq + (r.lost ? ' (lost)' : '');
        ctx.fillText(lbl, (r.kind === 'ack' ? sx + 10 : sx + 10), ry - 4);
      }
      $('swWinTxt').textContent = winInfo;
      $('swDeliv').textContent = stats.deliv;
      $('swTx').textContent = stats.tx;
      $('swRetx').textContent = stats.retx;
      var eff = stats.tx > 0 ? (stats.deliv / stats.tx) : 0;
      $('swEff').textContent = (eff * 100).toFixed(0) + '%';
    }

    var queue = [];
    function reset() {
      rows = []; queue = []; busy = false;
      stats = { deliv: 0, tx: 0, retx: 0 }; winInfo = 'W=' + W();
      clearLog($('swLog'));
      drawRows(false, 1);
    }

    function pushEventVisual(e) {
      if (e.type === 'frame') {
        rows.push({ seq: e.seq, kind: 'frame', lost: e.lost, retx: !!e.retx });
        winInfo = 'base..' + e.win[0] + '-' + e.win[1];
        logTo($('swLog'), (e.retx ? 'Retransmit ' : 'Send ') + '<b>F' + e.seq + '</b>' + (e.lost ? ' &mdash; <span style="color:#fca5a5">lost</span>' : ''));
      } else if (e.type === 'ack') {
        rows.push({ seq: e.seq, kind: 'ack', lost: false });
        logTo($('swLog'), 'Receiver <b>ACK ' + e.seq + '</b>' + (e.cum ? ' (cumulative)' : ''));
      } else if (e.type === 'timeout') {
        logTo($('swLog'), '<span style="color:#fbbf24">Timeout on F' + e.seq + '</span> &mdash; ' + (proto === 'gbn' ? 'go back to ' + e.seq : 'resend ' + e.seq + ' only'));
      }
      // recompute live stats
      var deliv = 0, tx = 0, retx = 0, maxAck = -1;
      for (var i = 0; i < rows.length; i++) {
        if (rows[i].kind === 'frame') { tx++; if (rows[i].retx) retx++; }
        if (rows[i].kind === 'ack' && rows[i].seq > maxAck) maxAck = rows[i].seq;
      }
      // delivered = number of distinct acked
      var ackset = {};
      for (var j = 0; j < rows.length; j++) if (rows[j].kind === 'ack') ackset[rows[j].seq] = 1;
      deliv = Object.keys(ackset).length;
      stats.deliv = deliv; stats.tx = tx; stats.retx = retx;
    }

    async function animateLast(isFrame) {
      var frames = 16;
      for (var f = 0; f <= frames; f++) { drawRows(true, f / frames); await sleep(delayFor(spd) / frames); }
      drawRows(false, 1);
    }

    async function stepOne() {
      if (!queue.length) return false;
      var e = queue.shift();
      pushEventVisual(e);
      if (e.type === 'timeout') { drawRows(false, 1); await sleep(delayFor(spd) * 0.5); return true; }
      await animateLast(e.type === 'frame');
      return true;
    }

    async function run() {
      if (busy) return;
      reset();
      queue = plan();
      busy = true;
      $('swRun').disabled = true;
      while (queue.length) { var more = await stepOne(); if (!more) break; }
      $('swRun').disabled = false;
      busy = false;
      logTo($('swLog'), '<b>Done.</b> ' + stats.deliv + ' delivered in ' + stats.tx + ' transmissions (' + stats.retx + ' retransmits).');
    }

    // proto segmented control
    var opts = document.querySelectorAll('#exp-3 .seg .opt');
    for (var o = 0; o < opts.length; o++) {
      opts[o].addEventListener('click', function () {
        if (busy) return;
        for (var i = 0; i < opts.length; i++) opts[i].classList.remove('on');
        this.classList.add('on');
        proto = this.getAttribute('data-proto');
        $('swProtoBadge').textContent = proto === 'gbn' ? 'Go-Back-N' : 'Selective Repeat';
        // clamp window for SR
        reset();
      });
    }

    $('swRun').addEventListener('click', run);
    $('swStep').addEventListener('click', function () {
      if (busy) return;
      if (!queue.length) { reset(); queue = plan(); }
      busy = true;
      stepOne().then(function () { busy = false; if (!queue.length) logTo($('swLog'), '<b>Done.</b>'); });
    });
    $('swReset').addEventListener('click', function () { if (!busy) reset(); });

    $('swWin').addEventListener('input', function () { $('swWinv').textContent = this.value; winInfo = 'W=' + this.value; if (!busy) reset(); });
    $('swFrames').addEventListener('input', function () { $('swFramesv').textContent = this.value; if (!busy) reset(); });
    $('swLoss').addEventListener('input', function () { $('swLossv').textContent = (this.value / 100).toFixed(2); if (!busy) reset(); });
    bindSpeed('swSpd', 'swSpdv', function (v) { spd = v; });

    REDRAW['3'] = function () { ctx = makeCtx(cv, LW, LH); drawRows(false, 1); };
    reset();
  })();

  // ===================================================================
  // EXPERIMENT 4 — ROUTING (Dijkstra + Bellman-Ford one iteration)
  // ===================================================================
  (function Routing() {
    var cv = $('rtCv'); if (!cv) return;
    var LW = 660, LH = 430;
    var ctx = makeCtx(cv, LW, LH);
    var nodes = [];   // {id,x,y,label}
    var edges = [];   // {a,b,w}
    var pending = null;
    var srcId = 0;
    var dijk = null;  // {dist,prev,tree:set of "a-b"}
    var INF = Infinity;

    function nodeLabel(i) { return String.fromCharCode(65 + i); }

    function addNode(x, y) {
      var id = nodes.length;
      nodes.push({ id: id, x: x, y: y, label: nodeLabel(id) });
      refreshSrc();
      stats();
    }
    function addEdge(a, b, w) {
      if (a === b) return;
      for (var i = 0; i < edges.length; i++) {
        if ((edges[i].a === a && edges[i].b === b) || (edges[i].a === b && edges[i].b === a)) { edges[i].w = w; stats(); return; }
      }
      edges.push({ a: a, b: b, w: w });
      stats();
    }

    function neighborsOf(id) {
      var out = [];
      for (var i = 0; i < edges.length; i++) {
        if (edges[i].a === id) out.push({ to: edges[i].b, w: edges[i].w });
        else if (edges[i].b === id) out.push({ to: edges[i].a, w: edges[i].w });
      }
      return out;
    }

    function dijkstra(src) {
      var n = nodes.length;
      var dist = new Array(n).fill(INF);
      var prev = new Array(n).fill(-1);
      var done = new Array(n).fill(false);
      dist[src] = 0;
      for (var it = 0; it < n; it++) {
        var u = -1, best = INF;
        for (var i = 0; i < n; i++) if (!done[i] && dist[i] < best) { best = dist[i]; u = i; }
        if (u === -1) break;
        done[u] = true;
        var nb = neighborsOf(u);
        for (var k = 0; k < nb.length; k++) {
          var v = nb[k].to, w = nb[k].w;
          if (dist[u] + w < dist[v]) { dist[v] = dist[u] + w; prev[v] = u; }
        }
      }
      var tree = {};
      for (var j = 0; j < n; j++) if (prev[j] >= 0) tree[Math.min(prev[j], j) + '-' + Math.max(prev[j], j)] = 1;
      return { dist: dist, prev: prev, tree: tree };
    }

    function draw() {
      ctx.clearRect(0, 0, LW, LH);
      ctx.fillStyle = COL.bg; ctx.fillRect(0, 0, LW, LH);
      // edges
      for (var i = 0; i < edges.length; i++) {
        var a = nodes[edges[i].a], b = nodes[edges[i].b];
        var key = Math.min(edges[i].a, edges[i].b) + '-' + Math.max(edges[i].a, edges[i].b);
        var inTree = dijk && dijk.tree[key];
        ctx.strokeStyle = inTree ? COL.amber : COL.edge;
        ctx.lineWidth = inTree ? 3.5 : 1.6;
        ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.stroke();
        // weight
        var mx = (a.x + b.x) / 2, my = (a.y + b.y) / 2;
        ctx.fillStyle = '#0a0a0c'; ctx.fillRect(mx - 12, my - 9, 24, 18);
        ctx.fillStyle = inTree ? COL.amber : '#9aa0aa';
        ctx.font = 'bold 11px Geist Mono'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(edges[i].w, mx, my);
      }
      // nodes
      for (var j = 0; j < nodes.length; j++) {
        var nd = nodes[j];
        var isSrc = nd.id === srcId;
        var reached = dijk && dijk.dist[j] !== INF;
        ctx.beginPath(); ctx.arc(nd.x, nd.y, 20, 0, Math.PI * 2);
        ctx.fillStyle = isSrc ? COL.cyan : (reached ? '#16351f' : COL.node);
        ctx.fill();
        ctx.lineWidth = 2.2;
        ctx.strokeStyle = isSrc ? COL.cyan : (pending === nd.id ? COL.purple : (reached ? COL.green : COL.stroke));
        ctx.stroke();
        ctx.fillStyle = isSrc ? '#04161b' : COL.text;
        ctx.font = 'bold 14px Geist Mono'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(nd.label, nd.x, nd.y);
        if (dijk) {
          var d = dijk.dist[j];
          ctx.fillStyle = d === INF ? COL.red : COL.green;
          ctx.font = '10px Geist Mono';
          ctx.fillText(d === INF ? 'inf' : ('d=' + d), nd.x, nd.y - 30);
        }
      }
    }

    function stats() {
      $('rtN').textContent = nodes.length;
      $('rtE').textContent = edges.length;
      draw();
    }

    function refreshSrc() {
      var sel = $('rtSrc');
      var cur = sel.value;
      sel.innerHTML = '';
      for (var i = 0; i < nodes.length; i++) {
        var op = document.createElement('option');
        op.value = i; op.textContent = nodes[i].label;
        sel.appendChild(op);
      }
      if (cur && parseInt(cur, 10) < nodes.length) sel.value = cur;
      else if (nodes.length) { sel.value = String(srcId < nodes.length ? srcId : 0); }
    }

    function runDijkstra() {
      if (nodes.length === 0) return;
      srcId = parseInt($('rtSrc').value, 10) || 0;
      dijk = dijkstra(srcId);
      var tb = $('rtDijkTbl').querySelector('tbody');
      tb.innerHTML = '';
      for (var i = 0; i < nodes.length; i++) {
        var d = dijk.dist[i];
        var via = dijk.prev[i] >= 0 ? nodes[dijk.prev[i]].label : (i === srcId ? '(source)' : '--');
        var tr = document.createElement('tr');
        tr.innerHTML = '<td class="mono">' + nodes[i].label + '</td><td>' + (d === INF ? '<span class="err">unreachable</span>' : d) + '</td><td>' + via + '</td>';
        tb.appendChild(tr);
      }
      logTo($('rtLog'), 'Dijkstra from <b>' + nodes[srcId].label + '</b>: shortest-path tree highlighted in amber.');
      draw();
    }

    function dvIteration() {
      // one synchronous Bellman-Ford round from the source's perspective table
      if (nodes.length === 0) return;
      srcId = parseInt($('rtSrc').value, 10) || 0;
      var n = nodes.length;
      // build full D matrix initialised to direct costs, then one relax round, show src row
      var D = [];
      for (var i = 0; i < n; i++) { D.push(new Array(n).fill(INF)); D[i][i] = 0; }
      for (var e = 0; e < edges.length; e++) {
        var a = edges[e].a, b = edges[e].b, w = edges[e].w;
        D[a][b] = Math.min(D[a][b], w); D[b][a] = Math.min(D[b][a], w);
      }
      // old estimate (this node's current vector = direct costs)
      var old = D[srcId].slice();
      // one synchronous update: D[src][t] = min over neighbours n of c(src,n)+D[n][t]
      var nw = old.slice();
      var nb = neighborsOf(srcId);
      for (var t = 0; t < n; t++) {
        if (t === srcId) continue;
        var best = old[t];
        for (var k = 0; k < nb.length; k++) {
          var via = nb[k].to, c = nb[k].w;
          if (D[via][t] !== INF && c + D[via][t] < best) best = c + D[via][t];
        }
        nw[t] = best;
      }
      var tb = $('rtDVTbl').querySelector('tbody');
      tb.innerHTML = '';
      var changed = 0;
      for (var d2 = 0; d2 < n; d2++) {
        if (d2 === srcId) continue;
        var ch = nw[d2] !== old[d2];
        if (ch) changed++;
        var tr = document.createElement('tr');
        tr.innerHTML = '<td class="mono">' + nodes[d2].label + '</td><td>' + (old[d2] === INF ? 'inf' : old[d2]) + '</td><td' + (ch ? ' class="mono"' : '') + '>' + (nw[d2] === INF ? 'inf' : nw[d2]) + (ch ? ' *' : '') + '</td>';
        tb.appendChild(tr);
      }
      logTo($('rtLog'), 'DV iteration from <b>' + nodes[srcId].label + '</b>: ' + changed + ' entries improved (marked *).');
    }

    function clearAll() {
      nodes = []; edges = []; pending = null; dijk = null; srcId = 0;
      $('rtDijkTbl').querySelector('tbody').innerHTML = '';
      $('rtDVTbl').querySelector('tbody').innerHTML = '';
      refreshSrc(); stats();
    }

    function sample() {
      clearAll();
      var P = [[140, 90], [330, 70], [520, 110], [120, 300], [340, 320], [540, 300]];
      for (var i = 0; i < P.length; i++) nodes.push({ id: i, x: P[i][0], y: P[i][1], label: nodeLabel(i) });
      addEdge(0, 1, 2); addEdge(1, 2, 3); addEdge(0, 3, 6); addEdge(1, 4, 2);
      addEdge(3, 4, 1); addEdge(4, 5, 4); addEdge(2, 5, 1); addEdge(1, 3, 5); addEdge(4, 2, 5);
      srcId = 0; refreshSrc(); $('rtSrc').value = '0'; stats();
      logTo($('rtLog'), 'Loaded sample six-node network. Run Dijkstra from A.');
    }

    function pick(x, y) {
      for (var i = 0; i < nodes.length; i++) {
        var dx = nodes[i].x - x, dy = nodes[i].y - y;
        if (dx * dx + dy * dy <= 22 * 22) return i;
      }
      return -1;
    }

    cv.addEventListener('contextmenu', function (e) { e.preventDefault(); });
    cv.addEventListener('mousedown', function (e) {
      var rect = cv.getBoundingClientRect();
      var sxr = LW / rect.width, syr = LH / rect.height;
      var x = (e.clientX - rect.left) * sxr, y = (e.clientY - rect.top) * syr;
      var hit = pick(x, y);
      if (e.button === 2) {
        if (hit >= 0) { srcId = hit; $('rtSrc').value = String(hit); dijk = null; $('rtMode').textContent = 'source = ' + nodes[hit].label; draw(); }
        return;
      }
      if (hit >= 0) {
        if (pending === null) { pending = hit; $('rtMode').textContent = 'pick 2nd node'; draw(); }
        else if (pending === hit) { pending = null; $('rtMode').textContent = 'add nodes'; draw(); }
        else {
          var w = parseInt($('rtW').value, 10); if (isNaN(w) || w < 1) w = 1;
          addEdge(pending, hit, w);
          logTo($('rtLog'), 'Edge ' + nodes[pending].label + ' &mdash; ' + nodes[hit].label + ' weight ' + w);
          pending = null; dijk = null; $('rtMode').textContent = 'add nodes'; draw();
        }
      } else {
        if (pending !== null) { pending = null; $('rtMode').textContent = 'add nodes'; }
        addNode(x, y);
        logTo($('rtLog'), 'Added node ' + nodes[nodes.length - 1].label);
      }
    });

    $('rtRun').addEventListener('click', runDijkstra);
    $('rtDV').addEventListener('click', dvIteration);
    $('rtSample').addEventListener('click', sample);
    $('rtClear').addEventListener('click', clearAll);
    $('rtUndo').addEventListener('click', function () { if (edges.length) { edges.pop(); dijk = null; stats(); } });
    $('rtSrc').addEventListener('change', function () { srcId = parseInt(this.value, 10) || 0; dijk = null; draw(); });

    REDRAW['4'] = function () { ctx = makeCtx(cv, LW, LH); draw(); };
    sample();
  })();

  // ===================================================================
  // EXPERIMENT 5 — ERROR DETECTION & CORRECTION
  // ===================================================================
  (function ErrorControl() {
    if (!$('crcMsg')) return;

    // ---- CRC ----
    function cleanBits(s) { return (s || '').replace(/[^01]/g, ''); }
    function crcCompute() {
      var err = $('crcErr'); err.textContent = '';
      var msg = cleanBits($('crcMsg').value);
      var gen = cleanBits($('crcGen').value);
      if (!msg) { err.textContent = 'Message must be a non-empty binary string.'; return; }
      if (gen.length < 2 || gen[0] !== '1') { err.textContent = 'Generator must be binary, start with 1, length >= 2.'; return; }
      var r = gen.length - 1;
      var aug = msg + new Array(r + 1).join('0');
      var bits = aug.split('').map(Number);
      var trace = '';
      var work = bits.slice();
      // long division
      trace += 'dividend (augmented): ' + aug + '\n';
      for (var i = 0; i + gen.length <= work.length; i++) {
        if (work[i] === 1) {
          var line = '';
          for (var s = 0; s < work.length; s++) line += (s < i ? ' ' : (s < i + gen.length ? gen[s - i] : ' '));
          trace += line + '  <- XOR\n';
          for (var j = 0; j < gen.length; j++) work[i + j] ^= +gen[j];
          var cur = work.join('');
          trace += cur + '\n';
        }
      }
      var rem = work.slice(work.length - r).join('');
      var frame = msg + rem;
      trace += 'remainder (CRC): ' + rem + '\n';
      $('crcTrace').textContent = trace;
      $('crcOut').innerHTML = '<b>CRC remainder:</b> <span style="color:#67e8f9">' + rem + '</span><br><b>Transmitted frame:</b> <span style="color:#86efac">' + frame + '</span><br><b>Verify:</b> dividing the frame by the generator gives remainder ' + verifyZero(frame, gen, r);
    }
    function verifyZero(frame, gen, r) {
      var work = frame.split('').map(Number);
      for (var i = 0; i + gen.length <= work.length; i++) {
        if (work[i] === 1) for (var j = 0; j < gen.length; j++) work[i + j] ^= +gen[j];
      }
      var rem = work.slice(work.length - r).join('');
      return /^0*$/.test(rem) ? '<span class="ok">0 (no error)</span>' : '<span class="err">' + rem + '</span>';
    }
    $('crcGo').addEventListener('click', crcCompute);

    // ---- Internet checksum ----
    function checksum() {
      var raw = ($('cksWords').value || '').trim().split(/\s+/);
      var words = [];
      for (var i = 0; i < raw.length; i++) {
        if (!raw[i]) continue;
        if (!/^[0-9a-fA-F]{1,4}$/.test(raw[i])) { $('cksOut').innerHTML = '<span class="err">Each word must be 1-4 hex digits.</span>'; return; }
        words.push(parseInt(raw[i], 16) & 0xFFFF);
      }
      if (!words.length) { $('cksOut').innerHTML = '<span class="err">Enter at least one word.</span>'; return; }
      var sum = 0;
      for (var k = 0; k < words.length; k++) {
        sum += words[k];
        sum = (sum & 0xFFFF) + (sum >>> 16);   // end-around carry
      }
      sum = (sum & 0xFFFF) + (sum >>> 16);
      var chk = (~sum) & 0xFFFF;
      function hx(x) { return ('000' + x.toString(16)).slice(-4); }
      var verifySum = sum;
      var vTotal = sum + chk;
      vTotal = (vTotal & 0xFFFF) + (vTotal >>> 16);
      $('cksOut').innerHTML = '<b>Wrapped 16-bit sum:</b> 0x' + hx(sum) +
        '<br><b>Checksum (one\'s complement):</b> <span style="color:#67e8f9">0x' + hx(chk) + '</span>' +
        '<br><b>Receiver check:</b> sum + checksum = 0x' + hx(vTotal) + ' &rarr; ' + (vTotal === 0xFFFF ? '<span class="ok">all ones, OK</span>' : '<span class="err">error</span>');
    }
    $('cksGo').addEventListener('click', checksum);

    // ---- Hamming(7,4) ----
    var code = [0, 0, 0, 0, 0, 0, 0];  // positions 1..7 stored 0-indexed
    function renderBits() {
      var host = $('hamBits'); host.innerHTML = '';
      var names = ['p1', 'p2', 'd1', 'p4', 'd2', 'd3', 'd4'];
      for (var i = 0; i < 7; i++) {
        (function (idx) {
          var d = document.createElement('div');
          var isP = (idx === 0 || idx === 1 || idx === 3);
          d.style.cssText = 'width:42px;text-align:center;border:1px solid ' + (isP ? '#3a4054' : '#a78bfa') + ';border-radius:6px;padding:6px 0;cursor:pointer;background:#0a0a0c;';
          d.innerHTML = '<div style="font-size:9px;color:#9aa0aa">' + names[idx] + ' (' + (idx + 1) + ')</div><div style="font-size:18px;color:' + (code[idx] ? '#67e8f9' : '#6b7280') + ';font-weight:700">' + code[idx] + '</div>';
          d.addEventListener('click', function () {
            code[idx] ^= 1;
            $('hamBadge').textContent = 'bit ' + (idx + 1) + ' flipped';
            $('hamBadge').className = 'badge warn';
            renderBits();
          });
          host.appendChild(d);
        })(i);
      }
    }
    function encode() {
      var data = cleanBits($('hamData').value);
      if (data.length !== 4) { $('hamOut').innerHTML = '<span class="err">Enter exactly 4 data bits.</span>'; return; }
      var d1 = +data[0], d2 = +data[1], d3 = +data[2], d4 = +data[3];
      // positions: 1=p1 2=p2 3=d1 4=p4 5=d2 6=d3 7=d4
      var p1 = d1 ^ d2 ^ d4;        // covers 3,5,7
      var p2 = d1 ^ d3 ^ d4;        // covers 3,6,7
      var p4 = d2 ^ d3 ^ d4;        // covers 5,6,7
      code = [p1, p2, d1, p4, d2, d3, d4];
      $('hamBadge').textContent = 'encoded'; $('hamBadge').className = 'badge';
      $('hamSyn').textContent = '--'; $('hamPos').textContent = '--';
      $('hamOut').innerHTML = '<b>Codeword:</b> <span style="color:#86efac">' + code.join('') + '</span><br>p1=' + p1 + ' p2=' + p2 + ' p4=' + p4 + '. Click a bit to inject an error, then Decode.';
      renderBits();
    }
    function decode() {
      // syndrome from received bits at positions 1..7
      var b = code;  // b[0]=pos1 ...
      // recompute parity checks
      var c1 = b[0] ^ b[2] ^ b[4] ^ b[6];   // pos 1,3,5,7
      var c2 = b[1] ^ b[2] ^ b[5] ^ b[6];   // pos 2,3,6,7
      var c4 = b[3] ^ b[4] ^ b[5] ^ b[6];   // pos 4,5,6,7
      var syn = c1 + c2 * 2 + c4 * 4;
      $('hamSyn').textContent = '' + c4 + c2 + c1 + ' (' + syn + ')';
      if (syn === 0) {
        $('hamPos').textContent = 'none';
        $('hamBadge').textContent = 'no error'; $('hamBadge').className = 'badge';
        $('hamOut').innerHTML = '<span class="ok">Syndrome 0 &mdash; no single-bit error detected.</span>';
      } else {
        $('hamPos').textContent = 'bit ' + syn;
        var corrected = code.slice();
        corrected[syn - 1] ^= 1;
        $('hamBadge').textContent = 'corrected bit ' + syn; $('hamBadge').className = 'badge';
        $('hamOut').innerHTML = '<span style="color:#fbbf24">Syndrome ' + syn + '</span> &rarr; error at position ' + syn + '. Corrected codeword: <span style="color:#86efac">' + corrected.join('') + '</span>. Data bits d1..d4 = <b>' + corrected[2] + corrected[4] + corrected[5] + corrected[6] + '</b>';
        code = corrected;
        renderBits();
      }
    }
    $('hamEnc').addEventListener('click', encode);
    $('hamDec').addEventListener('click', decode);

    REDRAW['5'] = function () { if (!$('hamBits').children.length) encode(); };
    encode();
    crcCompute();
    checksum();
  })();

  // ===================================================================
  // EXPERIMENT 6 — CIDR AGGREGATION HELPER
  // ===================================================================
  (function Cidr() {
    if (!$('cidrIn')) return;

    function parsePrefix(line) {
      var m = line.trim().match(/^(\d+\.\d+\.\d+\.\d+)\/(\d+)$/);
      if (!m) return null;
      var v = parseIp(m[1]);
      var p = parseInt(m[2], 10);
      if (v === null || p < 0 || p > 32) return null;
      return { net: networkOf(v, p), p: p };
    }

    function aggregate() {
      $('cidrErr').textContent = '';
      var lines = ($('cidrIn').value || '').split('\n');
      var list = [];
      for (var i = 0; i < lines.length; i++) {
        if (!lines[i].trim()) continue;
        var pf = parsePrefix(lines[i]);
        if (!pf) { $('cidrErr').textContent = 'Bad prefix: ' + lines[i].trim(); return; }
        list.push(pf);
      }
      if (!list.length) { $('cidrErr').textContent = 'Enter at least one prefix.'; return; }
      $('cidrInN').textContent = list.length;

      // sort by net then prefix
      list.sort(function (a, b) { return (a.net - b.net) || (a.p - b.p); });
      // remove duplicates / contained prefixes
      var dedup = [];
      for (var k = 0; k < list.length; k++) {
        var contained = false;
        for (var j = 0; j < dedup.length; j++) {
          if (dedup[j].p <= list[k].p && networkOf(list[k].net, dedup[j].p) === dedup[j].net) { contained = true; break; }
        }
        if (!contained) dedup.push(list[k]);
      }

      // iterative sibling merge
      var changed = true;
      var cur = dedup.slice();
      while (changed) {
        changed = false;
        cur.sort(function (a, b) { return (a.net - b.net) || (a.p - b.p); });
        var merged = [];
        var used = new Array(cur.length).fill(false);
        for (var a = 0; a < cur.length; a++) {
          if (used[a]) continue;
          var mergedFlag = false;
          for (var b2 = a + 1; b2 < cur.length; b2++) {
            if (used[b2]) continue;
            if (cur[a].p === cur[b2].p && cur[a].p > 0) {
              var parentP = cur[a].p - 1;
              if (networkOf(cur[a].net, parentP) === networkOf(cur[b2].net, parentP) && cur[a].net !== cur[b2].net) {
                // true siblings: lower of the two is the parent network
                merged.push({ net: networkOf(cur[a].net, parentP), p: parentP });
                used[a] = used[b2] = true; mergedFlag = true; changed = true; break;
              }
            }
          }
          if (!mergedFlag && !used[a]) merged.push(cur[a]);
        }
        cur = merged;
      }
      // final dedup again
      cur.sort(function (a, b) { return (a.net - b.net) || (a.p - b.p); });
      var finalSet = [];
      for (var f = 0; f < cur.length; f++) {
        var cont2 = false;
        for (var g = 0; g < finalSet.length; g++) {
          if (finalSet[g].p <= cur[f].p && networkOf(cur[f].net, finalSet[g].p) === finalSet[g].net) { cont2 = true; break; }
        }
        if (!cont2) finalSet.push(cur[f]);
      }

      $('cidrOutN').textContent = finalSet.length;
      var tb = $('cidrResTbl').querySelector('tbody');
      tb.innerHTML = '';
      for (var r = 0; r < finalSet.length; r++) {
        var span = (finalSet[r].p >= 32) ? 1 : Math.pow(2, 32 - finalSet[r].p);
        var tr = document.createElement('tr');
        tr.innerHTML = '<td>' + (r + 1) + '</td><td class="mono">' + ipToStr(finalSet[r].net) + '/' + finalSet[r].p + '</td><td>' + span.toLocaleString() + '</td>';
        tb.appendChild(tr);
      }
      window.__cidrOriginals = list;
    }

    function lpm() {
      var addr = parseIp(($('cidrLpm').value || '').trim());
      var tb = $('cidrLpmTbl').querySelector('tbody');
      tb.innerHTML = '';
      if (addr === null) {
        tb.innerHTML = '<tr><td><span class="err">Invalid address.</span></td></tr>';
        return;
      }
      var originals = window.__cidrOriginals || [];
      if (!originals.length) { aggregate(); originals = window.__cidrOriginals || []; }
      var bestP = -1, best = null;
      for (var i = 0; i < originals.length; i++) {
        if (networkOf(addr, originals[i].p) === originals[i].net && originals[i].p > bestP) {
          bestP = originals[i].p; best = originals[i];
        }
      }
      var rows = [['Target', ipToStr(addr)]];
      if (best) {
        rows.push(['Longest match', ipToStr(best.net) + '/' + best.p]);
        rows.push(['Result', 'matched']);
      } else {
        rows.push(['Longest match', 'none']);
        rows.push(['Result', 'no route']);
      }
      for (var r = 0; r < rows.length; r++) {
        var tr = document.createElement('tr');
        var val = rows[r][1];
        var cls = (rows[r][0] === 'Result') ? (best ? 'ok' : 'err') : 'mono';
        tr.innerHTML = '<td>' + rows[r][0] + '</td><td class="' + cls + '">' + val + '</td>';
        tb.appendChild(tr);
      }
    }

    $('cidrAgg').addEventListener('click', aggregate);
    $('cidrLpmGo').addEventListener('click', lpm);

    REDRAW['6'] = function () { if (!$('cidrResTbl').querySelector('tbody').children.length) aggregate(); };
    aggregate();
  })();

  // ===================================================================
  // SELF-ASSESSMENT QUIZZES
  // ===================================================================
  var QUIZZES = {
    '1': [
      { q: 'The host 192.168.10.130 with prefix /26 belongs to which network?',
        o: ['192.168.10.0', '192.168.10.128', '192.168.10.64', '192.168.10.192'], a: 1,
        e: 'A /26 has a block size of 64; 130 falls in the 128..191 block, so the network is .128.' },
      { q: 'A /29 subnet provides how many usable host addresses?',
        o: ['8', '6', '4', '14'], a: 1,
        e: '2^(32-29) = 8 total, minus the network and broadcast, leaves 6 usable hosts.' },
      { q: 'The broadcast address of a subnet is formed by:',
        o: ['address AND mask', 'network OR (NOT mask)', 'network minus one', 'address XOR mask'], a: 1,
        e: 'Setting every host bit to 1 means OR-ing the network with the inverted (wildcard) mask.' },
      { q: 'To split one block into 8 equal subnets you must borrow:',
        o: ['1 host bit', '2 host bits', '3 host bits', '8 host bits'], a: 2,
        e: '2^3 = 8, so three borrowed bits lengthen the prefix and create eight subnets.' }
    ],
    '2': [
      { q: 'In the three-way handshake, the server replies to the SYN with:',
        o: ['ACK only', 'SYN only', 'SYN and ACK together', 'FIN'], a: 2,
        e: 'The middle segment carries both SYN (server synchronises) and ACK (acknowledges the client SYN).' },
      { q: 'If the client SYN carries seq=x, the server acknowledgement number is:',
        o: ['x', 'x + 1', 'y', 'x - 1'], a: 1,
        e: 'A SYN consumes one sequence number, so the server acknowledges x + 1.' },
      { q: 'After sending its SYN, the active client is in which state?',
        o: ['LISTEN', 'SYN-SENT', 'ESTABLISHED', 'TIME-WAIT'], a: 1,
        e: 'The client moves CLOSED to SYN-SENT and waits for the SYN-ACK before ESTABLISHED.' },
      { q: 'The TIME-WAIT state exists mainly to:',
        o: ['Speed up the next connection', 'Let stray segments drain before the socket is reused', 'Send more data', 'Acknowledge the SYN'], a: 1,
        e: 'TIME-WAIT lasts twice the maximum segment lifetime so old duplicates expire safely.' }
    ],
    '3': [
      { q: 'When a frame is lost, Go-Back-N retransmits:',
        o: ['Only the lost frame', 'The lost frame and all frames sent after it', 'Nothing', 'The whole window twice'], a: 1,
        e: 'The receiver discards out-of-order frames, so on timeout the sender resends from the lost frame onward.' },
      { q: 'Selective Repeat differs from Go-Back-N because the receiver:',
        o: ['Uses a window of one', 'Buffers out-of-order frames and ACKs each individually', 'Sends cumulative ACKs only', 'Cannot detect loss'], a: 1,
        e: 'SR buffers correctly received frames and ACKs them one by one, so only the lost frame is resent.' },
      { q: 'With a k-bit sequence number, the Selective-Repeat sender window may be at most:',
        o: ['2^k', '2^k - 1', '2^(k-1)', 'k'], a: 2,
        e: 'SR needs sender and receiver windows to not overlap in the sequence space, capping each at half, 2^(k-1).' },
      { q: 'Pipelining (a window larger than 1) improves throughput by:',
        o: ['Reducing the error rate', 'Keeping the link busy while ACKs are in flight', 'Shrinking the frame size', 'Avoiding sequence numbers'], a: 1,
        e: 'Sending several frames before waiting for an ACK fills the bandwidth-delay product of the link.' }
    ],
    '4': [
      { q: 'Dijkstra\'s algorithm requires that all edge weights are:',
        o: ['Integers', 'Non-negative', 'Distinct', 'Less than one'], a: 1,
        e: 'A negative edge could improve a node already finalised, breaking the greedy correctness; weights must be non-negative.' },
      { q: 'At each step Dijkstra finalises the unvisited node with the:',
        o: ['Largest tentative distance', 'Smallest tentative distance', 'Most neighbours', 'Lowest index'], a: 1,
        e: 'Picking the closest unfinalised node guarantees its distance is already optimal.' },
      { q: 'The distance-vector update D[x][t] is computed as:',
        o: ['max over neighbours of c(x,n)+D[n][t]', 'min over neighbours of c(x,n)+D[n][t]', 'sum of all neighbour distances', 'c(x,t) only'], a: 1,
        e: 'Bellman-Ford takes the minimum over neighbours of the link cost plus the neighbour\'s distance to t.' },
      { q: 'A known drawback of distance-vector routing is:',
        o: ['It needs the full topology', 'The count-to-infinity / slow-convergence problem', 'It cannot use weights', 'It floods every link'], a: 1,
        e: 'Bad news propagates slowly, and loops can make a metric crawl up to infinity before converging.' }
    ],
    '5': [
      { q: 'A CRC is computed by dividing the message (over GF(2)) by the:',
        o: ['Checksum', 'Generator polynomial', 'Hamming code', 'Parity bit'], a: 1,
        e: 'CRC is the remainder of XOR-based polynomial division by a fixed generator.' },
      { q: 'The receiver knows a CRC-protected frame is error-free when the remainder is:',
        o: ['All ones', 'Zero', 'Equal to the generator', 'The original message'], a: 1,
        e: 'The CRC is chosen so the transmitted frame is exactly divisible by the generator; remainder 0 means no detected error.' },
      { q: 'Hamming(7,4) can:',
        o: ['Correct two-bit errors', 'Correct one-bit and detect that error\'s position', 'Only detect errors', 'Correct any number of errors'], a: 1,
        e: 'With minimum distance 3 it corrects a single-bit error, the syndrome giving its position.' },
      { q: 'A Hamming syndrome of 000 after reception means:',
        o: ['An error at position 0', 'No single-bit error detected', 'Two errors', 'The data must be re-sent'], a: 1,
        e: 'A zero syndrome indicates all parity checks pass, so no single-bit error is present.' }
    ],
    '6': [
      { q: 'The two prefixes 192.168.0.0/24 and 192.168.1.0/24 aggregate to:',
        o: ['192.168.0.0/23', '192.168.0.0/22', '192.168.0.0/25', 'They cannot merge'], a: 0,
        e: 'They are sibling /24s differing only in the 24th bit, so they collapse into a single /23.' },
      { q: 'Two equal-length prefixes can merge into a shorter one only when they:',
        o: ['Are anywhere in the same network', 'Are correctly-aligned sibling blocks', 'Have different masks', 'Overlap partially'], a: 1,
        e: 'Only adjacent, equal-size, properly aligned blocks (same /(p-1) parent, differing p-th bit) may merge.' },
      { q: 'A router forwarding a packet selects the matching route with the:',
        o: ['Shortest prefix', 'Longest prefix (most specific)', 'Lowest metric only', 'First listed'], a: 1,
        e: 'Longest-prefix match picks the most specific prefix that contains the destination.' },
      { q: 'Three contiguous /24s (.0, .1, .2) can be summarised as:',
        o: ['One /22', 'One /23 plus one /24', 'One /21', 'A single /24'], a: 1,
        e: 'Only the first two merge to a /23; the odd third stays a /24, since a /22 would also cover .3 which is absent.' }
    ]
  };

  function buildQuiz(host) {
    var qid = host.getAttribute('data-quiz');
    var qs = QUIZZES[qid]; if (!qs) return;
    for (var i = 0; i < qs.length; i++) {
      (function (item, idx) {
        var card = document.createElement('div');
        card.className = 'q';
        var qt = document.createElement('div');
        qt.className = 'qt';
        qt.innerHTML = '<b>Q' + (idx + 1) + '.</b> ' + item.q;
        card.appendChild(qt);
        var selected = -1;
        var opts = [];
        for (var j = 0; j < item.o.length; j++) {
          (function (optIdx) {
            var op = document.createElement('div');
            op.className = 'opt-a';
            op.textContent = item.o[optIdx];
            op.addEventListener('click', function () {
              if (card.getAttribute('data-done') === '1') return;
              for (var m = 0; m < opts.length; m++) opts[m].classList.remove('sel');
              op.classList.add('sel');
              selected = optIdx;
            });
            opts.push(op);
            card.appendChild(op);
          })(j);
        }
        var foot = document.createElement('div');
        foot.className = 'qfoot';
        var btn = document.createElement('button');
        btn.className = 'btn cyan';
        btn.textContent = 'Check';
        var verdict = document.createElement('span');
        verdict.className = 'verdict';
        foot.appendChild(btn); foot.appendChild(verdict);
        card.appendChild(foot);
        var expl = document.createElement('div');
        expl.className = 'expl';
        expl.innerHTML = '<b>Answer:</b> ' + item.o[item.a] + '. ' + item.e;
        card.appendChild(expl);

        btn.addEventListener('click', function () {
          if (selected < 0) { verdict.textContent = 'Select an option first'; verdict.className = 'verdict bad'; return; }
          card.setAttribute('data-done', '1');
          for (var m = 0; m < opts.length; m++) {
            opts[m].classList.remove('sel');
            if (m === item.a) opts[m].classList.add('correct');
            else if (m === selected) opts[m].classList.add('wrong');
          }
          if (selected === item.a) { verdict.textContent = 'Correct'; verdict.className = 'verdict good'; }
          else { verdict.textContent = 'Incorrect'; verdict.className = 'verdict bad'; card.classList.add('bad'); }
          expl.classList.add('show');
        });

        host.appendChild(card);
      })(qs[i], i);
    }
  }
  var quizHosts = document.querySelectorAll('.nwx .quiz');
  for (var qh = 0; qh < quizHosts.length; qh++) buildQuiz(quizHosts[qh]);

  // initial draw of experiment 1
  if (REDRAW['1']) { try { REDRAW['1'](); } catch (e) {} }
  window.addEventListener('resize', function () {
    var onExp = document.querySelector('.nwx .exp.on');
    if (onExp) { var n = onExp.id.split('-')[1]; if (REDRAW[n]) { try { REDRAW[n](); } catch (e) {} } }
  });
})();
</script>
