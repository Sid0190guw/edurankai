---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Fourier series · Virtual Labs · AquinTutor" description="Build a square / sawtooth / triangle wave from sinusoids.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; }
  .fs-wrap { max-width: 1200px; margin: 0 auto; padding: 20px 4vw 60px; }
  .fs-top { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 14px; margin-bottom: 18px; }
  .fs-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; }
  .fs-title { font-family: 'Cormorant Garamond', serif; font-size: 36px; font-weight: 600; margin: 4px 0 0; letter-spacing: -0.02em; }
  .fs-title em { color: #67e8f9; font-style: italic; font-weight: 500; }
  .fs-grid { display: grid; grid-template-columns: 260px minmax(0,1fr); gap: 16px; }
  @media (max-width: 1000px) { .fs-grid { grid-template-columns: 1fr; } }
  .fs-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 16px; margin-bottom: 12px; }
  .fs-panel h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 10px; }
  .fs-row label { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: #9aa6b6; display: block; margin-top: 8px; }
  .fs-row label span { color: #67e8f9; float: right; }
  .fs-row input, .fs-row select { width: 100%; }
  .fs-row select { background: #0a0a0c; border: 1px solid #2a2a35; color: #fff; padding: 7px 10px; border-radius: 5px; font-size: 12px; font-family: inherit; }
  .fs-canvas { width: 100%; aspect-ratio: 16 / 9; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 12px; display: block; }
</style>

<main class="fs-wrap">
  <div class="fs-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#67e8f9;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="fs-eye" style="margin-top:10px;">Signals · Fourier analysis</p>
      <h1 class="fs-title">Fourier <em>series</em>.</h1>
    </div>
  </div>

  <div class="fs-grid">
    <aside>
      <div class="fs-panel">
        <h3>Controls</h3>
        <div class="fs-row">
          <label>Target wave</label>
          <select id="wave">
            <option value="square">Square</option>
            <option value="sawtooth">Sawtooth</option>
            <option value="triangle">Triangle</option>
          </select>
          <label>Number of terms <span id="nv">5</span></label>
          <input id="nslider" type="range" min="1" max="50" step="1" value="5"/>
          <label>Show partials</label>
          <input id="showInd" type="checkbox" checked/>
          <label>Animate</label>
          <input id="anim" type="checkbox"/>
        </div>
      </div>
      <div class="fs-panel">
        <h3>How it works</h3>
        <p style="font-size:12.5px;color:#cfd6da;line-height:1.65;margin:0;">Any periodic signal is a sum of sinusoids at integer multiples of the base frequency. Pick a target wave and watch how the partial sum converges as more harmonics are added.</p>
      </div>
    </aside>

    <section>
      <canvas id="fsCanvas" class="fs-canvas" width="800" height="450"></canvas>
    </section>
  </div>
</main>

<script is:inline>
  (function () {
    var phase = 0;
    var canvas = document.getElementById('fsCanvas');
    var ctx = canvas.getContext('2d');

    function getTargetValue(t, wave) {
      if (wave === 'square') { return Math.sign(Math.sin(t)) || 1; }
      if (wave === 'sawtooth') { return ((t / Math.PI) % 2) - 1; }
      if (wave === 'triangle') { var s = (t / Math.PI) % 2; if (s > 1) { s = 2 - s; } return s * 2 - 1; }
      return 0;
    }

    function fourierTerms(wave, count) {
      var terms = [];
      if (wave === 'square') {
        for (var k = 1; k <= (2 * count - 1); k += 2) {
          terms.push({ a: 4 / (Math.PI * k), f: k });
        }
      } else if (wave === 'sawtooth') {
        for (var k = 1; k <= count; k++) {
          terms.push({ a: ((k % 2 === 0) ? -1 : 1) * 2 / (Math.PI * k), f: k });
        }
      } else if (wave === 'triangle') {
        for (var k = 1; k <= (2 * count - 1); k += 2) {
          terms.push({ a: 8 / (Math.PI * Math.PI * k * k) * ((k % 4 === 1) ? 1 : -1), f: k });
        }
      }
      return terms;
    }

    function draw() {
      var wave = document.getElementById('wave').value;
      var count = parseInt(document.getElementById('nslider').value, 10);
      var showInd = document.getElementById('showInd').checked;
      var anim = document.getElementById('anim').checked;
      document.getElementById('nv').textContent = count;
      var w = canvas.width, h = canvas.height;
      ctx.fillStyle = '#0a0a0c'; ctx.fillRect(0, 0, w, h);
      ctx.strokeStyle = '#2a2a35'; ctx.lineWidth = 1; ctx.beginPath();
      ctx.moveTo(0, h/2); ctx.lineTo(w, h/2); ctx.stroke();

      ctx.strokeStyle = '#7A6F68'; ctx.lineWidth = 1.5; ctx.setLineDash([4, 4]);
      ctx.beginPath();
      for (var px = 0; px <= w; px++) {
        var tt = (px / w) * 4 * Math.PI - 2 * Math.PI;
        var y = getTargetValue(tt, wave);
        var sy = h/2 - y * 100;
        if (px === 0) { ctx.moveTo(px, sy); } else { ctx.lineTo(px, sy); }
      }
      ctx.stroke(); ctx.setLineDash([]);

      var terms = fourierTerms(wave, count);

      if (showInd) {
        ctx.strokeStyle = 'rgba(167,139,250,0.5)'; ctx.lineWidth = 0.8;
        terms.forEach(function (term) {
          ctx.beginPath();
          for (var px = 0; px <= w; px++) {
            var tt = (px / w) * 4 * Math.PI - 2 * Math.PI + phase;
            var y = term.a * Math.sin(term.f * tt);
            var sy = h/2 - y * 100;
            if (px === 0) { ctx.moveTo(px, sy); } else { ctx.lineTo(px, sy); }
          }
          ctx.stroke();
        });
      }

      ctx.strokeStyle = '#67e8f9'; ctx.lineWidth = 2.5;
      ctx.beginPath();
      for (var px = 0; px <= w; px++) {
        var tt = (px / w) * 4 * Math.PI - 2 * Math.PI + phase;
        var s = 0;
        terms.forEach(function (term) { s += term.a * Math.sin(term.f * tt); });
        var sy = h/2 - s * 100;
        if (px === 0) { ctx.moveTo(px, sy); } else { ctx.lineTo(px, sy); }
      }
      ctx.stroke();

      ctx.fillStyle = '#7A6F68'; ctx.fillRect(20, 8, 14, 4);
      ctx.fillStyle = 'rgba(167,139,250,0.7)'; ctx.fillRect(100, 8, 14, 4);
      ctx.fillStyle = '#67e8f9'; ctx.fillRect(180, 8, 14, 4);
      ctx.fillStyle = '#cfd6da'; ctx.font = '10px ui-monospace';
      ctx.fillText('Target', 38, 14);
      ctx.fillText('Partials', 118, 14);
      ctx.fillText('Sum (n=' + count + ')', 198, 14);
    }

    function loop() {
      if (document.getElementById('anim').checked) { phase += 0.02; }
      draw();
      requestAnimationFrame(loop);
    }

    document.querySelectorAll('input, select').forEach(function (el) {
      el.addEventListener('input', draw); el.addEventListener('change', draw);
    });
    requestAnimationFrame(loop);
  })();
</script>
</BaseLayout>
