---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Fourier series · Virtual Labs · AquinTutor" description="Build any waveform from sinusoids. Square, sawtooth, triangle, custom. Real Fourier coefficients, live partial-sum animation.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; }
  .fr-wrap { max-width: 1300px; margin: 0 auto; padding: 18px 4vw 60px; }
  .fr-top { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 14px; margin-bottom: 18px; }
  .fr-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; }
  .fr-title { font-family: 'Cormorant Garamond', serif; font-size: 34px; font-weight: 600; margin: 4px 0 0; letter-spacing: -0.02em; }
  .fr-title em { color: #67e8f9; font-style: italic; font-weight: 500; }
  .fr-grid { display: grid; grid-template-columns: 280px minmax(0,1fr); gap: 18px; }
  @media (max-width: 1000px) { .fr-grid { grid-template-columns: 1fr; } }
  .fr-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 16px; margin-bottom: 12px; }
  .fr-panel h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 10px; }
  .fr-row label { font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; display: flex; justify-content: space-between; margin-bottom: 4px; }
  .fr-row label span { color: #67e8f9; }
  .fr-row input[type=range] { width: 100%; }
  .fr-row select { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; color: #fff; padding: 7px 10px; border-radius: 5px; font-size: 12px; font-family: inherit; }
  .fr-canvas { width: 100%; height: 320px; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 10px; }
  .fr-spectrum { width: 100%; height: 180px; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 10px; margin-top: 12px; }
  .fr-btn { background: #67e8f9; color: #04161b; padding: 9px 16px; border-radius: 6px; border: none; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
  .fr-btn-ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
  .fr-checkbox-row { display: flex; align-items: center; gap: 8px; padding: 6px 0; font-family: 'Geist Mono', monospace; font-size: 11.5px; color: #cfd6da; }
</style>

<main class="fr-wrap">
  <div class="fr-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#67e8f9;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="fr-eye" style="margin-top:10px;">Signals · Series</p>
      <h1 class="fr-title">Fourier <em>series</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;">
      <button id="resetBtn" class="fr-btn fr-btn-ghost">Reset</button>
      <button id="playBtn" class="fr-btn">Pause</button>
    </div>
  </div>

  <div class="fr-grid">
    <aside>
      <div class="fr-panel">
        <h3>Waveform</h3>
        <select id="waveform">
          <option value="square" selected>Square</option>
          <option value="sawtooth">Sawtooth</option>
          <option value="triangle">Triangle</option>
          <option value="pulse">Pulse train</option>
        </select>
      </div>
      <div class="fr-panel">
        <h3>Partial sum</h3>
        <div class="fr-row">
          <label>Number of harmonics N <span id="nV">7</span></label>
          <input id="nHarm" type="range" min="1" max="50" step="1" value="7"/>
          <label>Animation speed <span id="spV">1.00</span></label>
          <input id="speed" type="range" min="0" max="5" step="0.1" value="1"/>
        </div>
        <div class="fr-checkbox-row">
          <input id="showPartials" type="checkbox" checked/> <label for="showPartials" style="margin:0;color:#cfd6da;">Show individual sinusoids</label>
        </div>
        <div class="fr-checkbox-row">
          <input id="showTarget" type="checkbox" checked/> <label for="showTarget" style="margin:0;color:#cfd6da;">Show target waveform</label>
        </div>
      </div>
      <div class="fr-panel">
        <h3>Fourier coefficients</h3>
        <p style="font-family:'Geist Mono',monospace;font-size:11px;color:#9aa6b6;line-height:1.6;margin:0;">
          Square wave: <span style="color:#67e8f9;">b<sub>n</sub> = 4/(n&pi;)</span> for odd n<br/>
          Sawtooth: <span style="color:#67e8f9;">b<sub>n</sub> = 2(-1)<sup>n+1</sup>/(n&pi;)</span><br/>
          Triangle: <span style="color:#67e8f9;">b<sub>n</sub> = 8/(n<sup>2</sup>&pi;<sup>2</sup>)</span> for odd n
        </p>
      </div>
    </aside>

    <section>
      <p class="fr-eye">Approximation &mdash; partial sum of N harmonics</p>
      <svg id="canvas" class="fr-canvas" viewBox="0 0 1000 320" preserveAspectRatio="none"></svg>
      <p class="fr-eye" style="margin-top:12px;">Frequency spectrum &mdash; harmonic amplitudes</p>
      <svg id="spectrum" class="fr-spectrum" viewBox="0 0 1000 180"></svg>
    </section>
  </div>
</main>

<script is:inline>
  (function () {
    function $(id) { return document.getElementById(id); }
    var phase = 0; var paused = false;

    function coefficient(n, kind) {
      if (kind === 'square') return n % 2 === 1 ? 4 / (n * Math.PI) : 0;
      if (kind === 'sawtooth') return 2 * Math.pow(-1, n + 1) / (n * Math.PI);
      if (kind === 'triangle') return n % 2 === 1 ? 8 / (n * n * Math.PI * Math.PI) * Math.pow(-1, (n - 1) / 2) : 0;
      if (kind === 'pulse') return n % 2 === 1 ? 2 / (n * Math.PI) : 0;
      return 0;
    }
    function exact(x, kind) {
      x = ((x % (2 * Math.PI)) + 2 * Math.PI) % (2 * Math.PI);
      if (kind === 'square') return x < Math.PI ? 1 : -1;
      if (kind === 'sawtooth') return 1 - x / Math.PI;
      if (kind === 'triangle') return x < Math.PI ? -1 + 2 * x / Math.PI : 3 - 2 * x / Math.PI;
      if (kind === 'pulse') return x < Math.PI / 2 ? 1 : 0;
      return 0;
    }

    function svgEl(tag, attrs) {
      var e = document.createElementNS('http://www.w3.org/2000/svg', tag);
      for (var k in attrs) e.setAttribute(k, attrs[k]);
      return e;
    }

    function read() {
      var N = parseInt($('nHarm').value, 10);
      $('nV').textContent = N;
      var sp = parseFloat($('speed').value);
      $('spV').textContent = sp.toFixed(2);
      return { N: N, speed: sp, kind: $('waveform').value, showPartials: $('showPartials').checked, showTarget: $('showTarget').checked };
    }
    document.querySelectorAll('input,select').forEach(function (el) { el.addEventListener('input', read); el.addEventListener('change', read); });

    function draw() {
      var c = read();
      var svg = $('canvas'); svg.innerHTML = '';
      var W = 1000, H = 320, midY = H / 2;
      svg.appendChild(svgEl('line', { x1: 0, y1: midY, x2: W, y2: midY, stroke: '#2a2a35' }));
      for (var i = 0; i <= 8; i++) {
        var x = (W / 8) * i;
        svg.appendChild(svgEl('line', { x1: x, y1: 0, x2: x, y2: H, stroke: '#1a1a25' }));
      }
      var pts = 1000;
      // target
      if (c.showTarget) {
        var d = '';
        for (var i = 0; i <= pts; i++) {
          var x = i * 4 * Math.PI / pts;
          var y = exact(x + phase, c.kind);
          d += (i === 0 ? 'M' : 'L') + (i * W / pts) + ',' + (midY - y * 100);
        }
        svg.appendChild(svgEl('path', { d: d, fill: 'none', stroke: '#9aa6b6', 'stroke-width': 1, 'stroke-dasharray': '4 3' }));
      }
      // partials
      if (c.showPartials) {
        for (var n = 1; n <= c.N; n++) {
          var b = coefficient(n, c.kind);
          if (Math.abs(b) < 1e-6) continue;
          var d = '';
          for (var i = 0; i <= pts; i++) {
            var x = i * 4 * Math.PI / pts;
            var y = b * Math.sin(n * (x + phase));
            d += (i === 0 ? 'M' : 'L') + (i * W / pts) + ',' + (midY - y * 100);
          }
          var hue = (n * 47) % 360;
          svg.appendChild(svgEl('path', { d: d, fill: 'none', stroke: 'hsl(' + hue + ',70%,60%)', 'stroke-width': 0.7, opacity: 0.45 }));
        }
      }
      // partial sum
      var d2 = '';
      for (var i = 0; i <= pts; i++) {
        var x = i * 4 * Math.PI / pts;
        var sum = 0;
        for (var n = 1; n <= c.N; n++) sum += coefficient(n, c.kind) * Math.sin(n * (x + phase));
        d2 += (i === 0 ? 'M' : 'L') + (i * W / pts) + ',' + (midY - sum * 100);
      }
      svg.appendChild(svgEl('path', { d: d2, fill: 'none', stroke: '#FF7040', 'stroke-width': 2.5 }));

      // spectrum
      var sp = $('spectrum'); sp.innerHTML = '';
      var SW = 1000, SH = 180;
      sp.appendChild(svgEl('line', { x1: 0, y1: SH - 20, x2: SW, y2: SH - 20, stroke: '#2a2a35' }));
      for (var n = 1; n <= 50; n++) {
        var b = coefficient(n, c.kind);
        if (Math.abs(b) < 1e-6) continue;
        var bx = 20 + (n - 1) * (SW - 40) / 49;
        var bh = Math.abs(b) * 150;
        sp.appendChild(svgEl('rect', { x: bx - 4, y: SH - 20 - bh, width: 8, height: bh, fill: n <= c.N ? '#67e8f9' : '#2a2a35' }));
      }
      var lbl = svgEl('text', { x: 14, y: 18, fill: '#67e8f9', 'font-family': 'Geist Mono', 'font-size': 11 });
      lbl.textContent = c.kind + ' · N=' + c.N + ' harmonics';
      sp.appendChild(lbl);
    }

    $('playBtn').addEventListener('click', function () { paused = !paused; this.textContent = paused ? 'Play' : 'Pause'; });
    $('resetBtn').addEventListener('click', function () { phase = 0; draw(); });

    var last = 0;
    function loop(ts) {
      if (!last) last = ts;
      var dt = (ts - last) / 1000; last = ts;
      if (!paused) phase += dt * read().speed * 1.2;
      draw();
      requestAnimationFrame(loop);
    }
    draw();
    requestAnimationFrame(loop);
  })();
</script>

<div id="demoHint" style="position:fixed;left:16px;bottom:16px;max-width:330px;background:#11131a;color:#e8e8ee;border:1px solid #FF4F00;border-radius:12px;padding:14px 16px;z-index:9999;box-shadow:0 12px 34px rgba(0,0,0,0.45);">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:7px;gap:10px;">
    <span style="font-family:'Geist Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#FF4F00;font-weight:700;">Try this &middot; demo</span>
    <button onclick="this.closest('#demoHint').remove()" style="background:transparent;border:none;color:#9aa6b6;cursor:pointer;font-size:18px;line-height:1;padding:0;">&times;</button>
  </div>
  <p style="margin:0;font-size:12.5px;line-height:1.55;color:#cfd6da;font-family:'Inter Tight',sans-serif,system-ui;">Pick the <b>Square</b> wave and drag <b>N harmonics</b> up. Watch the orange sum sharpen toward the target as more sinusoids are added — Gibbs ringing at the edges.</p>
</div>

</BaseLayout>
