---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Fourier & spectral-analysis lab (advanced level). Two engines:
// (1) Series — the Fourier coefficients a_n, b_n are computed by NUMERICAL
//     integration (Simpson) of the target over a period, not memorised
//     formulas; it shows the partial sum, the magnitude/phase line spectrum, a
//     measured Gibbs overshoot at the discontinuity (converging to the ~8.95%
//     Wilbraham-Gibbs constant), and an RMS-error-vs-N log-log plot whose slope
//     ties spectral decay to smoothness (1/N for a jump, 1/N^2 for a corner).
// (2) DFT & leakage — an O(N^2) DFT of a cosine at an adjustable, possibly
//     non-integer, cycles-per-window, showing spectral LEAKAGE and how a
//     window (Hann / Hamming / Blackman) trades main-lobe width for side-lobe
//     suppression. No libraries.
---
<BaseLayout title="Fourier & Spectral Analysis · Virtual Labs · AquinTutor" description="Advanced signals: Fourier series with numerically integrated coefficients, a measured Gibbs overshoot, and a convergence-rate plot linking smoothness to spectral decay; plus a DFT showing spectral leakage and window functions trading main-lobe width for side-lobe level. Built from scratch.">
<style>
  body{ background:#06070c; color:#e8e8ee; }
  .lb{ max-width:1340px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:16px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#67e8f9; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#67e8f9; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:300px minmax(0,1fr); gap:18px; } @media(max-width:960px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#11131a,#0b0d13); border:1px solid #2a2a35; border-radius:14px; padding:15px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin:0 0 11px; }
  .lb-row{ display:grid; gap:8px; } .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.08em; text-transform:uppercase; color:#9aa6b6; font-weight:700; display:flex; justify-content:space-between; } .lb-row label span{ color:#67e8f9; } .lb-row input[type=range]{ width:100%; accent-color:#67e8f9; } select{ width:100%; background:#0a0a0c; border:1px solid #2a2a35; color:#fff; padding:8px 10px; border-radius:6px; font-size:12px; font-family:inherit; }
  .lb-seg{ display:flex; gap:4px; } .lb-seg button{ flex:1; background:#0a0a0c; border:1px solid #2a2a35; color:#9aa6b6; border-radius:7px; padding:6px 4px; font-family:'Geist Mono',monospace; font-size:10px; cursor:pointer; } .lb-seg button.on{ background:rgba(103,232,249,0.14); color:#67e8f9; border-color:#3a6b86; }
  .lb-cv{ display:block; width:100%; height:auto; background:#0a0a0c; border:1px solid #2a2a35; border-radius:10px; }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11px; padding:4px 0; border-bottom:1px solid #1a1a25; } .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#9aa6b6; } .lb-metric-v{ color:#67e8f9; font-weight:700; text-align:right; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#67e8f9;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">Signals · Fourier · Spectra</p>
      <h1 class="lb-title">Fourier &amp; <em>spectra</em>.</h1>
    </div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Engine</h3><div class="lb-seg" id="modeSeg"><button data-m="series" class="on">Series</button><button data-m="dft">DFT &amp; leakage</button></div></div>
      <div id="panSeries">
        <div class="lb-panel"><h3>Waveform</h3>
          <select id="wave"><option value="square" selected>Square (jump)</option><option value="saw">Sawtooth (jump)</option><option value="triangle">Triangle (corner)</option><option value="pulse">Pulse 25%</option><option value="rect">Half-wave rectified</option></select>
          <div class="lb-row" style="margin-top:10px;"><label>Harmonics N <span id="nV">9</span></label><input id="nHarm" type="range" min="1" max="80" step="1" value="9"/>
            <label>Animation <span id="spV">1.0</span></label><input id="speed" type="range" min="0" max="4" step="0.1" value="1"/></div>
        </div>
        <div class="lb-panel"><h3>Convergence</h3>
          <div class="lb-metric"><span class="lb-metric-l">Gibbs overshoot</span><span class="lb-metric-v" id="mGibbs">—</span></div>
          <div class="lb-metric"><span class="lb-metric-l">RMS error at N</span><span class="lb-metric-v" id="mRms">—</span></div>
          <div class="lb-metric"><span class="lb-metric-l">Coeff. decay</span><span class="lb-metric-v" id="mDecay" style="color:#a78bfa;">—</span></div>
        </div>
      </div>
      <div id="panDft" style="display:none;">
        <div class="lb-panel"><h3>Signal &amp; window</h3><div class="lb-row">
          <label>Cycles per window k <span id="kV">8.0</span></label><input id="cyc" type="range" min="2" max="40" step="0.1" value="8"/>
          <label>Samples N <span id="dnV">64</span></label><input id="dn" type="range" min="16" max="256" step="16" value="64"/>
        </div>
        <label style="font-family:'Geist Mono',monospace;font-size:9.5px;color:#9aa6b6;text-transform:uppercase;margin-top:8px;display:block;">Window</label>
        <select id="win"><option value="rect" selected>Rectangular</option><option value="hann">Hann</option><option value="hamming">Hamming</option><option value="blackman">Blackman</option></select>
        </div>
        <div class="lb-panel"><h3>Readout</h3>
          <div class="lb-metric"><span class="lb-metric-l">Integer cycles?</span><span class="lb-metric-v" id="mInt">—</span></div>
          <div class="lb-metric"><span class="lb-metric-l">Peak bin</span><span class="lb-metric-v" id="mBin">—</span></div>
          <div class="lb-metric"><span class="lb-metric-l">Leakage (dB in ±3 bins)</span><span class="lb-metric-v" id="mLeak" style="color:#fbbf24;">—</span></div>
        </div>
      </div>
    </aside>
    <section>
      <p class="lb-eye" id="topLbl">Partial sum of N harmonics</p>
      <canvas id="main" class="lb-cv" width="1000" height="300"></canvas>
      <p class="lb-eye" style="margin-top:12px;" id="botLbl">Line spectrum</p>
      <canvas id="spec" class="lb-cv" width="1000" height="220"></canvas>
    </section>
  </div>
</main>
<script is:inline>
(function(){
  function v(id){ return parseFloat(document.getElementById(id).value); }
  function setTxt(id,t){ var e=document.getElementById(id); if(e) e.textContent=t; }
  var mode='series', phase=0, TWO=2*Math.PI;
  function target(x,kind){ x=((x%TWO)+TWO)%TWO; if(kind==='square')return x<Math.PI?1:-1; if(kind==='saw')return 1-x/Math.PI; if(kind==='triangle')return x<Math.PI?-1+2*x/Math.PI:3-2*x/Math.PI; if(kind==='pulse')return x<Math.PI/2?1:-1/3; if(kind==='rect')return Math.max(0,Math.sin(x))*2-0.6366; return 0; }
  // numerical Fourier coefficients by Simpson over [0,2π]
  function coeffs(kind,N){ var M=2000, a=[0], b=[0]; var h=TWO/M;
    for(var n=1;n<=N;n++){ var sa=0,sb=0; for(var i=0;i<=M;i++){ var x=i*h, f=target(x,kind), wS=(i===0||i===M)?1:(i%2?4:2); sa+=wS*f*Math.cos(n*x); sb+=wS*f*Math.sin(n*x); } a.push(sa*h/3/Math.PI); b.push(sb*h/3/Math.PI); }
    // a0
    var s0=0; for(var i=0;i<=M;i++){ var wS=(i===0||i===M)?1:(i%2?4:2); s0+=wS*target(i*h,kind); } a[0]=s0*h/3/Math.PI; return {a:a,b:b}; }
  function partial(x,C,N){ var s=C.a[0]/2; for(var n=1;n<=N;n++) s+=C.a[n]*Math.cos(n*x)+C.b[n]*Math.sin(n*x); return s; }

  function hidpi(cv){ var r=cv.getBoundingClientRect(), dp=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w; cv.width=Math.round(w*dp); cv.height=Math.round(h*dp); var ctx=cv.getContext('2d'); ctx.setTransform(dp,0,0,dp,0,0); return {ctx:ctx,w:w,h:h}; }

  function drawSeries(){ var kind=document.getElementById('wave').value, N=Math.round(v('nHarm')); var C=coeffs(kind,Math.max(N,80));
    var cv=document.getElementById('main'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h, mid=H/2; ctx.fillStyle='#0a0a0c'; ctx.fillRect(0,0,W,H);
    ctx.strokeStyle='#1a1a25'; for(var i=0;i<=8;i++){ var x=W/8*i; ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,H); ctx.stroke(); } ctx.strokeStyle='#2a2a35'; ctx.beginPath(); ctx.moveTo(0,mid); ctx.lineTo(W,mid); ctx.stroke();
    var pts=1000, amp=H*0.32;
    // target
    ctx.strokeStyle='#9aa6b6'; ctx.setLineDash([4,3]); ctx.lineWidth=1; ctx.beginPath(); for(var i=0;i<=pts;i++){ var x=i*2*TWO/pts; var y=target(x+phase,kind); i?ctx.lineTo(i*W/pts,mid-y*amp):ctx.moveTo(0,mid-y*amp); } ctx.stroke(); ctx.setLineDash([]);
    // partial sum
    ctx.save(); ctx.shadowColor='#FF7040'; ctx.shadowBlur=6; ctx.strokeStyle='#FF7040'; ctx.lineWidth=2.4; ctx.beginPath(); var maxOver=0; for(var i=0;i<=pts;i++){ var x=i*2*TWO/pts; var s=partial(x+phase,C,N); i?ctx.lineTo(i*W/pts,mid-s*amp):ctx.moveTo(0,mid-s*amp); } ctx.stroke(); ctx.restore();
    // Gibbs overshoot: sample near a discontinuity (x=0/π for square)
    var peak=0; for(var i=0;i<pts;i++){ var x=i*TWO/pts; var s=partial(x,C,N); if(s>peak)peak=s; }
    var jump = kind==='square'||kind==='saw'||kind==='pulse'; var overshoot = jump ? (peak-1)*100 : 0;
    // spectrum
    drawSpectrum(C,N,kind);
    // convergence RMS + decay
    var rms=rmsError(kind,C,N); setTxt('mRms',rms.toFixed(4)); setTxt('mGibbs', jump? overshoot.toFixed(1)+'% (→8.95%)':'n/a (continuous)');
    setTxt('mDecay', (kind==='triangle'||kind==='rect')?'~1/n² (corner)':'~1/n (jump)');
    setTxt('nV',N); setTxt('spV',v('speed').toFixed(1));
  }
  function rmsError(kind,C,N){ var M=400,s=0; for(var i=0;i<M;i++){ var x=i*TWO/M; var e=target(x,kind)-partial(x,C,N); s+=e*e; } return Math.sqrt(s/M); }
  function drawSpectrum(C,N,kind){ var cv=document.getElementById('spec'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h; ctx.fillStyle='#0a0a0c'; ctx.fillRect(0,0,W,H);
    var base=H-40, nmax=Math.min(80,C.a.length-1); var mags=[]; for(var n=1;n<=nmax;n++) mags.push(Math.hypot(C.a[n],C.b[n])); var mx=Math.max.apply(null,mags)||1;
    ctx.strokeStyle='#2a2a35'; ctx.beginPath(); ctx.moveTo(20,base); ctx.lineTo(W-10,base); ctx.stroke();
    for(var n=1;n<=nmax;n++){ var m=Math.hypot(C.a[n],C.b[n]); var bx=20+(n-1)*(W-40)/nmax, bh=m/mx*(H-60); ctx.fillStyle=n<=N?'#67e8f9':'#2a2a35'; ctx.fillRect(bx-3,base-bh,6,bh); }
    // convergence inset (RMS vs N, log-log)
    var iw=180, ih=90, ix=W-iw-14, iy=8; ctx.fillStyle='rgba(20,22,30,0.9)'; ctx.fillRect(ix,iy,iw,ih); ctx.strokeStyle='#2a2a35'; ctx.strokeRect(ix,iy,iw,ih);
    var Ns=[]; for(var k=1;k<=64;k*=1.5) Ns.push(Math.round(k)); var errs=Ns.map(function(nn){ return rmsError(kind,C,Math.min(nn,C.a.length-1)); });
    var lemin=Math.log10(Math.min.apply(null,errs.filter(function(e){return e>0;}))||1e-3), lemax=Math.log10(Math.max.apply(null,errs)||1);
    ctx.strokeStyle='#a78bfa'; ctx.lineWidth=1.4; ctx.beginPath(); Ns.forEach(function(nn,i){ var x=ix+8+(Math.log2(nn)/Math.log2(64))*(iw-16); var y=iy+ih-8-((Math.log10(errs[i])-lemin)/(lemax-lemin+1e-9))*(ih-16); i?ctx.lineTo(x,y):ctx.moveTo(x,y); }); ctx.stroke();
    ctx.fillStyle='#9aa6b6'; ctx.font="8px 'Geist Mono',monospace"; ctx.fillText('RMS err vs N (log-log)',ix+6,iy+11);
    ctx.fillStyle='#67e8f9'; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText(kind+' · |cₙ| line spectrum · N='+N,20,16);
  }

  // ---- DFT ----
  function windowFn(name,m,N){ var x=m/(N-1); if(name==='hann')return 0.5-0.5*Math.cos(TWO*x); if(name==='hamming')return 0.54-0.46*Math.cos(TWO*x); if(name==='blackman')return 0.42-0.5*Math.cos(TWO*x)+0.08*Math.cos(2*TWO*x); return 1; }
  function drawDft(){ var k=v('cyc'), N=Math.round(v('dn')), win=document.getElementById('win').value;
    var x=[], w=[]; for(var m=0;m<N;m++){ var wm=windowFn(win,m,N); w.push(wm); x.push(Math.cos(TWO*k*m/N)*wm); }
    // time domain
    var cv=document.getElementById('main'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h, mid=H/2; ctx.fillStyle='#0a0a0c'; ctx.fillRect(0,0,W,H); ctx.strokeStyle='#2a2a35'; ctx.beginPath(); ctx.moveTo(0,mid); ctx.lineTo(W,mid); ctx.stroke();
    ctx.strokeStyle='rgba(103,232,249,0.4)'; ctx.lineWidth=1; ctx.beginPath(); for(var m=0;m<N;m++){ var px=m/(N-1)*W; m?ctx.lineTo(px,mid-w[m]*H*0.4):ctx.moveTo(px,mid-w[m]*H*0.4); } ctx.stroke();
    ctx.save(); ctx.shadowColor='#FF7040'; ctx.shadowBlur=5; ctx.strokeStyle='#FF7040'; ctx.lineWidth=1.6; ctx.beginPath(); for(var m=0;m<N;m++){ var px=m/(N-1)*W; m?ctx.lineTo(px,mid-x[m]*H*0.4):ctx.moveTo(px,mid-x[m]*H*0.4); } ctx.stroke(); ctx.restore();
    ctx.fillStyle='#9aa6b6'; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText('windowed x[m] (orange) · window (cyan) · N='+N,14,16);
    // DFT magnitude (dB)
    var half=N>>1, mag=[]; for(var bin=0;bin<=half;bin++){ var re=0,im=0; for(var m=0;m<N;m++){ var a=-TWO*bin*m/N; re+=x[m]*Math.cos(a); im+=x[m]*Math.sin(a); } mag.push(Math.hypot(re,im)); }
    var mmax=Math.max.apply(null,mag)||1; var peakBin=mag.indexOf(mmax);
    var sc=document.getElementById('spec'), S2=hidpi(sc), c2=S2.ctx, W2=S2.w, H2=S2.h; c2.fillStyle='#0a0a0c'; c2.fillRect(0,0,W2,H2); var base=H2-24;
    c2.strokeStyle='#1a1a25'; for(var db=0;db>=-80;db-=20){ var y=base-(db+80)/80*(H2-40); c2.beginPath(); c2.moveTo(30,y); c2.lineTo(W2-10,y); c2.stroke(); c2.fillStyle='#5f7597'; c2.font="8px 'Geist Mono',monospace"; c2.fillText(db+'dB',4,y+3); }
    for(var bin=0;bin<=half;bin++){ var dB=20*Math.log10(Math.max(1e-6,mag[bin]/mmax)); var bx=30+bin/half*(W2-40), bh=Math.max(0,(dB+80)/80*(H2-40)); c2.fillStyle=bin===peakBin?'#fbbf24':'#67e8f9'; c2.fillRect(bx-2,base-bh,4,bh); }
    c2.fillStyle='#67e8f9'; c2.font="10px 'Geist Mono',monospace"; c2.fillText('DFT magnitude (dB) · '+win+' window',30,14);
    // metrics
    var isInt=Math.abs(k-Math.round(k))<1e-6; setTxt('mInt',isInt?'yes (single bin)':'no → leakage'); setTxt('mBin',peakBin);
    var leak=0; for(var bin=0;bin<=half;bin++){ if(Math.abs(bin-peakBin)>3) leak+=mag[bin]*mag[bin]; } var total=0; for(var bin=0;bin<=half;bin++) total+=mag[bin]*mag[bin]; var leakDb=10*Math.log10((leak/Math.max(1e-9,total))||1e-9); setTxt('mLeak',leakDb.toFixed(1)+' dB');
    setTxt('kV',k.toFixed(1)); setTxt('dnV',N);
  }

  function render(){ if(mode==='series') drawSeries(); else drawDft(); }
  document.querySelectorAll('input,select').forEach(function(e){ e.addEventListener('input',render); e.addEventListener('change',render); });
  document.querySelectorAll('#modeSeg button').forEach(function(b){ b.addEventListener('click',function(){ document.querySelectorAll('#modeSeg button').forEach(function(x){x.classList.remove('on');}); b.classList.add('on'); mode=b.getAttribute('data-m');
    document.getElementById('panSeries').style.display=mode==='series'?'block':'none'; document.getElementById('panDft').style.display=mode==='dft'?'block':'none';
    setTxt('topLbl',mode==='series'?'Partial sum of N harmonics':'Time domain — windowed samples'); setTxt('botLbl',mode==='series'?'Line spectrum |cₙ| + convergence':'DFT magnitude spectrum'); render(); }); });
  var last=0; function loop(ts){ if(!last)last=ts; var dt=(ts-last)/1000; last=ts; if(mode==='series'){ phase+=dt*v('speed')*1.1; drawSeries(); } requestAnimationFrame(loop); }
  render(); requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
