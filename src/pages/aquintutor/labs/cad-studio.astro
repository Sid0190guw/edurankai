  .cs-param label b { color:#d9f9e8; }
  .cs-param input[type=range] { width:100%; accent-color:#FF4F00; }
  .cs-view { position:relative; overflow:hidden; background:#0b0d13; }
  #glCanvas { position:absolute; inset:0; width:100%; height:100%; display:block; touch-action:none; cursor:grab; }
  .cs-kv { display:flex; justify-content:space-between; padding:3px 0; border-bottom:1px dashed rgba(120,130,150,0.12); }
  .cs-kv b { color:#d9f9e8; text-align:right; }
  .cs-right h3 { font-family:'Cormorant Garamond',Georgia,serif; font-size:15px; color:#fff; margin:0 0 6px; font-weight:600; }
  .cs-right select, .cs-right input[type=text] { width:100%; background:#11131a; color:#e8e8ee; border:1px solid #2a2a35; border-radius:6px; padding:6px 8px; font-family:inherit; font-size:11px; margin-bottom:6px; }
  .cs-doc { display:flex; gap:4px; flex-wrap:wrap; margin-bottom:8px; }
  .cs-measure { position:absolute; left:12px; top:10px; font-family:'Geist Mono',monospace; font-size:11.5px; color:#fde68a; pointer-events:none; text-shadow:0 1px 3px #000; line-height:1.8; }
  .cs-hint { position:absolute; left:12px; bottom:10px; font-family:'Geist Mono',monospace; font-size:10px; color:#89a; pointer-events:none; text-shadow:0 1px 2px #000; }
