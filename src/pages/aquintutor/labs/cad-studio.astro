---
import BaseLayout from '@/layouts/BaseLayout.astro';
// CAD Studio — Phase 1 of the CAD-grade programme ("whatever time it takes").
// A real parametric solid modeler in the browser, hand-rolled per the labs
// philosophy (no third-party library):
//   - raw WebGL viewport: depth-buffered, per-face lit, 100k+ triangles
//   - TRUE boolean solids: BSP-tree CSG (union / subtract / intersect) —
//     holes are genuinely removed from the solid, and the mass properties,
//     section view and STL export all operate on the real result
//   - parametric feature history: edit any feature, the model regenerates
//   - undo, named documents (save / load / download JSON), materials,
//     divergence-theorem mass properties, section plane, measurement, STL.
// Phase 2 = constrained sketcher; Phase 3 = assemblies + drawings;
// Phase 4 = FEA. Tracked in the roadmap.
---
<BaseLayout title="CAD Studio · Virtual Labs · AquinTutor" description="Parametric solid modeling in the browser: true boolean CSG, WebGL viewport, feature history, mass properties, section view, measurement, STL export, documents. Hand-rolled, no libraries, works offline.">

<style is:global>
  body { background:#08080a; color:#e8e8ee; margin:0; }
  .era-fab { display:none !important; }
  .cs-wrap { display:grid; grid-template-rows:52px 1fr; height:100vh; height:100dvh; }
  .cs-bar { background:#11131a; border-bottom:1px solid #2a2a35; display:flex; align-items:center; padding:0 14px; gap:10px; font-family:'Geist Mono',monospace; font-size:11px; color:#cfd6da; }
  .cs-bar a { color:#FF9066; text-decoration:none; }
  .cs-title { font-family:'Cormorant Garamond',Georgia,serif; font-size:17px; color:#fff; font-weight:600; }
  .cs-title em { color:#FF7040; font-style:italic; }
  .cs-bar-right { margin-left:auto; display:flex; gap:5px; flex-wrap:wrap; }
  .cs-btn { background:transparent; border:1px solid #2a2a35; color:#cfd6da; padding:6px 10px; border-radius:6px; cursor:pointer; font-family:inherit; font-size:10px; letter-spacing:0.04em; text-transform:uppercase; font-weight:700; }
  .cs-btn:hover { background:#1a1a25; }
  .cs-btn.on { background:#FF4F00; color:#fff; border-color:#FF4F00; }
  .cs-main { display:grid; grid-template-columns:270px 1fr 270px; overflow:hidden; }
  @media (max-width:960px){ .cs-main { grid-template-columns:1fr; grid-template-rows:auto 44vh auto; overflow-y:auto; } .cs-left,.cs-right { max-height:34vh; } }
  .cs-left, .cs-right { background:#0c0e14; overflow-y:auto; padding:12px; }
  .cs-left { border-right:1px solid #2a2a35; }
  .cs-right { border-left:1px solid #2a2a35; font-family:'Geist Mono',monospace; font-size:11px; }
  .cs-cat { font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.18em; text-transform:uppercase; color:#FF9066; font-weight:700; margin:8px 0 6px; }
  .cs-addrow { display:flex; gap:4px; flex-wrap:wrap; margin-bottom:8px; }
  .cs-feat { display:flex; align-items:center; gap:7px; padding:7px 9px; border:1px solid #2a2a35; border-radius:8px; margin-bottom:5px; cursor:pointer; font-size:11.5px; color:#cfd6da; }
  .cs-feat.on { border-color:#FF4F00; background:#151018; color:#fff; }
  .cs-feat .op { font-family:'Geist Mono',monospace; font-size:9px; font-weight:800; padding:1px 6px; border-radius:4px; }
  .cs-feat .op.add { background:rgba(70,167,88,0.18); color:#46a758; }
  .cs-feat .op.subtract { background:rgba(229,72,77,0.18); color:#e5484d; }
  .cs-feat .op.intersect { background:rgba(103,232,249,0.18); color:#67e8f9; }
  .cs-feat .del { margin-left:auto; color:#788; background:none; border:0; cursor:pointer; font-size:12px; }
  .cs-param { margin:8px 0 2px; }
