  document.getElementById('mVol').textContent = (Math.abs(vol)/1000).toFixed(2) + ' cm3';
  document.getElementById('mMass').textContent = mass >= 1 ? mass.toFixed(3) + ' kg' : (mass*1000).toFixed(1) + ' g';
  document.getElementById('mSurf').textContent = (surf/100).toFixed(1) + ' cm2';
  document.getElementById('mCg').textContent = cg.map(function(x){ return x.toFixed(1); }).join(', ') + ' mm';
  document.getElementById('mBox').textContent = (mx[0]-mn[0]).toFixed(0) + ' x ' + (mx[1]-mn[1]).toFixed(0) + ' x ' + (mx[2]-mn[2]).toFixed(0) + ' mm';
