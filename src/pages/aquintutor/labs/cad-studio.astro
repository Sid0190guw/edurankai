    SOLID.forEach(function(poly){ poly.v.forEach(function(v){
      var s = mApply(MVP, v.p);
      var sx = (s[0]*0.5+0.5)*W, sy = (0.5-s[1]*0.5)*H;
      var d = Math.hypot(sx-px, sy-py);
      if (d < bd){ bd = d; best = v.p; }
    }); });
    if (best){
      mPts.push(best); if (mPts.length > 2) mPts = [best];
      var el = document.getElementById('csMeasure');
      if (mPts.length === 2){
        var d3 = vSub(mPts[1], mPts[0]);
        el.innerHTML = 'Distance: <b>' + vLen(d3).toFixed(2) + ' mm</b><br/>dx ' + Math.abs(d3[0]).toFixed(1) + ' &middot; dy ' + Math.abs(d3[1]).toFixed(1) + ' &middot; dz ' + Math.abs(d3[2]).toFixed(1);
      } else el.textContent = 'Measure: click the second vertex';
    }
    return;
  }
  drag = { x:e.clientX, y:e.clientY, pan:e.shiftKey }; cv.setPointerCapture(e.pointerId); cv.style.cursor = 'grabbing';
});
cv.addEventListener('pointermove', function(e){
  if (!drag) return;
  var dx = e.clientX-drag.x, dy = e.clientY-drag.y; drag.x = e.clientX; drag.y = e.clientY;
  if (drag.pan){
    var cp = Math.cos(pitch);
    var right = [Math.cos(yaw), 0, -Math.sin(yaw)];
    target = vAdd(target, vMul(right, -dx*dist*0.0016));
    target[1] += dy*dist*0.0016;
  } else { yaw -= dx*0.008; pitch = Math.max(-1.5, Math.min(1.5, pitch+dy*0.008)); }
  render();
});
cv.addEventListener('pointerup', function(){ drag = null; cv.style.cursor = measure ? 'crosshair' : 'grab'; });
cv.addEventListener('wheel', function(e){ e.preventDefault(); dist *= 1 + Math.sign(e.deltaY)*0.09; dist = Math.max(30, Math.min(4000, dist)); render(); }, { passive:false });
var pinch = null;
cv.addEventListener('touchstart', function(e){ if (e.touches.length===2) pinch = Math.hypot(e.touches[0].clientX-e.touches[1].clientX, e.touches[0].clientY-e.touches[1].clientY); }, {passive:true});
cv.addEventListener('touchmove', function(e){ if (pinch && e.touches.length===2){ var d = Math.hypot(e.touches[0].clientX-e.touches[1].clientX, e.touches[0].clientY-e.touches[1].clientY); dist *= pinch/d; dist = Math.max(30, Math.min(4000, dist)); pinch = d; render(); } }, {passive:true});
cv.addEventListener('touchend', function(){ pinch = null; }, {passive:true});

// ============================ toolbar ============================
document.getElementById('tShade').addEventListener('click', function(){ shaded = !shaded; this.classList.toggle('on', shaded); render(); });
document.getElementById('tEdges').addEventListener('click', function(){ edges = !edges; this.classList.toggle('on', edges); render(); });
document.getElementById('tSect').addEventListener('click', function(){ section = !section; this.classList.toggle('on', section); render(); });
document.getElementById('tMeas').addEventListener('click', function(){ measure = !measure; mPts = []; this.classList.toggle('on', measure); document.getElementById('csMeasure').textContent = measure ? 'Measure: click the first vertex' : ''; cv.style.cursor = measure ? 'crosshair' : 'grab'; render(); });
document.getElementById('tFit').addEventListener('click', function(){ if (BB){ target = BB.c.slice(); dist = BB.size*2.2 + 40; } render(); });
document.getElementById('tUndo').addEventListener('click', function(){
  if (!undoStack.length) return;
  features = JSON.parse(undoStack.pop());
  selected = null; regen(); drawParams();
});
window.addEventListener('keydown', function(e){ if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'z'){ e.preventDefault(); document.getElementById('tUndo').click(); } });
document.getElementById('tStl').addEventListener('click', function(){
  triangulate();
  var out = ['solid edurankai_cad'];
  TRIS.forEach(function(t){
    var n = vNorm(vCross(vSub(t[1],t[0]), vSub(t[2],t[0])));
    out.push(' facet normal ' + n.map(function(x){return x.toFixed(6);}).join(' '));
    out.push('  outer loop');
    t.forEach(function(p){ out.push('   vertex ' + p.map(function(x){return x.toFixed(4);}).join(' ')); });
    out.push('  endloop', ' endfacet');
  });
  out.push('endsolid edurankai_cad');
  var a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([out.join('\n')], { type:'model/stl' }));
  a.download = (document.getElementById('docName').value || 'part') + '.stl';
  document.body.appendChild(a); a.click();
  setTimeout(function(){ URL.revokeObjectURL(a.href); a.remove(); }, 400);
});

// ============================ feature tree + params ============================
function drawTree(){
  var host = document.getElementById('csTree'); host.innerHTML = '';
  features.forEach(function(f){
    var d = document.createElement('div');
    d.className = 'cs-feat' + (selected === f.id ? ' on' : '');
    d.innerHTML = '<span class="op ' + f.op + '">' + (f.op === 'add' ? 'ADD' : f.op === 'subtract' ? 'CUT' : 'INT') + '</span><span>' + f.name + '</span><button type="button" class="del" title="Delete feature">x</button>';
    d.addEventListener('click', function(e){
      if (e.target.classList.contains('del')){
        snapshot(); features = features.filter(function(x){ return x.id !== f.id; });
        if (selected === f.id) selected = null;
        regen(); drawParams(); return;
      }
      selected = f.id; drawTree(); drawParams();
    });
    host.appendChild(d);
  });
}
function drawParams(){
  var host = document.getElementById('csParams');
  var f = features.find(function(x){ return x.id === selected; });
  if (!f){ host.innerHTML = 'Select a feature to edit its parameters.'; return; }
  host.innerHTML = '';
  var opSel = document.createElement('select');
  opSel.style.cssText = 'width:100%;background:#11131a;color:#e8e8ee;border:1px solid #2a2a35;border-radius:6px;padding:6px;font-size:11px;margin-bottom:6px;';
  ['add','subtract','intersect'].forEach(function(op){
    var o = document.createElement('option'); o.value = op; o.textContent = op.toUpperCase(); if (f.op === op) o.selected = true; opSel.appendChild(o);
  });
  opSel.addEventListener('change', function(){ snapshot(); f.op = opSel.value; regen(); });
  host.appendChild(opSel);
  PARAM_DEFS[f.type].concat(XFORM_DEFS).forEach(function(def){
    var w = document.createElement('div'); w.className = 'cs-param';
    var val = f.p[def[0]] != null ? f.p[def[0]] : def[4];
    w.innerHTML = '<label>' + def[1] + ' <b data-v>' + val + '</b></label>';
    var r = document.createElement('input'); r.type = 'range'; r.min = def[2]; r.max = def[3]; r.step = def[5]; r.value = val;
    var t = null;
    r.addEventListener('input', function(){
      w.querySelector('[data-v]').textContent = r.value;
      clearTimeout(t);
      t = setTimeout(function(){ snapshot(); f.p[def[0]] = Number(r.value); regen(); }, 120);
    });
    w.appendChild(r); host.appendChild(w);
  });
}
document.querySelectorAll('[data-add]').forEach(function(b){
  b.addEventListener('click', function(){
    snapshot();
    var type = b.getAttribute('data-add');
    var p = { x:0, y:30, z:0, rx:0, ry:0, rz:0 };
    PARAM_DEFS[type].forEach(function(d){ p[d[0]] = d[4]; });
    var f = { id:FID++, type:type, op:'add', name:type.charAt(0).toUpperCase() + type.slice(1) + ' ' + FID, p:p };
    features.push(f); selected = f.id;
    regen(); drawParams();
  });
});

// ============================ documents ============================
var LSKEY = 'aqt_cad_docs';
function docs(){ try { return JSON.parse(localStorage.getItem(LSKEY) || '{}'); } catch(_) { return {}; } }
function loadDocObj(doc){
  var f = Array.isArray(doc) ? doc : (doc.features || []);
  var sk = Array.isArray(doc) ? [] : (doc.sketches || []);
  snapshot(); features = f; SKETCHES = sk; selected = null;
  FID = features.length ? Math.max.apply(null, features.map(function(x){ return x.id; })) + 1 : 1;
  SKID = SKETCHES.length ? Math.max.apply(null, SKETCHES.map(function(x){ return x.id; })) + 1 : 1;
  regen(); drawParams(); drawSkList();
}
document.getElementById('dSave').addEventListener('click', function(){
  var all = docs(); all[document.getElementById('docName').value || 'untitled'] = { features:features, sketches:SKETCHES };
  try { localStorage.setItem(LSKEY, JSON.stringify(all)); this.textContent = 'Saved'; var b = this; setTimeout(function(){ b.textContent = 'Save'; }, 900); } catch(_){}
});
document.getElementById('dLoad').addEventListener('click', function(){
  var all = docs(), names = Object.keys(all);
  if (!names.length){ alert('No saved documents on this device yet.'); return; }
  var pick = prompt('Open which document?\n\n' + names.join('\n'), names[names.length-1]);
  if (pick && all[pick]){ loadDocObj(all[pick]); document.getElementById('docName').value = pick; }
});
document.getElementById('dDown').addEventListener('click', function(){
  var a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([JSON.stringify({ name:document.getElementById('docName').value, features:features, sketches:SKETCHES }, null, 1)], { type:'application/json' }));
  a.download = (document.getElementById('docName').value || 'part') + '.cad.json';
  document.body.appendChild(a); a.click();
  setTimeout(function(){ URL.revokeObjectURL(a.href); a.remove(); }, 400);
});
document.getElementById('dNew').addEventListener('click', function(){
  if (!confirm('Start a new document? Unsaved changes are kept in Undo.')) return;
  snapshot(); features = defaultDoc(); selected = null; document.getElementById('docName').value = 'part-' + Math.floor(Math.random()*900+100); regen(); drawParams();
});

// ============================ PHASE 2 UI: 2D sketch editor ============================
var skTool = 'select', skView = { ox:0, oy:0, s:2.4 };
var skc = document.getElementById('skCanvas'), sctx = skc ? skc.getContext('2d') : null;
var skW = 0, skH = 0, skPending = null, skDragPt = null, skPan = null, skMouse = { px:0, py:0 };
function round5(x){ return Math.round(x*2)/2; }
function skResize(){ if (!skc) return; skW = skc.clientWidth; skH = skc.clientHeight; skc.width = skW*DPR; skc.height = skH*DPR; sctx.setTransform(DPR,0,0,DPR,0,0); skDraw(); }
window.addEventListener('resize', skResize);
function s2w(px, py){ return { u:(px - skW/2 - skView.ox)/skView.s, v:-(py - skH/2 - skView.oy)/skView.s }; }
function w2s(u, v){ return { x: skW/2 + skView.ox + u*skView.s, y: skH/2 + skView.oy - v*skView.s }; }
function w2s2(pid){ var p = skP(curSketch, pid); return w2s(p.u, p.v); }
function skSnap(u, v){ var best = null, bd = 9/skView.s; curSketch.points.forEach(function(p){ var d = Math.hypot(p.u-u, p.v-v); if (d < bd){ bd = d; best = p; } }); return best; }
function distToSeg(px, py, a, b){ var A = w2s(a.u,a.v), B = w2s(b.u,b.v), dx = B.x-A.x, dy = B.y-A.y; var t = ((px-A.x)*dx + (py-A.y)*dy)/(dx*dx+dy*dy||1); t = Math.max(0, Math.min(1, t)); return Math.hypot(px-(A.x+dx*t), py-(A.y+dy*t)); }
function pickLine(px, py){ var best = null, bd = 7; curSketch.lines.forEach(function(l){ var d = distToSeg(px, py, skP(curSketch,l.p1), skP(curSketch,l.p2)); if (d < bd){ bd = d; best = l; } }); return best; }
function pickCircle(px, py){ var best = null, bd = 8; curSketch.circles.forEach(function(c){ var ctr = skP(curSketch,c.c), s = w2s(ctr.u,ctr.v); var d = Math.abs(Math.hypot(px-s.x, py-s.y) - c.r*skView.s); if (d < bd){ bd = d; best = c; } }); return best; }
function skStatus(){ var el = document.getElementById('skStatus'); if (!el) return; var tips = { select:'Drag points to move. Set dimensions/constraints, then Finish.', line:'Click to chain connected points; click an existing point to close the loop.', circle:'Click centre, then click for radius.', dim:'Click a line to set its length, or a circle for its radius.', h:'Click a line to force it horizontal.', v:'Click a line to force it vertical.', delete:'Click a line or circle to remove it.' }; el.textContent = (curSketch ? curSketch.name + ' (' + curSketch.plane + ') - ' : '') + (tips[skTool] || ''); }
function openSketch(s){ curSketch = s; document.getElementById('skEditor').style.display = 'block'; skView = { ox:0, oy:0, s:2.4 }; skPending = null; skResize(); skStatus(); }
function closeSketch(){ document.getElementById('skEditor').style.display = 'none'; curSketch = null; drawSkList(); render(); }

function skDraw(){
  if (!sctx || !curSketch) return;
  sctx.fillStyle = '#0b0d13'; sctx.fillRect(0, 0, skW, skH);
  var g = 10*skView.s, o = w2s(0, 0);
  sctx.strokeStyle = 'rgba(120,130,150,0.09)'; sctx.lineWidth = 1;
  for (var x = o.x % g; x < skW; x += g){ sctx.beginPath(); sctx.moveTo(x, 0); sctx.lineTo(x, skH); sctx.stroke(); }
  for (var y = o.y % g; y < skH; y += g){ sctx.beginPath(); sctx.moveTo(0, y); sctx.lineTo(skW, y); sctx.stroke(); }
  sctx.strokeStyle = 'rgba(103,232,249,0.30)'; sctx.beginPath(); sctx.moveTo(0, o.y); sctx.lineTo(skW, o.y); sctx.moveTo(o.x, 0); sctx.lineTo(o.x, skH); sctx.stroke();
  curSketch.circles.forEach(function(c){ var ctr = skP(curSketch, c.c), s = w2s(ctr.u, ctr.v); sctx.strokeStyle = '#FF9066'; sctx.lineWidth = 1.8; sctx.beginPath(); sctx.arc(s.x, s.y, c.r*skView.s, 0, 2*Math.PI); sctx.stroke(); });
  curSketch.lines.forEach(function(l){ var a = w2s2(l.p1), b = w2s2(l.p2); sctx.strokeStyle = '#FF7040'; sctx.lineWidth = 2; sctx.beginPath(); sctx.moveTo(a.x, a.y); sctx.lineTo(b.x, b.y); sctx.stroke();
    var mid = { x:(a.x+b.x)/2, y:(a.y+b.y)/2 };
    var hv = curSketch.cons.find(function(c){ return c.a === l.id && (c.type === 'h' || c.type === 'v'); });
    if (hv){ sctx.fillStyle = '#67e8f9'; sctx.font = '9px monospace'; sctx.fillText(hv.type.toUpperCase(), mid.x+3, mid.y+11); }
  });
  curSketch.cons.forEach(function(c){
    if (c.type === 'dist'){ var l = curSketch.lines.find(function(x){ return x.id === c.a; }); if (!l) return; var a = w2s2(l.p1), b = w2s2(l.p2); sctx.fillStyle = '#fde68a'; sctx.font = '10px monospace'; sctx.fillText(c.value.toFixed(0), (a.x+b.x)/2+4, (a.y+b.y)/2-4); }
    else if (c.type === 'radius'){ var ci = curSketch.circles.find(function(x){ return x.id === c.a; }); if (!ci) return; var ctr = skP(curSketch, ci.c), s = w2s(ctr.u, ctr.v); sctx.fillStyle = '#fde68a'; sctx.font = '10px monospace'; sctx.fillText('R' + c.value.toFixed(0), s.x+4, s.y-4); }
  });
  curSketch.points.forEach(function(p){ var s = w2s(p.u, p.v); sctx.fillStyle = (skPending && skPending.id === p.id) ? '#FF4F00' : '#d9f9e8'; sctx.fillRect(s.x-2.5, s.y-2.5, 5, 5); });
  if (skPending && skTool === 'line' && !skPending.c){ var a = w2s(skPending.u, skPending.v); sctx.strokeStyle = 'rgba(255,112,64,0.5)'; sctx.setLineDash([4,3]); sctx.beginPath(); sctx.moveTo(a.x, a.y); sctx.lineTo(skMouse.px, skMouse.py); sctx.stroke(); sctx.setLineDash([]); }
  if (skPending && skPending.c && skTool === 'circle'){ var s2 = w2s(skPending.c.u, skPending.c.v); var r = Math.hypot(skMouse.px-s2.x, skMouse.py-s2.y); sctx.strokeStyle = 'rgba(255,144,102,0.5)'; sctx.setLineDash([4,3]); sctx.beginPath(); sctx.arc(s2.x, s2.y, r, 0, 2*Math.PI); sctx.stroke(); sctx.setLineDash([]); }
}

if (skc){
  document.querySelectorAll('.sk-tool').forEach(function(b){
    b.addEventListener('click', function(){ document.querySelectorAll('.sk-tool').forEach(function(x){ x.classList.remove('on'); }); b.classList.add('on'); skTool = b.getAttribute('data-tool'); skPending = null; skStatus(); skDraw(); });
  });
  document.getElementById('skFinish').addEventListener('click', function(){ solveSketch(curSketch); closeSketch(); });
  skc.addEventListener('pointerdown', function(e){
    var rect = skc.getBoundingClientRect(), px = e.clientX-rect.left, py = e.clientY-rect.top, w = s2w(px, py);
    if (e.shiftKey){ skPan = { x:e.clientX, y:e.clientY }; return; }
    if (skTool === 'line'){
      var p = skSnap(w.u, w.v) || skPt(curSketch, round5(w.u), round5(w.v));
      if (skPending && !skPending.c){ curSketch.lines.push({ id:curSketch._pid++, p1:skPending.id, p2:p.id }); }
      skPending = p;
    } else if (skTool === 'circle'){
      if (!skPending){ var c = skSnap(w.u, w.v) || skPt(curSketch, round5(w.u), round5(w.v)); skPending = { c:c }; }
      else { var r = Math.hypot(w.u-skPending.c.u, w.v-skPending.c.v); curSketch.circles.push({ id:curSketch._pid++, c:skPending.c.id, r:Math.max(1, r) }); skPending = null; }
    } else if (skTool === 'dim'){
      var l = pickLine(px, py);
      if (l){ var p1 = skP(curSketch,l.p1), p2 = skP(curSketch,l.p2); var val = prompt('Length (mm):', Math.hypot(p2.u-p1.u, p2.v-p1.v).toFixed(1)); if (val){ curSketch.cons.push({ type:'dist', a:l.id, value:parseFloat(val) }); solveSketch(curSketch); } }
      else { var ci = pickCircle(px, py); if (ci){ var v2 = prompt('Radius (mm):', ci.r.toFixed(1)); if (v2){ curSketch.cons.push({ type:'radius', a:ci.id, value:parseFloat(v2) }); solveSketch(curSketch); } } }
    } else if (skTool === 'h' || skTool === 'v'){
      var l2 = pickLine(px, py); if (l2){ curSketch.cons = curSketch.cons.filter(function(c){ return !(c.a === l2.id && (c.type === 'h' || c.type === 'v')); }); curSketch.cons.push({ type:skTool, a:l2.id }); solveSketch(curSketch); }
    } else if (skTool === 'delete'){
      var l3 = pickLine(px, py); if (l3){ curSketch.lines = curSketch.lines.filter(function(x){ return x !== l3; }); curSketch.cons = curSketch.cons.filter(function(c){ return c.a !== l3.id; }); }
      else { var c3 = pickCircle(px, py); if (c3){ curSketch.circles = curSketch.circles.filter(function(x){ return x !== c3; }); curSketch.cons = curSketch.cons.filter(function(c){ return c.a !== c3.id; }); } }
    } else { var pp = skSnap(w.u, w.v); if (pp) skDragPt = pp; }
    skDraw();
  });
  skc.addEventListener('pointermove', function(e){
    var rect = skc.getBoundingClientRect(); skMouse = { px:e.clientX-rect.left, py:e.clientY-rect.top };
    if (skPan){ skView.ox += e.clientX-skPan.x; skView.oy += e.clientY-skPan.y; skPan = { x:e.clientX, y:e.clientY }; skDraw(); return; }
    if (skDragPt){ var w = s2w(skMouse.px, skMouse.py); skDragPt.u = round5(w.u); skDragPt.v = round5(w.v); solveSketch(curSketch); skDraw(); }
    else if (skPending) skDraw();
  });
  skc.addEventListener('pointerup', function(){ skPan = null; skDragPt = null; });
  skc.addEventListener('wheel', function(e){ e.preventDefault(); var rect = skc.getBoundingClientRect(); skView.s = Math.max(0.4, Math.min(24, skView.s * (1 - Math.sign(e.deltaY)*0.1))); skDraw(); }, { passive:false });
}

document.getElementById('skNew').addEventListener('click', function(){ var s = newSketch(document.getElementById('skPlane').value); openSketch(s); });
function drawSkList(){
  var host = document.getElementById('skList'); if (!host) return; host.innerHTML = '';
  SKETCHES.forEach(function(s){
    var loops = sketchLoops(s).length;
    var d = document.createElement('div'); d.style.cssText = 'border:1px solid #2a2a35;border-radius:8px;padding:7px 9px;margin-bottom:5px;font-size:11px;';
    d.innerHTML = '<div style="display:flex;justify-content:space-between;"><b style="color:#fff;">' + s.name + '</b><span style="color:#788;">' + s.plane + ' &middot; ' + loops + ' loop' + (loops===1?'':'s') + '</span></div>';
    var row = document.createElement('div'); row.style.cssText = 'display:flex;gap:4px;margin-top:6px;flex-wrap:wrap;';
    [['Edit',null],['Extrude','extrude'],['Revolve','revolve']].forEach(function(act){
      var btn = document.createElement('button'); btn.className = 'cs-btn'; btn.textContent = act[0]; btn.style.fontSize = '9px'; btn.style.padding = '4px 8px';
      btn.addEventListener('click', function(){
        if (!act[1]){ openSketch(s); return; }
        snapshot();
        var f = { id:FID++, type:act[1], op:'add', name:act[0] + ' ' + s.name, sketchId:s.id, p:{ x:0, y:0, z:0, rx:0, ry:0, rz:0 } };
        f.p[act[1] === 'extrude' ? 'depth' : 'angle'] = act[1] === 'extrude' ? 20 : 360;
        features.push(f); selected = f.id; regen(); drawParams();
      });
      row.appendChild(btn);
    });
    d.appendChild(row); host.appendChild(d);
  });
}

regen(); resize(); drawSkList();
document.getElementById('tFit').click();
})();
</script>

</BaseLayout>
