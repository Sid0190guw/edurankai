        ctx.strokeStyle = '#fbbf24'; ctx.lineWidth = 3; ctx.lineCap = 'round'; ctx.beginPath();
        ctx.moveTo(bp[0].x, bp[0].y);
        for (var b = 1; b < bp.length; b++) ctx.lineTo(bp[b].x, bp[b].y);
        ctx.stroke();
