---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Robotics & AI · Virtual Labs · AquinTutor" description="Eight working robotics experiments — arm kinematics, workspace, mobile-robot navigation, potential fields, A* planning, PID and cart-pole balance.">
<style>
  .rbx { background:#0a0a0c; color:#e8e8ee; min-height:100vh; font-family:'Geist Mono',ui-monospace,monospace; }
  .rbx .wrap { max-width:1240px; margin:0 auto; padding:36px 22px 90px; }
  .rbx .back { display:inline-flex; align-items:center; gap:7px; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:#9aa0aa; text-decoration:none; margin-bottom:26px; }
  .rbx .back:hover { color:#67e8f9; }
  .rbx .eyebrow { font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin-bottom:12px; }
  .rbx h1 { font-family:'Cormorant Garamond',serif; font-size:40px; font-weight:600; letter-spacing:-0.02em; line-height:1.1; margin:0 0 12px; color:#f3f3f8; }
  .rbx h1 em { color:#a78bfa; font-style:italic; }
  .rbx .lede { color:#9aa0aa; max-width:820px; font-size:13.5px; line-height:1.65; margin-bottom:26px; }

  .rbx .shell { display:grid; grid-template-columns:248px minmax(0,1fr); gap:20px; align-items:start; }
  @media (max-width:900px) { .rbx .shell { grid-template-columns:1fr; } }

  .rbx .sidebar { background:#11131a; border:1px solid #2a2a35; border-radius:12px; padding:12px; position:sticky; top:18px; }
  .rbx .sidebar .stitle { font-size:9px; letter-spacing:0.18em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin:4px 6px 10px; }
  .rbx .exp-item { display:flex; gap:9px; align-items:flex-start; padding:9px 10px; border-radius:8px; cursor:pointer; border:1px solid transparent; transition:all .14s; margin-bottom:3px; }
  .rbx .exp-item:hover { background:#161922; }
  .rbx .exp-item.on { background:#161922; border-color:#a78bfa; }
  .rbx .exp-item .num { font-size:10px; color:#a78bfa; font-weight:700; min-width:14px; }
  .rbx .exp-item .nm { font-size:11px; color:#cfd6da; line-height:1.4; }
  .rbx .exp-item.on .nm { color:#f3f3f8; }

  .rbx .main { min-width:0; }
  .rbx .exp-head { font-family:'Cormorant Garamond',serif; font-size:27px; font-weight:600; color:#f3f3f8; margin:0 0 4px; }
  .rbx .exp-sub { font-size:11px; color:#9aa0aa; letter-spacing:0.04em; margin-bottom:16px; }

  .rbx .secbar { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:18px; border-bottom:1px solid #2a2a35; padding-bottom:12px; }
  .rbx .secbar .stab { background:#11131a; border:1px solid #2a2a35; color:#9aa0aa; padding:7px 12px; border-radius:8px; font-size:10px; letter-spacing:0.08em; text-transform:uppercase; font-weight:700; cursor:pointer; transition:all .14s; }
  .rbx .secbar .stab:hover { border-color:#3a3a48; color:#e8e8ee; }
  .rbx .secbar .stab.on { background:#161922; border-color:#67e8f9; color:#67e8f9; }

  .rbx .exp { display:none; }
  .rbx .exp.on { display:block; }
  .rbx .sec { display:none; }
  .rbx .sec.on { display:block; }

  .rbx .prose { font-size:13px; color:#c4c8d0; line-height:1.72; max-width:840px; }
  .rbx .prose b { color:#f3f3f8; }
  .rbx .prose code, .rbx .eq { color:#fbbf24; background:#0a0a0c; border:1px solid #1c1c26; padding:2px 6px; border-radius:4px; font-size:12px; }
  .rbx .eqblock { background:#0a0a0c; border:1px solid #232330; border-radius:9px; padding:13px 15px; margin:13px 0; font-size:12.5px; color:#fbbf24; line-height:2; }
  .rbx ol.steps { font-size:13px; color:#c4c8d0; line-height:1.7; max-width:820px; padding-left:20px; }
  .rbx ol.steps li { margin-bottom:9px; }
  .rbx ol.steps li b { color:#f3f3f8; }
  .rbx ul.refs { list-style:none; padding:0; max-width:840px; }
  .rbx ul.refs li { font-size:12px; color:#9aa0aa; line-height:1.6; padding:8px 0; border-bottom:1px solid #1a1a24; }
  .rbx ul.refs li b { color:#cfd6da; }

  .rbx .layout { display:grid; grid-template-columns:minmax(0,1fr) 320px; gap:18px; align-items:start; }
  @media (max-width:980px) { .rbx .layout { grid-template-columns:1fr; } }
  .rbx .panel { background:#11131a; border:1px solid #2a2a35; border-radius:12px; padding:16px; }
  .rbx .panel h3 { font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin:0 0 13px; }
  .rbx canvas { display:block; width:100%; background:#08080b; border:1px solid #232330; border-radius:10px; }
  .rbx .row { display:flex; gap:9px; align-items:center; margin-bottom:11px; flex-wrap:wrap; }
  .rbx .row > label { font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:#9aa0aa; min-width:64px; }
  .rbx input[type=range] { -webkit-appearance:none; appearance:none; background:#0a0a0c; border:1px solid #2a2a35; height:6px; border-radius:4px; flex:1; min-width:90px; }
  .rbx input[type=range]::-webkit-slider-thumb { -webkit-appearance:none; appearance:none; width:14px; height:14px; border-radius:50%; background:#a78bfa; cursor:pointer; border:none; }
  .rbx input[type=range]::-moz-range-thumb { width:14px; height:14px; border-radius:50%; background:#a78bfa; cursor:pointer; border:none; }
  .rbx select { background:#0a0a0c; border:1px solid #2a2a35; color:#e8e8ee; padding:7px 9px; border-radius:6px; font-family:inherit; font-size:11.5px; flex:1; }
  .rbx .val { font-size:11.5px; color:#a78bfa; min-width:52px; text-align:right; }
  .rbx .btn { background:#a78bfa; color:#16091f; padding:9px 13px; border:none; border-radius:7px; font-family:inherit; font-size:10.5px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; cursor:pointer; }
  .rbx .btn:hover { background:#bda3ff; }
  .rbx .btn.ghost { background:transparent; color:#cfd6da; border:1px solid #2a2a35; }
  .rbx .btn.ghost:hover { border-color:#a78bfa; color:#a78bfa; }
  .rbx .btn.cyan { background:#67e8f9; color:#04161b; }
  .rbx .btn.cyan:hover { background:#8af0ff; }
  .rbx .btns { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:6px; }
  .rbx .btns .full { grid-column:1/-1; }
  .rbx .stats { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:13px; }
  .rbx .stat { background:#0a0a0c; border:1px solid #232330; border-radius:7px; padding:8px 10px; }
  .rbx .stat .k { font-size:9px; letter-spacing:0.12em; text-transform:uppercase; color:#9aa0aa; }
  .rbx .stat .v { font-size:17px; color:#67e8f9; font-weight:700; margin-top:3px; }
  .rbx .help { font-size:10.5px; color:#9aa0aa; line-height:1.65; margin-top:11px; }
  .rbx .help b { color:#e8e8ee; }
  .rbx .help code { color:#fbbf24; background:#0a0a0c; padding:1px 5px; border-radius:3px; }
  .rbx .badge { display:inline-block; font-size:9px; padding:2px 7px; border-radius:4px; background:#1a1a25; color:#86efac; letter-spacing:0.1em; margin-left:6px; }
  .rbx .seg { display:flex; gap:6px; }
  .rbx .seg .opt { flex:1; text-align:center; background:#0a0a0c; border:1px solid #2a2a35; color:#9aa0aa; padding:7px 0; border-radius:6px; font-size:10px; letter-spacing:0.08em; text-transform:uppercase; cursor:pointer; }
  .rbx .seg .opt.on { border-color:#fbbf24; color:#fbbf24; }

  /* self-assessment */
  .rbx .quiz { max-width:840px; }
  .rbx .q { background:#11131a; border:1px solid #2a2a35; border-radius:10px; padding:14px 16px; margin-bottom:13px; }
  .rbx .q .qt { font-size:13px; color:#f3f3f8; line-height:1.55; margin-bottom:11px; }
  .rbx .q .qt b { color:#a78bfa; }
  .rbx .opt-a { display:block; padding:9px 12px; border:1px solid #2a2a35; border-radius:7px; margin-bottom:7px; font-size:12.5px; color:#cfd6da; cursor:pointer; transition:all .12s; }
  .rbx .opt-a:hover { border-color:#3a3a48; }
  .rbx .opt-a.sel { border-color:#67e8f9; color:#67e8f9; }
  .rbx .opt-a.correct { border-color:#86efac; background:rgba(134,239,172,0.08); color:#86efac; }
  .rbx .opt-a.wrong { border-color:#fca5a5; background:rgba(252,165,165,0.08); color:#fca5a5; }
  .rbx .q .expl { font-size:11.5px; color:#9aa0aa; line-height:1.6; margin-top:8px; padding-top:8px; border-top:1px solid #1c1c26; display:none; }
  .rbx .q .expl.show { display:block; }
  .rbx .q .expl b { color:#86efac; }
  .rbx .q.bad .expl b { color:#fca5a5; }
</style>
<main class="rbx">
  <div class="wrap">
    <a class="back" href="/aquintutor/labs">&#8592; All virtual labs</a>
    <div class="eyebrow">Robotics &amp; AI &middot; Virtual lab</div>
    <h1>Robot kinematics, planning &amp; <em>control</em></h1>
    <p class="lede">Eight self-contained experiments, each solved live in your browser with hand-rolled math &mdash; no libraries. Pick an experiment on the left, then move through Aim, Theory, Procedure, the live Simulation, a graded Self-assessment, and References.</p>

    <div class="shell">
      <!-- ===================== SIDEBAR ===================== -->
      <aside class="sidebar">
        <div class="stitle">Experiments</div>
        <div class="exp-item on" data-exp="1"><span class="num">1</span><span class="nm">Robot arm forward kinematics</span></div>
        <div class="exp-item" data-exp="2"><span class="num">2</span><span class="nm">Robot arm inverse kinematics</span></div>
        <div class="exp-item" data-exp="3"><span class="num">3</span><span class="nm">3-link arm &amp; workspace</span></div>
        <div class="exp-item" data-exp="4"><span class="num">4</span><span class="nm">Differential-drive navigation</span></div>
        <div class="exp-item" data-exp="5"><span class="num">5</span><span class="nm">Potential-field obstacle avoidance</span></div>
        <div class="exp-item" data-exp="6"><span class="num">6</span><span class="nm">A* grid path planning</span></div>
        <div class="exp-item" data-exp="7"><span class="num">7</span><span class="nm">PID control of a 1-D system</span></div>
        <div class="exp-item" data-exp="8"><span class="num">8</span><span class="nm">Inverted pendulum cart-pole</span></div>
      </aside>

      <!-- ===================== MAIN PANEL ===================== -->
      <div class="main">

        <!-- ============ EXPERIMENT 1 — FK ============ -->
        <section class="exp on" id="exp-1">
          <h2 class="exp-head">1 &middot; Robot arm forward kinematics</h2>
          <div class="exp-sub">Planar 2-link manipulator &mdash; joint angles to end-effector pose</div>
          <div class="secbar">
            <button class="stab on" data-sec="aim">Aim</button>
            <button class="stab" data-sec="theory">Theory</button>
            <button class="stab" data-sec="proc">Procedure</button>
            <button class="stab" data-sec="sim">Simulation</button>
            <button class="stab" data-sec="quiz">Self-assessment</button>
            <button class="stab" data-sec="ref">References</button>
          </div>

          <div class="sec aim on"><div class="prose">To compute and visualise the Cartesian pose of the end-effector of a planar 2-link revolute manipulator as a direct function of its joint angles, and to develop intuition for how each joint contributes to reach.</div></div>

          <div class="sec theory"><div class="prose">
            <p>Forward kinematics maps joint space to task space. For a planar arm with links <span class="eq">L1, L2</span> and joint angles <span class="eq">&theta;1, &theta;2</span> measured cumulatively from the base, each link adds its projection onto the global axes. The end-effector position is obtained by summing the link vectors.</p>
            <div class="eqblock">x = L1&middot;cos(&theta;1) + L2&middot;cos(&theta;1+&theta;2)<br>y = L1&middot;sin(&theta;1) + L2&middot;sin(&theta;1+&theta;2)</div>
            <p>The map is single-valued: every joint configuration yields exactly one pose. The reachable set lies in an annulus of outer radius <span class="eq">L1+L2</span> and inner radius <span class="eq">|L1-L2|</span>.</p>
          </div></div>

          <div class="sec proc"><ol class="steps">
            <li>Open the <b>Simulation</b> tab.</li>
            <li>Drag the <b>&theta;1</b> slider and observe the whole arm rotate about the base.</li>
            <li>Drag <b>&theta;2</b> and note that only the second link folds &mdash; the base joint is unaffected.</li>
            <li>Read the live <b>end-effector X / Y</b> values and confirm they match the equations.</li>
            <li>Watch <b>reach used</b>: it reaches 100% only when both links are aligned outward.</li>
          </ol></div>

          <div class="sec sim">
            <div class="layout">
              <div class="panel">
                <h3>Planar arm <span class="badge" id="armReach">in reach</span></h3>
                <canvas id="armCv" width="640" height="520"></canvas>
                <div class="help"><b>Forward kinematics:</b> drag the angle sliders to pose the arm; the green dot and label are the live end-effector position.</div>
              </div>
              <div>
                <div class="panel">
                  <h3>Configuration</h3>
                  <div class="row"><label>Links</label>
                    <div class="seg" style="flex:1" id="armLinks">
                      <div class="opt on" data-n="2">2-link</div>
                      <div class="opt" data-n="3">3-link</div>
                    </div>
                  </div>
                  <div class="row"><label>&#952;&#8321;</label><input type="range" id="a1" min="-180" max="180" value="35"><span class="val" id="a1v">35&deg;</span></div>
                  <div class="row"><label>&#952;&#8322;</label><input type="range" id="a2" min="-180" max="180" value="60"><span class="val" id="a2v">60&deg;</span></div>
                  <div class="row" id="a3row"><label>&#952;&#8323;</label><input type="range" id="a3" min="-180" max="180" value="-30"><span class="val" id="a3v">-30&deg;</span></div>
                  <div class="row"><label>Elbow</label>
                    <div class="seg" style="flex:1" id="armElbow">
                      <div class="opt on" data-e="1">Up</div>
                      <div class="opt" data-e="-1">Down</div>
                    </div>
                  </div>
                  <div class="btns">
                    <button class="btn ghost full" id="armHome">Reset to home</button>
                  </div>
                  <div class="stats">
                    <div class="stat"><div class="k">End-effector X</div><div class="v" id="armX">0</div></div>
                    <div class="stat"><div class="k">End-effector Y</div><div class="v" id="armY">0</div></div>
                    <div class="stat"><div class="k">Reach used</div><div class="v" id="armUse">0%</div></div>
                    <div class="stat"><div class="k">Target dist</div><div class="v" id="armTd">--</div></div>
                  </div>
                </div>
                <div class="panel" style="margin-top:13px;">
                  <h3>The math</h3>
                  <div class="help">FK: <code>x = L1 c1 + L2 c12</code>, <code>y = L1 s1 + L2 s12</code>. IK (2-link): <code>cos&#952;2 = (x&sup2;+y&sup2;-L1&sup2;-L2&sup2;)/(2 L1 L2)</code>, then <code>&#952;1 = atan2(y,x) - atan2(L2 s2, L1+L2 c2)</code>. The 3rd link, if present, holds a fixed wrist offset.</div>
                </div>
              </div>
            </div>
          </div>

          <div class="sec quiz"><div class="quiz" data-quiz="1"></div></div>

          <div class="sec ref"><ul class="refs">
            <li><b>Spong, Hutchinson &amp; Vidyasagar</b> &mdash; Robot Modeling and Control, Ch. 3 (Forward Kinematics). Wiley.</li>
            <li><b>Craig, J. J.</b> &mdash; Introduction to Robotics: Mechanics and Control, Ch. 3. Pearson.</li>
            <li><b>Virtual Labs (IIT)</b> &mdash; Robotics: Manipulator Kinematics, vlabs.ac.in.</li>
          </ul></div>
        </section>

        <!-- ============ EXPERIMENT 2 — IK ============ -->
        <section class="exp" id="exp-2">
          <h2 class="exp-head">2 &middot; Robot arm inverse kinematics</h2>
          <div class="exp-sub">Closed-form 2-link IK &mdash; target pose to joint angles, elbow up / down</div>
          <div class="secbar">
            <button class="stab on" data-sec="aim">Aim</button>
            <button class="stab" data-sec="theory">Theory</button>
            <button class="stab" data-sec="proc">Procedure</button>
            <button class="stab" data-sec="sim">Simulation</button>
            <button class="stab" data-sec="quiz">Self-assessment</button>
            <button class="stab" data-sec="ref">References</button>
          </div>

          <div class="sec aim on"><div class="prose">To solve the inverse-kinematics problem for a planar 2-link arm in closed form &mdash; given a target Cartesian point, find joint angles that place the end-effector there &mdash; and to explore the two-solution (elbow-up / elbow-down) nature of the problem and its singularities.</div></div>

          <div class="sec theory"><div class="prose">
            <p>Inverse kinematics inverts the FK map. Applying the law of cosines to the triangle formed by the two links and the line to the target <span class="eq">(x,y)</span> gives the elbow angle directly:</p>
            <div class="eqblock">cos&theta;2 = (x&sup2; + y&sup2; - L1&sup2; - L2&sup2;) / (2&middot;L1&middot;L2)<br>&theta;2 = &plusmn; atan2(&radic;(1-cos&sup2;&theta;2), cos&theta;2)<br>&theta;1 = atan2(y,x) - atan2(L2&middot;sin&theta;2, L1 + L2&middot;cos&theta;2)</div>
            <p>The &plusmn; sign selects elbow-up vs elbow-down. If <span class="eq">|cos&theta;2| &gt; 1</span> the point is unreachable. At the workspace boundary the two solutions merge &mdash; a <b>singularity</b> where the arm loses a degree of freedom.</p>
          </div></div>

          <div class="sec proc"><ol class="steps">
            <li>Open the <b>Simulation</b> tab.</li>
            <li><b>Click anywhere</b> inside the workspace to set a target; the arm animates to the analytic solution.</li>
            <li>Toggle <b>Elbow Up / Down</b> and click the same point &mdash; both pose the tip identically but bend oppositely.</li>
            <li>Click a point <b>outside</b> the dashed reach circle &mdash; the badge reads <b>out of reach</b> and no solution is drawn.</li>
            <li>Aim for a point on the boundary to observe the near-singular straightened arm.</li>
          </ol></div>

          <div class="sec sim">
            <div class="layout">
              <div class="panel">
                <h3>Click-to-solve IK <span class="badge" id="armReach2">in reach</span></h3>
                <canvas id="armCv2" width="640" height="520"></canvas>
                <div class="help"><b>Inverse kinematics:</b> click a target in the workspace &mdash; the arm solves its joint angles analytically (law of cosines) and animates to it. Sliders still drive forward kinematics.</div>
              </div>
              <div>
                <div class="panel">
                  <h3>Configuration</h3>
                  <div class="row"><label>&#952;&#8321;</label><input type="range" id="b1" min="-180" max="180" value="35"><span class="val" id="b1v">35&deg;</span></div>
                  <div class="row"><label>&#952;&#8322;</label><input type="range" id="b2" min="-180" max="180" value="60"><span class="val" id="b2v">60&deg;</span></div>
                  <div class="row"><label>Elbow</label>
                    <div class="seg" style="flex:1" id="armElbow2">
                      <div class="opt on" data-e="1">Up</div>
                      <div class="opt" data-e="-1">Down</div>
                    </div>
                  </div>
                  <div class="btns">
                    <button class="btn ghost full" id="armHome2">Reset to home</button>
                  </div>
                  <div class="stats">
                    <div class="stat"><div class="k">End-effector X</div><div class="v" id="armX2">0</div></div>
                    <div class="stat"><div class="k">End-effector Y</div><div class="v" id="armY2">0</div></div>
                    <div class="stat"><div class="k">&#952;&#8321; solved</div><div class="v" id="armS1">--</div></div>
                    <div class="stat"><div class="k">&#952;&#8322; solved</div><div class="v" id="armS2">--</div></div>
                  </div>
                </div>
                <div class="panel" style="margin-top:13px;">
                  <h3>Solution branches</h3>
                  <div class="help">Two joint solutions reach the same point. <b>Elbow-up</b> and <b>elbow-down</b> are mirror images about the base-to-target line. They coincide on the reach boundary &mdash; a singular configuration.</div>
                </div>
              </div>
            </div>
          </div>

          <div class="sec quiz"><div class="quiz" data-quiz="2"></div></div>

          <div class="sec ref"><ul class="refs">
            <li><b>Spong, Hutchinson &amp; Vidyasagar</b> &mdash; Robot Modeling and Control, Ch. 4 (Inverse Kinematics). Wiley.</li>
            <li><b>Paul, R. P.</b> &mdash; Robot Manipulators: Mathematics, Programming, and Control. MIT Press.</li>
            <li><b>Virtual Labs (IIT)</b> &mdash; Robotics: Inverse Kinematics of 2R Manipulator, vlabs.ac.in.</li>
          </ul></div>
        </section>

        <!-- ============ EXPERIMENT 3 — 3-LINK WORKSPACE (NEW) ============ -->
        <section class="exp" id="exp-3">
          <h2 class="exp-head">3 &middot; 3-link arm &amp; workspace</h2>
          <div class="exp-sub">3R planar manipulator &mdash; sweep joints to trace the reachable envelope</div>
          <div class="secbar">
            <button class="stab on" data-sec="aim">Aim</button>
            <button class="stab" data-sec="theory">Theory</button>
            <button class="stab" data-sec="proc">Procedure</button>
            <button class="stab" data-sec="sim">Simulation</button>
            <button class="stab" data-sec="quiz">Self-assessment</button>
            <button class="stab" data-sec="ref">References</button>
          </div>

          <div class="sec aim on"><div class="prose">To compute the forward kinematics of a redundant 3-link planar arm and to map its reachable workspace by Monte-Carlo / grid sampling of the joint space, illustrating how added links enlarge the workspace and create dexterous inner regions.</div></div>

          <div class="sec theory"><div class="prose">
            <p>For a 3R planar arm the tip position accumulates three link contributions, each rotated by the running sum of joint angles:</p>
            <div class="eqblock">x = L1 c&#8321; + L2 c&#8321;&#8322; + L3 c&#8321;&#8322;&#8323;<br>y = L1 s&#8321; + L2 s&#8321;&#8322; + L3 s&#8321;&#8322;&#8323;</div>
            <p>where <span class="eq">c&#8321;&#8322;&#8323; = cos(&theta;1+&theta;2+&theta;3)</span> and so on. The arm is <b>kinematically redundant</b>: it has 3 joints for a 2-DOF task, so infinitely many configurations reach most points. The <b>workspace</b> is the set of all reachable tips &mdash; here a disc of radius <span class="eq">L1+L2+L3</span>, with a possible unreachable inner hole when one link dominates. Sampling the joint space and plotting every resulting tip reveals this envelope empirically.</p>
          </div></div>

          <div class="sec proc"><ol class="steps">
            <li>Open the <b>Simulation</b> tab.</li>
            <li>Press <b>Sweep workspace</b> &mdash; the simulator samples thousands of joint triples and stipples each reachable tip, building up the envelope.</li>
            <li>Adjust the <b>L3 length</b> slider and re-sweep; note how the outer radius and inner hole change.</li>
            <li>Drag <b>&theta;1 / &theta;2 / &theta;3</b> to pose the live arm and confirm the tip always lands inside the sampled cloud.</li>
            <li>Read <b>outer / inner radius</b> &mdash; the measured envelope matches <span class="eq">L1+L2+L3</span>.</li>
          </ol></div>

          <div class="sec sim">
            <div class="layout">
              <div class="panel">
                <h3>3R workspace <span class="badge" id="wsState">ready</span></h3>
                <canvas id="wsCv" width="640" height="520"></canvas>
                <div class="help"><b>Workspace:</b> each cyan dot is the tip of one sampled joint configuration. The purple arm is your live pose. The dashed circle is the theoretical reach <code>L1+L2+L3</code>.</div>
              </div>
              <div>
                <div class="panel">
                  <h3>Joints &amp; geometry</h3>
                  <div class="row"><label>&#952;&#8321;</label><input type="range" id="w1" min="-180" max="180" value="40"><span class="val" id="w1v">40&deg;</span></div>
                  <div class="row"><label>&#952;&#8322;</label><input type="range" id="w2" min="-180" max="180" value="50"><span class="val" id="w2v">50&deg;</span></div>
                  <div class="row"><label>&#952;&#8323;</label><input type="range" id="w3" min="-180" max="180" value="-35"><span class="val" id="w3v">-35&deg;</span></div>
                  <div class="row"><label>L3 len</label><input type="range" id="wL3" min="20" max="130" step="2" value="70"><span class="val" id="wL3v">70</span></div>
                  <div class="btns">
                    <button class="btn cyan" id="wsSweep">Sweep workspace</button>
                    <button class="btn ghost" id="wsClear">Clear cloud</button>
                  </div>
                  <div class="stats">
                    <div class="stat"><div class="k">Tip X</div><div class="v" id="wsX">0</div></div>
                    <div class="stat"><div class="k">Tip Y</div><div class="v" id="wsY">0</div></div>
                    <div class="stat"><div class="k">Outer radius</div><div class="v" id="wsOut">0</div></div>
                    <div class="stat"><div class="k">Inner hole</div><div class="v" id="wsIn">0</div></div>
                  </div>
                </div>
                <div class="panel" style="margin-top:13px;">
                  <h3>Redundancy</h3>
                  <div class="help">A 3R arm has one extra DOF over a planar task. The same tip point can be reached by a continuum of elbow configurations &mdash; useful for dodging obstacles while holding a pose. The sampled cloud is the union of all those tips.</div>
                </div>
              </div>
            </div>
          </div>

          <div class="sec quiz"><div class="quiz" data-quiz="3"></div></div>

          <div class="sec ref"><ul class="refs">
            <li><b>Siciliano, Sciavicco, Villani &amp; Oriolo</b> &mdash; Robotics: Modelling, Planning and Control, Ch. 2-3. Springer.</li>
            <li><b>Lynch &amp; Park</b> &mdash; Modern Robotics, Ch. 4 (Forward Kinematics) &amp; workspace analysis. Cambridge.</li>
            <li><b>Virtual Labs (IIT)</b> &mdash; Robotics: Workspace of a Planar Manipulator, vlabs.ac.in.</li>
          </ul></div>
        </section>

        <!-- ============ EXPERIMENT 4 — MOBILE NAV ============ -->
        <section class="exp" id="exp-4">
          <h2 class="exp-head">4 &middot; Differential-drive mobile robot navigation</h2>
          <div class="exp-sub">Unicycle model with a proportional heading + speed controller</div>
          <div class="secbar">
            <button class="stab on" data-sec="aim">Aim</button>
            <button class="stab" data-sec="theory">Theory</button>
            <button class="stab" data-sec="proc">Procedure</button>
            <button class="stab" data-sec="sim">Simulation</button>
            <button class="stab" data-sec="quiz">Self-assessment</button>
            <button class="stab" data-sec="ref">References</button>
          </div>

          <div class="sec aim on"><div class="prose">To model a differential-drive (unicycle) mobile robot and drive it to clicked waypoints using a proportional controller on heading and speed, observing the integrated trajectory and the effect of controller gains on the approach.</div></div>

          <div class="sec theory"><div class="prose">
            <p>A differential-drive robot is modelled as a unicycle with pose <span class="eq">(x, y, &theta;)</span>, linear speed <span class="eq">v</span> and turn rate <span class="eq">&omega;</span>:</p>
            <div class="eqblock">x&#775; = v&middot;cos&theta;&nbsp;&nbsp;&nbsp;y&#775; = v&middot;sin&theta;&nbsp;&nbsp;&nbsp;&theta;&#775; = &omega;</div>
            <p>The controller computes a heading error to the goal, wrapped to <span class="eq">[-&pi;,&pi;]</span>, and commands turn rate proportionally; forward speed scales with remaining distance and de-rates when the heading error is large:</p>
            <div class="eqblock">e&theta; = atan2(dy,dx) - &theta;&nbsp;&nbsp;&omega; = K&omega;&middot;e&theta;&nbsp;&nbsp;v = K&#7515;&middot;d&middot;max(0, cos e&theta;)</div>
            <p>The pose is integrated each frame with Euler steps. This is a <b>nonholonomic</b> system &mdash; it cannot move sideways &mdash; so it must turn toward a goal before advancing.</p>
          </div></div>

          <div class="sec proc"><ol class="steps">
            <li>Open the <b>Simulation</b> tab and <b>click</b> a point to drop a goal.</li>
            <li>Watch the robot turn toward the goal first, then drive in &mdash; the cyan curve is its integrated path.</li>
            <li>Lower <b>K&omega;</b> and re-click: the robot arcs in slowly. Raise it for crisp turns (too high &mdash; it wobbles).</li>
            <li>Adjust <b>K&#7515;</b> and <b>Max v</b> to change how aggressively it accelerates and its top speed.</li>
            <li>Use <b>Reset robot</b> to return it to the corner.</li>
          </ol></div>

          <div class="sec sim">
            <div class="layout">
              <div class="panel">
                <h3>Differential-drive field <span class="badge" id="mobState">idle</span></h3>
                <canvas id="mobCv" width="640" height="520"></canvas>
                <div class="help"><b>Click</b> to drop a waypoint goal. The robot follows a proportional heading + speed controller integrating the unicycle model <code>x'=v cos&#952;, y'=v sin&#952;, &#952;'=&#969;</code>.</div>
              </div>
              <div>
                <div class="panel">
                  <h3>Controller gains</h3>
                  <div class="row"><label>K&#969; (head)</label><input type="range" id="mKw" min="0" max="8" step="0.1" value="3.5"><span class="val" id="mKwv">3.5</span></div>
                  <div class="row"><label>K&#7515; (speed)</label><input type="range" id="mKv" min="0" max="3" step="0.05" value="1.2"><span class="val" id="mKvv">1.2</span></div>
                  <div class="row"><label>Max v</label><input type="range" id="mVmax" min="30" max="180" step="5" value="110"><span class="val" id="mVmaxv">110</span></div>
                  <div class="row"><label>Avoid</label><input type="range" id="mAvoid" min="0" max="3" step="0.1" value="1.4"><span class="val" id="mAvoidv">1.4</span></div>
                  <div class="btns">
                    <button class="btn cyan" id="mobObst">Add obstacle</button>
                    <button class="btn ghost" id="mobClear">Clear path</button>
                    <button class="btn ghost full" id="mobReset">Reset robot</button>
                  </div>
                  <div class="stats">
                    <div class="stat"><div class="k">Speed v</div><div class="v" id="mobV">0</div></div>
                    <div class="stat"><div class="k">&#969; rad/s</div><div class="v" id="mobW">0</div></div>
                    <div class="stat"><div class="k">Heading</div><div class="v" id="mobTh">0&deg;</div></div>
                    <div class="stat"><div class="k">Goal dist</div><div class="v" id="mobD">--</div></div>
                  </div>
                </div>
                <div class="panel" style="margin-top:13px;">
                  <h3>How it steers</h3>
                  <div class="help">Heading error <code>e&#952; = atan2(dy,dx) - &#952;</code> wrapped to [-&#960;,&#960;]; <code>&#969; = K&#969; &middot; e&#952;</code>. Forward speed scales with distance and de-rates when steering hard. Obstacles (Exp. 5) add a repulsive push.</div>
                </div>
              </div>
            </div>
          </div>

          <div class="sec quiz"><div class="quiz" data-quiz="4"></div></div>

          <div class="sec ref"><ul class="refs">
            <li><b>Siegwart, Nourbakhsh &amp; Scaramuzza</b> &mdash; Introduction to Autonomous Mobile Robots, Ch. 3. MIT Press.</li>
            <li><b>LaValle, S. M.</b> &mdash; Planning Algorithms, Ch. 13 (Differential Models). Cambridge.</li>
            <li><b>Virtual Labs (IIT)</b> &mdash; Mobile Robotics: Unicycle Kinematics, vlabs.ac.in.</li>
          </ul></div>
        </section>

        <!-- ============ EXPERIMENT 5 — POTENTIAL FIELD ============ -->
        <section class="exp" id="exp-5">
          <h2 class="exp-head">5 &middot; Potential-field obstacle avoidance</h2>
          <div class="exp-sub">Attractive goal + repulsive obstacles bending the motion vector</div>
          <div class="secbar">
            <button class="stab on" data-sec="aim">Aim</button>
            <button class="stab" data-sec="theory">Theory</button>
            <button class="stab" data-sec="proc">Procedure</button>
            <button class="stab" data-sec="sim">Simulation</button>
            <button class="stab" data-sec="quiz">Self-assessment</button>
            <button class="stab" data-sec="ref">References</button>
          </div>

          <div class="sec aim on"><div class="prose">To implement artificial potential-field navigation, where the robot is pulled toward a goal by an attractive field and pushed away from obstacles by repulsive fields, and to observe the resulting collision-free trajectory and the local-minimum failure mode.</div></div>

          <div class="sec theory"><div class="prose">
            <p>The robot descends the gradient of a total potential <span class="eq">U = U_att + U_rep</span>. The attractive part pulls toward the goal; each obstacle contributes a repulsion that grows as the robot nears it, active only within an influence radius <span class="eq">d&#8320;</span>:</p>
            <div class="eqblock">F_att = k_a &middot; (goal - p) / |goal - p|<br>F_rep = k_r &middot; (d&#8320; - d)/d&#8320; &middot; (p - obs)/d,&nbsp; for d &lt; d&#8320;</div>
            <p>The net force vector sets the desired heading; the same unicycle controller then tracks it. Potential fields are fast and reactive but can trap the robot in a <b>local minimum</b> where attraction and repulsion cancel before reaching the goal.</p>
          </div></div>

          <div class="sec proc"><ol class="steps">
            <li>Open the <b>Simulation</b> tab &mdash; two obstacles are pre-placed.</li>
            <li><b>Click</b> a goal on the far side of an obstacle and watch the path bow smoothly around it.</li>
            <li>Press <b>Add obstacle</b>, then click to place a new repeller, and set a goal behind it.</li>
            <li>Raise the <b>Avoid</b> gain &mdash; the robot gives obstacles a wider berth.</li>
            <li>Try to trap the robot between two close obstacles to provoke a local minimum (it stalls short of the goal).</li>
          </ol></div>

          <div class="sec sim">
            <div class="layout">
              <div class="panel">
                <h3>Potential field <span class="badge" id="pfState">idle</span></h3>
                <canvas id="pfCv" width="640" height="520"></canvas>
                <div class="help"><b>Repulsive fields:</b> each obstacle adds a <code>1/d</code>-style push that bends the goal-seeking vector. Click for a goal; Add obstacle drops repellers.</div>
              </div>
              <div>
                <div class="panel">
                  <h3>Field gains</h3>
                  <div class="row"><label>K&#969; (head)</label><input type="range" id="pKw2" min="0" max="8" step="0.1" value="3.5"><span class="val" id="pKw2v">3.5</span></div>
                  <div class="row"><label>K&#7515; (speed)</label><input type="range" id="pKv2" min="0" max="3" step="0.05" value="1.2"><span class="val" id="pKv2v">1.2</span></div>
                  <div class="row"><label>Max v</label><input type="range" id="pVmax2" min="30" max="180" step="5" value="110"><span class="val" id="pVmax2v">110</span></div>
                  <div class="row"><label>Avoid k_r</label><input type="range" id="pAvoid2" min="0" max="3" step="0.1" value="1.6"><span class="val" id="pAvoid2v">1.6</span></div>
                  <div class="btns">
                    <button class="btn cyan" id="pfObst">Add obstacle</button>
                    <button class="btn ghost" id="pfClear">Clear path</button>
                    <button class="btn ghost full" id="pfReset">Reset field</button>
                  </div>
                  <div class="stats">
                    <div class="stat"><div class="k">Speed v</div><div class="v" id="pfV">0</div></div>
                    <div class="stat"><div class="k">Rep force</div><div class="v" id="pfRep">0</div></div>
                    <div class="stat"><div class="k">Obstacles</div><div class="v" id="pfN">2</div></div>
                    <div class="stat"><div class="k">Goal dist</div><div class="v" id="pfD">--</div></div>
                  </div>
                </div>
                <div class="panel" style="margin-top:13px;">
                  <h3>Local minima</h3>
                  <div class="help">When repulsion exactly opposes attraction the net force is zero away from the goal and the robot halts &mdash; the classic potential-field trap. Global planners (Exp. 6) avoid this by construction.</div>
                </div>
              </div>
            </div>
          </div>

          <div class="sec quiz"><div class="quiz" data-quiz="5"></div></div>

          <div class="sec ref"><ul class="refs">
            <li><b>Khatib, O.</b> &mdash; Real-Time Obstacle Avoidance for Manipulators and Mobile Robots. IJRR, 1986.</li>
            <li><b>Choset et al.</b> &mdash; Principles of Robot Motion, Ch. 4 (Potential Functions). MIT Press.</li>
            <li><b>Virtual Labs (IIT)</b> &mdash; Robot Navigation: Artificial Potential Fields, vlabs.ac.in.</li>
          </ul></div>
        </section>

        <!-- ============ EXPERIMENT 6 — A* PLANNING ============ -->
        <section class="exp" id="exp-6">
          <h2 class="exp-head">6 &middot; A* / Dijkstra grid path planning</h2>
          <div class="exp-sub">Heuristic search on an editable occupancy grid with animated frontier</div>
          <div class="secbar">
            <button class="stab on" data-sec="aim">Aim</button>
            <button class="stab" data-sec="theory">Theory</button>
            <button class="stab" data-sec="proc">Procedure</button>
            <button class="stab" data-sec="sim">Simulation</button>
            <button class="stab" data-sec="quiz">Self-assessment</button>
            <button class="stab" data-sec="ref">References</button>
          </div>

          <div class="sec aim on"><div class="prose">To find the shortest collision-free path on an occupancy grid using the A* algorithm, to visualise the expanding search frontier, and to compare heuristics (Manhattan, octile, Euclidean) and connectivity (4- vs 8-neighbour) for optimality and efficiency.</div></div>

          <div class="sec theory"><div class="prose">
            <p>A* expands grid cells in increasing order of an estimated total cost, popping the open cell with the smallest:</p>
            <div class="eqblock">f(n) = g(n) + h(n)</div>
            <p>where <span class="eq">g(n)</span> is the exact cost from the start and <span class="eq">h(n)</span> is a heuristic estimate to the goal. If <span class="eq">h</span> never overestimates (it is <b>admissible</b>) A* returns an optimal path; if it also satisfies the triangle inequality (<b>consistent</b>) no cell is re-expanded. With <span class="eq">h=0</span> A* degenerates to <b>Dijkstra</b>. For 8-connected grids the <b>octile</b> distance is the exact metric and so is admissible. Diagonal corner-cutting through walls is forbidden, and diagonal moves cost <span class="eq">&radic;2</span>.</p>
          </div></div>

          <div class="sec proc"><ol class="steps">
            <li>Open the <b>Simulation</b> tab. <b>Drag</b> to paint walls; <b>shift+click</b> sets the start, <b>ctrl+click</b> the goal.</li>
            <li>Choose a <b>heuristic</b> &mdash; Manhattan forces 4-direction motion; octile / Euclidean allow diagonals.</li>
            <li>Press <b>Plan &amp; drive</b> and watch the cyan frontier expand and the dark visited set fill in.</li>
            <li>Read <b>expanded</b> vs <b>path cells</b> &mdash; a sharper heuristic expands far fewer nodes for the same path.</li>
            <li>Set the heuristic so it acts like Dijkstra (Manhattan on an open grid) and note it expands a broad diamond.</li>
          </ol></div>

          <div class="sec sim">
            <div class="layout">
              <div class="panel">
                <h3>A* grid <span class="badge" id="planState">edit walls</span></h3>
                <canvas id="planCv" width="640" height="520"></canvas>
                <div class="help"><b>Drag</b> to paint walls, <b>shift+click</b> sets start, <b>ctrl+click</b> sets goal. Run A* to watch the frontier expand, then the robot drives the shortest path.</div>
              </div>
              <div>
                <div class="panel">
                  <h3>Planner</h3>
                  <div class="row"><label>Heuristic</label>
                    <select id="planH">
                      <option value="manhattan">Manhattan (4-dir)</option>
                      <option value="octile" selected>Octile (8-dir)</option>
                      <option value="euclid">Euclidean (8-dir)</option>
                    </select>
                  </div>
                  <div class="row"><label>Speed</label><input type="range" id="planSpeed" min="1" max="60" value="14"><span class="val" id="planSpeedv">14ms</span></div>
                  <div class="btns">
                    <button class="btn" id="planRun">Plan &amp; drive</button>
                    <button class="btn ghost" id="planClear">Clear walls</button>
                    <button class="btn ghost full" id="planReset">Reset overlay</button>
                  </div>
                  <div class="stats">
                    <div class="stat"><div class="k">Expanded</div><div class="v" id="planExp">0</div></div>
                    <div class="stat"><div class="k">Frontier</div><div class="v" id="planFr">0</div></div>
                    <div class="stat"><div class="k">Path cells</div><div class="v" id="planLen">0</div></div>
                    <div class="stat"><div class="k">Path cost</div><div class="v" id="planCost">0</div></div>
                  </div>
                </div>
                <div class="panel" style="margin-top:13px;">
                  <h3>A* notes</h3>
                  <div class="help">Expands the open node with smallest <code>f = g + h</code>, where <code>g</code> is true cost-so-far and <code>h</code> an admissible estimate. Octile distance is the exact shortest 8-connected metric, so it is admissible and yields optimal diagonal paths.</div>
                </div>
              </div>
            </div>
          </div>

          <div class="sec quiz"><div class="quiz" data-quiz="6"></div></div>

          <div class="sec ref"><ul class="refs">
            <li><b>Hart, Nilsson &amp; Raphael</b> &mdash; A Formal Basis for the Heuristic Determination of Minimum Cost Paths. IEEE TSSC, 1968.</li>
            <li><b>Russell &amp; Norvig</b> &mdash; Artificial Intelligence: A Modern Approach, Ch. 3 (Informed Search). Pearson.</li>
            <li><b>Virtual Labs (IIT)</b> &mdash; AI: A* and Dijkstra Shortest Path, vlabs.ac.in.</li>
          </ul></div>
        </section>

        <!-- ============ EXPERIMENT 7 — PID ============ -->
        <section class="exp" id="exp-7">
          <h2 class="exp-head">7 &middot; PID control of a 1-D system</h2>
          <div class="exp-sub">Mass-cart with drag driven to a setpoint &mdash; rise, overshoot, settling</div>
          <div class="secbar">
            <button class="stab on" data-sec="aim">Aim</button>
            <button class="stab" data-sec="theory">Theory</button>
            <button class="stab" data-sec="proc">Procedure</button>
            <button class="stab" data-sec="sim">Simulation</button>
            <button class="stab" data-sec="quiz">Self-assessment</button>
            <button class="stab" data-sec="ref">References</button>
          </div>

          <div class="sec aim on"><div class="prose">To tune a PID controller regulating the position of a 1-D mass with viscous drag to a setpoint, and to study how the proportional, integral and derivative gains shape the rise time, overshoot, steady-state error and settling time of the closed-loop response.</div></div>

          <div class="sec theory"><div class="prose">
            <p>The plant is a unit mass with drag <span class="eq">c</span> under control force <span class="eq">u</span>: <span class="eq">m&middot;a = u - c&middot;v</span>. The PID law acts on the tracking error <span class="eq">e = setpoint - x</span>:</p>
            <div class="eqblock">u = Kp&middot;e + Ki&middot;&int;e dt + Kd&middot;de/dt</div>
            <p><b>Kp</b> gives a force proportional to error &mdash; bigger Kp means faster rise but more overshoot. <b>Kd</b> reacts to the rate of change, adding damping that suppresses overshoot and oscillation. <b>Ki</b> accumulates past error to eliminate steady-state offset, at the cost of possible wind-up (mitigated here by clamping the integral). Key metrics: <b>overshoot</b> (peak above setpoint), <b>settling time</b> (entering and staying within a 2% band).</p>
          </div></div>

          <div class="sec proc"><ol class="steps">
            <li>Open the <b>Simulation</b> tab &mdash; the cart chases the amber setpoint and the curve plots position over time.</li>
            <li>Increase <b>Kp</b> alone: rise speeds up but overshoot climbs and oscillation appears.</li>
            <li>Add <b>Kd</b>: the response damps &mdash; watch overshoot and settling time drop.</li>
            <li>If a steady offset remains, add <b>Ki</b> to drive it to zero.</li>
            <li>Press <b>Step setpoint</b> to command a fresh step and read overshoot / settling for your tuning.</li>
          </ol></div>

          <div class="sec sim">
            <div class="layout">
              <div class="panel">
                <h3>Response &mdash; mass-cart to setpoint <span class="badge" id="pidState">running</span></h3>
                <canvas id="pidCv" width="640" height="360"></canvas>
                <canvas id="pidTrack" width="640" height="120" style="margin-top:10px;"></canvas>
                <div class="help">A unit mass with drag is driven by a PID force toward the setpoint. The curve is real-time integrated position; the lower strip shows the cart chasing the setpoint marker.</div>
              </div>
              <div>
                <div class="panel">
                  <h3>Gains &amp; setpoint</h3>
                  <div class="row"><label>Kp</label><input type="range" id="pKp" min="0" max="40" step="0.5" value="12"><span class="val" id="pKpv">12</span></div>
                  <div class="row"><label>Ki</label><input type="range" id="pKi" min="0" max="12" step="0.1" value="2.0"><span class="val" id="pKiv">2.0</span></div>
                  <div class="row"><label>Kd</label><input type="range" id="pKd" min="0" max="20" step="0.1" value="6.0"><span class="val" id="pKdv">6.0</span></div>
                  <div class="row"><label>Setpoint</label><input type="range" id="pSet" min="-90" max="90" step="1" value="55"><span class="val" id="pSetv">55</span></div>
                  <div class="row"><label>Mass</label><input type="range" id="pMass" min="0.4" max="4" step="0.1" value="1.0"><span class="val" id="pMassv">1.0</span></div>
                  <div class="btns">
                    <button class="btn ghost" id="pidStep">Step setpoint</button>
                    <button class="btn ghost" id="pidReset">Reset</button>
                  </div>
                  <div class="stats">
                    <div class="stat"><div class="k">Position</div><div class="v" id="pidPos">0</div></div>
                    <div class="stat"><div class="k">Error</div><div class="v" id="pidErr">0</div></div>
                    <div class="stat"><div class="k">Overshoot</div><div class="v" id="pidOver">0%</div></div>
                    <div class="stat"><div class="k">Settle t</div><div class="v" id="pidSettle">--</div></div>
                  </div>
                </div>
                <div class="panel" style="margin-top:13px;">
                  <h3>Control law</h3>
                  <div class="help"><code>u = Kp&middot;e + Ki&#8747;e dt + Kd&middot;de/dt</code>, with <code>e = setpoint - x</code>. Plant: <code>m&middot;a = u - c&middot;v</code>. Push Kp high for fast rise but watch overshoot; add Kd to damp it; trim steady-state offset with Ki.</div>
                </div>
              </div>
            </div>
          </div>

          <div class="sec quiz"><div class="quiz" data-quiz="7"></div></div>

          <div class="sec ref"><ul class="refs">
            <li><b>&Aring;str&ouml;m &amp; Murray</b> &mdash; Feedback Systems: An Introduction for Scientists and Engineers, Ch. 10. Princeton.</li>
            <li><b>Ogata, K.</b> &mdash; Modern Control Engineering, Ch. 5-8. Pearson.</li>
            <li><b>Virtual Labs (IIT)</b> &mdash; Control Systems: PID Controller Tuning, vlabs.ac.in.</li>
          </ul></div>
        </section>

        <!-- ============ EXPERIMENT 8 — CART-POLE (NEW) ============ -->
        <section class="exp" id="exp-8">
          <h2 class="exp-head">8 &middot; Inverted pendulum / cart-pole balance</h2>
          <div class="exp-sub">Integrate the nonlinear cart-pole; state-feedback balances the pole upright</div>
          <div class="secbar">
            <button class="stab on" data-sec="aim">Aim</button>
            <button class="stab" data-sec="theory">Theory</button>
            <button class="stab" data-sec="proc">Procedure</button>
            <button class="stab" data-sec="sim">Simulation</button>
            <button class="stab" data-sec="quiz">Self-assessment</button>
            <button class="stab" data-sec="ref">References</button>
          </div>

          <div class="sec aim on"><div class="prose">To integrate the nonlinear equations of motion of a cart-pole (inverted pendulum on a cart) and design a state-feedback / PID controller that applies a horizontal force to keep the pole balanced upright, studying the stabilising effect of each feedback term and the basin of attraction.</div></div>

          <div class="sec theory"><div class="prose">
            <p>The cart (mass <span class="eq">M</span>) carries a hinged pole (mass <span class="eq">m</span>, half-length <span class="eq">l</span>) at angle <span class="eq">&theta;</span> from vertical, driven by force <span class="eq">F</span>. The coupled nonlinear dynamics are:</p>
            <div class="eqblock">&theta;&#776; = (g sin&theta; - cos&theta;&middot;temp) / (l (4/3 - m cos&sup2;&theta;/(M+m)))<br>temp = (F + m l &theta;&#775;&sup2; sin&theta;) / (M+m)<br>x&#776; = temp - m l &theta;&#776; cos&theta; / (M+m)</div>
            <p>The upright equilibrium <span class="eq">&theta;=0</span> is <b>unstable</b> &mdash; any deviation grows without control. A linear state-feedback law <span class="eq">F = k&theta;&middot;&theta; + k&omega;&middot;&theta;&#775; + kx&middot;x + kv&middot;x&#775;</span> stabilises it: the angle terms right the pole, the cart terms keep it centred. Integrated with sub-stepped Euler, the controller catches and balances the pole.</p>
          </div></div>

          <div class="sec proc"><ol class="steps">
            <li>Open the <b>Simulation</b> tab &mdash; the pole starts slightly tilted and the controller catches it.</li>
            <li>Press <b>Nudge pole</b> to inject a disturbance and watch the cart dart to recover.</li>
            <li>Lower <b>k&theta;</b> toward zero &mdash; the controller can no longer hold the pole and it falls.</li>
            <li>Raise <b>k&omega;</b> (angular damping) to calm oscillation; raise <b>kx / kv</b> to pull the cart back to centre.</li>
            <li>Press <b>Drop pole</b> (disable control) to see the open-loop instability, then re-enable to recover.</li>
          </ol></div>

          <div class="sec sim">
            <div class="layout">
              <div class="panel">
                <h3>Cart-pole <span class="badge" id="cpState">balancing</span></h3>
                <canvas id="cpCv" width="640" height="320"></canvas>
                <canvas id="cpPlot" width="640" height="150" style="margin-top:10px;"></canvas>
                <div class="help"><b>Nonlinear cart-pole</b> integrated live. The amber curve is pole angle vs time; the controller force is shown as the arrow on the cart.</div>
              </div>
              <div>
                <div class="panel">
                  <h3>Feedback gains</h3>
                  <div class="row"><label>k&#952; (angle)</label><input type="range" id="cKth" min="0" max="220" step="2" value="120"><span class="val" id="cKthv">120</span></div>
                  <div class="row"><label>k&#969; (rate)</label><input type="range" id="cKw" min="0" max="40" step="0.5" value="18"><span class="val" id="cKwv">18</span></div>
                  <div class="row"><label>kx (cart)</label><input type="range" id="cKx" min="0" max="12" step="0.2" value="3"><span class="val" id="cKxv">3</span></div>
                  <div class="row"><label>kv (cart v)</label><input type="range" id="cKv" min="0" max="20" step="0.5" value="6"><span class="val" id="cKvv">6</span></div>
                  <div class="btns">
                    <button class="btn cyan" id="cpNudge">Nudge pole</button>
                    <button class="btn ghost" id="cpDrop">Drop pole</button>
                    <button class="btn ghost full" id="cpReset">Reset upright</button>
                  </div>
                  <div class="stats">
                    <div class="stat"><div class="k">Angle &#952;</div><div class="v" id="cpTh">0&deg;</div></div>
                    <div class="stat"><div class="k">Cart x</div><div class="v" id="cpX">0</div></div>
                    <div class="stat"><div class="k">Force F</div><div class="v" id="cpF">0</div></div>
                    <div class="stat"><div class="k">Status</div><div class="v" id="cpStat">up</div></div>
                  </div>
                </div>
                <div class="panel" style="margin-top:13px;">
                  <h3>Why it is hard</h3>
                  <div class="help">The upright pole is an unstable equilibrium &mdash; the linearised system has a right-half-plane pole. Feedback must act faster than the instability grows. Too little <code>k&#952;</code> and the basin of attraction vanishes; the pole topples past recovery.</div>
                </div>
              </div>
            </div>
          </div>

          <div class="sec quiz"><div class="quiz" data-quiz="8"></div></div>

