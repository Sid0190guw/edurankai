      ctx.beginPath(); ctx.moveTo(pivotX, pivotY); ctx.lineTo(tipX, tipY); ctx.stroke();
      ctx.fillStyle = '#67e8f9'; ctx.beginPath(); ctx.arc(tipX, tipY, 8, 0, TAU); ctx.fill();
      ctx.fillStyle = '#0a0a0c'; ctx.strokeStyle = '#e8e8ee'; ctx.lineWidth = 2;
      ctx.beginPath(); ctx.arc(pivotX, pivotY, 4, 0, TAU); ctx.fill(); ctx.stroke();
      // force arrow on cart
      if (Math.abs(force) > 0.5) {
        var fx = clamp(force * 2.2, -90, 90);
        ctx.strokeStyle = '#86efac'; ctx.lineWidth = 3;
        ctx.beginPath(); ctx.moveTo(cartX, groundY - 9); ctx.lineTo(cartX + fx, groundY - 9); ctx.stroke();
        var dir = fx >= 0 ? 1 : -1;
        ctx.beginPath();
        ctx.moveTo(cartX + fx, groundY - 9);
        ctx.lineTo(cartX + fx - dir * 7, groundY - 13);
        ctx.lineTo(cartX + fx - dir * 7, groundY - 5);
        ctx.closePath(); ctx.fillStyle = '#86efac'; ctx.fill();
      }
    }

    function drawPlot() {
      pctx.fillStyle = '#08080b'; pctx.fillRect(0, 0, PW, PH);
      var mid = PH / 2;
      pctx.strokeStyle = '#232330'; pctx.lineWidth = 1;
      pctx.beginPath(); pctx.moveTo(0, mid); pctx.lineTo(PW, mid); pctx.stroke();
      pctx.fillStyle = '#5a5a68'; pctx.font = '9px Geist Mono, monospace';
      pctx.fillText('pole angle theta (deg)', 6, 12);
      pctx.fillText('0', 4, mid - 2);
      var range = 60 * Math.PI / 180;          // +/- 60 deg full scale
      if (hist.length > 1) {
        pctx.strokeStyle = '#fbbf24'; pctx.lineWidth = 1.8; pctx.beginPath();
        for (var i = 0; i < hist.length; i++) {
          var X = i / (maxHist - 1) * PW;
          var Y = mid - clamp(hist[i] / range, -1, 1) * (mid - 8);
          if (i === 0) pctx.moveTo(X, Y); else pctx.lineTo(X, Y);
        }
        pctx.stroke();
      }
    }

    function loop(ts) {
      if (!lastFrame) lastFrame = ts;
      var dt = Math.min(0.03, (ts - lastFrame) / 1000); lastFrame = ts;
      var sub = 6, h = dt / sub;
      for (var s = 0; s < sub; s++) physics(h);
      drawScene(); drawPlot();
      $('cpTh').textContent = (st.th * 180 / Math.PI).toFixed(1) + '°';
      $('cpX').textContent = st.x.toFixed(2);
      $('cpF').textContent = force.toFixed(1);
      $('cpStat').textContent = !controlOn ? 'off' : (Math.abs(st.th) < 0.12 ? 'up' : 'catch');
      requestAnimationFrame(loop);
    }

    var sliders = [['cKth', 'cKthv', 0], ['cKw', 'cKwv', 0], ['cKx', 'cKxv', 1], ['cKv', 'cKvv', 1]];
    for (var si = 0; si < sliders.length; si++) {
      (function (id, vid, dp) { $(id).addEventListener('input', function () { $(vid).textContent = (+$(id).value).toFixed(dp); }); })(sliders[si][0], sliders[si][1], sliders[si][2]);
    }
    $('cpNudge').addEventListener('click', function () { st.thd += (Math.random() < 0.5 ? -1 : 1) * (2.0 + Math.random() * 1.5); });
    $('cpDrop').addEventListener('click', function () {
      controlOn = !controlOn;
      this.textContent = controlOn ? 'Drop pole' : 'Enable control';
      $('cpState').textContent = controlOn ? 'balancing' : 'open-loop';
    });
    $('cpReset').addEventListener('click', function () { reset(); $('cpDrop').textContent = 'Drop pole'; });

    requestAnimationFrame(loop);
  })();

})();
</script>
</BaseLayout>
