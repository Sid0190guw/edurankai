      if (ellAx) {
        var sc = 0.9;                                  // px per unit singular value
        ctx.save(); ctx.translate(st.x, st.y);
        var rot = Math.atan2(-ellAx.v1.y, ellAx.v1.x); // screen y is flipped
        ctx.rotate(rot);
        ctx.strokeStyle = 'rgba(251,191,36,0.85)'; ctx.lineWidth = 1.6;
        ctx.beginPath(); ctx.ellipse(0, 0, Math.max(2, ellAx.s1 * sc), Math.max(2, ellAx.s2 * sc), 0, 0, TAU); ctx.stroke();
        ctx.restore();
      }
      ctx.fillStyle = '#86efac'; ctx.beginPath(); ctx.arc(st.x, st.y, 5, 0, TAU); ctx.fill();
      if (target) {
        var tt = w2s(target.x, target.y);
        ctx.strokeStyle = '#fca5a5'; ctx.lineWidth = 1.5;
        ctx.beginPath(); ctx.arc(tt.x, tt.y, 9, 0, TAU); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(tt.x - 13, tt.y); ctx.lineTo(tt.x + 13, tt.y);
        ctx.moveTo(tt.x, tt.y - 13); ctx.lineTo(tt.x, tt.y + 13); ctx.stroke();
      }
      ctx.fillStyle = '#2a2a35'; ctx.fillRect(ox - 16, oy, 32, 12);
    }

    function loop() {
      if (solving && target) {
        for (var k = 0; k < 2; k++) {                  // a couple of iters per frame
          lastErr = dlsStep(); iters++;
          if (lastErr < 0.6 || iters > 600) { solving = false; $('jacState').textContent = lastErr < 1.5 ? 'converged' : 'stalled'; break; }
        }
        $('jacIt').textContent = iters;
        $('jacErr').textContent = lastErr.toFixed(1);
        $('jacW').textContent = manipW.toFixed(0);
        $('jacCond').textContent = condN > 900 ? '>900' : condN.toFixed(1);
      }
