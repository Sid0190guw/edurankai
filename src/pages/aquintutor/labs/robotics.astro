    function propagate(i) {
      // update costs of descendants after a rewire (bounded sweep)
      for (var pass = 0; pass < 2; pass++) {
        for (var j = 0; j < nodes.length; j++) {
          var p = nodes[j].parent;
          if (p >= 0) nodes[j].cost = nodes[p].cost + dist(nodes[j], nodes[p]);
