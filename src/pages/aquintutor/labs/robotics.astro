      integ = clamp(integ, -200, 200);                 // anti-windup
      var deriv = (e - prevErr) / dt;
      prevErr = e;
      var u = Kp * e + Ki * integ + Kd * deriv;
      u = clamp(u, -800, 800);
      // m a = u - c v
      var a = (u - drag * v) / mass;
      v += a * dt;
      x += v * dt;
      simT += dt;
      // metrics relative to last step
      var span = setpoint;
      if (Math.abs(span) > 1) {
        var over = (x - setpoint) / Math.abs(span) * 100 * (span >= 0 ? 1 : -1);
        if (over > peak) peak = over;
        if (settleT < 0 && Math.abs(e) < Math.abs(span) * 0.02 && simT > 0.3) settleT = simT - lastStepT;
        if (Math.abs(e) >= Math.abs(span) * 0.02) settleT = -1; // reset if it leaves band
      }
      hist.push({ t: simT, x: x, sp: setpoint });
      if (hist.length > maxHist) hist.shift();
    }

    function drawPlot() {
      ctx.fillStyle = '#08080b'; ctx.fillRect(0, 0, W, H);
      var pad = 34;
      var yMin = -100, yMax = 100;
      function sy(val) { return H - pad - (val - yMin) / (yMax - yMin) * (H - 2 * pad); }
      // axes
      ctx.strokeStyle = '#232330'; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(pad, sy(0)); ctx.lineTo(W - 6, sy(0)); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(pad, pad - 10); ctx.lineTo(pad, H - pad + 10); ctx.stroke();
      // gridlines + labels
      ctx.fillStyle = '#5a5a68'; ctx.font = '9px Geist Mono, monospace';
      for (var gv = -100; gv <= 100; gv += 50) {
        var yy = sy(gv);
        ctx.strokeStyle = '#15151d'; ctx.beginPath(); ctx.moveTo(pad, yy); ctx.lineTo(W - 6, yy); ctx.stroke();
        ctx.fillStyle = '#5a5a68'; ctx.fillText(gv.toString(), 4, yy + 3);
      }
      if (hist.length < 2) return;
      var n = hist.length;
      function px(i) { return pad + i / (maxHist - 1) * (W - pad - 6); }
      // setpoint line
      ctx.strokeStyle = '#fbbf24'; ctx.lineWidth = 1.5; ctx.setLineDash([5, 4]);
      ctx.beginPath();
      for (var i = 0; i < n; i++) { var X = px(i), Y = sy(hist[i].sp); if (i === 0) ctx.moveTo(X, Y); else ctx.lineTo(X, Y); }
      ctx.stroke(); ctx.setLineDash([]);
      // response curve
      ctx.strokeStyle = '#67e8f9'; ctx.lineWidth = 2; ctx.beginPath();
      for (var j = 0; j < n; j++) { var X2 = px(j), Y2 = sy(hist[j].x); if (j === 0) ctx.moveTo(X2, Y2); else ctx.lineTo(X2, Y2); }
      ctx.stroke();
      // settling band around current setpoint
      ctx.fillStyle = 'rgba(134,239,172,0.07)';
      var band = Math.abs(setpoint) * 0.02;
      ctx.fillRect(pad, sy(setpoint + band), W - pad - 6, sy(setpoint - band) - sy(setpoint + band));
      // legend
      ctx.fillStyle = '#67e8f9'; ctx.fillText('position x(t)', pad + 6, pad - 2);
      ctx.fillStyle = '#fbbf24'; ctx.fillText('setpoint', pad + 110, pad - 2);
    }

    function drawTrack() {
      tctx.fillStyle = '#08080b'; tctx.fillRect(0, 0, TW, TH);
      var midY = TH / 2;
      var cx = TW / 2;
      var scale = (TW / 2 - 50) / 100;          // map +-100 to track
      // rail
      tctx.strokeStyle = '#232330'; tctx.lineWidth = 2;
      tctx.beginPath(); tctx.moveTo(30, midY + 16); tctx.lineTo(TW - 30, midY + 16); tctx.stroke();
      // setpoint marker
      var spX = cx + setpoint * scale;
      tctx.strokeStyle = '#fbbf24'; tctx.lineWidth = 1.5; tctx.setLineDash([4, 3]);
      tctx.beginPath(); tctx.moveTo(spX, midY - 24); tctx.lineTo(spX, midY + 20); tctx.stroke(); tctx.setLineDash([]);
      tctx.fillStyle = '#fbbf24'; tctx.font = '9px Geist Mono, monospace'; tctx.fillText('set', spX - 8, midY - 28);
      // cart
      var cartX = cx + x * scale;
      cartX = clamp(cartX, 36, TW - 36);
      tctx.fillStyle = '#a78bfa';
      tctx.fillRect(cartX - 22, midY - 8, 44, 22);
      tctx.fillStyle = '#16091f';
      tctx.beginPath(); tctx.arc(cartX - 12, midY + 14, 5, 0, TAU); tctx.fill();
      tctx.beginPath(); tctx.arc(cartX + 12, midY + 14, 5, 0, TAU); tctx.fill();
      // origin tick
      tctx.strokeStyle = '#3a3a48'; tctx.beginPath(); tctx.moveTo(cx, midY + 12); tctx.lineTo(cx, midY + 20); tctx.stroke();
    }

    function loop(ts) {
      if (!lastFrame) lastFrame = ts;
      var dt = Math.min(0.04, (ts - lastFrame) / 1000); lastFrame = ts;
      // run a few fixed sub-steps for stability
      var sub = 3, h = dt / sub;
      for (var s = 0; s < sub; s++) physics(h);
      drawPlot(); drawTrack();
      $('pidPos').textContent = x.toFixed(1);
      $('pidErr').textContent = (setpoint - x).toFixed(1);
      $('pidOver').textContent = (peak > 0 ? peak.toFixed(0) : '0') + '%';
      $('pidSettle').textContent = settleT >= 0 ? settleT.toFixed(1) + 's' : '--';
      requestAnimationFrame(loop);
    }

    var sliders = [['pKp', 'pKpv', 1], ['pKi', 'pKiv', 1], ['pKd', 'pKdv', 1], ['pSet', 'pSetv', 0], ['pMass', 'pMassv', 1]];
    for (var si = 0; si < sliders.length; si++) {
      (function (id, vid, dp) {
        $(id).addEventListener('input', function () {
          $(vid).textContent = (+$(id).value).toFixed(dp);
          if (id === 'pSet') { peak = 0; settleT = -1; lastStepT = simT; }
        });
      })(sliders[si][0], sliders[si][1], sliders[si][2]);
    }
    $('pidStep').addEventListener('click', function () {
      var cur = +$('pSet').value;
      var next = cur > 0 ? -55 : 55;
      $('pSet').value = next; $('pSetv').textContent = next.toFixed(0);
      peak = 0; settleT = -1; lastStepT = simT;
    });
    $('pidReset').addEventListener('click', reset);

    requestAnimationFrame(loop);
  })();

})();
</script>
</BaseLayout>
