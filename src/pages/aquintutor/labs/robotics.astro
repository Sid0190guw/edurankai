        ctx.fillStyle = '#a78bfa'; ctx.beginPath(); ctx.arc(rxp, ryp, ROBOT_R, 0, TAU); ctx.fill();
        ctx.strokeStyle = '#e8e8ee'; ctx.lineWidth = 1.5; ctx.stroke();
