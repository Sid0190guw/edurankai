    }

    function buildPath() {
      if (bestGoalNode < 0) return [];
      var p = [{ x: goal.x, y: goal.y }];
      var cur = bestGoalNode, guard = 0;
      while (cur !== -1 && guard < nodes.length + 2) { p.push({ x: nodes[cur].x, y: nodes[cur].y }); cur = nodes[cur].parent; guard++; }
      p.reverse();
      return p;
    }

    function draw() {
      ctx.fillStyle = '#08080b'; ctx.fillRect(0, 0, W, H);
      ctx.strokeStyle = '#15151d'; ctx.lineWidth = 1;
      for (var gx = 0; gx <= W; gx += 40) { ctx.beginPath(); ctx.moveTo(gx, 0); ctx.lineTo(gx, H); ctx.stroke(); }
      for (var gy = 0; gy <= H; gy += 40) { ctx.beginPath(); ctx.moveTo(0, gy); ctx.lineTo(W, gy); ctx.stroke(); }
      for (var o = 0; o < obstacles.length; o++) {
        var ob = obstacles[o];
        ctx.fillStyle = 'rgba(252,165,165,0.13)'; ctx.beginPath(); ctx.arc(ob.x, ob.y, ob.r, 0, TAU); ctx.fill();
        ctx.strokeStyle = '#fca5a5'; ctx.lineWidth = 1.5; ctx.beginPath(); ctx.arc(ob.x, ob.y, ob.r, 0, TAU); ctx.stroke();
