        for (var s = 0; s < rate; s++) extend();
        $('rrtN').textContent = nodes.length;
        $('rrtRw').textContent = rewires;
        if (bestGoalNode >= 0) { $('rrtCost').textContent = bestCost.toFixed(0); $('rrtStat').textContent = 'path found'; $('rrtState').textContent = 'refining'; }
        else { $('rrtStat').textContent = 'searching'; }
