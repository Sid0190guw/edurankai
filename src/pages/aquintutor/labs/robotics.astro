      requestAnimationFrame(loop);
    }

    $('rEta').addEventListener('input', function () { $('rEtav').textContent = this.value; });
    $('rBias').addEventListener('input', function () { $('rBiasv').textContent = this.value + '%'; });
    $('rRate').addEventListener('input', function () { $('rRatev').textContent = this.value + '/f'; });
    $('rrtGrow').addEventListener('click', function () { growing = !growing; this.textContent = growing ? 'Pause' : 'Grow tree'; if (growing) $('rrtState').textContent = 'growing'; });
