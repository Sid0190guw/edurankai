        e: 'Three joints for a 2-DOF task gives a one-parameter null space, so infinitely many joint solutions reach a point.' }
    ],
    '10': [
      { q: 'What does RRT* add over plain RRT to achieve asymptotic optimality?',
        o: ['A bigger step size only', 'Choose-best-parent and rewire over a neighbourhood', 'Goal biasing only', 'A grid instead of samples'], a: 1,
        e: 'Re-parenting x_new to the cheapest neighbour and rewiring nearby nodes lets the path cost converge to the optimum.' },
      { q: 'The steer step x_new = x_near + eta*(x_rand - x_near)/|...| exists mainly to:',
        o: ['Reach the goal in one jump', 'Limit each extension to a fixed length eta', 'Skip collision checking', 'Randomise the goal'], a: 1,
        e: 'Steering caps growth to a controlled step eta toward the sample, keeping edges short and checkable.' },
      { q: 'Increasing the goal-bias probability tends to:',
        o: ['Explore the whole space more evenly', 'Pull the tree toward the goal faster (greedier)', 'Guarantee the shortest path immediately', 'Disable rewiring'], a: 1,
        e: 'Sampling the goal more often grows the tree toward it sooner, at some cost to uniform exploration.' },
      { q: 'In RRT* the cost(n) stored at a node is:',
        o: ['Its straight-line distance to the goal', 'The path length from the root along the tree', 'The number of obstacles nearby', 'A random priority'], a: 1,
        e: 'cost(n) is the accumulated edge length from the start root, which choose-parent and rewire minimise.' }
    ],
    '11': [
      { q: 'In the EKF, the predict step does what to the covariance P?',
        o: ['Shrinks it', 'Grows it via P <- F P F^T + Q', 'Leaves it unchanged', 'Sets it to zero'], a: 1,
        e: 'Propagating the motion model with process noise Q increases uncertainty between observations.' },
      { q: 'Why is it the EXTENDED Kalman filter rather than the plain Kalman filter here?',
        o: ['It uses more landmarks', 'The motion and range-bearing models are nonlinear, so they are linearised by Jacobians', 'It runs faster', 'It ignores noise'], a: 1,
        e: 'EKF linearises nonlinear g(x,u) and h(x) about the current mean using Jacobians F and H.' },
      { q: 'The Kalman gain K = P H^T (H P H^T + R)^-1 is large when:',
        o: ['Sensor noise R is large', 'State uncertainty P is large relative to sensor noise R', 'P is zero', 'There are no landmarks'], a: 1,
        e: 'High prior uncertainty and low measurement noise make the filter trust the observation more (large K).' },
      { q: 'The bearing innovation z - h must be wrapped to [-pi, pi] because:',
        o: ['Range can be negative', 'Angles are circular, so a raw difference can be off by 2*pi', 'P would become negative', 'It speeds up the matrix inverse'], a: 1,
        e: 'Without wrapping, e.g. +179 deg vs -179 deg gives a huge spurious innovation; wrapping picks the short angular error.' }
    ]
  };

  function buildQuiz(el) {
    var key = el.getAttribute('data-quiz');
    var qs = QUIZZES[key];
    if (!qs) return;
    var labels = ['A', 'B', 'C', 'D'];
    for (var i = 0; i < qs.length; i++) {
      (function (item, qi) {
        var card = document.createElement('div'); card.className = 'q';
        var qt = document.createElement('div'); qt.className = 'qt';
        qt.innerHTML = '<b>Q' + (qi + 1) + '.</b> ' + item.q;
        card.appendChild(qt);
        var chosen = { v: -1 };
        var optEls = [];
        for (var j = 0; j < item.o.length; j++) {
          (function (oi) {
            var oa = document.createElement('div'); oa.className = 'opt-a';
            oa.textContent = labels[oi] + '.  ' + item.o[oi];
            oa.addEventListener('click', function () {
              for (var m = 0; m < optEls.length; m++) optEls[m].classList.remove('sel', 'correct', 'wrong');
              card.classList.remove('bad');
              expl.classList.remove('show');
              oa.classList.add('sel'); chosen.v = oi;
            });
            optEls.push(oa); card.appendChild(oa);
          })(j);
        }
        var btn = document.createElement('button'); btn.className = 'btn'; btn.style.marginTop = '4px';
        btn.textContent = 'Check answer';
        var expl = document.createElement('div'); expl.className = 'expl';
        btn.addEventListener('click', function () {
          if (chosen.v < 0) { expl.innerHTML = '<b>Select an option first.</b>'; expl.classList.add('show'); card.classList.add('bad'); return; }
          for (var m = 0; m < optEls.length; m++) optEls[m].classList.remove('correct', 'wrong', 'sel');
          optEls[item.a].classList.add('correct');
          var ok = chosen.v === item.a;
          if (!ok) optEls[chosen.v].classList.add('wrong');
          card.classList.toggle('bad', !ok);
          expl.innerHTML = '<b>' + (ok ? 'Correct.' : 'Not quite.') + '</b> ' + item.e;
          expl.classList.add('show');
        });
        card.appendChild(btn);
        card.appendChild(expl);
        el.appendChild(card);
      })(qs[i], i);
    }
  }
  var quizEls = document.querySelectorAll('.rbx .quiz');
  for (var qz = 0; qz < quizEls.length; qz++) buildQuiz(quizEls[qz]);

  // ===================================================================
  // SHARED — planar arm engine (used by Exp.1 FK and Exp.2 IK)
  // ===================================================================
  function makeArm(opts) {
    var cv = $(opts.cv), ctx = cv.getContext('2d');
    var W = cv.width, H = cv.height;
    var ox = W / 2, oy = H * 0.62;        // base origin (screen px)
    var L1 = 150, L2 = 120, L3 = 60;      // link lengths (px)
    var nLinks = opts.nLinks || 2, elbow = 1;
    var th = [35 * Math.PI / 180, 60 * Math.PI / 180, -30 * Math.PI / 180];
    var target = null;                    // {x,y} in world coords (y up)
    var goal = null;                      // target joint angles for animation
    var api = {};

    function reach() { return nLinks === 3 ? L1 + L2 + L3 : L1 + L2; }

    function fk(angles) {
      var pts = [{ x: 0, y: 0 }];
      var a = 0, x = 0, y = 0;
      var Ls = [L1, L2, L3];
      var n = nLinks;
      for (var i = 0; i < n; i++) {
        a += angles[i];
        x += Ls[i] * Math.cos(a);
        y += Ls[i] * Math.sin(a);
        pts.push({ x: x, y: y });
      }
      return pts;
    }

    function ik(tx, ty) {
      var wx = tx, wy = ty;
      if (nLinks === 3) {
        var ang = Math.atan2(ty, tx);
        wx = tx - L3 * Math.cos(ang);
        wy = ty - L3 * Math.sin(ang);
      }
      var d2 = wx * wx + wy * wy;
      var c2 = (d2 - L1 * L1 - L2 * L2) / (2 * L1 * L2);
      if (c2 < -1 || c2 > 1) return null;
      var s2 = elbow * Math.sqrt(Math.max(0, 1 - c2 * c2));
      var t2 = Math.atan2(s2, c2);
      var t1 = Math.atan2(wy, wx) - Math.atan2(L2 * s2, L1 + L2 * c2);
      var res = [t1, t2];
      if (nLinks === 3) {
        var endAng = Math.atan2(ty, tx);
        res.push(wrap(endAng - t1 - t2));
      }
      return res;
    }

    function w2s(p) { return { x: ox + p.x, y: oy - p.y }; }
    function s2w(sx, sy) { return { x: sx - ox, y: oy - sy }; }

    function draw() {
      ctx.fillStyle = '#08080b'; ctx.fillRect(0, 0, W, H);
      ctx.strokeStyle = 'rgba(167,139,250,0.16)';
      ctx.setLineDash([4, 5]); ctx.lineWidth = 1;
      ctx.beginPath(); ctx.arc(ox, oy, reach(), 0, TAU); ctx.stroke();
      var inner = nLinks === 3 ? Math.max(0, L1 - L2 - L3) : Math.abs(L1 - L2);
      if (inner > 2) { ctx.beginPath(); ctx.arc(ox, oy, inner, 0, TAU); ctx.stroke(); }
      ctx.setLineDash([]);
      ctx.strokeStyle = '#232330'; ctx.beginPath(); ctx.moveTo(0, oy); ctx.lineTo(W, oy); ctx.stroke();

      var pts = fk(th);
      var cols = ['#67e8f9', '#a78bfa', '#fbbf24'];
      for (var i = 0; i < pts.length - 1; i++) {
        var a = w2s(pts[i]), b = w2s(pts[i + 1]);
        ctx.strokeStyle = cols[i]; ctx.lineWidth = 9; ctx.lineCap = 'round';
        ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.stroke();
      }
      for (var j = 0; j < pts.length; j++) {
        var sp = w2s(pts[j]);
        ctx.fillStyle = j === 0 ? '#444' : '#0a0a0c';
        ctx.strokeStyle = '#e8e8ee'; ctx.lineWidth = 2;
        ctx.beginPath(); ctx.arc(sp.x, sp.y, j === 0 ? 9 : 6, 0, TAU); ctx.fill(); ctx.stroke();
      }
      var ee = pts[pts.length - 1], se = w2s(ee);
      ctx.fillStyle = '#86efac';
      ctx.beginPath(); ctx.arc(se.x, se.y, 5, 0, TAU); ctx.fill();
      ctx.fillStyle = '#86efac'; ctx.font = '11px Geist Mono, monospace';
      ctx.fillText('(' + ee.x.toFixed(0) + ', ' + ee.y.toFixed(0) + ')', se.x + 9, se.y - 8);
      if (target) {
        var st = w2s(target);
        ctx.strokeStyle = '#fca5a5'; ctx.lineWidth = 1.5;
        ctx.beginPath(); ctx.arc(st.x, st.y, 9, 0, TAU); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(st.x - 13, st.y); ctx.lineTo(st.x + 13, st.y);
        ctx.moveTo(st.x, st.y - 13); ctx.lineTo(st.x, st.y + 13); ctx.stroke();
      }
      ctx.fillStyle = '#2a2a35';
      ctx.fillRect(ox - 18, oy, 36, 14);
      if (opts.onDraw) opts.onDraw(ee, pts, target, reach());
    }
    api.draw = draw;

    function loop() {
      if (goal) {
        var done = true;
        for (var i = 0; i < nLinks; i++) {
          var diff = wrap(goal[i] - th[i]);
          if (Math.abs(diff) > 0.004) { th[i] += diff * 0.16; done = false; }
          else th[i] = goal[i];
        }
        if (opts.onSync) opts.onSync(th);
        if (done) goal = null;
      }
      draw();
      requestAnimationFrame(loop);
    }

    api.setAngles = function (a1, a2, a3) {
      goal = null;
      th[0] = a1; th[1] = a2;
      if (a3 !== undefined) th[2] = a3;
    };
    api.setElbow = function (e) { elbow = e; if (target) { var so = ik(target.x, target.y); if (so) goal = so; } };
    api.setLinks = function (n) { nLinks = n; if (target) { var so = ik(target.x, target.y); if (so) goal = so; } };
    api.home = function () { target = null; goal = null; th = [35 * Math.PI / 180, 60 * Math.PI / 180, -30 * Math.PI / 180]; };
    api.getAngles = function () { return th; };
    api.getTarget = function () { return target; };
    api.solveLast = function () { if (target) { var so = ik(target.x, target.y); if (so) goal = so; } };

    cv.addEventListener('click', function (ev) {
      if (!opts.clickIK) return;
      var r = cv.getBoundingClientRect();
      var sx = (ev.clientX - r.left) * (W / r.width);
      var sy = (ev.clientY - r.top) * (H / r.height);
      var wp = s2w(sx, sy);
      target = wp;
      var sol = ik(wp.x, wp.y);
      if (sol) { goal = sol; if (opts.onSolve) opts.onSolve(sol, true); }
      else if (opts.onSolve) opts.onSolve(null, false);
      draw();
    });

    loop();
    return api;
  }

