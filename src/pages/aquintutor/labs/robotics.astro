---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Robotics & AI · Virtual Labs · AquinTutor" description="Robot-arm forward/inverse kinematics, mobile-robot path planning, and PID control — live.">
<style>
  .rbx { background:#0a0a0c; color:#e8e8ee; min-height:100vh; font-family:'Geist Mono',ui-monospace,monospace; }
  .rbx .wrap { max-width:1180px; margin:0 auto; padding:36px 22px 90px; }
  .rbx .back { display:inline-flex; align-items:center; gap:7px; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:#9aa0aa; text-decoration:none; margin-bottom:26px; }
  .rbx .back:hover { color:#67e8f9; }
  .rbx .eyebrow { font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin-bottom:12px; }
  .rbx h1 { font-family:'Cormorant Garamond',serif; font-size:40px; font-weight:600; letter-spacing:-0.02em; line-height:1.1; margin:0 0 12px; color:#f3f3f8; }
  .rbx h1 em { color:#a78bfa; font-style:italic; }
  .rbx .lede { color:#9aa0aa; max-width:760px; font-size:13.5px; line-height:1.65; margin-bottom:26px; }
  .rbx .tabs { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:22px; border-bottom:1px solid #2a2a35; padding-bottom:14px; }
  .rbx .tab { background:#11131a; border:1px solid #2a2a35; color:#9aa0aa; padding:9px 14px; border-radius:9px; font-size:11px; letter-spacing:0.08em; text-transform:uppercase; font-weight:700; cursor:pointer; transition:all .15s; }
  .rbx .tab:hover { border-color:#3a3a48; color:#e8e8ee; }
  .rbx .tab.on { background:#161922; border-color:#a78bfa; color:#a78bfa; }
  .rbx .pane { display:none; }
  .rbx .pane.on { display:block; }
  .rbx .layout { display:grid; grid-template-columns:minmax(0,1fr) 320px; gap:18px; align-items:start; }
  @media (max-width:920px) { .rbx .layout { grid-template-columns:1fr; } }
  .rbx .panel { background:#11131a; border:1px solid #2a2a35; border-radius:12px; padding:16px; }
  .rbx .panel h3 { font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin:0 0 13px; }
  .rbx canvas { display:block; width:100%; background:#08080b; border:1px solid #232330; border-radius:10px; }
  .rbx .row { display:flex; gap:9px; align-items:center; margin-bottom:11px; flex-wrap:wrap; }
  .rbx .row > label { font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:#9aa0aa; min-width:64px; }
  .rbx input[type=range] { -webkit-appearance:none; appearance:none; background:#0a0a0c; border:1px solid #2a2a35; height:6px; border-radius:4px; flex:1; min-width:90px; }
  .rbx input[type=range]::-webkit-slider-thumb { -webkit-appearance:none; appearance:none; width:14px; height:14px; border-radius:50%; background:#a78bfa; cursor:pointer; border:none; }
  .rbx input[type=range]::-moz-range-thumb { width:14px; height:14px; border-radius:50%; background:#a78bfa; cursor:pointer; border:none; }
  .rbx select { background:#0a0a0c; border:1px solid #2a2a35; color:#e8e8ee; padding:7px 9px; border-radius:6px; font-family:inherit; font-size:11.5px; flex:1; }
  .rbx .val { font-size:11.5px; color:#a78bfa; min-width:52px; text-align:right; }
  .rbx .btn { background:#a78bfa; color:#16091f; padding:9px 13px; border:none; border-radius:7px; font-family:inherit; font-size:10.5px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; cursor:pointer; }
  .rbx .btn:hover { background:#bda3ff; }
  .rbx .btn.ghost { background:transparent; color:#cfd6da; border:1px solid #2a2a35; }
  .rbx .btn.ghost:hover { border-color:#a78bfa; color:#a78bfa; }
  .rbx .btn.cyan { background:#67e8f9; color:#04161b; }
  .rbx .btn.cyan:hover { background:#8af0ff; }
  .rbx .btns { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:6px; }
  .rbx .btns .full { grid-column:1/-1; }
  .rbx .stats { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:13px; }
  .rbx .stat { background:#0a0a0c; border:1px solid #232330; border-radius:7px; padding:8px 10px; }
  .rbx .stat .k { font-size:9px; letter-spacing:0.12em; text-transform:uppercase; color:#9aa0aa; }
  .rbx .stat .v { font-size:17px; color:#67e8f9; font-weight:700; margin-top:3px; }
  .rbx .help { font-size:10.5px; color:#9aa0aa; line-height:1.65; margin-top:11px; }
  .rbx .help b { color:#e8e8ee; }
  .rbx .help code { color:#fbbf24; background:#0a0a0c; padding:1px 5px; border-radius:3px; }
  .rbx .badge { display:inline-block; font-size:9px; padding:2px 7px; border-radius:4px; background:#1a1a25; color:#86efac; letter-spacing:0.1em; margin-left:6px; }
  .rbx .seg { display:flex; gap:6px; }
  .rbx .seg .opt { flex:1; text-align:center; background:#0a0a0c; border:1px solid #2a2a35; color:#9aa0aa; padding:7px 0; border-radius:6px; font-size:10px; letter-spacing:0.08em; text-transform:uppercase; cursor:pointer; }
  .rbx .seg .opt.on { border-color:#fbbf24; color:#fbbf24; }
</style>
<main class="rbx">
  <div class="wrap">
    <a class="back" href="/aquintutor/labs">&#8592; All virtual labs</a>
    <div class="eyebrow">Robotics &amp; AI &middot; Interactive lab</div>
    <h1>Robot kinematics, planning &amp; <em>control</em></h1>
    <p class="lede">Four working experiments — solved live in your browser with hand-rolled math, no libraries. Drive a 2-link arm with forward &amp; closed-form inverse kinematics, steer a differential-drive robot through obstacles, plan with A* on an editable grid, and tune a PID loop watching overshoot and settling change in real time.</p>

    <div class="tabs">
      <button class="tab on" data-tab="arm">1 &middot; Arm kinematics</button>
      <button class="tab" data-tab="mobile">2 &middot; Mobile robot</button>
      <button class="tab" data-tab="plan">3 &middot; Path planning</button>
      <button class="tab" data-tab="pid">4 &middot; PID control</button>
    </div>

    <!-- TAB 1: ARM -->
    <section class="pane on" id="pane-arm">
      <div class="layout">
        <div class="panel">
          <h3>Planar arm <span class="badge" id="armReach">in reach</span></h3>
          <canvas id="armCv" width="640" height="520"></canvas>
          <div class="help"><b>Forward kinematics:</b> drag the angle sliders. <b>Inverse:</b> click anywhere in the workspace to set a target — the arm solves its joint angles analytically (law of cosines) and animates to it.</div>
        </div>
        <div>
          <div class="panel">
            <h3>Configuration</h3>
            <div class="row"><label>Links</label>
              <div class="seg" style="flex:1" id="armLinks">
                <div class="opt on" data-n="2">2-link</div>
                <div class="opt" data-n="3">3-link</div>
              </div>
            </div>
            <div class="row"><label>&#952;&#8321;</label><input type="range" id="a1" min="-180" max="180" value="35"><span class="val" id="a1v">35&deg;</span></div>
            <div class="row"><label>&#952;&#8322;</label><input type="range" id="a2" min="-180" max="180" value="60"><span class="val" id="a2v">60&deg;</span></div>
            <div class="row" id="a3row"><label>&#952;&#8323;</label><input type="range" id="a3" min="-180" max="180" value="-30"><span class="val" id="a3v">-30&deg;</span></div>
            <div class="row"><label>Elbow</label>
              <div class="seg" style="flex:1" id="armElbow">
                <div class="opt on" data-e="1">Up</div>
                <div class="opt" data-e="-1">Down</div>
              </div>
            </div>
            <div class="btns">
              <button class="btn ghost full" id="armHome">Reset to home</button>
            </div>
            <div class="stats">
              <div class="stat"><div class="k">End-effector X</div><div class="v" id="armX">0</div></div>
              <div class="stat"><div class="k">End-effector Y</div><div class="v" id="armY">0</div></div>
              <div class="stat"><div class="k">Reach used</div><div class="v" id="armUse">0%</div></div>
              <div class="stat"><div class="k">Target dist</div><div class="v" id="armTd">--</div></div>
            </div>
          </div>
          <div class="panel" style="margin-top:13px;">
            <h3>The math</h3>
            <div class="help">FK: <code>x = L1 c1 + L2 c12</code>, <code>y = L1 s1 + L2 s12</code>. IK (2-link): <code>cos&#952;2 = (x&sup2;+y&sup2;-L1&sup2;-L2&sup2;)/(2 L1 L2)</code>, then <code>&#952;1 = atan2(y,x) - atan2(L2 s2, L1+L2 c2)</code>. The 3rd link, if present, holds a fixed wrist offset.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- TAB 2: MOBILE -->
    <section class="pane" id="pane-mobile">
      <div class="layout">
        <div class="panel">
          <h3>Differential-drive field <span class="badge" id="mobState">idle</span></h3>
          <canvas id="mobCv" width="640" height="520"></canvas>
          <div class="help"><b>Click</b> to drop a waypoint goal. The robot follows a proportional heading + speed controller integrating the unicycle model <code>x'=v cos&#952;, y'=v sin&#952;, &#952;'=&#969;</code>, and steers around obstacles with a repulsive potential field.</div>
        </div>
        <div>
          <div class="panel">
            <h3>Controller gains</h3>
            <div class="row"><label>K&#969; (head)</label><input type="range" id="mKw" min="0" max="8" step="0.1" value="3.5"><span class="val" id="mKwv">3.5</span></div>
            <div class="row"><label>K&#7515; (speed)</label><input type="range" id="mKv" min="0" max="3" step="0.05" value="1.2"><span class="val" id="mKvv">1.2</span></div>
            <div class="row"><label>Max v</label><input type="range" id="mVmax" min="30" max="180" step="5" value="110"><span class="val" id="mVmaxv">110</span></div>
            <div class="row"><label>Avoid</label><input type="range" id="mAvoid" min="0" max="3" step="0.1" value="1.4"><span class="val" id="mAvoidv">1.4</span></div>
            <div class="btns">
              <button class="btn cyan" id="mobObst">Add obstacle</button>
              <button class="btn ghost" id="mobClear">Clear path</button>
              <button class="btn ghost full" id="mobReset">Reset robot</button>
            </div>
            <div class="stats">
              <div class="stat"><div class="k">Speed v</div><div class="v" id="mobV">0</div></div>
              <div class="stat"><div class="k">&#969; rad/s</div><div class="v" id="mobW">0</div></div>
              <div class="stat"><div class="k">Heading</div><div class="v" id="mobTh">0&deg;</div></div>
              <div class="stat"><div class="k">Goal dist</div><div class="v" id="mobD">--</div></div>
            </div>
          </div>
          <div class="panel" style="margin-top:13px;">
            <h3>How it steers</h3>
            <div class="help">Heading error <code>e&#952; = atan2(dy,dx) - &#952;</code> wrapped to [-&#960;,&#960;]; <code>&#969; = K&#969; &middot; e&#952;</code>. Forward speed scales with distance and de-rates when steering hard. Each obstacle adds a <code>1/d&sup2;</code> repulsive push that bends the goal vector.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- TAB 3: PLANNING -->
    <section class="pane" id="pane-plan">
      <div class="layout">
        <div class="panel">
          <h3>A* grid <span class="badge" id="planState">edit walls</span></h3>
          <canvas id="planCv" width="640" height="520"></canvas>
          <div class="help"><b>Drag</b> to paint walls, <b>shift+click</b> sets start, <b>ctrl+click</b> sets goal. Run A* to watch the frontier expand, then the robot drives the shortest path it found.</div>
        </div>
        <div>
          <div class="panel">
            <h3>Planner</h3>
            <div class="row"><label>Heuristic</label>
              <select id="planH">
                <option value="manhattan">Manhattan (4-dir)</option>
                <option value="octile" selected>Octile (8-dir)</option>
                <option value="euclid">Euclidean (8-dir)</option>
              </select>
            </div>
            <div class="row"><label>Speed</label><input type="range" id="planSpeed" min="1" max="60" value="14"><span class="val" id="planSpeedv">14ms</span></div>
            <div class="btns">
              <button class="btn" id="planRun">Plan &amp; drive</button>
              <button class="btn ghost" id="planClear">Clear walls</button>
              <button class="btn ghost full" id="planReset">Reset overlay</button>
            </div>
            <div class="stats">
              <div class="stat"><div class="k">Expanded</div><div class="v" id="planExp">0</div></div>
              <div class="stat"><div class="k">Frontier</div><div class="v" id="planFr">0</div></div>
              <div class="stat"><div class="k">Path cells</div><div class="v" id="planLen">0</div></div>
              <div class="stat"><div class="k">Path cost</div><div class="v" id="planCost">0</div></div>
            </div>
          </div>
          <div class="panel" style="margin-top:13px;">
            <h3>A* notes</h3>
            <div class="help">Expands the open node with smallest <code>f = g + h</code>, where <code>g</code> is true cost-so-far and <code>h</code> an admissible estimate. Octile distance is the exact shortest 8-connected metric, so it is admissible and yields optimal diagonal paths.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- TAB 4: PID -->
    <section class="pane" id="pane-pid">
      <div class="layout">
        <div class="panel">
          <h3>Response &mdash; mass-cart to setpoint <span class="badge" id="pidState">running</span></h3>
          <canvas id="pidCv" width="640" height="360"></canvas>
          <canvas id="pidTrack" width="640" height="120" style="margin-top:10px;"></canvas>
          <div class="help">A unit mass with drag is driven by a PID force toward the setpoint. The curve is real-time integrated position; the lower strip shows the cart physically chasing the setpoint marker.</div>
        </div>
        <div>
          <div class="panel">
            <h3>Gains &amp; setpoint</h3>
            <div class="row"><label>Kp</label><input type="range" id="pKp" min="0" max="40" step="0.5" value="12"><span class="val" id="pKpv">12</span></div>
            <div class="row"><label>Ki</label><input type="range" id="pKi" min="0" max="12" step="0.1" value="2.0"><span class="val" id="pKiv">2.0</span></div>
            <div class="row"><label>Kd</label><input type="range" id="pKd" min="0" max="20" step="0.1" value="6.0"><span class="val" id="pKdv">6.0</span></div>
            <div class="row"><label>Setpoint</label><input type="range" id="pSet" min="-90" max="90" step="1" value="55"><span class="val" id="pSetv">55</span></div>
            <div class="row"><label>Mass</label><input type="range" id="pMass" min="0.4" max="4" step="0.1" value="1.0"><span class="val" id="pMassv">1.0</span></div>
            <div class="btns">
              <button class="btn ghost" id="pidStep">Step setpoint</button>
              <button class="btn ghost" id="pidReset">Reset</button>
            </div>
            <div class="stats">
              <div class="stat"><div class="k">Position</div><div class="v" id="pidPos">0</div></div>
              <div class="stat"><div class="k">Error</div><div class="v" id="pidErr">0</div></div>
              <div class="stat"><div class="k">Overshoot</div><div class="v" id="pidOver">0%</div></div>
              <div class="stat"><div class="k">Settle t</div><div class="v" id="pidSettle">--</div></div>
            </div>
          </div>
          <div class="panel" style="margin-top:13px;">
            <h3>Control law</h3>
            <div class="help"><code>u = Kp&middot;e + Ki&#8747;e dt + Kd&middot;de/dt</code>, with <code>e = setpoint - x</code>. Plant: <code>m&middot;a = u - c&middot;v</code>. Push Kp high for fast rise but watch overshoot; add Kd to damp it; trim steady-state offset with Ki.</div>
          </div>
        </div>
      </div>
    </section>
  </div>
</main>

<script is:inline>
(function () {
  'use strict';
  var TAU = Math.PI * 2;
  function clamp(v, a, b) { return v < a ? a : (v > b ? b : v); }
  function wrap(a) { while (a > Math.PI) a -= TAU; while (a < -Math.PI) a += TAU; return a; }
  function $(id) { return document.getElementById(id); }

  // ---------- TAB SWITCHING ----------
  var tabs = document.querySelectorAll('.rbx .tab');
  for (var t = 0; t < tabs.length; t++) {
    tabs[t].addEventListener('click', function () {
      var name = this.getAttribute('data-tab');
      var allT = document.querySelectorAll('.rbx .tab');
      for (var i = 0; i < allT.length; i++) allT[i].classList.remove('on');
      this.classList.add('on');
      var panes = document.querySelectorAll('.rbx .pane');
      for (var j = 0; j < panes.length; j++) panes[j].classList.remove('on');
      $('pane-' + name).classList.add('on');
    });
  }

  // ===================================================================
  // EXPERIMENT 1 — ROBOT ARM (FK + analytic IK)
  // ===================================================================
  (function arm() {
    var cv = $('armCv'), ctx = cv.getContext('2d');
    var W = cv.width, H = cv.height;
    var ox = W / 2, oy = H * 0.62;        // base origin (screen px)
    var L1 = 150, L2 = 120, L3 = 60;      // link lengths (px)
    var nLinks = 2, elbow = 1;
    // joint angles in radians
    var th = [35 * Math.PI / 180, 60 * Math.PI / 180, -30 * Math.PI / 180];
    var target = null;                    // {x,y} in world coords (y up)
    var goal = null;                      // target joint angles for animation
    var sliderDriven = true;

    function reach() { return nLinks === 3 ? L1 + L2 + L3 : L1 + L2; }

    // forward kinematics -> array of joint points in world coords (y up)
    function fk(angles) {
      var pts = [{ x: 0, y: 0 }];
      var a = 0, x = 0, y = 0;
      var Ls = [L1, L2, L3];
      var n = nLinks;
      for (var i = 0; i < n; i++) {
        a += angles[i];
        x += Ls[i] * Math.cos(a);
        y += Ls[i] * Math.sin(a);
        pts.push({ x: x, y: y });
      }
      return pts;
    }

    // analytic 2-link IK; for 3-link we fix wrist via theta3 and IK the first two to wrist point
    function ik(tx, ty) {
      var wx = tx, wy = ty, wristTh = th[2];
      if (nLinks === 3) {
        // place wrist so link3 points toward target from wrist; subtract L3 along target direction
        var ang = Math.atan2(ty, tx);
        wx = tx - L3 * Math.cos(ang);
        wy = ty - L3 * Math.sin(ang);
      }
      var d2 = wx * wx + wy * wy;
      var c2 = (d2 - L1 * L1 - L2 * L2) / (2 * L1 * L2);
      if (c2 < -1 || c2 > 1) return null;            // unreachable
      var s2 = elbow * Math.sqrt(Math.max(0, 1 - c2 * c2));
      var t2 = Math.atan2(s2, c2);
      var t1 = Math.atan2(wy, wx) - Math.atan2(L2 * s2, L1 + L2 * c2);
      var res = [t1, t2];
      if (nLinks === 3) {
        var endAng = Math.atan2(ty, tx);
        res.push(wrap(endAng - t1 - t2));            // wrist points at target
      }
      return res;
    }

    function w2s(p) { return { x: ox + p.x, y: oy - p.y }; }   // world(y up) -> screen
    function s2w(sx, sy) { return { x: sx - ox, y: oy - sy }; }

    function draw() {
      ctx.fillStyle = '#08080b'; ctx.fillRect(0, 0, W, H);
      // reach annulus
      ctx.strokeStyle = 'rgba(167,139,250,0.16)';
      ctx.setLineDash([4, 5]); ctx.lineWidth = 1;
      ctx.beginPath(); ctx.arc(ox, oy, reach(), 0, TAU); ctx.stroke();
      var inner = nLinks === 3 ? Math.max(0, L1 - L2 - L3) : Math.abs(L1 - L2);
      if (inner > 2) { ctx.beginPath(); ctx.arc(ox, oy, inner, 0, TAU); ctx.stroke(); }
      ctx.setLineDash([]);
      // ground line
      ctx.strokeStyle = '#232330'; ctx.beginPath(); ctx.moveTo(0, oy); ctx.lineTo(W, oy); ctx.stroke();

      var pts = fk(th);
      // links
      var cols = ['#67e8f9', '#a78bfa', '#fbbf24'];
      for (var i = 0; i < pts.length - 1; i++) {
        var a = w2s(pts[i]), b = w2s(pts[i + 1]);
        ctx.strokeStyle = cols[i]; ctx.lineWidth = 9; ctx.lineCap = 'round';
        ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.stroke();
      }
      // joints
      for (var j = 0; j < pts.length; j++) {
        var sp = w2s(pts[j]);
        ctx.fillStyle = j === 0 ? '#444' : '#0a0a0c';
        ctx.strokeStyle = '#e8e8ee'; ctx.lineWidth = 2;
        ctx.beginPath(); ctx.arc(sp.x, sp.y, j === 0 ? 9 : 6, 0, TAU); ctx.fill(); ctx.stroke();
      }
      // end-effector
      var ee = pts[pts.length - 1], se = w2s(ee);
      ctx.fillStyle = '#86efac';
      ctx.beginPath(); ctx.arc(se.x, se.y, 5, 0, TAU); ctx.fill();
      ctx.fillStyle = '#86efac'; ctx.font = '11px Geist Mono, monospace';
      ctx.fillText('(' + ee.x.toFixed(0) + ', ' + ee.y.toFixed(0) + ')', se.x + 9, se.y - 8);
      // target marker
      if (target) {
        var st = w2s(target);
        ctx.strokeStyle = '#fca5a5'; ctx.lineWidth = 1.5;
        ctx.beginPath(); ctx.arc(st.x, st.y, 9, 0, TAU); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(st.x - 13, st.y); ctx.lineTo(st.x + 13, st.y);
        ctx.moveTo(st.x, st.y - 13); ctx.lineTo(st.x, st.y + 13); ctx.stroke();
      }
      // base
      ctx.fillStyle = '#2a2a35';
      ctx.fillRect(ox - 18, oy, 36, 14);

      // stats
      $('armX').textContent = ee.x.toFixed(0);
      $('armY').textContent = ee.y.toFixed(0);
      var dist = Math.sqrt(ee.x * ee.x + ee.y * ee.y);
      $('armUse').textContent = (100 * dist / reach()).toFixed(0) + '%';
      if (target) {
        var td = Math.sqrt(target.x * target.x + target.y * target.y);
        $('armTd').textContent = td.toFixed(0);
        var rb = $('armReach');
        if (td > reach() + 0.5 || (nLinks === 2 && td < Math.abs(L1 - L2) - 0.5)) {
          rb.textContent = 'out of reach'; rb.style.color = '#fca5a5'; rb.style.background = '#2a1518';
