  // ===================================================================
  // EXPERIMENT 9 — JACOBIAN IK via DAMPED LEAST SQUARES (NEW)
  // ===================================================================
  (function exp9() {
    var cv = $('jacCv'), ctx = cv.getContext('2d');
    var W = cv.width, H = cv.height;
    var ox = W / 2, oy = H * 0.58;
    var Ls = [120, 95, 75, 60];            // link lengths (px), up to 4
    var n = 3;
    var q = [0.5, 0.4, -0.3, 0.2];          // joint angles (rad)
    var target = null;                      // {x,y} world (y up)
    var iters = 0, lastErr = 0, solving = false;
    var manipW = 0, condN = 0, ellAx = null;

    function w2s(x, y) { return { x: ox + x, y: oy - y }; }
    function s2w(sx, sy) { return { x: sx - ox, y: oy - sy }; }

    // forward kinematics: cumulative joint positions (world, y up)
    function joints() {
      var pts = [{ x: 0, y: 0 }], ang = 0, x = 0, y = 0;
      for (var i = 0; i < n; i++) { ang += q[i]; x += Ls[i] * Math.cos(ang); y += Ls[i] * Math.sin(ang); pts.push({ x: x, y: y }); }
      return pts;
    }
    function tip() { var p = joints(); return p[p.length - 1]; }
    function reach() { var s = 0; for (var i = 0; i < n; i++) s += Ls[i]; return s; }

    // 2 x n position Jacobian: col j = perpendicular of (tip - joint_j)
    function jacobian(pts) {
      var t = pts[pts.length - 1];
      var J = [new Array(n), new Array(n)];
      for (var j = 0; j < n; j++) {
        var dx = t.x - pts[j].x, dy = t.y - pts[j].y;
        J[0][j] = -dy;   // d x_tip / d theta_j
        J[1][j] = dx;    // d y_tip / d theta_j
      }
      return J;
    }

    // A (2xn) times A^T (nx2) -> 2x2 symmetric
    function JJt(J) {
      var a = 0, b = 0, d = 0;
      for (var j = 0; j < n; j++) { a += J[0][j] * J[0][j]; b += J[0][j] * J[1][j]; d += J[1][j] * J[1][j]; }
      return [a, b, b, d]; // [m00,m01,m10,m11]
    }
    function inv2(m) {
      var det = m[0] * m[3] - m[1] * m[2];
      if (Math.abs(det) < 1e-9) det = (det < 0 ? -1 : 1) * 1e-9;
      return [m[3] / det, -m[1] / det, -m[2] / det, m[0] / det];
    }
    // eigen-decomposition of 2x2 symmetric [a b; b d]
    function eigSym(a, b, d) {
      var tr = a + d, det = a * d - b * b;
      var disc = Math.sqrt(Math.max(0, tr * tr / 4 - det));
      var l1 = tr / 2 + disc, l2 = tr / 2 - disc;
      var v1;
      if (Math.abs(b) > 1e-9) v1 = { x: l1 - d, y: b };
      else v1 = (a >= d) ? { x: 1, y: 0 } : { x: 0, y: 1 };
      var nrm = Math.sqrt(v1.x * v1.x + v1.y * v1.y) || 1;
      v1.x /= nrm; v1.y /= nrm;
      return { l1: Math.max(0, l1), l2: Math.max(0, l2), v1: v1, v2: { x: -v1.y, y: v1.x } };
    }

    // one damped-least-squares iteration; returns error magnitude
    function dlsStep() {
      var pts = joints(), t = pts[pts.length - 1];
      var ex = target.x - t.x, ey = target.y - t.y;
      var err = Math.sqrt(ex * ex + ey * ey);
      var J = jacobian(pts);
      var lam = +$('jLam').value;
      var gain = +$('jGain').value;
      var m = JJt(J);
      m[0] += lam * lam; m[3] += lam * lam;        // (J J^T + lambda^2 I)
      var mi = inv2(m);
