    var linkOpts = $('jacLinks').querySelectorAll('.opt');
    for (var li = 0; li < linkOpts.length; li++) {
      linkOpts[li].addEventListener('click', function () {
        for (var k = 0; k < linkOpts.length; k++) linkOpts[k].classList.remove('on');
