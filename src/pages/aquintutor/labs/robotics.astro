  // ===================================================================
  // EXPERIMENT 3 — 3-LINK ARM & WORKSPACE (NEW)
  // ===================================================================
  (function exp3() {
    var cv = $('wsCv'), ctx = cv.getContext('2d');
    var W = cv.width, H = cv.height;
    var ox = W / 2, oy = H * 0.55;
    var L1 = 120, L2 = 95, L3 = 70;
    var th = [40 * Math.PI / 180, 50 * Math.PI / 180, -35 * Math.PI / 180];
    var cloud = null;                    // ImageData accumulating samples
    var sweeping = false, sweepK = 0;
    var measuredOut = 0, measuredIn = 999;

    function w2s(x, y) { return { x: ox + x, y: oy - y }; }

    function fk(a) {
      var Ls = [L1, L2, L3];
      var ang = 0, x = 0, y = 0, pts = [{ x: 0, y: 0 }];
      for (var i = 0; i < 3; i++) { ang += a[i]; x += Ls[i] * Math.cos(ang); y += Ls[i] * Math.sin(ang); pts.push({ x: x, y: y }); }
      return pts;
    }

    function ensureCloud() {
      if (!cloud) cloud = ctx.createImageData(W, H);
    }
    function plotSample(x, y) {
      var s = w2s(x, y);
      var px = Math.round(s.x), py = Math.round(s.y);
      if (px < 0 || py < 0 || px >= W || py >= H) return;
      var idx = (py * W + px) * 4;
      cloud.data[idx] = 0x67; cloud.data[idx + 1] = 0xe8; cloud.data[idx + 2] = 0xf9; cloud.data[idx + 3] = 90;
      var r = Math.sqrt(x * x + y * y);
      if (r > measuredOut) measuredOut = r;
      if (r < measuredIn) measuredIn = r;
    }

    function draw() {
      ctx.fillStyle = '#08080b'; ctx.fillRect(0, 0, W, H);
      if (cloud) ctx.putImageData(cloud, 0, 0);
      // theoretical reach circle
      ctx.strokeStyle = 'rgba(167,139,250,0.25)'; ctx.setLineDash([4, 5]); ctx.lineWidth = 1;
      ctx.beginPath(); ctx.arc(ox, oy, L1 + L2 + L3, 0, TAU); ctx.stroke(); ctx.setLineDash([]);
      // ground + base
      ctx.strokeStyle = '#232330'; ctx.beginPath(); ctx.moveTo(0, oy); ctx.lineTo(W, oy); ctx.stroke();
      // live arm
      var pts = fk(th);
      var cols = ['#67e8f9', '#a78bfa', '#fbbf24'];
      for (var i = 0; i < pts.length - 1; i++) {
        var a = w2s(pts[i].x, pts[i].y), b = w2s(pts[i + 1].x, pts[i + 1].y);
        ctx.strokeStyle = cols[i]; ctx.lineWidth = 7; ctx.lineCap = 'round';
        ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.stroke();
      }
      for (var j = 0; j < pts.length; j++) {
        var sp = w2s(pts[j].x, pts[j].y);
        ctx.fillStyle = j === 0 ? '#444' : '#0a0a0c'; ctx.strokeStyle = '#e8e8ee'; ctx.lineWidth = 2;
        ctx.beginPath(); ctx.arc(sp.x, sp.y, j === 0 ? 8 : 5, 0, TAU); ctx.fill(); ctx.stroke();
      }
      var ee = pts[3], se = w2s(ee.x, ee.y);
      ctx.fillStyle = '#86efac'; ctx.beginPath(); ctx.arc(se.x, se.y, 5, 0, TAU); ctx.fill();
      ctx.fillStyle = '#2a2a35'; ctx.fillRect(ox - 16, oy, 32, 12);
      $('wsX').textContent = ee.x.toFixed(0);
      $('wsY').textContent = ee.y.toFixed(0);
      $('wsOut').textContent = (measuredOut > 0 ? measuredOut.toFixed(0) : (L1 + L2 + L3).toFixed(0));
      $('wsIn').textContent = (measuredIn < 999 ? measuredIn.toFixed(0) : '0');
    }

    function sweepStep() {
      if (!sweeping) return;
      ensureCloud();
      var batch = 1400;
      for (var n = 0; n < batch; n++) {
        var a1 = (Math.random() * 2 - 1) * Math.PI;
        var a2 = (Math.random() * 2 - 1) * Math.PI;
        var a3 = (Math.random() * 2 - 1) * Math.PI;
        var ang = a1, x = L1 * Math.cos(ang), y = L1 * Math.sin(ang);
        ang += a2; x += L2 * Math.cos(ang); y += L2 * Math.sin(ang);
        ang += a3; x += L3 * Math.cos(ang); y += L3 * Math.sin(ang);
        plotSample(x, y);
      }
      sweepK += batch;
      $('wsState').textContent = 'sweep ' + Math.round(sweepK / 1000) + 'k';
      if (sweepK >= 60000) { sweeping = false; $('wsState').textContent = 'done ' + Math.round(sweepK / 1000) + 'k'; }
    }

    function loop() { sweepStep(); draw(); requestAnimationFrame(loop); }

    function bindSlider(id, vid, idx) {
      $(id).addEventListener('input', function () {
        $(vid).textContent = $(id).value + '°';
        th[idx] = (+$(id).value) * Math.PI / 180;
      });
    }
    bindSlider('w1', 'w1v', 0); bindSlider('w2', 'w2v', 1); bindSlider('w3', 'w3v', 2);
    $('wL3').addEventListener('input', function () {
      $('wL3v').textContent = $('wL3').value; L3 = +$('wL3').value;
      cloud = null; measuredOut = 0; measuredIn = 999; sweepK = 0; sweeping = false; $('wsState').textContent = 'ready';
    });
    $('wsSweep').addEventListener('click', function () { sweeping = true; });
    $('wsClear').addEventListener('click', function () {
      cloud = null; measuredOut = 0; measuredIn = 999; sweepK = 0; sweeping = false; $('wsState').textContent = 'ready';
    });

    requestAnimationFrame(loop);
  })();

  // ===================================================================
  // SHARED — mobile robot engine (used by Exp.4 nav and Exp.5 field)
  // ===================================================================
  function makeMobile(opts) {
    var cv = $(opts.cv), ctx = cv.getContext('2d');
    var W = cv.width, H = cv.height;
    var startPose = { x: 90, y: H - 90, th: -Math.PI / 4 };
    var rob = { x: startPose.x, y: startPose.y, th: startPose.th, v: 0, w: 0 };
    var goal = null;
    var trail = [];
    var obstacles = opts.obstacles ? opts.obstacles.slice() : [];
    var lastT = 0;
    var lastRep = 0;
    var api = {};

    function reset() { rob = { x: startPose.x, y: startPose.y, th: startPose.th, v: 0, w: 0 }; trail = []; goal = null; }
    api.reset = function () { reset(); };
    api.clearTrail = function () { trail = []; };
    api.resetObstacles = function (obs) { reset(); obstacles = obs.slice(); };
    api.addObstacle = function (x, y, r) { obstacles.push({ x: x, y: y, r: r }); };
    api.setGoal = function (x, y) { goal = { x: x, y: y }; };
    api.obstacleCount = function () { return obstacles.length; };

    function draw() {
      ctx.fillStyle = '#08080b'; ctx.fillRect(0, 0, W, H);
      ctx.strokeStyle = '#15151d'; ctx.lineWidth = 1;
      for (var gx = 0; gx <= W; gx += 40) { ctx.beginPath(); ctx.moveTo(gx, 0); ctx.lineTo(gx, H); ctx.stroke(); }
      for (var gy = 0; gy <= H; gy += 40) { ctx.beginPath(); ctx.moveTo(0, gy); ctx.lineTo(W, gy); ctx.stroke(); }
      for (var o = 0; o < obstacles.length; o++) {
        var ob = obstacles[o];
        ctx.fillStyle = 'rgba(252,165,165,0.12)';
        ctx.beginPath(); ctx.arc(ob.x, ob.y, ob.r, 0, TAU); ctx.fill();
        ctx.strokeStyle = '#fca5a5'; ctx.lineWidth = 1.5;
        ctx.beginPath(); ctx.arc(ob.x, ob.y, ob.r, 0, TAU); ctx.stroke();
        if (opts.showInfluence) {
          ctx.strokeStyle = 'rgba(252,165,165,0.18)'; ctx.setLineDash([3, 4]);
          ctx.beginPath(); ctx.arc(ob.x, ob.y, ob.r + 55, 0, TAU); ctx.stroke(); ctx.setLineDash([]);
        }
      }
      if (trail.length > 1) {
        ctx.strokeStyle = '#67e8f9'; ctx.lineWidth = 2; ctx.beginPath();
        ctx.moveTo(trail[0].x, trail[0].y);
        for (var i = 1; i < trail.length; i++) ctx.lineTo(trail[i].x, trail[i].y);
        ctx.stroke();
      }
      if (goal) {
        ctx.strokeStyle = '#86efac'; ctx.lineWidth = 1.5;
        ctx.beginPath(); ctx.arc(goal.x, goal.y, 10, 0, TAU); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(goal.x - 14, goal.y); ctx.lineTo(goal.x + 14, goal.y);
        ctx.moveTo(goal.x, goal.y - 14); ctx.lineTo(goal.x, goal.y + 14); ctx.stroke();
      }
      ctx.save();
      ctx.translate(rob.x, rob.y); ctx.rotate(rob.th);
      ctx.fillStyle = '#a78bfa';
      ctx.beginPath(); ctx.moveTo(16, 0); ctx.lineTo(-11, 9); ctx.lineTo(-11, -9); ctx.closePath(); ctx.fill();
      ctx.fillStyle = '#16091f'; ctx.beginPath(); ctx.arc(0, 0, 3, 0, TAU); ctx.fill();
      ctx.restore();
    }

    function control(dt) {
      if (!goal) { rob.v += (0 - rob.v) * 0.1; rob.w *= 0.8; lastRep = 0; return; }
      var g = opts.gains();
      var Kw = g.Kw, Kv = g.Kv, Vmax = g.Vmax, Kavoid = g.Kavoid;
      var dx = goal.x - rob.x, dy = goal.y - rob.y;
      var dist = Math.sqrt(dx * dx + dy * dy);
      var ax = dx / (dist + 1e-6), ay = dy / (dist + 1e-6);
      var repMag = 0;
      for (var o = 0; o < obstacles.length; o++) {
        var ob = obstacles[o];
        var ex = rob.x - ob.x, ey = rob.y - ob.y;
        var ed = Math.sqrt(ex * ex + ey * ey);
        var influence = ob.r + 55;
        if (ed < influence) {
          var rep = Kavoid * (influence - ed) / influence;
          ax += (ex / (ed + 1e-6)) * rep * 2.2;
          ay += (ey / (ed + 1e-6)) * rep * 2.2;
          repMag += rep * 2.2;
        }
      }
      lastRep = repMag;
      var desired = Math.atan2(ay, ax);
      var eth = wrap(desired - rob.th);
      rob.w = Kw * eth;
      var headFactor = Math.max(0, Math.cos(eth));
      var vCmd = Kv * dist * headFactor;
      rob.v = clamp(vCmd, 0, Vmax);
      if (dist < 7) { rob.v = 0; rob.w = 0; }
      rob.th = wrap(rob.th + rob.w * dt);
      rob.x += rob.v * Math.cos(rob.th) * dt;
      rob.y += rob.v * Math.sin(rob.th) * dt;
      rob.x = clamp(rob.x, 8, W - 8); rob.y = clamp(rob.y, 8, H - 8);
      var last = trail[trail.length - 1];
      if (!last || (rob.x - last.x) * (rob.x - last.x) + (rob.y - last.y) * (rob.y - last.y) > 9) {
        trail.push({ x: rob.x, y: rob.y });
        if (trail.length > 1200) trail.shift();
      }
    }

    function loop(ts) {
      if (!lastT) lastT = ts;
      var dt = Math.min(0.05, (ts - lastT) / 1000); lastT = ts;
      control(dt);
      draw();
      var goalDist = null;
      if (goal) goalDist = Math.sqrt((goal.x - rob.x) * (goal.x - rob.x) + (goal.y - rob.y) * (goal.y - rob.y));
      if (opts.onFrame) opts.onFrame(rob, goalDist, lastRep, obstacles.length);
      requestAnimationFrame(loop);
    }
    api.canvasClick = function (cb) {
      cv.addEventListener('click', function (ev) {
        var r = cv.getBoundingClientRect();
        var x = (ev.clientX - r.left) * (W / r.width);
        var y = (ev.clientY - r.top) * (H / r.height);
        cb(x, y);
      });
    };
    requestAnimationFrame(loop);
    return api;
  }

