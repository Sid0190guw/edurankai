  // ===================================================================
  // EXPERIMENT 10 — RRT* SAMPLING-BASED MOTION PLANNING (NEW)
  // ===================================================================
  (function exp10() {
    var cv = $('rrtCv'), ctx = cv.getContext('2d');
    var W = cv.width, H = cv.height;
    var ROBOT_R = 7;
    var start = { x: 60, y: H - 60 }, goal = { x: W - 60, y: 60 };
    var defObs = [
      { x: 200, y: 360, r: 55 }, { x: 330, y: 250, r: 60 },
      { x: 220, y: 140, r: 45 }, { x: 440, y: 380, r: 50 },
      { x: 470, y: 200, r: 48 }, { x: 130, y: 230, r: 38 }
    ];
    var obstacles = defObs.slice();
    // nodes: {x,y,parent,cost}
    var nodes = [];
    var growing = false, rewires = 0, bestGoalNode = -1, bestCost = Infinity;
    var driving = false, driveIdx = 0, driveProg = 0, drivePath = [];

    function resetTree() {
      nodes = [{ x: start.x, y: start.y, parent: -1, cost: 0 }];
      growing = false; rewires = 0; bestGoalNode = -1; bestCost = Infinity;
      driving = false; driveIdx = 0; driveProg = 0; drivePath = [];
      $('rrtN').textContent = '1'; $('rrtCost').textContent = '--'; $('rrtRw').textContent = '0'; $('rrtStat').textContent = 'idle'; $('rrtState').textContent = 'ready';
    }

    function inObstacle(x, y) {
      for (var i = 0; i < obstacles.length; i++) {
        var o = obstacles[i], dx = x - o.x, dy = y - o.y;
        if (dx * dx + dy * dy < (o.r + ROBOT_R) * (o.r + ROBOT_R)) return true;
      }
      return false;
    }
    // segment p->qq collision-free? sample along it
    function freeSeg(px, py, qx, qy) {
      var dx = qx - px, dy = qy - py, len = Math.sqrt(dx * dx + dy * dy);
      var steps = Math.max(2, Math.ceil(len / 6));
      for (var s = 0; s <= steps; s++) {
        var tt = s / steps;
        if (inObstacle(px + dx * tt, py + dy * tt)) return false;
      }
      return true;
    }
    function nearest(x, y) {
      var bi = 0, bd = Infinity;
      for (var i = 0; i < nodes.length; i++) {
        var dx = nodes[i].x - x, dy = nodes[i].y - y, d = dx * dx + dy * dy;
        if (d < bd) { bd = d; bi = i; }
      }
      return bi;
    }
    function dist(a, b) { var dx = a.x - b.x, dy = a.y - b.y; return Math.sqrt(dx * dx + dy * dy); }

    function extend() {
      var eta = +$('rEta').value;
      var bias = +$('rBias').value / 100;
      var rx, ry;
      if (Math.random() < bias) { rx = goal.x; ry = goal.y; }
      else { rx = Math.random() * W; ry = Math.random() * H; }
      var ni = nearest(rx, ry);
      var nn = nodes[ni];
      var dx = rx - nn.x, dy = ry - nn.y, L = Math.sqrt(dx * dx + dy * dy) || 1;
      var nx = nn.x + dx / L * Math.min(eta, L);
      var ny = nn.y + dy / L * Math.min(eta, L);
      if (inObstacle(nx, ny) || !freeSeg(nn.x, nn.y, nx, ny)) return;
      // RRT*: shrinking neighbourhood radius
      var rad = Math.min(eta * 2.2, 70 * Math.sqrt(Math.log(nodes.length + 1) / (nodes.length + 1)) + eta);
      // choose best parent among near set
      var bestParent = ni, bestC = nn.cost + dist(nn, { x: nx, y: ny });
      var near = [];
      for (var i = 0; i < nodes.length; i++) {
        var d = dist(nodes[i], { x: nx, y: ny });
        if (d <= rad) {
          near.push(i);
          var c = nodes[i].cost + d;
          if (c < bestC && freeSeg(nodes[i].x, nodes[i].y, nx, ny)) { bestC = c; bestParent = i; }
        }
      }
      var newIdx = nodes.length;
      nodes.push({ x: nx, y: ny, parent: bestParent, cost: bestC });
      // rewire near set through the new node
      for (var k = 0; k < near.length; k++) {
        var j = near[k];
        if (j === bestParent) continue;
        var nc = bestC + dist(nodes[j], { x: nx, y: ny });
        if (nc < nodes[j].cost - 0.01 && freeSeg(nx, ny, nodes[j].x, nodes[j].y)) {
          nodes[j].parent = newIdx; nodes[j].cost = nc; rewires++;
          propagate(j);
