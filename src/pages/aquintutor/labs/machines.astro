    var view = $('xView').value;
    var svg = clearStage();

    if (view === 'phasor') {
      // phasor diagram: V2 reference horizontal, I2, drops I.R, I.X, E2
      add(svg, txt('Phasor diagram (referred to secondary, V2 as reference)', 450, 26, '#cfd6da', 13, 'middle', "'Cormorant Garamond', serif"));
      var ox = 250, oy = 330;
      // scale: choose so V2rated maps to ~300 px
      var Vsc = 300 / r.V2rated;
      var Isc = 230 / (r.I2rated || 1);
      add(svg, line(40, oy, 860, oy, '#222633', 1));
      add(svg, line(ox, 60, ox, 470, '#222633', 1));
      // V2 (terminal) along +x
      arrow(svg, ox, oy, r.V2 * Vsc, 0, '#67e8f9', 2.4, 'V2', 16);
      // current I2 at angle -phi (lagging) below axis
      var iang = r.sign * r.phi; // screen y is down, so positive math angle -> up; lagging current lags -> below
      var Idx = r.I2 * Isc * Math.cos(-iang); // negate because screen y down
      var Idy = -r.I2 * Isc * Math.sin(-iang);
      arrow(svg, ox, oy, Idx, Idy, '#fbbf24', 2.2, 'I2', 16);
      // voltage drops added to tip of V2 to reach E2
      var tipx = ox + r.V2 * Vsc, tipy = oy;
      var dR = cmul(r.Iphase, cx(r.Req2, 0)); // I*R drop, in phase with I
      var dX = cmul(r.Iphase, cx(0, r.Xeq2)); // I*X drop leads I by 90
      // map complex drop to screen (re -> +x, im -> -y)
      arrow(svg, tipx, tipy, dR.re * Vsc, -dR.im * Vsc, '#a78bfa', 1.8, 'I.R', 12);
      var midx = tipx + dR.re * Vsc, midy = tipy - dR.im * Vsc;
      arrow(svg, midx, midy, dX.re * Vsc, -dX.im * Vsc, '#86efac', 1.8, 'I.X', 12);
      // E2 from origin to final
      var ex = ox + r.E2c.re * Vsc, ey = oy - r.E2c.im * Vsc;
      add(svg, line(ox, oy, ex, ey, '#fca5a5', 2.2, '4 3'));
      add(svg, txt('E2', ex + 6, ey - 6, '#fca5a5', 10.5));
      legend([['V2 terminal', '#67e8f9'], ['I2 load current', '#fbbf24'], ['I.R drop', '#a78bfa'], ['I.X drop', '#86efac'], ['E2 induced', '#fca5a5']]);
      $('stageCap').textContent = 'E2 = V2 + I2(Req + jXeq). The angle between V2 and I2 is the load power-factor angle; the drop triangle (I.R, I.X) sets the regulation.';
    } else if (view === 'eff') {
      var pl = makePlot(svg, 95, 70, 700, 380, 0, 1.25, 0, 100, 'Load fraction  x = I2/I2(rated)', 'Efficiency  (%)', { nx: 5, ny: 5, xd: 2, yd: 0 });
      var pts = [];
      var xMaxEff = 0, effMax = 0;
      for (var xf = 0.0; xf <= 1.25001; xf += 0.01) {
        var pp = readXfmr(); pp.loadFrac = xf;
        var rr = transformerSolve(pp);
        if (xf > 0.001) {
          pts.push([pl.gx(xf), pl.gy(clamp(rr.eff, 0, 100))]);
          if (rr.eff > effMax) { effMax = rr.eff; xMaxEff = xf; }
        }
      }
      add(svg, path(polyPath(pts), '#86efac', 2.4));
      // mark the current operating point
      add(svg, circle(pl.gx(p.loadFrac), pl.gy(clamp(r.eff, 0, 100)), 5, { fill: '#fbbf24', stroke: '#0a0a0c', 'stroke-width': 1.5 }));
      // vertical at x for max efficiency
      add(svg, line(pl.gx(r.xmax), pl.oy, pl.gx(r.xmax), pl.oy + pl.h, '#a78bfa', 1.2, '4 4'));
      add(svg, txt('x* = ' + fmt(r.xmax, 2) + ' (Pcu = Pcore)', pl.gx(r.xmax) + 6, pl.oy + 16, '#a78bfa', 10));
      legend([['Efficiency curve', '#86efac'], ['Operating point', '#fbbf24'], ['Max-eff load x*', '#a78bfa']]);
      $('stageCap').textContent = 'Efficiency peaks where the variable copper loss equals the constant core loss, at x* = sqrt(Pcore / Pcu,rated). Output power = V2.I2.cos(phi).';
    } else {
      var pl2 = makePlot(svg, 95, 70, 700, 380, 0, 1.25, -8, 12, 'Load fraction  x', 'Voltage regulation  (%)', { nx: 5, ny: 5, xd: 2, yd: 0 });
      // three pf curves: 0.8 lag, unity, 0.8 lead
      var configs = [[0.8, true, '#fca5a5', '0.8 lag'], [1.0, true, '#67e8f9', 'unity'], [0.8, false, '#86efac', '0.8 lead']];
      for (var c = 0; c < configs.length; c++) {
        var cf = configs[c]; var ptsR = [];
        for (var xr = 0.0; xr <= 1.25001; xr += 0.02) {
          var pq = readXfmr(); pq.loadFrac = xr; pq.pf = cf[0]; pq.lagging = cf[1];
          var rq = transformerSolve(pq);
          ptsR.push([pl2.gx(xr), pl2.gy(clamp(rq.regUp, -8, 12))]);
        }
        add(svg, path(polyPath(ptsR), cf[2], 2.2));
      }
      add(svg, circle(pl2.gx(p.loadFrac), pl2.gy(clamp(r.regUp, -8, 12)), 5, { fill: '#fbbf24', stroke: '#0a0a0c', 'stroke-width': 1.5 }));
      legend([['0.8 lagging', '#fca5a5'], ['unity', '#67e8f9'], ['0.8 leading', '#86efac'], ['operating pt', '#fbbf24']]);
      $('stageCap').textContent = 'Regulation = (Vno-load - Vfull-load)/Vno-load x100. Lagging pf gives positive (terminal drops); leading pf can give negative regulation (terminal rises).';
    }

    bigReadout([
      ['Efficiency', fmt(r.eff, 2) + ' %'],
      ['Regulation', fmt(r.regUp, 2) + ' %']
    ]);
    resTable([
      ['Turns ratio a = N1/N2', fmt(r.a, 3), 'vc'],
      ['No-load V2 (rated)', fmt(r.V2rated, 1) + ' V', 'vc'],
      ['Terminal V2', fmt(r.V2, 1) + ' V', 'vc'],
      ['Rated I2', fmt(r.I2rated, 2) + ' A', 'va'],
      ['Load current I2', fmt(r.I2, 2) + ' A', 'va'],
      ['Req (ref sec)', fmt(r.Req2, 3) + ' ohm', 'vp'],
      ['Xeq (ref sec)', fmt(r.Xeq2, 3) + ' ohm', 'vp'],
      ['Core loss Pi', fmt(r.Pcore, 1) + ' W', 'vr'],
      ['Copper loss Pcu', fmt(r.Pcu, 1) + ' W', 'vr'],
      ['Output power', fmt(r.Pout, 1) + ' W', 'vc'],
      ['Input power', fmt(r.Pin, 1) + ' W', 'vc']
    ]);
  }

  // ==================================================================
  // EXP 2 — DC MACHINE
  // ==================================================================
  // Separately-excited / shunt DC machine. Magnetisation curve modelled
  // by a saturating function Eg0(If) at base speed. Back-EMF E = k.phi.w,
  // torque T = k.phi.Ia, with armature drop Ia.Ra and brush drop.
  function dcMagFlux(If, p) {
    // normalised flux vs field current: linear then saturating (tanh-like)
    // phi = phiSat * tanh(If / Iknee). Scale so rated field gives ~1.0 pu.
    var Iknee = p.Ifrated * 0.55;
    var phi = Math.tanh(If / Iknee);
    return phi; // per-unit flux (0..~1)
  }
  function dcSolve(p) {
    // p: mode (motor/gen), V (terminal), Ra, kPhiBase (V.s/rad at full flux),
    //    If, Ifrated, TL (load torque, motor) or speedRPM (gen), Nbase
    var phiPu = dcMagFlux(p.If, p);
    var kphi = p.kphi * phiPu;     // effective k*phi
    var out = {};
    out.phiPu = phiPu; out.kphi = kphi;
    if (p.mode === 'motor') {
      // Steady state: V = E + Ia*Ra, E = kphi*w, T = kphi*Ia = TL (+ no-load loss)
      // From torque balance: Ia = (TL + Tloss)/kphi ; then E = V - Ia*Ra ; w = E/kphi
      var Tloss = p.Tfric;          // rotational loss torque (approx const)
      var Ttot = p.TL + Tloss;
      var Ia, w, E;
      if (kphi < 1e-4) { Ia = 0; w = 0; E = 0; }
      else {
        Ia = Ttot / kphi;
        E = p.V - Ia * p.Ra;
        w = E / kphi;
      }
      var rpm = w * 60 / (2 * Math.PI);
      var Pmech = p.TL * w;          // useful output
      var Pdev = (kphi * Ia) * w;    // developed (gross) mech power = E*Ia
      var Pin = p.V * Ia;
      var Pcu = Ia * Ia * p.Ra;
      var eff = Pin > 1e-6 ? (Pmech / Pin) * 100 : 0;
      out.Ia = Ia; out.E = E; out.w = w; out.rpm = rpm; out.T = kphi * Ia;
      out.Pin = Pin; out.Pmech = Pmech; out.Pdev = Pdev; out.Pcu = Pcu; out.eff = eff;
    } else {
      // generator: driven at speedRPM, E = kphi*w, Ia flows into load R_load
      var wG = p.speedRPM * 2 * Math.PI / 60;
      var Eg = kphi * wG;
      // terminal: Vt = Eg - Ia*Ra, Ia = Vt/Rload  -> Eg = Ia*(Ra+Rload)
      var Ia2, Vt;
      if (p.Rload > 1e6) { Ia2 = 0; Vt = Eg; }
      else { Ia2 = Eg / (p.Ra + p.Rload); Vt = Ia2 * p.Rload; }
      var Pout2 = Vt * Ia2;
      var Pdev2 = Eg * Ia2;
      var Pcu2 = Ia2 * Ia2 * p.Ra;
      var Pin2 = Pdev2 + p.Tfric * wG; // mechanical input (gross + friction)
      var eff2 = Pin2 > 1e-6 ? Pout2 / Pin2 * 100 : 0;
      out.Eg = Eg; out.Ia = Ia2; out.Vt = Vt; out.w = wG; out.rpm = p.speedRPM;
      out.Pout = Pout2; out.Pdev = Pdev2; out.Pcu = Pcu2; out.Pin = Pin2; out.eff = eff2;
      out.T = kphi * Ia2;
    }
    return out;
  }
  function controls_dc() {
    return '' +
      '<div class="mc-panel">' +
        '<h3>Machine</h3>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Operating mode</span><select id="dMode"><option value="motor">Motor (torque-speed)</option><option value="gen">Generator (load test)</option></select></div>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Terminal V (V) <b id="dVL" class="mc-val">220</b></span><input type="range" id="dV" min="50" max="500" step="5" value="220"></div>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Armature Ra (ohm) <b id="dRaL" class="mc-val">0.50</b></span><input type="range" id="dRa" min="0.05" max="4" step="0.05" value="0.50"></div>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">k.phi(max) (V.s/rad) <b id="dKL" class="mc-val">1.60</b></span><input type="range" id="dK" min="0.4" max="3.5" step="0.05" value="1.60"></div>' +
      '</div>' +
      '<div class="mc-panel">' +
        '<h3>Field &amp; loss</h3>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Field current If (A) <b id="dIfL" class="mc-val">1.00</b></span><input type="range" id="dIf" min="0.05" max="2.5" step="0.05" value="1.00"></div>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Rated If (A) <b id="dIfrL" class="mc-val">1.00</b></span><input type="range" id="dIfr" min="0.5" max="2.5" step="0.05" value="1.00"></div>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Friction torque (N.m) <b id="dTfL" class="mc-val">1.50</b></span><input type="range" id="dTf" min="0" max="8" step="0.1" value="1.50"></div>' +
      '</div>' +
      '<div class="mc-panel" id="dLoadPanel">' +
        '<h3>Load</h3>' +
        '<div class="mc-ctrlrow" id="dTLrow"><span class="mc-lbl">Load torque TL (N.m) <b id="dTLL" class="mc-val">10.0</b></span><input type="range" id="dTL" min="0" max="60" step="0.5" value="10"></div>' +
        '<div class="mc-ctrlrow" id="dRLrow" style="display:none"><span class="mc-lbl">Load resistance (ohm) <b id="dRLL" class="mc-val">10.0</b></span><input type="range" id="dRL" min="0.5" max="60" step="0.5" value="10"></div>' +
        '<div class="mc-ctrlrow" id="dSProw" style="display:none"><span class="mc-lbl">Drive speed (rpm) <b id="dSPL" class="mc-val">1500</b></span><input type="range" id="dSP" min="200" max="3000" step="25" value="1500"></div>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Plot</span><select id="dView"><option value="ts">Torque-speed / load curve</option><option value="mag">Magnetisation curve</option></select></div>' +
      '</div>';
  }
  function wire_dc() {
    var ids = ['dMode', 'dV', 'dRa', 'dK', 'dIf', 'dIfr', 'dTf', 'dTL', 'dRL', 'dSP', 'dView'];
    for (var i = 0; i < ids.length; i++) { $(ids[i]).addEventListener('input', render_dc); $(ids[i]).addEventListener('change', render_dc); }
    $('dMode').addEventListener('change', function () {
      var motor = $('dMode').value === 'motor';
      $('dTLrow').style.display = motor ? 'grid' : 'none';
      $('dRLrow').style.display = motor ? 'none' : 'grid';
      $('dSProw').style.display = motor ? 'none' : 'grid';
    });
    render_dc();
  }
  function readDc() {
    return {
      mode: $('dMode').value, V: parseFloat($('dV').value), Ra: parseFloat($('dRa').value),
      kphi: parseFloat($('dK').value), If: parseFloat($('dIf').value), Ifrated: parseFloat($('dIfr').value),
      Tfric: parseFloat($('dTf').value), TL: parseFloat($('dTL').value),
      Rload: parseFloat($('dRL').value), speedRPM: parseFloat($('dSP').value)
    };
  }
  function render_dc() {
    var p = readDc();
    $('dVL').textContent = p.V.toFixed(0); $('dRaL').textContent = p.Ra.toFixed(2);
    $('dKL').textContent = p.kphi.toFixed(2); $('dIfL').textContent = p.If.toFixed(2);
    $('dIfrL').textContent = p.Ifrated.toFixed(2); $('dTfL').textContent = p.Tfric.toFixed(2);
    $('dTLL').textContent = p.TL.toFixed(1); $('dRLL').textContent = p.Rload.toFixed(1);
    $('dSPL').textContent = p.speedRPM.toFixed(0);

    var r = dcSolve(p);
    var svg = clearStage();
    var view = $('dView').value;

    if (view === 'mag') {
      // magnetisation curve: Eg vs If at base speed (use a nominal base 1500 rpm)
      var wBase = 1500 * 2 * Math.PI / 60;
      var pl = makePlot(svg, 95, 70, 700, 380, 0, 2.5, 0, p.kphi * wBase * 1.05, 'Field current If (A)', 'Generated EMF Eg at 1500 rpm (V)', { nx: 5, ny: 5, xd: 1, yd: 0 });
      var pts = [];
      for (var f = 0; f <= 2.5001; f += 0.02) {
        var phi = dcMagFlux(f, p);
        var eg = p.kphi * phi * wBase;
        pts.push([pl.gx(f), pl.gy(eg)]);
      }
      add(svg, path(polyPath(pts), '#67e8f9', 2.4));
      // air-gap (linear) line tangent at origin
      var slope = (dcMagFlux(0.02, p) / 0.02) * p.kphi * wBase;
      add(svg, line(pl.gx(0), pl.gy(0), pl.gx(2.5), pl.gy(clamp(slope * 2.5, 0, p.kphi * wBase * 1.05)), '#6b7280', 1.4, '5 4'));
      // operating field point
      var egOp = p.kphi * dcMagFlux(p.If, p) * wBase;
      add(svg, circle(pl.gx(p.If), pl.gy(egOp), 5, { fill: '#fbbf24', stroke: '#0a0a0c', 'stroke-width': 1.5 }));
      add(svg, line(pl.gx(p.If), pl.oy + pl.h, pl.gx(p.If), pl.gy(egOp), '#fbbf24', 1, '3 3'));
      legend([['Magnetisation curve', '#67e8f9'], ['Air-gap line', '#6b7280'], ['Operating If', '#fbbf24']]);
      $('stageCap').textContent = 'The open-circuit (magnetisation) curve flattens as the iron saturates; flux per amp of field falls. The air-gap line is the unsaturated tangent. phi(pu) = tanh(If / Iknee).';
    } else {
      if (p.mode === 'motor') {
        // torque-speed line: for fixed V, If -> sweep TL and plot rpm
        var pl3 = makePlot(svg, 100, 70, 690, 380, 0, 2400, 0, Math.max(80, p.TL * 1.3), 'Speed (rpm)', 'Torque T (N.m)', { nx: 6, ny: 5, xd: 0, yd: 0 });
        var pts2 = [];
        for (var T = 0; T <= Math.max(80, p.TL * 1.3); T += 1) {
          var pp = readDc(); pp.TL = T;
          var rr = dcSolve(pp);
          if (rr.rpm >= 0 && rr.rpm <= 2400) { pts2.push([pl3.gx(rr.rpm), pl3.gy(T)]); }
        }
        add(svg, path(polyPath(pts2), '#a78bfa', 2.4));
        add(svg, circle(pl3.gx(clamp(r.rpm, 0, 2400)), pl3.gy(clamp(p.TL, 0, Math.max(80, p.TL * 1.3))), 5, { fill: '#fbbf24', stroke: '#0a0a0c', 'stroke-width': 1.5 }));
        legend([['Torque-speed line', '#a78bfa'], ['Operating point', '#fbbf24']]);
        $('stageCap').textContent = 'Shunt/sep-excited motor: speed N = (V - Ia.Ra)/(k.phi). The nearly-flat droop comes from the small Ia.Ra term — speed falls slightly as torque (hence Ia) rises.';
      } else {
        // generator external characteristic: Vt vs Ia (sweep load resistance)
        var IaMax = (p.kphi * dcMagFlux(p.If, p) * (p.speedRPM * 2 * Math.PI / 60)) / p.Ra;
        var pl4 = makePlot(svg, 100, 70, 690, 380, 0, Math.max(5, IaMax * 1.05), 0, Math.max(50, r.Eg * 1.05), 'Armature current Ia (A)', 'Terminal voltage Vt (V)', { nx: 5, ny: 5, xd: 1, yd: 0 });
        var pts4 = [];
        var Eg = p.kphi * dcMagFlux(p.If, p) * (p.speedRPM * 2 * Math.PI / 60);
        for (var ia = 0; ia <= IaMax; ia += IaMax / 120) {
          var vt = Eg - ia * p.Ra;
          if (vt >= 0) { pts4.push([pl4.gx(ia), pl4.gy(vt)]); }
        }
        add(svg, path(polyPath(pts4), '#86efac', 2.4));
        add(svg, line(pl4.gx(0), pl4.gy(Eg), pl4.gx(Math.max(5, IaMax * 1.05)), pl4.gy(Eg), '#6b7280', 1.2, '4 4'));
        add(svg, txt('Eg (no-load) = ' + fmt(Eg, 1) + ' V', pl4.gx(0) + 8, pl4.gy(Eg) - 6, '#6b7280', 10));
        add(svg, circle(pl4.gx(clamp(r.Ia, 0, IaMax)), pl4.gy(clamp(r.Vt, 0, Eg)), 5, { fill: '#fbbf24', stroke: '#0a0a0c', 'stroke-width': 1.5 }));
        legend([['External characteristic', '#86efac'], ['Eg no-load', '#6b7280'], ['Operating point', '#fbbf24']]);
        $('stageCap').textContent = 'Generator external characteristic: Vt = Eg - Ia.Ra. As the load draws more current the terminal voltage droops linearly with the armature-resistance drop.';
      }
    }

    if (p.mode === 'motor') {
      bigReadout([['Speed', fmt(r.rpm, 0) + ' rpm'], ['Efficiency', fmt(r.eff, 1) + ' %']]);
      resTable([
        ['Flux (per-unit)', fmt(r.phiPu, 3), 'vc'],
        ['Back-EMF E', fmt(r.E, 1) + ' V', 'vc'],
        ['Armature current Ia', fmt(r.Ia, 2) + ' A', 'va'],
        ['Developed torque', fmt(r.T, 2) + ' N.m', 'vp'],
        ['Speed w', fmt(r.w, 2) + ' rad/s', 'vc'],
        ['Input power', fmt(r.Pin, 1) + ' W', 'vc'],
        ['Output power', fmt(r.Pmech, 1) + ' W', 'vc'],
        ['Copper loss', fmt(r.Pcu, 1) + ' W', 'vr']
      ]);
    } else {
      bigReadout([['Terminal V', fmt(r.Vt, 1) + ' V'], ['Efficiency', fmt(r.eff, 1) + ' %']]);
      resTable([
        ['Flux (per-unit)', fmt(r.phiPu, 3), 'vc'],
        ['Generated EMF Eg', fmt(r.Eg, 1) + ' V', 'vc'],
        ['Armature current Ia', fmt(r.Ia, 2) + ' A', 'va'],
        ['Terminal voltage Vt', fmt(r.Vt, 1) + ' V', 'vc'],
        ['Output power', fmt(r.Pout, 1) + ' W', 'vc'],
        ['Developed power', fmt(r.Pdev, 1) + ' W', 'vc'],
        ['Copper loss', fmt(r.Pcu, 1) + ' W', 'vr'],
        ['Torque on shaft', fmt(r.T, 2) + ' N.m', 'vp']
      ]);
    }
  }

  // ==================================================================
  // EXP 3 — THREE-PHASE INDUCTION MOTOR
  // ==================================================================
  // Per-phase IEEE equivalent circuit. Stator R1 + jX1, magnetising
  // jXm (and Rc parallel), rotor R2/s + jX2 referred to stator.
  // Air-gap power = I2'^2 * R2/s ; Pmech = (1-s) Pag ; T = Pag / ws.
  function imSolve(p, s) {
    // returns torque and currents for a given slip s
    if (Math.abs(s) < 1e-6) { s = 1e-6; }
    var R2s = p.R2 / s;
    var Zrotor = cx(R2s, p.X2);
    var Zm = cx(0, p.Xm);
    if (p.Rc > 0 && p.Rc < 1e9) { Zm = cpar(cx(p.Rc, 0), cx(0, p.Xm)); }
    var Zab = cpar(Zm, Zrotor);                // parallel mag + rotor
    var Zin = cadd(cx(p.R1, p.X1), Zab);       // total per-phase
    var Vph = p.Vline / SQRT3;
    var I1 = cdiv(cx(Vph, 0), Zin);            // stator current
    var Eab = cmul(I1, Zab);                   // air-gap (across mag branch)
    var I2 = cdiv(Eab, Zrotor);                // rotor current referred
    var I2mag = cabs(I2);
    var poles = p.poles;
    var ns = 120 * p.f / poles;                // sync speed rpm
    var ws = 2 * Math.PI * ns / 60;            // sync mech rad/s
    var Pag = 3 * I2mag * I2mag * R2s;         // air-gap power (3 phase)
    var Pmech = (1 - s) * Pag;                 // gross mechanical
    var Prcu = 3 * I2mag * I2mag * p.R2;       // rotor copper = s*Pag
    var T = Pag / ws;                          // developed torque
    var nr = ns * (1 - s);                     // rotor rpm
    var I1mag = cabs(I1);
    var pf = Math.cos(carg(I1));
    var Pin = 3 * Vph * I1mag * pf;
    var Pscu = 3 * I1mag * I1mag * p.R1;
    var Pcore = p.Rc > 0 && p.Rc < 1e9 ? 3 * cabs(Eab) * cabs(Eab) / p.Rc : 0;
    var Pshaft = Pmech;                         // ignore friction/windage for clarity
    var eff = Pin > 1e-6 ? Pshaft / Pin * 100 : 0;
    return {
      s: s, T: T, I1: I1mag, I2: I2mag, Pag: Pag, Pmech: Pmech, Prcu: Prcu,
      ns: ns, nr: nr, ws: ws, pf: pf, Pin: Pin, Pscu: Pscu, Pcore: Pcore, eff: eff
    };
  }
  function imMaxTorque(p) {
    // slip at max torque: s_maxT = R2 / sqrt(R1^2 + (X1+X2)^2)  (Thevenin approx)
    var Xt = p.X1 + p.X2;
    var smT = p.R2 / Math.sqrt(p.R1 * p.R1 + Xt * Xt);
    return smT;
  }
  function controls_im() {
    return '' +
      '<div class="mc-panel">' +
        '<h3>Supply &amp; build</h3>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Line voltage (V) <b id="iVL" class="mc-val">400</b></span><input type="range" id="iV" min="110" max="690" step="10" value="400"></div>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Frequency (Hz) <b id="iFL" class="mc-val">50</b></span><input type="range" id="iF" min="25" max="60" step="1" value="50"></div>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Poles</span><select id="iP"><option>2</option><option selected>4</option><option>6</option><option>8</option></select></div>' +
      '</div>' +
      '<div class="mc-panel">' +
        '<h3>Equivalent circuit (per phase)</h3>' +
