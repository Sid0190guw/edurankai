---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Electrical Machines · Virtual Labs · AquinTutor" description="Five computing experiments — single-phase transformer (regulation & efficiency), DC machine characteristics, three-phase induction motor torque-slip, synchronous machine phasors & V-curves, and three-phase star/delta fundamentals.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; }
  .mc-wrap { max-width: 1560px; margin: 0 auto; padding: 18px 3vw 70px; }
  .mc-top { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 12px; margin-bottom: 8px; }
  .mc-back { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #67e8f9; text-decoration: none; letter-spacing: 0.08em; }
  .mc-eye { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 12px 0 0; }
  .mc-title { font-family: 'Cormorant Garamond', serif; font-size: 34px; font-weight: 600; margin: 4px 0 0; letter-spacing: -0.02em; }
  .mc-title em { color: #67e8f9; font-style: italic; font-weight: 500; }
  .mc-lede { color: #9aa6b6; font-size: 13.5px; line-height: 1.55; max-width: 860px; margin: 10px 0 18px; }

  .mc-shell { display: grid; grid-template-columns: 264px minmax(0,1fr); gap: 18px; align-items: start; }
  @media (max-width: 1000px) { .mc-shell { grid-template-columns: 1fr; } }

  /* experiment sidebar */
  .mc-explist { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 10px; position: sticky; top: 14px; }
  .mc-explist h3 { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 4px 6px 10px; }
  .mc-exp { display: flex; gap: 9px; align-items: flex-start; width: 100%; text-align: left; background: transparent; border: 1px solid transparent; border-radius: 9px; padding: 8px 9px; margin-bottom: 3px; cursor: pointer; color: #cfd6da; }
  .mc-exp:hover { background: #0a0a0c; border-color: #2a2a35; }
  .mc-exp.active { background: #0a0a0c; border-color: #67e8f9; }
  .mc-exp .num { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; color: #67e8f9; font-weight: 700; min-width: 16px; padding-top: 1px; }
  .mc-exp .nm { font-family: 'Cormorant Garamond', serif; font-size: 16px; line-height: 1.15; font-weight: 600; }
  .mc-exp.active .nm { color: #fff; }

  /* experiment main */
  .mc-main { min-width: 0; }
  .mc-exhead { font-family: 'Cormorant Garamond', serif; font-size: 27px; font-weight: 600; margin: 2px 0 2px; letter-spacing: -0.01em; }
  .mc-exhead em { color: #67e8f9; font-style: italic; }
  .mc-exsub { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10.5px; color: #6b7280; letter-spacing: 0.06em; margin: 0 0 14px; }

  .mc-tabs { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 16px; border-bottom: 1px solid #2a2a35; padding-bottom: 12px; }
  .mc-tab { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 7px 12px; border-radius: 7px; border: 1px solid #2a2a35; background: #11131a; color: #9aa6b6; cursor: pointer; }
  .mc-tab.active { color: #04161b; background: #67e8f9; border-color: #67e8f9; }

  .mc-sec { display: none; }
  .mc-sec.active { display: block; }

  .mc-prose { color: #cbd2dc; font-size: 14px; line-height: 1.7; max-width: 880px; }
  .mc-prose p { margin: 0 0 12px; }
  .mc-prose ol { margin: 0; padding-left: 22px; line-height: 1.75; font-size: 13.5px; color: #cbd2dc; }
  .mc-prose ol li { margin-bottom: 7px; }
  .mc-prose b { color: #e8e8ee; }
  .mc-eqbox { background: #11131a; border: 1px solid #2a2a35; border-left: 3px solid #67e8f9; border-radius: 8px; padding: 12px 14px; margin: 14px 0; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12.5px; color: #e8e8ee; line-height: 1.9; white-space: pre-wrap; }
  .mc-eqbox .k { color: #fbbf24; }
  .mc-refs { list-style: none; padding: 0; margin: 0; }
  .mc-refs li { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12px; color: #9aa6b6; padding: 8px 0; border-bottom: 1px solid #1a1a25; line-height: 1.5; }
  .mc-refs li b { color: #cfd6da; font-weight: 700; }

  /* simulation layout */
  .mc-simgrid { display: grid; grid-template-columns: 330px minmax(0,1fr) 280px; gap: 16px; align-items: start; }
  @media (max-width: 1240px) { .mc-simgrid { grid-template-columns: 1fr; } }
  .mc-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 16px; margin-bottom: 14px; }
  .mc-panel h3 { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 12px; }
  .mc-lbl { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #9aa6b6; }
  .mc-val { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12px; color: #67e8f9; font-weight: 700; }
  .mc-btn { background: #67e8f9; color: #04161b; padding: 8px 14px; border-radius: 7px; border: none; cursor: pointer; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
  .mc-btn.ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
  .mc-btn.purple { background: #a78bfa; color: #160a2b; }
  .mc-btn.amber { background: #fbbf24; color: #2b1d00; }
  .mc-btnrow { display: flex; gap: 7px; flex-wrap: wrap; margin-top: 4px; }
  select, input[type=text], input[type=number] { background: #0a0a0c; border: 1px solid #2a2a35; color: #e8e8ee; border-radius: 6px; padding: 6px 8px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; width: 100%; box-sizing: border-box; }
  input[type=range] { width: 100%; accent-color: #67e8f9; }
  .mc-canvas-wrap { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 12px; padding: 4px; }
  .mc-stage { width: 100%; display: block; border-radius: 10px; }
  .mc-rt { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; width: 100%; border-collapse: collapse; }
  .mc-rt th { text-align: left; color: #6b7280; padding: 5px 6px; border-bottom: 1px solid #2a2a35; font-size: 9.5px; text-transform: uppercase; letter-spacing: 0.05em; }
  .mc-rt td { padding: 5px 6px; border-bottom: 1px solid #1a1a25; }
  .mc-rt .nm { color: #9aa6b6; }
  .mc-rt .vc { color: #86efac; text-align: right; font-weight: 700; }
  .mc-rt .vp { color: #a78bfa; text-align: right; font-weight: 700; }
  .mc-rt .va { color: #fbbf24; text-align: right; font-weight: 700; }
  .mc-rt .vr { color: #fca5a5; text-align: right; font-weight: 700; }
  .mc-note { font-size: 10.5px; color: #6b7280; line-height: 1.5; margin-top: 8px; font-family: 'Geist Mono', ui-monospace, monospace; }
  .mc-ctrlrow { display: grid; grid-template-columns: 1fr; gap: 4px; padding: 7px 0; }
  .mc-bigval { font-family: 'Cormorant Garamond', serif; font-size: 25px; color: #67e8f9; font-weight: 600; line-height: 1.15; }
  .mc-bigval span { font-size: 12px; color: #9aa6b6; font-family: 'Geist Mono', ui-monospace, monospace; }
  .mc-bigval.two { margin-top: 10px; }

  /* self assessment */
  .mc-q { background: #11131a; border: 1px solid #2a2a35; border-radius: 10px; padding: 14px 16px; margin-bottom: 12px; max-width: 880px; }
  .mc-q .qt { font-size: 14px; color: #e8e8ee; line-height: 1.5; margin: 0 0 10px; font-weight: 600; }
  .mc-opt { display: flex; gap: 9px; align-items: flex-start; padding: 7px 9px; border-radius: 7px; cursor: pointer; border: 1px solid transparent; font-size: 13px; color: #cbd2dc; line-height: 1.45; }
  .mc-opt:hover { background: #0a0a0c; }
  .mc-opt input { width: auto; margin-top: 3px; accent-color: #67e8f9; }
  .mc-opt.correct { border-color: #86efac; background: rgba(134,239,172,0.08); }
  .mc-opt.wrong { border-color: #fca5a5; background: rgba(252,165,165,0.08); }
  .mc-expl { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; line-height: 1.5; margin-top: 9px; padding: 8px 10px; border-radius: 7px; display: none; }
  .mc-expl.show { display: block; }
  .mc-expl.good { color: #86efac; background: rgba(134,239,172,0.06); }
  .mc-expl.bad { color: #fca5a5; background: rgba(252,165,165,0.06); }
  .mc-checkbtn { margin-top: 4px; }
  .mc-legend { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; color: #9aa6b6; margin-top: 8px; display: flex; flex-wrap: wrap; gap: 12px; }
  .mc-legend i { display: inline-block; width: 14px; height: 3px; border-radius: 2px; vertical-align: middle; margin-right: 5px; }
</style>

<main class="mc-wrap">
  <div class="mc-top">
    <div>
      <a class="mc-back" href="/aquintutor/labs">&larr; Virtual labs</a>
      <p class="mc-eye">Electrical Machines</p>
      <h1 class="mc-title">Rotating &amp; static <em>machines</em> virtual lab.</h1>
    </div>
  </div>
  <p class="mc-lede">Five self-contained experiments in the Virtual Labs format — the single-phase transformer, the DC machine, the three-phase induction motor, the synchronous machine, and three-phase star/delta fundamentals. Each opens with an aim, the underlying theory and the real equations, a numbered procedure, a genuinely-computing interactive simulator, a marked self-assessment quiz and references. Every curve is solved live from the per-phase equivalent circuit using complex-impedance arithmetic, the universal torque equation, phasor construction and exact star/delta relations — nothing is pre-baked.</p>

  <div class="mc-shell">
    <aside>
      <nav class="mc-explist" id="expList">
        <h3>Experiments</h3>
        <!-- buttons injected -->
      </nav>
    </aside>

    <section class="mc-main">
      <h2 class="mc-exhead" id="exTitle"></h2>
      <p class="mc-exsub" id="exSub"></p>

      <div class="mc-tabs" id="secTabs">
        <button class="mc-tab active" data-sec="aim">Aim</button>
        <button class="mc-tab" data-sec="theory">Theory</button>
        <button class="mc-tab" data-sec="proc">Procedure</button>
        <button class="mc-tab" data-sec="sim">Simulation</button>
        <button class="mc-tab" data-sec="quiz">Self-assessment</button>
        <button class="mc-tab" data-sec="ref">References</button>
      </div>

      <div class="mc-sec active" data-sec="aim">
        <div class="mc-prose" id="secAim"></div>
      </div>

      <div class="mc-sec" data-sec="theory">
        <div class="mc-prose" id="secTheory"></div>
      </div>

      <div class="mc-sec" data-sec="proc">
        <div class="mc-prose"><ol id="secProc"></ol></div>
      </div>

      <div class="mc-sec" data-sec="sim">
        <div class="mc-simgrid">
          <aside id="simControls"></aside>
          <div>
            <div class="mc-canvas-wrap">
              <svg id="stage" class="mc-stage" viewBox="0 0 900 540" preserveAspectRatio="xMidYMid meet"></svg>
            </div>
            <p class="mc-note" id="stageCap"></p>
            <div class="mc-legend" id="stageLegend"></div>
          </div>
          <aside>
            <div class="mc-panel">
              <h3>Live readouts</h3>
              <div id="bigReadout"></div>
              <table class="mc-rt" style="margin-top:10px;" id="resTable"></table>
            </div>
          </aside>
        </div>
      </div>

      <div class="mc-sec" data-sec="quiz">
        <div id="secQuiz"></div>
      </div>

      <div class="mc-sec" data-sec="ref">
        <ul class="mc-refs" id="secRef"></ul>
      </div>
    </section>
  </div>
</main>

<script is:inline>
(function () {
  'use strict';

  // ==================================================================
  // PART 1 — COMPLEX-NUMBER & MATH KERNEL
  // ==================================================================
  function cx(re, im) { return { re: re, im: (im === undefined ? 0 : im) }; }
  function cadd(a, b) { return { re: a.re + b.re, im: a.im + b.im }; }
  function csub(a, b) { return { re: a.re - b.re, im: a.im - b.im }; }
  function cmul(a, b) { return { re: a.re * b.re - a.im * b.im, im: a.re * b.im + a.im * b.re }; }
  function cdiv(a, b) { var d = b.re * b.re + b.im * b.im; return { re: (a.re * b.re + a.im * b.im) / d, im: (a.im * b.re - a.re * b.im) / d }; }
  function cabs(a) { return Math.sqrt(a.re * a.re + a.im * a.im); }
  function carg(a) { return Math.atan2(a.im, a.re); }
  function cscale(a, s) { return { re: a.re * s, im: a.im * s }; }
  function cconj(a) { return { re: a.re, im: -a.im }; }
  function polar(mag, angRad) { return { re: mag * Math.cos(angRad), im: mag * Math.sin(angRad) }; }
  // parallel of two complex impedances
  function cpar(z1, z2) { return cdiv(cmul(z1, z2), cadd(z1, z2)); }

  var DEG = 180 / Math.PI;
  var RAD = Math.PI / 180;
  var SQRT3 = Math.sqrt(3);

  // ==================================================================
  // PART 2 — FORMATTING + SVG HELPERS
  // ==================================================================
  function $(id) { return document.getElementById(id); }
  function fmt(x, d) {
    if (!isFinite(x)) { return '--'; }
    d = (d === undefined) ? 2 : d;
    var ax = Math.abs(x);
    if (ax !== 0 && (ax < 1e-3 || ax >= 1e7)) { return x.toExponential(2); }
    return x.toFixed(d);
  }
  function clamp(x, lo, hi) { return x < lo ? lo : (x > hi ? hi : x); }

  var SVGNS = 'http://www.w3.org/2000/svg';
  function svgEl(name, attrs) {
    var el = document.createElementNS(SVGNS, name);
    if (attrs) { for (var k in attrs) { el.setAttribute(k, attrs[k]); } }
    return el;
  }
  function clearStage() {
    var s = $('stage');
    while (s.firstChild) { s.removeChild(s.firstChild); }
    return s;
  }
  function add(parent, el) { parent.appendChild(el); return el; }
  function line(x1, y1, x2, y2, stroke, w, dash) {
    var a = { x1: x1, y1: y1, x2: x2, y2: y2, stroke: stroke, 'stroke-width': (w || 1.4) };
    if (dash) { a['stroke-dasharray'] = dash; }
    return svgEl('line', a);
  }
  function circle(cxx, cyy, r, attrs) {
    var a = { cx: cxx, cy: cyy, r: r };
    if (attrs) { for (var k in attrs) { a[k] = attrs[k]; } }
    return svgEl('circle', a);
  }
  function path(d, stroke, w, fill, dash) {
    var a = { d: d, stroke: (stroke || 'none'), 'stroke-width': (w || 1.6), fill: (fill || 'none'), 'stroke-linejoin': 'round', 'stroke-linecap': 'round' };
    if (dash) { a['stroke-dasharray'] = dash; }
    return svgEl('path', a);
  }
  function txt(s, x, y, fill, size, anchor, family) {
    var t = svgEl('text', { x: x, y: y, fill: fill, 'font-size': (size || 11),
      'font-family': (family || "'Geist Mono', ui-monospace, monospace"), 'text-anchor': (anchor || 'start') });
    t.textContent = s;
    return t;
  }

  // polyline from arrays of plot points (already in screen coords)
  function polyPath(pts) {
    if (!pts.length) { return ''; }
    var d = 'M ' + pts[0][0].toFixed(2) + ' ' + pts[0][1].toFixed(2);
    for (var i = 1; i < pts.length; i++) { d += ' L ' + pts[i][0].toFixed(2) + ' ' + pts[i][1].toFixed(2); }
    return d;
  }

  // a reusable axis/plot frame; returns mapping functions
  function makePlot(svg, ox, oy, w, h, xmin, xmax, ymin, ymax, xlabel, ylabel, opt) {
    opt = opt || {};
    var gx = function (x) { return ox + (x - xmin) / (xmax - xmin) * w; };
    var gy = function (y) { return oy + h - (y - ymin) / (ymax - ymin) * h; };
    // frame
    add(svg, svgEl('rect', { x: ox, y: oy, width: w, height: h, fill: '#08090d', stroke: '#2a2a35', 'stroke-width': 1, rx: 4 }));
    // gridlines
    var nx = opt.nx || 5, ny = opt.ny || 5, i;
    for (i = 0; i <= nx; i++) {
      var xv = xmin + (xmax - xmin) * i / nx;
      var sx = gx(xv);
      add(svg, line(sx, oy, sx, oy + h, '#171922', 1));
      add(svg, txt(fmt(xv, opt.xd === undefined ? 1 : opt.xd), sx, oy + h + 14, '#6b7280', 9, 'middle'));
    }
    for (i = 0; i <= ny; i++) {
      var yv = ymin + (ymax - ymin) * i / ny;
      var sy = gy(yv);
      add(svg, line(ox, sy, ox + w, sy, '#171922', 1));
      add(svg, txt(fmt(yv, opt.yd === undefined ? 1 : opt.yd), ox - 6, sy + 3, '#6b7280', 9, 'end'));
    }
    // zero line for y if in range
    if (ymin < 0 && ymax > 0) { add(svg, line(ox, gy(0), ox + w, gy(0), '#3a3a48', 1.2)); }
    add(svg, txt(xlabel, ox + w / 2, oy + h + 30, '#9aa6b6', 10.5, 'middle'));
    var yl = txt(ylabel, 0, 0, '#9aa6b6', 10.5, 'middle');
    yl.setAttribute('transform', 'translate(' + (ox - 38) + ',' + (oy + h / 2) + ') rotate(-90)');
    add(svg, yl);
    return { gx: gx, gy: gy, ox: ox, oy: oy, w: w, h: h, xmin: xmin, xmax: xmax, ymin: ymin, ymax: ymax };
  }

  // draw a phasor (arrow) from (x0,y0), components in screen units
  function arrow(svg, x0, y0, dx, dy, color, w, labelStr, labelOff) {
    var x1 = x0 + dx, y1 = y0 + dy;
    add(svg, line(x0, y0, x1, y1, color, (w || 2)));
    var len = Math.sqrt(dx * dx + dy * dy);
    if (len > 1) {
      var ux = dx / len, uy = dy / len;
      var ah = 9, aw = 4.5;
      var bx = x1 - ux * ah, by = y1 - uy * ah;
      var px = -uy, py = ux;
      var d = 'M ' + x1 + ' ' + y1 + ' L ' + (bx + px * aw) + ' ' + (by + py * aw) + ' L ' + (bx - px * aw) + ' ' + (by - py * aw) + ' Z';
      add(svg, svgEl('path', { d: d, fill: color, stroke: 'none' }));
    }
    if (labelStr) {
      var lo = labelOff || 12;
      add(svg, txt(labelStr, x1 + (dx === 0 ? 6 : (dx > 0 ? 6 : -6)), y1 + (dy > 0 ? lo : -6), color, 10.5, dx < 0 ? 'end' : 'start'));
    }
  }

  function legend(items) {
    var host = $('stageLegend');
    host.innerHTML = '';
    for (var i = 0; i < items.length; i++) {
      host.innerHTML += '<span><i style="background:' + items[i][1] + '"></i>' + items[i][0] + '</span>';
    }
  }

  function bigReadout(rows) {
    var host = $('bigReadout');
    var h = '';
    for (var i = 0; i < rows.length; i++) {
      h += '<div class="mc-bigval' + (i > 0 ? ' two' : '') + '">' + rows[i][0] + ' <span>' + rows[i][1] + '</span></div>';
    }
    host.innerHTML = h;
  }
  function resTable(rows) {
    var host = $('resTable');
    var h = '<tr><th>Quantity</th><th style="text-align:right">Value</th></tr>';
    for (var i = 0; i < rows.length; i++) {
      var cls = rows[i][2] || 'vc';
      h += '<tr><td class="nm">' + rows[i][0] + '</td><td class="' + cls + '">' + rows[i][1] + '</td></tr>';
    }
    host.innerHTML = h;
  }

  // ==================================================================
  // PART 3 — SHARED STATE
  // ==================================================================
  var currentExp = 0;
  var currentSec = 'aim';
  var animHandle = null;
  function stopAnim() { if (animHandle) { cancelAnimationFrame(animHandle); animHandle = null; } }

  // ==================================================================
  // EXP 1 — SINGLE-PHASE TRANSFORMER
  // ==================================================================
  // Equivalent circuit referred to primary: R1 + jX1 in series, then
  // shunt (Rc || jXm) magnetising branch, then (R2' + jX2') and load.
  // We use the approximate equivalent circuit (magnetising branch at the
  // input terminals) for regulation/efficiency, which is the standard EE
  // approach and matches OC/SC test interpretation.
  function transformerSolve(p) {
    // p: V1 (primary rated rms), N1, N2, R1, X1, R2, X2 (secondary referred),
    //    Rc, Xm (referred to primary), Sr (rated VA), pf, lagging, loadFrac
    var a = p.N1 / p.N2;            // turns ratio (a = N1/N2)
    var V2rated = p.V1 / a;         // ideal no-load secondary voltage
    // equivalent series impedance referred to secondary
    var R1s = p.R1 / (a * a);       // primary R referred to secondary
    var X1s = p.X1 / (a * a);
    var Req2 = R1s + p.R2;          // total equiv resistance ref to secondary
    var Xeq2 = X1s + p.X2;
    // rated secondary current
    var I2rated = p.Sr / V2rated;
    var I2 = I2rated * p.loadFrac;
    // load power factor angle (lagging negative imag of current rel to V)
    var phi = Math.acos(clamp(p.pf, 0, 1));
    var sign = p.lagging ? -1 : 1;  // lagging -> current lags voltage
    // Take terminal (load) voltage V2 as reference; compute required E2 (= V2rated)
    // For regulation we fix the no-load (E2) magnitude = V2rated and find the
    // terminal voltage drop. Use approximate regulation formula plus exact phasor.
    // Exact: E2 = V2 + I2*(Req2 + jXeq2). We solve for V2 given |E2| fixed.
    // Iterative: assume V2 magnitude, current angle from load pf.
    var Vt = V2rated; // initial guess for terminal voltage
    var i;
    for (i = 0; i < 60; i++) {
      var Ip = I2rated * p.loadFrac; // current magnitude scales with load
      var Iph = { re: Ip * Math.cos(sign * phi), im: Ip * Math.sin(sign * phi) };
      var Z = { re: Req2, im: Xeq2 };
      var drop = cmul(Iph, Z);
      // E2 = Vt(real, reference) + drop ; require |E2| = V2rated
      var E2 = { re: Vt + drop.re, im: drop.im };
      var mag = cabs(E2);
      // adjust Vt so |E2| matches V2rated
      Vt = Vt + (V2rated - mag);
      if (Math.abs(V2rated - mag) < 1e-7) { break; }
    }
    var V2 = Vt;
    var Iphase = { re: I2 * Math.cos(sign * phi), im: I2 * Math.sin(sign * phi) };
    var Zser = { re: Req2, im: Xeq2 };
    var dropC = cmul(Iphase, Zser);
    var E2c = { re: V2 + dropC.re, im: dropC.im };

    // voltage regulation = (E2 - V2)/V2  (down regulation) — standard = (Vnl - Vfl)/Vfl
    var regUp = (V2rated - V2) / V2rated * 100;   // referred to no-load (rated)
    var regDown = (V2rated - V2) / (V2 || 1) * 100;

    // losses
    var I2sq = I2 * I2;
    var Pcu = I2sq * Req2;                          // copper loss at this load
    var Pcu_rated = (I2rated * I2rated) * Req2;     // full-load copper loss
    // iron loss from Rc (constant, referred to primary). Approx Vm ~ V1.
    var Pcore = (p.V1 * p.V1) / p.Rc;
    var Pout = V2 * I2 * p.pf;                      // real output power
    var Pin = Pout + Pcu + Pcore;
    var eff = Pout / Pin * 100;
    // load fraction for max efficiency (Pcu = Pcore): x = sqrt(Pcore/Pcu_rated)
    var xmax = Math.sqrt(Pcore / Pcu_rated);
    return {
      a: a, V2rated: V2rated, I2rated: I2rated, I2: I2, V2: V2, E2: V2rated,
      Req2: Req2, Xeq2: Xeq2, Pcu: Pcu, Pcore: Pcore, Pout: Pout, Pin: Pin,
      eff: eff, regUp: regUp, regDown: regDown, phi: phi, sign: sign,
      Iphase: Iphase, E2c: E2c, xmax: xmax, Pcu_rated: Pcu_rated, dropC: dropC
    };
  }

