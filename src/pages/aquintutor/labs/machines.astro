        '<div class="mc-ctrlrow"><span class="mc-lbl">Stator X1 (ohm) <b id="iX1L" class="mc-val">1.10</b></span><input type="range" id="iX1" min="0.1" max="6" step="0.05" value="1.10"></div>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Rotor R2 (ohm) <b id="iR2L" class="mc-val">0.45</b></span><input type="range" id="iR2" min="0.05" max="4" step="0.05" value="0.45"></div>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Rotor X2 (ohm) <b id="iX2L" class="mc-val">1.10</b></span><input type="range" id="iX2" min="0.1" max="6" step="0.05" value="1.10"></div>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Magnetising Xm (ohm) <b id="iXmL" class="mc-val">35</b></span><input type="range" id="iXm" min="10" max="120" step="1" value="35"></div>' +
      '</div>' +
      '<div class="mc-panel">' +
        '<h3>Operating slip</h3>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Slip s <b id="iSL" class="mc-val">0.04</b></span><input type="range" id="iS" min="0.001" max="1" step="0.001" value="0.04"></div>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Plot</span><select id="iView"><option value="ts">Torque-slip curve</option><option value="cur">Current vs slip</option></select></div>' +
      '</div>';
  }
  function wire_im() {
    var ids = ['iV', 'iF', 'iP', 'iR1', 'iX1', 'iR2', 'iX2', 'iXm', 'iS', 'iView'];
    for (var i = 0; i < ids.length; i++) { $(ids[i]).addEventListener('input', render_im); $(ids[i]).addEventListener('change', render_im); }
    render_im();
  }
  function readIm() {
    return {
      Vline: parseFloat($('iV').value), f: parseFloat($('iF').value), poles: parseInt($('iP').value, 10),
      R1: parseFloat($('iR1').value), X1: parseFloat($('iX1').value),
      R2: parseFloat($('iR2').value), X2: parseFloat($('iX2').value),
      Xm: parseFloat($('iXm').value), Rc: 1e9
    };
  }
  function render_im() {
    var p = readIm();
    $('iVL').textContent = p.Vline.toFixed(0); $('iFL').textContent = p.f.toFixed(0);
    $('iR1L').textContent = p.R1.toFixed(2); $('iX1L').textContent = p.X1.toFixed(2);
    $('iR2L').textContent = p.R2.toFixed(2); $('iX2L').textContent = p.X2.toFixed(2);
    $('iXmL').textContent = p.Xm.toFixed(0);
    var s0 = parseFloat($('iS').value);
    $('iSL').textContent = s0.toFixed(3);

    var r = imSolve(p, s0);
    var smT = imMaxTorque(p);
    var rMax = imSolve(p, smT);
    var rStart = imSolve(p, 1.0);
    var rFL = r; // full-load = operating point

    var svg = clearStage();
    var view = $('iView').value;

    if (view === 'cur') {
      // stator current magnitude vs slip
      var pl = makePlot(svg, 95, 70, 700, 380, 0, 1, 0, 1, 'Slip s', 'Stator current |I1| (A)', { nx: 5, ny: 5, xd: 2, yd: 0 });
      var maxI = 0, ss, rr, ptsRaw = [];
      for (ss = 0.001; ss <= 1.0001; ss += 0.005) { rr = imSolve(p, ss); ptsRaw.push([ss, rr.I1]); if (rr.I1 > maxI) { maxI = rr.I1; } }
      // rescale y axis
      svg.innerHTML = '';
      var pl2 = makePlot(svg, 95, 70, 700, 380, 0, 1, 0, maxI * 1.1, 'Slip s', 'Stator current |I1| (A)', { nx: 5, ny: 5, xd: 2, yd: 0 });
      var pts = [];
      for (var k = 0; k < ptsRaw.length; k++) { pts.push([pl2.gx(ptsRaw[k][0]), pl2.gy(ptsRaw[k][1])]); }
      add(svg, path(polyPath(pts), '#fbbf24', 2.4));
      add(svg, circle(pl2.gx(s0), pl2.gy(clamp(r.I1, 0, maxI * 1.1)), 5, { fill: '#67e8f9', stroke: '#0a0a0c', 'stroke-width': 1.5 }));
      add(svg, line(pl2.gx(1), pl2.oy, pl2.gx(1), pl2.oy + pl2.h, '#fca5a5', 1.2, '4 4'));
      add(svg, txt('starting (s=1): ' + fmt(rStart.I1, 1) + ' A', pl2.gx(1) - 8, pl2.oy + 16, '#fca5a5', 10, 'end'));
      legend([['Stator current', '#fbbf24'], ['Operating slip', '#67e8f9'], ['Direct-on-line start', '#fca5a5']]);
      $('stageCap').textContent = 'At standstill (s=1) the rotor branch R2/s is small, so the inrush current is several times rated. As the rotor speeds up (s falls) the current drops to its small running value.';
    } else {
      // torque-slip curve, plotted with s on x from 1 (start) to 0 (sync)
      var Tpeak = rMax.T;
      var pl3 = makePlot(svg, 100, 70, 690, 380, 0, 1, 0, Tpeak * 1.15, 'Slip s   (s=1 start ... s=0 synchronous)', 'Developed torque T (N.m)', { nx: 5, ny: 5, xd: 2, yd: 0 });
      var ptsT = [];
      for (var st = 0.002; st <= 1.0001; st += 0.004) {
        var rt = imSolve(p, st);
        ptsT.push([pl3.gx(st), pl3.gy(clamp(rt.T, 0, Tpeak * 1.15))]);
      }
      add(svg, path(polyPath(ptsT), '#67e8f9', 2.6));
      // mark max-torque, start, full-load
      add(svg, circle(pl3.gx(smT), pl3.gy(clamp(Tpeak, 0, Tpeak * 1.15)), 5, { fill: '#a78bfa', stroke: '#0a0a0c', 'stroke-width': 1.5 }));
      add(svg, txt('T_max', pl3.gx(smT) + 6, pl3.gy(Tpeak) - 6, '#a78bfa', 10));
      add(svg, circle(pl3.gx(1), pl3.gy(clamp(rStart.T, 0, Tpeak * 1.15)), 5, { fill: '#fca5a5', stroke: '#0a0a0c', 'stroke-width': 1.5 }));
      add(svg, txt('T_start', pl3.gx(1) - 6, pl3.gy(rStart.T) - 6, '#fca5a5', 10, 'end'));
      add(svg, circle(pl3.gx(s0), pl3.gy(clamp(r.T, 0, Tpeak * 1.15)), 5, { fill: '#fbbf24', stroke: '#0a0a0c', 'stroke-width': 1.5 }));
      add(svg, txt('operating', pl3.gx(s0) + 6, pl3.gy(r.T) + 14, '#fbbf24', 10));
      // stable region shading note
      add(svg, line(pl3.gx(smT), pl3.oy, pl3.gx(smT), pl3.oy + pl3.h, '#a78bfa', 1, '3 3'));
      legend([['Torque-slip', '#67e8f9'], ['Max torque', '#a78bfa'], ['Starting torque', '#fca5a5'], ['Operating point', '#fbbf24']]);
      $('stageCap').textContent = 'T = Pag/ws = 3.I2^2.(R2/s)/ws. The peak (breakdown) torque occurs at s = R2/sqrt(R1^2+(X1+X2)^2). The stable running region is between s=0 and s=s(Tmax).';
    }

    bigReadout([['Torque', fmt(r.T, 2) + ' N.m'], ['Rotor speed', fmt(r.nr, 0) + ' rpm']]);
    resTable([
      ['Sync speed ns', fmt(r.ns, 0) + ' rpm', 'vc'],
      ['Rotor speed nr', fmt(r.nr, 0) + ' rpm', 'vc'],
      ['Stator current I1', fmt(r.I1, 2) + ' A', 'va'],
      ['Rotor current I2', fmt(r.I2, 2) + ' A', 'va'],
      ['Air-gap power Pag', fmt(r.Pag, 0) + ' W', 'vc'],
      ['Mech power Pmech', fmt(r.Pmech, 0) + ' W', 'vc'],
      ['Rotor cu loss', fmt(r.Prcu, 0) + ' W', 'vr'],
      ['Power factor', fmt(r.pf, 3), 'vp'],
      ['Efficiency', fmt(r.eff, 1) + ' %', 'vc'],
      ['Slip at T_max', fmt(smT, 3), 'vp'],
      ['T_start (s=1)', fmt(rStart.T, 2) + ' N.m', 'vr'],
      ['T_max (breakdown)', fmt(rMax.T, 2) + ' N.m', 'vp']
    ]);
  }

  // ==================================================================
  // EXP 4 — SYNCHRONOUS MACHINE
  // ==================================================================
  // Cylindrical-rotor machine, per phase: V (terminal) reference,
  // E = V + jXs*Ia (motor convention E = V - jXs*Ia or generator
  // E = V + jXs*Ia). We use the generator convention with armature
  // reaction reactance Xs and small Ra.
  function syncSolve(p) {
    // p: mode (gen/motor), Vph, Xs, Ra, Ef (excitation emf), P (per-phase power),
    //    For V-curve we sweep Ef at fixed P; for a single point use given.
    // Generator: E = V + Ia*(Ra + jXs). Power P = V*E*sin(delta)/Xs (per phase, Ra~0).
    // Given P and Ef -> sin(delta) = P*Xs/(V*Ef). Then Ia from E - V = Ia*jXs.
    var V = p.Vph;
    var Xs = p.Xs;
    var Ef = p.Ef;
    var Pph = p.Pph;
    var sinD = clamp(Pph * Xs / (V * Ef), -1, 1);
    var delta = Math.asin(sinD);
    var sign = p.mode === 'motor' ? -1 : 1;     // motor: E lags V (delta negative)
    var deltaS = sign * delta;
    // E phasor at angle deltaS
    var E = polar(Ef, deltaS);
    // Generator: E = V + jXs*Ia  -> Ia = (E - V)/(jXs)
    // Motor:     V = E + jXs*Ia  -> Ia = (V - E)/(jXs)
    var Vc = cx(V, 0);
    var jXs = cx(0, Xs);
    var Ia;
    if (p.mode === 'motor') { Ia = cdiv(csub(Vc, E), jXs); }
    else { Ia = cdiv(csub(E, Vc), jXs); }
    var Iamag = cabs(Ia);
    var pfang = -carg(Ia);                        // angle of V(ref 0) minus angle of Ia
    var pf = Math.cos(carg(Ia));
    // reactive: positive => lagging (Ia lags V)
    var Q = V * Iamag * Math.sin(-carg(Ia));
    var lead = carg(Ia) > 0;                       // Ia leads V
    return { V: V, Ef: Ef, Xs: Xs, delta: deltaS, E: E, Ia: Ia, Iamag: Iamag, pf: Math.abs(pf), Q: Q, lead: lead, sinD: sinD };
  }
  function controls_sync() {
    return '' +
      '<div class="mc-panel">' +
        '<h3>Machine &amp; operation</h3>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Operation</span><select id="sMode"><option value="gen">Generator (alternator)</option><option value="motor">Motor</option></select></div>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Terminal Vph (V) <b id="sVL" class="mc-val">230</b></span><input type="range" id="sV" min="100" max="400" step="5" value="230"></div>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Sync reactance Xs (ohm) <b id="sXsL" class="mc-val">3.00</b></span><input type="range" id="sXs" min="0.5" max="10" step="0.1" value="3.0"></div>' +
      '</div>' +
      '<div class="mc-panel">' +
        '<h3>Excitation &amp; load</h3>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Excitation EMF Ef (V) <b id="sEfL" class="mc-val">280</b></span><input type="range" id="sEf" min="120" max="450" step="2" value="280"></div>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Per-phase power P (W) <b id="sPL" class="mc-val">4000</b></span><input type="range" id="sP" min="0" max="15000" step="100" value="4000"></div>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">View</span><select id="sView"><option value="phasor">Phasor diagram</option><option value="vcurve">V-curves (Ia vs Ef)</option></select></div>' +
      '</div>';
  }
  function wire_sync() {
    var ids = ['sMode', 'sV', 'sXs', 'sEf', 'sP', 'sView'];
    for (var i = 0; i < ids.length; i++) { $(ids[i]).addEventListener('input', render_sync); $(ids[i]).addEventListener('change', render_sync); }
    render_sync();
  }
  function readSync() {
    return {
      mode: $('sMode').value, Vph: parseFloat($('sV').value), Xs: parseFloat($('sXs').value),
      Ra: 0, Ef: parseFloat($('sEf').value), Pph: parseFloat($('sP').value)
    };
  }
  function render_sync() {
    var p = readSync();
    $('sVL').textContent = p.Vph.toFixed(0); $('sXsL').textContent = p.Xs.toFixed(2);
    $('sEfL').textContent = p.Ef.toFixed(0); $('sPL').textContent = p.Pph.toFixed(0);

    var r = syncSolve(p);
    var svg = clearStage();
    var view = $('sView').value;

    if (view === 'vcurve') {
      // V-curve: |Ia| vs Ef at constant power, for three power levels
      var maxIa = 0;
      var levels = [[p.Pph * 0.4, '#86efac'], [p.Pph, '#67e8f9'], [Math.min(p.Pph * 1.6, 15000), '#fbbf24']];
      var L, ef, curves = [];
      for (var li = 0; li < levels.length; li++) {
        var cur = [];
        for (ef = 120; ef <= 450; ef += 2) {
          var pp = { mode: p.mode, Vph: p.Vph, Xs: p.Xs, Ra: 0, Ef: ef, Pph: levels[li][0] };
          var rr = syncSolve(pp);
          if (rr.sinD > -1 && rr.sinD < 1 && isFinite(rr.Iamag)) {
            cur.push([ef, rr.Iamag, rr.lead]);
            if (rr.Iamag > maxIa && rr.Iamag < 400) { maxIa = rr.Iamag; }
          }
        }
        curves.push(cur);
      }
      var pl = makePlot(svg, 100, 70, 690, 380, 120, 450, 0, maxIa * 1.1 || 40, 'Excitation EMF Ef (V)  -> field current', 'Armature current |Ia| (A)', { nx: 5, ny: 5, xd: 0, yd: 0 });
      for (var ci = 0; ci < curves.length; ci++) {
        var pts = [];
        for (var k = 0; k < curves[ci].length; k++) {
          if (curves[ci][k][1] < maxIa * 1.1) { pts.push([pl.gx(curves[ci][k][0]), pl.gy(curves[ci][k][1])]); }
        }
        add(svg, path(polyPath(pts), levels[ci][1], 2.2));
      }
      // operating point
      add(svg, circle(pl.gx(p.Ef), pl.gy(clamp(r.Iamag, 0, maxIa * 1.1)), 5, { fill: '#fca5a5', stroke: '#0a0a0c', 'stroke-width': 1.5 }));
      // unity-pf locus: minimum of each V curve roughly where Ef makes Q=0
      add(svg, txt('under-excited (lagging gen / leading motor)', pl.gx(120) + 6, pl.oy + 16, '#9aa6b6', 9.5));
      add(svg, txt('over-excited', pl.gx(450) - 6, pl.oy + 16, '#9aa6b6', 9.5, 'end'));
      legend([['P = ' + fmt(levels[0][0], 0) + ' W', '#86efac'], ['P = ' + fmt(levels[1][0], 0) + ' W', '#67e8f9'], ['P = ' + fmt(levels[2][0], 0) + ' W', '#fbbf24'], ['operating', '#fca5a5']]);
      $('stageCap').textContent = 'Each V-curve is U-shaped: armature current is minimum (unity pf) at one excitation and rises on either side as the machine supplies/absorbs reactive power. Higher load shifts the curve up.';
    } else {
      // phasor diagram
      add(svg, txt((p.mode === 'motor' ? 'Synchronous motor' : 'Alternator') + ' phasor diagram (V as reference)', 450, 26, '#cfd6da', 13, 'middle', "'Cormorant Garamond', serif"));
      var ox = 270, oy = 300;
      var sc = 280 / Math.max(p.Vph, p.Ef, 1);
      add(svg, line(40, oy, 860, oy, '#222633', 1));
      add(svg, line(ox, 50, ox, 500, '#222633', 1));
      // V along +x
      arrow(svg, ox, oy, p.Vph * sc, 0, '#67e8f9', 2.4, 'V', 16);
      // Ia
      var iaAng = carg(r.Ia);
      var iaScale = 280 / Math.max(r.Iamag, 1) * 0.5;
      arrow(svg, ox, oy, r.Ia.re * iaScale, -r.Ia.im * iaScale, '#fbbf24', 2.2, 'Ia', 16);
      // jXs*Ia drop
      var jdrop = cmul(r.Ia, cx(0, p.Xs));
      // E = V + jXsIa (gen) ; for motor V = E + jXsIa -> E = V - jXsIa
      var tipx = ox + p.Vph * sc, tipy = oy;
      if (p.mode === 'motor') {
        // draw -jXsIa from V tip to reach E
        arrow(svg, tipx, tipy, -jdrop.re * sc, jdrop.im * sc, '#86efac', 1.8, 'jXs.Ia', 12);
      } else {
        arrow(svg, tipx, tipy, jdrop.re * sc, -jdrop.im * sc, '#86efac', 1.8, 'jXs.Ia', 12);
      }
      // E phasor
      var ex = ox + r.E.re * sc, ey = oy - r.E.im * sc;
      add(svg, line(ox, oy, ex, ey, '#a78bfa', 2.4));
      add(svg, txt('E', ex + (r.E.re >= 0 ? 6 : -6), ey - 6, '#a78bfa', 11, r.E.re >= 0 ? 'start' : 'end'));
      // delta arc label
      add(svg, txt('delta = ' + fmt(r.delta * DEG, 1) + ' deg', ox + 20, oy - 14, '#cfd6da', 10));
      legend([['V terminal', '#67e8f9'], ['Ia armature', '#fbbf24'], ['jXs.Ia drop', '#86efac'], ['E excitation emf', '#a78bfa']]);
      $('stageCap').textContent = 'E = V + jXs.Ia (generator) or V = E + jXs.Ia (motor). The load angle delta between E and V sets the power P = V.E.sin(delta)/Xs; excitation Ef sets the reactive power and pf.';
    }

    var modeWord = p.mode === 'motor' ? 'absorbed' : 'delivered';
    var pfType = r.lead ? 'leading' : 'lagging';
    bigReadout([['Load angle delta', fmt(r.delta * DEG, 1) + ' deg'], ['Power factor', fmt(r.pf, 3) + ' ' + pfType]]);
    resTable([
      ['Terminal Vph', fmt(p.Vph, 1) + ' V', 'vc'],
      ['Excitation Ef', fmt(p.Ef, 1) + ' V', 'vp'],
      ['Load angle delta', fmt(r.delta * DEG, 2) + ' deg', 'vc'],
      ['Armature current Ia', fmt(r.Iamag, 2) + ' A', 'va'],
      ['Power factor', fmt(r.pf, 3) + ' ' + pfType, 'vp'],
      ['Real power (per ph)', fmt(p.Pph, 0) + ' W ' + modeWord, 'vc'],
      ['Reactive Q (per ph)', fmt(r.Q, 0) + ' VAr', 'vr'],
      ['Pull-out limit P_max', fmt(p.Vph * p.Ef / p.Xs, 0) + ' W', 'vp']
    ]);
  }

  // ==================================================================
  // EXP 5 — THREE-PHASE FUNDAMENTALS (star / delta)
  // ==================================================================
  // Balanced 3-phase source feeding a balanced load in star or delta.
  // Computes phase/line voltages and currents and total power with the
  // exact relations and an animated three-phase waveform.
  function threePhaseSolve(p) {
    // p: Vline (line-line rms), connection (star/delta), Rload, Xload (per phase), f
    var out = {};
    var Vline = p.Vline;
    var Zph = cx(p.R, p.X);
    var Zmag = cabs(Zph);
    var phi = carg(Zph);
    out.phi = phi; out.pf = Math.cos(phi);
    if (p.conn === 'star') {
      var Vphase = Vline / SQRT3;       // phase voltage = line/sqrt3
      var Iphase = Vphase / Zmag;        // = Iline
      out.Vphase = Vphase; out.Vline = Vline;
      out.Iphase = Iphase; out.Iline = Iphase;
    } else {
      var VphaseD = Vline;               // phase voltage = line voltage
      var IphaseD = VphaseD / Zmag;
      var IlineD = SQRT3 * IphaseD;      // line current = sqrt3 * phase
      out.Vphase = VphaseD; out.Vline = Vline;
      out.Iphase = IphaseD; out.Iline = IlineD;
    }
    // total power identical formula
    out.Ptotal = SQRT3 * Vline * out.Iline * out.pf;
    out.Qtotal = SQRT3 * Vline * out.Iline * Math.sin(phi);
    out.Stotal = SQRT3 * Vline * out.Iline;
    // per-phase
    out.Pphase = out.Vphase * out.Iphase * out.pf;
    return out;
  }
  function controls_3ph() {
    return '' +
      '<div class="mc-panel">' +
        '<h3>Source &amp; connection</h3>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Line voltage VL (V) <b id="tVL" class="mc-val">400</b></span><input type="range" id="tV" min="110" max="690" step="10" value="400"></div>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Frequency (Hz) <b id="tFL" class="mc-val">50</b></span><input type="range" id="tF" min="25" max="60" step="1" value="50"></div>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Load connection</span><select id="tConn"><option value="star">Star (Y / wye)</option><option value="delta">Delta (mesh)</option></select></div>' +
      '</div>' +
      '<div class="mc-panel">' +
        '<h3>Balanced load (per phase)</h3>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Resistance R (ohm) <b id="tRL" class="mc-val">8.0</b></span><input type="range" id="tR" min="1" max="50" step="0.5" value="8"></div>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">Reactance X (ohm) <b id="tXL" class="mc-val">6.0</b></span><input type="range" id="tX" min="0" max="50" step="0.5" value="6"></div>' +
        '<div class="mc-ctrlrow"><span class="mc-lbl">View</span><select id="tView"><option value="wave">Three-phase waveforms</option><option value="phasor">Voltage phasors</option></select></div>' +
        '<div class="mc-btnrow"><button class="mc-btn" id="tPlay">Pause</button><button class="mc-btn ghost" id="tReset">Reset</button></div>' +
      '</div>';
  }
  var tphTime = 0, tphPlaying = true;
  function wire_3ph() {
    var ids = ['tV', 'tF', 'tConn', 'tR', 'tX', 'tView'];
    for (var i = 0; i < ids.length; i++) { $(ids[i]).addEventListener('input', render_3ph); $(ids[i]).addEventListener('change', render_3ph); }
    $('tPlay').addEventListener('click', function () {
      tphPlaying = !tphPlaying;
      $('tPlay').textContent = tphPlaying ? 'Pause' : 'Play';
      if (tphPlaying) { anim3ph(); }
    });
    $('tReset').addEventListener('click', function () { tphTime = 0; render_3ph(); });
    tphPlaying = true; $('tPlay').textContent = 'Pause';
    render_3ph();
    anim3ph();
  }
  function anim3ph() {
    stopAnim();
    function step() {
      if (currentExp !== 4 || currentSec !== 'sim' || !tphPlaying) { animHandle = null; return; }
      if ($('tView') && $('tView').value === 'wave') {
        tphTime += 0.016;
        render_3ph();
      }
      animHandle = requestAnimationFrame(step);
    }
    animHandle = requestAnimationFrame(step);
  }
  function read3ph() {
    return {
      Vline: parseFloat($('tV').value), f: parseFloat($('tF').value), conn: $('tConn').value,
      R: parseFloat($('tR').value), X: parseFloat($('tX').value)
    };
  }
  function render_3ph() {
    var p = read3ph();
    $('tVL').textContent = p.Vline.toFixed(0); $('tFL').textContent = p.f.toFixed(0);
    $('tRL').textContent = p.R.toFixed(1); $('tXL').textContent = p.X.toFixed(1);

    var r = threePhaseSolve(p);
    var svg = clearStage();
    var view = $('tView').value;

    if (view === 'phasor') {
      add(svg, txt('Balanced three-phase voltage phasors (' + (p.conn === 'star' ? 'star' : 'delta') + ')', 450, 26, '#cfd6da', 13, 'middle', "'Cormorant Garamond', serif"));
      var ox = 360, oy = 290;
      var sc = 200 / r.Vphase;
      add(svg, circle(ox, oy, 200, { fill: 'none', stroke: '#1a1a25', 'stroke-width': 1 }));
      add(svg, line(ox - 230, oy, ox + 230, oy, '#222633', 1));
      add(svg, line(ox, oy - 230, ox, oy + 230, '#222633', 1));
      var cols = ['#fca5a5', '#fbbf24', '#86efac'];
      var labels = ['Va', 'Vb', 'Vc'];
      var a;
      // phase voltages at 0, -120, -240 (i.e. 120 apart)
      for (a = 0; a < 3; a++) {
        var ang = (a * -120) * RAD;     // screen: positive math angle is up if we negate y
        var dx = r.Vphase * sc * Math.cos(ang);
        var dy = -r.Vphase * sc * Math.sin(ang);
        arrow(svg, ox, oy, dx, dy, cols[a], 2.4, labels[a], 14);
      }
      // line voltage Vab = Va - Vb shown for star
      if (p.conn === 'star') {
        var Va = polar(r.Vphase, 0), Vb = polar(r.Vphase, -120 * RAD);
        var Vab = csub(Va, Vb);
        arrow(svg, ox, oy, Vab.re * sc, -Vab.im * sc, '#a78bfa', 1.8, 'Vab=Va-Vb', 12);
        add(svg, txt('|Vab| = sqrt3 . |Va| = ' + fmt(cabs(Vab), 1) + ' V', ox - 230, oy + 222, '#a78bfa', 10));
      } else {
        add(svg, txt('In delta, phase voltage = line voltage = ' + fmt(r.Vline, 1) + ' V', ox - 230, oy + 222, '#67e8f9', 10));
      }
      legend([['Va', '#fca5a5'], ['Vb', '#fbbf24'], ['Vc', '#86efac'], ['Line voltage Vab', '#a78bfa']]);
      $('stageCap').textContent = 'Three equal phasors 120 degrees apart. The line voltage is the phasor difference of two phase voltages; its magnitude is sqrt(3) times the phase voltage and it leads by 30 degrees.';
    } else {
      // three-phase instantaneous waveforms
      var pl = makePlot(svg, 95, 70, 700, 380, 0, 2, -r.Vphase * 1.5, r.Vphase * 1.5, 'Time (cycles)', 'Phase voltage (V instantaneous)', { nx: 8, ny: 6, xd: 2, yd: 0 });
      var cols2 = ['#fca5a5', '#fbbf24', '#86efac'];
      var Vpk = r.Vphase * Math.sqrt(2);
      var ph, ptsW;
      for (ph = 0; ph < 3; ph++) {
        ptsW = [];
        for (var tt = 0; tt <= 2.0001; tt += 0.005) {
          var theta = 2 * Math.PI * tt + tphTime * 2 * Math.PI * 0.7 - ph * 2 * Math.PI / 3;
          var v = Vpk * Math.sin(theta);
          ptsW.push([pl.gx(tt), pl.gy(clamp(v, -r.Vphase * 1.5, r.Vphase * 1.5))]);
        }
        add(svg, path(polyPath(ptsW), cols2[ph], 2.0));
      }
      // moving cursor markers showing instantaneous values
      var t0 = (tphTime * 0.7) % 1;
      // also show sum (should be ~0)
      var sumPts = [];
      for (var ts = 0; ts <= 2.0001; ts += 0.01) {
        var th0 = 2 * Math.PI * ts + tphTime * 2 * Math.PI * 0.7;
        var s = Vpk * (Math.sin(th0) + Math.sin(th0 - 2 * Math.PI / 3) + Math.sin(th0 - 4 * Math.PI / 3));
        sumPts.push([pl.gx(ts), pl.gy(clamp(s, -r.Vphase * 1.5, r.Vphase * 1.5))]);
      }
      add(svg, path(polyPath(sumPts), '#a78bfa', 1.4, 'none', '4 4'));
      legend([['Va', '#fca5a5'], ['Vb', '#fbbf24'], ['Vc', '#86efac'], ['sum = 0', '#a78bfa']]);
      $('stageCap').textContent = 'Three sinusoids of equal amplitude, 120 degrees apart. At every instant they sum to zero (purple dashed) — the basis of the neutral carrying no current in a balanced load.';
    }

    bigReadout([['Line current', fmt(r.Iline, 2) + ' A'], ['Total power', fmt(r.Ptotal, 0) + ' W']]);
    resTable([
      ['Connection', p.conn === 'star' ? 'STAR (Y)' : 'DELTA', 'vc'],
      ['Line voltage VL', fmt(r.Vline, 1) + ' V', 'vc'],
      ['Phase voltage Vph', fmt(r.Vphase, 1) + ' V', 'vp'],
      ['Phase current Iph', fmt(r.Iphase, 2) + ' A', 'va'],
      ['Line current IL', fmt(r.Iline, 2) + ' A', 'va'],
      ['Power factor', fmt(r.pf, 3), 'vp'],
      ['Total real P', fmt(r.Ptotal, 0) + ' W', 'vc'],
      ['Total reactive Q', fmt(r.Qtotal, 0) + ' VAr', 'vr'],
      ['Apparent power S', fmt(r.Stotal, 0) + ' VA', 'vc']
    ]);
  }

  // ==================================================================
  // PART 5 — EXPERIMENT DEFINITIONS
  // ==================================================================
  var EXPS = [
    {
      title: 'Single-phase transformer',
      sub: 'Turns ratio, equivalent circuit, voltage regulation & efficiency vs load; OC/SC test idea',
      aim: '<p>To study a single-phase transformer through its equivalent circuit: to relate the turns ratio to the voltage and current transformation, to determine the voltage regulation for lagging, unity and leading power factors, and to compute the efficiency as a function of load, identifying the load at which efficiency is maximum.</p>',
      theory: '<p>An ideal transformer relates primary and secondary by the turns ratio a = N1/N2 = V1/V2 = I2/I1, transferring power without loss. A real transformer is modelled by an <b>equivalent circuit</b>: a series winding impedance R1 + jX1 on the primary and R2 + jX2 on the secondary (which can be referred to one side by the factor a-squared), together with a shunt magnetising branch consisting of the core-loss resistance Rc in parallel with the magnetising reactance Xm. The two laboratory tests that find these parameters are the <b>open-circuit (OC) test</b> — performed at rated voltage with the secondary open, it draws only the small no-load current and measures the constant <b>core (iron) loss</b> Pi = V-squared / Rc — and the <b>short-circuit (SC) test</b> — performed at reduced voltage with the secondary shorted, it circulates rated current and measures the full-load <b>copper loss</b> and the equivalent series impedance Req + jXeq. The terminal voltage under load is E2 = V2 + I2(Req + jXeq); the voltage regulation is the per-unit drop from no-load to full-load. Efficiency is the ratio of output to input power; since copper loss varies as the load current squared while core loss is constant, efficiency is maximum when the variable copper loss equals the fixed core loss.</p>',
      eqs: 'Turns ratio:  <span class="k">a = N1/N2 = V1/V2 = I2/I1</span>\nReferred impedance:  Z(ref prim) = a^2 . Z(sec)\nLoad emf:  E2 = V2 + I2 (Req + jXeq)\nRegulation:  %Reg = (Vno-load - Vfull-load) / Vno-load x 100\nCore loss (OC test):  Pi = V1^2 / Rc   (constant)\nCopper loss (SC test):  Pcu = I2^2 . Req   (~ load^2)\nEfficiency:  eta = Pout / (Pout + Pcu + Pi)\nMax efficiency at load fraction:  x* = sqrt(Pi / Pcu,rated)',
      proc: [
        'Set the primary rated voltage V1, the rated VA and the turns N1, N2; read the turns ratio a and the rated secondary voltage.',
        'Enter the equivalent-circuit parameters (R1, X1, R2, X2 and the core resistance Rc) as found from the OC and SC tests.',
        'Choose the load power factor and whether it is lagging or leading.',
        'Sweep the load fraction x and read the terminal voltage, regulation and efficiency.',
        'Open the "Regulation vs load" view and compare the three power-factor curves.',
        'Open the "Efficiency vs load" view; locate the operating point and the maximum-efficiency load fraction x*.',
        'Open the phasor diagram and identify the I.R and I.X drops that build E2 from V2.'
      ],
      refs: [
        '<b>Fitzgerald, Kingsley & Umans.</b> Electric Machinery, 7th ed. McGraw-Hill, Ch. 2 (transformers).',
        '<b>Chapman, S. J.</b> Electric Machinery Fundamentals, 5th ed. McGraw-Hill, Ch. 2 — equivalent circuit, OC/SC tests, regulation & efficiency.',
        '<b>Say, M. G.</b> The Performance and Design of Alternating Current Machines, 3rd ed. Pitman.'
      ],
      quiz: [
        { q: 'For an ideal transformer with N1/N2 = 2, the secondary current relative to the primary current is:', opts: ['Half', 'Double', 'Equal', 'Four times'], correct: 1, expl: 'I2/I1 = N1/N2 = a. With a = 2 the secondary current is twice the primary current (the secondary is the low-voltage, high-current side).' },
        { q: 'The open-circuit test on a transformer is used mainly to find:', opts: ['The copper loss and series impedance', 'The core (iron) loss and the magnetising branch', 'The turns ratio only', 'The temperature rise'], correct: 1, expl: 'At rated voltage with the secondary open, the OC test measures the constant core loss and the shunt magnetising parameters Rc and Xm.' },
        { q: 'The efficiency of a transformer is maximum when:', opts: ['The load is rated', 'Copper loss equals core loss', 'Core loss is zero', 'The power factor is unity'], correct: 1, expl: 'Variable copper loss equals constant core loss at x* = sqrt(Pi/Pcu,rated); there the loss per unit output is minimised.' },
        { q: 'For a load with a leading power factor, the voltage regulation can be:', opts: ['Always positive and large', 'Zero or negative (terminal voltage rises)', 'Independent of pf', 'Always 100%'], correct: 1, expl: 'A leading (capacitive) load can make the terminal voltage rise above no-load, giving zero or negative regulation.' }
      ],
      controls: controls_xfmr, wire: wire_xfmr
    },
    {
      title: 'DC machine',
      sub: 'Motor & generator characteristics, back-EMF, torque-speed and the magnetisation curve',
      aim: '<p>To study a separately-excited / shunt DC machine in both motor and generator operation: to obtain the back-EMF and torque relations, the torque-speed characteristic of the motor, the external (load) characteristic of the generator, and the open-circuit magnetisation curve showing magnetic saturation.</p>',
      theory: '<p>In a DC machine the armature conductors moving through the field flux phi generate a back-EMF E = k.phi.w, where k is the machine constant and w the angular speed; the same constant gives the electromagnetic torque T = k.phi.Ia from the armature current Ia. In a <b>motor</b> the supply drives current against the back-EMF: V = E + Ia.Ra, so the speed is N = (V - Ia.Ra)/(k.phi). Because the armature-resistance drop is small, the shunt motor speed falls only slightly as load (hence Ia) rises — a nearly constant-speed characteristic. In a <b>generator</b> the prime mover turns the armature and E = k.phi.w drives current into the load; the terminal voltage droops as Vt = E - Ia.Ra. The flux itself depends on the field current through the <b>magnetisation (open-circuit) characteristic</b>: at low field the flux rises almost linearly along the air-gap line, but as the iron saturates the curve flattens, so additional field current produces little extra flux. Field weakening (reducing phi) is therefore used to run the motor above base speed.</p>',
      eqs: 'Back-EMF:  <span class="k">E = k phi w</span>\nTorque:  T = k phi Ia\nMotor:  V = E + Ia Ra   ->  N = (V - Ia Ra) / (k phi)\nGenerator:  Vt = E - Ia Ra,   E = k phi w\nMagnetisation:  phi = phi_sat . tanh(If / I_knee)  (saturating)\nInput (motor):  Pin = V Ia ;  Output:  Pmech = T w\nEfficiency:  eta = Pout / Pin',
      proc: [
        'Select motor or generator operation.',
        'Set the terminal voltage V, armature resistance Ra and the machine constant k.phi(max).',
        'Set the field current If; the saturating magnetisation model converts it to per-unit flux.',
        'For the motor: vary the load torque TL and read the operating speed, armature current and efficiency.',
        'For the generator: set the drive speed and load resistance and read the terminal voltage and current.',
        'Open the "Torque-speed / load curve" view to see the characteristic; open the "Magnetisation curve" view to see saturation and the air-gap line.'
      ],
      refs: [
        '<b>Chapman, S. J.</b> Electric Machinery Fundamentals, 5th ed. McGraw-Hill, Ch. 8–9 (DC motors and generators).',
        '<b>Fitzgerald, Kingsley & Umans.</b> Electric Machinery, 7th ed. McGraw-Hill, Ch. 7 (DC machines).',
        '<b>Bimbhra, P. S.</b> Electrical Machinery, 7th ed. Khanna Publishers — DC machine characteristics & magnetisation.'
      ],
      quiz: [
        { q: 'The back-EMF of a DC motor is proportional to:', opts: ['Armature current only', 'Flux times speed (k.phi.w)', 'Terminal voltage squared', 'Armature resistance'], correct: 1, expl: 'E = k.phi.w — the back-EMF rises with both the field flux and the rotational speed.' },
        { q: 'As load torque on a shunt DC motor increases, the speed:', opts: ['Rises sharply', 'Falls slightly because of the Ia.Ra drop', 'Stays exactly constant', 'Reverses'], correct: 1, expl: 'N = (V - Ia.Ra)/(k.phi); more torque means more Ia and a slightly larger drop, so the speed droops a little.' },
        { q: 'The DC machine magnetisation curve flattens at high field current because:', opts: ['The armature opens', 'The magnetic core saturates', 'The speed drops', 'Ra increases'], correct: 1, expl: 'Once the iron saturates, extra field current produces little extra flux, so the EMF curve bends over.' },
        { q: 'To run a DC motor above its base (rated) speed, one usually:', opts: ['Increases the field flux', 'Weakens the field flux', 'Increases Ra', 'Reduces the supply voltage'], correct: 1, expl: 'Field weakening lowers phi; since N is proportional to 1/phi for a fixed back-EMF, the speed rises above base.' }
      ],
      controls: controls_dc, wire: wire_dc
    },
    {
      title: 'Three-phase induction motor',
      sub: 'Slip, per-phase equivalent circuit, torque-slip curve with starting / max / full-load torque',
      aim: '<p>To analyse a three-phase induction motor from its per-phase equivalent circuit: to define slip, to compute the air-gap power and developed torque, and to construct the torque-slip characteristic identifying the starting torque, the breakdown (maximum) torque and the slip at which it occurs, and the stable full-load operating region.</p>',
      theory: '<p>The stator winding sets up a rotating field at the synchronous speed ns = 120 f / P. The rotor turns at nr, slightly slower; the fractional lag is the <b>slip</b> s = (ns - nr)/ns. In the <b>per-phase equivalent circuit</b> the stator branch R1 + jX1 feeds a magnetising reactance jXm in parallel with the referred rotor branch R2/s + jX2, where the slip-dependent term R2/s represents both the rotor copper loss (R2) and the converted mechanical power (R2(1-s)/s). The <b>air-gap power</b> transferred across the gap is Pag = 3.I2-squared.(R2/s); of this, a fraction s is lost as rotor copper loss and the remaining (1 - s) becomes gross mechanical power. The <b>developed torque</b> is T = Pag/ws, where ws is the synchronous angular speed. The torque is zero at synchronous speed (s = 0), rises to a peak <b>breakdown torque</b> at the slip s = R2 / sqrt(R1-squared + (X1 + X2)-squared), and at standstill (s = 1) gives the <b>starting torque</b>. The machine runs stably only on the low-slip side of the breakdown point. At standstill the small R2/s makes the starting current several times the rated value, motivating star-delta or soft starting.</p>',
      eqs: 'Sync speed:  ns = 120 f / P ;  Slip:  <span class="k">s = (ns - nr) / ns</span>\nRotor branch:  R2/s + jX2  (referred to stator)\nAir-gap power:  Pag = 3 I2^2 (R2/s)\nMech power:  Pmech = (1 - s) Pag ;  Rotor cu loss = s Pag\nTorque:  T = Pag / ws ,  ws = 2 pi ns / 60\nMax-torque slip:  s_mT = R2 / sqrt(R1^2 + (X1 + X2)^2)\nStarting torque at s = 1 ;  inrush current is large',
      proc: [
        'Set the line voltage, supply frequency and the number of poles; read the synchronous speed.',
        'Enter the per-phase equivalent-circuit parameters R1, X1, R2, X2 and the magnetising reactance Xm.',
        'Set the operating slip s and read the developed torque, currents, power and efficiency.',
        'Open the "Torque-slip curve" view; identify the starting torque (s = 1), the breakdown torque and its slip, and the operating point.',
        'Open the "Current vs slip" view to see the large starting (inrush) current and how it falls as the motor speeds up.',
        'Vary the rotor resistance R2 and observe how the breakdown torque shifts toward standstill (the basis of rotor-resistance starting).'
      ],
      refs: [
        '<b>Chapman, S. J.</b> Electric Machinery Fundamentals, 5th ed. McGraw-Hill, Ch. 6–7 (induction motors).',
        '<b>Fitzgerald, Kingsley & Umans.</b> Electric Machinery, 7th ed. McGraw-Hill, Ch. 6 (polyphase induction machines).',
        '<b>Krishnan, R.</b> Electric Motor Drives: Modeling, Analysis and Control. Pearson, Ch. 5.'
      ],
      quiz: [
        { q: 'The slip of an induction motor at synchronous speed is:', opts: ['1', '0.5', '0', 'Infinite'], correct: 2, expl: 'At synchronous speed nr = ns, so s = (ns - nr)/ns = 0 — and the developed torque is then zero.' },
        { q: 'The air-gap power Pag of an induction motor splits into:', opts: ['All mechanical power', 'Mechanical power (1-s)Pag and rotor copper loss sPag', 'All copper loss', 'Core loss only'], correct: 1, expl: 'A fraction s of Pag is rotor copper loss and (1 - s) becomes gross mechanical power.' },
        { q: 'The breakdown (maximum) torque of an induction motor occurs at the slip:', opts: ['s = 1 always', 's = R2/sqrt(R1^2 + (X1+X2)^2)', 's = 0', 's = X2/R2'], correct: 1, expl: 'Maximising T with respect to s gives s_mT = R2/sqrt(R1^2 + (X1+X2)^2).' },
        { q: 'Increasing the rotor resistance R2 (e.g. external resistance) moves the maximum torque:', opts: ['To a smaller slip', 'To a larger slip (toward standstill)', 'It does not move', 'To negative slip'], correct: 1, expl: 's_mT is proportional to R2, so adding rotor resistance raises the slip at which peak torque occurs — improving starting torque.' }
      ],
      controls: controls_im, wire: wire_im
    },
    {
      title: 'Synchronous machine',
      sub: 'Phasor diagram for varying excitation & load, and the V-curves',
      aim: '<p>To study a cylindrical-rotor synchronous machine (alternator or motor) through its per-phase phasor diagram: to relate the excitation EMF, terminal voltage and load angle, to see how the power factor changes with excitation, and to construct the characteristic V-curves of armature current versus excitation at constant load.</p>',
      theory: '<p>In a cylindrical-rotor synchronous machine the field winding produces an excitation EMF E (proportional to the field current) and the armature is modelled per phase by the synchronous reactance Xs (combining leakage and armature reaction) in series with a small resistance Ra. With the terminal voltage V as reference, the generator relation is E = V + jXs.Ia and the motor relation is V = E + jXs.Ia. The angle between E and V is the <b>load angle</b> (power angle) delta; the real power transferred is P = (V.E/Xs).sin(delta), so the machine slips out of synchronism (pulls out) if delta exceeds 90 degrees, setting the maximum power P_max = V.E/Xs. At fixed real power, changing the <b>excitation</b> changes only the reactive power: an <b>over-excited</b> machine (large E) supplies reactive power and operates at a leading power factor (generator) or absorbs it (motor), while an <b>under-excited</b> machine operates at a lagging power factor. Plotting the armature current against excitation at constant load traces the U-shaped <b>V-curve</b>, whose minimum is the unity-power-factor point; a family of V-curves is obtained for different load levels.</p>',
      eqs: 'Generator:  <span class="k">E = V + jXs Ia</span>   Motor:  V = E + jXs Ia\nPower:  P = (V E / Xs) sin(delta)   per phase\nPull-out power:  P_max = V E / Xs   (at delta = 90 deg)\nReactive power:  Q = (V E cos(delta) - V^2) / Xs\nOver-excited (E large)  ->  supplies VARs, leading pf (gen)\nUnder-excited (E small)  ->  lagging pf ;  V-curve minimum = unity pf',
      proc: [
        'Select generator or motor operation and set the terminal phase voltage and synchronous reactance Xs.',
        'Set the excitation EMF Ef and the per-phase real power P.',
        'Open the phasor diagram; identify V, Ia, the jXs.Ia drop and the excitation EMF E, and read the load angle delta.',
        'Increase the excitation and watch the armature current swing from lagging through unity to leading power factor.',
        'Open the "V-curves" view; for three load levels see the U-shaped armature-current curves and the unity-pf minima.',
        'Increase the load toward the pull-out limit P_max = V.E/Xs and observe delta approaching 90 degrees.'
      ],
      refs: [
        '<b>Fitzgerald, Kingsley & Umans.</b> Electric Machinery, 7th ed. McGraw-Hill, Ch. 5 (synchronous machines).',
        '<b>Chapman, S. J.</b> Electric Machinery Fundamentals, 5th ed. McGraw-Hill, Ch. 4–5 — phasor diagrams, V-curves, power angle.',
        '<b>Kothari & Nagrath.</b> Electric Machines, 4th ed. McGraw-Hill, Ch. 8.'
      ],
      quiz: [
        { q: 'The real power delivered per phase by a cylindrical-rotor synchronous machine is:', opts: ['V.E.cos(delta)/Xs', 'V.E.sin(delta)/Xs', 'V^2/Xs', 'E^2.Xs'], correct: 1, expl: 'P = (V.E/Xs).sin(delta); it is maximum at the load angle delta = 90 degrees (the pull-out point).' },
        { q: 'An over-excited synchronous generator (large field current) operates at a power factor that is:', opts: ['Lagging', 'Leading', 'Always unity', 'Zero'], correct: 1, expl: 'Over-excitation makes the machine supply reactive power, so the generator runs at a leading power factor.' },
        { q: 'The minimum point of a synchronous-machine V-curve corresponds to:', opts: ['Maximum reactive power', 'Unity power factor', 'Zero excitation', 'Pull-out'], correct: 1, expl: 'At the bottom of the V-curve the reactive component is zero, so the armature current is minimum and the pf is unity.' },
        { q: 'A synchronous machine pulls out of synchronism when the load angle delta:', opts: ['Reaches 0 degrees', 'Exceeds 90 degrees', 'Equals the pf angle', 'Is negative'], correct: 1, expl: 'Beyond delta = 90 degrees the developed power falls with increasing angle, so the machine cannot hold synchronism and pulls out.' }
      ],
      controls: controls_sync, wire: wire_sync
    },
    {
      title: 'Three-phase fundamentals',
      sub: 'Star / delta, line vs phase voltage & current, and three-phase power',
      aim: '<p>To establish the relations between line and phase quantities in balanced three-phase systems for both star (wye) and delta (mesh) connections, and to verify that the total three-phase power has the same form in either connection.</p>',
      theory: '<p>A balanced three-phase supply consists of three sinusoidal voltages of equal magnitude displaced by 120 degrees; at every instant they sum to zero, which is why the neutral of a balanced star load carries no current. In a <b>star (Y) connection</b> the line current equals the phase current, while the line voltage is the phasor difference of two phase voltages and is therefore sqrt(3) times the phase voltage and leads it by 30 degrees: VL = sqrt(3).Vph, IL = Iph. In a <b>delta (mesh) connection</b> the line voltage equals the phase voltage, while each line current is the phasor difference of two phase currents, giving IL = sqrt(3).Iph, VL = Vph. Despite the different distribution of voltage and current, the <b>total power</b> is identical in form: P = sqrt(3).VL.IL.cos(phi), where phi is the load impedance angle. Reactive and apparent power follow as Q = sqrt(3).VL.IL.sin(phi) and S = sqrt(3).VL.IL. A given load draws three times as much power in delta as in star from the same line voltage, which is exploited by the star-delta starter to limit starting current.</p>',
      eqs: 'Star:  <span class="k">VL = sqrt3 . Vph ,  IL = Iph</span>\nDelta:  VL = Vph ,  IL = sqrt3 . Iph\nLoad current:  Iph = Vph / |Z| ,  pf = cos(phi) = R / |Z|\nTotal power:  P = sqrt3 . VL . IL . cos(phi)\nReactive:  Q = sqrt3 . VL . IL . sin(phi)\nApparent:  S = sqrt3 . VL . IL\nP(delta) = 3 . P(star) for the same line voltage & load',
      proc: [
        'Set the line voltage and the supply frequency.',
        'Choose the load connection — star or delta.',
        'Set the per-phase load resistance R and reactance X; the power factor follows from cos(phi) = R/|Z|.',
        'Read the phase and line voltages and currents and confirm the sqrt(3) relations.',
        'Open the "Three-phase waveforms" view and watch the three sinusoids 120 degrees apart sum to zero.',
        'Open the "Voltage phasors" view and see how the line voltage is built as the phasor difference of two phase voltages.',
        'Switch between star and delta for the same load and compare the line current and the total power.'
      ],
      refs: [
        '<b>Irwin & Nelms.</b> Basic Engineering Circuit Analysis, 11th ed. Wiley, Ch. 11 (polyphase circuits).',
        '<b>Sadiku, M.</b> Fundamentals of Electric Circuits, 6th ed. McGraw-Hill, Ch. 12 (three-phase circuits).',
        '<b>Hughes, E.</b> Electrical and Electronic Technology, 12th ed. Pearson, Ch. 32–34.'
      ],
      quiz: [
        { q: 'In a balanced star (Y) connection, the line voltage relative to the phase voltage is:', opts: ['Equal', 'sqrt(3) times larger', 'sqrt(3) times smaller', 'Three times larger'], correct: 1, expl: 'VL = sqrt(3).Vph in star; the line voltage is the phasor difference of two phase voltages and leads by 30 degrees.' },
        { q: 'In a balanced delta connection, the line current relative to the phase current is:', opts: ['Equal', 'sqrt(3) times larger', 'Half', 'Three times larger'], correct: 1, expl: 'IL = sqrt(3).Iph in delta; the line current is the phasor difference of two phase currents.' },
        { q: 'The total three-phase real power, for either star or delta, is:', opts: ['VL.IL.cos(phi)', 'sqrt(3).VL.IL.cos(phi)', '3.VL.IL', 'VL.IL/sqrt(3)'], correct: 1, expl: 'P = sqrt(3).VL.IL.cos(phi) holds for both connections when VL and IL are line quantities.' },
        { q: 'For the same line voltage and load impedance, the power drawn in delta compared with star is:', opts: ['One third', 'Equal', 'Three times', 'sqrt(3) times'], correct: 2, expl: 'In delta each phase sees the full line voltage, so the load draws three times the power it would in star — the basis of the star-delta starter.' }
      ],
      controls: controls_3ph, wire: wire_3ph
    }
  ];

  // ==================================================================
  // PART 6 — SHELL: render experiment list, sections, quiz
  // ==================================================================
  function buildExpList() {
    var nav = $('expList');
    for (var i = 0; i < EXPS.length; i++) {
      (function (idx) {
        var b = document.createElement('button');
        b.className = 'mc-exp' + (idx === 0 ? ' active' : '');
        b.setAttribute('data-exp', idx);
        b.innerHTML = '<span class="num">' + (idx + 1) + '</span><span class="nm">' + EXPS[idx].title + '</span>';
        b.addEventListener('click', function () { selectExp(idx); });
        nav.appendChild(b);
      })(i);
    }
  }

  function selectExp(idx) {
    stopAnim();
    currentExp = idx;
    var ex = EXPS[idx];
    var btns = $('expList').querySelectorAll('.mc-exp');
    for (var i = 0; i < btns.length; i++) { btns[i].classList.toggle('active', i === idx); }

    $('exTitle').innerHTML = (idx + 1) + '. <em>' + ex.title + '</em>';
    $('exSub').textContent = ex.sub;
    $('secAim').innerHTML = ex.aim;
    $('secTheory').innerHTML = ex.theory + '<div class="mc-eqbox">' + ex.eqs.replace(/\n/g, '<br>') + '</div>';

    var procEl = $('secProc');
    procEl.innerHTML = '';
    for (i = 0; i < ex.proc.length; i++) { var li = document.createElement('li'); li.textContent = ex.proc[i]; procEl.appendChild(li); }

    var refEl = $('secRef');
    refEl.innerHTML = '';
    for (i = 0; i < ex.refs.length; i++) { var rli = document.createElement('li'); rli.innerHTML = ex.refs[i]; refEl.appendChild(rli); }

    buildQuiz(ex.quiz);

    $('simControls').innerHTML = ex.controls();
    clearStage();
    $('resTable').innerHTML = '';
    $('bigReadout').innerHTML = '';
    $('stageCap').textContent = '';
    $('stageLegend').innerHTML = '';
    ex.wire();

    showSection(currentSec);
  }

  function buildQuiz(quiz) {
    var host = $('secQuiz');
    host.innerHTML = '';
    for (var i = 0; i < quiz.length; i++) {
      (function (qi) {
        var q = quiz[qi];
        var card = document.createElement('div');
        card.className = 'mc-q';
        var html = '<p class="qt">' + (qi + 1) + '. ' + q.q + '</p>';
        for (var o = 0; o < q.opts.length; o++) {
          html += '<label class="mc-opt" data-opt="' + o + '"><input type="radio" name="q' + qi + '" value="' + o + '"><span>' + q.opts[o] + '</span></label>';
        }
        html += '<button class="mc-btn mc-checkbtn" data-check="' + qi + '">Check answer</button>';
        html += '<div class="mc-expl" id="expl_' + qi + '"></div>';
        card.innerHTML = html;
        host.appendChild(card);
        var btn = card.querySelector('[data-check]');
        btn.addEventListener('click', function () {
          var sel = card.querySelector('input[name="q' + qi + '"]:checked');
          var labels = card.querySelectorAll('.mc-opt');
          for (var k = 0; k < labels.length; k++) { labels[k].classList.remove('correct'); labels[k].classList.remove('wrong'); }
          var expl = card.querySelector('#expl_' + qi);
          if (!sel) {
            expl.className = 'mc-expl show bad';
            expl.textContent = 'Select an option first.';
            return;
          }
          var chosen = parseInt(sel.value, 10);
          labels[q.correct].classList.add('correct');
          if (chosen === q.correct) {
            expl.className = 'mc-expl show good';
            expl.textContent = 'Correct. ' + q.expl;
          } else {
            labels[chosen].classList.add('wrong');
            expl.className = 'mc-expl show bad';
            expl.textContent = 'Not quite. ' + q.expl;
          }
        });
      })(i);
    }
  }

  function showSection(sec) {
    currentSec = sec;
    var tabs = $('secTabs').querySelectorAll('.mc-tab');
    for (var i = 0; i < tabs.length; i++) { tabs[i].classList.toggle('active', tabs[i].getAttribute('data-sec') === sec); }
    var secs = document.querySelectorAll('.mc-sec');
    for (i = 0; i < secs.length; i++) { secs[i].classList.toggle('active', secs[i].getAttribute('data-sec') === sec); }
    // restart the three-phase animation if we re-enter its simulation
    if (sec === 'sim' && currentExp === 4 && tphPlaying) { anim3ph(); }
    if (sec !== 'sim') { stopAnim(); }
  }

  // ==================================================================
  // PART 7 — INIT
  // ==================================================================
  function init() {
    buildExpList();
    var tabs = $('secTabs').querySelectorAll('.mc-tab');
    for (var i = 0; i < tabs.length; i++) {
      tabs[i].addEventListener('click', function () { showSection(this.getAttribute('data-sec')); });
    }
    selectExp(0);
    showSection('aim');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

</BaseLayout>
