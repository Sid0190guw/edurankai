      var served = req.length;
      $('dkSeek').textContent = seek;
      $('dkN').textContent = served;
      $('dkAvg').textContent = served > 0 ? (seek / served).toFixed(1) : '--';
      $('dkStart').textContent = head;
      $('dkPol').textContent = { fcfs: 'FCFS', sstf: 'SSTF', scan: 'SCAN', cscan: 'C-SCAN', look: 'LOOK', clook: 'C-LOOK' }[pol];
      var ord = path.slice(1).join(' &rarr; ');
