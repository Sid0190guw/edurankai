                  <div class="stat"><div class="k">Requests served</div><div class="v purple" id="dkN">0</div></div>
                  <div class="stat"><div class="k">Avg seek / request</div><div class="v green" id="dkAvg">--</div></div>
                  <div class="stat"><div class="k">Head start</div><div class="v" id="dkStart">--</div></div>
                </div>
              </div>
