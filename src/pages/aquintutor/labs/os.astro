    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = COL.bg; ctx.fillRect(0, 0, W, H);
      if (!partitions.length) return;
      var padL = 50, padR = 16, padT = 24, padB = 22;
      var n = partitions.length;
      var gap = 12;
      var colW = (W - padL - padR - gap * (n - 1)) / n;
      var maxSize = 1; for (var i = 0; i < partitions.length; i++) maxSize = Math.max(maxSize, partitions[i].orig);
      var fullH = H - padT - padB;
      ctx.font = '9px Geist Mono, monospace'; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      ctx.fillStyle = COL.cyan; ctx.fillText('KB', 8, padT - 10);
      for (var p = 0; p < partitions.length; p++) {
        var part = partitions[p];
        var x = padL + p * (colW + gap);
        var h = (part.orig / maxSize) * fullH;
        var y = padT + (fullH - h);
        // partition outline
        ctx.strokeStyle = COL.stroke; ctx.lineWidth = 1.5;
        ctx.strokeRect(x, y, colW, h);
        // placements stacked from top
        var oy = y;
        for (var q = 0; q < part.placements.length; q++) {
          var pl = part.placements[q];
          var ph = (pl.size / maxSize) * fullH;
          var idNum = parseInt(pl.pid.slice(1), 10) - 1;
          ctx.fillStyle = PALETTE[idNum % PALETTE.length];
          ctx.globalAlpha = 0.85; ctx.fillRect(x + 1, oy + 1, colW - 2, ph - 1); ctx.globalAlpha = 1;
          ctx.fillStyle = '#0a0a0c'; ctx.font = 'bold 10px Geist Mono, monospace'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
          if (ph > 12) ctx.fillText(pl.pid + ' (' + pl.size + ')', x + colW / 2, oy + ph / 2);
          oy += ph;
        }
        // free remainder (dark)
        var freeH = (part.free / maxSize) * fullH;
        if (freeH > 0.5) {
          ctx.fillStyle = '#15171f'; ctx.fillRect(x + 1, oy + 1, colW - 2, freeH - 1);
          ctx.strokeStyle = '#23262f'; ctx.setLineDash([3, 3]); ctx.strokeRect(x + 1, oy + 1, colW - 2, Math.max(1, freeH - 1)); ctx.setLineDash([]);
          ctx.fillStyle = COL.dim; ctx.font = '9px Geist Mono, monospace'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
          if (freeH > 14) ctx.fillText('free ' + part.free, x + colW / 2, oy + freeH / 2);
        }
        // partition label
        ctx.fillStyle = COL.text; ctx.font = '9px Geist Mono, monospace'; ctx.textAlign = 'center'; ctx.textBaseline = 'top';
        ctx.fillText(part.orig + 'K', x + colW / 2, padT + fullH + 4);
      }
    }

    $('mmHoles').addEventListener('change', reset);
    $('mmProcs').addEventListener('change', reset);
    $('mmStratSel').addEventListener('change', reset);
    $('mmStep').addEventListener('click', function () { if (!busy) { if (pidx === 0) clearLog($('mmLog')); step(); } });
    $('mmRun').addEventListener('click', runAll);
    $('mmReset').addEventListener('click', function () { clearLog($('mmLog')); reset(); });
    $('mmRand').addEventListener('click', function () {
      var nh = rnd(4, 6), holesA = [];
      for (var i = 0; i < nh; i++) holesA.push(rnd(1, 7) * 100);
      var np = rnd(3, 5), pr = [];
      for (var j = 0; j < np; j++) pr.push(rnd(1, 6) * 100 + rnd(0, 99));
      $('mmHoles').value = holesA.join(' '); $('mmProcs').value = pr.join(' ');
      clearLog($('mmLog')); reset();
    });
    bindSpeed('mmSpd', 'mmSpdv', function (v) { spd = v; });

    REDRAW['5'] = function () { ctx = makeCtx(cv, 680, 300); draw(); };
    reset();
  })();

  // ===================================================================
  // EXPERIMENT 6 — PRODUCER-CONSUMER (semaphores)
  // ===================================================================
  (function PC() {
    var cv = $('pcCv'); if (!cv) return;
    var ctx = makeCtx(cv, 680, 240);
    var W = 680, H = 240;
    var N = 5;
    var buffer = [], inP = 0, outP = 0, count = 0;
    var semEmpty = 5, semFull = 0, semMutex = 1;
    var prodPhase = 0, consPhase = 0; // 0=idle ready
    var produced = 0, consumed = 0, nextItem = 1;
    var auto = false, spd = 5, autoTimer = null;

    // phases: producer 0 idle, 1 got empty, 2 got mutex(enqueued), done->idle
    var PROD_STATES = ['idle', 'wait(empty)', 'wait(mutex)+enqueue', 'signal(mutex)', 'signal(full)'];
    var CONS_STATES = ['idle', 'wait(full)', 'wait(mutex)+dequeue', 'signal(mutex)', 'signal(empty)'];

    function reset() {
      N = Math.max(1, Math.min(10, parseInt($('pcN').value, 10) || 5));
      buffer = []; for (var i = 0; i < N; i++) buffer.push(null);
      inP = 0; outP = 0; count = 0;
      semEmpty = N; semFull = 0; semMutex = 1;
      prodPhase = 0; consPhase = 0;
      produced = 0; consumed = 0; nextItem = 1;
      refresh(); draw();
    }

    function producerStep() {
      // sequence: wait(empty) -> wait(mutex) enqueue -> signal(mutex) -> signal(full)
      if (prodPhase === 0) {
        if (semEmpty <= 0) { logTo($('pcLog'), '<span class="no">producer BLOCKED on wait(empty) &mdash; buffer full</span>'); $('pcPState').textContent = 'blocked: wait(empty)'; $('pcPState').style.color = COL.red; return; }
        semEmpty--; prodPhase = 1; logTo($('pcLog'), 'producer wait(empty) &rarr; empty=' + semEmpty);
      } else if (prodPhase === 1) {
        if (semMutex <= 0) { logTo($('pcLog'), '<span class="no">producer BLOCKED on wait(mutex)</span>'); return; }
        semMutex--; buffer[inP] = nextItem; var slot = inP; inP = (inP + 1) % N; count++;
        logTo($('pcLog'), 'producer wait(mutex), enqueue item#' + nextItem + ' &rarr; slot ' + slot);
        nextItem++; prodPhase = 2;
      } else if (prodPhase === 2) {
        semMutex++; prodPhase = 3; logTo($('pcLog'), 'producer signal(mutex) &rarr; mutex=' + semMutex);
      } else if (prodPhase === 3) {
        semFull++; produced++; prodPhase = 0; logTo($('pcLog'), '<span class="ok">producer signal(full) &rarr; full=' + semFull + ', item committed</span>');
      }
      refresh(); draw();
    }

    function consumerStep() {
      if (consPhase === 0) {
        if (semFull <= 0) { logTo($('pcLog'), '<span class="no">consumer BLOCKED on wait(full) &mdash; buffer empty</span>'); $('pcCState').textContent = 'blocked: wait(full)'; $('pcCState').style.color = COL.red; return; }
        semFull--; consPhase = 1; logTo($('pcLog'), 'consumer wait(full) &rarr; full=' + semFull);
      } else if (consPhase === 1) {
        if (semMutex <= 0) { logTo($('pcLog'), '<span class="no">consumer BLOCKED on wait(mutex)</span>'); return; }
        semMutex--; var item = buffer[outP]; buffer[outP] = null; var slot = outP; outP = (outP + 1) % N; count--;
        logTo($('pcLog'), 'consumer wait(mutex), dequeue item#' + item + ' &larr; slot ' + slot);
        consPhase = 2;
      } else if (consPhase === 2) {
        semMutex++; consPhase = 3; logTo($('pcLog'), 'consumer signal(mutex) &rarr; mutex=' + semMutex);
      } else if (consPhase === 3) {
        semEmpty++; consumed++; consPhase = 0; logTo($('pcLog'), '<span class="ok">consumer signal(empty) &rarr; empty=' + semEmpty + ', slot freed</span>');
      }
      refresh(); draw();
    }

    function refresh() {
      $('pcEmpty').textContent = semEmpty;
      $('pcFull').textContent = semFull;
      $('pcMutex').textContent = semMutex;
      $('pcCounts').textContent = produced + ' / ' + consumed;
      var pst = PROD_STATES[prodPhase] || 'idle';
      var cst = CONS_STATES[consPhase] || 'idle';
      $('pcPState').textContent = pst; $('pcPState').style.color = prodPhase === 0 ? COL.cyan : COL.green;
      $('pcCState').textContent = cst; $('pcCState').style.color = consPhase === 0 ? COL.amber : COL.purple;
      var inCS = (semMutex === 0);
      var invHolds = (!inCS) ? (semEmpty + semFull === N) : true;
      $('pcInv').innerHTML = 'invariant empty + full = N : ' + semEmpty + ' + ' + semFull + ' = ' + (semEmpty + semFull) + (inCS ? ' (a thread is inside the critical section)' : (invHolds ? ' = N, holds' : ' &ne; N'));
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = COL.bg; ctx.fillRect(0, 0, W, H);
      var padL = 30, padR = 30, top = 70;
      var slotW = Math.min(70, (W - padL - padR) / N);
      var totalW = slotW * N;
      var startX = (W - totalW) / 2;
      var sh = 56;
      ctx.fillStyle = COL.cyan; ctx.font = 'bold 9px Geist Mono, monospace'; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
      ctx.fillText('BOUNDED CIRCULAR BUFFER (N = ' + N + ')', startX, 18);
      for (var i = 0; i < N; i++) {
        var x = startX + i * slotW;
        ctx.strokeStyle = COL.stroke; ctx.lineWidth = 1.5;
        ctx.strokeRect(x, top, slotW - 4, sh);
        if (buffer[i] !== null && buffer[i] !== undefined) {
          ctx.fillStyle = 'rgba(134,239,172,0.18)'; ctx.fillRect(x + 1, top + 1, slotW - 6, sh - 2);
          ctx.fillStyle = COL.green; ctx.font = 'bold 14px Geist Mono, monospace'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
          ctx.fillText('#' + buffer[i], x + (slotW - 4) / 2, top + sh / 2);
        } else {
          ctx.fillStyle = COL.dim; ctx.font = '10px Geist Mono, monospace'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
          ctx.fillText('empty', x + (slotW - 4) / 2, top + sh / 2);
        }
        ctx.fillStyle = COL.dim; ctx.font = '9px Geist Mono, monospace'; ctx.textAlign = 'center'; ctx.textBaseline = 'top';
        ctx.fillText(String(i), x + (slotW - 4) / 2, top + sh + 5);
        // in / out pointers
        if (i === inP) { ctx.fillStyle = COL.green; ctx.font = 'bold 9px Geist Mono, monospace'; ctx.fillText('in', x + (slotW - 4) / 2, top - 16); }
        if (i === outP) { ctx.fillStyle = COL.amber; ctx.font = 'bold 9px Geist Mono, monospace'; ctx.fillText('out', x + (slotW - 4) / 2, top - 28); }
      }
      // semaphore bars
      var by = top + sh + 30;
      function bar(label, val, maxv, color, yy) {
        ctx.fillStyle = COL.dim; ctx.font = '9px Geist Mono, monospace'; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
        ctx.fillText(label, startX, yy);
        var bx = startX + 80, bw = 200;
        ctx.strokeStyle = COL.grid; ctx.strokeRect(bx, yy - 6, bw, 12);
        ctx.fillStyle = color; var fillW = maxv > 0 ? (val / maxv) * bw : 0;
        ctx.fillRect(bx, yy - 6, Math.max(0, fillW), 12);
        ctx.fillStyle = COL.text; ctx.font = 'bold 10px Geist Mono, monospace'; ctx.textAlign = 'left';
        ctx.fillText(String(val), bx + bw + 10, yy);
      }
      bar('empty', semEmpty, N, COL.green, by);
      bar('full', semFull, N, COL.amber, by + 20);
      bar('mutex', semMutex, 1, COL.purple, by + 40);
    }

    function autoTick() {
      if (!auto) return;
      // simple interleave: if producer can make progress favour filling, else consume
      var act;
      if (prodPhase !== 0) act = 'p';
      else if (consPhase !== 0) act = 'c';
      else {
        var canProd = semEmpty > 0, canCons = semFull > 0;
        if (canProd && canCons) act = (Math.random() < 0.5 ? 'p' : 'c');
        else if (canProd) act = 'p';
        else if (canCons) act = 'c';
        else act = 'p';
      }
      if (act === 'p') producerStep(); else consumerStep();
      autoTimer = setTimeout(autoTick, delayFor(spd));
    }

    $('pcN').addEventListener('change', reset);
    $('pcProd').addEventListener('click', function () { auto = false; producerStep(); });
    $('pcCons').addEventListener('click', function () { auto = false; consumerStep(); });
    $('pcAuto').addEventListener('click', function () { if (auto) return; auto = true; autoTick(); });
    $('pcStop').addEventListener('click', function () { auto = false; if (autoTimer) clearTimeout(autoTimer); });
    $('pcReset').addEventListener('click', function () { auto = false; if (autoTimer) clearTimeout(autoTimer); clearLog($('pcLog')); reset(); });
    bindSpeed('pcSpd', 'pcSpdv', function (v) { spd = v; });

    REDRAW['6'] = function () { ctx = makeCtx(cv, 680, 240); draw(); };
    reset();
  })();

  // ===================================================================
  // SELF-ASSESSMENT QUIZZES (Check button per question)
  // ===================================================================
  var QUIZZES = {
    '1': [
      { q: 'Which scheduling policy minimises the average waiting time when all jobs are available at time zero?',
        o: ['FCFS', 'Round-Robin', 'Shortest-Job-First (SJF)', 'Priority'], a: 2,
        e: 'SJF is provably optimal for minimum average waiting time among non-preemptive policies.' },
      { q: 'The convoy effect, where short jobs wait behind one long job, is characteristic of:',
        o: ['SRTF', 'FCFS', 'Round-Robin', 'SJF'], a: 1,
        e: 'FCFS runs in arrival order, so a long early job forces every later short job to wait.' },
      { q: 'Turnaround time of a process is defined as:',
        o: ['Burst minus arrival', 'Completion minus arrival', 'Completion minus burst', 'Waiting plus response'], a: 1,
        e: 'TAT = completion time minus arrival time; waiting time is then TAT minus burst.' },
      { q: 'Increasing the Round-Robin time quantum toward infinity makes it behave like:',
        o: ['SJF', 'SRTF', 'FCFS', 'Priority'], a: 2,
        e: 'With a very large quantum each process runs to completion in arrival order, i.e. FCFS.' }
    ],
    '2': [
      { q: 'A reference to a page that is not resident in any frame causes a:',
        o: ['Cache hit', 'Page fault', 'Segmentation fault', 'TLB hit'], a: 1,
        e: 'A non-resident page must be brought in from backing store; that event is a page fault.' },
      { q: 'Belady\'s anomaly, where more frames can increase faults, occurs with:',
        o: ['LRU', 'Optimal', 'FIFO', 'All of them'], a: 2,
        e: 'FIFO is not a stack algorithm, so adding a frame can paradoxically raise the fault count.' },
      { q: 'The Optimal (MIN) algorithm evicts the page whose next use is:',
        o: ['Most recent in the past', 'Farthest in the future', 'Nearest in the future', 'Least frequent'], a: 1,
        e: 'Belady\'s rule replaces the page that will not be needed for the longest time ahead.' },
      { q: 'If a 20-reference string yields 12 faults, the hit ratio is:',
        o: ['60%', '40%', '12%', '20%'], a: 1,
        e: 'Hits = 20 - 12 = 8, so hit ratio = 8/20 = 0.40 = 40%.' }
    ],
    '3': [
      { q: 'SSTF disk scheduling selects the request that is:',
        o: ['Earliest in the queue', 'Closest to the current head position', 'At the largest cylinder', 'At cylinder zero'], a: 1,
        e: 'Shortest-Seek-Time-First greedily serves the nearest pending cylinder each step.' },
      { q: 'The SCAN algorithm is also known as the:',
        o: ['Banker algorithm', 'Elevator algorithm', 'Round-Robin', 'Clock algorithm'], a: 1,
        e: 'SCAN sweeps to one end then reverses, exactly like a lift servicing floors.' },
      { q: 'Compared with SCAN, C-SCAN mainly improves:',
        o: ['Total seek distance', 'Uniformity of waiting time', 'CPU utilisation', 'Page fault rate'], a: 1,
        e: 'By always sweeping in one direction and jumping back, C-SCAN gives more uniform wait times.' },
      { q: 'LOOK differs from SCAN in that it:',
        o: ['Never reverses direction', 'Reverses at the last request, not the disk edge', 'Serves in FCFS order', 'Ignores the head position'], a: 1,
        e: 'LOOK turns around at the last pending request rather than travelling to the physical end.' }
    ],
    '4': [
      { q: 'In the Banker\'s algorithm the Need matrix is computed as:',
        o: ['Max + Allocation', 'Allocation - Max', 'Max - Allocation', 'Available - Allocation'], a: 2,
        e: 'Need[i][j] = Max[i][j] - Allocation[i][j]: the resources a process may still request.' },
      { q: 'A state is safe if:',
        o: ['No process holds any resource', 'There exists an ordering letting every process finish', 'Available is all zero', 'Allocation equals Max'], a: 1,
        e: 'Safety means some sequence exists in which each process can get its Need and finish.' },
      { q: 'The safety check selects an unfinished process i only when:',
        o: ['Need[i] > Work', 'Need[i] <= Work', 'Allocation[i] = 0', 'Max[i] <= Available'], a: 1,
        e: 'A process can run only if its remaining Need fits within the current Work (free) vector.' },
      { q: 'A request is granted only if, after a tentative allocation, the system is:',
        o: ['Fully utilised', 'Still in a safe state', 'Deadlocked', 'Out of resources'], a: 1,
        e: 'The algorithm re-runs the safety check; it grants the request only if the state stays safe.' }
    ],
    '5': [
      { q: 'Best-fit allocation places a process in the:',
        o: ['First hole that fits', 'Largest hole', 'Smallest hole that fits', 'Last hole'], a: 2,
        e: 'Best-fit chooses the smallest free hole large enough, minimising the immediate leftover.' },
      { q: 'External fragmentation means:',
        o: ['A process is larger than memory', 'Free space exists but no single hole is big enough', 'A hole is wasted inside a partition', 'Memory is fully used'], a: 1,
        e: 'Enough total free memory exists, but it is split into holes too small for the next request.' },
      { q: 'Which strategy tends to leave many tiny, unusable holes?',
        o: ['Worst-fit', 'Best-fit', 'First-fit', 'Next-fit'], a: 1,
        e: 'Best-fit shaves the closest hole, often leaving slivers too small to ever reuse.' },
      { q: 'Worst-fit deliberately selects the largest hole in order to:',
        o: ['Run fastest', 'Leave a leftover big enough to stay useful', 'Minimise fragmentation entirely', 'Avoid searching'], a: 1,
        e: 'By splitting the biggest hole, worst-fit hopes the remainder is still large enough to use.' }
    ],
    '6': [
      { q: 'In the bounded-buffer solution the counting semaphore empty is initialised to:',
        o: ['0', '1', 'N (the buffer size)', 'N - 1'], a: 2,
        e: 'empty starts at N because all N slots are free; full starts at 0 and mutex at 1.' },
      { q: 'Why must a thread acquire the counting semaphore before the mutex?',
        o: ['For speed', 'To avoid holding the mutex while blocked, which would deadlock', 'To save memory', 'It is arbitrary'], a: 1,
        e: 'Blocking on empty/full while holding mutex would lock the other thread out forever.' },
      { q: 'A wait (P) operation on a semaphore:',
        o: ['Increments it and may wake a waiter', 'Decrements it and blocks if it would go negative', 'Resets it to zero', 'Does nothing'], a: 1,
        e: 'wait decrements the value; if the result would be negative the caller blocks.' },
      { q: 'When the buffer is full, the producer:',
        o: ['Overwrites the oldest slot', 'Blocks on wait(empty) since empty = 0', 'Skips the item', 'Signals full twice'], a: 1,
        e: 'empty has reached 0, so wait(empty) blocks the producer until a slot is freed.' }
    ]
  };

  function buildQuiz(host) {
    var qid = host.getAttribute('data-quiz');
    var qs = QUIZZES[qid]; if (!qs) return;
    for (var i = 0; i < qs.length; i++) {
      (function (item, idx) {
        var card = document.createElement('div');
        card.className = 'q';
        var qt = document.createElement('div');
        qt.className = 'qt';
        qt.innerHTML = '<b>Q' + (idx + 1) + '.</b> ' + item.q;
        card.appendChild(qt);
        var selected = -1, answered = false;
        var opts = [];
        for (var j = 0; j < item.o.length; j++) {
          (function (optIdx) {
            var op = document.createElement('div');
            op.className = 'opt-a';
            op.textContent = item.o[optIdx];
            op.addEventListener('click', function () {
              if (answered) return;
              for (var m = 0; m < opts.length; m++) opts[m].classList.remove('sel');
              op.classList.add('sel'); selected = optIdx;
            });
            opts.push(op);
            card.appendChild(op);
          })(j);
        }
        var chk = document.createElement('button');
        chk.className = 'btn cyan qchk';
        chk.textContent = 'Check';
        card.appendChild(chk);
        var expl = document.createElement('div');
        expl.className = 'expl';
        card.appendChild(expl);
        chk.addEventListener('click', function () {
          if (answered) return;
          if (selected < 0) { expl.classList.add('show'); expl.innerHTML = '<b style="color:#fbbf24">Pick an option first.</b>'; return; }
          answered = true;
          for (var m = 0; m < opts.length; m++) {
            opts[m].classList.remove('sel');
            if (m === item.a) opts[m].classList.add('correct');
            else if (m === selected) opts[m].classList.add('wrong');
          }
          var right = (selected === item.a);
          if (!right) card.classList.add('bad');
          expl.classList.add('show');
          expl.innerHTML = '<b>' + (right ? 'Correct.' : 'Incorrect.') + '</b> Answer: ' + item.o[item.a] + '. ' + item.e;
          chk.disabled = true;
        });
      })(qs[i], i);
    }
  }
  var quizHosts = document.querySelectorAll('.osx .quiz');
  for (var qh = 0; qh < quizHosts.length; qh++) buildQuiz(quizHosts[qh]);

  // initial draw of experiment 1
  if (REDRAW['1']) { try { REDRAW['1'](); } catch (e) {} }
  window.addEventListener('resize', function () {
    var onExp = document.querySelector('.osx .exp.on');
    if (onExp) { var n = onExp.id.split('-')[1]; if (REDRAW[n]) { try { REDRAW[n](); } catch (e) {} } }
  });
})();
</script>
</BaseLayout>
