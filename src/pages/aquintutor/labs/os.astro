  // ===================================================================
  // EXPERIMENT 1 — CPU SCHEDULING
  // ===================================================================
  (function CPU() {
    var gantt = $('cpuGantt'); if (!gantt) return;
    var gctx = makeCtx(gantt, 680, 120);
    var tctx = makeCtx($('cpuTable'), 680, 220);
    var GW = 680, GH = 120, TW = 680, TH = 220;
    var procs = [
      { pid: 'P1', at: 0, bt: 7, pr: 3 },
      { pid: 'P2', at: 2, bt: 4, pr: 1 },
      { pid: 'P3', at: 4, bt: 1, pr: 4 },
      { pid: 'P4', at: 5, bt: 4, pr: 2 }
    ];
    var lastResult = null;

    function renderTable() {
      var body = $('cpuBody');
      body.innerHTML = '';
      for (var i = 0; i < procs.length; i++) {
        (function (idx) {
          var p = procs[idx];
          var tr = document.createElement('tr');
          tr.innerHTML = '<td class="lbl">' + p.pid + '</td>'
            + '<td><input type="number" min="0" value="' + p.at + '" data-f="at" data-i="' + idx + '"></td>'
            + '<td><input type="number" min="1" value="' + p.bt + '" data-f="bt" data-i="' + idx + '"></td>'
            + '<td><input type="number" min="1" value="' + p.pr + '" data-f="pr" data-i="' + idx + '"></td>';
          body.appendChild(tr);
        })(i);
      }
      var ins = body.querySelectorAll('input');
      for (var k = 0; k < ins.length; k++) {
        ins[k].addEventListener('change', function () {
          var idx = parseInt(this.getAttribute('data-i'), 10);
          var f = this.getAttribute('data-f');
          var v = parseInt(this.value, 10); if (isNaN(v)) v = 0;
          if (f === 'bt' && v < 1) v = 1;
          if (f === 'pr' && v < 1) v = 1;
          procs[idx][f] = v;
        });
      }
    }

    // schedulers return { timeline:[{pid,start,end}], stats:{pid:{ct,tat,wt,rt}} }
    function deepCopy() {
      var c = [];
      for (var i = 0; i < procs.length; i++) c.push({ pid: procs[i].pid, at: procs[i].at, bt: procs[i].bt, pr: procs[i].pr, rem: procs[i].bt, first: -1, done: false });
      return c;
    }
    function mergeTimeline(tl) {
      var out = [];
      for (var i = 0; i < tl.length; i++) {
        if (out.length && out[out.length - 1].pid === tl[i].pid && out[out.length - 1].end === tl[i].start) {
          out[out.length - 1].end = tl[i].end;
        } else out.push({ pid: tl[i].pid, start: tl[i].start, end: tl[i].end });
      }
      return out;
    }

    function schedFCFS() {
      var ps = deepCopy().sort(function (a, b) { return a.at - b.at || a.pid.localeCompare(b.pid); });
      var t = 0, tl = [], stats = {};
      for (var i = 0; i < ps.length; i++) {
        var p = ps[i];
        if (t < p.at) t = p.at;
        var st = t, ed = t + p.bt;
        tl.push({ pid: p.pid, start: st, end: ed });
        stats[p.pid] = { ct: ed, tat: ed - p.at, wt: (ed - p.at) - p.bt, rt: st - p.at };
        t = ed;
      }
      return { timeline: tl, stats: stats };
    }
    function schedSJF() {
      var ps = deepCopy(); var n = ps.length, t = 0, done = 0, tl = [], stats = {};
      while (done < n) {
        var idx = -1, best = Infinity;
        for (var i = 0; i < n; i++) if (!ps[i].done && ps[i].at <= t && ps[i].bt < best) { best = ps[i].bt; idx = i; }
        if (idx === -1) { var nx = Infinity; for (var j = 0; j < n; j++) if (!ps[j].done && ps[j].at < nx) nx = ps[j].at; t = nx; continue; }
        var p = ps[idx], st = t, ed = t + p.bt;
        tl.push({ pid: p.pid, start: st, end: ed });
        stats[p.pid] = { ct: ed, tat: ed - p.at, wt: (ed - p.at) - p.bt, rt: st - p.at };
        t = ed; p.done = true; done++;
      }
      return { timeline: tl, stats: stats };
    }
    function schedSRTF() {
      var ps = deepCopy(); var n = ps.length, t = 0, done = 0, tl = [], stats = {};
      var horizon = 0; for (var i = 0; i < n; i++) horizon += ps[i].bt; var minAt = Infinity;
      for (var m = 0; m < n; m++) if (ps[m].at < minAt) minAt = ps[m].at;
      t = minAt;
      var guard = 0, maxG = (horizon + minAt) * 4 + 50;
      while (done < n && guard++ < maxG) {
        var idx = -1, best = Infinity;
        for (var k = 0; k < n; k++) if (!ps[k].done && ps[k].at <= t && ps[k].rem < best && ps[k].rem > 0) { best = ps[k].rem; idx = k; }
        if (idx === -1) { var nx = Infinity; for (var a = 0; a < n; a++) if (!ps[a].done && ps[a].at > t && ps[a].at < nx) nx = ps[a].at; t = (nx === Infinity ? t + 1 : nx); continue; }
        var p = ps[idx];
        if (p.first < 0) p.first = t;
        tl.push({ pid: p.pid, start: t, end: t + 1 });
        p.rem--; t++;
        if (p.rem === 0) { p.done = true; done++; stats[p.pid] = { ct: t, tat: t - p.at, wt: (t - p.at) - p.bt, rt: p.first - p.at }; }
      }
      return { timeline: mergeTimeline(tl), stats: stats };
    }
    function schedRR(q) {
      if (q < 1) q = 1;
      var ps = deepCopy().sort(function (a, b) { return a.at - b.at || a.pid.localeCompare(b.pid); });
      var n = ps.length, t = 0, done = 0, tl = [], stats = {};
      var queue = [], inq = {}; var i = 0;
      var minAt = Infinity; for (var z = 0; z < n; z++) if (ps[z].at < minAt) minAt = ps[z].at;
      t = minAt;
      function enqueueArrived(upto) {
        for (var j = 0; j < n; j++) if (!inq[ps[j].pid] && !ps[j].done && ps[j].at <= upto) { queue.push(j); inq[ps[j].pid] = true; }
      }
      enqueueArrived(t);
      var guard = 0, maxG = 0; for (var g = 0; g < n; g++) maxG += ps[g].bt; maxG = maxG * 3 + 100;
      while (done < n && guard++ < maxG) {
        if (queue.length === 0) {
          var nx = Infinity; for (var a = 0; a < n; a++) if (!ps[a].done && !inq[ps[a].pid] && ps[a].at > t && ps[a].at < nx) nx = ps[a].at;
          if (nx === Infinity) break; t = nx; enqueueArrived(t); continue;
        }
        var idx = queue.shift(); inq[ps[idx].pid] = false;
        var p = ps[idx];
        if (p.first < 0) p.first = t;
        var run = Math.min(q, p.rem);
        tl.push({ pid: p.pid, start: t, end: t + run });
        t += run; p.rem -= run;
        enqueueArrived(t);
        if (p.rem === 0) { p.done = true; done++; stats[p.pid] = { ct: t, tat: t - p.at, wt: (t - p.at) - p.bt, rt: p.first - p.at }; }
        else { queue.push(idx); inq[p.pid] = true; }
      }
      return { timeline: mergeTimeline(tl), stats: stats };
    }
    function schedPrio() {
      var ps = deepCopy(); var n = ps.length, t = 0, done = 0, tl = [], stats = {};
      while (done < n) {
        var idx = -1, best = Infinity;
        for (var i = 0; i < n; i++) if (!ps[i].done && ps[i].at <= t && ps[i].pr < best) { best = ps[i].pr; idx = i; }
        if (idx === -1) { var nx = Infinity; for (var j = 0; j < n; j++) if (!ps[j].done && ps[j].at < nx) nx = ps[j].at; t = nx; continue; }
        var p = ps[idx], st = t, ed = t + p.bt;
        tl.push({ pid: p.pid, start: st, end: ed });
        stats[p.pid] = { ct: ed, tat: ed - p.at, wt: (ed - p.at) - p.bt, rt: st - p.at };
        t = ed; p.done = true; done++;
      }
      return { timeline: tl, stats: stats };
    }

    function run() {
      var pol = $('cpuPol').value;
      var res;
      if (pol === 'fcfs') res = schedFCFS();
      else if (pol === 'sjf') res = schedSJF();
      else if (pol === 'srtf') res = schedSRTF();
      else if (pol === 'rr') res = schedRR(parseInt($('cpuQ').value, 10) || 2);
      else res = schedPrio();
      lastResult = res;
      drawGantt(res.timeline);
      drawResults(res);
      var sumW = 0, sumT = 0, sumR = 0, cnt = 0, totBurst = 0, finish = 0, startMin = Infinity;
      for (var p in res.stats) { if (!res.stats.hasOwnProperty(p)) continue; sumW += res.stats[p].wt; sumT += res.stats[p].tat; sumR += res.stats[p].rt; cnt++; }
      for (var i = 0; i < procs.length; i++) { totBurst += procs[i].bt; if (procs[i].at < startMin) startMin = procs[i].at; }
      for (var j = 0; j < res.timeline.length; j++) if (res.timeline[j].end > finish) finish = res.timeline[j].end;
      var span = finish - startMin;
      $('cpuAwt').textContent = cnt ? (sumW / cnt).toFixed(2) : '--';
      $('cpuAtat').textContent = cnt ? (sumT / cnt).toFixed(2) : '--';
      $('cpuArt').textContent = cnt ? (sumR / cnt).toFixed(2) : '--';
      $('cpuUtil').textContent = span > 0 ? ((totBurst / span) * 100).toFixed(1) + '%' : '--';
      var name = { fcfs: 'FCFS', sjf: 'SJF', srtf: 'SRTF', rr: 'Round-Robin (q=' + (parseInt($('cpuQ').value, 10) || 2) + ')', prio: 'Priority' }[pol];
      logTo($('cpuLog'), '<b>' + name + '</b> &mdash; avg WT ' + (cnt ? (sumW / cnt).toFixed(2) : '--') + ', avg TAT ' + (cnt ? (sumT / cnt).toFixed(2) : '--'));
    }

    function colorFor(pid) {
      for (var i = 0; i < procs.length; i++) if (procs[i].pid === pid) return PALETTE[i % PALETTE.length];
      return COL.dim;
    }

    function drawGantt(tl) {
      gctx.clearRect(0, 0, GW, GH);
      gctx.fillStyle = COL.bg; gctx.fillRect(0, 0, GW, GH);
      if (!tl.length) return;
      var t0 = tl[0].start, t1 = tl[tl.length - 1].end;
      var span = Math.max(1, t1 - t0);
      var padL = 18, padR = 18, top = 30, h = 44;
      var usable = GW - padL - padR;
      var sx = function (t) { return padL + ((t - t0) / span) * usable; };
      for (var i = 0; i < tl.length; i++) {
        var b = tl[i];
        var x0 = sx(b.start), x1 = sx(b.end);
        gctx.fillStyle = colorFor(b.pid);
        gctx.globalAlpha = 0.85; gctx.fillRect(x0, top, x1 - x0, h); gctx.globalAlpha = 1;
        gctx.strokeStyle = '#0a0a0c'; gctx.lineWidth = 1.5; gctx.strokeRect(x0, top, x1 - x0, h);
        gctx.fillStyle = '#0a0a0c'; gctx.font = 'bold 12px Geist Mono, monospace'; gctx.textAlign = 'center'; gctx.textBaseline = 'middle';
        if (x1 - x0 > 16) gctx.fillText(b.pid, (x0 + x1) / 2, top + h / 2);
        gctx.fillStyle = COL.dim; gctx.font = '10px Geist Mono, monospace'; gctx.textBaseline = 'top';
        gctx.fillText(String(b.start), x0, top + h + 5);
      }
      var last = tl[tl.length - 1];
      gctx.fillStyle = COL.dim; gctx.textAlign = 'left';
      gctx.fillText(String(last.end), sx(last.end) - 4, top + h + 5);
      gctx.fillStyle = COL.cyan; gctx.font = 'bold 9px Geist Mono, monospace'; gctx.textAlign = 'left'; gctx.textBaseline = 'top';
      gctx.fillText('GANTT CHART (time axis)', padL, 10);
    }

    function drawResults(res) {
      tctx.clearRect(0, 0, TW, TH);
      tctx.fillStyle = COL.bg; tctx.fillRect(0, 0, TW, TH);
      var cols = ['PID', 'Arrival', 'Burst', 'Completion', 'Turnaround', 'Waiting', 'Response'];
      var n = procs.length;
      var cw = TW / cols.length;
      var rh = Math.min(28, (TH - 34) / (n + 1));
      var top = 6;
      tctx.font = 'bold 10px Geist Mono, monospace'; tctx.textAlign = 'center'; tctx.textBaseline = 'middle';
      tctx.fillStyle = COL.cyan;
      for (var c = 0; c < cols.length; c++) tctx.fillText(cols[c], c * cw + cw / 2, top + rh / 2);
      tctx.strokeStyle = COL.grid; tctx.lineWidth = 1;
      tctx.beginPath(); tctx.moveTo(0, top + rh); tctx.lineTo(TW, top + rh); tctx.stroke();
      for (var i = 0; i < n; i++) {
        var p = procs[i]; var st = res.stats[p.pid] || { ct: '-', tat: '-', wt: '-', rt: '-' };
        var y = top + rh * (i + 1) + rh / 2;
        var vals = [p.pid, p.at, p.bt, st.ct, st.tat, st.wt, st.rt];
        for (var k = 0; k < vals.length; k++) {
          tctx.font = (k === 0 ? 'bold ' : '') + '11px Geist Mono, monospace';
          tctx.fillStyle = k === 0 ? colorFor(p.pid) : (k === 5 ? COL.amber : (k === 4 ? COL.green : COL.text));
          tctx.fillText(String(vals[k]), k * cw + cw / 2, y);
        }
        tctx.strokeStyle = '#14141c';
        tctx.beginPath(); tctx.moveTo(0, top + rh * (i + 1)); tctx.lineTo(TW, top + rh * (i + 1)); tctx.stroke();
      }
    }

    $('cpuAdd').addEventListener('click', function () {
      if (procs.length >= 8) return;
      var id = 'P' + (procs.length + 1);
