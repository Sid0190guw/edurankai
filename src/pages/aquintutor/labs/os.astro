      busy = false;
    }

    function refreshStats() {
      var freeTot = 0, leftoverTot = 0;
      for (var i = 0; i < partitions.length; i++) { freeTot += partitions[i].free; if (partitions[i].placements.length) leftoverTot += partitions[i].free; }
      $('mmPlaced').textContent = placed;
