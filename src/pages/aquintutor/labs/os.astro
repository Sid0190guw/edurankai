      var padL = 44, padR = 24, padT = 28, padB = 24;
      var usableW = W - padL - padR, usableH = H - padT - padB;
      var sx = function (c) { return padL + (c / Math.max(1, maxCyl)) * usableW; };
      var sy = function (i) { return padT + (i / Math.max(1, lastPath.length - 1)) * usableH; };
      // top axis ticks
      ctx.font = '9px Geist Mono, monospace'; ctx.textAlign = 'center'; ctx.textBaseline = 'top';
      for (var t = 0; t <= 4; t++) {
        var c = Math.round((maxCyl / 4) * t);
