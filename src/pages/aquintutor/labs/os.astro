    }

    function buildMatrix(tbl, data, editable, ridLabel, fname) {
      tbl.innerHTML = '';
      var thead = '<thead><tr><th></th>';
      for (var j = 0; j < R; j++) thead += '<th>R' + j + '</th>'; thead += '</tr></thead>';
      var html = thead + '<tbody>';
      for (var i = 0; i < data.length; i++) {
        html += '<tr><td class="lbl">' + (ridLabel ? ridLabel + i : '') + '</td>';
        for (var k = 0; k < data[i].length; k++) {
          if (editable) html += '<td><input type="number" min="0" value="' + data[i][k] + '" data-i="' + i + '" data-j="' + k + '"></td>';
          else html += '<td>' + data[i][k] + '</td>';
