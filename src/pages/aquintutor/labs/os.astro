  // ===================================================================
  // EXPERIMENT 3 — DISK SCHEDULING
  // ===================================================================
  (function DISK() {
    var cv = $('dkCv'); if (!cv) return;
    var ctx = makeCtx(cv, 680, 360);
    var W = 680, H = 360;
    var dir = 'up', lastPath = null, lastSeek = 0, head = 53, maxCyl = 199;

    function plan() {
      var q = parseNums($('dkQ').value);
      head = parseInt($('dkHead').value, 10); if (isNaN(head)) head = 0;
      maxCyl = parseInt($('dkMax').value, 10); if (isNaN(maxCyl) || maxCyl < 1) maxCyl = 199;
      var pol = $('dkPolSel').value;
      var req = [];
      for (var i = 0; i < q.length; i++) if (q[i] >= 0 && q[i] <= maxCyl) req.push(q[i]);
      var path = [head], seek = 0, cur = head;

      function go(c) { seek += Math.abs(c - cur); cur = c; path.push(c); }

      if (pol === 'fcfs') {
        for (var f = 0; f < req.length; f++) go(req[f]);
      } else if (pol === 'sstf') {
        var pending = req.slice();
        while (pending.length) {
          var bi = 0, bd = Infinity;
          for (var k = 0; k < pending.length; k++) { var d = Math.abs(pending[k] - cur); if (d < bd) { bd = d; bi = k; } }
          go(pending[bi]); pending.splice(bi, 1);
        }
      } else {
        var left = [], right = [];
        for (var r = 0; r < req.length; r++) { if (req[r] < head) left.push(req[r]); else right.push(req[r]); }
        left.sort(function (a, b) { return a - b; }); right.sort(function (a, b) { return a - b; });
        if (pol === 'scan') {
          if (dir === 'up') { for (var a = 0; a < right.length; a++) go(right[a]); if (cur !== maxCyl) go(maxCyl); for (var b = left.length - 1; b >= 0; b--) go(left[b]); }
          else { for (var c = left.length - 1; c >= 0; c--) go(left[c]); if (cur !== 0) go(0); for (var e = 0; e < right.length; e++) go(right[e]); }
        } else if (pol === 'cscan') {
          if (dir === 'up') { for (var a2 = 0; a2 < right.length; a2++) go(right[a2]); if (cur !== maxCyl) go(maxCyl); go(0); for (var b2 = 0; b2 < left.length; b2++) go(left[b2]); }
          else { for (var c2 = left.length - 1; c2 >= 0; c2--) go(left[c2]); if (cur !== 0) go(0); go(maxCyl); for (var e2 = right.length - 1; e2 >= 0; e2--) go(right[e2]); }
        } else if (pol === 'look') {
          if (dir === 'up') { for (var a3 = 0; a3 < right.length; a3++) go(right[a3]); for (var b3 = left.length - 1; b3 >= 0; b3--) go(left[b3]); }
          else { for (var c3 = left.length - 1; c3 >= 0; c3--) go(left[c3]); for (var e3 = 0; e3 < right.length; e3++) go(right[e3]); }
