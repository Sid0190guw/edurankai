  // ===================================================================
  // EXPERIMENT 5 — MEMORY ALLOCATION
  // ===================================================================
  (function MEM() {
    var cv = $('mmCv'); if (!cv) return;
    var ctx = makeCtx(cv, 680, 300);
    var W = 680, H = 300;
    var holes = [], procSizes = [], strat = 'first', spd = 6, busy = false;
    var partitions = []; // {orig, free, placements:[{pid,size}]}
    var pidx = 0, placed = 0, failed = 0;

    function readConfig() {
      holes = parseNums($('mmHoles').value); if (!holes.length) holes = [100, 200, 300];
      procSizes = parseNums($('mmProcs').value); if (!procSizes.length) procSizes = [100];
      strat = $('mmStratSel').value;
      $('mmStrat').textContent = { first: 'first-fit', best: 'best-fit', worst: 'worst-fit' }[strat];
    }

    function reset() {
      readConfig();
      partitions = holes.map(function (h) { return { orig: h, free: h, placements: [] }; });
      pidx = 0; placed = 0; failed = 0;
      refreshStats(); draw();
    }

    function chooseHole(size) {
      var pick = -1;
      if (strat === 'first') {
        for (var i = 0; i < partitions.length; i++) if (partitions[i].free >= size) { pick = i; break; }
      } else if (strat === 'best') {
        var bestFree = Infinity;
        for (var j = 0; j < partitions.length; j++) if (partitions[j].free >= size && partitions[j].free < bestFree) { bestFree = partitions[j].free; pick = j; }
      } else {
        var worstFree = -1;
        for (var k = 0; k < partitions.length; k++) if (partitions[k].free >= size && partitions[k].free > worstFree) { worstFree = partitions[k].free; pick = k; }
      }
      return pick;
    }

