    };
    renderTable();
    $('cpuQrow').style.display = 'none';
    run();
  })();

  // ===================================================================
  // EXPERIMENT 2 — PAGE REPLACEMENT
  // ===================================================================
  (function PAGE() {
    var cv = $('pgCv'); if (!cv) return;
    var ctx = makeCtx(cv, 680, 300);
    var W = 680, H = 300;
    var refs = [], frames = 3, pol = 'fifo', spd = 6;
    var pos = 0, faults = 0, hits = 0, busy = false;
    var history = []; // each step: { ref, frames:[...], fault:bool, evicted }

    function readRefs() {
      refs = parseNums($('pgRef').value);
      if (!refs.length) refs = [1, 2, 3, 4];
    }

    function computeAll() {
      readRefs();
      frames = Math.max(1, Math.min(7, parseInt($('pgFrames').value, 10) || 3));
      pol = $('pgPolSel').value;
      history = [];
      var mem = []; // current resident pages (array, slot order)
      var loadTime = {}; // for fifo: page -> insertion index
      var lastUse = {};  // for lru: page -> last ref index
      var clock = 0;
      for (var i = 0; i < refs.length; i++) {
        var pg = refs[i]; var fault = false, evicted = null;
        var inMem = mem.indexOf(pg) >= 0;
        if (inMem) {
          fault = false;
        } else {
          fault = true;
          if (mem.length < frames) {
            mem.push(pg); loadTime[pg] = clock;
          } else {
            var victimIdx = 0;
            if (pol === 'fifo') {
              var oldest = Infinity;
              for (var m = 0; m < mem.length; m++) if (loadTime[mem[m]] < oldest) { oldest = loadTime[mem[m]]; victimIdx = m; }
            } else if (pol === 'lru') {
              var lru = Infinity;
              for (var n = 0; n < mem.length; n++) { var lu = (lastUse[mem[n]] === undefined ? -1 : lastUse[mem[n]]); if (lu < lru) { lru = lu; victimIdx = n; } }
            } else { // optimal
              var farthest = -1;
              for (var k = 0; k < mem.length; k++) {
                var nextUse = Infinity;
                for (var f = i + 1; f < refs.length; f++) if (refs[f] === mem[k]) { nextUse = f; break; }
                if (nextUse > farthest) { farthest = nextUse; victimIdx = k; }
              }
            }
            evicted = mem[victimIdx];
            mem[victimIdx] = pg; loadTime[pg] = clock;
          }
        }
        lastUse[pg] = clock; clock++;
        history.push({ ref: pg, frames: mem.slice(), fault: fault, evicted: evicted });
      }
    }

    function statsUpTo(p) {
      var f = 0, h = 0;
      for (var i = 0; i < p && i < history.length; i++) { if (history[i].fault) f++; else h++; }
      return { f: f, h: h };
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = COL.bg; ctx.fillRect(0, 0, W, H);
      var n = history.length; if (!n) return;
      var padL = 56, padT = 36, padB = 40, padR = 12;
      var cw = Math.max(18, (W - padL - padR) / n);
      var rh = Math.min(34, (H - padT - padB) / frames);
      // header row: reference string
      ctx.font = 'bold 9px Geist Mono, monospace'; ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      ctx.fillStyle = COL.cyan; ctx.fillText('REF', 8, padT - 16);
      for (var f = 0; f < frames; f++) { ctx.fillStyle = COL.dim; ctx.textAlign = 'right'; ctx.fillText('f' + f, padL - 8, padT + f * rh + rh / 2); }
      ctx.textAlign = 'center';
      for (var i = 0; i < n; i++) {
        var step = history[i];
        var x = padL + i * cw;
        var hl = (i < pos);
        // reference number on top
        ctx.font = 'bold 11px Geist Mono, monospace';
        ctx.fillStyle = i === pos - 1 ? COL.cyan : (hl ? COL.text : COL.dim);
        ctx.fillText(String(step.ref), x + cw / 2, padT - 16);
        // fault / hit marker
        ctx.font = '8px Geist Mono, monospace';
        if (hl) { ctx.fillStyle = step.fault ? COL.amber : COL.green; ctx.fillText(step.fault ? 'F' : 'H', x + cw / 2, padT - 4); }
        // frame cells
        for (var fr = 0; fr < frames; fr++) {
          var cy = padT + fr * rh;
          ctx.strokeStyle = COL.grid; ctx.lineWidth = 1;
          ctx.strokeRect(x + 1, cy + 1, cw - 2, rh - 2);
          if (hl && fr < step.frames.length) {
            var val = step.frames[fr];
            var prev = i > 0 ? history[i - 1].frames : [];
            var changed = step.fault && (prev[fr] !== val);
            ctx.fillStyle = changed ? 'rgba(251,191,36,0.18)' : 'rgba(103,232,249,0.06)';
