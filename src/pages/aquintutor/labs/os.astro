        failed++;
        logTo($('mmLog'), '<span class="no">' + pid + ' (' + size + 'K) cannot be placed &mdash; no hole fits</span>');
      } else {
        partitions[hole].placements.push({ pid: pid, size: size });
        var leftover = partitions[hole].free - size;
        partitions[hole].free = leftover;
        placed++;
        logTo($('mmLog'), '<b>' + pid + '</b> (' + size + 'K) &rarr; partition ' + hole + ' (' + partitions[hole].orig + 'K), leftover ' + leftover + 'K');
      }
