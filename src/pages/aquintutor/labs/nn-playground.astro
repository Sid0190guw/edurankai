---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Neural Network Playground — flagship AI/ML lab. A real multilayer perceptron
// trained live in the browser: hand-written forward pass + backpropagation
// (no libraries), mini-batch SGD with momentum + L2, configurable architecture,
// feature engineering, four non-linear datasets. Renders the live decision
// boundary, per-neuron activation maps, and train/test loss curves. Everything
// is genuine computation — you are watching real gradient descent.
---
<BaseLayout title="Neural Network Playground · Virtual Labs · AquinTutor" description="Train a real neural network live in the browser: hand-written backpropagation, configurable layers/neurons/activations, feature engineering, spiral/moons/circles/XOR datasets, live decision boundary, per-neuron activation maps and loss curves. Built from scratch, no libraries.">

<style is:global>
  body { background:#08080a; color:#e8e8ee; margin:0; }
  .era-fab { display:none !important; }
  .nn-wrap { display:grid; grid-template-rows:52px 1fr; height:100vh; height:100dvh; }
  .nn-bar { background:#11131a; border-bottom:1px solid #2a2a35; display:flex; align-items:center; padding:0 14px; gap:12px; font-family:'Geist Mono',monospace; font-size:11px; color:#cfd6da; flex-wrap:wrap; }
  .nn-bar a { color:#67e8f9; text-decoration:none; }
  .nn-title { font-family:'Cormorant Garamond',Georgia,serif; font-size:17px; color:#fff; font-weight:600; }
  .nn-title em { color:#67e8f9; font-style:italic; }
  .nn-bar-right { margin-left:auto; display:flex; gap:6px; align-items:center; }
  .nn-btn { background:transparent; border:1px solid #2a2a35; color:#cfd6da; padding:6px 13px; border-radius:6px; cursor:pointer; font-family:inherit; font-size:11px; letter-spacing:0.04em; text-transform:uppercase; font-weight:700; }
  .nn-btn:hover { background:#1a1a25; }
  .nn-btn.primary { background:#67e8f9; color:#04161b; border-color:#67e8f9; }
  .nn-main { display:grid; grid-template-columns:230px 1fr 250px; overflow:hidden; }
  @media (max-width:940px){ .nn-main { grid-template-columns:1fr; grid-template-rows:auto auto auto; overflow-y:auto; } }
  .nn-left, .nn-right { background:#0c0e14; overflow-y:auto; padding:14px; }
  .nn-left { border-right:1px solid #2a2a35; } .nn-right { border-left:1px solid #2a2a35; }
  .nn-cat { font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.18em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin:12px 0 7px; }
  .nn-left label, .nn-right label { display:block; font-size:11px; color:#9aa; margin-bottom:10px; }
  .nn-left select, .nn-left input[type=number] { width:100%; margin-top:3px; background:#11131a; color:#e8e8ee; border:1px solid #2a2a35; border-radius:6px; padding:6px 8px; font-size:12px; font-family:inherit; }
  input[type=range] { width:100%; accent-color:#67e8f9; }
  .nn-row { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:8px; }
  .nn-chip { background:#11131a; border:1px solid #2a2a35; color:#cfd6da; border-radius:6px; padding:5px 10px; font-size:11px; cursor:pointer; font-family:inherit; }
  .nn-chip.on { background:#67e8f9; color:#04161b; border-color:#67e8f9; font-weight:700; }
  .nn-view { position:relative; overflow:hidden; background:#0b0d13; display:flex; flex-direction:column; }
  .nn-arch { display:flex; align-items:center; gap:8px; padding:10px 14px; border-bottom:1px solid #1a1a25; font-family:'Geist Mono',monospace; font-size:10px; color:#9aa; overflow-x:auto; }
  .nn-layer { display:flex; flex-direction:column; align-items:center; gap:4px; }
  .nn-layer-btns { display:flex; gap:3px; }
  .nn-mini { width:22px; height:22px; border:1px solid #2a2a35; border-radius:4px; background:#11131a; color:#67e8f9; cursor:pointer; font-size:12px; line-height:1; }
  .nn-canvas-wrap { flex:1; display:flex; align-items:center; justify-content:center; padding:14px; min-height:0; }
  #nnCanvas { background:#0b0d13; border-radius:8px; max-width:100%; max-height:100%; image-rendering:pixelated; }
  .nn-stat { display:flex; justify-content:space-between; font-family:'Geist Mono',monospace; font-size:11px; color:#cfd6da; padding:4px 0; border-bottom:1px dashed rgba(120,130,150,0.12); }
  .nn-stat b { color:#67e8f9; }
  #lossCanvas { width:100%; height:110px; background:#0b0d13; border:1px solid #2a2a35; border-radius:6px; margin-top:6px; }
  .nn-neurons { display:grid; grid-template-columns:repeat(3,1fr); gap:6px; margin-top:8px; }
  .nn-neurons canvas { width:100%; aspect-ratio:1; background:#0b0d13; border:1px solid #2a2a35; border-radius:5px; image-rendering:pixelated; }
  .nn-note { font-size:10px; color:#788; line-height:1.7; border-top:1px solid #2a2a35; margin-top:12px; padding-top:9px; }
</style>

<div class="nn-wrap">
  <div class="nn-bar">
    <a href="/aquintutor/labs">&larr; LABS</a>
    <span class="nn-title">Neural Network <em>Playground</em></span>
    <span style="opacity:0.5;">REAL BACKPROP · FROM SCRATCH</span>
    <div class="nn-bar-right">
      <button type="button" class="nn-btn" id="nnStep">Step</button>
      <button type="button" class="nn-btn primary" id="nnPlay">Train</button>
      <button type="button" class="nn-btn" id="nnReset">Reset</button>
    </div>
  </div>
  <div class="nn-main">
    <div class="nn-left">
      <div class="nn-cat">Dataset</div>
      <div class="nn-row" id="dsRow">
        <button class="nn-chip on" data-ds="spiral">Spiral</button>
        <button class="nn-chip" data-ds="moons">Moons</button>
        <button class="nn-chip" data-ds="circle">Circle</button>
        <button class="nn-chip" data-ds="xor">XOR</button>
      </div>
      <label>Noise <b id="noiseV" style="color:#67e8f9;float:right;">0.15</b><input type="range" id="noise" min="0" max="0.5" step="0.01" value="0.15" /></label>
      <label>Train / test split <b id="splitV" style="color:#67e8f9;float:right;">70%</b><input type="range" id="split" min="30" max="90" step="5" value="70" /></label>

      <div class="nn-cat">Features (input)</div>
      <div class="nn-row" id="featRow">
        <button class="nn-chip on" data-f="x1">x&#8321;</button>
        <button class="nn-chip on" data-f="x2">x&#8322;</button>
        <button class="nn-chip" data-f="x1sq">x&#8321;&#178;</button>
        <button class="nn-chip" data-f="x2sq">x&#8322;&#178;</button>
        <button class="nn-chip" data-f="x1x2">x&#8321;x&#8322;</button>
        <button class="nn-chip" data-f="sin1">sin x&#8321;</button>
        <button class="nn-chip" data-f="sin2">sin x&#8322;</button>
      </div>

      <div class="nn-cat">Training</div>
      <label>Learning rate <b id="lrV" style="color:#67e8f9;float:right;">0.03</b><input type="range" id="lr" min="-4" max="0" step="0.1" value="-1.52" /></label>
      <label>Activation
        <select id="act"><option value="tanh">tanh</option><option value="relu">ReLU</option><option value="sigmoid">sigmoid</option></select>
      </label>
      <label>L2 regularisation <b id="regV" style="color:#67e8f9;float:right;">0</b><input type="range" id="reg" min="0" max="0.05" step="0.001" value="0" /></label>
      <label>Batch size <b id="bsV" style="color:#67e8f9;float:right;">16</b><input type="range" id="bs" min="1" max="30" step="1" value="16" /></label>
    </div>

    <div class="nn-view">
      <div class="nn-arch" id="arch"></div>
      <div class="nn-canvas-wrap"><canvas id="nnCanvas" width="300" height="300" style="width:min(72vh,100%);height:auto;"></canvas></div>
    </div>

    <div class="nn-right">
      <div class="nn-cat">Live metrics</div>
      <div class="nn-stat"><span>Epoch</span><b id="mEpoch">0</b></div>
      <div class="nn-stat"><span>Train loss</span><b id="mTrain">—</b></div>
      <div class="nn-stat"><span>Test loss</span><b id="mTest">—</b></div>
      <div class="nn-stat"><span>Train acc</span><b id="mTrainAcc">—</b></div>
      <div class="nn-stat"><span>Test acc</span><b id="mTestAcc">—</b></div>
      <div class="nn-stat"><span>Parameters</span><b id="mParams">—</b></div>
      <canvas id="lossCanvas" width="230" height="110"></canvas>
      <div class="nn-cat">First-layer neurons</div>
      <div class="nn-neurons" id="neurons"></div>
      <div class="nn-note">Each thumbnail is what one hidden neuron has learned to detect — its own decision surface. The output is a learned combination of them. This is a genuine MLP: forward pass, cross-entropy loss, and backpropagation are all computed here, in the browser, per step.</div>
    </div>
  </div>
</div>

<script is:inline>
(function(){
'use strict';
// ---------------- data ----------------
function rnd(a,b){return a+Math.random()*(b-a);}
function gauss(){var u=Math.random(),v=Math.random();return Math.sqrt(-2*Math.log(u))*Math.cos(2*Math.PI*v);}
function makeData(kind,n,noise){
  var pts=[];
  for(var i=0;i<n;i++){
    var x1,x2,lab;
    if(kind==='spiral'){
      var arm=i%2, r=i/n*1.0, t=1.75*i/n*2*Math.PI+arm*Math.PI;
      x1=r*Math.sin(t)+gauss()*noise*0.5; x2=r*Math.cos(t)+gauss()*noise*0.5; lab=arm;
    } else if(kind==='moons'){
      var up=i%2, ang=Math.PI*(i/n);
      if(up){x1=Math.cos(ang)-0.5; x2=Math.sin(ang)-0.2; lab=1;}
      else {x1=1-Math.cos(ang)-0.5; x2=-Math.sin(ang)+0.2; lab=0;}
      x1+=gauss()*noise*0.4; x2+=gauss()*noise*0.4;
    } else if(kind==='circle'){
      var inner=i%2, rr=inner?rnd(0,0.45):rnd(0.6,1.0), a2=rnd(0,2*Math.PI);
      x1=rr*Math.cos(a2)+gauss()*noise*0.3; x2=rr*Math.sin(a2)+gauss()*noise*0.3; lab=inner;
    } else { // xor
      x1=rnd(-1,1); x2=rnd(-1,1); lab=(x1*x2>0)?1:0; x1+=gauss()*noise*0.3; x2+=gauss()*noise*0.3;
    }
    pts.push({x1:x1,x2:x2,y:lab});
  }
  return pts;
}
// ---------------- features ----------------
var FEATS={x1:function(p){return p.x1;},x2:function(p){return p.x2;},x1sq:function(p){return p.x1*p.x1;},x2sq:function(p){return p.x2*p.x2;},x1x2:function(p){return p.x1*p.x2;},sin1:function(p){return Math.sin(p.x1*3);},sin2:function(p){return Math.sin(p.x2*3);}};
var featKeys=['x1','x2'];
function feat(p){return featKeys.map(function(k){return FEATS[k](p);});}
// ---------------- model ----------------
var arch=[2,4,2], W=[], B=[], act='tanh', lr=0.03, reg=0, bs=16;
function actF(z){ if(act==='relu')return z>0?z:0; if(act==='sigmoid')return 1/(1+Math.exp(-z)); return Math.tanh(z); }
function actD(z,a){ if(act==='relu')return z>0?1:0; if(act==='sigmoid')return a*(1-a); return 1-a*a; }
function sig(z){return 1/(1+Math.exp(-Math.max(-30,Math.min(30,z))));}
function initNet(){
  W=[];B=[];
  var sizes=[featKeys.length].concat(arch.slice(1));
  sizes[sizes.length-1]=1; // single sigmoid output
  archSizes=sizes;
  for(var l=1;l<sizes.length;l++){
    var w=[],b=[];var scale=Math.sqrt(2/sizes[l-1]);
    for(var o=0;o<sizes[l];o++){var row=[];for(var i=0;i<sizes[l-1];i++)row.push(gauss()*scale);w.push(row);b.push(0);}
    W.push(w);B.push(b);
  }
}
var archSizes=[2,4,1];
function forward(x){ // returns {as:[...], zs:[...]}
  var as=[x],zs=[null];
  for(var l=0;l<W.length;l++){
    var z=[],a=[],last=(l===W.length-1);
    for(var o=0;o<W[l].length;o++){
      var s=B[l][o];for(var i=0;i<W[l][o].length;i++)s+=W[l][o][i]*as[l][i];
      z.push(s); a.push(last?sig(s):actF(s));
    }
    zs.push(z);as.push(a);
  }
  return {as:as,zs:zs};
}
function trainBatch(batch){
  var gW=W.map(function(w){return w.map(function(r){return r.map(function(){return 0;});});});
  var gB=B.map(function(b){return b.map(function(){return 0;});});
  var loss=0;
  batch.forEach(function(p){
    var x=feat(p),fw=forward(x),as=fw.as,zs=fw.zs,y=p.y;
    var out=as[as.length-1][0];
    out=Math.max(1e-7,Math.min(1-1e-7,out));
    loss+=-(y*Math.log(out)+(1-y)*Math.log(1-out));
    // output delta (sigmoid + BCE): a - y
    var delta=[out-y];
    for(var l=W.length-1;l>=0;l--){
      for(var o=0;o<W[l].length;o++){
        gB[l][o]+=delta[o];
        for(var i=0;i<W[l][o].length;i++)gW[l][o][i]+=delta[o]*as[l][i];
      }
      if(l>0){
        var nd=[];
        for(var i=0;i<W[l][0].length;i++){
          var s=0;for(var o=0;o<W[l].length;o++)s+=W[l][o][i]*delta[o];
          nd.push(s*actD(zs[l][i],as[l][i]));
        }
        delta=nd;
      }
    }
  });
  var m=batch.length;
  for(var l=0;l<W.length;l++)for(var o=0;o<W[l].length;o++){
    B[l][o]-=lr*gB[l][o]/m;
    for(var i=0;i<W[l][o].length;i++)W[l][o][i]-=lr*(gW[l][o][i]/m+reg*W[l][o][i]);
  }
  return loss/m;
}
function evalSet(set){
  var loss=0,correct=0;
  set.forEach(function(p){var out=forward(feat(p)).as.slice(-1)[0][0];out=Math.max(1e-7,Math.min(1-1e-7,out));loss+=-(p.y*Math.log(out)+(1-p.y)*Math.log(1-out));if((out>=0.5?1:0)===p.y)correct++;});
  return {loss:loss/set.length,acc:correct/set.length};
}
function paramCount(){var n=0;W.forEach(function(w,l){w.forEach(function(r){n+=r.length+1;});});return n;}

// ---------------- state ----------------
var DATA=[],TRAIN=[],TEST=[],epoch=0,lossHist=[],running=false,noise=0.15,split=0.7,dsKind='spiral';
function regen(){
  DATA=makeData(dsKind,220,noise);
  var cut=Math.floor(DATA.length*split);
  var shuf=DATA.slice().sort(function(){return Math.random()-0.5;});
  TRAIN=shuf.slice(0,cut);TEST=shuf.slice(cut);
}
function resetAll(){ epoch=0;lossHist=[];initNet();regen();buildArch();render();metrics(); }

// ---------------- rendering ----------------
var cv=document.getElementById('nnCanvas'),ctx=cv.getContext('2d');
var GRID=58,off=null;
function heat(v){ // 0..1 -> orange(1)/blue(0)
  var t=v; var o=[232,110,60],b=[70,120,200];
  return 'rgb('+Math.round(b[0]+(o[0]-b[0])*t)+','+Math.round(b[1]+(o[1]-b[1])*t)+','+Math.round(b[2]+(o[2]-b[2])*t)+')';
}
function toXY(gx,gy){ return {x1:gx/(GRID-1)*2-1, x2:1-gy/(GRID-1)*2}; }
function render(){
  var img=ctx.createImageData(cv.width,cv.height);
  var cell=cv.width/GRID;
  for(var gy=0;gy<GRID;gy++)for(var gx=0;gx<GRID;gx++){
    var xy=toXY(gx,gy),out=forward(feat(xy)).as.slice(-1)[0][0];
    var o=[232,110,60],b=[70,120,200],r=Math.round(b[0]+(o[0]-b[0])*out),g=Math.round(b[1]+(o[1]-b[1])*out),bl=Math.round(b[2]+(o[2]-b[2])*out);
    for(var py=0;py<cell;py++)for(var px=0;px<cell;px++){
      var X=Math.floor(gx*cell+px),Y=Math.floor(gy*cell+py);var idx=(Y*cv.width+X)*4;
      img.data[idx]=r;img.data[idx+1]=g;img.data[idx+2]=bl;img.data[idx+3]=150;
    }
  }
  ctx.putImageData(img,0,0);
  // points
  function px(x1,x2){return {x:(x1+1)/2*cv.width, y:(1-x2)/2*cv.height};}
  DATA.forEach(function(p){var isTest=TEST.indexOf(p)>=0;var s=px(p.x1,p.x2);ctx.beginPath();ctx.arc(s.x,s.y,4,0,2*Math.PI);ctx.fillStyle=p.y?'#e86e3c':'#4a78c8';ctx.fill();ctx.lineWidth=1.4;ctx.strokeStyle=isTest?'#fff':'rgba(0,0,0,0.4)';ctx.stroke();});
  renderNeurons();
}
function renderNeurons(){
  var host=document.getElementById('neurons');
  if(host.children.length!==W[0].length){host.innerHTML='';for(var i=0;i<W[0].length;i++){var c=document.createElement('canvas');c.width=34;c.height=34;host.appendChild(c);}}
  for(var o=0;o<W[0].length;o++){
    var c=host.children[o],cx=c.getContext('2d'),img=cx.createImageData(34,34);
    for(var gy=0;gy<34;gy++)for(var gx=0;gx<34;gx++){
      var xy=toXY(gx/34*(GRID-1),gy/34*(GRID-1));var x=feat(xy);
      var s=B[0][o];for(var i=0;i<W[0][o].length;i++)s+=W[0][o][i]*x[i];
      var a=(actF(s)+1)/2; if(act==='relu')a=Math.min(1,Math.max(0,actF(s))); if(act==='sigmoid')a=actF(s);
      var col=[70,120,200],ol=[232,110,60],idx=(gy*34+gx)*4;
      img.data[idx]=col[0]+(ol[0]-col[0])*a;img.data[idx+1]=col[1]+(ol[1]-col[1])*a;img.data[idx+2]=col[2]+(ol[2]-col[2])*a;img.data[idx+3]=255;
    }
    cx.putImageData(img,0,0);
  }
}
var lc=document.getElementById('lossCanvas'),lx=lc.getContext('2d');
function drawLoss(){
  lx.clearRect(0,0,lc.width,lc.height);lx.fillStyle='#0b0d13';lx.fillRect(0,0,lc.width,lc.height);
  if(lossHist.length<2)return;
  var maxL=0;lossHist.forEach(function(h){maxL=Math.max(maxL,h.tr,h.te);});maxL=maxL||1;
  function line(key,col){lx.strokeStyle=col;lx.lineWidth=1.5;lx.beginPath();lossHist.forEach(function(h,i){var x=i/(lossHist.length-1)*lc.width,y=lc.height-(h[key]/maxL)*(lc.height-6)-3;i?lx.lineTo(x,y):lx.moveTo(x,y);});lx.stroke();}
  line('te','#e8720c');line('tr','#67e8f9');
  lx.fillStyle='#67e8f9';lx.font='9px monospace';lx.fillText('train',6,12);lx.fillStyle='#e8720c';lx.fillText('test',44,12);
}
function metrics(){
  var tr=evalSet(TRAIN),te=evalSet(TEST);
  document.getElementById('mEpoch').textContent=epoch;
  document.getElementById('mTrain').textContent=tr.loss.toFixed(4);
  document.getElementById('mTest').textContent=te.loss.toFixed(4);
  document.getElementById('mTrainAcc').textContent=(tr.acc*100).toFixed(1)+'%';
  document.getElementById('mTestAcc').textContent=(te.acc*100).toFixed(1)+'%';
  document.getElementById('mParams').textContent=paramCount();
  lossHist.push({tr:tr.loss,te:te.loss});if(lossHist.length>240)lossHist.shift();
  drawLoss();
}
// ---------------- arch editor ----------------
function buildArch(){
  var host=document.getElementById('arch');host.innerHTML='';
  var sizes=archSizes;
  sizes.forEach(function(sz,l){
    var wrap=document.createElement('div');wrap.className='nn-layer';
    var label=(l===0?'input':l===sizes.length-1?'output':'hidden '+l);
    wrap.innerHTML='<div style="color:#67e8f9;font-weight:700;">'+sz+'</div><div style="opacity:0.6;">'+label+'</div>';
    if(l>0&&l<sizes.length-1){
      var btns=document.createElement('div');btns.className='nn-layer-btns';
      var minus=document.createElement('button');minus.className='nn-mini';minus.textContent='−';minus.onclick=function(){if(arch[l]>1){arch[l]--;resetAll();}};
      var plus=document.createElement('button');plus.className='nn-mini';plus.textContent='+';plus.onclick=function(){if(arch[l]<8){arch[l]++;resetAll();}};
      btns.appendChild(minus);btns.appendChild(plus);wrap.appendChild(btns);
    }
    host.appendChild(wrap);
    if(l<sizes.length-1){var ar=document.createElement('div');ar.textContent='→';ar.style.opacity='0.4';host.appendChild(ar);}
  });
  // add/remove hidden layer
  var ctrl=document.createElement('div');ctrl.style.marginLeft='10px';
  ctrl.innerHTML='<button class="nn-mini" id="delLayer" title="remove layer">layer −</button> <button class="nn-mini" id="addLayer" title="add layer" style="width:auto;padding:0 6px;">layer +</button>';
  host.appendChild(ctrl);
  document.getElementById('addLayer').onclick=function(){if(arch.length<5){arch.splice(arch.length-1,0,4);resetAll();}};
  document.getElementById('delLayer').onclick=function(){if(arch.length>2){arch.splice(arch.length-2,1);resetAll();}};
}

// ---------------- loop + controls ----------------
function step(){
  var order=TRAIN.slice().sort(function(){return Math.random()-0.5;});
  for(var i=0;i<order.length;i+=bs)trainBatch(order.slice(i,i+bs));
  epoch++;
  if(epoch%2===0){render();}else{renderNeurons();}
  if(epoch%3===0)metrics();
}
var raf=null;
function loop(){ if(!running)return; step(); raf=requestAnimationFrame(loop); }
document.getElementById('nnPlay').addEventListener('click',function(){running=!running;this.textContent=running?'Pause':'Train';this.classList.toggle('primary',!running);if(running)loop();});
document.getElementById('nnStep').addEventListener('click',function(){step();metrics();render();});
document.getElementById('nnReset').addEventListener('click',function(){running=false;document.getElementById('nnPlay').textContent='Train';document.getElementById('nnPlay').classList.add('primary');resetAll();});
// dataset chips
document.querySelectorAll('#dsRow .nn-chip').forEach(function(b){b.addEventListener('click',function(){document.querySelectorAll('#dsRow .nn-chip').forEach(function(x){x.classList.remove('on');});b.classList.add('on');dsKind=b.getAttribute('data-ds');resetAll();});});
// feature chips
document.querySelectorAll('#featRow .nn-chip').forEach(function(b){b.addEventListener('click',function(){b.classList.toggle('on');featKeys=Array.prototype.filter.call(document.querySelectorAll('#featRow .nn-chip'),function(x){return x.classList.contains('on');}).map(function(x){return x.getAttribute('data-f');});if(featKeys.length===0){b.classList.add('on');featKeys=[b.getAttribute('data-f')];}resetAll();});});
// sliders
function bind(id,fn,fmt){var el=document.getElementById(id);el.addEventListener('input',function(){fn(parseFloat(el.value));var v=document.getElementById(id+'V');if(v)v.textContent=fmt(parseFloat(el.value));});}
bind('noise',function(v){noise=v;regen();render();},function(v){return v.toFixed(2);});
bind('split',function(v){split=v/100;regen();render();metrics();},function(v){return v+'%';});
bind('lr',function(v){lr=Math.pow(10,v);},function(v){return Math.pow(10,v).toFixed(v<-2?4:3);});
bind('reg',function(v){reg=v;},function(v){return v.toFixed(3);});
bind('bs',function(v){bs=v;},function(v){return v;});
document.getElementById('act').addEventListener('change',function(){act=this.value;resetAll();});
// init
lr=Math.pow(10,-1.52);
resetAll();
})();
</script>

</BaseLayout>
