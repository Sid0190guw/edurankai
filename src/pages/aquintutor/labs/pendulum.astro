---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Pendulum lab · Virtual Labs · AquinTutor" description="Simple, damped, and driven pendulum. Real Runge-Kutta integration. Live energy and phase plot.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; }
  .pd-wrap { max-width: 1300px; margin: 0 auto; padding: 20px 4vw 60px; }
  .pd-top { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 14px; margin-bottom: 20px; }
  .pd-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; }
  .pd-title { font-family: 'Cormorant Garamond', serif; font-size: 36px; font-weight: 600; margin: 4px 0 0; letter-spacing: -0.02em; }
  .pd-title em { color: #67e8f9; font-style: italic; font-weight: 500; }
  .pd-grid { display: grid; grid-template-columns: 280px minmax(0,1fr); gap: 18px; }
  @media (max-width: 900px) { .pd-grid { grid-template-columns: 1fr; } }
  .pd-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 16px; margin-bottom: 12px; }
  .pd-panel h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 10px; }
  .pd-row { display: grid; gap: 8px; }
  .pd-row label { font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; display: flex; justify-content: space-between; }
  .pd-row label span { color: #67e8f9; }
  .pd-row input[type=range] { width: 100%; }
  .pd-row select { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; color: #fff; padding: 7px 10px; border-radius: 5px; font-size: 12px; font-family: inherit; }
  .pd-btn { background: #67e8f9; color: #04161b; padding: 9px 16px; border-radius: 6px; border: none; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
  .pd-btn-ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
  .pd-svg { width: 100%; height: 420px; background: radial-gradient(circle at 50% 30%, #15151c, #0a0a0c); border-radius: 12px; border: 1px solid #2a2a35; }
  .pd-plot { width: 100%; height: 200px; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; }
  .pd-metric { display: grid; grid-template-columns: 1fr auto; gap: 8px; font-family: 'Geist Mono', monospace; font-size: 11.5px; padding: 5px 0; border-bottom: 1px solid #1a1a25; }
  .pd-metric:last-child { border-bottom: none; }
  .pd-metric-l { color: #9aa6b6; }
  .pd-metric-v { color: #67e8f9; font-weight: 700; text-align: right; }
</style>

<main class="pd-wrap">
  <div class="pd-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#67e8f9;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="pd-eye" style="margin-top:10px;">Physics · Mechanics</p>
      <h1 class="pd-title">Pendulum &amp; <em>SHM</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;">
      <button id="resetBtn" class="pd-btn pd-btn-ghost">Reset</button>
      <button id="playBtn" class="pd-btn">Pause</button>
    </div>
  </div>

  <div class="pd-grid">
    <aside>
      <div class="pd-panel">
        <h3>Parameters</h3>
        <div class="pd-row">
          <label>Length (m) <span id="lenV">1.00</span></label>
          <input id="len" type="range" min="0.2" max="3.0" step="0.05" value="1.0"/>
          <label>Mass (kg) <span id="massV">1.00</span></label>
          <input id="mass" type="range" min="0.1" max="5.0" step="0.1" value="1.0"/>
          <label>Gravity (m/s²) <span id="gV">9.81</span></label>
          <input id="g" type="range" min="1" max="25" step="0.1" value="9.81"/>
          <label>Initial angle (°) <span id="th0V">45</span></label>
          <input id="th0" type="range" min="-179" max="179" step="1" value="45"/>
          <label>Damping (1/s) <span id="dampV">0.02</span></label>
          <input id="damp" type="range" min="0" max="2" step="0.01" value="0.02"/>
          <label>Drive amplitude <span id="driveV">0.00</span></label>
          <input id="drive" type="range" min="0" max="3" step="0.05" value="0"/>
          <label>Drive frequency <span id="driveFV">0.00</span></label>
          <input id="driveF" type="range" min="0" max="5" step="0.05" value="0"/>
        </div>
      </div>

      <div class="pd-panel">
        <h3>Mode</h3>
        <select id="mode">
          <option value="simple">Simple (small-angle)</option>
          <option value="nonlin" selected>Non-linear (full)</option>
          <option value="damped">Damped</option>
          <option value="driven">Driven + damped</option>
        </select>
      </div>

      <div class="pd-panel">
        <h3>Live state</h3>
        <div class="pd-metric"><span class="pd-metric-l">θ (rad)</span><span class="pd-metric-v" id="mTh">—</span></div>
        <div class="pd-metric"><span class="pd-metric-l">ω (rad/s)</span><span class="pd-metric-v" id="mOmega">—</span></div>
        <div class="pd-metric"><span class="pd-metric-l">Period T</span><span class="pd-metric-v" id="mT">—</span></div>
        <div class="pd-metric"><span class="pd-metric-l">KE (J)</span><span class="pd-metric-v" id="mKE">—</span></div>
        <div class="pd-metric"><span class="pd-metric-l">PE (J)</span><span class="pd-metric-v" id="mPE">—</span></div>
        <div class="pd-metric"><span class="pd-metric-l">Total E (J)</span><span class="pd-metric-v" id="mE">—</span></div>
      </div>
    </aside>

    <section>
      <svg id="svg" class="pd-svg" viewBox="0 0 600 420" preserveAspectRatio="xMidYMid meet"></svg>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:12px;">
        <div class="pd-panel" style="margin:0;">
          <h3>Energy vs time</h3>
          <svg id="energyPlot" class="pd-plot" viewBox="0 0 600 200"></svg>
        </div>
        <div class="pd-panel" style="margin:0;">
          <h3>Phase plot · θ vs ω</h3>
          <svg id="phasePlot" class="pd-plot" viewBox="-200 -150 400 300"></svg>
        </div>
      </div>
    </section>
  </div>
</main>

<script is:inline>
  (function () {
    var p = { L: 1.0, m: 1.0, g: 9.81, th: 45 * Math.PI / 180, omega: 0, t: 0, damp: 0.02, drive: 0, driveF: 0, mode: 'nonlin' };
    var paused = false;
    var history = []; // {t, KE, PE, E, th, omega}

    function readControls() {
      var v = function (id) { return parseFloat(document.getElementById(id).value); };
      p.L = v('len'); p.m = v('mass'); p.g = v('g'); p.damp = v('damp');
      p.drive = v('drive'); p.driveF = v('driveF');
      p.mode = document.getElementById('mode').value;
      document.getElementById('lenV').textContent = p.L.toFixed(2);
      document.getElementById('massV').textContent = p.m.toFixed(2);
      document.getElementById('gV').textContent = p.g.toFixed(2);
      document.getElementById('dampV').textContent = p.damp.toFixed(2);
      document.getElementById('driveV').textContent = p.drive.toFixed(2);
      document.getElementById('driveFV').textContent = p.driveF.toFixed(2);
      document.getElementById('th0V').textContent = (parseFloat(document.getElementById('th0').value)).toFixed(0);
    }
    document.querySelectorAll('input, select').forEach(function (el) { el.addEventListener('input', readControls); el.addEventListener('change', readControls); });
    readControls();

    function reset() {
      p.t = 0; p.th = parseFloat(document.getElementById('th0').value) * Math.PI / 180; p.omega = 0;
      history = [];
    }
    reset();

    document.getElementById('resetBtn').addEventListener('click', reset);
    document.getElementById('playBtn').addEventListener('click', function () {
      paused = !paused;
      this.textContent = paused ? 'Play' : 'Pause';
    });

    // dθ/dt = ω;  dω/dt = -(g/L)*sin(θ) - damp*ω + drive*cos(driveF*t)
    function deriv(th, omega, t) {
      var torque;
      if (p.mode === 'simple') torque = -(p.g / p.L) * th;
      else torque = -(p.g / p.L) * Math.sin(th);
      if (p.mode === 'damped' || p.mode === 'driven') torque -= p.damp * omega;
      if (p.mode === 'driven') torque += p.drive * Math.cos(p.driveF * t);
      return { dth: omega, domega: torque };
    }
    function step(dt) {
      var k1 = deriv(p.th, p.omega, p.t);
      var k2 = deriv(p.th + dt/2 * k1.dth, p.omega + dt/2 * k1.domega, p.t + dt/2);
      var k3 = deriv(p.th + dt/2 * k2.dth, p.omega + dt/2 * k2.domega, p.t + dt/2);
      var k4 = deriv(p.th + dt * k3.dth, p.omega + dt * k3.domega, p.t + dt);
      p.th += dt/6 * (k1.dth + 2*k2.dth + 2*k3.dth + k4.dth);
      p.omega += dt/6 * (k1.domega + 2*k2.domega + 2*k3.domega + k4.domega);
      p.t += dt;
    }

    function svgEl(tag, attrs) { var e = document.createElementNS('http://www.w3.org/2000/svg', tag); for (var k in attrs) e.setAttribute(k, attrs[k]); return e; }

    function draw() {
      var svg = document.getElementById('svg'); svg.innerHTML = '';
      var w = 600, h = 420, cx = w/2, cy = 80;
      var scale = 100; // px per metre
      var x = cx + scale * p.L * Math.sin(p.th);
      var y = cy + scale * p.L * Math.cos(p.th);
      // pivot
      svg.appendChild(svgEl('line', { x1: cx-30, y1: cy, x2: cx+30, y2: cy, stroke: '#67e8f9', 'stroke-width': 3 }));
      for (var i = 0; i < 6; i++) {
        svg.appendChild(svgEl('line', { x1: cx-30 + i*12, y1: cy, x2: cx-36 + i*12, y2: cy-8, stroke: '#67e8f9', 'stroke-width': 1 }));
      }
      // ghost trail
      history.slice(-40).forEach(function (s, i) {
        var sx = cx + scale * p.L * Math.sin(s.th);
        var sy = cy + scale * p.L * Math.cos(s.th);
        svg.appendChild(svgEl('circle', { cx: sx, cy: sy, r: 2, fill: '#67e8f9', opacity: i / 40 * 0.4 }));
      });
      // rod
      svg.appendChild(svgEl('line', { x1: cx, y1: cy, x2: x, y2: y, stroke: '#fbbf24', 'stroke-width': 2 }));
      // bob (size proportional to mass)
      var r = 8 + p.m * 4;
      svg.appendChild(svgEl('circle', { cx: x, cy: y, r: r, fill: '#fbbf24', stroke: '#fff', 'stroke-width': 1 }));
      // angle arc
      svg.appendChild(svgEl('path', { d: 'M ' + cx + ' ' + (cy + 40) + ' A 40 40 0 0 ' + (p.th > 0 ? 1 : 0) + ' ' + (cx + 40 * Math.sin(p.th)) + ' ' + (cy + 40 * Math.cos(p.th)), fill: 'none', stroke: '#9aa6b6', 'stroke-width': 1, 'stroke-dasharray': '3 3' }));
      var lbl = svgEl('text', { x: 12, y: 20, fill: '#67e8f9', 'font-family': 'Geist Mono', 'font-size': 12, 'font-weight': 700 });
      lbl.textContent = 't = ' + p.t.toFixed(2) + ' s   θ = ' + (p.th * 180 / Math.PI).toFixed(1) + '°';
      svg.appendChild(lbl);
    }

    function metrics() {
      var KE = 0.5 * p.m * Math.pow(p.L * p.omega, 2);
      var PE = p.m * p.g * p.L * (1 - Math.cos(p.th));
      var E = KE + PE;
      var T = 2 * Math.PI * Math.sqrt(p.L / p.g); // small-angle period
      document.getElementById('mTh').textContent = p.th.toFixed(3);
      document.getElementById('mOmega').textContent = p.omega.toFixed(3);
      document.getElementById('mT').textContent = T.toFixed(3) + ' s';
      document.getElementById('mKE').textContent = KE.toFixed(3);
      document.getElementById('mPE').textContent = PE.toFixed(3);
      document.getElementById('mE').textContent = E.toFixed(3);
      history.push({ t: p.t, KE: KE, PE: PE, E: E, th: p.th, omega: p.omega });
      if (history.length > 600) history.shift();
    }

    function drawEnergyPlot() {
      var svg = document.getElementById('energyPlot'); svg.innerHTML = '';
      if (history.length < 2) return;
      var maxE = Math.max(1e-3, Math.max.apply(null, history.map(function (h) { return h.E; })));
      var tMin = history[0].t, tMax = history[history.length-1].t;
      function px(t) { return ((t - tMin) / (tMax - tMin + 1e-9)) * 580 + 10; }
      function py(e, maxE) { return 190 - (e / maxE) * 170; }
      var paths = ['KE,#fbbf24', 'PE,#a78bfa', 'E,#67e8f9'];
      paths.forEach(function (p) {
        var key = p.split(',')[0], col = p.split(',')[1];
        var d = '';
        history.forEach(function (h, i) { d += (i === 0 ? 'M' : 'L') + px(h.t) + ',' + py(h[key], maxE); });
        svg.appendChild(svgEl('path', { d: d, fill: 'none', stroke: col, 'stroke-width': 1.5 }));
      });
      // legend
      ['KE,#fbbf24,20', 'PE,#a78bfa,80', 'E,#67e8f9,140'].forEach(function (p) {
        var parts = p.split(',');
        svg.appendChild(svgEl('rect', { x: parts[2], y: 6, width: 10, height: 10, fill: parts[1] }));
        var t = svgEl('text', { x: parseFloat(parts[2]) + 14, y: 15, fill: '#cfd6da', 'font-family': 'Geist Mono', 'font-size': 10 });
        t.textContent = parts[0]; svg.appendChild(t);
      });
    }

    function drawPhasePlot() {
      var svg = document.getElementById('phasePlot'); svg.innerHTML = '';
      svg.appendChild(svgEl('line', { x1: -190, y1: 0, x2: 190, y2: 0, stroke: '#2a2a35' }));
      svg.appendChild(svgEl('line', { x1: 0, y1: -140, x2: 0, y2: 140, stroke: '#2a2a35' }));
      var thLbl = svgEl('text', { x: 175, y: -8, fill: '#9aa6b6', 'font-family': 'Geist Mono', 'font-size': 10 }); thLbl.textContent = 'θ'; svg.appendChild(thLbl);
      var omLbl = svgEl('text', { x: 8, y: -130, fill: '#9aa6b6', 'font-family': 'Geist Mono', 'font-size': 10 }); omLbl.textContent = 'ω'; svg.appendChild(omLbl);
      if (history.length < 2) return;
      var d = '';
      history.forEach(function (h, i) {
        var x = h.th * 60;
        var y = -h.omega * 30;
        d += (i === 0 ? 'M' : 'L') + x + ',' + y;
      });
      svg.appendChild(svgEl('path', { d: d, fill: 'none', stroke: '#a78bfa', 'stroke-width': 1.2, opacity: 0.85 }));
      var last = history[history.length-1];
      svg.appendChild(svgEl('circle', { cx: last.th * 60, cy: -last.omega * 30, r: 4, fill: '#fbbf24' }));
    }

    var lastTs = 0;
    function loop(ts) {
      if (!lastTs) lastTs = ts;
      var dt = Math.min(0.05, (ts - lastTs) / 1000);
      lastTs = ts;
      if (!paused) {
        var steps = 4;
        for (var i = 0; i < steps; i++) step(dt / steps);
      }
      draw(); metrics(); drawEnergyPlot(); drawPhasePlot();
      requestAnimationFrame(loop);
    }
    requestAnimationFrame(loop);
  })();
</script>

<div id="demoHint" style="position:fixed;left:16px;bottom:16px;max-width:330px;background:#11131a;color:#e8e8ee;border:1px solid #FF4F00;border-radius:12px;padding:14px 16px;z-index:9999;box-shadow:0 12px 34px rgba(0,0,0,0.45);">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:7px;gap:10px;">
    <span style="font-family:'Geist Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#FF4F00;font-weight:700;">Try this &middot; demo</span>
    <button onclick="this.closest('#demoHint').remove()" style="background:transparent;border:none;color:#9aa6b6;cursor:pointer;font-size:18px;line-height:1;padding:0;">&times;</button>
  </div>
  <p style="margin:0;font-size:12.5px;line-height:1.55;color:#cfd6da;font-family:'Inter Tight',sans-serif,system-ui;">Switch Mode to <b>Driven + damped</b>. Set Drive amplitude ~2 and Drive frequency ~3. Watch resonance build, then chaos — the phase plot fills with loops.</p>
</div>

</BaseLayout>
