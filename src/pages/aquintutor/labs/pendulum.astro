---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Pendulum lab — RK4 physics (simple / non-linear / damped / driven), rendered
// on a high-DPI canvas with a depth-lit scene: gradient hall, metallic rod,
// glowing bob with specular highlight, motion-blur trail, live protractor, and
// glow-line energy + phase plots. Operational-grade, high graphics, no libraries.
---
<BaseLayout title="Pendulum lab · Virtual Labs · AquinTutor" description="Simple, damped, and driven pendulum. Real Runge-Kutta integration, energy accounting, and a live phase portrait — rendered on a depth-lit canvas.">
<style>
  body { background:#06070c; color:#e8ecf4; }
  .pd-wrap { max-width:1320px; margin:0 auto; padding:20px 4vw 70px; }
  .pd-top { display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:18px; }
  .pd-eye { font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .pd-title { font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; }
  .pd-title em { color:#5ee7ff; font-style:italic; font-weight:500; }
  .pd-grid { display:grid; grid-template-columns:290px minmax(0,1fr); gap:18px; }
  @media (max-width:900px){ .pd-grid { grid-template-columns:1fr; } }
  .pd-panel { background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:16px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .pd-panel h3 { font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 12px; }
  .pd-row { display:grid; gap:9px; }
  .pd-row label { font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.1em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; }
  .pd-row label span { color:#5ee7ff; }
  .pd-row input[type=range]{ width:100%; accent-color:#5ee7ff; }
  .pd-row select { width:100%; background:#080a12; border:1px solid #1e2740; color:#fff; padding:8px 10px; border-radius:6px; font-size:12px; font-family:inherit; }
  .pd-btn { background:linear-gradient(180deg,#7af0ff,#33cfe6); color:#04161b; padding:9px 16px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:11px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; box-shadow:0 4px 14px rgba(51,207,230,0.35); }
  .pd-btn-ghost { background:transparent; color:#cfd6da; border:1px solid #26314f; box-shadow:none; }
  .pd-stage { position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); }
  .pd-stage canvas { display:block; width:100%; height:auto; }
  .pd-plots { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-top:12px; }
  @media (max-width:680px){ .pd-plots { grid-template-columns:1fr; } }
  .pd-metric { display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11.5px; padding:5px 0; border-bottom:1px solid #141a2c; }
  .pd-metric:last-child { border-bottom:none; }
  .pd-metric-l { color:#8ea0be; } .pd-metric-v { color:#5ee7ff; font-weight:700; text-align:right; }
</style>

<main class="pd-wrap">
  <div class="pd-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="pd-eye" style="margin-top:10px;">Physics · Mechanics</p>
      <h1 class="pd-title">Pendulum &amp; <em>SHM</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;">
      <button id="resetBtn" class="pd-btn pd-btn-ghost">Reset</button>
      <button id="playBtn" class="pd-btn">Pause</button>
    </div>
  </div>

  <div class="pd-grid">
    <aside>
      <div class="pd-panel">
        <h3>Parameters</h3>
        <div class="pd-row">
          <label>Length (m) <span id="lenV">1.00</span></label>
          <input id="len" type="range" min="0.2" max="3.0" step="0.05" value="1.0"/>
          <label>Mass (kg) <span id="massV">1.00</span></label>
          <input id="mass" type="range" min="0.1" max="5.0" step="0.1" value="1.0"/>
          <label>Gravity (m/s²) <span id="gV">9.81</span></label>
          <input id="g" type="range" min="1" max="25" step="0.1" value="9.81"/>
          <label>Initial angle (°) <span id="th0V">45</span></label>
          <input id="th0" type="range" min="-179" max="179" step="1" value="45"/>
          <label>Damping (1/s) <span id="dampV">0.02</span></label>
          <input id="damp" type="range" min="0" max="2" step="0.01" value="0.02"/>
          <label>Drive amplitude <span id="driveV">0.00</span></label>
          <input id="drive" type="range" min="0" max="3" step="0.05" value="0"/>
          <label>Drive frequency <span id="driveFV">0.00</span></label>
          <input id="driveF" type="range" min="0" max="5" step="0.05" value="0"/>
        </div>
      </div>
      <div class="pd-panel">
        <h3>Mode</h3>
        <select id="mode">
          <option value="simple">Simple (small-angle)</option>
          <option value="nonlin" selected>Non-linear (full)</option>
          <option value="damped">Damped</option>
          <option value="driven">Driven + damped</option>
        </select>
      </div>
      <div class="pd-panel">
        <h3>Live state</h3>
        <div class="pd-metric"><span class="pd-metric-l">θ (rad)</span><span class="pd-metric-v" id="mTh">—</span></div>
        <div class="pd-metric"><span class="pd-metric-l">ω (rad/s)</span><span class="pd-metric-v" id="mOmega">—</span></div>
        <div class="pd-metric"><span class="pd-metric-l">Period T</span><span class="pd-metric-v" id="mT">—</span></div>
        <div class="pd-metric"><span class="pd-metric-l">KE (J)</span><span class="pd-metric-v" id="mKE">—</span></div>
        <div class="pd-metric"><span class="pd-metric-l">PE (J)</span><span class="pd-metric-v" id="mPE">—</span></div>
        <div class="pd-metric"><span class="pd-metric-l">Total E (J)</span><span class="pd-metric-v" id="mE">—</span></div>
      </div>
    </aside>

    <section>
      <div class="pd-stage"><canvas id="scene" width="900" height="620"></canvas></div>
      <div class="pd-plots">
        <div class="pd-panel" style="margin:0;"><h3>Energy vs time</h3><canvas id="energy" width="560" height="200" style="width:100%;height:auto;"></canvas></div>
        <div class="pd-panel" style="margin:0;"><h3>Phase portrait · θ vs ω</h3><canvas id="phase" width="560" height="200" style="width:100%;height:auto;"></canvas></div>
      </div>
    </section>
  </div>
</main>

<script is:inline>
(function(){
  var p = { L:1.0, m:1.0, g:9.81, th:45*Math.PI/180, omega:0, t:0, damp:0.02, drive:0, driveF:0, mode:'nonlin' };
  var paused=false, hist=[], trail=[];

  function v(id){ return parseFloat(document.getElementById(id).value); }
  function readControls(){
    p.L=v('len'); p.m=v('mass'); p.g=v('g'); p.damp=v('damp'); p.drive=v('drive'); p.driveF=v('driveF'); p.mode=document.getElementById('mode').value;
    document.getElementById('lenV').textContent=p.L.toFixed(2); document.getElementById('massV').textContent=p.m.toFixed(2);
    document.getElementById('gV').textContent=p.g.toFixed(2); document.getElementById('dampV').textContent=p.damp.toFixed(2);
    document.getElementById('driveV').textContent=p.drive.toFixed(2); document.getElementById('driveFV').textContent=p.driveF.toFixed(2);
    document.getElementById('th0V').textContent=v('th0').toFixed(0);
  }
  document.querySelectorAll('input,select').forEach(function(el){ el.addEventListener('input',readControls); el.addEventListener('change',readControls); });
  readControls();
  function reset(){ p.t=0; p.th=v('th0')*Math.PI/180; p.omega=0; hist=[]; trail=[]; }
  reset();
  document.getElementById('resetBtn').addEventListener('click',reset);
  document.getElementById('playBtn').addEventListener('click',function(){ paused=!paused; this.textContent=paused?'Play':'Pause'; });

  function deriv(th,omega,t){ var tq = p.mode==='simple' ? -(p.g/p.L)*th : -(p.g/p.L)*Math.sin(th);
    if(p.mode==='damped'||p.mode==='driven') tq -= p.damp*omega; if(p.mode==='driven') tq += p.drive*Math.cos(p.driveF*t);
    return { dth:omega, domega:tq }; }
  function stepRK4(dt){ var k1=deriv(p.th,p.omega,p.t),
    k2=deriv(p.th+dt/2*k1.dth,p.omega+dt/2*k1.domega,p.t+dt/2),
    k3=deriv(p.th+dt/2*k2.dth,p.omega+dt/2*k2.domega,p.t+dt/2),
    k4=deriv(p.th+dt*k3.dth,p.omega+dt*k3.domega,p.t+dt);
    p.th+=dt/6*(k1.dth+2*k2.dth+2*k3.dth+k4.dth); p.omega+=dt/6*(k1.domega+2*k2.domega+2*k3.domega+k4.domega); p.t+=dt; }

  // ---- high-DPI canvas setup ----
  function hidpi(cv){ var r=cv.getBoundingClientRect(), d=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w;
    cv.width=Math.round(w*d); cv.height=Math.round(h*d); var ctx=cv.getContext('2d'); ctx.setTransform(d,0,0,d,0,0); return {ctx:ctx,w:w,h:h}; }

  function drawScene(){
    var cv=document.getElementById('scene'); var s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h;
    // hall gradient
    var bg=ctx.createLinearGradient(0,0,0,H); bg.addColorStop(0,'#0c1226'); bg.addColorStop(0.55,'#080b16'); bg.addColorStop(1,'#05070f');
    ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    // faint grid
    ctx.strokeStyle='rgba(94,231,255,0.05)'; ctx.lineWidth=1;
    for(var gx=0;gx<W;gx+=40){ ctx.beginPath(); ctx.moveTo(gx,0); ctx.lineTo(gx,H); ctx.stroke(); }
    for(var gy=0;gy<H;gy+=40){ ctx.beginPath(); ctx.moveTo(0,gy); ctx.lineTo(W,gy); ctx.stroke(); }

    var cx=W/2, cy=H*0.16, scale=Math.min(W,H)*0.30/1.0; // px per metre-ish, scaled by L below
    var px=cx+scale*p.L*Math.sin(p.th), py=cy+scale*p.L*Math.cos(p.th);

    // ceiling mount with hatch
    ctx.fillStyle='#131a2e'; ctx.fillRect(cx-46,cy-16,92,16);
    ctx.strokeStyle='#5ee7ff'; ctx.lineWidth=2; ctx.beginPath(); ctx.moveTo(cx-46,cy); ctx.lineTo(cx+46,cy); ctx.stroke();
    ctx.strokeStyle='rgba(94,231,255,0.5)'; ctx.lineWidth=1;
    for(var i=0;i<9;i++){ ctx.beginPath(); ctx.moveTo(cx-44+i*11,cy); ctx.lineTo(cx-50+i*11,cy-10); ctx.stroke(); }

    // protractor arc + rest line
    ctx.strokeStyle='rgba(142,160,190,0.35)'; ctx.setLineDash([4,5]); ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(cx,cy); ctx.lineTo(cx,cy+scale*p.L*1.06); ctx.stroke();
    ctx.beginPath(); var a0=Math.PI/2, a1=Math.PI/2 - p.th; ctx.arc(cx,cy,54,Math.min(a0,a1),Math.max(a0,a1)); ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle='#8ea0be'; ctx.font="600 12px 'Geist Mono',monospace";
    ctx.fillText((p.th*180/Math.PI).toFixed(1)+'°', cx+8, cy+70);

    // motion-blur trail
    for(var t=0;t<trail.length;t++){ var pt=trail[t], al=(t/trail.length); ctx.beginPath();
      ctx.fillStyle='rgba(251,191,36,'+(al*0.5).toFixed(3)+')'; ctx.arc(pt.x,pt.y,2+al*2.5,0,7); ctx.fill(); }

    // rod (metallic gradient)
    var rg=ctx.createLinearGradient(cx,cy,px,py); rg.addColorStop(0,'#c7cfdd'); rg.addColorStop(0.5,'#6b7690'); rg.addColorStop(1,'#3a4258');
    ctx.strokeStyle=rg; ctx.lineWidth=4; ctx.lineCap='round'; ctx.beginPath(); ctx.moveTo(cx,cy); ctx.lineTo(px,py); ctx.stroke();
    // pivot cap
    ctx.fillStyle='#e8ecf4'; ctx.beginPath(); ctx.arc(cx,cy,4,0,7); ctx.fill();

    // bob — outer glow + radial body + specular
    var r=10+p.m*5;
    ctx.save(); ctx.shadowColor='rgba(251,191,36,0.8)'; ctx.shadowBlur=28;
    var bg2=ctx.createRadialGradient(px-r*0.35,py-r*0.4,r*0.2,px,py,r); bg2.addColorStop(0,'#fff2c4'); bg2.addColorStop(0.35,'#fcd34d'); bg2.addColorStop(1,'#b8791a');
    ctx.fillStyle=bg2; ctx.beginPath(); ctx.arc(px,py,r,0,7); ctx.fill(); ctx.restore();
    ctx.fillStyle='rgba(255,255,255,0.85)'; ctx.beginPath(); ctx.arc(px-r*0.32,py-r*0.36,r*0.22,0,7); ctx.fill();

    // HUD
    ctx.fillStyle='#5ee7ff'; ctx.font="700 13px 'Geist Mono',monospace";
    ctx.fillText('t = '+p.t.toFixed(2)+' s', 14, 24);
    ctx.fillStyle='#8ea0be'; ctx.fillText('ω = '+p.omega.toFixed(2)+' rad/s', 14, 42);
  }

  function metrics(){
    var KE=0.5*p.m*Math.pow(p.L*p.omega,2), PE=p.m*p.g*p.L*(1-Math.cos(p.th)), E=KE+PE, T=2*Math.PI*Math.sqrt(p.L/p.g);
    document.getElementById('mTh').textContent=p.th.toFixed(3); document.getElementById('mOmega').textContent=p.omega.toFixed(3);
    document.getElementById('mT').textContent=T.toFixed(3)+' s'; document.getElementById('mKE').textContent=KE.toFixed(3);
    document.getElementById('mPE').textContent=PE.toFixed(3); document.getElementById('mE').textContent=E.toFixed(3);
    hist.push({t:p.t,KE:KE,PE:PE,E:E,th:p.th,omega:p.omega}); if(hist.length>700) hist.shift();
  }

  function glowLine(ctx,pts,col){ ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=8; ctx.strokeStyle=col; ctx.lineWidth=1.6; ctx.beginPath();
    pts.forEach(function(q,i){ i?ctx.lineTo(q[0],q[1]):ctx.moveTo(q[0],q[1]); }); ctx.stroke(); ctx.restore(); }

  function drawEnergy(){
    var cv=document.getElementById('energy'); var s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h;
    ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H);
    ctx.strokeStyle='rgba(94,231,255,0.06)'; for(var y=0;y<H;y+=28){ ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke(); }
    if(hist.length<2) return;
    var maxE=Math.max(1e-3,Math.max.apply(null,hist.map(function(h){return h.E;})));
    var t0=hist[0].t, t1=hist[hist.length-1].t;
    function X(t){ return ((t-t0)/(t1-t0+1e-9))*(W-16)+8; } function Y(e){ return H-10-(e/maxE)*(H-24); }
    [['KE','#fbbf24'],['PE','#a78bfa'],['E','#5ee7ff']].forEach(function(k){ glowLine(ctx,hist.map(function(h){return [X(h.t),Y(h[k[0]])];}),k[1]); });
    var lx=10; [['KE','#fbbf24'],['PE','#a78bfa'],['E','#5ee7ff']].forEach(function(k){ ctx.fillStyle=k[1]; ctx.fillRect(lx,8,9,9); ctx.fillStyle='#cfd6da'; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText(k[0],lx+13,16); lx+=52; });
  }

  function drawPhase(){
    var cv=document.getElementById('phase'); var s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h, cx=W/2, cy=H/2;
    ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H);
    ctx.strokeStyle='#1a2340'; ctx.lineWidth=1; ctx.beginPath(); ctx.moveTo(8,cy); ctx.lineTo(W-8,cy); ctx.moveTo(cx,8); ctx.lineTo(cx,H-8); ctx.stroke();
    ctx.fillStyle='#8ea0be'; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText('θ',W-16,cy-6); ctx.fillText('ω',cx+6,14);
    if(hist.length<2) return;
    var sx=(W*0.42)/Math.PI, sy=(H*0.42)/Math.max(2,Math.max.apply(null,hist.map(function(h){return Math.abs(h.omega);})));
    glowLine(ctx,hist.map(function(h){return [cx+h.th*sx, cy-h.omega*sy];}),'#a78bfa');
    var last=hist[hist.length-1]; ctx.save(); ctx.shadowColor='#fbbf24'; ctx.shadowBlur=12; ctx.fillStyle='#fbbf24'; ctx.beginPath(); ctx.arc(cx+last.th*sx,cy-last.omega*sy,4,0,7); ctx.fill(); ctx.restore();
  }

  var lastTs=0;
  function loop(ts){ if(!lastTs) lastTs=ts; var dt=Math.min(0.05,(ts-lastTs)/1000); lastTs=ts;
    if(!paused){ for(var i=0;i<4;i++) stepRK4(dt/4);
      var cv=document.getElementById('scene'), rct=cv.getBoundingClientRect(); var W=rct.width||900, H=(620/900)*W;
      var cx=W/2, cy=H*0.16, scale=Math.min(W,H)*0.30; trail.push({x:cx+scale*p.L*Math.sin(p.th), y:cy+scale*p.L*Math.cos(p.th)}); if(trail.length>46) trail.shift();
    }
    drawScene(); metrics(); drawEnergy(); drawPhase(); requestAnimationFrame(loop);
  }
  requestAnimationFrame(loop);
})();
</script>

<div id="demoHint" style="position:fixed;left:16px;bottom:16px;max-width:330px;background:#0f1220;color:#e8ecf4;border:1px solid #5ee7ff;border-radius:12px;padding:14px 16px;z-index:9999;box-shadow:0 12px 34px rgba(0,0,0,0.5);">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:7px;gap:10px;">
    <span style="font-family:'Geist Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#5ee7ff;font-weight:700;">Try this &middot; demo</span>
    <button onclick="this.closest('#demoHint').remove()" style="background:transparent;border:none;color:#8ea0be;cursor:pointer;font-size:18px;line-height:1;padding:0;">&times;</button>
  </div>
  <p style="margin:0;font-size:12.5px;line-height:1.55;color:#cfd6da;font-family:'Inter Tight',sans-serif,system-ui;">Switch Mode to <b>Driven + damped</b>. Set Drive amplitude ~2 and Drive frequency ~3. Watch resonance build, then chaos — the phase portrait fills with loops.</p>
</div>
</BaseLayout>
