---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Pendulum & nonlinear dynamics lab (graduate level). RK4 physics for the
// single pendulum (simple / full nonlinear / damped / driven) AND the double
// pendulum — the canonical chaotic system — with a divergent "twin" started a
// hair away to show sensitive dependence on initial conditions. Computes: the
// exact large-amplitude period via the arithmetic-geometric mean (elliptic
// integral K) versus the small-angle approximation; a live largest Lyapunov
// exponent from renormalised trajectory separation; and a stroboscopic
// Poincaré section for the driven case. Depth-lit canvas, no libraries.
---
<BaseLayout title="Pendulum & Nonlinear Dynamics · Virtual Labs · AquinTutor" description="Graduate nonlinear dynamics: single + double pendulum with RK4, sensitive dependence (a divergent twin), a live Lyapunov exponent, a driven-pendulum Poincaré section, and the exact large-amplitude period via the AGM elliptic integral. Built from scratch.">
<style>
  body { background:#06070c; color:#e8ecf4; }
  .pd-wrap { max-width:1340px; margin:0 auto; padding:20px 4vw 70px; }
  .pd-top { display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:16px; }
  .pd-eye { font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .pd-title { font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; }
  .pd-title em { color:#5ee7ff; font-style:italic; font-weight:500; }
  .pd-grid { display:grid; grid-template-columns:300px minmax(0,1fr); gap:18px; }
  @media (max-width:960px){ .pd-grid { grid-template-columns:1fr; } }
  .pd-panel { background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:15px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .pd-panel h3 { font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 11px; }
  .pd-row { display:grid; gap:8px; }
  .pd-row label { font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.08em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; }
  .pd-row label span { color:#5ee7ff; }
  .pd-row input[type=range]{ width:100%; accent-color:#5ee7ff; }
  select { width:100%; background:#080a12; border:1px solid #1e2740; color:#fff; padding:8px 10px; border-radius:6px; font-size:12px; font-family:inherit; }
  .pd-btn { background:linear-gradient(180deg,#7af0ff,#33cfe6); color:#04161b; padding:9px 15px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:11px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; box-shadow:0 4px 14px rgba(51,207,230,0.35); }
  .pd-btn-ghost { background:transparent; color:#cfd6da; border:1px solid #26314f; box-shadow:none; }
  .pd-stage { position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); }
  .pd-stage canvas { display:block; width:100%; height:auto; }
  .pd-plots { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-top:12px; }
  @media (max-width:680px){ .pd-plots { grid-template-columns:1fr; } }
  .pd-metric { display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11px; padding:4px 0; border-bottom:1px solid #141a2c; }
  .pd-metric:last-child { border-bottom:none; } .pd-metric-l { color:#8ea0be; } .pd-metric-v { color:#5ee7ff; font-weight:700; text-align:right; }
</style>

<main class="pd-wrap">
  <div class="pd-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="pd-eye" style="margin-top:10px;">Physics · Nonlinear Dynamics · Chaos</p>
      <h1 class="pd-title">Pendulum &amp; <em>chaos</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;">
      <button id="resetBtn" class="pd-btn pd-btn-ghost">Reset</button>
      <button id="playBtn" class="pd-btn">Pause</button>
    </div>
  </div>

  <div class="pd-grid">
    <aside>
      <div class="pd-panel"><h3>System</h3>
        <select id="mode">
          <option value="nonlin" selected>Single · full nonlinear</option>
          <option value="simple">Single · small-angle</option>
          <option value="damped">Single · damped</option>
          <option value="driven">Single · driven + damped</option>
          <option value="double">Double pendulum (chaotic)</option>
        </select>
      </div>
      <div class="pd-panel"><h3>Parameters</h3><div class="pd-row">
        <label>Length L (m) <span id="lenV">1.00</span></label><input id="len" type="range" min="0.2" max="3.0" step="0.05" value="1.0"/>
        <label id="l2Wrap" style="display:none;">Length L₂ (m) <span id="len2V">1.00</span></label><input id="len2" type="range" min="0.2" max="3.0" step="0.05" value="1.0" style="display:none;"/>
        <label>Mass m (kg) <span id="massV">1.00</span></label><input id="mass" type="range" min="0.1" max="5.0" step="0.1" value="1.0"/>
        <label>Gravity g (m/s²) <span id="gV">9.81</span></label><input id="g" type="range" min="1" max="25" step="0.1" value="9.81"/>
        <label>Initial angle θ₀ (°) <span id="th0V">120</span></label><input id="th0" type="range" min="-179" max="179" step="1" value="120"/>
        <label id="dampWrap">Damping (1/s) <span id="dampV">0.00</span></label><input id="damp" type="range" min="0" max="2" step="0.01" value="0"/>
        <label id="drvAWrap" style="display:none;">Drive amplitude <span id="driveV">1.20</span></label><input id="drive" type="range" min="0" max="3" step="0.05" value="1.2" style="display:none;"/>
        <label id="drvFWrap" style="display:none;">Drive frequency <span id="driveFV">0.67</span></label><input id="driveF" type="range" min="0" max="5" step="0.01" value="0.67" style="display:none;"/>
      </div></div>
      <div class="pd-panel"><h3>Live state</h3>
        <div class="pd-metric"><span class="pd-metric-l">θ (rad)</span><span class="pd-metric-v" id="mTh">—</span></div>
        <div class="pd-metric"><span class="pd-metric-l">ω (rad/s)</span><span class="pd-metric-v" id="mOmega">—</span></div>
        <div class="pd-metric"><span class="pd-metric-l">Total E (J)</span><span class="pd-metric-v" id="mE">—</span></div>
        <div class="pd-metric"><span class="pd-metric-l">T (small-angle)</span><span class="pd-metric-v" id="mT0">—</span></div>
        <div class="pd-metric"><span class="pd-metric-l">T (exact, K/AGM)</span><span class="pd-metric-v" id="mTx">—</span></div>
        <div class="pd-metric"><span class="pd-metric-l">Large-angle error</span><span class="pd-metric-v" id="mTerr">—</span></div>
        <div class="pd-metric"><span class="pd-metric-l">Lyapunov λ (1/s)</span><span class="pd-metric-v" id="mLya">—</span></div>
        <div class="pd-metric"><span class="pd-metric-l">Regime</span><span class="pd-metric-v" id="mReg" style="color:#a78bfa;">—</span></div>
      </div>
    </aside>

    <section>
      <div class="pd-stage"><canvas id="scene" width="960" height="620"></canvas></div>
      <div class="pd-plots">
        <div class="pd-panel" style="margin:0;"><h3>Phase portrait · θ vs ω <span id="ppLbl" style="color:#7e8aa3;"></span></h3><canvas id="phase" width="560" height="210" style="width:100%;height:auto;"></canvas></div>
        <div class="pd-panel" style="margin:0;"><h3 id="auxH">Twin separation (log) · sensitive dependence</h3><canvas id="aux" width="560" height="210" style="width:100%;height:auto;"></canvas></div>
      </div>
    </section>
  </div>
</main>

<script is:inline>
(function(){
  function v(id){ return parseFloat(document.getElementById(id).value); }
  function setTxt(id,t){ var e=document.getElementById(id); if(e) e.textContent=t; }
  var P={ mode:'nonlin' }, paused=false;
  // single: [th,om]; double: [th1,th2,om1,om2]. twin = perturbed copy.
  var s=[2.09,0], twin=[2.09+1e-7,0], t=0, sepHist=[], phaseHist=[], poincare=[], lyaAccum=0, lyaTime=0;

  function readControls(){
    P.mode=document.getElementById('mode').value; P.L=v('len'); P.L2=v('len2'); P.m=v('mass'); P.g=v('g');
    P.damp=v('damp'); P.drive=v('drive'); P.driveF=v('driveF');
    setTxt('lenV',P.L.toFixed(2)); setTxt('len2V',P.L2.toFixed(2)); setTxt('massV',P.m.toFixed(2)); setTxt('gV',P.g.toFixed(2));
    setTxt('dampV',P.damp.toFixed(2)); setTxt('driveV',P.drive.toFixed(2)); setTxt('driveFV',P.driveF.toFixed(2)); setTxt('th0V',v('th0').toFixed(0));
    var dbl=P.mode==='double', drv=P.mode==='driven';
    document.getElementById('l2Wrap').style.display=dbl?'flex':'none'; document.getElementById('len2').style.display=dbl?'block':'none';
    document.getElementById('drvAWrap').style.display=drv?'flex':'none'; document.getElementById('drive').style.display=drv?'block':'none';
    document.getElementById('drvFWrap').style.display=drv?'flex':'none'; document.getElementById('driveF').style.display=drv?'block':'none';
    document.getElementById('auxH').textContent = drv ? 'Poincaré section · strobed at drive period' : 'Twin separation (log) · sensitive dependence';
    document.getElementById('ppLbl').textContent = dbl ? '(θ₁, ω₁)' : '';
  }
  document.querySelectorAll('input,select').forEach(function(el){ el.addEventListener('input',readControls); el.addEventListener('change',function(){ readControls(); reset(); }); });
  function reset(){ t=0; sepHist=[]; phaseHist=[]; poincare=[]; lyaAccum=0; lyaTime=0; var a=v('th0')*Math.PI/180;
    if(P.mode==='double'){ s=[a,a*0.6,0,0]; twin=[a+1e-7,a*0.6,0,0]; } else { s=[a,0]; twin=[a+1e-7,0]; } }
  readControls(); reset();
  document.getElementById('resetBtn').addEventListener('click',reset);
  document.getElementById('playBtn').addEventListener('click',function(){ paused=!paused; this.textContent=paused?'Play':'Pause'; });

  // ---- derivatives ----
  function fSingle(st,tt){ var th=st[0],om=st[1]; var dom = P.mode==='simple' ? -(P.g/P.L)*th : -(P.g/P.L)*Math.sin(th);
    if(P.mode==='damped'||P.mode==='driven') dom -= P.damp*om;
    if(P.mode==='driven') dom += P.drive*Math.cos(P.driveF*tt);
    return [om,dom]; }
  function fDouble(st){ var t1=st[0],t2=st[1],w1=st[2],w2=st[3], m1=P.m,m2=P.m,L1=P.L,L2=P.L2,g=P.g, dd=t1-t2;
    var den=2*m1+m2-m2*Math.cos(2*dd);
    var a1=( -g*(2*m1+m2)*Math.sin(t1) - m2*g*Math.sin(t1-2*t2) - 2*Math.sin(dd)*m2*(w2*w2*L2 + w1*w1*L1*Math.cos(dd)) )/(L1*den);
    var a2=( 2*Math.sin(dd)*( w1*w1*L1*(m1+m2) + g*(m1+m2)*Math.cos(t1) + w2*w2*L2*m2*Math.cos(dd) ) )/(L2*den);
    if(P.damp>0){ a1-=P.damp*w1; a2-=P.damp*w2; }
    return [w1,w2,a1,a2]; }
  function deriv(st,tt){ return P.mode==='double'?fDouble(st):fSingle(st,tt); }
  function rk4(st,tt,dt){ var n=st.length, k1=deriv(st,tt), s2=st.map(function(x,i){return x+dt/2*k1[i];}), k2=deriv(s2,tt+dt/2),
    s3=st.map(function(x,i){return x+dt/2*k2[i];}), k3=deriv(s3,tt+dt/2), s4=st.map(function(x,i){return x+dt*k3[i];}), k4=deriv(s4,tt+dt);
    var o=new Array(n); for(var i=0;i<n;i++) o[i]=st[i]+dt/6*(k1[i]+2*k2[i]+2*k3[i]+k4[i]); return o; }

  function phaseDist(a,b){ var d=0; for(var i=0;i<a.length;i++){ var x=a[i]-b[i]; d+=x*x; } return Math.sqrt(d); }
  var D0=1e-7;
  function step(dt){
    var pdrv = P.mode==='driven' ? (P.driveF>0 ? (P.driveF*t)%(2*Math.PI) : 0) : 0;
    s=rk4(s,t,dt); twin=rk4(twin,t,dt); t+=dt;
    // Lyapunov: measure separation, accumulate log growth, renormalise twin
    var d=phaseDist(s,twin); if(d>1e-12){ lyaAccum+=Math.log(d/D0); lyaTime+=dt; for(var i=0;i<s.length;i++){ twin[i]=s[i]+(twin[i]-s[i])*(D0/d); } }
    sepHist.push(Math.log10(Math.max(1e-16,d))); if(sepHist.length>600) sepHist.shift();
    var th=s[0], om=(P.mode==='double')?s[2]:s[1]; phaseHist.push([th,om]); if(phaseHist.length>2000) phaseHist.shift();
    // Poincaré: strobe when drive phase wraps
    if(P.mode==='driven' && P.driveF>0){ var ndrv=(P.driveF*t)%(2*Math.PI); if(ndrv<pdrv){ var w=th%(2*Math.PI); if(w>Math.PI)w-=2*Math.PI; if(w<-Math.PI)w+=2*Math.PI; poincare.push([w,om]); if(poincare.length>1500)poincare.shift(); } }
  }

  // ---- exact period via AGM: T = T0 / AGM(1, cos(theta0/2)) ; K(k) = pi/(2 AGM(1,sqrt(1-k^2))) ----
  function agm(a,b){ for(var i=0;i<40;i++){ var na=(a+b)/2, nb=Math.sqrt(a*b); a=na; b=nb; if(Math.abs(a-b)<1e-15)break; } return (a+b)/2; }
  function metrics(){
    var th=s[0], om=(P.mode==='double')?s[2]:s[1];
    setTxt('mTh',th.toFixed(3)); setTxt('mOmega',om.toFixed(3));
    var E;
    if(P.mode==='double'){ var t1=s[0],t2=s[1],w1=s[2],w2=s[3],m=P.m,L1=P.L,L2=P.L2,g=P.g;
      var KE=0.5*m*L1*L1*w1*w1+0.5*m*(L1*L1*w1*w1+L2*L2*w2*w2+2*L1*L2*w1*w2*Math.cos(t1-t2));
      var PE=-m*g*L1*Math.cos(t1)-m*g*(L1*Math.cos(t1)+L2*Math.cos(t2)); E=KE+PE; }
    else { var KE=0.5*P.m*Math.pow(P.L*om,2), PE=P.m*P.g*P.L*(1-Math.cos(th)); E=KE+PE; }
    setTxt('mE',E.toFixed(3));
    var T0=2*Math.PI*Math.sqrt(P.L/P.g); setTxt('mT0',T0.toFixed(3)+' s');
    var A=Math.abs(v('th0')*Math.PI/180);
    if(A<Math.PI-1e-3){ var Tx=T0/agm(1,Math.cos(A/2)); setTxt('mTx',Tx.toFixed(3)+' s'); setTxt('mTerr','+'+((Tx/T0-1)*100).toFixed(1)+'%'); }
    else { setTxt('mTx','→ ∞'); setTxt('mTerr','diverges'); }
    var lya = lyaTime>0.5 ? lyaAccum/lyaTime : NaN;
    setTxt('mLya', isNaN(lya)?'…':lya.toFixed(3));
    var reg = P.mode==='double' ? (lya>0.4?'chaotic':'settling') : (P.mode==='driven' ? (lya>0.15?'chaotic':'periodic/quasi') : (P.damp>0?'damped':'conservative'));
    setTxt('mReg',reg);
  }

  function hidpi(cv){ var r=cv.getBoundingClientRect(), dp=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w; cv.width=Math.round(w*dp); cv.height=Math.round(h*dp); var ctx=cv.getContext('2d'); ctx.setTransform(dp,0,0,dp,0,0); return {ctx:ctx,w:w,h:h}; }
  function bob(ctx,x,y,r,glow){ ctx.save(); ctx.shadowColor=glow; ctx.shadowBlur=22; var g=ctx.createRadialGradient(x-r*0.35,y-r*0.4,r*0.2,x,y,r); g.addColorStop(0,'#fff2c4'); g.addColorStop(0.35,'#fcd34d'); g.addColorStop(1,'#b8791a'); ctx.fillStyle=g; ctx.beginPath(); ctx.arc(x,y,r,0,7); ctx.fill(); ctx.restore(); ctx.fillStyle='rgba(255,255,255,0.8)'; ctx.beginPath(); ctx.arc(x-r*0.32,y-r*0.36,r*0.22,0,7); ctx.fill(); }
  function rod(ctx,x1,y1,x2,y2){ var g=ctx.createLinearGradient(x1,y1,x2,y2); g.addColorStop(0,'#c7cfdd'); g.addColorStop(1,'#3a4258'); ctx.strokeStyle=g; ctx.lineWidth=4; ctx.lineCap='round'; ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.stroke(); }

  var trail=[];
  function drawScene(){
    var cv=document.getElementById('scene'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h;
    var bg=ctx.createLinearGradient(0,0,0,H); bg.addColorStop(0,'#0c1226'); bg.addColorStop(0.55,'#080b16'); bg.addColorStop(1,'#05070f'); ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    ctx.strokeStyle='rgba(94,231,255,0.045)'; for(var gx=0;gx<W;gx+=40){ ctx.beginPath(); ctx.moveTo(gx,0); ctx.lineTo(gx,H); ctx.stroke(); } for(var gy=0;gy<H;gy+=40){ ctx.beginPath(); ctx.moveTo(0,gy); ctx.lineTo(W,gy); ctx.stroke(); }
    var cx=W/2, cy=H*0.24; ctx.fillStyle='#131a2e'; ctx.fillRect(cx-46,cy-14,92,14);
    if(P.mode==='double'){
      var sc=Math.min(W,H)*0.20;
      var x1=cx+sc*P.L*Math.sin(s[0]), y1=cy+sc*P.L*Math.cos(s[0]);
      var x2=x1+sc*P.L2*Math.sin(s[1]), y2=y1+sc*P.L2*Math.cos(s[1]);
      // twin (faint) — sensitive dependence
      var tx1=cx+sc*P.L*Math.sin(twin[0]), ty1=cy+sc*P.L*Math.cos(twin[0]); var tx2=tx1+sc*P.L2*Math.sin(twin[1]), ty2=ty1+sc*P.L2*Math.cos(twin[1]);
      ctx.globalAlpha=0.32; rod(ctx,cx,cy,tx1,ty1); rod(ctx,tx1,ty1,tx2,ty2); ctx.fillStyle='#f472b6'; ctx.beginPath(); ctx.arc(tx2,ty2,7,0,7); ctx.fill(); ctx.globalAlpha=1;
      trail.push([x2,y2]); if(trail.length>140) trail.shift();
      for(var i=0;i<trail.length;i++){ var al=i/trail.length; ctx.fillStyle='rgba(94,231,255,'+(al*0.5).toFixed(3)+')'; ctx.beginPath(); ctx.arc(trail[i][0],trail[i][1],1.6,0,7); ctx.fill(); }
      rod(ctx,cx,cy,x1,y1); rod(ctx,x1,y1,x2,y2); bob(ctx,x1,y1,8,'rgba(94,231,255,0.7)'); bob(ctx,x2,y2,10+P.m*2,'rgba(251,191,36,0.8)');
      ctx.fillStyle='#f472b6'; ctx.font="11px 'Geist Mono',monospace"; ctx.fillText('twin (Δθ=1e-7)', 14, H-16);
    } else {
      var sc=Math.min(W,H)*0.34; var px=cx+sc*P.L*Math.sin(s[0]), py=cy+sc*P.L*Math.cos(s[0]);
      ctx.strokeStyle='rgba(142,160,190,0.3)'; ctx.setLineDash([4,5]); ctx.beginPath(); ctx.moveTo(cx,cy); ctx.lineTo(cx,cy+sc*P.L*1.05); ctx.stroke(); ctx.setLineDash([]);
      ctx.fillStyle='#8ea0be'; ctx.font="600 12px 'Geist Mono',monospace"; ctx.fillText((s[0]*180/Math.PI).toFixed(1)+'°', cx+8, cy+64);
      trail.push([px,py]); if(trail.length>46) trail.shift();
      for(var i=0;i<trail.length;i++){ var al=i/trail.length; ctx.fillStyle='rgba(251,191,36,'+(al*0.5).toFixed(3)+')'; ctx.beginPath(); ctx.arc(trail[i][0],trail[i][1],2+al*2.5,0,7); ctx.fill(); }
      rod(ctx,cx,cy,px,py); ctx.fillStyle='#e8ecf4'; ctx.beginPath(); ctx.arc(cx,cy,4,0,7); ctx.fill(); bob(ctx,px,py,10+P.m*5,'rgba(251,191,36,0.8)');
    }
    ctx.fillStyle='#5ee7ff'; ctx.font="700 13px 'Geist Mono',monospace"; ctx.fillText('t = '+t.toFixed(2)+' s', 14, 24);
  }
  function glow(ctx,pts,col,wd){ ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=7; ctx.strokeStyle=col; ctx.lineWidth=wd||1.5; ctx.beginPath(); pts.forEach(function(q,i){ i?ctx.lineTo(q[0],q[1]):ctx.moveTo(q[0],q[1]); }); ctx.stroke(); ctx.restore(); }
  function drawPhase(){
    var cv=document.getElementById('phase'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h, cx=W/2, cy=H/2;
    ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H); ctx.strokeStyle='#1a2340'; ctx.beginPath(); ctx.moveTo(8,cy); ctx.lineTo(W-8,cy); ctx.moveTo(cx,8); ctx.lineTo(cx,H-8); ctx.stroke();
    ctx.fillStyle='#8ea0be'; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText('θ',W-16,cy-6); ctx.fillText('ω',cx+6,14);
    if(phaseHist.length<2) return; var maxW=Math.max(2,Math.max.apply(null,phaseHist.map(function(h){return Math.abs(h[1]);})));
    var sx=(W*0.44)/Math.PI, sy=(H*0.42)/maxW;
    glow(ctx,phaseHist.map(function(h){ var th=((h[0]+Math.PI)%(2*Math.PI)+2*Math.PI)%(2*Math.PI)-Math.PI; return [cx+th*sx,cy-h[1]*sy]; }),'#a78bfa',1.3);
    var last=phaseHist[phaseHist.length-1]; var lt=((last[0]+Math.PI)%(2*Math.PI)+2*Math.PI)%(2*Math.PI)-Math.PI; ctx.save(); ctx.shadowColor='#fbbf24'; ctx.shadowBlur=12; ctx.fillStyle='#fbbf24'; ctx.beginPath(); ctx.arc(cx+lt*sx,cy-last[1]*sy,4,0,7); ctx.fill(); ctx.restore();
  }
  function drawAux(){
    var cv=document.getElementById('aux'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h; ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H);
    if(P.mode==='driven'){ // Poincaré section
      var cx=W/2, cy=H/2; ctx.strokeStyle='#1a2340'; ctx.beginPath(); ctx.moveTo(8,cy); ctx.lineTo(W-8,cy); ctx.moveTo(cx,8); ctx.lineTo(cx,H-8); ctx.stroke();
      if(!poincare.length){ ctx.fillStyle='#5f7597'; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText('sampling once per drive period…',12,18); return; }
      var mw=Math.max(2,Math.max.apply(null,poincare.map(function(p){return Math.abs(p[1]);}))); var sx=(W*0.44)/Math.PI, sy=(H*0.42)/mw;
      poincare.forEach(function(p,i){ var al=0.25+0.75*i/poincare.length; ctx.fillStyle='rgba(52,211,153,'+al.toFixed(2)+')'; ctx.beginPath(); ctx.arc(cx+p[0]*sx,cy-p[1]*sy,1.5,0,7); ctx.fill(); });
      ctx.fillStyle='#8ea0be'; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText('θ',W-16,cy-6); ctx.fillText('ω',cx+6,14);
    } else { // twin separation (log) — sensitive dependence / Lyapunov slope
      ctx.strokeStyle='rgba(94,231,255,0.06)'; for(var y=0;y<H;y+=26){ ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke(); }
      if(sepHist.length<2){ return; }
      var lo=-16, hi=2; function Y(l){ return H-8-((l-lo)/(hi-lo))*(H-16); }
      ctx.fillStyle='#5f7597'; ctx.font="9px 'Geist Mono',monospace"; ctx.fillText('log₁₀|Δ|',6,12); ctx.fillText('0',W-14,Y(0)); ctx.fillText('-15',W-22,Y(-15));
      glow(ctx,sepHist.map(function(l,i){ return [8+i/(sepHist.length-1)*(W-16),Y(l)]; }),'#f472b6',1.6);
      // saturation line (separation caps ~ system size)
      ctx.strokeStyle='rgba(94,231,255,0.25)'; ctx.setLineDash([4,4]); ctx.beginPath(); ctx.moveTo(8,Y(0.4)); ctx.lineTo(W-8,Y(0.4)); ctx.stroke(); ctx.setLineDash([]);
    }
  }

  var lastTs=0;
  function loop(ts){ if(!lastTs)lastTs=ts; var dt=Math.min(0.03,(ts-lastTs)/1000); lastTs=ts;
    if(!paused){ var sub=P.mode==='double'?8:4; for(var i=0;i<sub;i++) step(dt/sub); }
    drawScene(); metrics(); drawPhase(); drawAux(); requestAnimationFrame(loop); }
  requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
