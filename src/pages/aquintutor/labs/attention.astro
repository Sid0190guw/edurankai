---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Transformer self-attention — the mechanism at the core of every modern LLM,
// implemented faithfully in the browser: token embeddings + sinusoidal
// positional encoding, per-head learnable-shaped projections Q,K,V, scaled
// dot-product scores QKᵀ/√d_k, temperature-softmax, multi-head concat + output
// projection. Live attention heatmaps, a weighted arc diagram, and per-head
// entropy. Graduate/postgraduate depth, hand-rolled linear algebra, no libs.
---
<BaseLayout title="Self-attention · Virtual Labs · AquinTutor" description="Multi-head scaled dot-product self-attention — the transformer core — computed live: embeddings, positional encoding, QKᵀ/√dk, softmax, multi-head mixing, with attention heatmaps and per-head entropy.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1320px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:14px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#a78bfa; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#a78bfa; font-style:italic; font-weight:500; }
  .lb-sub{ font-family:'Inter Tight',sans-serif; font-size:13.5px; color:#8ea0be; max-width:60ch; line-height:1.55; margin:8px 0 16px; }
  .lb-grid{ display:grid; grid-template-columns:300px minmax(0,1fr); gap:18px; } @media(max-width:940px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#12102a,#0b0a17); border:1px solid #2a2447; border-radius:14px; padding:16px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#a78bfa; font-weight:700; margin:0 0 12px; }
  .lb-row{ display:grid; gap:9px; } .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.1em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; }
  .lb-row label span{ color:#a78bfa; } .lb-row input[type=range]{ width:100%; accent-color:#a78bfa; }
  .lb-in{ width:100%; background:#080a12; border:1px solid #2a2447; color:#fff; padding:9px 11px; border-radius:8px; font-size:13px; font-family:'Geist Mono',monospace; outline:none; }
  .lb-btn{ background:linear-gradient(180deg,#c4b5fd,#8b6ff0); color:#12102a; padding:9px 14px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:10.5px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; }
  .head-tab{ background:#080a12; border:1px solid #2a2447; color:#cfd6da; padding:6px 12px; border-radius:6px; font-family:'Geist Mono',monospace; font-size:11px; cursor:pointer; } .head-tab.on{ background:#8b6ff0; color:#12102a; border-color:#8b6ff0; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #2a2447; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); }
  .lb-stage canvas{ display:block; width:100%; height:auto; }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11.5px; padding:5px 0; border-bottom:1px solid #201b3a; }
  .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#a78bfa; font-weight:700; text-align:right; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#a78bfa;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">AI/ML · Postgraduate · Transformers</p>
      <h1 class="lb-title">Self-<em>attention</em>.</h1>
    </div>
  </div>
  <p class="lb-sub">The exact operation at the heart of every modern language model. Each token forms a query, key and value; token i attends to token j with weight softmax(qᵢ·kⱼ/√d_k). Multiple heads attend in different learned subspaces, then their outputs are concatenated and projected. Everything below is computed live from the tokens you type.</p>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Sequence</h3><div class="lb-row">
        <label>Tokens (space-separated, ≤ 12)</label>
        <input id="seq" class="lb-in" value="the cat sat on the mat then it slept"/>
        <label style="margin-top:8px;">Softmax temperature <span id="tV">1.00</span></label><input id="temp" type="range" min="0.2" max="3" step="0.05" value="1"/>
      </div>
      <div style="display:flex;gap:6px;margin-top:12px;flex-wrap:wrap;">
        <button id="reseed" class="lb-btn">Re-seed weights</button>
        <label style="font-family:'Geist Mono',monospace;font-size:11px;color:#8ea0be;display:flex;align-items:center;gap:6px;"><input type="checkbox" id="pe" checked style="accent-color:#a78bfa;"/> positional encoding</label>
      </div></div>
      <div class="lb-panel"><h3>Head</h3>
        <div id="headTabs" style="display:flex;gap:6px;flex-wrap:wrap;"></div>
        <div class="lb-metric" style="margin-top:12px;"><span class="lb-metric-l">d_model</span><span class="lb-metric-v" id="mD">24</span></div>
        <div class="lb-metric"><span class="lb-metric-l">heads · d_k</span><span class="lb-metric-v" id="mH">4 · 6</span></div>
        <div class="lb-metric"><span class="lb-metric-l">attention entropy</span><span class="lb-metric-v" id="mEnt">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">strongest link</span><span class="lb-metric-v" id="mLink">—</span></div>
      </div>
      <div class="lb-panel"><h3>Note</h3><p style="font-family:'Inter Tight',sans-serif;font-size:12px;color:#8ea0be;line-height:1.55;margin:0;">Weights Wq,Wk,Wv,Wo here are randomly initialised (re-seed to resample). In a trained model they are learned, and heads specialise — some become positional (attend to the previous token), some syntactic, some semantic. The mechanism you're watching is identical.</p></div>
    </aside>
    <section>
      <div class="lb-stage" style="margin-bottom:12px;"><canvas id="heat" width="900" height="470"></canvas></div>
      <div class="lb-stage"><canvas id="arcs" width="900" height="240"></canvas></div>
    </section>
  </div>
</main>
<script is:inline>
(function(){
  var D=24, H=4, DK=6; document.getElementById('mH').textContent=H+' · '+DK;
  var head=0, seed=1337;
  function mulberry(a){ return function(){ a|=0; a=a+0x6D2B79F5|0; var t=Math.imul(a^a>>>15,1|a); t=t+Math.imul(t^t>>>7,61|t)^t; return ((t^t>>>14)>>>0)/4294967296; }; }
  function gauss(rng){ var u=rng()||1e-9, v=rng(); return Math.sqrt(-2*Math.log(u))*Math.cos(2*Math.PI*v); }
  function hashStr(s){ var h=2166136261; for(var i=0;i<s.length;i++){ h^=s.charCodeAt(i); h=Math.imul(h,16777619); } return h>>>0; }
  // fixed per-token embedding (deterministic by word) so same word -> same vector
  function embed(word){ var rng=mulberry(hashStr(word)^0x9e37); var e=[]; for(var i=0;i<D;i++) e.push(gauss(rng)*0.6); return e; }
  function posenc(pos){ var e=new Array(D).fill(0); for(var i=0;i<D;i+=2){ var w=Math.pow(10000,-i/D); e[i]=Math.sin(pos*w); if(i+1<D) e[i+1]=Math.cos(pos*w); } return e; }
  // weight matrices per head: Wq,Wk,Wv are D x DK
  var Wq,Wk,Wv;
  function initWeights(){ var rng=mulberry(seed); function mat(r,c){ var m=[]; for(var i=0;i<r;i++){ var row=[]; for(var j=0;j<c;j++) row.push(gauss(rng)/Math.sqrt(D)); m.push(row); } return m; }
    Wq=[];Wk=[];Wv=[]; for(var h=0;h<H;h++){ Wq.push(mat(D,DK)); Wk.push(mat(D,DK)); Wv.push(mat(D,DK)); } }
  initWeights();
  function proj(x,W){ var out=new Array(DK).fill(0); for(var k=0;k<DK;k++){ var s=0; for(var d=0;d<D;d++) s+=x[d]*W[d][k]; out[k]=s; } return out; }
  function dot(a,b){ var s=0; for(var i=0;i<a.length;i++) s+=a[i]*b[i]; return s; }
  function softmax(arr,temp){ var m=Math.max.apply(null,arr); var ex=arr.map(function(x){ return Math.exp((x-m)/temp); }); var s=ex.reduce(function(a,b){return a+b;},0); return ex.map(function(x){ return x/s; }); }

  var A=null, tokens=[];
  function compute(){ var raw=document.getElementById('seq').value.trim().split(/\s+/).filter(Boolean).slice(0,12); tokens=raw; var n=tokens.length; if(n<1){ A=null; return; }
    var pe=document.getElementById('pe').checked, temp=parseFloat(document.getElementById('temp').value);
    var X=tokens.map(function(t,i){ var e=embed(t); if(pe){ var p=posenc(i); e=e.map(function(v,d){ return v+p[d]; }); } return e; });
    var h=head; var Q=X.map(function(x){ return proj(x,Wq[h]); }), K=X.map(function(x){ return proj(x,Wk[h]); });
    var scale=1/Math.sqrt(DK); A=[]; for(var i=0;i<n;i++){ var row=[]; for(var j=0;j<n;j++) row.push(dot(Q[i],K[j])*scale); A.push(softmax(row,temp)); }
    // entropy (avg over rows) + strongest link
    var ent=0, best=0, bi=0,bj=0; for(var i=0;i<n;i++){ var e=0; for(var j=0;j<n;j++){ var p=A[i][j]; if(p>1e-9) e-=p*Math.log2(p); if(p>best){ best=p; bi=i; bj=j; } } ent+=e; } ent/=n;
    document.getElementById('mEnt').textContent=ent.toFixed(2)+' bits'; document.getElementById('mLink').textContent='"'+tokens[bi]+'"→"'+tokens[bj]+'"';
  }
  function hidpi(c){ var r=c.getBoundingClientRect(), d=window.devicePixelRatio||1; var w=r.width||c.width, hh=(c.height/c.width)*w; c.width=Math.round(w*d); c.height=Math.round(hh*d); var ctx=c.getContext('2d'); ctx.setTransform(d,0,0,d,0,0); return {ctx:ctx,w:w,h:hh}; }
  function heatColor(t){ var r=Math.round(30+225*t), g=Math.round(20+120*t), b=Math.round(70+185*(1-t*0.4)); return 'rgb('+r+','+g+','+b+')'; }
  function drawHeat(){ var cv=document.getElementById('heat'), s=hidpi(cv), ctx=s.ctx, W=s.w, Ht=s.h; ctx.fillStyle='#0a0917'; ctx.fillRect(0,0,W,Ht);
    if(!A) return; var n=A.length; var padT=70, padL=90, cell=Math.min((W-padL-16)/n,(Ht-padT-16)/n);
    ctx.font="12px 'Geist Mono',monospace"; ctx.fillStyle='#a78bfa'; ctx.fillText('key  (attended to) →', padL, 20); ctx.save(); ctx.translate(20,padT+cell*n*0.5); ctx.rotate(-Math.PI/2); ctx.fillText('← query', 0, 0); ctx.restore();
    // column labels
    ctx.textAlign='center'; for(var j=0;j<n;j++){ ctx.fillStyle='#8ea0be'; ctx.save(); ctx.translate(padL+j*cell+cell/2,padT-8); ctx.rotate(-0.5); ctx.fillText(tokens[j].slice(0,8),0,0); ctx.restore(); }
    ctx.textAlign='right'; for(var i=0;i<n;i++){ ctx.fillStyle='#8ea0be'; ctx.fillText(tokens[i].slice(0,8), padL-6, padT+i*cell+cell/2+4); }
    ctx.textAlign='left';
    for(var i=0;i<n;i++) for(var j=0;j<n;j++){ var t=A[i][j]; ctx.fillStyle=heatColor(t); if(t>0.25){ ctx.save(); ctx.shadowColor='#a78bfa'; ctx.shadowBlur=t*14; ctx.fillRect(padL+j*cell+1,padT+i*cell+1,cell-2,cell-2); ctx.restore(); } else ctx.fillRect(padL+j*cell+1,padT+i*cell+1,cell-2,cell-2);
      if(cell>26){ ctx.fillStyle=t>0.4?'#0a0917':'rgba(255,255,255,0.4)'; ctx.font=(cell*0.28)+"px 'Geist Mono',monospace"; ctx.textAlign='center'; ctx.fillText(t.toFixed(2),padL+j*cell+cell/2,padT+i*cell+cell/2+3); ctx.textAlign='left'; } }
  }
  function drawArcs(){ var cv=document.getElementById('arcs'), s=hidpi(cv), ctx=s.ctx, W=s.w, Ht=s.h; ctx.fillStyle='#0a0917'; ctx.fillRect(0,0,W,Ht);
    if(!A) return; var n=A.length; var y=Ht-40, x0=60, x1=W-60, step=(x1-x0)/Math.max(1,n-1);
    for(var i=0;i<n;i++) for(var j=0;j<n;j++){ if(i===j) continue; var t=A[i][j]; if(t<0.06) continue; var xi=x0+i*step, xj=x0+j*step; var mid=(xi+xj)/2, h2=Math.min(150,Math.abs(xi-xj)*0.5+18);
      ctx.save(); ctx.strokeStyle='rgba(167,139,250,'+Math.min(0.9,t*1.4)+')'; ctx.lineWidth=Math.max(0.6,t*6); ctx.shadowColor='#a78bfa'; ctx.shadowBlur=t*8; ctx.beginPath(); ctx.moveTo(xi,y); ctx.quadraticCurveTo(mid,y-h2,xj,y); ctx.stroke(); ctx.restore(); }
    for(var i=0;i<n;i++){ var x=x0+i*step; ctx.save(); ctx.shadowColor='#8b6ff0'; ctx.shadowBlur=8; ctx.fillStyle='#c4b5fd'; ctx.beginPath(); ctx.arc(x,y,5,0,7); ctx.fill(); ctx.restore(); ctx.fillStyle='#cfd6da'; ctx.font="11px 'Geist Mono',monospace"; ctx.textAlign='center'; ctx.fillText(tokens[i].slice(0,9),x,y+20); }
    ctx.textAlign='left'; ctx.fillStyle='#8ea0be'; ctx.font="11px 'Geist Mono',monospace"; ctx.fillText('arc thickness = attention weight (head '+head+')', 16, 20);
  }
  function tabs(){ var c=document.getElementById('headTabs'); c.innerHTML=''; for(var h=0;h<H;h++){ (function(h){ var b=document.createElement('button'); b.className='head-tab'+(h===head?' on':''); b.textContent='H'+h; b.addEventListener('click',function(){ head=h; document.querySelectorAll('.head-tab').forEach(function(x,i){ x.classList.toggle('on',i===head); }); }); c.appendChild(b); })(h); } }
  tabs();
  document.getElementById('seq').addEventListener('input',function(){});
  document.getElementById('temp').addEventListener('input',function(){ document.getElementById('tV').textContent=parseFloat(this.value).toFixed(2); });
  document.getElementById('reseed').addEventListener('click',function(){ seed=(Math.random()*1e9)|0; initWeights(); });
  function loop(){ compute(); drawHeat(); drawArcs(); requestAnimationFrame(loop); } requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
