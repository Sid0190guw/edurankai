---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Control systems flagship — a PID controller in closed loop around a
// second-order plant. RK4 time-domain simulation of the true state equations,
// closed-loop pole locations from the characteristic cubic (Durand-Kerner), and
// the standard performance metrics (overshoot, settling, rise, steady-state
// error). Graduate control-theory depth, hand-rolled, no libraries.
---
<BaseLayout title="PID control · Virtual Labs · AquinTutor" description="Tune a PID controller on a second-order plant and watch the closed-loop step response, control effort and pole locations respond live — real state-space simulation and characteristic-root finding.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1320px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#f472b6; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#f472b6; font-style:italic; font-weight:500; }
  .lb-sub{ font-family:'Inter Tight',sans-serif; font-size:13.5px; color:#8ea0be; max-width:66ch; line-height:1.55; margin:8px 0 16px; }
  .lb-grid{ display:grid; grid-template-columns:300px minmax(0,1fr); gap:18px; } @media(max-width:940px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#1a0f18,#120a10); border:1px solid #402036; border-radius:14px; padding:16px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#f472b6; font-weight:700; margin:0 0 12px; }
  .lb-row{ display:grid; gap:9px; } .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.1em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; }
  .lb-row label span{ color:#f472b6; } .lb-row input[type=range]{ width:100%; accent-color:#f472b6; }
  .preset{ background:#150b12; border:1px solid #402036; color:#cfd6da; padding:7px 10px; border-radius:6px; font-family:'Geist Mono',monospace; font-size:11px; cursor:pointer; }
  .lb-stage{ border-radius:14px; overflow:hidden; border:1px solid #402036; box-shadow:inset 0 0 40px rgba(0,0,0,0.5); } .lb-stage canvas{ display:block; width:100%; height:auto; }
  .split{ display:grid; grid-template-columns:1.6fr 1fr; gap:12px; margin-top:12px; } @media(max-width:680px){ .split{ grid-template-columns:1fr; } }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11.5px; padding:5px 0; border-bottom:1px solid #2a1622; } .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#f472b6; font-weight:700; }
</style>
<main class="lb">
  <div>
    <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#f472b6;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
    <p class="lb-eye" style="margin-top:10px;">Control systems · Postgraduate · Feedback</p>
    <h1 class="lb-title">PID <em>control</em>.</h1>
    <p class="lb-sub">A PID controller closed around the plant G(s) = ωₙ² / (s² + 2ζωₙs + ωₙ²). The loop is simulated from its true state equations; the closed-loop poles come from the characteristic cubic s³ + (2ζωₙ+K_d)s² + (ωₙ²+K_p)s + K_i = 0. Push the poles into the left half-plane and watch overshoot and settling time respond.</p>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Controller (PID)</h3><div class="lb-row">
        <label>K_p <span id="kpV">6.0</span></label><input id="kp" type="range" min="0" max="30" step="0.2" value="6"/>
        <label>K_i <span id="kiV">4.0</span></label><input id="ki" type="range" min="0" max="30" step="0.2" value="4"/>
        <label>K_d <span id="kdV">2.0</span></label><input id="kd" type="range" min="0" max="15" step="0.1" value="2"/>
      </div>
      <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:10px;"><button class="preset" data-p="0">P only</button><button class="preset" data-p="1">PI</button><button class="preset" data-p="2">Critically damped</button></div>
      </div>
      <div class="lb-panel"><h3>Plant</h3><div class="lb-row">
        <label>Damping ζ <span id="zV">0.30</span></label><input id="z" type="range" min="0.02" max="2" step="0.02" value="0.3"/>
        <label>Natural freq ωₙ <span id="wV">2.0</span></label><input id="w" type="range" min="0.5" max="5" step="0.1" value="2"/>
      </div></div>
      <div class="lb-panel"><h3>Performance</h3>
        <div class="lb-metric"><span class="lb-metric-l">Overshoot</span><span class="lb-metric-v" id="mOS">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Settling (2%)</span><span class="lb-metric-v" id="mTs">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Rise time</span><span class="lb-metric-v" id="mTr">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Steady-state err</span><span class="lb-metric-v" id="mSS">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Stable?</span><span class="lb-metric-v" id="mStab">—</span></div>
      </div>
    </aside>
    <section>
      <div class="lb-stage"><canvas id="step" width="880" height="320"></canvas></div>
      <div class="split">
        <div class="lb-stage"><canvas id="ctrl" width="540" height="220"></canvas></div>
        <div class="lb-stage"><canvas id="pole" width="340" height="220"></canvas></div>
      </div>
    </section>
  </div>
</main>
<script is:inline>
(function(){
  function v(id){ return parseFloat(document.getElementById(id).value); }
  function sync(){ document.getElementById('kpV').textContent=v('kp').toFixed(1); document.getElementById('kiV').textContent=v('ki').toFixed(1); document.getElementById('kdV').textContent=v('kd').toFixed(1); document.getElementById('zV').textContent=v('z').toFixed(2); document.getElementById('wV').textContent=v('w').toFixed(1); }
  document.querySelectorAll('input').forEach(function(e){ e.addEventListener('input',sync); }); sync();
  document.querySelectorAll('.preset').forEach(function(b){ b.addEventListener('click',function(){ var p=b.getAttribute('data-p'); if(p==='0'){ set('kp',8); set('ki',0); set('kd',0); } else if(p==='1'){ set('kp',6); set('ki',5); set('kd',0); } else { set('kp',10); set('ki',6); set('kd',5); } sync(); }); });
  function set(id,val){ document.getElementById(id).value=val; }

  // complex helpers for cubic roots
  function C(re,im){ return {re:re,im:im||0}; } function cadd(a,b){ return C(a.re+b.re,a.im+b.im); } function csub(a,b){ return C(a.re-b.re,a.im-b.im); }
  function cmul(a,b){ return C(a.re*b.re-a.im*b.im,a.re*b.im+a.im*b.re); } function cdiv(a,b){ var d=b.re*b.re+b.im*b.im; return C((a.re*b.re+a.im*b.im)/d,(a.im*b.re-a.re*b.im)/d); }
  function cubicRoots(a2,a1,a0){ var r=[C(0.4,0.9),C(-0.7,0.5),C(-0.6,-0.4)]; function f(z){ var z2=cmul(z,z),z3=cmul(z2,z); return cadd(cadd(z3,cmul(C(a2),z2)),cadd(cmul(C(a1),z),C(a0))); }
    for(var it=0;it<120;it++){ for(var i=0;i<3;i++){ var den=C(1,0); for(var j=0;j<3;j++) if(j!==i) den=cmul(den,csub(r[i],r[j])); r[i]=csub(r[i],cdiv(f(r[i]),den)); } } return r; }

  function simulate(){ var kp=v('kp'),ki=v('ki'),kd=v('kd'),z=v('z'),w=v('w'); var a=2*z*w, b=w*w, r=1;
    var T=12, dt=0.004, N=Math.round(T/dt); var ys=[], us=[]; var x1=0,x2=0,xi=0;
    function deriv(x1,x2,xi){ var e=r-x1; var u=kp*e+ki*xi+kd*(-x2); var dx2=-a*x2-b*x1+b*u; return {d1:x2,d2:dx2,di:e,u:u}; }
    for(var n=0;n<N;n++){ var k1=deriv(x1,x2,xi); var k2=deriv(x1+dt/2*k1.d1,x2+dt/2*k1.d2,xi+dt/2*k1.di); var k3=deriv(x1+dt/2*k2.d1,x2+dt/2*k2.d2,xi+dt/2*k2.di); var k4=deriv(x1+dt*k3.d1,x2+dt*k3.d2,xi+dt*k3.di);
      if(n%3===0){ ys.push({t:n*dt,y:x1}); us.push({t:n*dt,u:k1.u}); }
      x1+=dt/6*(k1.d1+2*k2.d1+2*k3.d1+k4.d1); x2+=dt/6*(k1.d2+2*k2.d2+2*k3.d2+k4.d2); xi+=dt/6*(k1.di+2*k2.di+2*k3.di+k4.di); if(!isFinite(x1)||Math.abs(x1)>1e4){ break; } }
    // metrics
    var yfinal=ys.length?ys[ys.length-1].y:0; var peak=0,tp=0; ys.forEach(function(p){ if(p.y>peak){ peak=p.y; tp=p.t; } });
    var os=yfinal>0.01? Math.max(0,(peak-1)/1*100):0;
    var ts=T; for(var i=ys.length-1;i>=0;i--){ if(Math.abs(ys[i].y-1)>0.02){ ts=ys[i].t; break; } }
    var tr=T; for(var i=0;i<ys.length;i++){ if(ys[i].y>=0.9){ tr=ys[i].t; break; } }
    var poles=cubicRoots(a+kd, b+kp, ki); var stable=poles.every(function(p){ return p.re<1e-6; });
    return {ys:ys,us:us,os:os,ts:ts,tr:tr,ss:Math.abs(1-yfinal),poles:poles,stable:stable}; }

  function hidpi(c){ var r=c.getBoundingClientRect(), d=window.devicePixelRatio||1; var w=r.width||c.width, h=(c.height/c.width)*w; c.width=Math.round(w*d); c.height=Math.round(h*d); var ctx=c.getContext('2d'); ctx.setTransform(d,0,0,d,0,0); return {ctx:ctx,w:w,h:h}; }
  function drawStep(S){ var cv=document.getElementById('step'), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h; ctx.fillStyle='#0d0810'; ctx.fillRect(0,0,W,H);
    var padL=44,padB=26,padT=14, T=12; var ymax=Math.max(1.6, S.ys.reduce(function(m,p){return Math.max(m,p.y);},0)*1.1);
    function X(t){ return padL+t/T*(W-padL-14); } function Y(y){ return H-padB-(y/ymax)*(H-padT-padB); }
    ctx.strokeStyle='rgba(244,114,182,0.07)'; ctx.fillStyle='#5f7597'; ctx.font="10px 'Geist Mono',monospace";
    for(var y=0;y<=ymax;y+=0.5){ ctx.beginPath(); ctx.moveTo(padL,Y(y)); ctx.lineTo(W-14,Y(y)); ctx.stroke(); ctx.fillText(y.toFixed(1),10,Y(y)+3); }
    for(var t=0;t<=T;t+=2){ ctx.fillText(t+'s',X(t)-6,H-12); }
    // setpoint
    ctx.strokeStyle='rgba(94,231,255,0.5)'; ctx.setLineDash([5,4]); ctx.beginPath(); ctx.moveTo(padL,Y(1)); ctx.lineTo(W-14,Y(1)); ctx.stroke(); ctx.setLineDash([]); ctx.fillStyle='#5ee7ff'; ctx.fillText('setpoint',W-70,Y(1)-6);
    // output
    ctx.save(); ctx.shadowColor='#f472b6'; ctx.shadowBlur=8; ctx.strokeStyle='#f472b6'; ctx.lineWidth=2.2; ctx.beginPath(); S.ys.forEach(function(p,i){ i?ctx.lineTo(X(p.t),Y(p.y)):ctx.moveTo(X(p.t),Y(p.y)); }); ctx.stroke(); ctx.restore();
    ctx.fillStyle='#f472b6'; ctx.font="11px 'Geist Mono',monospace"; ctx.fillText('closed-loop step response y(t)', padL+6, padT+12);
  }
  function drawCtrl(S){ var cv=document.getElementById('ctrl'), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h; ctx.fillStyle='#0d0810'; ctx.fillRect(0,0,W,H);
    var T=12, umax=Math.max.apply(null,S.us.map(function(p){return Math.abs(p.u);}))||1; var mid=H*0.5;
    ctx.strokeStyle='#2a1622'; ctx.beginPath(); ctx.moveTo(8,mid); ctx.lineTo(W-8,mid); ctx.stroke();
    ctx.save(); ctx.shadowColor='#fbbf24'; ctx.shadowBlur=6; ctx.strokeStyle='#fbbf24'; ctx.lineWidth=1.6; ctx.beginPath(); S.us.forEach(function(p,i){ var x=8+p.t/T*(W-16), y=mid-(p.u/umax)*(H*0.42); i?ctx.lineTo(x,y):ctx.moveTo(x,y); }); ctx.stroke(); ctx.restore();
    ctx.fillStyle='#fbbf24'; ctx.font="11px 'Geist Mono',monospace"; ctx.fillText('control effort u(t)', 12, 18);
  }
  function drawPole(S){ var cv=document.getElementById('pole'), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h, cx=W*0.62, cy=H/2; ctx.fillStyle='#0d0810'; ctx.fillRect(0,0,W,H);
    var sc=W/16; // s-plane
    ctx.fillStyle='rgba(52,211,153,0.05)'; ctx.fillRect(0,0,cx,H); ctx.fillStyle='rgba(248,113,113,0.05)'; ctx.fillRect(cx,0,W-cx,H);
    ctx.strokeStyle='#2a1622'; ctx.beginPath(); ctx.moveTo(0,cy); ctx.lineTo(W,cy); ctx.moveTo(cx,0); ctx.lineTo(cx,H); ctx.stroke();
    ctx.fillStyle='#5f7597'; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText('Re',W-20,cy-6); ctx.fillText('Im',cx+4,12); ctx.fillText('stable ← | → unstable',6,H-8);
    S.poles.forEach(function(p){ var x=cx+p.re*sc, y=cy-p.im*sc; var col=p.re<0?'#34d399':'#f87171'; ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=12; ctx.strokeStyle=col; ctx.lineWidth=2.5; ctx.beginPath(); ctx.moveTo(x-6,y-6); ctx.lineTo(x+6,y+6); ctx.moveTo(x+6,y-6); ctx.lineTo(x-6,y+6); ctx.stroke(); ctx.restore(); });
    ctx.fillStyle='#f472b6'; ctx.fillText('closed-loop poles', 10, 18);
  }
  function loop(){ var S=simulate();
    document.getElementById('mOS').textContent=S.stable?S.os.toFixed(1)+' %':'—'; document.getElementById('mTs').textContent=S.stable?S.ts.toFixed(2)+' s':'—';
    document.getElementById('mTr').textContent=S.stable?S.tr.toFixed(2)+' s':'—'; document.getElementById('mSS').textContent=S.stable?S.ss.toFixed(3):'—';
    document.getElementById('mStab').textContent=S.stable?'yes':'NO'; document.getElementById('mStab').style.color=S.stable?'#34d399':'#f87171';
    drawStep(S); drawCtrl(S); drawPole(S); requestAnimationFrame(loop); }
  requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
