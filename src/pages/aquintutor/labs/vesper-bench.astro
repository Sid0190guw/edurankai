---
import BaseLayout from '@/layouts/BaseLayout.astro';
// VESPER Test Bench — engineering verification for the Viśvambhara programme:
// all three tiers (Bee micro-UAV, Mother SSTO, Grandmother command vessel)
// against their real requirements. Genuine computation, no libraries:
//   Bee    — actuator-disk hover power P = T^1.5 / sqrt(2*rho*A), battery
//            endurance, free-space-path-loss link budget, gust margin.
//   Mother — Tsiolkovsky delta-v, liftoff T/W, and a numeric RK4 2-D ascent
//            integration (gravity turn, exponential atmosphere, drag) that
//            reports the actually-achieved orbit, not just the ideal number.
//   Grandmother — interplanetary delta-v budget, berth capacity, power and
//            shielding margins.
// Requirement-driven: each tier runs a test campaign with PASS/FAIL margins.
---
<BaseLayout title="VESPER Test Bench · Virtual Labs · AquinTutor" description="Engineering verification for the VESPER three-tier swarm: Bee micro-UAV hover and link budgets, Mother SSTO RK4 ascent to orbit, Grandmother interplanetary delta-v. Requirement-driven pass/fail test campaigns. No libraries.">

<style is:global>
  body { background:#08080a; color:#e8e8ee; margin:0; }
  .era-fab { display:none !important; }
  .vb-wrap { display:grid; grid-template-rows:52px 1fr; height:100vh; height:100dvh; }
  .vb-bar { background:#11131a; border-bottom:1px solid #2a2a35; display:flex; align-items:center; padding:0 14px; gap:12px; font-family:'Geist Mono',monospace; font-size:11px; color:#cfd6da; }
  .vb-bar a { color:#FF9066; text-decoration:none; }
  .vb-title { font-family:'Cormorant Garamond',Georgia,serif; font-size:17px; color:#fff; font-weight:600; }
  .vb-title em { color:#FF7040; font-style:italic; }
  .vb-tiers { margin-left:auto; display:flex; gap:6px; }
  .vb-tier { background:transparent; border:1px solid #2a2a35; color:#cfd6da; padding:6px 13px; border-radius:6px; cursor:pointer; font-family:inherit; font-size:10.5px; letter-spacing:0.05em; text-transform:uppercase; font-weight:700; }
  .vb-tier.on { background:#FF4F00; color:#fff; border-color:#FF4F00; }
  .vb-main { display:grid; grid-template-columns:260px 1fr 320px; overflow:hidden; }
  @media (max-width:960px){ .vb-main { grid-template-columns:1fr; grid-template-rows:auto 42vh auto; overflow-y:auto; } }
  .vb-left { background:#0c0e14; border-right:1px solid #2a2a35; overflow-y:auto; padding:14px; }
  .vb-cat { font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.18em; text-transform:uppercase; color:#FF9066; font-weight:700; margin:4px 0 8px; }
  .vb-param { margin:10px 0 2px; }
  .vb-param label { display:flex; justify-content:space-between; font-family:'Geist Mono',monospace; font-size:10px; color:#9aa; margin-bottom:3px; }
  .vb-param label b { color:#d9f9e8; }
  .vb-param input[type=range] { width:100%; accent-color:#FF4F00; }
  .vb-view { position:relative; overflow:hidden; background:#0b0d13; }
  #vbCanvas { position:absolute; inset:0; width:100%; height:100%; display:block; }
  .vb-right { background:#0c0e14; border-left:1px solid #2a2a35; overflow-y:auto; padding:14px; font-family:'Geist Mono',monospace; font-size:11px; color:#cfd6da; }
  .vb-right h3 { font-family:'Cormorant Garamond',Georgia,serif; font-size:15px; color:#fff; margin:0 0 8px; font-weight:600; }
  .vb-kv { display:flex; justify-content:space-between; padding:3px 0; border-bottom:1px dashed rgba(120,130,150,0.12); }
  .vb-kv b { color:#d9f9e8; }
  .vb-run { width:100%; margin:12px 0; background:#FF4F00; color:#fff; border:none; padding:10px; border-radius:8px; font-family:inherit; font-size:11px; font-weight:800; letter-spacing:0.08em; text-transform:uppercase; cursor:pointer; }
  .vb-test { display:grid; grid-template-columns:1fr auto; gap:4px 8px; padding:7px 9px; border:1px solid #2a2a35; border-radius:8px; margin-bottom:6px; font-size:10.5px; }
  .vb-test .req { color:#9aa; }
  .vb-test .val { text-align:right; color:#d9f9e8; }
  .vb-test .verdict { grid-column:1/-1; font-weight:800; letter-spacing:0.1em; }
  .vb-test.pass { border-color:rgba(70,167,88,0.5); } .vb-test.pass .verdict { color:#46a758; }
  .vb-test.fail { border-color:rgba(229,72,77,0.5); } .vb-test.fail .verdict { color:#e5484d; }
  .vb-overall { text-align:center; font-weight:800; letter-spacing:0.14em; padding:10px; border-radius:8px; margin-top:8px; font-size:12px; }
  .vb-overall.pass { background:rgba(70,167,88,0.12); color:#46a758; border:1px solid rgba(70,167,88,0.4); }
  .vb-overall.fail { background:rgba(229,72,77,0.12); color:#e5484d; border:1px solid rgba(229,72,77,0.4); }
  .vb-note { font-size:10px; color:#788; line-height:1.7; border-top:1px solid #2a2a35; margin-top:12px; padding-top:10px; }
</style>

<div class="vb-wrap">
  <div class="vb-bar">
    <a href="/aquintutor/labs">&larr; LABS</a>
    <span class="vb-title">VESPER <em>Test Bench</em></span>
    <span style="opacity:0.55;">VERIFICATION &middot; ALL THREE TIERS</span>
    <div class="vb-tiers">
      <button type="button" class="vb-tier on" data-tier="bee">Bee</button>
      <button type="button" class="vb-tier" data-tier="mother">Mother</button>
      <button type="button" class="vb-tier" data-tier="grandmother">Grandmother</button>
    </div>
  </div>
  <div class="vb-main">
    <div class="vb-left">
      <div class="vb-cat" id="vbTierName">Bee - micro-UAV configuration</div>
      <div id="vbParams"></div>
    </div>
    <div class="vb-view"><canvas id="vbCanvas"></canvas></div>
    <div class="vb-right">
      <h3>Derived engineering values</h3>
      <div id="vbDerived"></div>
      <button type="button" class="vb-run" id="vbRun">Run test campaign</button>
      <div id="vbTests"></div>
      <div id="vbOverall"></div>
      <div class="vb-note" id="vbNote"></div>
    </div>
  </div>
</div>

<script is:inline>
(function(){
  'use strict';
  var cv = document.getElementById('vbCanvas'), ctx = cv.getContext('2d');
  var W = 0, H = 0, DPR = Math.min(2, window.devicePixelRatio || 1);
  function resize(){ W = cv.clientWidth; H = cv.clientHeight; cv.width = W*DPR; cv.height = H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); update(); }
  window.addEventListener('resize', resize);
  var G0 = 9.80665, RE = 6371000, MU = 3.986e14, RHO0 = 1.225, HSCALE = 8500;

  // ============================ TIER DEFINITIONS ============================
  var TIERS = {
    bee: {
      name: 'Bee - micro-UAV configuration',
      params: [
        ['mass','All-up mass (g)',2.0,6.0,3.2,0.1],
        ['rotor','Rotor diameter (mm)',10,40,22,1],
        ['nrot','Rotors',2,8,4,1],
        ['cap','Battery capacity (mAh)',20,150,70,5],
        ['volt','Battery voltage (V)',3.0,7.6,3.7,0.1],
        ['txp','Comms TX power (mW)',1,100,25,1],
        ['freq','Link frequency (GHz)',0.9,5.8,2.4,0.1],
      ],
      derive: function(P){
        var m = P.mass/1000, T = m*G0;                              // hover thrust (N)
        var A = P.nrot * Math.PI * Math.pow(P.rotor/2000, 2);       // total disk area (m2)
        var pIdeal = Math.pow(T, 1.5) / Math.sqrt(2*RHO0*A);        // actuator disk (W)
        var pHover = pIdeal / 0.55;                                 // figure of merit 0.55
        var eWh = P.cap/1000 * P.volt;                              // battery energy (Wh)
        var endurance = (eWh*0.8) / (pHover + P.txp/1000/4) * 60;   // min, 80% usable
        var tw = Math.min(9.9, (A*280) / T);                        // crude max-thrust proxy
        // link budget: FSPL at range r; sensitivity -95 dBm, antennas 0 dBi
        var txDbm = 10*Math.log10(P.txp);
        var range = Math.pow(10, (txDbm + 95 - 32.44 - 20*Math.log10(P.freq*1000)) / 20) * 1000; // m
        return {
          list: [
            ['Hover thrust', (T*1000).toFixed(1) + ' mN'],
            ['Disk loading', (T/A).toFixed(1) + ' N/m2'],
            ['Hover power', pHover.toFixed(2) + ' W'],
            ['Battery energy', eWh.toFixed(2) + ' Wh'],
            ['Hover endurance', endurance.toFixed(1) + ' min'],
            ['Thrust margin (T/W)', tw.toFixed(2)],
            ['Link budget range', (range/1000).toFixed(2) + ' km'],
          ],
          tests: [
            ['All-up mass <= 3.5 g', P.mass, ' g', P.mass <= 3.5],
            ['Hover endurance >= 15 min', endurance.toFixed(1), ' min', endurance >= 15],
            ['Thrust margin T/W >= 2.0 (gust survival)', tw.toFixed(2), '', tw >= 2.0],
            ['Comms range >= 1.2 km (swarm mesh hop)', (range/1000).toFixed(2), ' km', range >= 1200],
            ['Hover power <= 2.5 W (thermal limit)', pHover.toFixed(2), ' W', pHover <= 2.5],
          ],
          note: 'Hover power from actuator-disk (momentum) theory with figure of merit 0.55 - the standard first-order rotorcraft sizing method. Link range from the Friis free-space path loss at -95 dBm receiver sensitivity. Every value recomputes live from your configuration.',
          plot: { kind:'bee' }
        };
      }
    },
    mother: {
      name: 'Mother - SSTO configuration',
      params: [
        ['dry','Dry mass (t)',20,80,38,1],
        ['prop','Propellant (t)',100,600,300,10],
        ['isp','Engine Isp (s)',330,460,420,5],
        ['thrust','Total thrust (kN)',3000,12000,6500,100],
        ['cda','Drag area CdA (m2)',10,80,30,2],
        ['bees','Bee payload (thousand)',20,150,100,5],
      ],
      derive: function(P){
        var beeMass = P.bees*1000 * 0.0032 / 1000;                  // t
        var m0 = (P.dry + P.prop + beeMass) * 1000;                 // kg
        var mf = (P.dry + beeMass) * 1000;
        var dv = P.isp * G0 * Math.log(m0/mf);                      // Tsiolkovsky
        var tw = (P.thrust*1000) / (m0*G0);
        // 2-D ascent integration (RK4): pitch program 90->0 deg by 65 km.
        var traj = ascend(P, m0, mf);
        return {
          list: [
            ['Bee payload mass', beeMass.toFixed(2) + ' t (' + P.bees + 'k bees)'],
            ['Liftoff mass', (m0/1000).toFixed(0) + ' t'],
            ['Mass ratio', (m0/mf).toFixed(2)],
            ['Ideal delta-v (Tsiolkovsky)', (dv/1000).toFixed(2) + ' km/s'],
            ['Liftoff T/W', tw.toFixed(2)],
            ['Integrated final velocity', (traj.v/1000).toFixed(2) + ' km/s'],
            ['Integrated apoapsis', (traj.apo/1000).toFixed(0) + ' km'],
            ['Gravity + drag losses', ((dv - traj.v)/1000).toFixed(2) + ' km/s'],
          ],
          tests: [
            ['Liftoff T/W >= 1.25', tw.toFixed(2), '', tw >= 1.25],
            ['Ideal delta-v >= 9.4 km/s (LEO incl. losses)', (dv/1000).toFixed(2), ' km/s', dv >= 9400],
            ['Integrated orbit velocity >= 7.6 km/s', (traj.v/1000).toFixed(2), ' km/s', traj.v >= 7600],
            ['Apoapsis >= 200 km', (traj.apo/1000).toFixed(0), ' km', traj.apo >= 200000],
            ['Carries 100k bees (320 kg)', beeMass.toFixed(2), ' t', P.bees >= 100],
          ],
          note: 'The ideal delta-v is Tsiolkovsky; the integrated values come from a genuine RK4 time-march of the 2-D equations of motion with an exponential atmosphere, quadratic drag and a linear gravity-turn pitch program - so gravity and drag losses are computed, not assumed. SSTO closes only when the mass ratio and Isp are both aggressive: that is the engineering point.',
          plot: { kind:'traj', traj: traj }
        };
      }
    },
    grandmother: {
      name: 'Grandmother - command vessel',
      params: [
        ['dry','Dry mass (kt)',8,40,17,1],
        ['prop','Propellant (kt)',4,30,11,1],
        ['isp','NEP Isp (s)',2000,9000,5000,100],
        ['berths','Mother berths',200,800,500,10],
        ['power','Reactor power (MW)',100,1200,600,20],
        ['shield','Shield mass fraction (%)',5,25,12,1],
      ],
      derive: function(P){
        var m0 = (P.dry + P.prop)*1e6, mf = P.dry*1e6;
        var dv = P.isp * G0 * Math.log(m0/mf);
        var perBerth = P.power*1000 / P.berths;                     // kW per berth
        var shieldT = P.dry * P.shield/100;                          // kt
        var marsDv = 5600;                                           // LEO->Mars orbit budget (m/s)
        return {
          list: [
            ['Departure mass', (m0/1e6).toFixed(1) + ' kt'],
            ['Mass ratio', (m0/mf).toFixed(2)],
            ['Delta-v capability', (dv/1000).toFixed(2) + ' km/s'],
            ['Mars transfer budget', (marsDv/1000).toFixed(1) + ' km/s'],
            ['Delta-v margin', (((dv-marsDv)/marsDv)*100).toFixed(0) + ' %'],
            ['Power per berth', perBerth.toFixed(0) + ' kW'],
            ['Shield mass', shieldT.toFixed(1) + ' kt'],
            ['Fleet at capacity', P.berths + ' Mothers / ' + (P.berths*0.1).toFixed(0) + 'M bees'],
          ],
          tests: [
            ['Delta-v >= 6.0 km/s (Mars + 20% reserve)', (dv/1000).toFixed(2), ' km/s', dv >= 6000],
            ['Berths >= 500 Mother Ships', String(P.berths), '', P.berths >= 500],
            ['Power per berth >= 900 kW (turnaround)', perBerth.toFixed(0), ' kW', perBerth >= 900],
            ['Shield fraction >= 10% (crew GCR dose)', String(P.shield), ' %', P.shield >= 10],
            ['Mass ratio <= 2.2 (structural realism)', (m0/mf).toFixed(2), '', (m0/mf) <= 2.2],
          ],
          note: 'Nuclear-electric propulsion trades thrust for exhaust velocity: at Isp 5000 s a modest mass ratio buys interplanetary delta-v that chemical stages cannot reach. Berth power sets fleet turnaround tempo; shield fraction is the crew galactic-cosmic-ray dose knob. All budgets recompute live.',
          plot: { kind:'gm' }
        };
      }
    }
  };

  // RK4 2-D ascent: state [x, h, vx, vh, m]; pitch 90->0 deg linearly to 65 km.
  function ascend(P, m0, mf){
    var mdot = (P.thrust*1000) / (P.isp*G0);
    var s = { x:0, h:0, vx:0, vh:0, m:m0 }, pts = [], burnT = (m0-mf)/mdot;
    function deriv(st){
      var pitch = Math.max(0, Math.PI/2 * (1 - st.h/65000));       // rad from horizontal
      var thrusting = st.m > mf;
      var Ft = thrusting ? P.thrust*1000 : 0;
      var rho = RHO0 * Math.exp(-st.h/HSCALE);
      var v = Math.hypot(st.vx, st.vh) || 1e-6;
      var Fd = 0.5*rho*v*v*P.cda;
      var g = MU / Math.pow(RE + st.h, 2);
      return {
        x: st.vx, h: st.vh,
        vx: (Ft*Math.cos(pitch) - Fd*st.vx/v)/st.m,
        vh: (Ft*Math.sin(pitch) - Fd*st.vh/v)/st.m - g + (st.vx*st.vx)/(RE+st.h), // centrifugal relief
        m: thrusting ? -mdot : 0
      };
    }
    var dt = 0.5, tMax = burnT + 10;
    for (var t=0; t<tMax; t+=dt){
      var k1 = deriv(s);
      var s2 = {x:s.x+k1.x*dt/2, h:s.h+k1.h*dt/2, vx:s.vx+k1.vx*dt/2, vh:s.vh+k1.vh*dt/2, m:s.m+k1.m*dt/2};
      var k2 = deriv(s2);
      var s3 = {x:s.x+k2.x*dt/2, h:s.h+k2.h*dt/2, vx:s.vx+k2.vx*dt/2, vh:s.vh+k2.vh*dt/2, m:s.m+k2.m*dt/2};
      var k3 = deriv(s3);
      var s4 = {x:s.x+k3.x*dt, h:s.h+k3.h*dt, vx:s.vx+k3.vx*dt, vh:s.vh+k3.vh*dt, m:s.m+k3.m*dt};
      var k4 = deriv(s4);
      s = { x:s.x + dt/6*(k1.x+2*k2.x+2*k3.x+k4.x), h:s.h + dt/6*(k1.h+2*k2.h+2*k3.h+k4.h),
            vx:s.vx + dt/6*(k1.vx+2*k2.vx+2*k3.vx+k4.vx), vh:s.vh + dt/6*(k1.vh+2*k2.vh+2*k3.vh+k4.vh),
            m:Math.max(mf, s.m + dt/6*(k1.m+2*k2.m+2*k3.m+k4.m)) };
      if (s.h < -10) break;
      if (t % 2 < dt) pts.push({ t:t, h:s.h, v:Math.hypot(s.vx, s.vh) });
    }
    var v = Math.hypot(s.vx, s.vh), r = RE + s.h;
    var energy = v*v/2 - MU/r, sma = -MU/(2*energy);
    var hVec = r * s.vx; // specific ang. momentum (planar approx)
    var ecc = Math.sqrt(Math.max(0, 1 + 2*energy*hVec*hVec/(MU*MU)));
    var apo = sma > 0 ? sma*(1+ecc) - RE : s.h;
    return { v:v, h:s.h, apo:Math.max(0, apo), pts:pts, burnT:burnT };
  }

  // ============================ UI wiring ============================
  var cur = 'bee', P = {}, D = null;
  function buildParams(){
    var host = document.getElementById('vbParams'); host.innerHTML = '';
    document.getElementById('vbTierName').textContent = TIERS[cur].name;
    P = {};
    TIERS[cur].params.forEach(function(def){
      P[def[0]] = def[4];
      var w = document.createElement('div'); w.className = 'vb-param';
      w.innerHTML = '<label>' + def[1] + ' <b data-v>' + def[4] + '</b></label>';
      var r = document.createElement('input'); r.type='range'; r.min=def[2]; r.max=def[3]; r.step=def[5]; r.value=def[4];
      r.addEventListener('input', function(){ P[def[0]] = Number(r.value); w.querySelector('[data-v]').textContent = r.value; update(); });
      w.appendChild(r); host.appendChild(w);
    });
  }
  document.querySelectorAll('.vb-tier').forEach(function(b){
    b.addEventListener('click', function(){
      document.querySelectorAll('.vb-tier').forEach(function(x){ x.classList.remove('on'); });
      b.classList.add('on'); cur = b.getAttribute('data-tier');
      document.getElementById('vbTests').innerHTML = ''; document.getElementById('vbOverall').innerHTML = '';
      buildParams(); update();
    });
  });
  function update(){
    D = TIERS[cur].derive(P);
    var dv = document.getElementById('vbDerived'); dv.innerHTML = '';
    D.list.forEach(function(kv){ var d = document.createElement('div'); d.className = 'vb-kv'; d.innerHTML = '<span>' + kv[0] + '</span><b>' + kv[1] + '</b>'; dv.appendChild(d); });
    document.getElementById('vbNote').textContent = D.note;
    plot();
  }
  document.getElementById('vbRun').addEventListener('click', function(){
    var host = document.getElementById('vbTests'); host.innerHTML = '';
    var all = true;
    D.tests.forEach(function(t){
      if (!t[3]) all = false;
      var d = document.createElement('div'); d.className = 'vb-test ' + (t[3] ? 'pass' : 'fail');
      d.innerHTML = '<span class="req">' + t[0] + '</span><span class="val">' + t[1] + t[2] + '</span><span class="verdict">' + (t[3] ? 'PASS' : 'FAIL') + '</span>';
      host.appendChild(d);
    });
    var o = document.getElementById('vbOverall');
    o.className = 'vb-overall ' + (all ? 'pass' : 'fail');
    o.textContent = all ? 'CAMPAIGN PASSED - CONFIGURATION VERIFIED' : 'CAMPAIGN FAILED - ADJUST THE CONFIGURATION';
  });

  // ============================ plots / schematics ============================
  function plot(){
    if (!W) return;
    ctx.fillStyle = '#0b0d13'; ctx.fillRect(0,0,W,H);
    ctx.strokeStyle = 'rgba(120,130,150,0.12)';
    for (var i=1;i<10;i++){ ctx.beginPath(); ctx.moveTo(W*i/10, 0); ctx.lineTo(W*i/10, H); ctx.stroke(); ctx.beginPath(); ctx.moveTo(0, H*i/10); ctx.lineTo(W, H*i/10); ctx.stroke(); }
    ctx.font = '11px monospace';
    if (D.plot.kind === 'traj'){
      var pts = D.plot.traj.pts; if (!pts.length) return;
      var tMax = pts[pts.length-1].t || 1, hMax = 0, vMax = 0;
      pts.forEach(function(p){ hMax = Math.max(hMax, p.h); vMax = Math.max(vMax, p.v); });
      hMax = Math.max(hMax, 1); vMax = Math.max(vMax, 1);
      function X(t){ return 50 + (W-80)*t/tMax; }
      // altitude curve
      ctx.strokeStyle = '#FF7040'; ctx.lineWidth = 2; ctx.beginPath();
      pts.forEach(function(p,i){ var x = X(p.t), y = H-40 - (H-90)*p.h/hMax; i ? ctx.lineTo(x,y) : ctx.moveTo(x,y); }); ctx.stroke();
      // velocity curve
      ctx.strokeStyle = '#67e8f9'; ctx.lineWidth = 2; ctx.beginPath();
      pts.forEach(function(p,i){ var x = X(p.t), y = H-40 - (H-90)*p.v/vMax; i ? ctx.lineTo(x,y) : ctx.moveTo(x,y); }); ctx.stroke();
      ctx.fillStyle = '#FF7040'; ctx.fillText('altitude (max ' + (hMax/1000).toFixed(0) + ' km)', 54, 24);
      ctx.fillStyle = '#67e8f9'; ctx.fillText('velocity (max ' + (vMax/1000).toFixed(2) + ' km/s)', 54, 40);
      ctx.fillStyle = '#9aa'; ctx.fillText('RK4 ascent integration - burn ' + D.plot.traj.burnT.toFixed(0) + ' s, dt 0.5 s', 54, H-16);
      // orbital velocity reference
      var yRef = H-40 - (H-90)*7800/vMax;
      if (yRef > 20){ ctx.strokeStyle = 'rgba(103,232,249,0.35)'; ctx.setLineDash([5,4]); ctx.beginPath(); ctx.moveTo(50,yRef); ctx.lineTo(W-30,yRef); ctx.stroke(); ctx.setLineDash([]); ctx.fillStyle = 'rgba(103,232,249,0.6)'; ctx.fillText('7.8 km/s orbital', W-170, yRef-6); }
    } else if (D.plot.kind === 'bee'){
      // schematic quad + power bar chart
      var cx0 = W/2, cy0 = H/2 - 20, r = Math.min(W,H)*0.09;
      ctx.strokeStyle = '#FF7040'; ctx.lineWidth = 2;
      [[-1,-1],[1,-1],[-1,1],[1,1]].forEach(function(o){
        ctx.beginPath(); ctx.arc(cx0 + o[0]*r*1.7, cy0 + o[1]*r*1.1, r, 0, 2*Math.PI); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(cx0, cy0); ctx.lineTo(cx0 + o[0]*r*1.7, cy0 + o[1]*r*1.1); ctx.stroke();
      });
      ctx.fillStyle = '#e8e8ee'; ctx.fillRect(cx0-9, cy0-9, 18, 18);
      ctx.fillStyle = '#9aa'; ctx.fillText('Bee ' + P.mass + ' g - rotor ' + P.rotor + ' mm x' + P.nrot, cx0-90, cy0 + r*2.3);
      // endurance vs mass sweep (design-space curve)
      ctx.strokeStyle = '#67e8f9'; ctx.lineWidth = 1.6; ctx.beginPath();
      for (var mm=2.0; mm<=6.0; mm+=0.1){
        var T = mm/1000*G0, A = P.nrot*Math.PI*Math.pow(P.rotor/2000,2);
        var pw = Math.pow(T,1.5)/Math.sqrt(2*RHO0*A)/0.55;
        var e = (P.cap/1000*P.volt*0.8)/pw*60;
        var x = 50 + (W-80)*(mm-2)/4, y = H-30 - Math.min(H-70, e*(H-70)/60);
        mm === 2.0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
      }
      ctx.stroke();
      ctx.fillStyle = '#67e8f9'; ctx.fillText('endurance vs all-up mass (2-6 g)', 54, H-40);
      var xNow = 50 + (W-80)*(P.mass-2)/4;
      ctx.strokeStyle = '#FF4F00'; ctx.setLineDash([4,3]); ctx.beginPath(); ctx.moveTo(xNow, 30); ctx.lineTo(xNow, H-30); ctx.stroke(); ctx.setLineDash([]);
    } else {
      // grandmother: berth ring schematic + delta-v bar
      var cx0 = W/2, cy0 = H/2, R = Math.min(W,H)*0.3;
      ctx.strokeStyle = '#FF7040'; ctx.lineWidth = 2;
      ctx.beginPath(); ctx.arc(cx0, cy0, R, 0, 2*Math.PI); ctx.stroke();
      ctx.beginPath(); ctx.arc(cx0, cy0, R*0.55, 0, 2*Math.PI); ctx.stroke();
      var n = Math.min(72, Math.round(P.berths/10));
      ctx.fillStyle = '#67e8f9';
      for (var i=0;i<n;i++){ var a = i/n*2*Math.PI; ctx.fillRect(cx0 + Math.cos(a)*R*0.78 - 2, cy0 + Math.sin(a)*R*0.78 - 2, 4, 4); }
      ctx.fillStyle = '#9aa'; ctx.fillText(P.berths + ' berths (1 dot = 10)', cx0 - 70, cy0 + R + 22);
      ctx.fillText('reactor ' + P.power + ' MW - ' + (P.dry+P.prop) + ' kt departure', cx0 - 110, cy0 + R + 40);
    }
  }

  buildParams(); resize();
})();
</script>

</BaseLayout>
