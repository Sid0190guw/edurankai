---
import BaseLayout from '@/layouts/BaseLayout.astro';

const LABS = [
  { slug: 'logic-bench', cat: 'Digital · Bench', label: 'Digital Logic Workbench', desc: 'Real breadboard bench: power supply, toggle switches, glowing LEDs. Drag gate chips, click-to-wire, press START. Auto-builds half/full-adder, MUX, SR-latch.', icon: 'cpu', color: '#10b981', live: true },
  { slug: 'eee-bench', cat: 'Analog · Bench', label: 'Analog Electronics Workbench', desc: 'Real breadboard: battery, colour-banded resistors, LEDs, potentiometer, switches. Wire it pin-to-pin, probe with a multimeter (V/A/Ω). Ohm law to Wheatstone bridge.', icon: 'zap', color: '#f59e0b', live: true },
  { slug: 'cro-bench', cat: 'Instrumentation · Bench', label: 'Oscilloscope + Function Gen', desc: 'Dual-channel CRO with a phosphor-green CRT and turnable knobs (volts/div, time/div, trigger), two function generators, auto-measure (freq, Vpp, phase), and Lissajous figures.', icon: 'activity', color: '#22d3ee', live: true },
  { slug: 'optics-bench', cat: 'Optics · Bench', label: 'Optical Bench', desc: 'Slide lenses and mirrors along a graduated rail, trace ray fans, and watch real/virtual images form with genuine thin-lens / mirror physics. Multi-element systems.', icon: 'eye', color: '#818cf8', live: true },
  { slug: 'titration-bench', cat: 'Chemistry · Bench', label: 'Titration Bench', desc: 'Burette on a stand over a conical flask. Add titrant dropwise, watch the indicator turn, and build the live pH curve to the equivalence point. Strong/weak acid-base.', icon: 'droplet', color: '#f472b6', live: true },
  { slug: 'vlsi', cat: 'VLSI · Digital', label: 'VLSI & Digital Design', desc: 'Gate-level logic + Quine-McCluskey K-maps, FSM designer, static timing analysis, CMOS Elmore delay/sizing, and power analysis. 11 experiments.', icon: 'cpu', color: '#67e8f9', live: true },
  { slug: 'eee', cat: 'Electrical', label: 'Electrical & Electronics', desc: 'Nodal analysis, transient scope, AC Bode, plus transfer-function pole-zero, root-locus control, and BJT/MOSFET I-V curves. 11 experiments.', icon: 'zap', color: '#fbbf24', live: true },
  { slug: 'cybersecurity', cat: 'Security', label: 'Cybersecurity', desc: 'Ciphers, RSA, Diffie-Hellman, SHA-256, AES-GCM plus AES round internals (S-box/MixColumns), elliptic-curve crypto, stack-overflow visualizer. 11 experiments.', icon: 'package', color: '#86efac', live: true },
  { slug: 'exploit-sandbox', cat: 'Security', label: 'Exploit Sandbox', desc: 'A real stack buffer-overflow exploit sandbox: craft a payload, overflow into the saved return address, hijack control flow to win() (ret2win). Defeat stack canaries, NX and ASLR in sequence with a simulated info-leak. Live stack memory. Flagship depth, deterministic simulator.', icon: 'package', color: '#86efac', live: true },
  { slug: 'ai-ml', cat: 'AI / ML', label: 'AI & Machine Learning', desc: 'Regression, k-means, k-NN, backprop MLP, plus CNN feature-maps, bias-variance + k-fold CV, and an Iris classifier with confusion matrix. 11 experiments.', icon: 'share-2', color: '#FF4F00', live: true },
  { slug: 'nn-playground', cat: 'AI / ML', label: 'Neural Network Playground', desc: 'Train a real MLP live: hand-written forward pass + backpropagation (no libraries), configurable layers/neurons/activation, feature engineering, spiral/moons/circle/XOR data. Live decision boundary, per-neuron activation maps, train/test loss curves. Flagship depth.', icon: 'share-2', color: '#67e8f9', live: true },
  { slug: 'robotics', cat: 'Robotics', label: 'Robotics & AI', desc: 'Arm FK/IK, navigation, A*, PID, plus damped-least-squares Jacobian IK, RRT* planning, and EKF-SLAM with covariance ellipses. 11 experiments.', icon: 'activity', color: '#a78bfa', live: true },
  { slug: 'flight-sim', cat: 'Aerospace', label: 'Flight Simulator', desc: 'Real-time 3D flight over procedural terrain: four-forces model, bank-turn physics (g·tan(bank)/v), stall dynamics, landing challenge. Chase, cockpit and orbit cameras. Hand-rolled 3D renderer, no libraries.', icon: 'send', color: '#FF7040', live: true },
  { slug: 'cad-studio', cat: 'Aerospace', label: 'CAD Studio', desc: 'A real parametric solid modeler: TRUE boolean solids (BSP-tree CSG union/cut/intersect), WebGL viewport, editable feature history, constrained 2D sketcher with extrude/revolve, undo, documents, divergence-theorem mass properties, section, measurement, orthographic drawings, STL export. Phases 1-2 of the CAD-grade programme.', icon: 'box', color: '#FF7040', live: true },
  { slug: 'cad-assembly', cat: 'Aerospace', label: 'CAD Assembly', desc: 'Multi-part assembly with a real INTERFERENCE CHECK (AABB broad-phase + Monte-Carlo clash-volume estimate by ray-parity), per-part placement, exploded view, assembly mass roll-up + centre of mass, STL export. Phase 3 of the CAD-grade programme.', icon: 'layers', color: '#67e8f9', live: true },
  { slug: 'cad-fea', cat: 'Aerospace', label: 'CAD FEA', desc: 'Real 2-D plane-stress finite-element analysis: constant-strain-triangle mesh, global stiffness assembly, direct solve of K·u=F, von Mises stress field on the deformed shape, deflection and yield safety factor. Shows stress concentration around holes. Phase 4 of the CAD-grade programme.', icon: 'activity', color: '#e5484d', live: true },
  { slug: 'cad-bench', cat: 'Aerospace', label: 'CAD Workbench', desc: 'Parametric aerospace part design: NACA 4-digit wing ribs, bell nozzles, fuselage frames. Mass properties (Pappus, shoelace), materials, section view, vertex measurement, ASCII STL export that opens in real CAD tools.', icon: 'box', color: '#67e8f9', live: true },
  { slug: 'vesper-bench', cat: 'Aerospace', label: 'VESPER Test Bench', desc: 'Verification for the three-tier swarm: Bee hover physics + link budgets, Mother SSTO with genuine RK4 ascent-to-orbit integration, Grandmother interplanetary delta-v. Requirement-driven PASS/FAIL campaigns.', icon: 'target', color: '#a78bfa', live: true },
  { slug: 'mechanical', cat: 'Mechanical', label: 'Mechanical Engineering', desc: 'Beams, stress-strain, gears, thermo cycles, plus 2D finite-element von Mises stress, Euler buckling, and fatigue (Goodman/Soderberg). 11 experiments.', icon: 'box', color: '#7fb3ff', live: true },
  { slug: 'fluid-bench', cat: 'Fluid Mechanics', label: 'Fluid Mechanics & Hydraulics', desc: 'Bernoulli + continuity, Reynolds dye apparatus, Darcy-Weisbach pipe friction with a Moody chart, venturi/orifice meters, Torricelli draining. 6 experiments.', icon: 'wind', color: '#38bdf8', live: true },
  { slug: 'reaction-bench', cat: 'Chemical Engineering', label: 'Chemical Reaction Engineering', desc: 'Batch / CSTR / PFR reactors (real RK4 kinetics), Levenspiel plots, Arrhenius fit, reaction-order determination. 6 experiments.', icon: 'droplet', color: '#fb923c', live: true },
  { slug: 'biotech-bench', cat: 'Biology', label: 'Molecular Biology', desc: 'PCR thermal cycler, gel electrophoresis, restriction digestion, Michaelis-Menten kinetics, transcription/translation, Beer-Lambert. 6 experiments.', icon: 'shuffle', color: '#34d399', live: true },
  { slug: 'dsa-bench', cat: 'Algorithms', label: 'Data Structures & Algorithms', desc: 'Animated BST/AVL, heaps, hash tables (chaining + probing), stacks/queues, linked lists, and BFS/DFS graph traversal. 7 experiments.', icon: 'share-2', color: '#c084fc', live: true },
  { slug: 'signals-systems', cat: 'Signals & Systems', label: 'Signals & Systems', desc: 'Signal generator (incl. complex exponential), even/odd decomposition, time transforms, animated convolution, Fourier-series synthesis (Gibbs), sampling/aliasing, LTI response.', icon: 'radio', color: '#22d3ee', live: true },
  { slug: 'control-systems', cat: 'Control Systems', label: 'Control Systems', desc: 'Transfer-function pole-zero + step, time-domain specs, root locus, Bode + margins, Nyquist stability, PID tuning, Routh-Hurwitz.', icon: 'activity', color: '#60a5fa', live: true },
  { slug: 'dsp', cat: 'DSP', label: 'Digital Signal Processing', desc: 'DFT/FFT spectra, FIR windowed design + response, Butterworth IIR, windowing trade-offs, z-plane response, sampling, convolution/correlation.', icon: 'radio', color: '#818cf8', live: true },
  { slug: 'os', cat: 'Operating Systems', label: 'Operating Systems', desc: 'CPU scheduling (FCFS/SJF/SRTF/RR/Priority) + Gantt, page replacement (FIFO/LRU/Optimal), disk scheduling, Banker deadlock, memory allocation.', icon: 'cpu', color: '#34d399', live: true },
  { slug: 'networks', cat: 'Computer Networks', label: 'Computer Networks', desc: 'IP subnetting, TCP handshake state machine, sliding window (GBN/SR), Dijkstra + distance-vector routing, CRC/checksum/Hamming.', icon: 'share-2', color: '#2dd4bf', live: true },
  { slug: 'machines', cat: 'Electrical Machines', label: 'Electrical Machines', desc: 'Transformer equivalent circuit + regulation/efficiency, DC machine characteristics, induction-motor torque-slip, synchronous V-curves, three-phase.', icon: 'zap', color: '#fbbf24', live: true },
  { slug: 'structural', cat: 'Civil · Structures', label: 'Structural Analysis', desc: 'Truss by joints + sections (tension/compression), beam SFD/BMD, deflection (Macaulay), influence lines, Euler buckling.', icon: 'box', color: '#a3a3a3', live: true },
  { slug: 'numerical', cat: 'Numerical Methods', label: 'Numerical Methods', desc: 'Root finding (bisection/Newton/secant), Lagrange/Newton interpolation, Simpson/trapezoidal integration, Euler/RK4 ODEs, Gauss/LU/Gauss-Seidel, least squares.', icon: 'trending-up', color: '#f472b6', live: true },
  { slug: 'pendulum', cat: 'Physics', label: 'Pendulum & SHM', desc: 'Simple + damped + driven pendulum. Vary length, mass, gravity. Live energy + phase plot.', icon: 'activity', color: '#2b577e', live: true },
  { slug: 'projectile', cat: 'Physics', label: 'Projectile motion', desc: 'Vary angle, velocity, gravity, air drag. Live trajectory and range.', icon: 'send', color: '#2b577e', live: true },
  { slug: 'optics', cat: 'Physics', label: 'Ray optics', desc: 'Place lenses + mirrors + prisms; trace rays. Convex, concave, dispersion.', icon: 'eye', color: '#2b577e', live: true },
  { slug: 'circuit', cat: 'Electronics', label: 'Circuit builder', desc: 'Drag resistors, capacitors, batteries, switches. Live current + voltage.', icon: 'zap', color: '#946322', live: true },
  { slug: 'logic-gates', cat: 'Electronics', label: 'Logic gate builder', desc: 'AND, OR, NOT, XOR, NAND. Build adders + flip-flops. Live truth table.', icon: 'cpu', color: '#946322', live: true },
  { slug: 'titration', cat: 'Chemistry', label: 'Acid-base titration', desc: 'Pick acid + base + indicator. Live pH curve + colour change.', icon: 'droplet', color: '#a04330', live: true },
  { slug: 'periodic', cat: 'Chemistry', label: 'Periodic table explorer', desc: 'All 118 elements, electron config, orbital diagrams, trends.', icon: 'grid', color: '#a04330', live: true },
  { slug: 'molecular', cat: 'Chemistry', label: 'Molecular viewer', desc: '3D ball-and-stick models. Rotate, measure bond angles + lengths.', icon: 'package', color: '#a04330', live: true },
  { slug: 'genetics', cat: 'Biology', label: 'Punnett square', desc: 'Monohybrid + dihybrid crosses. Vary dominance, sex linkage.', icon: 'shuffle', color: '#4a7048', live: true },
  { slug: 'ecosystem', cat: 'Biology', label: 'Predator-prey', desc: 'Lotka-Volterra. Live populations + phase plot.', icon: 'wind', color: '#4a7048', live: true },
  { slug: 'plot', cat: 'Mathematics', label: 'Function plotter', desc: 'Plot any f(x). Algebraic + trig + exponential. Live zoom + pan.', icon: 'trending-up', color: '#5b4a92', live: true },
  { slug: 'linear-algebra', cat: 'Mathematics', label: 'Matrix transforms', desc: '2D linear transforms. See eigenvalues, eigenvectors, determinant geometrically.', icon: 'box', color: '#5b4a92', live: true },
  { slug: 'sorting', cat: 'CS', label: 'Sorting visualiser', desc: 'Bubble, quick, merge, heap, radix. Step through with sound.', icon: 'bar-chart-2', color: '#8a486b', live: true },
  { slug: 'pathfinding', cat: 'CS', label: 'Path-finding', desc: 'A*, Dijkstra, BFS, DFS on a grid maze. Live frontier visualisation.', icon: 'map', color: '#8a486b', live: true },
  { slug: 'neural-net', cat: 'AI', label: 'Neural network playground', desc: 'Build a 3-layer net. Pick activation, dataset. Watch decision boundary form.', icon: 'share-2', color: '#FF4F00', live: true },
  { slug: 'fourier', cat: 'Signals', label: 'Fourier series', desc: 'Square / sawtooth / triangle. Add up sinusoids. Watch the approximation.', icon: 'radio', color: '#67e8f9', live: true },
];

// External (existing) lab routes — link out for these
const EXTERNAL_LABS = [
  { slug: '/aquintutor/quantum/composer', cat: 'Quantum', label: 'Quantum circuit composer', desc: 'Up to 8 qubits. Full Qiskit gate set. QASM 2.0 import. 1024-shot sim.', icon: 'cpu', color: '#a78bfa' },
  { slug: '/aquintutor/hpc/simulator', cat: 'HPC', label: 'HPC job simulator', desc: 'Cluster + workload + Gantt + Amdahl. 5 workload models.', icon: 'server', color: '#67e8f9' },
  { slug: '/portal/tools/ide', cat: 'Tools', label: 'Code IDE', desc: 'VS-Code-class browser editor. Multi-tab, terminal, palette.', icon: 'terminal', color: '#86efac' },
  { slug: '/portal/tools/notebook', cat: 'Tools', label: 'Notebook', desc: 'Colab-class cells. JS sandbox, chart() + table() helpers.', icon: 'book-open', color: '#fbbf24' },
  { slug: '/portal/tools/canvas-pro', cat: 'Tools', label: 'Canvas Pro', desc: 'Layered raster editor. 14 blend modes. PNG export.', icon: 'image', color: '#fb923c' },
];

// Group the labs into discipline sections (vlabs-style information architecture).
const DISC_ORDER = ['Electronics & Electrical', 'Computer Science & AI', 'Mechanical', 'Civil', 'Robotics', 'Physics', 'Chemistry', 'Biology', 'Mathematics'];
function discOf(cat: string): string {
  const c = (cat || '').toLowerCase();
  if (/civil|structur|geotech|survey|hydraul/.test(c)) return 'Civil';
  if (/digital|vlsi|analog|instrument|electronic|electrical|signal|control|dsp|machines/.test(c)) return 'Electronics & Electrical';
  if (/security|cyber|\bai\b|ai ?\/? ?ml|machine learning|\bcs\b|algorithm|data struct|operating|network/.test(c)) return 'Computer Science & AI';
  if (/robot/.test(c)) return 'Robotics';
  if (/mechanical|fluid/.test(c)) return 'Mechanical';
  if (/chem|reaction/.test(c)) return 'Chemistry';
  if (/optic|physics|signal/.test(c)) return 'Physics';
  if (/bio/.test(c)) return 'Biology';
  if (/math|numerical/.test(c)) return 'Mathematics';
  return 'More';
}
const disciplines = DISC_ORDER.map((name) => ({ name, items: LABS.filter((l) => discOf(l.cat) === name) }))
  .concat([{ name: 'More simulators', items: LABS.filter((l) => discOf(l.cat) === 'More') }])
  .filter((d) => d.items.length > 0);
---
<BaseLayout title="Virtual Labs · AquinTutor" description="27 working browser-based simulators across VLSI, electrical, cybersecurity, AI/ML, robotics, mechanical, physics, chemistry, biology, mathematics, CS and signals. Real interactive labs — no install.">

<style>
  body { background: #FAF8F5; }
  .vl-wrap { max-width: 1280px; margin: 0 auto; padding: 24px 5vw 100px; }
  .vl-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .vl-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 6vw, 68px); font-weight: 600; letter-spacing: -0.03em; margin: 8px 0 14px; line-height: 1; }
  .vl-title em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .vl-sub { font-size: 17px; color: #2E2520; max-width: 720px; line-height: 1.65; }

  .vl-strip { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px; margin: 30px 0 40px; }
  .vl-stat { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 10px; padding: 14px 16px; }
  .vl-stat-val { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 600; color: #0E0B08; line-height: 1; letter-spacing: -0.02em; }
  .vl-stat-lbl { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: #7A6F68; margin-top: 5px; font-weight: 700; }

  .vl-section-head { display: flex; align-items: baseline; justify-content: space-between; padding: 28px 0 14px; }
  .vl-section-head h2 { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 600; letter-spacing: -0.02em; margin: 0; line-height: 1.1; }
  .vl-section-head h2 em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .vl-section-head .count { font-family: 'Geist Mono', monospace; font-size: 11px; color: #7A6F68; letter-spacing: 0.1em; }

  .vl-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 12px; }
  .vl-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 18px; text-decoration: none; color: inherit; transition: all 0.18s; display: block; }
  .vl-card:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(14,11,8,0.08); border-color: #FF4F00; }
  .vl-card-top { display: flex; gap: 10px; align-items: flex-start; }
  .vl-icon { width: 40px; height: 40px; border-radius: 9px; display: flex; align-items: center; justify-content: center; color: #fff; flex-shrink: 0; }
  .vl-card-cat { font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.14em; text-transform: uppercase; color: #7A6F68; font-weight: 700; }
  .vl-card-title { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; margin: 2px 0 6px; line-height: 1.2; letter-spacing: -0.01em; }
  .vl-card-desc { font-size: 13px; color: #2E2520; line-height: 1.55; }
  .vl-live { display: inline-block; padding: 2px 8px; border-radius: 100px; background: #1A6B35; color: #fff; font-family: 'Geist Mono', monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 700; margin-left: auto; }

  .vl-xr-card { background: linear-gradient(135deg, #FF4F00, #FF7040); color: #fff; border-radius: 16px; padding: 28px; margin-top: 24px; }
  .vl-xr-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 600; margin: 0; letter-spacing: -0.02em; }
  .vl-xr-card p { font-size: 14.5px; line-height: 1.6; margin: 10px 0 16px; opacity: 0.92; max-width: 640px; }
  .vl-xr-btn { background: #fff; color: #FF4F00; padding: 10px 22px; border-radius: 8px; text-decoration: none; font-weight: 800; display: inline-block; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; }

  /* How-to guide */
  .vl-how { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 16px; padding: 26px; margin-top: 24px; }
  .vl-how-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin: 0; }
  .vl-how-h { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 600; margin: 6px 0 4px; letter-spacing: -0.02em; }
  .vl-how-h em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .vl-how-sub { font-size: 14px; color: #2E2520; line-height: 1.6; max-width: 620px; margin: 0 0 20px; }
  .vl-steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; }
  .vl-step { background: #FAF8F5; border: 1px solid rgba(14,11,8,0.08); border-radius: 12px; padding: 18px; position: relative; }
  .vl-step-n { font-family: 'Geist Mono', monospace; font-size: 11px; color: #fff; background: #FF4F00; width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; }
  .vl-step-h { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; margin: 12px 0 6px; line-height: 1.2; }
  .vl-step-p { font-size: 13px; color: #2E2520; line-height: 1.55; margin: 0; }
  .vl-startcard { display: flex; gap: 18px; align-items: center; flex-wrap: wrap; background: linear-gradient(135deg, #FFF3EE, #fff); border: 1px solid #FFD4BC; border-radius: 14px; padding: 20px 24px; margin-top: 16px; }
  .vl-startcard .lt { flex: 1; min-width: 260px; }
  .vl-startcard-eye { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .vl-startcard-h { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; margin: 4px 0 6px; }
  .vl-startcard-p { font-size: 13.5px; color: #2E2520; line-height: 1.6; margin: 0; }
  .vl-startcard-btn { background: #FF4F00; color: #fff; padding: 12px 24px; border-radius: 10px; text-decoration: none; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; white-space: nowrap; }
</style>

<main class="vl-wrap">

  <header>
    <p class="vl-eyebrow">AquinTutor · Virtual Labs</p>
    <h1 class="vl-title">40 labs, <em>150+ experiments</em>.</h1>
    <p class="vl-sub">Browser-based virtual labs across VLSI, electrical & electronics, cybersecurity, AI/ML, robotics, mechanical, physics, chemistry, biology, mathematics, CS, signals, plus quantum + HPC. The six engineering labs are full vlabs-style workbenches — 11 experiments each, every one with aim, theory, procedure, a live simulation and a graded self-assessment. Genuine computation, no install, no third-party library.</p>
  </header>

  <div class="vl-strip">
    <div class="vl-stat"><p class="vl-stat-val">40</p><p class="vl-stat-lbl">Labs</p></div>
    <div class="vl-stat"><p class="vl-stat-val">100+</p><p class="vl-stat-lbl">Experiments</p></div>
    <div class="vl-stat"><p class="vl-stat-val">100%</p><p class="vl-stat-lbl">Browser-side</p></div>
    <div class="vl-stat"><p class="vl-stat-val">0</p><p class="vl-stat-lbl">3rd-party libs</p></div>
    <div class="vl-stat"><p class="vl-stat-val">WebXR</p><p class="vl-stat-lbl">AR / VR ready</p></div>
  </div>

  <div class="vl-xr-card">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.18em;text-transform:uppercase;margin:0 0 6px;font-weight:700;opacity:0.9;">New · AR / VR / XR</p>
    <h3>Step into the simulator.</h3>
    <p>WebXR support for the immersive labs. Bring a Meta Quest, an Apple Vision Pro, or any WebXR-compatible headset — the molecular viewer, the pendulum, the projectile lab, and the periodic table all enter VR with one click. No app install. Hands tracked.</p>
    <a href="/aquintutor/labs/xr" class="vl-xr-btn">Open the XR hub &rarr;</a>
  </div>

  {/* HOW TO USE */}
  <div class="vl-how">
    <p class="vl-how-eye">Getting started</p>
    <h2 class="vl-how-h">How the labs <em>work</em>.</h2>
    <p class="vl-how-sub">Every lab is a real working simulator — not a video, not a slideshow. You change inputs and the physics, chemistry, or algorithm recomputes live in your browser. Nothing to install. Here is the loop.</p>
    <div class="vl-steps">
      <div class="vl-step">
        <span class="vl-step-n">1</span>
        <p class="vl-step-h">Open a lab</p>
        <p class="vl-step-p">Pick any simulator below. It loads instantly and starts running — no sign-up, no plugin, no wait.</p>
      </div>
      <div class="vl-step">
        <span class="vl-step-n">2</span>
        <p class="vl-step-h">Move the sliders</p>
        <p class="vl-step-p">Every control on the left panel changes a real parameter. Drag a slider and watch the canvas respond in real time.</p>
      </div>
      <div class="vl-step">
        <span class="vl-step-n">3</span>
        <p class="vl-step-h">Read the live readouts</p>
        <p class="vl-step-p">The metrics panel shows what is actually happening — energy, period, pH, eigenvalues, loss — computed from the live state, not faked.</p>
      </div>
      <div class="vl-step">
        <span class="vl-step-n">4</span>
        <p class="vl-step-h">Experiment &amp; reset</p>
        <p class="vl-step-p">Try extreme values, hit Pause to freeze, Reset to start over. You cannot break anything — that is the point of a lab.</p>
      </div>
    </div>

    <div class="vl-startcard">
      <div class="lt">
        <p class="vl-startcard-eye">Start here · the easiest first lab</p>
        <p class="vl-startcard-h">The pendulum.</p>
        <p class="vl-startcard-p">Drag <strong>Length</strong> and watch the period change. Add <strong>Damping</strong> to see it slow and stop. Switch to <strong>Driven</strong> mode and turn up the drive to see resonance and chaos. The energy and phase plots update with every swing. Five minutes here and every other lab makes sense.</p>
      </div>
      <a href="/aquintutor/labs/pendulum" class="vl-startcard-btn">Open the pendulum &rarr;</a>
    </div>
  </div>

  {disciplines.map((d) => (
  <div>
  <div class="vl-section-head" style="padding-top:30px;">
    <h2>{d.name}</h2>
    <span class="count">{d.items.length} {d.items.length === 1 ? 'lab' : 'labs'}</span>
  </div>
  <div class="vl-grid">
    {d.items.map((l) => (
      <a href={'/aquintutor/labs/' + l.slug} class="vl-card">
        <div class="vl-card-top">
          <div class="vl-icon" style={'background:' + l.color + ';'}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              {l.icon === 'activity' && <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>}
              {l.icon === 'send' && <><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></>}
              {l.icon === 'eye' && <><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></>}
              {l.icon === 'zap' && <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>}
              {l.icon === 'cpu' && <><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="2" x2="9" y2="4"/><line x1="15" y1="2" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="22"/><line x1="15" y1="20" x2="15" y2="22"/><line x1="20" y1="9" x2="22" y2="9"/><line x1="20" y1="15" x2="22" y2="15"/><line x1="2" y1="9" x2="4" y2="9"/><line x1="2" y1="15" x2="4" y2="15"/></>}
              {l.icon === 'droplet' && <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>}
              {l.icon === 'grid' && <><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></>}
              {l.icon === 'package' && <><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></>}
              {l.icon === 'shuffle' && <><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></>}
              {l.icon === 'wind' && <path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/>}
              {l.icon === 'trending-up' && <><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></>}
              {l.icon === 'box' && <><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></>}
              {l.icon === 'bar-chart-2' && <><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></>}
              {l.icon === 'map' && <><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></>}
              {l.icon === 'share-2' && <><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></>}
              {l.icon === 'radio' && <><circle cx="12" cy="12" r="2"/><path d="M16.24 7.76a6 6 0 0 1 0 8.49m-8.48-.01a6 6 0 0 1 0-8.49m11.31-2.82a10 10 0 0 1 0 14.14m-14.14 0a10 10 0 0 1 0-14.14"/></>}
            </svg>
          </div>
          <div style="flex:1;min-width:0;">
            <p class="vl-card-cat">{l.cat}<span class="vl-live">Live</span></p>
            <p class="vl-card-title">{l.label}</p>
          </div>
        </div>
        <p class="vl-card-desc" style="margin-top:8px;">{l.desc}</p>
      </a>
    ))}
  </div>
  </div>
  ))}

  <div class="vl-section-head" style="padding-top:36px;">
    <h2>Advanced <em>labs</em> &amp; tools.</h2>
    <span class="count">{EXTERNAL_LABS.length} live</span>
  </div>
  <div class="vl-grid">
    {EXTERNAL_LABS.map((l) => (
      <a href={l.slug} class="vl-card">
        <div class="vl-card-top">
          <div class="vl-icon" style={'background:' + l.color + ';'}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              {l.icon === 'cpu' && <><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/></>}
              {l.icon === 'server' && <><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></>}
              {l.icon === 'terminal' && <><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></>}
              {l.icon === 'book-open' && <><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></>}
              {l.icon === 'image' && <><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></>}
            </svg>
          </div>
          <div style="flex:1;min-width:0;">
            <p class="vl-card-cat">{l.cat}<span class="vl-live">Live</span></p>
            <p class="vl-card-title">{l.label}</p>
          </div>
        </div>
        <p class="vl-card-desc" style="margin-top:8px;">{l.desc}</p>
      </a>
    ))}
  </div>

</main>
</BaseLayout>
