  /* ============================================================
     STATE
     ============================================================ */
  var curExp = 0, curTab = 'aim';
  var animHandle = null;

  function stopAnim() { if (animHandle) { cancelAnimationFrame(animHandle); animHandle = null; } }

  /* ============================================================
     RENDER:  tabs
     ============================================================ */
  function renderTab() {
    stopAnim();
    var p = $('panel');
    p.innerHTML = '';
    var e = EXPS[curExp];
    if (curTab === 'aim') renderAim(p, e);
    else if (curTab === 'theory') renderTheory(p, e);
    else if (curTab === 'procedure') renderProc(p, e);
    else if (curTab === 'simulation') renderSim(p, e);
    else if (curTab === 'assessment') renderQuiz(p, e);
    else if (curTab === 'references') renderRefs(p, e);
  }

  function renderAim(p, e) {
    p.appendChild(el('h2', null, 'Aim'));
    var d = el('div', { 'class': 'dsp-prose' });
    d.appendChild(el('p', null, e.aim));
    p.appendChild(d);
  }
  function renderTheory(p, e) {
    p.appendChild(el('h2', null, 'Theory'));
    var d = el('div', { 'class': 'dsp-prose' });
    e.theory.forEach(function (t) { d.appendChild(el('p', null, t)); });
    d.appendChild(el('h4', null, 'Governing equations'));
    e.eqs.forEach(function (q) { d.appendChild(el('div', { 'class': 'dsp-eq' }, q)); });
    p.appendChild(d);
  }
  function renderProc(p, e) {
    p.appendChild(el('h2', null, 'Procedure'));
    var d = el('div', { 'class': 'dsp-prose' });
    var ol = el('ol');
    e.proc.forEach(function (s) { ol.appendChild(el('li', null, s)); });
    d.appendChild(ol);
    p.appendChild(d);
  }
  function renderRefs(p, e) {
    p.appendChild(el('h2', null, 'References'));
    var d = el('div', { 'class': 'dsp-prose' });
    var ul = el('ul');
    e.refs.forEach(function (r) { ul.appendChild(el('li', null, r)); });
    d.appendChild(ul);
    p.appendChild(d);
  }

