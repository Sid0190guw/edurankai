---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Digital Signal Processing · Virtual Labs · AquinTutor" description="A vlabs-format virtual lab for Digital Signal Processing: DFT/FFT spectra, FIR windowed filter design, Butterworth IIR via bilinear transform, windowing trade-offs, the z-plane, sampling and aliasing, plus convolution and correlation. Every readout is computed live from real DSP algorithms.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; }
  .dsp-wrap { max-width: 1500px; margin: 0 auto; padding: 16px 3vw 70px; }
  .dsp-top { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 12px; margin-bottom: 16px; }
  .dsp-back { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #67e8f9; text-decoration: none; letter-spacing: 0.08em; }
  .dsp-eye { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 10px 0 0; }
  .dsp-title { font-family: 'Cormorant Garamond', 'Fraunces', serif; font-size: 36px; font-weight: 600; margin: 4px 0 0; letter-spacing: -0.02em; color: #f4f4fb; }
  .dsp-title em { color: #67e8f9; font-style: italic; font-weight: 500; }
  .dsp-lede { color: #9aa6b6; font-size: 13.5px; line-height: 1.55; max-width: 940px; margin: 9px 0 0; }

  .dsp-grid { display: grid; grid-template-columns: 248px minmax(0,1fr); gap: 18px; align-items: start; margin-top: 18px; }
  @media (max-width: 1000px) { .dsp-grid { grid-template-columns: 1fr; } }

  /* sidebar */
  .dsp-side { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 12px; position: sticky; top: 12px; }
  .dsp-side h3 { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9.5px; letter-spacing: 0.16em; text-transform: uppercase; color: #a78bfa; font-weight: 700; margin: 2px 4px 10px; }
  .dsp-exp { display: block; width: 100%; text-align: left; box-sizing: border-box; background: #0a0a0c; border: 1px solid #2a2a35; color: #cfd6da; border-radius: 8px; padding: 9px 11px; margin-bottom: 7px; cursor: pointer; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; line-height: 1.35; letter-spacing: 0.02em; transition: border-color .12s, background .12s; }
  .dsp-exp:hover { border-color: #67e8f9; }
  .dsp-exp.active { background: #14222a; border-color: #67e8f9; color: #d7fbff; }
  .dsp-exp .num { color: #67e8f9; font-weight: 700; }
  .dsp-exp .sub { display: block; color: #6f7a88; font-size: 9px; margin-top: 2px; letter-spacing: 0.04em; }

  /* main panel */
  .dsp-main { min-width: 0; }
  .dsp-tabs { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 14px; }
  .dsp-tab { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 7px 12px; border-radius: 7px; border: 1px solid #2a2a35; background: #11131a; color: #9aa6b6; cursor: pointer; }
  .dsp-tab.active { background: #67e8f9; color: #04161b; border-color: #67e8f9; }

  .dsp-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 18px; }
  .dsp-panel h2 { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 600; margin: 0 0 6px; color: #f4f4fb; }
  .dsp-panel h4 { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #a78bfa; margin: 14px 0 6px; }
  .dsp-prose { color: #b8c2cf; font-size: 13.5px; line-height: 1.7; }
  .dsp-prose p { margin: 0 0 9px; }
  .dsp-eq { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12.5px; color: #86efac; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; padding: 10px 12px; margin: 8px 0; line-height: 1.7; overflow-x: auto; white-space: pre-wrap; }
  .dsp-prose ol { margin: 6px 0; padding-left: 20px; line-height: 1.75; }
  .dsp-prose ul { margin: 6px 0; padding-left: 20px; line-height: 1.75; }
  .dsp-prose code { font-family: 'Geist Mono', ui-monospace, monospace; color: #fbbf24; font-size: 12px; }
  .dsp-prose a { color: #67e8f9; }

  /* simulation layout */
  .sim-grid { display: grid; grid-template-columns: 256px minmax(0,1fr); gap: 16px; align-items: start; }
  @media (max-width: 900px) { .sim-grid { grid-template-columns: 1fr; } }
  .sim-ctrl { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 10px; padding: 13px; }
  .sim-ctrl h4 { margin-top: 0; }
  .ctl { margin-bottom: 12px; }
  .ctl label { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; display: flex; justify-content: space-between; margin-bottom: 4px; }
  .ctl label span { color: #67e8f9; }
  .ctl input[type=range] { width: 100%; accent-color: #67e8f9; }
  .ctl select, .ctl input[type=text], .ctl input[type=number] { width: 100%; box-sizing: border-box; background: #11131a; border: 1px solid #2a2a35; color: #e8e8ee; padding: 7px 9px; border-radius: 6px; font-size: 12px; font-family: 'Geist Mono', ui-monospace, monospace; }
  .ctl-check { display: flex; align-items: center; gap: 8px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #cfd6da; padding: 4px 0; }
  .ctl-check input { accent-color: #a78bfa; }
  .sim-canvas { width: 100%; display: block; background: #07070a; border: 1px solid #2a2a35; border-radius: 10px; }
  .sim-cap { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; color: #6f7a88; margin: 4px 2px 12px; letter-spacing: 0.04em; }
  .sim-cap b { color: #67e8f9; }
  .sim-readout { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-top: 10px; }
  .ro { background: #11131a; border: 1px solid #2a2a35; border-radius: 8px; padding: 7px 9px; }
  .ro .k { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 8.5px; letter-spacing: 0.08em; text-transform: uppercase; color: #6f7a88; }
  .ro .v { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 14px; font-weight: 700; color: #fbbf24; margin-top: 2px; }
  .sim-btn { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 8px 13px; border-radius: 7px; border: 1px solid #2a2a35; background: #11131a; color: #cfd6da; cursor: pointer; margin: 2px 4px 2px 0; }
  .sim-btn.primary { background: #67e8f9; color: #04161b; border-color: #67e8f9; }
  .sim-btn.purple { background: #a78bfa; color: #14091f; border-color: #a78bfa; }

  /* self assessment */
  .quiz-q { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 10px; padding: 14px; margin-bottom: 12px; }
  .quiz-q .qt { font-size: 13.5px; color: #e8e8ee; line-height: 1.5; margin-bottom: 9px; }
  .quiz-q .qt b { color: #67e8f9; }
  .quiz-opt { display: block; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12px; color: #cfd6da; padding: 7px 10px; border: 1px solid #2a2a35; border-radius: 7px; margin-bottom: 6px; cursor: pointer; }
  .quiz-opt:hover { border-color: #a78bfa; }
  .quiz-opt input { margin-right: 8px; accent-color: #a78bfa; }
  .quiz-opt.correct { border-color: #86efac; background: #0e1a12; color: #c9f7d6; }
  .quiz-opt.wrong { border-color: #fca5a5; background: #1a0e0e; color: #f7c9c9; }
  .quiz-exp { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; line-height: 1.55; color: #9aa6b6; margin-top: 6px; display: none; }
  .quiz-exp.show { display: block; }
  .quiz-exp b { color: #86efac; }
  .quiz-exp.bad b { color: #fca5a5; }

  .tabpane { display: none; }
  .tabpane.active { display: block; }
  .hidden { display: none !important; }
</style>

<main class="dsp-wrap">
  <div class="dsp-top">
    <div>
      <a class="dsp-back" href="/aquintutor/labs">&larr; Virtual Labs</a>
      <p class="dsp-eye">Signals &amp; Systems &middot; Virtual Labs</p>
      <h1 class="dsp-title">Digital Signal <em>Processing</em></h1>
      <a href="/aquintutor/labs/filter-designer" style="display:inline-flex;align-items:center;gap:8px;margin:6px 0 4px;background:linear-gradient(90deg,rgba(51,207,230,0.18),rgba(51,207,230,0.04));border:1px solid #33cfe6;border-radius:99px;padding:7px 16px;text-decoration:none;color:#7af0ff;font-family:'Geist Mono',monospace;font-size:12px;font-weight:700;letter-spacing:0.04em;">POSTGRADUATE FLAGSHIP · Z-plane filter designer &rarr;</a>
      <p class="dsp-lede">
        Seven instruments, every readout computed live from genuine DSP routines: a radix-2 FFT, windowed FIR design,
        a bilinear-transform Butterworth IIR, the discrete-time sampling theorem, the z-plane geometric evaluation,
        and direct convolution / correlation. Nothing here is faked &mdash; the spectra you see are the transforms of the
        sequences you build.
      </p>
    </div>
  </div>

  <div class="dsp-grid">
    <aside class="dsp-side" id="sidebar">
      <h3>Experiments</h3>
      <button class="dsp-exp active" data-exp="0"><span class="num">01.</span> DFT / FFT spectrum<span class="sub">magnitude + phase</span></button>
      <button class="dsp-exp" data-exp="1"><span class="num">02.</span> FIR design by windowing<span class="sub">LP / HP / BP filters</span></button>
      <button class="dsp-exp" data-exp="2"><span class="num">03.</span> Butterworth IIR<span class="sub">bilinear transform</span></button>
      <button class="dsp-exp" data-exp="3"><span class="num">04.</span> Window trade-offs<span class="sub">main-lobe vs side-lobe</span></button>
      <button class="dsp-exp" data-exp="4"><span class="num">05.</span> The z-plane<span class="sub">poles, zeros, response</span></button>
      <button class="dsp-exp" data-exp="5"><span class="num">06.</span> Sampling &amp; aliasing<span class="sub">reconstruction</span></button>
      <button class="dsp-exp" data-exp="6"><span class="num">07.</span> Convolution / correlation<span class="sub">linear, cross</span></button>
    </aside>

    <section class="dsp-main">
      <div class="dsp-tabs" id="tabbar">
        <button class="dsp-tab active" data-tab="aim">Aim</button>
        <button class="dsp-tab" data-tab="theory">Theory</button>
        <button class="dsp-tab" data-tab="procedure">Procedure</button>
        <button class="dsp-tab" data-tab="simulation">Simulation</button>
        <button class="dsp-tab" data-tab="assessment">Self-Assessment</button>
        <button class="dsp-tab" data-tab="references">References</button>
      </div>
      <div class="dsp-panel" id="panel"><!-- filled by script --></div>
    </section>
  </div>
</main>

<script is:inline>
(function () {
  "use strict";
  function $(id) { return document.getElementById(id); }
  function el(tag, attrs, html) {
    var e = document.createElement(tag);
    if (attrs) for (var k in attrs) e.setAttribute(k, attrs[k]);
    if (html != null) e.innerHTML = html;
    return e;
  }
  var TAU = Math.PI * 2;

  /* ============================================================
     CORE DSP MATH  (hand-rolled, no libraries)
     ============================================================ */

  // Radix-2 iterative FFT (Cooley-Tukey). re/im modified in place. dir = +1 forward, -1 inverse.
  function fft(re, im, dir) {
    var n = re.length, i, j, k, m;
    // bit reversal permutation
    for (i = 1, j = 0; i < n; i++) {
      var bit = n >> 1;
      for (; j & bit; bit >>= 1) j ^= bit;
      j ^= bit;
      if (i < j) {
        var tr = re[i]; re[i] = re[j]; re[j] = tr;
        var ti = im[i]; im[i] = im[j]; im[j] = ti;
      }
    }
    for (var len = 2; len <= n; len <<= 1) {
      var ang = dir * TAU / len;
      var wr = Math.cos(ang), wi = Math.sin(ang);
      for (i = 0; i < n; i += len) {
        var cr = 1, ci = 0;
        for (k = 0; k < len / 2; k++) {
          var a = i + k, b = i + k + len / 2;
          var xr = re[b] * cr - im[b] * ci;
          var xi = re[b] * ci + im[b] * cr;
          re[b] = re[a] - xr; im[b] = im[a] - xi;
          re[a] += xr; im[a] += xi;
          var ncr = cr * wr - ci * wi;
          ci = cr * wi + ci * wr; cr = ncr;
        }
      }
    }
    if (dir === -1) for (i = 0; i < n; i++) { re[i] /= n; im[i] /= n; }
    return [re, im];
  }

  // Direct DFT (genuine O(N^2)) — used so we can also handle non-power-of-2 N and verify FFT.
  function dft(x) {
    var N = x.length, Re = new Array(N), Im = new Array(N);
    for (var k = 0; k < N; k++) {
      var sr = 0, si = 0;
      for (var n = 0; n < N; n++) {
        var a = -TAU * k * n / N;
        sr += x[n] * Math.cos(a);
        si += x[n] * Math.sin(a);
      }
      Re[k] = sr; Im[k] = si;
    }
    return { re: Re, im: Im };
  }

  function nextPow2(n) { var p = 1; while (p < n) p <<= 1; return p; }

  // Window functions, length M (n = 0..M-1)
  function windowVal(type, n, M) {
    var d = M - 1;
    if (d <= 0) return 1;
    var r = n / d;
    switch (type) {
      case 'rect': return 1;
      case 'hamming': return 0.54 - 0.46 * Math.cos(TAU * r);
      case 'hanning': return 0.5 - 0.5 * Math.cos(TAU * r);
      case 'blackman': return 0.42 - 0.5 * Math.cos(TAU * r) + 0.08 * Math.cos(2 * TAU * r);
      default: return 1;
    }
  }

  // Ideal FIR impulse responses (sinc-based), length M (odd preferred), cutoff(s) normalized 0..1 of pi (i.e. fraction of Nyquist)
  // wc in radians = fc * pi
  function firIdeal(kind, M, fc1, fc2) {
    var h = new Array(M);
    var mid = (M - 1) / 2;
    var wc1 = fc1 * Math.PI, wc2 = fc2 * Math.PI;
    for (var n = 0; n < M; n++) {
      var k = n - mid, v;
      if (kind === 'lp') {
        v = (k === 0) ? wc1 / Math.PI : Math.sin(wc1 * k) / (Math.PI * k);
      } else if (kind === 'hp') {
        v = (k === 0) ? 1 - wc1 / Math.PI : -Math.sin(wc1 * k) / (Math.PI * k);
      } else { // bp
        v = (k === 0) ? (wc2 - wc1) / Math.PI : (Math.sin(wc2 * k) - Math.sin(wc1 * k)) / (Math.PI * k);
      }
      h[n] = v;
    }
    return h;
  }

  // Apply window to impulse response
  function applyWindow(h, type) {
    var M = h.length, out = new Array(M);
    for (var n = 0; n < M; n++) out[n] = h[n] * windowVal(type, n, M);
    return out;
  }

  // Frequency response of an FIR/transfer numerator b (and optional denominator a) evaluated at omega in [0,pi]
  // H(e^jw) = sum b[n] e^{-jwn} / sum a[n] e^{-jwn}
  function freqResponse(b, a, npts) {
    a = a || [1];
    var mag = new Array(npts), ph = new Array(npts), w = new Array(npts);
    for (var i = 0; i < npts; i++) {
      var om = Math.PI * i / (npts - 1);
      var nr = 0, ni = 0, dr = 0, di = 0;
      for (var n = 0; n < b.length; n++) { nr += b[n] * Math.cos(om * n); ni -= b[n] * Math.sin(om * n); }
      for (var m = 0; m < a.length; m++) { dr += a[m] * Math.cos(om * m); di -= a[m] * Math.sin(om * m); }
      // complex divide
      var den = dr * dr + di * di;
      var hr = (nr * dr + ni * di) / den;
      var hi = (ni * dr - nr * di) / den;
      mag[i] = Math.sqrt(hr * hr + hi * hi);
      ph[i] = Math.atan2(hi, hr);
      w[i] = om;
    }
    return { mag: mag, ph: ph, w: w };
  }

  // Butterworth analog prototype poles (normalized, wc=1), then bilinear transform to digital
  // Returns digital {b, a, zeros, poles} for a low-pass with order N and digital cutoff fcN (fraction of Nyquist, 0..1)
  function butterworthLP(N, fcN) {
    // pre-warp: analog cutoff Wc such that 2*atan(...)... ; T = 2 -> wc_digital = fcN*pi
    var wd = fcN * Math.PI;
    var T = 2;
    var Wc = (2 / T) * Math.tan(wd / 2); // pre-warped analog cutoff
    // analog poles of normalized Butterworth, scaled by Wc
    var apRe = [], apIm = [];
    for (var k = 0; k < N; k++) {
      var theta = Math.PI * (2 * k + 1) / (2 * N) + Math.PI / 2;
      apRe.push(Wc * Math.cos(theta));
      apIm.push(Wc * Math.sin(theta));
    }
    // bilinear: z = (1 + s*T/2)/(1 - s*T/2)  =>  s -> (2/T)(z-1)/(z+1)
    // map each analog pole s_p to digital pole z_p = (1 + s_p T/2)/(1 - s_p T/2)
    var dpRe = [], dpIm = [];
    for (var i = 0; i < N; i++) {
      var sr = apRe[i] * T / 2, si = apIm[i] * T / 2;
      var numr = 1 + sr, numi = si;
      var denr = 1 - sr, deni = -si;
      var dd = denr * denr + deni * deni;
      dpRe.push((numr * denr + numi * deni) / dd);
      dpIm.push((numi * denr - numr * deni) / dd);
    }
    // analog has N zeros at infinity; bilinear maps s=inf to z=-1 => N zeros at z=-1
    // Build denominator polynomial a(z) from digital poles
    var a = polyFromRoots(dpRe, dpIm);
    // Build numerator from N zeros at z=-1
    var zRe = [], zIm = [];
    for (var j = 0; j < N; j++) { zRe.push(-1); zIm.push(0); }
    var bRaw = polyFromRoots(zRe, zIm);
    // Normalize for unity gain at DC (z=1 => omega=0)
    var hNum = 0, hDen = 0;
    for (var p = 0; p < bRaw.length; p++) hNum += bRaw[p];
    for (var q = 0; q < a.length; q++) hDen += a[q];
    var g = hDen / hNum;
    var b = bRaw.map(function (c) { return c * g; });
    return { b: b, a: a, poles: { re: dpRe, im: dpIm }, zeros: { re: zRe, im: zIm } };
  }

  // Build real polynomial coefficients from complex roots (conjugate pairs assumed for real output;
  // we keep complex arithmetic and the imaginary residue is ~0).
  function polyFromRoots(rootsRe, rootsIm) {
    var cr = [1], ci = [0]; // start poly = 1
    for (var i = 0; i < rootsRe.length; i++) {
      // multiply current poly by (x - root)
      var nr = new Array(cr.length + 1), ni = new Array(cr.length + 1);
      for (var j = 0; j < nr.length; j++) { nr[j] = 0; ni[j] = 0; }
      for (var k = 0; k < cr.length; k++) {
        // x term
        nr[k] += cr[k]; ni[k] += ci[k];
        // -root term
        nr[k + 1] -= cr[k] * rootsRe[i] - ci[k] * rootsIm[i];
        ni[k + 1] -= cr[k] * rootsIm[i] + ci[k] * rootsRe[i];
      }
      cr = nr; ci = ni;
    }
    return cr.map(function (v) { return v; }); // real parts (imag ~ 0 for conjugate-paired roots)
  }

  // Linear convolution
  function convolve(x, h) {
    var n = x.length, m = h.length, y = new Array(n + m - 1);
    for (var i = 0; i < y.length; i++) {
      var s = 0;
      for (var k = 0; k < n; k++) { var j = i - k; if (j >= 0 && j < m) s += x[k] * h[j]; }
      y[i] = s;
    }
    return y;
  }
  // Cross-correlation r_xy[l] = sum x[n] y[n-l]
  function crossCorr(x, y) {
    var n = x.length, m = y.length, L = n + m - 1, out = new Array(L), lags = new Array(L);
    var lagStart = -(m - 1);
    for (var li = 0; li < L; li++) {
      var lag = lagStart + li, s = 0;
      for (var k = 0; k < n; k++) { var j = k - lag; if (j >= 0 && j < m) s += x[k] * y[j]; }
      out[li] = s; lags[li] = lag;
    }
    return { r: out, lags: lags };
  }

  /* ============================================================
     CANVAS PLOTTING HELPERS
     ============================================================ */
  function makeCanvas(w, h, cls) {
    var c = el('canvas', { width: w * 2, height: h * 2, 'class': cls || 'sim-canvas' });
    c.style.height = h + 'px';
    var ctx = c.getContext('2d');
    ctx.scale(2, 2); // crisp on HiDPI
    return { c: c, ctx: ctx, w: w, h: h };
  }
  function clearC(ctx, w, h, bg) { ctx.fillStyle = bg || '#07070a'; ctx.fillRect(0, 0, w, h); }
  function axes(ctx, x0, y0, w, h, opts) {
    opts = opts || {};
    ctx.strokeStyle = '#1c1c26'; ctx.lineWidth = 1;
    // grid
    var gx = opts.gx || 8, gy = opts.gy || 4, i;
    for (i = 0; i <= gx; i++) { var gpx = x0 + w * i / gx; ctx.beginPath(); ctx.moveTo(gpx, y0); ctx.lineTo(gpx, y0 + h); ctx.stroke(); }
    for (i = 0; i <= gy; i++) { var gpy = y0 + h * i / gy; ctx.beginPath(); ctx.moveTo(x0, gpy); ctx.lineTo(x0 + w, gpy); ctx.stroke(); }
    ctx.strokeStyle = '#3a3a48'; ctx.lineWidth = 1.2;
    if (opts.zeroY != null) { ctx.beginPath(); ctx.moveTo(x0, opts.zeroY); ctx.lineTo(x0 + w, opts.zeroY); ctx.stroke(); }
  }
  function label(ctx, x, y, txt, color, sz, align) {
    ctx.fillStyle = color || '#6f7a88';
    ctx.font = (sz || 9) + "px 'Geist Mono', monospace";
    ctx.textAlign = align || 'left';
    ctx.fillText(txt, x, y);
    ctx.textAlign = 'left';
  }
  // line plot of array y over x range, auto or fixed y-range
  function plotLine(ctx, x0, y0, w, h, ys, ymin, ymax, color, lw) {
    ctx.strokeStyle = color; ctx.lineWidth = lw || 1.6;
    ctx.beginPath();
    var n = ys.length;
    for (var i = 0; i < n; i++) {
      var px = x0 + w * i / (n - 1);
      var py = y0 + h * (1 - (ys[i] - ymin) / (ymax - ymin));
      if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
    }
    ctx.stroke();
  }
  // stem plot
  function plotStem(ctx, x0, y0, w, h, ys, ymin, ymax, color, baseY) {
    var n = ys.length;
    ctx.strokeStyle = color; ctx.fillStyle = color; ctx.lineWidth = 1.4;
    for (var i = 0; i < n; i++) {
      var px = x0 + w * (i + 0.5) / n;
      var py = y0 + h * (1 - (ys[i] - ymin) / (ymax - ymin));
      ctx.beginPath(); ctx.moveTo(px, baseY); ctx.lineTo(px, py); ctx.stroke();
      ctx.beginPath(); ctx.arc(px, py, 2.2, 0, TAU); ctx.fill();
    }
  }

