---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Acid-base titration lab (graduate level). Instead of piecewise pH formulas,
// the pH at every point is found by solving the exact charge (proton) balance
// numerically — C_B + [H+] = [OH-] + C_A·(average anion charge) — which holds
// through the buffer region, the equivalence point and the dilute limit alike.
// Supports polyprotic acids (mono/di/tri) via their stepwise Ka's, so carbonic
// and phosphoric acid show multiple equivalence points and buffer plateaus. It
// plots the titration curve, its first derivative dpH/dV (equivalence detection)
// and the buffer capacity β = dC_B/dpH (maxima at pH = pKa). No libraries.
---
<BaseLayout title="Titration & Buffer Equilibria · Virtual Labs · AquinTutor" description="Graduate acid-base chemistry: exact numerical pH from the charge balance, polyprotic acids (mono/di/tri) with multiple equivalence points, the first-derivative equivalence detection, and buffer capacity beta with maxima at pH=pKa. Built from scratch.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1340px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:16px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:300px minmax(0,1fr); gap:18px; } @media(max-width:960px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:15px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 11px; }
  .lb-row{ display:grid; gap:8px; } .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.08em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; }
  .lb-row label span{ color:#5ee7ff; } .lb-row input[type=range]{ width:100%; accent-color:#5ee7ff; } select{ width:100%; background:#080a12; border:1px solid #1e2740; color:#fff; padding:8px 10px; border-radius:6px; font-size:12px; font-family:inherit; }
  .lb-seg{ display:flex; gap:4px; } .lb-seg button{ flex:1; background:#0b1020; border:1px solid #26314f; color:#8ea0be; border-radius:7px; padding:6px 4px; font-family:'Geist Mono',monospace; font-size:10px; cursor:pointer; } .lb-seg button.on{ background:rgba(94,231,255,0.14); color:#5ee7ff; border-color:#3a6b86; }
  .lb-btn{ background:linear-gradient(180deg,#7af0ff,#33cfe6); color:#04161b; padding:9px 15px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:11px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; }
  .lb-stage{ display:grid; grid-template-columns:210px 1fr; gap:14px; } @media(max-width:640px){ .lb-stage{ grid-template-columns:1fr; } }
  .lb-cv{ width:100%; border-radius:16px; border:1px solid #1e2740; box-shadow:inset 0 0 40px rgba(0,0,0,0.5); display:block; }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11px; padding:4px 0; border-bottom:1px solid #141a2c; }
  .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#5ee7ff; font-weight:700; text-align:right; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">Chemistry · Ionic Equilibria</p>
      <h1 class="lb-title">Titration &amp; <em>buffers</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;"><button id="runBtn" class="lb-btn">Auto-titrate</button></div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Analyte</h3>
        <select id="acid">
          <option value="hcl">Strong acid (HCl)</option>
          <option value="acetic" selected>Acetic acid · pKa 4.76</option>
          <option value="carbonic">Carbonic (diprotic) · 6.35, 10.33</option>
          <option value="phosphoric">Phosphoric (triprotic) · 2.15, 7.20, 12.35</option>
        </select>
        <p id="pkaShow" class="" style="font-family:'Geist Mono',monospace;font-size:10px;color:#7e8aa3;margin:9px 0 0;"></p>
      </div>
      <div class="lb-panel"><h3>Concentrations</h3><div class="lb-row">
        <label>Acid C_A (M) <span id="caV">0.10</span></label><input id="ca" type="range" min="0.01" max="0.5" step="0.01" value="0.1"/>
        <label>Acid volume (mL) <span id="vaV">25</span></label><input id="va" type="range" min="10" max="50" step="1" value="25"/>
        <label>Base C_B (M) <span id="cbV">0.10</span></label><input id="cb" type="range" min="0.01" max="0.5" step="0.01" value="0.1"/>
        <label>Base added (mL) <span id="vbV">0</span></label><input id="vb" type="range" min="0" max="120" step="0.2" value="0"/>
      </div></div>
      <div class="lb-panel"><h3>Second plot</h3>
        <div class="lb-seg" id="plotSeg"><button data-p="deriv" class="on">dpH/dV</button><button data-p="buffer">Buffer β</button></div>
      </div>
      <div class="lb-panel"><h3>Readout</h3>
        <div class="lb-metric"><span class="lb-metric-l">pH</span><span class="lb-metric-v" id="mPh">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Equivalence pts (mL)</span><span class="lb-metric-v" id="mVeq">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Region</span><span class="lb-metric-v" id="mReg" style="color:#a78bfa;">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Buffer β (M/pH)</span><span class="lb-metric-v" id="mBeta">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Indicator (pH 8–10)</span><span class="lb-metric-v" id="mInd">—</span></div>
      </div>
    </aside>
    <section><div class="lb-stage">
      <canvas id="beaker" class="lb-cv" width="210" height="440"></canvas>
      <div style="display:flex;flex-direction:column;gap:12px;">
        <canvas id="curve" class="lb-cv" width="660" height="280"></canvas>
        <canvas id="deriv" class="lb-cv" width="660" height="150"></canvas>
      </div>
    </div></section>
  </div>
</main>
<script is:inline>
(function(){
  function v(id){ return parseFloat(document.getElementById(id).value); }
  function setTxt(id,t){ var e=document.getElementById(id); if(e) e.textContent=t; }
  var Kw=1e-14;
  var ACIDS={ hcl:{pKa:[-7],name:'HCl'}, acetic:{pKa:[4.76],name:'acetic'}, carbonic:{pKa:[6.35,10.33],name:'carbonic'}, phosphoric:{pKa:[2.15,7.20,12.35],name:'phosphoric'} };
  var plotB='deriv';
  function acid(){ return ACIDS[document.getElementById('acid').value]; }
  function sync(){ setTxt('caV',v('ca').toFixed(2)); setTxt('vaV',v('va').toFixed(0)); setTxt('cbV',v('cb').toFixed(2)); setTxt('vbV',v('vb').toFixed(1));
    var a=acid(); setTxt('pkaShow', a.pKa[0]<-1?'Fully dissociated (n=1).':('pKa: '+a.pKa.map(function(x){return x.toFixed(2);}).join(', ')+'  ·  n='+a.pKa.length)); }
  document.querySelectorAll('input,select').forEach(function(e){ e.addEventListener('input',sync); e.addEventListener('change',sync); }); sync();
  document.querySelectorAll('#plotSeg button').forEach(function(b){ b.addEventListener('click',function(){ document.querySelectorAll('#plotSeg button').forEach(function(x){x.classList.remove('on');}); b.classList.add('on'); plotB=b.getAttribute('data-p'); }); });

  // average anion charge (mean protons lost) for a polyprotic acid at proton conc h
  function zBar(h, Ka){ var terms=[1], prod=1; for(var i=0;i<Ka.length;i++){ prod*=Ka[i]; terms.push(prod/Math.pow(h,i+1)); }
    var D=0,num=0; for(var j=0;j<terms.length;j++){ D+=terms[j]; num+=j*terms[j]; } return num/D; }
  // exact pH by solving charge balance: C_B + h - Kw/h - C_A*zBar = 0  (bisection on pH)
  function pHat(Vb){ var a=acid(); var Ka=a.pKa.map(function(p){return Math.pow(10,-p);});
    var Va=v('va')/1000, Vt=Va+Vb/1000; var CA=v('ca')*Va/Vt, CB=v('cb')*(Vb/1000)/Vt;
    function g(pH){ var h=Math.pow(10,-pH); return CB + h - Kw/h - CA*zBar(h,Ka); }
    var lo=-1, hi=15, glo=g(lo); for(var i=0;i<70;i++){ var mid=(lo+hi)/2, gm=g(mid); if(glo*gm<=0){ hi=mid; } else { lo=mid; glo=gm; } }
    return Math.max(0,Math.min(14,(lo+hi)/2)); }
  function eqVols(){ var a=acid(); var moleA=v('ca')*v('va'); var out=[]; for(var j=1;j<=a.pKa.length;j++) out.push(j*moleA/v('cb')); return out; }

  function hidpi(cv){ var r=cv.getBoundingClientRect(), dp=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w; cv.width=Math.round(w*dp); cv.height=Math.round(h*dp); var ctx=cv.getContext('2d'); ctx.setTransform(dp,0,0,dp,0,0); return {ctx:ctx,w:w,h:h}; }
  function indColor(ph){ if(ph<8.0) return null; if(ph<9.6) return 'rgba(236,72,153,'+((ph-8)/1.6*0.7+0.15).toFixed(2)+')'; return 'rgba(219,39,119,0.85)'; }
  function drawBeaker(ph,Vb){ var cv=document.getElementById('beaker'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h; ctx.fillStyle='#080b16'; ctx.fillRect(0,0,W,H);
    ctx.fillStyle='#141a2c'; ctx.fillRect(W/2-8,10,16,150); ctx.strokeStyle='#2a3450'; ctx.strokeRect(W/2-8,10,16,150);
    var bfill=Math.max(0,1-Vb/120); ctx.fillStyle='rgba(94,231,255,0.5)'; ctx.fillRect(W/2-6,12+(146*(1-bfill)),12,146*bfill);
    ctx.fillStyle='#7af0ff'; ctx.beginPath(); ctx.arc(W/2,168,2.5,0,7); ctx.fill();
    var bx=W*0.16, bw=W*0.68, by=H*0.5, bh=H*0.42; ctx.strokeStyle='#3a4763'; ctx.lineWidth=3; ctx.beginPath(); ctx.moveTo(bx,by); ctx.lineTo(bx,by+bh); ctx.lineTo(bx+bw,by+bh); ctx.lineTo(bx+bw,by); ctx.stroke();
    var col=indColor(ph), base=col?col:'rgba(120,160,220,0.35)'; var lg=ctx.createLinearGradient(0,by+bh*0.2,0,by+bh); lg.addColorStop(0,base); lg.addColorStop(1,'rgba(0,0,0,0.2)'); ctx.fillStyle=lg; ctx.fillRect(bx+2,by+bh*0.2,bw-4,bh*0.8-2);
    if(col){ ctx.save(); ctx.shadowColor='#ec4899'; ctx.shadowBlur=18; ctx.fillStyle=col; ctx.fillRect(bx+2,by+bh*0.2,bw-4,bh*0.8-2); ctx.restore(); }
    ctx.fillStyle='#5ee7ff'; ctx.font="700 18px 'Geist Mono',monospace"; ctx.fillText('pH '+ph.toFixed(2), bx+6, by+bh*0.5); }

  function drawCurve(){ var cv=document.getElementById('curve'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h; ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H);
    var padL=32,padB=22; var eqs=eqVols(); var Vmax=Math.max(40, eqs[eqs.length-1]*1.6);
    function X(vb){ return padL+vb/Vmax*(W-padL-12); } function Y(ph){ return H-padB-ph/14*(H-padB-10); }
    ctx.strokeStyle='rgba(94,231,255,0.07)'; ctx.fillStyle='#5f7597'; ctx.font="9px 'Geist Mono',monospace";
    for(var p=0;p<=14;p+=2){ ctx.beginPath(); ctx.moveTo(padL,Y(p)); ctx.lineTo(W-12,Y(p)); ctx.stroke(); ctx.fillText(p,4,Y(p)+3); }
    // equivalence lines + half-eq (pKa) lines
    var a=acid(); eqs.forEach(function(ve,idx){ ctx.strokeStyle='rgba(167,139,250,0.55)'; ctx.setLineDash([4,4]); ctx.beginPath(); ctx.moveTo(X(ve),12); ctx.lineTo(X(ve),H-padB); ctx.stroke(); ctx.setLineDash([]); ctx.fillStyle='#a78bfa'; ctx.fillText('eq'+(eqs.length>1?(idx+1):''),X(ve)-6,20);
      if(a.pKa[idx]>-1){ var vh=(idx+0.5)*(v('ca')*v('va'))/v('cb'); ctx.strokeStyle='rgba(52,211,153,0.35)'; ctx.setLineDash([2,4]); ctx.beginPath(); ctx.moveTo(X(vh),Y(a.pKa[idx])); ctx.lineTo(X(vh),H-padB); ctx.stroke(); ctx.setLineDash([]); ctx.fillStyle='#34d399'; ctx.fillText('pKa'+(a.pKa.length>1?(idx+1):''),X(vh)-8,Y(a.pKa[idx])-4); } });
    // curve
    ctx.save(); ctx.shadowColor='#5ee7ff'; ctx.shadowBlur=8; ctx.strokeStyle='#5ee7ff'; ctx.lineWidth=2; ctx.beginPath(); for(var i=0;i<=340;i++){ var vb=Vmax*i/340, ph=pHat(vb); i?ctx.lineTo(X(vb),Y(ph)):ctx.moveTo(X(vb),Y(ph)); } ctx.stroke(); ctx.restore();
    var vb=v('vb'), ph=pHat(vb); ctx.save(); ctx.shadowColor='#fbbf24'; ctx.shadowBlur=13; ctx.fillStyle='#fbbf24'; ctx.beginPath(); ctx.arc(X(vb),Y(ph),5,0,7); ctx.fill(); ctx.restore();
    return ph; }

  function drawDeriv(){ var cv=document.getElementById('deriv'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h; ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H);
    var padL=32,padB=16; var eqs=eqVols(); var Vmax=Math.max(40, eqs[eqs.length-1]*1.6); function X(vb){ return padL+vb/Vmax*(W-padL-12); }
    var N=300, dv=Vmax/N, vals=[];
    if(plotB==='deriv'){ for(var i=1;i<N;i++){ var vb=i*dv; vals.push([vb, (pHat(vb+dv)-pHat(vb-dv))/(2*dv)]); }
      var mx=Math.max.apply(null,vals.map(function(x){return x[1];}))||1; function Y(d){ return H-padB-(d/mx)*(H-padB-8); }
      ctx.save(); ctx.shadowColor='#f472b6'; ctx.shadowBlur=6; ctx.strokeStyle='#f472b6'; ctx.lineWidth=1.7; ctx.beginPath(); vals.forEach(function(p,i){ i?ctx.lineTo(X(p[0]),Y(p[1])):ctx.moveTo(X(p[0]),Y(p[1])); }); ctx.stroke(); ctx.restore();
      ctx.fillStyle='#8ea0be'; ctx.font="9px 'Geist Mono',monospace"; ctx.fillText('dpH/dV — peaks locate equivalence',padL,12);
    } else { // buffer capacity beta = dC_B/dpH ; approximate as (dC_B/dV)/(dpH/dV) = (Cb/Vt)/(dpH/dV)
      for(var i=1;i<N;i++){ var vb=i*dv; var dph=(pHat(vb+dv)-pHat(vb-dv))/(2*dv); var Vt=v('va')/1000+vb/1000; var dCb=v('cb')/1000/Vt; // per mL -> approximate slope
        var beta = Math.abs(dph)>1e-6 ? Math.abs((v('cb')/Vt)*(dv/1000))/Math.abs(dph)/(dv/1000) : 0; vals.push([vb, beta]); }
      var mx=Math.max.apply(null,vals.map(function(x){return x[1];}))||1; function Yb(d){ return H-padB-(d/mx)*(H-padB-8); }
      ctx.save(); ctx.shadowColor='#34d399'; ctx.shadowBlur=6; ctx.strokeStyle='#34d399'; ctx.lineWidth=1.7; ctx.beginPath(); vals.forEach(function(p,i){ i?ctx.lineTo(X(p[0]),Yb(p[1])):ctx.moveTo(X(p[0]),Yb(p[1])); }); ctx.stroke(); ctx.restore();
      ctx.fillStyle='#8ea0be'; ctx.font="9px 'Geist Mono',monospace"; ctx.fillText('buffer capacity β — maxima at pH = pKa',padL,12);
    }
    eqs.forEach(function(ve){ ctx.strokeStyle='rgba(167,139,250,0.4)'; ctx.setLineDash([3,3]); ctx.beginPath(); ctx.moveTo(X(ve),8); ctx.lineTo(X(ve),H-padB); ctx.stroke(); ctx.setLineDash([]); });
    var cvb=v('vb'); ctx.strokeStyle='rgba(251,191,36,0.6)'; ctx.beginPath(); ctx.moveTo(X(cvb),8); ctx.lineTo(X(cvb),H-padB); ctx.stroke();
  }

  function metrics(ph){ var eqs=eqVols(); setTxt('mVeq', eqs.map(function(x){return x.toFixed(1);}).join(', '));
    var vb=v('vb'); var dv=0.1; var beta = Math.abs((pHat(vb+dv)-pHat(vb-dv))/(2*dv))>1e-6 ? (v('cb')/(v('va')/1000+vb/1000))/Math.abs((pHat(vb+dv)-pHat(vb-dv))/(2*dv))/1000 : 0;
    setTxt('mBeta', (beta*1000).toFixed(3));
    var nearEq=eqs.some(function(e){ return Math.abs(vb-e)<0.5; });
    var reg = nearEq?'Equivalence':(vb<eqs[0]-0.3? (acid().pKa[0]<-1?'Acidic':'Buffer region') : 'Base excess'); setTxt('mReg',reg);
    setTxt('mInd', ph<8.0?'colourless':(ph<9.6?'pink':'magenta')); setTxt('mPh',ph.toFixed(2)); }

  var running=false;
  document.getElementById('runBtn').addEventListener('click',function(){ running=!running; this.textContent=running?'Pause':'Auto-titrate'; if(running && v('vb')>=119) document.getElementById('vb').value=0; });
  function loop(){ if(running){ var nx=Math.min(120,v('vb')+0.3); document.getElementById('vb').value=nx; sync(); if(nx>=120){ running=false; document.getElementById('runBtn').textContent='Auto-titrate'; } }
    var ph=drawCurve(); drawDeriv(); drawBeaker(ph,v('vb')); metrics(ph); requestAnimationFrame(loop); }
  requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
