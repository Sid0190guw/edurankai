---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Acid-base titration lab — real equilibrium pH for strong- and weak-acid vs
// strong-base titrations, a burette+beaker with phenolphthalein colour change,
// and the live pH curve with the equivalence point. High-DPI canvas, no libs.
---
<BaseLayout title="Titration lab · Virtual Labs · AquinTutor" description="Titrate a strong or weak acid with strong base — watch pH, the equivalence point, and the phenolphthalein colour change build in real time.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1320px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:18px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; }
  .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:290px minmax(0,1fr); gap:18px; }
  @media(max-width:900px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:16px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 12px; }
  .lb-row{ display:grid; gap:9px; }
  .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.1em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; }
  .lb-row label span{ color:#5ee7ff; } .lb-row input[type=range]{ width:100%; accent-color:#5ee7ff; }
  .lb-row select{ width:100%; background:#080a12; border:1px solid #1e2740; color:#fff; padding:8px 10px; border-radius:6px; font-size:12px; font-family:inherit; }
  .lb-btn{ background:linear-gradient(180deg,#7af0ff,#33cfe6); color:#04161b; padding:9px 16px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:11px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; }
  .lb-stage{ display:grid; grid-template-columns:240px 1fr; gap:14px; }
  @media(max-width:640px){ .lb-stage{ grid-template-columns:1fr; } }
  .lb-cv{ width:100%; border-radius:16px; border:1px solid #1e2740; box-shadow:inset 0 0 40px rgba(0,0,0,0.5); display:block; }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11.5px; padding:5px 0; border-bottom:1px solid #141a2c; }
  .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#5ee7ff; font-weight:700; text-align:right; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">Chemistry · Equilibrium</p>
      <h1 class="lb-title">Acid-base <em>titration</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;"><button id="runBtn" class="lb-btn">Auto-titrate</button></div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Analyte &amp; titrant</h3><div class="lb-row">
        <label>Acid</label><select id="acid"><option value="strong" selected>Strong acid (HCl)</option><option value="weak">Weak acid (Ka)</option></select>
        <label>pKa (weak only) <span id="pkaV">4.8</span></label><input id="pka" type="range" min="2" max="9" step="0.1" value="4.8"/>
        <label>Acid conc (M) <span id="caV">0.10</span></label><input id="ca" type="range" min="0.02" max="0.5" step="0.01" value="0.1"/>
        <label>Acid volume (mL) <span id="vaV">25</span></label><input id="va" type="range" min="10" max="50" step="1" value="25"/>
        <label>Base conc (M) <span id="cbV">0.10</span></label><input id="cb" type="range" min="0.02" max="0.5" step="0.01" value="0.1"/>
        <label>Base added (mL) <span id="vbV">0</span></label><input id="vb" type="range" min="0" max="80" step="0.2" value="0"/>
      </div></div>
      <div class="lb-panel"><h3>Readout</h3>
        <div class="lb-metric"><span class="lb-metric-l">pH</span><span class="lb-metric-v" id="mPh">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Equivalence (mL)</span><span class="lb-metric-v" id="mVeq">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Region</span><span class="lb-metric-v" id="mReg">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Indicator</span><span class="lb-metric-v" id="mInd">—</span></div>
      </div>
    </aside>
    <section><div class="lb-stage">
      <canvas id="beaker" class="lb-cv" width="240" height="420"></canvas>
      <canvas id="curve" class="lb-cv" width="640" height="420"></canvas>
    </div></section>
  </div>
</main>
<script is:inline>
(function(){
  function v(id){ return parseFloat(document.getElementById(id).value); }
  function log10(x){ return Math.log(x)/Math.LN10; }
  function sync(){ document.getElementById('pkaV').textContent=v('pka').toFixed(1); document.getElementById('caV').textContent=v('ca').toFixed(2); document.getElementById('vaV').textContent=v('va').toFixed(0); document.getElementById('cbV').textContent=v('cb').toFixed(2); document.getElementById('vbV').textContent=v('vb').toFixed(1); }
  document.querySelectorAll('input,select').forEach(function(e){ e.addEventListener('input',sync); e.addEventListener('change',sync); }); sync();

  function pH(Vb){ var weak=document.getElementById('acid').value==='weak'; var Ca=v('ca'), Va=v('va')/1000, Cb=v('cb'), Ka=Math.pow(10,-v('pka'));
    var nA=Ca*Va, nB=Cb*(Vb/1000), Vt=Va+Vb/1000, ph;
    if(!weak){ if(nA>nB) ph=-log10((nA-nB)/Vt); else if(nB>nA) ph=14+log10((nB-nA)/Vt); else ph=7; }
    else { var pKa=v('pka'); if(nB<=1e-12){ ph=0.5*(pKa - log10(Ca)); }
      else if(nB<nA-1e-12){ ph=pKa + log10(nB/(nA-nB)); }
      else if(Math.abs(nB-nA)<=1e-12+nA*1e-6){ var C=nA/Vt, Kb=1e-14/Ka; ph=14+log10(Math.sqrt(Kb*C)); }
      else { ph=14+log10((nB-nA)/Vt); } }
    return Math.max(0,Math.min(14,ph)); }

  function indColor(ph){ if(ph<8.0) return null; if(ph<9.6) return 'rgba(236,72,153,'+((ph-8)/1.6*0.7+0.15).toFixed(2)+')'; return 'rgba(219,39,119,0.85)'; }
  function hidpi(cv){ var r=cv.getBoundingClientRect(), d=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w; cv.width=Math.round(w*d); cv.height=Math.round(h*d); var ctx=cv.getContext('2d'); ctx.setTransform(d,0,0,d,0,0); return {ctx:ctx,w:w,h:h}; }

  function drawBeaker(ph,Vb){ var cv=document.getElementById('beaker'), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h;
    ctx.fillStyle='#080b16'; ctx.fillRect(0,0,W,H);
    // burette
    ctx.fillStyle='#141a2c'; ctx.fillRect(W/2-8,10,16,150); ctx.strokeStyle='#2a3450'; ctx.strokeRect(W/2-8,10,16,150);
    var bfill=Math.max(0,1-Vb/80); ctx.fillStyle='rgba(94,231,255,0.5)'; ctx.fillRect(W/2-6,12+ (146*(1-bfill)),12,146*bfill);
    // drip
    ctx.fillStyle='#7af0ff'; ctx.beginPath(); ctx.arc(W/2,168,2.5,0,7); ctx.fill();
    // beaker
    var bx=W*0.18, bw=W*0.64, by=H*0.5, bh=H*0.42; ctx.strokeStyle='#3a4763'; ctx.lineWidth=3; ctx.beginPath(); ctx.moveTo(bx,by); ctx.lineTo(bx,by+bh); ctx.lineTo(bx+bw,by+bh); ctx.lineTo(bx+bw,by); ctx.stroke();
    // liquid
    var col=indColor(ph); var base=col?col:'rgba(120,160,220,0.35)';
    var lg=ctx.createLinearGradient(0,by+bh*0.2,0,by+bh); lg.addColorStop(0,base); lg.addColorStop(1,'rgba(0,0,0,0.2)'); ctx.fillStyle=lg; ctx.fillRect(bx+2,by+bh*0.2,bw-4,bh*0.8-2);
    if(col){ ctx.save(); ctx.shadowColor='#ec4899'; ctx.shadowBlur=20; ctx.fillStyle=col; ctx.fillRect(bx+2,by+bh*0.2,bw-4,bh*0.8-2); ctx.restore(); }
    ctx.fillStyle='#5ee7ff'; ctx.font="700 20px 'Geist Mono',monospace"; ctx.fillText('pH '+ph.toFixed(2), bx+8, by+bh*0.5);
  }
  function drawCurve(){ var cv=document.getElementById('curve'), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h;
    ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H); var padL=40,padB=30;
    var Veq=v('ca')*v('va')/v('cb'); var Vmax=Math.max(80,Veq*2);
    function X(vb){ return padL + vb/Vmax*(W-padL-14); } function Y(ph){ return H-padB - ph/14*(H-padB-14); }
    ctx.strokeStyle='rgba(94,231,255,0.07)'; ctx.fillStyle='#5f7597'; ctx.font="10px 'Geist Mono',monospace";
    for(var p=0;p<=14;p+=2){ ctx.beginPath(); ctx.moveTo(padL,Y(p)); ctx.lineTo(W-14,Y(p)); ctx.stroke(); ctx.fillText(p,6,Y(p)+3); }
    for(var vv=0;vv<=Vmax;vv+= (Vmax>120?40:20)){ ctx.fillText(vv.toFixed(0),X(vv)-6,H-14); }
    // curve
    ctx.save(); ctx.shadowColor='#5ee7ff'; ctx.shadowBlur=8; ctx.strokeStyle='#5ee7ff'; ctx.lineWidth=2; ctx.beginPath();
    for(var i=0;i<=300;i++){ var vb=Vmax*i/300, ph=pH(vb); i?ctx.lineTo(X(vb),Y(ph)):ctx.moveTo(X(vb),Y(ph)); } ctx.stroke(); ctx.restore();
    // equivalence line
    ctx.strokeStyle='rgba(167,139,250,0.6)'; ctx.setLineDash([4,4]); ctx.beginPath(); ctx.moveTo(X(Veq),16); ctx.lineTo(X(Veq),H-padB); ctx.stroke(); ctx.setLineDash([]);
    ctx.fillStyle='#a78bfa'; ctx.fillText('eq '+Veq.toFixed(1)+' mL', X(Veq)+4, 24);
    // current point
    var vb=v('vb'), ph=pH(vb); ctx.save(); ctx.shadowColor='#fbbf24'; ctx.shadowBlur=14; ctx.fillStyle='#fbbf24'; ctx.beginPath(); ctx.arc(X(vb),Y(ph),5,0,7); ctx.fill(); ctx.restore();
    document.getElementById('mVeq').textContent=Veq.toFixed(1);
    var reg = vb<Veq-0.2 ? (document.getElementById('acid').value==='weak'?'Buffer region':'Acidic') : (Math.abs(vb-Veq)<=0.4?'Equivalence':'Base excess');
    document.getElementById('mReg').textContent=reg;
    document.getElementById('mInd').textContent = ph<8.0?'Colourless':(ph<9.6?'Pink':'Magenta');
    document.getElementById('mPh').textContent=ph.toFixed(2);
    return ph;
  }
  var running=false;
  document.getElementById('runBtn').addEventListener('click',function(){ running=!running; this.textContent=running?'Pause':'Auto-titrate'; if(running && v('vb')>=79.5) document.getElementById('vb').value=0; });
  function loop(){ if(running){ var nx=Math.min(80,v('vb')+0.25); document.getElementById('vb').value=nx; sync(); if(nx>=80){ running=false; document.getElementById('runBtn').textContent='Auto-titrate'; } }
    var ph=drawCurve(); drawBeaker(ph, v('vb')); requestAnimationFrame(loop); }
  requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
