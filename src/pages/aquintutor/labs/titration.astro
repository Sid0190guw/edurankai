---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Acid-Base Titration Lab" description="Real numerical pH simulation with mass/charge balance and bisection solver">
<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; font-family: 'Inter', system-ui, sans-serif; }
  .wrap { max-width: 1320px; margin: 0 auto; padding: 40px 28px 80px; }
  .eyebrow { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #a04330; font-weight: 700; }
  h1 { font-family: 'Cormorant Garamond', serif; font-size: 34px; font-weight: 600; letter-spacing: -0.02em; margin: 6px 0 6px; }
  h1 em { color: #67e8f9; font-style: italic; font-weight: 500; }
  .lede { color: #9ca3af; max-width: 760px; font-size: 14px; line-height: 1.6; margin-bottom: 28px; }
  .grid { display: grid; grid-template-columns: 320px 1fr 320px; gap: 16px; }
  @media (max-width: 1100px) { .grid { grid-template-columns: 1fr; } }
  .panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 16px; }
  .panel h3 { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #a04330; font-weight: 700; margin: 0 0 12px; }
  .row { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-bottom: 10px; }
  .row label { font-size: 11px; color: #cfd6da; font-family: 'Geist Mono', monospace; letter-spacing: 0.04em; }
  .row .val { font-family: 'Geist Mono', monospace; font-size: 11px; color: #67e8f9; min-width: 64px; text-align: right; }
  select, input[type="number"], input[type="text"] {
    background: #0a0a0c; border: 1px solid #2a2a35; color: #fff; padding: 7px 10px; border-radius: 5px;
    font-family: 'Geist Mono', monospace; font-size: 11px; width: 100%;
  }
  input[type="range"] { width: 100%; accent-color: #a04330; }
  .btn { background: #67e8f9; color: #04161b; padding: 9px 16px; border-radius: 6px; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; border: none; cursor: pointer; }
  .btn:hover { background: #a3eef9; }
  .btn.ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
  .btn.ghost:hover { border-color: #a04330; color: #fff; }
  .btn.red { background: #a04330; color: #fff; }
  .btn.red:hover { background: #c25640; }
  .btn-row { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 8px; }
  .btn-row .btn { flex: 1; padding: 8px 10px; font-size: 10px; }
  canvas { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 10px; display: block; }
  .metrics { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 10px; }
  .metric { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 6px; padding: 8px 10px; }
  .metric .k { font-family: 'Geist Mono', monospace; font-size: 9px; color: #6b7280; letter-spacing: 0.12em; text-transform: uppercase; }
  .metric .v { font-family: 'Geist Mono', monospace; font-size: 16px; color: #67e8f9; font-weight: 700; margin-top: 2px; }
  .metric .v.red { color: #ff8060; }
  .glass { display: flex; gap: 16px; align-items: flex-start; justify-content: center; padding: 12px 0; }
  .legend { font-family: 'Geist Mono', monospace; font-size: 10px; color: #9ca3af; line-height: 1.6; margin-top: 8px; }
  .legend .dot { display: inline-block; width: 9px; height: 9px; border-radius: 50%; vertical-align: middle; margin-right: 5px; }
  .badge { display: inline-block; background: #1f2937; color: #67e8f9; padding: 2px 8px; border-radius: 999px; font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.06em; }
  .info { font-family: 'Geist Mono', monospace; font-size: 10px; color: #9ca3af; line-height: 1.7; }
  .info b { color: #cfd6da; }
  .divider { height: 1px; background: #2a2a35; margin: 14px 0; }
  .alert { background: #2a1810; border: 1px solid #a04330; color: #ffb59f; padding: 8px 10px; border-radius: 6px; font-family: 'Geist Mono', monospace; font-size: 10px; margin-top: 8px; display: none; }
  .alert.show { display: block; }
</style>
<main class="wrap">
  <div class="eyebrow">VIRTUAL LAB &middot; CHEMISTRY</div>
  <h1>Acid-Base <em>titration</em> simulator</h1>
  <p class="lede">Real numerical pH solver via bisection on mass-balance and charge-balance equations. Supports monoprotic, diprotic, and triprotic systems, weak/strong combinations, and four standard pH indicators with proper transition ranges. No empirical fits &mdash; every point on the curve comes from charge neutrality.</p>

  <div class="grid">
    <!-- LEFT: controls -->
    <div class="panel">
      <h3>Analyte (in beaker)</h3>
      <div class="row"><label>Species</label></div>
      <select id="analyte">
        <option value="HCl">HCl &mdash; strong acid</option>
        <option value="CH3COOH" selected>CH&#8323;COOH &mdash; weak acid (pKa 4.76)</option>
        <option value="NH4Cl">NH&#8324;Cl &mdash; weak conj. acid (pKa 9.25)</option>
        <option value="H2CO3">H&#8322;CO&#8323; &mdash; diprotic (6.35, 10.33)</option>
        <option value="H3PO4">H&#8323;PO&#8324; &mdash; triprotic (2.15, 7.20, 12.35)</option>
        <option value="NH3">NH&#8323; &mdash; weak base (pKb 4.75)</option>
      </select>
      <div class="row" style="margin-top:12px"><label>Concentration</label><span class="val" id="caV">0.100 M</span></div>
      <input id="ca" type="range" min="-3" max="0" step="0.01" value="-1" />
      <div class="row" style="margin-top:12px"><label>Volume</label><span class="val" id="vaV">25.0 mL</span></div>
      <input id="va" type="range" min="10" max="100" step="1" value="25" />

      <div class="divider"></div>

      <h3>Titrant (from burette)</h3>
      <div class="row"><label>Species</label></div>
      <select id="titrant">
        <option value="NaOH" selected>NaOH &mdash; strong base</option>
        <option value="KOH">KOH &mdash; strong base</option>
        <option value="HCl">HCl &mdash; strong acid</option>
        <option value="NH3">NH&#8323; &mdash; weak base</option>
      </select>
      <div class="row" style="margin-top:12px"><label>Concentration</label><span class="val" id="ctV">0.100 M</span></div>
      <input id="ct" type="range" min="-3" max="0" step="0.01" value="-1" />

      <div class="divider"></div>

      <h3>Indicator</h3>
      <select id="ind">
        <option value="phenolphthalein" selected>Phenolphthalein (8.2&ndash;10.0)</option>
        <option value="methylorange">Methyl orange (3.1&ndash;4.4)</option>
        <option value="bromothymol">Bromothymol blue (6.0&ndash;7.6)</option>
        <option value="methylred">Methyl red (4.4&ndash;6.2)</option>
      </select>

      <div class="divider"></div>

      <h3>Titrate</h3>
      <div class="btn-row">
        <button class="btn ghost" data-add="0.1">+0.1 mL</button>
        <button class="btn ghost" data-add="0.5">+0.5 mL</button>
        <button class="btn ghost" data-add="1">+1 mL</button>
        <button class="btn ghost" data-add="5">+5 mL</button>
      </div>
      <div class="btn-row">
        <button class="btn red" id="autoBtn">Auto-titrate</button>
        <button class="btn ghost" id="resetBtn">Reset</button>
      </div>
      <div class="alert" id="warn">Burette empty. Reset to continue.</div>
    </div>

    <!-- CENTER: visualisation -->
    <div>
      <div class="panel">
        <h3>Apparatus</h3>
        <div class="glass">
          <svg id="apparatus" viewBox="0 0 360 360" width="360" height="360" aria-hidden="true">
            <!-- burette body -->
            <rect x="160" y="10" width="40" height="180" fill="#0a0a0c" stroke="#2a2a35" stroke-width="2" rx="3"/>
            <!-- burette tip -->
            <polygon points="170,190 190,190 184,210 176,210" fill="#0a0a0c" stroke="#2a2a35" stroke-width="2"/>
            <line x1="180" y1="210" x2="180" y2="222" stroke="#2a2a35" stroke-width="2"/>
            <!-- burette graduations -->
            <g stroke="#3a3a48" stroke-width="1">
              <line x1="160" y1="40" x2="170" y2="40"/><line x1="160" y1="70" x2="170" y2="70"/>
              <line x1="160" y1="100" x2="170" y2="100"/><line x1="160" y1="130" x2="170" y2="130"/>
              <line x1="160" y1="160" x2="170" y2="160"/>
            </g>
            <!-- burette liquid -->
            <rect id="buretteLiquid" x="162" y="12" width="36" height="176" fill="#67e8f9" opacity="0.55"/>
            <!-- drop -->
            <circle id="drop" cx="180" cy="218" r="0" fill="#67e8f9" opacity="0.8"/>
            <!-- beaker -->
            <path d="M90,240 L90,340 Q90,348 98,348 L262,348 Q270,348 270,340 L270,240 Z"
                  fill="none" stroke="#3a3a48" stroke-width="2.5"/>
            <!-- beaker liquid -->
            <clipPath id="beakerClip">
              <path d="M92,242 L92,338 Q92,346 100,346 L260,346 Q268,346 268,338 L268,242 Z"/>
            </clipPath>
            <rect id="beakerLiquid" x="92" y="270" width="176" height="76" fill="#f5e6d3" clip-path="url(#beakerClip)"/>
            <!-- beaker label tick lines -->
            <g stroke="#3a3a48" stroke-width="1">
              <line x1="90" y1="260" x2="100" y2="260"/><line x1="90" y1="290" x2="100" y2="290"/>
              <line x1="90" y1="320" x2="100" y2="320"/>
            </g>
            <!-- stir bar -->
            <ellipse id="stirbar" cx="180" cy="340" rx="22" ry="3" fill="#cfd6da" opacity="0.5"/>
          </svg>
          <div style="flex: 1;">
            <div class="metrics" style="grid-template-columns: 1fr;">
              <div class="metric"><div class="k">pH</div><div class="v" id="phOut">7.00</div></div>
              <div class="metric"><div class="k">Volume added</div><div class="v" id="volOut">0.00 mL</div></div>
              <div class="metric"><div class="k">Equivalence vol.</div><div class="v" id="eqOut">&mdash;</div></div>
              <div class="metric"><div class="k">Equiv. progress</div><div class="v" id="progOut">0%</div></div>
            </div>
            <div class="legend">
              <span class="dot" id="indDot" style="background:#f5e6d3"></span>
              <span id="indState">Indicator: colourless</span>
            </div>
          </div>
        </div>
      </div>

      <div class="panel" style="margin-top:16px">
        <h3>Titration curve &mdash; pH vs volume added</h3>
        <canvas id="curve" width="900" height="380"></canvas>
        <div class="legend" style="display:flex; gap:18px; flex-wrap:wrap; margin-top:10px">
          <span><span class="dot" style="background:#67e8f9"></span>pH curve</span>
          <span><span class="dot" style="background:#a04330"></span>Current point</span>
          <span><span class="dot" style="background:#fde68a"></span>Equivalence point</span>
          <span><span class="dot" style="background:#86efac"></span>Half-equivalence (pKa)</span>
        </div>
      </div>
    </div>

    <!-- RIGHT: chemistry / theory -->
    <div class="panel">
      <h3>Live chemistry</h3>
      <div class="info" id="chemBlock">
        Choose an analyte and titrant, then add titrant.
      </div>

      <div class="divider"></div>
      <h3>Indicator scale</h3>
      <canvas id="indScale" width="280" height="80"></canvas>

      <div class="divider"></div>
      <h3>Method</h3>
      <div class="info">
        <b>Solver.</b> At each volume, the unknown [H&#8314;] satisfies charge neutrality. We bisect on log&#8321;&#8320;[H&#8314;] over &minus;14 to 0, with Ka equilibria evaluated at each guess. K<sub>w</sub> = 10<sup>&minus;14</sup>. Pure water gives pH 7.000.
        <br><br>
        <b>Polyprotic.</b> H&#8322;CO&#8323; and H&#8323;PO&#8324; solve the full alpha-fractionation: &alpha;&#8320;, &alpha;&#8321;, &alpha;&#8322;, &alpha;&#8323; from K<sub>a1</sub>&hellip;K<sub>a3</sub>; total charge from acid + base + Na&#8314;/K&#8314; + Cl&#8315; balances H&#8314; and OH&#8315;.
      </div>
    </div>
  </div>
</main>

<script is:inline>
(function () {
  'use strict';

  // ===================== CHEMISTRY DATA =====================
  // pKa values; for bases we store the conjugate acid pKa
  const SPECIES = {
    HCl:      { kind: 'strongAcid', n: 1 },
    NaOH:     { kind: 'strongBase', n: 1 },
    KOH:      { kind: 'strongBase', n: 1 },
    CH3COOH:  { kind: 'weakAcid', pKa: [4.76] },
    NH4Cl:    { kind: 'weakAcid', pKa: [9.25] },       // NH4+ → NH3
    H2CO3:    { kind: 'weakAcid', pKa: [6.35, 10.33] },
    H3PO4:    { kind: 'weakAcid', pKa: [2.15, 7.20, 12.35] },
    NH3:      { kind: 'weakBase', pKa: [9.25] }        // conj. acid NH4+
  };
  const Kw = 1e-14;

  const INDICATORS = {
    phenolphthalein: { lo: 8.2, hi: 10.0, cAcid: '#f5e6d3', cBase: '#d94c8a', label: 'colourless → magenta' },
    methylorange:    { lo: 3.1, hi: 4.4,  cAcid: '#d12c2c', cBase: '#f6c844', label: 'red → yellow' },
    bromothymol:     { lo: 6.0, hi: 7.6,  cAcid: '#f6c844', cBase: '#3a7cd9', label: 'yellow → blue' },
    methylred:       { lo: 4.4, hi: 6.2,  cAcid: '#d12c2c', cBase: '#f6c844', label: 'red → yellow' }
  };

  // ===================== STATE =====================
  const state = {
    analyte: 'CH3COOH',
    titrant: 'NaOH',
    Ca: 0.100,   // M
    Ct: 0.100,   // M
    Va0: 25,     // mL
    Vt: 0,       // mL added so far
    indicator: 'phenolphthalein',
    curve: [],   // [{v, pH}]
    auto: false,
    drop: { y: 218, active: false, t: 0 }
  };

  // ===================== PH SOLVER =====================
  // For a mixture in a beaker, compute [H+] by bisection on charge balance.
  // Variables:
  //   Ca_tot = (Ca * Va0) / (Va0 + Vt)     -- total analyte concentration
  //   Ct_tot = (Ct * Vt)  / (Va0 + Vt)     -- total titrant concentration
  // Strong-acid contribution = +Ct_tot (HCl titrant, dissociates fully) etc.
  // We treat strong bases (Na+, K+) as a fixed positive spectator ion.
  // Weak acids: alpha fractions weighted by deprotonation count give average charge.

  function alphasMono(H, Ka) {
    // HA / A-
    const sum = H + Ka;
    return [H/sum, Ka/sum];
  }
  function alphasDi(H, K1, K2) {
    const d = H*H + H*K1 + K1*K2;
    return [H*H/d, H*K1/d, K1*K2/d];
  }
  function alphasTri(H, K1, K2, K3) {
    const d = H*H*H + H*H*K1 + H*K1*K2 + K1*K2*K3;
    return [H*H*H/d, H*H*K1/d, H*K1*K2/d, K1*K2*K3/d];
  }

  // Returns net charge balance for a guess [H+].
  // Positive ions: H+, Na+/K+/NH4+ from titrant strong base or weak conj acid
  // Negative ions: OH-, Cl- from analyte/titrant strong acid, conjugate base fractions
  function chargeBalance(H) {
    const OH = Kw / H;
    const Vtot = state.Va0 + state.Vt;
    if (Vtot <= 0) return H - OH;
    const Ca_tot = (state.Ca * state.Va0) / Vtot; // mol/L of total analyte
    const Ct_tot = (state.Ct * state.Vt) / Vtot;  // mol/L of total titrant

    let posSpec = 0; // spectator cation concentration (Na+, K+)
    let negSpec = 0; // spectator anion concentration (Cl-)
    let analyteNetCharge = 0; // sum_i (-i) * alpha_i * Ca_tot for an acid HnA
    let titrantNetCharge = 0;

    // ----- ANALYTE -----
    const A = SPECIES[state.analyte];
    if (A.kind === 'strongAcid') {
      // Fully → H+ + Cl-
      negSpec += Ca_tot * A.n;
    } else if (A.kind === 'strongBase') {
      posSpec += Ca_tot * A.n;
    } else if (A.kind === 'weakAcid') {
      const pKa = A.pKa;
      if (pKa.length === 1) {
        const a = alphasMono(H, Math.pow(10, -pKa[0]));
        // HA neutral, A- charge -1
        analyteNetCharge = -1 * a[1] * Ca_tot;
        // If analyte is NH4Cl: spectator Cl-
        if (state.analyte === 'NH4Cl') negSpec += Ca_tot;
        // NH4+ contributes +1 * alpha0
        if (state.analyte === 'NH4Cl') analyteNetCharge = (a[0] * 1 + a[1] * 0) * Ca_tot - 0;
        // Wait — re-derive NH4Cl: it's the conjugate acid form. Total nitrogen Ca_tot.
        // NH4+ fraction = alpha0, NH3 fraction = alpha1. NH4+ charges +1, NH3 charge 0.
        // So NH-form contribution = +alpha0 * Ca_tot. Plus spectator Cl- (already added).
      } else if (pKa.length === 2) {
        const a = alphasDi(H, Math.pow(10, -pKa[0]), Math.pow(10, -pKa[1]));
        // H2A 0, HA- -1, A2- -2
        analyteNetCharge = (-1 * a[1] - 2 * a[2]) * Ca_tot;
      } else {
        const a = alphasTri(H, Math.pow(10, -pKa[0]), Math.pow(10, -pKa[1]), Math.pow(10, -pKa[2]));
        analyteNetCharge = (-1 * a[1] - 2 * a[2] - 3 * a[3]) * Ca_tot;
      }
    } else if (A.kind === 'weakBase') {
      // e.g. NH3. Conjugate acid NH4+ has pKa from list. fraction NH4+ = H/(H+Ka).
      const Ka = Math.pow(10, -A.pKa[0]);
      const a = alphasMono(H, Ka); // a[0]=NH4+, a[1]=NH3
      analyteNetCharge = (+1 * a[0]) * Ca_tot;
    }

    // ----- TITRANT -----
    const T = SPECIES[state.titrant];
    if (T.kind === 'strongBase') {
      posSpec += Ct_tot * T.n;
    } else if (T.kind === 'strongAcid') {
      negSpec += Ct_tot * T.n;
    } else if (T.kind === 'weakBase') {
      const Ka = Math.pow(10, -T.pKa[0]);
      const a = alphasMono(H, Ka);
      titrantNetCharge = (+1 * a[0]) * Ct_tot;
    } else if (T.kind === 'weakAcid') {
      const pKa = T.pKa[0];
      const Ka = Math.pow(10, -pKa);
      const a = alphasMono(H, Ka);
      titrantNetCharge = (-1 * a[1]) * Ct_tot;
    }

    // Charge balance: H+ + posSpec + (positive analyte/titrant contributions) =
    // OH- + negSpec + (negative analyte/titrant abs contributions)
    // analyteNetCharge already signed; same for titrant.
    // Rearranged: H+ - OH- + posSpec - negSpec + (analyte + titrant signed) = 0
    return H - OH + posSpec - negSpec + analyteNetCharge + titrantNetCharge;
  }

  function solvePH() {
    // Bisect over log10[H+] in [-14, 0]
    let lo = -14, hi = 0;
    // ensure bracket
    let fLo = chargeBalance(Math.pow(10, lo));
    let fHi = chargeBalance(Math.pow(10, hi));
    if (fLo * fHi > 0) {
      // No sign change — scan
      let best = lo, bestAbs = Math.abs(fLo);
      for (let x = -14; x <= 0; x += 0.1) {
        const f = Math.abs(chargeBalance(Math.pow(10, x)));
        if (f < bestAbs) { bestAbs = f; best = x; }
      }
      return -best;
    }
    for (let i = 0; i < 80; i++) {
      const mid = 0.5 * (lo + hi);
      const fMid = chargeBalance(Math.pow(10, mid));
      if (fLo * fMid <= 0) { hi = mid; fHi = fMid; } else { lo = mid; fLo = fMid; }
    }
    return -0.5 * (lo + hi);
  }

  // ===================== EQUIVALENCE VOLUME =====================
  function equivalenceVolume() {
    // moles of titratable protons / moles per mL of titrant
    const A = SPECIES[state.analyte];
    let nProtons = 1;
    if (A.kind === 'weakAcid') nProtons = A.pKa.length;
    if (state.analyte === 'NH4Cl') nProtons = 1;
    if (A.kind === 'weakBase') nProtons = 1;
    if (A.kind === 'strongAcid') nProtons = A.n;
    if (A.kind === 'strongBase') nProtons = A.n; // titrating with acid
    const molesA = state.Ca * state.Va0 / 1000 * nProtons;
    const Veq_mL = (molesA * 1000) / state.Ct;
    return Veq_mL;
  }

  // ===================== UI =====================
  const $ = (id) => document.getElementById(id);
  const ca = $('ca'), va = $('va'), ct = $('ct');
  const analyte = $('analyte'), titrant = $('titrant'), ind = $('ind');
  const caV = $('caV'), vaV = $('vaV'), ctV = $('ctV');
  const phOut = $('phOut'), volOut = $('volOut'), eqOut = $('eqOut'), progOut = $('progOut');
  const beakerLiquid = $('beakerLiquid'), buretteLiquid = $('buretteLiquid');
  const indDot = $('indDot'), indState = $('indState');
  const chemBlock = $('chemBlock'), warn = $('warn');
  const curveCanvas = $('curve'), curveCtx = curveCanvas.getContext('2d');
  const indCanvas = $('indScale'), indCtx = indCanvas.getContext('2d');
  const dropEl = $('drop');

  function fmt(x, d) { return Number(x).toFixed(d); }
  function fmtConc(x) { return x >= 0.1 ? fmt(x, 3) + ' M' : x >= 0.01 ? fmt(x, 4) + ' M' : x.toExponential(2) + ' M'; }

  function bindRange(el, out, fmtFn, set) {
    el.addEventListener('input', () => {
      const v = parseFloat(el.value);
      const real = el === va ? v : Math.pow(10, v);
      out.textContent = fmtFn(real);
      set(real);
      recompute(true);
    });
  }
  bindRange(ca, caV, fmtConc, (v) => state.Ca = v);
  bindRange(va, vaV, (v) => fmt(v, 1) + ' mL', (v) => state.Va0 = v);
  bindRange(ct, ctV, fmtConc, (v) => state.Ct = v);

  analyte.addEventListener('change', () => { state.analyte = analyte.value; resetAll(); });
  titrant.addEventListener('change', () => { state.titrant = titrant.value; resetAll(); });
  ind.addEventListener('change', () => { state.indicator = ind.value; recompute(); drawIndScale(); });

  document.querySelectorAll('[data-add]').forEach(b => {
    b.addEventListener('click', () => {
      const dV = parseFloat(b.getAttribute('data-add'));
      addTitrant(dV);
    });
  });

  $('resetBtn').addEventListener('click', resetAll);
  $('autoBtn').addEventListener('click', () => {
    state.auto = !state.auto;
    $('autoBtn').textContent = state.auto ? 'Stop auto' : 'Auto-titrate';
  });

  function addTitrant(dV) {
    const Veq = equivalenceVolume();
    const limit = Math.max(Veq * 3, 100);
    if (state.Vt + dV > limit) { warn.classList.add('show'); return; }
    state.Vt += dV;
    state.drop.active = true; state.drop.t = 0;
    recompute();
  }

  function resetAll() {
    state.Vt = 0;
    state.curve = [];
    state.auto = false;
    $('autoBtn').textContent = 'Auto-titrate';
    warn.classList.remove('show');
    recompute(true);
  }

  // ===================== RECOMPUTE =====================
  function recompute(rebuildCurve) {
    const pH = solvePH();
    // Append point
    if (state.curve.length === 0 || Math.abs(state.curve[state.curve.length-1].v - state.Vt) > 1e-6) {
      state.curve.push({ v: state.Vt, pH: pH });
      state.curve.sort((a,b) => a.v - b.v);
    } else {
      state.curve[state.curve.length-1].pH = pH;
    }
    if (rebuildCurve) {
      // Rebuild full curve by sweeping volumes — keeps the chart smooth after parameter changes
      const Veq = equivalenceVolume();
      const Vmax = Math.max(Veq * 2, state.Vt * 1.1, 5);
      const savedVt = state.Vt;
      const arr = [];
      const N = 220;
      for (let i = 0; i <= N; i++) {
        state.Vt = (i / N) * Vmax;
        arr.push({ v: state.Vt, pH: solvePH() });
      }
      state.Vt = savedVt;
      state.curve = arr;
      // ensure current Vt point exists
      const idx = state.curve.findIndex(p => p.v >= state.Vt);
      if (idx === -1) state.curve.push({ v: state.Vt, pH: pH });
    }
    drawCurve();
    drawIndScale();
    updateReadouts(pH);
    updateBeakerColor(pH);
    updateBuretteLiquid();
    updateChemInfo(pH);
  }

  function updateReadouts(pH) {
    phOut.textContent = fmt(pH, 2);
    volOut.textContent = fmt(state.Vt, 2) + ' mL';
    const Veq = equivalenceVolume();
    eqOut.textContent = fmt(Veq, 2) + ' mL';
    const prog = Math.min(200, (state.Vt / Veq) * 100);
    progOut.textContent = fmt(prog, 0) + '%';
    progOut.className = 'v' + (prog >= 95 && prog <= 105 ? ' red' : '');
  }

  function indicatorColor(pH) {
    const I = INDICATORS[state.indicator];
    let t = (pH - I.lo) / (I.hi - I.lo);
    t = Math.max(0, Math.min(1, t));
    return lerpColor(I.cAcid, I.cBase, t);
  }
  function lerpColor(a, b, t) {
    const ah = parseInt(a.slice(1), 16), bh = parseInt(b.slice(1), 16);
    const ar = (ah>>16)&255, ag = (ah>>8)&255, ab = ah&255;
    const br = (bh>>16)&255, bg = (bh>>8)&255, bb = bh&255;
    const r = Math.round(ar + (br-ar)*t), g = Math.round(ag + (bg-ag)*t), bl = Math.round(ab + (bb-ab)*t);
    return '#' + ((1<<24) + (r<<16) + (g<<8) + bl).toString(16).slice(1);
  }
  function updateBeakerColor(pH) {
    const c = indicatorColor(pH);
    beakerLiquid.setAttribute('fill', c);
    indDot.style.background = c;
    const I = INDICATORS[state.indicator];
    const t = (pH - I.lo) / (I.hi - I.lo);
    let state2 = 'transition';
    if (t <= 0) state2 = 'acid form';
    else if (t >= 1) state2 = 'base form';
    indState.textContent = 'Indicator: ' + state2 + ' (pH ' + fmt(pH,2) + ')';
    // Beaker liquid height grows with volume
    const Vtot = state.Va0 + state.Vt;
    const frac = Math.min(1, Vtot / 120);
    const h = 40 + frac * 60;
    beakerLiquid.setAttribute('y', String(346 - h));
    beakerLiquid.setAttribute('height', String(h));
  }
  function updateBuretteLiquid() {
    // Visual only — burette starts full, drains with Vt up to 50 mL on display
    const drained = Math.min(1, state.Vt / 50);
    const top = 12 + drained * 170;
    buretteLiquid.setAttribute('y', String(top));
    buretteLiquid.setAttribute('height', String(188 - top));
    const T = SPECIES[state.titrant];
    const col = T.kind === 'strongBase' || T.kind === 'weakBase' ? '#67e8f9' : '#ff8060';
    buretteLiquid.setAttribute('fill', col);
  }

  // ===================== CURVE CANVAS =====================
  function drawCurve() {
    const ctx = curveCtx;
    const W = curveCanvas.width, H = curveCanvas.height;
    ctx.fillStyle = '#0a0a0c'; ctx.fillRect(0,0,W,H);
    const pad = { l: 50, r: 20, t: 20, b: 36 };
    const plotW = W - pad.l - pad.r, plotH = H - pad.t - pad.b;

    // x range
    const Veq = equivalenceVolume();
    const Vmax = Math.max(Veq * 2, state.Vt * 1.1, 5);

    // axes / grid
    ctx.strokeStyle = '#1f2937'; ctx.lineWidth = 1;
    ctx.font = "10px 'Geist Mono', monospace"; ctx.fillStyle = '#6b7280';
    for (let pH = 0; pH <= 14; pH += 2) {
      const y = pad.t + plotH * (1 - pH/14);
      ctx.beginPath(); ctx.moveTo(pad.l, y); ctx.lineTo(W - pad.r, y); ctx.stroke();
      ctx.fillText(String(pH), 8, y + 3);
    }
    const xticks = 8;
    for (let i = 0; i <= xticks; i++) {
      const v = (i/xticks) * Vmax;
      const x = pad.l + (v/Vmax) * plotW;
      ctx.beginPath(); ctx.moveTo(x, pad.t); ctx.lineTo(x, H - pad.b); ctx.strokeStyle = '#15181f'; ctx.stroke();
      ctx.fillStyle = '#6b7280';
      ctx.fillText(v.toFixed(1), x - 10, H - pad.b + 14);
    }
    // axis labels
    ctx.save();
    ctx.fillStyle = '#9ca3af';
    ctx.font = "10px 'Geist Mono', monospace";
    ctx.fillText('mL added', W/2 - 20, H - 6);
    ctx.translate(14, H/2); ctx.rotate(-Math.PI/2);
    ctx.fillText('pH', 0, 0);
    ctx.restore();

    // pH 7 reference
    ctx.strokeStyle = '#374151'; ctx.setLineDash([3,4]);
    const y7 = pad.t + plotH * (1 - 7/14);
    ctx.beginPath(); ctx.moveTo(pad.l, y7); ctx.lineTo(W - pad.r, y7); ctx.stroke();
    ctx.setLineDash([]);

    // equivalence vertical
    if (Veq > 0 && Veq <= Vmax) {
      ctx.strokeStyle = '#fde68a'; ctx.setLineDash([2,3]);
      const xeq = pad.l + (Veq/Vmax) * plotW;
      ctx.beginPath(); ctx.moveTo(xeq, pad.t); ctx.lineTo(xeq, H - pad.b); ctx.stroke();
      ctx.setLineDash([]);
      // half-equivalence (pKa) markers
      const A = SPECIES[state.analyte];
      if (A.kind === 'weakAcid' && A.pKa) {
        A.pKa.forEach((pKa, k) => {
          const vHalf = (k + 0.5) * Veq / A.pKa.length;
          if (vHalf > 0 && vHalf < Vmax) {
            ctx.strokeStyle = '#86efac'; ctx.setLineDash([1,3]);
            const x = pad.l + (vHalf/Vmax) * plotW;
            ctx.beginPath(); ctx.moveTo(x, pad.t); ctx.lineTo(x, H - pad.b); ctx.stroke();
            ctx.setLineDash([]);
          }
        });
      }
    }

    // curve
    if (state.curve.length > 1) {
      ctx.strokeStyle = '#67e8f9'; ctx.lineWidth = 2;
      ctx.beginPath();
      state.curve.forEach((p, i) => {
        const x = pad.l + Math.min(1, p.v / Vmax) * plotW;
        const y = pad.t + plotH * (1 - p.pH / 14);
        if (i === 0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
      });
      ctx.stroke();
    }

    // current point
    const curPH = solvePH();
    const cx = pad.l + Math.min(1, state.Vt / Vmax) * plotW;
    const cy = pad.t + plotH * (1 - curPH / 14);
    ctx.fillStyle = '#a04330';
    ctx.beginPath(); ctx.arc(cx, cy, 5, 0, Math.PI*2); ctx.fill();
    ctx.strokeStyle = '#fff'; ctx.lineWidth = 1.5; ctx.stroke();
  }

  // ===================== INDICATOR SCALE =====================
  function drawIndScale() {
    const ctx = indCtx;
    const W = indCanvas.width, H = indCanvas.height;
    ctx.fillStyle = '#0a0a0c'; ctx.fillRect(0,0,W,H);
    const pad = 20;
    const barY = 18, barH = 24;
    const I = INDICATORS[state.indicator];
    // gradient strip across pH 0..14
    for (let x = 0; x < W - pad*2; x++) {
      const pH = (x / (W - pad*2)) * 14;
      ctx.fillStyle = (function(){
        let t = (pH - I.lo) / (I.hi - I.lo);
        t = Math.max(0, Math.min(1, t));
        return lerpColor(I.cAcid, I.cBase, t);
      })();
      ctx.fillRect(pad + x, barY, 1, barH);
    }
    // ticks
    ctx.strokeStyle = '#3a3a48'; ctx.lineWidth = 1;
    ctx.font = "9px 'Geist Mono', monospace"; ctx.fillStyle = '#9ca3af';
    for (let p = 0; p <= 14; p += 2) {
      const x = pad + (p/14) * (W - pad*2);
      ctx.beginPath(); ctx.moveTo(x, barY + barH); ctx.lineTo(x, barY + barH + 4); ctx.stroke();
      ctx.fillText(String(p), x - 4, barY + barH + 14);
    }
    // current marker
    const pH = solvePH();
    const mx = pad + (pH/14) * (W - pad*2);
    ctx.strokeStyle = '#fff'; ctx.lineWidth = 2;
    ctx.beginPath(); ctx.moveTo(mx, barY - 4); ctx.lineTo(mx, barY + barH + 4); ctx.stroke();
    ctx.fillStyle = '#fff';
    ctx.fillText(I.label, pad, 10);
  }

  // ===================== CHEM INFO PANEL =====================
  function updateChemInfo(pH) {
    const Veq = equivalenceVolume();
    const A = SPECIES[state.analyte];
    let html = '<b>Reaction.</b> ' + reactionString() + '<br><br>';
    html += '<b>Initial moles analyte:</b> ' + fmt(state.Ca * state.Va0 / 1000 * 1000, 4) + ' mmol<br>';
    html += '<b>Moles titrant added:</b> ' + fmt(state.Ct * state.Vt / 1000 * 1000, 4) + ' mmol<br>';
    html += '<b>Equivalence volume:</b> ' + fmt(Veq, 2) + ' mL<br>';
    if (A.kind === 'weakAcid' && A.pKa) {
      html += '<b>pKa:</b> ' + A.pKa.map(k => k.toFixed(2)).join(', ') + '<br>';
      if (state.Vt > 0 && state.Vt < Veq) {
        // For monoprotic Henderson-Hasselbalch sanity
        if (A.pKa.length === 1) {
          const frac = state.Vt / Veq;
          const ratio = frac / (1 - frac + 1e-9);
          const pHpred = A.pKa[0] + Math.log10(ratio);
          html += '<b>Henderson&ndash;Hasselbalch:</b> ' + fmt(pHpred, 2) + '<br>';
        }
      }
    }
    if (Math.abs(state.Vt - Veq) < 0.05) html += '<br><b style="color:#fde68a">At equivalence point.</b>';
    chemBlock.innerHTML = html;
  }
  function reactionString() {
    const A = state.analyte, T = state.titrant;
    const titrantBase = SPECIES[T].kind.includes('Base');
    const arrow = ' &rarr; ';
    if (A === 'CH3COOH' && titrantBase) return 'CH&#8323;COOH + OH&#8315;' + arrow + 'CH&#8323;COO&#8315; + H&#8322;O';
    if (A === 'HCl' && titrantBase) return 'HCl + OH&#8315;' + arrow + 'Cl&#8315; + H&#8322;O';
    if (A === 'NH4Cl' && titrantBase) return 'NH&#8324;&#8314; + OH&#8315;' + arrow + 'NH&#8323; + H&#8322;O';
    if (A === 'NH3' && !titrantBase) return 'NH&#8323; + H&#8314;' + arrow + 'NH&#8324;&#8314;';
    if (A === 'H2CO3' && titrantBase) return 'H&#8322;CO&#8323; + 2 OH&#8315;' + arrow + 'CO&#8323;&#178;&#8315; + 2 H&#8322;O';
    if (A === 'H3PO4' && titrantBase) return 'H&#8323;PO&#8324; + 3 OH&#8315;' + arrow + 'PO&#8324;&#179;&#8315; + 3 H&#8322;O';
    return A + ' + ' + T;
  }

  // ===================== ANIMATION (drops + auto) =====================
  function animate() {
    if (state.drop.active) {
      state.drop.t += 1;
      const yStart = 218, yEnd = 290;
      const t = state.drop.t / 20;
      if (t >= 1) {
        dropEl.setAttribute('r', '0');
        state.drop.active = false;
      } else {
        const y = yStart + (yEnd - yStart) * t;
        dropEl.setAttribute('cy', String(y));
        dropEl.setAttribute('r', String(3 + 1.5 * Math.sin(t * Math.PI)));
        const T = SPECIES[state.titrant];
        dropEl.setAttribute('fill', T.kind === 'strongBase' || T.kind === 'weakBase' ? '#67e8f9' : '#ff8060');
      }
    }
    if (state.auto) {
      const Veq = equivalenceVolume();
      const limit = Veq * 2.5;
      if (state.Vt < limit) {
        // adaptive step: small near equivalence, larger far from it
        const distToEq = Math.abs(state.Vt - Veq);
        const dV = distToEq < 0.5 ? 0.05 : distToEq < 2 ? 0.2 : 0.5;
        addTitrant(dV);
      } else {
        state.auto = false;
        $('autoBtn').textContent = 'Auto-titrate';
      }
    }
    requestAnimationFrame(animate);
  }

  // ===================== INIT =====================
  // initial setting of slider readouts
  caV.textContent = fmtConc(state.Ca);
  vaV.textContent = fmt(state.Va0, 1) + ' mL';
  ctV.textContent = fmtConc(state.Ct);
  recompute(true);
  animate();
})();
</script>
</BaseLayout>
