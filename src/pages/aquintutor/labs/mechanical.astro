---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Mechanical Engineering · Virtual Labs · AquinTutor" description="Beam bending, stress-strain, gear trains, and thermodynamic cycles — computed live.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; }
  .mz-wrap { max-width: 1320px; margin: 0 auto; padding: 24px 4vw 80px; }
  .mz-back { display: inline-flex; align-items: center; gap: 6px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #9aa0a6; text-decoration: none; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px; }
  .mz-back:hover { color: #67e8f9; }
  .mz-eye { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; }
  .mz-title { font-family: 'Cormorant Garamond', serif; font-size: 38px; font-weight: 600; margin: 4px 0 6px; letter-spacing: -0.02em; line-height: 1.1; }
  .mz-title em { color: #67e8f9; font-style: italic; font-weight: 500; }
  .mz-sub { color: #9aa0a6; max-width: 760px; font-size: 14px; line-height: 1.55; margin: 0 0 22px; }

  .mz-tabs { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 22px; border-bottom: 1px solid #1d1d28; }
  .mz-tab { background: transparent; border: none; border-bottom: 2px solid transparent; color: #9aa0a6; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 10px 14px; cursor: pointer; }
  .mz-tab:hover { color: #cfd6da; }
  .mz-tab.active { color: #67e8f9; border-bottom-color: #67e8f9; }

  .mz-pane { display: none; }
  .mz-pane.active { display: block; }

  .mz-grid { display: grid; grid-template-columns: 300px minmax(0,1fr); gap: 18px; }
  @media (max-width: 920px) { .mz-grid { grid-template-columns: 1fr; } }

  .mz-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 16px; margin-bottom: 14px; }
  .mz-panel h3 { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 12px; }

  .mz-ctl { display: grid; gap: 5px; margin-bottom: 12px; }
  .mz-ctl label { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; display: flex; justify-content: space-between; }
  .mz-ctl label span { color: #67e8f9; }
  .mz-ctl input[type=range] { width: 100%; accent-color: #67e8f9; }
  .mz-ctl select { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; color: #fff; padding: 7px 10px; border-radius: 5px; font-size: 12px; font-family: inherit; }

  .mz-seg { display: flex; gap: 6px; margin-bottom: 12px; }
  .mz-seg button { flex: 1; background: #0a0a0c; border: 1px solid #2a2a35; color: #9aa0a6; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; padding: 8px 6px; border-radius: 5px; cursor: pointer; }
  .mz-seg button.on { background: rgba(103,232,249,0.12); border-color: #67e8f9; color: #67e8f9; }

  .mz-metric { display: grid; grid-template-columns: 1fr auto; gap: 8px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11.5px; padding: 5px 0; border-bottom: 1px solid #1a1a25; }
  .mz-metric:last-child { border-bottom: none; }
  .mz-metric-l { color: #9aa6b6; }
  .mz-metric-v { color: #67e8f9; font-weight: 700; text-align: right; }
  .mz-metric-v.amber { color: #fbbf24; }
  .mz-metric-v.green { color: #86efac; }
  .mz-metric-v.red { color: #fca5a5; }
  .mz-metric-v.purple { color: #a78bfa; }

  .mz-svg { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 10px; display: block; }
  .mz-formula { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12px; color: #cfd6da; line-height: 1.7; background: #0a0a0c; border: 1px solid #1d1d28; border-radius: 8px; padding: 12px 14px; margin-top: 4px; }
  .mz-formula b { color: #fbbf24; }
  .mz-note { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; color: #6b7280; line-height: 1.6; margin-top: 8px; }
  .mz-plots { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  @media (max-width: 720px) { .mz-plots { grid-template-columns: 1fr; } }
</style>

<main class="mz-wrap">
  <a href="/aquintutor/labs" class="mz-back">
    <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    Back to Labs
  </a>
  <div class="mz-eye">Lab · Mechanical Engineering</div>
  <h1 class="mz-title">Solid mechanics, machines &amp; <em>thermal</em> cycles.</h1>
  <p class="mz-sub">Four working benches. Every slider re-solves the underlying engineering mathematics — beam statics by equilibrium and double integration, an engineering stress-strain model, gear-train kinematics with live meshing, and an Otto/Carnot air-standard cycle on the P-V plane.</p>

  <div class="mz-tabs" id="tabs">
    <button class="mz-tab active" data-pane="beam">Beam bending</button>
    <button class="mz-tab" data-pane="stress">Stress-strain</button>
    <button class="mz-tab" data-pane="gear">Gear train</button>
    <button class="mz-tab" data-pane="thermo">Thermo cycle</button>
  </div>

  <!-- ===================== BEAM ===================== -->
  <section class="mz-pane active" id="pane-beam">
    <div class="mz-grid">
      <aside>
        <div class="mz-panel">
          <h3>Support type</h3>
          <div class="mz-seg" id="beamType">
            <button class="on" data-t="ss">Simply supported</button>
            <button data-t="cant">Cantilever</button>
          </div>
        </div>
        <div class="mz-panel">
          <h3>Geometry &amp; loads</h3>
          <div class="mz-ctl"><label>Span L (m) <span id="b_LV">6.00</span></label><input id="b_L" type="range" min="1" max="12" step="0.1" value="6"/></div>
          <div class="mz-ctl"><label>Point load P (kN) <span id="b_PV">20.0</span></label><input id="b_P" type="range" min="0" max="100" step="0.5" value="20"/></div>
          <div class="mz-ctl"><label>Load position a (m) <span id="b_aV">3.00</span></label><input id="b_a" type="range" min="0" max="12" step="0.1" value="3"/></div>
          <div class="mz-ctl"><label>UDL w (kN/m) <span id="b_wV">5.0</span></label><input id="b_w" type="range" min="0" max="40" step="0.5" value="5"/></div>
        </div>
        <div class="mz-panel">
          <h3>Section &amp; material</h3>
          <div class="mz-ctl"><label>E (GPa) <span id="b_EV">200</span></label><input id="b_E" type="range" min="50" max="400" step="5" value="200"/></div>
          <div class="mz-ctl"><label>I (10^-6 m^4) <span id="b_IV">80</span></label><input id="b_I" type="range" min="5" max="500" step="5" value="80"/></div>
        </div>
        <div class="mz-panel">
          <h3>Results</h3>
          <div class="mz-metric"><span class="mz-metric-l">Reaction R_A</span><span class="mz-metric-v" id="b_RA">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">Reaction R_B</span><span class="mz-metric-v" id="b_RB">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">|V| max</span><span class="mz-metric-v amber" id="b_Vmax">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">M max</span><span class="mz-metric-v amber" id="b_Mmax">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">at x =</span><span class="mz-metric-v" id="b_Mx">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">Max deflection</span><span class="mz-metric-v green" id="b_dmax">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">Max bending stress</span><span class="mz-metric-v red" id="b_sig">—</span></div>
        </div>
      </aside>
      <div>
        <div class="mz-panel">
          <h3>Loaded beam</h3>
          <svg id="b_beam" class="mz-svg" viewBox="0 0 760 170" preserveAspectRatio="xMidYMid meet"></svg>
        </div>
        <div class="mz-plots">
          <div class="mz-panel" style="margin:0;">
            <h3>Shear force diagram · V(x) [kN]</h3>
            <svg id="b_sfd" class="mz-svg" viewBox="0 0 380 210" preserveAspectRatio="none"></svg>
          </div>
          <div class="mz-panel" style="margin:0;">
            <h3>Bending moment diagram · M(x) [kN·m]</h3>
            <svg id="b_bmd" class="mz-svg" viewBox="0 0 380 210" preserveAspectRatio="none"></svg>
          </div>
        </div>
        <div class="mz-panel" style="margin-top:14px;">
          <h3>Elastic curve · deflection (mm)</h3>
          <svg id="b_def" class="mz-svg" viewBox="0 0 760 150" preserveAspectRatio="none"></svg>
          <div class="mz-note">Deflection from EI&middot;y'' = M(x), integrated twice numerically with boundary conditions applied at the supports.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== STRESS-STRAIN ===================== -->
  <section class="mz-pane" id="pane-stress">
    <div class="mz-grid">
      <aside>
        <div class="mz-panel">
          <h3>Material</h3>
          <div class="mz-ctl"><select id="s_mat"></select></div>
        </div>
        <div class="mz-panel">
          <h3>Applied load</h3>
          <div class="mz-ctl"><label>Strain &epsilon; (%) <span id="s_eV">0.10</span></label><input id="s_e" type="range" min="0" max="100" step="0.05" value="0.5"/></div>
          <div class="mz-ctl"><label>Working stress (MPa) <span id="s_wV">150</span></label><input id="s_w" type="range" min="10" max="600" step="5" value="150"/></div>
        </div>
        <div class="mz-panel">
          <h3>Material constants</h3>
          <div class="mz-metric"><span class="mz-metric-l">E (Young's)</span><span class="mz-metric-v" id="s_E">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">Yield &sigma;_y</span><span class="mz-metric-v amber" id="s_sy">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">UTS</span><span class="mz-metric-v red" id="s_uts">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">Fracture strain</span><span class="mz-metric-v" id="s_ef">—</span></div>
        </div>
        <div class="mz-panel">
          <h3>Current state</h3>
          <div class="mz-metric"><span class="mz-metric-l">Strain</span><span class="mz-metric-v" id="s_cur_e">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">Stress</span><span class="mz-metric-v" id="s_cur_s">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">Region</span><span class="mz-metric-v purple" id="s_region">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">FoS (UTS / working)</span><span class="mz-metric-v green" id="s_fos">—</span></div>
        </div>
      </aside>
      <div>
        <div class="mz-panel">
          <h3>Engineering stress-strain curve</h3>
          <svg id="s_curve" class="mz-svg" viewBox="0 0 760 460" preserveAspectRatio="xMidYMid meet"></svg>
          <div class="mz-note">Elastic line slope = E. Beyond yield: parabolic strain hardening to the UTS, then load-drop necking to fracture. The marker tracks your applied strain.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== GEAR ===================== -->
  <section class="mz-pane" id="pane-gear">
    <div class="mz-grid">
      <aside>
        <div class="mz-panel">
          <h3>Configuration</h3>
          <div class="mz-seg" id="gearStages">
            <button class="on" data-st="1">One stage</button>
            <button data-st="2">Two stages</button>
          </div>
        </div>
        <div class="mz-panel">
          <h3>Teeth &amp; input</h3>
          <div class="mz-ctl"><label>Driver Z1 <span id="g_z1V">12</span></label><input id="g_z1" type="range" min="8" max="40" step="1" value="12"/></div>
          <div class="mz-ctl"><label>Gear Z2 <span id="g_z2V">36</span></label><input id="g_z2" type="range" min="8" max="60" step="1" value="36"/></div>
          <div class="mz-ctl" id="g_z3wrap"><label>Driver Z3 <span id="g_z3V">14</span></label><input id="g_z3" type="range" min="8" max="40" step="1" value="14"/></div>
          <div class="mz-ctl" id="g_z4wrap"><label>Output Z4 <span id="g_z4V">42</span></label><input id="g_z4" type="range" min="8" max="60" step="1" value="42"/></div>
          <div class="mz-ctl"><label>Input speed (rpm) <span id="g_nV">1500</span></label><input id="g_n" type="range" min="0" max="3000" step="10" value="1500"/></div>
          <div class="mz-ctl"><label>Input torque (N&middot;m) <span id="g_tV">10.0</span></label><input id="g_t" type="range" min="0" max="100" step="0.5" value="10"/></div>
        </div>
        <div class="mz-panel">
          <h3>Results</h3>
          <div class="mz-metric"><span class="mz-metric-l">Total gear ratio</span><span class="mz-metric-v" id="g_ratio">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">Output speed</span><span class="mz-metric-v amber" id="g_nout">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">Output torque</span><span class="mz-metric-v green" id="g_tout">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">Direction</span><span class="mz-metric-v purple" id="g_dir">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">Type</span><span class="mz-metric-v" id="g_kind">—</span></div>
        </div>
      </aside>
      <div>
        <div class="mz-panel">
          <h3>Meshing gear train</h3>
          <svg id="g_svg" class="mz-svg" viewBox="0 0 760 440" preserveAspectRatio="xMidYMid meet" style="background:radial-gradient(circle at 50% 45%,#14141c,#0a0a0c);"></svg>
          <div class="mz-formula">ratio i = Z_out / Z_in &nbsp;&middot;&nbsp; n_out = n_in / i &nbsp;&middot;&nbsp; T_out = T_in &times; i &times; &eta; &nbsp;(<b>&eta; = 0.97 / stage</b>)</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== THERMO ===================== -->
  <section class="mz-pane" id="pane-thermo">
    <div class="mz-grid">
      <aside>
        <div class="mz-panel">
          <h3>Cycle</h3>
          <div class="mz-seg" id="cycType">
            <button class="on" data-c="otto">Otto</button>
            <button data-c="carnot">Carnot</button>
          </div>
        </div>
        <div class="mz-panel">
          <h3>Parameters</h3>
          <div class="mz-ctl"><label>Compression ratio r <span id="t_rV">8.0</span></label><input id="t_r" type="range" min="2" max="20" step="0.1" value="8"/></div>
          <div class="mz-ctl"><label>&gamma; (cp/cv) <span id="t_gV">1.40</span></label><input id="t_g" type="range" min="1.1" max="1.67" step="0.01" value="1.4"/></div>
          <div class="mz-ctl"><label>T cold / intake (K) <span id="t_tcV">300</span></label><input id="t_tc" type="range" min="250" max="500" step="5" value="300"/></div>
          <div class="mz-ctl"><label>T hot / peak (K) <span id="t_thV">1800</span></label><input id="t_th" type="range" min="600" max="2600" step="10" value="1800"/></div>
        </div>
        <div class="mz-panel">
          <h3>Results</h3>
          <div class="mz-metric"><span class="mz-metric-l">Thermal efficiency</span><span class="mz-metric-v green" id="t_eff">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">Carnot limit</span><span class="mz-metric-v" id="t_carn">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">Heat in q_in</span><span class="mz-metric-v amber" id="t_qin">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">Heat out q_out</span><span class="mz-metric-v" id="t_qout">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">Net work w_net</span><span class="mz-metric-v purple" id="t_wnet">—</span></div>
          <div class="mz-metric"><span class="mz-metric-l">MEP (rel.)</span><span class="mz-metric-v" id="t_mep">—</span></div>
        </div>
      </aside>
      <div>
        <div class="mz-panel">
          <h3>P-V diagram</h3>
          <svg id="t_pv" class="mz-svg" viewBox="0 0 760 460" preserveAspectRatio="xMidYMid meet"></svg>
          <div class="mz-formula" id="t_form"></div>
        </div>
      </div>
    </div>
  </section>
</main>

<script is:inline>
(function () {
  var SVGNS = 'http://www.w3.org/2000/svg';
  function el(id) { return document.getElementById(id); }
  function clr(node) { while (node.firstChild) node.removeChild(node.firstChild); }
  function svg(parent, tag, attrs) {
    var n = document.createElementNS(SVGNS, tag);
    for (var k in attrs) { if (attrs.hasOwnProperty(k)) n.setAttribute(k, attrs[k]); }
    parent.appendChild(n);
    return n;
  }
  function txt(parent, x, y, s, attrs) {
    var n = svg(parent, 'text', attrs || {});
    n.setAttribute('x', x); n.setAttribute('y', y);
    n.textContent = s;
    return n;
  }
  function fmt(v, d) { if (!isFinite(v)) return '—'; return v.toFixed(d === undefined ? 2 : d); }
  function v(id) { return parseFloat(el(id).value); }

  /* ---------- Tabs ---------- */
  var tabs = el('tabs').querySelectorAll('.mz-tab');
  for (var i = 0; i < tabs.length; i++) {
    (function (t) {
      t.addEventListener('click', function () {
        for (var j = 0; j < tabs.length; j++) tabs[j].classList.remove('active');
        t.classList.add('active');
        var panes = document.querySelectorAll('.mz-pane');
        for (var k = 0; k < panes.length; k++) panes[k].classList.remove('active');
        el('pane-' + t.getAttribute('data-pane')).classList.add('active');
      });
    })(tabs[i]);
  }

  /* ================================================================
     1. BEAM BENDING  — real statics + double integration
     ================================================================ */
  var beamType = 'ss';
  (function () {
    var seg = el('beamType').querySelectorAll('button');
    for (var i = 0; i < seg.length; i++) {
      (function (b) {
        b.addEventListener('click', function () {
          for (var j = 0; j < seg.length; j++) seg[j].classList.remove('on');
          b.classList.add('on'); beamType = b.getAttribute('data-t'); beamUpdate();
        });
      })(seg[i]);
    }
    var ids = ['b_L', 'b_P', 'b_a', 'b_w', 'b_E', 'b_I'];
    for (var n = 0; n < ids.length; n++) el(ids[n]).addEventListener('input', beamUpdate);
  })();

  function beamSolve(L, P, a, w) {
    // Returns sampled V(x), M(x), reactions. Units: kN, kN/m, m.
    var N = 240, i, x;
    var xs = [], V = [], M = [];
    var RA, RB;
    if (beamType === 'ss') {
      // Simply supported: supports at 0 and L. Loads: point P at a, UDL w over span.
      var W = w * L;
      // sum moments about A = 0  ->  RB*L = P*a + W*(L/2)
      RB = (P * a + W * (L / 2)) / L;
      RA = P + W - RB;
    } else {
      // Cantilever fixed at x=0, free at x=L. RA carries everything (reaction + moment).
      RA = P + w * L; RB = 0;
    }
    for (i = 0; i <= N; i++) {
      x = L * i / N; xs.push(x);
      var sh, mo;
      if (beamType === 'ss') {
        sh = RA - w * x - (x >= a ? P : 0);
        mo = RA * x - w * x * x / 2 - (x >= a ? P * (x - a) : 0);
      } else {
        // Fixed-end reactions act as the left cut; shear/moment from loads to the right.
        sh = RA - w * x - (x >= a ? P : 0);
        // Fixing moment M0 at wall so that M(L)=0 at free end (statically determinate cantilever):
        // Easier: integrate from free end. M(x) = -[ load contributions to the right of x ].
        var Pr = (a >= x) ? P : 0;
        var armP = (a >= x) ? (a - x) : 0;
        var wr = w * (L - x); var armw = (L - x) / 2;
        mo = -(Pr * armP + wr * armw); // hogging negative
      }
      V.push(sh); M.push(mo);
    }
    return { xs: xs, V: V, M: M, RA: RA, RB: RB, N: N };
  }

  function beamDeflection(sol, L, EI) {
    // EI y'' = M(x). Integrate twice (trapezoid) then apply BCs.
    var N = sol.N, h = L / N, i;
    var theta = [0], y = [0];
    // first integration: slope (un-normalised)
    for (i = 1; i <= N; i++) theta.push(theta[i - 1] + (sol.M[i - 1] + sol.M[i]) / 2 * h / EI);
    for (i = 1; i <= N; i++) y.push(y[i - 1] + (theta[i - 1] + theta[i]) / 2 * h);
    if (beamType === 'ss') {
      // BC: y(0)=0 (already) and y(L)=0 -> subtract linear correction C*x
      var C = y[N] / L;
      for (i = 0; i <= N; i++) y[i] = y[i] - C * sol.xs[i];
    }
    // Cantilever: y(0)=0 and theta(0)=0 already satisfied (fixed at left), nothing to correct.
    return y; // metres (M in kN·m, EI in kN·m^2 -> y in m)
  }

  function plotDiagram(elt, xs, ys, L, color, label, fillSign) {
    clr(elt);
    var W = 380, H = 210, padL = 40, padR = 10, padT = 14, padB = 24;
    var iw = W - padL - padR, ih = H - padT - padB;
    var ymax = 1e-9, i;
    for (i = 0; i < ys.length; i++) ymax = Math.max(ymax, Math.abs(ys[i]));
    var sx = function (x) { return padL + x / L * iw; };
    var zeroY = padT + ih / 2;
    var sy = function (y) { return zeroY - y / ymax * (ih / 2 - 4); };
    // grid + axes
    svg(elt, 'rect', { x: padL, y: padT, width: iw, height: ih, fill: 'none', stroke: '#1a1a25' });
    svg(elt, 'line', { x1: padL, y1: zeroY, x2: padL + iw, y2: zeroY, stroke: '#3a3a45', 'stroke-width': 1 });
    // filled area
    var d = 'M ' + sx(xs[0]) + ' ' + zeroY;
    for (i = 0; i < xs.length; i++) d += ' L ' + sx(xs[i]) + ' ' + sy(ys[i]);
    d += ' L ' + sx(xs[xs.length - 1]) + ' ' + zeroY + ' Z';
    svg(elt, 'path', { d: d, fill: color, 'fill-opacity': '0.16', stroke: 'none' });
    var dl = 'M ' + sx(xs[0]) + ' ' + sy(ys[0]);
    for (i = 1; i < xs.length; i++) dl += ' L ' + sx(xs[i]) + ' ' + sy(ys[i]);
    svg(elt, 'path', { d: dl, fill: 'none', stroke: color, 'stroke-width': 1.8 });
    // axis labels
    txt(elt, padL, H - 8, '0', { fill: '#6b7280', 'font-family': 'ui-monospace', 'font-size': '9' });
    txt(elt, padL + iw - 18, H - 8, fmt(L, 1) + 'm', { fill: '#6b7280', 'font-family': 'ui-monospace', 'font-size': '9' });
    txt(elt, 4, sy(ymax) + 4, '+' + fmt(ymax, 0), { fill: '#6b7280', 'font-family': 'ui-monospace', 'font-size': '9' });
    txt(elt, 4, sy(-ymax) + 4, '-' + fmt(ymax, 0), { fill: '#6b7280', 'font-family': 'ui-monospace', 'font-size': '9' });
  }

  function drawBeam(L, P, a, w) {
    var elt = el('b_beam'); clr(elt);
    var W = 760, padL = 50, padR = 50, y0 = 95;
    var iw = W - padL - padR;
    var sx = function (x) { return padL + x / L * iw; };
    // beam line
    svg(elt, 'rect', { x: padL, y: y0 - 6, width: iw, height: 12, fill: '#2a2a35', stroke: '#454553' });
    // supports
    if (beamType === 'ss') {
      // pin at A (triangle), roller at B
      svg(elt, 'path', { d: 'M ' + padL + ' ' + (y0 + 6) + ' l -11 18 l 22 0 z', fill: '#67e8f9' });
      svg(elt, 'path', { d: 'M ' + (padL + iw) + ' ' + (y0 + 6) + ' l -11 18 l 22 0 z', fill: '#67e8f9' });
      svg(elt, 'circle', { cx: padL + iw - 6, cy: y0 + 28, r: 3, fill: '#67e8f9' });
      svg(elt, 'circle', { cx: padL + iw + 6, cy: y0 + 28, r: 3, fill: '#67e8f9' });
    } else {
      // fixed wall at left
      svg(elt, 'rect', { x: padL - 14, y: y0 - 30, width: 14, height: 60, fill: '#67e8f9', 'fill-opacity': '0.3', stroke: '#67e8f9' });
    }
    // UDL arrows
    if (w > 0.01) {
      for (var k = 0; k <= 12; k++) {
        var xx = padL + iw * k / 12;
        svg(elt, 'line', { x1: xx, y1: y0 - 32, x2: xx, y2: y0 - 8, stroke: '#a78bfa', 'stroke-width': 1 });
        svg(elt, 'path', { d: 'M ' + xx + ' ' + (y0 - 8) + ' l -3 -5 l 6 0 z', fill: '#a78bfa' });
      }
      svg(elt, 'line', { x1: padL, y1: y0 - 32, x2: padL + iw, y2: y0 - 32, stroke: '#a78bfa', 'stroke-width': 1 });
      txt(elt, padL + iw / 2 - 30, y0 - 38, 'w = ' + fmt(w, 1) + ' kN/m', { fill: '#a78bfa', 'font-family': 'ui-monospace', 'font-size': '11' });
    }
    // Point load arrow
    if (P > 0.01 && a <= L) {
      var px = sx(a);
      svg(elt, 'line', { x1: px, y1: y0 - 58, x2: px, y2: y0 - 8, stroke: '#fbbf24', 'stroke-width': 2.4 });
      svg(elt, 'path', { d: 'M ' + px + ' ' + (y0 - 8) + ' l -5 -8 l 10 0 z', fill: '#fbbf24' });
      txt(elt, px - 24, y0 - 64, 'P = ' + fmt(P, 0) + ' kN', { fill: '#fbbf24', 'font-family': 'ui-monospace', 'font-size': '11' });
    }
  }

  function drawDeflection(xs, y, L) {
    var elt = el('b_def'); clr(elt);
    var W = 760, H = 150, padL = 40, padR = 20, padT = 16, padB = 20;
    var iw = W - padL - padR, ih = H - padT - padB;
    var ymax = 1e-12, i;
    for (i = 0; i < y.length; i++) ymax = Math.max(ymax, Math.abs(y[i]));
    var sx = function (x) { return padL + x / L * iw; };
    var midY = padT + ih * 0.4;
    // EI y'' = M(sagging +) gives downward sag as NEGATIVE y; negate so physical
    // downward deflection is drawn below the neutral line.
    var sY = function (val) { return midY - val / ymax * (ih * 0.5); };
    svg(elt, 'line', { x1: padL, y1: midY, x2: padL + iw, y2: midY, stroke: '#2a2a35', 'stroke-dasharray': '4 4' });
    var d = 'M ' + sx(xs[0]) + ' ' + sY(y[0]);
    for (i = 1; i < xs.length; i++) d += ' L ' + sx(xs[i]) + ' ' + sY(y[i]);
    svg(elt, 'path', { d: d, fill: 'none', stroke: '#86efac', 'stroke-width': 2 });
    txt(elt, padL, midY - 4, 'undeflected', { fill: '#4b5563', 'font-family': 'ui-monospace', 'font-size': '9' });
    txt(elt, 4, padT + 8, fmt(ymax * 1000, 1) + 'mm', { fill: '#86efac', 'font-family': 'ui-monospace', 'font-size': '9' });
  }

  function beamUpdate() {
    var L = v('b_L'), P = v('b_P'), a = Math.min(v('b_a'), L), w = v('b_w');
    var E = v('b_E') * 1e9; // Pa
    var I = v('b_I') * 1e-6; // m^4
    el('b_LV').textContent = fmt(L, 2); el('b_PV').textContent = fmt(P, 1);
    el('b_aV').textContent = fmt(a, 2); el('b_wV').textContent = fmt(w, 1);
    el('b_EV').textContent = fmt(v('b_E'), 0); el('b_IV').textContent = fmt(v('b_I'), 0);
    // clamp a slider visual to span
    if (parseFloat(el('b_a').max) !== L) { /* keep range; just clamp value used */ }

    var sol = beamSolve(L, P, a, w);
    // max V, M
    var Vmax = 0, Mmax = 0, Mx = 0, i;
    for (i = 0; i <= sol.N; i++) {
      if (Math.abs(sol.V[i]) > Math.abs(Vmax)) Vmax = sol.V[i];
      if (Math.abs(sol.M[i]) > Math.abs(Mmax)) { Mmax = sol.M[i]; Mx = sol.xs[i]; }
    }
    var EI_kN = E * I / 1000; // kN·m^2  (since M is in kN·m)
    var ydef = beamDeflection(sol, L, EI_kN);
    var dmax = 0;
    for (i = 0; i <= sol.N; i++) if (Math.abs(ydef[i]) > Math.abs(dmax)) dmax = ydef[i];
    // bending stress sigma = M*c / I, take c ~ assume from I a square-ish section: c = (I*? )
    // Use a representative extreme-fibre distance derived from I treating a rectangular section h: I = b h^3/12,
    // assume b = h/2 -> I = h^4/24 -> h = (24 I)^(1/4); c = h/2.
    var h_sec = Math.pow(24 * I, 0.25);
    var c = h_sec / 2;
    var sigma = Math.abs(Mmax) * 1000 * c / I / 1e6; // MPa (Mmax kN·m ->N·m)

    el('b_RA').textContent = fmt(sol.RA, 2) + ' kN';
    el('b_RB').textContent = (beamType === 'ss' ? fmt(sol.RB, 2) + ' kN' : 'fixed');
    el('b_Vmax').textContent = fmt(Math.abs(Vmax), 2) + ' kN';
    el('b_Mmax').textContent = fmt(Math.abs(Mmax), 2) + ' kN·m';
    el('b_Mx').textContent = fmt(Mx, 2) + ' m';
    el('b_dmax').textContent = fmt(Math.abs(dmax) * 1000, 2) + ' mm';
    el('b_sig').textContent = fmt(sigma, 1) + ' MPa';

    drawBeam(L, P, a, w);
    plotDiagram(el('b_sfd'), sol.xs, sol.V, L, '#fbbf24');
    plotDiagram(el('b_bmd'), sol.xs, sol.M, L, '#67e8f9');
    drawDeflection(sol.xs, ydef, L);
  }

  /* ================================================================
     2. STRESS-STRAIN  — engineering model + FoS
     ================================================================ */
  var MATERIALS = [
    // E (GPa), yield (MPa), UTS (MPa), strain at UTS, fracture strain (eng.)
    { name: 'Mild steel (AISI 1020)', E: 200, sy: 250, uts: 420, eu: 0.18, ef: 0.30 },
    { name: 'Aluminium 6061-T6', E: 69, sy: 276, uts: 310, eu: 0.10, ef: 0.17 },
    { name: 'Copper (annealed)', E: 117, sy: 70, uts: 220, eu: 0.30, ef: 0.45 },
    { name: 'Structural steel S355', E: 210, sy: 355, uts: 510, eu: 0.16, ef: 0.26 }
  ];
  (function () {
    var sel = el('s_mat');
    for (var i = 0; i < MATERIALS.length; i++) {
      var o = document.createElement('option'); o.value = i; o.textContent = MATERIALS[i].name; sel.appendChild(o);
    }
    sel.addEventListener('change', stressUpdate);
    el('s_e').addEventListener('input', stressUpdate);
    el('s_w').addEventListener('input', stressUpdate);
  })();

  function stressAt(m, eps) {
    // eps as fraction. Returns {stress MPa, region}
    var eY = m.sy / (m.E * 1000); // yield strain (E in GPa -> *1000 = MPa per unit strain)
    if (eps <= 0) return { s: 0, region: 'unloaded' };
    if (eps <= eY) return { s: m.E * 1000 * eps, region: 'elastic' };
    if (eps <= m.eu) {
      // strain hardening: parabola from (eY, sy) up to (eu, uts) with zero slope at uts
      var t = (eps - eY) / (m.eu - eY);
      var s = m.sy + (m.uts - m.sy) * (2 * t - t * t); // ease-out parabola
      return { s: s, region: 'plastic (strain-hardening)' };
    }
    if (eps <= m.ef) {
      // necking: load drops from uts to ~0.75 uts at fracture
      var tn = (eps - m.eu) / (m.ef - m.eu);
      var s2 = m.uts - (m.uts * 0.28) * tn * tn;
      return { s: s2, region: 'necking' };
    }
    return { s: 0, region: 'fractured' };
  }

  function stressUpdate() {
    var m = MATERIALS[parseInt(el('s_mat').value, 10)];
    var epsPct = v('s_e'); var eps = epsPct / 100;
    var working = v('s_w');
    el('s_eV').textContent = fmt(epsPct, 2);
    el('s_wV').textContent = fmt(working, 0);
    el('s_E').textContent = m.E + ' GPa';
    el('s_sy').textContent = m.sy + ' MPa';
    el('s_uts').textContent = m.uts + ' MPa';
    el('s_ef').textContent = fmt(m.ef * 100, 0) + ' %';

    var st = stressAt(m, eps);
    el('s_cur_e').textContent = fmt(epsPct, 2) + ' %';
    el('s_cur_s').textContent = fmt(st.s, 1) + ' MPa';
    el('s_region').textContent = st.region;
    var fos = m.uts / Math.max(1, working);
    el('s_fos').textContent = fmt(fos, 2);
    el('s_fos').className = 'mz-metric-v ' + (fos >= 2 ? 'green' : (fos >= 1.5 ? 'amber' : 'red'));

    drawStressCurve(m, eps, st, working);
  }

  function drawStressCurve(m, eps, st, working) {
    var elt = el('s_curve'); clr(elt);
    var W = 760, H = 460, padL = 56, padR = 24, padT = 20, padB = 44;
    var iw = W - padL - padR, ih = H - padT - padB;
    var emax = m.ef * 1.05;
    var smax = m.uts * 1.12;
    var sx = function (e) { return padL + e / emax * iw; };
    var sy = function (s) { return padT + ih - s / smax * ih; };
    // grid
    var gi;
    for (gi = 0; gi <= 5; gi++) {
      var gy = padT + ih * gi / 5;
      svg(elt, 'line', { x1: padL, y1: gy, x2: padL + iw, y2: gy, stroke: '#16161f' });
      txt(elt, 8, gy + 4, fmt(smax * (1 - gi / 5), 0), { fill: '#4b5563', 'font-family': 'ui-monospace', 'font-size': '10' });
    }
    for (gi = 0; gi <= 6; gi++) {
      var gx = padL + iw * gi / 6;
      svg(elt, 'line', { x1: gx, y1: padT, x2: gx, y2: padT + ih, stroke: '#16161f' });
      txt(elt, gx - 8, padT + ih + 16, fmt(emax * 100 * gi / 6, 0), { fill: '#4b5563', 'font-family': 'ui-monospace', 'font-size': '10' });
    }
    txt(elt, padL + iw / 2 - 36, H - 8, 'strain  ε (%)', { fill: '#9aa6b6', 'font-family': 'ui-monospace', 'font-size': '11' });
    txt(elt, 12, padT - 6, 'stress σ (MPa)', { fill: '#9aa6b6', 'font-family': 'ui-monospace', 'font-size': '11' });

    // working stress line
    svg(elt, 'line', { x1: padL, y1: sy(working), x2: padL + iw, y2: sy(working), stroke: '#86efac', 'stroke-dasharray': '5 4', 'stroke-width': 1 });
    txt(elt, padL + iw - 110, sy(working) - 5, 'working ' + fmt(working, 0) + ' MPa', { fill: '#86efac', 'font-family': 'ui-monospace', 'font-size': '10' });

    // full curve, sampled
    var d = '', i, e, p, first = true;
    for (i = 0; i <= 300; i++) {
      e = m.ef * i / 300;
      p = stressAt(m, e);
      if (p.region === 'fractured') break;
      d += (first ? 'M ' : ' L ') + sx(e) + ' ' + sy(p.s); first = false;
    }
    svg(elt, 'path', { d: d, fill: 'none', stroke: '#67e8f9', 'stroke-width': 2.4 });

    // yield marker
    var eY = m.sy / (m.E * 1000);
    svg(elt, 'circle', { cx: sx(eY), cy: sy(m.sy), r: 4, fill: '#fbbf24' });
    txt(elt, sx(eY) + 8, sy(m.sy) - 6, 'yield', { fill: '#fbbf24', 'font-family': 'ui-monospace', 'font-size': '10' });
    // UTS marker
    svg(elt, 'circle', { cx: sx(m.eu), cy: sy(m.uts), r: 4, fill: '#fca5a5' });
    txt(elt, sx(m.eu) - 6, sy(m.uts) - 8, 'UTS', { fill: '#fca5a5', 'font-family': 'ui-monospace', 'font-size': '10' });
    // fracture X
    svg(elt, 'path', { d: 'M ' + (sx(m.ef) - 5) + ' ' + (sy(stressAt(m, m.ef * 0.999).s) - 5) + ' l 10 10 m 0 -10 l -10 10', stroke: '#fca5a5', 'stroke-width': 1.6 });

    // current marker
    if (st.region !== 'fractured' && eps > 0) {
      var cx = sx(Math.min(eps, m.ef)), cy = sy(st.s);
      svg(elt, 'line', { x1: cx, y1: padT + ih, x2: cx, y2: cy, stroke: '#a78bfa', 'stroke-dasharray': '3 3' });
      svg(elt, 'line', { x1: padL, y1: cy, x2: cx, y2: cy, stroke: '#a78bfa', 'stroke-dasharray': '3 3' });
      svg(elt, 'circle', { cx: cx, cy: cy, r: 6, fill: '#a78bfa', stroke: '#0a0a0c', 'stroke-width': 2 });
    }
  }

  /* ================================================================
     3. GEAR TRAIN  — kinematics + live meshing animation
     ================================================================ */
  var gearStages = 1;
  (function () {
    var seg = el('gearStages').querySelectorAll('button');
    for (var i = 0; i < seg.length; i++) {
      (function (b) {
        b.addEventListener('click', function () {
          for (var j = 0; j < seg.length; j++) seg[j].classList.remove('on');
          b.classList.add('on'); gearStages = parseInt(b.getAttribute('data-st'), 10);
          el('g_z3wrap').style.display = gearStages === 2 ? 'grid' : 'none';
          el('g_z4wrap').style.display = gearStages === 2 ? 'grid' : 'none';
          gearCompute();
        });
      })(seg[i]);
    }
    el('g_z3wrap').style.display = 'none'; el('g_z4wrap').style.display = 'none';
    var ids = ['g_z1', 'g_z2', 'g_z3', 'g_z4', 'g_n', 'g_t'];
    for (var n = 0; n < ids.length; n++) el(ids[n]).addEventListener('input', gearCompute);
  })();

  var gearData = null; // {gears:[{cx,cy,r,Z,phase,omega,color}], ...}

  function gearGeom() {
    var z1 = v('g_z1'), z2 = v('g_z2'), z3 = v('g_z3'), z4 = v('g_z4');
    var module = 4; // mm/tooth pitch scale (visual)
    function R(z) { return z * module / 2; }
    var cy = 220, gap = 2;
    var gears = [];
    var x = 130;
    var r1 = R(z1), r2 = R(z2);
    gears.push({ Z: z1, r: r1, cx: x, cy: cy, color: '#67e8f9' });
    x += r1 + r2 + gap;
    gears.push({ Z: z2, r: r2, cx: x, cy: cy, color: '#a78bfa' });
    if (gearStages === 2) {
      // gear 3 mounted on same shaft as gear 2 (compound) -> same centre as gear2
      var r3 = R(z3), r4 = R(z4);
      gears.push({ Z: z3, r: r3, cx: x, cy: cy, color: '#fbbf24', compound: true });
      x += r3 + r4 + gap;
      gears.push({ Z: z4, r: r4, cx: x, cy: cy, color: '#86efac' });
    }
    return gears;
  }

  function gearCompute() {
    var z1 = v('g_z1'), z2 = v('g_z2'), z3 = v('g_z3'), z4 = v('g_z4');
    var nIn = v('g_n'), Tin = v('g_t');
    el('g_z1V').textContent = z1; el('g_z2V').textContent = z2;
    el('g_z3V').textContent = z3; el('g_z4V').textContent = z4;
    el('g_nV').textContent = fmt(nIn, 0); el('g_tV').textContent = fmt(Tin, 1);

    var ratio, eta, nOut, Tout, kind, sameDir;
    if (gearStages === 1) {
      ratio = z2 / z1; eta = 0.97;
      sameDir = false; // single external mesh reverses
    } else {
      ratio = (z2 / z1) * (z4 / z3); eta = 0.97 * 0.97;
      sameDir = true; // two external meshes -> back to same direction
    }
    nOut = nIn / ratio;
    Tout = Tin * ratio * eta;
    kind = ratio > 1 ? 'reduction (torque up)' : (ratio < 1 ? 'overdrive (speed up)' : 'direct 1:1');

    el('g_ratio').textContent = fmt(ratio, 3) + ' : 1';
    el('g_nout').textContent = fmt(nOut, 1) + ' rpm';
    el('g_tout').textContent = fmt(Tout, 2) + ' N·m';
    el('g_dir').textContent = sameDir ? 'same as input' : 'reversed';
    el('g_kind').textContent = kind;

    // build geometry + per-gear angular speed (rad/s, signed)
    var gears = gearGeom();
    var wIn = nIn * 2 * Math.PI / 60; // rad/s
    // gear0 = driver
    gears[0].omega = wIn;
    // gear1 meshes externally -> opposite sign, ratio Z1/Z2
    gears[1].omega = -wIn * gears[0].Z / gears[1].Z;
    if (gearStages === 2) {
      // gear2 compound on gear1 shaft -> same omega as gear1
      gears[2].omega = gears[1].omega;
      // gear3 meshes externally with gear2 -> opposite sign
      gears[3].omega = -gears[2].omega * gears[2].Z / gears[3].Z;
    }
    for (var i = 0; i < gears.length; i++) if (gears[i].phase === undefined) gears[i].phase = 0;
    // preserve phases across rebuilds
    if (gearData) for (var k = 0; k < gears.length; k++) if (gearData.gears[k]) gears[k].phase = gearData.gears[k].phase;
    gearData = { gears: gears };
    drawGears(true);
  }

  function gearPath(g) {
    // simple involute-ish toothed wheel via alternating radii
    var Z = g.Z, ro = g.r + 4, ri = g.r - 4, rh = g.r * 0.35;
    var pts = '', i, ang, tooth = Math.PI * 2 / Z;
    for (i = 0; i < Z; i++) {
      var a0 = i * tooth, a1 = a0 + tooth * 0.32, a2 = a0 + tooth * 0.5, a3 = a0 + tooth * 0.82;
      pts += (i === 0 ? 'M ' : ' L ') + (g.cx + ri * Math.cos(a0)) + ' ' + (g.cy + ri * Math.sin(a0));
      pts += ' L ' + (g.cx + ro * Math.cos(a1)) + ' ' + (g.cy + ro * Math.sin(a1));
      pts += ' L ' + (g.cx + ro * Math.cos(a2)) + ' ' + (g.cy + ro * Math.sin(a2));
      pts += ' L ' + (g.cx + ri * Math.cos(a3)) + ' ' + (g.cy + ri * Math.sin(a3));
    }
    pts += ' Z';
    return pts;
  }

  function drawGears(rebuild) {
    var elt = el('g_svg');
    if (rebuild) {
      clr(elt);
      gearData.nodes = [];
      for (var i = 0; i < gearData.gears.length; i++) {
        var g = gearData.gears[i];
        var grp = svg(elt, 'g', {});
        var body = svg(grp, 'path', { d: gearPath(g), fill: g.color, 'fill-opacity': '0.20', stroke: g.color, 'stroke-width': 1.6 });
        svg(grp, 'circle', { cx: g.cx, cy: g.cy, r: g.r * 0.32, fill: 'none', stroke: g.color, 'stroke-width': 1.4 });
        svg(grp, 'circle', { cx: g.cx, cy: g.cy, r: 4, fill: g.color });
        // a spoke to show rotation
        svg(grp, 'line', { x1: g.cx, y1: g.cy, x2: g.cx + g.r * 0.85, y2: g.cy, stroke: g.color, 'stroke-width': 2, 'data-spoke': '1' });
        txt(elt, g.cx - 10, g.cy + g.r + 16, 'Z=' + g.Z, { fill: g.color, 'font-family': 'ui-monospace', 'font-size': '11', 'font-weight': '700' });
        gearData.nodes.push(grp);
      }
    }
    for (var j = 0; j < gearData.gears.length; j++) {
      var gg = gearData.gears[j];
      var deg = gg.phase * 180 / Math.PI;
      gearData.nodes[j].setAttribute('transform', 'rotate(' + deg + ' ' + gg.cx + ' ' + gg.cy + ')');
    }
  }

  /* ================================================================
     4. THERMO CYCLE  — Otto / Carnot air-standard
     ================================================================ */
  var cycType = 'otto';
  (function () {
    var seg = el('cycType').querySelectorAll('button');
    for (var i = 0; i < seg.length; i++) {
      (function (b) {
        b.addEventListener('click', function () {
          for (var j = 0; j < seg.length; j++) seg[j].classList.remove('on');
          b.classList.add('on'); cycType = b.getAttribute('data-c'); thermoUpdate();
        });
      })(seg[i]);
    }
    var ids = ['t_r', 't_g', 't_tc', 't_th'];
    for (var n = 0; n < ids.length; n++) el(ids[n]).addEventListener('input', thermoUpdate);
  })();

  function thermoUpdate() {
    var r = v('t_r'), g = v('t_g'), Tc = v('t_tc'), Th = v('t_th');
    if (Th <= Tc) Th = Tc + 50;
    el('t_rV').textContent = fmt(r, 1); el('t_gV').textContent = fmt(g, 2);
    el('t_tcV').textContent = fmt(Tc, 0); el('t_thV').textContent = fmt(Th, 0);

    var R = 0.287, cv = R / (g - 1); // kJ/kg·K for air
    var carnot = 1 - Tc / Th;
    var eff, qin, qout, wnet, mep, states, formula;

    if (cycType === 'otto') {
      // State 1: BDC (intake), V1=r*V2, T1=Tc, P1=100 kPa
      var P1 = 100, V1 = r, V2 = 1; // relative volumes
      var T1 = Tc;
      // 1-2 isentropic compression: T2 = T1 r^(g-1)
      var T2 = T1 * Math.pow(r, g - 1);
      var P2 = P1 * Math.pow(r, g);
      // 2-3 constant-volume heat addition to peak Th
      var T3 = Th, P3 = P2 * (T3 / T2);
      // 3-4 isentropic expansion
      var T4 = T3 * Math.pow(1 / r, g - 1);
      var P4 = P3 * Math.pow(1 / r, g);
      eff = 1 - 1 / Math.pow(r, g - 1);
      qin = cv * (T3 - T2);
      qout = cv * (T4 - T1);
      wnet = qin - qout;
      mep = wnet / (V1 - V2);
      states = [
        { P: P1, V: V1 }, { P: P2, V: V2 }, { P: P3, V: V2 }, { P: P4, V: V1 }
      ];
      formula = 'Otto: η = 1 − 1/r^(γ−1) = 1 − 1/' + fmt(r, 1) + '^' + fmt(g - 1, 2) + ' = <b>' + fmt(eff * 100, 1) + '%</b>';
    } else {
      // Carnot between Tc, Th. Efficiency = 1 - Tc/Th. Build P-V with two isotherms + two adiabats.
      eff = carnot;
      // choose V1..V4 from r as the expansion ratio along an isotherm
      var P1c = 200, V1c = 1;
      var T_h = Th, T_c = Tc;
      var V2c = V1c * r;                         // isothermal expansion at Th (1->2)
      var V3c = V2c * Math.pow(T_h / T_c, 1 / (g - 1)); // adiabatic expansion 2->3
      var V4c = V3c / r;                         // isothermal compression at Tc 3->4
      var Pof = function (V, T) { return P1c * V1c * T / (T_h * V); }; // PV = const*T (relative)
      states = [
        { P: Pof(V1c, T_h), V: V1c }, { P: Pof(V2c, T_h), V: V2c },
        { P: Pof(V3c, T_c), V: V3c }, { P: Pof(V4c, T_c), V: V4c }
      ];
      qin = R * T_h * Math.log(V2c / V1c);
      qout = R * T_c * Math.log(V3c / V4c);
      wnet = qin - qout;
      mep = wnet / (V3c - V1c);
      formula = 'Carnot: η = 1 − T_c/T_h = 1 − ' + fmt(Tc, 0) + '/' + fmt(Th, 0) + ' = <b>' + fmt(eff * 100, 1) + '%</b>';
    }

    el('t_eff').textContent = fmt(eff * 100, 1) + ' %';
    el('t_carn').textContent = fmt(carnot * 100, 1) + ' %';
    el('t_qin').textContent = fmt(qin, 1) + ' kJ/kg';
    el('t_qout').textContent = fmt(qout, 1) + ' kJ/kg';
    el('t_wnet').textContent = fmt(wnet, 1) + ' kJ/kg';
    el('t_mep').textContent = fmt(mep, 1);
    el('t_form').innerHTML = formula;

    drawPV(states, cycType, g);
  }

  function pvCurveSamples(a, b, cyc, g, leg) {
    // returns array of {P,V} from state a to b along the correct process
    var pts = [], i, n = 40, V, P;
    if (cyc === 'otto') {
      if (leg === 0 || leg === 2) { // isentropic legs (1->2 compression, 3->4 expansion)
        for (i = 0; i <= n; i++) {
          V = a.V + (b.V - a.V) * i / n;
          P = a.P * Math.pow(a.V / V, g);
          pts.push({ P: P, V: V });
        }
      } else { // constant volume legs -> straight vertical
        pts.push({ P: a.P, V: a.V }); pts.push({ P: b.P, V: b.V });
      }
    } else { // carnot
      if (leg === 0 || leg === 2) { // isotherms PV=const
        for (i = 0; i <= n; i++) {
          V = a.V + (b.V - a.V) * i / n;
          P = a.P * a.V / V;
          pts.push({ P: P, V: V });
        }
      } else { // adiabats
        for (i = 0; i <= n; i++) {
          V = a.V + (b.V - a.V) * i / n;
          P = a.P * Math.pow(a.V / V, g);
          pts.push({ P: P, V: V });
        }
      }
    }
    return pts;
  }

  function drawPV(states, cyc, g) {
    var elt = el('t_pv'); clr(elt);
    var W = 760, H = 460, padL = 64, padR = 24, padT = 20, padB = 46;
    var iw = W - padL - padR, ih = H - padT - padB;
    // gather all points to scale
    var legs = [], i;
    for (i = 0; i < 4; i++) legs.push(pvCurveSamples(states[i], states[(i + 1) % 4], cyc, g, i));
    var Vmin = Infinity, Vmax = -Infinity, Pmin = Infinity, Pmax = -Infinity, j, k;
    for (j = 0; j < legs.length; j++) for (k = 0; k < legs[j].length; k++) {
      var pt = legs[j][k];
      Vmin = Math.min(Vmin, pt.V); Vmax = Math.max(Vmax, pt.V);
      Pmin = Math.min(Pmin, pt.P); Pmax = Math.max(Pmax, pt.P);
    }
    Pmin = 0; Vmin = Math.max(0, Vmin - (Vmax - Vmin) * 0.05);
    Vmax *= 1.05; Pmax *= 1.1;
    var sx = function (V) { return padL + (V - Vmin) / (Vmax - Vmin) * iw; };
    var sy = function (P) { return padT + ih - (P - Pmin) / (Pmax - Pmin) * ih; };
    // grid
    for (i = 0; i <= 5; i++) {
      var gy = padT + ih * i / 5;
      svg(elt, 'line', { x1: padL, y1: gy, x2: padL + iw, y2: gy, stroke: '#16161f' });
      txt(elt, 8, gy + 4, fmt(Pmax * (1 - i / 5), 0), { fill: '#4b5563', 'font-family': 'ui-monospace', 'font-size': '10' });
    }
    for (i = 0; i <= 5; i++) {
      var gx = padL + iw * i / 5;
      svg(elt, 'line', { x1: gx, y1: padT, x2: gx, y2: padT + ih, stroke: '#16161f' });
      txt(elt, gx - 8, padT + ih + 16, fmt(Vmin + (Vmax - Vmin) * i / 5, 1), { fill: '#4b5563', 'font-family': 'ui-monospace', 'font-size': '10' });
    }
    txt(elt, padL + iw / 2 - 56, H - 8, 'volume  V (relative)', { fill: '#9aa6b6', 'font-family': 'ui-monospace', 'font-size': '11' });
    txt(elt, 12, padT - 6, 'pressure  P (kPa)', { fill: '#9aa6b6', 'font-family': 'ui-monospace', 'font-size': '11' });

    // filled cycle area
    var dFill = '';
    for (j = 0; j < legs.length; j++) for (k = 0; k < legs[j].length; k++) {
      dFill += (dFill === '' ? 'M ' : ' L ') + sx(legs[j][k].V) + ' ' + sy(legs[j][k].P);
    }
    dFill += ' Z';
    svg(elt, 'path', { d: dFill, fill: '#67e8f9', 'fill-opacity': '0.08', stroke: 'none' });

    // legs in distinct colours
    var legColors = (cyc === 'otto')
      ? ['#a78bfa', '#fbbf24', '#86efac', '#fca5a5']
      : ['#fbbf24', '#a78bfa', '#67e8f9', '#fca5a5'];
    for (j = 0; j < legs.length; j++) {
      var d = '';
      for (k = 0; k < legs[j].length; k++) d += (k === 0 ? 'M ' : ' L ') + sx(legs[j][k].V) + ' ' + sy(legs[j][k].P);
      svg(elt, 'path', { d: d, fill: 'none', stroke: legColors[j], 'stroke-width': 2.2 });
    }
    // state points
    var labels = ['1', '2', '3', '4'];
    for (i = 0; i < 4; i++) {
      svg(elt, 'circle', { cx: sx(states[i].V), cy: sy(states[i].P), r: 4.5, fill: '#e8e8ee', stroke: '#0a0a0c', 'stroke-width': 1.5 });
      txt(elt, sx(states[i].V) + 8, sy(states[i].P) - 6, labels[i], { fill: '#e8e8ee', 'font-family': 'ui-monospace', 'font-size': '12', 'font-weight': '700' });
    }
  }

  /* ================================================================
     Animation loop (gears)
     ================================================================ */
  var lastT = 0;
  function loop(ts) {
    var dt = lastT ? (ts - lastT) / 1000 : 0; lastT = ts;
    if (dt > 0.1) dt = 0.1;
    if (gearData) {
      // scale down real omega for visual comfort
      var scale = 0.06;
      for (var i = 0; i < gearData.gears.length; i++) {
        gearData.gears[i].phase += gearData.gears[i].omega * dt * scale;
      }
      drawGears(false);
    }
    requestAnimationFrame(loop);
  }

  /* ---------- init ---------- */
  beamUpdate();
  stressUpdate();
  gearCompute();
  thermoUpdate();
  requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
