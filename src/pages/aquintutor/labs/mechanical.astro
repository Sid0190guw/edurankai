              </div>
            </aside>
            <div>
              <div class="mz-panel">
                <h3>Meshing gear train</h3>
                <svg id="g_svg" class="mz-svg" viewBox="0 0 760 440" preserveAspectRatio="xMidYMid meet" style="background:radial-gradient(circle at 50% 45%,#14141c,#0a0a0c);"></svg>
                <div class="mz-formula">ratio i = Z_out / Z_in &nbsp;&middot;&nbsp; n_out = n_in / i &nbsp;&middot;&nbsp; T_out = T_in &times; i &times; &eta; &nbsp;(<b>&eta; = 0.97 / stage</b>)</div>
              </div>
