  var quizBuilt = {};
  function buildQuiz(id){
    if (quizBuilt[id]) return;
    var host = bodies[id].querySelector('.quiz');
    if (!host) return;
    var qs = QUIZ[id]; var html = "";
    for (var i = 0; i < qs.length; i++){
      html += '<div class="q" data-qi="' + i + '"><div class="qq">' + (i + 1) + ". " + qs[i].q + '</div>';
      for (var j = 0; j < qs[i].opts.length; j++){
        html += '<label class="opt"><input type="radio" name="' + id + '_q' + i + '" value="' + j + '"><span>' + qs[i].opts[j] + '</span></label>';
      }
      html += '<div class="expl"></div></div>';
    }
    html += '<div class="quizbar"><button class="btn" data-check="' + id + '">Check answers</button><span class="quizscore" data-score="' + id + '"></span></div>';
    host.innerHTML = html;
    host.querySelector('[data-check="' + id + '"]').addEventListener("click", function(){ checkQuiz(id, host); });
    quizBuilt[id] = true;
  }
  function checkQuiz(id, host){
    var qs = QUIZ[id]; var correct = 0;
    var blocks = host.querySelectorAll(".q");
    for (var i = 0; i < blocks.length; i++){
      var opts = blocks[i].querySelectorAll(".opt");
      var chosen = -1;
      for (var j = 0; j < opts.length; j++){
        opts[j].classList.remove("correct", "wrong");
        var radio = opts[j].querySelector("input");
        if (radio.checked) chosen = j;
      }
      for (var k = 0; k < opts.length; k++){
        if (k === qs[i].a) opts[k].classList.add("correct");
        else if (k === chosen) opts[k].classList.add("wrong");
      }
      if (chosen === qs[i].a) correct++;
      var ex = blocks[i].querySelector(".expl");
      ex.innerHTML = "<b>" + (chosen === qs[i].a ? "Correct." : "Answer: " + (qs[i].a + 1) + ".") + "</b> " + qs[i].ex;
      ex.classList.add("show");
    }
    host.querySelector('[data-score="' + id + '"]').textContent = "Score: " + correct + " / " + qs.length;
  }

  // ======================================================================
  // 1. LINEAR REGRESSION via GRADIENT DESCENT  (preserved verbatim)
  // ======================================================================
  var REG = (function(){
    var cv = document.getElementById("regCanvas"), ctx = cv.getContext("2d");
    var lc = document.getElementById("regLoss"), lctx = lc.getContext("2d");
    var W = cv.width, H = cv.height;
    var pts = [];           // data-space points {x:0..1, y:0..1}
    var w = 0, b = 0;       // model params (in normalised space)
    var epoch = 0, loss = NaN, lossHist = [], running = false, raf = null;
    var lr = 0.05;

    function lrFromSlider(){ lr = Math.pow(10, parseFloat(document.getElementById("regLr").value)); document.getElementById("regLrV").textContent = lr < 0.001 ? lr.toExponential(1) : fmt(lr, 4); }

    // map data [0,1] -> pixels
    function px(x){ return 40 + x * (W - 70); }
    function py(y){ return (H - 40) - y * (H - 70); }
    function invX(sx){ return (sx - 40) / (W - 70); }
    function invY(sy){ return ((H - 40) - sy) / (H - 70); }

    function reset(){ w = rnd(-0.5, 0.5); b = rnd(0.2, 0.6); epoch = 0; loss = NaN; lossHist = []; }

    function computeLoss(){
      if (!pts.length) return NaN;
      var s = 0;
      for (var i = 0; i < pts.length; i++){ var e = (w * pts[i].x + b) - pts[i].y; s += e * e; }
      return s / pts.length;
    }

    function step(){
      if (pts.length < 2) return;
      // gradients of MSE = (1/n) sum (w x + b - y)^2
      var gw = 0, gb = 0, n = pts.length;
      for (var i = 0; i < n; i++){
        var pr = w * pts[i].x + b;
        var err = pr - pts[i].y;
        gw += err * pts[i].x;
        gb += err;
      }
      gw = (2 / n) * gw; gb = (2 / n) * gb;
      w -= lr * gw; b -= lr * gb;
      epoch++;
      loss = computeLoss();
      lossHist.push(loss);
      if (lossHist.length > 600) lossHist.shift();
    }

    function r2(){
      if (pts.length < 2) return NaN;
      var mean = 0, i; for (i = 0; i < pts.length; i++) mean += pts[i].y; mean /= pts.length;
      var ssTot = 0, ssRes = 0;
      for (i = 0; i < pts.length; i++){
        var pr = w * pts[i].x + b;
        ssRes += (pts[i].y - pr) * (pts[i].y - pr);
        ssTot += (pts[i].y - mean) * (pts[i].y - mean);
      }
      return ssTot === 0 ? 0 : 1 - ssRes / ssTot;
    }

    function grid(){
      ctx.strokeStyle = "#1a1c24"; ctx.lineWidth = 1;
      for (var g = 0; g <= 10; g++){
        ctx.beginPath(); ctx.moveTo(px(g/10), py(0)); ctx.lineTo(px(g/10), py(1)); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(px(0), py(g/10)); ctx.lineTo(px(1), py(g/10)); ctx.stroke();
      }
      ctx.strokeStyle = "#2a2a35"; ctx.lineWidth = 1.5;
      ctx.beginPath(); ctx.moveTo(px(0), py(0)); ctx.lineTo(px(1), py(0)); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(px(0), py(0)); ctx.lineTo(px(0), py(1)); ctx.stroke();
    }

    function draw(){
      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = "#0a0a0c"; ctx.fillRect(0, 0, W, H);
      grid();
      // fitted line
      if (pts.length >= 1){
        ctx.strokeStyle = "#a78bfa"; ctx.lineWidth = 2.5;
        ctx.beginPath();
        var y0 = w * 0 + b, y1 = w * 1 + b;
        ctx.moveTo(px(0), py(clamp(y0, -0.5, 1.5))); ctx.lineTo(px(1), py(clamp(y1, -0.5, 1.5)));
        ctx.stroke();
      }
      // residuals + points
      for (var i = 0; i < pts.length; i++){
        var pr = w * pts[i].x + b;
        ctx.strokeStyle = "rgba(252,165,165,0.35)"; ctx.lineWidth = 1;
        ctx.beginPath(); ctx.moveTo(px(pts[i].x), py(pts[i].y)); ctx.lineTo(px(pts[i].x), py(pr)); ctx.stroke();
        ctx.fillStyle = "#67e8f9";
        ctx.beginPath(); ctx.arc(px(pts[i].x), py(pts[i].y), 4, 0, 6.2832); ctx.fill();
      }
      drawLoss();
      document.getElementById("regW").textContent = fmt(w, 3);
      document.getElementById("regB").textContent = fmt(b, 3);
      document.getElementById("regL").textContent = isFinite(loss) ? fmt(loss, 5) : "--";
      document.getElementById("regE").textContent = epoch;
      var r = r2(); document.getElementById("regR2").textContent = isFinite(r) ? fmt(r, 4) : "--";
    }

    function drawLoss(){
      lctx.clearRect(0, 0, lc.width, lc.height);
      lctx.fillStyle = "#0a0a0c"; lctx.fillRect(0, 0, lc.width, lc.height);
      lctx.fillStyle = "#9aa0aa"; lctx.font = "10px ui-monospace";
      lctx.fillText("MSE loss", 8, 14);
      if (lossHist.length < 2) return;
      var mx = 0; for (var i = 0; i < lossHist.length; i++) if (lossHist[i] > mx) mx = lossHist[i];
      if (mx <= 0) mx = 1;
      lctx.strokeStyle = "#fbbf24"; lctx.lineWidth = 2; lctx.beginPath();
      for (var j = 0; j < lossHist.length; j++){
        var x = 8 + j / (lossHist.length - 1) * (lc.width - 16);
        var y = lc.height - 12 - (lossHist[j] / mx) * (lc.height - 30);
        if (j === 0) lctx.moveTo(x, y); else lctx.lineTo(x, y);
      }
      lctx.stroke();
    }

    function loop(){ if (!running) return; for (var s = 0; s < 3; s++) step(); draw(); if (loss < 1e-7 && epoch > 30){ running = false; document.getElementById("regRun").textContent = "Train"; return; } raf = requestAnimationFrame(loop); }

    function seedSample(){
      pts = [];
      var tw = rnd(0.5, 1.4), tb = rnd(0.05, 0.4);
      for (var i = 0; i < 26; i++){ var x = rnd(0.04, 0.96); var y = clamp(tw * x + tb + gauss() * 0.06, 0.01, 0.99); pts.push({ x: x, y: y }); }
      reset(); draw();
    }

    cv.addEventListener("click", function(e){
      var p = evtXY(cv, e);
      var x = invX(p.x), y = invY(p.y);
      if (x < -0.02 || x > 1.02 || y < -0.02 || y > 1.02) return;
      pts.push({ x: clamp(x, 0, 1), y: clamp(y, 0, 1) });
      loss = computeLoss(); draw();
    });
    document.getElementById("regLr").addEventListener("input", lrFromSlider);
    document.getElementById("regRun").addEventListener("click", function(){
      if (pts.length < 2) return;
      running = !running; this.textContent = running ? "Pause" : "Train";
      if (running) loop();
    });
    document.getElementById("regStep").addEventListener("click", function(){ for (var s = 0; s < 5; s++) step(); draw(); });
    document.getElementById("regSeed").addEventListener("click", seedSample);
    document.getElementById("regClear").addEventListener("click", function(){ pts = []; reset(); draw(); });

    lrFromSlider(); reset(); seedSample();
    return { draw: draw };
  })();

  // ======================================================================
  // 2. LOGISTIC REGRESSION (NEW): sigmoid + BCE, gradient descent
  // ======================================================================
  var LOGIT = (function(){
    var cv = document.getElementById("lgCanvas"), ctx = cv.getContext("2d");
    var lc = document.getElementById("lgLoss"), lctx = lc.getContext("2d");
    var W = cv.width, H = cv.height;
    var pts = [];                    // {x:0..1, y:0..1, c:0|1}
    var w1 = 0, w2 = 0, b = 0;       // weights in normalised feature space
    var loss = NaN, acc = NaN, lossHist = [], running = false, raf = null;
    var lr = 0.5, activeClass = 0;

    function sigmoid(z){ if (z < -30) return 0; if (z > 30) return 1; return 1 / (1 + Math.exp(-z)); }
    function lrFromSlider(){ lr = Math.pow(10, parseFloat(document.getElementById("lgLr").value)); document.getElementById("lgLrV").textContent = fmt(lr, lr < 0.1 ? 3 : 2); }
    function reset(){ w1 = rnd(-0.4, 0.4); w2 = rnd(-0.4, 0.4); b = 0; loss = NaN; acc = NaN; lossHist = []; }

    function feat(p){ return [(p.x - 0.5) * 4, (p.y - 0.5) * 4]; } // scale to ~[-2,2]

    function step(){
      if (pts.length < 2) return;
      var gw1 = 0, gw2 = 0, gb = 0, n = pts.length, totLoss = 0, correct = 0;
      for (var i = 0; i < n; i++){
        var f = feat(pts[i]);
        var z = w1 * f[0] + w2 * f[1] + b;
        var p = sigmoid(z), y = pts[i].c;
        var err = p - y;
        gw1 += err * f[0]; gw2 += err * f[1]; gb += err;
        var pc = clamp(p, 1e-7, 1 - 1e-7);
        totLoss += -(y * Math.log(pc) + (1 - y) * Math.log(1 - pc));
        if ((p > 0.5 ? 1 : 0) === y) correct++;
      }
      w1 -= lr * gw1 / n; w2 -= lr * gw2 / n; b -= lr * gb / n;
      loss = totLoss / n; acc = correct / n;
      lossHist.push(loss); if (lossHist.length > 600) lossHist.shift();
    }

    function recompute(){
      if (pts.length < 1){ loss = NaN; acc = NaN; return; }
      var n = pts.length, totLoss = 0, correct = 0;
      for (var i = 0; i < n; i++){
        var f = feat(pts[i]);
        var p = sigmoid(w1 * f[0] + w2 * f[1] + b), y = pts[i].c;
        var pc = clamp(p, 1e-7, 1 - 1e-7);
        totLoss += -(y * Math.log(pc) + (1 - y) * Math.log(1 - pc));
        if ((p > 0.5 ? 1 : 0) === y) correct++;
      }
      loss = totLoss / n; acc = correct / n;
    }

    function render(){
      ctx.clearRect(0, 0, W, H); ctx.fillStyle = "#0a0a0c"; ctx.fillRect(0, 0, W, H);
      // probability surface
      var cell = 10, img = ctx.createImageData(W, H);
      for (var gy = 0; gy < H; gy += cell){
        for (var gx = 0; gx < W; gx += cell){
          var nx = (gx + cell / 2) / W, ny = (gy + cell / 2) / H;
          var f = feat({ x: nx, y: ny });
          var p = sigmoid(w1 * f[0] + w2 * f[1] + b);
          var t = clamp((p - 0.5) * 2, -1, 1), rr, gg, bb;
          if (t >= 0){ rr = 80 + t * 171; gg = 60 + t * 131; bb = 30; }
          else { var u = -t; rr = 40; gg = 60 + u * 172; bb = 60 + u * 189; }
          for (var yy = gy; yy < gy + cell && yy < H; yy++){
            for (var xx = gx; xx < gx + cell && xx < W; xx++){
              var idx = (yy * W + xx) * 4;
              img.data[idx] = rr; img.data[idx + 1] = gg; img.data[idx + 2] = bb; img.data[idx + 3] = 60;
            }
          }
        }
      }
      ctx.putImageData(img, 0, 0);
      // decision boundary: w1*f1 + w2*f2 + b = 0, with f = (x-0.5)*4
      // => w1*(x-0.5)*4 + w2*(y-0.5)*4 + b = 0. Solve for y across x in [0,1].
      if (Math.abs(w2) > 1e-6){
        ctx.strokeStyle = "#ffffff"; ctx.lineWidth = 2; ctx.beginPath();
        var drawn = false;
        for (var sx = 0; sx <= 1.0001; sx += 0.02){
          var fx = (sx - 0.5) * 4;
          var fy = -(w1 * fx + b) / w2;
          var yy2 = fy / 4 + 0.5;
          var X = sx * W, Y = yy2 * H;
          if (!drawn){ ctx.moveTo(X, Y); drawn = true; } else ctx.lineTo(X, Y);
        }
        ctx.stroke();
      }
      // points
      for (var i = 0; i < pts.length; i++){
        ctx.fillStyle = pts[i].c === 1 ? "#fbbf24" : "#67e8f9";
        ctx.strokeStyle = "#0a0a0c"; ctx.lineWidth = 1.4;
        ctx.beginPath(); ctx.arc(pts[i].x * W, pts[i].y * H, 5, 0, 6.2832); ctx.fill(); ctx.stroke();
      }
      drawLoss();
      document.getElementById("lgW1").textContent = fmt(w1, 3);
      document.getElementById("lgW2").textContent = fmt(w2, 3);
      document.getElementById("lgL").textContent = isFinite(loss) ? fmt(loss, 4) : "--";
      document.getElementById("lgAcc").textContent = isFinite(acc) ? (acc * 100).toFixed(1) + "%" : "--";
    }

    function drawLoss(){
      lctx.clearRect(0, 0, lc.width, lc.height); lctx.fillStyle = "#0a0a0c"; lctx.fillRect(0, 0, lc.width, lc.height);
      lctx.fillStyle = "#9aa0aa"; lctx.font = "10px ui-monospace"; lctx.fillText("BCE loss", 8, 14);
      if (lossHist.length < 2) return;
      var mx = 0; for (var i = 0; i < lossHist.length; i++) if (lossHist[i] > mx) mx = lossHist[i];
      if (mx <= 0) mx = 1;
      lctx.strokeStyle = "#a78bfa"; lctx.lineWidth = 2; lctx.beginPath();
      for (var j = 0; j < lossHist.length; j++){
        var x = 8 + j / (lossHist.length - 1) * (lc.width - 16);
        var y = lc.height - 12 - (lossHist[j] / mx) * (lc.height - 26);
        if (j === 0) lctx.moveTo(x, y); else lctx.lineTo(x, y);
      }
      lctx.stroke();
    }

    function loop(){ if (!running) return; for (var s = 0; s < 4; s++) step(); render(); raf = requestAnimationFrame(loop); }

    function seedSample(){
      pts = [];
      var ang = rnd(0, Math.PI), dx = Math.cos(ang) * 0.22, dy = Math.sin(ang) * 0.22;
      for (var i = 0; i < 24; i++) pts.push({ x: clamp(0.5 - dx + gauss() * 0.07, 0.03, 0.97), y: clamp(0.5 - dy + gauss() * 0.07, 0.03, 0.97), c: 0 });
      for (i = 0; i < 24; i++) pts.push({ x: clamp(0.5 + dx + gauss() * 0.07, 0.03, 0.97), y: clamp(0.5 + dy + gauss() * 0.07, 0.03, 0.97), c: 1 });
      reset(); recompute(); render();
    }

    cv.addEventListener("click", function(e){ var p = evtXY(cv, e); pts.push({ x: clamp(p.x / W, 0, 1), y: clamp(p.y / H, 0, 1), c: activeClass }); recompute(); render(); });
    var seg = document.getElementById("lgSeg").querySelectorAll("button");
    for (var s = 0; s < seg.length; s++){
      (function(btn){ btn.addEventListener("click", function(){ for (var z = 0; z < seg.length; z++) seg[z].classList.remove("on"); btn.classList.add("on"); activeClass = parseInt(btn.getAttribute("data-cls"), 10); }); })(seg[s]);
    }
    document.getElementById("lgLr").addEventListener("input", lrFromSlider);
    document.getElementById("lgRun").addEventListener("click", function(){ if (pts.length < 2) return; running = !running; this.textContent = running ? "Pause" : "Train"; if (running) loop(); });
    document.getElementById("lgStep").addEventListener("click", function(){ for (var s2 = 0; s2 < 8; s2++) step(); render(); });
    document.getElementById("lgSeed").addEventListener("click", seedSample);
    document.getElementById("lgClear").addEventListener("click", function(){ pts = []; reset(); render(); });

    lrFromSlider(); reset(); seedSample();
    return { render: render };
  })();

  // ======================================================================
  // 3. k-NN CLASSIFIER  (preserved verbatim)
  // ======================================================================
  var KNN = (function(){
    var cv = document.getElementById("knnCanvas"), ctx = cv.getContext("2d");
    var W = cv.width, H = cv.height;
    var pts = [];          // {x,y,c}
    var activeClass = 0, k = 5;
    var cols = ["#67e8f9", "#fbbf24"];
    var fills = [[103,232,249], [251,191,36]];

    function classifyAt(x, y){
      if (pts.length === 0) return -1;
      // partial selection of k nearest via array of distances
      var ds = [];
      for (var i = 0; i < pts.length; i++){
        var dx = pts[i].x - x, dy = pts[i].y - y;
        ds.push({ d: dx * dx + dy * dy, c: pts[i].c });
      }
      ds.sort(function(a, b){ return a.d - b.d; });
      var kk = Math.min(k, ds.length), v0 = 0, v1 = 0;
      for (var j = 0; j < kk; j++){ if (ds[j].c === 0) v0++; else v1++; }
      return v0 === v1 ? (ds[0].c) : (v0 > v1 ? 0 : 1);
    }
    function render(){
      ctx.clearRect(0, 0, W, H); ctx.fillStyle = "#0a0a0c"; ctx.fillRect(0, 0, W, H);
      var cell = 10;
      if (pts.length > 0){
        var img = ctx.createImageData(W, H);
        for (var gy = 0; gy < H; gy += cell){
          for (var gx = 0; gx < W; gx += cell){
            var c = classifyAt(gx + cell / 2, gy + cell / 2);
            var rgb = c < 0 ? [20, 22, 30] : fills[c];
            for (var yy = gy; yy < gy + cell && yy < H; yy++){
              for (var xx = gx; xx < gx + cell && xx < W; xx++){
                var idx = (yy * W + xx) * 4;
                img.data[idx] = rgb[0]; img.data[idx + 1] = rgb[1]; img.data[idx + 2] = rgb[2]; img.data[idx + 3] = c < 0 ? 255 : 46;
              }
            }
          }
        }
        ctx.putImageData(img, 0, 0);
      }
      for (var i = 0; i < pts.length; i++){
        ctx.fillStyle = cols[pts[i].c]; ctx.strokeStyle = "#0a0a0c"; ctx.lineWidth = 1.5;
        ctx.beginPath(); ctx.arc(pts[i].x, pts[i].y, 5, 0, 6.2832); ctx.fill(); ctx.stroke();
      }
      var a = 0, b = 0; for (var p = 0; p < pts.length; p++){ if (pts[p].c === 0) a++; else b++; }
      document.getElementById("knnA").textContent = a;
      document.getElementById("knnB").textContent = b;
    }
    function seedSample(){
      pts = [];
      var i;
      for (i = 0; i < 22; i++) pts.push({ x: clamp(rnd(0.15, 0.45) * W + gauss() * 30, 6, W - 6), y: clamp(rnd(0.2, 0.7) * H + gauss() * 30, 6, H - 6), c: 0 });
      for (i = 0; i < 22; i++) pts.push({ x: clamp(rnd(0.55, 0.85) * W + gauss() * 30, 6, W - 6), y: clamp(rnd(0.3, 0.8) * H + gauss() * 30, 6, H - 6), c: 1 });
      render();
    }
    cv.addEventListener("click", function(e){ var p = evtXY(cv, e); pts.push({ x: p.x, y: p.y, c: activeClass }); render(); });
    var seg = document.getElementById("knnSeg").querySelectorAll("button");
    for (var s = 0; s < seg.length; s++){
      (function(btn){ btn.addEventListener("click", function(){ for (var z = 0; z < seg.length; z++) seg[z].classList.remove("on"); btn.classList.add("on"); activeClass = parseInt(btn.getAttribute("data-cls"), 10); }); })(seg[s]);
    }
    document.getElementById("knnK").addEventListener("input", function(){ k = parseInt(this.value, 10); document.getElementById("knnKV").textContent = k; render(); });
    document.getElementById("knnSeed").addEventListener("click", seedSample);
    document.getElementById("knnClear").addEventListener("click", function(){ pts = []; render(); });

    seedSample();
    return { render: render };
  })();

  // ======================================================================
  // 4. K-MEANS (Lloyd's algorithm)  (preserved verbatim)
  // ======================================================================
  var KM = (function(){
    var cv = document.getElementById("kmCanvas"), ctx = cv.getContext("2d");
    var W = cv.width, H = cv.height;
    var palette = ["#67e8f9", "#a78bfa", "#fbbf24", "#86efac", "#fca5a5", "#f0abfc"];
    var pts = [], cents = [], assign = [], K = 3, N = 220;
    var iter = 0, inertia = NaN, moved = NaN, running = false, raf = null, converged = false;

    function seed(){
      pts = []; iter = 0; inertia = NaN; converged = false;
      var blobs = 2 + ((Math.random() * 4) | 0);
      var centers = [];
      for (var b = 0; b < blobs; b++) centers.push({ x: rnd(0.12, 0.88) * W, y: rnd(0.12, 0.88) * H });
      for (var i = 0; i < N; i++){
        var c = centers[(Math.random() * blobs) | 0];
        var spread = Math.min(W, H) * 0.07;
        pts.push({ x: clamp(c.x + gauss() * spread, 4, W - 4), y: clamp(c.y + gauss() * spread, 4, H - 4) });
      }
      initCents();
    }
    function initCents(){
      // k-means++ style: first random, rest by distance weighting
      cents = []; assign = [];
      cents.push({ x: pts[(Math.random() * pts.length) | 0].x, y: pts[(Math.random() * pts.length) | 0].y });
      while (cents.length < K){
        var d2 = [], sum = 0, i, j;
        for (i = 0; i < pts.length; i++){
          var best = Infinity;
          for (j = 0; j < cents.length; j++){
            var dx = pts[i].x - cents[j].x, dy = pts[i].y - cents[j].y, d = dx * dx + dy * dy;
            if (d < best) best = d;
          }
          d2.push(best); sum += best;
        }
        var r = Math.random() * sum, acc = 0, pick = 0;
        for (i = 0; i < pts.length; i++){ acc += d2[i]; if (acc >= r){ pick = i; break; } }
        cents.push({ x: pts[pick].x, y: pts[pick].y });
      }
      assignAll(); iter = 0; converged = false;
    }
    function assignAll(){
      inertia = 0;
      for (var i = 0; i < pts.length; i++){
        var best = Infinity, bi = 0;
        for (var c = 0; c < cents.length; c++){
          var dx = pts[i].x - cents[c].x, dy = pts[i].y - cents[c].y, d = dx * dx + dy * dy;
          if (d < best){ best = d; bi = c; }
        }
        assign[i] = bi; inertia += best;
      }
    }
    function step(){
      if (converged) return;
      // recompute centroids = mean of assigned points
      var sumx = [], sumy = [], cnt = [], c;
      for (c = 0; c < K; c++){ sumx[c] = 0; sumy[c] = 0; cnt[c] = 0; }
      for (var i = 0; i < pts.length; i++){ var a = assign[i]; sumx[a] += pts[i].x; sumy[a] += pts[i].y; cnt[a]++; }
      moved = 0;
      for (c = 0; c < K; c++){
        if (cnt[c] === 0){ continue; }
        var nx = sumx[c] / cnt[c], ny = sumy[c] / cnt[c];
        moved += Math.sqrt((nx - cents[c].x) * (nx - cents[c].x) + (ny - cents[c].y) * (ny - cents[c].y));
        cents[c].x = nx; cents[c].y = ny;
      }
      assignAll();
      iter++;
      if (moved < 0.4){ converged = true; }
    }
    function draw(){
      ctx.clearRect(0, 0, W, H); ctx.fillStyle = "#0a0a0c"; ctx.fillRect(0, 0, W, H);
      for (var i = 0; i < pts.length; i++){
        ctx.fillStyle = palette[assign[i] % palette.length];
        ctx.globalAlpha = 0.85;
        ctx.beginPath(); ctx.arc(pts[i].x, pts[i].y, 3.2, 0, 6.2832); ctx.fill();
      }
      ctx.globalAlpha = 1;
      for (var c = 0; c < cents.length; c++){
        ctx.strokeStyle = "#e8e8ee"; ctx.lineWidth = 3;
        var s = 9, cx = cents[c].x, cy = cents[c].y;
        ctx.beginPath(); ctx.moveTo(cx - s, cy); ctx.lineTo(cx + s, cy); ctx.moveTo(cx, cy - s); ctx.lineTo(cx, cy + s); ctx.stroke();
        ctx.strokeStyle = palette[c % palette.length]; ctx.lineWidth = 1.5;
        ctx.beginPath(); ctx.arc(cx, cy, 12, 0, 6.2832); ctx.stroke();
      }
      document.getElementById("kmIt").textContent = iter;
      document.getElementById("kmIn").textContent = isFinite(inertia) ? (inertia / 1000).toFixed(1) + "k" : "--";
      document.getElementById("kmMv").textContent = isFinite(moved) ? fmt(moved, 1) : "--";
      document.getElementById("kmSt").textContent = converged ? "converged" : (running ? "running" : "ready");
    }
    function loop(){ if (!running) return; step(); draw(); if (converged){ running = false; document.getElementById("kmRun").textContent = "Run Lloyd"; return; } raf = requestAnimationFrame(function(){ setTimeout(loop, 260); }); }

    document.getElementById("kmK").addEventListener("input", function(){ K = parseInt(this.value, 10); document.getElementById("kmKV").textContent = K; initCents(); draw(); });
    document.getElementById("kmN").addEventListener("input", function(){ N = parseInt(this.value, 10); document.getElementById("kmNV").textContent = N; seed(); draw(); });
    document.getElementById("kmRun").addEventListener("click", function(){ if (converged) initCents(); running = !running; this.textContent = running ? "Pause" : "Run Lloyd"; if (running) loop(); });
    document.getElementById("kmStep").addEventListener("click", function(){ step(); draw(); });
    document.getElementById("kmReseed").addEventListener("click", function(){ seed(); draw(); });

    seed(); draw();
    return { draw: draw };
  })();

  // ======================================================================
  // 5. DECISION TREE (NEW): recursive Gini/entropy splits on 2D points
  // ======================================================================
  var TREE = (function(){
    var cv = document.getElementById("trCanvas"), ctx = cv.getContext("2d");
    var W = cv.width, H = cv.height;
    var pts = [];            // {x:0..1, y:0..1, c:0|1}
    var activeClass = 0, criterion = "gini", maxDepth = 3;
    var root = null, leafCount = 0, depthUsed = 0;
    var cols = ["#67e8f9", "#fbbf24"];
    var fills = [[103,232,249], [251,191,36]];

    function impurity(subset){
      var n = subset.length; if (n === 0) return 0;
      var n1 = 0; for (var i = 0; i < n; i++) if (subset[i].c === 1) n1++;
      var p1 = n1 / n, p0 = 1 - p1;
      if (criterion === "gini") return 1 - p0 * p0 - p1 * p1;
      // entropy (log2)
      var h = 0;
      if (p0 > 0) h -= p0 * Math.log(p0) / Math.log(2);
      if (p1 > 0) h -= p1 * Math.log(p1) / Math.log(2);
      return h;
    }
    function majority(subset){
      var n1 = 0; for (var i = 0; i < subset.length; i++) if (subset[i].c === 1) n1++;
      return n1 * 2 >= subset.length ? 1 : 0;
    }
    function bestSplit(subset){
      var parentI = impurity(subset), n = subset.length;
      var best = null, bestGain = 1e-9;
      for (var feat = 0; feat < 2; feat++){
        // candidate thresholds = midpoints of sorted unique values
        var vals = [];
        for (var i = 0; i < n; i++) vals.push(feat === 0 ? subset[i].x : subset[i].y);
        vals.sort(function(a, b){ return a - b; });
        for (var t = 0; t < n - 1; t++){
          if (vals[t] === vals[t + 1]) continue;
          var thr = (vals[t] + vals[t + 1]) / 2;
          var L = [], R = [];
          for (i = 0; i < n; i++){
            var v = feat === 0 ? subset[i].x : subset[i].y;
            if (v <= thr) L.push(subset[i]); else R.push(subset[i]);
          }
          if (L.length === 0 || R.length === 0) continue;
          var gain = parentI - (L.length / n) * impurity(L) - (R.length / n) * impurity(R);
          if (gain > bestGain){ bestGain = gain; best = { feat: feat, thr: thr, L: L, R: R }; }
        }
      }
      return best;
    }
    function buildNode(subset, depth){
      var node = { leaf: true, cls: majority(subset), count: subset.length, depth: depth };
      if (depth >= depthUsed) depthUsed = depth;
      if (depth >= maxDepth || subset.length < 2 || impurity(subset) < 1e-9){ leafCount++; return node; }
      var sp = bestSplit(subset);
      if (!sp){ leafCount++; return node; }
      node.leaf = false; node.feat = sp.feat; node.thr = sp.thr;
      node.L = buildNode(sp.L, depth + 1);
      node.R = buildNode(sp.R, depth + 1);
      return node;
    }
    function predict(node, x, y){
      while (!node.leaf){
        var v = node.feat === 0 ? x : y;
        node = (v <= node.thr) ? node.L : node.R;
      }
      return node.cls;
    }
    function build(){
      if (pts.length < 2){ root = null; render(); return; }
      root = null; leafCount = 0; depthUsed = 0;
      root = buildNode(pts.slice(), 0);
      render();
    }
    function accuracy(){
      if (!root || pts.length === 0) return NaN;
      var correct = 0;
      for (var i = 0; i < pts.length; i++) if (predict(root, pts[i].x, pts[i].y) === pts[i].c) correct++;
      return correct / pts.length;
    }
    // recursively paint a region [x0,x1]x[y0,y1] in normalised coords
    function paintNode(node, x0, x1, y0, y1){
      if (node.leaf){
        var rgb = fills[node.cls];
        ctx.fillStyle = "rgba(" + rgb[0] + "," + rgb[1] + "," + rgb[2] + ",0.20)";
        ctx.fillRect(x0 * W, y0 * H, (x1 - x0) * W, (y1 - y0) * H);
        return;
      }
      if (node.feat === 0){
        paintNode(node.L, x0, node.thr, y0, y1);
        paintNode(node.R, node.thr, x1, y0, y1);
        ctx.strokeStyle = "rgba(255,255,255,0.55)"; ctx.lineWidth = 1.2;
        ctx.beginPath(); ctx.moveTo(node.thr * W, y0 * H); ctx.lineTo(node.thr * W, y1 * H); ctx.stroke();
      } else {
        paintNode(node.L, x0, x1, y0, node.thr);
        paintNode(node.R, x0, x1, node.thr, y1);
        ctx.strokeStyle = "rgba(255,255,255,0.55)"; ctx.lineWidth = 1.2;
        ctx.beginPath(); ctx.moveTo(x0 * W, node.thr * H); ctx.lineTo(x1 * W, node.thr * H); ctx.stroke();
      }
    }
    function render(){
      ctx.clearRect(0, 0, W, H); ctx.fillStyle = "#0a0a0c"; ctx.fillRect(0, 0, W, H);
      if (root) paintNode(root, 0, 1, 0, 1);
      for (var i = 0; i < pts.length; i++){
        ctx.fillStyle = cols[pts[i].c]; ctx.strokeStyle = "#0a0a0c"; ctx.lineWidth = 1.4;
        ctx.beginPath(); ctx.arc(pts[i].x * W, pts[i].y * H, 5, 0, 6.2832); ctx.fill(); ctx.stroke();
      }
      document.getElementById("trLeaves").textContent = root ? leafCount : "--";
      document.getElementById("trUsed").textContent = root ? depthUsed : "--";
      var ac = accuracy();
      document.getElementById("trAcc").textContent = isFinite(ac) ? (ac * 100).toFixed(1) + "%" : "--";
      document.getElementById("trN").textContent = pts.length;
    }
    function seedSample(){
      pts = [];
      // XOR-like four blobs: diagonal pairs share a class
      var centers = [ {x:0.28,y:0.28,c:0}, {x:0.72,y:0.72,c:0}, {x:0.72,y:0.28,c:1}, {x:0.28,y:0.72,c:1} ];
      for (var b = 0; b < centers.length; b++){
        for (var i = 0; i < 16; i++){
          pts.push({ x: clamp(centers[b].x + gauss() * 0.08, 0.02, 0.98), y: clamp(centers[b].y + gauss() * 0.08, 0.02, 0.98), c: centers[b].c });
        }
      }
      root = null; render();
    }
    cv.addEventListener("click", function(e){ var p = evtXY(cv, e); pts.push({ x: clamp(p.x / W, 0, 1), y: clamp(p.y / H, 0, 1), c: activeClass }); root = null; render(); });
    var seg = document.getElementById("trSeg").querySelectorAll("button");
    for (var s = 0; s < seg.length; s++){
      (function(btn){ btn.addEventListener("click", function(){ for (var z = 0; z < seg.length; z++) seg[z].classList.remove("on"); btn.classList.add("on"); activeClass = parseInt(btn.getAttribute("data-cls"), 10); }); })(seg[s]);
    }
    var cseg = document.getElementById("trCrit").querySelectorAll("button");
    for (var cs = 0; cs < cseg.length; cs++){
      (function(btn){ btn.addEventListener("click", function(){ for (var z = 0; z < cseg.length; z++) cseg[z].classList.remove("on"); btn.classList.add("on"); criterion = btn.getAttribute("data-crit"); }); })(cseg[cs]);
    }
    document.getElementById("trDepth").addEventListener("input", function(){ maxDepth = parseInt(this.value, 10); document.getElementById("trDepthV").textContent = maxDepth; });
    document.getElementById("trBuild").addEventListener("click", build);
    document.getElementById("trSeed").addEventListener("click", seedSample);
    document.getElementById("trClear").addEventListener("click", function(){ pts = []; root = null; render(); });

    seedSample();
    return { render: render };
  })();

  // ======================================================================
  // 6. PCA (NEW): covariance + power iteration -> principal axes
  // ======================================================================
  var PCA = (function(){
    var cv = document.getElementById("pcaCanvas"), ctx = cv.getContext("2d");
    var W = cv.width, H = cv.height;
    var pts = [];            // {x:0..1, y:0..1}
    var mean = null, v1 = null, v2 = null, l1 = NaN, l2 = NaN, iters = 0, showProj = true;

    function compute(){
      var n = pts.length;
      if (n < 2){ mean = null; v1 = null; v2 = null; l1 = NaN; l2 = NaN; iters = 0; return; }
      // center
      var mx = 0, my = 0, i;
      for (i = 0; i < n; i++){ mx += pts[i].x; my += pts[i].y; }
      mx /= n; my /= n; mean = { x: mx, y: my };
      // 2x2 covariance
      var cxx = 0, cxy = 0, cyy = 0;
      for (i = 0; i < n; i++){ var dx = pts[i].x - mx, dy = pts[i].y - my; cxx += dx * dx; cxy += dx * dy; cyy += dy * dy; }
      cxx /= n; cxy /= n; cyy /= n;
      // power iteration for top eigenvector
      var vx = rnd(-1, 1), vy = rnd(-1, 1), nrm = Math.sqrt(vx * vx + vy * vy) || 1; vx /= nrm; vy /= nrm;
      iters = 0; var prevx = 0, prevy = 0;
      for (var it = 0; it < 200; it++){
        var nx = cxx * vx + cxy * vy;
        var ny = cxy * vx + cyy * vy;
        var m = Math.sqrt(nx * nx + ny * ny);
        if (m < 1e-12) break;
        nx /= m; ny /= m;
        iters++;
        // fix sign for stability
        if (nx * vx + ny * vy < 0){ nx = -nx; ny = -ny; }
        if (Math.abs(nx - vx) < 1e-9 && Math.abs(ny - vy) < 1e-9){ vx = nx; vy = ny; break; }
        vx = nx; vy = ny;
      }
      // Rayleigh quotient = top eigenvalue
      l1 = vx * (cxx * vx + cxy * vy) + vy * (cxy * vx + cyy * vy);
      // second eigenvector orthogonal in 2D; eigenvalue via trace
      v1 = { x: vx, y: vy };
      v2 = { x: -vy, y: vx };
      l2 = (cxx + cyy) - l1;
      if (l2 < 0) l2 = 0;
    }

    function arrow(cx, cy, dx, dy, len, color){
      var ex = cx + dx * len, ey = cy + dy * len;
      ctx.strokeStyle = color; ctx.fillStyle = color; ctx.lineWidth = 2.5;
      ctx.beginPath(); ctx.moveTo(cx, cy); ctx.lineTo(ex, ey); ctx.stroke();
      // head
      var ang = Math.atan2(ey - cy, ex - cx), s = 9;
      ctx.beginPath();
      ctx.moveTo(ex, ey);
      ctx.lineTo(ex - s * Math.cos(ang - 0.4), ey - s * Math.sin(ang - 0.4));
      ctx.lineTo(ex - s * Math.cos(ang + 0.4), ey - s * Math.sin(ang + 0.4));
      ctx.closePath(); ctx.fill();
    }
    function draw(){
      ctx.clearRect(0, 0, W, H); ctx.fillStyle = "#0a0a0c"; ctx.fillRect(0, 0, W, H);
      // faint grid
      ctx.strokeStyle = "#15171f"; ctx.lineWidth = 1;
      for (var g = 1; g < 10; g++){ ctx.beginPath(); ctx.moveTo(g / 10 * W, 0); ctx.lineTo(g / 10 * W, H); ctx.stroke(); ctx.beginPath(); ctx.moveTo(0, g / 10 * H); ctx.lineTo(W, g / 10 * H); ctx.stroke(); }
      // projections onto PC1
      if (mean && v1 && showProj){
        var cx = mean.x * W, cy = mean.y * H;
        var ax = v1.x * W, ay = v1.y * H, alen = Math.sqrt(ax * ax + ay * ay) || 1;
        var ux = ax / alen, uy = ay / alen; // unit direction in pixels
        ctx.strokeStyle = "rgba(251,191,36,0.4)"; ctx.lineWidth = 1;
        for (var i = 0; i < pts.length; i++){
          var pxp = pts[i].x * W, pyp = pts[i].y * H;
          var t = (pxp - cx) * ux + (pyp - cy) * uy;
          var projx = cx + t * ux, projy = cy + t * uy;
          ctx.beginPath(); ctx.moveTo(pxp, pyp); ctx.lineTo(projx, projy); ctx.stroke();
          ctx.fillStyle = "rgba(251,191,36,0.8)";
          ctx.beginPath(); ctx.arc(projx, projy, 2.4, 0, 6.2832); ctx.fill();
        }
      }
      // points
      for (var p = 0; p < pts.length; p++){
        ctx.fillStyle = "#e8e8ee"; ctx.strokeStyle = "#0a0a0c"; ctx.lineWidth = 1.2;
        ctx.beginPath(); ctx.arc(pts[p].x * W, pts[p].y * H, 4, 0, 6.2832); ctx.fill(); ctx.stroke();
      }
      // axes
      if (mean && v1){
        var ccx = mean.x * W, ccy = mean.y * H;
        var sc1 = 60 + Math.sqrt(Math.max(l1, 0)) * 900;
        var sc2 = 40 + Math.sqrt(Math.max(l2, 0)) * 900;
        // draw both directions of PC1
        arrow(ccx, ccy, v1.x, v1.y, sc1, "#67e8f9");
        arrow(ccx, ccy, -v1.x, -v1.y, sc1, "#67e8f9");
        arrow(ccx, ccy, v2.x, v2.y, sc2, "#a78bfa");
        arrow(ccx, ccy, -v2.x, -v2.y, sc2, "#a78bfa");
        ctx.fillStyle = "#86efac"; ctx.beginPath(); ctx.arc(ccx, ccy, 4, 0, 6.2832); ctx.fill();
      }
      var tot = (l1 + l2);
      document.getElementById("pcaL1").textContent = isFinite(l1) ? (l1 * 1000).toFixed(2) : "--";
      document.getElementById("pcaL2").textContent = isFinite(l2) ? (l2 * 1000).toFixed(2) : "--";
      document.getElementById("pcaExp").textContent = (isFinite(l1) && tot > 0) ? (l1 / tot * 100).toFixed(1) + "%" : "--";
      document.getElementById("pcaIt").textContent = iters || "--";
      document.getElementById("pcaAng").textContent = v1 ? (Math.atan2(v1.y, v1.x) * 180 / Math.PI).toFixed(1) + " deg" : "--";
    }
    function seedSample(){
      pts = [];
      var ang = rnd(0.3, 1.2), ca = Math.cos(ang), sa = Math.sin(ang);
      for (var i = 0; i < 50; i++){
        var a = gauss() * 0.24, b = gauss() * 0.06; // elongated cloud
        var x = 0.5 + a * ca - b * sa;
        var y = 0.5 + a * sa + b * ca;
        pts.push({ x: clamp(x, 0.03, 0.97), y: clamp(y, 0.03, 0.97) });
      }
      compute(); draw();
    }
    cv.addEventListener("click", function(e){ var p = evtXY(cv, e); pts.push({ x: clamp(p.x / W, 0, 1), y: clamp(p.y / H, 0, 1) }); compute(); draw(); });
    document.getElementById("pcaRun").addEventListener("click", function(){ compute(); draw(); });
    document.getElementById("pcaSeed").addEventListener("click", seedSample);
    document.getElementById("pcaClear").addEventListener("click", function(){ pts = []; mean = null; v1 = null; v2 = null; l1 = NaN; l2 = NaN; iters = 0; draw(); });
    document.getElementById("pcaProj").addEventListener("click", function(){ showProj = !showProj; draw(); });

    seedSample();
    return { draw: draw };
  })();

  // ======================================================================
  // 7. NEURAL NETWORK (real backprop): 2 -> 8 -> 8 -> 1  (preserved verbatim)
  // ======================================================================
  var NN = (function(){
    var cv = document.getElementById("nnCanvas"), ctx = cv.getContext("2d");
    var lc = document.getElementById("nnLoss"), lctx = lc.getContext("2d");
    var W = cv.width, H = cv.height;
    var sizes = [2, 8, 8, 1];
    var Wm = [], Bm = [];   // weights[layer][j][i], biases[layer][j]
    var data = [], dataset = "xor";
    var epoch = 0, loss = NaN, acc = NaN, lossHist = [], running = false, raf = null, lr = 0.2;

    function tanh(x){ if (x > 20) return 1; if (x < -20) return -1; var e = Math.exp(2 * x); return (e - 1) / (e + 1); }
    function sigmoid(x){ if (x < -30) return 0; if (x > 30) return 1; return 1 / (1 + Math.exp(-x)); }

    function initNet(){
      Wm = []; Bm = [];
      for (var l = 1; l < sizes.length; l++){
        var nIn = sizes[l - 1], nOut = sizes[l];
        var limit = Math.sqrt(6 / (nIn + nOut)); // Xavier
        var wl = [], bl = [];
        for (var j = 0; j < nOut; j++){
          var row = [];
          for (var i = 0; i < nIn; i++) row.push(rnd(-limit, limit));
          wl.push(row); bl.push(0);
        }
        Wm.push(wl); Bm.push(bl);
      }
      epoch = 0; loss = NaN; acc = NaN; lossHist = [];
    }

    // forward pass; returns activations per layer (a[0] = input)
    function forward(input){
      var a = [input], cur = input;
      for (var l = 0; l < Wm.length; l++){
        var next = [], isLast = (l === Wm.length - 1);
        for (var j = 0; j < Wm[l].length; j++){
          var z = Bm[l][j];
          for (var i = 0; i < cur.length; i++) z += Wm[l][j][i] * cur[i];
          next.push(isLast ? sigmoid(z) : tanh(z));
        }
        a.push(next); cur = next;
      }
      return a;
    }

    function trainEpoch(){
      // accumulate gradients over full batch
      var gW = [], gB = [], l, j, i;
      for (l = 0; l < Wm.length; l++){
        gW[l] = []; gB[l] = [];
        for (j = 0; j < Wm[l].length; j++){ gW[l][j] = []; for (i = 0; i < Wm[l][j].length; i++) gW[l][j][i] = 0; gB[l][j] = 0; }
      }
      var totalLoss = 0, correct = 0, n = data.length;
      for (var s = 0; s < n; s++){
        var x = [data[s].x, data[s].y], target = data[s].c;
        var a = forward(x);
        var out = a[a.length - 1][0];
        var oc = clamp(out, 1e-7, 1 - 1e-7);
        totalLoss += -(target * Math.log(oc) + (1 - target) * Math.log(1 - oc));
        if ((out > 0.5 ? 1 : 0) === target) correct++;

        // backprop: delta for each layer
        var deltas = [];
        for (l = 0; l < Wm.length; l++) deltas[l] = [];
        // output layer (sigmoid + BCE): dL/dz = out - target
        var L = Wm.length - 1;
        deltas[L][0] = out - target;
        // hidden layers (tanh): delta = (W^T delta_next) * (1 - a^2)
        for (l = L - 1; l >= 0; l--){
          var aOut = a[l + 1];
          for (j = 0; j < Wm[l].length; j++){
            var sum = 0;
            for (var jn = 0; jn < Wm[l + 1].length; jn++) sum += Wm[l + 1][jn][j] * deltas[l + 1][jn];
            deltas[l][j] = sum * (1 - aOut[j] * aOut[j]);
          }
        }
        // accumulate gradients
        for (l = 0; l < Wm.length; l++){
          var aPrev = a[l];
          for (j = 0; j < Wm[l].length; j++){
            for (i = 0; i < aPrev.length; i++) gW[l][j][i] += deltas[l][j] * aPrev[i];
            gB[l][j] += deltas[l][j];
          }
        }
      }
      // apply averaged gradients
      for (l = 0; l < Wm.length; l++){
        for (j = 0; j < Wm[l].length; j++){
          for (i = 0; i < Wm[l][j].length; i++) Wm[l][j][i] -= lr * gW[l][j][i] / n;
          Bm[l][j] -= lr * gB[l][j] / n;
        }
      }
      epoch++;
      loss = totalLoss / n;
      acc = correct / n;
      lossHist.push(loss); if (lossHist.length > 700) lossHist.shift();
    }

    function genData(){
      data = []; var i, n;
      if (dataset === "xor"){
        n = 200;
        for (i = 0; i < n; i++){
          var qx = Math.random() < 0.5 ? rnd(0.05, 0.45) : rnd(0.55, 0.95);
          var qy = Math.random() < 0.5 ? rnd(0.05, 0.45) : rnd(0.55, 0.95);
          var c = ((qx > 0.5) !== (qy > 0.5)) ? 1 : 0;
          data.push({ x: qx, y: qy, c: c });
        }
      } else if (dataset === "circles"){
        n = 220;
        for (i = 0; i < n; i++){
          var inner = i < n / 2;
          var rad = inner ? rnd(0, 0.22) : rnd(0.34, 0.48);
          var th = rnd(0, 6.2832);
          data.push({ x: 0.5 + rad * Math.cos(th), y: 0.5 + rad * Math.sin(th), c: inner ? 1 : 0 });
        }
      } else if (dataset === "moons"){
        n = 220;
        for (i = 0; i < n; i++){
          if (i < n / 2){ var t1 = rnd(0, Math.PI); data.push({ x: 0.32 + 0.32 * Math.cos(t1) + gauss() * 0.025, y: 0.62 - 0.30 * Math.sin(t1) + gauss() * 0.025, c: 0 }); }
          else { var t2 = rnd(0, Math.PI); data.push({ x: 0.68 - 0.32 * Math.cos(t2) + gauss() * 0.025, y: 0.40 + 0.30 * Math.sin(t2) + gauss() * 0.025, c: 1 }); }
        }
      } else { // spiral
        n = 240;
        for (i = 0; i < n / 2; i++){
          var r = i / (n / 2) * 0.46;
          var t = i / (n / 2) * 4 + gauss() * 0.12;
          data.push({ x: 0.5 + r * Math.cos(t), y: 0.5 + r * Math.sin(t), c: 0 });
          data.push({ x: 0.5 + r * Math.cos(t + Math.PI), y: 0.5 + r * Math.sin(t + Math.PI), c: 1 });
        }
      }
      for (i = 0; i < data.length; i++){ data[i].x = clamp(data[i].x, 0, 1); data[i].y = clamp(data[i].y, 0, 1); }
    }

    function draw(){
      ctx.clearRect(0, 0, W, H); ctx.fillStyle = "#0a0a0c"; ctx.fillRect(0, 0, W, H);
      // prediction surface on coarse grid
      var cell = 8;
      var img = ctx.createImageData(W, H);
      for (var gy = 0; gy < H; gy += cell){
        for (var gx = 0; gx < W; gx += cell){
          var nx = (gx + cell / 2) / W, ny = (gy + cell / 2) / H;
          var a = forward([nx, ny]);
          var p = a[a.length - 1][0]; // 0..1
          // class1 = amber, class0 = cyan ; intensity by confidence
          var t = clamp((p - 0.5) * 2, -1, 1);
          var rr, gg, bb;
          if (t >= 0){ rr = 80 + t * 171; gg = 60 + t * 131; bb = 30; }   // toward amber
          else { var u = -t; rr = 40; gg = 60 + u * 172; bb = 60 + u * 189; } // toward cyan
          for (var yy = gy; yy < gy + cell && yy < H; yy++){
            for (var xx = gx; xx < gx + cell && xx < W; xx++){
              var idx = (yy * W + xx) * 4;
              img.data[idx] = rr; img.data[idx + 1] = gg; img.data[idx + 2] = bb; img.data[idx + 3] = 70;
            }
          }
        }
      }
      ctx.putImageData(img, 0, 0);
      // data points
      for (var s = 0; s < data.length; s++){
        ctx.fillStyle = data[s].c === 1 ? "#fbbf24" : "#67e8f9";
        ctx.strokeStyle = "#0a0a0c"; ctx.lineWidth = 1.2;
        ctx.beginPath(); ctx.arc(data[s].x * W, data[s].y * H, 4, 0, 6.2832); ctx.fill(); ctx.stroke();
      }
      drawLoss();
      document.getElementById("nnE").textContent = epoch;
      document.getElementById("nnL").textContent = isFinite(loss) ? fmt(loss, 4) : "--";
      document.getElementById("nnAcc").textContent = isFinite(acc) ? (acc * 100).toFixed(1) + "%" : "--";
      document.getElementById("nnSt").textContent = running ? "training" : (epoch ? "paused" : "idle");
    }
    function drawLoss(){
      lctx.clearRect(0, 0, lc.width, lc.height); lctx.fillStyle = "#0a0a0c"; lctx.fillRect(0, 0, lc.width, lc.height);
      lctx.fillStyle = "#9aa0aa"; lctx.font = "10px ui-monospace"; lctx.fillText("BCE loss", 8, 14);
      if (lossHist.length < 2) return;
      var mx = 0; for (var i = 0; i < lossHist.length; i++) if (lossHist[i] > mx) mx = lossHist[i];
      if (mx <= 0) mx = 1;
      lctx.strokeStyle = "#a78bfa"; lctx.lineWidth = 2; lctx.beginPath();
      for (var j = 0; j < lossHist.length; j++){
        var x = 8 + j / (lossHist.length - 1) * (lc.width - 16);
        var y = lc.height - 12 - (lossHist[j] / mx) * (lc.height - 30);
        if (j === 0) lctx.moveTo(x, y); else lctx.lineTo(x, y);
      }
      lctx.stroke();
    }
    function loop(){ if (!running) return; for (var s = 0; s < 4; s++) trainEpoch(); draw(); raf = requestAnimationFrame(loop); }

    document.getElementById("nnData").addEventListener("change", function(){ dataset = this.value; initNet(); genData(); running = false; document.getElementById("nnRun").textContent = "Train"; draw(); });
    document.getElementById("nnLr").addEventListener("input", function(){ lr = Math.pow(10, parseFloat(this.value)); document.getElementById("nnLrV").textContent = fmt(lr, lr < 0.01 ? 4 : 2); });
    document.getElementById("nnRun").addEventListener("click", function(){ running = !running; this.textContent = running ? "Pause" : "Train"; if (running) loop(); });
    document.getElementById("nnReset").addEventListener("click", function(){ running = false; document.getElementById("nnRun").textContent = "Train"; initNet(); draw(); });

    lr = Math.pow(10, parseFloat(document.getElementById("nnLr").value));
    document.getElementById("nnLrV").textContent = fmt(lr, 2);
    initNet(); genData(); draw();
    return { draw: draw };
  })();

  // ======================================================================
  // 8. OPTIMIZERS COMPARED (NEW): SGD vs momentum vs Adam on a 2D surface
  // ======================================================================
  var OPT = (function(){
    var cv = document.getElementById("optCanvas"), ctx = cv.getContext("2d");
    var lc = document.getElementById("optLoss"), lctx = lc.getContext("2d");
    var W = cv.width, H = cv.height;
    var surface = "bowl", lr = 0.04, iter = 0, running = false, raf = null;
    var start = { x: -2.2, y: 2.2 };   // domain coords
    // domain box in math coords
    var X0 = -3, X1 = 3, Y0 = -3, Y1 = 3;
    var opts = null;                    // three optimizer states
    var paths = { sgd: [], mom: [], adam: [] };
    var hist = { sgd: [], mom: [], adam: [] };
    var colors = { sgd: "#67e8f9", mom: "#fbbf24", adam: "#a78bfa" };

    // loss + analytic gradient for each surface
    function fval(x, y){
      if (surface === "bowl") return 0.5 * (0.15 * x * x + 2.2 * y * y);
      if (surface === "saddle") return 0.5 * (x * x - y * y) + 0.05 * y * y * y * y + 0.3 * y * y;
      // rosenbrock (scaled down)
      var a = 1, b = 12;
      return ((a - x) * (a - x) + b * (y - x * x) * (y - x * x)) / 12;
    }
    function grad(x, y){
      if (surface === "bowl") return { gx: 0.15 * x, gy: 2.2 * y };
      if (surface === "saddle") return { gx: x, gy: -y + 0.2 * y * y * y + 0.6 * y };
      var a = 1, b = 12;
      var gx = (-2 * (a - x) - 4 * b * x * (y - x * x)) / 12;
      var gy = (2 * b * (y - x * x)) / 12;
      return { gx: gx, gy: gy };
    }
    function minPoint(){
      if (surface === "rosen") return { x: 1, y: 1 };
      return { x: 0, y: 0 };
    }

    function toPx(x, y){ return { x: (x - X0) / (X1 - X0) * W, y: (1 - (y - Y0) / (Y1 - Y0)) * H }; }
    function toMath(px, py){ return { x: X0 + px / W * (X1 - X0), y: Y0 + (1 - py / H) * (Y1 - Y0) }; }

    function reset(){
      iter = 0;
      paths = { sgd: [{ x: start.x, y: start.y }], mom: [{ x: start.x, y: start.y }], adam: [{ x: start.x, y: start.y }] };
      hist = { sgd: [], mom: [], adam: [] };
      opts = {
        sgd:  { x: start.x, y: start.y },
        mom:  { x: start.x, y: start.y, vx: 0, vy: 0, beta: 0.9 },
        adam: { x: start.x, y: start.y, mx: 0, my: 0, sx: 0, sy: 0, b1: 0.9, b2: 0.999, t: 0 }
      };
    }

    function step(){
      // SGD
      var s = opts.sgd, g = grad(s.x, s.y);
      s.x -= lr * g.gx; s.y -= lr * g.gy;
      paths.sgd.push({ x: s.x, y: s.y });
      // Momentum
      var m = opts.mom, gm = grad(m.x, m.y);
      m.vx = m.beta * m.vx + gm.gx; m.vy = m.beta * m.vy + gm.gy;
      m.x -= lr * m.vx; m.y -= lr * m.vy;
      paths.mom.push({ x: m.x, y: m.y });
      // Adam
      var ad = opts.adam, ga = grad(ad.x, ad.y);
      ad.t++;
      ad.mx = ad.b1 * ad.mx + (1 - ad.b1) * ga.gx; ad.my = ad.b1 * ad.my + (1 - ad.b1) * ga.gy;
      ad.sx = ad.b2 * ad.sx + (1 - ad.b2) * ga.gx * ga.gx; ad.sy = ad.b2 * ad.sy + (1 - ad.b2) * ga.gy * ga.gy;
      var mhx = ad.mx / (1 - Math.pow(ad.b1, ad.t)), mhy = ad.my / (1 - Math.pow(ad.b1, ad.t));
      var shx = ad.sx / (1 - Math.pow(ad.b2, ad.t)), shy = ad.sy / (1 - Math.pow(ad.b2, ad.t));
      var adamLr = lr * 8; // Adam's effective step is smaller; scale for comparability
      ad.x -= adamLr * mhx / (Math.sqrt(shx) + 1e-8); ad.y -= adamLr * mhy / (Math.sqrt(shy) + 1e-8);
      paths.adam.push({ x: ad.x, y: ad.y });

      hist.sgd.push(fval(s.x, s.y));
      hist.mom.push(fval(m.x, m.y));
      hist.adam.push(fval(ad.x, ad.y));
      if (hist.sgd.length > 400){ hist.sgd.shift(); hist.mom.shift(); hist.adam.shift(); }
      iter++;
    }

    function draw(){
      ctx.clearRect(0, 0, W, H); ctx.fillStyle = "#0a0a0c"; ctx.fillRect(0, 0, W, H);
      // contour shading via per-cell loss value
      var cell = 8, img = ctx.createImageData(W, H), maxv = 0;
      // estimate a normalisation by sampling corners + center
      var samples = [fval(X0, Y0), fval(X1, Y1), fval(X0, Y1), fval(X1, Y0), fval(0, 0)];
      for (var si = 0; si < samples.length; si++) if (samples[si] > maxv) maxv = samples[si];
      if (maxv <= 0) maxv = 1;
      for (var gy = 0; gy < H; gy += cell){
        for (var gx = 0; gx < W; gx += cell){
          var mc = toMath(gx + cell / 2, gy + cell / 2);
          var v = fval(mc.x, mc.y);
          var t = clamp(v / maxv, 0, 1);
          // dark (low loss) -> bright steel (high loss)
          var rr = 10 + t * 40, gg = 12 + t * 44, bb = 18 + t * 70;
          // contour bands
          var band = (Math.floor(Math.sqrt(t) * 9) % 2 === 0) ? 0 : 14;
          rr += band; gg += band; bb += band;
          for (var yy = gy; yy < gy + cell && yy < H; yy++){
            for (var xx = gx; xx < gx + cell && xx < W; xx++){
              var idx = (yy * W + xx) * 4;
              img.data[idx] = rr; img.data[idx + 1] = gg; img.data[idx + 2] = bb; img.data[idx + 3] = 255;
            }
          }
        }
      }
      ctx.putImageData(img, 0, 0);
      // minimum marker
      var mp = minPoint(), mpx = toPx(mp.x, mp.y);
      ctx.strokeStyle = "#86efac"; ctx.lineWidth = 2;
      ctx.beginPath(); ctx.arc(mpx.x, mpx.y, 8, 0, 6.2832); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(mpx.x - 5, mpx.y); ctx.lineTo(mpx.x + 5, mpx.y); ctx.moveTo(mpx.x, mpx.y - 5); ctx.lineTo(mpx.x, mpx.y + 5); ctx.stroke();
      // paths
      ["sgd", "mom", "adam"].forEach(function(key){
        var pth = paths[key]; if (!pth || pth.length === 0) return;
        ctx.strokeStyle = colors[key]; ctx.lineWidth = 2; ctx.beginPath();
        for (var i = 0; i < pth.length; i++){
          var pp = toPx(pth[i].x, pth[i].y);
          if (i === 0) ctx.moveTo(pp.x, pp.y); else ctx.lineTo(pp.x, pp.y);
        }
        ctx.stroke();
        var last = toPx(pth[pth.length - 1].x, pth[pth.length - 1].y);
        ctx.fillStyle = colors[key]; ctx.beginPath(); ctx.arc(last.x, last.y, 4.5, 0, 6.2832); ctx.fill();
      });
      // start marker
      var sp = toPx(start.x, start.y);
      ctx.strokeStyle = "#e8e8ee"; ctx.lineWidth = 1.5;
      ctx.beginPath(); ctx.arc(sp.x, sp.y, 5, 0, 6.2832); ctx.stroke();

      drawLoss();
      document.getElementById("optIt").textContent = iter;
      document.getElementById("optLs").textContent = hist.sgd.length ? fmt(hist.sgd[hist.sgd.length - 1], 4) : "--";
      document.getElementById("optLm").textContent = hist.mom.length ? fmt(hist.mom[hist.mom.length - 1], 4) : "--";
      document.getElementById("optLa").textContent = hist.adam.length ? fmt(hist.adam[hist.adam.length - 1], 4) : "--";
    }
    function drawLoss(){
      lctx.clearRect(0, 0, lc.width, lc.height); lctx.fillStyle = "#0a0a0c"; lctx.fillRect(0, 0, lc.width, lc.height);
      lctx.fillStyle = "#9aa0aa"; lctx.font = "10px ui-monospace"; lctx.fillText("loss vs iteration", 8, 14);
      var len = hist.sgd.length; if (len < 2) return;
      var mx = 0, keys = ["sgd", "mom", "adam"], ki, jj;
      for (ki = 0; ki < 3; ki++) for (jj = 0; jj < hist[keys[ki]].length; jj++) if (hist[keys[ki]][jj] > mx) mx = hist[keys[ki]][jj];
      if (mx <= 0) mx = 1;
      for (ki = 0; ki < 3; ki++){
        var h = hist[keys[ki]];
        lctx.strokeStyle = colors[keys[ki]]; lctx.lineWidth = 2; lctx.beginPath();
        for (jj = 0; jj < h.length; jj++){
          var x = 8 + jj / (h.length - 1) * (lc.width - 16);
          var y = lc.height - 12 - (h[jj] / mx) * (lc.height - 30);
          if (jj === 0) lctx.moveTo(x, y); else lctx.lineTo(x, y);
        }
        lctx.stroke();
      }
    }
    function loop(){ if (!running) return; for (var s = 0; s < 2; s++) step(); draw();
      if (iter > 600){ running = false; document.getElementById("optRun").textContent = "Run"; return; }
      raf = requestAnimationFrame(loop);
    }
    function lrFromSlider(){ lr = Math.pow(10, parseFloat(document.getElementById("optLr").value)); document.getElementById("optLrV").textContent = fmt(lr, lr < 0.01 ? 4 : 3); }

    cv.addEventListener("click", function(e){ var p = evtXY(cv, e); var m = toMath(p.x, p.y); start = { x: m.x, y: m.y }; running = false; document.getElementById("optRun").textContent = "Run"; reset(); draw(); });
    document.getElementById("optSurf").addEventListener("change", function(){ surface = this.value; running = false; document.getElementById("optRun").textContent = "Run"; reset(); draw(); });
    document.getElementById("optLr").addEventListener("input", lrFromSlider);
    document.getElementById("optRun").addEventListener("click", function(){ if (iter > 600) reset(); running = !running; this.textContent = running ? "Pause" : "Run"; if (running) loop(); });
    document.getElementById("optStep").addEventListener("click", function(){ for (var s = 0; s < 5; s++) step(); draw(); });
    document.getElementById("optReset").addEventListener("click", function(){ running = false; document.getElementById("optRun").textContent = "Run"; reset(); draw(); });

    lrFromSlider(); reset(); draw();
    return { draw: draw };
  })();

  // ======================================================================
  // 9. CNN CONVOLUTION + RELU + MAX-POOL (NEW)
  // ======================================================================
  var CNN = (function(){
    var cv = document.getElementById("cnnCanvas"), ctx = cv.getContext("2d");
    var W = cv.width, H = cv.height;
    var N = 16;                          // input grid is NxN
    var img = [];                        // input image, values 0..1
    var kernelName = "sobelx", useRelu = true, usePool = true, drawing = false;

    var KERNELS = {
      sobelx:  [-1,0,1, -2,0,2, -1,0,1],
      sobely:  [-1,-2,-1, 0,0,0, 1,2,1],
      gauss:   [1/16,2/16,1/16, 2/16,4/16,2/16, 1/16,2/16,1/16],
      sharpen: [0,-1,0, -1,5,-1, 0,-1,0]
    };

    function blank(){ img = []; for (var i = 0; i < N * N; i++) img.push(0); }

    function activeKernel(){
      if (kernelName === "custom"){
        var raw = (document.getElementById("cnnCustom").value || "").split(",");
        var k = [];
        for (var i = 0; i < 9; i++){ var v = parseFloat(raw[i]); k.push(isFinite(v) ? v : 0); }
        return k;
      }
      return KERNELS[kernelName];
    }

    // valid 3x3 convolution: input NxN -> (N-2)x(N-2)
    function convolve(){
      var k = activeKernel(), M = N - 2, out = [];
      for (var y = 0; y < M; y++){
        for (var x = 0; x < M; x++){
          var s = 0, ki = 0;
          for (var u = 0; u < 3; u++){
            for (var v = 0; v < 3; v++){
              s += k[ki++] * img[(y + u) * N + (x + v)];
            }
          }
          out.push(s);
        }
      }
      return { data: out, dim: M };
    }
    function reluMap(m){
      var out = [];
      for (var i = 0; i < m.data.length; i++) out.push(m.data[i] < 0 ? 0 : m.data[i]);
      return { data: out, dim: m.dim };
    }
    // 2x2 max-pool, stride 2: dim -> floor(dim/2)
    function poolMap(m){
      var D = m.dim, P = Math.floor(D / 2), out = [];
      for (var y = 0; y < P; y++){
        for (var x = 0; x < P; x++){
          var a = m.data[(2*y) * D + (2*x)];
          var b = m.data[(2*y) * D + (2*x+1)];
          var c = m.data[(2*y+1) * D + (2*x)];
          var d = m.data[(2*y+1) * D + (2*x+1)];
          var mx = a; if (b > mx) mx = b; if (c > mx) mx = c; if (d > mx) mx = d;
          out.push(mx);
        }
      }
      return { data: out, dim: P };
    }

    // draw a map of values into a square box, color = signed (cyan +, red -) or single ramp
    function paintMap(data, dim, bx, by, boxW, signed, baseRGB){
      var cw = boxW / dim;
      var maxAbs = 1e-6;
      for (var i = 0; i < data.length; i++){ var av = Math.abs(data[i]); if (av > maxAbs) maxAbs = av; }
      for (var y = 0; y < dim; y++){
        for (var x = 0; x < dim; x++){
          var val = data[y * dim + x], t = val / maxAbs;
          var rr, gg, bb;
          if (signed){
            if (t >= 0){ rr = 30 + t * 73; gg = 50 + t * 182; bb = 60 + t * 189; }   // cyan for positive
            else { var u = -t; rr = 40 + u * 212; gg = 30 + u * 70; bb = 40 + u * 70; } // red for negative
          } else {
            var tt = clamp(val / maxAbs, 0, 1);
            rr = baseRGB[0] * tt; gg = baseRGB[1] * tt; bb = baseRGB[2] * tt;
          }
          ctx.fillStyle = "rgb(" + (rr|0) + "," + (gg|0) + "," + (bb|0) + ")";
          ctx.fillRect(bx + x * cw, by + y * cw, Math.ceil(cw), Math.ceil(cw));
        }
      }
      ctx.strokeStyle = "#2a2a35"; ctx.lineWidth = 1;
      ctx.strokeRect(bx, by, boxW, boxW);
    }
    function label(text, bx, by, dimText){
      ctx.fillStyle = "#9aa0aa"; ctx.font = "11px ui-monospace";
      ctx.fillText(text, bx, by - 16);
      ctx.fillStyle = "#67e8f9"; ctx.font = "10px ui-monospace";
      ctx.fillText(dimText, bx, by - 4);
    }

    function draw(){
      ctx.clearRect(0, 0, W, H); ctx.fillStyle = "#0a0a0c"; ctx.fillRect(0, 0, W, H);
      var boxW = 150, pad = 28, top = 50;
      // input (grayscale)
      label("Input", pad, top, N + "x" + N);
      paintMap(img, N, pad, top, boxW, false, [232, 232, 238]);

      var conv = convolve();
      var maxAct = 0; for (var i = 0; i < conv.data.length; i++){ var a = Math.abs(conv.data[i]); if (a > maxAct) maxAct = a; }
      var bx2 = pad + boxW + pad;
      label("Convolution", bx2, top, conv.dim + "x" + conv.dim);
      paintMap(conv.data, conv.dim, bx2, top, boxW, true, [103, 232, 249]);

      var stage = conv;
      var bx3 = bx2 + boxW + pad;
      if (useRelu){
        stage = reluMap(conv);
        label("ReLU", bx3, top, stage.dim + "x" + stage.dim);
        paintMap(stage.data, stage.dim, bx3, top, boxW, false, [134, 239, 172]);
      } else {
        ctx.fillStyle = "#3a3a45"; ctx.font = "11px ui-monospace";
        ctx.fillText("(ReLU off)", bx3, top + boxW / 2);
      }

      var poolDim = "--";
      if (usePool){
        var pooled = poolMap(stage);
        poolDim = pooled.dim + "x" + pooled.dim;
        // place pooled below the input row
        var bottomY = top + boxW + 64;
        label("Max-pool 2x2", pad, bottomY, poolDim);
        paintMap(pooled.data, pooled.dim, pad, bottomY, boxW, false, [251, 191, 36]);
        ctx.fillStyle = "#9aa0aa"; ctx.font = "10px ui-monospace";
        ctx.fillText("strongest activation in each 2x2 window, halving resolution", pad + boxW + pad, bottomY + boxW / 2);
      }
      document.getElementById("cnnInDim").textContent = N + "x" + N;
      document.getElementById("cnnConvDim").textContent = conv.dim + "x" + conv.dim;
      document.getElementById("cnnPoolDim").textContent = usePool ? poolDim : "off";
      document.getElementById("cnnMax").textContent = fmt(maxAct, 2);
    }

    function setPixel(e){
      var p = evtXY(cv, e);
      var boxW = 150, pad = 28, top = 50;
      var lx = p.x - pad, ly = p.y - top;
      if (lx < 0 || ly < 0 || lx >= boxW || ly >= boxW) return;
      var cw = boxW / N;
      var gx = Math.floor(lx / cw), gy = Math.floor(ly / cw);
      // soft brush: paint cell and neighbours
      for (var dy = -1; dy <= 1; dy++){
        for (var dx = -1; dx <= 1; dx++){
          var nx = gx + dx, ny = gy + dy;
          if (nx < 0 || ny < 0 || nx >= N || ny >= N) continue;
          var add = (dx === 0 && dy === 0) ? 1 : 0.45;
          var idx = ny * N + nx;
          img[idx] = clamp(img[idx] + add, 0, 1);
        }
      }
      draw();
    }
    cv.addEventListener("mousedown", function(e){ drawing = true; setPixel(e); });
    cv.addEventListener("mousemove", function(e){ if (drawing) setPixel(e); });
    cv.addEventListener("mouseup", function(){ drawing = false; });
    cv.addEventListener("mouseleave", function(){ drawing = false; });

    function seedDigit(){
      blank();
      // a stylised "7": top bar + diagonal stroke (in a 16x16 grid)
      var r, c;
      for (c = 3; c <= 12; c++){ img[3 * N + c] = 1; img[4 * N + c] = 0.7; }
      for (r = 5; r <= 13; r++){
        var cc = Math.round(12 - (r - 4) * 0.7);
        img[r * N + cc] = 1;
        if (cc - 1 >= 0) img[r * N + (cc - 1)] = 0.7;
      }
      draw();
    }

    document.getElementById("cnnKernel").addEventListener("change", function(){
      kernelName = this.value;
      document.getElementById("cnnCustomWrap").style.display = (kernelName === "custom") ? "block" : "none";
      draw();
    });
    document.getElementById("cnnCustom").addEventListener("input", function(){ if (kernelName === "custom") draw(); });
    var rseg = document.getElementById("cnnRelu").querySelectorAll("button");
    for (var rs = 0; rs < rseg.length; rs++){
      (function(btn){ btn.addEventListener("click", function(){ for (var z = 0; z < rseg.length; z++) rseg[z].classList.remove("on"); btn.classList.add("on"); useRelu = btn.getAttribute("data-relu") === "1"; draw(); }); })(rseg[rs]);
    }
    var pseg = document.getElementById("cnnPool").querySelectorAll("button");
    for (var ps = 0; ps < pseg.length; ps++){
      (function(btn){ btn.addEventListener("click", function(){ for (var z = 0; z < pseg.length; z++) pseg[z].classList.remove("on"); btn.classList.add("on"); usePool = btn.getAttribute("data-pool") === "1"; draw(); }); })(pseg[ps]);
    }
    document.getElementById("cnnSeed").addEventListener("click", seedDigit);
    document.getElementById("cnnClear").addEventListener("click", function(){ blank(); draw(); });

    blank(); seedDigit();
    return { draw: draw };
  })();

  // ======================================================================
  // 10. BIAS-VARIANCE + RIDGE REGRESSION (NEW)
  //   closed-form normal equations solved by Gaussian elimination,
  //   train/validation split, k-fold cross-validation
  // ======================================================================
  var BV = (function(){
    var cv = document.getElementById("bvCanvas"), ctx = cv.getContext("2d");
    var ec = document.getElementById("bvErr"), ectx = ec.getContext("2d");
    var W = cv.width, H = cv.height;
    var pts = [];                        // {x:0..1, y:0..1}
    var degree = 3, lambda = 0, kFolds = 5, noiseAmp = 0.06;
    var coef = null, trainMSE = NaN, validMSE = NaN, cvMSE = NaN, wNorm = NaN;

    // ---- linear algebra (hand-rolled) ----
    function powers(x, d){ var v = [], p = 1; for (var i = 0; i <= d; i++){ v.push(p); p *= x; } return v; }
    // solve A w = b for symmetric A (size m x m) via Gaussian elimination with partial pivoting
    function solve(A, b, m){
      // build augmented copy
      var M = [];
      for (var i = 0; i < m; i++){ var row = A[i].slice(); row.push(b[i]); M.push(row); }
      for (var col = 0; col < m; col++){
        // pivot
        var piv = col, best = Math.abs(M[col][col]);
        for (var r = col + 1; r < m; r++){ var av = Math.abs(M[r][col]); if (av > best){ best = av; piv = r; } }
        if (best < 1e-12) continue; // singular column, skip (regularization usually prevents this)
        var tmp = M[col]; M[col] = M[piv]; M[piv] = tmp;
        var pv = M[col][col];
        for (var c2 = col; c2 <= m; c2++) M[col][c2] /= pv;
        for (var rr = 0; rr < m; rr++){
          if (rr === col) continue;
          var f = M[rr][col];
          if (f === 0) continue;
          for (var cc = col; cc <= m; cc++) M[rr][cc] -= f * M[col][cc];
        }
      }
      var w = []; for (var k = 0; k < m; k++) w.push(M[k][m]);
      return w;
    }
    // ridge fit on a subset of points, returns coefficient vector (length degree+1)
    function fitRidge(subset, d, lam){
      var m = d + 1;
      var A = [], bb = [], i, j;
      for (i = 0; i < m; i++){ A.push([]); for (j = 0; j < m; j++) A[i].push(0); bb.push(0); }
      for (var s = 0; s < subset.length; s++){
        var ph = powers(subset[s].x, d), y = subset[s].y;
        for (i = 0; i < m; i++){
          for (j = 0; j < m; j++) A[i][j] += ph[i] * ph[j];
          bb[i] += ph[i] * y;
        }
      }
      // add lambda*I (skip intercept i=0)
      for (i = 1; i < m; i++) A[i][i] += lam;
      return solve(A, bb, m);
    }
    function evalPoly(w, x){ var ph = powers(x, w.length - 1), s = 0; for (var i = 0; i < w.length; i++) s += w[i] * ph[i]; return s; }
    function mseOn(subset, w){
      if (subset.length === 0) return NaN;
      var s = 0; for (var i = 0; i < subset.length; i++){ var e = evalPoly(w, subset[i].x) - subset[i].y; s += e * e; }
      return s / subset.length;
    }

    // split deterministically: every 3rd point to validation
    function split(){
      var tr = [], va = [];
      for (var i = 0; i < pts.length; i++){ if (i % 3 === 1) va.push(pts[i]); else tr.push(pts[i]); }
      return { tr: tr, va: va };
    }
    function kfold(){
      if (pts.length < kFolds + 1) return NaN;
      // copy + simple shuffle by index stride to keep deterministic-ish
      var idx = []; for (var i = 0; i < pts.length; i++) idx.push(i);
      var total = 0, used = 0;
      for (var f = 0; f < kFolds; f++){
        var tr = [], va = [];
        for (var j = 0; j < pts.length; j++){ if (j % kFolds === f) va.push(pts[j]); else tr.push(pts[j]); }
        if (va.length === 0 || tr.length < degree + 1) continue;
        var w = fitRidge(tr, degree, lambda);
        var e = mseOn(va, w);
        if (isFinite(e)){ total += e; used++; }
      }
      return used ? total / used : NaN;
    }

    function refit(){
      if (pts.length < degree + 1){ coef = null; trainMSE = NaN; validMSE = NaN; wNorm = NaN; return; }
      var sp = split();
      coef = fitRidge(sp.tr.length >= degree + 1 ? sp.tr : pts, degree, lambda);
      trainMSE = mseOn(sp.tr, coef);
      validMSE = mseOn(sp.va, coef);
      var nn = 0; for (var i = 1; i < coef.length; i++) nn += coef[i] * coef[i];
      wNorm = Math.sqrt(nn);
    }

    function px(x){ return 40 + x * (W - 70); }
    function py(y){ return (H - 30) - y * (H - 60); }
    function invX(sx){ return (sx - 40) / (W - 70); }
    function invY(sy){ return ((H - 30) - sy) / (H - 60); }

    function draw(){
      refit();
      ctx.clearRect(0, 0, W, H); ctx.fillStyle = "#0a0a0c"; ctx.fillRect(0, 0, W, H);
      ctx.strokeStyle = "#1a1c24"; ctx.lineWidth = 1;
      for (var g = 0; g <= 10; g++){
        ctx.beginPath(); ctx.moveTo(px(g/10), py(0)); ctx.lineTo(px(g/10), py(1)); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(px(0), py(g/10)); ctx.lineTo(px(1), py(g/10)); ctx.stroke();
      }
      // fitted curve
      if (coef){
        ctx.strokeStyle = "#a78bfa"; ctx.lineWidth = 2.5; ctx.beginPath();
        var first = true;
        for (var sx = 0; sx <= 1.0001; sx += 0.005){
          var yy = evalPoly(coef, sx);
          var Y = py(clamp(yy, -0.3, 1.3));
          if (first){ ctx.moveTo(px(sx), Y); first = false; } else ctx.lineTo(px(sx), Y);
        }
        ctx.stroke();
      }
      // points (validation = amber ring, train = cyan)
      var sp = split();
      for (var i = 0; i < pts.length; i++){
        var isVa = (i % 3 === 1);
        ctx.fillStyle = isVa ? "#fbbf24" : "#67e8f9";
        ctx.strokeStyle = "#0a0a0c"; ctx.lineWidth = 1.3;
        ctx.beginPath(); ctx.arc(px(pts[i].x), py(pts[i].y), 4.2, 0, 6.2832); ctx.fill(); ctx.stroke();
      }
      drawErr();
      document.getElementById("bvTrain").textContent = isFinite(trainMSE) ? fmt(trainMSE, 5) : "--";
      document.getElementById("bvValid").textContent = isFinite(validMSE) ? fmt(validMSE, 5) : "--";
      document.getElementById("bvNorm").textContent = isFinite(wNorm) ? fmt(wNorm, 2) : "--";
      // regime label
      var reg = "--";
      if (isFinite(trainMSE) && isFinite(validMSE)){
        if (validMSE > trainMSE * 3 + 0.002) reg = "overfitting (high variance)";
        else if (trainMSE > 0.02) reg = "underfitting (high bias)";
        else reg = "good fit";
      }
      document.getElementById("bvRegime").textContent = reg;
    }

    // lower chart: sweep degree 1..12 at the current lambda, plot train (cyan) vs validation (amber)
    function drawErr(){
      ectx.clearRect(0, 0, ec.width, ec.height); ectx.fillStyle = "#0a0a0c"; ectx.fillRect(0, 0, ec.width, ec.height);
      ectx.fillStyle = "#9aa0aa"; ectx.font = "10px ui-monospace";
      ectx.fillText("train (cyan) vs validation (amber) MSE across polynomial degree", 8, 14);
      if (pts.length < 4) return;
      var maxD = 12, sp = split();
      var trArr = [], vaArr = [], mx = 1e-6, d;
      for (d = 1; d <= maxD; d++){
        var base = sp.tr.length >= d + 1 ? sp.tr : pts;
        var w = fitRidge(base, d, lambda);
        var te = mseOn(sp.tr, w), ve = mseOn(sp.va, w);
        if (!isFinite(te)) te = 0; if (!isFinite(ve)) ve = 0;
        // clip absurd values so the chart stays readable
        te = Math.min(te, 0.5); ve = Math.min(ve, 0.5);
        trArr.push(te); vaArr.push(ve);
        if (te > mx) mx = te; if (ve > mx) mx = ve;
      }
      function plot(arr, color){
        ectx.strokeStyle = color; ectx.lineWidth = 2; ectx.beginPath();
        for (var i = 0; i < arr.length; i++){
          var x = 30 + i / (arr.length - 1) * (ec.width - 44);
          var y = ec.height - 16 - (arr[i] / mx) * (ec.height - 34);
          if (i === 0) ectx.moveTo(x, y); else ectx.lineTo(x, y);
        }
        ectx.stroke();
      }
      plot(trArr, "#67e8f9"); plot(vaArr, "#fbbf24");
      // mark current degree
      var cxp = 30 + (degree - 1) / (maxD - 1) * (ec.width - 44);
      ectx.strokeStyle = "rgba(167,139,250,0.7)"; ectx.lineWidth = 1.5;
      ectx.beginPath(); ectx.moveTo(cxp, 18); ectx.lineTo(cxp, ec.height - 12); ectx.stroke();
    }

    function trueCurve(x){ return 0.5 + 0.34 * Math.sin(x * 6.2 + 0.6) - 0.12 * x; }
    function seedSample(){
      pts = [];
      for (var i = 0; i < 28; i++){
        var x = i / 27;
        var y = clamp(trueCurve(x) + gauss() * noiseAmp, 0.02, 0.98);
        pts.push({ x: x, y: y });
      }
      draw();
    }

    cv.addEventListener("click", function(e){
      var p = evtXY(cv, e), x = invX(p.x), y = invY(p.y);
      if (x < -0.02 || x > 1.02 || y < -0.02 || y > 1.02) return;
      pts.push({ x: clamp(x, 0, 1), y: clamp(y, 0, 1) });
      pts.sort(function(a, b){ return a.x - b.x; });
      draw();
    });
    document.getElementById("bvDeg").addEventListener("input", function(){ degree = parseInt(this.value, 10); document.getElementById("bvDegV").textContent = degree; draw(); });
    document.getElementById("bvLam").addEventListener("input", function(){
      var raw = parseFloat(this.value);
      lambda = raw <= -6 ? 0 : Math.pow(10, raw);
      document.getElementById("bvLamV").textContent = lambda === 0 ? "0" : (lambda < 0.01 ? lambda.toExponential(1) : fmt(lambda, 3));
      draw();
    });
    document.getElementById("bvK").addEventListener("input", function(){ kFolds = parseInt(this.value, 10); document.getElementById("bvKV").textContent = kFolds; });
    document.getElementById("bvCV").addEventListener("click", function(){
      cvMSE = kfold();
      document.getElementById("bvCVv").textContent = isFinite(cvMSE) ? fmt(cvMSE, 5) : "--";
    });
    document.getElementById("bvNoise").addEventListener("click", function(){ noiseAmp = noiseAmp >= 0.14 ? 0.04 : noiseAmp + 0.04; seedSample(); });
    document.getElementById("bvSeed").addEventListener("click", seedSample);
    document.getElementById("bvClear").addEventListener("click", function(){ pts = []; coef = null; cvMSE = NaN; document.getElementById("bvCVv").textContent = "--"; draw(); });

    seedSample();
    return { draw: draw };
  })();

  // ======================================================================
  // 11. IRIS CLASSIFIER + CONFUSION MATRIX (NEW)
  //   softmax (multinomial logistic) regression on the real 150-row dataset
  // ======================================================================
  var IRIS = (function(){
    var cv = document.getElementById("irCanvas"), ctx = cv.getContext("2d");
    var conf = document.getElementById("irConf"), cctx = conf.getContext("2d");
    var W = cv.width, H = cv.height;
    // ---- embedded Iris dataset: [sepalL, sepalW, petalL, petalW, class] class 0=setosa 1=versicolor 2=virginica
    var IRIS_RAW = [
      [5.1,3.5,1.4,0.2,0],[4.9,3.0,1.4,0.2,0],[4.7,3.2,1.3,0.2,0],[4.6,3.1,1.5,0.2,0],[5.0,3.6,1.4,0.2,0],
      [5.4,3.9,1.7,0.4,0],[4.6,3.4,1.4,0.3,0],[5.0,3.4,1.5,0.2,0],[4.4,2.9,1.4,0.2,0],[4.9,3.1,1.5,0.1,0],
      [5.4,3.7,1.5,0.2,0],[4.8,3.4,1.6,0.2,0],[4.8,3.0,1.4,0.1,0],[4.3,3.0,1.1,0.1,0],[5.8,4.0,1.2,0.2,0],
      [5.7,4.4,1.5,0.4,0],[5.4,3.9,1.3,0.4,0],[5.1,3.5,1.4,0.3,0],[5.7,3.8,1.7,0.3,0],[5.1,3.8,1.5,0.3,0],
      [5.4,3.4,1.7,0.2,0],[5.1,3.7,1.5,0.4,0],[4.6,3.6,1.0,0.2,0],[5.1,3.3,1.7,0.5,0],[4.8,3.4,1.9,0.2,0],
      [5.0,3.0,1.6,0.2,0],[5.0,3.4,1.6,0.4,0],[5.2,3.5,1.5,0.2,0],[5.2,3.4,1.4,0.2,0],[4.7,3.2,1.6,0.2,0],
      [4.8,3.1,1.6,0.2,0],[5.4,3.4,1.5,0.4,0],[5.2,4.1,1.5,0.1,0],[5.5,4.2,1.4,0.2,0],[4.9,3.1,1.5,0.2,0],
      [5.0,3.2,1.2,0.2,0],[5.5,3.5,1.3,0.2,0],[4.9,3.6,1.4,0.1,0],[4.4,3.0,1.3,0.2,0],[5.1,3.4,1.5,0.2,0],
      [5.0,3.5,1.3,0.3,0],[4.5,2.3,1.3,0.3,0],[4.4,3.2,1.3,0.2,0],[5.0,3.5,1.6,0.6,0],[5.1,3.8,1.9,0.4,0],
      [4.8,3.0,1.4,0.3,0],[5.1,3.8,1.6,0.2,0],[4.6,3.2,1.4,0.2,0],[5.3,3.7,1.5,0.2,0],[5.0,3.3,1.4,0.2,0],
      [7.0,3.2,4.7,1.4,1],[6.4,3.2,4.5,1.5,1],[6.9,3.1,4.9,1.5,1],[5.5,2.3,4.0,1.3,1],[6.5,2.8,4.6,1.5,1],
      [5.7,2.8,4.5,1.3,1],[6.3,3.3,4.7,1.6,1],[4.9,2.4,3.3,1.0,1],[6.6,2.9,4.6,1.3,1],[5.2,2.7,3.9,1.4,1],
      [5.0,2.0,3.5,1.0,1],[5.9,3.0,4.2,1.5,1],[6.0,2.2,4.0,1.0,1],[6.1,2.9,4.7,1.4,1],[5.6,2.9,3.6,1.3,1],
      [6.7,3.1,4.4,1.4,1],[5.6,3.0,4.5,1.5,1],[5.8,2.7,4.1,1.0,1],[6.2,2.2,4.5,1.5,1],[5.6,2.5,3.9,1.1,1],
      [5.9,3.2,4.8,1.8,1],[6.1,2.8,4.0,1.3,1],[6.3,2.5,4.9,1.5,1],[6.1,2.8,4.7,1.2,1],[6.4,2.9,4.3,1.3,1],
      [6.6,3.0,4.4,1.4,1],[6.8,2.8,4.8,1.4,1],[6.7,3.0,5.0,1.7,1],[6.0,2.9,4.5,1.5,1],[5.7,2.6,3.5,1.0,1],
      [5.5,2.4,3.8,1.1,1],[5.5,2.4,3.7,1.0,1],[5.8,2.7,3.9,1.2,1],[6.0,2.7,5.1,1.6,1],[5.4,3.0,4.5,1.5,1],
      [6.0,3.4,4.5,1.6,1],[6.7,3.1,4.7,1.5,1],[6.3,2.3,4.4,1.3,1],[5.6,3.0,4.1,1.3,1],[5.5,2.5,4.0,1.3,1],
      [5.5,2.6,4.4,1.2,1],[6.1,3.0,4.6,1.4,1],[5.8,2.6,4.0,1.2,1],[5.0,2.3,3.3,1.0,1],[5.6,2.7,4.2,1.3,1],
      [5.7,3.0,4.2,1.2,1],[5.7,2.9,4.2,1.3,1],[6.2,2.9,4.3,1.3,1],[5.1,2.5,3.0,1.1,1],[5.7,2.8,4.1,1.3,1],
      [6.3,3.3,6.0,2.5,2],[5.8,2.7,5.1,1.9,2],[7.1,3.0,5.9,2.1,2],[6.3,2.9,5.6,1.8,2],[6.5,3.0,5.8,2.2,2],
      [7.6,3.0,6.6,2.1,2],[4.9,2.5,4.5,1.7,2],[7.3,2.9,6.3,1.8,2],[6.7,2.5,5.8,1.8,2],[7.2,3.6,6.1,2.5,2],
      [6.5,3.2,5.1,2.0,2],[6.4,2.7,5.3,1.9,2],[6.8,3.0,5.5,2.1,2],[5.7,2.5,5.0,2.0,2],[5.8,2.8,5.1,2.4,2],
      [6.4,3.2,5.3,2.3,2],[6.5,3.0,5.5,1.8,2],[7.7,3.8,6.7,2.2,2],[7.7,2.6,6.9,2.3,2],[6.0,2.2,5.0,1.5,2],
      [6.9,3.2,5.7,2.3,2],[5.6,2.8,4.9,2.0,2],[7.7,2.8,6.7,2.0,2],[6.3,2.7,4.9,1.8,2],[6.7,3.3,5.7,2.1,2],
      [7.2,3.2,6.0,1.8,2],[6.2,2.8,4.8,1.8,2],[6.1,3.0,4.9,1.8,2],[6.4,2.8,5.6,2.1,2],[7.2,3.0,5.8,1.6,2],
      [7.4,2.8,6.1,1.9,2],[7.9,3.8,6.4,2.0,2],[6.4,2.8,5.6,2.2,2],[6.3,2.8,5.1,1.5,2],[6.1,2.6,5.6,1.4,2],
      [7.7,3.0,6.1,2.3,2],[6.3,3.4,5.6,2.4,2],[6.4,3.1,5.5,1.8,2],[6.0,3.0,4.8,1.8,2],[6.9,3.1,5.4,2.1,2],
      [6.7,3.1,5.6,2.4,2],[6.9,3.1,5.1,2.3,2],[5.8,2.7,5.1,1.9,2],[6.8,3.2,5.9,2.3,2],[6.7,3.3,5.7,2.5,2],
      [6.7,3.0,5.2,2.3,2],[6.3,2.5,5.0,1.9,2],[6.5,3.0,5.2,2.0,2],[6.2,3.4,5.4,2.3,2],[5.9,3.0,5.1,1.8,2]
    ];
    var NF = 4, NC = 3;
    var COLS = ["#67e8f9", "#fbbf24", "#a78bfa"];
    var NAMES = ["setosa", "versicolor", "virginica"];
    var mu = [], sd = [];                     // standardization stats (over all data)
    var data = [];                            // standardized {f:[4], y}
    var trainIdx = [], testIdx = [];
    var Wm = [], Bm = [];                     // Wm[class][feat], Bm[class]
    var fx = 2, fy = 3, splitFrac = 0.3, lr = 0.32;
    var epoch = 0, testAcc = NaN, running = false, raf = null;
    var confM = null, prec = [], rec = [];

    function standardize(){
      mu = [0,0,0,0]; sd = [0,0,0,0];
      var i, j, n = IRIS_RAW.length;
      for (i = 0; i < n; i++) for (j = 0; j < NF; j++) mu[j] += IRIS_RAW[i][j];
      for (j = 0; j < NF; j++) mu[j] /= n;
      for (i = 0; i < n; i++) for (j = 0; j < NF; j++){ var d = IRIS_RAW[i][j] - mu[j]; sd[j] += d * d; }
      for (j = 0; j < NF; j++){ sd[j] = Math.sqrt(sd[j] / n) || 1; }
      data = [];
      for (i = 0; i < n; i++){
        var f = []; for (j = 0; j < NF; j++) f.push((IRIS_RAW[i][j] - mu[j]) / sd[j]);
        data.push({ f: f, y: IRIS_RAW[i][4] });
      }
    }
    function resplit(){
      trainIdx = []; testIdx = [];
      // stratified: split within each class so all three are represented
      for (var c = 0; c < NC; c++){
        var idx = []; for (var i = 0; i < data.length; i++) if (data[i].y === c) idx.push(i);
        // Fisher-Yates shuffle
        for (var k = idx.length - 1; k > 0; k--){ var j = (Math.random() * (k + 1)) | 0; var t = idx[k]; idx[k] = idx[j]; idx[j] = t; }
        var nTest = Math.round(idx.length * splitFrac);
        for (var m = 0; m < idx.length; m++){ if (m < nTest) testIdx.push(idx[m]); else trainIdx.push(idx[m]); }
      }
      initNet(); epoch = 0; testAcc = NaN; confM = null; prec = []; rec = [];
    }
    function initNet(){
      Wm = []; Bm = [];
      for (var c = 0; c < NC; c++){ var row = []; for (var j = 0; j < NF; j++) row.push(rnd(-0.1, 0.1)); Wm.push(row); Bm.push(0); }
    }
    function softmax(f){
      var z = [], i;
      for (var c = 0; c < NC; c++){ var s = Bm[c]; for (i = 0; i < NF; i++) s += Wm[c][i] * f[i]; z.push(s); }
      var mx = z[0]; for (i = 1; i < NC; i++) if (z[i] > mx) mx = z[i];
      var sum = 0, p = [];
      for (i = 0; i < NC; i++){ var e = Math.exp(z[i] - mx); p.push(e); sum += e; }
      for (i = 0; i < NC; i++) p[i] /= sum;
      return p;
    }
    function trainEpoch(){
      var gW = [], gB = [], c, j;
      for (c = 0; c < NC; c++){ gW.push([0,0,0,0]); gB.push(0); }
      var n = trainIdx.length;
      for (var s = 0; s < n; s++){
        var d = data[trainIdx[s]], p = softmax(d.f);
        for (c = 0; c < NC; c++){
          var err = p[c] - (c === d.y ? 1 : 0);
          for (j = 0; j < NF; j++) gW[c][j] += err * d.f[j];
          gB[c] += err;
        }
      }
      for (c = 0; c < NC; c++){
        for (j = 0; j < NF; j++) Wm[c][j] -= lr * gW[c][j] / n;
        Bm[c] -= lr * gB[c] / n;
      }
      epoch++;
    }
    function predict(f){ var p = softmax(f), bi = 0, bv = p[0]; for (var c = 1; c < NC; c++) if (p[c] > bv){ bv = p[c]; bi = c; } return bi; }

    function evaluate(){
      confM = []; for (var a = 0; a < NC; a++){ confM.push([0,0,0]); }
      var correct = 0;
      for (var s = 0; s < testIdx.length; s++){
        var d = data[testIdx[s]], pr = predict(d.f);
        confM[d.y][pr]++;
        if (pr === d.y) correct++;
      }
      testAcc = testIdx.length ? correct / testIdx.length : NaN;
      prec = []; rec = [];
      for (var c = 0; c < NC; c++){
        var colSum = 0, rowSum = 0;
        for (var t = 0; t < NC; t++){ colSum += confM[t][c]; rowSum += confM[c][t]; }
        prec.push(colSum ? confM[c][c] / colSum : NaN);
        rec.push(rowSum ? confM[c][c] / rowSum : NaN);
      }
    }

    // map a standardized feature value back to a pixel via min/max of that feature
    function featRange(fi){
      var lo = Infinity, hi = -Infinity;
      for (var i = 0; i < data.length; i++){ var v = data[i].f[fi]; if (v < lo) lo = v; if (v > hi) hi = v; }
      var pad = (hi - lo) * 0.08; return { lo: lo - pad, hi: hi + pad };
    }
    function draw(){
      ctx.clearRect(0, 0, W, H); ctx.fillStyle = "#0a0a0c"; ctx.fillRect(0, 0, W, H);
      var rx = featRange(fx), ry = featRange(fy);
      // mean (standardized) for the two held features
      var meanF = [0,0,0,0]; // standardized mean is ~0 by construction
      // decision regions on a coarse grid
      var cell = 10;
      var img = ctx.createImageData(W, H);
      var fillRGB = [[40,90,100],[90,72,30],[64,52,96]];
      for (var gy = 0; gy < H; gy += cell){
        for (var gx = 0; gx < W; gx += cell){
          var vx = rx.lo + (gx + cell/2) / W * (rx.hi - rx.lo);
          var vy = ry.lo + (1 - (gy + cell/2) / H) * (ry.hi - ry.lo);
          var f = meanF.slice(); f[fx] = vx; f[fy] = vy;
          var c = predict(f), rgb = fillRGB[c];
          for (var yy = gy; yy < gy + cell && yy < H; yy++){
            for (var xx = gx; xx < gx + cell && xx < W; xx++){
              var idx = (yy * W + xx) * 4;
              img.data[idx] = rgb[0]; img.data[idx+1] = rgb[1]; img.data[idx+2] = rgb[2]; img.data[idx+3] = 70;
            }
          }
        }
      }
      ctx.putImageData(img, 0, 0);
      function toX(v){ return (v - rx.lo) / (rx.hi - rx.lo) * W; }
      function toY(v){ return (1 - (v - ry.lo) / (ry.hi - ry.lo)) * H; }
      // training points = rings, test points = filled
      var isTest = {}; for (var s = 0; s < testIdx.length; s++) isTest[testIdx[s]] = true;
      for (var i = 0; i < data.length; i++){
        var d = data[i], X = toX(d.f[fx]), Y = toY(d.f[fy]);
        ctx.lineWidth = 1.6;
        if (isTest[i]){ ctx.fillStyle = COLS[d.y]; ctx.strokeStyle = "#0a0a0c"; ctx.beginPath(); ctx.arc(X, Y, 5, 0, 6.2832); ctx.fill(); ctx.stroke(); }
        else { ctx.strokeStyle = COLS[d.y]; ctx.beginPath(); ctx.arc(X, Y, 4.2, 0, 6.2832); ctx.stroke(); }
      }
      // axis labels
      ctx.fillStyle = "#9aa0aa"; ctx.font = "11px ui-monospace";
      ctx.fillText(["sepal length","sepal width","petal length","petal width"][fx] + " (x)", 12, H - 10);
      ctx.save(); ctx.translate(14, 20); ctx.fillText(["sepal length","sepal width","petal length","petal width"][fy] + " (y)", 0, 0); ctx.restore();

      document.getElementById("irAcc").textContent = isFinite(testAcc) ? (testAcc * 100).toFixed(1) + "%" : "--";
      document.getElementById("irE").textContent = epoch;
      drawConf();
    }
    function drawConf(){
      cctx.clearRect(0, 0, conf.width, conf.height); cctx.fillStyle = "#0a0a0c"; cctx.fillRect(0, 0, conf.width, conf.height);
      var ox = 70, oy = 30, cellW = (conf.width - ox - 8) / NC, cellH = (conf.height - oy - 30) / NC;
      if (!confM){
        cctx.fillStyle = "#9aa0aa"; cctx.font = "11px ui-monospace"; cctx.fillText("train to populate", 80, conf.height / 2); return;
      }
      var maxc = 1; for (var a = 0; a < NC; a++) for (var b = 0; b < NC; b++) if (confM[a][b] > maxc) maxc = confM[a][b];
      cctx.font = "9px ui-monospace";
      cctx.fillStyle = "#9aa0aa";
      cctx.fillText("pred ->", ox, 12);
      cctx.fillText("true", 4, 24);
      for (var t = 0; t < NC; t++){
        // row label
        cctx.fillStyle = COLS[t]; cctx.font = "9px ui-monospace";
        cctx.fillText(NAMES[t].slice(0, 6), 6, oy + t * cellH + cellH / 2 + 3);
        // col label
        cctx.fillText(NAMES[t].slice(0, 4), ox + t * cellW + cellW / 2 - 8, oy - 4);
        for (var p = 0; p < NC; p++){
          var v = confM[t][p], it = v / maxc;
          var onDiag = (t === p);
          var base = onDiag ? [60, 130, 90] : [120, 50, 55];
          cctx.fillStyle = "rgba(" + base[0] + "," + base[1] + "," + base[2] + "," + (0.18 + it * 0.7).toFixed(3) + ")";
          cctx.fillRect(ox + p * cellW, oy + t * cellH, cellW - 2, cellH - 2);
          cctx.fillStyle = "#e8e8ee"; cctx.font = "13px ui-monospace";
          cctx.fillText(String(v), ox + p * cellW + cellW / 2 - 4, oy + t * cellH + cellH / 2 + 4);
        }
      }
      // precision/recall text
      var html = "";
      for (var c = 0; c < NC; c++){
        html += '<div><span style="color:' + COLS[c] + '">' + NAMES[c] + '</span> &nbsp; P ' + (isFinite(prec[c]) ? (prec[c] * 100).toFixed(0) + "%" : "--") + ' / R ' + (isFinite(rec[c]) ? (rec[c] * 100).toFixed(0) + "%" : "--") + '</div>';
      }
      document.getElementById("irPR").innerHTML = html;
    }
    function loop(){ if (!running) return; for (var s = 0; s < 6; s++) trainEpoch(); evaluate(); draw(); if (epoch > 600){ running = false; document.getElementById("irRun").textContent = "Train"; return; } raf = requestAnimationFrame(loop); }

    document.getElementById("irFx").addEventListener("change", function(){ fx = parseInt(this.value, 10); draw(); });
    document.getElementById("irFy").addEventListener("change", function(){ fy = parseInt(this.value, 10); draw(); });
    document.getElementById("irSplit").addEventListener("input", function(){ splitFrac = parseFloat(this.value); document.getElementById("irSplitV").textContent = fmt(splitFrac, 2); resplit(); draw(); });
    document.getElementById("irLr").addEventListener("input", function(){ lr = Math.pow(10, parseFloat(this.value)); document.getElementById("irLrV").textContent = fmt(lr, 2); });
    document.getElementById("irRun").addEventListener("click", function(){ running = !running; this.textContent = running ? "Pause" : "Train"; if (running) loop(); });
    document.getElementById("irResplit").addEventListener("click", function(){ running = false; document.getElementById("irRun").textContent = "Train"; resplit(); draw(); });

    lr = Math.pow(10, parseFloat(document.getElementById("irLr").value));
    document.getElementById("irLrV").textContent = fmt(lr, 2);
    standardize(); resplit(); draw();
    return { draw: draw };
  })();

  // ---------- boot ----------
  switchExp("reg");

})();
</script>
</BaseLayout>
