---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="AI & Machine Learning · Virtual Labs · AquinTutor" description="Train models live — gradient-descent regression, k-means, k-NN, and a real backprop neural net.">
<style>
  body { background:#0a0a0c; color:#e8e8ee; margin:0; font-family:ui-monospace,'Geist Mono',monospace; }
  .wrap { max-width:1180px; margin:0 auto; padding:40px 24px 96px; }
  .back { display:inline-flex; align-items:center; gap:7px; font-family:'Geist Mono',ui-monospace,monospace; font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:#9aa0aa; text-decoration:none; margin-bottom:26px; }
  .back:hover { color:#67e8f9; }
  .back svg { width:14px; height:14px; }
  .eyebrow { font-family:'Geist Mono',ui-monospace,monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin-bottom:12px; }
  h1.title { font-family:'Cormorant Garamond',Georgia,serif; font-size:clamp(34px,5vw,52px); font-weight:600; letter-spacing:-0.02em; line-height:1.05; margin:0 0 12px; }
  h1.title em { color:#a78bfa; font-style:italic; font-weight:500; }
  .lede { color:#9aa0aa; max-width:720px; font-size:14px; line-height:1.65; margin-bottom:26px; font-family:ui-monospace,'Geist Mono',monospace; }
  .tabs { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:22px; border-bottom:1px solid #2a2a35; padding-bottom:0; }
  .tab { background:transparent; border:1px solid transparent; border-bottom:none; color:#9aa0aa; padding:10px 16px; font-family:'Geist Mono',ui-monospace,monospace; font-size:12px; letter-spacing:0.04em; cursor:pointer; border-radius:8px 8px 0 0; position:relative; top:1px; }
  .tab:hover { color:#e8e8ee; }
  .tab.active { color:#0a0a0c; background:#67e8f9; font-weight:700; }
  .tab .num { opacity:0.7; margin-right:7px; }
  .view { display:none; }
  .view.active { display:block; }
  .grid { display:grid; grid-template-columns:minmax(0,1fr) 320px; gap:18px; align-items:start; }
  @media (max-width:920px){ .grid { grid-template-columns:1fr; } }
  .panel { background:#11131a; border:1px solid #2a2a35; border-radius:12px; padding:16px; }
  .panel h3 { font-family:'Geist Mono',ui-monospace,monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin:0 0 12px; }
  canvas { display:block; width:100%; background:#0a0a0c; border:1px solid #2a2a35; border-radius:10px; cursor:crosshair; }
  canvas.loss { cursor:default; height:150px; margin-top:14px; }
  .row { display:flex; gap:10px; align-items:center; margin-bottom:13px; flex-wrap:wrap; }
  .row > label { font-family:'Geist Mono',ui-monospace,monospace; font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:#9aa0aa; min-width:74px; }
  select, input[type=range] { background:#0a0a0c; border:1px solid #2a2a35; color:#fff; padding:7px 10px; border-radius:5px; font-family:'Geist Mono',ui-monospace,monospace; font-size:12px; flex:1; }
  input[type=range] { padding:0; height:24px; accent-color:#a78bfa; }
  .val { font-family:'Geist Mono',ui-monospace,monospace; font-size:12px; color:#fbbf24; min-width:54px; text-align:right; }
  .btn { background:#67e8f9; color:#04161b; padding:9px 14px; border:none; border-radius:6px; font-family:'Geist Mono',ui-monospace,monospace; font-size:11px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; cursor:pointer; }
  .btn:hover { background:#7ff0ff; }
  .btn.purple { background:#a78bfa; color:#0a0a0c; }
  .btn.purple:hover { background:#bda5ff; }
  .btn.ghost { background:transparent; color:#cfd6da; border:1px solid #2a2a35; }
  .btn.ghost:hover { border-color:#67e8f9; color:#67e8f9; }
  .btn:disabled { opacity:0.4; cursor:not-allowed; }
  .btns { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:6px; }
  .btns .full { grid-column:1 / -1; }
  .stats { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:14px; }
  .stat { background:#0a0a0c; border:1px solid #2a2a35; border-radius:6px; padding:8px 10px; }
  .stat .label { font-family:'Geist Mono',ui-monospace,monospace; font-size:9px; letter-spacing:0.13em; text-transform:uppercase; color:#9aa0aa; }
  .stat .value { font-family:'Geist Mono',ui-monospace,monospace; font-size:18px; color:#86efac; font-weight:700; margin-top:2px; word-break:break-all; }
  .stat .value.cy { color:#67e8f9; } .stat .value.pu { color:#a78bfa; } .stat .value.am { color:#fbbf24; }
  .helptext { font-family:'Geist Mono',ui-monospace,monospace; font-size:10px; color:#9aa0aa; line-height:1.7; margin-top:12px; }
  .helptext code { color:#67e8f9; background:#0a0a0c; padding:1px 5px; border-radius:3px; }
  .helptext strong { color:#e8e8ee; }
  .legend { display:flex; flex-wrap:wrap; gap:12px; margin-top:12px; font-family:'Geist Mono',ui-monospace,monospace; font-size:10px; color:#cfd6da; }
  .legend > span { display:inline-flex; align-items:center; gap:6px; }
  .dot { width:11px; height:11px; border-radius:50%; display:inline-block; }
  .seg { display:inline-flex; border:1px solid #2a2a35; border-radius:6px; overflow:hidden; }
  .seg button { background:#0a0a0c; color:#9aa0aa; border:none; padding:7px 12px; font-family:'Geist Mono',ui-monospace,monospace; font-size:11px; cursor:pointer; }
  .seg button.on { background:#a78bfa; color:#0a0a0c; font-weight:700; }
</style>
<main class="wrap">
  <a class="back" href="/aquintutor/labs">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    All virtual labs
  </a>
  <div class="eyebrow">Lab 15 &middot; Artificial Intelligence</div>
  <h1 class="title">AI &amp; Machine <em>Learning</em></h1>
  <p class="lede">Four models that genuinely train in your browser — no precomputed results, no libraries. Hand-rolled gradient descent, Lloyd's algorithm, Euclidean k-NN, and full backpropagation. Click the canvases to feed in your own data and watch the math converge.</p>

  <div class="tabs" id="tabs">
    <button class="tab active" data-tab="reg"><span class="num">01</span>Linear regression</button>
    <button class="tab" data-tab="km"><span class="num">02</span>K-means</button>
    <button class="tab" data-tab="knn"><span class="num">03</span>k-NN classifier</button>
    <button class="tab" data-tab="nn"><span class="num">04</span>Neural network</button>
  </div>

  <!-- ============ 1. LINEAR REGRESSION ============ -->
  <section class="view active" id="view-reg">
    <div class="grid">
      <div class="panel">
        <h3>Gradient descent &middot; MSE loss</h3>
        <canvas id="regCanvas" width="760" height="440"></canvas>
        <canvas id="regLoss" class="loss" width="760" height="150"></canvas>
        <div class="helptext"><strong>Click</strong> the plot to drop <code>(x, y)</code> points. Gradient descent fits <code>y = w&middot;x + b</code> by minimising mean-squared error; the line and loss curve update every epoch.</div>
      </div>
      <div>
        <div class="panel">
          <h3>Controls</h3>
          <div class="row"><label>Learn rate</label><input type="range" id="regLr" min="-4" max="0" step="0.05" value="-1.3"><span class="val" id="regLrV">0.05</span></div>
          <div class="btns">
            <button class="btn" id="regRun">Train</button>
            <button class="btn ghost" id="regStep">Step</button>
            <button class="btn ghost full" id="regSeed">Sample data</button>
            <button class="btn ghost full" id="regClear">Clear points</button>
          </div>
          <div class="stats">
            <div class="stat"><div class="label">weight w</div><div class="value cy" id="regW">0.000</div></div>
            <div class="stat"><div class="label">bias b</div><div class="value pu" id="regB">0.000</div></div>
            <div class="stat"><div class="label">MSE loss</div><div class="value" id="regL">--</div></div>
            <div class="stat"><div class="label">epoch</div><div class="value am" id="regE">0</div></div>
          </div>
        </div>
        <div class="panel" style="margin-top:14px;">
          <h3>R&sup2; goodness of fit</h3>
          <div class="stat"><div class="value am" id="regR2" style="font-size:24px;">--</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ 2. K-MEANS ============ -->
  <section class="view" id="view-km">
    <div class="grid">
      <div class="panel">
        <h3>Lloyd's algorithm</h3>
        <canvas id="kmCanvas" width="760" height="500"></canvas>
        <div class="helptext"><strong>Crosses</strong> are centroids; points recolour to their nearest centroid each iteration. Inertia is the total within-cluster squared distance — it only ever decreases.</div>
      </div>
      <div>
        <div class="panel">
          <h3>Controls</h3>
          <div class="row"><label>Clusters k</label><input type="range" id="kmK" min="2" max="6" step="1" value="3"><span class="val" id="kmKV">3</span></div>
          <div class="row"><label>Points</label><input type="range" id="kmN" min="60" max="400" step="20" value="220"><span class="val" id="kmNV">220</span></div>
          <div class="btns">
            <button class="btn purple" id="kmRun">Run Lloyd</button>
            <button class="btn ghost" id="kmStep">Step</button>
            <button class="btn ghost full" id="kmReseed">Re-seed blobs</button>
          </div>
          <div class="stats">
            <div class="stat"><div class="label">iteration</div><div class="value am" id="kmIt">0</div></div>
            <div class="stat"><div class="label">inertia</div><div class="value pu" id="kmIn">--</div></div>
            <div class="stat"><div class="label">moved</div><div class="value cy" id="kmMv">--</div></div>
            <div class="stat"><div class="label">status</div><div class="value" id="kmSt">idle</div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ 3. k-NN ============ -->
  <section class="view" id="view-knn">
    <div class="grid">
      <div class="panel">
        <h3>k-Nearest-Neighbours decision regions</h3>
        <canvas id="knnCanvas" width="760" height="500"></canvas>
        <div class="legend">
          <span><span class="dot" style="background:#67e8f9;"></span>Class A</span>
          <span><span class="dot" style="background:#fbbf24;"></span>Class B</span>
          <span>Shaded = predicted region (majority vote of k nearest)</span>
        </div>
        <div class="helptext"><strong>Click</strong> to place a point of the active class. The grid is reclassified live by real Euclidean distance whenever you add a point or change k.</div>
      </div>
      <div>
        <div class="panel">
          <h3>Controls</h3>
          <div class="row"><label>Active</label>
            <div class="seg" id="knnSeg">
              <button class="on" data-cls="0">Class A</button>
              <button data-cls="1">Class B</button>
            </div>
          </div>
          <div class="row"><label>Neighbours k</label><input type="range" id="knnK" min="1" max="15" step="2" value="5"><span class="val" id="knnKV">5</span></div>
          <div class="btns">
            <button class="btn ghost" id="knnSeed">Sample data</button>
            <button class="btn ghost" id="knnClear">Clear</button>
          </div>
          <div class="stats">
            <div class="stat"><div class="label">class A pts</div><div class="value cy" id="knnA">0</div></div>
            <div class="stat"><div class="label">class B pts</div><div class="value am" id="knnB">0</div></div>
          </div>
          <div class="helptext">Grid resolution is adaptive. Every cell is classified by majority vote over its <code>k</code> nearest training points.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ 4. NEURAL NETWORK ============ -->
  <section class="view" id="view-nn">
    <div class="grid">
      <div class="panel">
        <h3>2 &rarr; 8 &rarr; 8 &rarr; 1 MLP &middot; backpropagation</h3>
        <canvas id="nnCanvas" width="760" height="440"></canvas>
        <canvas id="nnLoss" class="loss" width="760" height="150"></canvas>
        <div class="helptext">A real multilayer perceptron with two tanh hidden layers and a sigmoid output, trained by backprop + full-batch gradient descent. The background shading is the network's live prediction surface; the loss is binary cross-entropy.</div>
      </div>
      <div>
        <div class="panel">
          <h3>Controls</h3>
          <div class="row"><label>Dataset</label>
            <select id="nnData">
              <option value="xor">XOR</option>
              <option value="circles">Two circles</option>
              <option value="moons">Two moons</option>
              <option value="spiral">Spiral</option>
            </select>
          </div>
          <div class="row"><label>Learn rate</label><input type="range" id="nnLr" min="-3" max="0.3" step="0.05" value="-0.7"><span class="val" id="nnLrV">0.20</span></div>
          <div class="btns">
            <button class="btn purple" id="nnRun">Train</button>
            <button class="btn ghost" id="nnReset">Reset</button>
          </div>
          <div class="stats">
            <div class="stat"><div class="label">epoch</div><div class="value am" id="nnE">0</div></div>
            <div class="stat"><div class="label">BCE loss</div><div class="value pu" id="nnL">--</div></div>
            <div class="stat"><div class="label">accuracy</div><div class="value cy" id="nnAcc">--</div></div>
            <div class="stat"><div class="label">status</div><div class="value" id="nnSt">idle</div></div>
          </div>
          <div class="helptext">Weights use Xavier initialisation. Decision boundary is recomputed on a coarse grid each frame through a real forward pass.</div>
        </div>
      </div>
    </div>
  </section>
</main>

<script is:inline>
(function(){
  "use strict";

  // ---------- shared helpers ----------
  function rnd(a, b){ return a + Math.random() * (b - a); }
  function gauss(){ // Box-Muller standard normal
    var u = 1 - Math.random(), v = Math.random();
    return Math.sqrt(-2 * Math.log(u)) * Math.cos(2 * Math.PI * v);
  }
  function clamp(x, lo, hi){ return x < lo ? lo : (x > hi ? hi : x); }
  function fmt(x, d){ if (!isFinite(x)) return "--"; return x.toFixed(d == null ? 3 : d); }

  // ---------- tab switching ----------
  var tabs = document.getElementById("tabs").querySelectorAll(".tab");
  var views = { reg: document.getElementById("view-reg"), km: document.getElementById("view-km"), knn: document.getElementById("view-knn"), nn: document.getElementById("view-nn") };
  for (var i = 0; i < tabs.length; i++){
    (function(t){
      t.addEventListener("click", function(){
        for (var j = 0; j < tabs.length; j++) tabs[j].classList.remove("active");
        t.classList.add("active");
        for (var k in views) views[k].classList.remove("active");
        views[t.getAttribute("data-tab")].classList.add("active");
        if (t.getAttribute("data-tab") === "km") KM.draw();
        if (t.getAttribute("data-tab") === "knn") KNN.render();
        if (t.getAttribute("data-tab") === "nn") NN.draw();
        if (t.getAttribute("data-tab") === "reg") REG.draw();
      });
    })(tabs[i]);
  }

  // canvas pixel-coordinate helper (account for CSS scaling)
  function evtXY(canvas, e){
    var r = canvas.getBoundingClientRect();
    return { x: (e.clientX - r.left) * (canvas.width / r.width), y: (e.clientY - r.top) * (canvas.height / r.height) };
  }

  // ======================================================================
  // 1. LINEAR REGRESSION via GRADIENT DESCENT
  // ======================================================================
  var REG = (function(){
    var cv = document.getElementById("regCanvas"), ctx = cv.getContext("2d");
    var lc = document.getElementById("regLoss"), lctx = lc.getContext("2d");
    var W = cv.width, H = cv.height;
    var pts = [];           // data-space points {x:0..1, y:0..1}
    var w = 0, b = 0;       // model params (in normalised space)
    var epoch = 0, loss = NaN, lossHist = [], running = false, raf = null;
    var lr = 0.05;

    function lrFromSlider(){ lr = Math.pow(10, parseFloat(document.getElementById("regLr").value)); document.getElementById("regLrV").textContent = lr < 0.001 ? lr.toExponential(1) : fmt(lr, 4); }

    // map data [0,1] -> pixels
    function px(x){ return 40 + x * (W - 70); }
    function py(y){ return (H - 40) - y * (H - 70); }
    function invX(sx){ return (sx - 40) / (W - 70); }
    function invY(sy){ return ((H - 40) - sy) / (H - 70); }

    function reset(){ w = rnd(-0.5, 0.5); b = rnd(0.2, 0.6); epoch = 0; loss = NaN; lossHist = []; }

    function computeLoss(){
      if (!pts.length) return NaN;
      var s = 0;
      for (var i = 0; i < pts.length; i++){ var e = (w * pts[i].x + b) - pts[i].y; s += e * e; }
      return s / pts.length;
    }

    function step(){
      if (pts.length < 2) return;
      // gradients of MSE = (1/n) sum (w x + b - y)^2
      var gw = 0, gb = 0, n = pts.length;
      for (var i = 0; i < n; i++){
        var pr = w * pts[i].x + b;
        var err = pr - pts[i].y;
        gw += err * pts[i].x;
        gb += err;
      }
      gw = (2 / n) * gw; gb = (2 / n) * gb;
      w -= lr * gw; b -= lr * gb;
      epoch++;
      loss = computeLoss();
      lossHist.push(loss);
      if (lossHist.length > 600) lossHist.shift();
    }

    function r2(){
      if (pts.length < 2) return NaN;
      var mean = 0, i; for (i = 0; i < pts.length; i++) mean += pts[i].y; mean /= pts.length;
      var ssTot = 0, ssRes = 0;
      for (i = 0; i < pts.length; i++){
        var pr = w * pts[i].x + b;
        ssRes += (pts[i].y - pr) * (pts[i].y - pr);
        ssTot += (pts[i].y - mean) * (pts[i].y - mean);
      }
      return ssTot === 0 ? 0 : 1 - ssRes / ssTot;
    }

    function grid(){
      ctx.strokeStyle = "#1a1c24"; ctx.lineWidth = 1;
      for (var g = 0; g <= 10; g++){
        ctx.beginPath(); ctx.moveTo(px(g/10), py(0)); ctx.lineTo(px(g/10), py(1)); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(px(0), py(g/10)); ctx.lineTo(px(1), py(g/10)); ctx.stroke();
      }
      ctx.strokeStyle = "#2a2a35"; ctx.lineWidth = 1.5;
      ctx.beginPath(); ctx.moveTo(px(0), py(0)); ctx.lineTo(px(1), py(0)); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(px(0), py(0)); ctx.lineTo(px(0), py(1)); ctx.stroke();
    }

    function draw(){
      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = "#0a0a0c"; ctx.fillRect(0, 0, W, H);
      grid();
      // fitted line
      if (pts.length >= 1){
        ctx.strokeStyle = "#a78bfa"; ctx.lineWidth = 2.5;
        ctx.beginPath();
        var y0 = w * 0 + b, y1 = w * 1 + b;
        ctx.moveTo(px(0), py(clamp(y0, -0.5, 1.5))); ctx.lineTo(px(1), py(clamp(y1, -0.5, 1.5)));
        ctx.stroke();
      }
      // residuals + points
      for (var i = 0; i < pts.length; i++){
        var pr = w * pts[i].x + b;
        ctx.strokeStyle = "rgba(252,165,165,0.35)"; ctx.lineWidth = 1;
        ctx.beginPath(); ctx.moveTo(px(pts[i].x), py(pts[i].y)); ctx.lineTo(px(pts[i].x), py(pr)); ctx.stroke();
        ctx.fillStyle = "#67e8f9";
        ctx.beginPath(); ctx.arc(px(pts[i].x), py(pts[i].y), 4, 0, 6.2832); ctx.fill();
      }
      drawLoss();
      document.getElementById("regW").textContent = fmt(w, 3);
      document.getElementById("regB").textContent = fmt(b, 3);
      document.getElementById("regL").textContent = isFinite(loss) ? fmt(loss, 5) : "--";
      document.getElementById("regE").textContent = epoch;
      var r = r2(); document.getElementById("regR2").textContent = isFinite(r) ? fmt(r, 4) : "--";
    }

    function drawLoss(){
      lctx.clearRect(0, 0, lc.width, lc.height);
      lctx.fillStyle = "#0a0a0c"; lctx.fillRect(0, 0, lc.width, lc.height);
      lctx.fillStyle = "#9aa0aa"; lctx.font = "10px ui-monospace";
      lctx.fillText("MSE loss", 8, 14);
      if (lossHist.length < 2) return;
      var mx = 0; for (var i = 0; i < lossHist.length; i++) if (lossHist[i] > mx) mx = lossHist[i];
      if (mx <= 0) mx = 1;
      lctx.strokeStyle = "#fbbf24"; lctx.lineWidth = 2; lctx.beginPath();
      for (var j = 0; j < lossHist.length; j++){
        var x = 8 + j / (lossHist.length - 1) * (lc.width - 16);
        var y = lc.height - 12 - (lossHist[j] / mx) * (lc.height - 30);
        if (j === 0) lctx.moveTo(x, y); else lctx.lineTo(x, y);
      }
      lctx.stroke();
    }

    function loop(){ if (!running) return; for (var s = 0; s < 3; s++) step(); draw(); if (loss < 1e-7 && epoch > 30){ running = false; document.getElementById("regRun").textContent = "Train"; return; } raf = requestAnimationFrame(loop); }

    function seedSample(){
      pts = [];
      var tw = rnd(0.5, 1.4), tb = rnd(0.05, 0.4);
      for (var i = 0; i < 26; i++){ var x = rnd(0.04, 0.96); var y = clamp(tw * x + tb + gauss() * 0.06, 0.01, 0.99); pts.push({ x: x, y: y }); }
      reset(); draw();
    }

    cv.addEventListener("click", function(e){
      var p = evtXY(cv, e);
      var x = invX(p.x), y = invY(p.y);
      if (x < -0.02 || x > 1.02 || y < -0.02 || y > 1.02) return;
      pts.push({ x: clamp(x, 0, 1), y: clamp(y, 0, 1) });
      loss = computeLoss(); draw();
    });
    document.getElementById("regLr").addEventListener("input", lrFromSlider);
    document.getElementById("regRun").addEventListener("click", function(){
      if (pts.length < 2) return;
      running = !running; this.textContent = running ? "Pause" : "Train";
      if (running) loop();
    });
    document.getElementById("regStep").addEventListener("click", function(){ for (var s = 0; s < 5; s++) step(); draw(); });
    document.getElementById("regSeed").addEventListener("click", seedSample);
    document.getElementById("regClear").addEventListener("click", function(){ pts = []; reset(); draw(); });

    lrFromSlider(); reset(); seedSample();
    return { draw: draw };
  })();

  // ======================================================================
  // 2. K-MEANS (Lloyd's algorithm)
  // ======================================================================
  var KM = (function(){
    var cv = document.getElementById("kmCanvas"), ctx = cv.getContext("2d");
    var W = cv.width, H = cv.height;
    var palette = ["#67e8f9", "#a78bfa", "#fbbf24", "#86efac", "#fca5a5", "#f0abfc"];
    var pts = [], cents = [], assign = [], K = 3, N = 220;
    var iter = 0, inertia = NaN, moved = NaN, running = false, raf = null, converged = false;

    function seed(){
      pts = []; iter = 0; inertia = NaN; converged = false;
      var blobs = 2 + ((Math.random() * 4) | 0);
      var centers = [];
      for (var b = 0; b < blobs; b++) centers.push({ x: rnd(0.12, 0.88) * W, y: rnd(0.12, 0.88) * H });
      for (var i = 0; i < N; i++){
        var c = centers[(Math.random() * blobs) | 0];
        var spread = Math.min(W, H) * 0.07;
        pts.push({ x: clamp(c.x + gauss() * spread, 4, W - 4), y: clamp(c.y + gauss() * spread, 4, H - 4) });
      }
      initCents();
    }
    function initCents(){
      // k-means++ style: first random, rest by distance weighting
      cents = []; assign = [];
      cents.push({ x: pts[(Math.random() * pts.length) | 0].x, y: pts[(Math.random() * pts.length) | 0].y });
      while (cents.length < K){
        var d2 = [], sum = 0, i, j;
        for (i = 0; i < pts.length; i++){
          var best = Infinity;
          for (j = 0; j < cents.length; j++){
            var dx = pts[i].x - cents[j].x, dy = pts[i].y - cents[j].y, d = dx * dx + dy * dy;
            if (d < best) best = d;
          }
          d2.push(best); sum += best;
        }
        var r = Math.random() * sum, acc = 0, pick = 0;
        for (i = 0; i < pts.length; i++){ acc += d2[i]; if (acc >= r){ pick = i; break; } }
        cents.push({ x: pts[pick].x, y: pts[pick].y });
      }
      assignAll(); iter = 0; converged = false;
    }
    function assignAll(){
      inertia = 0;
      for (var i = 0; i < pts.length; i++){
        var best = Infinity, bi = 0;
        for (var c = 0; c < cents.length; c++){
          var dx = pts[i].x - cents[c].x, dy = pts[i].y - cents[c].y, d = dx * dx + dy * dy;
          if (d < best){ best = d; bi = c; }
        }
        assign[i] = bi; inertia += best;
      }
    }
    function step(){
      if (converged) return;
      // recompute centroids = mean of assigned points
      var sumx = [], sumy = [], cnt = [], c;
      for (c = 0; c < K; c++){ sumx[c] = 0; sumy[c] = 0; cnt[c] = 0; }
      for (var i = 0; i < pts.length; i++){ var a = assign[i]; sumx[a] += pts[i].x; sumy[a] += pts[i].y; cnt[a]++; }
      moved = 0;
      for (c = 0; c < K; c++){
        if (cnt[c] === 0){ continue; }
        var nx = sumx[c] / cnt[c], ny = sumy[c] / cnt[c];
        moved += Math.sqrt((nx - cents[c].x) * (nx - cents[c].x) + (ny - cents[c].y) * (ny - cents[c].y));
        cents[c].x = nx; cents[c].y = ny;
      }
      assignAll();
      iter++;
      if (moved < 0.4){ converged = true; }
    }
    function draw(){
      ctx.clearRect(0, 0, W, H); ctx.fillStyle = "#0a0a0c"; ctx.fillRect(0, 0, W, H);
      for (var i = 0; i < pts.length; i++){
        ctx.fillStyle = palette[assign[i] % palette.length];
        ctx.globalAlpha = 0.85;
        ctx.beginPath(); ctx.arc(pts[i].x, pts[i].y, 3.2, 0, 6.2832); ctx.fill();
      }
      ctx.globalAlpha = 1;
      for (var c = 0; c < cents.length; c++){
        ctx.strokeStyle = "#e8e8ee"; ctx.lineWidth = 3;
        var s = 9, cx = cents[c].x, cy = cents[c].y;
        ctx.beginPath(); ctx.moveTo(cx - s, cy); ctx.lineTo(cx + s, cy); ctx.moveTo(cx, cy - s); ctx.lineTo(cx, cy + s); ctx.stroke();
        ctx.strokeStyle = palette[c % palette.length]; ctx.lineWidth = 1.5;
        ctx.beginPath(); ctx.arc(cx, cy, 12, 0, 6.2832); ctx.stroke();
      }
      document.getElementById("kmIt").textContent = iter;
      document.getElementById("kmIn").textContent = isFinite(inertia) ? (inertia / 1000).toFixed(1) + "k" : "--";
      document.getElementById("kmMv").textContent = isFinite(moved) ? fmt(moved, 1) : "--";
      document.getElementById("kmSt").textContent = converged ? "converged" : (running ? "running" : "ready");
    }
    function loop(){ if (!running) return; step(); draw(); if (converged){ running = false; document.getElementById("kmRun").textContent = "Run Lloyd"; return; } raf = requestAnimationFrame(function(){ setTimeout(loop, 260); }); }

    document.getElementById("kmK").addEventListener("input", function(){ K = parseInt(this.value, 10); document.getElementById("kmKV").textContent = K; initCents(); draw(); });
    document.getElementById("kmN").addEventListener("input", function(){ N = parseInt(this.value, 10); document.getElementById("kmNV").textContent = N; seed(); draw(); });
    document.getElementById("kmRun").addEventListener("click", function(){ if (converged) initCents(); running = !running; this.textContent = running ? "Pause" : "Run Lloyd"; if (running) loop(); });
    document.getElementById("kmStep").addEventListener("click", function(){ step(); draw(); });
    document.getElementById("kmReseed").addEventListener("click", function(){ seed(); draw(); });

    seed(); draw();
    return { draw: draw };
  })();

  // ======================================================================
  // 3. k-NN CLASSIFIER
  // ======================================================================
  var KNN = (function(){
    var cv = document.getElementById("knnCanvas"), ctx = cv.getContext("2d");
    var W = cv.width, H = cv.height;
    var pts = [];          // {x,y,c}
    var activeClass = 0, k = 5;
    var cols = ["#67e8f9", "#fbbf24"];
    var fills = [[103,232,249], [251,191,36]];

    function classifyAt(x, y){
      if (pts.length === 0) return -1;
      // partial selection of k nearest via array of distances
      var ds = [];
      for (var i = 0; i < pts.length; i++){
        var dx = pts[i].x - x, dy = pts[i].y - y;
        ds.push({ d: dx * dx + dy * dy, c: pts[i].c });
      }
      ds.sort(function(a, b){ return a.d - b.d; });
      var kk = Math.min(k, ds.length), v0 = 0, v1 = 0;
      for (var j = 0; j < kk; j++){ if (ds[j].c === 0) v0++; else v1++; }
      return v0 === v1 ? (ds[0].c) : (v0 > v1 ? 0 : 1);
    }
    function render(){
      ctx.clearRect(0, 0, W, H); ctx.fillStyle = "#0a0a0c"; ctx.fillRect(0, 0, W, H);
      var cell = 10;
      if (pts.length > 0){
        var img = ctx.createImageData(W, H);
        for (var gy = 0; gy < H; gy += cell){
          for (var gx = 0; gx < W; gx += cell){
            var c = classifyAt(gx + cell / 2, gy + cell / 2);
            var rgb = c < 0 ? [20, 22, 30] : fills[c];
            for (var yy = gy; yy < gy + cell && yy < H; yy++){
              for (var xx = gx; xx < gx + cell && xx < W; xx++){
                var idx = (yy * W + xx) * 4;
                img.data[idx] = rgb[0]; img.data[idx + 1] = rgb[1]; img.data[idx + 2] = rgb[2]; img.data[idx + 3] = c < 0 ? 255 : 46;
              }
            }
          }
        }
        ctx.putImageData(img, 0, 0);
      }
      for (var i = 0; i < pts.length; i++){
        ctx.fillStyle = cols[pts[i].c]; ctx.strokeStyle = "#0a0a0c"; ctx.lineWidth = 1.5;
        ctx.beginPath(); ctx.arc(pts[i].x, pts[i].y, 5, 0, 6.2832); ctx.fill(); ctx.stroke();
      }
      var a = 0, b = 0; for (var p = 0; p < pts.length; p++){ if (pts[p].c === 0) a++; else b++; }
      document.getElementById("knnA").textContent = a;
      document.getElementById("knnB").textContent = b;
    }
    function seedSample(){
      pts = [];
      var i;
      for (i = 0; i < 22; i++) pts.push({ x: clamp(rnd(0.15, 0.45) * W + gauss() * 30, 6, W - 6), y: clamp(rnd(0.2, 0.7) * H + gauss() * 30, 6, H - 6), c: 0 });
      for (i = 0; i < 22; i++) pts.push({ x: clamp(rnd(0.55, 0.85) * W + gauss() * 30, 6, W - 6), y: clamp(rnd(0.3, 0.8) * H + gauss() * 30, 6, H - 6), c: 1 });
      render();
    }
    cv.addEventListener("click", function(e){ var p = evtXY(cv, e); pts.push({ x: p.x, y: p.y, c: activeClass }); render(); });
    var seg = document.getElementById("knnSeg").querySelectorAll("button");
    for (var s = 0; s < seg.length; s++){
      (function(btn){ btn.addEventListener("click", function(){ for (var z = 0; z < seg.length; z++) seg[z].classList.remove("on"); btn.classList.add("on"); activeClass = parseInt(btn.getAttribute("data-cls"), 10); }); })(seg[s]);
    }
    document.getElementById("knnK").addEventListener("input", function(){ k = parseInt(this.value, 10); document.getElementById("knnKV").textContent = k; render(); });
    document.getElementById("knnSeed").addEventListener("click", seedSample);
    document.getElementById("knnClear").addEventListener("click", function(){ pts = []; render(); });

    seedSample();
    return { render: render };
  })();

  // ======================================================================
  // 4. NEURAL NETWORK (real backprop): 2 -> 8 -> 8 -> 1
  // ======================================================================
  var NN = (function(){
    var cv = document.getElementById("nnCanvas"), ctx = cv.getContext("2d");
    var lc = document.getElementById("nnLoss"), lctx = lc.getContext("2d");
    var W = cv.width, H = cv.height;
    var sizes = [2, 8, 8, 1];
    var Wm = [], Bm = [];   // weights[layer][j][i], biases[layer][j]
    var data = [], dataset = "xor";
    var epoch = 0, loss = NaN, acc = NaN, lossHist = [], running = false, raf = null, lr = 0.2;

    function tanh(x){ if (x > 20) return 1; if (x < -20) return -1; var e = Math.exp(2 * x); return (e - 1) / (e + 1); }
    function sigmoid(x){ if (x < -30) return 0; if (x > 30) return 1; return 1 / (1 + Math.exp(-x)); }

    function initNet(){
      Wm = []; Bm = [];
      for (var l = 1; l < sizes.length; l++){
        var nIn = sizes[l - 1], nOut = sizes[l];
        var limit = Math.sqrt(6 / (nIn + nOut)); // Xavier
        var wl = [], bl = [];
        for (var j = 0; j < nOut; j++){
          var row = [];
          for (var i = 0; i < nIn; i++) row.push(rnd(-limit, limit));
          wl.push(row); bl.push(0);
        }
        Wm.push(wl); Bm.push(bl);
      }
      epoch = 0; loss = NaN; acc = NaN; lossHist = [];
    }

    // forward pass; returns activations per layer (a[0] = input)
    function forward(input){
      var a = [input], cur = input;
      for (var l = 0; l < Wm.length; l++){
        var next = [], isLast = (l === Wm.length - 1);
        for (var j = 0; j < Wm[l].length; j++){
          var z = Bm[l][j];
          for (var i = 0; i < cur.length; i++) z += Wm[l][j][i] * cur[i];
          next.push(isLast ? sigmoid(z) : tanh(z));
        }
        a.push(next); cur = next;
      }
      return a;
    }

    function trainEpoch(){
      // accumulate gradients over full batch
      var gW = [], gB = [], l, j, i;
      for (l = 0; l < Wm.length; l++){
        gW[l] = []; gB[l] = [];
        for (j = 0; j < Wm[l].length; j++){ gW[l][j] = []; for (i = 0; i < Wm[l][j].length; i++) gW[l][j][i] = 0; gB[l][j] = 0; }
      }
      var totalLoss = 0, correct = 0, n = data.length;
      for (var s = 0; s < n; s++){
        var x = [data[s].x, data[s].y], target = data[s].c;
        var a = forward(x);
        var out = a[a.length - 1][0];
        var oc = clamp(out, 1e-7, 1 - 1e-7);
        totalLoss += -(target * Math.log(oc) + (1 - target) * Math.log(1 - oc));
        if ((out > 0.5 ? 1 : 0) === target) correct++;

        // backprop: delta for each layer
        var deltas = [];
        for (l = 0; l < Wm.length; l++) deltas[l] = [];
        // output layer (sigmoid + BCE): dL/dz = out - target
        var L = Wm.length - 1;
        deltas[L][0] = out - target;
        // hidden layers (tanh): delta = (W^T delta_next) * (1 - a^2)
        for (l = L - 1; l >= 0; l--){
          var aOut = a[l + 1];
          for (j = 0; j < Wm[l].length; j++){
            var sum = 0;
            for (var jn = 0; jn < Wm[l + 1].length; jn++) sum += Wm[l + 1][jn][j] * deltas[l + 1][jn];
            deltas[l][j] = sum * (1 - aOut[j] * aOut[j]);
          }
        }
        // accumulate gradients
        for (l = 0; l < Wm.length; l++){
          var aPrev = a[l];
          for (j = 0; j < Wm[l].length; j++){
            for (i = 0; i < aPrev.length; i++) gW[l][j][i] += deltas[l][j] * aPrev[i];
            gB[l][j] += deltas[l][j];
          }
        }
      }
      // apply averaged gradients
      for (l = 0; l < Wm.length; l++){
        for (j = 0; j < Wm[l].length; j++){
          for (i = 0; i < Wm[l][j].length; i++) Wm[l][j][i] -= lr * gW[l][j][i] / n;
          Bm[l][j] -= lr * gB[l][j] / n;
        }
      }
      epoch++;
      loss = totalLoss / n;
      acc = correct / n;
      lossHist.push(loss); if (lossHist.length > 700) lossHist.shift();
    }

    function genData(){
      data = []; var i, n;
      if (dataset === "xor"){
        n = 200;
        for (i = 0; i < n; i++){
          var qx = Math.random() < 0.5 ? rnd(0.05, 0.45) : rnd(0.55, 0.95);
          var qy = Math.random() < 0.5 ? rnd(0.05, 0.45) : rnd(0.55, 0.95);
          var c = ((qx > 0.5) !== (qy > 0.5)) ? 1 : 0;
          data.push({ x: qx, y: qy, c: c });
        }
      } else if (dataset === "circles"){
        n = 220;
        for (i = 0; i < n; i++){
          var inner = i < n / 2;
          var rad = inner ? rnd(0, 0.22) : rnd(0.34, 0.48);
          var th = rnd(0, 6.2832);
          data.push({ x: 0.5 + rad * Math.cos(th), y: 0.5 + rad * Math.sin(th), c: inner ? 1 : 0 });
        }
      } else if (dataset === "moons"){
        n = 220;
        for (i = 0; i < n; i++){
          if (i < n / 2){ var t1 = rnd(0, Math.PI); data.push({ x: 0.32 + 0.32 * Math.cos(t1) + gauss() * 0.025, y: 0.62 - 0.30 * Math.sin(t1) + gauss() * 0.025, c: 0 }); }
          else { var t2 = rnd(0, Math.PI); data.push({ x: 0.68 - 0.32 * Math.cos(t2) + gauss() * 0.025, y: 0.40 + 0.30 * Math.sin(t2) + gauss() * 0.025, c: 1 }); }
        }
      } else { // spiral
        n = 240;
        for (i = 0; i < n / 2; i++){
          var r = i / (n / 2) * 0.46;
          var t = i / (n / 2) * 4 + gauss() * 0.12;
          data.push({ x: 0.5 + r * Math.cos(t), y: 0.5 + r * Math.sin(t), c: 0 });
          data.push({ x: 0.5 + r * Math.cos(t + Math.PI), y: 0.5 + r * Math.sin(t + Math.PI), c: 1 });
        }
      }
      for (i = 0; i < data.length; i++){ data[i].x = clamp(data[i].x, 0, 1); data[i].y = clamp(data[i].y, 0, 1); }
    }

    function draw(){
      ctx.clearRect(0, 0, W, H); ctx.fillStyle = "#0a0a0c"; ctx.fillRect(0, 0, W, H);
      // prediction surface on coarse grid
      var cell = 8;
      var img = ctx.createImageData(W, H);
      for (var gy = 0; gy < H; gy += cell){
        for (var gx = 0; gx < W; gx += cell){
          var nx = (gx + cell / 2) / W, ny = (gy + cell / 2) / H;
          var a = forward([nx, ny]);
          var p = a[a.length - 1][0]; // 0..1
          // class1 = amber, class0 = cyan ; intensity by confidence
          var t = clamp((p - 0.5) * 2, -1, 1);
          var rr, gg, bb;
          if (t >= 0){ rr = 80 + t * 171; gg = 60 + t * 131; bb = 30; }   // toward amber
          else { var u = -t; rr = 40; gg = 60 + u * 172; bb = 60 + u * 189; } // toward cyan
          for (var yy = gy; yy < gy + cell && yy < H; yy++){
            for (var xx = gx; xx < gx + cell && xx < W; xx++){
              var idx = (yy * W + xx) * 4;
              img.data[idx] = rr; img.data[idx + 1] = gg; img.data[idx + 2] = bb; img.data[idx + 3] = 70;
            }
          }
        }
      }
      ctx.putImageData(img, 0, 0);
      // data points
      for (var s = 0; s < data.length; s++){
        ctx.fillStyle = data[s].c === 1 ? "#fbbf24" : "#67e8f9";
        ctx.strokeStyle = "#0a0a0c"; ctx.lineWidth = 1.2;
        ctx.beginPath(); ctx.arc(data[s].x * W, data[s].y * H, 4, 0, 6.2832); ctx.fill(); ctx.stroke();
      }
      drawLoss();
      document.getElementById("nnE").textContent = epoch;
      document.getElementById("nnL").textContent = isFinite(loss) ? fmt(loss, 4) : "--";
      document.getElementById("nnAcc").textContent = isFinite(acc) ? (acc * 100).toFixed(1) + "%" : "--";
      document.getElementById("nnSt").textContent = running ? "training" : (epoch ? "paused" : "idle");
    }
    function drawLoss(){
      lctx.clearRect(0, 0, lc.width, lc.height); lctx.fillStyle = "#0a0a0c"; lctx.fillRect(0, 0, lc.width, lc.height);
      lctx.fillStyle = "#9aa0aa"; lctx.font = "10px ui-monospace"; lctx.fillText("BCE loss", 8, 14);
      if (lossHist.length < 2) return;
      var mx = 0; for (var i = 0; i < lossHist.length; i++) if (lossHist[i] > mx) mx = lossHist[i];
      if (mx <= 0) mx = 1;
      lctx.strokeStyle = "#a78bfa"; lctx.lineWidth = 2; lctx.beginPath();
      for (var j = 0; j < lossHist.length; j++){
        var x = 8 + j / (lossHist.length - 1) * (lc.width - 16);
        var y = lc.height - 12 - (lossHist[j] / mx) * (lc.height - 30);
        if (j === 0) lctx.moveTo(x, y); else lctx.lineTo(x, y);
      }
      lctx.stroke();
    }
    function loop(){ if (!running) return; for (var s = 0; s < 4; s++) trainEpoch(); draw(); raf = requestAnimationFrame(loop); }

    document.getElementById("nnData").addEventListener("change", function(){ dataset = this.value; initNet(); genData(); running = false; document.getElementById("nnRun").textContent = "Train"; draw(); });
    document.getElementById("nnLr").addEventListener("input", function(){ lr = Math.pow(10, parseFloat(this.value)); document.getElementById("nnLrV").textContent = fmt(lr, lr < 0.01 ? 4 : 2); });
    document.getElementById("nnRun").addEventListener("click", function(){ running = !running; this.textContent = running ? "Pause" : "Train"; if (running) loop(); });
    document.getElementById("nnReset").addEventListener("click", function(){ running = false; document.getElementById("nnRun").textContent = "Train"; initNet(); draw(); });

    lr = Math.pow(10, parseFloat(document.getElementById("nnLr").value));
    document.getElementById("nnLrV").textContent = fmt(lr, 2);
    initNet(); genData(); draw();
    return { draw: draw };
  })();

})();
</script>
</BaseLayout>
