---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Sorting Visualiser — AquinTutor Labs" description="Interactive visualiser for bubble, insertion, selection, merge, quick, heap, and radix sort. Real step-by-step generators with comparison/swap highlighting and Web Audio feedback.">
<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; font-family: 'Inter', system-ui, sans-serif; }
  .wrap { max-width: 1280px; margin: 0 auto; padding: 32px 24px 80px; }
  .eyebrow { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin-bottom: 10px; }
  h1 { font-family: 'Cormorant Garamond', serif; font-size: 34px; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 8px; color: #e8e8ee; }
  h1 em { font-style: italic; color: #67e8f9; font-weight: 500; }
  .lede { color: #9ba0aa; max-width: 720px; margin: 0 0 24px; font-size: 14px; line-height: 1.6; }
  .grid { display: grid; grid-template-columns: 280px 1fr; gap: 18px; }
  @media (max-width: 900px) { .grid { grid-template-columns: 1fr; } }
  .panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 16px; }
  .panel h3 { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 12px; }
  .row { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
  .row label { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.08em; color: #9ba0aa; text-transform: uppercase; display: flex; justify-content: space-between; }
  .row input[type=range] { width: 100%; accent-color: #67e8f9; }
  .row select, .row input[type=number] { background: #0a0a0c; border: 1px solid #2a2a35; color: #fff; padding: 7px 10px; border-radius: 5px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12px; }
  .btns { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 8px; }
  .btn { background: #67e8f9; color: #04161b; padding: 9px 16px; border-radius: 6px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; border: none; cursor: pointer; transition: transform 0.06s; }
  .btn:hover { transform: translateY(-1px); }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .btn.ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
  .btn.full { grid-column: span 2; }
  canvas { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 10px; display: block; }
  .metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-top: 14px; }
  .metric { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; padding: 10px 12px; }
  .metric .k { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9px; letter-spacing: 0.14em; color: #67e8f9; text-transform: uppercase; }
  .metric .v { font-family: 'Cormorant Garamond', serif; font-size: 22px; color: #fff; margin-top: 2px; }
  .legend { display: flex; gap: 16px; margin-top: 12px; flex-wrap: wrap; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; color: #9ba0aa; }
  .swatch { display: inline-block; width: 10px; height: 10px; border-radius: 2px; margin-right: 6px; vertical-align: middle; }
  .complexity { margin-top: 14px; padding: 12px; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #cfd6da; line-height: 1.7; }
  .complexity .cx-name { color: #67e8f9; font-weight: 700; }
  .complexity .cx-row { display: flex; justify-content: space-between; }
  .checkbox { display: flex; align-items: center; gap: 8px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #cfd6da; cursor: pointer; }
  .checkbox input { accent-color: #67e8f9; }
  .footer-note { margin-top: 24px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; color: #6b7280; letter-spacing: 0.05em; }
  .back { display: inline-flex; align-items: center; gap: 8px; color: #67e8f9; text-decoration: none; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 16px; }
  .back:hover { text-decoration: underline; }
</style>
<main class="wrap">
  <a href="/aquintutor/labs" class="back">
    <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    All labs
  </a>
  <div class="eyebrow">Algorithm Lab 07</div>
  <h1>Sorting <em>visualiser</em></h1>
  <p class="lede">Seven hand-written sorting algorithms rendered as step-by-step generators. Each comparison and swap is yielded and animated; counters track comparisons, swaps, and array accesses. Optional Web Audio sonification maps array values to pitch (200 + value*4 Hz, 5 ms blips).</p>

  <div class="grid">
    <aside class="panel">
      <h3>Configuration</h3>

      <div class="row">
        <label>Algorithm <span id="lbl-algo"></span></label>
        <select id="algo">
          <option value="bubble">Bubble sort</option>
          <option value="insertion">Insertion sort</option>
          <option value="selection">Selection sort</option>
          <option value="merge">Merge sort</option>
          <option value="quick" selected>Quick sort (Lomuto, random pivot)</option>
          <option value="heap">Heap sort (max-heap, sift-down)</option>
          <option value="radix">Radix sort (LSD, base-10)</option>
        </select>
      </div>

      <div class="row">
        <label>Array size <span id="lbl-size">80</span></label>
        <input id="size" type="range" min="10" max="200" value="80">
      </div>

      <div class="row">
        <label>Step delay (ms) <span id="lbl-speed">8</span></label>
        <input id="speed" type="range" min="1" max="100" value="8">
      </div>

      <div class="row">
        <label>Initial shape</label>
        <select id="shape">
          <option value="random">Random</option>
          <option value="nearly">Nearly sorted</option>
          <option value="reverse">Reverse sorted</option>
          <option value="few">Few unique values</option>
          <option value="dup">Many duplicates</option>
        </select>
      </div>

      <label class="checkbox">
        <input id="sound" type="checkbox">
        Sound (Web Audio sonification)
      </label>

      <div class="btns">
        <button class="btn" id="play">Play</button>
        <button class="btn ghost" id="step">Step</button>
        <button class="btn ghost" id="gen">Generate</button>
        <button class="btn ghost" id="reset">Reset</button>
      </div>

      <div class="complexity" id="complexity"></div>
    </aside>

    <section class="panel">
      <h3>Live trace</h3>
      <canvas id="canvas" width="900" height="440"></canvas>

      <div class="legend">
        <span><span class="swatch" style="background:#3b3f4a"></span>Unsorted</span>
        <span><span class="swatch" style="background:#fbbf24"></span>Comparing</span>
        <span><span class="swatch" style="background:#ef4444"></span>Swapping</span>
        <span><span class="swatch" style="background:#10b981"></span>Sorted</span>
        <span><span class="swatch" style="background:#67e8f9"></span>Pivot / aux</span>
      </div>

      <div class="metrics">
        <div class="metric"><div class="k">Comparisons</div><div class="v" id="m-cmp">0</div></div>
        <div class="metric"><div class="k">Swaps</div><div class="v" id="m-swap">0</div></div>
        <div class="metric"><div class="k">Array accesses</div><div class="v" id="m-acc">0</div></div>
      </div>

      <p class="footer-note">All generators are pure JavaScript: no libraries, no async/await wrappers around DOM. The driver pulls one yielded frame per tick and paints with Canvas2D.</p>
    </section>
  </div>
</main>

<script is:inline>
(function () {
  var canvas = document.getElementById('canvas');
  var ctx = canvas.getContext('2d');
  var sel = document.getElementById('algo');
  var sizeIn = document.getElementById('size');
  var speedIn = document.getElementById('speed');
  var shapeIn = document.getElementById('shape');
  var soundIn = document.getElementById('sound');
  var lblSize = document.getElementById('lbl-size');
  var lblSpeed = document.getElementById('lbl-speed');
  var lblAlgo = document.getElementById('lbl-algo');
  var btnPlay = document.getElementById('play');
  var btnStep = document.getElementById('step');
  var btnGen = document.getElementById('gen');
  var btnReset = document.getElementById('reset');
  var mCmp = document.getElementById('m-cmp');
  var mSwap = document.getElementById('m-swap');
  var mAcc = document.getElementById('m-acc');
  var cxBox = document.getElementById('complexity');

  // -------- state --------
  var arr = [];
  var original = [];
  var gen = null;
  var running = false;
  var timer = null;
  var stats = { cmp: 0, swap: 0, acc: 0 };
  var frame = { compare: [], swap: [], pivot: [], aux: [], sortedFrom: -1, sortedTo: -1, sortedSet: null };
  var audioCtx = null;

  // -------- audio --------
  function blip(v) {
    if (!soundIn.checked) return;
    try {
      if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      var o = audioCtx.createOscillator();
      var g = audioCtx.createGain();
      o.type = 'square';
      o.frequency.value = 200 + v * 4;
      g.gain.value = 0.04;
      o.connect(g); g.connect(audioCtx.destination);
      o.start();
      o.stop(audioCtx.currentTime + 0.005);
    } catch (e) { /* user gesture not yet, ignore */ }
  }

  // -------- array generation --------
  function generateArray() {
    var n = +sizeIn.value;
    var a = new Array(n);
    var shape = shapeIn.value;
    if (shape === 'random') {
      for (var i = 0; i < n; i++) a[i] = Math.floor(Math.random() * 380) + 8;
    } else if (shape === 'nearly') {
      for (var j = 0; j < n; j++) a[j] = Math.floor(8 + (j / n) * 380);
      // perturb ~10% pairs
      var swaps = Math.max(1, Math.floor(n * 0.05));
      for (var s = 0; s < swaps; s++) {
        var p = Math.floor(Math.random() * n);
        var q = Math.min(n - 1, p + Math.floor(Math.random() * 3) + 1);
        var t = a[p]; a[p] = a[q]; a[q] = t;
      }
    } else if (shape === 'reverse') {
      for (var k = 0; k < n; k++) a[k] = Math.floor(8 + ((n - 1 - k) / n) * 380);
    } else if (shape === 'few') {
      var bucket = [60, 120, 180, 240, 320];
      for (var m = 0; m < n; m++) a[m] = bucket[Math.floor(Math.random() * bucket.length)];
    } else if (shape === 'dup') {
      for (var u = 0; u < n; u++) a[u] = Math.floor(Math.random() * 8) * 48 + 24;
    }
    arr = a.slice();
    original = a.slice();
    resetState();
    draw();
  }

  function resetState() {
    stats.cmp = 0; stats.swap = 0; stats.acc = 0;
    frame = { compare: [], swap: [], pivot: [], aux: [], sortedFrom: -1, sortedTo: -1, sortedSet: null };
    gen = null;
    running = false;
    btnPlay.textContent = 'Play';
    if (timer) { clearTimeout(timer); timer = null; }
    renderStats();
  }

  // -------- drawing --------
  function resizeCanvas() {
    var rect = canvas.getBoundingClientRect();
    var dpr = window.devicePixelRatio || 1;
    canvas.width = Math.floor(rect.width * dpr);
    canvas.height = Math.floor(rect.height * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function draw() {
    var rect = canvas.getBoundingClientRect();
    var W = rect.width, H = rect.height;
    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = '#0a0a0c';
    ctx.fillRect(0, 0, W, H);

    var n = arr.length;
    if (n === 0) return;
    var gap = n > 80 ? 1 : 2;
    var bw = Math.max(1, (W - gap * (n - 1)) / n);

    // build lookups
    var cmpSet = new Set(frame.compare);
    var swapSet = new Set(frame.swap);
    var pivSet = new Set(frame.pivot);
    var auxSet = new Set(frame.aux);
    var sortedSet = frame.sortedSet;

    var maxV = 400;
    for (var i = 0; i < n; i++) {
      var v = arr[i];
      var h = Math.max(2, (v / maxV) * (H - 24));
      var x = i * (bw + gap);
      var y = H - h;
      var fill = '#3b3f4a';
      if (sortedSet && sortedSet.has(i)) fill = '#10b981';
      else if (i >= frame.sortedFrom && i <= frame.sortedTo && frame.sortedFrom !== -1) fill = '#10b981';
      if (auxSet.has(i)) fill = '#67e8f9';
      if (pivSet.has(i)) fill = '#67e8f9';
      if (cmpSet.has(i)) fill = '#fbbf24';
      if (swapSet.has(i)) fill = '#ef4444';
      ctx.fillStyle = fill;
      ctx.fillRect(x, y, bw, h);
    }
  }

  function renderStats() {
    mCmp.textContent = stats.cmp.toLocaleString();
    mSwap.textContent = stats.swap.toLocaleString();
    mAcc.textContent = stats.acc.toLocaleString();
  }

  // -------- yield helpers --------
  function* compareYield(a, i, j, extra) {
    stats.cmp++; stats.acc += 2;
    var f = { compare: [i, j], swap: [], pivot: extra && extra.pivot ? [extra.pivot] : [], aux: extra && extra.aux ? extra.aux : [], sortedFrom: extra && extra.sortedFrom != null ? extra.sortedFrom : -1, sortedTo: extra && extra.sortedTo != null ? extra.sortedTo : -1, sortedSet: extra && extra.sortedSet ? extra.sortedSet : null };
    yield f;
  }
  function* swapYield(a, i, j, extra) {
    var tmp = a[i]; a[i] = a[j]; a[j] = tmp;
    stats.swap++; stats.acc += 4;
    var f = { compare: [], swap: [i, j], pivot: extra && extra.pivot ? [extra.pivot] : [], aux: extra && extra.aux ? extra.aux : [], sortedFrom: extra && extra.sortedFrom != null ? extra.sortedFrom : -1, sortedTo: extra && extra.sortedTo != null ? extra.sortedTo : -1, sortedSet: extra && extra.sortedSet ? extra.sortedSet : null };
    yield f;
    blip(a[i]);
  }

  // -------- algorithms (generators) --------
  function* bubbleSort(a) {
    var n = a.length;
    for (var i = 0; i < n - 1; i++) {
      var swapped = false;
      for (var j = 0; j < n - 1 - i; j++) {
        yield* compareYield(a, j, j + 1, { sortedFrom: n - i, sortedTo: n - 1 });
        if (a[j] > a[j + 1]) {
          yield* swapYield(a, j, j + 1, { sortedFrom: n - i, sortedTo: n - 1 });
          swapped = true;
        }
      }
      if (!swapped) break;
    }
    yield { compare: [], swap: [], pivot: [], aux: [], sortedFrom: 0, sortedTo: n - 1, sortedSet: null };
  }

  function* insertionSort(a) {
    var n = a.length;
    for (var i = 1; i < n; i++) {
      var j = i;
      while (j > 0) {
        yield* compareYield(a, j - 1, j, { sortedFrom: 0, sortedTo: i - 1 });
        if (a[j - 1] > a[j]) {
          yield* swapYield(a, j - 1, j, { sortedFrom: 0, sortedTo: i - 1 });
          j--;
        } else break;
      }
    }
    yield { compare: [], swap: [], pivot: [], aux: [], sortedFrom: 0, sortedTo: n - 1, sortedSet: null };
  }

  function* selectionSort(a) {
    var n = a.length;
    for (var i = 0; i < n - 1; i++) {
      var minIdx = i;
      for (var j = i + 1; j < n; j++) {
        yield* compareYield(a, minIdx, j, { sortedFrom: 0, sortedTo: i - 1, aux: [minIdx] });
        stats.acc += 1;
        if (a[j] < a[minIdx]) minIdx = j;
      }
      if (minIdx !== i) yield* swapYield(a, i, minIdx, { sortedFrom: 0, sortedTo: i - 1 });
    }
    yield { compare: [], swap: [], pivot: [], aux: [], sortedFrom: 0, sortedTo: n - 1, sortedSet: null };
  }

  function* mergeSort(a) {
    var n = a.length;
    function* mergeRange(lo, hi) {
      if (hi - lo <= 1) return;
      var mid = (lo + hi) >> 1;
      yield* mergeRange(lo, mid);
      yield* mergeRange(mid, hi);
      yield* merge(lo, mid, hi);
    }
    function* merge(lo, mid, hi) {
      var left = a.slice(lo, mid);
      var right = a.slice(mid, hi);
      stats.acc += (hi - lo);
      var i = 0, j = 0, k = lo;
      while (i < left.length && j < right.length) {
        stats.cmp++; stats.acc += 2;
        yield { compare: [lo + i, mid + j], swap: [], pivot: [], aux: [k], sortedFrom: -1, sortedTo: -1, sortedSet: null };
        if (left[i] <= right[j]) {
          a[k++] = left[i++];
          stats.acc += 2;
        } else {
          a[k++] = right[j++];
          stats.acc += 2;
        }
        yield { compare: [], swap: [k - 1], pivot: [], aux: [], sortedFrom: -1, sortedTo: -1, sortedSet: null };
        blip(a[k - 1]);
      }
      while (i < left.length) {
        a[k++] = left[i++]; stats.acc += 2;
        yield { compare: [], swap: [k - 1], pivot: [], aux: [], sortedFrom: -1, sortedTo: -1, sortedSet: null };
        blip(a[k - 1]);
      }
      while (j < right.length) {
        a[k++] = right[j++]; stats.acc += 2;
        yield { compare: [], swap: [k - 1], pivot: [], aux: [], sortedFrom: -1, sortedTo: -1, sortedSet: null };
        blip(a[k - 1]);
      }
    }
    yield* mergeRange(0, n);
    yield { compare: [], swap: [], pivot: [], aux: [], sortedFrom: 0, sortedTo: n - 1, sortedSet: null };
  }

  function* quickSort(a) {
    var n = a.length;
    var doneSet = new Set();
    function* qs(lo, hi) {
      if (lo >= hi) {
        if (lo === hi) doneSet.add(lo);
        return;
      }
      // random pivot, swap with hi
      var rp = lo + Math.floor(Math.random() * (hi - lo + 1));
      if (rp !== hi) {
        var t = a[rp]; a[rp] = a[hi]; a[hi] = t; stats.swap++; stats.acc += 4;
        yield { compare: [], swap: [rp, hi], pivot: [hi], aux: [], sortedFrom: -1, sortedTo: -1, sortedSet: new Set(doneSet) };
      }
      var pivot = a[hi];
      var i = lo;
      for (var j = lo; j < hi; j++) {
        stats.cmp++; stats.acc += 2;
        yield { compare: [j, hi], swap: [], pivot: [hi], aux: [i], sortedFrom: -1, sortedTo: -1, sortedSet: new Set(doneSet) };
        if (a[j] < pivot) {
          if (i !== j) {
            var tt = a[i]; a[i] = a[j]; a[j] = tt; stats.swap++; stats.acc += 4;
            yield { compare: [], swap: [i, j], pivot: [hi], aux: [], sortedFrom: -1, sortedTo: -1, sortedSet: new Set(doneSet) };
            blip(a[i]);
          }
          i++;
        }
      }
      if (i !== hi) {
        var tt2 = a[i]; a[i] = a[hi]; a[hi] = tt2; stats.swap++; stats.acc += 4;
        yield { compare: [], swap: [i, hi], pivot: [], aux: [], sortedFrom: -1, sortedTo: -1, sortedSet: new Set(doneSet) };
        blip(a[i]);
      }
      doneSet.add(i);
      yield { compare: [], swap: [], pivot: [], aux: [], sortedFrom: -1, sortedTo: -1, sortedSet: new Set(doneSet) };
      yield* qs(lo, i - 1);
      yield* qs(i + 1, hi);
    }
    yield* qs(0, n - 1);
    yield { compare: [], swap: [], pivot: [], aux: [], sortedFrom: 0, sortedTo: n - 1, sortedSet: null };
  }

  function* heapSort(a) {
    var n = a.length;
    function* siftDown(start, end) {
      var root = start;
      while (root * 2 + 1 <= end) {
        var child = root * 2 + 1;
        var swp = root;
        stats.cmp++; stats.acc += 2;
        yield { compare: [swp, child], swap: [], pivot: [], aux: [root], sortedFrom: end + 1, sortedTo: n - 1, sortedSet: null };
        if (a[swp] < a[child]) swp = child;
        if (child + 1 <= end) {
          stats.cmp++; stats.acc += 2;
          yield { compare: [swp, child + 1], swap: [], pivot: [], aux: [root], sortedFrom: end + 1, sortedTo: n - 1, sortedSet: null };
          if (a[swp] < a[child + 1]) swp = child + 1;
        }
        if (swp === root) return;
        var t = a[root]; a[root] = a[swp]; a[swp] = t; stats.swap++; stats.acc += 4;
        yield { compare: [], swap: [root, swp], pivot: [], aux: [], sortedFrom: end + 1, sortedTo: n - 1, sortedSet: null };
        blip(a[root]);
        root = swp;
      }
    }
    // heapify
    for (var s = (n - 2) >> 1; s >= 0; s--) yield* siftDown(s, n - 1);
    // sort
    for (var e = n - 1; e > 0; e--) {
      var t = a[0]; a[0] = a[e]; a[e] = t; stats.swap++; stats.acc += 4;
      yield { compare: [], swap: [0, e], pivot: [], aux: [], sortedFrom: e, sortedTo: n - 1, sortedSet: null };
      blip(a[0]);
      yield* siftDown(0, e - 1);
    }
    yield { compare: [], swap: [], pivot: [], aux: [], sortedFrom: 0, sortedTo: n - 1, sortedSet: null };
  }

  function* radixSort(a) {
    var n = a.length;
    var maxv = 0;
    for (var i = 0; i < n; i++) { if (a[i] > maxv) maxv = a[i]; stats.acc++; }
    var exp = 1;
    while (Math.floor(maxv / exp) > 0) {
      var buckets = [[], [], [], [], [], [], [], [], [], []];
      for (var j = 0; j < n; j++) {
        var d = Math.floor(a[j] / exp) % 10;
        buckets[d].push(a[j]);
        stats.acc += 2;
        yield { compare: [j], swap: [], pivot: [], aux: [j], sortedFrom: -1, sortedTo: -1, sortedSet: null };
      }
      var k = 0;
      for (var b = 0; b < 10; b++) {
        for (var p = 0; p < buckets[b].length; p++) {
          a[k] = buckets[b][p]; stats.acc += 2;
          yield { compare: [], swap: [k], pivot: [], aux: [], sortedFrom: -1, sortedTo: -1, sortedSet: null };
          blip(a[k]);
          k++;
        }
      }
      exp *= 10;
    }
    yield { compare: [], swap: [], pivot: [], aux: [], sortedFrom: 0, sortedTo: n - 1, sortedSet: null };
  }

  var ALGOS = {
    bubble: { name: 'Bubble sort', fn: bubbleSort, best: 'O(n)', avg: 'O(n²)', worst: 'O(n²)', space: 'O(1)', stable: 'Yes', desc: 'Adjacent-swap pass; short-circuits if a pass makes no swaps. Optimal as a teaching baseline; never in production.' },
    insertion: { name: 'Insertion sort', fn: insertionSort, best: 'O(n)', avg: 'O(n²)', worst: 'O(n²)', space: 'O(1)', stable: 'Yes', desc: 'Linear when nearly sorted; the hidden inner loop of TimSort once runs fall below 32 elements.' },
    selection: { name: 'Selection sort', fn: selectionSort, best: 'O(n²)', avg: 'O(n²)', worst: 'O(n²)', space: 'O(1)', stable: 'No', desc: 'Pick the minimum of the unsorted tail and swap to the boundary. Always n²/2 comparisons regardless of input shape.' },
    merge: { name: 'Merge sort', fn: mergeSort, best: 'O(n log n)', avg: 'O(n log n)', worst: 'O(n log n)', space: 'O(n)', stable: 'Yes', desc: 'Divide-and-conquer with stable merge. Worst-case optimal for comparison sorting; external-friendly.' },
    quick: { name: 'Quick sort', fn: quickSort, best: 'O(n log n)', avg: 'O(n log n)', worst: 'O(n²)', space: 'O(log n)', stable: 'No', desc: 'Lomuto partition with random pivot to dodge adversarial inputs. Cache-friendly; the fastest comparison sort in practice.' },
    heap: { name: 'Heap sort', fn: heapSort, best: 'O(n log n)', avg: 'O(n log n)', worst: 'O(n log n)', space: 'O(1)', stable: 'No', desc: 'In-place max-heap with sift-down. Guaranteed n log n with no extra memory; loses to quicksort on caches.' },
    radix: { name: 'Radix sort (LSD)', fn: radixSort, best: 'O(nk)', avg: 'O(nk)', worst: 'O(nk)', space: 'O(n + k)', stable: 'Yes', desc: 'Non-comparison: distribute by digit d, gather, advance d. k = number of digits. Beats n log n when k is small.' }
  };

  function updateComplexity() {
    var a = ALGOS[sel.value];
    cxBox.innerHTML =
      '<div class="cx-name">' + a.name + '</div>' +
      '<div class="cx-row"><span>Best</span><span>' + a.best + '</span></div>' +
      '<div class="cx-row"><span>Average</span><span>' + a.avg + '</span></div>' +
      '<div class="cx-row"><span>Worst</span><span>' + a.worst + '</span></div>' +
      '<div class="cx-row"><span>Space</span><span>' + a.space + '</span></div>' +
      '<div class="cx-row"><span>Stable</span><span>' + a.stable + '</span></div>' +
      '<div style="margin-top:8px;color:#9ba0aa;font-size:10px;line-height:1.5">' + a.desc + '</div>';
    lblAlgo.textContent = '';
  }

  // -------- driver --------
  function tick() {
    if (!gen) return;
    var res = gen.next();
    if (res.done) {
      running = false;
      btnPlay.textContent = 'Play';
      // mark all sorted
      frame.sortedFrom = 0;
      frame.sortedTo = arr.length - 1;
      frame.compare = []; frame.swap = []; frame.pivot = []; frame.aux = [];
      draw();
      renderStats();
      return;
    }
    frame = res.value;
    draw();
    renderStats();
    if (running) {
      var delay = +speedIn.value;
      timer = setTimeout(tick, delay);
    }
  }

  function startGen() {
    if (!gen) {
      arr = original.slice();
      stats.cmp = 0; stats.swap = 0; stats.acc = 0;
      gen = ALGOS[sel.value].fn(arr);
    }
  }

  // -------- bindings --------
  btnPlay.addEventListener('click', function () {
    if (!gen) startGen();
    running = !running;
    btnPlay.textContent = running ? 'Pause' : 'Play';
    if (running) tick();
    else if (timer) { clearTimeout(timer); timer = null; }
  });
  btnStep.addEventListener('click', function () {
    if (running) return;
    if (!gen) startGen();
    var was = running; running = false;
    tick();
  });
  btnGen.addEventListener('click', function () { generateArray(); });
  btnReset.addEventListener('click', function () {
    arr = original.slice();
    resetState();
    draw();
  });
  sel.addEventListener('change', function () {
    updateComplexity();
    resetState();
    arr = original.slice();
    draw();
  });
  sizeIn.addEventListener('input', function () {
    lblSize.textContent = sizeIn.value;
  });
  sizeIn.addEventListener('change', function () { generateArray(); });
  speedIn.addEventListener('input', function () { lblSpeed.textContent = speedIn.value; });
  shapeIn.addEventListener('change', function () { generateArray(); });

  window.addEventListener('resize', function () { resizeCanvas(); draw(); });

  // boot
  resizeCanvas();
  updateComplexity();
  generateArray();
})();
</script>

