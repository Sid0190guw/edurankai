---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Sorting & complexity lab (advanced level). Two views: a bar-field animation of
// a single algorithm (compares/swaps highlighted), and an ANALYSE view that runs
// each algorithm across growing input sizes, counts the comparisons, and plots
// them on log-log axes against the O(N^2), O(N log N) and O(N) guide lines and
// the information-theoretic log2(N!) comparison lower bound — so the empirical
// complexity class is read straight off the slope. Input distributions (random /
// sorted / reversed / nearly-sorted / few-unique) expose best/worst/adaptive
// behaviour (insertion O(N) on sorted, naive quicksort O(N^2) on sorted, radix
// beating the comparison bound). No libraries.
---
<BaseLayout title="Sorting & Complexity · Virtual Labs · AquinTutor" description="Advanced algorithms: bubble/insertion/selection/quick/merge/heap/shell/radix with input distributions exposing best/worst/adaptive cases, and an empirical complexity plot on log-log axes against O(N^2)/O(N log N)/O(N) and the log2(N!) lower bound. Built from scratch.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1340px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:16px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:300px minmax(0,1fr); gap:18px; } @media(max-width:960px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:15px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 11px; }
  .lb-row{ display:grid; gap:8px; } .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.08em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; } .lb-row label span{ color:#5ee7ff; } .lb-row input[type=range]{ width:100%; accent-color:#5ee7ff; } select{ width:100%; background:#080a12; border:1px solid #1e2740; color:#fff; padding:8px 10px; border-radius:6px; font-size:12px; font-family:inherit; }
  .lb-seg{ display:flex; gap:4px; } .lb-seg button{ flex:1; background:#0b1020; border:1px solid #26314f; color:#8ea0be; border-radius:7px; padding:6px 4px; font-family:'Geist Mono',monospace; font-size:10px; cursor:pointer; } .lb-seg button.on{ background:rgba(94,231,255,0.14); color:#5ee7ff; border-color:#3a6b86; }
  .lb-btn{ background:linear-gradient(180deg,#7af0ff,#33cfe6); color:#04161b; padding:9px 15px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:11px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; }
  .lb-btn-ghost{ background:transparent; color:#cfd6da; border:1px solid #26314f; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); } .lb-stage canvas{ display:block; width:100%; height:auto; }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11px; padding:4px 0; border-bottom:1px solid #141a2c; } .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#5ee7ff; font-weight:700; text-align:right; }
  table{ width:100%; border-collapse:collapse; font-family:'Geist Mono',monospace; font-size:10.5px; margin-top:10px; } th,td{ text-align:left; padding:4px 6px; border-bottom:1px solid #141a2c; } th{ color:#5ee7ff; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">CS · Algorithm complexity</p>
      <h1 class="lb-title">Sorting &amp; <em>complexity</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;"><button id="shuffleBtn" class="lb-btn lb-btn-ghost">Shuffle</button><button id="goBtn" class="lb-btn">Sort</button></div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>View</h3>
        <div class="lb-seg" id="viewSeg"><button data-v="vis" class="on">Visualise</button><button data-v="ana">Analyse complexity</button></div>
      </div>
      <div class="lb-panel"><h3>Setup</h3><div class="lb-row">
        <label>Algorithm</label><select id="algo"><option value="bubble">Bubble</option><option value="insertion">Insertion</option><option value="selection">Selection</option><option value="quick" selected>Quicksort (last pivot)</option><option value="merge">Merge</option><option value="heap">Heap</option><option value="shell">Shell</option><option value="radix">Radix (LSD)</option></select>
        <label>Distribution</label><select id="dist"><option value="random" selected>Random</option><option value="sorted">Sorted</option><option value="reversed">Reversed</option><option value="nearly">Nearly sorted</option><option value="fewuniq">Few unique</option></select>
        <label id="szWrap">Size N <span id="szV">60</span></label><input id="sz" type="range" min="10" max="140" step="1" value="60"/>
        <label id="spWrap">Speed <span id="spV">6</span></label><input id="sp" type="range" min="1" max="40" step="1" value="6"/>
      </div></div>
      <div class="lb-panel" id="counters"><h3>Counters</h3>
        <div class="lb-metric"><span class="lb-metric-l">Comparisons</span><span class="lb-metric-v" id="mC">0</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Writes / moves</span><span class="lb-metric-v" id="mW">0</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Big-O (avg / worst)</span><span class="lb-metric-v" id="mO">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Stable · in-place</span><span class="lb-metric-v" id="mProps">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Status</span><span class="lb-metric-v" id="mS">idle</span></div>
      </div>
    </aside>
    <section><div class="lb-stage"><canvas id="scene" width="960" height="520"></canvas></div>
      <div class="lb-panel" id="tableWrap" style="display:none;"><h3>Empirical complexity · comparisons at largest N</h3><div id="table"></div></div>
    </section>
  </div>
</main>
<script is:inline>
(function(){
  function v(id){ return parseFloat(document.getElementById(id).value); }
  function setTxt(id,t){ var e=document.getElementById(id); if(e) e.textContent=t; }
  var view='vis';
  var META={ bubble:['O(n²)/O(n²)','yes','yes'], insertion:['O(n²)/O(n²)','yes','yes'], selection:['O(n²)/O(n²)','no','yes'], quick:['O(n log n)/O(n²)','no','yes'], merge:['O(n log n)/O(n log n)','yes','no'], heap:['O(n log n)/O(n log n)','no','yes'], shell:['O(n^1.3)/O(n²)','no','yes'], radix:['O(nk)/O(nk)','yes','no'] };
  var COLR={ bubble:'#f87171', insertion:'#fbbf24', selection:'#fb923c', quick:'#5ee7ff', merge:'#34d399', heap:'#a78bfa', shell:'#f472b6', radix:'#67e8f9' };

  function genInts(n,dist){ var a=[]; if(dist==='sorted'){ for(var i=0;i<n;i++)a.push(i); }
    else if(dist==='reversed'){ for(var i=0;i<n;i++)a.push(n-i); }
    else if(dist==='nearly'){ for(var i=0;i<n;i++)a.push(i); for(var k=0;k<Math.max(1,n/20);k++){ var x=(Math.random()*n)|0,y=(Math.random()*n)|0,t=a[x];a[x]=a[y];a[y]=t; } }
    else if(dist==='fewuniq'){ for(var i=0;i<n;i++)a.push((Math.random()*5)|0); }
    else { for(var i=0;i<n;i++)a.push((Math.random()*n*4)|0); } return a; }

  // ---- count-only sorts (comparisons, writes) ----
  function cnt(algo,a0){ var a=a0.slice(), C={c:0,w:0}; function lt(i,j){ C.c++; return a[i]<a[j]; } function ltv(x,y){ C.c++; return x<y; } function sw(i,j){ C.w+=2; var t=a[i];a[i]=a[j];a[j]=t; }
    if(algo==='bubble'){ for(var i=0;i<a.length;i++)for(var j=0;j<a.length-1-i;j++){ if(lt(j+1,j)) sw(j,j+1); } }
    else if(algo==='insertion'){ for(var i=1;i<a.length;i++){ var key=a[i],j=i-1; while(j>=0){ C.c++; if(a[j]>key){ a[j+1]=a[j]; C.w++; j--; } else break; } a[j+1]=key; C.w++; } }
    else if(algo==='selection'){ for(var i=0;i<a.length;i++){ var m=i; for(var j=i+1;j<a.length;j++){ if(lt(j,m)) m=j; } if(m!==i) sw(i,m); } }
    else if(algo==='quick'){ (function qs(lo,hi){ if(lo>=hi)return; var p=a[hi],i=lo; for(var j=lo;j<hi;j++){ C.c++; if(a[j]<p){ if(i!==j)sw(i,j); i++; } } sw(i,hi); qs(lo,i-1); qs(i+1,hi); })(0,a.length-1); }
    else if(algo==='merge'){ (function ms(lo,hi){ if(hi-lo<1)return; var mid=(lo+hi)>>1; ms(lo,mid); ms(mid+1,hi); var i=lo,j=mid+1,tmp=[]; while(i<=mid&&j<=hi){ C.c++; if(a[i]<=a[j])tmp.push(a[i++]); else tmp.push(a[j++]); } while(i<=mid)tmp.push(a[i++]); while(j<=hi)tmp.push(a[j++]); for(var k=0;k<tmp.length;k++){ a[lo+k]=tmp[k]; C.w++; } })(0,a.length-1); }
    else if(algo==='heap'){ var n=a.length; function hf(n,i){ var l=2*i+1,r=2*i+2,m=i; if(l<n){ C.c++; if(a[l]>a[m])m=l; } if(r<n){ C.c++; if(a[r]>a[m])m=r; } if(m!==i){ sw(i,m); hf(n,m); } } for(var i=(n>>1)-1;i>=0;i--)hf(n,i); for(var e=n-1;e>0;e--){ sw(0,e); hf(e,0); } }
    else if(algo==='shell'){ var n=a.length; for(var gap=n>>1; gap>0; gap>>=1){ for(var i=gap;i<n;i++){ var tmp=a[i],j=i; while(j>=gap){ C.c++; if(a[j-gap]>tmp){ a[j]=a[j-gap]; C.w++; j-=gap; } else break; } a[j]=tmp; C.w++; } } }
    else if(algo==='radix'){ var mx=Math.max.apply(null,a)||0; for(var exp=1; Math.floor(mx/exp)>0; exp*=10){ var out=new Array(a.length), cc=new Array(10).fill(0); for(var i=0;i<a.length;i++){ cc[Math.floor(a[i]/exp)%10]++; } for(var i=1;i<10;i++)cc[i]+=cc[i-1]; for(var i=a.length-1;i>=0;i--){ var d=Math.floor(a[i]/exp)%10; out[--cc[d]]=a[i]; C.w++; } for(var i=0;i<a.length;i++){ a[i]=out[i]; C.w++; } } }
    return C; }

  // ---- op-recording for the visualiser (comparison sorts + heap/shell; radix simplified) ----
  var arr=[], ops=[], oi=0, running=false, cmp=0, wr=0, active={}, sortedTo=-1;
  function record(algo,a0){ var a=a0.slice(), o=[]; function cm(i,j){ o.push(['c',i,j]); } function sw(i,j){ o.push(['s',i,j]); var t=a[i];a[i]=a[j];a[j]=t; } function st(i,val){ o.push(['w',i,val]); a[i]=val; }
    if(algo==='bubble'){ for(var i=0;i<a.length;i++)for(var j=0;j<a.length-1-i;j++){ cm(j,j+1); if(a[j]>a[j+1])sw(j,j+1); } }
    else if(algo==='insertion'){ for(var i=1;i<a.length;i++){ var key=a[i],j=i-1; while(j>=0){ cm(j,j+1); if(a[j]>key){ st(j+1,a[j]); j--; } else break; } st(j+1,key); } }
    else if(algo==='selection'){ for(var i=0;i<a.length;i++){ var m=i; for(var j=i+1;j<a.length;j++){ cm(j,m); if(a[j]<a[m])m=j; } if(m!==i)sw(i,m); } }
    else if(algo==='quick'){ (function qs(lo,hi){ if(lo>=hi)return; var p=a[hi],i=lo; for(var j=lo;j<hi;j++){ cm(j,hi); if(a[j]<p){ if(i!==j)sw(i,j); i++; } } sw(i,hi); qs(lo,i-1); qs(i+1,hi); })(0,a.length-1); }
    else if(algo==='merge'){ (function ms(lo,hi){ if(hi-lo<1)return; var mid=(lo+hi)>>1; ms(lo,mid); ms(mid+1,hi); var i=lo,j=mid+1,tmp=[]; while(i<=mid&&j<=hi){ cm(i,j); if(a[i]<=a[j])tmp.push(a[i++]); else tmp.push(a[j++]); } while(i<=mid)tmp.push(a[i++]); while(j<=hi)tmp.push(a[j++]); for(var k=0;k<tmp.length;k++)st(lo+k,tmp[k]); })(0,a.length-1); }
    else if(algo==='heap'){ var n=a.length; function hf(n,i){ var l=2*i+1,r=2*i+2,m=i; if(l<n){ cm(l,m); if(a[l]>a[m])m=l; } if(r<n){ cm(r,m); if(a[r]>a[m])m=r; } if(m!==i){ sw(i,m); hf(n,m); } } for(var i=(n>>1)-1;i>=0;i--)hf(n,i); for(var e=n-1;e>0;e--){ sw(0,e); hf(e,0); } }
    else if(algo==='shell'){ var n=a.length; for(var gap=n>>1; gap>0; gap>>=1){ for(var i=gap;i<n;i++){ var tmp=a[i],j=i; while(j>=gap){ cm(j-gap,j); if(a[j-gap]>tmp){ st(j,a[j-gap]); j-=gap; } else break; } st(j,tmp); } } }
    else if(algo==='radix'){ var mx=Math.max.apply(null,a)||0; for(var exp=1; Math.floor(mx/exp)>0; exp*=10){ var out=new Array(a.length), cc=new Array(10).fill(0); for(var i=0;i<a.length;i++)cc[Math.floor(a[i]/exp)%10]++; for(var i=1;i<10;i++)cc[i]+=cc[i-1]; var snap=a.slice(); for(var i=snap.length-1;i>=0;i--){ var d=Math.floor(snap[i]/exp)%10; out[--cc[d]]=snap[i]; } for(var i=0;i<a.length;i++) st(i,out[i]); } }
    return o; }

  function shuffle(){ running=false; ops=[]; oi=0; cmp=0; wr=0; active={}; sortedTo=-1; arr=genInts(Math.round(v('sz')),document.getElementById('dist').value);
    setTxt('mS','idle'); setTxt('mC',0); setTxt('mW',0); var mm=META[document.getElementById('algo').value]; setTxt('mO',mm[0]); setTxt('mProps',mm[1]+' · '+mm[2]); }
  document.getElementById('shuffleBtn').addEventListener('click',shuffle);
  document.getElementById('sz').addEventListener('change',shuffle); document.getElementById('dist').addEventListener('change',function(){ shuffle(); if(view==='ana') analyse(); });
  document.getElementById('algo').addEventListener('change',function(){ var mm=META[document.getElementById('algo').value]; setTxt('mO',mm[0]); setTxt('mProps',mm[1]+' · '+mm[2]); });
  document.querySelectorAll('input').forEach(function(e){ e.addEventListener('input',function(){ setTxt('szV',v('sz').toFixed(0)); setTxt('spV',v('sp').toFixed(0)); }); });

  function apply(op){ if(op[0]==='c'){ cmp++; active={a:op[1],b:op[2],kind:'c'}; } else if(op[0]==='s'){ wr+=2; var t=arr[op[1]];arr[op[1]]=arr[op[2]];arr[op[2]]=t; active={a:op[1],b:op[2],kind:'s'}; } else if(op[0]==='w'){ wr++; arr[op[1]]=op[2]; active={a:op[1],kind:'s'}; } }
  document.getElementById('goBtn').addEventListener('click',function(){ if(view==='ana'){ analyse(); return; } if(running)return; ops=record(document.getElementById('algo').value,arr); oi=0; cmp=0; wr=0; running=true; setTxt('mS','sorting'); });

  function hidpi(cv){ var r=cv.getBoundingClientRect(), dp=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w; cv.width=Math.round(w*dp); cv.height=Math.round(h*dp); var ctx=cv.getContext('2d'); ctx.setTransform(dp,0,0,dp,0,0); return {ctx:ctx,w:w,h:h}; }
  function drawVis(){ var cv=document.getElementById('scene'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h; ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H); var n=arr.length, bw=(W-24)/n, base=H-16, mx=Math.max.apply(null,arr)||1;
    for(var i=0;i<n;i++){ var bh=arr[i]/mx*(H-40), x=12+i*bw, y=base-bh, col; if(active&&(active.a===i||active.b===i)) col=active.kind==='c'?'#fbbf24':'#f472b6'; else if(!running&&oi>0) col='#34d399'; else col='#3fa9e0';
      ctx.save(); if(active&&(active.a===i||active.b===i)){ ctx.shadowColor=col; ctx.shadowBlur=12; } var g=ctx.createLinearGradient(0,y,0,base); g.addColorStop(0,col); g.addColorStop(1,'rgba(0,0,0,0.35)'); ctx.fillStyle=g; ctx.fillRect(x,y,Math.max(1,bw-1.5),bh); ctx.restore(); }
    setTxt('mC',cmp); setTxt('mW',wr); }

  // ---- ANALYSE ----
  var anaData=null;
  function analyse(){ var dist=document.getElementById('dist').value; var Ns=[16,32,64,128,256,512,1024,2048]; var algos=['insertion','quick','merge','heap','shell','radix']; var series={};
    algos.forEach(function(al){ series[al]=[]; Ns.forEach(function(N){ var a=genInts(N,dist); var c=cnt(al,a); series[al].push([N, al==='radix'? c.w : c.c ]); }); });
    anaData={Ns:Ns,algos:algos,series:series,dist:dist}; drawAna(); tableAna(); }
  function drawAna(){ var cv=document.getElementById('scene'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h; ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H); if(!anaData)return;
    var padL=48,padB=34,padT=14,padR=14; var Nmin=16,Nmax=2048; var vmax=0; anaData.algos.forEach(function(al){ anaData.series[al].forEach(function(p){ if(p[1]>vmax)vmax=p[1]; }); }); vmax=Math.max(vmax,100);
    function X(N){ return padL+(Math.log2(N)-Math.log2(Nmin))/(Math.log2(Nmax)-Math.log2(Nmin))*(W-padL-padR); }
    function Y(vv){ return H-padB-(Math.log10(Math.max(1,vv))/Math.log10(vmax))*(H-padB-padT); }
    // grid
    ctx.strokeStyle='rgba(94,231,255,0.06)'; ctx.fillStyle='#5f7597'; ctx.font="9px 'Geist Mono',monospace";
    [16,64,256,1024].forEach(function(N){ var x=X(N); ctx.beginPath(); ctx.moveTo(x,padT); ctx.lineTo(x,H-padB); ctx.stroke(); ctx.fillText('N='+N,x-10,H-6); });
    // guide lines: N^2, N log2 N, N, log2(N!)
    function guide(fn,col,lab){ ctx.strokeStyle=col; ctx.setLineDash([4,4]); ctx.lineWidth=1; ctx.beginPath(); for(var N=Nmin;N<=Nmax;N*=1.1){ var x=X(N),y=Y(fn(N)); (N===Nmin)?ctx.moveTo(x,y):ctx.lineTo(x,y); } ctx.stroke(); ctx.setLineDash([]); ctx.fillStyle=col; ctx.fillText(lab,X(Nmax)-38,Y(fn(Nmax))-3); }
    var k=anaData.series.merge[0][1]/(16*Math.log2(16))||1; // scale guides to the merge curve
    guide(function(N){return k*N*N/16;},'rgba(248,113,113,0.5)','O(n²)'); guide(function(N){return k*N*Math.log2(N);},'rgba(52,211,153,0.5)','O(n log n)'); guide(function(N){return k*N;},'rgba(103,232,249,0.45)','O(n)');
    guide(function(N){ var s=0; for(var i=2;i<=N;i++)s+=Math.log2(i); return k*s; },'rgba(251,191,36,0.35)','log₂(N!)');
    // series
    anaData.algos.forEach(function(al){ var col=COLR[al]; ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=5; ctx.strokeStyle=col; ctx.lineWidth=1.8; ctx.beginPath(); anaData.series[al].forEach(function(p,i){ i?ctx.lineTo(X(p[0]),Y(p[1])):ctx.moveTo(X(p[0]),Y(p[1])); }); ctx.stroke(); anaData.series[al].forEach(function(p){ ctx.beginPath(); ctx.arc(X(p[0]),Y(p[1]),2.5,0,7); ctx.fill(); }); ctx.restore(); });
    ctx.fillStyle='#8ea0be'; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText('comparisons (log)  vs  N (log₂) · '+anaData.dist,padL,12);
  }
  function tableAna(){ var d=anaData, N=d.Ns[d.Ns.length-1]; var rows='<table><tr><th>Algorithm</th><th>Comparisons @'+N+'</th><th>Avg / worst</th><th>Stable</th><th>In-place</th></tr>';
    d.algos.forEach(function(al){ var last=d.series[al][d.series[al].length-1][1]; var m=META[al]; rows+='<tr><td style="color:'+COLR[al]+'">'+al+'</td><td>'+last.toLocaleString()+(al==='radix'?' moves':'')+'</td><td>'+m[0]+'</td><td>'+m[1]+'</td><td>'+m[2]+'</td></tr>'; });
    rows+='</table>'; document.getElementById('table').innerHTML=rows; }

  document.querySelectorAll('#viewSeg button').forEach(function(b){ b.addEventListener('click',function(){ document.querySelectorAll('#viewSeg button').forEach(function(x){x.classList.remove('on');}); b.classList.add('on'); view=b.getAttribute('data-v');
    document.getElementById('goBtn').textContent=view==='ana'?'Run analysis':'Sort'; document.getElementById('counters').style.display=view==='ana'?'none':'block'; document.getElementById('tableWrap').style.display=view==='ana'?'block':'none';
    document.getElementById('szWrap').style.display=view==='ana'?'none':'flex'; document.getElementById('spWrap').style.display=view==='ana'?'none':'flex';
    if(view==='ana') analyse(); }); });

  function loop(){ if(view==='vis'){ if(running){ var pf=Math.max(1,Math.round(v('sp'))); for(var k=0;k<pf&&oi<ops.length;k++) apply(ops[oi++]); if(oi>=ops.length){ running=false; setTxt('mS','done'); active={}; } } drawVis(); } requestAnimationFrame(loop); }
  shuffle(); requestAnimationFrame(loop);
})();
</script>
