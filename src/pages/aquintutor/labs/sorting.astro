---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Sorting visualizer — bubble / insertion / selection / quick / merge, recorded
// as an operation stream and replayed on a glowing gradient bar field with
// compare/swap highlighting, live counters and adjustable speed. High-DPI canvas.
---
<BaseLayout title="Sorting lab · Virtual Labs · AquinTutor" description="Watch bubble, insertion, selection, quick and merge sort race — every compare and swap highlighted, with live counters on a glowing bar field.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1320px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:18px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:290px minmax(0,1fr); gap:18px; } @media(max-width:900px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:16px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 12px; }
  .lb-row{ display:grid; gap:9px; } .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.1em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; }
  .lb-row label span{ color:#5ee7ff; } .lb-row input[type=range]{ width:100%; accent-color:#5ee7ff; }
  .lb-row select{ width:100%; background:#080a12; border:1px solid #1e2740; color:#fff; padding:8px 10px; border-radius:6px; font-size:12px; font-family:inherit; }
  .lb-btn{ background:linear-gradient(180deg,#7af0ff,#33cfe6); color:#04161b; padding:9px 16px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:11px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; }
  .lb-btn-ghost{ background:transparent; color:#cfd6da; border:1px solid #26314f; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); }
  .lb-stage canvas{ display:block; width:100%; height:auto; }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11.5px; padding:5px 0; border-bottom:1px solid #141a2c; }
  .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#5ee7ff; font-weight:700; text-align:right; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">CS · Algorithms</p>
      <h1 class="lb-title">Sorting <em>visualizer</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;"><button id="shuffleBtn" class="lb-btn lb-btn-ghost">Shuffle</button><button id="sortBtn" class="lb-btn">Sort</button></div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Setup</h3><div class="lb-row">
        <label>Algorithm</label><select id="algo"><option value="bubble">Bubble</option><option value="insertion">Insertion</option><option value="selection">Selection</option><option value="quick" selected>Quick</option><option value="merge">Merge</option></select>
        <label>Size <span id="szV">50</span></label><input id="sz" type="range" min="10" max="120" step="1" value="50"/>
        <label>Speed <span id="spV">6</span></label><input id="sp" type="range" min="1" max="30" step="1" value="6"/>
      </div></div>
      <div class="lb-panel"><h3>Counters</h3>
        <div class="lb-metric"><span class="lb-metric-l">Comparisons</span><span class="lb-metric-v" id="mC">0</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Writes</span><span class="lb-metric-v" id="mW">0</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Status</span><span class="lb-metric-v" id="mS">idle</span></div>
      </div>
    </aside>
    <section><div class="lb-stage"><canvas id="scene" width="900" height="480"></canvas></div></section>
  </div>
</main>
<script is:inline>
(function(){
  function v(id){ return parseFloat(document.getElementById(id).value); }
  var arr=[], ops=[], oi=0, running=false, cmp=0, wr=0, active={}, sortedTo=-1;
  function sync(){ document.getElementById('szV').textContent=v('sz').toFixed(0); document.getElementById('spV').textContent=v('sp').toFixed(0); }
  document.querySelectorAll('input').forEach(function(e){ e.addEventListener('input',sync); }); sync();
  document.getElementById('sz').addEventListener('change',shuffle);
  function shuffle(){ running=false; ops=[]; oi=0; cmp=0; wr=0; active={}; sortedTo=-1; var n=v('sz'); arr=[]; for(var i=0;i<n;i++) arr.push(Math.random()); document.getElementById('mS').textContent='idle'; document.getElementById('mC').textContent=0; document.getElementById('mW').textContent=0; }
  document.getElementById('shuffleBtn').addEventListener('click',shuffle); shuffle();

  function record(algo){ var a=arr.slice(), o=[]; function cm(i,j){ o.push(['c',i,j]); } function sw(i,j){ o.push(['s',i,j]); var t=a[i]; a[i]=a[j]; a[j]=t; } function st(i,val){ o.push(['w',i,val]); a[i]=val; } function done(i){ o.push(['d',i]); }
    if(algo==='bubble'){ for(var i=0;i<a.length;i++){ for(var j=0;j<a.length-1-i;j++){ cm(j,j+1); if(a[j]>a[j+1]) sw(j,j+1); } done(a.length-1-i); } done(0); }
    else if(algo==='insertion'){ for(var i=1;i<a.length;i++){ var key=a[i], j=i-1; while(j>=0){ cm(j,j+1); if(a[j]>key){ st(j+1,a[j]); j--; } else break; } st(j+1,key); } for(var k=0;k<a.length;k++) done(k); }
    else if(algo==='selection'){ for(var i=0;i<a.length;i++){ var m=i; for(var j=i+1;j<a.length;j++){ cm(j,m); if(a[j]<a[m]) m=j; } if(m!==i) sw(i,m); done(i); } }
    else if(algo==='quick'){ (function qs(lo,hi){ if(lo>=hi){ if(lo===hi) done(lo); return; } var p=a[hi], i=lo; for(var j=lo;j<hi;j++){ cm(j,hi); if(a[j]<p){ if(i!==j) sw(i,j); i++; } } sw(i,hi); done(i); qs(lo,i-1); qs(i+1,hi); })(0,a.length-1); }
    else if(algo==='merge'){ var aux=a.slice(); (function ms(lo,hi){ if(hi-lo<1) return; var mid=(lo+hi)>>1; ms(lo,mid); ms(mid+1,hi); var i=lo,j=mid+1; var tmp=[]; while(i<=mid&&j<=hi){ cm(i,j); if(a[i]<=a[j]) tmp.push(a[i++]); else tmp.push(a[j++]); } while(i<=mid) tmp.push(a[i++]); while(j<=hi) tmp.push(a[j++]); for(var k=0;k<tmp.length;k++) st(lo+k,tmp[k]); })(0,a.length-1); for(var k=0;k<a.length;k++) done(k); }
    return o;
  }
  document.getElementById('sortBtn').addEventListener('click',function(){ if(running) return; ops=record(document.getElementById('algo').value); oi=0; cmp=0; wr=0; sortedTo=-1; running=true; document.getElementById('mS').textContent='sorting'; });

  function apply(op){ if(op[0]==='c'){ cmp++; active={a:op[1],b:op[2],kind:'c'}; } else if(op[0]==='s'){ wr+=2; var t=arr[op[1]]; arr[op[1]]=arr[op[2]]; arr[op[2]]=t; active={a:op[1],b:op[2],kind:'s'}; } else if(op[0]==='w'){ wr++; arr[op[1]]=op[2]; active={a:op[1],kind:'s'}; } else if(op[0]==='d'){ if(op[1]>sortedTo && op[1]===sortedTo+1) sortedTo=op[1]; active.done=op[1]; } }

  function hidpi(cv){ var r=cv.getBoundingClientRect(), d=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w; cv.width=Math.round(w*d); cv.height=Math.round(h*d); var ctx=cv.getContext('2d'); ctx.setTransform(d,0,0,d,0,0); return {ctx:ctx,w:w,h:h}; }
  function draw(){ var cv=document.getElementById('scene'), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h;
    ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H); var n=arr.length, bw=(W-24)/n, base=H-16;
    for(var i=0;i<n;i++){ var bh=arr[i]*(H-40); var x=12+i*bw, y=base-bh; var col;
      if(active&&(active.a===i||active.b===i)){ col=active.kind==='c'?'#fbbf24':'#f472b6'; }
      else if(!running && oi>0){ col='#34d399'; }
      else if(sortedTo>=i){ col='#34d399'; }
      else { col='#3fa9e0'; }
      ctx.save(); if(active&&(active.a===i||active.b===i)){ ctx.shadowColor=col; ctx.shadowBlur=12; }
      var g=ctx.createLinearGradient(0,y,0,base); g.addColorStop(0,col); g.addColorStop(1,'rgba(0,0,0,0.35)'); ctx.fillStyle=g; ctx.fillRect(x,y,Math.max(1,bw-1.5),bh); ctx.restore(); }
    document.getElementById('mC').textContent=cmp; document.getElementById('mW').textContent=wr;
  }
  var acc=0; function loop(){ if(running){ var perFrame=Math.max(1,Math.round(v('sp'))); for(var k=0;k<perFrame && oi<ops.length;k++){ apply(ops[oi++]); } if(oi>=ops.length){ running=false; sortedTo=arr.length; document.getElementById('mS').textContent='done'; active={}; } } draw(); requestAnimationFrame(loop); }
  requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
