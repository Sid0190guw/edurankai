---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Combinational-logic synthesiser (advanced level). Edit a truth table (0/1/X
// don't-care) for a function of 2-4 variables and it SYNTHESISES the minimal
// two-level logic: Quine-McCluskey generates the prime implicants, the prime-
// implicant chart selects the essential ones plus a greedy cover, and the
// result is shown as the minimal sum-of-products, a Karnaugh map with each
// chosen implicant outlined, the AND-OR gate-level circuit, and the literal /
// gate counts (with the NAND-NAND equivalence). No libraries.
---
<BaseLayout title="Logic Synthesis & Minimisation · Virtual Labs · AquinTutor" description="Advanced digital design: edit a truth table with don't-cares and synthesise the minimal SOP by Quine-McCluskey, with the Karnaugh map, prime implicants, gate-level circuit and literal/gate counts. Built from scratch.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1340px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:16px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:280px minmax(0,1fr); gap:18px; } @media(max-width:960px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:15px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 11px; }
  select{ width:100%; background:#080a12; border:1px solid #1e2740; color:#fff; padding:8px 10px; border-radius:6px; font-size:12px; font-family:inherit; }
  .tt{ font-family:'Geist Mono',monospace; font-size:12px; width:100%; } .tt th{ color:#5ee7ff; text-align:center; padding:3px; font-size:10px; } .tt td{ text-align:center; padding:2px; color:#8ea0be; } .tt .out{ cursor:pointer; border-radius:4px; padding:2px 6px; font-weight:700; } .tt .o0{ color:#5f7597; } .tt .o1{ color:#34d399; background:rgba(52,211,153,0.12); } .tt .ox{ color:#fbbf24; }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11px; padding:4px 0; border-bottom:1px solid #141a2c; } .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#5ee7ff; font-weight:700; text-align:right; }
  .lb-expr{ font-family:'Geist Mono',monospace; font-size:15px; color:#34d399; line-height:1.7; word-break:break-word; } .lb-expr sup{ color:#f87171; }
  .lb-cv{ display:block; width:100%; height:auto; background:#070a12; border:1px solid #1e2740; border-radius:12px; margin-top:12px; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">Digital design · Two-level minimisation</p>
      <h1 class="lb-title">Logic <em>synthesis</em>.</h1>
    </div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Function</h3>
        <select id="vars"><option value="2">2 variables (A,B)</option><option value="3" selected>3 variables (A,B,C)</option><option value="4">4 variables (A,B,C,D)</option></select>
        <select id="preset" style="margin-top:8px;"><option value="">Preset…</option><option value="sum">Full-adder Sum</option><option value="cout">Full-adder Carry</option><option value="maj">Majority</option><option value="parity">Even parity</option><option value="rand">Random</option><option value="clear">All zero</option></select>
      </div>
      <div class="lb-panel"><h3>Truth table <span style="color:#7e8aa3;font-size:9px;">(click output: 0→1→X)</span></h3>
        <div id="ttWrap"></div>
      </div>
      <div class="lb-panel"><h3>Synthesis</h3>
        <div class="lb-metric"><span class="lb-metric-l">Prime implicants</span><span class="lb-metric-v" id="mPI">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Essential PIs</span><span class="lb-metric-v" id="mEPI">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Product terms</span><span class="lb-metric-v" id="mTerms">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Literals</span><span class="lb-metric-v" id="mLit">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Gates (AND+OR)</span><span class="lb-metric-v" id="mGates" style="color:#fbbf24;">—</span></div>
      </div>
    </aside>
    <section>
      <div class="lb-panel"><h3>Minimal sum-of-products</h3>
        <div class="lb-expr" id="expr">—</div>
        <p style="font-size:11px;color:#7e8aa3;margin:8px 0 0;line-height:1.6;">Quine-McCluskey prime implicants + essential-PI cover. The same two-level SOP realises directly as NAND-NAND with identical gate count (De Morgan).</p>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;" id="cvGrid">
        <div><p class="lb-eye">Karnaugh map · implicant groups</p><canvas id="kmap" class="lb-cv" width="460" height="300"></canvas></div>
        <div><p class="lb-eye">Gate-level circuit (AND-OR)</p><canvas id="circ" class="lb-cv" width="460" height="300"></canvas></div>
      </div>
    </section>
  </div>
</main>
<script is:inline>
(function(){
  var VARS=['A','B','C','D']; var n=3; var out=[]; // out[minterm] = 0|1|2(X)
  var PICOLS=['#34d399','#f472b6','#fbbf24','#67e8f9','#a78bfa','#fb923c','#6ee7a8','#ff6b6b'];
  function setN(nn){ n=nn; out=new Array(1<<n).fill(0); }
  setN(3);

  function preset(name){ var N=1<<n; out=new Array(N).fill(0);
    if(name==='sum'){ setN(3); out=[0,1,1,0,1,0,0,1]; }
    else if(name==='cout'){ setN(3); out=[0,0,0,1,0,1,1,1]; }
    else if(name==='maj'){ for(var m=0;m<(1<<n);m++){ var b=0; for(var i=0;i<n;i++) b+=(m>>i)&1; out[m]=b>n/2?1:0; } }
    else if(name==='parity'){ for(var m=0;m<(1<<n);m++){ var b=0; for(var i=0;i<n;i++) b+=(m>>i)&1; out[m]=(b%2===0)?1:0; } }
    else if(name==='rand'){ for(var m=0;m<(1<<n);m++) out[m]=Math.random()<0.4?1:(Math.random()<0.12?2:0); }
    else { out=new Array(1<<n).fill(0); }
  }

  // ---- Quine-McCluskey ----
  function primeImplicants(mins,dc){ var cur=mins.concat(dc).map(function(m){return {v:m,dash:0};}); var primes=[], seen={};
    while(cur.length){ var used=new Array(cur.length).fill(false), nextMap={};
      for(var i=0;i<cur.length;i++)for(var j=i+1;j<cur.length;j++){ if(cur[i].dash!==cur[j].dash)continue; var x=cur[i].v^cur[j].v; if(x!==0 && (x&(x-1))===0){ used[i]=used[j]=true; var nd=cur[i].dash|x, nv=cur[i].v&~x; nextMap[nv+'|'+nd]={v:nv,dash:nd}; } }
      for(var i=0;i<cur.length;i++){ if(!used[i]){ var k=cur[i].v+'|'+cur[i].dash; if(!seen[k]){ seen[k]=1; primes.push(cur[i]); } } }
      cur=Object.keys(nextMap).map(function(k){return nextMap[k];}); }
    return primes; }
  function covers(p,m){ return (m&~p.dash)===(p.v&~p.dash); }
  function minimalCover(primes,mins){ var chosen={}, essential={};
    mins.forEach(function(m){ var c=[]; primes.forEach(function(p,pi){ if(covers(p,m))c.push(pi); }); if(c.length===1){ chosen[c[0]]=1; essential[c[0]]=1; } });
    var covered={}; Object.keys(chosen).forEach(function(pi){ mins.forEach(function(m){ if(covers(primes[pi],m))covered[m]=1; }); });
    var rem=mins.filter(function(m){return !covered[m];});
    while(rem.length){ var best=-1,bc=-1; for(var pi=0;pi<primes.length;pi++){ if(chosen[pi])continue; var cnt=rem.filter(function(m){return covers(primes[pi],m);}).length; if(cnt>bc){bc=cnt;best=pi;} } if(best<0)break; chosen[best]=1; rem=rem.filter(function(m){return !covers(primes[best],m);}); }
    return { chosen:Object.keys(chosen).map(Number), essential:essential }; }
  function term(p){ if(p.dash===((1<<n)-1)) return '1'; var s=''; for(var b=n-1;b>=0;b--){ if((p.dash>>b)&1)continue; var name=VARS[n-1-b]; s+= ((p.v>>b)&1) ? name : name+"<sup>'</sup>"; } return s; }
  function litCount(p){ var c=0; for(var b=0;b<n;b++) if(!((p.dash>>b)&1)) c++; return c; }

  function synth(){ var mins=[],dc=[]; for(var m=0;m<(1<<n);m++){ if(out[m]===1)mins.push(m); else if(out[m]===2)dc.push(m); }
    var primes=primeImplicants(mins,dc); var cov=mins.length? minimalCover(primes,mins):{chosen:[],essential:{}};
    var chosen=cov.chosen.map(function(pi){return primes[pi];});
    // expression
    var expr; if(!mins.length) expr='0 (always false)'; else if(chosen.length===1 && chosen[0].dash===((1<<n)-1)) expr='1 (always true)'; else expr=chosen.map(term).join(' + ');
    document.getElementById('expr').innerHTML=expr;
    document.getElementById('mPI').textContent=primes.length; document.getElementById('mEPI').textContent=Object.keys(cov.essential).length;
    document.getElementById('mTerms').textContent=chosen.length; var lits=chosen.reduce(function(a,p){return a+litCount(p);},0); document.getElementById('mLit').textContent=lits;
    var ngAnd=chosen.filter(function(p){return litCount(p)>1;}).length; document.getElementById('mGates').textContent=(ngAnd)+(chosen.length>1?1:0)+' + inv';
    drawKmap(chosen); drawCirc(chosen);
  }

  // ---- Karnaugh map ----
  function grayLayout(){ if(n===2) return {rowsBits:1,colsBits:1,rowG:[0,1],colG:[0,1],rowVar:[0],colVar:[1]};
    if(n===3) return {rowsBits:1,colsBits:2,rowG:[0,1],colG:[0,1,3,2],rowVar:[0],colVar:[1,2]};
    return {rowsBits:2,colsBits:2,rowG:[0,1,3,2],colG:[0,1,3,2],rowVar:[0,1],colVar:[2,3]}; }
  function mintermAt(L,ri,ci){ var rg=L.rowG[ri], cg=L.colG[ci]; var m=0; // high vars are rowVar (A,...), low are colVar
    for(var k=0;k<L.rowVar.length;k++){ var bit=(rg>>(L.rowVar.length-1-k))&1; m |= bit<<(n-1-L.rowVar[k]); }
    for(var k=0;k<L.colVar.length;k++){ var bit=(cg>>(L.colVar.length-1-k))&1; m |= bit<<(n-1-L.colVar[k]); }
    return m; }
  function hidpi(cv){ var r=cv.getBoundingClientRect(), dp=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w; cv.width=Math.round(w*dp); cv.height=Math.round(h*dp); var ctx=cv.getContext('2d'); ctx.setTransform(dp,0,0,dp,0,0); return {ctx:ctx,w:w,h:h}; }
  function drawKmap(chosen){ var cv=document.getElementById('kmap'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h; ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H);
    var L=grayLayout(); var R=L.rowG.length, C=L.colG.length; var pad=34, cw=(W-pad-8)/C, ch=(H-pad-8)/R;
    function cellXY(ri,ci){ return [pad+ci*cw, pad+ri*ch]; }
    // labels
    ctx.fillStyle='#8ea0be'; ctx.font="10px 'Geist Mono',monospace"; ctx.textAlign='center';
    ctx.fillText(L.colVar.map(function(i){return VARS[i];}).join(''), pad+C*cw/2, 14);
    ctx.save(); ctx.translate(12,pad+R*ch/2); ctx.rotate(-Math.PI/2); ctx.fillText(L.rowVar.map(function(i){return VARS[i];}).join(''),0,0); ctx.restore();
    for(var ci=0;ci<C;ci++){ ctx.fillStyle='#5f7597'; ctx.fillText(bits(L.colG[ci],L.colsBits), pad+ci*cw+cw/2, pad-4); }
    for(var ri=0;ri<R;ri++){ ctx.fillStyle='#5f7597'; ctx.textAlign='right'; ctx.fillText(bits(L.rowG[ri],L.rowsBits), pad-4, pad+ri*ch+ch/2+3); ctx.textAlign='center'; }
    // cells
    for(var ri=0;ri<R;ri++)for(var ci=0;ci<C;ci++){ var m=mintermAt(L,ri,ci); var xy=cellXY(ri,ci); ctx.strokeStyle='#1e2740'; ctx.strokeRect(xy[0],xy[1],cw,ch);
      var val=out[m]; ctx.fillStyle=val===1?'#34d399':val===2?'#fbbf24':'#3a4258'; ctx.font="700 15px 'Geist Mono',monospace"; ctx.fillText(val===2?'X':val, xy[0]+cw/2, xy[1]+ch/2+5);
      ctx.fillStyle='#3a4258'; ctx.font="8px 'Geist Mono',monospace"; ctx.fillText('m'+m, xy[0]+cw-11, xy[1]+10); }
    // implicant outlines
    chosen.forEach(function(p,idx){ var col=PICOLS[idx%PICOLS.length]; var inset=3+idx*2;
      for(var ri=0;ri<R;ri++)for(var ci=0;ci<C;ci++){ var m=mintermAt(L,ri,ci); if(covers(p,m) && out[m]!==0){ var xy=cellXY(ri,ci); ctx.strokeStyle=col; ctx.lineWidth=2; ctx.strokeRect(xy[0]+inset,xy[1]+inset,cw-2*inset,ch-2*inset); } } });
    ctx.textAlign='left';
  }
  function bits(v,w){ var s=''; for(var i=w-1;i>=0;i--) s+=(v>>i)&1; return s; }

  // ---- circuit ----
  function drawCirc(chosen){ var cv=document.getElementById('circ'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h; ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H);
    if(!chosen.length){ ctx.fillStyle='#5f7597'; ctx.font="12px 'Geist Mono',monospace"; ctx.fillText('output = 0',20,30); return; }
    var terms=chosen.map(term).map(function(t){ return t.replace(/<sup>'<\/sup>/g,"'"); });
    var ty=H/(chosen.length+1); ctx.font="12px 'Geist Mono',monospace";
    chosen.forEach(function(p,i){ var y=ty*(i+1); ctx.strokeStyle='#5ee7ff'; ctx.lineWidth=1.4;
      // AND gate box
      var gx=W*0.45, gw=44, gh=Math.min(34,ty*0.7); ctx.fillStyle='rgba(94,231,255,0.08)'; ctx.strokeStyle='#5ee7ff'; ctx.beginPath(); ctx.moveTo(gx,y-gh/2); ctx.lineTo(gx+gw*0.5,y-gh/2); ctx.arc(gx+gw*0.5,y,gh/2,-Math.PI/2,Math.PI/2); ctx.lineTo(gx,y+gh/2); ctx.closePath(); ctx.fill(); ctx.stroke();
      ctx.fillStyle=PICOLS[i%PICOLS.length]; ctx.fillText(litCount(p)>1?'AND':'', gx+6,y+4);
      // literal label
      ctx.fillStyle='#cfd6da'; ctx.textAlign='right'; ctx.fillText(terms[i]||'1', gx-6, y+4); ctx.textAlign='left';
      // wire to OR
      ctx.strokeStyle='#31405f'; ctx.beginPath(); ctx.moveTo(gx+gw,y); ctx.lineTo(W*0.74,y); ctx.stroke(); });
    // OR gate
    if(chosen.length>1){ var ox=W*0.74, oy=H/2, ow=46, oh=Math.min(H*0.7,chosen.length*ty); ctx.fillStyle='rgba(52,211,153,0.08)'; ctx.strokeStyle='#34d399'; ctx.lineWidth=1.6; ctx.beginPath(); ctx.moveTo(ox,oy-oh/2); ctx.quadraticCurveTo(ox+ow*0.6,oy-oh/2,ox+ow,oy); ctx.quadraticCurveTo(ox+ow*0.6,oy+oh/2,ox,oy+oh/2); ctx.quadraticCurveTo(ox+ow*0.28,oy,ox,oy-oh/2); ctx.closePath(); ctx.fill(); ctx.stroke(); ctx.fillStyle='#34d399'; ctx.fillText('OR',ox+8,oy+4);
      ctx.strokeStyle='#34d399'; ctx.beginPath(); ctx.moveTo(ox+ow,oy); ctx.lineTo(W-14,oy); ctx.stroke(); ctx.save(); ctx.shadowColor='#34d399'; ctx.shadowBlur=10; ctx.fillStyle='#34d399'; ctx.beginPath(); ctx.arc(W-12,oy,5,0,7); ctx.fill(); ctx.restore(); }
    else { ctx.save(); ctx.shadowColor='#34d399'; ctx.shadowBlur=10; ctx.fillStyle='#34d399'; ctx.beginPath(); ctx.arc(W-12,ty,5,0,7); ctx.fill(); ctx.restore(); }
    ctx.fillStyle='#cfd6da'; ctx.font="700 12px 'Geist Mono',monospace"; ctx.fillText('Y', W-8, H/2-8);
  }

  function buildTT(){ var wrap=document.getElementById('ttWrap'); var N=1<<n; var html='<table class="tt"><tr>'; for(var i=0;i<n;i++)html+='<th>'+VARS[i]+'</th>'; html+='<th>Y</th></tr>';
    for(var m=0;m<N;m++){ html+='<tr>'; for(var i=0;i<n;i++)html+='<td>'+((m>>(n-1-i))&1)+'</td>'; var cls=out[m]===1?'o1':out[m]===2?'ox':'o0'; html+='<td><span class="out '+cls+'" data-m="'+m+'">'+(out[m]===2?'X':out[m])+'</span></td></tr>'; }
    html+='</table>'; wrap.innerHTML=html;
    wrap.querySelectorAll('.out').forEach(function(el){ el.addEventListener('click',function(){ var m=+el.getAttribute('data-m'); out[m]=(out[m]+1)%3; buildTT(); synth(); }); }); }

  document.getElementById('vars').addEventListener('change',function(){ setN(+this.value); buildTT(); synth(); });
  document.getElementById('preset').addEventListener('change',function(){ if(this.value){ if(this.value==='sum'||this.value==='cout'){ document.getElementById('vars').value='3'; setN(3); } preset(this.value); buildTT(); synth(); } });
  preset('cout'); document.getElementById('vars').value='3'; buildTT(); synth();
})();
</script>
</BaseLayout>
