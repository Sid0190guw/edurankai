---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Logic Gate Builder — AquinTutor Labs" description="Drag-drop digital logic builder with live signal propagation and auto-generated truth tables">
<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; font-family: 'Inter', system-ui, sans-serif; }
  .wrap { max-width: 1400px; margin: 0 auto; padding: 28px 24px 80px; }
  .eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #f2c14e; font-weight: 700; }
  h1 { font-family: 'Cormorant Garamond', serif; font-size: 34px; font-weight: 600; letter-spacing: -0.02em; margin: 6px 0 4px; }
  h1 em { color: #f2c14e; font-weight: 500; font-style: italic; }
  .sub { color: #9097a0; font-size: 14px; max-width: 720px; line-height: 1.55; }
  .layout { display: grid; grid-template-columns: 200px 1fr 320px; gap: 16px; margin-top: 22px; }
  @media (max-width: 1100px) { .layout { grid-template-columns: 1fr; } }
  .panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 14px; }
  .panel h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #f2c14e; font-weight: 700; margin: 0 0 10px; }
  .palette { display: grid; gap: 6px; }
  .palette button { background: #1a1d27; color: #e8e8ee; border: 1px solid #2a2a35; border-radius: 6px; padding: 8px 10px; font-family: 'Geist Mono', monospace; font-size: 11px; cursor: pointer; text-align: left; font-weight: 700; letter-spacing: 0.04em; transition: all .14s; }
  .palette button:hover { background: #946322; border-color: #946322; color: #fff; }
  .palette .group-title { color: #6b7280; font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; margin: 10px 0 4px; padding-left: 2px; }
  .stage-wrap { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 10px; overflow: hidden; position: relative; }
  #stage { display: block; width: 100%; height: 560px; cursor: crosshair; }
  .toolbar { display: flex; gap: 8px; padding: 10px; border-bottom: 1px solid #2a2a35; background: #11131a; flex-wrap: wrap; align-items: center; }
  .btn { background: #f2c14e; color: #1a1206; padding: 8px 14px; border-radius: 6px; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; border: none; cursor: pointer; }
  .btn:hover { background: #f9d176; }
  .btn.ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
  .btn.ghost:hover { border-color: #f2c14e; color: #f2c14e; }
  select { background: #0a0a0c; border: 1px solid #2a2a35; color: #fff; padding: 7px 10px; border-radius: 5px; font-family: 'Geist Mono', monospace; font-size: 11px; }
  .hint { color: #6b7280; font-size: 11px; margin-left: auto; font-family: 'Geist Mono', monospace; }
  table.tt { width: 100%; border-collapse: collapse; font-family: 'Geist Mono', monospace; font-size: 11px; }
  table.tt th, table.tt td { padding: 5px 7px; border: 1px solid #2a2a35; text-align: center; }
  table.tt th { background: #1a1d27; color: #f2c14e; font-weight: 700; font-size: 10px; letter-spacing: 0.08em; }
  table.tt td.one { background: rgba(242, 193, 78, 0.18); color: #f9d176; font-weight: 700; }
  table.tt td.zero { color: #6b7280; }
  .metric { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px dashed #2a2a35; font-family: 'Geist Mono', monospace; font-size: 11px; }
  .metric:last-child { border-bottom: none; }
  .metric .k { color: #9097a0; }
  .metric .v { color: #f2c14e; font-weight: 700; }
  .tt-wrap { max-height: 280px; overflow: auto; margin-top: 4px; }
  .legend { font-family: 'Geist Mono', monospace; font-size: 10px; color: #6b7280; line-height: 1.6; margin-top: 8px; }
</style>
<main class="wrap">
  <div class="eyebrow">AquinTutor Labs / Digital Logic</div>
  <h1>Logic Gate <em>Builder</em></h1>
  <p class="sub">Drop gates, drag wires between pins, toggle inputs, watch signals propagate in real time. The right panel enumerates every input combination and runs the full circuit to produce a truth table. Includes presets for half adder, full adder, SR latch, D flip-flop, 2-bit comparator and 4:1 mux.</p>

  <div class="layout">
    <div class="panel palette">
      <h3>Components</h3>
      <div class="group-title">I/O</div>
      <button data-add="IN">Input switch</button>
      <button data-add="OUT">Output LED</button>
      <button data-add="CLK">Clock</button>
      <div class="group-title">Gates</div>
      <button data-add="AND">AND</button>
      <button data-add="OR">OR</button>
      <button data-add="NOT">NOT</button>
      <button data-add="NAND">NAND</button>
      <button data-add="NOR">NOR</button>
      <button data-add="XOR">XOR</button>
      <button data-add="XNOR">XNOR</button>
      <div class="group-title">Presets</div>
      <select id="preset">
        <option value="">-- load preset --</option>
        <option value="half-adder">Half Adder</option>
        <option value="full-adder">Full Adder</option>
        <option value="sr-latch">SR Latch</option>
        <option value="d-flipflop">D Flip-Flop</option>
        <option value="comparator">2-bit Comparator</option>
        <option value="mux41">4:1 Multiplexer</option>
      </select>
    </div>

    <div class="stage-wrap">
      <div class="toolbar">
        <button class="btn" id="clear">Clear</button>
        <button class="btn ghost" id="delete-sel">Delete selected</button>
        <button class="btn ghost" id="step">Step</button>
        <span class="hint">Click pin &rarr; pin to wire &middot; Click input to toggle &middot; Right-click to delete</span>
      </div>
      <canvas id="stage" width="900" height="560"></canvas>
    </div>

    <div class="panel">
      <h3>Truth Table</h3>
      <div class="tt-wrap" id="tt-wrap"><div style="color:#6b7280;font-family:'Geist Mono',monospace;font-size:11px;padding:8px 4px;">Add inputs and outputs to see the truth table.</div></div>
      <h3 style="margin-top:14px">Circuit Metrics</h3>
      <div class="metric"><span class="k">Gates</span><span class="v" id="m-gates">0</span></div>
      <div class="metric"><span class="k">Inputs</span><span class="v" id="m-in">0</span></div>
      <div class="metric"><span class="k">Outputs</span><span class="v" id="m-out">0</span></div>
      <div class="metric"><span class="k">Wires</span><span class="v" id="m-wires">0</span></div>
      <div class="metric"><span class="k">Max depth</span><span class="v" id="m-depth">0</span></div>
      <div class="legend">
        Combinational circuits are topologically sorted then evaluated in one forward pass. Sequential circuits (latches) are evaluated iteratively until the network settles or 32 iterations elapse.
      </div>
    </div>
  </div>
</main>

<script is:inline>
(function () {
  const cvs = document.getElementById('stage');
  const ctx = cvs.getContext('2d');
  function fit() {
    const r = cvs.getBoundingClientRect();
    const dpr = window.devicePixelRatio || 1;
    cvs.width = r.width * dpr; cvs.height = r.height * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }
  fit(); window.addEventListener('resize', fit);

  const W = () => cvs.getBoundingClientRect().width;
  const H = () => cvs.getBoundingClientRect().height;

  // Gate definitions: name → {nInputs, fn, w, h}
  const GATES = {
    IN:   { nin: 0, nout: 1, w: 64, h: 36, color: '#946322', label: '' },
    OUT:  { nin: 1, nout: 0, w: 56, h: 36, color: '#946322', label: '' },
    CLK:  { nin: 0, nout: 1, w: 64, h: 36, color: '#946322', label: 'CLK' },
    AND:  { nin: 2, nout: 1, w: 70, h: 50, color: '#1a1d27', label: 'AND', fn: a => a[0] & a[1] },
    OR:   { nin: 2, nout: 1, w: 70, h: 50, color: '#1a1d27', label: 'OR',  fn: a => a[0] | a[1] },
    NOT:  { nin: 1, nout: 1, w: 70, h: 40, color: '#1a1d27', label: 'NOT', fn: a => 1 - a[0] },
    NAND: { nin: 2, nout: 1, w: 70, h: 50, color: '#1a1d27', label: 'NAND', fn: a => 1 - (a[0] & a[1]) },
    NOR:  { nin: 2, nout: 1, w: 70, h: 50, color: '#1a1d27', label: 'NOR', fn: a => 1 - (a[0] | a[1]) },
    XOR:  { nin: 2, nout: 1, w: 70, h: 50, color: '#1a1d27', label: 'XOR', fn: a => a[0] ^ a[1] },
    XNOR: { nin: 2, nout: 1, w: 70, h: 50, color: '#1a1d27', label: 'XNOR', fn: a => 1 - (a[0] ^ a[1]) },
  };

  const state = {
    nodes: [],   // {id,type,x,y,name,value,clk}
    wires: [],   // {from:{node,port}, to:{node,port}}
    pendingPin: null, // {node, port, isOut}
    nextId: 1,
    selected: null,
    drag: null,
    tickCounter: 0,
  };

  function addNode(type, x, y, opts = {}) {
    const def = GATES[type];
    const id = state.nextId++;
    const sameType = state.nodes.filter(n => n.type === type).length;
    const name = opts.name || (type === 'IN' ? String.fromCharCode(65 + sameType) : type === 'OUT' ? 'Y' + sameType : '');
    state.nodes.push({ id, type, x, y, w: def.w, h: def.h, name, value: 0, clk: 0 });
    return id;
  }
  function addWire(fromNode, fromPort, toNode, toPort) {
    // Each input pin can have only one driver — remove any existing wire to (toNode,toPort)
    state.wires = state.wires.filter(w => !(w.to.node === toNode && w.to.port === toPort));
    state.wires.push({ from: { node: fromNode, port: fromPort }, to: { node: toNode, port: toPort } });
  }
  function removeNode(id) {
    state.nodes = state.nodes.filter(n => n.id !== id);
    state.wires = state.wires.filter(w => w.from.node !== id && w.to.node !== id);
  }

  function pinPos(node, isOut, port) {
    const def = GATES[node.type];
    if (isOut) {
      return { x: node.x + node.w / 2 + 4, y: node.y };
    }
    if (def.nin === 1) return { x: node.x - node.w / 2 - 4, y: node.y };
    // multiple input pins, vertically distributed
    const total = def.nin;
    const yStart = -node.h / 2 + node.h / (total + 1);
    return { x: node.x - node.w / 2 - 4, y: node.y + yStart + (node.h / (total + 1)) * port };
  }

  function nodeAt(px, py) {
    for (let i = state.nodes.length - 1; i >= 0; i--) {
      const n = state.nodes[i];
      if (Math.abs(px - n.x) <= n.w / 2 + 10 && Math.abs(py - n.y) <= n.h / 2 + 6) return n;
    }
    return null;
  }
  function pinAt(px, py) {
    for (const n of state.nodes) {
      const def = GATES[n.type];
      if (def.nout > 0) {
        const p = pinPos(n, true, 0);
        if (Math.hypot(p.x - px, p.y - py) <= 8) return { node: n.id, port: 0, isOut: true };
      }
      for (let i = 0; i < def.nin; i++) {
        const p = pinPos(n, false, i);
        if (Math.hypot(p.x - px, p.y - py) <= 8) return { node: n.id, port: i, isOut: false };
      }
    }
    return null;
  }

  // ── Evaluation ────────────────────────────────────────────────────────────
  function evaluate(inputOverrides) {
    // inputOverrides = optional { nodeId: 0|1 } for truth-table runs
    const valByNode = {};
    for (const n of state.nodes) {
      if (n.type === 'IN' || n.type === 'CLK') {
        valByNode[n.id] = inputOverrides && inputOverrides[n.id] != null ? inputOverrides[n.id] : (n.value | 0);
      } else {
        valByNode[n.id] = 0;
      }
    }
    // Iterate up to 32 passes for sequential circuits
    let changed = true, iter = 0;
    while (changed && iter < 32) {
      changed = false; iter++;
      for (const n of state.nodes) {
        if (n.type === 'IN' || n.type === 'CLK' || n.type === 'OUT') continue;
        const def = GATES[n.type];
        const inVals = [];
        for (let p = 0; p < def.nin; p++) {
          const w = state.wires.find(w => w.to.node === n.id && w.to.port === p);
          inVals.push(w ? (valByNode[w.from.node] | 0) : 0);
        }
        const nv = def.fn(inVals) & 1;
        if (nv !== valByNode[n.id]) { valByNode[n.id] = nv; changed = true; }
      }
    }
    // OUT nodes inherit from their driver
    for (const n of state.nodes) {
      if (n.type !== 'OUT') continue;
      const w = state.wires.find(w => w.to.node === n.id && w.to.port === 0);
      valByNode[n.id] = w ? (valByNode[w.from.node] | 0) : 0;
    }
    return valByNode;
  }

  function depth() {
    // Longest path from any IN to any OUT, ignoring loops
    const memo = {};
    const visiting = {};
    function d(id, seen) {
      if (seen[id]) return 0;
      if (memo[id] != null) return memo[id];
      seen[id] = true;
      const incoming = state.wires.filter(w => w.to.node === id);
      let best = 0;
      for (const w of incoming) best = Math.max(best, 1 + d(w.from.node, { ...seen }));
      memo[id] = best;
      return best;
    }
    let max = 0;
    for (const n of state.nodes) if (n.type === 'OUT') max = Math.max(max, d(n.id, {}));
    return max;
  }

  // ── Rendering ─────────────────────────────────────────────────────────────
  function draw() {
    const vals = evaluate();
    ctx.clearRect(0, 0, W(), H());
    // grid
    ctx.strokeStyle = '#15161e'; ctx.lineWidth = 1;
    for (let x = 0; x < W(); x += 24) { ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H()); ctx.stroke(); }
    for (let y = 0; y < H(); y += 24) { ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W(), y); ctx.stroke(); }

    // wires
    for (const w of state.wires) {
      const from = state.nodes.find(n => n.id === w.from.node);
      const to = state.nodes.find(n => n.id === w.to.node);
      if (!from || !to) continue;
      const p1 = pinPos(from, true, w.from.port);
      const p2 = pinPos(to, false, w.to.port);
      const live = vals[w.from.node];
      ctx.strokeStyle = live ? '#f2c14e' : '#3a3a45';
      ctx.lineWidth = live ? 2.4 : 1.6;
      ctx.beginPath();
      ctx.moveTo(p1.x, p1.y);
      const mx = (p1.x + p2.x) / 2;
      ctx.bezierCurveTo(mx, p1.y, mx, p2.y, p2.x, p2.y);
      ctx.stroke();
    }

    // pending wire preview
    if (state.pendingPin) {
      const n = state.nodes.find(x => x.id === state.pendingPin.node);
      if (n && state.mouse) {
        const p = pinPos(n, state.pendingPin.isOut, state.pendingPin.port);
        ctx.strokeStyle = '#f9d176'; ctx.setLineDash([4, 4]); ctx.lineWidth = 1.6;
        ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(state.mouse.x, state.mouse.y); ctx.stroke();
        ctx.setLineDash([]);
      }
    }

    // nodes
    for (const n of state.nodes) {
      const def = GATES[n.type];
      const v = vals[n.id] | 0;
      const sel = state.selected === n.id;
      ctx.fillStyle = n.type === 'IN' || n.type === 'CLK'
        ? (v ? '#f2c14e' : '#1a1d27')
        : n.type === 'OUT'
        ? (v ? '#f2c14e' : '#1a1d27')
        : '#1a1d27';
      ctx.strokeStyle = sel ? '#f9d176' : (v && n.type !== 'OUT' && n.type !== 'IN' && n.type !== 'CLK' ? '#946322' : '#2a2a35');
      ctx.lineWidth = sel ? 2 : 1.4;

      if (n.type === 'IN' || n.type === 'CLK') {
        // rounded toggle
        const r = 8;
        ctx.beginPath();
        ctx.moveTo(n.x - n.w / 2 + r, n.y - n.h / 2);
        ctx.lineTo(n.x + n.w / 2 - r, n.y - n.h / 2);
        ctx.quadraticCurveTo(n.x + n.w / 2, n.y - n.h / 2, n.x + n.w / 2, n.y - n.h / 2 + r);
        ctx.lineTo(n.x + n.w / 2, n.y + n.h / 2 - r);
        ctx.quadraticCurveTo(n.x + n.w / 2, n.y + n.h / 2, n.x + n.w / 2 - r, n.y + n.h / 2);
        ctx.lineTo(n.x - n.w / 2 + r, n.y + n.h / 2);
        ctx.quadraticCurveTo(n.x - n.w / 2, n.y + n.h / 2, n.x - n.w / 2, n.y + n.h / 2 - r);
        ctx.lineTo(n.x - n.w / 2, n.y - n.h / 2 + r);
        ctx.quadraticCurveTo(n.x - n.w / 2, n.y - n.h / 2, n.x - n.w / 2 + r, n.y - n.h / 2);
        ctx.fill(); ctx.stroke();
        ctx.fillStyle = v ? '#1a1206' : '#cfd6da';
        ctx.font = 'bold 13px Geist Mono, monospace';
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(n.type === 'CLK' ? 'CLK' : (n.name + ':' + v), n.x, n.y);
      } else if (n.type === 'OUT') {
        // LED circle
        ctx.beginPath();
        ctx.arc(n.x, n.y, n.h / 2 - 2, 0, Math.PI * 2);
        ctx.fill(); ctx.stroke();
        if (v) {
          ctx.beginPath();
          ctx.arc(n.x, n.y, n.h / 2 - 5, 0, Math.PI * 2);
          ctx.fillStyle = '#f9d176';
          ctx.shadowColor = '#f2c14e'; ctx.shadowBlur = 16;
          ctx.fill();
          ctx.shadowBlur = 0;
        }
        ctx.fillStyle = '#9097a0';
        ctx.font = 'bold 10px Geist Mono, monospace';
        ctx.textAlign = 'center';
        ctx.fillText(n.name, n.x, n.y + n.h / 2 + 12);
      } else {
        // gate body — rounded rectangle
        const r = 6;
        ctx.beginPath();
        ctx.moveTo(n.x - n.w / 2 + r, n.y - n.h / 2);
        ctx.lineTo(n.x + n.w / 2 - r, n.y - n.h / 2);
        ctx.quadraticCurveTo(n.x + n.w / 2, n.y - n.h / 2, n.x + n.w / 2, n.y - n.h / 2 + r);
        ctx.lineTo(n.x + n.w / 2, n.y + n.h / 2 - r);
        ctx.quadraticCurveTo(n.x + n.w / 2, n.y + n.h / 2, n.x + n.w / 2 - r, n.y + n.h / 2);
        ctx.lineTo(n.x - n.w / 2 + r, n.y + n.h / 2);
        ctx.quadraticCurveTo(n.x - n.w / 2, n.y + n.h / 2, n.x - n.w / 2, n.y + n.h / 2 - r);
        ctx.lineTo(n.x - n.w / 2, n.y - n.h / 2 + r);
        ctx.quadraticCurveTo(n.x - n.w / 2, n.y - n.h / 2, n.x - n.w / 2 + r, n.y - n.h / 2);
        ctx.fill(); ctx.stroke();
        ctx.fillStyle = v ? '#f9d176' : '#cfd6da';
        ctx.font = 'bold 12px Geist Mono, monospace';
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(def.label, n.x, n.y);
      }

      // pins
      const drawPin = (p, on, isInput) => {
        ctx.beginPath();
        ctx.arc(p.x, p.y, 4, 0, Math.PI * 2);
        ctx.fillStyle = on ? '#f2c14e' : '#2a2a35';
        ctx.fill();
        ctx.strokeStyle = '#946322'; ctx.lineWidth = 1; ctx.stroke();
      };
      if (def.nout > 0) {
        const p = pinPos(n, true, 0);
        drawPin(p, vals[n.id] | 0, false);
      }
      for (let i = 0; i < def.nin; i++) {
        const p = pinPos(n, false, i);
        const w = state.wires.find(w => w.to.node === n.id && w.to.port === i);
        const driver = w ? vals[w.from.node] : 0;
        drawPin(p, driver, true);
      }
    }
    updateSidePanel(vals);
  }

  function updateSidePanel(vals) {
    document.getElementById('m-gates').textContent = state.nodes.filter(n => !['IN','OUT','CLK'].includes(n.type)).length;
    document.getElementById('m-in').textContent = state.nodes.filter(n => n.type === 'IN' || n.type === 'CLK').length;
    document.getElementById('m-out').textContent = state.nodes.filter(n => n.type === 'OUT').length;
    document.getElementById('m-wires').textContent = state.wires.length;
    document.getElementById('m-depth').textContent = depth();
    renderTruthTable();
  }

  function renderTruthTable() {
    const inputs = state.nodes.filter(n => n.type === 'IN' || n.type === 'CLK');
    const outputs = state.nodes.filter(n => n.type === 'OUT');
    const wrap = document.getElementById('tt-wrap');
    if (!inputs.length || !outputs.length) {
      wrap.innerHTML = '<div style="color:#6b7280;font-family:\'Geist Mono\',monospace;font-size:11px;padding:8px 4px;">Add inputs and outputs to see the truth table.</div>';
      return;
    }
    if (inputs.length > 6) {
      wrap.innerHTML = '<div style="color:#6b7280;font-family:\'Geist Mono\',monospace;font-size:11px;padding:8px 4px;">' + inputs.length + ' inputs &rarr; 2<sup>' + inputs.length + '</sup> rows. Reduce to 6 or fewer inputs to enumerate.</div>';
      return;
    }
    const rows = 1 << inputs.length;
    let html = '<table class="tt"><thead><tr>';
    for (const i of inputs) html += '<th>' + (i.type === 'CLK' ? 'CLK' : i.name) + '</th>';
    for (const o of outputs) html += '<th>' + o.name + '</th>';
    html += '</tr></thead><tbody>';
    for (let r = 0; r < rows; r++) {
      const overrides = {};
      for (let i = 0; i < inputs.length; i++) {
        overrides[inputs[i].id] = (r >> (inputs.length - 1 - i)) & 1;
      }
      const v = evaluate(overrides);
      html += '<tr>';
      for (const inp of inputs) {
        const val = overrides[inp.id];
        html += '<td class="' + (val ? 'one' : 'zero') + '">' + val + '</td>';
      }
      for (const o of outputs) {
        const val = v[o.id] | 0;
        html += '<td class="' + (val ? 'one' : 'zero') + '">' + val + '</td>';
      }
      html += '</tr>';
    }
    html += '</tbody></table>';
    wrap.innerHTML = html;
  }

  // ── Mouse handling ────────────────────────────────────────────────────────
  function localCoords(ev) {
    const r = cvs.getBoundingClientRect();
    return { x: ev.clientX - r.left, y: ev.clientY - r.top };
  }
  cvs.addEventListener('mousemove', (ev) => {
    state.mouse = localCoords(ev);
    if (state.drag) {
      const n = state.nodes.find(x => x.id === state.drag.id);
      if (n) {
        n.x = state.mouse.x - state.drag.dx;
        n.y = state.mouse.y - state.drag.dy;
        n.x = Math.max(n.w / 2 + 8, Math.min(W() - n.w / 2 - 8, n.x));
        n.y = Math.max(n.h / 2 + 8, Math.min(H() - n.h / 2 - 8, n.y));
      }
    }
    draw();
  });
  cvs.addEventListener('mousedown', (ev) => {
    if (ev.button === 2) return;
    const m = localCoords(ev);
    const pin = pinAt(m.x, m.y);
    if (pin) {
      if (!state.pendingPin) {
        state.pendingPin = pin;
      } else {
        // complete a wire if one end is out, other is in
        const a = state.pendingPin, b = pin;
        if (a.node !== b.node && a.isOut !== b.isOut) {
          const out = a.isOut ? a : b;
          const inp = a.isOut ? b : a;
          addWire(out.node, out.port, inp.node, inp.port);
        }
        state.pendingPin = null;
      }
      draw();
      return;
    }
    const n = nodeAt(m.x, m.y);
    if (n) {
      state.selected = n.id;
      if (n.type === 'IN') {
        // toggle on simple click without drag → set up drag detection
        state.drag = { id: n.id, dx: m.x - n.x, dy: m.y - n.y, didMove: false, isInput: true };
      } else {
        state.drag = { id: n.id, dx: m.x - n.x, dy: m.y - n.y, didMove: false };
      }
    } else {
      state.selected = null;
      state.pendingPin = null;
    }
    draw();
  });
  cvs.addEventListener('mouseup', (ev) => {
    if (state.drag) {
      const n = state.nodes.find(x => x.id === state.drag.id);
      if (n && state.drag.isInput && !state.drag.didMove) {
        n.value = n.value ? 0 : 1;
      }
      state.drag = null;
    }
    draw();
  });
  cvs.addEventListener('mousemove', () => { if (state.drag) state.drag.didMove = true; }, true);
  cvs.addEventListener('contextmenu', (ev) => {
    ev.preventDefault();
    const m = localCoords(ev);
    const n = nodeAt(m.x, m.y);
    if (n) removeNode(n.id);
    draw();
  });

  // ── Palette + toolbar ────────────────────────────────────────────────────
  document.querySelectorAll('[data-add]').forEach(btn => {
    btn.addEventListener('click', () => {
      const t = btn.getAttribute('data-add');
      // spawn at first free spot
      const x = 100 + (state.nodes.length % 8) * 90;
      const y = 80 + Math.floor(state.nodes.length / 8) * 70;
      addNode(t, x, y);
      draw();
    });
  });
  document.getElementById('clear').addEventListener('click', () => {
    state.nodes = []; state.wires = []; state.nextId = 1; draw();
  });
  document.getElementById('delete-sel').addEventListener('click', () => {
    if (state.selected) { removeNode(state.selected); state.selected = null; draw(); }
  });
  document.getElementById('step').addEventListener('click', () => {
    // pulse all CLK inputs
    for (const n of state.nodes) if (n.type === 'CLK') n.value = n.value ? 0 : 1;
    draw();
  });

  // ── Presets ──────────────────────────────────────────────────────────────
  document.getElementById('preset').addEventListener('change', (ev) => {
    const k = ev.target.value;
    if (!k) return;
    loadPreset(k);
    ev.target.value = '';
  });

  function loadPreset(k) {
    state.nodes = []; state.wires = []; state.nextId = 1; state.selected = null;
    if (k === 'half-adder') {
      const a = addNode('IN', 90, 160, { name: 'A' });
      const b = addNode('IN', 90, 240, { name: 'B' });
      const x = addNode('XOR', 280, 160);
      const an = addNode('AND', 280, 280);
      const s = addNode('OUT', 480, 160, { name: 'S' });
      const c = addNode('OUT', 480, 280, { name: 'Cout' });
      addWire(a, 0, x, 0); addWire(b, 0, x, 1);
      addWire(a, 0, an, 0); addWire(b, 0, an, 1);
      addWire(x, 0, s, 0); addWire(an, 0, c, 0);
    } else if (k === 'full-adder') {
      const a = addNode('IN', 70, 100, { name: 'A' });
      const b = addNode('IN', 70, 180, { name: 'B' });
      const ci = addNode('IN', 70, 260, { name: 'Ci' });
      const x1 = addNode('XOR', 230, 140);
      const x2 = addNode('XOR', 420, 200);
      const a1 = addNode('AND', 230, 280);
      const a2 = addNode('AND', 420, 360);
      const or = addNode('OR', 580, 320);
      const s = addNode('OUT', 760, 200, { name: 'S' });
      const co = addNode('OUT', 760, 320, { name: 'Co' });
      addWire(a, 0, x1, 0); addWire(b, 0, x1, 1);
      addWire(a, 0, a1, 0); addWire(b, 0, a1, 1);
      addWire(x1, 0, x2, 0); addWire(ci, 0, x2, 1);
      addWire(x1, 0, a2, 0); addWire(ci, 0, a2, 1);
      addWire(a2, 0, or, 0); addWire(a1, 0, or, 1);
      addWire(x2, 0, s, 0); addWire(or, 0, co, 0);
    } else if (k === 'sr-latch') {
      const s = addNode('IN', 90, 160, { name: 'S' });
      const r = addNode('IN', 90, 320, { name: 'R' });
      const n1 = addNode('NOR', 320, 200);
      const n2 = addNode('NOR', 320, 360);
      const q = addNode('OUT', 540, 200, { name: 'Q' });
      const qn = addNode('OUT', 540, 360, { name: 'Q̅' });
      addWire(s, 0, n1, 0); addWire(n2, 0, n1, 1);
      addWire(n1, 0, n2, 0); addWire(r, 0, n2, 1);
      addWire(n1, 0, q, 0); addWire(n2, 0, qn, 0);
    } else if (k === 'd-flipflop') {
      // Gated D latch (D + CLK → Q)
      const d = addNode('IN', 70, 160, { name: 'D' });
      const c = addNode('IN', 70, 280, { name: 'C' });
      const notd = addNode('NOT', 220, 120);
      const a1 = addNode('NAND', 380, 160);
      const a2 = addNode('NAND', 380, 320);
      const n1 = addNode('NAND', 580, 220);
      const n2 = addNode('NAND', 580, 360);
      const q = addNode('OUT', 780, 220, { name: 'Q' });
      const qn = addNode('OUT', 780, 360, { name: 'Q̅' });
      addWire(d, 0, notd, 0);
      addWire(notd, 0, a1, 0); addWire(c, 0, a1, 1);
      addWire(d, 0, a2, 0); addWire(c, 0, a2, 1);
      addWire(a1, 0, n1, 0); addWire(n2, 0, n1, 1);
      addWire(n1, 0, n2, 0); addWire(a2, 0, n2, 1);
      addWire(n1, 0, q, 0); addWire(n2, 0, qn, 0);
    } else if (k === 'comparator') {
      const a1 = addNode('IN', 60, 90, { name: 'A1' });
      const a0 = addNode('IN', 60, 170, { name: 'A0' });
      const b1 = addNode('IN', 60, 250, { name: 'B1' });
      const b0 = addNode('IN', 60, 330, { name: 'B0' });
      const x1 = addNode('XNOR', 240, 130);
      const x0 = addNode('XNOR', 240, 290);
      const an = addNode('AND', 420, 210);
      const eq = addNode('OUT', 600, 210, { name: 'A=B' });
      addWire(a1, 0, x1, 0); addWire(b1, 0, x1, 1);
      addWire(a0, 0, x0, 0); addWire(b0, 0, x0, 1);
      addWire(x1, 0, an, 0); addWire(x0, 0, an, 1);
      addWire(an, 0, eq, 0);
    } else if (k === 'mux41') {
      // 4:1 multiplexer with inputs I0..I3 and select bits S1,S0
      const i0 = addNode('IN', 60, 70, { name: 'I0' });
      const i1 = addNode('IN', 60, 140, { name: 'I1' });
      const i2 = addNode('IN', 60, 210, { name: 'I2' });
      const i3 = addNode('IN', 60, 280, { name: 'I3' });
      const s1 = addNode('IN', 60, 360, { name: 'S1' });
      const s0 = addNode('IN', 60, 430, { name: 'S0' });
      const ns1 = addNode('NOT', 200, 360);
      const ns0 = addNode('NOT', 200, 430);
      // sel0 = !s1 & !s0, sel1 = !s1 & s0, sel2 = s1 & !s0, sel3 = s1 & s0
      const g0a = addNode('AND', 360, 70); // !s1 & !s0
      const g0  = addNode('AND', 520, 70); // & i0
      const g1a = addNode('AND', 360, 140);
      const g1  = addNode('AND', 520, 140);
      const g2a = addNode('AND', 360, 210);
      const g2  = addNode('AND', 520, 210);
      const g3a = addNode('AND', 360, 280);
      const g3  = addNode('AND', 520, 280);
      const or1 = addNode('OR', 660, 105);
      const or2 = addNode('OR', 660, 245);
      const orf = addNode('OR', 780, 175);
      const y   = addNode('OUT', 880, 175, { name: 'Y' });
      addWire(s1, 0, ns1, 0); addWire(s0, 0, ns0, 0);
      addWire(ns1, 0, g0a, 0); addWire(ns0, 0, g0a, 1);
      addWire(ns1, 0, g1a, 0); addWire(s0, 0, g1a, 1);
      addWire(s1, 0, g2a, 0); addWire(ns0, 0, g2a, 1);
      addWire(s1, 0, g3a, 0); addWire(s0, 0, g3a, 1);
      addWire(g0a, 0, g0, 0); addWire(i0, 0, g0, 1);
      addWire(g1a, 0, g1, 0); addWire(i1, 0, g1, 1);
      addWire(g2a, 0, g2, 0); addWire(i2, 0, g2, 1);
      addWire(g3a, 0, g3, 0); addWire(i3, 0, g3, 1);
      addWire(g0, 0, or1, 0); addWire(g1, 0, or1, 1);
      addWire(g2, 0, or2, 0); addWire(g3, 0, or2, 1);
      addWire(or1, 0, orf, 0); addWire(or2, 0, orf, 1);
      addWire(orf, 0, y, 0);
    }
    draw();
  }

  // bootstrap with a half-adder so the page isn't blank
  loadPreset('half-adder');
  draw();
})();
</script>

<div id="demoHint" style="position:fixed;left:16px;bottom:16px;max-width:330px;background:#11131a;color:#e8e8ee;border:1px solid #FF4F00;border-radius:12px;padding:14px 16px;z-index:9999;box-shadow:0 12px 34px rgba(0,0,0,0.45);">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:7px;gap:10px;">
    <span style="font-family:'Geist Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#FF4F00;font-weight:700;">Try this &middot; demo</span>
    <button onclick="this.closest('#demoHint').remove()" style="background:transparent;border:none;color:#9aa6b6;cursor:pointer;font-size:18px;line-height:1;padding:0;">&times;</button>
  </div>
  <p style="margin:0;font-size:12.5px;line-height:1.55;color:#cfd6da;font-family:'Inter Tight',sans-serif,system-ui;">Load the <b>Full adder</b> preset. Toggle the input pins and watch the SUM and CARRY outputs flip — the truth table fills every combination automatically.</p>
</div>

