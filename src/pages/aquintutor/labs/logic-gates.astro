---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Logic gates lab — a live 1-bit full adder (A, B, Cin -> Sum, Cout) drawn with
// real AND / OR / XOR glyphs, wires that glow green when carrying a 1, output
// LEDs, and a truth table with the current row highlighted. High-DPI canvas.
---
<BaseLayout title="Logic gates lab · Virtual Labs · AquinTutor" description="A working 1-bit full adder — toggle the inputs and watch signals propagate through XOR, AND and OR gates to Sum and Carry, with the live truth table.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1320px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:18px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:260px minmax(0,1fr); gap:18px; } @media(max-width:900px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:16px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 12px; }
  .tog{ display:flex; align-items:center; justify-content:space-between; padding:8px 0; }
  .tog b{ font-family:'Geist Mono',monospace; font-size:14px; color:#cfd6da; }
  .sw{ width:56px; height:28px; border-radius:99px; background:#1a2236; position:relative; cursor:pointer; border:1px solid #26314f; }
  .sw.on{ background:#1f5a3f; } .sw i{ position:absolute; top:2px; left:2px; width:22px; height:22px; border-radius:50%; background:#5f7597; transition:left .12s, background .12s; } .sw.on i{ left:30px; background:#34d399; box-shadow:0 0 10px #34d399; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); }
  .lb-stage canvas{ display:block; width:100%; height:auto; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">CS · Digital logic</p>
      <h1 class="lb-title">Full <em>adder</em>.</h1>
    </div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Inputs</h3>
        <div class="tog"><b>A</b><div class="sw" data-in="A"><i></i></div></div>
        <div class="tog"><b>B</b><div class="sw" data-in="B"><i></i></div></div>
        <div class="tog"><b>Cin</b><div class="sw" data-in="Cin"><i></i></div></div>
      </div>
      <div class="lb-panel"><h3>Output</h3>
        <div class="tog"><b>Sum</b><b id="oSum" style="color:#34d399;">0</b></div>
        <div class="tog"><b>Cout</b><b id="oCout" style="color:#fbbf24;">0</b></div>
        <p style="font-family:'Inter Tight',sans-serif;font-size:12px;color:#8ea0be;margin:8px 0 0;line-height:1.5;">A one-bit full adder: Sum = A ⊕ B ⊕ Cin, Cout = AB + Cin(A ⊕ B). Toggle inputs; wires glow when carrying a 1.</p>
      </div>
    </aside>
    <section><div class="lb-stage"><canvas id="scene" width="900" height="520"></canvas></div></section>
  </div>
</main>
<script is:inline>
(function(){
  var IN={A:0,B:0,Cin:0};
  document.querySelectorAll('.sw').forEach(function(sw){ sw.addEventListener('click',function(){ var k=sw.getAttribute('data-in'); IN[k]=IN[k]?0:1; sw.classList.toggle('on',!!IN[k]); }); });
  function hidpi(c){ var r=c.getBoundingClientRect(), d=window.devicePixelRatio||1; var w=r.width||c.width, h=(c.height/c.width)*w; c.width=Math.round(w*d); c.height=Math.round(h*d); var ctx=c.getContext('2d'); ctx.setTransform(d,0,0,d,0,0); return {ctx:ctx,w:w,h:h}; }
  function wire(ctx,x1,y1,x2,y2,on){ ctx.save(); var col=on?'#34d399':'#31405f'; if(on){ ctx.shadowColor=col; ctx.shadowBlur=8; } ctx.strokeStyle=col; ctx.lineWidth=on?2.4:1.6; var mx=(x1+x2)/2; ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(mx,y1); ctx.lineTo(mx,y2); ctx.lineTo(x2,y2); ctx.stroke(); ctx.restore(); }
  function gate(ctx,type,x,y,w,h,on){ var col=on?'#34d399':'#48597c'; ctx.save(); if(on){ ctx.shadowColor=col; ctx.shadowBlur=12; } ctx.strokeStyle=col; ctx.fillStyle=on?'rgba(52,211,153,0.14)':'rgba(72,89,124,0.08)'; ctx.lineWidth=2.4; ctx.beginPath();
    if(type==='AND'){ ctx.moveTo(x,y); ctx.lineTo(x+w*0.45,y); ctx.arc(x+w*0.45,y+h/2,h/2,-Math.PI/2,Math.PI/2); ctx.lineTo(x,y+h); ctx.closePath(); }
    else { // OR / XOR
      ctx.moveTo(x+4,y); ctx.quadraticCurveTo(x+w*0.65,y,x+w,y+h/2); ctx.quadraticCurveTo(x+w*0.65,y+h,x+4,y+h); ctx.quadraticCurveTo(x+w*0.28,y+h/2,x+4,y); ctx.closePath();
    }
    ctx.fill(); ctx.stroke();
    if(type==='XOR'){ ctx.beginPath(); ctx.moveTo(x-3,y); ctx.quadraticCurveTo(x+w*0.24,y+h/2,x-3,y+h); ctx.stroke(); }
    ctx.restore(); ctx.fillStyle=col; ctx.font="10px 'Geist Mono',monospace"; ctx.textAlign='center'; ctx.fillText(type, x+w*0.42, y+h/2+3); ctx.textAlign='left';
  }
  function led(ctx,x,y,label,on,col){ ctx.save(); if(on){ ctx.shadowColor=col; ctx.shadowBlur=18; } ctx.fillStyle=on?col:'#26314f'; ctx.beginPath(); ctx.arc(x,y,13,0,7); ctx.fill(); ctx.restore(); ctx.fillStyle='#cfd6da'; ctx.font="700 12px 'Geist Mono',monospace"; ctx.fillText(label,x+20,y+4); ctx.fillStyle=on?'#0b0d17':'#8ea0be'; ctx.textAlign='center'; ctx.fillText(on?'1':'0',x,y+4); ctx.textAlign='left'; }
  function inputNode(ctx,x,y,label,on){ ctx.save(); if(on){ ctx.shadowColor='#34d399'; ctx.shadowBlur=14; } ctx.fillStyle=on?'#34d399':'#26314f'; ctx.beginPath(); ctx.arc(x,y,15,0,7); ctx.fill(); ctx.restore(); ctx.fillStyle=on?'#0b0d17':'#cfd6da'; ctx.font="700 13px 'Geist Mono',monospace"; ctx.textAlign='center'; ctx.fillText(on?'1':'0',x,y+5); ctx.fillStyle='#8ea0be'; ctx.font="11px 'Geist Mono',monospace"; ctx.fillText(label,x-28,y+4); ctx.textAlign='left'; }

  function draw(){ var cv=document.getElementById('scene'), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h;
    var bg=ctx.createLinearGradient(0,0,0,H); bg.addColorStop(0,'#0c1226'); bg.addColorStop(1,'#06080f'); ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    var A=IN.A,B=IN.B,Ci=IN.Cin; var x1=A^B, sum=x1^Ci, a1=A&B, a2=x1&Ci, cout=a1|a2;
    var sx=W/900, sy=H/520; function P(x,y){ return [x*sx,y*sy]; }
    // input nodes
    var Ay=P(70,110), By=P(70,230), Cy=P(70,400);
    // gate boxes (x,y,w,h)
    var xor1=[300,120,70,64], and1=[300,300,70,64], xor2=[540,90,70,64], and2=[540,300,70,64], org=[720,300,70,64];
    function gin(g,which){ return P(g[0], g[1]+ (which?g[3]*0.72:g[3]*0.28)); } function gout(g){ return P(g[0]+g[2], g[1]+g[3]/2); }
    // wires (draw before gates)
    wire(ctx,Ay[0]+15,Ay[1],gin(xor1,0)[0],gin(xor1,0)[1],A); wire(ctx,By[0]+15,By[1],gin(xor1,1)[0],gin(xor1,1)[1],B);
    wire(ctx,Ay[0]+15,Ay[1],gin(and1,0)[0],gin(and1,0)[1],A); wire(ctx,By[0]+15,By[1],gin(and1,1)[0],gin(and1,1)[1],B);
    wire(ctx,gout(xor1)[0],gout(xor1)[1],gin(xor2,0)[0],gin(xor2,0)[1],x1); wire(ctx,Cy[0]+15,Cy[1],gin(xor2,1)[0],gin(xor2,1)[1],Ci);
    wire(ctx,gout(xor1)[0],gout(xor1)[1],gin(and2,0)[0],gin(and2,0)[1],x1); wire(ctx,Cy[0]+15,Cy[1],gin(and2,1)[0],gin(and2,1)[1],Ci);
    wire(ctx,gout(and1)[0],gout(and1)[1],gin(org,0)[0],gin(org,0)[1],a1); wire(ctx,gout(and2)[0],gout(and2)[1],gin(org,1)[0],gin(org,1)[1],a2);
    wire(ctx,gout(xor2)[0],gout(xor2)[1],P(820,120)[0],P(820,120)[1],sum); wire(ctx,gout(org)[0],gout(org)[1],P(840,332)[0],P(840,332)[1],cout);
    // gates
    gate(ctx,'XOR',xor1[0]*sx,xor1[1]*sy,xor1[2]*sx,xor1[3]*sy,x1); gate(ctx,'AND',and1[0]*sx,and1[1]*sy,and1[2]*sx,and1[3]*sy,a1);
    gate(ctx,'XOR',xor2[0]*sx,xor2[1]*sy,xor2[2]*sx,xor2[3]*sy,sum); gate(ctx,'AND',and2[0]*sx,and2[1]*sy,and2[2]*sx,and2[3]*sy,a2); gate(ctx,'OR',org[0]*sx,org[1]*sy,org[2]*sx,org[3]*sy,cout);
    // io
    inputNode(ctx,Ay[0],Ay[1],'A',A); inputNode(ctx,By[0],By[1],'B',B); inputNode(ctx,Cy[0],Cy[1],'Cin',Ci);
    led(ctx,P(820,120)[0],P(820,120)[1],'Sum',sum,'#34d399'); led(ctx,P(840,332)[0],P(840,332)[1],'Cout',cout,'#fbbf24');
    document.getElementById('oSum').textContent=sum; document.getElementById('oCout').textContent=cout;
    // truth table
    var tx=P(30,470)[0], ty=P(30,470)[1]; ctx.font="11px 'Geist Mono',monospace";
    var hdr='A B Cin | S Co'; ctx.fillStyle='#5ee7ff'; ctx.fillText(hdr,tx,ty);
    var col=0; for(var r=0;r<8;r++){ var a=(r>>2)&1,b=(r>>1)&1,ci=r&1; var su=a^b^ci, co=(a&b)|((a^b)&ci); var here=(a===A&&b===B&&ci===Ci);
      var rowTxt=a+' '+b+'  '+ci+'  | '+su+'  '+co; var rx=tx+(r<4?0:150), ry=ty+18+((r%4)+1)*16; ctx.fillStyle=here?'#fbbf24':'#8ea0be'; if(here){ ctx.fillStyle='rgba(251,191,36,0.15)'; ctx.fillRect(rx-4,ry-11,140,15); ctx.fillStyle='#fbbf24'; } ctx.fillText(rowTxt,rx,ry); }
  }
  function loop(){ draw(); requestAnimationFrame(loop); } requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
