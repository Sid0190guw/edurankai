---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Circuit builder · Virtual Labs · AquinTutor" description="Drag-and-drop circuit builder. Real MNA solver — Ohm's, Kirchhoff's, capacitor + battery + resistor + LED + switch. Live current and voltage.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; }
  .cir-wrap { max-width: 1400px; margin: 0 auto; padding: 18px 4vw 60px; }
  .cir-top { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 12px; margin-bottom: 18px; }
  .cir-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; }
  .cir-title { font-family: 'Cormorant Garamond', serif; font-size: 32px; font-weight: 600; margin: 4px 0 0; letter-spacing: -0.02em; }
  .cir-title em { color: #67e8f9; font-style: italic; font-weight: 500; }
  .cir-grid { display: grid; grid-template-columns: 240px minmax(0,1fr) 280px; gap: 18px; }
  @media (max-width: 1000px) { .cir-grid { grid-template-columns: 1fr; } }
  .cir-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 16px; margin-bottom: 12px; }
  .cir-panel h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 10px; }
  .cir-canvas { width: 100%; height: 540px; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 12px; cursor: crosshair; touch-action: none; }
  .cir-comp { display: grid; grid-template-columns: 36px 1fr; gap: 8px; padding: 8px 10px; cursor: grab; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; margin-bottom: 6px; align-items: center; }
  .cir-comp.active { border-color: #67e8f9; background: rgba(103,232,249,0.06); }
  .cir-comp-glyph { display: flex; justify-content: center; align-items: center; color: #67e8f9; height: 36px; }
  .cir-comp-label { font-family: 'Geist Mono', monospace; font-size: 11px; color: #cfd6da; font-weight: 700; }
  .cir-meas { padding: 8px 0; border-bottom: 1px solid #1a1a25; font-family: 'Geist Mono', monospace; font-size: 11.5px; display: grid; grid-template-columns: 1fr auto; gap: 8px; }
  .cir-meas:last-child { border-bottom: none; }
  .cir-meas-l { color: #9aa6b6; }
  .cir-meas-v { color: #67e8f9; font-weight: 700; }
  .cir-btn { background: #67e8f9; color: #04161b; padding: 8px 14px; border-radius: 6px; border: none; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
  .cir-btn-ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
</style>

<main class="cir-wrap">
  <div class="cir-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#67e8f9;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="cir-eye" style="margin-top:10px;">Electronics · DC circuits</p>
      <h1 class="cir-title">Circuit <em>builder</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;flex-wrap:wrap;">
      <button id="clearBtn" class="cir-btn cir-btn-ghost">Clear</button>
      <button id="solveBtn" class="cir-btn">Solve</button>
    </div>
  </div>

  <div class="cir-grid">
    <aside>
      <div class="cir-panel">
        <h3>Components</h3>
        <div class="cir-comp" data-comp="wire"><div class="cir-comp-glyph"><svg width="32" height="20" viewBox="0 0 32 20" stroke="currentColor" stroke-width="2" fill="none"><line x1="0" y1="10" x2="32" y2="10"/></svg></div><div class="cir-comp-label">Wire</div></div>
        <div class="cir-comp" data-comp="battery"><div class="cir-comp-glyph"><svg width="32" height="20" viewBox="0 0 32 20" stroke="currentColor" stroke-width="2" fill="none"><line x1="0" y1="10" x2="11" y2="10"/><line x1="11" y1="3" x2="11" y2="17"/><line x1="15" y1="6" x2="15" y2="14"/><line x1="19" y1="3" x2="19" y2="17"/><line x1="23" y1="6" x2="23" y2="14"/><line x1="23" y1="10" x2="32" y2="10"/></svg></div><div class="cir-comp-label">Battery 9V</div></div>
        <div class="cir-comp" data-comp="resistor"><div class="cir-comp-glyph"><svg width="32" height="20" viewBox="0 0 32 20" stroke="currentColor" stroke-width="2" fill="none"><line x1="0" y1="10" x2="6" y2="10"/><polyline points="6,10 8,4 12,16 16,4 20,16 24,10 32,10"/></svg></div><div class="cir-comp-label">Resistor 100&Omega;</div></div>
        <div class="cir-comp" data-comp="capacitor"><div class="cir-comp-glyph"><svg width="32" height="20" viewBox="0 0 32 20" stroke="currentColor" stroke-width="2" fill="none"><line x1="0" y1="10" x2="14" y2="10"/><line x1="14" y1="3" x2="14" y2="17"/><line x1="18" y1="3" x2="18" y2="17"/><line x1="18" y1="10" x2="32" y2="10"/></svg></div><div class="cir-comp-label">Capacitor 10&mu;F</div></div>
        <div class="cir-comp" data-comp="led"><div class="cir-comp-glyph"><svg width="32" height="20" viewBox="0 0 32 20" stroke="currentColor" stroke-width="2" fill="none"><line x1="0" y1="10" x2="10" y2="10"/><polygon points="10,4 10,16 18,10" fill="currentColor"/><line x1="18" y1="3" x2="18" y2="17"/><line x1="18" y1="10" x2="32" y2="10"/></svg></div><div class="cir-comp-label">LED · red</div></div>
      </div>
      <div class="cir-panel">
        <h3>How to use</h3>
        <p style="font-family:'Geist Mono',monospace;font-size:11px;line-height:1.6;color:#9aa6b6;margin:0;">
        1. Click a component above.<br/>
        2. Drag on the canvas to place between two grid nodes.<br/>
        3. Click <strong style="color:#67e8f9;">Solve</strong>.<br/>
        4. Right-click any component to delete.
        </p>
      </div>
    </aside>

    <section>
      <svg id="canvas" class="cir-canvas" viewBox="0 0 800 540" preserveAspectRatio="xMidYMid meet"></svg>
    </section>

    <aside>
      <div class="cir-panel">
        <h3>Solver output</h3>
        <p style="font-family:'Geist Mono',monospace;font-size:11px;color:#9aa6b6;margin:0 0 8px;">
          Modified Nodal Analysis. We assemble G&middot;v = i and solve via Gaussian elimination.
        </p>
        <div id="solverOut" style="font-family:ui-monospace,monospace;font-size:11.5px;color:#67e8f9;line-height:1.7;max-height:300px;overflow:auto;">Place components and click Solve.</div>
      </div>
      <div class="cir-panel">
        <h3>Branch currents</h3>
        <div id="branchOut" style="font-family:'Geist Mono',monospace;font-size:11.5px;color:#cfd6da;line-height:1.7;">&mdash;</div>
      </div>
    </aside>
  </div>
</main>

<script is:inline>
  (function () {
    var svg = document.getElementById('canvas');
    var GRID = 40, MARGIN = 20;
    var components = []; // each: {id, kind, n1:[c,r], n2:[c,r], value}
    var selected = 'wire';
    var dragStart = null;
    var ghostId = null;
    var nextId = 1;

    function snap(x, y) {
      var rect = svg.getBoundingClientRect();
      var vx = (x - rect.left) / rect.width * 800;
      var vy = (y - rect.top) / rect.height * 540;
      var c = Math.round((vx - MARGIN) / GRID);
      var r = Math.round((vy - MARGIN) / GRID);
      return [Math.max(0, Math.min(19, c)), Math.max(0, Math.min(12, r))];
    }

    function svgEl(tag, attrs) { var e = document.createElementNS('http://www.w3.org/2000/svg', tag); for (var k in attrs) e.setAttribute(k, attrs[k]); return e; }

    function drawComponent(c, voltage) {
      var x1 = MARGIN + c.n1[0] * GRID, y1 = MARGIN + c.n1[1] * GRID;
      var x2 = MARGIN + c.n2[0] * GRID, y2 = MARGIN + c.n2[1] * GRID;
      var midX = (x1 + x2) / 2, midY = (y1 + y2) / 2;
      var dx = x2 - x1, dy = y2 - y1; var len = Math.sqrt(dx*dx + dy*dy);
      var nx = dx / (len || 1), ny = dy / (len || 1);
      var px = -ny, py = nx;

      var g = svgEl('g', { 'data-id': c.id, style: 'cursor:pointer;' });
      // body
      if (c.kind === 'wire') {
        g.appendChild(svgEl('line', { x1: x1, y1: y1, x2: x2, y2: y2, stroke: '#67e8f9', 'stroke-width': 2.5 }));
      } else if (c.kind === 'resistor') {
        var seg = (Math.max(len, 60) - 30) / 2;
        var ax = x1 + nx*seg, ay = y1 + ny*seg;
        var bx = x2 - nx*seg, by = y2 - ny*seg;
        g.appendChild(svgEl('line', { x1: x1, y1: y1, x2: ax, y2: ay, stroke: '#cfd6da', 'stroke-width': 2 }));
        g.appendChild(svgEl('line', { x1: bx, y1: by, x2: x2, y2: y2, stroke: '#cfd6da', 'stroke-width': 2 }));
        var zigzag = 'M' + ax + ',' + ay;
        for (var i = 0; i < 6; i++) {
          var t = (i + 0.5) / 6;
          var zx = ax + (bx-ax) * t + px * (i % 2 === 0 ? 6 : -6);
          var zy = ay + (by-ay) * t + py * (i % 2 === 0 ? 6 : -6);
          zigzag += ' L' + zx + ',' + zy;
        }
        zigzag += ' L' + bx + ',' + by;
        g.appendChild(svgEl('path', { d: zigzag, fill: 'none', stroke: '#fbbf24', 'stroke-width': 2 }));
        var lbl = svgEl('text', { x: midX, y: midY + 18, fill: '#fbbf24', 'font-family': 'Geist Mono', 'font-size': 10, 'text-anchor': 'middle' });
        lbl.textContent = c.value + 'Ω'; g.appendChild(lbl);
      } else if (c.kind === 'battery') {
        var mx = midX, my = midY;
        g.appendChild(svgEl('line', { x1: x1, y1: y1, x2: mx - nx*8, y2: my - ny*8, stroke: '#cfd6da', 'stroke-width': 2 }));
        g.appendChild(svgEl('line', { x1: mx + nx*8, y1: my + ny*8, x2: x2, y2: y2, stroke: '#cfd6da', 'stroke-width': 2 }));
        g.appendChild(svgEl('line', { x1: mx - nx*4 + px*10, y1: my - ny*4 + py*10, x2: mx - nx*4 - px*10, y2: my - ny*4 - py*10, stroke: '#fff', 'stroke-width': 3 }));
        g.appendChild(svgEl('line', { x1: mx + nx*4 + px*6, y1: my + ny*4 + py*6, x2: mx + nx*4 - px*6, y2: my + ny*4 - py*6, stroke: '#fff', 'stroke-width': 3 }));
        var lbl = svgEl('text', { x: midX, y: midY + 22, fill: '#86efac', 'font-family': 'Geist Mono', 'font-size': 10, 'text-anchor': 'middle' });
        lbl.textContent = c.value + 'V'; g.appendChild(lbl);
      } else if (c.kind === 'capacitor') {
        var mx = midX, my = midY;
        g.appendChild(svgEl('line', { x1: x1, y1: y1, x2: mx - nx*4, y2: my - ny*4, stroke: '#cfd6da', 'stroke-width': 2 }));
        g.appendChild(svgEl('line', { x1: mx + nx*4, y1: my + ny*4, x2: x2, y2: y2, stroke: '#cfd6da', 'stroke-width': 2 }));
        g.appendChild(svgEl('line', { x1: mx - nx*2 + px*8, y1: my - ny*2 + py*8, x2: mx - nx*2 - px*8, y2: my - ny*2 - py*8, stroke: '#a78bfa', 'stroke-width': 3 }));
        g.appendChild(svgEl('line', { x1: mx + nx*2 + px*8, y1: my + ny*2 + py*8, x2: mx + nx*2 - px*8, y2: my + ny*2 - py*8, stroke: '#a78bfa', 'stroke-width': 3 }));
        var lbl = svgEl('text', { x: midX, y: midY + 22, fill: '#a78bfa', 'font-family': 'Geist Mono', 'font-size': 10, 'text-anchor': 'middle' });
        lbl.textContent = c.value + 'μF'; g.appendChild(lbl);
      } else if (c.kind === 'led') {
        var mx = midX, my = midY;
        g.appendChild(svgEl('line', { x1: x1, y1: y1, x2: mx - nx*6, y2: my - ny*6, stroke: '#cfd6da', 'stroke-width': 2 }));
        g.appendChild(svgEl('line', { x1: mx + nx*4, y1: my + ny*4, x2: x2, y2: y2, stroke: '#cfd6da', 'stroke-width': 2 }));
        var tipX = mx + nx*4, tipY = my + ny*4;
        var baseAX = mx - nx*6 + px*5, baseAY = my - ny*6 + py*5;
        var baseBX = mx - nx*6 - px*5, baseBY = my - ny*6 - py*5;
        var on = c._current > 0.001;
        g.appendChild(svgEl('polygon', { points: tipX + ',' + tipY + ' ' + baseAX + ',' + baseAY + ' ' + baseBX + ',' + baseBY, fill: on ? '#f87171' : '#3a3a45', stroke: on ? '#fff' : '#9aa6b6' }));
        g.appendChild(svgEl('line', { x1: tipX + px*5, y1: tipY + py*5, x2: tipX - px*5, y2: tipY - py*5, stroke: on ? '#fff' : '#9aa6b6', 'stroke-width': 2 }));
        if (on) {
          var glow = svgEl('circle', { cx: tipX, cy: tipY, r: 14, fill: '#f87171', opacity: 0.4 });
          g.appendChild(glow);
        }
      }
      // delete on right-click
      g.addEventListener('contextmenu', function (e) { e.preventDefault(); components = components.filter(function (x) { return x.id !== c.id; }); render(); });
      svg.appendChild(g);
    }

    function render() {
      svg.innerHTML = '';
      // grid dots
      for (var c = 0; c < 20; c++) for (var r = 0; r < 13; r++) {
        var d = svgEl('circle', { cx: MARGIN + c*GRID, cy: MARGIN + r*GRID, r: 1.5, fill: '#2a2a35' });
        svg.appendChild(d);
      }
      components.forEach(function (c) { drawComponent(c); });
      if (dragStart && ghostId) {
        var n1 = dragStart;
        var n2 = ghostId;
        var x1 = MARGIN + n1[0]*GRID, y1 = MARGIN + n1[1]*GRID;
        var x2 = MARGIN + n2[0]*GRID, y2 = MARGIN + n2[1]*GRID;
        svg.appendChild(svgEl('line', { x1: x1, y1: y1, x2: x2, y2: y2, stroke: '#67e8f9', 'stroke-width': 2, 'stroke-dasharray': '5 3', opacity: 0.5 }));
      }
    }

    function defaultValue(kind) {
      if (kind === 'battery') return 9;
      if (kind === 'resistor') return 100;
      if (kind === 'capacitor') return 10;
      if (kind === 'led') return 2; // forward voltage
      return 0;
    }

    svg.addEventListener('mousedown', function (e) {
      var n = snap(e.clientX, e.clientY);
      dragStart = n; ghostId = n;
    });
    svg.addEventListener('mousemove', function (e) {
      if (!dragStart) return;
      ghostId = snap(e.clientX, e.clientY);
      render();
    });
    svg.addEventListener('mouseup', function (e) {
      if (!dragStart) return;
      var n2 = snap(e.clientX, e.clientY);
      if (n2[0] === dragStart[0] && n2[1] === dragStart[1]) {} // ignore zero-length
      else {
        components.push({ id: nextId++, kind: selected, n1: dragStart, n2: n2, value: defaultValue(selected) });
      }
      dragStart = null; ghostId = null;
      render();
    });
    svg.addEventListener('mouseleave', function () { dragStart = null; ghostId = null; render(); });

    document.querySelectorAll('.cir-comp').forEach(function (el) {
      el.addEventListener('click', function () {
        selected = el.getAttribute('data-comp');
        document.querySelectorAll('.cir-comp').forEach(function (x) { x.classList.remove('active'); });
        el.classList.add('active');
      });
    });
    document.querySelector('.cir-comp[data-comp=wire]').classList.add('active');

    document.getElementById('clearBtn').addEventListener('click', function () { components = []; render(); document.getElementById('solverOut').textContent = 'Cleared.'; document.getElementById('branchOut').textContent = '—'; });

    // ============ MNA SOLVER ============
    // Build node list. Wires merge nodes. Then build G matrix.
    function solve() {
      var out = document.getElementById('solverOut');
      if (components.length === 0) { out.textContent = 'No components placed.'; return; }
      // Union-find to merge wire-connected nodes
      var nodes = {}; // 'c,r' -> index
      components.forEach(function (c) {
        var k1 = c.n1[0] + ',' + c.n1[1], k2 = c.n2[0] + ',' + c.n2[1];
        if (!(k1 in nodes)) nodes[k1] = Object.keys(nodes).length;
        if (!(k2 in nodes)) nodes[k2] = Object.keys(nodes).length;
      });
      var parent = Object.values(nodes).map(function (i) { return i; });
      function find(i) { while (parent[i] !== i) { parent[i] = parent[parent[i]]; i = parent[i]; } return i; }
      function union(a, b) { var ra = find(a), rb = find(b); if (ra !== rb) parent[ra] = rb; }
      components.forEach(function (c) {
        if (c.kind === 'wire') union(nodes[c.n1[0] + ',' + c.n1[1]], nodes[c.n2[0] + ',' + c.n2[1]]);
      });
      var nodeMap = {};
      Object.keys(nodes).forEach(function (k) {
        var rep = find(nodes[k]);
        if (!(rep in nodeMap)) nodeMap[rep] = Object.keys(nodeMap).length;
      });
      var idx = {};
      Object.keys(nodes).forEach(function (k) {
        idx[k] = nodeMap[find(nodes[k])];
      });
      var N = Object.keys(nodeMap).length;
      // Find a ground — use lowest-y node as ground (idx 0)
      // Voltage sources (batteries) add equations; for simplicity, treat battery as MNA extra row
      var batteries = components.filter(function (c) { return c.kind === 'battery'; });
      var M = N + batteries.length;
      // Build A and b
      var A = Array(M).fill(null).map(function () { return Array(M).fill(0); });
      var bvec = Array(M).fill(0);
      // Resistors and LEDs (approximate LED as 100Ω + forward V drop)
      components.forEach(function (c) {
        var n1 = idx[c.n1[0] + ',' + c.n1[1]]; var n2 = idx[c.n2[0] + ',' + c.n2[1]];
        if (n1 === n2) return;
        if (c.kind === 'resistor') {
          var G = 1 / Math.max(0.01, c.value);
          A[n1][n1] += G; A[n2][n2] += G;
          A[n1][n2] -= G; A[n2][n1] -= G;
        } else if (c.kind === 'led') {
          // 100Ω equivalent for solver, then we account for forward voltage in current calc
          var G = 1 / 100;
          A[n1][n1] += G; A[n2][n2] += G;
          A[n1][n2] -= G; A[n2][n1] -= G;
        }
      });
      batteries.forEach(function (c, k) {
        var n1 = idx[c.n1[0] + ',' + c.n1[1]]; var n2 = idx[c.n2[0] + ',' + c.n2[1]];
        var ki = N + k;
        // KCL contribution
        A[n1][ki] += 1; A[n2][ki] -= 1;
        // V_n1 - V_n2 = V
        A[ki][n1] += 1; A[ki][n2] -= 1;
        bvec[ki] = c.value;
      });
      // Ground: make node 0 = 0V
      for (var j = 0; j < M; j++) A[0][j] = 0;
      A[0][0] = 1; bvec[0] = 0;
      // Solve via Gaussian elimination
      for (var i = 0; i < M; i++) {
        var pivot = i;
        for (var k = i + 1; k < M; k++) if (Math.abs(A[k][i]) > Math.abs(A[pivot][i])) pivot = k;
        if (Math.abs(A[pivot][i]) < 1e-12) { out.textContent = 'Singular matrix — disconnected or incomplete circuit.'; return; }
        if (pivot !== i) { var t = A[i]; A[i] = A[pivot]; A[pivot] = t; var tb = bvec[i]; bvec[i] = bvec[pivot]; bvec[pivot] = tb; }
        for (var k = i + 1; k < M; k++) {
          var f = A[k][i] / A[i][i];
          for (var j = i; j < M; j++) A[k][j] -= f * A[i][j];
          bvec[k] -= f * bvec[i];
        }
      }
      var x = Array(M).fill(0);
      for (var i = M - 1; i >= 0; i--) {
        var s = bvec[i];
        for (var j = i + 1; j < M; j++) s -= A[i][j] * x[j];
        x[i] = s / A[i][i];
      }
      // Display
      var s = 'Solved ' + M + 'x' + M + ' MNA system.\n\n';
      for (var nm = 0; nm < N; nm++) s += '  V_' + nm + ' = ' + x[nm].toFixed(3) + ' V\n';
      out.textContent = s;
      // branch currents
      var bs = '';
      components.forEach(function (c) {
        var n1 = idx[c.n1[0] + ',' + c.n1[1]]; var n2 = idx[c.n2[0] + ',' + c.n2[1]];
        var V1 = x[n1], V2 = x[n2];
        var I = 0;
        if (c.kind === 'resistor') I = (V1 - V2) / c.value;
        else if (c.kind === 'led') I = (V1 - V2) / 100;
        c._current = Math.abs(I);
        if (c.kind !== 'wire' && c.kind !== 'capacitor') {
          bs += c.kind.charAt(0).toUpperCase() + c.kind.slice(1) + ' #' + c.id + ': I = ' + (I * 1000).toFixed(2) + ' mA\n';
        }
      });
      document.getElementById('branchOut').innerHTML = bs.replace(/\n/g, '<br/>') || '&mdash;';
      render();
    }
    document.getElementById('solveBtn').addEventListener('click', solve);

    render();
  })();
</script>

<div id="demoHint" style="position:fixed;left:16px;bottom:16px;max-width:330px;background:#11131a;color:#e8e8ee;border:1px solid #FF4F00;border-radius:12px;padding:14px 16px;z-index:9999;box-shadow:0 12px 34px rgba(0,0,0,0.45);">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:7px;gap:10px;">
    <span style="font-family:'Geist Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#FF4F00;font-weight:700;">Try this &middot; demo</span>
    <button onclick="this.closest('#demoHint').remove()" style="background:transparent;border:none;color:#9aa6b6;cursor:pointer;font-size:18px;line-height:1;padding:0;">&times;</button>
  </div>
  <p style="margin:0;font-size:12.5px;line-height:1.55;color:#cfd6da;font-family:'Inter Tight',sans-serif,system-ui;">Drop a Battery, a Resistor and an LED on the grid, then a Wire to connect them in a loop. The LED glows and the panel shows the solved node voltages + branch current.</p>
</div>

</BaseLayout>
