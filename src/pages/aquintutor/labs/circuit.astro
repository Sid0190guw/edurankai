---
import BaseLayout from '@/layouts/BaseLayout.astro';
// RC circuit lab — battery + resistor + capacitor, charge/discharge, with the
// exact exponential solution, animated charge flow whose speed tracks current,
// filling capacitor plates, and live V_c(t) / I(t) glow-line plots. High-DPI
// canvas, no libraries.
---
<BaseLayout title="Circuit lab · Virtual Labs · AquinTutor" description="An RC circuit you can watch charge and discharge — real exponential dynamics, animated current, and live voltage/current curves.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1320px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:18px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; }
  .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:290px minmax(0,1fr); gap:18px; }
  @media(max-width:900px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:16px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 12px; }
  .lb-row{ display:grid; gap:9px; }
  .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.1em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; }
  .lb-row label span{ color:#5ee7ff; } .lb-row input[type=range]{ width:100%; accent-color:#5ee7ff; }
  .lb-btn{ background:linear-gradient(180deg,#7af0ff,#33cfe6); color:#04161b; padding:9px 16px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:11px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; box-shadow:0 4px 14px rgba(51,207,230,0.35); }
  .lb-btn-ghost{ background:transparent; color:#cfd6da; border:1px solid #26314f; box-shadow:none; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); }
  .lb-stage canvas{ display:block; width:100%; height:auto; }
  .lb-plots{ display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-top:12px; } @media(max-width:680px){ .lb-plots{ grid-template-columns:1fr; } }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11.5px; padding:5px 0; border-bottom:1px solid #141a2c; }
  .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#5ee7ff; font-weight:700; text-align:right; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">Physics · Electricity</p>
      <h1 class="lb-title">RC <em>circuit</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;"><button id="modeBtn" class="lb-btn">Discharge</button><button id="resetBtn" class="lb-btn lb-btn-ghost">Reset</button></div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Components</h3><div class="lb-row">
        <label>Battery V (V) <span id="vV">9</span></label><input id="volt" type="range" min="1" max="24" step="0.5" value="9"/>
        <label>Resistance (kΩ) <span id="rV">2.0</span></label><input id="res" type="range" min="0.2" max="10" step="0.1" value="2"/>
        <label>Capacitance (µF) <span id="cV">100</span></label><input id="cap" type="range" min="10" max="1000" step="10" value="100"/>
      </div></div>
      <div class="lb-panel"><h3>State</h3>
        <div class="lb-metric"><span class="lb-metric-l">τ = RC (s)</span><span class="lb-metric-v" id="mTau">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">V_c (V)</span><span class="lb-metric-v" id="mVc">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">I (mA)</span><span class="lb-metric-v" id="mI">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Q (µC)</span><span class="lb-metric-v" id="mQ">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">t / τ</span><span class="lb-metric-v" id="mTt">—</span></div>
      </div>
    </aside>
    <section>
      <div class="lb-stage"><canvas id="scene" width="900" height="440"></canvas></div>
      <div class="lb-plots">
        <div class="lb-panel" style="margin:0;"><h3>Capacitor voltage V_c(t)</h3><canvas id="pv" width="560" height="180" style="width:100%;height:auto;"></canvas></div>
        <div class="lb-panel" style="margin:0;"><h3>Current I(t)</h3><canvas id="pi" width="560" height="180" style="width:100%;height:auto;"></canvas></div>
      </div>
    </section>
  </div>
</main>
<script is:inline>
(function(){
  function v(id){ return parseFloat(document.getElementById(id).value); }
  var st={ Vc:0, t:0, charging:true, flow:0, hVc:[], hI:[] };
  function sync(){ document.getElementById('vV').textContent=v('volt').toFixed(1); document.getElementById('rV').textContent=v('res').toFixed(1); document.getElementById('cV').textContent=v('cap').toFixed(0); }
  document.querySelectorAll('input').forEach(function(e){ e.addEventListener('input',sync); }); sync();
  document.getElementById('modeBtn').addEventListener('click',function(){ st.charging=!st.charging; this.textContent=st.charging?'Discharge':'Charge'; });
  document.getElementById('resetBtn').addEventListener('click',function(){ st.Vc=st.charging?0:v('volt'); st.t=0; st.hVc=[]; st.hI=[]; });
  st.Vc=0;
  function params(){ return { V:v('volt'), R:v('res')*1000, C:v('cap')*1e-6 }; }
  function hidpi(cv){ var r=cv.getBoundingClientRect(), d=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w; cv.width=Math.round(w*d); cv.height=Math.round(h*d); var ctx=cv.getContext('2d'); ctx.setTransform(d,0,0,d,0,0); return {ctx:ctx,w:w,h:h}; }
  function glow(ctx,pts,col){ ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=8; ctx.strokeStyle=col; ctx.lineWidth=1.8; ctx.beginPath(); pts.forEach(function(q,i){ i?ctx.lineTo(q[0],q[1]):ctx.moveTo(q[0],q[1]); }); ctx.stroke(); ctx.restore(); }

  function scene(I){
    var cv=document.getElementById('scene'), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h; var pr=params();
    var bg=ctx.createLinearGradient(0,0,0,H); bg.addColorStop(0,'#0c1226'); bg.addColorStop(1,'#06080f'); ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    var L=W*0.14, R=W*0.86, T=H*0.24, B=H*0.78;
    // wires
    ctx.strokeStyle='#2a3450'; ctx.lineWidth=6; ctx.lineJoin='round'; ctx.beginPath(); ctx.rect(L,T,R-L,B-T); ctx.stroke();
    // current glow on wire proportional to |I|
    var mag=Math.min(1,Math.abs(I)/(pr.V/pr.R+1e-9)); ctx.save(); ctx.shadowColor='#5ee7ff'; ctx.shadowBlur=10*mag+2; ctx.strokeStyle='rgba(94,231,255,'+(0.25+0.6*mag)+')'; ctx.lineWidth=3; ctx.beginPath(); ctx.rect(L,T,R-L,B-T); ctx.stroke(); ctx.restore();
    // battery (left)
    ctx.strokeStyle='#e8ecf4'; ctx.lineWidth=3; var my=(T+B)/2;
    ctx.beginPath(); ctx.moveTo(L,my-22); ctx.lineTo(L,my+22); ctx.stroke();
    ctx.lineWidth=6; ctx.beginPath(); ctx.moveTo(L-7,my-12); ctx.lineTo(L+7,my-12); ctx.stroke();
    ctx.lineWidth=2; ctx.beginPath(); ctx.moveTo(L-4,my+12); ctx.lineTo(L+4,my+12); ctx.stroke();
    ctx.fillStyle='#8ea0be'; ctx.font="11px 'Geist Mono',monospace"; ctx.fillText(pr.V.toFixed(1)+' V',L-40,my-30);
    // resistor (top, zigzag)
    var rx0=W*0.36, rx1=W*0.62, ry=T; ctx.strokeStyle='#fbbf24'; ctx.lineWidth=3; ctx.beginPath(); ctx.moveTo(rx0,ry);
    for(var i=0;i<=8;i++){ var x=rx0+(rx1-rx0)*i/8; ctx.lineTo(x, ry+(i%2?-9:9)); } ctx.lineTo(rx1,ry); ctx.stroke();
    ctx.fillStyle='#fbbf24'; ctx.fillText((pr.R/1000).toFixed(1)+' kΩ', (rx0+rx1)/2-22, ry-16);
    // capacitor (right, two plates that fill)
    var cx=R, gap=14, ph=54; var frac=st.Vc/Math.max(0.01,pr.V);
    ctx.strokeStyle='#a78bfa'; ctx.lineWidth=4;
    ctx.beginPath(); ctx.moveTo(cx,my-ph/2); ctx.lineTo(cx,my-6); ctx.stroke(); ctx.beginPath(); ctx.moveTo(cx,my+6); ctx.lineTo(cx,my+ph/2); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(cx-16,my-6); ctx.lineTo(cx+16,my-6); ctx.stroke(); ctx.beginPath(); ctx.moveTo(cx-16,my+6); ctx.lineTo(cx+16,my+6); ctx.stroke();
    ctx.save(); ctx.shadowColor='#a78bfa'; ctx.shadowBlur=18*frac; ctx.fillStyle='rgba(167,139,250,'+(0.25+0.6*frac)+')'; ctx.fillRect(cx-16,my-6-4,32,4); ctx.fillRect(cx-16,my+6,32,4); ctx.restore();
    ctx.fillStyle='#a78bfa'; ctx.fillText((pr.C*1e6).toFixed(0)+' µF', cx+22, my-4); ctx.fillStyle='#5ee7ff'; ctx.fillText(st.Vc.toFixed(2)+' V', cx+22, my+14);
    // moving charge dots (direction by sign of I)
    var n=26, dir=I>=0?1:-1; st.flow=(st.flow+dir*mag*0.02)%1; if(st.flow<0) st.flow+=1;
    var perim=[[L,T],[R,T],[R,B],[L,B]]; function seg(f){ var p=f*4, i=Math.floor(p)%4, tt=p-Math.floor(p); var a=perim[i], b=perim[(i+1)%4]; return [a[0]+(b[0]-a[0])*tt, a[1]+(b[1]-a[1])*tt]; }
    for(var k=0;k<n;k++){ var f=(k/n + st.flow)%1; var pt=seg(f); ctx.save(); ctx.shadowColor='#5ee7ff'; ctx.shadowBlur=8; ctx.fillStyle='#bff3ff'; ctx.beginPath(); ctx.arc(pt[0],pt[1],2.4,0,7); ctx.fill(); ctx.restore(); }
  }
  function plot(id,data,col,ymax,unit){ var cv=document.getElementById(id), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h;
    ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H); ctx.strokeStyle='rgba(94,231,255,0.06)'; for(var y=0;y<H;y+=22){ ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke(); }
    if(data.length<2) return; var n=data.length; function X(i){ return 8+i/(n-1)*(W-16); } function Y(val){ return H-8-(val/ymax)*(H-20); }
    glow(ctx, data.map(function(d,i){ return [X(i),Y(d)]; }), col);
    ctx.fillStyle=col; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText(data[data.length-1].toFixed(2)+' '+unit, W-70, 14);
  }
  function loop(){ var pr=params(); var dt=0.016;
    var target=st.charging?pr.V:0; var I=(target-st.Vc)/pr.R; st.Vc += I/pr.C*dt; st.t+=dt;
    var tau=pr.R*pr.C, Q=st.Vc*pr.C*1e6, ImA=I*1000;
    st.hVc.push(st.Vc); st.hI.push(ImA); if(st.hVc.length>240){ st.hVc.shift(); st.hI.shift(); }
    document.getElementById('mTau').textContent=tau.toFixed(3); document.getElementById('mVc').textContent=st.Vc.toFixed(2);
    document.getElementById('mI').textContent=ImA.toFixed(2); document.getElementById('mQ').textContent=Q.toFixed(1); document.getElementById('mTt').textContent=(st.t/tau).toFixed(2);
    scene(I); plot('pv',st.hVc,'#a78bfa',Math.max(1,pr.V),'V'); plot('pi',st.hI.map(Math.abs),'#fbbf24',Math.max(0.5,pr.V/pr.R*1000),'mA');
    if(st.t>tau*7){ st.t=0; st.charging=!st.charging; document.getElementById('modeBtn').textContent=st.charging?'Discharge':'Charge'; }
    requestAnimationFrame(loop); }
  requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
