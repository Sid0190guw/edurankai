---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Circuit builder · Virtual Labs · AquinTutor" description="Drag resistors, capacitors, batteries onto a grid. Real Kirchhoff-law solver. Live current and voltage.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; }
  .cb-wrap { max-width: 1300px; margin: 0 auto; padding: 20px 4vw 60px; }
  .cb-top { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 14px; margin-bottom: 20px; }
  .cb-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #fbbf24; font-weight: 700; }
  .cb-title { font-family: 'Cormorant Garamond', serif; font-size: 36px; font-weight: 600; margin: 4px 0 0; letter-spacing: -0.02em; }
  .cb-title em { color: #fbbf24; font-style: italic; font-weight: 500; }
  .cb-grid { display: grid; grid-template-columns: 240px minmax(0,1fr) 260px; gap: 16px; }
  @media (max-width: 1100px) { .cb-grid { grid-template-columns: 1fr; } }
  .cb-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 14px; }
  .cb-panel h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #fbbf24; font-weight: 700; margin: 0 0 10px; }
  .cb-tools { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
  .cb-tool { background: #1a1a25; border: 1px solid #2a2a35; color: #cfd6da; padding: 9px 6px; border-radius: 6px; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 10.5px; font-weight: 700; text-align: center; letter-spacing: 0.04em; text-transform: uppercase; }
  .cb-tool.active { background: #fbbf24; color: #04161b; border-color: #fbbf24; }
  .cb-canvas { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 12px; cursor: crosshair; width: 100%; height: 540px; }
  .cb-metric { display: grid; grid-template-columns: 1fr auto; padding: 5px 0; border-bottom: 1px solid #1a1a25; font-family: 'Geist Mono', monospace; font-size: 11.5px; }
  .cb-metric:last-child { border-bottom: none; }
  .cb-metric-l { color: #9aa6b6; }
  .cb-metric-v { color: #fbbf24; font-weight: 700; }
  .cb-btn { background: #fbbf24; color: #04161b; padding: 8px 14px; border-radius: 6px; border: none; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
  .cb-btn-ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
</style>

<main class="cb-wrap">
  <div class="cb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#fbbf24;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="cb-eye" style="margin-top:10px;">Electronics · DC circuits</p>
      <h1 class="cb-title">Circuit <em>builder</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;">
      <button id="clearBtn" class="cb-btn cb-btn-ghost">Clear</button>
      <button id="solveBtn" class="cb-btn">Solve</button>
    </div>
  </div>

  <div class="cb-grid">
    <aside>
      <div class="cb-panel">
        <h3>Tools</h3>
        <div class="cb-tools">
          <div class="cb-tool active" data-tool="wire">Wire</div>
          <div class="cb-tool" data-tool="battery">Battery</div>
          <div class="cb-tool" data-tool="resistor">Resistor</div>
          <div class="cb-tool" data-tool="capacitor">Cap</div>
          <div class="cb-tool" data-tool="led">LED</div>
          <div class="cb-tool" data-tool="delete">Delete</div>
        </div>
      </div>
      <div class="cb-panel" style="margin-top:12px;">
        <h3>Selected component</h3>
        <div id="selectedInfo" style="font-size:12px;color:#9aa6b6;line-height:1.6;">Click a component on the canvas to edit its value.</div>
        <div id="valueEditor" style="margin-top:10px;display:none;">
          <label style="font-family:'Geist Mono',monospace;font-size:10px;color:#9aa6b6;display:block;margin-bottom:4px;">Value</label>
          <input id="valueInput" type="number" step="0.01" style="width:100%;background:#0a0a0c;border:1px solid #2a2a35;color:#fff;padding:6px 10px;border-radius:5px;font-size:12px;"/>
          <button id="setBtn" class="cb-btn" style="margin-top:8px;width:100%;">Set</button>
        </div>
      </div>
    </aside>

    <section>
      <svg id="canvas" class="cb-canvas" viewBox="0 0 800 540" preserveAspectRatio="xMidYMid meet"></svg>
      <p style="font-family:'Geist Mono',monospace;font-size:10.5px;color:#9aa6b6;margin-top:8px;letter-spacing:0.06em;">Click two grid points to place a wire / component. Components snap to the 40-pixel grid. Click a placed component to edit.</p>
    </section>

    <aside>
      <div class="cb-panel">
        <h3>Solver output</h3>
        <div id="solverOut" style="font-size:11.5px;color:#9aa6b6;line-height:1.6;">Place at least 1 battery + 1 resistor + a closed loop, then click Solve.</div>
      </div>
      <div class="cb-panel" style="margin-top:12px;">
        <h3>Component branches</h3>
        <div id="branches" style="font-family:'Geist Mono',monospace;font-size:11px;color:#cfd6da;max-height:300px;overflow-y:auto;"></div>
      </div>
    </aside>
  </div>
</main>

<script is:inline>
  /* =========================================================
     Real DC circuit solver — modified nodal analysis.
     Components: wire, battery (V source), resistor, capacitor (open circuit at DC steady state), LED (assumed forward Vf=2V if current flows).
     Builds A * x = b where x is node voltages + voltage-source currents.
     Solves with Gaussian elimination. Pure JS.
     ========================================================= */
  (function () {
    var GRID = 40;
    var W = 800, H = 540;
    var COLS = W / GRID, ROWS = H / GRID;
    var tool = 'wire';
    var components = []; // { type, x1,y1,x2,y2, value, current, vDrop }
    var firstPt = null;
    var canvas = document.getElementById('canvas');
    var selected = null;

    function svgEl(tag, attrs) { var e = document.createElementNS('http://www.w3.org/2000/svg', tag); for (var k in attrs) e.setAttribute(k, attrs[k]); return e; }

    function drawGrid() {
      for (var i = 0; i <= COLS; i++) canvas.appendChild(svgEl('line', { x1: i*GRID, y1: 0, x2: i*GRID, y2: H, stroke: '#1a1a25', 'stroke-width': 0.5 }));
      for (var j = 0; j <= ROWS; j++) canvas.appendChild(svgEl('line', { x1: 0, y1: j*GRID, x2: W, y2: j*GRID, stroke: '#1a1a25', 'stroke-width': 0.5 }));
      for (var i = 0; i <= COLS; i++) for (var j = 0; j <= ROWS; j++) canvas.appendChild(svgEl('circle', { cx: i*GRID, cy: j*GRID, r: 1.5, fill: '#2a2a35' }));
    }

    function render() {
      canvas.innerHTML = ''; drawGrid();
      components.forEach(function (c, idx) {
        var col = { wire: '#cfd6da', battery: '#fbbf24', resistor: '#fb923c', capacitor: '#67e8f9', led: '#86efac' }[c.type];
        if (c.type === 'wire') {
          canvas.appendChild(svgEl('line', { x1: c.x1, y1: c.y1, x2: c.x2, y2: c.y2, stroke: col, 'stroke-width': 3, 'data-idx': idx, style: 'cursor:pointer;' }));
        } else {
          var mx = (c.x1 + c.x2) / 2, my = (c.y1 + c.y2) / 2;
          // wire stubs
          canvas.appendChild(svgEl('line', { x1: c.x1, y1: c.y1, x2: c.x1 + (mx - c.x1) * 0.35, y2: c.y1 + (my - c.y1) * 0.35, stroke: col, 'stroke-width': 2 }));
          canvas.appendChild(svgEl('line', { x1: c.x2 - (mx - c.x1) * 0.35, y1: c.y2 - (my - c.y1) * 0.35, x2: c.x2, y2: c.y2, stroke: col, 'stroke-width': 2 }));
          // body
          if (c.type === 'resistor') {
            var dx = c.x2 - c.x1, dy = c.y2 - c.y1;
            var len = Math.sqrt(dx*dx + dy*dy);
            var nx = -dy / len * 6, ny = dx / len * 6;
            var path = 'M ' + (c.x1 + dx*0.35) + ' ' + (c.y1 + dy*0.35);
            for (var k = 0; k < 6; k++) {
              var t = 0.35 + k * 0.05; var t2 = t + 0.025;
              path += ' L ' + (c.x1 + dx*t + (k%2===0 ? nx : -nx)) + ' ' + (c.y1 + dy*t + (k%2===0 ? ny : -ny));
            }
            path += ' L ' + (c.x1 + dx*0.65) + ' ' + (c.y1 + dy*0.65);
            canvas.appendChild(svgEl('path', { d: path, stroke: col, 'stroke-width': 2, fill: 'none', 'data-idx': idx, style: 'cursor:pointer;' }));
          } else if (c.type === 'battery') {
            var dx = c.x2 - c.x1, dy = c.y2 - c.y1;
            var len = Math.sqrt(dx*dx + dy*dy);
            var nx = -dy / len, ny = dx / len;
            var t1 = 0.42, t2 = 0.58;
            // long plate (+)
            canvas.appendChild(svgEl('line', { x1: c.x1 + dx*t1 + nx*14, y1: c.y1 + dy*t1 + ny*14, x2: c.x1 + dx*t1 - nx*14, y2: c.y1 + dy*t1 - ny*14, stroke: col, 'stroke-width': 3 }));
            // short plate (-)
            canvas.appendChild(svgEl('line', { x1: c.x1 + dx*t2 + nx*8, y1: c.y1 + dy*t2 + ny*8, x2: c.x1 + dx*t2 - nx*8, y2: c.y1 + dy*t2 - ny*8, stroke: col, 'stroke-width': 3 }));
            canvas.appendChild(svgEl('rect', { x: mx-12, y: my-12, width: 24, height: 24, fill: 'transparent', 'data-idx': idx, style: 'cursor:pointer;' }));
          } else if (c.type === 'capacitor') {
            var dx = c.x2 - c.x1, dy = c.y2 - c.y1;
            var len = Math.sqrt(dx*dx + dy*dy);
            var nx = -dy / len, ny = dx / len;
            canvas.appendChild(svgEl('line', { x1: c.x1 + dx*0.45 + nx*12, y1: c.y1 + dy*0.45 + ny*12, x2: c.x1 + dx*0.45 - nx*12, y2: c.y1 + dy*0.45 - ny*12, stroke: col, 'stroke-width': 3 }));
            canvas.appendChild(svgEl('line', { x1: c.x1 + dx*0.55 + nx*12, y1: c.y1 + dy*0.55 + ny*12, x2: c.x1 + dx*0.55 - nx*12, y2: c.y1 + dy*0.55 - ny*12, stroke: col, 'stroke-width': 3 }));
            canvas.appendChild(svgEl('rect', { x: mx-12, y: my-12, width: 24, height: 24, fill: 'transparent', 'data-idx': idx, style: 'cursor:pointer;' }));
          } else if (c.type === 'led') {
            var glow = c.current && Math.abs(c.current) > 1e-6;
            canvas.appendChild(svgEl('polygon', { points: (mx-8) + ',' + (my-8) + ' ' + (mx-8) + ',' + (my+8) + ' ' + (mx+8) + ',' + my, fill: glow ? '#86efac' : 'none', stroke: col, 'stroke-width': 2 }));
            if (glow) canvas.appendChild(svgEl('circle', { cx: mx, cy: my, r: 14, fill: 'none', stroke: '#86efac', 'stroke-width': 1, opacity: 0.5 }));
            canvas.appendChild(svgEl('rect', { x: mx-12, y: my-12, width: 24, height: 24, fill: 'transparent', 'data-idx': idx, style: 'cursor:pointer;' }));
          }
          // value label
          var lblTxt = c.type === 'resistor' ? (c.value + ' Ω') : c.type === 'battery' ? (c.value + ' V') : c.type === 'capacitor' ? (c.value + ' μF') : c.type === 'led' ? '' : '';
          if (lblTxt) {
            var t = svgEl('text', { x: mx, y: my + 26, 'text-anchor': 'middle', fill: col, 'font-family': 'Geist Mono', 'font-size': 10, 'font-weight': 700 });
            t.textContent = lblTxt; canvas.appendChild(t);
          }
          if (c.current != null && Math.abs(c.current) > 1e-6) {
            var ct = svgEl('text', { x: mx, y: my - 18, 'text-anchor': 'middle', fill: '#67e8f9', 'font-family': 'Geist Mono', 'font-size': 9 });
            ct.textContent = (c.current * 1000).toFixed(2) + ' mA';
            canvas.appendChild(ct);
          }
        }
      });
      // first-point marker
      if (firstPt) canvas.appendChild(svgEl('circle', { cx: firstPt.x, cy: firstPt.y, r: 6, fill: '#fbbf24', opacity: 0.7 }));
    }

    function snap(p) { return { x: Math.round(p.x / GRID) * GRID, y: Math.round(p.y / GRID) * GRID }; }

    canvas.addEventListener('click', function (e) {
      // Did we click an existing component?
      var idxAttr = e.target.getAttribute && e.target.getAttribute('data-idx');
      if (idxAttr != null && tool !== 'delete' && tool === 'wire' && !firstPt) {
        // select for editing
        selected = +idxAttr;
        var c = components[selected];
        document.getElementById('selectedInfo').textContent = c.type + ' (value: ' + c.value + ')';
        document.getElementById('valueEditor').style.display = 'block';
        document.getElementById('valueInput').value = c.value;
        return;
      }
      if (idxAttr != null && tool === 'delete') {
        components.splice(+idxAttr, 1); render(); return;
      }
      var pt = canvas.createSVGPoint(); pt.x = e.clientX; pt.y = e.clientY;
      var sp = pt.matrixTransform(canvas.getScreenCTM().inverse());
      var s = snap(sp);
      if (tool === 'delete') return;
      if (!firstPt) { firstPt = s; render(); return; }
      if (firstPt.x === s.x && firstPt.y === s.y) { firstPt = null; render(); return; }
      // Only orthogonal
      if (firstPt.x !== s.x && firstPt.y !== s.y) { firstPt = s; render(); return; }
      var defaults = { wire: 0, battery: 9, resistor: 100, capacitor: 10, led: 0 };
      components.push({ type: tool, x1: firstPt.x, y1: firstPt.y, x2: s.x, y2: s.y, value: defaults[tool], current: null });
      firstPt = null; render();
    });

    document.querySelectorAll('.cb-tool').forEach(function (b) {
      b.addEventListener('click', function () {
        tool = b.getAttribute('data-tool');
        document.querySelectorAll('.cb-tool').forEach(function (x) { x.classList.remove('active'); });
        b.classList.add('active'); firstPt = null;
      });
    });

    document.getElementById('clearBtn').addEventListener('click', function () { components = []; firstPt = null; render(); document.getElementById('solverOut').textContent = 'Cleared.'; document.getElementById('branches').textContent = ''; });
    document.getElementById('setBtn').addEventListener('click', function () {
      if (selected == null) return;
      components[selected].value = parseFloat(document.getElementById('valueInput').value) || 0;
      render();
    });

    document.getElementById('solveBtn').addEventListener('click', solve);

    // ============ Solver: Modified Nodal Analysis ============
    function solve() {
      // 1. Identify nodes (each unique point a component connects to). Wires merge endpoints into the same node.
      var pts = [];
      var pkey = function (x, y) { return x + ',' + y; };
      var nodeOf = {};
      function getNode(x, y) { var k = pkey(x, y); if (nodeOf[k] == null) { nodeOf[k] = pts.length; pts.push({ x: x, y: y }); } return nodeOf[k]; }
      // First, register all endpoints
      components.forEach(function (c) { getNode(c.x1, c.y1); getNode(c.x2, c.y2); });
      // Union-Find to merge wire endpoints
      var parent = pts.map(function (_, i) { return i; });
      function find(x) { while (parent[x] !== x) { parent[x] = parent[parent[x]]; x = parent[x]; } return x; }
      function union(a, b) { var ra = find(a), rb = find(b); if (ra !== rb) parent[ra] = rb; }
      components.forEach(function (c) { if (c.type === 'wire') union(nodeOf[pkey(c.x1, c.y1)], nodeOf[pkey(c.x2, c.y2)]); });
      // remap to compact node indices
      var remap = {}; var nodeCount = 0;
      pts.forEach(function (_, i) { var r = find(i); if (remap[r] == null) remap[r] = nodeCount++; });
      function nodeFor(x, y) { return remap[find(nodeOf[pkey(x, y)])]; }

      // 2. Build MNA matrix. Ground = node 0. Unknowns = (nodeCount - 1) voltages + N_vsources currents.
      var batteries = components.filter(function (c) { return c.type === 'battery'; });
      var resistors = components.filter(function (c) { return c.type === 'resistor'; });
      var leds = components.filter(function (c) { return c.type === 'led'; });
      if (batteries.length === 0 || (resistors.length + leds.length) === 0) { document.getElementById('solverOut').innerHTML = '<span style="color:#f87171;">Need at least 1 battery and 1 resistor / LED.</span>'; return; }
      var N = nodeCount, M = batteries.length;
      var sz = (N - 1) + M;
      var A = []; for (var i = 0; i < sz; i++) { var row = []; for (var j = 0; j < sz; j++) row.push(0); A.push(row); }
      var b = []; for (var i = 0; i < sz; i++) b.push(0);
      function nodeIdx(n) { return n === 0 ? -1 : (n - 1); }
      // Stamp resistors
      resistors.forEach(function (r) {
        var n1 = nodeFor(r.x1, r.y1), n2 = nodeFor(r.x2, r.y2);
        var G = 1 / Math.max(0.01, r.value);
        if (nodeIdx(n1) >= 0) A[nodeIdx(n1)][nodeIdx(n1)] += G;
        if (nodeIdx(n2) >= 0) A[nodeIdx(n2)][nodeIdx(n2)] += G;
        if (nodeIdx(n1) >= 0 && nodeIdx(n2) >= 0) { A[nodeIdx(n1)][nodeIdx(n2)] -= G; A[nodeIdx(n2)][nodeIdx(n1)] -= G; }
      });
      // Stamp LEDs as a resistor of 50 ohm + voltage drop of Vf (treat as small-signal — Vf modelled as a 50Ω resistor in series with a 2V drop. Approximate.)
      leds.forEach(function (l) {
        var n1 = nodeFor(l.x1, l.y1), n2 = nodeFor(l.x2, l.y2);
        var G = 1 / 50;
        if (nodeIdx(n1) >= 0) A[nodeIdx(n1)][nodeIdx(n1)] += G;
        if (nodeIdx(n2) >= 0) A[nodeIdx(n2)][nodeIdx(n2)] += G;
        if (nodeIdx(n1) >= 0 && nodeIdx(n2) >= 0) { A[nodeIdx(n1)][nodeIdx(n2)] -= G; A[nodeIdx(n2)][nodeIdx(n1)] -= G; }
      });
      // Stamp batteries (voltage sources)
      batteries.forEach(function (v, k) {
        var n1 = nodeFor(v.x1, v.y1); // (+)
        var n2 = nodeFor(v.x2, v.y2); // (-)
        var row = (N - 1) + k;
        if (nodeIdx(n1) >= 0) { A[nodeIdx(n1)][row] += 1; A[row][nodeIdx(n1)] += 1; }
        if (nodeIdx(n2) >= 0) { A[nodeIdx(n2)][row] -= 1; A[row][nodeIdx(n2)] -= 1; }
        b[row] = v.value;
      });

      // 3. Gaussian elimination
      function solveLinear(A, b) {
        var n = b.length;
        for (var i = 0; i < n; i++) {
          var p = i; for (var j = i + 1; j < n; j++) if (Math.abs(A[j][i]) > Math.abs(A[p][i])) p = j;
          if (Math.abs(A[p][i]) < 1e-12) return null;
          [A[i], A[p]] = [A[p], A[i]]; [b[i], b[p]] = [b[p], b[i]];
          for (var j = i + 1; j < n; j++) {
            var r = A[j][i] / A[i][i];
            for (var k = i; k < n; k++) A[j][k] -= r * A[i][k];
            b[j] -= r * b[i];
          }
        }
        var x = new Array(n);
        for (var i = n - 1; i >= 0; i--) {
          var s = b[i];
          for (var j = i + 1; j < n; j++) s -= A[i][j] * x[j];
          x[i] = s / A[i][i];
        }
        return x;
      }
      var x = solveLinear(A, b);
      if (!x) { document.getElementById('solverOut').innerHTML = '<span style="color:#f87171;">Singular system — check for short circuit or floating nodes.</span>'; return; }

      // 4. Extract node voltages
      var V = [0]; for (var i = 0; i < N - 1; i++) V.push(x[i]);
      // 5. Compute branch currents
      resistors.concat(leds).forEach(function (c) {
        var n1 = nodeFor(c.x1, c.y1), n2 = nodeFor(c.x2, c.y2);
        var Vd = V[n1] - V[n2];
        var R = c.type === 'led' ? 50 : c.value;
        c.current = Vd / Math.max(0.01, R);
      });
      batteries.forEach(function (c, k) { c.current = x[(N - 1) + k]; });

      // 6. Output
      var html = 'Solved. ' + N + ' nodes, ' + M + ' voltage source(s).<br/><br/>';
      html += 'Node voltages (ground = node 0):<br/>';
      V.forEach(function (v, i) { html += '&nbsp;&nbsp;V<sub>' + i + '</sub> = ' + v.toFixed(3) + ' V<br/>'; });
      document.getElementById('solverOut').innerHTML = html;
      var bh = '';
      components.forEach(function (c) {
        if (c.current == null) return;
        bh += c.type.toUpperCase() + ' (' + c.value + (c.type==='resistor'?'Ω':c.type==='battery'?'V':'') + '): ' + (c.current * 1000).toFixed(2) + ' mA<br/>';
      });
      document.getElementById('branches').innerHTML = bh;
      render();
    }

    render();
  })();
</script>
</BaseLayout>
