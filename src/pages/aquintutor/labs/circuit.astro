---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Series RLC lab (graduate level). Two regimes on one circuit: the second-order
// TRANSIENT step response L C v'' + R C v' + v = V integrated by RK4 (under /
// critically / over-damped, with damping ratio zeta, natural and damped
// frequencies, quality factor Q, overshoot), and AC STEADY-STATE phasor
// analysis (complex impedance Z = R + j(wL - 1/wC), a rotating phasor diagram
// of V_R / V_L / V_C / source, phase angle and power factor), plus the
// resonance frequency response |I(f)| with its bandwidth and Q. No libraries.
---
<BaseLayout title="RLC Circuits · Virtual Labs · AquinTutor" description="Graduate circuits: second-order RLC transient step response (damping ratio, Q, damped frequency, overshoot) via RK4, AC steady-state phasor analysis (complex impedance, phasor diagram, power factor), and the resonance frequency response with bandwidth and Q. Built from scratch.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1340px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:16px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:300px minmax(0,1fr); gap:18px; } @media(max-width:960px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:15px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 11px; }
  .lb-row{ display:grid; gap:8px; } .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.08em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; }
  .lb-row label span{ color:#5ee7ff; } .lb-row input[type=range]{ width:100%; accent-color:#5ee7ff; }
  .lb-seg{ display:flex; gap:4px; } .lb-seg button{ flex:1; background:#0b1020; border:1px solid #26314f; color:#8ea0be; border-radius:7px; padding:6px 4px; font-family:'Geist Mono',monospace; font-size:10px; cursor:pointer; } .lb-seg button.on{ background:rgba(94,231,255,0.14); color:#5ee7ff; border-color:#3a6b86; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); }
  .lb-stage canvas{ display:block; width:100%; height:auto; }
  .lb-plots{ display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-top:12px; } @media(max-width:680px){ .lb-plots{ grid-template-columns:1fr; } }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11px; padding:4px 0; border-bottom:1px solid #141a2c; }
  .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#5ee7ff; font-weight:700; text-align:right; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">Electrical · Second-order · Resonance</p>
      <h1 class="lb-title">Series <em>RLC</em>.</h1>
    </div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Analysis</h3>
        <div class="lb-seg" id="modeSeg"><button data-m="tran" class="on">Transient step</button><button data-m="ac">AC steady-state</button></div>
      </div>
      <div class="lb-panel"><h3>Components</h3><div class="lb-row">
        <label>Source V (V) <span id="vV">5.0</span></label><input id="volt" type="range" min="1" max="20" step="0.5" value="5"/>
        <label>Resistance R (Ω) <span id="rV">30</span></label><input id="res" type="range" min="1" max="600" step="1" value="30"/>
        <label>Inductance L (mH) <span id="lV">10</span></label><input id="ind" type="range" min="0.5" max="200" step="0.5" value="10"/>
        <label>Capacitance C (µF) <span id="cV">1.00</span></label><input id="cap" type="range" min="0.01" max="10" step="0.01" value="1"/>
        <label id="fWrap" style="display:none;">Drive freq f (Hz) <span id="fV">1592</span></label><input id="freq" type="range" min="20" max="8000" step="1" value="1592" style="display:none;"/>
      </div></div>
      <div class="lb-panel"><h3>Characteristics</h3>
        <div class="lb-metric"><span class="lb-metric-l">f₀ resonance (Hz)</span><span class="lb-metric-v" id="mF0">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">ω₀ (rad/s)</span><span class="lb-metric-v" id="mW0">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Damping ζ</span><span class="lb-metric-v" id="mZeta">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Quality Q</span><span class="lb-metric-v" id="mQ">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Regime</span><span class="lb-metric-v" id="mReg" style="color:#a78bfa;">—</span></div>
        <div class="lb-metric" id="rowAc1"><span class="lb-metric-l">|Z| (Ω)</span><span class="lb-metric-v" id="mZ">—</span></div>
        <div class="lb-metric" id="rowAc2"><span class="lb-metric-l">Phase φ</span><span class="lb-metric-v" id="mPhi">—</span></div>
        <div class="lb-metric" id="rowAc3"><span class="lb-metric-l">Power factor</span><span class="lb-metric-v" id="mPF">—</span></div>
        <div class="lb-metric" id="rowTr1"><span class="lb-metric-l">Damped f_d (Hz)</span><span class="lb-metric-v" id="mFd">—</span></div>
        <div class="lb-metric" id="rowTr2"><span class="lb-metric-l">Overshoot</span><span class="lb-metric-v" id="mOS">—</span></div>
      </div>
    </aside>
    <section>
      <div class="lb-stage"><canvas id="scene" width="960" height="380"></canvas></div>
      <div class="lb-plots">
        <div class="lb-panel" style="margin:0;"><h3 id="plotAh">Step response v_C(t) &amp; i(t)</h3><canvas id="ptime" width="560" height="200" style="width:100%;height:auto;"></canvas></div>
        <div class="lb-panel" style="margin:0;"><h3>Frequency response |I(f)| · resonance</h3><canvas id="pfreq" width="560" height="200" style="width:100%;height:auto;"></canvas></div>
      </div>
    </section>
  </div>
</main>
<script is:inline>
(function(){
  function v(id){ return parseFloat(document.getElementById(id).value); }
  function setTxt(id,t){ var e=document.getElementById(id); if(e) e.textContent=t; }
  var mode='tran';
  // transient state
  var vc=0, dvc=0, tt=0, hist=[], acPhase=0;
  function params(){ return { V:v('volt'), R:v('res'), L:v('ind')/1000, C:v('cap')*1e-6, f:v('freq') }; }
  function sync(){ setTxt('vV',v('volt').toFixed(1)); setTxt('rV',v('res').toFixed(0)); setTxt('lV',v('ind').toFixed(1)); setTxt('cV',v('cap').toFixed(2)); setTxt('fV',v('freq').toFixed(0)); }
  document.querySelectorAll('input').forEach(function(e){ e.addEventListener('input',sync); }); sync();
  document.querySelectorAll('#modeSeg button').forEach(function(b){ b.addEventListener('click',function(){ document.querySelectorAll('#modeSeg button').forEach(function(x){x.classList.remove('on');}); b.classList.add('on'); mode=b.getAttribute('data-m');
    var ac=mode==='ac'; document.getElementById('fWrap').style.display=ac?'flex':'none'; document.getElementById('freq').style.display=ac?'block':'none';
    ['rowAc1','rowAc2','rowAc3'].forEach(function(id){ document.getElementById(id).style.display=ac?'grid':'none'; });
    ['rowTr1','rowTr2'].forEach(function(id){ document.getElementById(id).style.display=ac?'none':'grid'; });
    setTxt('plotAh', ac?'Source & current waveforms':'Step response v_C(t) & i(t)'); vc=0; dvc=0; tt=0; hist=[]; }); });
  // init row visibility
  ['rowAc1','rowAc2','rowAc3'].forEach(function(id){ document.getElementById(id).style.display='none'; });

  function chars(){ var p=params(); var w0=1/Math.sqrt(p.L*p.C); var f0=w0/(2*Math.PI);
    var zeta=(p.R/2)*Math.sqrt(p.C/p.L); var Q=zeta>1e-9?1/(2*zeta):Infinity; var wd=zeta<1?w0*Math.sqrt(1-zeta*zeta):0;
    return { w0:w0, f0:f0, zeta:zeta, Q:Q, wd:wd, p:p }; }

  // ---- transient: L C v'' + R C v' + v = V, state [v, dv] ----
  function stepTran(dt){ var p=params(); var LC=p.L*p.C, RC=p.R*p.C;
    function acc(v_,dv_){ return (p.V - v_ - RC*dv_)/LC; }
    var k1v=dvc, k1a=acc(vc,dvc);
    var k2v=dvc+dt/2*k1a, k2a=acc(vc+dt/2*k1v, dvc+dt/2*k1a);
    var k3v=dvc+dt/2*k2a, k3a=acc(vc+dt/2*k2v, dvc+dt/2*k2a);
    var k4v=dvc+dt*k3a, k4a=acc(vc+dt*k3v, dvc+dt*k3a);
    vc+=dt/6*(k1v+2*k2v+2*k3v+k4v); dvc+=dt/6*(k1a+2*k2a+2*k3a+k4a); tt+=dt;
    var i=p.C*dvc; hist.push([tt,vc,i]); if(hist.length>900) hist.shift(); }

  function hidpi(cv){ var r=cv.getBoundingClientRect(), dp=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w; cv.width=Math.round(w*dp); cv.height=Math.round(h*dp); var ctx=cv.getContext('2d'); ctx.setTransform(dp,0,0,dp,0,0); return {ctx:ctx,w:w,h:h}; }
  function glow(ctx,pts,col,wd){ ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=7; ctx.strokeStyle=col; ctx.lineWidth=wd||1.6; ctx.beginPath(); pts.forEach(function(q,i){ i?ctx.lineTo(q[0],q[1]):ctx.moveTo(q[0],q[1]); }); ctx.stroke(); ctx.restore(); }

  function schematic(ctx,W,H,ch){
    var L=W*0.08, R=W*0.92, T=H*0.28, B=H*0.80; ctx.strokeStyle='#2a3450'; ctx.lineWidth=5; ctx.lineJoin='round'; ctx.strokeRect(L,T,R-L,B-T);
    var my=(T+B)/2, p=ch.p;
    // source (left)
    ctx.strokeStyle='#e8ecf4'; ctx.lineWidth=2.5; if(mode==='ac'){ ctx.beginPath(); ctx.arc(L,my,15,0,7); ctx.stroke(); ctx.beginPath(); for(var a=-10;a<=10;a++){ var xa=L-9+18*(a+10)/20; ctx.lineTo(xa, my-5*Math.sin((a/10)*Math.PI)); } ctx.stroke(); }
    else { ctx.beginPath(); ctx.moveTo(L,my-20); ctx.lineTo(L,my+20); ctx.stroke(); ctx.lineWidth=6; ctx.beginPath(); ctx.moveTo(L-7,my-11); ctx.lineTo(L+7,my-11); ctx.stroke(); ctx.lineWidth=2; ctx.beginPath(); ctx.moveTo(L-4,my+11); ctx.lineTo(L+4,my+11); ctx.stroke(); }
    ctx.fillStyle='#8ea0be'; ctx.font="11px 'Geist Mono',monospace"; ctx.fillText(p.V.toFixed(1)+' V',L-16,my-26);
    // R (top-left zigzag)
    var rx0=W*0.20,rx1=W*0.40; ctx.strokeStyle='#fbbf24'; ctx.lineWidth=2.5; ctx.beginPath(); ctx.moveTo(rx0,T); for(var i=0;i<=8;i++){ var x=rx0+(rx1-rx0)*i/8; ctx.lineTo(x,T+(i%2?-8:8)); } ctx.lineTo(rx1,T); ctx.stroke(); ctx.fillStyle='#fbbf24'; ctx.fillText(p.R.toFixed(0)+' Ω',(rx0+rx1)/2-18,T-14);
    // L (top-mid coil)
    var lx0=W*0.48,lx1=W*0.68; ctx.strokeStyle='#34d399'; ctx.beginPath(); ctx.moveTo(lx0,T); for(var i=0;i<4;i++){ var xc=lx0+(lx1-lx0)*(i+0.5)/4; ctx.arc(xc,T,(lx1-lx0)/8,Math.PI,0,false); } ctx.lineTo(lx1,T); ctx.stroke(); ctx.fillStyle='#34d399'; ctx.fillText((p.L*1000).toFixed(1)+' mH',(lx0+lx1)/2-22,T-14);
    // C (right side)
    var cy=my; ctx.strokeStyle='#a78bfa'; ctx.lineWidth=3; ctx.beginPath(); ctx.moveTo(R,cy-26); ctx.lineTo(R,cy-6); ctx.stroke(); ctx.beginPath(); ctx.moveTo(R,cy+6); ctx.lineTo(R,cy+26); ctx.stroke(); ctx.beginPath(); ctx.moveTo(R-15,cy-6); ctx.lineTo(R+15,cy-6); ctx.stroke(); ctx.beginPath(); ctx.moveTo(R-15,cy+6); ctx.lineTo(R+15,cy+6); ctx.stroke(); ctx.fillStyle='#a78bfa'; ctx.fillText((p.C*1e6).toFixed(2)+' µF',R-64,cy-14);
    // current magnitude glow
    var Imag = mode==='ac' ? acAmp() : Math.abs(ch.p.C*dvc);
    var norm=Math.min(1,Imag/((p.V/p.R)+1e-9)); ctx.save(); ctx.shadowColor='#5ee7ff'; ctx.shadowBlur=8*norm+2; ctx.strokeStyle='rgba(94,231,255,'+(0.2+0.55*norm)+')'; ctx.lineWidth=2.5; ctx.strokeRect(L,T,R-L,B-T); ctx.restore();
  }
  function acAmp(){ var p=params(); var w=2*Math.PI*p.f; var Z=Math.hypot(p.R, w*p.L-1/(w*p.C)); return p.V/Z; }

  function drawPhasor(ctx,W,H){
    var p=params(); var w=2*Math.PI*p.f; var XL=w*p.L, XC=1/(w*p.C); var X=XL-XC; var Z=Math.hypot(p.R,X); var phi=Math.atan2(X,p.R);
    var I=p.V/Z; var VR=I*p.R, VL=I*XL, VC=I*XC;
    var cx=W*0.72, cy=H*0.5, sc=(H*0.36)/Math.max(p.V,VL,VC,1e-6);
    // rotating frame: draw phasors as vectors at current animation angle
    var th=acPhase; function vec(mag,ph,col,lab){ var ax=Math.cos(th+ph)*mag*sc, ay=Math.sin(th+ph)*mag*sc; ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=7; ctx.strokeStyle=col; ctx.fillStyle=col; ctx.lineWidth=2; ctx.beginPath(); ctx.moveTo(cx,cy); ctx.lineTo(cx+ax,cy-ay); ctx.stroke(); var aa=Math.atan2(-ay,ax); ctx.beginPath(); ctx.moveTo(cx+ax,cy-ay); ctx.lineTo(cx+ax-8*Math.cos(aa-0.4),cy-ay-8*Math.sin(aa-0.4)); ctx.lineTo(cx+ax-8*Math.cos(aa+0.4),cy-ay-8*Math.sin(aa+0.4)); ctx.closePath(); ctx.fill(); ctx.restore(); ctx.fillStyle=col; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText(lab,cx+ax*1.05,cy-ay*1.05); }
    // reference axes
    ctx.strokeStyle='#1a2340'; ctx.beginPath(); ctx.moveTo(cx-H*0.4,cy); ctx.lineTo(cx+H*0.4,cy); ctx.moveTo(cx,cy-H*0.4); ctx.lineTo(cx,cy+H*0.4); ctx.stroke();
    // current I at angle -phi relative to source V(0); source at angle 0
    vec(p.V,0,'#5ee7ff','V');           // source
    vec(I* p.R*0+I,  -phi,'#fbbf24','I'); // current (scaled by I; show direction)
    vec(VR,-phi,'#fb923c','VR'); vec(VL,-phi+Math.PI/2,'#34d399','VL'); vec(VC,-phi-Math.PI/2,'#a78bfa','VC');
    ctx.fillStyle='#8ea0be'; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText('phasors (rotating)',cx-40,H-10);
  }

  function drawScene(){ var cv=document.getElementById('scene'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h; var ch=chars();
    var bg=ctx.createLinearGradient(0,0,0,H); bg.addColorStop(0,'#0c1226'); bg.addColorStop(1,'#06080f'); ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    schematic(ctx,W,H,ch); if(mode==='ac') drawPhasor(ctx,W,H); }

  function drawTime(){ var cv=document.getElementById('ptime'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h; ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H);
    ctx.strokeStyle='rgba(94,231,255,0.06)'; for(var y=0;y<H;y+=25){ ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke(); }
    var p=params();
    if(mode==='ac'){ var w=2*Math.PI*p.f, Z=Math.hypot(p.R,w*p.L-1/(w*p.C)), phi=Math.atan2(w*p.L-1/(w*p.C),p.R), I=p.V/Z;
      var cy=H/2, N=W; ctx.strokeStyle='#1a2340'; ctx.beginPath(); ctx.moveTo(0,cy); ctx.lineTo(W,cy); ctx.stroke();
      // draw a few periods
      function wave(amp,ph,col){ ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=6; ctx.strokeStyle=col; ctx.lineWidth=1.6; ctx.beginPath(); for(var xx=0;xx<N;xx++){ var a=acPhase - (xx/N)*6*Math.PI; ctx.lineTo(xx, cy - amp*Math.sin(a+ph)*(H*0.4)); } ctx.stroke(); ctx.restore(); }
      wave(p.V/Math.max(p.V,I*Math.max(p.R,w*p.L,1/(w*p.C))),0,'#5ee7ff'); wave(I*p.R/Math.max(p.V,I*Math.max(p.R,w*p.L,1/(w*p.C))),-phi,'#fbbf24');
      ctx.fillStyle='#5ee7ff'; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText('V',8,14); ctx.fillStyle='#fbbf24'; ctx.fillText('I (φ='+(phi*180/Math.PI).toFixed(0)+'°)',26,14);
    } else {
      if(hist.length<2) return; var t0=hist[0][0], t1=hist[hist.length-1][0]; var maxI=Math.max.apply(null,hist.map(function(h){return Math.abs(h[2]);}))||1;
      function X(t){ return 8+(t-t0)/(t1-t0+1e-9)*(W-16); } function Yv(val){ return H-8-(val/Math.max(p.V*1.4,1))*(H-16); } function Yi(val){ return H/2 - val/maxI*(H*0.42); }
      ctx.strokeStyle='rgba(94,231,255,0.5)'; ctx.setLineDash([4,4]); ctx.beginPath(); ctx.moveTo(8,Yv(p.V)); ctx.lineTo(W-8,Yv(p.V)); ctx.stroke(); ctx.setLineDash([]);
      glow(ctx,hist.map(function(h){return [X(h[0]),Yv(h[1])];}),'#a78bfa'); glow(ctx,hist.map(function(h){return [X(h[0]),Yi(h[2])+ -(H/2-Yv(0))*0];}),'#fbbf24');
      ctx.fillStyle='#a78bfa'; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText('v_C',8,14); ctx.fillStyle='#fbbf24'; ctx.fillText('i',34,14);
    }
  }
  function drawFreq(){ var cv=document.getElementById('pfreq'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h; ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H);
    var p=params(); var fmin=20, fmax=8000; var padL=8, padB=16;
    function Xf(f){ return padL + (Math.log10(f)-Math.log10(fmin))/(Math.log10(fmax)-Math.log10(fmin))*(W-padL-8); }
    function I(f){ var w=2*Math.PI*f; return p.V/Math.hypot(p.R, w*p.L-1/(w*p.C)); }
    var imax=I(1/(2*Math.PI*Math.sqrt(p.L*p.C))); function Y(val){ return H-padB-(val/imax)*(H-padB-10); }
    ctx.strokeStyle='rgba(94,231,255,0.06)'; [50,100,500,1000,5000].forEach(function(f){ if(f<fmax){ var x=Xf(f); ctx.beginPath(); ctx.moveTo(x,8); ctx.lineTo(x,H-padB); ctx.stroke(); ctx.fillStyle='#5f7597'; ctx.font="8px 'Geist Mono',monospace"; ctx.fillText(f>=1000?(f/1000)+'k':f,x-6,H-4); } });
    ctx.save(); ctx.shadowColor='#34d399'; ctx.shadowBlur=7; ctx.strokeStyle='#34d399'; ctx.lineWidth=1.8; ctx.beginPath(); for(var xx=padL;xx<W-8;xx++){ var f=Math.pow(10, Math.log10(fmin)+(xx-padL)/(W-padL-8)*(Math.log10(fmax)-Math.log10(fmin))); (xx===padL)?ctx.moveTo(xx,Y(I(f))):ctx.lineTo(xx,Y(I(f))); } ctx.stroke(); ctx.restore();
    var f0=1/(2*Math.PI*Math.sqrt(p.L*p.C)); ctx.strokeStyle='rgba(52,211,153,0.5)'; ctx.setLineDash([3,3]); ctx.beginPath(); ctx.moveTo(Xf(f0),8); ctx.lineTo(Xf(f0),H-padB); ctx.stroke(); ctx.setLineDash([]); ctx.fillStyle='#34d399'; ctx.font="9px 'Geist Mono',monospace"; ctx.fillText('f₀',Xf(f0)-4,16);
    // half-power band (I=imax/√2)
    var ch=chars(); if(isFinite(ch.Q)&&ch.Q>0.5){ var bw=f0/ch.Q; var f1=Xf(Math.max(fmin,f0-bw/2)), f2=Xf(Math.min(fmax,f0+bw/2)); ctx.fillStyle='rgba(52,211,153,0.08)'; ctx.fillRect(f1,8,f2-f1,H-padB-8); }
    if(mode==='ac'){ var fx=Xf(p.f); ctx.save(); ctx.shadowColor='#fbbf24'; ctx.shadowBlur=10; ctx.fillStyle='#fbbf24'; ctx.beginPath(); ctx.arc(fx,Y(I(p.f)),4,0,7); ctx.fill(); ctx.restore(); }
  }

  function metrics(){ var ch=chars(); var p=ch.p;
    setTxt('mF0',ch.f0.toFixed(0)); setTxt('mW0',ch.w0.toFixed(0)); setTxt('mZeta',ch.zeta.toFixed(3)); setTxt('mQ',isFinite(ch.Q)?ch.Q.toFixed(2):'∞');
    setTxt('mReg', ch.zeta<0.999?'underdamped':ch.zeta<1.001?'critically damped':'overdamped');
    if(mode==='ac'){ var w=2*Math.PI*p.f, X=w*p.L-1/(w*p.C), Z=Math.hypot(p.R,X), phi=Math.atan2(X,p.R);
      setTxt('mZ',Z.toFixed(1)); setTxt('mPhi',(phi*180/Math.PI).toFixed(1)+'°'); setTxt('mPF',Math.cos(phi).toFixed(3)); }
    else { setTxt('mFd', ch.wd>0?(ch.wd/(2*Math.PI)).toFixed(0):'—'); setTxt('mOS', ch.zeta<1?(Math.exp(-Math.PI*ch.zeta/Math.sqrt(1-ch.zeta*ch.zeta))*100).toFixed(1)+'%':'0%'); }
  }

  var lastTs=0;
  function loop(ts){ if(!lastTs)lastTs=ts; var dt=Math.min(0.03,(ts-lastTs)/1000); lastTs=ts;
    if(mode==='tran'){ var ch=chars(); var T=Math.max(6/Math.max(ch.zeta*ch.w0,ch.w0*0.1), 6*Math.sqrt(params().L*params().C)); var sub=60; for(var i=0;i<sub;i++) stepTran((T/600)); if(tt>T*1.05){ vc=0; dvc=0; tt=0; hist=[]; } }
    else { acPhase += dt*Math.min(6, 2*Math.PI*Math.min(4, params().f/400)); }
    drawScene(); drawTime(); drawFreq(); metrics(); requestAnimationFrame(loop); }
  requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
