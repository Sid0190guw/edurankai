---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Lens-design optics lab (graduate level). Instead of the ideal thin lens, this
// traces a fan of meridional rays EXACTLY through both spherical surfaces of a
// thick lens with Snell's law at each interface. Real aberrations therefore
// emerge from the geometry: spherical aberration (marginal rays focus nearer
// than paraxial — the longitudinal LSA is measured), and chromatic aberration
// from a dispersive glass n(λ) set by index n_d and Abbe number V_d (red/blue
// foci split — axial color is measured). It reports the lensmaker EFL, the
// f-number, and the paraxial image from two near-axis rays. No libraries.
---
<BaseLayout title="Lens Design & Aberrations · Virtual Labs · AquinTutor" description="Graduate optics: exact meridional ray tracing through a thick lens' two spherical surfaces with Snell's law, revealing spherical aberration (LSA) and chromatic aberration from a dispersive glass (n_d, Abbe V_d), plus lensmaker EFL and f-number. Built from scratch.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1340px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:16px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:300px minmax(0,1fr); gap:18px; } @media(max-width:960px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:15px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 11px; }
  .lb-row{ display:grid; gap:8px; } .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.08em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; }
  .lb-row label span{ color:#5ee7ff; } .lb-row input[type=range]{ width:100%; accent-color:#5ee7ff; }
  select{ width:100%; background:#080a12; border:1px solid #1e2740; color:#fff; padding:8px 10px; border-radius:6px; font-size:12px; font-family:inherit; }
  .lb-seg{ display:flex; gap:4px; } .lb-seg button{ flex:1; background:#0b1020; border:1px solid #26314f; color:#8ea0be; border-radius:7px; padding:6px 4px; font-family:'Geist Mono',monospace; font-size:10px; cursor:pointer; } .lb-seg button.on{ background:rgba(94,231,255,0.14); color:#5ee7ff; border-color:#3a6b86; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); }
  .lb-stage canvas{ display:block; width:100%; height:auto; }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11px; padding:4px 0; border-bottom:1px solid #141a2c; }
  .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#5ee7ff; font-weight:700; text-align:right; }
  .lb-note{ font-size:11px; color:#7e8aa3; line-height:1.6; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">Physics · Lens design · Aberrations</p>
      <h1 class="lb-title">Lens <em>aberrations</em>.</h1>
    </div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Thick lens</h3><div class="lb-row">
        <label>Radius R₁ (cm) <span id="r1V">12</span></label><input id="r1" type="range" min="-40" max="40" step="0.5" value="12"/>
        <label>Radius R₂ (cm) <span id="r2V">-12</span></label><input id="r2" type="range" min="-40" max="40" step="0.5" value="-12"/>
        <label>Centre thickness d (cm) <span id="dV">2.0</span></label><input id="d" type="range" min="0.2" max="6" step="0.1" value="2.0"/>
        <label>Aperture radius (cm) <span id="apV">6</span></label><input id="ap" type="range" min="1" max="12" step="0.5" value="6"/>
      </div></div>
      <div class="lb-panel"><h3>Glass &amp; object</h3><div class="lb-row">
        <label>Index n_d <span id="ndV">1.517</span></label><input id="nd" type="range" min="1.35" max="1.95" step="0.001" value="1.517"/>
        <label>Abbe number V_d <span id="abbeV">64</span></label><input id="abbe" type="range" min="20" max="90" step="1" value="64"/>
        <label>Object distance (cm) <span id="odV">60</span></label><input id="od" type="range" min="20" max="140" step="1" value="60"/>
      </div>
      <div class="lb-seg" id="colorSeg" style="margin-top:10px;"><button data-c="tri" class="on">R/G/B</button><button data-c="mono">Mono</button></div>
      </div>
      <div class="lb-panel"><h3>Results</h3>
        <div class="lb-metric"><span class="lb-metric-l">EFL (lensmaker)</span><span class="lb-metric-v" id="mEFL">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">f-number f/#</span><span class="lb-metric-v" id="mFno">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Paraxial image (cm)</span><span class="lb-metric-v" id="mImg">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Marginal focus (cm)</span><span class="lb-metric-v" id="mMarg">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Spherical aberr. LSA</span><span class="lb-metric-v" id="mLSA" style="color:#fbbf24;">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Axial color (F−C)</span><span class="lb-metric-v" id="mChr" style="color:#f472b6;">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">n_F, n_C</span><span class="lb-metric-v" id="mNfc">—</span></div>
      </div>
    </aside>
    <section><div class="lb-stage"><canvas id="scene" width="1000" height="560"></canvas></div>
      <p class="lb-note" style="margin-top:10px;">Rays are traced exactly (Snell's law at each spherical surface), so they do NOT meet at a point: outer rays cross the axis nearer the lens than paraxial rays — that gap is the longitudinal spherical aberration. With a dispersive glass the red and blue marginal rays focus at different points (axial chromatic aberration). Flip a surface (R&lt;0) or raise the Abbe number to see them shrink.</p>
    </section>
  </div>
</main>
<script is:inline>
(function(){
  function v(id){ return parseFloat(document.getElementById(id).value); }
  function setTxt(id,t){ var e=document.getElementById(id); if(e) e.textContent=t; }
  var colorMode='tri';
  function sync(){ setTxt('r1V',v('r1').toFixed(1)); setTxt('r2V',v('r2').toFixed(1)); setTxt('dV',v('d').toFixed(1)); setTxt('apV',v('ap').toFixed(1)); setTxt('ndV',v('nd').toFixed(3)); setTxt('abbeV',v('abbe').toFixed(0)); setTxt('odV',v('od').toFixed(0)); }
  document.querySelectorAll('input').forEach(function(e){ e.addEventListener('input',sync); }); sync();
  document.querySelectorAll('#colorSeg button').forEach(function(b){ b.addEventListener('click',function(){ document.querySelectorAll('#colorSeg button').forEach(function(x){x.classList.remove('on');}); b.classList.add('on'); colorMode=b.getAttribute('data-c'); }); });

  // n at Fraunhofer F(486)/d(587)/C(656) from n_d and Abbe V_d: n_F - n_C = (n_d-1)/V_d
  function nAt(band){ var nd=v('nd'), V=v('abbe'); var dnfc=(nd-1)/V; if(band==='d')return nd; if(band==='F')return nd+0.5*dnfc; return nd-0.5*dnfc; }

  function norm(x,y){ var m=Math.hypot(x,y)||1; return {x:x/m,y:y/m}; }
  function refract(dx,dy,nx,ny,eta){ var cosi=-(dx*nx+dy*ny); if(cosi<0){ nx=-nx; ny=-ny; cosi=-(dx*nx+dy*ny); } var k=1-eta*eta*(1-cosi*cosi); if(k<0) return null; var f=eta*cosi-Math.sqrt(k); return {x:eta*dx+f*nx, y:eta*dy+f*ny}; }
  function hitSphere(px,py,dx,dy,cx,vx,r){ var ocx=px-cx, ocy=py; var b=ocx*dx+ocy*dy, c=ocx*ocx+ocy*ocy-r*r, disc=b*b-c; if(disc<0)return null; var s=Math.sqrt(disc); var best=null,bd=1e9; [-b-s,-b+s].forEach(function(t){ if(t>1e-6){ var hx=px+t*dx, hy=py+t*dy, dd=Math.abs(hx-vx); if(dd<bd){bd=dd;best={x:hx,y:hy};} } }); return best; }
  // trace ray from (px,py) dir(dx,dy) through the two surfaces; return segments + exit ray + axis crossing
  function trace(px,py,dx,dy,nG){ var R1=v('r1'),R2=v('r2'),d=v('d'),ap=v('ap');
    var D=norm(dx,dy); var segs=[[px,py]];
    var h1=hitSphere(px,py,D.x,D.y,R1,0,Math.abs(R1)); if(!h1||Math.abs(h1.y)>ap) return null; segs.push([h1.x,h1.y]);
    var n1x=(h1.x-R1)/Math.abs(R1), n1y=h1.y/Math.abs(R1); var d1=refract(D.x,D.y,n1x,n1y,1/nG); if(!d1) return null;
    var h2=hitSphere(h1.x,h1.y,d1.x,d1.y,d+R2,d,Math.abs(R2)); if(!h2||Math.abs(h2.y)>ap) return null; segs.push([h2.x,h2.y]);
    var n2x=(h2.x-(d+R2))/Math.abs(R2), n2y=h2.y/Math.abs(R2); var d2=refract(d1.x,d1.y,n2x,n2y,nG/1); if(!d2) return null;
    var cross=Math.abs(d2.y)>1e-6 ? h2.x - h2.y*(d2.x/d2.y) : Infinity;
    return { segs:segs, ex:h2.x, ey:h2.y, dx:d2.x, dy:d2.y, cross:cross }; }

  function lensmaker(nG){ var R1=v('r1'),R2=v('r2'),d=v('d'); var inv=(nG-1)*(1/R1 - 1/R2 + (nG-1)*d/(nG*R1*R2)); return 1/inv; }

  function hidpi(cv){ var r=cv.getBoundingClientRect(), dp=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w; cv.width=Math.round(w*dp); cv.height=Math.round(h*dp); var ctx=cv.getContext('2d'); ctx.setTransform(dp,0,0,dp,0,0); return {ctx:ctx,w:w,h:h}; }
  function draw(){
    var cv=document.getElementById('scene'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h;
    var bg=ctx.createLinearGradient(0,0,0,H); bg.addColorStop(0,'#0c1226'); bg.addColorStop(1,'#06080f'); ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    var od=v('od'), ap=v('ap'), d=v('d'), R1=v('r1'), R2=v('r2');
    var nd=nAt('d'); var fEFL=lensmaker(nd);
    // scaling: world x from -od-4 to focus+margin; center axis vertically
    var xmin=-od-2, xmax=Math.max(d+Math.abs(fEFL)*2.2, d+40);
    var padL=20, cy=H*0.5, sx=(W-2*padL)/(xmax-xmin); var syAvail=(H*0.44)/Math.max(ap*1.15,8); var sc=Math.min(sx,syAvail);
    // recompute so the whole span fits horizontally
    sc=Math.min((W-2*padL)/(xmax-xmin), (H*0.44)/Math.max(ap*1.15,8));
    function X(x){ return padL + (x-xmin)*sc; } function Y(y){ return cy - y*sc; }
    // optical axis
    ctx.strokeStyle='#2a3450'; ctx.lineWidth=1.4; ctx.beginPath(); ctx.moveTo(0,cy); ctx.lineTo(W,cy); ctx.stroke();
    // lens body (two arcs) — draw surface profiles
    function surf(vx,R,col){ ctx.strokeStyle=col; ctx.lineWidth=2; ctx.beginPath(); for(var yy=-ap;yy<=ap;yy+=ap/60){ var xx = vx + (R>0? (R-Math.sqrt(Math.max(0,R*R-yy*yy))) : (R+Math.sqrt(Math.max(0,R*R-yy*yy)))); (yy===-ap)?ctx.moveTo(X(xx),Y(yy)):ctx.lineTo(X(xx),Y(yy)); } ctx.stroke(); }
    ctx.save(); ctx.shadowColor='#5ee7ff'; ctx.shadowBlur=10; surf(0,R1,'#7af0ff'); surf(d,R2,'#7af0ff'); ctx.restore();
    ctx.fillStyle='rgba(94,231,255,0.06)'; ctx.fillRect(X(0),Y(ap),Math.max(2,X(d)-X(0)),Y(-ap)-Y(ap));

    // object arrow
    var oh=ap*0.6; ctx.strokeStyle='#fbbf24'; ctx.fillStyle='#fbbf24'; ctx.lineWidth=2.5; ctx.beginPath(); ctx.moveTo(X(-od),cy); ctx.lineTo(X(-od),Y(oh)); ctx.stroke(); ctx.beginPath(); ctx.moveTo(X(-od),Y(oh)); ctx.lineTo(X(-od)-5,Y(oh)+9); ctx.lineTo(X(-od)+5,Y(oh)+9); ctx.closePath(); ctx.fill();

    // ---- trace an on-axis fan (object at (-od,0)) to reveal spherical aberration ----
    var bands = colorMode==='tri' ? [['C','#ff6b6b'],['d','#34d399'],['F','#6aa8ff']] : [['d','#34d399']];
    var paraxCross=null, margCross={}, allCross=[];
    var N=11;
    bands.forEach(function(bd){ var nG=nAt(bd[0]);
      for(var i=0;i<N;i++){ var yt=(-ap + 2*ap*i/(N-1))*0.94; if(Math.abs(yt)<1e-3) continue;
        var r=trace(-od,0, (0-(-od)), (yt-0), nG); if(!r) continue;
        // draw incident + internal + exit segments
        ctx.strokeStyle=bd[1]; ctx.globalAlpha=0.62; ctx.lineWidth=1; ctx.beginPath(); ctx.moveTo(X(-od),Y(0)); ctx.lineTo(X(r.segs[1][0]),Y(r.segs[1][1])); ctx.lineTo(X(r.segs[2][0]),Y(r.segs[2][1]));
        var xend=isFinite(r.cross)&&r.cross>d&&r.cross<xmax ? r.cross : xmax; var yend=r.ey + r.dy/ (Math.hypot(r.dx,r.dy))*0 ; var tEnd=(xend-r.ex)/r.dx; var yE=r.ey+tEnd*r.dy; ctx.lineTo(X(xend),Y(yE)); ctx.stroke(); ctx.globalAlpha=1;
        if(isFinite(r.cross)){ allCross.push(r.cross); if(bd[0]==='d' && Math.abs(Math.abs(yt)-ap*0.94)<ap*0.1) margCross.d=r.cross; if(Math.abs(Math.abs(yt)-ap*0.94)<ap*0.1) margCross[bd[0]]=r.cross; }
      }
      // paraxial ray (tiny height) for this band
      var pr=trace(-od,0,od, ap*0.02, nG); if(pr && isFinite(pr.cross)){ if(bd[0]==='d') paraxCross=pr.cross; }
    });
    // paraxial image plane (green)
    if(paraxCross&&paraxCross>d&&paraxCross<xmax){ ctx.strokeStyle='rgba(52,211,153,0.8)'; ctx.setLineDash([5,4]); ctx.lineWidth=1.4; ctx.beginPath(); ctx.moveTo(X(paraxCross),Y(ap)); ctx.lineTo(X(paraxCross),Y(-ap)); ctx.stroke(); ctx.setLineDash([]); ctx.fillStyle='#34d399'; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText('paraxial', X(paraxCross)-22, Y(-ap)+14); }
    // marginal focus marker (green)
    if(margCross.d&&margCross.d>d){ ctx.fillStyle='#fbbf24'; ctx.beginPath(); ctx.arc(X(margCross.d),cy,3.5,0,7); ctx.fill(); }

    // metrics
    var nF=nAt('F'), nC=nAt('C');
    setTxt('mEFL', fEFL.toFixed(2)+' cm'); setTxt('mFno', (Math.abs(fEFL)/(2*ap)).toFixed(2));
    setTxt('mImg', paraxCross?((paraxCross-d).toFixed(2)+' cm'):'—');
    setTxt('mMarg', margCross.d?((margCross.d-d).toFixed(2)+' cm'):'—');
    setTxt('mLSA', (paraxCross&&margCross.d)?((margCross.d-paraxCross).toFixed(2)+' cm'):'—');
    setTxt('mChr', (margCross.F&&margCross.C)?((margCross.F-margCross.C).toFixed(2)+' cm'):'—');
    setTxt('mNfc', nF.toFixed(4)+', '+nC.toFixed(4));
    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
})();
</script>
</BaseLayout>
