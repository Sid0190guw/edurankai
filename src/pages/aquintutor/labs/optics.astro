---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Ray Optics Lab — AquinTutor" description="Hand-rolled ray-tracer: Snell refraction, reflection, thin-lens equation, dispersion through prisms.">
<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; font-family: 'Inter', system-ui, sans-serif; }
  .wrap { max-width: 1360px; margin: 0 auto; padding: 28px 22px 80px; }
  .eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; }
  h1.title { font-family: 'Cormorant Garamond', serif; font-size: 34px; font-weight: 600; letter-spacing: -0.02em; margin: 8px 0 6px; }
  h1.title em { font-style: italic; font-weight: 500; color: #67e8f9; }
  .sub { color: #a0a4ad; font-size: 13px; max-width: 720px; line-height: 1.55; }
  .grid { display: grid; grid-template-columns: 220px 1fr 280px; gap: 14px; margin-top: 22px; }
  .panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 16px; }
  .panel h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 12px; }
  .palette { display: flex; flex-direction: column; gap: 8px; }
  .pal-btn { background: #0a0a0c; border: 1px solid #2a2a35; color: #e8e8ee; padding: 9px 11px; border-radius: 6px; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.04em; text-align: left; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: all .15s; }
  .pal-btn:hover { border-color: #67e8f9; color: #67e8f9; }
  .pal-btn.active { border-color: #67e8f9; background: rgba(103,232,249,0.08); color: #67e8f9; }
  .pal-btn svg { flex-shrink: 0; }
  .bench-wrap { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 14px; }
  .bench-toolbar { display: flex; gap: 10px; align-items: center; margin-bottom: 10px; flex-wrap: wrap; }
  .btn { background: #67e8f9; color: #04161b; padding: 8px 14px; border: none; border-radius: 6px; font-family: 'Geist Mono', monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; cursor: pointer; }
  .btn.ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
  .btn.ghost:hover { border-color: #67e8f9; color: #67e8f9; }
  .slider-row { display: flex; align-items: center; gap: 8px; font-family: 'Geist Mono', monospace; font-size: 10px; color: #a0a4ad; }
  .slider-row input[type=range] { width: 100px; accent-color: #67e8f9; }
  .slider-row .val { color: #67e8f9; font-weight: 700; min-width: 26px; text-align: right; }
  #bench { width: 100%; height: 540px; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 10px; display: block; cursor: crosshair; }
  .props { display: flex; flex-direction: column; gap: 10px; }
  .prop-row { display: flex; flex-direction: column; gap: 4px; }
  .prop-row label { font-family: 'Geist Mono', monospace; font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: #a0a4ad; }
  .prop-row input, .prop-row select { background: #0a0a0c; border: 1px solid #2a2a35; color: #fff; padding: 7px 10px; border-radius: 5px; font-family: 'Geist Mono', monospace; font-size: 11px; }
  .prop-row input:focus, .prop-row select:focus { outline: none; border-color: #67e8f9; }
  .no-sel { color: #6b7280; font-size: 12px; font-style: italic; padding: 14px 0; text-align: center; }
  .legend { display: flex; gap: 14px; flex-wrap: wrap; font-family: 'Geist Mono', monospace; font-size: 10px; color: #a0a4ad; margin-top: 10px; }
  .legend span { display: inline-flex; align-items: center; gap: 5px; }
  .legend i { display: inline-block; width: 14px; height: 2px; background: #67e8f9; }
  .formula { font-family: 'Cormorant Garamond', serif; font-style: italic; color: #cfd6da; font-size: 14px; margin-top: 8px; }
  .del-btn { background: #1a0a0a; color: #fca5a5; border: 1px solid #4c1d1d; padding: 6px 10px; border-radius: 5px; font-family: 'Geist Mono', monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; }
  .del-btn:hover { background: #4c1d1d; color: #fff; }
  .help { color: #6b7280; font-size: 11px; line-height: 1.5; margin-top: 10px; }
  @media (max-width: 1100px) { .grid { grid-template-columns: 1fr; } }
</style>

<main class="wrap">
  <div class="eyebrow">Virtual Lab &middot; Geometric Optics</div>
  <h1 class="title">Ray <em>Optics</em> Bench</h1>
  <p class="sub">Live Snell's-law refraction (n<sub>1</sub>&middot;sin&theta;<sub>1</sub> = n<sub>2</sub>&middot;sin&theta;<sub>2</sub>), specular reflection, thin-lens 1/v &minus; 1/u = 1/f and triangular-prism dispersion. Place elements on the bench, drag to position, edit properties on the right.</p>

  <div class="grid">
    <aside class="panel">
      <h3>Components</h3>
      <div class="palette" id="palette">
        <button class="pal-btn" data-kind="source"><svg width="18" height="18" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><circle cx="12" cy="12" r="4"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M5 5l2 2M17 17l2 2M5 19l2-2M17 7l2-2"/></svg>Light Source</button>
        <button class="pal-btn" data-kind="convex"><svg width="18" height="18" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M12 3c-3 2-3 16 0 18M12 3c3 2 3 16 0 18"/></svg>Convex Lens</button>
        <button class="pal-btn" data-kind="concave"><svg width="18" height="18" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M10 3c2 2 2 16 0 18M14 3c-2 2-2 16 0 18"/></svg>Concave Lens</button>
        <button class="pal-btn" data-kind="mirror_plane"><svg width="18" height="18" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M12 3v18"/><path d="M14 5l4 2M14 9l4 2M14 13l4 2M14 17l4 2"/></svg>Plane Mirror</button>
        <button class="pal-btn" data-kind="mirror_concave"><svg width="18" height="18" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M14 3c-4 4-4 14 0 18"/><path d="M16 6l3 2M16 12l3 0M16 18l3-2"/></svg>Concave Mirror</button>
        <button class="pal-btn" data-kind="mirror_convex"><svg width="18" height="18" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M10 3c4 4 4 14 0 18"/><path d="M5 6l-3 2M5 12l-3 0M5 18l-3-2"/></svg>Convex Mirror</button>
        <button class="pal-btn" data-kind="aperture"><svg width="18" height="18" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M12 3v6M12 15v6"/><path d="M9 3h6M9 21h6"/></svg>Aperture</button>
        <button class="pal-btn" data-kind="prism"><svg width="18" height="18" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M12 3l9 18H3z"/></svg>Prism</button>
        <button class="pal-btn" data-kind="screen"><svg width="18" height="18" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><rect x="9" y="3" width="6" height="18" rx="1"/></svg>Screen</button>
      </div>
      <div class="help">Click a component, then click the bench to place. Click an element to select &amp; edit. Drag to move.</div>
    </aside>

    <section class="bench-wrap">
      <div class="bench-toolbar">
        <button class="btn" id="clearBtn">Clear Bench</button>
        <button class="btn ghost" id="preset1">Preset: Convex 2f</button>
        <button class="btn ghost" id="preset2">Preset: Prism Dispersion</button>
        <button class="btn ghost" id="preset3">Preset: Telescope</button>
        <div class="slider-row"><label>Rays</label><input type="range" id="raysSlider" min="1" max="50" value="9"/><span class="val" id="raysVal">9</span></div>
        <div class="slider-row"><label>Spread (&deg;)</label><input type="range" id="spreadSlider" min="0" max="60" value="20"/><span class="val" id="spreadVal">20</span></div>
        <div class="slider-row"><label>Mode</label>
          <select id="colorMode" style="background:#0a0a0c;border:1px solid #2a2a35;color:#fff;padding:5px 8px;border-radius:5px;font-family:'Geist Mono',monospace;font-size:10px;">
            <option value="angle">Colour by angle</option>
            <option value="wavelength">Colour by wavelength</option>
          </select>
        </div>
      </div>
      <svg id="bench" viewBox="0 0 1100 540" xmlns="http://www.w3.org/2000/svg"></svg>
      <div class="legend">
        <span><i style="background:#ef4444"></i>principal axis</span>
        <span><i style="background:#fbbf24"></i>focal points</span>
        <span><i style="background:#67e8f9"></i>light rays</span>
        <span><i style="background:#a78bfa"></i>refractive material</span>
      </div>
    </section>

    <aside class="panel">
      <h3>Properties</h3>
      <div id="props"><div class="no-sel">Select an element on the bench to edit its properties.</div></div>
      <div class="formula" id="formulaDisplay" style="margin-top:18px;"></div>
    </aside>
  </div>
</main>

<script is:inline>
(function(){
  'use strict';

  const svg = document.getElementById('bench');
  const palette = document.getElementById('palette');
  const propsBox = document.getElementById('props');
  const formulaBox = document.getElementById('formulaDisplay');
  const raysSlider = document.getElementById('raysSlider');
  const raysVal = document.getElementById('raysVal');
  const spreadSlider = document.getElementById('spreadSlider');
  const spreadVal = document.getElementById('spreadVal');
  const colorMode = document.getElementById('colorMode');

  const W = 1100, H = 540;
  const AXIS_Y = H/2;

  let placeKind = null;        // currently chosen tool from palette
  let selectedId = null;
  let drag = null;             // {id, dx, dy}
  let nextId = 1;

  // Bench state
  let elements = [];
  // Each element: { id, kind, x, y, params: {...} }
  //   source:        { angle (deg, axis offset), wavelength? }
  //   convex:        { f, diameter }
  //   concave:       { f (negative), diameter }
  //   mirror_plane:  { angle (deg, rotation), diameter }
  //   mirror_concave:{ f, diameter }
  //   mirror_convex: { f (negative), diameter }
  //   aperture:      { opening, diameter }
  //   prism:         { size, n (refractive index) }
  //   screen:        { diameter }

  // ---------- Palette ----------
  palette.addEventListener('click', e => {
    const b = e.target.closest('.pal-btn');
    if (!b) return;
    [...palette.querySelectorAll('.pal-btn')].forEach(x => x.classList.remove('active'));
    if (placeKind === b.dataset.kind) {
      placeKind = null;
    } else {
      placeKind = b.dataset.kind;
      b.classList.add('active');
    }
  });

  function clearActive(){
    [...palette.querySelectorAll('.pal-btn')].forEach(x => x.classList.remove('active'));
    placeKind = null;
  }

  // ---------- Add element ----------
  function defaultParams(kind){
    switch(kind){
      case 'source':         return { angle: 0, wavelength: 550 };
      case 'convex':         return { f: 120, diameter: 120 };
      case 'concave':        return { f: -120, diameter: 120 };
      case 'mirror_plane':   return { angle: 90, diameter: 110 };
      case 'mirror_concave': return { f: 140, diameter: 130 };
      case 'mirror_convex':  return { f: -140, diameter: 130 };
      case 'aperture':       return { opening: 30, diameter: 140 };
      case 'prism':          return { size: 80, n: 1.52 };
      case 'screen':         return { diameter: 160 };
    }
    return {};
  }

  function addElement(kind, x, y){
    const el = { id: nextId++, kind, x, y, params: defaultParams(kind) };
    elements.push(el);
    selectedId = el.id;
    render();
  }

  // ---------- Bench click / drag ----------
  function svgPoint(evt){
    const r = svg.getBoundingClientRect();
    const x = (evt.clientX - r.left) * (W / r.width);
    const y = (evt.clientY - r.top) * (H / r.height);
    return { x, y };
  }

  svg.addEventListener('mousedown', evt => {
    const p = svgPoint(evt);
    const hit = elements.find(e => Math.hypot(e.x - p.x, e.y - p.y) < 38);
    if (hit) {
      selectedId = hit.id;
      drag = { id: hit.id, dx: p.x - hit.x, dy: p.y - hit.y };
      render();
    } else if (placeKind) {
      addElement(placeKind, p.x, p.y);
      clearActive();
    } else {
      selectedId = null;
      render();
    }
  });
  window.addEventListener('mousemove', evt => {
    if (!drag) return;
    const p = svgPoint(evt);
    const el = elements.find(e => e.id === drag.id);
    if (!el) return;
    el.x = Math.max(20, Math.min(W-20, p.x - drag.dx));
    el.y = Math.max(20, Math.min(H-20, p.y - drag.dy));
    render();
  });
  window.addEventListener('mouseup', () => drag = null);

  document.getElementById('clearBtn').addEventListener('click', ()=>{
    elements = []; selectedId = null; render();
  });

  // ---------- Presets ----------
  document.getElementById('preset1').addEventListener('click', ()=>{
    elements = [
      { id: nextId++, kind: 'source',   x: 110, y: AXIS_Y, params: { angle: 0, wavelength: 550 } },
      { id: nextId++, kind: 'convex',   x: 470, y: AXIS_Y, params: { f: 160, diameter: 140 } },
      { id: nextId++, kind: 'screen',   x: 830, y: AXIS_Y, params: { diameter: 200 } }
    ];
    selectedId = null; render();
  });
  document.getElementById('preset2').addEventListener('click', ()=>{
    elements = [
      { id: nextId++, kind: 'source',   x: 110, y: AXIS_Y, params: { angle: -10, wavelength: 550 } },
      { id: nextId++, kind: 'prism',    x: 500, y: AXIS_Y, params: { size: 110, n: 1.52 } },
      { id: nextId++, kind: 'screen',   x: 900, y: AXIS_Y+40, params: { diameter: 260 } }
    ];
    colorMode.value = 'wavelength';
    selectedId = null; render();
  });
  document.getElementById('preset3').addEventListener('click', ()=>{
    elements = [
      { id: nextId++, kind: 'source',   x: 90,  y: AXIS_Y, params: { angle: 0, wavelength: 550 } },
      { id: nextId++, kind: 'convex',   x: 380, y: AXIS_Y, params: { f: 220, diameter: 150 } },
      { id: nextId++, kind: 'convex',   x: 780, y: AXIS_Y, params: { f: 80,  diameter: 110 } },
      { id: nextId++, kind: 'screen',   x: 980, y: AXIS_Y, params: { diameter: 200 } }
    ];
    selectedId = null; render();
  });

  // ---------- Properties panel ----------
  function renderProps(){
    const el = elements.find(e => e.id === selectedId);
    if (!el) {
      propsBox.innerHTML = '<div class="no-sel">Select an element on the bench to edit its properties.</div>';
      formulaBox.innerHTML = '';
      return;
    }
    const kindLabel = ({
      source: 'Light Source', convex: 'Convex Lens', concave: 'Concave Lens',
      mirror_plane: 'Plane Mirror', mirror_concave: 'Concave Mirror', mirror_convex: 'Convex Mirror',
      aperture: 'Aperture', prism: 'Prism (triangular)', screen: 'Screen'
    })[el.kind];

    let html = `<div style="font-family:'Cormorant Garamond',serif;font-size:18px;color:#67e8f9;margin-bottom:8px;">${kindLabel}</div>`;
    const p = el.params;

    function row(label, key, min, max, step, suffix){
      return `<div class="prop-row"><label>${label}</label><input type="number" data-key="${key}" value="${p[key]}" min="${min}" max="${max}" step="${step}"/></div>`;
    }

    if (el.kind === 'source') {
      html += row('Tilt angle (&deg;)', 'angle', -45, 45, 1);
      html += `<div class="prop-row"><label>Base wavelength (nm)</label><input type="number" data-key="wavelength" value="${p.wavelength}" min="380" max="750" step="5"/></div>`;
    }
    if (el.kind === 'convex' || el.kind === 'mirror_concave') {
      html += row('Focal length f (px)', 'f', 30, 400, 5);
      html += row('Diameter (px)', 'diameter', 40, 240, 5);
    }
    if (el.kind === 'concave' || el.kind === 'mirror_convex') {
      html += `<div class="prop-row"><label>Focal length f (negative, px)</label><input type="number" data-key="f" value="${p.f}" min="-400" max="-30" step="5"/></div>`;
      html += row('Diameter (px)', 'diameter', 40, 240, 5);
    }
    if (el.kind === 'mirror_plane') {
      html += row('Rotation (&deg;)', 'angle', 0, 180, 1);
      html += row('Diameter (px)', 'diameter', 40, 240, 5);
    }
    if (el.kind === 'aperture') {
      html += row('Opening (px)', 'opening', 4, 200, 2);
      html += row('Outer diameter (px)', 'diameter', 40, 240, 5);
    }
    if (el.kind === 'prism') {
      html += row('Side length (px)', 'size', 30, 200, 5);
      html += row('Refractive index n', 'n', 1.0, 2.5, 0.01);
    }
    if (el.kind === 'screen') {
      html += row('Height (px)', 'diameter', 40, 320, 5);
    }
    html += `<div style="display:flex;gap:8px;margin-top:14px;"><button class="del-btn" id="delBtn">Delete</button></div>`;
    propsBox.innerHTML = html;

    propsBox.querySelectorAll('input').forEach(inp => {
      inp.addEventListener('input', () => {
        const k = inp.dataset.key;
        const v = parseFloat(inp.value);
        if (!isNaN(v)) {
          p[k] = v;
          render();
        }
      });
    });
    const delBtn = document.getElementById('delBtn');
    if (delBtn) delBtn.addEventListener('click', () => {
      elements = elements.filter(e => e.id !== el.id);
      selectedId = null;
      render();
    });

    // Formula display
    if (el.kind === 'convex' || el.kind === 'concave') {
      formulaBox.innerHTML = `<div style="font-family:'Geist Mono',monospace;font-size:10px;color:#a0a4ad;letter-spacing:.12em;text-transform:uppercase;">Thin-Lens</div>1/v &minus; 1/u = 1/f<br><span style="font-family:'Geist Mono',monospace;font-size:11px;color:#67e8f9;">f = ${p.f.toFixed(0)} px</span>`;
    } else if (el.kind === 'prism') {
      formulaBox.innerHTML = `<div style="font-family:'Geist Mono',monospace;font-size:10px;color:#a0a4ad;letter-spacing:.12em;text-transform:uppercase;">Snell</div>n<sub>1</sub>&middot;sin&theta;<sub>1</sub> = n<sub>2</sub>&middot;sin&theta;<sub>2</sub><br><span style="font-family:'Geist Mono',monospace;font-size:11px;color:#67e8f9;">n = ${p.n.toFixed(2)}</span>`;
    } else if (el.kind.startsWith('mirror')) {
      formulaBox.innerHTML = `<div style="font-family:'Geist Mono',monospace;font-size:10px;color:#a0a4ad;letter-spacing:.12em;text-transform:uppercase;">Reflection</div>&theta;<sub>i</sub> = &theta;<sub>r</sub>`;
    } else {
      formulaBox.innerHTML = '';
    }
  }

  // ============================================================
  // PHYSICS — ray tracing
  // ============================================================
  // A ray segment: { x1, y1, x2, y2, color }
  // We propagate a Ray { x, y, dx, dy, color, alive } through elements ordered left-to-right.

  // Wavelength (nm) -> RGB approximation. (Bruton 1996)
  function wlToRgb(wl){
    let r=0,g=0,b=0;
    if (wl >= 380 && wl < 440){ r=-(wl-440)/60; g=0; b=1; }
    else if (wl < 490){ r=0; g=(wl-440)/50; b=1; }
    else if (wl < 510){ r=0; g=1; b=-(wl-510)/20; }
    else if (wl < 580){ r=(wl-510)/70; g=1; b=0; }
    else if (wl < 645){ r=1; g=-(wl-645)/65; b=0; }
    else if (wl <= 780){ r=1; g=0; b=0; }
    let f=1;
    if (wl<420) f = 0.3 + 0.7*(wl-380)/40;
    else if (wl>700) f = 0.3 + 0.7*(780-wl)/80;
    return `rgb(${Math.round(255*r*f)},${Math.round(255*g*f)},${Math.round(255*b*f)})`;
  }

  // Cauchy-like dispersion: n(lambda) = n + B/lambda^2 (lambda in nm).
  function dispersedN(nBase, wl){
    // Tuned so n shifts by ~0.02 across visible band.
    const B = 9000;
    return nBase + B/(wl*wl) - B/(550*550);
  }

  // Intersect ray (x,y,dx,dy) with vertical line x = ex; returns t (>0) or null.
  function intersectVertical(r, ex){
    if (Math.abs(r.dx) < 1e-9) return null;
    const t = (ex - r.x) / r.dx;
    return t > 1e-6 ? t : null;
  }
  // Intersect with line segment (ax,ay)-(bx,by), returns {t,u, nx,ny} where t is along ray, u in [0,1] along segment.
  function intersectSegment(r, ax, ay, bx, by){
    const sx = bx - ax, sy = by - ay;
    const denom = r.dx * sy - r.dy * sx;
    if (Math.abs(denom) < 1e-9) return null;
    const t = ((ax - r.x) * sy - (ay - r.y) * sx) / denom;
    const u = ((ax - r.x) * r.dy - (ay - r.y) * r.dx) / denom;
    if (t > 1e-6 && u >= 0 && u <= 1) {
      // Segment normal (left-hand normal to segment direction)
      const segLen = Math.hypot(sx, sy);
      const nx = -sy / segLen;
      const ny =  sx / segLen;
      return { t, u, nx, ny, ix: r.x + t*r.dx, iy: r.y + t*r.dy };
    }
    return null;
  }

  // Refract incident direction (dx,dy) across normal (nx,ny) from index n1 to n2.
  // Returns new (dx,dy) or null on total internal reflection.
  function refract(dx, dy, nx, ny, n1, n2){
    // Make normal point against the incoming ray.
    let cosi = -(dx*nx + dy*ny);
    let Nx = nx, Ny = ny;
    if (cosi < 0) { cosi = -cosi; Nx = -nx; Ny = -ny; }
    const eta = n1 / n2;
    const k = 1 - eta*eta*(1 - cosi*cosi);
    if (k < 0) return null; // TIR
    const tx = eta*dx + (eta*cosi - Math.sqrt(k)) * Nx;
    const ty = eta*dy + (eta*cosi - Math.sqrt(k)) * Ny;
    const len = Math.hypot(tx, ty);
    return { dx: tx/len, dy: ty/len };
  }

  function reflect(dx, dy, nx, ny){
    const dot = dx*nx + dy*ny;
    const rx = dx - 2*dot*nx;
    const ry = dy - 2*dot*ny;
    const len = Math.hypot(rx, ry);
    return { dx: rx/len, dy: ry/len };
  }

  // Apply thin-lens refraction: ray crosses lens plane at (lx, ly_hit). For a thin lens at x=lx, y=cy:
  //   incoming slope m_in = dy/dx. Height h = ly_hit - cy.
  //   For an object at distance u (negative if to the left), image at v with 1/v - 1/u = 1/f.
  //   Better: paraxial transfer matrix [1 0; -1/f 1] applied to (h, slope).
  //   Output slope = slope_in - h/f. Same height.
  function lensRefract(r, lensX, lensY, f){
    // r.x assumed = lensX after intersection
    const h = r.y - lensY;
    const slope = r.dy / r.dx; // dy/dx
    const newSlope = slope - h / f;
    // Direction must remain forward; assume r.dx > 0.
    const sign = Math.sign(r.dx) || 1;
    const dx = sign;
    const dy = newSlope * sign;
    const L = Math.hypot(dx, dy);
    return { dx: dx/L, dy: dy/L };
  }

  // Sort elements by x (rays travel left-to-right). Sources excluded from optical chain.
  function opticalChain(){
    return elements
      .filter(e => e.kind !== 'source')
      .slice()
      .sort((a,b) => a.x - b.x);
  }

  function traceRay(startX, startY, dirX, dirY, color, maxBounces){
    const segs = [];
    let r = { x: startX, y: startY, dx: dirX, dy: dirY };
    let bounces = 0;
    let lastIdx = -1;

    while (bounces < maxBounces) {
      const chain = opticalChain();
      // Find nearest unblocked element ahead.
      let best = null;
      for (let i = 0; i < chain.length; i++) {
        if (i === lastIdx) continue;
        const e = chain[i];
        const hit = elementIntersect(r, e);
        if (hit && (!best || hit.t < best.hit.t)) best = { hit, e, idx: i };
      }
      if (!best) {
        // Cast to canvas edge
        segs.push({ x1: r.x, y1: r.y, x2: r.x + r.dx * 3000, y2: r.y + r.dy * 3000, color });
        break;
      }
      const h = best.hit;
      segs.push({ x1: r.x, y1: r.y, x2: h.ix, y2: h.iy, color });
      const action = elementInteract(r, best.e, h, color);
      lastIdx = best.idx;
      if (!action) break;
      r = { x: h.ix + action.dx*0.5, y: h.iy + action.dy*0.5, dx: action.dx, dy: action.dy };
      if (action.terminate) break;
      bounces++;
    }
    return segs;
  }

  // Compute (t, ix, iy, nx, ny) for ray vs element. Return null if miss.
  function elementIntersect(r, e){
    const p = e.params;
    if (e.kind === 'convex' || e.kind === 'concave') {
      // Vertical lens plane
      const t = intersectVertical(r, e.x);
      if (!t) return null;
      const ix = r.x + t*r.dx, iy = r.y + t*r.dy;
      if (Math.abs(iy - e.y) > p.diameter/2) return null;
      return { t, ix, iy, nx: 1, ny: 0 };
    }
    if (e.kind === 'screen') {
      const t = intersectVertical(r, e.x);
      if (!t) return null;
      const ix = r.x + t*r.dx, iy = r.y + t*r.dy;
      if (Math.abs(iy - e.y) > p.diameter/2) return null;
      return { t, ix, iy, nx: 1, ny: 0 };
    }
    if (e.kind === 'aperture') {
      const t = intersectVertical(r, e.x);
      if (!t) return null;
      const ix = r.x + t*r.dx, iy = r.y + t*r.dy;
      if (Math.abs(iy - e.y) > p.diameter/2) return null; // misses entire stop -> passes
      return { t, ix, iy, nx: 1, ny: 0 };
    }
    if (e.kind === 'mirror_plane') {
      // Segment of length diameter at angle p.angle around centre
      const a = (p.angle - 90) * Math.PI/180;
      const hx = Math.cos(a) * p.diameter/2;
      const hy = Math.sin(a) * p.diameter/2;
      return intersectSegment(r, e.x - hx, e.y - hy, e.x + hx, e.y + hy);
    }
    if (e.kind === 'mirror_concave' || e.kind === 'mirror_convex') {
      // Approximate spherical mirror as vertical segment (paraxial)
      const t = intersectVertical(r, e.x);
      if (!t) return null;
      const ix = r.x + t*r.dx, iy = r.y + t*r.dy;
      if (Math.abs(iy - e.y) > p.diameter/2) return null;
      return { t, ix, iy, nx: 1, ny: 0 };
    }
    if (e.kind === 'prism') {
      // Equilateral triangle, apex up
      const s = p.size;
      const h = s * Math.sqrt(3)/2;
      const A = { x: e.x,         y: e.y - h*2/3 };  // apex
      const B = { x: e.x - s/2,   y: e.y + h/3 };    // bottom-left
      const C = { x: e.x + s/2,   y: e.y + h/3 };    // bottom-right
      let best = null;
      [[A,B],[B,C],[C,A]].forEach((seg, i) => {
        const r0 = intersectSegment(r, seg[0].x, seg[0].y, seg[1].x, seg[1].y);
        if (r0 && (!best || r0.t < best.t)) { best = r0; best.side = i; }
      });
      return best;
    }
    return null;
  }

  function elementInteract(r, e, hit, color){
    const p = e.params;
    if (e.kind === 'screen') {
      // Ray terminates at screen
      return { dx: r.dx, dy: r.dy, terminate: true };
    }
    if (e.kind === 'aperture') {
      // Centre opening passes, rim blocks
      if (Math.abs(hit.iy - e.y) <= p.opening/2) {
        return { dx: r.dx, dy: r.dy };
      }
      return { dx: r.dx, dy: r.dy, terminate: true };
    }
    if (e.kind === 'convex' || e.kind === 'concave') {
      const d = lensRefract(r, e.x, e.y, p.f);
      return d;
    }
    if (e.kind === 'mirror_plane' || e.kind === 'mirror_concave' || e.kind === 'mirror_convex') {
      let dx = r.dx, dy = r.dy;
      if (e.kind === 'mirror_concave' || e.kind === 'mirror_convex') {
        // Apply lens-like slope adjustment first (focusing/diverging) then reflect about vertical.
        const slope = r.dy / r.dx;
        const h = r.y - e.y;
        const newSlope = slope - h / p.f; // converging mirror with f>0
        const L = Math.hypot(1, newSlope);
        dx = (r.dx > 0 ? 1 : -1) / L;
        dy = (r.dx > 0 ? 1 : -1) * newSlope / L;
      }
      // Reflect about element normal
      const ref = reflect(dx, dy, hit.nx, hit.ny);
      return ref;
    }
    if (e.kind === 'prism') {
      // Determine wavelength used: stored on the ray via color param shortcut.
      const wl = r.wl || 550;
      const nGlass = dispersedN(p.n, wl);
      // Decide which side: if entering (going into glass) or leaving.
      // Heuristic: track via r.inGlass flag.
      const n1 = r.inGlass ? nGlass : 1.0;
      const n2 = r.inGlass ? 1.0 : nGlass;
      const ref = refract(r.dx, r.dy, hit.nx, hit.ny, n1, n2);
      if (!ref) {
        // TIR: reflect
        const rr = reflect(r.dx, r.dy, hit.nx, hit.ny);
        const out = { dx: rr.dx, dy: rr.dy };
        out.wl = wl;
        out.inGlass = r.inGlass;
        return out;
      }
      const out = { dx: ref.dx, dy: ref.dy };
      out.wl = wl;
      out.inGlass = !r.inGlass;
      return out;
    }
    return null;
  }

  // Spawn rays from each source
  function spawnRays(){
    const sources = elements.filter(e => e.kind === 'source');
    const N = parseInt(raysSlider.value, 10);
    const spread = parseFloat(spreadSlider.value) * Math.PI/180;
    const mode = colorMode.value;
    const out = [];
    sources.forEach(s => {
      const baseAng = s.params.angle * Math.PI/180;
      for (let i = 0; i < N; i++) {
        const t = N === 1 ? 0 : (i/(N-1) - 0.5) * 2; // -1..1
        let wl, color;
        if (mode === 'wavelength') {
          wl = 380 + (i/(Math.max(1,N-1))) * (740 - 380);
          color = wlToRgb(wl);
        } else {
          wl = s.params.wavelength;
          // Cyan -> magenta gradient by index
          const hue = 180 + t*60;
          color = `hsl(${hue},80%,65%)`;
        }
        const ang = baseAng + t * spread;
        const dx = Math.cos(ang), dy = Math.sin(ang);
        // Trace
        const segs = traceRayWith(s.x + 8, s.y, dx, dy, color, wl);
        out.push(...segs);
      }
    });
    return out;
  }

  function traceRayWith(sx, sy, dx, dy, color, wl){
    const segs = [];
    let r = { x: sx, y: sy, dx, dy, wl, inGlass: false };
    let bounces = 0;
    let lastKey = '';
    while (bounces < 30) {
      const chain = opticalChain();
      let best = null;
      for (let i = 0; i < chain.length; i++) {
        const e = chain[i];
        const key = e.id + ':' + bounces;
        // Allow re-hitting same prism for entry/exit, but prevent infinite loops on same surface
        const hit = elementIntersect(r, e);
        if (!hit) continue;
        if (hit.t < 0.5 && lastKey === e.id+':'+(hit.side||'v')) continue;
        if (!best || hit.t < best.hit.t) best = { hit, e };
      }
      if (!best) {
        segs.push({ x1: r.x, y1: r.y, x2: r.x + r.dx*2000, y2: r.y + r.dy*2000, color });
        break;
      }
      const h = best.hit;
      segs.push({ x1: r.x, y1: r.y, x2: h.ix, y2: h.iy, color });
      const action = elementInteract(r, best.e, h, color);
      if (!action || action.terminate) break;
      lastKey = best.e.id + ':' + (h.side !== undefined ? h.side : 'v');
      r = { x: h.ix + action.dx*0.3, y: h.iy + action.dy*0.3,
            dx: action.dx, dy: action.dy,
            wl: action.wl !== undefined ? action.wl : r.wl,
            inGlass: action.inGlass !== undefined ? action.inGlass : r.inGlass };
      bounces++;
    }
    return segs;
  }

  // ============================================================
  // RENDER
  // ============================================================
  function render(){
    let html = '';
    // Principal axis
    html += `<line x1="0" y1="${AXIS_Y}" x2="${W}" y2="${AXIS_Y}" stroke="#ef4444" stroke-width="1" stroke-dasharray="6 5" opacity="0.5"/>`;
    // Grid ticks
    for (let x = 0; x <= W; x += 50) {
      html += `<line x1="${x}" y1="${AXIS_Y-3}" x2="${x}" y2="${AXIS_Y+3}" stroke="#3a3a45" stroke-width="1"/>`;
    }

    // Rays
    const segs = spawnRays();
    segs.forEach(s => {
      html += `<line x1="${s.x1.toFixed(1)}" y1="${s.y1.toFixed(1)}" x2="${s.x2.toFixed(1)}" y2="${s.y2.toFixed(1)}" stroke="${s.color}" stroke-width="1.2" opacity="0.85"/>`;
    });

    // Elements
    elements.forEach(e => {
      const sel = e.id === selectedId;
      html += elementSvg(e, sel);
    });

    svg.innerHTML = html;
    renderProps();
  }

  function elementSvg(e, sel){
    const p = e.params;
    const stroke = sel ? '#67e8f9' : '#cfd6da';
    const sw = sel ? 2.2 : 1.6;
    const halo = sel ? `<circle cx="${e.x}" cy="${e.y}" r="22" fill="none" stroke="#67e8f9" stroke-width="0.6" opacity="0.5"/>` : '';

    if (e.kind === 'source') {
      const a = p.angle * Math.PI/180;
      return `<g>
        <circle cx="${e.x}" cy="${e.y}" r="9" fill="#fef3c7" stroke="${stroke}" stroke-width="${sw}"/>
        <circle cx="${e.x}" cy="${e.y}" r="14" fill="none" stroke="#fbbf24" stroke-width="0.6" opacity="0.7"/>
        <line x1="${e.x+12}" y1="${e.y}" x2="${e.x+22+Math.cos(a)*8}" y2="${e.y+Math.sin(a)*8}" stroke="#fbbf24" stroke-width="1.4"/>
        ${halo}
      </g>`;
    }
    if (e.kind === 'convex') {
      const d = p.diameter/2;
      // Symmetric lens shape
      const c = 14;
      const path = `M ${e.x} ${e.y-d} Q ${e.x+c} ${e.y} ${e.x} ${e.y+d} Q ${e.x-c} ${e.y} ${e.x} ${e.y-d} Z`;
      const f = p.f;
      return `<g>
        <line x1="${e.x}" y1="${e.y-d-8}" x2="${e.x}" y2="${e.y+d+8}" stroke="${stroke}" stroke-width="0.7" opacity="0.4"/>
        <path d="${path}" fill="rgba(103,232,249,0.12)" stroke="${stroke}" stroke-width="${sw}"/>
        <circle cx="${e.x+f}" cy="${AXIS_Y}" r="3" fill="#fbbf24"/>
        <circle cx="${e.x-f}" cy="${AXIS_Y}" r="3" fill="#fbbf24"/>
        ${halo}
      </g>`;
    }
    if (e.kind === 'concave') {
      const d = p.diameter/2;
      const c = 10;
      const path = `M ${e.x-c} ${e.y-d} Q ${e.x+c} ${e.y-d/2} ${e.x+c} ${e.y} Q ${e.x+c} ${e.y+d/2} ${e.x-c} ${e.y+d}
                    L ${e.x+c} ${e.y+d} Q ${e.x-c} ${e.y+d/2} ${e.x-c} ${e.y} Q ${e.x-c} ${e.y-d/2} ${e.x+c} ${e.y-d} Z`;
      const f = p.f;
      return `<g>
        <line x1="${e.x}" y1="${e.y-d-8}" x2="${e.x}" y2="${e.y+d+8}" stroke="${stroke}" stroke-width="0.7" opacity="0.4"/>
        <path d="${path}" fill="rgba(103,232,249,0.10)" stroke="${stroke}" stroke-width="${sw}"/>
        <circle cx="${e.x+f}" cy="${AXIS_Y}" r="3" fill="#fbbf24"/>
        <circle cx="${e.x-f}" cy="${AXIS_Y}" r="3" fill="#fbbf24"/>
        ${halo}
      </g>`;
    }
    if (e.kind === 'mirror_plane') {
      const a = (p.angle - 90) * Math.PI/180;
      const hx = Math.cos(a) * p.diameter/2;
      const hy = Math.sin(a) * p.diameter/2;
      const x1 = e.x - hx, y1 = e.y - hy, x2 = e.x + hx, y2 = e.y + hy;
      // Hatching on back side
      let hatch = '';
      for (let t = 0.05; t < 1; t += 0.12) {
        const cx = x1 + (x2-x1)*t, cy = y1 + (y2-y1)*t;
        const nx = -Math.sin(a)*7, ny = Math.cos(a)*7;
        hatch += `<line x1="${cx}" y1="${cy}" x2="${cx-nx}" y2="${cy-ny}" stroke="${stroke}" stroke-width="0.6" opacity="0.6"/>`;
      }
      return `<g><line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" stroke="${stroke}" stroke-width="${sw+0.5}"/>${hatch}${halo}</g>`;
    }
    if (e.kind === 'mirror_concave' || e.kind === 'mirror_convex') {
      const d = p.diameter/2;
      const curve = e.kind === 'mirror_concave' ? -12 : 12;
      const path = `M ${e.x} ${e.y-d} Q ${e.x+curve} ${e.y} ${e.x} ${e.y+d}`;
      // Hatching
      let hatch = '';
      for (let t = 0.1; t < 1; t += 0.12) {
        const yy = e.y - d + 2*d*t;
        hatch += `<line x1="${e.x}" y1="${yy}" x2="${e.x - 6 * (e.kind === 'mirror_concave' ? -1 : 1)}" y2="${yy}" stroke="${stroke}" stroke-width="0.6" opacity="0.5"/>`;
      }
      return `<g>
        <path d="${path}" fill="none" stroke="${stroke}" stroke-width="${sw+0.4}"/>
        ${hatch}
        <circle cx="${e.x+p.f}" cy="${AXIS_Y}" r="3" fill="#fbbf24"/>
        ${halo}
      </g>`;
    }
    if (e.kind === 'aperture') {
      const d = p.diameter/2;
      const o = p.opening/2;
      return `<g>
        <line x1="${e.x}" y1="${e.y-d}" x2="${e.x}" y2="${e.y-o}" stroke="${stroke}" stroke-width="${sw+1}"/>
        <line x1="${e.x}" y1="${e.y+o}" x2="${e.x}" y2="${e.y+d}" stroke="${stroke}" stroke-width="${sw+1}"/>
        <line x1="${e.x-4}" y1="${e.y-d}" x2="${e.x+4}" y2="${e.y-d}" stroke="${stroke}" stroke-width="${sw}"/>
        <line x1="${e.x-4}" y1="${e.y+d}" x2="${e.x+4}" y2="${e.y+d}" stroke="${stroke}" stroke-width="${sw}"/>
        ${halo}
      </g>`;
    }
    if (e.kind === 'prism') {
      const s = p.size;
      const h = s * Math.sqrt(3)/2;
      const A = { x: e.x,         y: e.y - h*2/3 };
      const B = { x: e.x - s/2,   y: e.y + h/3 };
      const C = { x: e.x + s/2,   y: e.y + h/3 };
      return `<g>
        <polygon points="${A.x},${A.y} ${B.x},${B.y} ${C.x},${C.y}"
                 fill="rgba(167,139,250,0.18)" stroke="${sel?'#67e8f9':'#a78bfa'}" stroke-width="${sw}"/>
        <text x="${e.x}" y="${e.y+8}" text-anchor="middle" fill="#a78bfa" font-family="Cormorant Garamond" font-style="italic" font-size="14">n=${p.n.toFixed(2)}</text>
        ${halo}
      </g>`;
    }
    if (e.kind === 'screen') {
      const d = p.diameter/2;
      return `<g>
        <rect x="${e.x-3}" y="${e.y-d}" width="6" height="${d*2}" fill="rgba(255,255,255,0.08)" stroke="${stroke}" stroke-width="${sw}"/>
        <line x1="${e.x+3}" y1="${e.y-d}" x2="${e.x+9}" y2="${e.y-d}" stroke="${stroke}" stroke-width="${sw}"/>
        <line x1="${e.x+3}" y1="${e.y+d}" x2="${e.x+9}" y2="${e.y+d}" stroke="${stroke}" stroke-width="${sw}"/>
        ${halo}
      </g>`;
    }
    return '';
  }

  // ---------- Slider wiring ----------
  raysSlider.addEventListener('input', () => { raysVal.textContent = raysSlider.value; render(); });
  spreadSlider.addEventListener('input', () => { spreadVal.textContent = spreadSlider.value; render(); });
  colorMode.addEventListener('change', render);

  // ---------- Initial demo ----------
  elements = [
    { id: nextId++, kind: 'source', x: 110, y: AXIS_Y, params: { angle: 0, wavelength: 550 } },
    { id: nextId++, kind: 'convex', x: 470, y: AXIS_Y, params: { f: 160, diameter: 140 } },
    { id: nextId++, kind: 'screen', x: 830, y: AXIS_Y, params: { diameter: 200 } }
  ];
  render();
})();
</script>

<div id="demoHint" style="position:fixed;left:16px;bottom:16px;max-width:330px;background:#11131a;color:#e8e8ee;border:1px solid #FF4F00;border-radius:12px;padding:14px 16px;z-index:9999;box-shadow:0 12px 34px rgba(0,0,0,0.45);">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:7px;gap:10px;">
    <span style="font-family:'Geist Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#FF4F00;font-weight:700;">Try this &middot; demo</span>
    <button onclick="this.closest('#demoHint').remove()" style="background:transparent;border:none;color:#9aa6b6;cursor:pointer;font-size:18px;line-height:1;padding:0;">&times;</button>
  </div>
  <p style="margin:0;font-size:12.5px;line-height:1.55;color:#cfd6da;font-family:'Inter Tight',sans-serif,system-ui;">Click the <b>Prism dispersion</b> preset. White light enters the prism and splits into a rainbow — real Cauchy dispersion, each wavelength bending differently.</p>
</div>

</BaseLayout>
