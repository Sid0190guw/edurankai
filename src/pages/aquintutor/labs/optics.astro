---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Thin-lens optics lab — converging / diverging lens, real ray tracing of the
// three principal rays with glow, image construction (real or virtual), and the
// lens equation solved live. Depth-lit high-DPI canvas, no libraries.
---
<BaseLayout title="Optics lab · Virtual Labs · AquinTutor" description="Trace the three principal rays through a thin lens and watch the image form — real or virtual, magnified or diminished — with the lens equation live.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1320px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:18px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; }
  .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:290px minmax(0,1fr); gap:18px; }
  @media(max-width:900px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:16px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 12px; }
  .lb-row{ display:grid; gap:9px; }
  .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.1em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; }
  .lb-row label span{ color:#5ee7ff; } .lb-row input[type=range]{ width:100%; accent-color:#5ee7ff; }
  .lb-row select{ width:100%; background:#080a12; border:1px solid #1e2740; color:#fff; padding:8px 10px; border-radius:6px; font-size:12px; font-family:inherit; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); }
  .lb-stage canvas{ display:block; width:100%; height:auto; }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11.5px; padding:5px 0; border-bottom:1px solid #141a2c; }
  .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#5ee7ff; font-weight:700; text-align:right; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">Physics · Optics</p>
      <h1 class="lb-title">Thin <em>lens</em>.</h1>
    </div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Lens &amp; object</h3><div class="lb-row">
        <label>Type</label><select id="type"><option value="conv" selected>Converging (convex)</option><option value="div">Diverging (concave)</option></select>
        <label>Focal length |f| (cm) <span id="fV">15</span></label><input id="f" type="range" min="5" max="40" step="1" value="15"/>
        <label>Object distance (cm) <span id="doV">30</span></label><input id="do" type="range" min="5" max="70" step="1" value="30"/>
        <label>Object height (cm) <span id="hoV">8</span></label><input id="ho" type="range" min="2" max="16" step="1" value="8"/>
      </div></div>
      <div class="lb-panel"><h3>Image</h3>
        <div class="lb-metric"><span class="lb-metric-l">Image dist v (cm)</span><span class="lb-metric-v" id="mDi">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Magnification m</span><span class="lb-metric-v" id="mM">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Image height (cm)</span><span class="lb-metric-v" id="mHi">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Nature</span><span class="lb-metric-v" id="mNat">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Orientation</span><span class="lb-metric-v" id="mOri">—</span></div>
      </div>
    </aside>
    <section><div class="lb-stage"><canvas id="scene" width="900" height="520"></canvas></div></section>
  </div>
</main>
<script is:inline>
(function(){
  function v(id){ return parseFloat(document.getElementById(id).value); }
  function sync(){ document.getElementById('fV').textContent=v('f').toFixed(0); document.getElementById('doV').textContent=v('do').toFixed(0); document.getElementById('hoV').textContent=v('ho').toFixed(0); }
  document.querySelectorAll('input,select').forEach(function(e){ e.addEventListener('input',sync); e.addEventListener('change',sync); }); sync();
  function hidpi(cv){ var r=cv.getBoundingClientRect(), d=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w; cv.width=Math.round(w*d); cv.height=Math.round(h*d); var ctx=cv.getContext('2d'); ctx.setTransform(d,0,0,d,0,0); return {ctx:ctx,w:w,h:h}; }
  function ray(ctx,x1,y1,x2,y2,col,dash){ ctx.save(); if(dash) ctx.setLineDash([5,5]); ctx.shadowColor=col; ctx.shadowBlur=dash?0:7; ctx.strokeStyle=col; ctx.lineWidth=dash?1:1.6; ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.stroke(); ctx.restore(); }

  function draw(){
    var cv=document.getElementById('scene'), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h;
    var bg=ctx.createLinearGradient(0,0,0,H); bg.addColorStop(0,'#0c1226'); bg.addColorStop(1,'#06080f'); ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    var conv=document.getElementById('type').value==='conv'; var f=(conv?1:-1)*v('f'), doo=v('do'), ho=v('ho');
    var di=1/(1/f - 1/doo); // 1/do + 1/di = 1/f  ->  di = 1/(1/f - 1/do)
    var m=-di/doo, hi=m*ho;
    var cx=W*0.5, cy=H*0.5, sc=Math.min((W*0.42)/Math.max(70,doo*1.1, Math.abs(di)*1.1), (H*0.42)/Math.max(20,ho*1.4,Math.abs(hi)*1.2));
    function X(x){ return cx + x*sc; } function Y(y){ return cy - y*sc; }
    // optical axis
    ctx.strokeStyle='#2a3450'; ctx.lineWidth=1.5; ctx.beginPath(); ctx.moveTo(0,cy); ctx.lineTo(W,cy); ctx.stroke();
    // foci
    [[f,'F′'],[-f,'F']].forEach(function(p){ ctx.fillStyle='#5f7597'; ctx.beginPath(); ctx.arc(X(p[0]),cy,3,0,7); ctx.fill(); ctx.font="10px 'Geist Mono',monospace"; ctx.fillText(p[1],X(p[0])-6,cy+16); });
    // lens shape
    var lh=Math.min(H*0.42, sc*Math.max(ho,10)*1.4);
    ctx.save(); ctx.shadowColor='#5ee7ff'; ctx.shadowBlur=16;
    var lg=ctx.createLinearGradient(cx-14,0,cx+14,0); lg.addColorStop(0,'rgba(94,231,255,0.12)'); lg.addColorStop(0.5,'rgba(94,231,255,0.32)'); lg.addColorStop(1,'rgba(94,231,255,0.12)');
    ctx.fillStyle=lg; ctx.strokeStyle='#7af0ff'; ctx.lineWidth=2; ctx.beginPath();
    if(conv){ ctx.moveTo(cx,cy-lh); ctx.quadraticCurveTo(cx+16,cy,cx,cy+lh); ctx.quadraticCurveTo(cx-16,cy,cx,cy-lh); }
    else { ctx.moveTo(cx-9,cy-lh); ctx.quadraticCurveTo(cx+5,cy,cx-9,cy+lh); ctx.lineTo(cx+9,cy+lh); ctx.quadraticCurveTo(cx-5,cy,cx+9,cy-lh); ctx.closePath(); }
    ctx.fill(); ctx.stroke(); ctx.restore();
    // object arrow (left, up)
    var ox=-doo; ctx.strokeStyle='#fbbf24'; ctx.fillStyle='#fbbf24'; ctx.lineWidth=3; ctx.beginPath(); ctx.moveTo(X(ox),cy); ctx.lineTo(X(ox),Y(ho)); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(X(ox),Y(ho)); ctx.lineTo(X(ox)-5,Y(ho)+9); ctx.lineTo(X(ox)+5,Y(ho)+9); ctx.closePath(); ctx.fill();
    // three principal rays: object tip (ox,ho) -> lens -> image tip (di,hi)
    var tipX=X(ox), tipY=Y(ho), imX=X(di), imY=Y(hi);
    // ray parallel: to lens at (0,ho) then to image tip
    ray(ctx,tipX,tipY,cx,Y(ho),'#67e8f9'); ray(ctx,cx,Y(ho),imX,imY,'#67e8f9');
    if(di<0){ ray(ctx,cx,Y(ho),X(v('do')*0+Math.min(-70,di)),imY,'#67e8f9'); ray(ctx,cx,Y(ho),imX,imY,'#67e8f9',true); }
    // ray through center
    ray(ctx,tipX,tipY,imX,imY,'#a78bfa'); if(di<0) ray(ctx,cx,cy,imX,imY,'#a78bfa',true);
    // ray through focus
    var y3 = -ho*f/(doo-f); ray(ctx,tipX,tipY,cx,Y(y3),'#f472b6'); ray(ctx,cx,Y(y3),imX,imY,'#f472b6'); if(di<0) ray(ctx,cx,Y(y3),imX,imY,'#f472b6',true);
    // image arrow
    var real=di>0; ctx.strokeStyle=real?'#34d399':'#f59e0b'; ctx.fillStyle=ctx.strokeStyle; ctx.lineWidth=3; if(!real) ctx.setLineDash([4,4]);
    ctx.beginPath(); ctx.moveTo(imX,cy); ctx.lineTo(imX,imY); ctx.stroke();
    ctx.beginPath(); var dir=hi>=0?1:-1; ctx.moveTo(imX,imY); ctx.lineTo(imX-5,imY+9*dir); ctx.lineTo(imX+5,imY+9*dir); ctx.closePath(); ctx.fill(); ctx.setLineDash([]);

    document.getElementById('mDi').textContent=isFinite(di)?di.toFixed(1):'∞';
    document.getElementById('mM').textContent=isFinite(m)?m.toFixed(2):'∞';
    document.getElementById('mHi').textContent=isFinite(hi)?hi.toFixed(1):'∞';
    document.getElementById('mNat').textContent=real?'Real':'Virtual';
    document.getElementById('mOri').textContent=(hi>=0?'Upright':'Inverted')+(Math.abs(m)>1?' · enlarged':Math.abs(m)<1?' · diminished':'');
  }
  function loop(){ draw(); requestAnimationFrame(loop); } requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
