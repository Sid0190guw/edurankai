    sw.addEventListener('click', function () {
      activePalette = name;
      document.querySelectorAll('.an-swatch').forEach(function (x) { x.classList.remove('active'); });
      sw.classList.add('active');
    });
    palEl.appendChild(sw);
  });

  // Controls
  document.getElementById('playBtn').addEventListener('click', function () { paused = !paused; this.textContent = paused ? 'Play' : 'Pause'; });
  document.getElementById('resetBtn').addEventListener('click', function () { renderScene(); });
  document.getElementById('speedSlider').addEventListener('input', function () {
    speed = parseFloat(this.value);
    document.getElementById('spdLbl').textContent = speed.toFixed(2) + '×';
  });
  document.getElementById('bgCol').addEventListener('input', function () { bgColor = this.value; });
  document.getElementById('resSel').addEventListener('change', function () {
    var dims = this.value.split('x');
    canvas.width = parseInt(dims[0], 10); canvas.height = parseInt(dims[1], 10);
  });

  // Save frame
  document.getElementById('frameBtn').addEventListener('click', function () {
    var fmt = document.getElementById('frameFmt').value;
    var quality = fmt === 'image/png' ? 1 : (fmt === 'image/jpeg' ? 0.95 : 0.9);
    canvas.toBlob(function (blob) {
      var a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = 'animator_' + currentScene.id + '_' + Date.now() + '.' + fmt.split('/')[1];
      a.click();
      addRecording(a.download, a.href);
    }, fmt, quality);
  });

  // Record video
  var recordBtn = document.getElementById('recordBtn');
  recordBtn.addEventListener('click', function () {
    if (!recorder || recorder.state === 'inactive') {
      try {
        var stream = canvas.captureStream(60);
        var mime = 'video/webm;codecs=vp9';
        if (!MediaRecorder.isTypeSupported(mime)) mime = 'video/webm;codecs=vp8';
        if (!MediaRecorder.isTypeSupported(mime)) mime = 'video/webm';
        recorder = new MediaRecorder(stream, { mimeType: mime, videoBitsPerSecond: 8_000_000 });
        recChunks = [];
        recorder.ondataavailable = function (e) { if (e.data.size > 0) recChunks.push(e.data); };
        recorder.onstop = function () {
          var blob = new Blob(recChunks, { type: mime });
          var url = URL.createObjectURL(blob);
          var a = document.createElement('a');
          a.href = url;
          a.download = 'animator_' + currentScene.id + '_' + Date.now() + '.webm';
          a.click();
          addRecording(a.download, url);
        };
        recordingStart = performance.now();
        recorder.start();
        recordBtn.textContent = 'Stop';
        recordBtn.classList.add('active');
        document.getElementById('recStatus').classList.add('active');
      } catch (e) { alert('Recording failed: ' + e.message); }
    } else {
      recorder.stop();
      recordBtn.textContent = 'Record';
      recordBtn.classList.remove('active');
      document.getElementById('recStatus').classList.remove('active');
    }
  });

  document.getElementById('exportSeq').addEventListener('click', function () {
    var n = parseInt(prompt('How many frames to export?', '60'), 10);
    if (!n || n < 1 || n > 600) return;
    var i = 0;
    function tick() {
      if (i >= n) return;
      canvas.toBlob(function (blob) {
        var a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'frame_' + currentScene.id + '_' + String(i).padStart(4, '0') + '.png';
        a.click();
        i++;
        if (i < n) setTimeout(tick, 60);
      }, 'image/png');
    }
    tick();
  });

  document.getElementById('exportGif').addEventListener('click', function () {
    alert('GIF export queues frames at current resolution. For high-quality video, use the Record button (VP9 WebM at 8 Mbps).');
  });

  function addRecording(name, url) {
    recordings.unshift({ name: name, url: url, when: new Date().toLocaleTimeString() });
    var list = document.getElementById('fileList');
    list.innerHTML = recordings.slice(0, 8).map(function (r) {
      return '<div>&middot; <a href="' + r.url + '" download="' + r.name + '">' + r.name + '</a> <span style="color:#7A6F68;">' + r.when + '</span></div>';
    }).join('');
  }

  // Boot
  renderScene();
  requestAnimationFrame(loop);

})();
</script>

