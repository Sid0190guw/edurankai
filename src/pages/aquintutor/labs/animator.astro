---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Animation studio · Virtual Labs · AquinTutor" description="Real-time animation generation. 16 scenes — fractals, attractors, waves, fluid dynamics, particle fields, fractal trees, Turing patterns. Record to video, save frames, export GIF. Pure browser.">

<style>
  body { background: #08080a; color: #e8e8ee; margin: 0; }
  .an-wrap { display: grid; grid-template-rows: 56px 1fr; height: 100vh; }
  .an-bar { background: #11131a; border-bottom: 1px solid #2a2a35; display: flex; align-items: center; padding: 0 18px; gap: 16px; font-family: 'Geist Mono', monospace; font-size: 11px; color: #cfd6da; letter-spacing: 0.06em; }
  .an-bar a { color: #67e8f9; text-decoration: none; letter-spacing: 0.08em; }
  .an-title { font-family: 'Cormorant Garamond', serif; font-size: 17px; color: #fff; font-weight: 600; letter-spacing: -0.01em; margin-left: 4px; }
  .an-title em { color: #67e8f9; font-style: italic; }
  .an-bar-right { margin-left: auto; display: flex; gap: 6px; align-items: center; }
  .an-bar-btn { background: transparent; border: 1px solid #2a2a35; color: #cfd6da; padding: 6px 14px; border-radius: 6px; cursor: pointer; font-family: inherit; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 700; }
  .an-bar-btn:hover { background: #1a1a25; }
  .an-bar-btn.primary { background: #67e8f9; color: #04161b; border-color: #67e8f9; }
  .an-bar-btn.record { background: #b91c1c; color: #fff; border-color: #b91c1c; }
  .an-bar-btn.record.active { background: #f87171; animation: rec-pulse 1.4s infinite; }
  @keyframes rec-pulse { 0%,100% { box-shadow: 0 0 0 0 rgba(248,113,113,0.4); } 50% { box-shadow: 0 0 0 8px rgba(248,113,113,0); } }

  .an-main { display: grid; grid-template-columns: 240px 1fr 280px; overflow: hidden; }
  .an-scenes { background: #0c0e14; border-right: 1px solid #2a2a35; overflow-y: auto; padding: 10px 0; }
  .an-scene-cat { font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; padding: 12px 16px 6px; font-weight: 700; }
  .an-scene { padding: 9px 16px; cursor: pointer; font-size: 12.5px; color: #cfd6da; display: flex; gap: 8px; align-items: center; border-left: 3px solid transparent; }
  .an-scene:hover { background: #11131a; }
  .an-scene.active { background: #11131a; border-left-color: #67e8f9; color: #67e8f9; }
  .an-scene-icon { width: 16px; height: 16px; flex-shrink: 0; color: inherit; }

  .an-stage { background: #08080a; display: flex; align-items: center; justify-content: center; overflow: hidden; position: relative; }
  #stageCanvas { background: #000; box-shadow: 0 0 0 1px #2a2a35; max-width: 100%; max-height: 100%; }
  .an-fps { position: absolute; top: 12px; left: 12px; font-family: 'Geist Mono', monospace; font-size: 10.5px; color: #67e8f9; background: rgba(8,8,10,0.7); padding: 4px 10px; border-radius: 4px; pointer-events: none; letter-spacing: 0.06em; }
  .an-rec-status { position: absolute; top: 12px; right: 12px; font-family: 'Geist Mono', monospace; font-size: 11px; color: #f87171; background: rgba(8,8,10,0.85); padding: 5px 12px; border-radius: 4px; display: none; align-items: center; gap: 6px; }
  .an-rec-status.active { display: flex; }
  .an-rec-dot { width: 8px; height: 8px; border-radius: 50%; background: #f87171; animation: rec-pulse 1.2s infinite; }

  .an-controls { background: #0c0e14; border-left: 1px solid #2a2a35; overflow-y: auto; padding: 16px; }
  .an-controls h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 12px; }
  .an-controls h4 { font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.14em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; margin: 16px 0 8px; padding-top: 12px; border-top: 1px solid #1a1a25; }
  .an-row { margin-bottom: 12px; }
  .an-row label { font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.08em; color: #9aa6b6; font-weight: 600; display: flex; justify-content: space-between; margin-bottom: 4px; }
  .an-row label span { color: #67e8f9; }
  .an-row input[type=range] { width: 100%; }
  .an-row input[type=number], .an-row input[type=text], .an-row select { width: 100%; box-sizing: border-box; background: #08080a; border: 1px solid #2a2a35; color: #fff; padding: 6px 10px; border-radius: 4px; font-size: 11.5px; font-family: inherit; }
  .an-row input[type=color] { width: 100%; height: 32px; background: #08080a; border: 1px solid #2a2a35; border-radius: 4px; cursor: pointer; padding: 1px; }
  .an-palette { display: grid; grid-template-columns: repeat(8, 1fr); gap: 3px; margin-top: 4px; }
  .an-swatch { aspect-ratio: 1; border-radius: 3px; cursor: pointer; border: 1px solid #2a2a35; }
  .an-swatch.active { border: 2px solid #67e8f9; transform: scale(1.1); }

  .an-export-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-top: 6px; }
  .an-export-btn { background: #11131a; border: 1px solid #2a2a35; color: #cfd6da; padding: 8px 6px; border-radius: 6px; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; text-align: center; }
  .an-export-btn:hover { border-color: #67e8f9; color: #67e8f9; }

  #fileList { font-family: 'Geist Mono', monospace; font-size: 11px; color: #9aa6b6; line-height: 1.7; margin-top: 6px; }
  #fileList a { color: #67e8f9; text-decoration: none; }
</style>

<div class="an-wrap">

  <div class="an-bar">
    <a href="/aquintutor/labs">&larr; Labs</a>
    <span class="an-title">Animation <em>studio</em>.</span>
    <span style="color:#7A6F68;margin-left:8px;">Real-time. Hand-coded. Record + export.</span>
    <div class="an-bar-right">
      <button id="playBtn" class="an-bar-btn primary">Pause</button>
      <button id="resetBtn" class="an-bar-btn">Reset</button>
      <button id="frameBtn" class="an-bar-btn">Save frame</button>
      <button id="recordBtn" class="an-bar-btn record">Record</button>
    </div>
  </div>

  <div class="an-main">

    <aside class="an-scenes" id="sceneList"></aside>

    <div class="an-stage">
      <canvas id="stageCanvas" width="1280" height="720"></canvas>
      <div id="fpsLbl" class="an-fps">— fps</div>
      <div id="recStatus" class="an-rec-status"><div class="an-rec-dot"></div><span id="recTime">REC 00:00</span></div>
    </div>

    <aside class="an-controls">
      <h3 id="sceneTitle">Scene</h3>
      <div id="sceneControls"></div>

      <h4>Render</h4>
      <div class="an-row">
        <label>Resolution</label>
        <select id="resSel">
          <option value="640x360">640 × 360 · draft</option>
          <option value="1280x720" selected>1280 × 720 · HD</option>
          <option value="1920x1080">1920 × 1080 · FHD</option>
          <option value="2560x1440">2560 × 1440 · QHD</option>
          <option value="3840x2160">3840 × 2160 · 4K</option>
        </select>
      </div>
      <div class="an-row">
        <label>Speed <span id="spdLbl">1.00&times;</span></label>
        <input id="speedSlider" type="range" min="0.1" max="5" step="0.05" value="1"/>
      </div>
      <div class="an-row">
        <label>Background</label>
        <input id="bgCol" type="color" value="#000000"/>
      </div>
      <div class="an-row">
        <label>Palette</label>
        <div class="an-palette" id="palette"></div>
      </div>

      <h4>Export</h4>
      <div class="an-row">
        <label>Frame format</label>
        <select id="frameFmt">
          <option value="image/png" selected>PNG · lossless</option>
          <option value="image/jpeg">JPEG · 95% q</option>
          <option value="image/webp">WebP · 90% q</option>
        </select>
      </div>
      <div class="an-row">
        <label>Video format · auto</label>
        <select id="recFmt" disabled>
          <option>WebM · VP9</option>
        </select>
      </div>
      <div class="an-export-grid">
        <button id="exportGif" class="an-export-btn">Export GIF</button>
        <button id="exportSeq" class="an-export-btn">Export frames</button>
      </div>

      <h4>Recordings</h4>
      <div id="fileList">No recordings yet.</div>
    </aside>

  </div>
</div>

<script is:inline>
/* ============================================================
   AquinTutor Animation Studio — pure-browser, no 3rd-party libs.
   16 real working scenes. MediaRecorder + canvas.captureStream
   for video. Hand-rolled simple GIF encoder for short clips.
   ============================================================ */
(function () {

  // ============ SCENES ============
  // Each scene: { id, label, cat, controls: [{id,label,min,max,step,value}], init(state), draw(ctx, t, p, w, h) }

  var palettes = {
    cosmic: ['#0a0a3a', '#1d2671', '#5b4a92', '#a78bfa', '#67e8f9', '#86efac', '#fbbf24', '#fb923c'],
    warm:   ['#1a0a00', '#451a03', '#7c2d12', '#c2410c', '#fb923c', '#fde047', '#f0fdfa', '#fff7ed'],
    cool:   ['#04161b', '#0c4a6e', '#0369a1', '#0ea5e9', '#67e8f9', '#a78bfa', '#e0e7ff', '#fff'],
    fire:   ['#000', '#7f1d1d', '#dc2626', '#f97316', '#facc15', '#fde047', '#fff', '#fff'],
    forest: ['#022c22', '#064e3b', '#065f46', '#10b981', '#86efac', '#fef9c3', '#fff7ed', '#fff'],
    mono:   ['#000', '#262626', '#525252', '#a3a3a3', '#d4d4d4', '#f5f5f5', '#fff', '#fff'],
  };
  var activePalette = 'cosmic';
  function pal(i) { var p = palettes[activePalette]; return p[Math.abs(i) % p.length]; }
  function palLerp(t) {
    var p = palettes[activePalette];
    t = Math.max(0, Math.min(0.999, t));
    var pos = t * (p.length - 1);
    var i = Math.floor(pos), f = pos - i;
    var a = hex2rgb(p[i]), b = hex2rgb(p[i + 1] || p[i]);
    return 'rgb(' + Math.round(a[0] + (b[0]-a[0])*f) + ',' + Math.round(a[1] + (b[1]-a[1])*f) + ',' + Math.round(a[2] + (b[2]-a[2])*f) + ')';
  }
  function hex2rgb(h) { var n = parseInt(h.slice(1), 16); return [(n>>16)&255, (n>>8)&255, n&255]; }

  var SCENES = [];

  // -------- 1. Mandelbrot zoom --------
  SCENES.push({
    id: 'mandelbrot', label: 'Mandelbrot zoom', cat: 'Fractals',
    controls: [
      { id: 'iter', label: 'Max iterations', min: 50, max: 400, step: 10, value: 180 },
      { id: 'zoom', label: 'Zoom speed', min: 0, max: 0.5, step: 0.01, value: 0.12 },
      { id: 'cx', label: 'Center X', min: -2, max: 1, step: 0.001, value: -0.7435 },
      { id: 'cy', label: 'Center Y', min: -1.5, max: 1.5, step: 0.001, value: 0.1314 },
    ],
    draw: function (ctx, t, p, w, h) {
      var scale = 3 / Math.exp(t * p.zoom);
      var img = ctx.createImageData(w, h);
      for (var py = 0; py < h; py++) {
        for (var px = 0; px < w; px++) {
          var x0 = p.cx + (px - w/2) / w * scale;
          var y0 = p.cy + (py - h/2) / h * scale;
          var x = 0, y = 0, n = 0;
          while (x*x + y*y < 4 && n < p.iter) {
            var xt = x*x - y*y + x0;
            y = 2*x*y + y0; x = xt; n++;
          }
          var idx = (py * w + px) * 4;
          if (n === p.iter) { img.data[idx]=0; img.data[idx+1]=0; img.data[idx+2]=0; img.data[idx+3]=255; }
          else {
            var sm = n + 1 - Math.log(Math.log(Math.sqrt(x*x+y*y))) / Math.log(2);
            var c = palLerp((sm % 60) / 60);
            var rgb = c.match(/\d+/g);
            img.data[idx]=+rgb[0]; img.data[idx+1]=+rgb[1]; img.data[idx+2]=+rgb[2]; img.data[idx+3]=255;
          }
        }
      }
      ctx.putImageData(img, 0, 0);
    },
  });

  // -------- 2. Julia set --------
  SCENES.push({
    id: 'julia', label: 'Julia set', cat: 'Fractals',
    controls: [
      { id: 'iter', label: 'Max iterations', min: 50, max: 250, step: 10, value: 150 },
      { id: 'rot', label: 'Rotation speed', min: 0, max: 0.3, step: 0.01, value: 0.05 },
      { id: 'r', label: 'Radius', min: 0.5, max: 0.85, step: 0.01, value: 0.7885 },
    ],
    draw: function (ctx, t, p, w, h) {
      var cx = p.r * Math.cos(t * p.rot);
      var cy = p.r * Math.sin(t * p.rot);
      var img = ctx.createImageData(w, h);
      var scale = 3;
      for (var py = 0; py < h; py++) {
        for (var px = 0; px < w; px++) {
          var x = (px - w/2) / w * scale;
          var y = (py - h/2) / h * scale;
          var n = 0;
          while (x*x + y*y < 4 && n < p.iter) {
            var xt = x*x - y*y + cx;
            y = 2*x*y + cy; x = xt; n++;
          }
          var idx = (py * w + px) * 4;
          if (n === p.iter) { img.data[idx]=0; img.data[idx+1]=0; img.data[idx+2]=0; img.data[idx+3]=255; }
          else {
            var c = palLerp((n * 4) / p.iter);
            var rgb = c.match(/\d+/g);
            img.data[idx]=+rgb[0]; img.data[idx+1]=+rgb[1]; img.data[idx+2]=+rgb[2]; img.data[idx+3]=255;
          }
        }
      }
      ctx.putImageData(img, 0, 0);
    },
  });

  // -------- 3. Lorenz attractor --------
  SCENES.push({
    id: 'lorenz', label: 'Lorenz attractor', cat: 'Dynamics',
    controls: [
      { id: 'sigma', label: 'σ', min: 5, max: 20, step: 0.1, value: 10 },
      { id: 'rho', label: 'ρ', min: 20, max: 50, step: 0.1, value: 28 },
      { id: 'beta', label: 'β', min: 1, max: 5, step: 0.1, value: 8/3 },
      { id: 'rotY', label: 'Rotation Y', min: 0, max: 1, step: 0.01, value: 0.2 },
    ],
    state: null,
    draw: function (ctx, t, p, w, h) {
      if (!this.state || this.state._reset) { this.state = { points: [[0.1,0,0]], _reset: false }; }
      var dt = 0.005, steps = 20;
      var last = this.state.points[this.state.points.length - 1];
      for (var i = 0; i < steps; i++) {
        var x = last[0], y = last[1], z = last[2];
        var dx = p.sigma * (y - x);
        var dy = x * (p.rho - z) - y;
        var dz = x * y - p.beta * z;
        last = [x + dx*dt, y + dy*dt, z + dz*dt];
        this.state.points.push(last);
      }
      if (this.state.points.length > 8000) this.state.points = this.state.points.slice(-8000);
      ctx.fillStyle = 'rgba(0,0,0,0.08)'; ctx.fillRect(0, 0, w, h);
      var cy = Math.cos(t * p.rotY), sy = Math.sin(t * p.rotY);
      var cx = Math.cos(0.3), sx = Math.sin(0.3);
      ctx.beginPath();
      for (var i = 1; i < this.state.points.length; i++) {
        var pt = this.state.points[i];
        var px = pt[0], py = pt[1] - 25, pz = pt[2];
        var x1 = px * cy - pz * sy;
        var z1 = px * sy + pz * cy;
        var y1 = py * cx - z1 * sx;
        var scale = 8;
        var sx2 = w/2 + x1 * scale;
        var sy2 = h/2 + y1 * scale;
        if (i === 1) ctx.moveTo(sx2, sy2); else ctx.lineTo(sx2, sy2);
      }
      ctx.strokeStyle = palLerp(0.6); ctx.lineWidth = 0.7; ctx.stroke();
    },
  });

  // -------- 4. Wave interference --------
  SCENES.push({
    id: 'waves', label: 'Wave interference', cat: 'Physics',
    controls: [
      { id: 'src1', label: 'Source 1 frequency', min: 0.1, max: 2, step: 0.05, value: 0.8 },
      { id: 'src2', label: 'Source 2 frequency', min: 0.1, max: 2, step: 0.05, value: 0.7 },
      { id: 'k', label: 'Wave number', min: 0.05, max: 0.3, step: 0.01, value: 0.15 },
      { id: 'amp', label: 'Amplitude', min: 50, max: 255, step: 5, value: 200 },
    ],
    draw: function (ctx, t, p, w, h) {
      var img = ctx.createImageData(w, h);
      var s1x = w * 0.3, s1y = h * 0.4;
      var s2x = w * 0.7, s2y = h * 0.6;
      for (var py = 0; py < h; py += 2) {
        for (var px = 0; px < w; px += 2) {
          var d1 = Math.hypot(px - s1x, py - s1y);
          var d2 = Math.hypot(px - s2x, py - s2y);
          var v = Math.sin(d1 * p.k - t * p.src1) + Math.sin(d2 * p.k - t * p.src2);
          var c = palLerp((v + 2) / 4);
          var rgb = c.match(/\d+/g);
          for (var dy = 0; dy < 2; dy++) for (var dx = 0; dx < 2; dx++) {
            var idx = ((py + dy) * w + (px + dx)) * 4;
            img.data[idx]=+rgb[0]; img.data[idx+1]=+rgb[1]; img.data[idx+2]=+rgb[2]; img.data[idx+3]=255;
          }
        }
      }
      ctx.putImageData(img, 0, 0);
    },
  });

  // -------- 5. Particle field --------
  SCENES.push({
    id: 'particles', label: 'Particle field', cat: 'Particles',
    controls: [
      { id: 'count', label: 'Particles', min: 50, max: 800, step: 10, value: 250 },
      { id: 'speed', label: 'Speed', min: 0.1, max: 5, step: 0.1, value: 1.5 },
      { id: 'noise', label: 'Curl noise', min: 0, max: 0.05, step: 0.001, value: 0.012 },
    ],
    state: null,
    draw: function (ctx, t, p, w, h) {
      if (!this.state || this.state.particles.length !== Math.floor(p.count) || this.state._reset) {
        var parts = [];
        for (var i = 0; i < Math.floor(p.count); i++) {
          parts.push({ x: Math.random() * w, y: Math.random() * h, vx: 0, vy: 0, hue: Math.random() });
        }
        this.state = { particles: parts, _reset: false };
      }
      ctx.fillStyle = 'rgba(0,0,0,0.05)'; ctx.fillRect(0, 0, w, h);
      this.state.particles.forEach(function (q) {
        var nx = Math.sin(q.x * p.noise + t * 0.5) + Math.cos(q.y * p.noise + t * 0.3);
        var ny = Math.cos(q.x * p.noise + t * 0.5) - Math.sin(q.y * p.noise + t * 0.3);
        q.vx = q.vx * 0.92 + nx * p.speed;
        q.vy = q.vy * 0.92 + ny * p.speed;
        q.x += q.vx; q.y += q.vy;
        if (q.x < 0) q.x += w; if (q.x > w) q.x -= w;
        if (q.y < 0) q.y += h; if (q.y > h) q.y -= h;
        ctx.fillStyle = palLerp(q.hue);
        ctx.fillRect(q.x, q.y, 1.5, 1.5);
      });
    },
  });

  // -------- 6. Cellular automaton (Game of Life) --------
  SCENES.push({
    id: 'gol', label: 'Game of Life', cat: 'Cellular',
    controls: [
      { id: 'cellSize', label: 'Cell size', min: 4, max: 20, step: 1, value: 8 },
      { id: 'speed', label: 'Update rate', min: 1, max: 30, step: 1, value: 6 },
    ],
    state: null,
    draw: function (ctx, t, p, w, h) {
      var cs = p.cellSize;
      var cols = Math.floor(w / cs), rows = Math.floor(h / cs);
      if (!this.state || this.state.cols !== cols || this.state._reset) {
        var grid = [];
        for (var i = 0; i < rows; i++) { grid.push([]); for (var j = 0; j < cols; j++) grid[i].push(Math.random() < 0.25 ? 1 : 0); }
        this.state = { grid: grid, cols: cols, rows: rows, lastT: t, _reset: false };
      }
      if (t - this.state.lastT > 1/p.speed) {
        var g = this.state.grid, ng = [];
        for (var i = 0; i < rows; i++) {
          ng.push([]);
          for (var j = 0; j < cols; j++) {
            var n = 0;
            for (var di = -1; di <= 1; di++) for (var dj = -1; dj <= 1; dj++) {
              if (di === 0 && dj === 0) continue;
              var ni = (i + di + rows) % rows, nj = (j + dj + cols) % cols;
              n += g[ni][nj];
            }
            ng[i].push(g[i][j] === 1 ? (n === 2 || n === 3 ? 1 : 0) : (n === 3 ? 1 : 0));
          }
        }
        this.state.grid = ng; this.state.lastT = t;
      }
      ctx.fillStyle = '#000'; ctx.fillRect(0, 0, w, h);
      ctx.fillStyle = palLerp(0.6);
      for (var i = 0; i < rows; i++) for (var j = 0; j < cols; j++) {
        if (this.state.grid[i][j]) ctx.fillRect(j * cs, i * cs, cs - 1, cs - 1);
      }
    },
  });

  // -------- 7. L-system tree --------
  SCENES.push({
    id: 'tree', label: 'Fractal tree', cat: 'Fractals',
    controls: [
      { id: 'depth', label: 'Depth', min: 4, max: 12, step: 1, value: 10 },
      { id: 'angle', label: 'Branch angle', min: 10, max: 45, step: 1, value: 25 },
      { id: 'sway', label: 'Wind sway', min: 0, max: 0.5, step: 0.01, value: 0.15 },
      { id: 'len', label: 'Trunk length', min: 80, max: 200, step: 5, value: 130 },
    ],
    draw: function (ctx, t, p, w, h) {
      ctx.fillStyle = '#000'; ctx.fillRect(0, 0, w, h);
      function branch(x, y, len, ang, d) {
        if (d <= 0 || len < 1) return;
        var x2 = x + Math.cos(ang) * len;
        var y2 = y + Math.sin(ang) * len;
        ctx.strokeStyle = palLerp(1 - d / p.depth);
        ctx.lineWidth = Math.max(0.5, d / 3);
