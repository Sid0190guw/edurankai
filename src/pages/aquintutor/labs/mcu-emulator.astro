---
import BaseLayout from '@/layouts/BaseLayout.astro';
// MCU Emulator — flagship embedded-systems lab. A working 8-bit microcontroller
// you program in assembly: registers R0-R7, 256 bytes of RAM, a stack, flags,
// memory-mapped GPIO (8 LEDs + 4 buttons) and a hardware timer. Two-pass label
// resolution, an instruction-level CPU, and a live hardware panel that reacts
// to your code. Hand-built, no libraries.
---
<BaseLayout title="MCU Emulator · Virtual Labs · AquinTutor" description="Program a real 8-bit microcontroller in assembly: registers, RAM, stack, flags, memory-mapped GPIO (LEDs + buttons) and a timer. Write code, assemble, single-step or run, and watch the hardware react. Built from scratch, no libraries.">

<style is:global>
  body { background:#08080a; color:#e8e8ee; margin:0; }
  .era-fab { display:none !important; }
  .mc-wrap { display:grid; grid-template-rows:52px 1fr; height:100vh; height:100dvh; }
  .mc-bar { background:#11131a; border-bottom:1px solid #2a2a35; display:flex; align-items:center; padding:0 14px; gap:12px; font-family:'Geist Mono',monospace; font-size:11px; color:#cfd6da; flex-wrap:wrap; }
  .mc-bar a { color:#7fb3ff; text-decoration:none; }
  .mc-title { font-family:'Cormorant Garamond',Georgia,serif; font-size:17px; color:#fff; font-weight:600; }
  .mc-title em { color:#7fb3ff; font-style:italic; }
  .mc-bar-right { margin-left:auto; display:flex; gap:6px; align-items:center; flex-wrap:wrap; }
  .mc-btn { background:transparent; border:1px solid #2a2a35; color:#cfd6da; padding:6px 12px; border-radius:6px; cursor:pointer; font-family:inherit; font-size:11px; letter-spacing:0.04em; text-transform:uppercase; font-weight:700; }
  .mc-btn:hover { background:#1a1a25; }
  .mc-btn.primary { background:#7fb3ff; color:#04122b; border-color:#7fb3ff; }
  .mc-main { display:grid; grid-template-columns:1fr 340px; overflow:hidden; }
  @media (max-width:900px){ .mc-main { grid-template-columns:1fr; grid-template-rows:1fr auto; overflow-y:auto; } }
  .mc-code { display:flex; flex-direction:column; border-right:1px solid #2a2a35; overflow:hidden; }
  .mc-codetop { display:flex; align-items:center; gap:8px; padding:8px 12px; border-bottom:1px solid #1a1a25; font-family:'Geist Mono',monospace; font-size:10.5px; color:#9aa; }
  .mc-codetop select { background:#11131a; color:#e8e8ee; border:1px solid #2a2a35; border-radius:6px; padding:5px 8px; font-family:inherit; font-size:11px; }
  .mc-editor { flex:1; display:flex; overflow:auto; }
  .mc-gutter { background:#0c0e14; color:#4a5568; font-family:'Geist Mono',monospace; font-size:12.5px; line-height:1.55; padding:12px 8px; text-align:right; user-select:none; white-space:pre; }
  .mc-gutter .cur { color:#7fb3ff; background:rgba(127,179,255,0.12); font-weight:700; }
  #mcCode { flex:1; background:#0b0d13; color:#d8dee9; border:none; outline:none; resize:none; font-family:'Geist Mono',monospace; font-size:12.5px; line-height:1.55; padding:12px; white-space:pre; tab-size:4; }
  .mc-right { background:#0c0e14; overflow-y:auto; padding:14px; }
  .mc-cat { font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.18em; text-transform:uppercase; color:#7fb3ff; font-weight:700; margin:12px 0 8px; }
  .mc-regs { display:grid; grid-template-columns:repeat(4,1fr); gap:6px; font-family:'Geist Mono',monospace; font-size:11px; }
  .mc-reg { background:#11131a; border:1px solid #2a2a35; border-radius:6px; padding:6px 4px; text-align:center; }
  .mc-reg .k { color:#7fb3ff; font-size:9px; } .mc-reg .v { color:#fff; font-weight:700; }
  .mc-reg.changed .v { color:#86efac; }
  .mc-flags { display:flex; gap:8px; margin-top:8px; font-family:'Geist Mono',monospace; font-size:11px; }
  .mc-flag { flex:1; text-align:center; background:#11131a; border:1px solid #2a2a35; border-radius:6px; padding:5px; }
  .mc-flag.on { background:rgba(134,239,172,0.15); color:#86efac; border-color:#86efac55; }
  .mc-leds { display:flex; gap:8px; justify-content:center; margin:6px 0 4px; }
  .mc-led { width:30px; height:30px; border-radius:50%; background:#1a1a20; border:2px solid #2a2a35; box-shadow:inset 0 0 6px rgba(0,0,0,0.6); transition:all .05s; }
  .mc-led.on { background:#ff5a3c; border-color:#ff8a6c; box-shadow:0 0 14px rgba(255,90,60,0.8), inset 0 0 6px rgba(255,180,150,0.6); }
  .mc-ledlab { display:flex; gap:8px; justify-content:center; font-family:'Geist Mono',monospace; font-size:9px; color:#5c6370; margin-bottom:10px; }
  .mc-ledlab span { width:30px; text-align:center; }
  .mc-btns { display:flex; gap:8px; justify-content:center; }
  .mc-hwbtn { width:52px; height:36px; border-radius:8px; background:#1a1a20; border:1px solid #2a2a35; color:#9aa; font-family:'Geist Mono',monospace; font-size:10px; cursor:pointer; }
  .mc-hwbtn.on { background:#7fb3ff; color:#04122b; border-color:#7fb3ff; }
  .mc-ram { font-family:'Geist Mono',monospace; font-size:10px; color:#9aa; line-height:1.7; background:#0b0d13; border:1px solid #2a2a35; border-radius:6px; padding:8px; overflow-x:auto; white-space:pre; }
  .mc-ram b { color:#7fb3ff; } .mc-ram .io { color:#ff8a6c; }
  .mc-stat { display:flex; justify-content:space-between; font-family:'Geist Mono',monospace; font-size:11px; color:#cfd6da; padding:3px 0; }
  .mc-stat b { color:#7fb3ff; }
  .mc-err { font-family:'Geist Mono',monospace; font-size:11px; color:#f2a5a8; margin-top:8px; white-space:pre-wrap; }
  .mc-note { font-size:10px; color:#788; line-height:1.7; border-top:1px solid #2a2a35; margin-top:12px; padding-top:9px; }
</style>

<div class="mc-wrap">
  <div class="mc-bar">
    <a href="/aquintutor/labs">&larr; LABS</a>
    <span class="mc-title">MCU <em>Emulator</em></span>
    <span style="opacity:0.5;">8-BIT · ASSEMBLY · GPIO</span>
    <div class="mc-bar-right">
      <span id="mcSpeedLab" style="opacity:0.6;">4 Hz</span>
      <input type="range" id="mcSpeed" min="1" max="7" step="1" value="3" style="width:90px;accent-color:#7fb3ff;" />
      <button type="button" class="mc-btn" id="mcStep">Step</button>
      <button type="button" class="mc-btn primary" id="mcRun">Run</button>
      <button type="button" class="mc-btn" id="mcReset">Reset</button>
    </div>
  </div>
  <div class="mc-main">
    <div class="mc-code">
      <div class="mc-codetop">
        <span>Program</span>
        <select id="mcExample">
          <option value="blink">blink.asm</option>
          <option value="counter">counter.asm</option>
          <option value="knight">knight-rider.asm</option>
          <option value="button">button-toggle.asm</option>
        </select>
        <span style="margin-left:auto;">R0-R7 · 256B RAM · LED @0xF0 · BTN @0xF1 · TMR @0xF2</span>
      </div>
      <div class="mc-editor">
        <div class="mc-gutter" id="mcGutter"></div>
        <textarea id="mcCode" spellcheck="false"></textarea>
      </div>
    </div>
    <div class="mc-right">
      <div class="mc-cat">Hardware</div>
      <div class="mc-leds" id="mcLeds"></div>
      <div class="mc-ledlab"><span>7</span><span>6</span><span>5</span><span>4</span><span>3</span><span>2</span><span>1</span><span>0</span></div>
      <div class="mc-btns" id="mcHwBtns"></div>

      <div class="mc-cat">Registers</div>
      <div class="mc-regs" id="mcRegs"></div>
      <div class="mc-flags" id="mcFlags"></div>

      <div class="mc-cat">CPU</div>
      <div class="mc-stat"><span>PC</span><b id="mcPC">0</b></div>
      <div class="mc-stat"><span>SP</span><b id="mcSP">0xEF</b></div>
      <div class="mc-stat"><span>Cycles</span><b id="mcCyc">0</b></div>
      <div class="mc-stat"><span>Timer @0xF2</span><b id="mcTmr">0</b></div>

      <div class="mc-cat">RAM</div>
      <div class="mc-ram" id="mcRam"></div>
      <div class="mc-err" id="mcErr"></div>
      <div class="mc-note">A genuine instruction-level CPU: two-pass label resolution, an 8-bit datapath with Z/C flags, a descending stack (CALL/RET/PUSH/POP), and memory-mapped I/O — writing 0xF0 drives the LEDs, reading 0xF1 samples the buttons, 0xF2 is a free-running timer. This is how real firmware talks to hardware.</div>
    </div>
  </div>
</div>

<script is:inline>
(function(){
'use strict';
var EXAMPLES = {
  blink:
"; Blink LED0 forever\n" +
"start:\n" +
"    MOV R0, #0x01\n" +
"loop:\n" +
"    ST  0xF0, R0     ; write LEDs\n" +
"    XOR R0, #0xFF     ; invert\n" +
"    AND R0, #0x01     ; keep bit 0\n" +
"    DELAY #6\n" +
"    JMP loop\n",
  counter:
"; Binary counter on the LEDs\n" +
"    MOV R0, #0\n" +
"loop:\n" +
"    ST  0xF0, R0\n" +
"    INC R0\n" +
"    DELAY #4\n" +
"    JMP loop\n",
  knight:
"; Knight Rider — bounce a lit LED\n" +
"    MOV R0, #0x01     ; pattern\n" +
"right:\n" +
"    ST  0xF0, R0\n" +
"    DELAY #3\n" +
"    SHL R0\n" +
"    CMP R0, #0x80\n" +
"    JNZ right\n" +
"left:\n" +
"    ST  0xF0, R0\n" +
"    DELAY #3\n" +
"    SHR R0\n" +
"    CMP R0, #0x01\n" +
"    JNZ left\n" +
"    JMP right\n",
  button:
"; Toggle LED0 each time button 0 is pressed\n" +
"    MOV R2, #0        ; last button state\n" +
"    MOV R3, #0        ; led state\n" +
"loop:\n" +
"    LD  R0, 0xF1      ; read buttons\n" +
"    AND R0, #0x01     ; button 0\n" +
"    CMP R0, R2\n" +
"    JZ  same\n" +
"    CMP R0, #1        ; rising edge?\n" +
"    JNZ store\n" +
"    XOR R3, #0x01     ; toggle led\n" +
"    ST  0xF0, R3\n" +
"store:\n" +
"    MOV R2, R0\n" +
"same:\n" +
"    DELAY #1\n" +
"    JMP loop\n",
};

// ---- CPU state ----
var R=new Array(8).fill(0), PC=0, SP=0xEF, Z=false, C=false, cycles=0, halted=false;
var mem=new Uint8Array(256);
var LED=0xF0, BTN=0xF1, TMR=0xF2;
var prog=[], labels={}, err='';
var prevR=R.slice();

function u8(v){ return ((v%256)+256)%256; }
function parseVal(t){ // register or immediate
  t=t.trim();
  if(/^R[0-7]$/i.test(t)) return {reg:parseInt(t.slice(1))};
  if(t[0]==='#') return {imm:u8(parseInt(t.slice(1)))};
  return {imm:u8(parseInt(t))}; // bare number = immediate
}
function parseAddr(t){ t=t.trim(); return parseInt(t); }
function assemble(src){
  labels={}; prog=[]; err='';
  var lines=src.split('\n');
  // pass 1: labels
  var idx=0, pruned=[];
  lines.forEach(function(raw,ln){
    var line=raw.replace(/;.*$/,'').trim();
    if(!line) return;
    var m=line.match(/^([A-Za-z_][A-Za-z0-9_]*):\s*(.*)$/);
    if(m){ labels[m[1]]=idx; if(m[2].trim()){ pruned.push({t:m[2].trim(),ln:ln}); idx++; } return; }
    pruned.push({t:line,ln:ln}); idx++;
  });
  // pass 2: encode
  pruned.forEach(function(p){
    var parts=p.t.split(/[\s,]+/).filter(Boolean);
    prog.push({op:parts[0].toUpperCase(), args:parts.slice(1), ln:p.ln, txt:p.t});
  });
}
function reset(full){
  R=new Array(8).fill(0); prevR=R.slice(); PC=0; SP=0xEF; Z=false; C=false; cycles=0; halted=false;
  mem=new Uint8Array(256);
  render();
}
function step(){
  if(halted||PC<0||PC>=prog.length){ halted=true; return; }
  mem[TMR]=u8(mem[TMR]+1);
  var ins=prog[PC], a=ins.args, op=ins.op; prevR=R.slice();
  function reg(i){ return R[i]; }
  function setFlagsZ(v){ Z=(u8(v)===0); }
  var next=PC+1;
  try {
    switch(op){
      case 'MOV': { var d=parseVal(a[0]).reg, s=parseVal(a[1]); R[d]=('reg'in s)?R[s.reg]:s.imm; break; }
      case 'LD':  { var d=parseVal(a[0]).reg, ad=parseAddr(a[1]); R[d]=mem[u8(ad)]; break; }
      case 'ST':  { var ad=parseAddr(a[0]), s=parseVal(a[1]); mem[u8(ad)]=('reg'in s)?R[s.reg]:s.imm; break; }
      case 'LDR': { var d=parseVal(a[0]).reg, rs=parseVal(a[1].replace(/[\[\]]/g,'')).reg; R[d]=mem[u8(R[rs])]; break; }
      case 'STR': { var rd=parseVal(a[0].replace(/[\[\]]/g,'')).reg, s=parseVal(a[1]); mem[u8(R[rd])]=('reg'in s)?R[s.reg]:s.imm; break; }
      case 'ADD': { var d=parseVal(a[0]).reg, s=parseVal(a[1]); var v=R[d]+(('reg'in s)?R[s.reg]:s.imm); C=v>255; R[d]=u8(v); setFlagsZ(R[d]); break; }
      case 'SUB': { var d=parseVal(a[0]).reg, s=parseVal(a[1]); var sv=('reg'in s)?R[s.reg]:s.imm; C=R[d]<sv; R[d]=u8(R[d]-sv); setFlagsZ(R[d]); break; }
      case 'INC': { var d=parseVal(a[0]).reg; R[d]=u8(R[d]+1); setFlagsZ(R[d]); break; }
      case 'DEC': { var d=parseVal(a[0]).reg; R[d]=u8(R[d]-1); setFlagsZ(R[d]); break; }
      case 'AND': { var d=parseVal(a[0]).reg, s=parseVal(a[1]); R[d]=R[d]&(('reg'in s)?R[s.reg]:s.imm); setFlagsZ(R[d]); break; }
      case 'OR':  { var d=parseVal(a[0]).reg, s=parseVal(a[1]); R[d]=R[d]|(('reg'in s)?R[s.reg]:s.imm); setFlagsZ(R[d]); break; }
      case 'XOR': { var d=parseVal(a[0]).reg, s=parseVal(a[1]); R[d]=u8(R[d]^(('reg'in s)?R[s.reg]:s.imm)); setFlagsZ(R[d]); break; }
      case 'NOT': { var d=parseVal(a[0]).reg; R[d]=u8(~R[d]); setFlagsZ(R[d]); break; }
      case 'SHL': { var d=parseVal(a[0]).reg; C=(R[d]&0x80)!==0; R[d]=u8(R[d]<<1); setFlagsZ(R[d]); break; }
      case 'SHR': { var d=parseVal(a[0]).reg; C=(R[d]&1)!==0; R[d]=R[d]>>1; setFlagsZ(R[d]); break; }
      case 'CMP': { var d=parseVal(a[0]), s=parseVal(a[1]); var dv=('reg'in d)?R[d.reg]:d.imm, sv=('reg'in s)?R[s.reg]:s.imm; Z=(dv===sv); C=(dv<sv); break; }
      case 'JMP': next=lbl(a[0]); break;
      case 'JZ':  if(Z) next=lbl(a[0]); break;
      case 'JNZ': if(!Z) next=lbl(a[0]); break;
      case 'JC':  if(C) next=lbl(a[0]); break;
      case 'JNC': if(!C) next=lbl(a[0]); break;
      case 'CALL': mem[SP]=(PC+1)&0xff; SP=u8(SP-1); next=lbl(a[0]); break;
      case 'RET': SP=u8(SP+1); next=mem[SP]; break;
      case 'PUSH': { var s=parseVal(a[0]); mem[SP]=('reg'in s)?R[s.reg]:s.imm; SP=u8(SP-1); break; }
      case 'POP': { var d=parseVal(a[0]).reg; SP=u8(SP+1); R[d]=mem[SP]; break; }
      case 'DELAY': { delayLeft=parseVal(a[0]).imm; break; }
      case 'NOP': break;
      case 'HLT': halted=true; break;
      default: throw new Error('unknown instruction: '+op);
    }
  } catch(e){ err='Runtime error @ line '+(ins.ln+1)+': '+e.message; halted=true; }
  PC=next; cycles++;
}
function lbl(name){ if(!(name in labels)) throw new Error('unknown label: '+name); return labels[name]; }

var delayLeft=0;
function tick(){
  if(delayLeft>0){ delayLeft--; cycles++; mem[TMR]=u8(mem[TMR]+1); return; }
  step();
}

// ---- rendering ----
function render(){
  // leds
  var leds=document.getElementById('mcLeds');
  if(leds.children.length!==8){ leds.innerHTML=''; for(var i=0;i<8;i++){ var d=document.createElement('div'); d.className='mc-led'; leds.appendChild(d); } }
  for(var i=0;i<8;i++){ leds.children[i].classList.toggle('on', (mem[LED]>>(7-i))&1); }
  // regs
  var rg=document.getElementById('mcRegs');
  if(rg.children.length!==8){ rg.innerHTML=''; for(var i=0;i<8;i++){ var c=document.createElement('div'); c.className='mc-reg'; c.innerHTML='<div class="k">R'+i+'</div><div class="v"></div>'; rg.appendChild(c); } }
  for(var i=0;i<8;i++){ rg.children[i].querySelector('.v').textContent='0x'+(R[i]<16?'0':'')+R[i].toString(16); rg.children[i].classList.toggle('changed', R[i]!==prevR[i]); }
  // flags
  var fl=document.getElementById('mcFlags');
  fl.innerHTML='<div class="mc-flag '+(Z?'on':'')+'">Z '+(Z?1:0)+'</div><div class="mc-flag '+(C?'on':'')+'">C '+(C?1:0)+'</div><div class="mc-flag '+(halted?'on':'')+'">'+(halted?'HALT':'RUN')+'</div>';
  document.getElementById('mcPC').textContent=PC;
  document.getElementById('mcSP').textContent='0x'+SP.toString(16);
  document.getElementById('mcCyc').textContent=cycles;
  document.getElementById('mcTmr').textContent=mem[TMR];
  // ram (first 48 bytes + IO row)
  var ram='';
  for(var r=0;r<3;r++){ ram+='<b>'+('0'+ (r*16).toString(16)).slice(-2)+'</b>  '; for(var c=0;c<16;c++){ var v=mem[r*16+c]; ram+=(v<16?'0':'')+v.toString(16)+' '; } ram+='\n'; }
  ram+='<span class="io">F0</span>  LED='+hex(mem[LED])+'  BTN='+hex(mem[BTN])+'  TMR='+hex(mem[TMR]);
  document.getElementById('mcRam').innerHTML=ram;
  document.getElementById('mcErr').textContent=err;
  // gutter + current line highlight
  drawGutter();
}
function hex(v){ return '0x'+(v<16?'0':'')+v.toString(16); }
function drawGutter(){
  var code=document.getElementById('mcCode').value, lines=code.split('\n');
  var curLn = (prog[PC] && !halted) ? prog[PC].ln : -1;
  var g=document.getElementById('mcGutter'); g.innerHTML='';
  lines.forEach(function(_,i){ var s=document.createElement('div'); if(i===curLn) s.className='cur'; s.textContent=(i+1); g.appendChild(s); });
}

// ---- run loop ----
var timer=null, hz=4;
function setRunning(on){
  document.getElementById('mcRun').textContent=on?'Pause':'Run';
  document.getElementById('mcRun').classList.toggle('primary',!on);
  if(timer){clearInterval(timer);timer=null;}
  if(on){ timer=setInterval(function(){ var n=Math.max(1,Math.round(hz/8)); for(var k=0;k<Math.max(1,hz<=8?1:hz/8);k++){ tick(); if(halted)break; } render(); if(halted)setRunning(false); }, 1000/Math.min(hz,8)); }
}
document.getElementById('mcRun').addEventListener('click',function(){ if(!prog.length) doAssemble(); setRunning(this.textContent==='Run'); });
document.getElementById('mcStep').addEventListener('click',function(){ if(!prog.length) doAssemble(); tick(); render(); });
document.getElementById('mcReset').addEventListener('click',function(){ setRunning(false); doAssemble(); reset(true); });
document.getElementById('mcSpeed').addEventListener('input',function(){ var map=[0,1,2,4,8,16,32,64]; hz=map[this.value]; document.getElementById('mcSpeedLab').textContent=hz+' Hz'; if(timer){setRunning(false);setRunning(true);} });
document.getElementById('mcCode').addEventListener('input',function(){ prog=[]; drawGutter(); });
document.getElementById('mcCode').addEventListener('scroll',function(){ document.getElementById('mcGutter').style.transform='translateY('+(-this.scrollTop)+'px)'; });
document.getElementById('mcExample').addEventListener('change',function(){ load(this.value); });
function doAssemble(){ assemble(document.getElementById('mcCode').value); reset(true); if(err){document.getElementById('mcErr').textContent=err;} }
function load(name){ setRunning(false); document.getElementById('mcCode').value=EXAMPLES[name]; assemble(EXAMPLES[name]); reset(true); }

// hardware buttons
var hb=document.getElementById('mcHwBtns');
for(var i=0;i<4;i++){ (function(bit){ var b=document.createElement('button'); b.className='mc-hwbtn'; b.textContent='BTN'+bit;
  b.addEventListener('mousedown',function(){ mem[BTN]|=(1<<bit); b.classList.add('on'); render(); });
  b.addEventListener('mouseup',function(){ mem[BTN]&=~(1<<bit); b.classList.remove('on'); render(); });
  b.addEventListener('mouseleave',function(){ if(mem[BTN]&(1<<bit)){ mem[BTN]&=~(1<<bit); b.classList.remove('on'); render(); } });
  b.addEventListener('touchstart',function(e){ e.preventDefault(); mem[BTN]|=(1<<bit); b.classList.add('on'); render(); },{passive:false});
  b.addEventListener('touchend',function(e){ e.preventDefault(); mem[BTN]&=~(1<<bit); b.classList.remove('on'); render(); },{passive:false});
  hb.appendChild(b);
})(i); }

load('blink');
})();
</script>

</BaseLayout>
