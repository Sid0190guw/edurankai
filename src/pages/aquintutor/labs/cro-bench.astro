---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Oscilloscope Bench · Virtual Labs · AquinTutor" description="A dual-channel CRO and a function generator: set volts/div and time/div, trigger, measure frequency and amplitude, and draw Lissajous figures.">

<style>
  body { background: #0b0c10; color: #e8e8ee; margin: 0; }
  .cro-wrap { max-width: 1560px; margin: 0 auto; padding: 18px 3vw 80px; }

  .cro-top { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 12px; margin-bottom: 6px; }
  .cro-back { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #67e8f9; text-decoration: none; letter-spacing: 0.08em; }
  .cro-eye { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 12px 0 0; }
  .cro-title { font-family: 'Cormorant Garamond', serif; font-size: 34px; font-weight: 600; margin: 4px 0 0; letter-spacing: -0.02em; }
  .cro-title em { color: #67e8f9; font-style: italic; font-weight: 500; }
  .cro-lede { color: #9aa6b6; font-size: 13.5px; line-height: 1.55; max-width: 880px; margin: 10px 0 18px; }

  /* tasks bar */
  .cro-tasks { display: flex; gap: 8px; flex-wrap: wrap; margin: 0 0 18px; }
  .cro-task { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10.5px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; padding: 8px 13px; border-radius: 8px; border: 1px solid #2a2a35; background: #14161e; color: #9aa6b6; cursor: pointer; transition: all .12s; }
  .cro-task:hover { border-color: #67e8f9; color: #cfeefb; }
  .cro-task.active { background: #67e8f9; color: #04161b; border-color: #67e8f9; }

  /* bench layout */
  .cro-bench { display: grid; grid-template-columns: minmax(0,1fr) 320px; gap: 18px; align-items: start; }
  @media (max-width: 1180px) { .cro-bench { grid-template-columns: 1fr; } }

  /* the oscilloscope chassis */
  .scope { background: linear-gradient(160deg,#3a3f47,#22252b 60%,#16181d); border: 1px solid #45494f; border-radius: 16px; padding: 16px; box-shadow: 0 24px 60px rgba(0,0,0,.55), inset 0 1px 0 rgba(255,255,255,.06); }
  .scope-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; padding: 0 4px; }
  .scope-brand { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 700; color: #d6dade; letter-spacing: 0.02em; }
  .scope-brand span { color: #67e8f9; }
  .scope-model { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9.5px; letter-spacing: 0.2em; color: #8b9098; text-transform: uppercase; }
  .scope-pwr { display: flex; align-items: center; gap: 7px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9.5px; color: #8b9098; letter-spacing: 0.14em; text-transform: uppercase; }
  .pwr-led { width: 9px; height: 9px; border-radius: 50%; background: #2bd66a; box-shadow: 0 0 8px #2bd66a; }
  .pwr-led.off { background: #5a2222; box-shadow: none; }

  .scope-body { display: grid; grid-template-columns: minmax(0,1fr) 196px; gap: 14px; align-items: start; }
  @media (max-width: 720px) { .scope-body { grid-template-columns: 1fr; } }

  /* CRT bezel + screen */
  .crt-bezel { background: #0a0b0d; border: 6px solid #15171b; border-radius: 12px; padding: 8px; box-shadow: inset 0 0 0 2px #2a2d33, inset 0 0 26px rgba(0,0,0,.9); }
  .crt-screen { position: relative; width: 100%; aspect-ratio: 5 / 4; border-radius: 7px; overflow: hidden; background: radial-gradient(ellipse at center, #06160c 0%, #03100a 70%, #020a06 100%); }
  #crt { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
  .crt-vignette { position: absolute; inset: 0; pointer-events: none; border-radius: 7px; box-shadow: inset 0 0 70px 18px rgba(0,0,0,.78); }
  .crt-scan { position: absolute; inset: 0; pointer-events: none; background: repeating-linear-gradient(0deg, rgba(0,0,0,0) 0px, rgba(0,0,0,0) 2px, rgba(0,0,0,.13) 3px); opacity: .5; }

  .crt-readout { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 6px 14px; margin-top: 8px; padding: 0 4px; }
  .ro-item { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; color: #9aa6b6; letter-spacing: 0.03em; }
  .ro-item b { color: #7df3a0; font-weight: 700; }
  .ro-item.c1 b { color: #ffd34d; }
  .ro-item.c2 b { color: #6cc7ff; }

  /* right control column of scope (timebase + trigger + display) */
  .scope-right { display: flex; flex-direction: column; gap: 12px; }
  .sect { background: #1b1e24; border: 1px solid #34383f; border-radius: 10px; padding: 10px 11px; }
  .sect h4 { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; margin: 0 0 9px; }

  /* knob */
  .knob-row { display: flex; align-items: center; gap: 10px; margin-bottom: 9px; }
  .knob-row:last-child { margin-bottom: 0; }
  .knob { position: relative; width: 46px; height: 46px; border-radius: 50%; background: radial-gradient(circle at 38% 32%, #5b616a, #2c3036 62%, #1a1d22 100%); border: 1px solid #14161a; box-shadow: 0 3px 7px rgba(0,0,0,.55), inset 0 1px 1px rgba(255,255,255,.12); cursor: ns-resize; flex-shrink: 0; touch-action: none; }
  .knob::after { content: ''; position: absolute; top: 5px; left: 50%; width: 3px; height: 14px; margin-left: -1.5px; border-radius: 2px; background: #f0f3f6; box-shadow: 0 0 3px rgba(255,255,255,.5); transform-origin: 50% 18px; }
  .knob.k1::after { background: #ffd34d; }
  .knob.k2::after { background: #6cc7ff; }
  .knob-meta { min-width: 0; flex: 1; }
  .knob-meta .kn { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: #8b9098; }
  .knob-meta .kv { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 13px; color: #e8edf2; font-weight: 700; line-height: 1.2; }
  .knob-meta .kv.c1 { color: #ffd34d; }
  .knob-meta .kv.c2 { color: #6cc7ff; }

  .btn-row { display: flex; gap: 6px; flex-wrap: wrap; }
  .pbtn { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9.5px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; padding: 7px 9px; border-radius: 6px; border: 1px solid #3a3f47; background: linear-gradient(180deg,#2c3036,#1d2025); color: #c4cad1; cursor: pointer; flex: 1; min-width: 40px; }
  .pbtn:hover { border-color: #67e8f9; }
  .pbtn.on { background: linear-gradient(180deg,#67e8f9,#33b8d6); color: #04161b; border-color: #67e8f9; box-shadow: 0 0 9px rgba(103,232,249,.4); }
  .pbtn.run { background: linear-gradient(180deg,#2bd66a,#1f9e4e); color: #04230f; border-color: #2bd66a; }
  .pbtn.stop { background: linear-gradient(180deg,#e05050,#b83030); color: #2a0606; border-color: #e05050; }

  .mini-lbl { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 8.5px; letter-spacing: 0.12em; text-transform: uppercase; color: #71767d; margin: 8px 0 4px; }
  input[type=range].slider { -webkit-appearance: none; appearance: none; width: 100%; height: 4px; border-radius: 3px; background: #34383f; outline: none; margin: 4px 0; }
  input[type=range].slider::-webkit-slider-thumb { -webkit-appearance: none; appearance: none; width: 15px; height: 15px; border-radius: 50%; background: #67e8f9; cursor: pointer; box-shadow: 0 0 4px rgba(103,232,249,.6); }
  input[type=range].slider::-moz-range-thumb { width: 15px; height: 15px; border: none; border-radius: 50%; background: #67e8f9; cursor: pointer; }

  /* function generator panels (below scope) */
  .fgen-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 16px; }
  @media (max-width: 720px) { .fgen-grid { grid-template-columns: 1fr; } }
  .fgen { background: linear-gradient(160deg,#262a31,#191b20); border: 1px solid #3a3f47; border-radius: 14px; padding: 14px; box-shadow: 0 14px 36px rgba(0,0,0,.4), inset 0 1px 0 rgba(255,255,255,.05); }
  .fgen-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 11px; }
  .fgen-name { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 700; }
  .fgen-name.c1 { color: #ffd34d; }
  .fgen-name.c2 { color: #6cc7ff; }
  .fgen-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 6px; vertical-align: middle; }
  .fgen-dot.c1 { background: #ffd34d; box-shadow: 0 0 7px #ffd34d; }
  .fgen-dot.c2 { background: #6cc7ff; box-shadow: 0 0 7px #6cc7ff; }
  .fgen-mini { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9px; color: #71767d; letter-spacing: 0.08em; }

  .wave-btns { display: flex; gap: 5px; margin-bottom: 11px; }
  .wbtn { flex: 1; padding: 7px 0; border-radius: 7px; border: 1px solid #3a3f47; background: #1d2025; cursor: pointer; display: flex; align-items: center; justify-content: center; }
  .wbtn svg { width: 26px; height: 14px; }
  .wbtn:hover { border-color: #67e8f9; }
  .wbtn.on { border-color: #67e8f9; background: #0e2b32; }
  .wbtn .ws { stroke: #9aa6b6; }
  .wbtn.on .ws { stroke: #67e8f9; }

  .fld { margin-bottom: 9px; }
  .fld-top { display: flex; justify-content: space-between; align-items: baseline; }
  .fld-top .fl { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: #8b9098; }
  .fld-top .fv { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12px; color: #e8edf2; font-weight: 700; }
  .fld-top .fv.c1 { color: #ffd34d; }
  .fld-top .fv.c2 { color: #6cc7ff; }

  /* measurement / info side rail */
  .rail { display: flex; flex-direction: column; gap: 14px; position: sticky; top: 14px; }
  .panel { background: #14161e; border: 1px solid #2a2a35; border-radius: 12px; padding: 14px; }
  .panel h3 { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 12px; }

  .meas-tabs { display: flex; gap: 5px; margin-bottom: 11px; }
  .mtab { flex: 1; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; padding: 6px 0; border-radius: 6px; border: 1px solid #2a2a35; background: #0e1015; cursor: pointer; }
  .mtab.c1 { color: #ffd34d; } .mtab.c1.on { background: #ffd34d; color: #1a1404; }
  .mtab.c2 { color: #6cc7ff; } .mtab.c2.on { background: #6cc7ff; color: #041420; }

  .mtable { width: 100%; border-collapse: collapse; }
  .mtable td { padding: 7px 2px; border-bottom: 1px solid #1f2029; font-family: 'Geist Mono', ui-monospace, monospace; }
  .mtable tr:last-child td { border-bottom: none; }
  .mtable td.ml { font-size: 10.5px; color: #9aa6b6; letter-spacing: 0.04em; }
  .mtable td.mv { font-size: 13px; color: #7df3a0; font-weight: 700; text-align: right; }

  .phase-box { margin-top: 10px; background: #0e1015; border: 1px solid #2a2a35; border-radius: 9px; padding: 10px 11px; }
  .phase-box .pl { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: #8b9098; }
  .phase-box .pv { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 18px; color: #c4a8ff; font-weight: 700; margin-top: 2px; }

  .guide { font-size: 12.5px; color: #cbd2dc; line-height: 1.62; }
  .guide b { color: #fff; }
  .guide .gtag { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: #67e8f9; font-weight: 700; display: block; margin-bottom: 6px; }
  .guide ol { margin: 8px 0 0; padding-left: 18px; }
  .guide ol li { margin-bottom: 6px; }
  .guide .ans { margin-top: 10px; padding: 9px 10px; background: #0e1015; border-left: 3px solid #2bd66a; border-radius: 6px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #7df3a0; line-height: 1.5; }

  .note { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; color: #71767d; line-height: 1.6; }
</style>

<main class="cro-wrap">
  <div class="cro-top">
    <a class="cro-back" href="/aquintutor/labs">&larr; Virtual Labs</a>
    <span class="scope-model">Instrumentation &middot; CRO-2200D</span>
  </div>
  <p class="cro-eye">Instrumentation Lab</p>
  <h1 class="cro-title">Oscilloscope <em>Bench</em></h1>
  <p class="cro-lede">A genuine dual-channel cathode-ray oscilloscope and twin function generators. Set VOLTS/DIV and TIME/DIV, trigger the sweep, read amplitude and frequency straight off the graticule, switch to X-Y mode for Lissajous figures, and let the AutoMeasure unit confirm your readings. Every trace is computed from the live generator settings.</p>

  <div class="cro-tasks" id="taskbar">
    <button class="cro-task active" data-task="0">Free Bench</button>
    <button class="cro-task" data-task="1">1 &middot; Unknown Sine</button>
    <button class="cro-task" data-task="2">2 &middot; Phase Difference</button>
    <button class="cro-task" data-task="3">3 &middot; Lissajous Ratio</button>
    <button class="cro-task" data-task="4">4 &middot; Square / Duty</button>
  </div>

  <div class="cro-bench">
    <div>
      <!-- OSCILLOSCOPE -->
      <div class="scope">
        <div class="scope-head">
          <div>
            <div class="scope-brand">Aquin<span>Scope</span></div>
            <div class="scope-model">Dual-Channel Cathode-Ray Oscilloscope &middot; 200 MHz</div>
          </div>
          <div class="scope-pwr">
            <span class="pwr-led" id="pwrLed"></span><span id="pwrTxt">Power</span>
          </div>
        </div>

        <div class="scope-body">
          <div>
            <div class="crt-bezel">
              <div class="crt-screen">
                <canvas id="crt" width="700" height="560"></canvas>
                <div class="crt-scan"></div>
                <div class="crt-vignette"></div>
              </div>
            </div>
            <div class="crt-readout">
              <span class="ro-item c1">CH1 <b id="roV1">2.00 V/div</b></span>
              <span class="ro-item c2">CH2 <b id="roV2">2.00 V/div</b></span>
              <span class="ro-item">TIME <b id="roT">0.50 ms/div</b></span>
              <span class="ro-item">TRIG <b id="roTrig">CH1 UP 0.0 V</b></span>
              <span class="ro-item">MODE <b id="roMode">BOTH</b></span>
            </div>
          </div>

          <div class="scope-right">
            <div class="sect">
              <h4>Vertical</h4>
              <div class="knob-row">
                <div class="knob k1" id="knV1" data-knob="v1"></div>
                <div class="knob-meta"><div class="kn">CH1 Volts/Div</div><div class="kv c1" id="kvV1">2 V</div></div>
              </div>
              <div class="knob-row">
                <div class="knob k1" id="knP1" data-knob="p1"></div>
                <div class="knob-meta"><div class="kn">CH1 Position</div><div class="kv c1" id="kvP1">0.0 div</div></div>
              </div>
              <div class="knob-row">
                <div class="knob k2" id="knV2" data-knob="v2"></div>
                <div class="knob-meta"><div class="kn">CH2 Volts/Div</div><div class="kv c2" id="kvV2">2 V</div></div>
              </div>
              <div class="knob-row">
                <div class="knob k2" id="knP2" data-knob="p2"></div>
                <div class="knob-meta"><div class="kn">CH2 Position</div><div class="kv c2" id="kvP2">0.0 div</div></div>
              </div>
            </div>

            <div class="sect">
              <h4>Horizontal</h4>
              <div class="knob-row">
                <div class="knob" id="knT" data-knob="t"></div>
                <div class="knob-meta"><div class="kn">Time/Div</div><div class="kv" id="kvT">0.5 ms</div></div>
              </div>
              <div class="knob-row">
                <div class="knob" id="knH" data-knob="h"></div>
                <div class="knob-meta"><div class="kn">Horiz Position</div><div class="kv" id="kvH">0.0 div</div></div>
              </div>
            </div>

            <div class="sect">
              <h4>Trigger</h4>
              <div class="knob-row">
                <div class="knob" id="knTr" data-knob="tr"></div>
                <div class="knob-meta"><div class="kn">Level</div><div class="kv" id="kvTr">0.0 V</div></div>
              </div>
              <div class="mini-lbl">Source</div>
              <div class="btn-row" id="trigSrc">
                <button class="pbtn on" data-src="1">CH1</button>
                <button class="pbtn" data-src="2">CH2</button>
              </div>
              <div class="mini-lbl">Edge</div>
              <div class="btn-row" id="trigEdge">
                <button class="pbtn on" data-edge="up">Rising</button>
                <button class="pbtn" data-edge="down">Falling</button>
              </div>
            </div>

            <div class="sect">
              <h4>Display</h4>
              <div class="mini-lbl">Mode</div>
              <div class="btn-row" id="modeBtns">
                <button class="pbtn" data-mode="ch1">CH1</button>
                <button class="pbtn" data-mode="ch2">CH2</button>
                <button class="pbtn on" data-mode="both">BOTH</button>
                <button class="pbtn" data-mode="xy">X-Y</button>
              </div>
              <div class="mini-lbl">Sweep</div>
              <div class="btn-row">
                <button class="pbtn run" id="runBtn">Run</button>
                <button class="pbtn" id="stopBtn">Stop</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- FUNCTION GENERATORS -->
      <div class="fgen-grid">
        <!-- CH1 generator -->
        <div class="fgen">
          <div class="fgen-head">
            <div class="fgen-name c1"><span class="fgen-dot c1"></span>Function Gen A &rarr; CH1</div>
            <div class="fgen-mini">SOURCE 1</div>
          </div>
          <div class="wave-btns" data-gen="1" id="wave1">
            <button class="wbtn on" data-w="sine" title="Sine"><svg viewBox="0 0 26 14"><path class="ws" fill="none" stroke-width="1.6" d="M1 7 Q4 0 7 7 T13 7 T19 7 T25 7"/></svg></button>
            <button class="wbtn" data-w="square" title="Square"><svg viewBox="0 0 26 14"><path class="ws" fill="none" stroke-width="1.6" d="M1 12 L1 2 L9 2 L9 12 L17 12 L17 2 L25 2"/></svg></button>
            <button class="wbtn" data-w="triangle" title="Triangle"><svg viewBox="0 0 26 14"><path class="ws" fill="none" stroke-width="1.6" d="M1 12 L7 2 L13 12 L19 2 L25 12"/></svg></button>
            <button class="wbtn" data-w="saw" title="Sawtooth"><svg viewBox="0 0 26 14"><path class="ws" fill="none" stroke-width="1.6" d="M1 12 L9 2 L9 12 L17 2 L17 12 L25 2"/></svg></button>
          </div>
          <div class="fld"><div class="fld-top"><span class="fl">Frequency</span><span class="fv c1" id="fvFreq1">1.000 kHz</span></div>
            <input type="range" class="slider" id="freq1" min="0" max="1000" value="600"></div>
          <div class="fld"><div class="fld-top"><span class="fl">Amplitude (Vpp)</span><span class="fv c1" id="fvAmp1">4.00 Vpp</span></div>
            <input type="range" class="slider" id="amp1" min="2" max="2000" value="400"></div>
          <div class="fld"><div class="fld-top"><span class="fl">DC Offset</span><span class="fv c1" id="fvOff1">0.00 V</span></div>
            <input type="range" class="slider" id="off1" min="-500" max="500" value="0"></div>
          <div class="fld"><div class="fld-top"><span class="fl">Phase</span><span class="fv c1" id="fvPh1">0&deg;</span></div>
            <input type="range" class="slider" id="ph1" min="0" max="360" value="0"></div>
        </div>

        <!-- CH2 generator -->
        <div class="fgen">
          <div class="fgen-head">
            <div class="fgen-name c2"><span class="fgen-dot c2"></span>Function Gen B &rarr; CH2</div>
            <div class="fgen-mini">SOURCE 2</div>
          </div>
          <div class="wave-btns" data-gen="2" id="wave2">
            <button class="wbtn on" data-w="sine" title="Sine"><svg viewBox="0 0 26 14"><path class="ws" fill="none" stroke-width="1.6" d="M1 7 Q4 0 7 7 T13 7 T19 7 T25 7"/></svg></button>
            <button class="wbtn" data-w="square" title="Square"><svg viewBox="0 0 26 14"><path class="ws" fill="none" stroke-width="1.6" d="M1 12 L1 2 L9 2 L9 12 L17 12 L17 2 L25 2"/></svg></button>
            <button class="wbtn" data-w="triangle" title="Triangle"><svg viewBox="0 0 26 14"><path class="ws" fill="none" stroke-width="1.6" d="M1 12 L7 2 L13 12 L19 2 L25 12"/></svg></button>
            <button class="wbtn" data-w="saw" title="Sawtooth"><svg viewBox="0 0 26 14"><path class="ws" fill="none" stroke-width="1.6" d="M1 12 L9 2 L9 12 L17 2 L17 12 L25 2"/></svg></button>
          </div>
          <div class="fld"><div class="fld-top"><span class="fl">Frequency</span><span class="fv c2" id="fvFreq2">1.000 kHz</span></div>
            <input type="range" class="slider" id="freq2" min="0" max="1000" value="600"></div>
          <div class="fld"><div class="fld-top"><span class="fl">Amplitude (Vpp)</span><span class="fv c2" id="fvAmp2">2.00 Vpp</span></div>
            <input type="range" class="slider" id="amp2" min="2" max="2000" value="200"></div>
          <div class="fld"><div class="fld-top"><span class="fl">DC Offset</span><span class="fv c2" id="fvOff2">0.00 V</span></div>
            <input type="range" class="slider" id="off2" min="-500" max="500" value="0"></div>
          <div class="fld"><div class="fld-top"><span class="fl">Phase</span><span class="fv c2" id="fvPh2">90&deg;</span></div>
            <input type="range" class="slider" id="ph2" min="0" max="360" value="90"></div>
        </div>
      </div>
    </div>

    <!-- SIDE RAIL -->
    <div class="rail">
      <div class="panel">
        <h3>AutoMeasure</h3>
        <div class="meas-tabs" id="measTabs">
          <button class="mtab c1 on" data-ch="1">CH1</button>
          <button class="mtab c2" data-ch="2">CH2</button>
        </div>
        <table class="mtable">
          <tr><td class="ml">Frequency</td><td class="mv" id="mFreq">--</td></tr>
          <tr><td class="ml">Period</td><td class="mv" id="mPer">--</td></tr>
          <tr><td class="ml">Vpp</td><td class="mv" id="mVpp">--</td></tr>
          <tr><td class="ml">Vrms</td><td class="mv" id="mVrms">--</td></tr>
          <tr><td class="ml">Vavg (DC)</td><td class="mv" id="mVavg">--</td></tr>
          <tr><td class="ml">Vmax / Vmin</td><td class="mv" id="mVmm">--</td></tr>
        </table>
        <div class="phase-box">
          <div class="pl">CH2 &minus; CH1 Phase / Lissajous</div>
          <div class="pv" id="mPhase">--</div>
        </div>
      </div>

      <div class="panel">
        <h3 id="guideTitle">Guided Task</h3>
        <div class="guide" id="guideBody">
          <span class="gtag">Free Bench</span>
          Turn the knobs and drag the sliders. Read amplitude on the vertical graticule (multiply divisions by VOLTS/DIV) and the period on the horizontal axis (divisions multiplied by TIME/DIV). Frequency equals one divided by the period. AutoMeasure on the left confirms your hand readings.
        </div>
      </div>

      <div class="panel">
        <h3>Quick Reference</h3>
        <div class="note">
          GRATICULE: 10 horizontal &times; 8 vertical divisions.<br><br>
          AMPLITUDE: Vpp = (vertical divisions spanned) &times; (VOLTS/DIV).<br><br>
          PERIOD: T = (horizontal divisions per cycle) &times; (TIME/DIV).<br><br>
          FREQUENCY: f = 1 / T.<br><br>
          LISSAJOUS: ratio of horizontal-to-vertical tangent points gives fCH1 : fCH2.
        </div>
      </div>
    </div>
  </div>
</main>

<script is:inline>
(function(){
  'use strict';

  /* ---------- instrument state ---------- */
  var DIV_X = 10, DIV_Y = 8;          /* graticule divisions */

  /* VOLTS/DIV sequence (1-2-5) in volts */
  var VDIV = [0.01,0.02,0.05,0.1,0.2,0.5,1,2,5,10];
  /* TIME/DIV sequence in seconds */
  var TDIV = [
    0.0000001,0.0000002,0.0000005,
    0.000001,0.000002,0.000005,
    0.00001,0.00002,0.00005,
    0.0001,0.0002,0.0005,
    0.001,0.002,0.005,
    0.01,0.02,0.05,0.1
  ];

  var state = {
    gen: [
      null,
      { wave:'sine', freq:1000, vpp:4, off:0, ph:0 },   /* CH1 = index 1 */
      { wave:'sine', freq:1000, vpp:2, off:0, ph:90 }   /* CH2 = index 2 */
    ],
    vdivIdx: [0,7,7],      /* index into VDIV per channel (7 => 2 V) */
    vpos: [0,0,0],         /* vertical position in divisions per channel */
    tdivIdx: 11,           /* index into TDIV (11 => 0.5 ms) */
    hpos: 0,               /* horizontal position in divisions */
    trigSrc: 1,
    trigEdge: 'up',
    trigLevel: 0,
    mode: 'both',
    running: true,
    measCh: 1
  };

  /* ---------- helpers ---------- */
  function fmtVdiv(v){
    if(v >= 1) return v + ' V';
    if(v >= 0.001) return (v*1000) + ' mV';
    return (v*1e6) + ' uV';
  }
  function fmtVdivLong(v){
    if(v >= 1) return v.toFixed(2) + ' V/div';
    return (v*1000).toFixed(0) + ' mV/div';
  }
  function fmtTdiv(t){
    if(t >= 1) return t + ' s';
    if(t >= 0.001) return (t*1000) + ' ms';
    if(t >= 0.000001) return (t*1e6) + ' us';
    return (t*1e9) + ' ns';
  }
  function fmtTdivLong(t){
    if(t >= 1) return t.toFixed(2) + ' s/div';
    if(t >= 0.001) return (t*1000).toFixed(2) + ' ms/div';
    if(t >= 0.000001) return (t*1e6).toFixed(2) + ' us/div';
    return (t*1e9).toFixed(1) + ' ns/div';
  }
  function fmtFreq(f){
    if(f <= 0) return 'DC';
    if(f >= 1e6) return (f/1e6).toFixed(3) + ' MHz';
    if(f >= 1000) return (f/1000).toFixed(3) + ' kHz';
    return f.toFixed(2) + ' Hz';
  }
  function fmtTime(t){
    if(t >= 1) return t.toFixed(3) + ' s';
    if(t >= 0.001) return (t*1000).toFixed(3) + ' ms';
    if(t >= 0.000001) return (t*1e6).toFixed(2) + ' us';
    return (t*1e9).toFixed(1) + ' ns';
  }
  function fmtVolt(v){
    var a = Math.abs(v);
    if(a >= 1 || a === 0) return v.toFixed(2) + ' V';
    return (v*1000).toFixed(1) + ' mV';
  }
  function clamp(x,a,b){ return x < a ? a : (x > b ? b : x); }
  function $(id){ return document.getElementById(id); }

  /* slider value (0..1000) -> frequency 1 Hz .. 1 MHz, log scale */
  function sliderToFreq(s){
    var t = s / 1000;                 /* 0..1 */
    var f = Math.pow(10, t * 6);      /* 1 .. 1e6 */
    return f;
  }
  function freqToSlider(f){
    if(f < 1) f = 1;
    var t = Math.log(f) / Math.log(10) / 6;
    return Math.round(clamp(t,0,1) * 1000);
  }

  /* ---------- waveform value: phase in radians 0..2pi, returns volts ---------- */
  function waveValue(wave, ph){
    /* normalize to 0..1 */
    var x = ph / (2*Math.PI);
    x = x - Math.floor(x);
    var y;
    if(wave === 'sine'){
      y = Math.sin(ph);
    } else if(wave === 'square'){
      y = (x < 0.5) ? 1 : -1;
    } else if(wave === 'triangle'){
      /* peak at x=0.25, trough at x=0.75 */
      if(x < 0.25) y = x*4;
      else if(x < 0.75) y = 2 - x*4;
      else y = x*4 - 4;
    } else { /* saw: ramp -1 -> +1 */
      y = 2*x - 1;
    }
    return y; /* amplitude -1..+1 */
  }

  /* instantaneous voltage of a channel at absolute time t (s) */
  function channelVolt(ch, t){
    var g = state.gen[ch];
    var amp = g.vpp / 2;
    var ph = 2*Math.PI*g.freq*t + g.ph*Math.PI/180;
    return g.off + amp * waveValue(g.wave, ph);
  }

  /* ---------- trigger: find a phase offset so the trace starts at trigger crossing ---------- */
  function findTrigTime(ch, level, edge, baseT){
    /* search within one or two periods for crossing of level on chosen edge */
    var g = state.gen[ch];
    if(g.freq <= 0) return 0;
    var period = 1/g.freq;
    var amp = g.vpp/2;
    /* clamp level into signal range; if outside, no trigger -> free run */
    var top = g.off + amp, bot = g.off - amp;
    if(level > top || level < bot) return 0;
    var steps = 2000;
    var span = period;          /* one period contains the crossing for these shapes */
    var prev = channelVolt(ch, baseT);
    for(var i=1;i<=steps;i++){
      var tt = baseT + (i/steps)*span;
      var cur = channelVolt(ch, tt);
      var crossed = false;
      if(edge === 'up'){ crossed = (prev < level && cur >= level); }
      else { crossed = (prev > level && cur <= level); }
      if(crossed){
        /* linear interpolate for sub-step accuracy */
        var frac = (level - prev)/(cur - prev);
        var tcross = baseT + ((i-1+frac)/steps)*span;
        return tcross;
      }
      prev = cur;
    }
    return baseT; /* fallback */
  }

  /* ---------- canvas ---------- */
  var cv = $('crt');
  var ctx = cv.getContext('2d');
  var W = cv.width, H = cv.height;
  var PAD = 14;
  var plotW = W - PAD*2, plotH = H - PAD*2;
  var dxDiv = plotW / DIV_X;
  var dyDiv = plotH / DIV_Y;
  var cx = PAD + plotW/2, cyMid = PAD + plotH/2;

  function clearScreen(){
    ctx.fillStyle = '#031007';
    ctx.fillRect(0,0,W,H);
    /* subtle phosphor radial */
    var g = ctx.createRadialGradient(W/2,H/2,40,W/2,H/2,W*0.7);
    g.addColorStop(0,'rgba(20,80,40,0.18)');
    g.addColorStop(1,'rgba(0,0,0,0)');
    ctx.fillStyle = g;
    ctx.fillRect(0,0,W,H);
  }

  function drawGraticule(){
    ctx.save();
    ctx.lineWidth = 1;
    ctx.strokeStyle = 'rgba(80,150,100,0.30)';
    /* vertical division lines */
    for(var i=0;i<=DIV_X;i++){
      var x = PAD + i*dxDiv;
      ctx.beginPath(); ctx.moveTo(x,PAD); ctx.lineTo(x,PAD+plotH); ctx.stroke();
    }
    for(var j=0;j<=DIV_Y;j++){
      var y = PAD + j*dyDiv;
      ctx.beginPath(); ctx.moveTo(PAD,y); ctx.lineTo(PAD+plotW,y); ctx.stroke();
    }
    /* center cross brighter */
    ctx.strokeStyle = 'rgba(110,200,140,0.55)';
    ctx.lineWidth = 1.4;
    ctx.beginPath(); ctx.moveTo(cx,PAD); ctx.lineTo(cx,PAD+plotH); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(PAD,cyMid); ctx.lineTo(PAD+plotW,cyMid); ctx.stroke();
    /* center axis minor tick marks (5 per division) */
    ctx.strokeStyle = 'rgba(110,200,140,0.5)';
    ctx.lineWidth = 1;
    var tick = dxDiv/5;
    for(var k=0;k<=DIV_X*5;k++){
      var tx = PAD + k*tick;
      ctx.beginPath(); ctx.moveTo(tx, cyMid-4); ctx.lineTo(tx, cyMid+4); ctx.stroke();
    }
    var tickY = dyDiv/5;
    for(var m=0;m<=DIV_Y*5;m++){
      var ty = PAD + m*tickY;
      ctx.beginPath(); ctx.moveTo(cx-4, ty); ctx.lineTo(cx+4, ty); ctx.stroke();
    }
    /* outer frame */
    ctx.strokeStyle = 'rgba(90,170,110,0.55)';
    ctx.lineWidth = 1.5;
    ctx.strokeRect(PAD,PAD,plotW,plotH);
    ctx.restore();
  }

  /* convert volts -> screen y for a channel (includes position) */
  function voltToY(ch, v){
    var vdiv = VDIV[state.vdivIdx[ch]];
    var divs = v / vdiv + state.vpos[ch];     /* divisions above center */
    return cyMid - divs * dyDiv;
  }

  /* draw a time-domain trace for a channel */
  function drawTrace(ch, color, glow){
    var tdiv = TDIV[state.tdivIdx];
    var totalT = tdiv * DIV_X;                 /* time across screen */
    var hShift = state.hpos * tdiv;            /* horizontal position offset in seconds */
    /* both channels are drawn relative to the SAME trigger time (held this frame)
       so their relative phase is preserved on screen */
    var t0 = currentTrigT;

    var N = plotW;                             /* one sample per pixel column */
    ctx.save();
    ctx.lineJoin = 'round';
    ctx.lineCap = 'round';
    if(glow){
      ctx.shadowColor = color;
      ctx.shadowBlur = 9;
    }
    ctx.strokeStyle = color;
    ctx.lineWidth = 2;
    ctx.beginPath();
    for(var i=0;i<=N;i++){
      var frac = i / N;                        /* 0..1 across screen */
      var t = t0 + frac*totalT - hShift;
      var v = channelVolt(ch, t);
      var x = PAD + i;
      var y = voltToY(ch, v);
      if(i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
    }
    ctx.stroke();
    ctx.restore();

    /* zero-line / ground marker arrow at left */
    var gy = voltToY(ch, 0);
    ctx.save();
    ctx.fillStyle = color;
    ctx.beginPath();
    ctx.moveTo(PAD-2, gy);
    ctx.lineTo(PAD+9, gy-5);
    ctx.lineTo(PAD+9, gy+5);
    ctx.closePath();
    ctx.fill();
    ctx.restore();
  }

  /* draw X-Y / Lissajous: CH1 on X, CH2 on Y */
  function drawLissajous(){
    var t0 = currentTrigT;
    var g1 = state.gen[1], g2 = state.gen[2];
    var fmax = Math.max(g1.freq, g2.freq, 1);
    /* draw enough time to trace the closed figure: a few periods of the slower */
    var fmin = Math.min(g1.freq||fmax, g2.freq||fmax);
    var span = (fmin>0) ? (4/fmin) : (4/fmax);
    var N = 3000;
    var vdiv1 = VDIV[state.vdivIdx[1]];
    var vdiv2 = VDIV[state.vdivIdx[2]];
    ctx.save();
    ctx.shadowColor = '#7df3a0';
    ctx.shadowBlur = 8;
    ctx.strokeStyle = '#9af7b9';
    ctx.lineWidth = 1.8;
    ctx.lineJoin = 'round';
    ctx.beginPath();
    for(var i=0;i<=N;i++){
      var t = t0 + (i/N)*span;
      var vx = channelVolt(1, t);
      var vy = channelVolt(2, t);
      var dx = vx / vdiv1 + state.hpos;
      var dy = vy / vdiv2 + state.vpos[2];
      var x = cx + dx * dxDiv;
      var y = cyMid - dy * dyDiv;
      if(i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
    }
    ctx.stroke();
    ctx.restore();
  }

  /* trigger marker line */
  function drawTrigMarker(){
    if(state.mode === 'xy') return;
    var ch = state.trigSrc;
    var y = voltToY(ch, state.trigLevel);
    if(y < PAD || y > PAD+plotH) return;
    ctx.save();
    ctx.setLineDash([5,4]);
    ctx.strokeStyle = 'rgba(255,160,60,0.6)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(PAD,y); ctx.lineTo(PAD+plotW,y); ctx.stroke();
    /* small T marker on right */
    ctx.setLineDash([]);
    ctx.fillStyle = 'rgba(255,160,60,0.9)';
    ctx.beginPath();
    ctx.moveTo(PAD+plotW, y);
    ctx.lineTo(PAD+plotW-9, y-5);
    ctx.lineTo(PAD+plotW-9, y+5);
    ctx.closePath();
    ctx.fill();
    ctx.restore();
  }

  /* corner labels on the CRT itself */
  function drawScreenLabels(){
    ctx.save();
    ctx.font = '12px ui-monospace, monospace';
    ctx.textBaseline = 'top';
    if(state.mode === 'xy'){
      ctx.fillStyle = '#9af7b9';
      ctx.fillText('X-Y  CH1(X) vs CH2(Y)', PAD+6, PAD+5);
      ctx.fillStyle = '#ffd34d';
      ctx.fillText('X: '+fmtVdivLong(VDIV[state.vdivIdx[1]]), PAD+6, PAD+plotH-34);
      ctx.fillStyle = '#6cc7ff';
      ctx.fillText('Y: '+fmtVdivLong(VDIV[state.vdivIdx[2]]), PAD+6, PAD+plotH-18);
    } else {
      ctx.fillStyle = '#ffd34d';
      if(state.mode==='ch1'||state.mode==='both')
        ctx.fillText('CH1 '+fmtVdivLong(VDIV[state.vdivIdx[1]]), PAD+6, PAD+5);
      ctx.fillStyle = '#6cc7ff';
      if(state.mode==='ch2'||state.mode==='both')
        ctx.fillText('CH2 '+fmtVdivLong(VDIV[state.vdivIdx[2]]), PAD+6, PAD+21);
      ctx.fillStyle = '#9af7b9';
      ctx.textAlign = 'right';
      ctx.fillText(fmtTdivLong(TDIV[state.tdivIdx]), PAD+plotW-6, PAD+5);
      ctx.textAlign = 'left';
    }
    ctx.restore();
  }

  /* ---------- animation timing ---------- */
  var startMs = Date.now();
  var frozenPhase = 0;       /* simulated wall time when stopped */
  function runningPhase(){
    if(state.running){
      return (Date.now() - startMs)/1000;
    }
    return frozenPhase;
  }
  var currentTrigT = 0;

  function render(){
    clearScreen();
    drawGraticule();

    var baseT = runningPhase();
    /* compute the common trigger time used by all channels this frame */
    if(state.mode === 'xy'){
      currentTrigT = baseT;
      drawScreenLabels();
      drawLissajous();
    } else {
      currentTrigT = findTrigTime(state.trigSrc, state.trigLevel, state.trigEdge, baseT);
      drawScreenLabels();
      drawTrigMarker();
      if(state.mode==='ch1'||state.mode==='both') drawTrace(1,'#ffd34d',true);
      if(state.mode==='ch2'||state.mode==='both') drawTrace(2,'#6cc7ff',true);
    }
  }

  function loop(){
    render();
    requestAnimationFrame(loop);
  }

  /* ---------- measurements (analytic, exact from generator settings) ---------- */
  function measureChannel(ch){
    var g = state.gen[ch];
    var amp = g.vpp/2;
    var vmax = g.off + amp;
    var vmin = g.off - amp;
    var vpp = g.vpp;
    var vavg = g.off;   /* mean over a full cycle is the DC offset for all these symmetric shapes */
    /* RMS of AC part for each shape, about its mean */
    var acRms;
    if(g.wave === 'sine') acRms = amp/Math.SQRT2;
    else if(g.wave === 'square') acRms = amp;                 /* 50% square: |a| */
    else if(g.wave === 'triangle') acRms = amp/Math.sqrt(3);
    else acRms = amp/Math.sqrt(3);                            /* sawtooth same as triangle */
    var vrms = Math.sqrt(vavg*vavg + acRms*acRms);            /* total RMS incl. DC */
    var period = (g.freq>0) ? 1/g.freq : 0;
    return { freq:g.freq, period:period, vpp:vpp, vrms:vrms, vavg:vavg, vmax:vmax, vmin:vmin };
  }

  function phaseDiff(){
    var g1 = state.gen[1], g2 = state.gen[2];
    /* meaningful only when both sine and equal frequency */
    if(g1.wave==='sine' && g2.wave==='sine' && Math.abs(g1.freq-g2.freq) < 1e-6 && g1.freq>0){
      var d = (g2.ph - g1.ph) % 360;
      if(d > 180) d -= 360;
      if(d < -180) d += 360;
      return { type:'phase', value:d };
    }
    /* otherwise report frequency ratio for Lissajous */
    if(g1.freq>0 && g2.freq>0){
      var r = ratio(g1.freq, g2.freq);
      return { type:'ratio', a:r[0], b:r[1] };
    }
    return { type:'none' };
  }

  function ratio(a,b){
    /* approximate integer ratio of a:b */
    var best=[1,1], err=1e9;
    for(var p=1;p<=12;p++){
      for(var q=1;q<=12;q++){
        var e = Math.abs(a*q - b*p);
        if(e/Math.max(a,b) < err){ err = e/Math.max(a,b); best=[p,q]; }
      }
    }
    /* reduce */
    function gcd(x,y){ return y? gcd(y,x%y) : x; }
    var gg = gcd(best[0],best[1]);
    return [best[0]/gg, best[1]/gg];
  }

  function updateMeasPanel(){
    var ch = state.measCh;
    var m = measureChannel(ch);
    $('mFreq').textContent = fmtFreq(m.freq);
    $('mPer').textContent = (m.period>0)? fmtTime(m.period) : 'DC';
    $('mVpp').textContent = fmtVolt(m.vpp);
    $('mVrms').textContent = fmtVolt(m.vrms);
    $('mVavg').textContent = fmtVolt(m.vavg);
    $('mVmm').textContent = fmtVolt(m.vmax)+' / '+fmtVolt(m.vmin);
    var pd = phaseDiff();
    if(pd.type==='phase'){
      var sgn = pd.value>=0 ? '+' : '';
      $('mPhase').textContent = sgn + pd.value.toFixed(1) + ' deg';
      $('mPhase').style.color = '#c4a8ff';
    } else if(pd.type==='ratio'){
      $('mPhase').textContent = 'ratio ' + pd.a + ' : ' + pd.b + ' (f1:f2)';
      $('mPhase').style.color = '#9af7b9';
    } else {
      $('mPhase').textContent = '--';
      $('mPhase').style.color = '#c4a8ff';
    }
  }

  /* ---------- knob visuals ---------- */
  function setKnobAngle(el, frac){
    /* frac 0..1 -> angle -135..+135 deg */
    var ang = -135 + frac*270;
    el.style.setProperty('transform','rotate('+ang+'deg)');
    /* rotate only the indicator via a child transform trick: we rotate the whole knob; indicator is ::after relative */
  }

  /* Since ::after can't be transformed independently easily, rotate the knob element. */
  function knobFrac(kind){
    if(kind==='v1') return state.vdivIdx[1]/(VDIV.length-1);
    if(kind==='v2') return state.vdivIdx[2]/(VDIV.length-1);
    if(kind==='t') return state.tdivIdx/(TDIV.length-1);
    if(kind==='p1') return clamp((state.vpos[1]+4)/8,0,1);
    if(kind==='p2') return clamp((state.vpos[2]+4)/8,0,1);
    if(kind==='h') return clamp((state.hpos+5)/10,0,1);
    if(kind==='tr') return clamp((state.trigLevel+10)/20,0,1);
    return 0.5;
  }
  function refreshKnobs(){
    var map = { v1:'knV1', v2:'knV2', t:'knT', p1:'knP1', p2:'knP2', h:'knH', tr:'knTr' };
    for(var k in map){
      var el = $(map[k]);
      if(el) setKnobAngle(el, knobFrac(k));
    }
  }

  /* ---------- update readouts/labels ---------- */
  function refreshLabels(){
    $('kvV1').textContent = fmtVdiv(VDIV[state.vdivIdx[1]]);
    $('kvV2').textContent = fmtVdiv(VDIV[state.vdivIdx[2]]);
    $('kvT').textContent = fmtTdiv(TDIV[state.tdivIdx]);
    $('kvP1').textContent = state.vpos[1].toFixed(1)+' div';
    $('kvP2').textContent = state.vpos[2].toFixed(1)+' div';
    $('kvH').textContent = state.hpos.toFixed(1)+' div';
    $('kvTr').textContent = fmtVolt(state.trigLevel);

    $('roV1').textContent = fmtVdivLong(VDIV[state.vdivIdx[1]]);
    $('roV2').textContent = fmtVdivLong(VDIV[state.vdivIdx[2]]);
    $('roT').textContent = fmtTdivLong(TDIV[state.tdivIdx]);
    $('roTrig').textContent = 'CH'+state.trigSrc+' '+(state.trigEdge==='up'?'UP':'DN')+' '+fmtVolt(state.trigLevel);
    $('roMode').textContent = state.mode.toUpperCase();

    refreshKnobs();
    updateMeasPanel();
  }

  /* refresh generator field labels */
  function refreshGenLabels(){
    for(var ch=1;ch<=2;ch++){
      var g = state.gen[ch];
      $('fvFreq'+ch).textContent = fmtFreq(g.freq);
      $('fvAmp'+ch).textContent = g.vpp.toFixed(2)+' Vpp';
      $('fvOff'+ch).textContent = g.off.toFixed(2)+' V';
      $('fvPh'+ch).textContent = Math.round(g.ph)+' deg';
    }
  }

  /* ---------- knob drag handling ---------- */
  function attachKnob(elId, kind){
    var el = $(elId);
    if(!el) return;
    var dragging = false, lastY = 0, accum = 0;
    function onDown(e){
      dragging = true; accum = 0;
      lastY = (e.touches? e.touches[0].clientY : e.clientY);
      e.preventDefault();
    }
    function onMove(e){
      if(!dragging) return;
      var y = (e.touches? e.touches[0].clientY : e.clientY);
      var dy = lastY - y;   /* up = increase */
      lastY = y;
      accum += dy;
      var step = 6;         /* pixels per discrete step */
      while(accum >= step){ accum -= step; stepKnob(kind, +1); }
      while(accum <= -step){ accum += step; stepKnob(kind, -1); }
      if(e.cancelable) e.preventDefault();
    }
    function onUp(){ dragging = false; }
    el.addEventListener('mousedown', onDown);
    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseup', onUp);
    el.addEventListener('touchstart', onDown, {passive:false});
    document.addEventListener('touchmove', onMove, {passive:false});
    document.addEventListener('touchend', onUp);
    /* wheel adjust */
    el.addEventListener('wheel', function(e){
      stepKnob(kind, e.deltaY < 0 ? +1 : -1);
      e.preventDefault();
    }, {passive:false});
  }

  function stepKnob(kind, dir){
    if(kind==='v1'){ state.vdivIdx[1] = clamp(state.vdivIdx[1]+dir,0,VDIV.length-1); }
    else if(kind==='v2'){ state.vdivIdx[2] = clamp(state.vdivIdx[2]+dir,0,VDIV.length-1); }
    else if(kind==='t'){ state.tdivIdx = clamp(state.tdivIdx+dir,0,TDIV.length-1); }
    else if(kind==='p1'){ state.vpos[1] = clamp(state.vpos[1]+dir*0.2,-4,4); }
    else if(kind==='p2'){ state.vpos[2] = clamp(state.vpos[2]+dir*0.2,-4,4); }
    else if(kind==='h'){ state.hpos = clamp(state.hpos+dir*0.2,-5,5); }
    else if(kind==='tr'){ state.trigLevel = clamp(state.trigLevel+dir*0.1,-10,10); state.trigLevel = Math.round(state.trigLevel*10)/10; }
    refreshLabels();
  }

  ['v1','v2','t','p1','p2','h','tr'].forEach(function(k){
    var idmap = { v1:'knV1', v2:'knV2', t:'knT', p1:'knP1', p2:'knP2', h:'knH', tr:'knTr' };
    attachKnob(idmap[k], k);
  });

  /* ---------- generator sliders ---------- */
  function bindGenSliders(ch){
    var fq = $('freq'+ch), am = $('amp'+ch), of = $('off'+ch), ph = $('ph'+ch);
    fq.addEventListener('input', function(){
      state.gen[ch].freq = Math.round(sliderToFreq(+fq.value));
      refreshGenLabels(); refreshLabels();
    });
    am.addEventListener('input', function(){
      state.gen[ch].vpp = (+am.value)/100;     /* 0.02 .. 20 Vpp */
      refreshGenLabels(); refreshLabels();
    });
    of.addEventListener('input', function(){
      state.gen[ch].off = (+of.value)/100;     /* -5 .. +5 V */
      refreshGenLabels(); refreshLabels();
    });
    ph.addEventListener('input', function(){
      state.gen[ch].ph = +ph.value;
      refreshGenLabels(); refreshLabels();
    });
  }
  bindGenSliders(1);
  bindGenSliders(2);

  /* set slider DOM from state (used by presets) */
  function syncGenSliders(){
    for(var ch=1;ch<=2;ch++){
      var g = state.gen[ch];
      $('freq'+ch).value = freqToSlider(g.freq);
      $('amp'+ch).value = Math.round(g.vpp*100);
      $('off'+ch).value = Math.round(g.off*100);
      $('ph'+ch).value = Math.round(g.ph);
      /* waveform buttons */
      var grp = $('wave'+ch);
      var btns = grp.getElementsByClassName('wbtn');
      for(var i=0;i<btns.length;i++){
        if(btns[i].getAttribute('data-w')===g.wave) btns[i].classList.add('on');
        else btns[i].classList.remove('on');
      }
    }
    refreshGenLabels();
  }

  /* ---------- waveform buttons ---------- */
  function bindWaveButtons(ch){
    var grp = $('wave'+ch);
    grp.addEventListener('click', function(e){
      var b = e.target;
      while(b && b !== grp && !b.classList.contains('wbtn')) b = b.parentNode;
      if(!b || b===grp) return;
      var w = b.getAttribute('data-w');
      state.gen[ch].wave = w;
      var btns = grp.getElementsByClassName('wbtn');
      for(var i=0;i<btns.length;i++) btns[i].classList.remove('on');
      b.classList.add('on');
      refreshLabels();
    });
  }
  bindWaveButtons(1);
  bindWaveButtons(2);

  /* ---------- trigger source / edge / mode / run-stop ---------- */
  function bindBtnGroup(groupId, attr, cb){
    var grp = $(groupId);
    grp.addEventListener('click', function(e){
      var b = e.target;
      while(b && b !== grp && !b.classList.contains('pbtn')) b = b.parentNode;
      if(!b || b===grp) return;
      var v = b.getAttribute(attr);
      if(v===null) return;
      var btns = grp.getElementsByClassName('pbtn');
      for(var i=0;i<btns.length;i++) btns[i].classList.remove('on');
      b.classList.add('on');
      cb(v);
    });
  }
  bindBtnGroup('trigSrc','data-src',function(v){ state.trigSrc = +v; refreshLabels(); });
  bindBtnGroup('trigEdge','data-edge',function(v){ state.trigEdge = v; refreshLabels(); });
  bindBtnGroup('modeBtns','data-mode',function(v){ state.mode = v; refreshLabels(); });

  $('runBtn').addEventListener('click', function(){
    if(!state.running){
      /* resume: rebase clock so phase continues from frozen point */
      startMs = Date.now() - frozenPhase*1000;
      state.running = true;
      $('pwrLed').classList.remove('off');
      $('pwrTxt').textContent = 'Run';
    }
  });
  $('stopBtn').addEventListener('click', function(){
    if(state.running){
      frozenPhase = runningPhase();
      state.running = false;
      $('pwrTxt').textContent = 'Stop';
    }
  });

  /* ---------- measurement channel tabs ---------- */
  $('measTabs').addEventListener('click', function(e){
    var b = e.target;
    if(!b.classList.contains('mtab')) return;
    var ch = +b.getAttribute('data-ch');
    state.measCh = ch;
    var tabs = $('measTabs').getElementsByClassName('mtab');
    for(var i=0;i<tabs.length;i++) tabs[i].classList.remove('on');
    b.classList.add('on');
    updateMeasPanel();
  });

  /* ---------- guided tasks / presets ---------- */
  var TASKS = [
    {
      tag:'Free Bench',
      html:'Turn the knobs and drag the sliders. Read amplitude on the vertical graticule (divisions multiplied by VOLTS/DIV) and period on the horizontal axis (divisions multiplied by TIME/DIV). Frequency is one divided by the period. AutoMeasure on the left confirms your hand readings.',
      apply:null
    },
    {
      tag:'Task 1 - Unknown Sine',
      html:'An <b>unknown sine</b> is on CH1. Adjust CH1 VOLTS/DIV and TIME/DIV until the wave fills a useful part of the screen. <ol><li>Count the vertical divisions peak-to-peak and multiply by VOLTS/DIV to get Vpp.</li><li>Count horizontal divisions for one full cycle and multiply by TIME/DIV to get the period T.</li><li>Compute frequency f = 1 / T.</li></ol><div class="ans" id="ans1"></div>',
      apply:function(){
        state.gen[1] = { wave:'sine', freq:1250, vpp:3.4, off:0, ph:0 };
        state.gen[2] = { wave:'sine', freq:1250, vpp:0, off:0, ph:0 };
        state.vdivIdx[1]=7; state.tdivIdx=11;
        state.mode='ch1'; state.trigSrc=1; state.trigLevel=0; state.trigEdge='up';
        state.measCh=1;
        setMode('ch1');
      },
      reveal:function(){
        var m = measureChannel(1);
        $('ans1').textContent = 'Answer: Vpp = '+fmtVolt(m.vpp)+', T = '+fmtTime(m.period)+', f = '+fmtFreq(m.freq)+'.';
      }
    },
    {
      tag:'Task 2 - Phase Difference',
      html:'Two sine waves of the <b>same frequency</b> are on CH1 and CH2. <ol><li>Use BOTH mode and align both zero levels to centre.</li><li>Measure the horizontal shift &Delta;t between the two zero-crossings, in divisions multiplied by TIME/DIV.</li><li>Phase = 360 multiplied by (&Delta;t / T) degrees.</li></ol><div class="ans" id="ans2"></div>',
      apply:function(){
        state.gen[1] = { wave:'sine', freq:1000, vpp:4, off:0, ph:0 };
        state.gen[2] = { wave:'sine', freq:1000, vpp:4, off:0, ph:60 };
        state.vdivIdx[1]=7; state.vdivIdx[2]=7; state.tdivIdx=11;
        state.mode='both'; state.trigSrc=1; state.trigLevel=0;
        state.measCh=1;
        setMode('both');
      },
      reveal:function(){
        var pd = phaseDiff();
        if(pd.type==='phase') $('ans2').textContent = 'Answer: CH2 leads CH1 by '+pd.value.toFixed(1)+' degrees.';
      }
    },
    {
      tag:'Task 3 - Lissajous Ratio',
      html:'Switch the scope to <b>X-Y</b> mode. CH1 drives X, CH2 drives Y. <ol><li>Count the tangent points where the figure touches a horizontal line (nx) and a vertical line (ny).</li><li>The frequency ratio is fCH1 : fCH2 = ny : nx.</li><li>Here CH2 is set to twice CH1 - look for the classic figure-eight.</li></ol><div class="ans" id="ans3"></div>',
      apply:function(){
        state.gen[1] = { wave:'sine', freq:500, vpp:6, off:0, ph:0 };
        state.gen[2] = { wave:'sine', freq:1000, vpp:6, off:0, ph:90 };
        state.vdivIdx[1]=7; state.vdivIdx[2]=7;
        state.mode='xy';
        state.measCh=2;
        setMode('xy');
      },
      reveal:function(){
        var pd = phaseDiff();
        if(pd.type==='ratio') $('ans3').textContent = 'Answer: fCH1 : fCH2 = '+pd.a+' : '+pd.b+'.';
      }
    },
    {
      tag:'Task 4 - Square / Duty',
      html:'A <b>square wave</b> is on CH1. <ol><li>Use a fast TIME/DIV to inspect the edges - an ideal generator gives a near-vertical transition.</li><li>Measure the high time and the full period; duty cycle = high / period (50% here).</li><li>Vpp spans the full peak-to-peak; note that Vrms of a 50% square equals half the Vpp.</li></ol><div class="ans" id="ans4"></div>',
      apply:function(){
        state.gen[1] = { wave:'square', freq:2000, vpp:5, off:0, ph:0 };
        state.gen[2] = { wave:'sine', freq:2000, vpp:0, off:0, ph:0 };
        state.vdivIdx[1]=7; state.tdivIdx=10;  /* 0.1 ms/div */
        state.mode='ch1'; state.trigSrc=1; state.trigLevel=0; state.trigEdge='up';
        state.measCh=1;
        setMode('ch1');
      },
      reveal:function(){
        var m = measureChannel(1);
        $('ans4').textContent = 'Answer: T = '+fmtTime(m.period)+', duty = 50%, Vpp = '+fmtVolt(m.vpp)+', Vrms = '+fmtVolt(m.vrms)+'.';
      }
    }
  ];

  /* programmatically set display mode buttons */
  function setMode(mode){
    state.mode = mode;
    var grp = $('modeBtns');
    var btns = grp.getElementsByClassName('pbtn');
    for(var i=0;i<btns.length;i++){
      if(btns[i].getAttribute('data-mode')===mode) btns[i].classList.add('on');
      else btns[i].classList.remove('on');
    }
  }
  function setTrigButtons(){
    var sg = $('trigSrc').getElementsByClassName('pbtn');
    for(var i=0;i<sg.length;i++){
      if(+sg[i].getAttribute('data-src')===state.trigSrc) sg[i].classList.add('on'); else sg[i].classList.remove('on');
    }
    var eg = $('trigEdge').getElementsByClassName('pbtn');
    for(var j=0;j<eg.length;j++){
      if(eg[j].getAttribute('data-edge')===state.trigEdge) eg[j].classList.add('on'); else eg[j].classList.remove('on');
    }
    var mt = $('measTabs').getElementsByClassName('mtab');
    for(var k=0;k<mt.length;k++){
      if(+mt[k].getAttribute('data-ch')===state.measCh) mt[k].classList.add('on'); else mt[k].classList.remove('on');
    }
  }

  function loadTask(idx){
    var t = TASKS[idx];
    $('guideBody').innerHTML = '<span class="gtag">'+t.tag+'</span>'+t.html;
    if(t.apply){
      t.apply();
      syncGenSliders();
      setTrigButtons();
      refreshLabels();
      /* reveal answer after a short observation period */
      if(t.reveal){
        setTimeout(function(){ try{ t.reveal(); }catch(e){} }, 50);
      }
    }
    /* active task button */
    var tb = $('taskbar').getElementsByClassName('cro-task');
    for(var i=0;i<tb.length;i++){
      if(+tb[i].getAttribute('data-task')===idx) tb[i].classList.add('active');
      else tb[i].classList.remove('active');
    }
  }
  $('taskbar').addEventListener('click', function(e){
    var b = e.target;
    if(!b.classList.contains('cro-task')) return;
    loadTask(+b.getAttribute('data-task'));
  });

  /* ---------- init ---------- */
  function init(){
    /* sync slider DOM with default state */
    syncGenSliders();
    setTrigButtons();
    refreshLabels();
    refreshGenLabels();
    loop();
  }
  init();
})();
</script>
</BaseLayout>
