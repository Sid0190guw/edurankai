---
import BaseLayout from '@/layouts/BaseLayout.astro';
// ECC workbench — real elliptic-curve cryptography on the ACTUAL secp256k1 curve
// (the one securing Bitcoin and TLS), not a toy mod-p demo. Full 256-bit BigInt
// field arithmetic, affine point add/double, double-and-add scalar multiply,
// real keypair generation, ECDH shared-secret agreement, and ECDSA signing +
// verification against SHA-256 (Web Crypto). Everything computed here.
---
<BaseLayout title="ECC workbench (secp256k1) · Virtual Labs · AquinTutor" description="Real elliptic-curve cryptography on secp256k1 — the curve behind Bitcoin and TLS. Generate 256-bit keys, agree a shared secret with ECDH, and sign and verify with ECDSA over SHA-256, all computed live in BigInt.">
<style>
  body{ background:#05070a; color:#e8ecf4; }
  .lb{ max-width:1180px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#34d399; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#34d399; font-style:italic; font-weight:500; }
  .lb-sub{ font-family:'Inter Tight',sans-serif; font-size:13.5px; color:#8ea0be; max-width:70ch; line-height:1.55; margin:8px 0 8px; }
  .curveband{ font-family:'Geist Mono',monospace; font-size:11px; color:#6ee7a8; background:linear-gradient(90deg,rgba(52,211,153,0.1),transparent); border-left:2px solid #34d399; padding:8px 12px; border-radius:0 8px 8px 0; margin:6px 0 20px; word-break:break-all; }
  .card{ background:linear-gradient(180deg,#0a1410,#070d0a); border:1px solid #163a2a; border-radius:16px; padding:20px; margin-bottom:16px; box-shadow:0 10px 30px rgba(0,0,0,0.4); }
  .card h3{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:#34d399; font-weight:700; margin:0 0 14px; display:flex; align-items:center; gap:10px; }
  .card h3 .n{ display:inline-flex; align-items:center; justify-content:center; width:22px; height:22px; border-radius:6px; background:#163a2a; color:#6ee7a8; font-size:12px; }
  .btn{ background:linear-gradient(180deg,#6ee7a8,#22c07e); color:#06140d; padding:10px 18px; border-radius:9px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:11px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; box-shadow:0 4px 14px rgba(34,192,126,0.3); }
  .btn-ghost{ background:transparent; color:#cfd6da; border:1px solid #1e4030; box-shadow:none; }
  .fld{ margin:10px 0; } .fld .lbl{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.1em; text-transform:uppercase; color:#8ea0be; font-weight:700; margin-bottom:4px; }
  .hex{ font-family:'Geist Mono',monospace; font-size:11.5px; color:#6ee7a8; background:#050c08; border:1px solid #163a2a; border-radius:8px; padding:9px 11px; word-break:break-all; line-height:1.5; }
  .hex.pub{ color:#7ad0ff; } .hex.sig{ color:#fbbf24; }
  .in{ width:100%; background:#050c08; border:1px solid #163a2a; color:#fff; padding:10px 12px; border-radius:8px; font-size:13px; font-family:inherit; outline:none; }
  .two{ display:grid; grid-template-columns:1fr 1fr; gap:16px; } @media(max-width:760px){ .two{ grid-template-columns:1fr; } }
  .badge{ display:inline-flex; align-items:center; gap:7px; font-family:'Geist Mono',monospace; font-size:12px; font-weight:700; padding:6px 14px; border-radius:99px; }
  .badge.ok{ background:rgba(52,211,153,0.15); color:#6ee7a8; border:1px solid #34d399; } .badge.bad{ background:rgba(248,113,113,0.15); color:#fca5a5; border:1px solid #f87171; }
  .canvaswrap{ border-radius:14px; overflow:hidden; border:1px solid #163a2a; } .canvaswrap canvas{ display:block; width:100%; height:auto; }
</style>
<main class="lb">
  <div>
    <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#34d399;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
    <p class="lb-eye" style="margin-top:10px;">Cybersecurity · Postgraduate · Production ECC</p>
    <h1 class="lb-title">ECC workbench &middot; <em>secp256k1</em>.</h1>
    <p class="lb-sub">Not a toy. This is the real curve — the exact 256-bit secp256k1 used by Bitcoin, Ethereum and TLS — with genuine field arithmetic, key generation, ECDH key agreement and ECDSA signatures verified against SHA-256. The private keys are drawn from the browser's cryptographic RNG. Nothing here is scaled down.</p>
    <div class="curveband">y² = x³ + 7  over  𝔽ₚ,  p = 2²⁵⁶ − 2³² − 977.  Generator order n ≈ 1.16 × 10⁷⁷ — a 256-bit prime.</div>
  </div>

  <div class="canvaswrap" style="margin-bottom:16px;"><canvas id="curve" width="1100" height="230"></canvas></div>

  <div class="card">
    <h3><span class="n">1</span> Key generation &nbsp;·&nbsp; Q = d·G</h3>
    <button id="genA" class="btn">Generate keypair</button>
    <div class="fld" style="margin-top:14px;"><div class="lbl">private key d (256-bit, secret)</div><div class="hex" id="dA">—</div></div>
    <div class="fld"><div class="lbl">public key Q = d·G (compressed, 33 bytes)</div><div class="hex pub" id="QA">—</div></div>
    <div class="fld"><div class="lbl">scalar multiplications performed (double-and-add)</div><div class="hex" id="opsA" style="color:#8ea0be;">—</div></div>
  </div>

  <div class="card">
    <h3><span class="n">2</span> ECDH &nbsp;·&nbsp; shared secret without ever sending d</h3>
    <div class="two">
      <div><div class="lbl" style="font-family:'Geist Mono',monospace;font-size:9.5px;color:#8ea0be;text-transform:uppercase;letter-spacing:0.1em;">Alice public</div><div class="hex pub" id="pubAl" style="margin-top:4px;">—</div></div>
      <div><div class="lbl" style="font-family:'Geist Mono',monospace;font-size:9.5px;color:#8ea0be;text-transform:uppercase;letter-spacing:0.1em;">Bob public</div><div class="hex pub" id="pubBo" style="margin-top:4px;">—</div></div>
    </div>
    <button id="ecdh" class="btn" style="margin-top:14px;">Run ECDH exchange</button>
    <div class="fld" style="margin-top:14px;"><div class="lbl">Alice computes d_A · Q_B</div><div class="hex" id="shA">—</div></div>
    <div class="fld"><div class="lbl">Bob computes d_B · Q_A</div><div class="hex" id="shB">—</div></div>
    <div id="ecdhBadge"></div>
  </div>

  <div class="card">
    <h3><span class="n">3</span> ECDSA &nbsp;·&nbsp; sign &amp; verify over SHA-256</h3>
    <div class="fld"><div class="lbl">message</div><input id="msg" class="in" value="Transfer 5 BTC to Alice."/></div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;"><button id="sign" class="btn">Sign with d_A</button><button id="verify" class="btn btn-ghost">Verify with Q_A</button><button id="tamper" class="btn btn-ghost">Tamper &amp; re-verify</button></div>
    <div class="fld" style="margin-top:14px;"><div class="lbl">SHA-256(message) → z</div><div class="hex" id="z" style="color:#8ea0be;">—</div></div>
    <div class="two">
      <div class="fld"><div class="lbl">signature r</div><div class="hex sig" id="sigR">—</div></div>
      <div class="fld"><div class="lbl">signature s</div><div class="hex sig" id="sigS">—</div></div>
    </div>
    <div id="verBadge"></div>
  </div>
</main>
<script is:inline>
(function(){
  // secp256k1
  var p=0xFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFEFFFFFC2Fn;
  var a=0n, b=7n;
  var Gx=0x79BE667EF9DCBBAC55A06295CE870B07029BFCDB2DCE28D959F2815B16F81798n;
  var Gy=0x483ADA7726A3C4655DA4FBFC0E1108A8FD17B448A68554199C47D08FFB10D4B8n;
  var n=0xFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFEBAAEDCE6AF48A03BBFD25E8CD0364141n;
  var G={x:Gx,y:Gy};
  function mod(x,m){ x%=m; return x<0n?x+m:x; }
  function egcd(a,b){ var or=a,r=b,os=1n,s=0n; while(r!==0n){ var q=or/r; var t=or-q*r; or=r; r=t; t=os-q*s; os=s; s=t; } return [or,os]; }
  function inv(x,m){ x=mod(x,m); var g=egcd(x,m); if(g[0]!==1n) return 0n; return mod(g[1],m); }
  var opCount=0;
  function add(P,Q){ if(!P) return Q; if(!Q) return P; if(P.x===Q.x){ if(mod(P.y+Q.y,p)===0n) return null; return dbl(P); }
    var m=mod((Q.y-P.y)*inv(Q.x-P.x,p),p); var x=mod(m*m-P.x-Q.x,p); return {x:x,y:mod(m*(P.x-x)-P.y,p)}; }
  function dbl(P){ if(!P) return null; if(P.y===0n) return null; var m=mod((3n*P.x*P.x+a)*inv(2n*P.y,p),p); var x=mod(m*m-2n*P.x,p); return {x:x,y:mod(m*(P.x-x)-P.y,p)}; }
  function mul(k,P){ opCount=0; var R=null,A=P; k=mod(k,n); while(k>0n){ if(k&1n){ R=add(R,A); } A=dbl(A); opCount++; k>>=1n; } return R; }
  function randScalar(){ var bytes=new Uint8Array(32); crypto.getRandomValues(bytes); var x=0n; for(var i=0;i<32;i++) x=(x<<8n)|BigInt(bytes[i]); x=mod(x,n-1n)+1n; return x; }
  function hx(x){ var s=x.toString(16); while(s.length<64) s='0'+s; return '0x'+s; }
  function compress(P){ if(!P) return '(point at infinity)'; var pre=(P.y&1n)?'03':'02'; var xs=P.x.toString(16); while(xs.length<64) xs='0'+xs; return '0x'+pre+xs; }
  async function sha256Int(msg){ var enc=new TextEncoder().encode(msg); var h=await crypto.subtle.digest('SHA-256', enc); var arr=new Uint8Array(h); var x=0n; for(var i=0;i<arr.length;i++) x=(x<<8n)|BigInt(arr[i]); return mod(x,n); }

  // key state
  var dA, QA, dB, QB;
  function genA(){ dA=randScalar(); QA=mul(dA,G); document.getElementById('dA').textContent=hx(dA); document.getElementById('QA').textContent=compress(QA); document.getElementById('opsA').textContent=opCount+' point doublings + additions on a 256-bit curve'; refreshPubs(); }
  function refreshPubs(){ if(QA) document.getElementById('pubAl').textContent=compress(QA); if(QB) document.getElementById('pubBo').textContent=compress(QB); }
  document.getElementById('genA').addEventListener('click',genA);

  document.getElementById('ecdh').addEventListener('click',function(){ if(!dA) genA(); dB=randScalar(); QB=mul(dB,G); refreshPubs();
    var sAB=mul(dA,QB), sBA=mul(dB,QA); document.getElementById('shA').textContent=hx(sAB.x); document.getElementById('shB').textContent=hx(sBA.x);
    var same=sAB.x===sBA.x; document.getElementById('ecdhBadge').innerHTML='<div style="margin-top:12px;"><span class="badge '+(same?'ok':'bad')+'">'+(same?'✓ shared secrets identical — key agreed over an open channel':'mismatch')+'</span></div>'; });

  var sig=null, sigMsg='';
  document.getElementById('sign').addEventListener('click',async function(){ if(!dA) genA(); var msg=document.getElementById('msg').value; var z=await sha256Int(msg); document.getElementById('z').textContent=hx(z);
    var r,s,k; do{ k=randScalar(); var R=mul(k,G); r=mod(R.x,n); if(r===0n) continue; s=mod(inv(k,n)*mod(z+r*dA,n),n); }while(s===0n);
    sig={r:r,s:s}; sigMsg=msg; document.getElementById('sigR').textContent=hx(r); document.getElementById('sigS').textContent=hx(s); document.getElementById('verBadge').innerHTML='<div style="margin-top:12px;font-family:Geist Mono,monospace;font-size:12px;color:#8ea0be;">signed — press Verify.</div>'; });

  async function verifyNow(msg){ if(!sig||!QA) return null; var z=await sha256Int(msg); var r=sig.r,s=sig.s; if(r<=0n||r>=n||s<=0n||s>=n) return false; var w=inv(s,n); var u1=mod(z*w,n), u2=mod(r*w,n); var P=add(mul(u1,G),mul(u2,QA)); if(!P) return false; return mod(P.x,n)===r; }
  document.getElementById('verify').addEventListener('click',async function(){ var ok=await verifyNow(document.getElementById('msg').value); badge(ok, ok?'✓ signature valid — message authentic and untampered':'✗ signature invalid'); });
  document.getElementById('tamper').addEventListener('click',async function(){ var orig=document.getElementById('msg').value; var ok=await verifyNow(orig+' '); badge(ok, ok?'valid?!':'✗ rejected — one extra byte changed SHA-256(z); the signature no longer verifies'); });
  function badge(ok,txt){ document.getElementById('verBadge').innerHTML='<div style="margin-top:12px;"><span class="badge '+(ok?'ok':'bad')+'">'+txt+'</span></div>'; }

  // geometric intuition: real-number curve y^2 = x^3 + 7 with P+Q=R construction
  function drawCurve(){ var cv=document.getElementById('curve'); var d=window.devicePixelRatio||1; var r=cv.getBoundingClientRect(); var W=r.width||1100, H=(230/1100)*W; cv.width=W*d; cv.height=H*d; var ctx=cv.getContext('2d'); ctx.setTransform(d,0,0,d,0,0);
    var bg=ctx.createLinearGradient(0,0,0,H); bg.addColorStop(0,'#081310'); bg.addColorStop(1,'#050c08'); ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    var cx=W*0.5, cy=H*0.5, sc=H/9; function X(x){ return cx+x*sc; } function Y(y){ return cy-y*sc; }
    ctx.strokeStyle='#12261c'; ctx.beginPath(); ctx.moveTo(0,cy); ctx.lineTo(W,cy); ctx.moveTo(cx,0); ctx.lineTo(cx,H); ctx.stroke();
    // curve y^2=x^3+7 (a=0,b=7); real form: for x where x^3+7>=0 i.e. x>=-cbrt7
    ctx.save(); ctx.shadowColor='#34d399'; ctx.shadowBlur=8; ctx.strokeStyle='#34d399'; ctx.lineWidth=2; ctx.beginPath(); var started=false;
    for(var px=0;px<=W;px++){ var x=(px-cx)/sc; var rhs=x*x*x+7; if(rhs<0){ started=false; continue; } var y=Math.sqrt(rhs); var yp=Y(y); if(!started){ ctx.moveTo(px,yp); started=true; } else ctx.lineTo(px,yp); } ctx.stroke();
    started=false; ctx.beginPath(); for(var px=0;px<=W;px++){ var x=(px-cx)/sc; var rhs=x*x*x+7; if(rhs<0){ started=false; continue; } var y=-Math.sqrt(rhs); var yp=Y(y); if(!started){ ctx.moveTo(px,yp); started=true; } else ctx.lineTo(px,yp); } ctx.stroke(); ctx.restore();
    // demo chord P+Q=R
    function pt(x){ return {x:x,y:Math.sqrt(x*x*x+7)}; } var P=pt(-1.6), Q=pt(0.4); var m=(Q.y-P.y)/(Q.x-P.x); var Rx=m*m-P.x-Q.x; var Ry=m*(P.x-Rx)-P.y; var R3={x:Rx,y:Ry};
    ctx.strokeStyle='rgba(122,208,255,0.7)'; ctx.lineWidth=1.4; ctx.beginPath(); ctx.moveTo(X(P.x-1),Y(P.y-m*1)); ctx.lineTo(X(R3.x+1),Y(P.y+m*(R3.x+1-P.x))); ctx.stroke();
    ctx.setLineDash([4,4]); ctx.strokeStyle='rgba(251,191,36,0.7)'; ctx.beginPath(); ctx.moveTo(X(Rx),Y(Ry)); ctx.lineTo(X(Rx),Y(-Ry)); ctx.stroke(); ctx.setLineDash([]);
    function dot(pp,col,lab){ ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=10; ctx.fillStyle=col; ctx.beginPath(); ctx.arc(X(pp.x),Y(pp.y),5,0,7); ctx.fill(); ctx.restore(); ctx.fillStyle=col; ctx.font="12px 'Geist Mono',monospace"; ctx.fillText(lab,X(pp.x)+8,Y(pp.y)-6); }
    dot(P,'#7ad0ff','P'); dot(Q,'#7ad0ff','Q'); dot({x:Rx,y:Ry},'#8ea0be','—R'); dot({x:Rx,y:-Ry},'#34d399','P+Q');
    ctx.fillStyle='#8ea0be'; ctx.font="11px 'Geist Mono',monospace"; ctx.fillText('group law (over ℝ for intuition): line through P,Q meets curve at −R, reflect to get P+Q. The real crypto below runs this over 𝔽ₚ with 256-bit coordinates.', 14, H-12);
  }
  drawCurve(); window.addEventListener('resize',function(){ clearTimeout(window._t); window._t=setTimeout(drawCurve,150); });
  genA();
})();
</script>
</BaseLayout>
