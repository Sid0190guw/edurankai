---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Ecosystem Dynamics Lab — AquinTutor" description="Lotka-Volterra predator-prey simulator with RK4 integration, phase portraits, and three-species food chain extension.">
<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; font-family: 'Inter', system-ui, sans-serif; }
  .eco-wrap { max-width: 1280px; margin: 0 auto; padding: 48px 24px 96px; }
  .eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 12px; }
  .title { font-family: 'Cormorant Garamond', serif; font-size: 34px; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 8px; line-height: 1.15; }
  .title em { font-style: italic; color: #67e8f9; font-weight: 500; }
  .lede { color: #9aa3ad; font-size: 14px; max-width: 720px; margin: 0 0 32px; line-height: 1.6; }
  .grid { display: grid; grid-template-columns: 320px 1fr; gap: 18px; }
  @media (max-width: 980px) { .grid { grid-template-columns: 1fr; } }
  .panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 16px; }
  .panel h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 14px; }
  .panel + .panel { margin-top: 14px; }
  .slider-row { margin-bottom: 12px; }
  .slider-row label { display: flex; justify-content: space-between; font-family: 'Geist Mono', monospace; font-size: 11px; color: #cfd6da; margin-bottom: 4px; }
  .slider-row label span:last-child { color: #67e8f9; font-weight: 700; }
  .slider-row input[type=range] { width: 100%; accent-color: #67e8f9; }
  .btn { background: #67e8f9; color: #04161b; padding: 9px 16px; border-radius: 6px; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; border: 0; cursor: pointer; }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .btn-ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; padding: 9px 16px; border-radius: 6px; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; cursor: pointer; }
  .btn-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 6px; }
  .preset-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
  .preset-grid button { background: #0a0a0c; color: #cfd6da; border: 1px solid #2a2a35; padding: 8px; border-radius: 5px; font-family: 'Geist Mono', monospace; font-size: 10px; cursor: pointer; text-align: left; line-height: 1.3; }
  .preset-grid button:hover { border-color: #67e8f9; color: #67e8f9; }
  .toggle-row { display: flex; align-items: center; gap: 10px; padding: 10px; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 6px; }
  .toggle-row label { font-family: 'Geist Mono', monospace; font-size: 11px; color: #cfd6da; flex: 1; cursor: pointer; }
  .toggle { position: relative; width: 36px; height: 20px; background: #2a2a35; border-radius: 10px; cursor: pointer; transition: background 0.2s; }
  .toggle.on { background: #67e8f9; }
  .toggle::after { content: ''; position: absolute; top: 2px; left: 2px; width: 16px; height: 16px; background: #fff; border-radius: 50%; transition: transform 0.2s; }
  .toggle.on::after { transform: translateX(16px); }
  canvas { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 10px; display: block; }
  .canvas-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  @media (max-width: 720px) { .canvas-grid { grid-template-columns: 1fr; } }
  .canvas-label { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #67e8f9; margin: 0 0 8px; font-weight: 700; }
  .legend { display: flex; gap: 14px; margin-top: 8px; font-family: 'Geist Mono', monospace; font-size: 11px; color: #cfd6da; flex-wrap: wrap; }
  .legend span { display: inline-flex; align-items: center; gap: 6px; }
  .legend i { width: 14px; height: 3px; border-radius: 2px; display: inline-block; }
  .stat-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-top: 12px; }
  .stat { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 6px; padding: 10px; }
  .stat .k { font-family: 'Geist Mono', monospace; font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: #67e8f9; font-weight: 700; }
  .stat .v { font-family: 'Cormorant Garamond', serif; font-size: 22px; color: #fff; margin-top: 2px; }
  .eq-box { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 6px; padding: 10px; font-family: 'Geist Mono', monospace; font-size: 11px; color: #9aa3ad; line-height: 1.7; }
  .eq-box code { color: #67e8f9; }
  .three-only { display: none; }
  .three-mode .three-only { display: block; }
</style>
<main class="eco-wrap">
  <div class="eyebrow">Lab 11 / Dynamical Systems</div>
  <h1 class="title">Ecosystem <em>dynamics</em> &mdash; predator, prey, and the orbit of populations</h1>
  <p class="lede">A live Lotka-Volterra solver integrated with classical Runge-Kutta 4. Drag the parameters and watch closed orbits emerge in phase space &mdash; or break them, and watch a population collapse. Toggle the three-species extension to add an apex predator and see how a single trophic level changes everything.</p>

  <div class="grid">
    <div>
      <div class="panel">
        <h3>Parameters</h3>
        <div class="slider-row">
          <label><span>&alpha; prey growth</span><span id="vAlpha">1.10</span></label>
          <input type="range" id="alpha" min="0.1" max="2.0" step="0.01" value="1.1" />
        </div>
        <div class="slider-row">
          <label><span>&beta; predation rate</span><span id="vBeta">0.040</span></label>
          <input type="range" id="beta" min="0.01" max="0.5" step="0.001" value="0.04" />
        </div>
        <div class="slider-row">
          <label><span>&gamma; predator death</span><span id="vGamma">0.40</span></label>
          <input type="range" id="gamma" min="0.1" max="2.0" step="0.01" value="0.4" />
        </div>
        <div class="slider-row">
          <label><span>&delta; predator efficiency</span><span id="vDelta">0.0200</span></label>
          <input type="range" id="delta" min="0.001" max="0.05" step="0.0001" value="0.02" />
        </div>
        <div class="slider-row">
          <label><span>x&#8320; initial prey</span><span id="vX0">40</span></label>
          <input type="range" id="x0" min="10" max="500" step="1" value="40" />
        </div>
        <div class="slider-row">
          <label><span>y&#8320; initial predator</span><span id="vY0">9</span></label>
          <input type="range" id="y0" min="5" max="200" step="1" value="9" />
        </div>
        <div class="three-only">
          <div class="slider-row">
            <label><span>&epsilon; apex predation</span><span id="vEps">0.010</span></label>
            <input type="range" id="eps" min="0.001" max="0.1" step="0.0005" value="0.01" />
          </div>
          <div class="slider-row">
            <label><span>&zeta; apex efficiency</span><span id="vZeta">0.0050</span></label>
            <input type="range" id="zeta" min="0.0005" max="0.05" step="0.0001" value="0.005" />
          </div>
          <div class="slider-row">
            <label><span>&eta; apex death</span><span id="vEta">0.30</span></label>
            <input type="range" id="eta" min="0.05" max="1.5" step="0.01" value="0.3" />
          </div>
          <div class="slider-row">
            <label><span>z&#8320; initial apex</span><span id="vZ0">5</span></label>
            <input type="range" id="z0" min="1" max="100" step="1" value="5" />
          </div>
        </div>
        <div class="btn-row">
          <button class="btn" id="btnRun">Pause</button>
          <button class="btn-ghost" id="btnReset">Reset</button>
        </div>
      </div>

      <div class="panel">
        <h3>Presets</h3>
        <div class="preset-grid">
          <button data-preset="stable">Stable<br/>oscillation</button>
          <button data-preset="extinct">Predator<br/>extinction</button>
          <button data-preset="over">Prey<br/>overgrowth</button>
          <button data-preset="boom">Boom-<br/>bust</button>
        </div>
      </div>

      <div class="panel">
        <h3>Three-species mode</h3>
        <div class="toggle-row">
          <label for="threeToggle">Add apex predator <strong style="color:#67e8f9">z</strong></label>
          <div class="toggle" id="threeToggle" role="switch" aria-checked="false" tabindex="0"></div>
        </div>
      </div>

      <div class="panel">
        <h3>Equations</h3>
        <div class="eq-box" id="eqBox">
          <code>dx/dt = &alpha;x &minus; &beta;xy</code><br/>
          <code>dy/dt = &delta;xy &minus; &gamma;y</code>
        </div>
      </div>
    </div>

    <div>
      <div class="panel">
        <h3>Time series</h3>
        <p class="canvas-label">Population vs. time &mdash; t window scrolls</p>
        <canvas id="cTime" width="900" height="320"></canvas>
        <div class="legend">
          <span><i style="background:#5be8a3"></i>Prey x</span>
          <span><i style="background:#ff6a5b"></i>Predator y</span>
          <span class="three-only"><i style="background:#c084fc"></i>Apex z</span>
        </div>
        <div class="stat-row">
          <div class="stat"><div class="k">t</div><div class="v" id="sT">0.00</div></div>
          <div class="stat"><div class="k">x prey</div><div class="v" id="sX">40</div></div>
          <div class="stat"><div class="k">y pred</div><div class="v" id="sY">9</div></div>
          <div class="stat"><div class="k">z apex</div><div class="v" id="sZ">&mdash;</div></div>
        </div>
      </div>

      <div class="panel" style="margin-top:14px;">
        <div class="canvas-grid">
          <div>
            <p class="canvas-label">Phase portrait &mdash; x &times; y</p>
            <canvas id="cPhase" width="500" height="380"></canvas>
          </div>
          <div>
            <p class="canvas-label">Ecosystem field &mdash; live</p>
            <canvas id="cField" width="500" height="380"></canvas>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<script is:inline>
(function () {
  // ----- state -----
  var P = {
    alpha: 1.1, beta: 0.04, gamma: 0.4, delta: 0.02,
    eps: 0.01, zeta: 0.005, eta: 0.3,
    x: 40, y: 9, z: 5,
    x0: 40, y0: 9, z0: 5,
    t: 0, dt: 0.01,
    running: true,
    threeMode: false
  };

  // history buffers
  var HIST_LEN = 2000;
  var histT = [], histX = [], histY = [], histZ = [];
  var phaseTrail = []; // last N (x,y) points
  var PHASE_TRAIL_LEN = 600;

  // ----- helpers -----
  function $(id) { return document.getElementById(id); }
  function clamp(v, lo, hi) { return v < lo ? lo : (v > hi ? hi : v); }

  // ----- derivatives -----
  function deriv2(x, y) {
    var dx = P.alpha * x - P.beta * x * y;
    var dy = P.delta * x * y - P.gamma * y;
    return [dx, dy];
  }
  function deriv3(x, y, z) {
    var dx = P.alpha * x - P.beta * x * y;
    var dy = P.delta * x * y - P.gamma * y - P.eps * y * z;
    var dz = P.zeta * y * z - P.eta * z;
    return [dx, dy, dz];
  }

  // ----- RK4 step -----
  function rk4Step2() {
    var x = P.x, y = P.y, h = P.dt;
    var k1 = deriv2(x, y);
    var k2 = deriv2(x + 0.5*h*k1[0], y + 0.5*h*k1[1]);
    var k3 = deriv2(x + 0.5*h*k2[0], y + 0.5*h*k2[1]);
    var k4 = deriv2(x + h*k3[0], y + h*k3[1]);
    P.x = x + (h/6)*(k1[0] + 2*k2[0] + 2*k3[0] + k4[0]);
    P.y = y + (h/6)*(k1[1] + 2*k2[1] + 2*k3[1] + k4[1]);
    if (P.x < 0) P.x = 0;
    if (P.y < 0) P.y = 0;
  }
  function rk4Step3() {
    var x = P.x, y = P.y, z = P.z, h = P.dt;
    var k1 = deriv3(x, y, z);
    var k2 = deriv3(x + 0.5*h*k1[0], y + 0.5*h*k1[1], z + 0.5*h*k1[2]);
    var k3 = deriv3(x + 0.5*h*k2[0], y + 0.5*h*k2[1], z + 0.5*h*k2[2]);
    var k4 = deriv3(x + h*k3[0], y + h*k3[1], z + h*k3[2]);
    P.x = x + (h/6)*(k1[0] + 2*k2[0] + 2*k3[0] + k4[0]);
    P.y = y + (h/6)*(k1[1] + 2*k2[1] + 2*k3[1] + k4[1]);
    P.z = z + (h/6)*(k1[2] + 2*k2[2] + 2*k3[2] + k4[2]);
    if (P.x < 0) P.x = 0;
    if (P.y < 0) P.y = 0;
    if (P.z < 0) P.z = 0;
  }

  // ----- canvases -----
  var cT = $('cTime'), cP = $('cPhase'), cF = $('cField');
  var gT = cT.getContext('2d'), gP = cP.getContext('2d'), gF = cF.getContext('2d');

  function resizeForDPR(c) {
    var dpr = window.devicePixelRatio || 1;
    var rect = c.getBoundingClientRect();
    c.width = Math.floor(rect.width * dpr);
    c.height = Math.floor(rect.height * dpr);
    c.getContext('2d').setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function drawTime() {
    var w = cT.clientWidth, h = cT.clientHeight;
    gT.clearRect(0, 0, w, h);
    // grid
    gT.strokeStyle = '#1c1f28'; gT.lineWidth = 1;
    for (var i = 0; i <= 10; i++) {
      var yy = (i / 10) * h;
      gT.beginPath(); gT.moveTo(0, yy); gT.lineTo(w, yy); gT.stroke();
    }
    for (var j = 0; j <= 10; j++) {
      var xx = (j / 10) * w;
      gT.beginPath(); gT.moveTo(xx, 0); gT.lineTo(xx, h); gT.stroke();
    }
    if (histT.length < 2) return;
    // find max for scaling
    var maxV = 1;
    for (var k = 0; k < histX.length; k++) {
      if (histX[k] > maxV) maxV = histX[k];
      if (histY[k] > maxV) maxV = histY[k];
      if (P.threeMode && histZ[k] > maxV) maxV = histZ[k];
    }
    maxV = maxV * 1.1;
    var tMin = histT[0], tMax = histT[histT.length - 1];
    var tSpan = Math.max(0.001, tMax - tMin);
    function sx(t) { return ((t - tMin) / tSpan) * w; }
    function sy(v) { return h - (v / maxV) * h; }

    function plot(arr, color) {
      gT.strokeStyle = color; gT.lineWidth = 2;
      gT.beginPath();
      for (var i = 0; i < arr.length; i++) {
        var x = sx(histT[i]), y = sy(arr[i]);
        if (i === 0) gT.moveTo(x, y); else gT.lineTo(x, y);
      }
      gT.stroke();
    }
    plot(histX, '#5be8a3');
    plot(histY, '#ff6a5b');
    if (P.threeMode) plot(histZ, '#c084fc');

    // axis labels
    gT.fillStyle = '#67e8f9'; gT.font = '10px "Geist Mono", monospace';
    gT.fillText('pop ' + maxV.toFixed(0), 6, 12);
    gT.fillText('0', 6, h - 4);
    gT.fillText('t=' + tMax.toFixed(1), w - 60, h - 4);
  }

  function drawPhase() {
    var w = cP.clientWidth, h = cP.clientHeight;
    gP.clearRect(0, 0, w, h);
    // grid
    gP.strokeStyle = '#1c1f28'; gP.lineWidth = 1;
    for (var i = 0; i <= 10; i++) {
      gP.beginPath(); gP.moveTo(0, (i/10)*h); gP.lineTo(w, (i/10)*h); gP.stroke();
      gP.beginPath(); gP.moveTo((i/10)*w, 0); gP.lineTo((i/10)*w, h); gP.stroke();
    }
    if (phaseTrail.length < 2) return;
    // scale
    var maxX = 1, maxY = 1;
    for (var k = 0; k < phaseTrail.length; k++) {
      if (phaseTrail[k][0] > maxX) maxX = phaseTrail[k][0];
      if (phaseTrail[k][1] > maxY) maxY = phaseTrail[k][1];
    }
    maxX *= 1.15; maxY *= 1.15;
    var pad = 30;
    function px(v) { return pad + (v / maxX) * (w - pad - 8); }
    function py(v) { return h - pad - (v / maxY) * (h - pad - 8); }

    // trail with fading alpha
    for (var i = 1; i < phaseTrail.length; i++) {
      var a = i / phaseTrail.length;
      gP.strokeStyle = 'rgba(103, 232, 249, ' + (0.15 + a * 0.55) + ')';
      gP.lineWidth = 1.2;
      gP.beginPath();
      gP.moveTo(px(phaseTrail[i-1][0]), py(phaseTrail[i-1][1]));
      gP.lineTo(px(phaseTrail[i][0]), py(phaseTrail[i][1]));
      gP.stroke();
    }

    // current point
    var cur = phaseTrail[phaseTrail.length - 1];
    gP.fillStyle = '#67e8f9';
    gP.beginPath(); gP.arc(px(cur[0]), py(cur[1]), 5, 0, Math.PI * 2); gP.fill();

    // equilibrium point (gamma/delta, alpha/beta)
    var ex = P.gamma / P.delta, ey = P.alpha / P.beta;
    if (ex < maxX && ey < maxY) {
      gP.strokeStyle = '#ff6a5b'; gP.lineWidth = 1.5;
      gP.beginPath();
      gP.moveTo(px(ex) - 6, py(ey)); gP.lineTo(px(ex) + 6, py(ey));
      gP.moveTo(px(ex), py(ey) - 6); gP.lineTo(px(ex), py(ey) + 6);
      gP.stroke();
    }

    // axes labels
    gP.fillStyle = '#67e8f9'; gP.font = '10px "Geist Mono", monospace';
    gP.fillText('x (prey)', w - 70, h - 6);
    gP.save(); gP.translate(12, 14); gP.fillText('y (predator)', 0, 0); gP.restore();
  }

  function drawField() {
    var w = cF.clientWidth, h = cF.clientHeight;
    // soft fade trail
    gF.fillStyle = 'rgba(10, 10, 12, 0.22)';
    gF.fillRect(0, 0, w, h);

    var preyN = Math.min(220, Math.round(P.x * 1.2));
    var predN = Math.min(140, Math.round(P.y * 1.5));
    var apexN = P.threeMode ? Math.min(80, Math.round(P.z * 2)) : 0;

    // seeded pseudo-random based on time so dots wander coherently
    var tt = P.t;
    for (var i = 0; i < preyN; i++) {
      var seed = i * 13.37;
      var jx = Math.sin(seed * 0.7 + tt * 0.6) * 0.5 + 0.5;
      var jy = Math.cos(seed * 1.1 + tt * 0.5) * 0.5 + 0.5;
      var x = jx * (w - 12) + 6;
      var y = jy * (h - 12) + 6;
      gF.fillStyle = 'rgba(91, 232, 163, 0.85)';
      gF.beginPath(); gF.arc(x, y, 2.2, 0, Math.PI * 2); gF.fill();
    }
    for (var p = 0; p < predN; p++) {
      var s2 = p * 7.91 + 100;
      var px2 = (Math.sin(s2 * 0.9 + tt * 0.9) * 0.5 + 0.5) * (w - 16) + 8;
      var py2 = (Math.cos(s2 * 0.6 + tt * 0.7) * 0.5 + 0.5) * (h - 16) + 8;
      gF.fillStyle = 'rgba(255, 106, 91, 0.92)';
      gF.beginPath(); gF.arc(px2, py2, 3.0, 0, Math.PI * 2); gF.fill();
    }
    for (var q = 0; q < apexN; q++) {
      var s3 = q * 5.27 + 500;
      var qx = (Math.sin(s3 * 0.4 + tt * 0.4) * 0.5 + 0.5) * (w - 22) + 11;
      var qy = (Math.cos(s3 * 0.8 + tt * 0.35) * 0.5 + 0.5) * (h - 22) + 11;
      gF.fillStyle = 'rgba(192, 132, 252, 0.95)';
      gF.beginPath(); gF.arc(qx, qy, 4.0, 0, Math.PI * 2); gF.fill();
    }

    // count overlay
    gF.fillStyle = '#67e8f9'; gF.font = '10px "Geist Mono", monospace';
    gF.fillText('prey ' + Math.round(P.x), 8, 14);
    gF.fillText('pred ' + Math.round(P.y), 8, 28);
    if (P.threeMode) gF.fillText('apex ' + Math.round(P.z), 8, 42);
  }

  function pushHistory() {
    histT.push(P.t); histX.push(P.x); histY.push(P.y); histZ.push(P.z);
    if (histT.length > HIST_LEN) {
      histT.shift(); histX.shift(); histY.shift(); histZ.shift();
    }
    phaseTrail.push([P.x, P.y]);
    if (phaseTrail.length > PHASE_TRAIL_LEN) phaseTrail.shift();
  }

  function updateStats() {
    $('sT').textContent = P.t.toFixed(2);
    $('sX').textContent = P.x.toFixed(1);
    $('sY').textContent = P.y.toFixed(1);
    $('sZ').textContent = P.threeMode ? P.z.toFixed(1) : '—';
  }

  function updateEq() {
    if (P.threeMode) {
      $('eqBox').innerHTML =
        '<code>dx/dt = &alpha;x &minus; &beta;xy</code><br/>' +
        '<code>dy/dt = &delta;xy &minus; &gamma;y &minus; &epsilon;yz</code><br/>' +
        '<code>dz/dt = &zeta;yz &minus; &eta;z</code>';
    } else {
      $('eqBox').innerHTML =
        '<code>dx/dt = &alpha;x &minus; &beta;xy</code><br/>' +
        '<code>dy/dt = &delta;xy &minus; &gamma;y</code>';
    }
  }

  // ----- animation loop -----
  var stepsPerFrame = 8;
  function loop() {
    if (P.running) {
      for (var s = 0; s < stepsPerFrame; s++) {
        if (P.threeMode) rk4Step3(); else rk4Step2();
        P.t += P.dt;
      }
      pushHistory();
    }
    drawTime(); drawPhase(); drawField();
    updateStats();
    requestAnimationFrame(loop);
  }

  // ----- controls -----
  function bindSlider(id, key, label, fmt) {
    var el = $(id), lbl = $(label);
    el.addEventListener('input', function () {
      P[key] = parseFloat(el.value);
      lbl.textContent = fmt(P[key]);
    });
    lbl.textContent = fmt(P[key]);
  }
  var f2 = function (v) { return v.toFixed(2); };
  var f3 = function (v) { return v.toFixed(3); };
  var f4 = function (v) { return v.toFixed(4); };
  var fi = function (v) { return Math.round(v).toString(); };

  bindSlider('alpha', 'alpha', 'vAlpha', f2);
  bindSlider('beta', 'beta', 'vBeta', f3);
  bindSlider('gamma', 'gamma', 'vGamma', f2);
  bindSlider('delta', 'delta', 'vDelta', f4);
  bindSlider('x0', 'x0', 'vX0', fi);
  bindSlider('y0', 'y0', 'vY0', fi);
  bindSlider('eps', 'eps', 'vEps', f3);
  bindSlider('zeta', 'zeta', 'vZeta', f4);
  bindSlider('eta', 'eta', 'vEta', f2);
  bindSlider('z0', 'z0', 'vZ0', fi);

  function resetState() {
    P.x = P.x0; P.y = P.y0; P.z = P.z0; P.t = 0;
    histT = []; histX = []; histY = []; histZ = [];
    phaseTrail = [];
  }

  $('btnRun').addEventListener('click', function () {
    P.running = !P.running;
    this.textContent = P.running ? 'Pause' : 'Resume';
  });
  $('btnReset').addEventListener('click', resetState);

  // presets
  var presets = {
    stable:  { alpha: 1.1, beta: 0.04, gamma: 0.4,  delta: 0.02,   x0: 40,  y0: 9 },
    extinct: { alpha: 0.3, beta: 0.2,  gamma: 1.5,  delta: 0.008,  x0: 30,  y0: 25 },
    over:    { alpha: 1.8, beta: 0.05, gamma: 1.6,  delta: 0.003,  x0: 100, y0: 40 },
    boom:    { alpha: 1.6, beta: 0.08, gamma: 0.6,  delta: 0.035,  x0: 30,  y0: 6 }
  };
  document.querySelectorAll('.preset-grid button').forEach(function (b) {
    b.addEventListener('click', function () {
      var p = presets[b.getAttribute('data-preset')];
      if (!p) return;
      P.alpha = p.alpha; P.beta = p.beta; P.gamma = p.gamma; P.delta = p.delta;
      P.x0 = p.x0; P.y0 = p.y0;
      $('alpha').value = p.alpha; $('vAlpha').textContent = f2(p.alpha);
      $('beta').value = p.beta;   $('vBeta').textContent  = f3(p.beta);
      $('gamma').value = p.gamma; $('vGamma').textContent = f2(p.gamma);
      $('delta').value = p.delta; $('vDelta').textContent = f4(p.delta);
      $('x0').value = p.x0; $('vX0').textContent = fi(p.x0);
      $('y0').value = p.y0; $('vY0').textContent = fi(p.y0);
      resetState();
    });
  });

  // three-species toggle
  var tg = $('threeToggle');
  function toggleThree() {
    P.threeMode = !P.threeMode;
    tg.classList.toggle('on', P.threeMode);
    tg.setAttribute('aria-checked', P.threeMode ? 'true' : 'false');
    document.body.classList.toggle('three-mode', P.threeMode);
    updateEq();
    resetState();
  }
  tg.addEventListener('click', toggleThree);
  tg.addEventListener('keydown', function (e) {
    if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); toggleThree(); }
  });

  // initial setup
  function setupCanvases() {
    resizeForDPR(cT); resizeForDPR(cP); resizeForDPR(cF);
  }
  window.addEventListener('resize', setupCanvases);
  setupCanvases();
  resetState();
  updateEq();
  loop();
})();
</script>

