---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Population-dynamics lab (graduate level). Four models on the same phase
// plane: neutral Lotka-Volterra (a center), logistic-prey LV (stable
// coexistence focus), Rosenzweig-MacArthur with a Holling type-II response
// (a Hopf bifurcation to a limit cycle — the paradox of enrichment), and
// two-species competition (exclusion vs coexistence). For each it locates the
// interior equilibrium (Newton), forms the Jacobian there, and classifies the
// fixed point from its eigenvalues; it overlays the nullclines and a normalised
// vector field, and integrates the trajectory with RK4. No libraries.
---
<BaseLayout title="Population Dynamics · Virtual Labs · AquinTutor" description="Graduate mathematical biology: Lotka-Volterra, logistic-prey, Rosenzweig-MacArthur (Holling II, Hopf/limit cycle) and competition models with equilibrium, Jacobian eigenvalue stability classification, nullclines and a phase-plane vector field. Built from scratch.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1340px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:16px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:300px minmax(0,1fr); gap:18px; } @media(max-width:960px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:15px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 11px; }
  .lb-row{ display:grid; gap:8px; } .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.08em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; }
  .lb-row label span{ color:#5ee7ff; } .lb-row input[type=range]{ width:100%; accent-color:#5ee7ff; }
  select{ width:100%; background:#080a12; border:1px solid #1e2740; color:#fff; padding:8px 10px; border-radius:6px; font-size:12px; font-family:inherit; }
  .lb-btn{ background:linear-gradient(180deg,#7af0ff,#33cfe6); color:#04161b; padding:9px 15px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:11px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); }
  .lb-stage canvas{ display:block; width:100%; height:auto; }
  .lb-plots{ display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-top:12px; } @media(max-width:680px){ .lb-plots{ grid-template-columns:1fr; } }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11px; padding:4px 0; border-bottom:1px solid #141a2c; }
  .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#5ee7ff; font-weight:700; text-align:right; }
  .lb-note{ font-size:11px; color:#7e8aa3; line-height:1.6; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">Mathematical Biology · Nonlinear ODE</p>
      <h1 class="lb-title">Population <em>dynamics</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;"><button id="resetBtn" class="lb-btn">Reset orbit</button></div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Model</h3>
        <select id="model">
          <option value="lv">Lotka-Volterra (neutral center)</option>
          <option value="log" selected>Logistic prey (coexistence focus)</option>
          <option value="rm">Rosenzweig-MacArthur (Holling II)</option>
          <option value="comp">Two-species competition</option>
        </select>
        <p class="lb-note" id="modelNote" style="margin-top:9px;"></p>
      </div>
      <div class="lb-panel"><h3>Parameters</h3><div class="lb-row">
        <label id="rWrap">Prey growth r <span id="rV">1.00</span></label><input id="r" type="range" min="0.1" max="2.5" step="0.05" value="1.0"/>
        <label id="aWrap">Interaction a <span id="aV">0.10</span></label><input id="a" type="range" min="0.02" max="1.5" step="0.01" value="0.1"/>
        <label id="cWrap">Conversion/comp c <span id="cV">0.08</span></label><input id="c" type="range" min="0.02" max="1.5" step="0.01" value="0.08"/>
        <label id="mWrap">Predator death m <span id="mV">1.00</span></label><input id="m" type="range" min="0.1" max="2.5" step="0.05" value="1.0"/>
        <label id="KWrap">Carrying capacity K <span id="KV">30</span></label><input id="K" type="range" min="5" max="80" step="1" value="30"/>
        <label id="hWrap" style="display:none;">Handling time h <span id="hV">0.30</span></label><input id="h" type="range" min="0" max="1.5" step="0.02" value="0.3" style="display:none;"/>
      </div></div>
      <div class="lb-panel"><h3>Equilibrium &amp; stability</h3>
        <div class="lb-metric"><span class="lb-metric-l">Fixed point (x*,y*)</span><span class="lb-metric-v" id="mFP">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Jacobian tr, det</span><span class="lb-metric-v" id="mTrDet">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Eigenvalues</span><span class="lb-metric-v" id="mEig">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Classification</span><span class="lb-metric-v" id="mClass" style="color:#a78bfa;">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Live x, y</span><span class="lb-metric-v" id="mXY">—</span></div>
      </div>
    </aside>
    <section>
      <div class="lb-stage"><canvas id="phase" width="960" height="560"></canvas></div>
      <div class="lb-plots">
        <div class="lb-panel" style="margin:0;"><h3>Populations vs time</h3><canvas id="pop" width="560" height="200" style="width:100%;height:auto;"></canvas></div>
        <div class="lb-panel" style="margin:0;"><h3>Legend</h3>
          <p class="lb-note" style="margin:0;">Green = x-nullcline (ẋ=0), red = y-nullcline (ẏ=0). Their intersection is the interior equilibrium. Grey arrows are the normalised flow. The orbit (amber) is RK4-integrated; click the phase plane to re-seed it.</p>
        </div>
      </div>
    </section>
  </div>
</main>
<script is:inline>
(function(){
  function v(id){ return parseFloat(document.getElementById(id).value); }
  function setTxt(id,t){ var e=document.getElementById(id); if(e) e.textContent=t; }
  var model='log', x=12,y=8,t=0,hist=[];
  var NOTES={ lv:'ẋ=rx−axy, ẏ=cxy−my. The interior fixed point is a neutral center: closed orbits, no damping — structurally fragile.', log:'Prey self-limit at K: ẋ=rx(1−x/K)−axy. The equilibrium becomes a stable focus — populations spiral into coexistence.', rm:'Holling type-II saturating predation axy/(1+ahx). Enriching K destabilises the focus through a Hopf bifurcation into a stable limit cycle (paradox of enrichment).', comp:'Two competitors: ẋ=rx(1−(x+ay)/K), ẏ=my(1−(y+cx)/K). Depending on a,c you get competitive exclusion (a saddle interior) or stable coexistence.' };
  function rates(X,Y){ var r=v('r'),a=v('a'),c=v('c'),m=v('m'),K=v('K'),h=v('h');
    if(model==='lv') return [r*X - a*X*Y, c*X*Y - m*Y];
    if(model==='log') return [r*X*(1-X/K) - a*X*Y, c*X*Y - m*Y];
    if(model==='rm'){ var fr=a*X/(1+a*h*X); return [r*X*(1-X/K) - fr*Y, c*fr*Y - m*Y]; }
    return [r*X*(1-(X+a*Y)/K), m*Y*(1-(Y+c*X)/K)]; }
  function jac(X,Y){ var e=1e-5, f=rates(X,Y), fx=rates(X+e,Y), fy=rates(X,Y+e);
    return [(fx[0]-f[0])/e,(fy[0]-f[0])/e,(fx[1]-f[1])/e,(fy[1]-f[1])/e]; }
  function findFP(){ var r=v('r'),a=v('a'),c=v('c'),m=v('m'),K=v('K');
    var X,Y; if(model==='lv'){ X=m/c; Y=r/a; } else if(model==='log'){ X=m/c; Y=(r/a)*(1-X/K); }
    else if(model==='rm'){ var h=v('h'); X=m/(a*(c-m*h)); Y=(r/a)*(1-X/K)*(1+a*h*X); }
    else { var den=1-a*c; X=K*(1-a)/den; Y=K*(1-c)/den; }
    // Newton polish
    for(var i=0;i<30;i++){ var f=rates(X,Y), J=jac(X,Y), det=J[0]*J[3]-J[1]*J[2]; if(Math.abs(det)<1e-12)break;
      var dX=(J[3]*(-f[0])-J[1]*(-f[1]))/det, dY=(-J[2]*(-f[0])+J[0]*(-f[1]))/det; X+=dX; Y+=dY; if(Math.hypot(dX,dY)<1e-10)break; }
    return [X,Y]; }
  function classify(J){ var tr=J[0]+J[3], det=J[0]*J[3]-J[1]*J[2], disc=tr*tr-4*det;
    var cls, eig;
    if(disc<0){ var re=tr/2, im=Math.sqrt(-disc)/2; eig=re.toFixed(3)+'±'+im.toFixed(3)+'i';
      cls = Math.abs(re)<1e-3?'center (neutral)':(re<0?'stable focus (spiral in)':'unstable focus (spiral out)'); }
    else { var r1=(tr+Math.sqrt(disc))/2, r2=(tr-Math.sqrt(disc))/2; eig=r1.toFixed(3)+', '+r2.toFixed(3);
      cls = (r1*r2<0)?'saddle (unstable)':(r1<0?'stable node':'unstable node'); }
    return { tr:tr, det:det, eig:eig, cls:cls }; }

  function readControls(){ model=document.getElementById('model').value; setTxt('modelNote',NOTES[model]);
    ['r','a','c','m','K','h'].forEach(function(id){ var e=document.getElementById(id+'V'); if(e) e.textContent=v(id).toFixed(id==='K'?0:2); });
    document.getElementById('KWrap').style.display=model==='lv'?'none':'flex'; document.getElementById('K').style.display=model==='lv'?'none':'block';
    document.getElementById('hWrap').style.display=model==='rm'?'flex':'none'; document.getElementById('h').style.display=model==='rm'?'block':'none'; }
  document.querySelectorAll('input,select').forEach(function(e){ e.addEventListener('input',readControls); e.addEventListener('change',function(){ readControls(); reset(); }); });
  function reset(){ var fp=findFP(); x=Math.max(1,fp[0]*0.5); y=Math.max(1,fp[1]*0.6); t=0; hist=[]; }
  readControls(); reset();
  document.getElementById('resetBtn').addEventListener('click',reset);

  function rk4(dt){ var k1=rates(x,y), k2=rates(x+dt/2*k1[0],y+dt/2*k1[1]), k3=rates(x+dt/2*k2[0],y+dt/2*k2[1]), k4=rates(x+dt*k3[0],y+dt*k3[1]);
    x+=dt/6*(k1[0]+2*k2[0]+2*k3[0]+k4[0]); y+=dt/6*(k1[1]+2*k2[1]+2*k3[1]+k4[1]); if(x<0.001)x=0.001; if(y<0.001)y=0.001; t+=dt; hist.push([t,x,y]); if(hist.length>1600)hist.shift(); }

  function hidpi(cv){ var r=cv.getBoundingClientRect(), dp=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w; cv.width=Math.round(w*dp); cv.height=Math.round(h*dp); var ctx=cv.getContext('2d'); ctx.setTransform(dp,0,0,dp,0,0); return {ctx:ctx,w:w,h:h}; }
  function bisectY(X,lo,hi){ var flo=rates(X,lo)[0]; for(var i=0;i<40;i++){ var mid=(lo+hi)/2, fm=rates(X,mid)[0]; if(flo*fm<=0){ hi=mid; } else { lo=mid; flo=fm; } } return (lo+hi)/2; }
  function bisectX(Y,lo,hi){ var flo=rates(lo,Y)[1]; for(var i=0;i<40;i++){ var mid=(lo+hi)/2, fm=rates(mid,Y)[1]; if(flo*fm<=0){ hi=mid; } else { lo=mid; flo=fm; } } return (lo+hi)/2; }

  var fp=[0,0], cls=null;
  function drawPhase(){
    var cv=document.getElementById('phase'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h;
    var bg=ctx.createLinearGradient(0,0,0,H); bg.addColorStop(0,'#0b1f14'); bg.addColorStop(1,'#060f0a'); ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    fp=findFP(); var J=jac(fp[0],fp[1]); cls=classify(J);
    var xmax=Math.max(fp[0]*2.4, model==='lv'?fp[0]*2.4:v('K')*1.05, x*1.3, 8);
    var ymax=Math.max(fp[1]*2.4, y*1.3, 6);
    var padL=44,padB=34; function X(vx){ return padL+vx/xmax*(W-padL-14); } function Y(vy){ return H-padB-vy/ymax*(H-padB-14); }
    // axes
    ctx.strokeStyle='#294a35'; ctx.lineWidth=1.2; ctx.beginPath(); ctx.moveTo(padL,H-padB); ctx.lineTo(W-8,H-padB); ctx.moveTo(padL,H-padB); ctx.lineTo(padL,10); ctx.stroke();
    ctx.fillStyle='#6e8a78'; ctx.font="11px 'Geist Mono',monospace"; ctx.fillText(model==='comp'?'species x →':'prey x →',W-96,H-14); ctx.save(); ctx.translate(14,80); ctx.rotate(-Math.PI/2); ctx.fillText(model==='comp'?'species y →':'predators y →',0,0); ctx.restore();
    // vector field
    var ng=16; for(var i=1;i<=ng;i++)for(var j=1;j<=ng;j++){ var vx=i/ng*xmax*0.98, vy=j/ng*ymax*0.98; var f=rates(vx,vy); var mag=Math.hypot(f[0],f[1])||1; var ux=f[0]/mag, uy=f[1]/mag; var px=X(vx),py=Y(vy), len=10;
      ctx.strokeStyle='rgba(120,150,140,0.28)'; ctx.beginPath(); ctx.moveTo(px,py); ctx.lineTo(px+ux*len,py-uy*len); ctx.stroke();
      ctx.fillStyle='rgba(120,150,140,0.28)'; ctx.beginPath(); ctx.arc(px+ux*len,py-uy*len,1.3,0,7); ctx.fill(); }
    // nullclines
    ctx.lineWidth=2;
    ctx.strokeStyle='#34d399'; ctx.beginPath(); var started=false; for(var px2=0;px2<=xmax;px2+=xmax/160){ var yy=bisectY(px2,0.0001,ymax*1.4); if(yy>0.001&&yy<ymax*1.4){ var sx=X(px2),sy=Y(yy); started?ctx.lineTo(sx,sy):ctx.moveTo(sx,sy); started=true; } else started=false; } ctx.stroke();
    ctx.strokeStyle='#f87171'; ctx.beginPath(); started=false; for(var py2=0;py2<=ymax;py2+=ymax/160){ var xx=bisectX(py2,0.0001,xmax*1.4); if(xx>0.001&&xx<xmax*1.4){ var sx=X(xx),sy=Y(py2); started?ctx.lineTo(sx,sy):ctx.moveTo(sx,sy); started=true; } else started=false; } ctx.stroke();
    // trajectory
    ctx.save(); ctx.shadowColor='#fbbf24'; ctx.shadowBlur=6; ctx.strokeStyle='rgba(251,191,36,0.9)'; ctx.lineWidth=1.6; ctx.beginPath(); hist.forEach(function(h,i){ var sx=X(h[1]),sy=Y(h[2]); i?ctx.lineTo(sx,sy):ctx.moveTo(sx,sy); }); ctx.stroke(); ctx.restore();
    ctx.save(); ctx.shadowColor='#fff3c4'; ctx.shadowBlur=14; ctx.fillStyle='#fff3c4'; ctx.beginPath(); ctx.arc(X(x),Y(y),5,0,7); ctx.fill(); ctx.restore();
    // fixed point marker
    if(fp[0]>0&&fp[1]>0&&fp[0]<xmax&&fp[1]<ymax){ var stable=cls.cls.indexOf('stable')===0||cls.cls.indexOf('center')===0; ctx.strokeStyle=stable?'#5ee7ff':'#ef4444'; ctx.lineWidth=2; ctx.beginPath(); ctx.arc(X(fp[0]),Y(fp[1]),6,0,7); ctx.stroke(); ctx.fillStyle=stable?'rgba(94,231,255,0.5)':'rgba(239,68,68,0.4)'; ctx.beginPath(); ctx.arc(X(fp[0]),Y(fp[1]),3,0,7); ctx.fill(); }
    // click to seed
    cv.onclick=function(ev){ var rct=cv.getBoundingClientRect(); var mx=(ev.clientX-rct.left), my=(ev.clientY-rct.top); x=Math.max(0.5,(mx-padL)/(W-padL-14)*xmax); y=Math.max(0.5,(H-padB-my)/(H-padB-14)*ymax); hist=[]; t=0; };
    // metrics
    setTxt('mFP','('+fp[0].toFixed(2)+', '+fp[1].toFixed(2)+')'); setTxt('mTrDet',cls.tr.toFixed(3)+', '+cls.det.toFixed(3)); setTxt('mEig',cls.eig); setTxt('mClass',cls.cls); setTxt('mXY',x.toFixed(2)+', '+y.toFixed(2));
  }
  function drawPop(){ var cv=document.getElementById('pop'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h; ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H);
    ctx.strokeStyle='rgba(94,231,255,0.06)'; for(var yy=0;yy<H;yy+=25){ ctx.beginPath(); ctx.moveTo(0,yy); ctx.lineTo(W,yy); ctx.stroke(); }
    if(hist.length<2) return; var mx=Math.max.apply(null,hist.map(function(h){return Math.max(h[1],h[2]);}))*1.1; var t0=hist[0][0], t1=hist[hist.length-1][0];
    function X(tt){ return 8+(tt-t0)/(t1-t0+1e-9)*(W-16); } function Y(val){ return H-8-val/mx*(H-20); }
    function gl(col,idx){ ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=7; ctx.strokeStyle=col; ctx.lineWidth=1.6; ctx.beginPath(); hist.forEach(function(h,i){ i?ctx.lineTo(X(h[0]),Y(h[idx])):ctx.moveTo(X(h[0]),Y(h[idx])); }); ctx.stroke(); ctx.restore(); }
    gl('#6ee7a8',1); gl('#f87171',2); }
  function loop(){ var dt=0.02, sub=3; for(var i=0;i<sub;i++) rk4(dt/sub); drawPhase(); drawPop(); requestAnimationFrame(loop); }
  requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
