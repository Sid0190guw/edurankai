---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Ecosystem lab — Lotka-Volterra predator-prey dynamics (RK4), rendered as a
// living field of glowing prey/predator agents plus population-vs-time and
// phase-portrait plots. Depth-lit high-DPI canvas, no libraries.
---
<BaseLayout title="Ecosystem lab · Virtual Labs · AquinTutor" description="Predator and prey in the Lotka-Volterra dance — a living agent field, the population cycle over time, and the closed phase-portrait orbit.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1320px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:18px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:290px minmax(0,1fr); gap:18px; } @media(max-width:900px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:16px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 12px; }
  .lb-row{ display:grid; gap:9px; } .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.1em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; }
  .lb-row label span{ color:#5ee7ff; } .lb-row input[type=range]{ width:100%; accent-color:#5ee7ff; }
  .lb-btn{ background:linear-gradient(180deg,#7af0ff,#33cfe6); color:#04161b; padding:9px 16px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:11px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); }
  .lb-stage canvas{ display:block; width:100%; height:auto; }
  .lb-plots{ display:grid; grid-template-columns:1.5fr 1fr; gap:12px; margin-top:12px; } @media(max-width:680px){ .lb-plots{ grid-template-columns:1fr; } }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11.5px; padding:5px 0; border-bottom:1px solid #141a2c; }
  .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#5ee7ff; font-weight:700; text-align:right; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">Biology · Population dynamics</p>
      <h1 class="lb-title">Predator &amp; <em>prey</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;"><button id="resetBtn" class="lb-btn">Reset</button></div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Lotka-Volterra</h3><div class="lb-row">
        <label>Prey birth α <span id="aV">1.0</span></label><input id="a" type="range" min="0.2" max="2" step="0.05" value="1.0"/>
        <label>Predation β <span id="bV">0.10</span></label><input id="b" type="range" min="0.02" max="0.3" step="0.01" value="0.1"/>
        <label>Pred. growth δ <span id="dV">0.075</span></label><input id="d" type="range" min="0.02" max="0.2" step="0.005" value="0.075"/>
        <label>Pred. death γ <span id="gV">1.0</span></label><input id="g" type="range" min="0.2" max="2" step="0.05" value="1.0"/>
        <label>Start prey <span id="x0V">10</span></label><input id="x0" type="range" min="2" max="30" step="1" value="10"/>
        <label>Start predators <span id="y0V">5</span></label><input id="y0" type="range" min="1" max="20" step="1" value="5"/>
      </div></div>
      <div class="lb-panel"><h3>Populations</h3>
        <div class="lb-metric"><span class="lb-metric-l">Prey</span><span class="lb-metric-v" id="mX" style="color:#6ee7a8;">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Predators</span><span class="lb-metric-v" id="mY" style="color:#f87171;">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Time</span><span class="lb-metric-v" id="mT">—</span></div>
      </div>
    </aside>
    <section>
      <div class="lb-stage"><canvas id="field" width="900" height="360"></canvas></div>
      <div class="lb-plots">
        <div class="lb-panel" style="margin:0;"><h3>Populations vs time</h3><canvas id="pop" width="560" height="200" style="width:100%;height:auto;"></canvas></div>
        <div class="lb-panel" style="margin:0;"><h3>Phase portrait · prey vs predator</h3><canvas id="phase" width="380" height="200" style="width:100%;height:auto;"></canvas></div>
      </div>
    </section>
  </div>
</main>
<script is:inline>
(function(){
  function v(id){ return parseFloat(document.getElementById(id).value); }
  var x=10,y=5,t=0,hist=[],agents=[];
  function sync(){ ['a','b','d','g','x0','y0'].forEach(function(id){ var el=document.getElementById(id+'V'); if(!el) return; var val=v(id); el.textContent = (id==='b'||id==='d')?val.toFixed(id==='d'?3:2):(id==='x0'||id==='y0')?val.toFixed(0):val.toFixed(2); }); }
  document.querySelectorAll('input').forEach(function(e){ e.addEventListener('input',sync); }); sync();
  function reset(){ x=v('x0'); y=v('y0'); t=0; hist=[]; agents=[]; } document.getElementById('resetBtn').addEventListener('click',reset); reset();
  function f(x,y){ var a=v('a'),b=v('b'),d=v('d'),g=v('g'); return { dx:a*x-b*x*y, dy:d*x*y-g*y }; }
  function rk4(dt){ var k1=f(x,y), k2=f(x+dt/2*k1.dx,y+dt/2*k1.dy), k3=f(x+dt/2*k2.dx,y+dt/2*k2.dy), k4=f(x+dt*k3.dx,y+dt*k3.dy);
    x+=dt/6*(k1.dx+2*k2.dx+2*k3.dx+k4.dx); y+=dt/6*(k1.dy+2*k2.dy+2*k3.dy+k4.dy); if(x<0.01)x=0.01; if(y<0.01)y=0.01; t+=dt; hist.push([t,x,y]); if(hist.length>800) hist.shift(); }
  function hidpi(cv){ var r=cv.getBoundingClientRect(), d=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w; cv.width=Math.round(w*d); cv.height=Math.round(h*d); var ctx=cv.getContext('2d'); ctx.setTransform(d,0,0,d,0,0); return {ctx:ctx,w:w,h:h}; }
  function glow(ctx,pts,col){ ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=8; ctx.strokeStyle=col; ctx.lineWidth=1.8; ctx.beginPath(); pts.forEach(function(q,i){ i?ctx.lineTo(q[0],q[1]):ctx.moveTo(q[0],q[1]); }); ctx.stroke(); ctx.restore(); }
  function field(){ var cv=document.getElementById('field'), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h;
    var bg=ctx.createLinearGradient(0,0,0,H); bg.addColorStop(0,'#0b1f14'); bg.addColorStop(1,'#06110b'); ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    var np=Math.min(140,Math.round(x*3)), nq=Math.min(90,Math.round(y*4));
    while(agents.filter(function(a){return a.t==='p';}).length<np) agents.push({t:'p',x:Math.random()*W,y:Math.random()*H,a:Math.random()*7});
    while(agents.filter(function(a){return a.t==='q';}).length<nq) agents.push({t:'q',x:Math.random()*W,y:Math.random()*H,a:Math.random()*7});
    // trim
    var pc=0,qc=0; agents=agents.filter(function(a){ if(a.t==='p'){ if(pc++<np) return true; return false;} if(qc++<nq) return true; return false; });
    agents.forEach(function(a){ a.a+=(Math.random()-0.5)*0.4; var sp=a.t==='p'?0.8:1.4; a.x+=Math.cos(a.a)*sp; a.y+=Math.sin(a.a)*sp; if(a.x<0)a.x+=W; if(a.x>W)a.x-=W; if(a.y<0)a.y+=H; if(a.y>H)a.y-=H;
      var col=a.t==='p'?'#6ee7a8':'#f87171'; ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=8; ctx.fillStyle=col; ctx.beginPath(); ctx.arc(a.x,a.y,a.t==='p'?3:4,0,7); ctx.fill(); ctx.restore(); });
    ctx.fillStyle='#6ee7a8'; ctx.font="700 13px 'Geist Mono',monospace"; ctx.fillText('prey '+x.toFixed(1), 14, 22); ctx.fillStyle='#f87171'; ctx.fillText('predators '+y.toFixed(1), 14, 40);
  }
  function popPlot(){ var cv=document.getElementById('pop'), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h; ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H);
    ctx.strokeStyle='rgba(94,231,255,0.06)'; for(var yy=0;yy<H;yy+=25){ ctx.beginPath(); ctx.moveTo(0,yy); ctx.lineTo(W,yy); ctx.stroke(); }
    if(hist.length<2) return; var mx=Math.max.apply(null,hist.map(function(h){return Math.max(h[1],h[2]);}))*1.1; var t0=hist[0][0], t1=hist[hist.length-1][0];
    function X(tt){ return 8+(tt-t0)/(t1-t0+1e-9)*(W-16); } function Y(val){ return H-8-val/mx*(H-20); }
    glow(ctx,hist.map(function(h){return [X(h[0]),Y(h[1])];}),'#6ee7a8'); glow(ctx,hist.map(function(h){return [X(h[0]),Y(h[2])];}),'#f87171'); }
  function phasePlot(){ var cv=document.getElementById('phase'), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h; ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H);
    ctx.strokeStyle='#1a2340'; ctx.strokeRect(8,8,W-16,H-16); ctx.fillStyle='#8ea0be'; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText('prey →',W-46,H-12); ctx.save(); ctx.translate(14,44); ctx.rotate(-Math.PI/2); ctx.fillText('predators →',0,0); ctx.restore();
    if(hist.length<2) return; var mx=Math.max.apply(null,hist.map(function(h){return h[1];}))*1.1, my=Math.max.apply(null,hist.map(function(h){return h[2];}))*1.1;
    function X(xx){ return 20+xx/mx*(W-36); } function Y(yy){ return H-20-yy/my*(H-36); }
    glow(ctx,hist.map(function(h){return [X(h[1]),Y(h[2])];}),'#a78bfa'); var l=hist[hist.length-1]; ctx.save(); ctx.shadowColor='#fbbf24'; ctx.shadowBlur=12; ctx.fillStyle='#fbbf24'; ctx.beginPath(); ctx.arc(X(l[1]),Y(l[2]),4,0,7); ctx.fill(); ctx.restore(); }
  function loop(){ rk4(0.02); document.getElementById('mX').textContent=x.toFixed(1); document.getElementById('mY').textContent=y.toFixed(1); document.getElementById('mT').textContent=t.toFixed(1);
    field(); popPlot(); phasePlot(); requestAnimationFrame(loop); }
  requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
