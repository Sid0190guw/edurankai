      { q: 'For BIBO stability, all poles of G(s) must have:', opts: ['Positive real part', 'Negative real part', 'Zero real part', 'Magnitude greater than 1'], correct: 1, exp: 'Stability requires every pole strictly in the open left-half plane, i.e. Re(p) < 0.' },
