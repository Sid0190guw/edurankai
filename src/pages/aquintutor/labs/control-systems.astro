---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Control Systems · Virtual Labs · AquinTutor" description="A vlabs-format virtual lab in classical control: poles and zeros, time-domain specs, root locus, Bode, Nyquist, PID tuning and Routh-Hurwitz. Genuine numerics, hand-rolled on Canvas.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; }
  .cs-wrap { max-width: 1340px; margin: 0 auto; padding: 18px 3vw 70px; }
  .cs-back { font-family: 'Geist Mono', monospace; font-size: 11px; color: #67e8f9; text-decoration: none; letter-spacing: 0.08em; }
  .cs-back:hover { text-decoration: underline; }
  .cs-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 12px 0 2px; }
  .cs-title { font-family: 'Cormorant Garamond', serif; font-size: 38px; font-weight: 600; margin: 2px 0 16px; letter-spacing: -0.02em; }
  .cs-title em { color: #a78bfa; font-style: italic; font-weight: 500; }
  .cs-grid { display: grid; grid-template-columns: 248px minmax(0,1fr); gap: 18px; align-items: start; }
  @media (max-width: 980px) { .cs-grid { grid-template-columns: 1fr; } }

  .cs-side { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 12px; position: sticky; top: 14px; }
  .cs-side h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; margin: 4px 6px 10px; }
  .cs-exp { display: block; width: 100%; text-align: left; background: transparent; border: 1px solid transparent; border-radius: 8px; padding: 9px 10px; margin-bottom: 3px; color: #cfd6da; font-family: 'Geist Mono', monospace; font-size: 11.5px; cursor: pointer; line-height: 1.35; transition: background .14s, border-color .14s; }
  .cs-exp:hover { background: #161922; }
  .cs-exp.active { background: #161c26; border-color: #67e8f9; color: #67e8f9; }
  .cs-exp .num { color: #a78bfa; font-weight: 700; margin-right: 6px; }
  .cs-exp.active .num { color: #67e8f9; }

  .cs-main { min-width: 0; }
  .cs-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 18px; }

  .cs-tabs { display: flex; flex-wrap: wrap; gap: 4px; border-bottom: 1px solid #2a2a35; margin-bottom: 16px; }
  .cs-tab { background: transparent; border: none; border-bottom: 2px solid transparent; color: #9aa6b6; font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 700; padding: 8px 11px; cursor: pointer; margin-bottom: -1px; }
  .cs-tab:hover { color: #e8e8ee; }
  .cs-tab.active { color: #67e8f9; border-bottom-color: #67e8f9; }

  .cs-sec { display: none; }
  .cs-sec.active { display: block; }
  .cs-sec h4 { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #fbbf24; font-weight: 700; margin: 0 0 8px; }
  .cs-sec p { font-size: 14px; line-height: 1.7; color: #c4cad6; margin: 0 0 10px; max-width: 760px; }
  .cs-sec ol { font-size: 13.5px; line-height: 1.75; color: #c4cad6; padding-left: 20px; margin: 0 0 8px; max-width: 760px; }
  .cs-eq { font-family: 'Geist Mono', monospace; font-size: 13px; color: #86efac; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; padding: 10px 14px; margin: 8px 0; overflow-x: auto; white-space: pre; line-height: 1.7; }
  .cs-ref { font-family: 'Geist Mono', monospace; font-size: 12px; color: #9aa6b6; line-height: 1.7; }

  .cs-sim { display: grid; grid-template-columns: 244px minmax(0,1fr); gap: 16px; align-items: start; }
  @media (max-width: 760px) { .cs-sim { grid-template-columns: 1fr; } }
  .cs-controls { background: #0d0f15; border: 1px solid #2a2a35; border-radius: 10px; padding: 14px; }
  .cs-controls h5 { font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.14em; text-transform: uppercase; color: #a78bfa; font-weight: 700; margin: 0 0 10px; }
  .cs-ctl { margin-bottom: 11px; }
  .cs-ctl label { font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.08em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; display: flex; justify-content: space-between; margin-bottom: 4px; }
  .cs-ctl label span { color: #67e8f9; }
  .cs-ctl input[type=range] { width: 100%; accent-color: #67e8f9; }
  .cs-ctl input[type=text], .cs-ctl input[type=number], .cs-ctl select { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; color: #e8e8ee; padding: 7px 9px; border-radius: 6px; font-size: 12px; font-family: 'Geist Mono', monospace; box-sizing: border-box; }
  .cs-canvas { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 10px; display: block; }
  .cs-plotlbl { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: #9aa6b6; margin: 0 0 6px; }

  .cs-read { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 8px; margin-top: 12px; }
  .cs-read .cell { background: #0d0f15; border: 1px solid #2a2a35; border-radius: 8px; padding: 9px 11px; }
  .cs-read .cell .k { font-family: 'Geist Mono', monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: #9aa6b6; }
  .cs-read .cell .v { font-family: 'Geist Mono', monospace; font-size: 16px; color: #67e8f9; font-weight: 700; margin-top: 2px; }
  .cs-read .cell .v.amber { color: #fbbf24; }
  .cs-read .cell .v.purple { color: #a78bfa; }
  .cs-read .cell .v.green { color: #86efac; }
  .cs-read .cell .v.red { color: #fca5a5; }

  .cs-btn { background: #67e8f9; color: #04161b; padding: 8px 14px; border-radius: 6px; border: none; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 10.5px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
  .cs-btn-ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
  .cs-btn:hover { filter: brightness(1.08); }

  .cs-status { font-family: 'Geist Mono', monospace; font-size: 12px; padding: 8px 12px; border-radius: 8px; margin-top: 10px; }
  .cs-status.ok { background: rgba(134,239,172,0.08); border: 1px solid #2f5a3f; color: #86efac; }
  .cs-status.bad { background: rgba(252,165,165,0.08); border: 1px solid #5a2f2f; color: #fca5a5; }
  .cs-status.warn { background: rgba(251,191,36,0.08); border: 1px solid #5a4a2f; color: #fbbf24; }

  .cs-quiz { background: #0d0f15; border: 1px solid #2a2a35; border-radius: 10px; padding: 14px 16px; margin-bottom: 10px; }
  .cs-quiz .q { font-size: 14px; color: #e8e8ee; margin: 0 0 10px; line-height: 1.6; }
  .cs-quiz label { display: block; font-size: 13px; color: #c4cad6; padding: 6px 8px; border-radius: 6px; cursor: pointer; }
  .cs-quiz label:hover { background: #161922; }
  .cs-quiz input { accent-color: #67e8f9; margin-right: 8px; }
  .cs-quiz .exp { font-family: 'Geist Mono', monospace; font-size: 11.5px; margin-top: 8px; display: none; line-height: 1.6; }
  .cs-quiz .exp.show { display: block; }
  .cs-quiz .exp.right { color: #86efac; }
  .cs-quiz .exp.wrong { color: #fca5a5; }
  .cs-tablewrap { overflow-x: auto; }
  table.cs-routh { border-collapse: collapse; font-family: 'Geist Mono', monospace; font-size: 12px; margin-top: 10px; }
  table.cs-routh td { border: 1px solid #2a2a35; padding: 6px 12px; text-align: right; color: #e8e8ee; min-width: 64px; }
  table.cs-routh td.lbl { color: #a78bfa; text-align: left; background: #0d0f15; font-weight: 700; }
  table.cs-routh td.neg { color: #fca5a5; }
  .cs-hint { font-family: 'Geist Mono', monospace; font-size: 10.5px; color: #6b7585; margin-top: 6px; line-height: 1.5; }
</style>

<main class="cs-wrap">
  <a class="cs-back" href="/aquintutor/labs">&larr; Virtual Labs</a>
  <p class="cs-eye">Electrical · Classical control theory</p>
  <h1 class="cs-title">Control <em>Systems</em>.</h1>

  <div class="cs-grid">
    <aside class="cs-side">
      <h3>Experiments</h3>
      <button class="cs-exp active" data-exp="0"><span class="num">01</span>Poles, zeros &amp; transient response</button>
      <button class="cs-exp" data-exp="1"><span class="num">02</span>Second-order time-domain specs</button>
      <button class="cs-exp" data-exp="2"><span class="num">03</span>Root locus</button>
      <button class="cs-exp" data-exp="3"><span class="num">04</span>Bode plot &amp; stability margins</button>
      <button class="cs-exp" data-exp="4"><span class="num">05</span>Nyquist plot &amp; encirclement</button>
      <button class="cs-exp" data-exp="5"><span class="num">06</span>PID controller tuning</button>
      <button class="cs-exp" data-exp="6"><span class="num">07</span>Routh-Hurwitz criterion</button>
    </aside>

    <section class="cs-main">
      <div class="cs-panel">
        <div class="cs-tabs">
          <button class="cs-tab active" data-tab="aim">Aim</button>
          <button class="cs-tab" data-tab="theory">Theory</button>
          <button class="cs-tab" data-tab="procedure">Procedure</button>
          <button class="cs-tab" data-tab="sim">Simulation</button>
          <button class="cs-tab" data-tab="quiz">Self-assessment</button>
          <button class="cs-tab" data-tab="ref">References</button>
        </div>
        <div id="csBody"></div>
      </div>
    </section>
  </div>
</main>

<script is:inline>
(function () {
  'use strict';
  function $(id) { return document.getElementById(id); }
  function el(tag, attrs, html) {
    var e = document.createElement(tag);
    if (attrs) for (var k in attrs) e.setAttribute(k, attrs[k]);
    if (html != null) e.innerHTML = html;
    return e;
  }

  /* ============================================================
     COMPLEX ARITHMETIC + POLYNOMIAL ROOT FINDING (Durand-Kerner)
     ============================================================ */
  function cAdd(a, b) { return { re: a.re + b.re, im: a.im + b.im }; }
  function cSub(a, b) { return { re: a.re - b.re, im: a.im - b.im }; }
  function cMul(a, b) { return { re: a.re * b.re - a.im * b.im, im: a.re * b.im + a.im * b.re }; }
  function cDiv(a, b) {
    var d = b.re * b.re + b.im * b.im;
    return { re: (a.re * b.re + a.im * b.im) / d, im: (a.im * b.re - a.re * b.im) / d };
  }
  function cAbs(a) { return Math.hypot(a.re, a.im); }
  function cArg(a) { return Math.atan2(a.im, a.re); }

  // Evaluate real-coefficient polynomial (highest degree first) at complex z.
  function polyEvalC(coeffs, z) {
    var r = { re: 0, im: 0 };
    for (var i = 0; i < coeffs.length; i++) {
      r = cMul(r, z);
      r = cAdd(r, { re: coeffs[i], im: 0 });
    }
    return r;
  }
  // Real evaluation
  function polyEval(coeffs, x) {
    var r = 0;
    for (var i = 0; i < coeffs.length; i++) r = r * x + coeffs[i];
    return r;
  }

  // Find all roots of a real polynomial (highest degree first) via Durand-Kerner.
  function polyRoots(coeffsIn) {
    // strip leading zeros
    var coeffs = coeffsIn.slice();
    while (coeffs.length > 1 && Math.abs(coeffs[0]) < 1e-14) coeffs.shift();
    var n = coeffs.length - 1;
    if (n <= 0) return [];
    // normalize to monic
    var lead = coeffs[0];
    var mon = coeffs.map(function (c) { return c / lead; });
    // handle trailing zeros (roots at origin)
    var rootsAtZero = [];
    while (mon.length > 1 && Math.abs(mon[mon.length - 1]) < 1e-14) {
      mon.pop();
      rootsAtZero.push({ re: 0, im: 0 });
    }
    var m = mon.length - 1;
    if (m === 0) return rootsAtZero;
    if (m === 1) { return rootsAtZero.concat([{ re: -mon[1], im: 0 }]); }
    if (m === 2) {
      // quadratic closed form, accurate
      var b = mon[1], c = mon[2];
      var disc = b * b - 4 * c;
      var rs;
      if (disc >= 0) {
        var s = Math.sqrt(disc);
        rs = [{ re: (-b + s) / 2, im: 0 }, { re: (-b - s) / 2, im: 0 }];
      } else {
        var s2 = Math.sqrt(-disc) / 2;
        rs = [{ re: -b / 2, im: s2 }, { re: -b / 2, im: -s2 }];
      }
      return rootsAtZero.concat(rs);
    }
    // initial guesses on a circle (Aberth-style spread)
    var roots = [];
    var radius = 1 + Math.max.apply(null, mon.slice(1).map(Math.abs));
    for (var k = 0; k < m; k++) {
      var ang = (2 * Math.PI * k) / m + 0.4;
      roots.push({ re: radius * 0.5 * Math.cos(ang), im: radius * 0.5 * Math.sin(ang) });
    }
    for (var iter = 0; iter < 500; iter++) {
      var maxDelta = 0;
      for (var i = 0; i < m; i++) {
        var num = polyEvalC(mon, roots[i]);
        var den = { re: 1, im: 0 };
        for (var j = 0; j < m; j++) {
          if (j === i) continue;
          den = cMul(den, cSub(roots[i], roots[j]));
        }
        if (cAbs(den) < 1e-300) den = { re: 1e-12, im: 0 };
        var delta = cDiv(num, den);
        roots[i] = cSub(roots[i], delta);
        var dm = cAbs(delta);
        if (dm > maxDelta) maxDelta = dm;
      }
      if (maxDelta < 1e-12) break;
    }
    // clean tiny imaginary parts
    for (var r2 = 0; r2 < roots.length; r2++) {
      if (Math.abs(roots[r2].im) < 1e-7 * (1 + Math.abs(roots[r2].re))) roots[r2].im = 0;
    }
    return rootsAtZero.concat(roots);
  }

  // Multiply two polynomials (arrays, highest degree first).
  function polyMul(a, b) {
    var out = new Array(a.length + b.length - 1).fill(0);
    for (var i = 0; i < a.length; i++)
      for (var j = 0; j < b.length; j++)
        out[i + j] += a[i] * b[j];
    return out;
  }
  // Add two polynomials of possibly different length (highest degree first).
  function polyAdd(a, b) {
    var n = Math.max(a.length, b.length);
    var out = new Array(n).fill(0);
    for (var i = 0; i < a.length; i++) out[n - a.length + i] += a[i];
    for (var j = 0; j < b.length; j++) out[n - b.length + j] += b[j];
    return out;
  }
  function polyScale(a, s) { return a.map(function (c) { return c * s; }); }

  // Parse a space/comma separated coefficient list.
  function parseCoeffs(str) {
    if (str == null) return [];
    var parts = String(str).trim().split(/[\s,]+/).filter(function (p) { return p.length; });
    var out = [];
    for (var i = 0; i < parts.length; i++) {
      var v = parseFloat(parts[i]);
      if (isNaN(v)) return null;
      out.push(v);
    }
    return out;
  }

  /* ============================================================
     STEP / IMPULSE RESPONSE via RK4 on controllable canonical form
     System: G(s) = num(s)/den(s).  We simulate y for input u(t).
     State-space (controllable canonical), then y = C x + D u.
     ============================================================ */
  function buildStateSpace(num, den) {
    // strip leading zeros of den
    var d = den.slice();
    while (d.length > 1 && Math.abs(d[0]) < 1e-14) d.shift();
    var a0 = d[0];
    d = d.map(function (c) { return c / a0; });
    var n = d.length - 1; // order
    var b = num.map(function (c) { return c / a0; });
    // pad b to length n+1 (proper). If improper, clamp.
    while (b.length < n + 1) b.unshift(0);
    if (b.length > n + 1) b = b.slice(b.length - (n + 1));
    // D term (direct feedthrough) = b0 (coefficient of s^n in numerator)
    var D = b[0];
    // Controllable canonical form:
    // dx = A x + B u ; A is companion, B = e_n, C from (b_i - b0*a_i)
    // den(s) = s^n + a_{1} s^{n-1} + ... + a_n  (d[1..n])
    var A = [];
    for (var i = 0; i < n; i++) {
      A.push(new Array(n).fill(0));
      if (i < n - 1) A[i][i + 1] = 1;
    }
    for (var j = 0; j < n; j++) A[n - 1][j] = -d[n - j]; // -a_n .. -a_1
    var B = new Array(n).fill(0); if (n > 0) B[n - 1] = 1;
    var C = new Array(n).fill(0);
    for (var k = 0; k < n; k++) {
      // y coefficient: (b_{n-k} - b0 * a_{n-k})
      C[k] = b[n - k] - D * d[n - k];
    }
    return { A: A, B: B, C: C, D: D, n: n };
  }

  function matVec(A, x) {
    var n = A.length, out = new Array(n).fill(0);
    for (var i = 0; i < n; i++) {
      var s = 0;
      for (var j = 0; j < n; j++) s += A[i][j] * x[j];
      out[i] = s;
    }
    return out;
  }

  // Simulate response. inputType: 'step' or 'impulse'. Returns {t:[], y:[]}.
  function simulateResponse(num, den, T, N, inputType) {
    var ss;
    try { ss = buildStateSpace(num, den); } catch (e) { return null; }
    var n = ss.n;
    var dt = T / N;
    var t = [], y = [];
    var x = new Array(n).fill(0);
    // impulse: set initial state x(0) = B (equivalent to delta input)
    if (inputType === 'impulse') { for (var i = 0; i < n; i++) x[i] = ss.B[i]; }
    function deriv(xv, u) {
      var ax = matVec(ss.A, xv);
      var out = new Array(n);
      for (var i = 0; i < n; i++) out[i] = ax[i] + ss.B[i] * u;
      return out;
    }
    for (var k = 0; k <= N; k++) {
      var tk = k * dt;
      var u = (inputType === 'step') ? 1 : 0;
      var yk = 0;
      for (var i2 = 0; i2 < n; i2++) yk += ss.C[i2] * x[i2];
      yk += ss.D * u;
      // impulse direct term contributes a spike only at t=0 conceptually; skip D for impulse plotting
      if (inputType === 'impulse') yk = 0, (function () { for (var ii = 0; ii < n; ii++) yk += ss.C[ii] * x[ii]; })();
      t.push(tk); y.push(yk);
      // RK4 step
      if (k < N) {
        var k1 = deriv(x, u);
        var x2 = x.map(function (xi, i) { return xi + 0.5 * dt * k1[i]; });
        var k2 = deriv(x2, u);
        var x3 = x.map(function (xi, i) { return xi + 0.5 * dt * k2[i]; });
        var k3 = deriv(x3, u);
        var x4 = x.map(function (xi, i) { return xi + dt * k3[i]; });
        var k4 = deriv(x4, u);
        for (var m = 0; m < n; m++) x[m] = x[m] + (dt / 6) * (k1[m] + 2 * k2[m] + 2 * k3[m] + k4[m]);
      }
    }
    return { t: t, y: y };
  }

  /* ============================================================
     FREQUENCY RESPONSE  G(jw) = num(jw)/den(jw)
     ============================================================ */
  function freqResponse(num, den, w) {
    var jw = { re: 0, im: w };
    var nC = polyEvalC(num, jw);
    var dC = polyEvalC(den, jw);
    return cDiv(nC, dC);
  }

  /* ============================================================
     CANVAS PLOTTING HELPERS
     ============================================================ */
  function setupCanvas(canvas, cssW, cssH) {
    var dpr = window.devicePixelRatio || 1;
    canvas.style.width = '100%';
    canvas.style.height = cssH + 'px';
    var rect = canvas.getBoundingClientRect();
    var w = rect.width || cssW;
    canvas.width = Math.round(w * dpr);
    canvas.height = Math.round(cssH * dpr);
    var ctx = canvas.getContext('2d');
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    return { ctx: ctx, w: w, h: cssH };
  }
  function clearC(ctx, w, h) { ctx.fillStyle = '#0a0a0c'; ctx.fillRect(0, 0, w, h); }

  function makeScale(min, max, pxMin, pxMax) {
    var d = (max - min) || 1;
    return function (v) { return pxMin + (v - min) / d * (pxMax - pxMin); };
  }

  /* ============================================================
     SECTION CONTENT FOR EACH EXPERIMENT
     ============================================================ */
  var EXP = [];

  // ---- helper to make MCQ block ----
  function quizBlock(items) {
    // items: [{q, opts:[], correct:idx, exp}]
    var wrap = el('div');
    items.forEach(function (it, qi) {
      var card = el('div', { 'class': 'cs-quiz' });
      card.appendChild(el('p', { 'class': 'q' }, (qi + 1) + '. ' + it.q));
      it.opts.forEach(function (op, oi) {
        var lab = el('label');
        lab.innerHTML = '<input type="radio" name="q_' + Math.random().toString(36).slice(2) + '_' + qi + '" value="' + oi + '">' + op;
        // ensure same name within card
        card.appendChild(lab);
      });
      // unify radio names within this card
      var nm = 'qz' + Math.random().toString(36).slice(2);
      card.querySelectorAll('input[type=radio]').forEach(function (r) { r.name = nm; });
      var exp = el('div', { 'class': 'exp' });
      card.appendChild(exp);
      card.__check = function () {
        var sel = card.querySelector('input[type=radio]:checked');
        if (!sel) { exp.className = 'exp show wrong'; exp.textContent = 'Select an answer first.'; return false; }
        var ok = parseInt(sel.value, 10) === it.correct;
        exp.className = 'exp show ' + (ok ? 'right' : 'wrong');
        exp.textContent = (ok ? 'Correct. ' : 'Incorrect. ') + it.exp;
        return ok;
      };
      wrap.appendChild(card);
    });
    var bar = el('div', { style: 'display:flex;gap:8px;margin-top:6px;' });
    var btn = el('button', { 'class': 'cs-btn' }, 'Check answers');
    var score = el('span', { style: "font-family:'Geist Mono',monospace;font-size:12px;color:#67e8f9;align-self:center;" });
    btn.onclick = function () {
