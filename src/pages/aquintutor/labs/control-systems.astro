      { q: 'The number of sign changes in the first column equals:', opts: ['The number of LHP roots', 'The polynomial degree', 'The number of RHP roots', 'Zero always'], correct: 2, exp: 'Each first-column sign change corresponds to one root in the right-half plane.' },
      { q: 'A complete row of zeros in the Routh array indicates:', opts: ['A stable system', 'Roots symmetric about the origin (possibly on the jw axis)', 'A computational error', 'No information'], correct: 1, exp: 'A zero row signals symmetric roots; the auxiliary polynomial reveals roots on the imaginary axis (marginal stability).' },
      { q: 'For s^2 + a1 s + a2, stability requires:', opts: ['a1 > 0 and a2 > 0', 'a1 < 0', 'a2 = 0', 'a1 = a2'], correct: 0, exp: 'A second-order monic polynomial is stable iff both coefficients are positive.' }
