  /* ============================================================
     MOUNT FUNCTIONS (the live simulations)
     ============================================================ */

  function makeControlPanel(title) {
    var p = el('div', { 'class': 'cs-controls' });
    p.appendChild(el('h5', {}, title));
    return p;
  }
  function slider(parent, label, min, max, step, val, fmt, onchange) {
    var ctl = el('div', { 'class': 'cs-ctl' });
    var lab = el('label');
    var span = el('span');
    lab.appendChild(document.createTextNode(label + ' '));
    lab.appendChild(span);
    var inp = el('input', { type: 'range', min: min, max: max, step: step, value: val });
    ctl.appendChild(lab); ctl.appendChild(inp);
    parent.appendChild(ctl);
    function upd() { span.textContent = fmt(parseFloat(inp.value)); onchange(parseFloat(inp.value)); }
    inp.addEventListener('input', upd);
    span.textContent = fmt(parseFloat(inp.value));
    return { input: inp, set: function (v) { inp.value = v; span.textContent = fmt(v); } };
  }
  function textInput(parent, label, val, onchange) {
    var ctl = el('div', { 'class': 'cs-ctl' });
    var lab = el('label'); lab.textContent = label;
    var inp = el('input', { type: 'text', value: val });
    ctl.appendChild(lab); ctl.appendChild(inp);
    parent.appendChild(ctl);
    inp.addEventListener('input', function () { onchange(inp.value); });
    return inp;
  }
  function readoutGrid(parent) {
    var g = el('div', { 'class': 'cs-read' });
    parent.appendChild(g);
    return {
      cell: function (k, cls) {
        var c = el('div', { 'class': 'cell' });
        c.appendChild(el('div', { 'class': 'k' }, k));
        var v = el('div', { 'class': 'v' + (cls ? ' ' + cls : '') }, '–');
        c.appendChild(v);
        g.appendChild(c);
        return v;
      }
    };
  }

  // ----- s-plane drawing shared by Exp1/Exp3 -----
  function drawSPlane(canvas, poles, zeros, opts) {
    opts = opts || {};
    var d = setupCanvas(canvas, 600, opts.height || 340);
    var ctx = d.ctx, W = d.w, H = d.h;
    clearC(ctx, W, H);
    var pad = 36;
    var allre = [], allim = [];
    poles.concat(zeros).forEach(function (p) { allre.push(p.re); allim.push(p.im); });
    if (opts.extraPts) opts.extraPts.forEach(function (p) { allre.push(p.re); allim.push(p.im); });
    var maxR = 1;
    allre.concat(allim).forEach(function (v) { if (Math.abs(v) > maxR) maxR = Math.abs(v); });
    maxR = maxR * 1.25;
    if (opts.fixedRange) maxR = opts.fixedRange;
    var sx = makeScale(-maxR, maxR, pad, W - pad);
    var sy = makeScale(-maxR, maxR, H - pad, pad);
    // stable region shading (left half)
    ctx.fillStyle = 'rgba(134,239,172,0.05)';
    ctx.fillRect(pad, pad, sx(0) - pad, H - 2 * pad);
    // grid
    ctx.strokeStyle = '#1a1a25'; ctx.lineWidth = 1;
    var ticks = 4;
    for (var i = -ticks; i <= ticks; i++) {
      var gx = sx(maxR * i / ticks), gy = sy(maxR * i / ticks);
      ctx.beginPath(); ctx.moveTo(gx, pad); ctx.lineTo(gx, H - pad); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(pad, gy); ctx.lineTo(W - pad, gy); ctx.stroke();
    }
    // axes
    ctx.strokeStyle = '#3a4252'; ctx.lineWidth = 1.4;
    ctx.beginPath(); ctx.moveTo(pad, sy(0)); ctx.lineTo(W - pad, sy(0)); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(sx(0), pad); ctx.lineTo(sx(0), H - pad); ctx.stroke();
    ctx.fillStyle = '#9aa6b6'; ctx.font = "11px 'Geist Mono', monospace";
    ctx.fillText('Re', W - pad - 16, sy(0) - 6);
    ctx.fillText('jw', sx(0) + 6, pad + 12);
    ctx.fillText('Im', sx(0) + 6, pad + 12);
    // locus trail
    if (opts.trail) {
      ctx.fillStyle = 'rgba(167,139,250,0.35)';
      opts.trail.forEach(function (p) {
        ctx.beginPath(); ctx.arc(sx(p.re), sy(p.im), 1.4, 0, 2 * Math.PI); ctx.fill();
      });
    }
    // zeros (o)
    ctx.strokeStyle = '#fbbf24'; ctx.lineWidth = 2;
    zeros.forEach(function (z) {
      ctx.beginPath(); ctx.arc(sx(z.re), sy(z.im), 6, 0, 2 * Math.PI); ctx.stroke();
    });
    // poles (x)
    ctx.strokeStyle = '#fca5a5'; ctx.lineWidth = 2.2;
    poles.forEach(function (p) {
      var x = sx(p.re), y = sy(p.im), r = 5;
      ctx.beginPath(); ctx.moveTo(x - r, y - r); ctx.lineTo(x + r, y + r);
      ctx.moveTo(x + r, y - r); ctx.lineTo(x - r, y + r); ctx.stroke();
    });
    // highlighted closed-loop poles
    if (opts.highlight) {
      ctx.fillStyle = '#67e8f9';
      opts.highlight.forEach(function (p) {
        ctx.beginPath(); ctx.arc(sx(p.re), sy(p.im), 4.5, 0, 2 * Math.PI); ctx.fill();
      });
    }
    return { sx: sx, sy: sy };
  }

  // ----- time response plot shared by Exp1/Exp2/Exp6 -----
  function drawResponse(canvas, data, opts) {
    opts = opts || {};
    var d = setupCanvas(canvas, 600, opts.height || 320);
    var ctx = d.ctx, W = d.w, H = d.h;
    clearC(ctx, W, H);
    var pad = 40, padR = 14, padT = 14, padB = 30;
    var t = data.t, y = data.y;
    var ymin = Math.min.apply(null, y), ymax = Math.max.apply(null, y);
    if (opts.yMinForce != null) ymin = Math.min(ymin, opts.yMinForce);
    if (opts.yMaxForce != null) ymax = Math.max(ymax, opts.yMaxForce);
    var span = ymax - ymin; if (span < 1e-9) span = 1;
    ymin -= span * 0.08; ymax += span * 0.08;
    var tmax = t[t.length - 1] || 1;
    var sx = makeScale(0, tmax, pad, W - padR);
    var sy = makeScale(ymin, ymax, H - padB, padT);
    // grid
    ctx.strokeStyle = '#1a1a25'; ctx.lineWidth = 1;
    for (var i = 0; i <= 5; i++) {
      var gx = pad + (W - padR - pad) * i / 5;
      ctx.beginPath(); ctx.moveTo(gx, padT); ctx.lineTo(gx, H - padB); ctx.stroke();
      var gy = padT + (H - padB - padT) * i / 5;
      ctx.beginPath(); ctx.moveTo(pad, gy); ctx.lineTo(W - padR, gy); ctx.stroke();
    }
    // zero line & final value
    ctx.strokeStyle = '#3a4252'; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(pad, sy(0)); ctx.lineTo(W - padR, sy(0)); ctx.stroke();
    if (opts.finalVal != null) {
      ctx.strokeStyle = '#3a4252'; ctx.setLineDash([4, 4]);
      ctx.beginPath(); ctx.moveTo(pad, sy(opts.finalVal)); ctx.lineTo(W - padR, sy(opts.finalVal)); ctx.stroke();
      ctx.setLineDash([]);
      // 2% band
      if (opts.band) {
        ctx.strokeStyle = 'rgba(251,191,36,0.4)'; ctx.setLineDash([3, 4]);
        ctx.beginPath(); ctx.moveTo(pad, sy(opts.finalVal * 1.02)); ctx.lineTo(W - padR, sy(opts.finalVal * 1.02)); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(pad, sy(opts.finalVal * 0.98)); ctx.lineTo(W - padR, sy(opts.finalVal * 0.98)); ctx.stroke();
        ctx.setLineDash([]);
      }
    }
    // curve
    ctx.strokeStyle = opts.color || '#67e8f9'; ctx.lineWidth = 2;
    ctx.beginPath();
    for (var k = 0; k < t.length; k++) {
      var X = sx(t[k]), Y = sy(y[k]);
      if (k === 0) ctx.moveTo(X, Y); else ctx.lineTo(X, Y);
    }
    ctx.stroke();
    // markers
    if (opts.markers) {
      opts.markers.forEach(function (m) {
        ctx.fillStyle = m.color || '#fbbf24';
        ctx.beginPath(); ctx.arc(sx(m.t), sy(m.y), 4, 0, 2 * Math.PI); ctx.fill();
        if (m.label) {
          ctx.font = "10px 'Geist Mono', monospace";
          ctx.fillText(m.label, sx(m.t) + 6, sy(m.y) - 6);
        }
      });
    }
    // axis labels
    ctx.fillStyle = '#9aa6b6'; ctx.font = "11px 'Geist Mono', monospace";
    ctx.fillText('t (s)', W - padR - 30, H - 8);
    ctx.fillText('y(t)', pad - 28, padT + 8);
    ctx.fillText('0', pad - 14, sy(0) + 4);
    ctx.fillText(tmax.toFixed(1), W - padR - 18, H - padB + 14);
  }

  // measure specs from a step response curve
  function measureSpecs(data, finalVal) {
    var t = data.t, y = data.y;
    var peak = -Infinity, tp = 0;
    for (var i = 0; i < y.length; i++) { if (y[i] > peak) { peak = y[i]; tp = t[i]; } }
    var os = finalVal !== 0 ? (peak - finalVal) / Math.abs(finalVal) * 100 : 0;
    if (os < 0) os = 0;
    // settling time (last time outside +/-2%)
    var ts = 0;
    for (var j = 0; j < y.length; j++) {
      if (Math.abs(y[j] - finalVal) > 0.02 * Math.abs(finalVal || 1)) ts = t[j];
    }
    // rise time 10%->90% of final
    var t10 = null, t90 = null;
    for (var k = 0; k < y.length; k++) {
      if (t10 === null && y[k] >= 0.1 * finalVal) t10 = t[k];
      if (t90 === null && y[k] >= 0.9 * finalVal) { t90 = t[k]; break; }
    }
    var tr = (t10 !== null && t90 !== null) ? (t90 - t10) : 0;
    return { peak: peak, tp: tp, os: os, ts: ts, tr: tr };
  }

  /* ---------- EXP 1 ---------- */
  function mountExp1(root) {
    var sim = el('div', { 'class': 'cs-sim' });
    var left = makeControlPanel('Transfer function');
    var right = el('div');
    sim.appendChild(left); sim.appendChild(right);
    root.appendChild(sim);

    var state = { num: '1', den: '1 2 5', T: 8, resp: 'step' };
    textInput(left, 'Numerator (high s first)', state.num, function (v) { state.num = v; render(); });
    textInput(left, 'Denominator (high s first)', state.den, function (v) { state.den = v; render(); });
    var respSel = el('div', { 'class': 'cs-ctl' });
    respSel.innerHTML = '<label>Response</label>';
    var sel = el('select');
    sel.innerHTML = '<option value="step">Step</option><option value="impulse">Impulse</option>';
    sel.addEventListener('change', function () { state.resp = sel.value; render(); });
    respSel.appendChild(sel); left.appendChild(respSel);
    slider(left, 'Time window T', 1, 40, 0.5, state.T, function (v) { return v.toFixed(1) + ' s'; }, function (v) { state.T = v; render(); });

    var status = el('div', { 'class': 'cs-status ok' }); left.appendChild(status);

    right.appendChild(el('p', { 'class': 'cs-plotlbl' }, 's-plane: poles (x) and zeros (o)'));
    var splane = el('canvas', { 'class': 'cs-canvas' }); right.appendChild(splane);
    right.appendChild(el('p', { 'class': 'cs-plotlbl', style: 'margin-top:14px;' }, 'Time response'));
    var resp = el('canvas', { 'class': 'cs-canvas' }); right.appendChild(resp);
    var ro = readoutGrid(right);
    var rPoles = ro.cell('Poles', 'red');
    var rZeros = ro.cell('Zeros', 'amber');
    var rStab = ro.cell('Stability', 'green');
    var rFinal = ro.cell('Final value', 'purple');

    function render() {
      var num = parseCoeffs(state.num), den = parseCoeffs(state.den);
      if (!num || !den || num.length === 0 || den.length === 0) {
        status.className = 'cs-status bad'; status.textContent = 'Enter valid numeric coefficients.'; return;
      }
      var poles = polyRoots(den), zeros = polyRoots(num);
      drawSPlane(splane, poles, zeros, {});
      var unstable = poles.some(function (p) { return p.re > 1e-9; });
      var marginal = poles.some(function (p) { return Math.abs(p.re) < 1e-7; });
      var data = simulateResponse(num, den, state.T, 1400, state.resp);
      if (data) drawResponse(resp, data, { color: state.resp === 'step' ? '#67e8f9' : '#a78bfa' });
      rPoles.textContent = poles.map(fmtC).join('  ');
      rZeros.textContent = zeros.length ? zeros.map(fmtC).join('  ') : 'none';
      rStab.className = 'v ' + (unstable ? 'red' : (marginal ? 'amber' : 'green'));
      rStab.textContent = unstable ? 'UNSTABLE' : (marginal ? 'MARGINAL' : 'STABLE');
      // DC gain final value (step)
      var dc = den[den.length - 1] !== 0 ? num[num.length - 1] / den[den.length - 1] : NaN;
      rFinal.textContent = state.resp === 'step' ? (isFinite(dc) ? dc.toFixed(3) : 'inf') : '0';
      status.className = 'cs-status ' + (unstable ? 'bad' : 'ok');
      status.textContent = 'Order ' + (den.length - 1) + ' system, ' + poles.length + ' pole(s), ' + zeros.length + ' zero(s).';
    }
    render();
    window.addEventListener('resize', render);
  }
  function fmtC(c) {
    if (Math.abs(c.im) < 1e-6) return c.re.toFixed(2);
    return c.re.toFixed(2) + (c.im >= 0 ? '+' : '-') + Math.abs(c.im).toFixed(2) + 'j';
  }

  /* ---------- EXP 2 ---------- */
  function mountExp2(root) {
    var sim = el('div', { 'class': 'cs-sim' });
    var left = makeControlPanel('Second-order parameters');
    var right = el('div');
    sim.appendChild(left); sim.appendChild(right);
    root.appendChild(sim);

    var state = { zeta: 0.4, wn: 2 };
    slider(left, 'Damping ratio zeta', 0.05, 1.5, 0.01, state.zeta, function (v) { return v.toFixed(2); }, function (v) { state.zeta = v; render(); });
    slider(left, 'Natural freq wn', 0.3, 8, 0.1, state.wn, function (v) { return v.toFixed(1) + ' rad/s'; }, function (v) { state.wn = v; render(); });
    var note = el('div', { 'class': 'cs-hint' });
    note.textContent = 'G(s) = wn^2 / (s^2 + 2 zeta wn s + wn^2)';
    left.appendChild(note);
    var status = el('div', { 'class': 'cs-status ok' }); left.appendChild(status);

    right.appendChild(el('p', { 'class': 'cs-plotlbl' }, 'Unit-step response (analytic specs overlaid)'));
    var resp = el('canvas', { 'class': 'cs-canvas' }); right.appendChild(resp);
    var ro = readoutGrid(right);
    var rTp = ro.cell('Peak time tp', 'amber');
    var rOs = ro.cell('% Overshoot', 'red');
    var rTs = ro.cell('Settling ts (2%)', 'purple');
    var rTr = ro.cell('Rise time tr', 'green');
    var rWd = ro.cell('Damped wd', 'green');
    var rPoles = ro.cell('Poles', 'red');

    function render() {
      var z = state.zeta, wn = state.wn;
      var num = [wn * wn], den = [1, 2 * z * wn, wn * wn];
      // analytic specs (underdamped only for tp/os)
      var under = z < 1;
      var wd = wn * Math.sqrt(Math.max(0, 1 - z * z));
      var tp = under && wd > 0 ? Math.PI / wd : NaN;
      var os = under ? 100 * Math.exp(-z * Math.PI / Math.sqrt(1 - z * z)) : 0;
      var ts = 4 / (z * wn);
      var tr = (1.76 * z * z * z - 0.417 * z * z + 1.039 * z + 1) / wn;
      var Twin = Math.max(ts * 1.6, (isFinite(tp) ? tp * 4 : 6));
      var data = simulateResponse(num, den, Twin, 1600, 'step');
      var markers = [];
      if (isFinite(tp)) {
        // peak value from analytic = 1 + os/100
        markers.push({ t: tp, y: 1 + os / 100, color: '#fbbf24', label: 'tp' });
      }
      markers.push({ t: ts, y: 1, color: '#a78bfa', label: 'ts' });
      drawResponse(resp, data, { finalVal: 1, band: true, markers: markers, yMaxForce: 1 + os / 100 + 0.05, yMinForce: 0 });
      var poles = polyRoots(den);
      rTp.textContent = isFinite(tp) ? tp.toFixed(3) + ' s' : 'n/a (overdamped)';
      rOs.textContent = os.toFixed(2) + ' %';
      rTs.textContent = ts.toFixed(3) + ' s';
      rTr.textContent = tr.toFixed(3) + ' s';
      rWd.textContent = wd.toFixed(3) + ' rad/s';
      rPoles.textContent = poles.map(fmtC).join('  ');
      status.className = 'cs-status ' + (under ? 'ok' : 'warn');
      status.textContent = under ? 'Underdamped (zeta < 1): oscillatory.' : (z === 1 ? 'Critically damped.' : 'Overdamped (zeta > 1): no overshoot.');
    }
    render();
    window.addEventListener('resize', render);
  }

  /* ---------- EXP 3 ---------- */
  function mountExp3(root) {
    var sim = el('div', { 'class': 'cs-sim' });
    var left = makeControlPanel('Open-loop G(s) and gain');
    var right = el('div');
    sim.appendChild(left); sim.appendChild(right);
    root.appendChild(sim);

    var state = { num: '1', den: '1 3 2 0', K: 4, Kmax: 40 };
    textInput(left, 'Numerator N(s)', state.num, function (v) { state.num = v; render(); });
    textInput(left, 'Denominator D(s)', state.den, function (v) { state.den = v; render(); });
    var sK = slider(left, 'Gain K', 0, state.Kmax, 0.1, state.K, function (v) { return v.toFixed(1); }, function (v) { state.K = v; render(); });
    slider(left, 'Sweep Kmax', 1, 200, 1, state.Kmax, function (v) { return v.toFixed(0); }, function (v) { state.Kmax = v; sK.input.max = v; render(); });
    var status = el('div', { 'class': 'cs-status ok' }); left.appendChild(status);

    right.appendChild(el('p', { 'class': 'cs-plotlbl' }, 'Root locus: open-loop x/o fixed, cyan = closed-loop poles at current K, trail = full sweep'));
    var splane = el('canvas', { 'class': 'cs-canvas' }); right.appendChild(splane);
    var ro = readoutGrid(right);
    var rCl = ro.cell('Closed-loop poles @ K', 'green');
    var rStab = ro.cell('Stability @ K', 'green');
    var rKcrit = ro.cell('Critical K (jw cross)', 'amber');

    function clPoles(num, den, K) {
      // char poly = den + K*num
      return polyRoots(polyAdd(den, polyScale(num, K)));
    }

    function render() {
      var num = parseCoeffs(state.num), den = parseCoeffs(state.den);
      if (!num || !den || den.length < 2) { status.className = 'cs-status bad'; status.textContent = 'Enter valid G(s).'; return; }
      var olp = polyRoots(den), olz = polyRoots(num);
      // sweep trail
      var trail = [];
      var steps = 240;
      var prevSign = null, kcrit = null;
      for (var i = 0; i <= steps; i++) {
        var K = state.Kmax * i / steps;
        var rs = clPoles(num, den, K);
        var maxRe = -Infinity;
        rs.forEach(function (p) { trail.push(p); if (p.re > maxRe) maxRe = p.re; });
        var sgn = maxRe > 0 ? 1 : -1;
        if (prevSign !== null && sgn !== prevSign && kcrit === null && maxRe >= 0) kcrit = K;
        prevSign = sgn;
      }
      var cur = clPoles(num, den, state.K);
      drawSPlane(splane, olp, olz, { trail: trail, highlight: cur });
      var unstable = cur.some(function (p) { return p.re > 1e-7; });
      rCl.textContent = cur.map(fmtC).join('  ');
      rStab.className = 'v ' + (unstable ? 'red' : 'green');
      rStab.textContent = unstable ? 'UNSTABLE' : 'STABLE';
      rKcrit.textContent = kcrit !== null ? kcrit.toFixed(2) : 'none in sweep';
      status.className = 'cs-status ' + (unstable ? 'bad' : 'ok');
      status.textContent = olp.length + ' branches. Open-loop poles at K=0, migrating to ' + (olz.length || 0) + ' zero(s).';
    }
    render();
    window.addEventListener('resize', render);
  }

  /* ---------- EXP 4 ---------- */
  function mountExp4(root) {
    var sim = el('div', { 'class': 'cs-sim' });
    var left = makeControlPanel('Open-loop G(s)');
    var right = el('div');
    sim.appendChild(left); sim.appendChild(right);
    root.appendChild(sim);

    var state = { num: '10', den: '1 2 0', wmin: -2, wmax: 3 };
    textInput(left, 'Numerator N(s)', state.num, function (v) { state.num = v; render(); });
    textInput(left, 'Denominator D(s)', state.den, function (v) { state.den = v; render(); });
    slider(left, 'log10 w min', -3, 0, 0.5, state.wmin, function (v) { return v.toFixed(1); }, function (v) { state.wmin = v; render(); });
    slider(left, 'log10 w max', 1, 4, 0.5, state.wmax, function (v) { return v.toFixed(1); }, function (v) { state.wmax = v; render(); });
    var status = el('div', { 'class': 'cs-status ok' }); left.appendChild(status);

    right.appendChild(el('p', { 'class': 'cs-plotlbl' }, 'Magnitude (dB) vs log frequency'));
    var magc = el('canvas', { 'class': 'cs-canvas' }); right.appendChild(magc);
    right.appendChild(el('p', { 'class': 'cs-plotlbl', style: 'margin-top:14px;' }, 'Phase (deg) vs log frequency'));
    var phc = el('canvas', { 'class': 'cs-canvas' }); right.appendChild(phc);
    var ro = readoutGrid(right);
    var rGM = ro.cell('Gain margin', 'green');
    var rPM = ro.cell('Phase margin', 'green');
    var rWgc = ro.cell('Gain crossover wgc', 'amber');
    var rWpc = ro.cell('Phase crossover wpc', 'purple');

    function render() {
      var num = parseCoeffs(state.num), den = parseCoeffs(state.den);
      if (!num || !den) { status.className = 'cs-status bad'; status.textContent = 'Enter valid G(s).'; return; }
      var N = 600;
      var ws = [], mag = [], ph = [];
      var lastPh = null;
      for (var i = 0; i <= N; i++) {
        var lw = state.wmin + (state.wmax - state.wmin) * i / N;
        var w = Math.pow(10, lw);
        var g = freqResponse(num, den, w);
        var m = 20 * Math.log10(cAbs(g) + 1e-300);
        var p = cArg(g) * 180 / Math.PI;
        // unwrap phase
        if (lastPh !== null) {
          while (p - lastPh > 180) p -= 360;
          while (p - lastPh < -180) p += 360;
        }
        lastPh = p;
        ws.push(lw); mag.push(m); ph.push(p);
      }
      drawBode(magc, ws, mag, 'mag');
      drawBode(phc, ws, ph, 'phase');
      // crossovers
      var wgc = interpCross(ws, mag, 0);
      var wpc = interpCross(ws, ph, -180);
      var pm = null, gm = null;
      if (wgc !== null) { var phAtGc = interpAt(ws, ph, wgc); pm = 180 + phAtGc; }
      if (wpc !== null) { var magAtPc = interpAt(ws, mag, wpc); gm = -magAtPc; }
      rGM.className = 'v ' + (gm === null ? 'green' : (gm > 0 ? 'green' : 'red'));
      rGM.textContent = gm === null ? 'inf (no -180 xover)' : gm.toFixed(2) + ' dB';
      rPM.className = 'v ' + (pm === null ? 'green' : (pm > 0 ? 'green' : 'red'));
      rPM.textContent = pm === null ? 'n/a' : pm.toFixed(2) + ' deg';
      rWgc.textContent = wgc === null ? 'none' : Math.pow(10, wgc).toFixed(3) + ' rad/s';
      rWpc.textContent = wpc === null ? 'none' : Math.pow(10, wpc).toFixed(3) + ' rad/s';
      var stable = (pm === null || pm > 0) && (gm === null || gm > 0);
      status.className = 'cs-status ' + (stable ? 'ok' : 'bad');
      status.textContent = stable ? 'Closed loop stable: positive margins.' : 'Closed loop unstable: a margin is negative.';
    }
    render();
    window.addEventListener('resize', render);
  }

  function drawBode(canvas, ws, vals, kind) {
    var d = setupCanvas(canvas, 600, 220);
    var ctx = d.ctx, W = d.w, H = d.h;
    clearC(ctx, W, H);
    var pad = 46, padR = 14, padT = 12, padB = 26;
    var wmin = ws[0], wmax = ws[ws.length - 1];
    var vmin = Math.min.apply(null, vals), vmax = Math.max.apply(null, vals);
    if (kind === 'phase') { vmin = Math.min(vmin, -190); vmax = Math.max(vmax, 5); }
    var spanV = vmax - vmin; if (spanV < 1e-6) spanV = 1; vmin -= spanV * 0.08; vmax += spanV * 0.08;
    var sx = makeScale(wmin, wmax, pad, W - padR);
    var sy = makeScale(vmin, vmax, H - padB, padT);
    // grid (decade lines)
    ctx.strokeStyle = '#1a1a25'; ctx.lineWidth = 1;
    for (var dlog = Math.ceil(wmin); dlog <= Math.floor(wmax); dlog++) {
      var gx = sx(dlog);
      ctx.beginPath(); ctx.moveTo(gx, padT); ctx.lineTo(gx, H - padB); ctx.stroke();
    }
    for (var hy = 0; hy <= 4; hy++) {
      var gy = padT + (H - padB - padT) * hy / 4;
      ctx.beginPath(); ctx.moveTo(pad, gy); ctx.lineTo(W - padR, gy); ctx.stroke();
    }
    // reference line
    ctx.strokeStyle = '#5a4a2f'; ctx.setLineDash([5, 4]); ctx.lineWidth = 1.2;
    var refV = kind === 'mag' ? 0 : -180;
    if (refV >= vmin && refV <= vmax) {
      ctx.beginPath(); ctx.moveTo(pad, sy(refV)); ctx.lineTo(W - padR, sy(refV)); ctx.stroke();
    }
    ctx.setLineDash([]);
    // curve
    ctx.strokeStyle = kind === 'mag' ? '#67e8f9' : '#a78bfa'; ctx.lineWidth = 2;
    ctx.beginPath();
    for (var k = 0; k < ws.length; k++) {
      var X = sx(ws[k]), Y = sy(vals[k]);
      if (k === 0) ctx.moveTo(X, Y); else ctx.lineTo(X, Y);
    }
    ctx.stroke();
    // labels
    ctx.fillStyle = '#9aa6b6'; ctx.font = "10px 'Geist Mono', monospace";
    ctx.fillText(kind === 'mag' ? 'dB' : 'deg', 6, padT + 8);
    ctx.fillText('log10 w', W - padR - 50, H - 6);
    ctx.fillText(vmax.toFixed(0), 6, padT + 18);
    ctx.fillText(vmin.toFixed(0), 6, H - padB);
    for (var dl = Math.ceil(wmin); dl <= Math.floor(wmax); dl++) {
      ctx.fillText(dl.toString(), sx(dl) - 4, H - padB + 14);
    }
  }
  // find first crossing of target value, return interpolated x (log w)
  function interpCross(xs, ys, target) {
    for (var i = 1; i < ys.length; i++) {
      var a = ys[i - 1] - target, b = ys[i] - target;
      if (a === 0) return xs[i - 1];
      if (a * b < 0) {
        var f = a / (a - b);
        return xs[i - 1] + f * (xs[i] - xs[i - 1]);
      }
    }
    return null;
  }
  function interpAt(xs, ys, xv) {
    for (var i = 1; i < xs.length; i++) {
      if ((xs[i - 1] <= xv && xv <= xs[i]) || (xs[i] <= xv && xv <= xs[i - 1])) {
        var f = (xv - xs[i - 1]) / (xs[i] - xs[i - 1]);
        return ys[i - 1] + f * (ys[i] - ys[i - 1]);
      }
    }
    return ys[ys.length - 1];
  }

  /* ---------- EXP 5 ---------- */
  function mountExp5(root) {
    var sim = el('div', { 'class': 'cs-sim' });
    var left = makeControlPanel('Open-loop G(s)');
    var right = el('div');
    sim.appendChild(left); sim.appendChild(right);
    root.appendChild(sim);

    var state = { num: '5', den: '1 2 1 0' };
    textInput(left, 'Numerator N(s)', state.num, function (v) { state.num = v; render(); });
    textInput(left, 'Denominator D(s)', state.den, function (v) { state.den = v; render(); });
    var status = el('div', { 'class': 'cs-status ok' }); left.appendChild(status);
    left.appendChild(el('div', { 'class': 'cs-hint' }, 'Locus drawn for w from -inf to +inf. Red dot is the critical point -1 + j0.'));

    right.appendChild(el('p', { 'class': 'cs-plotlbl' }, 'Nyquist plot of G(jw)'));
    var nyq = el('canvas', { 'class': 'cs-canvas' }); right.appendChild(nyq);
    var ro = readoutGrid(right);
    var rP = ro.cell('P (open-loop RHP poles)', 'amber');
    var rN = ro.cell('N (encirclements of -1)', 'purple');
    var rZ = ro.cell('Z = N + P', 'red');
    var rStab = ro.cell('Closed-loop', 'green');

    function render() {
      var num = parseCoeffs(state.num), den = parseCoeffs(state.den);
      if (!num || !den) { status.className = 'cs-status bad'; status.textContent = 'Enter valid G(s).'; return; }
      var olp = polyRoots(den);
      var P = olp.filter(function (p) { return p.re > 1e-7; }).length;
      var hasOrigin = olp.some(function (p) { return Math.abs(p.re) < 1e-7 && Math.abs(p.im) < 1e-7; });
      // build locus over positive and negative w
      var pts = [];
      var N = 1400;
      var wlogMin = -3, wlogMax = 3.5;
      // positive frequencies
      for (var i = 0; i <= N; i++) {
        var lw = wlogMin + (wlogMax - wlogMin) * i / N;
        var w = Math.pow(10, lw);
        var g = freqResponse(num, den, w);
        if (isFinite(g.re) && isFinite(g.im)) pts.push({ re: g.re, im: g.im });
      }
      // negative frequencies (mirror), reversed for continuity
      var neg = [];
      for (var j = 0; j <= N; j++) {
        var lw2 = wlogMin + (wlogMax - wlogMin) * j / N;
        var w2 = -Math.pow(10, lw2);
        var g2 = freqResponse(num, den, w2);
        if (isFinite(g2.re) && isFinite(g2.im)) neg.push({ re: g2.re, im: g2.im });
      }
      neg.reverse();
      var locus = neg.concat(pts);
      // count encirclements of -1 by accumulated angle of (G + 1)
      var totalAngle = 0;
      for (var k = 1; k < locus.length; k++) {
        var a1 = Math.atan2(locus[k - 1].im, locus[k - 1].re + 1);
        var a2 = Math.atan2(locus[k].im, locus[k].re + 1);
        var da = a2 - a1;
        while (da > Math.PI) da -= 2 * Math.PI;
        while (da < -Math.PI) da += 2 * Math.PI;
        totalAngle += da;
      }
      // CW encirclements positive: angle decreasing => -totalAngle/2pi
      var Ncount = -Math.round(totalAngle / (2 * Math.PI));
      var Z = Ncount + P;
      drawNyquist(nyq, locus);
      rP.textContent = P.toString() + (hasOrigin ? ' (+ jw-axis pole)' : '');
      rN.textContent = (Ncount >= 0 ? '+' : '') + Ncount + ' (CW)';
      rZ.textContent = Z.toString();
      rZ.className = 'v ' + (Z <= 0 ? 'green' : 'red');
      var stable = Z <= 0 && !hasOrigin ? true : (Z <= 0);
      rStab.className = 'v ' + (Z === 0 ? 'green' : 'red');
      rStab.textContent = Z === 0 ? 'STABLE' : (Z + ' RHP pole(s)');
      status.className = 'cs-status ' + (Z === 0 ? 'ok' : 'bad');
      status.textContent = 'Z = N + P = ' + Ncount + ' + ' + P + ' = ' + Z + (hasOrigin ? '. Open-loop has a pole on the jw-axis (integrator).' : '.');
    }
    render();
    window.addEventListener('resize', render);
  }

  function drawNyquist(canvas, locus) {
    var d = setupCanvas(canvas, 600, 360);
    var ctx = d.ctx, W = d.w, H = d.h;
    clearC(ctx, W, H);
    var pad = 36;
    var re = locus.map(function (p) { return p.re; });
    var im = locus.map(function (p) { return p.im; });
    var maxA = 1.4;
    re.concat(im).concat([-1, 1]).forEach(function (v) { if (isFinite(v) && Math.abs(v) > maxA) maxA = Math.abs(v); });
    maxA = Math.min(maxA, 60) * 1.1;
    var sx = makeScale(-maxA, maxA, pad, W - pad);
    var sy = makeScale(-maxA, maxA, H - pad, pad);
    // grid
    ctx.strokeStyle = '#1a1a25'; ctx.lineWidth = 1;
    for (var i = -4; i <= 4; i++) {
      var gx = sx(maxA * i / 4), gy = sy(maxA * i / 4);
      ctx.beginPath(); ctx.moveTo(gx, pad); ctx.lineTo(gx, H - pad); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(pad, gy); ctx.lineTo(W - pad, gy); ctx.stroke();
    }
    // axes
    ctx.strokeStyle = '#3a4252'; ctx.lineWidth = 1.4;
    ctx.beginPath(); ctx.moveTo(pad, sy(0)); ctx.lineTo(W - pad, sy(0)); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(sx(0), pad); ctx.lineTo(sx(0), H - pad); ctx.stroke();
    // unit circle (reference)
    ctx.strokeStyle = '#2a2a35'; ctx.setLineDash([3, 4]);
    ctx.beginPath(); ctx.arc(sx(0), sy(0), Math.abs(sx(1) - sx(0)), 0, 2 * Math.PI); ctx.stroke();
    ctx.setLineDash([]);
    // locus
    ctx.strokeStyle = '#67e8f9'; ctx.lineWidth = 1.8;
    ctx.beginPath();
    var started = false;
    for (var k = 0; k < locus.length; k++) {
      var X = sx(locus[k].re), Y = sy(locus[k].im);
      if (X < -2000 || X > W + 2000 || Y < -2000 || Y > H + 2000) { started = false; continue; }
      if (!started) { ctx.moveTo(X, Y); started = true; } else ctx.lineTo(X, Y);
    }
    ctx.stroke();
    // arrows of direction (a few)
    ctx.fillStyle = '#a78bfa';
    for (var a = 0.25; a < 1; a += 0.25) {
      var idx = Math.floor(locus.length * a);
      var p0 = locus[idx], p1 = locus[Math.min(idx + 1, locus.length - 1)];
      var ang = Math.atan2(sy(p1.im) - sy(p0.im), sx(p1.re) - sx(p0.re));
      var X2 = sx(p0.re), Y2 = sy(p0.im);
      if (Math.abs(X2) < W * 2 && Math.abs(Y2) < H * 2) {
        ctx.save(); ctx.translate(X2, Y2); ctx.rotate(ang);
        ctx.beginPath(); ctx.moveTo(0, 0); ctx.lineTo(-7, -3); ctx.lineTo(-7, 3); ctx.closePath(); ctx.fill();
        ctx.restore();
      }
    }
    // critical point -1
    ctx.fillStyle = '#fca5a5';
    ctx.beginPath(); ctx.arc(sx(-1), sy(0), 5, 0, 2 * Math.PI); ctx.fill();
    ctx.font = "11px 'Geist Mono', monospace";
    ctx.fillText('-1', sx(-1) - 4, sy(0) - 8);
    ctx.fillStyle = '#9aa6b6';
    ctx.fillText('Re', W - pad - 16, sy(0) - 6);
    ctx.fillText('Im', sx(0) + 6, pad + 12);
  }

  /* ---------- EXP 6 ---------- */
  function mountExp6(root) {
    var sim = el('div', { 'class': 'cs-sim' });
    var left = makeControlPanel('PID gains and plant');
    var right = el('div');
    sim.appendChild(left); sim.appendChild(right);
    root.appendChild(sim);

    var plants = {
      'second-order': { num: [1], den: [1, 1, 1], label: '1 / (s^2 + s + 1)' },
      'integrator-lag': { num: [1], den: [1, 1, 0], label: '1 / (s^2 + s)' },
      'first-order': { num: [1], den: [2, 1], label: '1 / (2s + 1)' },
      'third-order': { num: [1], den: [1, 3, 3, 1], label: '1 / (s+1)^3' }
    };
    var state = { Kp: 2, Ki: 0, Kd: 0, plant: 'second-order', T: 12 };
    var plctl = el('div', { 'class': 'cs-ctl' });
    plctl.innerHTML = '<label>Plant P(s)</label>';
    var psel = el('select');
    for (var key in plants) {
      var o = el('option', { value: key }, key + '  ' + plants[key].label);
      psel.appendChild(o);
    }
    psel.addEventListener('change', function () { state.plant = psel.value; render(); });
    plctl.appendChild(psel); left.appendChild(plctl);

    slider(left, 'Proportional Kp', 0, 30, 0.1, state.Kp, function (v) { return v.toFixed(1); }, function (v) { state.Kp = v; render(); });
    slider(left, 'Integral Ki', 0, 30, 0.1, state.Ki, function (v) { return v.toFixed(1); }, function (v) { state.Ki = v; render(); });
    slider(left, 'Derivative Kd', 0, 15, 0.05, state.Kd, function (v) { return v.toFixed(2); }, function (v) { state.Kd = v; render(); });
    slider(left, 'Time window T', 2, 40, 0.5, state.T, function (v) { return v.toFixed(1) + ' s'; }, function (v) { state.T = v; render(); });
    var status = el('div', { 'class': 'cs-status ok' }); left.appendChild(status);

    right.appendChild(el('p', { 'class': 'cs-plotlbl' }, 'Closed-loop unit-step response'));
    var resp = el('canvas', { 'class': 'cs-canvas' }); right.appendChild(resp);
    var ro = readoutGrid(right);
    var rOs = ro.cell('% Overshoot', 'red');
    var rTs = ro.cell('Settling ts (2%)', 'purple');
    var rTr = ro.cell('Rise time', 'green');
    var rSS = ro.cell('Steady-state err', 'amber');
    var rStab = ro.cell('Closed-loop', 'green');

    function render() {
      var P = plants[state.plant];
      // C(s) = Kd s^2 + Kp s + Ki  over  s
      var Cnum = [state.Kd, state.Kp, state.Ki];
      var Cden = [1, 0];
      // strip leading zero of Cnum if Kd==0 etc handled by polyMul fine
      // L(s) = C*P : num = Cnum*Pnum, den = Cden*Pden
      var Lnum = polyMul(Cnum, P.num);
      var Lden = polyMul(Cden, P.den);
      // T(s) = Lnum / (Lden + Lnum)
      var Tnum = Lnum.slice();
      var Tden = polyAdd(Lden, Lnum);
      var data = simulateResponse(Tnum, Tden, state.T, 1800, 'step');
      var final = Tden[Tden.length - 1] !== 0 ? Tnum[Tnum.length - 1] / Tden[Tden.length - 1] : 1;
      if (data) drawResponse(resp, data, { finalVal: final, band: true, color: '#86efac', yMinForce: 0 });
      var poles = polyRoots(Tden);
      var unstable = poles.some(function (p) { return p.re > 1e-6; });
      var specs = data ? measureSpecs(data, final) : { os: 0, ts: 0, tr: 0 };
      var ssErr = Math.abs(1 - final);
      rOs.textContent = unstable ? '∞' : specs.os.toFixed(2) + ' %';
      rTs.textContent = unstable ? '∞' : specs.ts.toFixed(2) + ' s';
      rTr.textContent = unstable ? 'n/a' : specs.tr.toFixed(2) + ' s';
      rSS.textContent = unstable ? 'n/a' : ssErr.toFixed(3);
      rStab.className = 'v ' + (unstable ? 'red' : 'green');
      rStab.textContent = unstable ? 'UNSTABLE' : 'STABLE';
      status.className = 'cs-status ' + (unstable ? 'bad' : 'ok');
      status.textContent = unstable ? 'Closed loop unstable — reduce gains.' : ('Closed-loop order ' + (Tden.length - 1) + '. ' + (state.Ki > 0 ? 'Integral action: zero SS error.' : 'No integral: residual SS error.'));
    }
    render();
    window.addEventListener('resize', render);
  }

  /* ---------- EXP 7 ---------- */
  function mountExp7(root) {
    var sim = el('div', { 'class': 'cs-sim' });
    var left = makeControlPanel('Characteristic polynomial');
    var right = el('div');
    sim.appendChild(left); sim.appendChild(right);
    root.appendChild(sim);

    var state = { coeffs: '1 2 3 4 5' };
    var inp = textInput(left, 'Coefficients (high s first)', state.coeffs, function (v) { state.coeffs = v; });
    var btn = el('button', { 'class': 'cs-btn' }, 'Build Routh array');
    btn.style.marginTop = '4px';
    left.appendChild(btn);
    left.appendChild(el('div', { 'class': 'cs-hint' }, 'e.g. "1 2 3 4 5" means s^4 + 2 s^3 + 3 s^2 + 4 s + 5. Try "1 1 2 24 5 75 ..." or "1 2 3 4".'));
    var presets = el('div', { style: 'display:flex;gap:6px;flex-wrap:wrap;margin-top:8px;' });
    [['Stable', '1 4 6 4 1'], ['Unstable', '1 2 3 4 5'], ['Marginal', '1 0 4 0 3'], ['Zero-row', '1 1 2 2 3 15']].forEach(function (pr) {
      var b = el('button', { 'class': 'cs-btn cs-btn-ghost', style: 'font-size:9px;padding:5px 8px;' }, pr[0]);
      b.onclick = function () { inp.value = pr[1]; state.coeffs = pr[1]; build(); };
      presets.appendChild(b);
    });
    left.appendChild(presets);
    var status = el('div', { 'class': 'cs-status ok' }); left.appendChild(status);

    right.appendChild(el('p', { 'class': 'cs-plotlbl' }, 'Routh array (first column sign changes highlighted)'));
    var tablewrap = el('div', { 'class': 'cs-tablewrap' }); right.appendChild(tablewrap);
    var ro = readoutGrid(right);
    var rChanges = ro.cell('First-column sign changes', 'amber');
    var rRHP = ro.cell('RHP roots', 'red');
    var rVerdict = ro.cell('Verdict', 'green');

    btn.onclick = build;
    inp.addEventListener('keydown', function (e) { if (e.key === 'Enter') build(); });

    function build() {
      var coeffs = parseCoeffs(state.coeffs);
      if (!coeffs || coeffs.length < 2) { status.className = 'cs-status bad'; status.textContent = 'Enter at least two coefficients.'; tablewrap.innerHTML = ''; return; }
      var res = routhArray(coeffs);
      renderRouth(res, coeffs.length - 1);
      rChanges.textContent = res.signChanges.toString();
      rRHP.textContent = res.signChanges.toString();
      var verdict, cls;
      if (res.marginal) { verdict = 'MARGINAL'; cls = 'amber'; }
      else if (res.signChanges === 0) { verdict = 'STABLE'; cls = 'green'; }
      else { verdict = 'UNSTABLE'; cls = 'red'; }
      rVerdict.className = 'v ' + cls;
      rVerdict.textContent = verdict;
      status.className = 'cs-status ' + (verdict === 'STABLE' ? 'ok' : (verdict === 'MARGINAL' ? 'warn' : 'bad'));
      status.textContent = res.note || (verdict === 'STABLE' ? 'All first-column entries share a sign: stable.' : res.signChanges + ' sign change(s): ' + res.signChanges + ' RHP root(s).');
    }

    function renderRouth(res, n) {
      var tbl = el('table', { 'class': 'cs-routh' });
      var rows = res.rows;
      for (var i = 0; i < rows.length; i++) {
        var tr = el('tr');
        var lbl = el('td', { 'class': 'lbl' }, 's^' + (n - i));
        tr.appendChild(lbl);
        for (var j = 0; j < rows[i].length; j++) {
          var val = rows[i][j];
          var td = el('td', {}, isFinite(val) ? (Math.abs(val) < 1e-10 ? '0' : val.toFixed(4)) : '0');
          if (j === 0 && val < -1e-12) td.className = 'neg';
          tr.appendChild(td);
        }
        tbl.appendChild(tr);
      }
      tablewrap.innerHTML = '';
      tablewrap.appendChild(tbl);
    }

    build();
  }

  // Build Routh array from polynomial coefficients (high power first).
  function routhArray(coeffs) {
    var n = coeffs.length - 1;
    var cols = Math.ceil((n + 1) / 2);
    var rows = [];
    // first two rows
    var r0 = [], r1 = [];
    for (var i = 0; i <= n; i++) {
      if (i % 2 === 0) r0.push(coeffs[i]); else r1.push(coeffs[i]);
    }
    while (r0.length < cols) r0.push(0);
    while (r1.length < cols) r1.push(0);
    rows.push(r0); rows.push(r1);
    var note = '', marginal = false;
    var EPS = 1e-9;
    for (var k = 2; k <= n; k++) {
      var prev = rows[k - 1], prev2 = rows[k - 2];
      // detect all-zero row
      var allZero = prev.every(function (v) { return Math.abs(v) < 1e-12; });
      if (allZero) {
        // auxiliary polynomial from row k-2, order (n-(k-2))
        marginal = true;
        var auxOrder = n - (k - 2);
        var aux = [];
        for (var c = 0; c < prev2.length; c++) {
          aux.push(prev2[c]); // coefficient of s^(auxOrder - 2c)
        }
        // derivative of aux: d/ds of sum a_c s^(auxOrder-2c)
        var der = [];
        for (var c2 = 0; c2 < prev2.length; c2++) {
          var power = auxOrder - 2 * c2;
          if (power > 0) der.push(prev2[c2] * power);
        }
        while (der.length < cols) der.push(0);
        rows[k - 1] = der;
        prev = der;
        note = 'Row of zeros at s^' + (n - (k - 1)) + ': roots symmetric about origin (jw-axis or RHP/LHP pairs). Replaced with auxiliary derivative.';
      }
      // detect zero in first column with nonzero rest -> epsilon
      if (Math.abs(prev[0]) < 1e-12) {
        var restNonzero = prev.slice(1).some(function (v) { return Math.abs(v) > 1e-12; });
        if (restNonzero) { prev[0] = EPS; if (!note) note = 'Zero in first column replaced by small epsilon (special case).'; }
      }
      var newRow = [];
      for (var c3 = 0; c3 < cols; c3++) {
        var a = prev2[0];
        var b = prev[0];
        var cTop = (c3 + 1 < prev2.length) ? prev2[c3 + 1] : 0;
        var dTop = (c3 + 1 < prev.length) ? prev[c3 + 1] : 0;
        var val = b !== 0 ? (b * cTop - a * dTop) / b : 0;
        newRow.push(val);
      }
      rows.push(newRow);
    }
    // count sign changes in first column
    var firstCol = rows.map(function (r) { return r[0]; }).filter(function (v) { return Math.abs(v) > 1e-13; });
    var changes = 0;
    for (var s = 1; s < firstCol.length; s++) {
      if ((firstCol[s] > 0) !== (firstCol[s - 1] > 0)) changes++;
    }
    return { rows: rows, signChanges: changes, marginal: marginal && changes === 0, note: note };
  }

  /* ============================================================
     UI WIRING: experiment switcher + tab switcher
     ============================================================ */
  var currentExp = 0;
  var currentTab = 'aim';
  var body = $('csBody');

  function renderTab() {
    body.innerHTML = '';
    var e = EXP[currentExp];
    if (currentTab === 'aim') {
      body.appendChild(el('h4', {}, 'Aim'));
      body.appendChild(el('p', {}, e.aim));
    } else if (currentTab === 'theory') {
      body.appendChild(el('h4', {}, 'Theory'));
      body.appendChild(e.theory());
    } else if (currentTab === 'procedure') {
      body.appendChild(el('h4', {}, 'Procedure'));
      var ol = el('ol');
      e.procedure.forEach(function (s) { ol.appendChild(el('li', {}, s)); });
      body.appendChild(ol);
    } else if (currentTab === 'sim') {
      body.appendChild(el('h4', {}, 'Simulation — ' + e.name));
      e.sim(body);
    } else if (currentTab === 'quiz') {
      body.appendChild(el('h4', {}, 'Self-assessment'));
      body.appendChild(quizBlock(e.quiz));
    } else if (currentTab === 'ref') {
      body.appendChild(el('h4', {}, 'References'));
      var refdiv = el('div', { 'class': 'cs-ref' });
      e.refs.forEach(function (r, i) { refdiv.appendChild(el('div', {}, '[' + (i + 1) + '] ' + r)); });
      body.appendChild(refdiv);
    }
  }

  document.querySelectorAll('.cs-exp').forEach(function (b) {
    b.addEventListener('click', function () {
      document.querySelectorAll('.cs-exp').forEach(function (x) { x.classList.remove('active'); });
      b.classList.add('active');
      currentExp = parseInt(b.getAttribute('data-exp'), 10);
      renderTab();
    });
  });
  document.querySelectorAll('.cs-tab').forEach(function (b) {
    b.addEventListener('click', function () {
      document.querySelectorAll('.cs-tab').forEach(function (x) { x.classList.remove('active'); });
      b.classList.add('active');
      currentTab = b.getAttribute('data-tab');
      renderTab();
    });
  });

  renderTab();
})();
</script>

</BaseLayout>
