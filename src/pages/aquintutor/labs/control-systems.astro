  /* ===================== EXPERIMENT 5 ===================== */
  EXP[4] = {
    name: 'Nyquist plot & encirclement',
    aim: 'Trace the polar plot of G(jw) in the complex plane, mark the critical point (-1, 0), and apply the Nyquist criterion N = Z - P to judge closed-loop stability from encirclements.',
    theory: function () {
      var w = el('div');
      w.appendChild(el('p', {}, 'The Nyquist plot maps the imaginary axis s=jw (and its mirror) through G(s), producing a closed contour in the complex plane. The Nyquist stability criterion states Z = N + P, where P is the number of open-loop poles in the right-half plane, N is the number of clockwise encirclements of the critical point -1+j0 by the G(jw) locus, and Z is the number of closed-loop poles in the right-half plane. For stability we need Z = 0, so the locus must encircle -1 exactly -P times (counter-clockwise) when P open-loop RHP poles exist; for an open-loop-stable system (P=0) the locus must simply not encircle -1.'));
      w.appendChild(el('div', { 'class': 'cs-eq' }, 'Nyquist criterion:   Z = N + P\n\nP = open-loop poles in RHP\nN = clockwise encirclements of (-1, 0) by G(jw)\nZ = closed-loop poles in RHP  (need Z = 0 for stability)\n\nStable  <=>  N = -P  (i.e. P CCW encirclements)'));
      w.appendChild(el('p', {}, 'The locus is computed from the exact complex value G(jw) over positive and negative frequencies. Encirclements of -1 are counted by accumulating the change in the argument of (G(jw) + 1) around the contour, and P is found from the open-loop poles, so the criterion is applied numerically rather than by eye.'));
      return w;
    },
    procedure: ['Enter the open-loop transfer function; P (RHP open-loop poles) is reported automatically.',
