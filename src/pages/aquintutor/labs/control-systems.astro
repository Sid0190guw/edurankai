  /* ===================== EXPERIMENT 1 ===================== */
  EXP[0] = {
    name: 'Poles, zeros & transient response',
    aim: 'Enter a transfer function G(s)=num/den, locate its poles and zeros in the s-plane, and compute the step and impulse responses by numerical integration of the system’s state-space form.',
    theory: function () {
      var w = el('div');
      w.appendChild(el('p', {}, 'A linear time-invariant system is fully described by its transfer function G(s) = N(s)/D(s), the ratio of two polynomials in the Laplace variable s. The roots of N(s) are the zeros and the roots of D(s) are the poles. Poles govern the natural modes of the system: a real pole at s=-a contributes a decaying term e^(-a t), while a complex-conjugate pair s=-sigma +/- j*wd contributes a damped oscillation e^(-sigma t) cos(wd t). The system is BIBO stable if and only if every pole lies strictly in the open left-half plane (Re s < 0).'));
      w.appendChild(el('div', { 'class': 'cs-eq' }, 'G(s) = N(s) / D(s) = b0 s^m + ... + bm  over  a0 s^n + ... + an\n\nStep response:    Y(s) = G(s) / s\nImpulse response: y(t) = inverse-Laplace of G(s)\n\nStable  <=>  Re(p_i) < 0 for all poles p_i'));
      w.appendChild(el('p', {}, 'Here the response is obtained without symbolic partial fractions: G(s) is converted to a controllable-canonical state-space model dx/dt = A x + B u, y = C x + D u, and integrated with a fixed-step fourth-order Runge-Kutta scheme. This is exactly how a numerical control toolbox computes lsim/step.'));
      return w;
    },
    procedure: ['Type numerator and denominator coefficients (highest power of s first), e.g. denominator "1 2 5" means s^2 + 2s + 5.',
