---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="VLSI & Digital Design · Virtual Labs · AquinTutor" description="Gate-level logic simulator with live timing waveforms, truth tables and CMOS view.">
<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; font-family: 'Inter', system-ui, sans-serif; }
  .vw { max-width: 1480px; margin: 0 auto; padding: 22px 22px 90px; }
  .back { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: #67e8f9; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; }
  .back:hover { color: #a78bfa; }
  .eyebrow { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #fbbf24; font-weight: 700; margin-top: 18px; }
  h1 { font-family: 'Cormorant Garamond', serif; font-size: 38px; font-weight: 600; letter-spacing: -0.02em; margin: 6px 0 4px; }
  h1 em { color: #67e8f9; font-weight: 500; font-style: italic; }
  .sub { color: #9aa0ac; font-size: 14px; max-width: 860px; line-height: 1.6; }
  .layout { display: grid; grid-template-columns: 360px 1fr 320px; gap: 14px; margin-top: 20px; }
  @media (max-width: 1180px) { .layout { grid-template-columns: 1fr; } }
  .panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 14px; }
  .panel h3 { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #fbbf24; font-weight: 700; margin: 0 0 10px; }
  .mono { font-family: 'Geist Mono', ui-monospace, monospace; }
  .row { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }
  .palette { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; }
  .palette button, .tbtn { background: #1a1d27; color: #e8e8ee; border: 1px solid #2a2a35; border-radius: 6px; padding: 7px 8px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10.5px; cursor: pointer; font-weight: 700; letter-spacing: 0.03em; transition: all .13s; }
  .palette button:hover, .tbtn:hover { background: #15303a; border-color: #67e8f9; color: #67e8f9; }
  .group-title { color: #6b7280; font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; margin: 12px 0 5px; }
  select, input[type=text] { background: #0a0a0c; border: 1px solid #2a2a35; color: #e8e8ee; padding: 6px 8px; border-radius: 5px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; }
  .btn { background: #67e8f9; color: #06222a; padding: 8px 13px; border-radius: 6px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; border: none; cursor: pointer; }
  .btn:hover { background: #97f2ff; }
  .btn.purple { background: #a78bfa; color: #1a0f33; }
  .btn.purple:hover { background: #c3b0ff; }
  .btn.ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
  .btn.ghost:hover { border-color: #67e8f9; color: #67e8f9; }
  .toolbar { display: flex; gap: 8px; padding: 10px; border-bottom: 1px solid #2a2a35; background: #11131a; flex-wrap: wrap; align-items: center; border-radius: 12px 12px 0 0; }
  .stage-wrap { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 12px; overflow: hidden; }
  #wave { display: block; width: 100%; height: 360px; }
  #cmos { display: block; width: 100%; height: 260px; }
  .hint { color: #6b7280; font-size: 10.5px; margin-left: auto; font-family: 'Geist Mono', ui-monospace, monospace; }
  .nodes-list { display: grid; gap: 7px; max-height: 360px; overflow: auto; padding-right: 3px; }
  .node-card { background: #0d0f15; border: 1px solid #242430; border-radius: 8px; padding: 8px 9px; }
  .node-head { display: flex; align-items: center; gap: 7px; margin-bottom: 6px; }
  .net-tag { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; font-weight: 700; color: #06222a; background: #67e8f9; border-radius: 4px; padding: 2px 6px; }
  .gate-tag { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; font-weight: 700; color: #a78bfa; letter-spacing: 0.06em; }
  .node-head .val { margin-left: auto; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; font-weight: 700; }
  .node-head .val.hi { color: #86efac; } .node-head .val.lo { color: #6b7280; }
  .node-rm { background: transparent; border: none; color: #fca5a5; cursor: pointer; font-size: 15px; line-height: 1; padding: 0 2px; }
  .node-rm:hover { color: #ff7676; }
  .ins { display: grid; gap: 4px; }
  .in-row { display: flex; gap: 5px; align-items: center; }
  .in-row label { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9.5px; color: #7a8088; width: 26px; }
  .in-row select { flex: 1; padding: 4px 6px; font-size: 10px; }
  .probe-row { display: flex; align-items: center; gap: 6px; margin-top: 6px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; color: #9aa0ac; }
  .probe-row input { accent-color: #67e8f9; }
  .toggle { cursor: pointer; border: 1px solid #2a2a35; border-radius: 5px; padding: 4px 10px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; font-weight: 700; }
  .toggle.hi { background: #86efac; color: #0a2a14; border-color: #86efac; }
  .toggle.lo { background: #1a1d27; color: #6b7280; }
  table.tt { width: 100%; border-collapse: collapse; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10.5px; }
  table.tt th, table.tt td { padding: 4px 6px; border: 1px solid #2a2a35; text-align: center; }
  table.tt th { background: #1a1d27; color: #fbbf24; font-weight: 700; font-size: 9.5px; letter-spacing: 0.06em; }
  table.tt td.one { background: rgba(134,239,172,0.16); color: #86efac; font-weight: 700; }
  table.tt td.zero { color: #6b7280; }
  .tt-wrap { max-height: 300px; overflow: auto; margin-top: 4px; }
  .note { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; color: #fbbf24; line-height: 1.5; margin-top: 8px; padding: 7px 9px; background: rgba(251,191,36,0.07); border: 1px solid rgba(251,191,36,0.2); border-radius: 7px; }
  .legend { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; color: #6b7280; line-height: 1.6; margin-top: 10px; }
  .speed { display: flex; align-items: center; gap: 7px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; color: #9aa0ac; }
  input[type=range] { accent-color: #a78bfa; }
  .clk-led { width: 11px; height: 11px; border-radius: 50%; background: #2a2a35; display: inline-block; border: 1px solid #3a3a45; }
  .clk-led.on { background: #fbbf24; box-shadow: 0 0 8px #fbbf24; }
  .cmos-explain { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; color: #9aa0ac; line-height: 1.55; margin-top: 8px; }
  .empty { color: #6b7280; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; padding: 10px 4px; }
</style>

<main class="vw">
  <a class="back" href="/aquintutor/labs">&larr; All virtual labs</a>
  <div class="eyebrow">AquinTutor Labs / VLSI &amp; Digital Design</div>
  <h1>Gate-level <em>logic simulator</em></h1>
  <p class="sub">Build a netlist from primitive gates, a clock and a D flip-flop, then watch real event-driven signals settle through your circuit. Probe any net onto the live timing waveform, sweep every input combination into a truth table, and inspect the transistor-level CMOS pull-up / pull-down networks behind each basic gate. This is a working simulator — every control drives the computation live.</p>

  <div class="layout">
    <!-- LEFT: builder -->
    <div class="panel">
      <h3>Netlist Builder</h3>
      <div class="group-title">Sources</div>
      <div class="palette">
        <button data-add="INPUT">INPUT</button>
        <button data-add="CLOCK">CLOCK</button>
        <button data-add="OUTPUT">PROBE</button>
      </div>
      <div class="group-title">Combinational gates</div>
      <div class="palette">
        <button data-add="BUF">BUF</button>
        <button data-add="NOT">NOT</button>
        <button data-add="AND">AND</button>
        <button data-add="OR">OR</button>
        <button data-add="NAND">NAND</button>
        <button data-add="NOR">NOR</button>
        <button data-add="XOR">XOR</button>
        <button data-add="XNOR">XNOR</button>
        <button data-add="MUX2">MUX 2:1</button>
      </div>
      <div class="group-title">Sequential</div>
      <div class="palette">
        <button data-add="DFF">D FLIP-FLOP</button>
      </div>
      <div class="group-title">Presets</div>
      <select id="preset" style="width:100%">
        <option value="">-- load a working circuit --</option>
        <option value="half">Half adder</option>
        <option value="full">Full adder</option>
        <option value="mux">2:1 multiplexer</option>
        <option value="sr">SR latch (NOR)</option>
        <option value="dff">D flip-flop (toggle)</option>
        <option value="counter">2-bit ripple counter</option>
      </select>
      <div class="group-title">Nets</div>
      <div class="nodes-list" id="nodes"></div>
    </div>

    <!-- CENTER: waveform + cmos -->
    <div>
      <div class="stage-wrap">
        <div class="toolbar">
          <button class="btn" id="step">Step &frac12;</button>
          <button class="btn purple" id="run">Run</button>
          <button class="btn ghost" id="reset">Reset</button>
          <span class="speed">CLK <span class="clk-led" id="clkled"></span></span>
          <span class="speed">SPEED <input type="range" id="speed" min="1" max="20" value="7"></span>
          <span class="hint">tick <span id="tickn" class="mono">0</span> &middot; probed nets scroll right</span>
        </div>
        <canvas id="wave" width="900" height="360"></canvas>
      </div>

      <div class="panel" style="margin-top:14px">
        <h3>CMOS Transistor View</h3>
        <div class="row" style="margin-bottom:8px">
          <span class="mono" style="font-size:10px;color:#9aa0ac">Gate</span>
          <select id="cmosgate">
            <option value="NOT">NOT (inverter)</option>
            <option value="NAND">NAND</option>
            <option value="NOR">NOR</option>
          </select>
          <span class="mono" style="font-size:10px;color:#9aa0ac;margin-left:8px">A</span>
          <span class="toggle lo mono" id="cmA">0</span>
          <span class="mono" style="font-size:10px;color:#9aa0ac" id="cmBwrap">B</span>
          <span class="toggle lo mono" id="cmB">0</span>
        </div>
        <div class="stage-wrap"><canvas id="cmos" width="900" height="260"></canvas></div>
        <div class="cmos-explain" id="cmosExplain"></div>
      </div>
    </div>

    <!-- RIGHT: truth table + inputs + metrics -->
    <div class="panel">
      <h3>Live Inputs</h3>
      <div class="row" id="inputToggles"><span class="empty">No INPUT/CLOCK sources yet.</span></div>

      <h3 style="margin-top:16px">Truth Table</h3>
      <button class="btn ghost" id="gentt" style="width:100%;margin-bottom:8px">Generate truth table</button>
      <div class="tt-wrap" id="tt"><div class="empty">Add INPUTs and PROBE outputs, then generate.</div></div>

      <h3 style="margin-top:16px">Circuit Stats</h3>
      <div class="legend" id="stats"></div>
      <div class="legend">
        Combinational nets are re-evaluated each tick until the network settles (max 50 iterations, so feedback latches converge). D flip-flops capture D on the clock <b>rising edge</b> only.
      </div>
    </div>
  </div>
</main>

<script is:inline>
(function () {
  'use strict';

  // ── Gate library ──────────────────────────────────────────────────────────
  // nin: input count; seq: sequential; eval(a) → 0|1 for combinational gates.
  var GATES = {
    INPUT:  { nin: 0, src: true,  label: 'INPUT' },
    CLOCK:  { nin: 0, src: true,  clock: true, label: 'CLOCK' },
    OUTPUT: { nin: 1, sink: true, label: 'PROBE', eval: function (a) { return a[0]; } },
    BUF:    { nin: 1, label: 'BUF',  eval: function (a) { return a[0]; } },
    NOT:    { nin: 1, label: 'NOT',  eval: function (a) { return a[0] ? 0 : 1; } },
    AND:    { nin: 2, label: 'AND',  eval: function (a) { return (a[0] & a[1]) ? 1 : 0; } },
    OR:     { nin: 2, label: 'OR',   eval: function (a) { return (a[0] | a[1]) ? 1 : 0; } },
    NAND:   { nin: 2, label: 'NAND', eval: function (a) { return (a[0] & a[1]) ? 0 : 1; } },
    NOR:    { nin: 2, label: 'NOR',  eval: function (a) { return (a[0] | a[1]) ? 0 : 1; } },
    XOR:    { nin: 2, label: 'XOR',  eval: function (a) { return (a[0] ^ a[1]) ? 1 : 0; } },
    XNOR:   { nin: 2, label: 'XNOR', eval: function (a) { return (a[0] ^ a[1]) ? 0 : 1; } },
    // MUX 2:1 — pins: [in0, in1, sel].  sel=0 -> in0, sel=1 -> in1
    MUX2:   { nin: 3, label: 'MUX', pins: ['D0', 'D1', 'S'], eval: function (a) { return a[2] ? a[1] : a[0]; } },
    // D flip-flop — pins: [D, CLK]. Sequential: output = stored state.
    DFF:    { nin: 2, seq: true, label: 'DFF', pins: ['D', 'CLK'] }
  };

  // ── State ─────────────────────────────────────────────────────────────────
  var nodes = [];        // { id, type, name, value, probe, ins:[netId|null], state, prevClk }
  var nextId = 1;
  var tick = 0;
  var running = false;
  var rafTimer = null;
  var clkPhase = 0;      // 0/1 — the global step half-cycle indicator
  var WAVE_LEN = 64;     // visible ticks on the waveform
  var history = {};      // netId -> array of recorded values

  function pinLabel(type, i) {
    var g = GATES[type];
    if (g.pins && g.pins[i] != null) return g.pins[i];
    if (g.nin === 1) return 'IN';
    return String.fromCharCode(65 + i); // A,B,...
  }

  function defaultName(type) {
    var prefix = type === 'INPUT' ? 'I' : type === 'CLOCK' ? 'CK' : type === 'OUTPUT' ? 'Y'
      : type === 'DFF' ? 'Q' : type.charAt(0) + 'g';
    var n = 0;
    for (var i = 0; i < nodes.length; i++) if (nodes[i].type === type) n++;
    return prefix + n;
  }

  function addNode(type, opts) {
    opts = opts || {};
    var g = GATES[type];
    var node = {
      id: nextId++,
      type: type,
      name: opts.name || defaultName(type),
      value: opts.value ? 1 : 0,    // for sources: driven level
      probe: opts.probe || false,
      ins: [],
      state: 0,                     // for DFF: stored Q
      prevClk: 0
    };
    for (var i = 0; i < g.nin; i++) node.ins.push(opts.ins && opts.ins[i] != null ? opts.ins[i] : null);
    nodes.push(node);
    history[node.id] = [];
    return node.id;
  }

  function removeNode(id) {
    nodes = nodes.filter(function (n) { return n.id !== id; });
    delete history[id];
    // null out any input that referenced this net
    for (var i = 0; i < nodes.length; i++)
      for (var j = 0; j < nodes[i].ins.length; j++)
        if (nodes[i].ins[j] === id) nodes[i].ins[j] = null;
  }

  function nodeById(id) {
    for (var i = 0; i < nodes.length; i++) if (nodes[i].id === id) return nodes[i];
    return null;
  }

  // ── Core evaluation: settle the combinational network ─────────────────────
  // Returns a map netId -> 0|1 with current values, given current source levels
  // and stored DFF states. Does NOT advance flip-flops (that happens on edges).
  function settle() {
    var val = {};
    var i, j, n;
    // initialise: sources to their level, DFF outputs to stored state, rest 0
    for (i = 0; i < nodes.length; i++) {
      n = nodes[i];
      if (GATES[n.type].src) val[n.id] = n.value & 1;
      else if (n.type === 'DFF') val[n.id] = n.state & 1;
      else val[n.id] = 0;
    }
    // iterate to fixpoint (handles cross-coupled feedback latches)
    var changed = true, iter = 0;
    while (changed && iter < 50) {
      changed = false; iter++;
      for (i = 0; i < nodes.length; i++) {
        n = nodes[i];
        var g = GATES[n.type];
        if (g.src || n.type === 'DFF') continue; // sources fixed; DFF driven by state
        var args = [];
        for (j = 0; j < g.nin; j++) {
          var src = n.ins[j];
          args.push(src != null && val[src] != null ? (val[src] & 1) : 0);
        }
        var nv = g.eval(args) & 1;
        if (nv !== val[n.id]) { val[n.id] = nv; changed = true; }
      }
    }
    return val;
  }

  // Advance flip-flops: sample D on rising clock edge using settled values.
  function advanceSequential(val) {
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      if (n.type !== 'DFF') continue;
      var dNet = n.ins[0], cNet = n.ins[1];
      var clk = cNet != null && val[cNet] != null ? (val[cNet] & 1) : 0;
      var d = dNet != null && val[dNet] != null ? (val[dNet] & 1) : 0;
      if (n.prevClk === 0 && clk === 1) n.state = d; // rising edge capture
      n.prevClk = clk;
    }
  }

  function hasClock() {
    for (var i = 0; i < nodes.length; i++) if (nodes[i].type === 'CLOCK') return true;
    return false;
  }
  function hasDFF() {
    for (var i = 0; i < nodes.length; i++) if (nodes[i].type === 'DFF') return true;
    return false;
  }

  // ── Simulation tick = one clock half-cycle ────────────────────────────────
  function doTick() {
    clkPhase = clkPhase ? 0 : 1;
    // drive all CLOCK sources to the phase
    for (var i = 0; i < nodes.length; i++)
      if (nodes[i].type === 'CLOCK') nodes[i].value = clkPhase;
    var val = settle();
    advanceSequential(val);
    // DFF outputs may now have changed → settle once more so probes downstream are current
    val = settle();
    // record history for every net
    for (var k = 0; k < nodes.length; k++) {
      var id = nodes[k].id;
      if (!history[id]) history[id] = [];
      history[id].push(val[id] & 1);
      if (history[id].length > WAVE_LEN) history[id].shift();
    }
    tick++;
    document.getElementById('tickn').textContent = String(tick);
    document.getElementById('clkled').className = 'clk-led' + (clkPhase ? ' on' : '');
    drawWave(val);
    renderNodeValues(val);
  }

  function resetSim() {
    tick = 0; clkPhase = 0;
    for (var i = 0; i < nodes.length; i++) {
      if (nodes[i].type === 'CLOCK') nodes[i].value = 0;
      nodes[i].state = 0; nodes[i].prevClk = 0;
      history[nodes[i].id] = [];
    }
    document.getElementById('tickn').textContent = '0';
    document.getElementById('clkled').className = 'clk-led';
    var val = settle();
    drawWave(val);
    renderNodeValues(val);
  }

  // ── Run loop ──────────────────────────────────────────────────────────────
  function startRun() {
    running = true;
    document.getElementById('run').textContent = 'Pause';
    loop();
  }
  function stopRun() {
    running = false;
    document.getElementById('run').textContent = 'Run';
    if (rafTimer) { clearTimeout(rafTimer); rafTimer = null; }
  }
  function loop() {
    if (!running) return;
    doTick();
    var speed = parseInt(document.getElementById('speed').value, 10) || 7;
    var delay = Math.round(620 / speed); // ms per half-cycle
    rafTimer = setTimeout(loop, delay);
  }

  // ── Waveform rendering (SVG-style step lines on a canvas) ──────────────────
  var wave = document.getElementById('wave');
  var wctx = wave.getContext('2d');
  function fitCanvas(cv, ctx) {
    var r = cv.getBoundingClientRect();
    var dpr = window.devicePixelRatio || 1;
    cv.width = r.width * dpr; cv.height = r.height * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    return { w: r.width, h: r.height };
  }

  function drawWave(curVal) {
    var dim = fitCanvas(wave, wctx);
    var W = dim.w, H = dim.h;
    wctx.clearRect(0, 0, W, H);
    var probed = nodes.filter(function (n) { return n.probe; });
    if (!probed.length) {
      wctx.fillStyle = '#6b7280';
      wctx.font = '12px "Geist Mono", ui-monospace, monospace';
      wctx.fillText('Tick the "probe" box on any net to scope it here.', 18, 30);
      return;
    }
    var labelW = 92;
    var plotW = W - labelW - 14;
    var rowH = Math.min(56, (H - 16) / probed.length);
    var pad = 9; // vertical pad inside a row
    var cellW = plotW / WAVE_LEN;

    for (var r = 0; r < probed.length; r++) {
      var n = probed[r];
      var top = 8 + r * rowH;
      var yHi = top + pad;
      var yLo = top + rowH - pad - 6;
      // row baseline grid
      wctx.strokeStyle = '#1b1d26'; wctx.lineWidth = 1;
      wctx.beginPath(); wctx.moveTo(labelW, yLo); wctx.lineTo(W - 12, yLo); wctx.stroke();
      // label
      var cur = curVal && curVal[n.id] != null ? curVal[n.id] : 0;
      wctx.fillStyle = cur ? '#86efac' : '#9aa0ac';
      wctx.font = '700 11px "Geist Mono", ui-monospace, monospace';
      wctx.textBaseline = 'middle';
      wctx.fillText(n.name, 10, (yHi + yLo) / 2);
      wctx.fillStyle = '#3a3a45';
      wctx.fillText(GATES[n.type].label, 10, (yHi + yLo) / 2 + 14);

      var hist = history[n.id] || [];
      // colour per net
      var color = '#67e8f9';
      if (n.type === 'CLOCK') color = '#fbbf24';
      else if (n.type === 'DFF') color = '#a78bfa';
      else if (n.type === 'INPUT') color = '#86efac';
      wctx.strokeStyle = color; wctx.lineWidth = 2;
      wctx.beginPath();
      var started = false, prevY = yLo, px = labelW;
      // right-align the history so newest sample is at the right edge
      var offset = WAVE_LEN - hist.length;
      for (var t = 0; t < hist.length; t++) {
        var v = hist[t];
        var x0 = labelW + (offset + t) * cellW;
        var x1 = x0 + cellW;
        var y = v ? yHi : yLo;
        if (!started) { wctx.moveTo(x0, y); started = true; }
        else { wctx.lineTo(x0, prevY); wctx.lineTo(x0, y); } // vertical edge then move
        wctx.lineTo(x1, y);
        prevY = y;
      }
      wctx.stroke();
      // faint hi-level guide
      wctx.strokeStyle = 'rgba(255,255,255,0.05)';
      wctx.beginPath(); wctx.moveTo(labelW, yHi); wctx.lineTo(W - 12, yHi); wctx.stroke();
    }
    // separator after label gutter
    wctx.strokeStyle = '#2a2a35'; wctx.lineWidth = 1;
    wctx.beginPath(); wctx.moveTo(labelW, 4); wctx.lineTo(labelW, H - 4); wctx.stroke();
  }

  // ── Node list UI ──────────────────────────────────────────────────────────
  function netOptions(forNode, selected) {
    // valid drivers = every node that produces an output (not a PROBE sink),
    // excluding the node itself for combinational gates (allowed for feedback only
    // via separate nets — we keep it simple: a gate may not feed its own input).
    var opts = '<option value="">— unconnected —</option>';
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      if (n.type === 'OUTPUT') continue;          // PROBE has no output
      if (n.id === forNode.id) continue;          // no direct self-loop
      var sel = (selected === n.id) ? ' selected' : '';
      opts += '<option value="' + n.id + '"' + sel + '>' + n.name + ' [' + GATES[n.type].label + ']</option>';
    }
    return opts;
  }

  function renderNodes() {
    var host = document.getElementById('nodes');
    if (!nodes.length) { host.innerHTML = '<div class="empty">Add gates from the palette above.</div>'; renderInputs(); renderStats(); return; }
    var html = '';
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      var g = GATES[n.type];
      html += '<div class="node-card" data-id="' + n.id + '">';
      html += '<div class="node-head">';
      html += '<span class="net-tag">' + n.name + '</span>';
      html += '<span class="gate-tag">' + g.label + '</span>';
      html += '<span class="val lo" data-val>0</span>';
      html += '<button class="node-rm" data-rm="' + n.id + '" title="remove">&times;</button>';
      html += '</div>';
      if (g.nin > 0) {
        html += '<div class="ins">';
        for (var p = 0; p < g.nin; p++) {
          html += '<div class="in-row"><label>' + pinLabel(n.type, p) + '</label>' +
            '<select data-in="' + n.id + '" data-pin="' + p + '">' + netOptions(n, n.ins[p]) + '</select></div>';
        }
        html += '</div>';
      }
      html += '<label class="probe-row"><input type="checkbox" data-probe="' + n.id + '"' + (n.probe ? ' checked' : '') + '> probe on waveform</label>';
      html += '</div>';
    }
    host.innerHTML = html;

    // wire up
    var rms = host.querySelectorAll('[data-rm]');
    for (var a = 0; a < rms.length; a++) rms[a].addEventListener('click', function () {
      removeNode(parseInt(this.getAttribute('data-rm'), 10)); rebuild();
    });
    var sels = host.querySelectorAll('[data-in]');
    for (var b = 0; b < sels.length; b++) sels[b].addEventListener('change', function () {
      var id = parseInt(this.getAttribute('data-in'), 10);
      var pin = parseInt(this.getAttribute('data-pin'), 10);
      var node = nodeById(id);
      if (node) node.ins[pin] = this.value === '' ? null : parseInt(this.value, 10);
      liveRefresh();
    });
    var pbs = host.querySelectorAll('[data-probe]');
    for (var c = 0; c < pbs.length; c++) pbs[c].addEventListener('change', function () {
      var node = nodeById(parseInt(this.getAttribute('data-probe'), 10));
      if (node) node.probe = this.checked;
      liveRefresh();
    });

    renderInputs();
    renderStats();
  }

  function renderNodeValues(val) {
    var host = document.getElementById('nodes');
    var cards = host.querySelectorAll('.node-card');
    for (var i = 0; i < cards.length; i++) {
      var id = parseInt(cards[i].getAttribute('data-id'), 10);
      var v = val && val[id] != null ? val[id] : 0;
      var span = cards[i].querySelector('[data-val]');
      if (span) { span.textContent = String(v); span.className = 'val ' + (v ? 'hi' : 'lo'); }
    }
    // sync live input toggles
    var tg = document.querySelectorAll('[data-toggle]');
    for (var j = 0; j < tg.length; j++) {
      var nid = parseInt(tg[j].getAttribute('data-toggle'), 10);
      var node = nodeById(nid);
      if (node && node.type === 'INPUT') {
        tg[j].textContent = String(node.value);
        tg[j].className = 'toggle mono ' + (node.value ? 'hi' : 'lo');
      }
    }
  }

  // ── Live input toggles ────────────────────────────────────────────────────
  function renderInputs() {
    var host = document.getElementById('inputToggles');
    var srcs = nodes.filter(function (n) { return n.type === 'INPUT' || n.type === 'CLOCK'; });
    if (!srcs.length) { host.innerHTML = '<span class="empty">No INPUT/CLOCK sources yet.</span>'; return; }
    var html = '';
    for (var i = 0; i < srcs.length; i++) {
      var n = srcs[i];
      if (n.type === 'CLOCK') {
        html += '<span class="toggle lo mono" style="cursor:default" title="driven by clock">' + n.name + ' CLK</span>';
      } else {
        html += '<span class="toggle ' + (n.value ? 'hi' : 'lo') + ' mono" data-toggle="' + n.id + '">' + n.name + ': ' + n.value + '</span>';
      }
    }
    host.innerHTML = html;
    var tg = host.querySelectorAll('[data-toggle]');
    for (var k = 0; k < tg.length; k++) tg[k].addEventListener('click', function () {
      var node = nodeById(parseInt(this.getAttribute('data-toggle'), 10));
      if (node) node.value = node.value ? 0 : 1;
      liveRefresh();
    });
  }

  function renderStats() {
    var gates = 0, ins = 0, outs = 0, ff = 0, wires = 0, clk = 0;
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i], g = GATES[n.type];
      if (n.type === 'INPUT') ins++;
      else if (n.type === 'CLOCK') clk++;
      else if (n.type === 'OUTPUT') outs++;
      else if (n.type === 'DFF') ff++;
      else gates++;
      for (var p = 0; p < n.ins.length; p++) if (n.ins[p] != null) wires++;
    }
    document.getElementById('stats').innerHTML =
      'inputs ' + ins + ' &middot; clocks ' + clk + ' &middot; gates ' + gates +
      ' &middot; flip-flops ' + ff + ' &middot; probes ' + outs + ' &middot; nets ' + wires;
  }

  // refresh without advancing the clock (settle and redraw current state)
  function liveRefresh() {
    var val = settle();
    // also push a sample so combinational changes appear on the scope immediately
    for (var k = 0; k < nodes.length; k++) {
      var id = nodes[k].id;
      if (!history[id]) history[id] = [];
      history[id].push(val[id] & 1);
      if (history[id].length > WAVE_LEN) history[id].shift();
    }
    drawWave(val);
    renderNodeValues(val);
    renderStats();
  }

  function rebuild() {
    renderNodes();
    var val = settle();
    drawWave(val);
    renderNodeValues(val);
  }

  // ── Truth table generator ─────────────────────────────────────────────────
  function generateTT() {
    var host = document.getElementById('tt');
    var ins = nodes.filter(function (n) { return n.type === 'INPUT'; });
    var outs = nodes.filter(function (n) { return n.probe && n.type !== 'CLOCK'; });
    if (!ins.length || !outs.length) {
      host.innerHTML = '<div class="empty">Need at least one INPUT and one probed net.</div>'; return;
    }
    if (ins.length > 8) {
      host.innerHTML = '<div class="empty">' + ins.length + ' inputs is too wide to enumerate (cap 8).</div>'; return;
    }
    // snapshot current input levels so we can restore after sweeping
    var saved = ins.map(function (n) { return n.value; });
    var savedState = nodes.map(function (n) { return n.state; });
    var rows = 1 << ins.length;
    var html = '';
    if (hasDFF()) html += '<div class="note">A D flip-flop is present — this table shows the <b>combinational</b> response with Q held at its current stored state. Use Step / Run for sequential behaviour.</div>';
    html += '<table class="tt"><thead><tr>';
    for (var i = 0; i < ins.length; i++) html += '<th>' + ins[i].name + '</th>';
    for (var o = 0; o < outs.length; o++) html += '<th>' + outs[o].name + '</th>';
    html += '</tr></thead><tbody>';
    for (var r = 0; r < rows; r++) {
      for (var b = 0; b < ins.length; b++) ins[b].value = (r >> (ins.length - 1 - b)) & 1;
      var val = settle();
      html += '<tr>';
      for (var c = 0; c < ins.length; c++) {
        var iv = ins[c].value;
        html += '<td class="' + (iv ? 'one' : 'zero') + '">' + iv + '</td>';
      }
      for (var d = 0; d < outs.length; d++) {
        var ov = val[outs[d].id] != null ? val[outs[d].id] : 0;
        html += '<td class="' + (ov ? 'one' : 'zero') + '">' + ov + '</td>';
      }
      html += '</tr>';
    }
    html += '</tbody></table>';
    host.innerHTML = html;
    // restore
    for (var s = 0; s < ins.length; s++) ins[s].value = saved[s];
    for (var t = 0; t < nodes.length; t++) nodes[t].state = savedState[t];
    liveRefresh();
  }

  // ── CMOS schematic view ───────────────────────────────────────────────────
  var cmos = document.getElementById('cmos');
  var cctx = cmos.getContext('2d');
  var cmA = 0, cmB = 0;

  function transistor(ctx, x, y, type, on, label) {
    // simple MOSFET glyph: vertical channel with gate
    var w = 26, h = 34;
    ctx.lineWidth = 2;
    ctx.strokeStyle = on ? (type === 'P' ? '#fca5a5' : '#86efac') : '#3a3a45';
    // channel terminals (drain top, source bottom)
    ctx.beginPath(); ctx.moveTo(x, y - h / 2); ctx.lineTo(x, y - h / 2 + 8); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(x, y + h / 2); ctx.lineTo(x, y + h / 2 - 8); ctx.stroke();
    // channel bar
    ctx.strokeStyle = on ? (type === 'P' ? '#fca5a5' : '#86efac') : '#52525e';
    ctx.beginPath(); ctx.moveTo(x, y - h / 2 + 8); ctx.lineTo(x, y - 6); ctx.moveTo(x, y + 6); ctx.lineTo(x, y + h / 2 - 8); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(x + 5, y - 9); ctx.lineTo(x + 5, y + 9); ctx.stroke();
    // gate line
    ctx.strokeStyle = '#67e8f9';
    ctx.beginPath(); ctx.moveTo(x + 5 + (type === 'P' ? 6 : 4), y - 9); ctx.lineTo(x + 5 + (type === 'P' ? 6 : 4), y + 9); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(x + 5, y); ctx.lineTo(x + 5 + (type === 'P' ? 6 : 4), y); ctx.stroke();
    // P-type bubble on gate
    if (type === 'P') {
      ctx.beginPath(); ctx.arc(x + 13, y, 3, 0, Math.PI * 2); ctx.strokeStyle = '#67e8f9'; ctx.stroke();
    }
    // label
    ctx.fillStyle = '#9aa0ac';
    ctx.font = '700 10px "Geist Mono", ui-monospace, monospace';
    ctx.fillText(label, x + 20, y + 4);
    return { gx: x + 22, gy: y, dx: x, dyTop: y - h / 2, dyBot: y + h / 2 };
  }

  function wire(ctx, x1, y1, x2, y2, on) {
    ctx.strokeStyle = on ? '#67e8f9' : '#3a3a45';
    ctx.lineWidth = on ? 2 : 1.5;
    ctx.beginPath(); ctx.moveTo(x1, y1); ctx.lineTo(x2, y2); ctx.stroke();
  }
  function node(ctx, x, y, label, color) {
    ctx.fillStyle = color || '#fbbf24';
    ctx.beginPath(); ctx.arc(x, y, 4, 0, Math.PI * 2); ctx.fill();
    if (label) { ctx.fillStyle = '#9aa0ac'; ctx.font = '700 10px "Geist Mono", ui-monospace, monospace'; ctx.fillText(label, x - 5, y - 8); }
  }

  function drawCMOS() {
    var gate = document.getElementById('cmosgate').value;
    var dim = fitCanvas(cmos, cctx);
    var W = dim.w, H = dim.h;
    cctx.clearRect(0, 0, W, H);
    var cx = W / 2;
    var vddY = 22, gndY = H - 22, outY = H / 2;
    var outX = cx + 150;

    // rails
    cctx.strokeStyle = '#fca5a5'; cctx.lineWidth = 2;
    cctx.beginPath(); cctx.moveTo(40, vddY); cctx.lineTo(W - 40, vddY); cctx.stroke();
    cctx.fillStyle = '#fca5a5'; cctx.font = '700 11px "Geist Mono", ui-monospace, monospace';
    cctx.fillText('VDD', 12, vddY + 4);
    cctx.strokeStyle = '#86efac';
    cctx.beginPath(); cctx.moveTo(40, gndY); cctx.lineTo(W - 40, gndY); cctx.stroke();
    cctx.fillStyle = '#86efac';
    cctx.fillText('GND', 12, gndY + 4);

    // compute output for current A,B
    var a = cmA, b = cmB, out;
    if (gate === 'NOT') out = a ? 0 : 1;
    else if (gate === 'NAND') out = (a & b) ? 0 : 1;
    else out = (a | b) ? 0 : 1; // NOR

    var pullX = cx - 40;

    if (gate === 'NOT') {
      // 1 PMOS (pull-up) + 1 NMOS (pull-down), gates tied to A
      var p = transistor(cctx, pullX, vddY + 50, 'P', a === 0, 'P:A');
      var nT = transistor(cctx, pullX, gndY - 50, 'N', a === 1, 'N:A');
      wire(cctx, pullX, vddY, pullX, vddY + 33, true);                       // VDD to PMOS drain
      wire(cctx, pullX, vddY + 67, pullX, outY, out === 1);                  // PMOS src to OUT
      wire(cctx, pullX, outY, pullX, gndY - 67, out === 0);                  // OUT to NMOS drain
      wire(cctx, pullX, gndY - 33, pullX, gndY, true);                       // NMOS src to GND
      // input A to both gates
      cctx.fillStyle = '#67e8f9'; cctx.font = '700 11px "Geist Mono", ui-monospace, monospace';
      cctx.fillText('A=' + a, pullX + 60, outY - 50);
      node(cctx, pullX, outY, 'OUT', out ? '#86efac' : '#52525e');
      wire(cctx, pullX, outY, outX, outY, true);
      cctx.fillStyle = out ? '#86efac' : '#9aa0ac';
      cctx.font = '700 13px "Geist Mono", ui-monospace, monospace';
      cctx.fillText('Y = ' + out, outX + 8, outY + 4);
    } else if (gate === 'NAND') {
      // PMOS pull-up: A,B in PARALLEL ; NMOS pull-down: A,B in SERIES
      var pa = transistor(cctx, pullX - 26, vddY + 50, 'P', a === 0, 'A');
      var pb = transistor(cctx, pullX + 26, vddY + 50, 'P', b === 0, 'B');
      wire(cctx, pullX - 26, vddY, pullX - 26, vddY + 33, true);
      wire(cctx, pullX + 26, vddY, pullX + 26, vddY + 33, true);
      // both PMOS sources to a common output node
      var pUp = (a === 0) || (b === 0);
      wire(cctx, pullX - 26, vddY + 67, pullX - 26, outY - 20, pUp);
      wire(cctx, pullX + 26, vddY + 67, pullX + 26, outY - 20, pUp);
      wire(cctx, pullX - 26, outY - 20, pullX + 26, outY - 20, pUp);
      wire(cctx, pullX, outY - 20, pullX, outY, pUp);
      // NMOS in series A over B
      var na = transistor(cctx, pullX, outY + 24, 'N', a === 1, 'A');
      var nb = transistor(cctx, pullX, gndY - 40, 'N', b === 1, 'B');
      wire(cctx, pullX, outY, pullX, outY + 7, out === 0);
      wire(cctx, pullX, outY + 41, pullX, gndY - 57, (a === 1 && b === 1));
      wire(cctx, pullX, gndY - 23, pullX, gndY, true);
      node(cctx, pullX, outY, 'OUT', out ? '#86efac' : '#52525e');
      wire(cctx, pullX, outY, outX, outY, true);
      cctx.fillStyle = '#67e8f9'; cctx.font = '700 11px "Geist Mono", ui-monospace, monospace';
      cctx.fillText('A=' + a + ' B=' + b, pullX + 70, vddY + 50);
      cctx.fillStyle = out ? '#86efac' : '#9aa0ac';
      cctx.font = '700 13px "Geist Mono", ui-monospace, monospace';
      cctx.fillText('Y = ' + out, outX + 8, outY + 4);
    } else {
      // NOR: PMOS pull-up A,B in SERIES ; NMOS pull-down A,B in PARALLEL
      var npa = transistor(cctx, pullX, vddY + 40, 'P', a === 0, 'A');
      var npb = transistor(cctx, pullX, vddY + 86, 'P', b === 0, 'B');
      wire(cctx, pullX, vddY, pullX, vddY + 23, true);
      wire(cctx, pullX, vddY + 57, pullX, vddY + 69, (a === 0 && b === 0));
      wire(cctx, pullX, vddY + 103, pullX, outY, out === 1);
      var nna = transistor(cctx, pullX - 26, gndY - 50, 'N', a === 1, 'A');
      var nnb = transistor(cctx, pullX + 26, gndY - 50, 'N', b === 1, 'B');
      var pDn = (a === 1) || (b === 1);
      wire(cctx, pullX, outY, pullX, outY + 20, out === 0);
      wire(cctx, pullX - 26, outY + 20, pullX + 26, outY + 20, pDn);
      wire(cctx, pullX, outY, pullX, outY + 20, true);
      wire(cctx, pullX - 26, outY + 20, pullX - 26, gndY - 67, pDn);
      wire(cctx, pullX + 26, outY + 20, pullX + 26, gndY - 67, pDn);
      wire(cctx, pullX - 26, gndY - 33, pullX - 26, gndY, true);
      wire(cctx, pullX + 26, gndY - 33, pullX + 26, gndY, true);
      node(cctx, pullX, outY, 'OUT', out ? '#86efac' : '#52525e');
      wire(cctx, pullX, outY, outX, outY, true);
      cctx.fillStyle = '#67e8f9'; cctx.font = '700 11px "Geist Mono", ui-monospace, monospace';
      cctx.fillText('A=' + a + ' B=' + b, pullX + 70, vddY + 60);
      cctx.fillStyle = out ? '#86efac' : '#9aa0ac';
      cctx.font = '700 13px "Geist Mono", ui-monospace, monospace';
      cctx.fillText('Y = ' + out, outX + 8, outY + 4);
    }

    // explanation text
    var ex = document.getElementById('cmosExplain');
    var two = (gate !== 'NOT');
    document.getElementById('cmBwrap').style.display = two ? '' : 'none';
    document.getElementById('cmB').style.display = two ? '' : 'none';
    var txt;
    if (gate === 'NOT') txt = 'Inverter: one PMOS pull-up and one NMOS pull-down share gate A. A=0 turns the PMOS on (Y pulled to VDD = 1); A=1 turns the NMOS on (Y pulled to GND = 0). Always exactly one network conducts.';
    else if (gate === 'NAND') txt = 'NAND: PMOS pull-up has A and B in PARALLEL (either low input pulls Y high), NMOS pull-down has A and B in SERIES (both must be high to pull Y low). Y is low only when A=B=1.';
    else txt = 'NOR: PMOS pull-up has A and B in SERIES (both must be low to pull Y high), NMOS pull-down has A and B in PARALLEL (any high input pulls Y low). Y is high only when A=B=0.';
    ex.textContent = txt;
  }

  // ── Presets ───────────────────────────────────────────────────────────────
  function clearAll() { nodes = []; nextId = 1; history = {}; tick = 0; clkPhase = 0; }

  function loadPreset(key) {
    clearAll();
    if (key === 'half') {
      var a = addNode('INPUT', { name: 'A' });
      var b = addNode('INPUT', { name: 'B' });
      var sx = addNode('XOR', { name: 'SUM', ins: [a, b], probe: true });
      addNode('AND', { name: 'CARRY', ins: [a, b], probe: true });
    } else if (key === 'full') {
      var fa = addNode('INPUT', { name: 'A' });
      var fb = addNode('INPUT', { name: 'B' });
      var ci = addNode('INPUT', { name: 'CIN' });
      var x1 = addNode('XOR', { name: 'x1', ins: [fa, fb] });
      var sum = addNode('XOR', { name: 'SUM', ins: [x1, ci], probe: true });
      var a1 = addNode('AND', { name: 'a1', ins: [x1, ci] });
      var a2 = addNode('AND', { name: 'a2', ins: [fa, fb] });
      addNode('OR', { name: 'COUT', ins: [a1, a2], probe: true });
    } else if (key === 'mux') {
      var d0 = addNode('INPUT', { name: 'D0', value: 1 });
      var d1 = addNode('INPUT', { name: 'D1' });
      var s = addNode('INPUT', { name: 'SEL' });
      addNode('MUX2', { name: 'Y', ins: [d0, d1, s], probe: true });
    } else if (key === 'sr') {
      var sset = addNode('INPUT', { name: 'S' });
      var srst = addNode('INPUT', { name: 'R' });
      var n1 = addNode('NOR', { name: 'Q' });
      var n2 = addNode('NOR', { name: 'QN' });
      var qNode = nodeById(n1), qnNode = nodeById(n2);
      qNode.ins = [srst, n2];   // NOR(R, QN) = Q
      qnNode.ins = [sset, n1];  // NOR(S, Q)  = QN
      qNode.probe = true; qnNode.probe = true;
    } else if (key === 'dff') {
      var ck = addNode('CLOCK', { name: 'CLK' });
      var qn = addNode('NOT', { name: 'QN' });        // feedback inverter
      var dff = addNode('DFF', { name: 'Q' });
      var qf = nodeById(qn), df = nodeById(dff);
      df.ins = [qn, ck];        // D = QN  -> toggles every rising edge (divide-by-2)
      qf.ins = [dff];           // QN = NOT(Q)
      df.probe = true; nodeById(ck).probe = true; qf.probe = true;
    } else if (key === 'counter') {
      // 2-bit ripple counter: two T-flip-flops built from DFF with D=QN feedback
      var c0 = addNode('CLOCK', { name: 'CLK' });
      // bit 0
      var qn0 = addNode('NOT', { name: 'QN0' });
      var q0 = addNode('DFF', { name: 'Q0' });
      var q0n = nodeById(qn0), q0f = nodeById(q0);
      q0f.ins = [qn0, c0]; q0n.ins = [q0]; q0f.probe = true;
      // bit 1, clocked by QN0 (ripple)
      var qn1 = addNode('NOT', { name: 'QN1' });
      var q1 = addNode('DFF', { name: 'Q1' });
      var q1n = nodeById(qn1), q1f = nodeById(q1);
      q1f.ins = [qn1, qn0]; q1n.ins = [q1]; q1f.probe = true;
      nodeById(c0).probe = true;
    }
    rebuild();
  }

  // ── Toolbar wiring ────────────────────────────────────────────────────────
  var addBtns = document.querySelectorAll('[data-add]');
  for (var i = 0; i < addBtns.length; i++) addBtns[i].addEventListener('click', function () {
    addNode(this.getAttribute('data-add'), {});
    rebuild();
  });
  document.getElementById('preset').addEventListener('change', function () {
    if (this.value) { loadPreset(this.value); this.value = ''; }
  });
  document.getElementById('step').addEventListener('click', function () { doTick(); });
  document.getElementById('run').addEventListener('click', function () {
    if (running) stopRun(); else startRun();
  });
  document.getElementById('reset').addEventListener('click', function () { stopRun(); resetSim(); });
  document.getElementById('gentt').addEventListener('click', generateTT);

  document.getElementById('cmosgate').addEventListener('change', drawCMOS);
  document.getElementById('cmA').addEventListener('click', function () {
    cmA = cmA ? 0 : 1; this.textContent = String(cmA); this.className = 'toggle mono ' + (cmA ? 'hi' : 'lo'); drawCMOS();
  });
  document.getElementById('cmB').addEventListener('click', function () {
    cmB = cmB ? 0 : 1; this.textContent = String(cmB); this.className = 'toggle mono ' + (cmB ? 'hi' : 'lo'); drawCMOS();
  });
  document.getElementById('speed').addEventListener('input', function () { /* live; loop reads value */ });

  window.addEventListener('resize', function () {
    var val = settle(); drawWave(val); drawCMOS();
  });

  // ── Boot ──────────────────────────────────────────────────────────────────
  loadPreset('full');
  drawCMOS();
})();
</script>
