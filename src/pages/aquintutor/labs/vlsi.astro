  function buildSidebar() {
    var host = document.getElementById('explist');
    var h = '<h4>Experiments</h4>';
    for (var i = 0; i < EXPERIMENTS.length; i++) {
      h += '<button class="exp-item" data-exp="' + i + '"><span class="exp-num">' + (i + 1) + '</span><span class="exp-ti">' + EXPERIMENTS[i].title + '</span></button>';
    }
    host.innerHTML = h;
    var btns = host.querySelectorAll('[data-exp]');
    for (var b = 0; b < btns.length; b++) btns[b].addEventListener('click', function () {
      selectExp(parseInt(this.getAttribute('data-exp'), 10));
    });
  }

  function buildTabs() {
    var host = document.getElementById('tabbar');
    var h = '';
    for (var i = 0; i < TABS.length; i++) h += '<button class="tab" data-tab="' + TABS[i].id + '">' + TABS[i].label + '</button>';
    host.innerHTML = h;
    var btns = host.querySelectorAll('[data-tab]');
    for (var b = 0; b < btns.length; b++) btns[b].addEventListener('click', function () {
      selectTab(this.getAttribute('data-tab'));
    });
  }

  function selectTab(id) {
    curTab = id;
    var tabs = document.querySelectorAll('#tabbar .tab');
    for (var i = 0; i < tabs.length; i++) tabs[i].className = 'tab' + (tabs[i].getAttribute('data-tab') === id ? ' active' : '');
    var panels = document.querySelectorAll('.tabpanel');
    for (var j = 0; j < panels.length; j++) panels[j].className = 'tabpanel' + (panels[j].getAttribute('data-tab') === id ? ' active' : '');
    // redraw active canvas-based sims when their tab becomes visible
    if (id === 'sim') {
      var e = EXPERIMENTS[curExp];
      setTimeout(function () {
        if (e.sim === 'netlist') { var v = settle(); drawWave(v); drawCMOS(); }
        else if (e.sim === 'fsm') fsmDraw();
      }, 0);
    }
  }

  function showSim(which, exp) {
    var sims = document.querySelectorAll('.sim');
    for (var i = 0; i < sims.length; i++) sims[i].style.display = (sims[i].getAttribute('data-sim') === which) ? '' : 'none';
    if (which === 'netlist') {
      // show/hide CMOS panel
      var cmosPanel = document.querySelector('[data-show="cmos"]');
      if (cmosPanel) cmosPanel.style.display = exp.cmos ? '' : 'none';
    }
    // lazy-bind interactive sims
    if (which === 'kmap' && !simBound.kmap) { bindKmap(); simBound.kmap = true; }
    if (which === 'muxdec' && !simBound.muxdec) { bindMuxDec(); simBound.muxdec = true; }
    if (which === 'ff' && !simBound.ff) { bindFF(); simBound.ff = true; }
    if (which === 'fsm' && !simBound.fsm) { bindFSM(); simBound.fsm = true; }
  }

