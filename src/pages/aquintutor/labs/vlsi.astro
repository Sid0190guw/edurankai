    for (var i = 0; i < exp.quiz.length; i++) {
      var item = exp.quiz[i];
      h += '<div class="q" data-qi="' + i + '"><div class="qt">' + (i + 1) + '. ' + item.q + '</div>';
      for (var o = 0; o < item.opts.length; o++) {
        h += '<label class="opt"><input type="radio" name="q' + i + '" value="' + o + '"><span>' + item.opts[o] + '</span></label>';
      }
      h += '<div class="expl"></div></div>';
    }
    host.innerHTML = h;
    document.getElementById('quizScore').textContent = '';
  }

  function checkQuiz() {
    var exp = EXPERIMENTS[curExp];
    var score = 0;
    for (var i = 0; i < exp.quiz.length; i++) {
      var item = exp.quiz[i];
      var qDiv = document.querySelector('.q[data-qi="' + i + '"]');
      var opts = qDiv.querySelectorAll('.opt');
      var chosen = -1;
      var radios = qDiv.querySelectorAll('input[type=radio]');
      for (var r = 0; r < radios.length; r++) if (radios[r].checked) chosen = parseInt(radios[r].value, 10);
      for (var o = 0; o < opts.length; o++) {
        opts[o].className = 'opt';
        if (o === item.a) opts[o].className = 'opt right';
        else if (o === chosen) opts[o].className = 'opt wrong';
      }
      var expl = qDiv.querySelector('.expl');
      if (chosen === item.a) {
        score++;
        expl.className = 'expl show ok'; expl.textContent = 'Correct. ' + item.e;
      } else if (chosen === -1) {
        expl.className = 'expl show no'; expl.textContent = 'Not answered. ' + item.e;
      } else {
        expl.className = 'expl show no'; expl.textContent = 'Incorrect. ' + item.e;
      }
    }
    document.getElementById('quizScore').textContent = 'Score: ' + score + ' / ' + exp.quiz.length;
  }

  function selectExp(idx) {
    curExp = idx;
    var exp = EXPERIMENTS[idx];
    // sidebar active
    var items = document.querySelectorAll('[data-exp]');
    for (var i = 0; i < items.length; i++) items[i].className = 'exp-item' + (parseInt(items[i].getAttribute('data-exp'), 10) === idx ? ' active' : '');
    // title
    document.getElementById('expTitle').innerHTML = (idx + 1) + '. <em>' + exp.title + '</em>';
    // content panes
    document.getElementById('paneAim').innerHTML = '<p>' + exp.aim + '</p>';
    document.getElementById('paneTheory').innerHTML = exp.theory;
    var proc = '';
    for (var p = 0; p < exp.proc.length; p++) proc += '<li>' + exp.proc[p] + '</li>';
    document.getElementById('paneProc').innerHTML = proc;
    var refs = '';
    for (var rf = 0; rf < exp.refs.length; rf++) refs += '<li>' + exp.refs[rf] + '</li>';
    document.getElementById('paneRefs').innerHTML = refs;
    renderQuiz(exp);

    // simulation
    showSim(exp.sim, exp);
    if (exp.sim === 'netlist' && exp.preset) {
      stopRun();
      loadPreset(exp.preset);
    }

    // default to Simulation tab on switch
    selectTab('sim');
  }

  document.getElementById('quizCheck').addEventListener('click', checkQuiz);

  window.addEventListener('resize', function () {
    var e = EXPERIMENTS[curExp];
    if (e.sim === 'netlist') { var v = settle(); drawWave(v); drawCMOS(); }
    else if (e.sim === 'fsm') fsmDraw();
  });

  // ── Boot ──────────────────────────────────────────────────────────────────
  buildSidebar();
  buildTabs();
  drawCMOS();
  selectExp(0);
})();
</script>
</BaseLayout>
