  }

  // ---------- SECTION (tab) SWITCHING within each experiment ----------
  var secbars = document.querySelectorAll('.crx .secbar');
  for (var s = 0; s < secbars.length; s++) {
    (function (bar) {
      var stabs = bar.querySelectorAll('.stab');
      var expEl = bar.parentNode;
      for (var k = 0; k < stabs.length; k++) {
        stabs[k].addEventListener('click', function () {
          var name = this.getAttribute('data-sec');
          for (var a = 0; a < stabs.length; a++) stabs[a].classList.remove('on');
          this.classList.add('on');
