    bindRange('cv0', 'cv0v', 'v0', function (v) { return fmt(v, 1); });
    bindRange('cvol', 'cvolv', 'V', function (v) { return fmt(v, 1); });

    var result = { X: 0, tau: 0, Da: 0, CA: 0, FA0: 0, rA: 0 };
    function recompute() {
      var tau = st.V / st.v0;
      var X = cstrSolve(st.k, st.CA0, st.n, tau);
      var CA = st.CA0 * (1 - X);
      var FA0 = st.CA0 * st.v0;
      var rA = rateX(st.k, st.CA0, st.n, X);
      var Da = st.k * tau * Math.pow(st.CA0, st.n - 1);
      result = { X: X, tau: tau, Da: Da, CA: CA, FA0: FA0, rA: rA };
      $('cstrTau').textContent = fmt(tau, 2);
      $('cstrDa').textContent = fmt(Da, 2);
      $('cstrX').textContent = fmt(X * 100, 1) + '%';
      $('cstrCA').textContent = fmt(CA, 3);
      $('cstrFA0').textContent = fmt(FA0, 2);
      $('cstrRA').textContent = fmt(rA, 3);
      $('cstrBadge').textContent = X > 0.9 ? 'high X' : (X < 0.2 ? 'low X' : 'steady');
      draw();
    }
    function draw() {
      clearCanvas(ctx, W, H);
      var cx = W / 2, tankY = 60, tankW = 180, tankH = 200, tankX = cx - tankW / 2;
      // feed pipe (top-left in)
      ctx.strokeStyle = '#3a3a48'; ctx.lineWidth = 12;
      ctx.beginPath(); ctx.moveTo(40, 40); ctx.lineTo(tankX + 30, 40); ctx.lineTo(tankX + 30, tankY); ctx.stroke();
      // exit pipe (bottom-right out)
      ctx.beginPath(); ctx.moveTo(tankX + tankW - 30, tankY + tankH); ctx.lineTo(tankX + tankW - 30, tankY + tankH + 36); ctx.lineTo(W - 40, tankY + tankH + 36); ctx.stroke();
      // animated feed droplets in
      st.phase += 0.02;
      drawFlow(ctx, [[40, 40], [tankX + 30, 40], [tankX + 30, tankY]], '#f59e0b', st.phase, 6);
      drawFlow(ctx, [[tankX + tankW - 30, tankY + tankH], [tankX + tankW - 30, tankY + tankH + 36], [W - 40, tankY + tankH + 36]], '#67e8f9', st.phase, 6);
      // tank body
      ctx.fillStyle = '#0e0f15'; ctx.strokeStyle = '#4a4a58'; ctx.lineWidth = 3;
      ctx.beginPath(); ctx.rect(tankX, tankY, tankW, tankH); ctx.fill(); ctx.stroke();
      // uniform contents = exit concentration colour
      var frac = clamp(result.CA / st.CA0, 0, 1);
      var r = Math.round(60 + 180 * frac), g = Math.round(170 - 30 * frac), b = Math.round(70 + 110 * (1 - frac));
      ctx.fillStyle = 'rgba(' + r + ',' + g + ',' + b + ',0.5)';
      ctx.fillRect(tankX + 4, tankY + 4, tankW - 8, tankH - 8);
