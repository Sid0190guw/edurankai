      ctx.strokeStyle = '#8a8f99'; ctx.lineWidth = 3;
      ctx.beginPath(); ctx.moveTo(shx, tankY - 22); ctx.lineTo(shx, shy); ctx.stroke();
      ctx.fillStyle = '#2a2a35'; ctx.fillRect(shx - 18, tankY - 36, 36, 16);
      ctx.strokeStyle = '#4a4a58'; ctx.strokeRect(shx - 18, tankY - 36, 36, 16);
      ctx.save(); ctx.translate(shx, shy); ctx.rotate(st.phase * 6);
      ctx.strokeStyle = '#cfd6da'; ctx.lineWidth = 4;
      ctx.beginPath(); ctx.moveTo(-26, 0); ctx.lineTo(26, 0); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(0, -12); ctx.lineTo(0, 12); ctx.stroke();
