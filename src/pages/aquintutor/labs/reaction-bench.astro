  function axes(ctx, box, opts) {
    // box: {x,y,w,h}; opts: xlab,ylab,xmin,xmax,ymin,ymax
    ctx.save();
    ctx.strokeStyle = '#232330';
    ctx.lineWidth = 1;
    ctx.fillStyle = '#11131a';
    ctx.fillRect(box.x, box.y, box.w, box.h);
    ctx.strokeRect(box.x, box.y, box.w, box.h);
    // gridlines
    ctx.strokeStyle = '#1a1a24';
    ctx.fillStyle = '#7a8088';
    ctx.font = '9px Geist Mono, monospace';
    var gx = 5, gy = 4, i;
    for (i = 0; i <= gx; i++) {
      var fx = box.x + box.w * i / gx;
      ctx.beginPath(); ctx.moveTo(fx, box.y); ctx.lineTo(fx, box.y + box.h); ctx.stroke();
      var vx = opts.xmin + (opts.xmax - opts.xmin) * i / gx;
      ctx.textAlign = 'center';
      ctx.fillText(fmtTick(vx), fx, box.y + box.h + 12);
    }
    for (i = 0; i <= gy; i++) {
      var fy = box.y + box.h * i / gy;
      ctx.beginPath(); ctx.moveTo(box.x, fy); ctx.lineTo(box.x + box.w, fy); ctx.stroke();
      var vy = opts.ymax - (opts.ymax - opts.ymin) * i / gy;
      ctx.textAlign = 'right';
      ctx.fillText(fmtTick(vy), box.x - 4, fy + 3);
    }
    ctx.fillStyle = '#9aa0aa';
    ctx.font = '10px Geist Mono, monospace';
    ctx.textAlign = 'center';
    ctx.fillText(opts.xlab, box.x + box.w / 2, box.y + box.h + 26);
    ctx.save();
    ctx.translate(box.x - 34, box.y + box.h / 2);
    ctx.rotate(-Math.PI / 2);
    ctx.fillText(opts.ylab, 0, 0);
    ctx.restore();
    ctx.restore();
  }
  function fmtTick(v) {
