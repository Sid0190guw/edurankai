      for (i = 1; i < N; i++) sum += (i % 2 ? 4 : 2) * recip(i * h);
      var Vp = (h / 3) * sum;
      var Vc = Xt * recip(Xt);
      result = { Vp: Vp, Vc: Vc, ratio: Vp > 0 ? Vc / Vp : 0 };
      $('levVp').textContent = fmt(Vp, 3);
      $('levVc').textContent = fmt(Vc, 3);
      $('levRatio').textContent = fmt(result.ratio, 3);
      var win = Vc < Vp ? 'CSTR' : 'PFR';
      $('levWin').textContent = win;
      $('levBadge').textContent = win + ' smaller';
      draw();
    }
    function draw() {
      clearCanvas(ctx, W, H);
      // determine y-axis range from reciprocal-rate up to Xt+ margin
      var Xhi = Math.min(0.99, st.Xt + 0.05);
      var ymax = recip(Xhi) * 1.1;
      if (!isFinite(ymax) || ymax <= 0) ymax = 10;
      ymax = Math.min(ymax, recip(0) * 40);
      var box = { x: 80, y: 40, w: W - 130, h: 440 };
      var opts = { xlab: 'conversion X', ylab: '1 / (-rA)', xmin: 0, xmax: 1, ymin: 0, ymax: ymax };
      // build curve
      var curve = [], i;
      for (i = 0; i <= 200; i++) { var X = i / 200 * 0.995; curve.push([X, recip(X)]); }
      // shade PFR area (under curve 0..Xt)
      ctx.save();
      ctx.beginPath(); ctx.rect(box.x, box.y, box.w, box.h); ctx.clip();
      ctx.beginPath();
      ctx.moveTo(mapX(box, opts, 0), mapY(box, opts, 0));
      for (i = 0; i <= 200; i++) {
        var Xa = i / 200 * st.Xt;
        ctx.lineTo(mapX(box, opts, Xa), mapY(box, opts, recip(Xa)));
      }
      ctx.lineTo(mapX(box, opts, st.Xt), mapY(box, opts, 0));
      ctx.closePath();
      ctx.fillStyle = 'rgba(245,158,11,0.22)'; ctx.fill();
      // CSTR rectangle (height = recip at Xt, width 0..Xt)
      var rh = recip(st.Xt);
      ctx.beginPath();
      ctx.rect(mapX(box, opts, 0), mapY(box, opts, rh), mapX(box, opts, st.Xt) - mapX(box, opts, 0), mapY(box, opts, 0) - mapY(box, opts, rh));
      ctx.strokeStyle = 'rgba(103,232,249,0.9)'; ctx.lineWidth = 2; ctx.setLineDash([5, 3]); ctx.stroke(); ctx.setLineDash([]);
      ctx.fillStyle = 'rgba(103,232,249,0.08)'; ctx.fill();
      ctx.restore();
      axes(ctx, box, opts);
      // re-shade area on top of axes for clarity is already under; draw curve
      plotLine(ctx, box, opts, curve, '#f3f3f8', 2.5);
      // Xt marker
      var mx = mapX(box, opts, st.Xt);
      ctx.save(); ctx.strokeStyle = 'rgba(255,255,255,0.4)'; ctx.setLineDash([4, 4]);
      ctx.beginPath(); ctx.moveTo(mx, box.y); ctx.lineTo(mx, box.y + box.h); ctx.stroke(); ctx.setLineDash([]); ctx.restore();
      // point on curve
      ctx.fillStyle = '#86efac'; ctx.beginPath(); ctx.arc(mx, mapY(box, opts, recip(st.Xt)), 5, 0, Math.PI * 2); ctx.fill();
      // legend
      ctx.font = '10px Geist Mono, monospace'; ctx.textAlign = 'left';
      ctx.fillStyle = '#f59e0b'; ctx.fillText('PFR area = ' + fmt(result.Vp, 3), box.x + 10, box.y + 18);
      ctx.fillStyle = '#67e8f9'; ctx.fillText('CSTR rect = ' + fmt(result.Vc, 3), box.x + 10, box.y + 34);
      ctx.fillStyle = '#cfd6da'; ctx.fillText('V_CSTR / V_PFR = ' + fmt(result.ratio, 2), box.x + 10, box.y + 50);
    }
    st.n = parseInt(ordSeg.get(), 10);
    recompute();
  })();

  // ===================================================================
  // EXPERIMENT 5 — ARRHENIUS
  // ===================================================================
  (function () {
    var cv = $('arrCv'); if (!cv) return;
    var ctx = cv.getContext('2d'), W = cv.width, H = cv.height;
    var st = { EakJ: 60, lnA: 18, T: 350 };

    function bindRange(id, vid, key, fmtfn) {
      var el = $(id), lab = $(vid);
      el.addEventListener('input', function () { st[key] = parseFloat(el.value); lab.textContent = fmtfn(st[key]); recompute(); });
    }
    bindRange('aEa', 'aEav', 'EakJ', function (v) { return fmt(v, 0); });
    bindRange('aA', 'aAv', 'lnA', function (v) { return fmt(v, 1); });
    bindRange('aT', 'aTv', 'T', function (v) { return fmt(v, 0); });

    function kAt(T) { var Ea = st.EakJ * 1000; return Math.exp(st.lnA) * Math.exp(-Ea / (R_GAS * T)); }
    function recompute() {
      var Ea = st.EakJ * 1000;
      var k = kAt(st.T);
      // sample ln k vs 1/T across the window, fit a line to recover Ea, lnA
      var Tmin = 280, Tmax = 500, xs = [], ys = [], i;
      for (i = 0; i <= 40; i++) { var T = Tmin + (Tmax - Tmin) * i / 40; xs.push(1 / T); ys.push(Math.log(kAt(T))); }
      var fit = linfit(xs, ys);
      var EaRec = -fit.m * R_GAS / 1000;
      var k2 = kAt(st.T + 10);
      $('arrK').textContent = k.toExponential(2);
      $('arrLnk').textContent = fmt(Math.log(k), 2);
      $('arrSlope').textContent = fmt(fit.m, 0);
      $('arrInt').textContent = fmt(fit.b, 2);
      $('arrRatio').textContent = fmt(k2 / k, 2) + 'x';
      $('arrEaRec').textContent = fmt(EaRec, 1) + ' kJ';
      draw(fit, Tmin, Tmax);
    }
    function draw(fit, Tmin, Tmax) {
      clearCanvas(ctx, W, H);
      // ---- top: k vs T ----
      var b1 = { x: 80, y: 36, w: W - 130, h: 195 };
      var kmin = kAt(Tmin), kmax = kAt(Tmax);
      var o1 = { xlab: 'T (K)', ylab: 'k', xmin: Tmin, xmax: Tmax, ymin: 0, ymax: kmax * 1.05 };
      axes(ctx, b1, o1);
      var c1 = [], i;
      for (i = 0; i <= 200; i++) { var T = Tmin + (Tmax - Tmin) * i / 200; c1.push([T, kAt(T)]); }
      plotLine(ctx, b1, o1, c1, '#f59e0b', 2.5);
      var pkx = mapX(b1, o1, st.T), pky = mapY(b1, o1, kAt(st.T));
      ctx.save(); ctx.strokeStyle = 'rgba(245,158,11,0.4)'; ctx.setLineDash([4, 4]);
      ctx.beginPath(); ctx.moveTo(pkx, b1.y); ctx.lineTo(pkx, b1.y + b1.h); ctx.stroke(); ctx.setLineDash([]); ctx.restore();
      ctx.fillStyle = '#67e8f9'; ctx.beginPath(); ctx.arc(pkx, pky, 5, 0, Math.PI * 2); ctx.fill();
      ctx.fillStyle = '#9aa0aa'; ctx.font = '9px Geist Mono, monospace'; ctx.textAlign = 'left';
      ctx.fillText('k = A exp(-Ea/RT)', b1.x + 8, b1.y + 14);

      // ---- bottom: ln k vs 1/T ----
      var b2 = { x: 80, y: 300, w: W - 130, h: 195 };
      var xMin = 1 / Tmax, xMax = 1 / Tmin;
      var yLo = Math.log(kAt(Tmin)), yHi = Math.log(kAt(Tmax)); // note: smaller 1/T -> bigger k
      var ymn = Math.min(yLo, yHi), ymx = Math.max(yLo, yHi);
      var pad = (ymx - ymn) * 0.08 + 0.5;
      var o2 = { xlab: '1 / T', ylab: 'ln k', xmin: xMin, xmax: xMax, ymin: ymn - pad, ymax: ymx + pad };
      axes(ctx, b2, o2);
      // straight line ln k = b + m*(1/T)
      var ln1 = [[xMin, fit.b + fit.m * xMin], [xMax, fit.b + fit.m * xMax]];
      plotLine(ctx, b2, o2, ln1, '#86efac', 2.5);
      // sampled points
      var pts = [];
      for (i = 0; i <= 12; i++) { var T2 = Tmin + (Tmax - Tmin) * i / 12; pts.push([1 / T2, Math.log(kAt(T2))]); }
      plotDots(ctx, b2, o2, pts, '#f59e0b', 3);
      var px = mapX(b2, o2, 1 / st.T), py = mapY(b2, o2, Math.log(kAt(st.T)));
      ctx.fillStyle = '#67e8f9'; ctx.beginPath(); ctx.arc(px, py, 5, 0, Math.PI * 2); ctx.fill();
      ctx.fillStyle = '#9aa0aa'; ctx.font = '9px Geist Mono, monospace'; ctx.textAlign = 'left';
      ctx.fillText('slope = -Ea/R = ' + fmt(fit.m, 0) + ',  intercept = ln A = ' + fmt(fit.b, 2), b2.x + 8, b2.y + 14);
    }
    recompute();
  })();

  // ===================================================================
  // EXPERIMENT 6 — REACTION ORDER DETERMINATION
  // ===================================================================
  (function () {
    var cv = $('ordCv'); if (!cv) return;
    var ctx = cv.getContext('2d'), W = cv.width, H = cv.height;
    var st = { trial: 1, noise: 0.02, revealed: false, trueOrder: 1, k: 0.4, CA0: 2.0, data: [], times: [] };

    var trialSeg = segment('ordTrial', 'data-n', function (v) { st.trial = parseInt(v, 10); analyse(); });
    $('onz').addEventListener('input', function () { st.noise = parseFloat(this.value); $('onzv').textContent = fmt(st.noise, 3); });

    function genData() {
      st.trueOrder = Math.floor(Math.random() * 3);   // 0,1,2 hidden
      st.k = 0.2 + Math.random() * 0.5;
      st.CA0 = 1.5 + Math.random() * 1.5;
      st.revealed = false;
      $('ordTrue').textContent = 'hidden';
      // generate clean CA(t) then add noise; choose tMax to give meaningful decay
      var tMax;
      if (st.trueOrder === 0) tMax = st.CA0 / st.k * 0.85;
      else if (st.trueOrder === 1) tMax = Math.LN2 / st.k * 4;
      else tMax = (1 / (st.k * st.CA0)) * 7;
      st.times = []; st.data = [];
      var npts = 12;
      for (var i = 0; i < npts; i++) {
        var tt = tMax * (i + 0.4) / npts;
        var ca = batchAnalytic(st.CA0, st.k, st.trueOrder, tt);
        // multiplicative-ish noise
        var noisy = ca * (1 + (Math.random() * 2 - 1) * st.noise) + (Math.random() * 2 - 1) * st.noise * st.CA0 * 0.4;
        if (noisy < 0.001) noisy = 0.001;
        st.times.push(tt); st.data.push(noisy);
      }
      analyse();
    }
    function transform(order) {
      var xs = [], ys = [], i;
      for (i = 0; i < st.times.length; i++) {
        var ca = st.data[i];
        if (order === 0) { xs.push(st.times[i]); ys.push(ca); }
        else if (order === 1) { xs.push(st.times[i]); ys.push(Math.log(ca)); }
        else { xs.push(st.times[i]); ys.push(1 / ca); }
      }
      return { xs: xs, ys: ys };
    }
    function analyse() {
      var fits = [];
      for (var o = 0; o < 3; o++) { var tr = transform(o); fits.push(linfit(tr.xs, tr.ys)); }
      $('ordR0').textContent = fmt(fits[0].r2, 4);
      $('ordR1').textContent = fmt(fits[1].r2, 4);
      $('ordR2').textContent = fmt(fits[2].r2, 4);
      // best order = highest r2
      var best = 0; for (var o2 = 1; o2 < 3; o2++) if (fits[o2].r2 > fits[best].r2) best = o2;
      $('ordBest').textContent = 'order ' + best;
      // recovered k from slope magnitude of best
      var kRec = Math.abs(fits[best].m);
      $('ordK').textContent = fmt(kRec, 3);
      $('ordBadge').textContent = 'R2 best: order ' + best;
      draw(fits);
    }
    function draw(fits) {
      clearCanvas(ctx, W, H);
      var tr = transform(st.trial);
      var fit = fits[st.trial];
      var ylab = st.trial === 0 ? 'CA' : (st.trial === 1 ? 'ln CA' : '1 / CA');
      // axis ranges
      var xmin = 0, xmax = 0, ymin = Infinity, ymax = -Infinity, i;
      for (i = 0; i < tr.xs.length; i++) {
        if (tr.xs[i] > xmax) xmax = tr.xs[i];
        if (tr.ys[i] < ymin) ymin = tr.ys[i];
        if (tr.ys[i] > ymax) ymax = tr.ys[i];
      }
      // include the fit line endpoints
      var ly0 = fit.b, ly1 = fit.b + fit.m * xmax;
      ymin = Math.min(ymin, ly0, ly1); ymax = Math.max(ymax, ly0, ly1);
      var pad = (ymax - ymin) * 0.12 + 0.05; ymin -= pad; ymax += pad;
      xmax *= 1.05;
      var box = { x: 80, y: 50, w: W - 130, h: 420 };
      var opts = { xlab: 't (min)', ylab: ylab, xmin: xmin, xmax: xmax, ymin: ymin, ymax: ymax };
      axes(ctx, box, opts);
      // fit line
      plotLine(ctx, box, opts, [[xmin, fit.b], [xmax, fit.b + fit.m * xmax]], '#86efac', 2.5);
      // data points
      var pts = []; for (i = 0; i < tr.xs.length; i++) pts.push([tr.xs[i], tr.ys[i]]);
      plotDots(ctx, box, opts, pts, '#f59e0b', 4);
      // labels
      ctx.fillStyle = '#cfd6da'; ctx.font = '10px Geist Mono, monospace'; ctx.textAlign = 'left';
      ctx.fillText('trial: ' + ylab + ' vs t', box.x + 10, box.y + 18);
      ctx.fillStyle = '#86efac';
      ctx.fillText('R-squared = ' + fmt(fit.r2, 4) + '   slope = ' + fmt(fit.m, 4), box.x + 10, box.y + 34);
      if (st.revealed) {
        ctx.fillStyle = '#67e8f9'; ctx.font = '11px Geist Mono, monospace';
        ctx.fillText('TRUE order = ' + st.trueOrder + '   (k = ' + fmt(st.k, 3) + ')', box.x + 10, box.y + 52);
      }
    }
    $('ordNew').addEventListener('click', genData);
    $('ordReveal').addEventListener('click', function () {
      st.revealed = true;
      $('ordTrue').textContent = 'order ' + st.trueOrder;
      analyse();
    });
    st.trial = parseInt(trialSeg.get(), 10);
    genData();
  })();

})();
</script>
</BaseLayout>
