        var px = shx + Math.cos(ang) * rr, py = shy + Math.sin(ang * 1.2) * rr * 0.7;
        if (py > tankY + 6 && py < tankY + tankH - 6) { ctx.beginPath(); ctx.arc(px, py, 2 + (p % 3), 0, Math.PI * 2); ctx.fill(); }
      }
      // labels
      ctx.fillStyle = '#f59e0b'; ctx.font = '10px Geist Mono, monospace'; ctx.textAlign = 'left';
      ctx.fillText('feed  CA0 = ' + fmt(st.CA0, 1), 44, 30);
      ctx.fillStyle = '#67e8f9'; ctx.textAlign = 'right';
      ctx.fillText('exit  CA = ' + fmt(result.CA, 3), W - 44, tankY + tankH + 30);
      ctx.fillStyle = '#cfd6da'; ctx.textAlign = 'center'; ctx.font = '11px Geist Mono, monospace';
      ctx.fillText('CSTR  V = ' + fmt(st.V, 1), shx, tankY + tankH * 0.5 - 20);
      ctx.font = '10px Geist Mono, monospace'; ctx.fillStyle = '#9aa0aa';
