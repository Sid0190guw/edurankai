      ctx.fillRect(bx, by, bw, bh); ctx.strokeRect(bx, by, bw, bh);
      ctx.fillStyle = 'rgba(245,158,11,0.6)';
      ctx.fillRect(bx, by, bw * result.X, bh);
      ctx.fillStyle = '#f3f3f8'; ctx.font = '11px Geist Mono, monospace'; ctx.textAlign = 'center';
