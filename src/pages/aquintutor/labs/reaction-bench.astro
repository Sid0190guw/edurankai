  // ---------- KINETICS HELPERS ----------
  // rate of reaction (-rA) at conversion X for order n: -rA = k * CA0^n * (1-X)^n
  function rateX(k, CA0, n, X) {
    var c = CA0 * (1 - X);
    if (c < 0) c = 0;
    return k * Math.pow(c, n);
  }
  // RK4 step for batch dCA/dt = -k CA^n
  function rk4Batch(CA, k, n, dt) {
    function f(c) { return -k * Math.pow(c < 0 ? 0 : c, n); }
    var k1 = f(CA);
    var k2 = f(CA + 0.5 * dt * k1);
    var k3 = f(CA + 0.5 * dt * k2);
    var k4 = f(CA + dt * k3);
    var nc = CA + (dt / 6) * (k1 + 2 * k2 + 2 * k3 + k4);
    return nc < 0 ? 0 : nc;
  }
  // analytic batch CA(t)
  function batchAnalytic(CA0, k, n, time) {
    if (n === 0) return Math.max(0, CA0 - k * time);
    if (n === 1) return CA0 * Math.exp(-k * time);
    // second order
    return 1 / (1 / CA0 + k * time);
  }
  // RK4 step for PFR dX/dV = k*CA0^(n-1)*(1-X)^n / v0
  function rk4PFR(X, k, CA0, n, v0, dV) {
    function f(x) {
      var c = 1 - x; if (c < 0) c = 0;
      return k * Math.pow(CA0, n - 1) * Math.pow(c, n) / v0;
    }
    var k1 = f(X);
    var k2 = f(X + 0.5 * dV * k1);
    var k3 = f(X + 0.5 * dV * k2);
    var k4 = f(X + dV * k3);
    var nx = X + (dV / 6) * (k1 + 2 * k2 + 2 * k3 + k4);
    return clamp(nx, 0, 0.99999);
  }
  // CSTR: solve tau*k*CA0^(n-1)*(1-X)^n - X = 0 by bisection
  function cstrSolve(k, CA0, n, tau) {
    function g(X) { return tau * k * Math.pow(CA0, n - 1) * Math.pow(1 - X, n) - X; }
    var lo = 0, hi = 0.9999999;
    if (g(lo) <= 0) return 0;
    for (var it = 0; it < 80; it++) {
      var mid = 0.5 * (lo + hi);
      if (g(mid) > 0) lo = mid; else hi = mid;
    }
    return 0.5 * (lo + hi);
  }
  // least squares fit -> {m, b, r2}
  function linfit(xs, ys) {
    var n = xs.length, sx = 0, sy = 0, sxx = 0, sxy = 0, i;
    for (i = 0; i < n; i++) { sx += xs[i]; sy += ys[i]; sxx += xs[i] * xs[i]; sxy += xs[i] * ys[i]; }
    var denom = n * sxx - sx * sx;
    var m = denom === 0 ? 0 : (n * sxy - sx * sy) / denom;
    var b = (sy - m * sx) / n;
    var meanY = sy / n, ssTot = 0, ssRes = 0;
    for (i = 0; i < n; i++) {
      var pred = m * xs[i] + b;
      ssRes += (ys[i] - pred) * (ys[i] - pred);
      ssTot += (ys[i] - meanY) * (ys[i] - meanY);
    }
    var r2 = ssTot === 0 ? 1 : 1 - ssRes / ssTot;
    return { m: m, b: b, r2: r2 };
  }

