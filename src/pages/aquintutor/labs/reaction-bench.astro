      ctx.fillText('feed CA0 = ' + fmt(st.CA0, 1), tx + 4, ty - 8);
      ctx.fillStyle = '#67e8f9'; ctx.textAlign = 'right';
      ctx.fillText('exit CA = ' + fmt(result.CA, 3), tx + tw - 4, ty - 8);
      ctx.fillStyle = '#9aa0aa'; ctx.textAlign = 'center'; ctx.font = '10px Geist Mono, monospace';
      ctx.fillText('PFR tube  (concentration gradient along length)  V = ' + fmt(st.V, 1), tx + tw / 2, ty + th + 18);

      // ---- conversion vs volume plot (bottom) ----
      var box = { x: 70, y: 165, w: W - 110, h: 320 };
      var opts = { xlab: 'reactor volume V', ylab: 'conversion X', xmin: 0, xmax: Vmax, ymin: 0, ymax: 1 };
      axes(ctx, box, opts);
