---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Chemical Reaction Engineering · Virtual Labs · AquinTutor" description="Batch, CSTR and PFR reactors, conversion vs residence time, rate laws and Arrhenius — live with real kinetics.">
<style>
  .crx { background:#0a0a0c; color:#e8e8ee; min-height:100vh; font-family:'Geist Mono',ui-monospace,monospace; }
  .crx .wrap { max-width:1240px; margin:0 auto; padding:36px 22px 90px; }
  .crx .back { display:inline-flex; align-items:center; gap:7px; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:#9aa0aa; text-decoration:none; margin-bottom:26px; }
  .crx .back:hover { color:#67e8f9; }
  .crx .eyebrow { font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin-bottom:12px; }
  .crx h1 { font-family:'Cormorant Garamond',serif; font-size:40px; font-weight:600; letter-spacing:-0.02em; line-height:1.1; margin:0 0 12px; color:#f3f3f8; }
  .crx h1 em { color:#f59e0b; font-style:italic; }
  .crx .lede { color:#9aa0aa; max-width:820px; font-size:13.5px; line-height:1.65; margin-bottom:26px; }

  .crx .shell { display:grid; grid-template-columns:248px minmax(0,1fr); gap:20px; align-items:start; }
  @media (max-width:900px) { .crx .shell { grid-template-columns:1fr; } }

  .crx .sidebar { background:#11131a; border:1px solid #2a2a35; border-radius:12px; padding:12px; position:sticky; top:18px; }
  .crx .sidebar .stitle { font-size:9px; letter-spacing:0.18em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin:4px 6px 10px; }
  .crx .exp-item { display:flex; gap:9px; align-items:flex-start; padding:9px 10px; border-radius:8px; cursor:pointer; border:1px solid transparent; transition:all .14s; margin-bottom:3px; }
  .crx .exp-item:hover { background:#161922; }
  .crx .exp-item.on { background:#161922; border-color:#f59e0b; }
  .crx .exp-item .num { font-size:10px; color:#f59e0b; font-weight:700; min-width:14px; }
  .crx .exp-item .nm { font-size:11px; color:#cfd6da; line-height:1.4; }
  .crx .exp-item.on .nm { color:#f3f3f8; }

  .crx .main { min-width:0; }
  .crx .exp-head { font-family:'Cormorant Garamond',serif; font-size:27px; font-weight:600; color:#f3f3f8; margin:0 0 4px; }
  .crx .exp-sub { font-size:11px; color:#9aa0aa; letter-spacing:0.04em; margin-bottom:16px; }

  .crx .secbar { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:18px; border-bottom:1px solid #2a2a35; padding-bottom:12px; }
  .crx .secbar .stab { background:#11131a; border:1px solid #2a2a35; color:#9aa0aa; padding:7px 12px; border-radius:8px; font-size:10px; letter-spacing:0.08em; text-transform:uppercase; font-weight:700; cursor:pointer; transition:all .14s; }
  .crx .secbar .stab:hover { border-color:#3a3a48; color:#e8e8ee; }
  .crx .secbar .stab.on { background:#161922; border-color:#67e8f9; color:#67e8f9; }

  .crx .exp { display:none; }
  .crx .exp.on { display:block; }
  .crx .sec { display:none; }
  .crx .sec.on { display:block; }

  .crx .prose { font-size:13px; color:#c4c8d0; line-height:1.72; max-width:840px; }
  .crx .prose b { color:#f3f3f8; }
  .crx .prose p { margin:0 0 13px; }
  .crx .prose code, .crx .eq { color:#fbbf24; background:#0a0a0c; border:1px solid #1c1c26; padding:2px 6px; border-radius:4px; font-size:12px; }
  .crx .eqblock { background:#0a0a0c; border:1px solid #232330; border-radius:9px; padding:13px 15px; margin:13px 0; font-size:12.5px; color:#fbbf24; line-height:2; }
  .crx ol.steps { font-size:13px; color:#c4c8d0; line-height:1.7; max-width:820px; padding-left:20px; }
  .crx ol.steps li { margin-bottom:9px; }
  .crx ol.steps li b { color:#f3f3f8; }
  .crx ul.refs { list-style:none; padding:0; max-width:840px; }
  .crx ul.refs li { font-size:12px; color:#9aa0aa; line-height:1.6; padding:8px 0; border-bottom:1px solid #1a1a24; }
  .crx ul.refs li b { color:#cfd6da; }

  .crx .layout { display:grid; grid-template-columns:minmax(0,1fr) 320px; gap:18px; align-items:start; }
  @media (max-width:980px) { .crx .layout { grid-template-columns:1fr; } }
  .crx .panel { background:#11131a; border:1px solid #2a2a35; border-radius:12px; padding:16px; }
  .crx .panel h3 { font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin:0 0 13px; }
  .crx canvas { display:block; width:100%; background:#08080b; border:1px solid #232330; border-radius:10px; }
  .crx .row { display:flex; gap:9px; align-items:center; margin-bottom:11px; flex-wrap:wrap; }
  .crx .row > label { font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:#9aa0aa; min-width:78px; }
  .crx input[type=range] { -webkit-appearance:none; appearance:none; background:#0a0a0c; border:1px solid #2a2a35; height:6px; border-radius:4px; flex:1; min-width:90px; }
  .crx input[type=range]::-webkit-slider-thumb { -webkit-appearance:none; appearance:none; width:14px; height:14px; border-radius:50%; background:#f59e0b; cursor:pointer; border:none; }
  .crx input[type=range]::-moz-range-thumb { width:14px; height:14px; border-radius:50%; background:#f59e0b; cursor:pointer; border:none; }
  .crx select { background:#0a0a0c; border:1px solid #2a2a35; color:#e8e8ee; padding:7px 9px; border-radius:6px; font-family:inherit; font-size:11.5px; flex:1; }
  .crx .val { font-size:11.5px; color:#f59e0b; min-width:58px; text-align:right; }
  .crx .btn { background:#f59e0b; color:#1a0f00; padding:9px 13px; border:none; border-radius:7px; font-family:inherit; font-size:10.5px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; cursor:pointer; }
  .crx .btn:hover { background:#fbbf24; }
  .crx .btn.ghost { background:transparent; color:#cfd6da; border:1px solid #2a2a35; }
  .crx .btn.ghost:hover { border-color:#f59e0b; color:#f59e0b; }
  .crx .btn.cyan { background:#67e8f9; color:#04161b; }
  .crx .btn.cyan:hover { background:#8af0ff; }
  .crx .btns { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:6px; }
  .crx .btns .full { grid-column:1/-1; }
  .crx .stats { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:13px; }
  .crx .stat { background:#0a0a0c; border:1px solid #232330; border-radius:7px; padding:8px 10px; }
  .crx .stat .k { font-size:9px; letter-spacing:0.12em; text-transform:uppercase; color:#9aa0aa; }
  .crx .stat .v { font-size:17px; color:#67e8f9; font-weight:700; margin-top:3px; }
  .crx .help { font-size:10.5px; color:#9aa0aa; line-height:1.65; margin-top:11px; }
  .crx .help b { color:#e8e8ee; }
  .crx .help code { color:#fbbf24; background:#0a0a0c; padding:1px 5px; border-radius:3px; }
  .crx .badge { display:inline-block; font-size:9px; padding:2px 7px; border-radius:4px; background:#1a1a25; color:#86efac; letter-spacing:0.1em; margin-left:6px; }
  .crx .seg { display:flex; gap:6px; }
  .crx .seg .opt { flex:1; text-align:center; background:#0a0a0c; border:1px solid #2a2a35; color:#9aa0aa; padding:7px 0; border-radius:6px; font-size:10px; letter-spacing:0.06em; text-transform:uppercase; cursor:pointer; }
  .crx .seg .opt.on { border-color:#fbbf24; color:#fbbf24; }

  /* self-assessment */
  .crx .quiz { max-width:840px; }
  .crx .q { background:#11131a; border:1px solid #2a2a35; border-radius:10px; padding:14px 16px; margin-bottom:13px; }
  .crx .q .qt { font-size:13px; color:#f3f3f8; line-height:1.55; margin-bottom:11px; }
  .crx .q .qt b { color:#f59e0b; }
  .crx .opt-a { display:block; padding:9px 12px; border:1px solid #2a2a35; border-radius:7px; margin-bottom:7px; font-size:12.5px; color:#cfd6da; cursor:pointer; transition:all .12s; }
  .crx .opt-a:hover { border-color:#3a3a48; }
  .crx .opt-a.sel { border-color:#67e8f9; color:#67e8f9; }
  .crx .opt-a.correct { border-color:#86efac; background:rgba(134,239,172,0.08); color:#86efac; }
  .crx .opt-a.wrong { border-color:#fca5a5; background:rgba(252,165,165,0.08); color:#fca5a5; }
  .crx .q .expl { font-size:11.5px; color:#9aa0aa; line-height:1.6; margin-top:8px; padding-top:8px; border-top:1px solid #1c1c26; display:none; }
  .crx .q .expl.show { display:block; }
  .crx .q .expl b { color:#86efac; }
  .crx .q.bad .expl b { color:#fca5a5; }
</style>
<main class="crx">
  <div class="wrap">
    <a class="back" href="/aquintutor/labs">&#8592; All virtual labs</a>
    <div class="eyebrow">Chemical Reaction Engineering &middot; Virtual lab</div>
    <h1>Reactor design, kinetics &amp; <em>conversion</em></h1>
    <p class="lede">Six self-contained experiments, each solved live in your browser with hand-rolled numerics &mdash; no libraries. The rate ODEs are integrated with RK4, the design equations are solved on the fly, and every plot is drawn on a canvas. Pick an experiment on the left, then move through Aim, Theory, Procedure, the live Simulation, a graded Self-assessment, and References.</p>

    <div class="shell">
      <!-- ===================== SIDEBAR ===================== -->
      <aside class="sidebar">
        <div class="stitle">Experiments</div>
        <div class="exp-item on" data-exp="1"><span class="num">1</span><span class="nm">Batch reactor kinetics</span></div>
        <div class="exp-item" data-exp="2"><span class="num">2</span><span class="nm">CSTR steady-state design</span></div>
        <div class="exp-item" data-exp="3"><span class="num">3</span><span class="nm">PFR &mdash; plug-flow reactor</span></div>
        <div class="exp-item" data-exp="4"><span class="num">4</span><span class="nm">CSTR vs PFR &mdash; Levenspiel</span></div>
        <div class="exp-item" data-exp="5"><span class="num">5</span><span class="nm">Arrhenius temperature law</span></div>
        <div class="exp-item" data-exp="6"><span class="num">6</span><span class="nm">Reaction order determination</span></div>
      </aside>

      <!-- ===================== MAIN PANEL ===================== -->
      <div class="main">

        <!-- ============ EXPERIMENT 1 — BATCH REACTOR ============ -->
        <section class="exp on" id="exp-1">
          <h2 class="exp-head">1 &middot; Batch reactor kinetics</h2>
          <div class="exp-sub">Integrating dCA/dt = -k CA^n for zero, first and second order in a stirred tank</div>
          <div class="secbar">
            <button class="stab on" data-sec="aim">Aim</button>
            <button class="stab" data-sec="theory">Theory</button>
            <button class="stab" data-sec="proc">Procedure</button>
            <button class="stab" data-sec="sim">Simulation</button>
            <button class="stab" data-sec="quiz">Self-assessment</button>
            <button class="stab" data-sec="ref">References</button>
          </div>

          <div class="sec aim on"><div class="prose">To study a constant-volume batch reactor by numerically integrating the species mole balance for an irreversible reaction A &rarr; products, for reaction orders 0, 1 and 2; to plot concentration and fractional conversion against time; and to confirm the analytic first-order result CA = CA0 e^(-k t) and half-life t&frac12; = ln2 / k.</div></div>

          <div class="sec theory"><div class="prose">
            <p>In a well-mixed, constant-volume <b>batch reactor</b> there is no inflow or outflow. The mole balance on reactant A reduces to the rate of change of concentration equalling the reaction rate:</p>
            <div class="eqblock">dCA/dt = rA = &minus;k &middot; CA^n</div>
            <p>where <span class="eq">k</span> is the rate constant, <span class="eq">n</span> the reaction order and <span class="eq">CA</span> the concentration of A. The fractional <b>conversion</b> is defined relative to the initial charge:</p>
            <div class="eqblock">X = (CA0 &minus; CA) / CA0&nbsp;&nbsp;&rArr;&nbsp;&nbsp;CA = CA0 (1 &minus; X)</div>
            <p>Closed-form solutions exist for the integer orders, and the simulator's RK4 integrator must reproduce them exactly:</p>
            <div class="eqblock">order 0:&nbsp; CA = CA0 &minus; k t&nbsp;&nbsp;(until CA hits 0)<br>order 1:&nbsp; CA = CA0 e^(&minus;k t),&nbsp; t&frac12; = ln2 / k<br>order 2:&nbsp; 1/CA = 1/CA0 + k t,&nbsp; t&frac12; = 1 / (k CA0)</div>
            <p>Note that only the first-order half-life is independent of the starting concentration &mdash; a fingerprint used to identify reaction order experimentally.</p>
          </div></div>

          <div class="sec proc"><ol class="steps">
            <li>Open the <b>Simulation</b> tab.</li>
            <li>Choose a <b>reaction order</b> (0, 1 or 2) with the segmented control.</li>
            <li>Set the <b>rate constant k</b> and <b>initial concentration CA0</b> with the sliders.</li>
            <li>Press <b>Run</b> and watch the stirred tank fade as A is consumed; the live readouts show CA, X and the instantaneous rate.</li>
            <li>For order 1, read the <b>half-life</b> and check that it equals ln2 / k and does <b>not</b> change when you raise CA0.</li>
            <li>Switch the curve toggle between <b>concentration</b> and <b>conversion</b> and compare the shapes.</li>
          </ol></div>

          <div class="sec sim">
            <div class="layout">
              <div class="panel">
                <h3>Stirred batch reactor <span class="badge" id="batchState">idle</span></h3>
                <canvas id="batchCv" width="660" height="540"></canvas>
                <div class="help"><b>Batch reactor:</b> the tank colour tracks the remaining concentration of A; the lower plot is the live integrated curve. RK4 with dt is used &mdash; toggle to overlay the analytic solution and verify they coincide.</div>
              </div>
              <div>
                <div class="panel">
                  <h3>Kinetics</h3>
                  <div class="row"><label>Order n</label>
                    <div class="seg" style="flex:1" id="batchOrder">
                      <div class="opt" data-n="0">0</div>
                      <div class="opt on" data-n="1">1</div>
                      <div class="opt" data-n="2">2</div>
                    </div>
                  </div>
                  <div class="row"><label>k</label><input type="range" id="bk" min="0.02" max="1.5" step="0.01" value="0.35"><span class="val" id="bkv">0.35</span></div>
                  <div class="row"><label>CA0</label><input type="range" id="bc0" min="0.2" max="4" step="0.1" value="2.0"><span class="val" id="bc0v">2.0</span></div>
                  <div class="row"><label>Speed</label><input type="range" id="bsp" min="0.25" max="4" step="0.25" value="1"><span class="val" id="bspv">1.0x</span></div>
                  <div class="row"><label>Plot</label>
                    <div class="seg" style="flex:1" id="batchPlot">
                      <div class="opt on" data-p="c">CA(t)</div>
                      <div class="opt" data-p="x">X(t)</div>
                    </div>
                  </div>
                  <div class="btns">
                    <button class="btn" id="batchRun">Run</button>
                    <button class="btn ghost" id="batchReset">Reset</button>
                    <button class="btn ghost full" id="batchAnal">Overlay analytic: off</button>
                  </div>
                  <div class="stats">
                    <div class="stat"><div class="k">t (min)</div><div class="v" id="batchT">0</div></div>
                    <div class="stat"><div class="k">CA</div><div class="v" id="batchCA">2.000</div></div>
                    <div class="stat"><div class="k">Conversion X</div><div class="v" id="batchX">0%</div></div>
                    <div class="stat"><div class="k">Rate &minus;rA</div><div class="v" id="batchR">--</div></div>
                    <div class="stat"><div class="k">Half-life t&frac12;</div><div class="v" id="batchHL">--</div></div>
                    <div class="stat"><div class="k">RK4 vs exact</div><div class="v" id="batchErr">--</div></div>
                  </div>
                </div>
                <div class="panel" style="margin-top:13px;">
                  <h3>The math</h3>
                  <div class="help">Integrator: <code>RK4</code> on <code>dCA/dt = -k CA^n</code>. Half-life: order 1 gives <code>ln2/k</code> (independent of CA0); order 2 gives <code>1/(k CA0)</code>. The error stat is the maximum gap between the numeric and analytic curve.</div>
                </div>
              </div>
            </div>
          </div>

          <div class="sec quiz"><div class="quiz" data-quiz="1"></div></div>

          <div class="sec ref"><ul class="refs">
            <li><b>Fogler, H. S.</b> &mdash; Elements of Chemical Reaction Engineering, Ch. 1-5 (Mole Balances, Batch). Pearson.</li>
            <li><b>Levenspiel, O.</b> &mdash; Chemical Reaction Engineering, Ch. 3 (Interpretation of Batch Reactor Data). Wiley.</li>
            <li><b>Virtual Labs (IIT)</b> &mdash; Chemical Engineering: Batch Reactor, vlabs.ac.in.</li>
          </ul></div>
        </section>

        <!-- ============ EXPERIMENT 2 — CSTR ============ -->
        <section class="exp" id="exp-2">
          <h2 class="exp-head">2 &middot; CSTR steady-state design</h2>
          <div class="exp-sub">The design equation V = FA0 X / (&minus;rA) for a continuous stirred-tank reactor</div>
          <div class="secbar">
            <button class="stab on" data-sec="aim">Aim</button>
            <button class="stab" data-sec="theory">Theory</button>
            <button class="stab" data-sec="proc">Procedure</button>
            <button class="stab" data-sec="sim">Simulation</button>
            <button class="stab" data-sec="quiz">Self-assessment</button>
            <button class="stab" data-sec="ref">References</button>
          </div>

          <div class="sec aim on"><div class="prose">To apply the steady-state CSTR design equation to find the exit conversion of a single continuous stirred-tank reactor for a given volume, volumetric flow and reaction kinetics, and to visualise the inlet and outlet streams and the perfectly-mixed contents at the exit concentration.</div></div>

          <div class="sec theory"><div class="prose">
            <p>A <b>CSTR</b> is assumed perfectly mixed, so the exit stream has exactly the contents' composition. A steady-state mole balance on A (in &minus; out + generation = 0) gives the classic design equation:</p>
            <div class="eqblock">V = FA0 &middot; X / (&minus;rA)|exit</div>
            <p>where <span class="eq">FA0 = CA0 &middot; v0</span> is the molar feed rate and the rate is evaluated at the <b>exit</b> conditions <span class="eq">CA = CA0(1&minus;X)</span>. Defining the <b>space time</b> <span class="eq">&tau; = V / v0</span>, for an n-th order reaction:</p>
            <div class="eqblock">&tau; &middot; k &middot; CA0^(n&minus;1) (1&minus;X)^n = X</div>
            <p>For first order this rearranges to a clean closed form; for second order it is a quadratic in X. The simulator solves the implicit equation by bisection so any positive order works:</p>
            <div class="eqblock">order 1:&nbsp; X = k&tau; / (1 + k&tau;)</div>
            <p>Unlike a batch or PFR, the whole CSTR operates at the (low) exit rate, so it generally needs the <b>largest</b> volume for positive-order kinetics.</p>
          </div></div>

          <div class="sec proc"><ol class="steps">
            <li>Open the <b>Simulation</b> tab.</li>
            <li>Pick the <b>order</b>, then set <b>k</b>, feed concentration <b>CA0</b> and volumetric flow <b>v0</b>.</li>
            <li>Adjust the reactor <b>volume V</b> and watch the solver return the steady-state exit conversion.</li>
            <li>Confirm the first-order case against <code>X = k&tau;/(1+k&tau;)</code> using the displayed space time &tau;.</li>
            <li>Increase <b>v0</b> (shorter &tau;) and note conversion falls; increase <b>V</b> and note it rises toward 1.</li>
          </ol></div>

          <div class="sec sim">
            <div class="layout">
              <div class="panel">
                <h3>CSTR apparatus <span class="badge" id="cstrBadge">steady</span></h3>
                <canvas id="cstrCv" width="660" height="540"></canvas>
                <div class="help"><b>CSTR:</b> feed enters top-left at CA0, the tank is uniform at the exit concentration, product leaves bottom-right. The bar shows how exit conversion responds to volume.</div>
              </div>
              <div>
                <div class="panel">
                  <h3>Design inputs</h3>
                  <div class="row"><label>Order n</label>
                    <div class="seg" style="flex:1" id="cstrOrder">
                      <div class="opt" data-n="0">0</div>
                      <div class="opt on" data-n="1">1</div>
                      <div class="opt" data-n="2">2</div>
                    </div>
                  </div>
                  <div class="row"><label>k</label><input type="range" id="ck" min="0.05" max="2" step="0.01" value="0.5"><span class="val" id="ckv">0.50</span></div>
                  <div class="row"><label>CA0</label><input type="range" id="cc0" min="0.2" max="4" step="0.1" value="2.0"><span class="val" id="cc0v">2.0</span></div>
                  <div class="row"><label>v0</label><input type="range" id="cv0" min="0.2" max="5" step="0.1" value="1.0"><span class="val" id="cv0v">1.0</span></div>
                  <div class="row"><label>Volume V</label><input type="range" id="cvol" min="0.1" max="20" step="0.1" value="4.0"><span class="val" id="cvolv">4.0</span></div>
                  <div class="stats">
                    <div class="stat"><div class="k">Space time &tau;</div><div class="v" id="cstrTau">--</div></div>
                    <div class="stat"><div class="k">Damkohler Da</div><div class="v" id="cstrDa">--</div></div>
                    <div class="stat"><div class="k">Exit conversion</div><div class="v" id="cstrX">--</div></div>
                    <div class="stat"><div class="k">Exit CA</div><div class="v" id="cstrCA">--</div></div>
                    <div class="stat"><div class="k">FA0</div><div class="v" id="cstrFA0">--</div></div>
                    <div class="stat"><div class="k">&minus;rA exit</div><div class="v" id="cstrRA">--</div></div>
                  </div>
                </div>
                <div class="panel" style="margin-top:13px;">
                  <h3>The math</h3>
                  <div class="help">Solver: bisection on <code>tau*k*CA0^(n-1)*(1-X)^n - X = 0</code> over X in [0,1). Da = <code>k*tau*CA0^(n-1)</code>. The whole tank reacts at the slow exit rate &mdash; that is why CSTRs are volume-hungry.</div>
                </div>
              </div>
            </div>
          </div>

          <div class="sec quiz"><div class="quiz" data-quiz="2"></div></div>

          <div class="sec ref"><ul class="refs">
            <li><b>Fogler, H. S.</b> &mdash; Elements of Chemical Reaction Engineering, Ch. 2 &amp; 5 (Conversion and Reactor Sizing, CSTR). Pearson.</li>
            <li><b>Levenspiel, O.</b> &mdash; Chemical Reaction Engineering, Ch. 5 (Ideal Reactors for a Single Reaction). Wiley.</li>
            <li><b>Virtual Labs (IIT)</b> &mdash; Chemical Engineering: Continuous Stirred Tank Reactor, vlabs.ac.in.</li>
          </ul></div>
        </section>

        <!-- ============ EXPERIMENT 3 — PFR ============ -->
        <section class="exp" id="exp-3">
          <h2 class="exp-head">3 &middot; PFR &mdash; plug-flow reactor</h2>
          <div class="exp-sub">Integrating dX/dV = (&minus;rA)/FA0 down a tubular reactor</div>
          <div class="secbar">
            <button class="stab on" data-sec="aim">Aim</button>
            <button class="stab" data-sec="theory">Theory</button>
            <button class="stab" data-sec="proc">Procedure</button>
            <button class="stab" data-sec="sim">Simulation</button>
            <button class="stab" data-sec="quiz">Self-assessment</button>
            <button class="stab" data-sec="ref">References</button>
          </div>

          <div class="sec aim on"><div class="prose">To integrate the plug-flow design equation along the length of a tubular reactor, obtaining conversion as a function of cumulative reactor volume, and to confirm the first-order analytic result X = 1 &minus; e^(&minus;k&tau;) where &tau; = V/v0.</div></div>

          <div class="sec theory"><div class="prose">
            <p>In an ideal <b>PFR</b> the fluid moves as discrete plugs with no axial mixing; composition varies continuously down the tube. A differential mole balance over a slice <span class="eq">dV</span> gives the design equation:</p>
            <div class="eqblock">dX/dV = (&minus;rA) / FA0&nbsp;&nbsp;with&nbsp;&nbsp;&minus;rA = k CA0^n (1&minus;X)^n</div>
            <p>Because <span class="eq">FA0 = CA0 v0</span>, dividing through introduces the space time and the integral becomes purely a function of <span class="eq">k&tau;</span>. Integrating from the inlet (X = 0) to volume V:</p>
            <div class="eqblock">order 1:&nbsp; X = 1 &minus; e^(&minus;k&tau;)<br>order 2:&nbsp; X = k&tau; CA0 / (1 + k&tau; CA0)</div>
            <p>The simulator marches X forward in V with RK4, so the curve is exact even for non-integer orders. Compare it to the CSTR result of the same &tau;: the PFR always converts more for positive order because it exploits the high inlet rate.</p>
          </div></div>

          <div class="sec proc"><ol class="steps">
            <li>Open the <b>Simulation</b> tab.</li>
            <li>Set <b>order</b>, <b>k</b>, <b>CA0</b> and the volumetric flow <b>v0</b>.</li>
            <li>Drag the <b>reactor volume</b> slider; the marker sweeps down the tube and the conversion profile fills in.</li>
            <li>Note the tube colour gradient &mdash; dark feed at the inlet fading to converted product at the outlet.</li>
            <li>For order 1, verify the exit conversion equals <code>1 - exp(-k*tau)</code> shown in the readout.</li>
            <li>Switch the overlay to compare the PFR profile with the single-CSTR exit at the same &tau;.</li>
          </ol></div>

          <div class="sec sim">
            <div class="layout">
              <div class="panel">
                <h3>Tubular plug-flow reactor <span class="badge" id="pfrBadge">flowing</span></h3>
                <canvas id="pfrCv" width="660" height="540"></canvas>
                <div class="help"><b>PFR:</b> the top schematic shows the concentration gradient along the tube; the lower plot is conversion X versus cumulative volume. The dashed line marks the equivalent single-CSTR exit conversion.</div>
              </div>
              <div>
                <div class="panel">
                  <h3>Design inputs</h3>
                  <div class="row"><label>Order n</label>
                    <div class="seg" style="flex:1" id="pfrOrder">
                      <div class="opt" data-n="0">0</div>
                      <div class="opt on" data-n="1">1</div>
                      <div class="opt" data-n="2">2</div>
                    </div>
                  </div>
                  <div class="row"><label>k</label><input type="range" id="pk" min="0.05" max="2" step="0.01" value="0.5"><span class="val" id="pkv">0.50</span></div>
                  <div class="row"><label>CA0</label><input type="range" id="pc0" min="0.2" max="4" step="0.1" value="2.0"><span class="val" id="pc0v">2.0</span></div>
                  <div class="row"><label>v0</label><input type="range" id="pv0" min="0.2" max="5" step="0.1" value="1.0"><span class="val" id="pv0v">1.0</span></div>
                  <div class="row"><label>Volume V</label><input type="range" id="pvol" min="0.1" max="20" step="0.1" value="6.0"><span class="val" id="pvolv">6.0</span></div>
                  <div class="row"><label>Compare</label>
                    <div class="seg" style="flex:1" id="pfrCmp">
                      <div class="opt on" data-c="0">PFR only</div>
                      <div class="opt" data-c="1">vs CSTR</div>
                    </div>
                  </div>
                  <div class="stats">
                    <div class="stat"><div class="k">Space time &tau;</div><div class="v" id="pfrTau">--</div></div>
                    <div class="stat"><div class="k">Exit conversion</div><div class="v" id="pfrX">--</div></div>
                    <div class="stat"><div class="k">Exit CA</div><div class="v" id="pfrCA">--</div></div>
                    <div class="stat"><div class="k">CSTR X (same &tau;)</div><div class="v" id="pfrXc">--</div></div>
                  </div>
                </div>
                <div class="panel" style="margin-top:13px;">
                  <h3>The math</h3>
                  <div class="help">Integrator: <code>RK4</code> on <code>dX/dV = k*CA0^(n-1)*(1-X)^n / v0</code>. The result depends only on <code>k*tau</code>. For order 1 the exact exit conversion is <code>1 - exp(-k*tau)</code>.</div>
                </div>
              </div>
            </div>
          </div>

          <div class="sec quiz"><div class="quiz" data-quiz="3"></div></div>

          <div class="sec ref"><ul class="refs">
            <li><b>Fogler, H. S.</b> &mdash; Elements of Chemical Reaction Engineering, Ch. 2 &amp; 5 (Tubular Reactors). Pearson.</li>
            <li><b>Levenspiel, O.</b> &mdash; Chemical Reaction Engineering, Ch. 5 (Plug Flow Reactor). Wiley.</li>
            <li><b>Virtual Labs (IIT)</b> &mdash; Chemical Engineering: Plug Flow Reactor, vlabs.ac.in.</li>
          </ul></div>
        </section>

        <!-- ============ EXPERIMENT 4 — CSTR vs PFR / LEVENSPIEL ============ -->
        <section class="exp" id="exp-4">
          <h2 class="exp-head">4 &middot; CSTR vs PFR &mdash; Levenspiel plot</h2>
          <div class="exp-sub">Comparing required volumes via the area under 1/(&minus;rA) versus X</div>
          <div class="secbar">
            <button class="stab on" data-sec="aim">Aim</button>
            <button class="stab" data-sec="theory">Theory</button>
            <button class="stab" data-sec="proc">Procedure</button>
            <button class="stab" data-sec="sim">Simulation</button>
            <button class="stab" data-sec="quiz">Self-assessment</button>
            <button class="stab" data-sec="ref">References</button>
          </div>

          <div class="sec aim on"><div class="prose">To compare the reactor volume required by a single CSTR and a single PFR to reach the same target conversion with identical kinetics, using the Levenspiel plot of 1/(&minus;rA) against X, and to see graphically why the PFR is smaller for positive-order reactions.</div></div>

          <div class="sec theory"><div class="prose">
            <p>Both ideal reactor volumes are integrals (or areas) on the same axes. Plotting the reciprocal rate <span class="eq">1/(&minus;rA)</span> against conversion <span class="eq">X</span> &mdash; the <b>Levenspiel plot</b> &mdash; turns sizing into reading an area:</p>
            <div class="eqblock">V_PFR = FA0 &middot; &int;&#8320;^X dX / (&minus;rA)&nbsp;&nbsp;(area under the curve)<br>V_CSTR = FA0 &middot; X / (&minus;rA)|X&nbsp;&nbsp;(rectangle to the exit point)</div>
            <p>For positive-order kinetics the rate falls (so 1/(&minus;rA) rises) as X grows. The PFR uses the small area under the rising curve; the CSTR is forced to use the full-height rectangle evaluated at the slow exit rate. Hence:</p>
            <div class="eqblock">V_PFR &lt; V_CSTR&nbsp;&nbsp;(positive order)</div>
            <p>The ratio V_CSTR / V_PFR grows with target conversion and with reaction order. For autocatalytic or negative-order behaviour the inequality can reverse &mdash; the geometry tells you instantly.</p>
          </div></div>

          <div class="sec proc"><ol class="steps">
            <li>Open the <b>Simulation</b> tab.</li>
            <li>Choose <b>order</b>, <b>k</b> and feed <b>CA0</b>.</li>
            <li>Slide the <b>target conversion X</b> and watch both shaded regions grow: the area (PFR) and the rectangle (CSTR).</li>
            <li>Read the two required volumes and their <b>ratio</b>; confirm PFR &lt; CSTR for orders 1 and 2.</li>
            <li>Push X toward 1 and observe both areas blow up &mdash; the last few percent of conversion are the most expensive.</li>
          </ol></div>

          <div class="sec sim">
            <div class="layout">
              <div class="panel">
                <h3>Levenspiel plot <span class="badge" id="levBadge">PFR smaller</span></h3>
                <canvas id="levCv" width="660" height="540"></canvas>
                <div class="help"><b>Levenspiel:</b> the orange shaded <b>area</b> is V_PFR / FA0; the cyan dashed <b>rectangle</b> is V_CSTR / FA0. Both share the same 1/(&minus;rA) curve.</div>
              </div>
              <div>
                <div class="panel">
                  <h3>Kinetics and target</h3>
                  <div class="row"><label>Order n</label>
                    <div class="seg" style="flex:1" id="levOrder">
                      <div class="opt" data-n="0">0</div>
                      <div class="opt on" data-n="1">1</div>
                      <div class="opt" data-n="2">2</div>
                    </div>
                  </div>
                  <div class="row"><label>k</label><input type="range" id="lk" min="0.05" max="2" step="0.01" value="0.5"><span class="val" id="lkv">0.50</span></div>
                  <div class="row"><label>CA0</label><input type="range" id="lc0" min="0.2" max="4" step="0.1" value="2.0"><span class="val" id="lc0v">2.0</span></div>
                  <div class="row"><label>Target X</label><input type="range" id="lx" min="0.05" max="0.95" step="0.01" value="0.8"><span class="val" id="lxv">0.80</span></div>
                  <div class="stats">
                    <div class="stat"><div class="k">V_PFR / FA0</div><div class="v" id="levVp">--</div></div>
                    <div class="stat"><div class="k">V_CSTR / FA0</div><div class="v" id="levVc">--</div></div>
                    <div class="stat"><div class="k">Volume ratio</div><div class="v" id="levRatio">--</div></div>
                    <div class="stat"><div class="k">Smaller reactor</div><div class="v" id="levWin">--</div></div>
                  </div>
                </div>
                <div class="panel" style="margin-top:13px;">
                  <h3>The math</h3>
                  <div class="help">PFR: composite-Simpson integral of <code>1/(-rA)</code> from 0 to X. CSTR: rectangle <code>X / (-rA)|X</code>. Ratio = V_CSTR / V_PFR. For positive order the curve rises, so the rectangle beats the area &mdash; PFR wins.</div>
                </div>
              </div>
            </div>
          </div>

          <div class="sec quiz"><div class="quiz" data-quiz="4"></div></div>

          <div class="sec ref"><ul class="refs">
            <li><b>Levenspiel, O.</b> &mdash; Chemical Reaction Engineering, Ch. 5-6 (Single &amp; Multiple Reactor Systems). Wiley.</li>
            <li><b>Fogler, H. S.</b> &mdash; Elements of Chemical Reaction Engineering, Ch. 2 (Reactor Sizing, Levenspiel plots). Pearson.</li>
            <li><b>Virtual Labs (IIT)</b> &mdash; Chemical Engineering: Comparison of Reactors, vlabs.ac.in.</li>
          </ul></div>
        </section>

        <!-- ============ EXPERIMENT 5 — ARRHENIUS ============ -->
        <section class="exp" id="exp-5">
          <h2 class="exp-head">5 &middot; Arrhenius temperature law</h2>
          <div class="exp-sub">k = A exp(&minus;Ea/RT): the ln k versus 1/T straight line</div>
          <div class="secbar">
            <button class="stab on" data-sec="aim">Aim</button>
            <button class="stab" data-sec="theory">Theory</button>
            <button class="stab" data-sec="proc">Procedure</button>
            <button class="stab" data-sec="sim">Simulation</button>
            <button class="stab" data-sec="quiz">Self-assessment</button>
            <button class="stab" data-sec="ref">References</button>
          </div>

          <div class="sec aim on"><div class="prose">To study how the rate constant depends on temperature through the Arrhenius equation, to construct the linearised ln k versus 1/T plot, to read the activation energy Ea from its slope and the pre-exponential factor A from its intercept, and to see how temperature changes shift reactor conversion.</div></div>

          <div class="sec theory"><div class="prose">
            <p>The <b>Arrhenius equation</b> captures the strong temperature sensitivity of most reaction rates:</p>
            <div class="eqblock">k = A &middot; exp(&minus;Ea / (R T))</div>
            <p>where <span class="eq">A</span> is the pre-exponential (frequency) factor, <span class="eq">Ea</span> the activation energy, <span class="eq">R = 8.314 J/mol&middot;K</span> and <span class="eq">T</span> the absolute temperature. Taking logarithms linearises it:</p>
            <div class="eqblock">ln k = ln A &minus; (Ea / R) &middot; (1/T)</div>
            <p>So a plot of <span class="eq">ln k</span> against <span class="eq">1/T</span> is a straight line of slope <span class="eq">&minus;Ea/R</span> and intercept <span class="eq">ln A</span>. Measuring k at two temperatures is enough:</p>
            <div class="eqblock">ln(k2/k1) = &minus;(Ea/R)(1/T2 &minus; 1/T1)</div>
            <p>A rough rule of thumb: a 10 K rise near room temperature roughly doubles many rates &mdash; the simulator lets you check this for any Ea you set.</p>
          </div></div>

          <div class="sec proc"><ol class="steps">
            <li>Open the <b>Simulation</b> tab.</li>
            <li>Set the activation energy <b>Ea</b> and pre-exponential factor <b>A</b> with the sliders.</li>
            <li>Drag the <b>temperature</b> marker along the curve; the dot moves along the Arrhenius and ln-plot lines together.</li>
            <li>Read the recovered <b>slope</b> (&minus;Ea/R) and <b>intercept</b> (ln A) from the fitted line and confirm they match the inputs.</li>
            <li>Use the <b>k(T2)/k(T1)</b> readout to test the 10 K doubling rule for different Ea values.</li>
          </ol></div>

          <div class="sec sim">
            <div class="layout">
              <div class="panel">
                <h3>Arrhenius plots <span class="badge" id="arrBadge">linear in 1/T</span></h3>
                <canvas id="arrCv" width="660" height="540"></canvas>
                <div class="help"><b>Arrhenius:</b> top is k versus T (curved); bottom is ln k versus 1/T (straight). The slope is &minus;Ea/R; the intercept is ln A. Both dots track the temperature slider.</div>
              </div>
              <div>
                <div class="panel">
                  <h3>Parameters</h3>
                  <div class="row"><label>Ea kJ/mol</label><input type="range" id="aEa" min="10" max="120" step="1" value="60"><span class="val" id="aEav">60</span></div>
                  <div class="row"><label>ln A</label><input type="range" id="aA" min="5" max="30" step="0.5" value="18"><span class="val" id="aAv">18</span></div>
                  <div class="row"><label>T (K)</label><input type="range" id="aT" min="280" max="500" step="1" value="350"><span class="val" id="aTv">350</span></div>
                  <div class="stats">
                    <div class="stat"><div class="k">k at T</div><div class="v" id="arrK">--</div></div>
                    <div class="stat"><div class="k">ln k</div><div class="v" id="arrLnk">--</div></div>
                    <div class="stat"><div class="k">Slope (&minus;Ea/R)</div><div class="v" id="arrSlope">--</div></div>
                    <div class="stat"><div class="k">Intercept (ln A)</div><div class="v" id="arrInt">--</div></div>
                    <div class="stat"><div class="k">k(T+10)/k(T)</div><div class="v" id="arrRatio">--</div></div>
                    <div class="stat"><div class="k">Recovered Ea</div><div class="v" id="arrEaRec">--</div></div>
                  </div>
                </div>
                <div class="panel" style="margin-top:13px;">
                  <h3>The math</h3>
                  <div class="help">A least-squares line is fit to sampled <code>(1/T, ln k)</code> points; its slope <code>m</code> gives <code>Ea = -m*R</code> and intercept gives <code>ln A</code>. Recovered Ea should equal your input to within rounding.</div>
                </div>
              </div>
            </div>
          </div>

          <div class="sec quiz"><div class="quiz" data-quiz="5"></div></div>

          <div class="sec ref"><ul class="refs">
            <li><b>Fogler, H. S.</b> &mdash; Elements of Chemical Reaction Engineering, Ch. 3 (Rate Laws, Arrhenius). Pearson.</li>
            <li><b>Levenspiel, O.</b> &mdash; Chemical Reaction Engineering, Ch. 2 (Kinetics of Homogeneous Reactions). Wiley.</li>
            <li><b>Atkins, P. &amp; de Paula, J.</b> &mdash; Physical Chemistry, Ch. on Reaction Kinetics. Oxford.</li>
          </ul></div>
        </section>

        <!-- ============ EXPERIMENT 6 — ORDER DETERMINATION ============ -->
        <section class="exp" id="exp-6">
          <h2 class="exp-head">6 &middot; Reaction order determination</h2>
          <div class="exp-sub">Integral method: which linearisation of concentration-time data is straight</div>
          <div class="secbar">
            <button class="stab on" data-sec="aim">Aim</button>
            <button class="stab" data-sec="theory">Theory</button>
            <button class="stab" data-sec="proc">Procedure</button>
            <button class="stab" data-sec="sim">Simulation</button>
            <button class="stab" data-sec="quiz">Self-assessment</button>
            <button class="stab" data-sec="ref">References</button>
          </div>

          <div class="sec aim on"><div class="prose">To determine the order of a reaction from synthetic batch concentration-time data using the integral method &mdash; testing the zero, first and second-order linearisations, identifying which one is a straight line by its correlation coefficient, and recovering the rate constant from the slope.</div></div>

          <div class="sec theory"><div class="prose">
            <p>The <b>integral method</b> assumes an order, integrates the batch rate law and checks whether the data fall on a straight line. Each order has its own linear coordinate:</p>
            <div class="eqblock">order 0:&nbsp; CA&nbsp;&nbsp;vs t&nbsp;&nbsp;(slope = &minus;k)<br>order 1:&nbsp; ln CA&nbsp;&nbsp;vs t&nbsp;&nbsp;(slope = &minus;k)<br>order 2:&nbsp; 1/CA&nbsp;&nbsp;vs t&nbsp;&nbsp;(slope = +k)</div>
            <p>The correct order is the one whose transformed plot is straight &mdash; quantified by the coefficient of determination <span class="eq">R&sup2;</span> closest to 1. The rate constant follows from the slope of that best-fit line.</p>
            <div class="eqblock">R&sup2; = 1 &minus; SS_res / SS_tot</div>
            <p>The simulator generates noisy data from a hidden true order and asks you to identify it &mdash; just as a real kinetic study would, where measurement scatter makes the wrong orders look almost-but-not-quite linear.</p>
          </div></div>

          <div class="sec proc"><ol class="steps">
            <li>Open the <b>Simulation</b> tab.</li>
            <li>Press <b>New data set</b> to generate noisy CA(t) measurements from a hidden true order.</li>
            <li>Toggle between the three linearisations and read each one's <b>R&sup2;</b>.</li>
            <li>Pick the order whose plot is straightest (highest R&sup2;) and read off the recovered <b>k</b>.</li>
            <li>Press <b>Reveal</b> to check your call against the hidden true order, then add or remove noise and repeat.</li>
          </ol></div>

          <div class="sec sim">
            <div class="layout">
              <div class="panel">
                <h3>Integral-method fit <span class="badge" id="ordBadge">fit a line</span></h3>
                <canvas id="ordCv" width="660" height="540"></canvas>
                <div class="help"><b>Order determination:</b> the points are the (transformed) data for the chosen trial order; the line is its least-squares fit. The straight one &mdash; highest R&sup2; &mdash; reveals the true order.</div>
              </div>
              <div>
                <div class="panel">
                  <h3>Analysis</h3>
                  <div class="row"><label>Trial order</label>
                    <div class="seg" style="flex:1" id="ordTrial">
                      <div class="opt" data-n="0">CA</div>
                      <div class="opt on" data-n="1">ln CA</div>
                      <div class="opt" data-n="2">1/CA</div>
                    </div>
                  </div>
                  <div class="row"><label>Noise</label><input type="range" id="onz" min="0" max="0.08" step="0.005" value="0.02"><span class="val" id="onzv">0.020</span></div>
                  <div class="btns">
                    <button class="btn" id="ordNew">New data set</button>
                    <button class="btn ghost" id="ordReveal">Reveal</button>
                  </div>
                  <div class="stats">
                    <div class="stat"><div class="k">R&sup2; order 0</div><div class="v" id="ordR0">--</div></div>
                    <div class="stat"><div class="k">R&sup2; order 1</div><div class="v" id="ordR1">--</div></div>
                    <div class="stat"><div class="k">R&sup2; order 2</div><div class="v" id="ordR2">--</div></div>
                    <div class="stat"><div class="k">Best order</div><div class="v" id="ordBest">--</div></div>
                    <div class="stat"><div class="k">Recovered k</div><div class="v" id="ordK">--</div></div>
                    <div class="stat"><div class="k">True order</div><div class="v" id="ordTrue">hidden</div></div>
                  </div>
                </div>
                <div class="panel" style="margin-top:13px;">
                  <h3>The math</h3>
                  <div class="help">Each trial transforms CA, fits a line by least squares, and reports <code>R-squared</code>. The order with the highest R-squared is the answer; its slope magnitude is the rate constant <code>k</code>.</div>
                </div>
              </div>
            </div>
          </div>

          <div class="sec quiz"><div class="quiz" data-quiz="6"></div></div>

          <div class="sec ref"><ul class="refs">
            <li><b>Levenspiel, O.</b> &mdash; Chemical Reaction Engineering, Ch. 3 (Interpretation of Batch Reactor Data, integral &amp; differential methods). Wiley.</li>
            <li><b>Fogler, H. S.</b> &mdash; Elements of Chemical Reaction Engineering, Ch. 7 (Collection and Analysis of Rate Data). Pearson.</li>
            <li><b>Virtual Labs (IIT)</b> &mdash; Chemical Engineering: Determination of Order of Reaction, vlabs.ac.in.</li>
          </ul></div>
        </section>

      </div>
    </div>
  </div>
</main>

<script is:inline>
