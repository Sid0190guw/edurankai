      // legend
      ctx.font = '9px Geist Mono, monospace'; ctx.textAlign = 'left';
      ctx.fillStyle = '#f59e0b'; ctx.fillText('PFR  X = ' + fmt(result.X * 100, 1) + '%', box.x + 8, box.y + 16);
      if (st.cmp === 1) { ctx.fillStyle = '#67e8f9'; ctx.fillText('CSTR (same tau)  X = ' + fmt(result.Xc * 100, 1) + '%', box.x + 8, box.y + 30); }
