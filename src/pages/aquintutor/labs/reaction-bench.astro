  // ===================================================================
  // EXPERIMENT 2 — CSTR
  // ===================================================================
  (function () {
    var cv = $('cstrCv'); if (!cv) return;
    var ctx = cv.getContext('2d'), W = cv.width, H = cv.height;
    var st = { k: 0.5, CA0: 2.0, v0: 1.0, V: 4.0, n: 1, phase: 0 };

