    if (a >= 100) return v.toFixed(0);
    if (a >= 10) return v.toFixed(1);
    return v.toFixed(2);
  }
  function mapX(box, opts, v) { return box.x + box.w * (v - opts.xmin) / (opts.xmax - opts.xmin); }
  function mapY(box, opts, v) { return box.y + box.h * (1 - (v - opts.ymin) / (opts.ymax - opts.ymin)); }
  function plotLine(ctx, box, opts, pts, color, lw) {
    ctx.save();
