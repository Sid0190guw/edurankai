          }
          acc += seglens[i - 1];
        }
        ctx.beginPath(); ctx.arc(sx, sy, 3.5, 0, Math.PI * 2); ctx.fill();
      }
    }
    st.n = parseInt(ordSeg.get(), 10);
    recompute();
    (function anim() { st.phase += 0.012; draw(); requestAnimationFrame(anim); })();
  })();

  // ===================================================================
  // EXPERIMENT 3 — PFR
