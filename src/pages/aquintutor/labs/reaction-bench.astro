  // ===================================================================
  // EXPERIMENT 4 — LEVENSPIEL / CSTR vs PFR
  // ===================================================================
  (function () {
    var cv = $('levCv'); if (!cv) return;
    var ctx = cv.getContext('2d'), W = cv.width, H = cv.height;
    var st = { k: 0.5, CA0: 2.0, n: 1, Xt: 0.8 };

    var ordSeg = segment('levOrder', 'data-n', function (v) { st.n = parseInt(v, 10); recompute(); });
    function bindRange(id, vid, key, fmtfn) {
      var el = $(id), lab = $(vid);
      el.addEventListener('input', function () { st[key] = parseFloat(el.value); lab.textContent = fmtfn(st[key]); recompute(); });
    }
    bindRange('lk', 'lkv', 'k', function (v) { return fmt(v, 2); });
    bindRange('lc0', 'lc0v', 'CA0', function (v) { return fmt(v, 1); });
    bindRange('lx', 'lxv', 'Xt', function (v) { return fmt(v, 2); });

    function recip(X) { var r = rateX(st.k, st.CA0, st.n, X); return r <= 1e-9 ? 1e9 : 1 / r; }
    var result = { Vp: 0, Vc: 0, ratio: 0 };
    function recompute() {
