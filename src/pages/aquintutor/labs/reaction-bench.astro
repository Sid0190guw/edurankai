    var st = { k: 0.35, CA0: 2.0, n: 1, speed: 1, t: 0, CA: 2.0, running: false, plot: 'c', analytic: false, hist: [], anaHist: [], maxErr: 0, tMax: 24 };

    var ordSeg = segment('batchOrder', 'data-n', function (v) { st.n = parseInt(v, 10); reset(); });
    var plotSeg = segment('batchPlot', 'data-p', function (v) { st.plot = v; draw(); });

    function bindRange(id, vid, key, fmtfn) {
