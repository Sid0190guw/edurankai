  (function () {
    var cv = $('pfrCv'); if (!cv) return;
    var ctx = cv.getContext('2d'), W = cv.width, H = cv.height;
    var st = { k: 0.5, CA0: 2.0, v0: 1.0, V: 6.0, n: 1, cmp: 0, phase: 0 };

    var ordSeg = segment('pfrOrder', 'data-n', function (v) { st.n = parseInt(v, 10); recompute(); });
    var cmpSeg = segment('pfrCmp', 'data-c', function (v) { st.cmp = parseInt(v, 10); recompute(); });
    function bindRange(id, vid, key, fmtfn) {
      var el = $(id), lab = $(vid);
      el.addEventListener('input', function () { st[key] = parseFloat(el.value); lab.textContent = fmtfn(st[key]); recompute(); });
    }
    bindRange('pk', 'pkv', 'k', function (v) { return fmt(v, 2); });
    bindRange('pc0', 'pc0v', 'CA0', function (v) { return fmt(v, 1); });
    bindRange('pv0', 'pv0v', 'v0', function (v) { return fmt(v, 1); });
    bindRange('pvol', 'pvolv', 'V', function (v) { return fmt(v, 1); });

    var profile = [], result = { X: 0, tau: 0, CA: 0, Xc: 0 };
    function recompute() {
      var Vmax = 20; // axis volume
      profile = [];
      var X = 0, steps = 400, dV = Vmax / steps;
      profile.push([0, 0]);
      for (var i = 0; i < steps; i++) {
        X = rk4PFR(X, st.k, st.CA0, st.n, st.v0, dV);
        profile.push([(i + 1) * dV, X]);
      }
      // exit X at current volume V (interpolate)
      var idx = clamp(Math.round(st.V / dV), 0, steps);
      var Xexit = profile[idx][1];
      var tau = st.V / st.v0;
      var CA = st.CA0 * (1 - Xexit);
      var Xc = cstrSolve(st.k, st.CA0, st.n, tau);
      result = { X: Xexit, tau: tau, CA: CA, Xc: Xc, Vmax: Vmax };
      $('pfrTau').textContent = fmt(tau, 2);
      $('pfrX').textContent = fmt(Xexit * 100, 1) + '%';
      $('pfrCA').textContent = fmt(CA, 3);
      $('pfrXc').textContent = fmt(Xc * 100, 1) + '%';
      $('pfrBadge').textContent = Xexit > 0.9 ? 'near complete' : 'flowing';
      draw();
    }
    function draw() {
      clearCanvas(ctx, W, H);
      // ---- tube schematic (top) ----
      var tx = 50, ty = 30, tw = W - 100, th = 70;
      var frac = result.X; // exit conversion
      // gradient along tube: dark feed -> light product
      var grad = ctx.createLinearGradient(tx, 0, tx + tw, 0);
      // colour ramps by local conversion at each point of current V window
      var Vmax = result.Vmax || 20;
      for (var g = 0; g <= 10; g++) {
        var vAt = (st.V) * g / 10;
        var idx = clamp(Math.round(vAt / (Vmax / 400)), 0, 400);
        var xl = profile[idx] ? profile[idx][1] : 0;
        var fr = 1 - xl;
        var rr = Math.round(60 + 180 * fr), gg = Math.round(165 - 30 * fr), bb = Math.round(70 + 110 * (1 - fr));
        grad.addColorStop(g / 10, 'rgba(' + rr + ',' + gg + ',' + bb + ',0.75)');
      }
      ctx.fillStyle = grad;
      ctx.fillRect(tx, ty, tw, th);
      ctx.strokeStyle = '#4a4a58'; ctx.lineWidth = 3; ctx.strokeRect(tx, ty, tw, th);
      // flow particles inside the tube
      st.phase += 0.0;
      ctx.fillStyle = 'rgba(255,255,255,0.16)';
      for (var p = 0; p < 18; p++) {
