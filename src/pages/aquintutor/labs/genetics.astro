---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Genetics lab — mono- and dihybrid Punnett squares. Real gamete enumeration
// and offspring tallying, drawn as a glowing grid with genotype + phenotype
// ratio bars and an offspring population of phenotype-coloured dots. High-DPI
// canvas, no libraries.
---
<BaseLayout title="Genetics lab · Virtual Labs · AquinTutor" description="Cross two parents and watch the Punnett square fill in — real gamete combinations, genotype and phenotype ratios, and an offspring population.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1320px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:18px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:290px minmax(0,1fr); gap:18px; } @media(max-width:900px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:16px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 12px; }
  .lb-row{ display:grid; gap:9px; } .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.1em; text-transform:uppercase; color:#8ea0be; font-weight:700; }
  .lb-row select{ width:100%; background:#080a12; border:1px solid #1e2740; color:#fff; padding:8px 10px; border-radius:6px; font-size:13px; font-family:'Geist Mono',monospace; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); }
  .lb-stage canvas{ display:block; width:100%; height:auto; }
  .lb-metric{ font-family:'Geist Mono',monospace; font-size:12px; padding:5px 0; border-bottom:1px solid #141a2c; color:#cfd6da; } .lb-metric:last-child{ border-bottom:none; } .lb-metric b{ color:#5ee7ff; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">Biology · Inheritance</p>
      <h1 class="lb-title">Punnett <em>square</em>.</h1>
    </div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Cross</h3><div class="lb-row">
        <label>Type</label><select id="type"><option value="mono" selected>Monohybrid (1 gene)</option><option value="di">Dihybrid (2 genes)</option></select>
        <label>Parent 1 · gene A</label><select id="p1a"><option>AA</option><option selected>Aa</option><option>aa</option></select>
        <label>Parent 2 · gene A</label><select id="p2a"><option>AA</option><option selected>Aa</option><option>aa</option></select>
        <label class="dionly">Parent 1 · gene B</label><select id="p1b" class="dionly"><option>BB</option><option selected>Bb</option><option>bb</option></select>
        <label class="dionly">Parent 2 · gene B</label><select id="p2b" class="dionly"><option>BB</option><option selected>Bb</option><option>bb</option></select>
      </div></div>
      <div class="lb-panel"><h3>Outcome</h3>
        <div id="genoOut"></div>
        <div style="height:8px;"></div>
        <div id="phenoOut"></div>
      </div>
    </aside>
    <section><div class="lb-stage"><canvas id="scene" width="900" height="560"></canvas></div></section>
  </div>
</main>
<script is:inline>
(function(){
  function val(id){ return document.getElementById(id).value; }
  function gametes(genes){ // genes: array of 2-char genotype strings e.g. ['Aa'] or ['Aa','Bb']
    var opts=genes.map(function(g){ return [g[0],g[1]]; });
    var res=['']; opts.forEach(function(pair){ var nx=[]; res.forEach(function(r){ pair.forEach(function(al){ nx.push(r+al); }); }); res=nx; });
    return res; // for dihybrid returns AB,Ab,aB,ab combos
  }
  function normGeno(str){ // sort each gene pair so 'aA'->'Aa'
    var out=''; for(var i=0;i<str.length;i+=2){ var pair=[str[i],str[i+1]].sort(function(a,b){ return a.toLowerCase()===b.toLowerCase() ? (a<b?-1:1) : 0; }); // uppercase first
      if(pair[0].toLowerCase()===pair[1].toLowerCase()){ pair.sort(); if(pair[0]>pair[1]) pair.reverse(); }
      // ensure uppercase before lowercase
      if(pair[0]===pair[0].toLowerCase() && pair[1]===pair[1].toUpperCase()) pair.reverse();
      out+=pair.join(''); } return out; }
  function combineGametes(g1,g2){ // pair up allele by gene position (interleave)
    var geno=''; for(var i=0;i<g1.length;i++){ var a=g1[i],b=g2[i]; var pair=(a===a.toUpperCase()? a+b : (b===b.toUpperCase()? b+a : a+b)); geno+=pair; } return geno; }
  function phenotype(geno){ var ph=''; for(var i=0;i<geno.length;i+=2){ var dom = geno[i]===geno[i].toUpperCase() || geno[i+1]===geno[i+1].toUpperCase(); ph += dom ? geno[i].toUpperCase()+'_' : geno[i].toLowerCase()+geno[i].toLowerCase(); } return ph; }

  function hidpi(cv){ var r=cv.getBoundingClientRect(), d=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w; cv.width=Math.round(w*d); cv.height=Math.round(h*d); var ctx=cv.getContext('2d'); ctx.setTransform(d,0,0,d,0,0); return {ctx:ctx,w:w,h:h}; }

  function compute(){
    var di=val('type')==='di';
    document.querySelectorAll('.dionly').forEach(function(e){ e.style.display=di?'':'none'; });
    var p1=[val('p1a')], p2=[val('p2a')]; if(di){ p1.push(val('p1b')); p2.push(val('p2b')); }
    var g1=gametes(p1), g2=gametes(p2);
    var grid=[], genoT={}, phenoT={}, total=0;
    g2.forEach(function(a){ var row=[]; g1.forEach(function(b){ var geno=normGeno(combineGametes(a,b)); row.push(geno); genoT[geno]=(genoT[geno]||0)+1; var ph=phenotype(geno); phenoT[ph]=(phenoT[ph]||0)+1; total++; }); grid.push(row); });
    return { di:di, g1:g1, g2:g2, grid:grid, genoT:genoT, phenoT:phenoT, total:total };
  }

  var COLORS=['#6ee7a8','#f87171','#5ee7ff','#fbbf24','#a78bfa','#f472b6','#7ad0ff','#facc15','#34d399'];
  function draw(){
    var r=compute(); var cv=document.getElementById('scene'), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h;
    var bg=ctx.createLinearGradient(0,0,0,H); bg.addColorStop(0,'#0c1226'); bg.addColorStop(1,'#06080f'); ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    var n=r.g1.length, gridPx=Math.min(W*0.6,H*0.82), cell=gridPx/(n+1), ox=20, oy=20;
    // header gametes (top = parent1 g1, left = parent2 g2)
    ctx.font="600 "+Math.min(20,cell*0.4)+"px 'Geist Mono',monospace"; ctx.textAlign='center'; ctx.textBaseline='middle';
    ctx.fillStyle='#5ee7ff'; ctx.fillText('P1 →', ox+cell*0.5, oy+cell*0.3);
    r.g1.forEach(function(gm,i){ ctx.fillStyle='#8ea0be'; ctx.fillRect(ox+(i+1)*cell+3,oy+3,cell-6,cell-6); ctx.fillStyle='#0b0d17'; ctx.font="700 "+Math.min(18,cell*0.36)+"px 'Geist Mono',monospace"; ctx.fillText(gm,ox+(i+1)*cell+cell/2,oy+cell/2); });
    r.g2.forEach(function(gm,j){ ctx.fillStyle='#8ea0be'; ctx.fillRect(ox+3,oy+(j+1)*cell+3,cell-6,cell-6); ctx.fillStyle='#0b0d17'; ctx.font="700 "+Math.min(18,cell*0.36)+"px 'Geist Mono',monospace"; ctx.fillText(gm,ox+cell/2,oy+(j+1)*cell+cell/2); });
    // cells
    var phList=Object.keys(r.phenoT), phCol={}; phList.forEach(function(p,i){ phCol[p]=COLORS[i%COLORS.length]; });
    r.grid.forEach(function(row,j){ row.forEach(function(geno,i){ var ph=phenotype(geno), col=phCol[ph];
      var cx=ox+(i+1)*cell, cy=oy+(j+1)*cell; ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=10; ctx.fillStyle=col+'33'; ctx.fillRect(cx+3,cy+3,cell-6,cell-6); ctx.restore();
      ctx.strokeStyle=col; ctx.lineWidth=1.5; ctx.strokeRect(cx+3,cy+3,cell-6,cell-6);
      ctx.fillStyle=col; ctx.font="700 "+Math.min(17,cell*0.32)+"px 'Geist Mono',monospace"; ctx.fillText(geno,cx+cell/2,cy+cell/2); }); });
    // offspring population dots (right side)
    var px0=ox+gridPx+30, pw=W-px0-16; ctx.textAlign='left';
    ctx.fillStyle='#8ea0be'; ctx.font="11px 'Geist Mono',monospace"; ctx.fillText('offspring (phenotype)',px0,oy+12);
    var dots=64, dy=oy+28, dx=px0, per=Math.floor(pw/16); var idx=0;
    phList.forEach(function(ph){ var cnt=Math.round(r.phenoT[ph]/r.total*dots); for(var k=0;k<cnt;k++){ var col=phCol[ph]; var gx=dx+(idx%per)*16, gy=dy+Math.floor(idx/per)*16; ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=6; ctx.fillStyle=col; ctx.beginPath(); ctx.arc(gx+6,gy+6,4.5,0,7); ctx.fill(); ctx.restore(); idx++; } });
    // legend
    var ly=dy+Math.ceil(dots/per)*16+18; phList.forEach(function(ph,i){ var col=phCol[ph]; ctx.fillStyle=col; ctx.fillRect(px0,ly+i*20,12,12); ctx.fillStyle='#cfd6da'; ctx.font="12px 'Geist Mono',monospace"; ctx.fillText(ph+'  '+(r.phenoT[ph]/r.total*100).toFixed(0)+'%',px0+18,ly+i*20+10); });

    // side ratio panels
    var gk=Object.keys(r.genoT).sort(); document.getElementById('genoOut').innerHTML='<div style="font-family:Geist Mono,monospace;font-size:10px;color:#5ee7ff;letter-spacing:0.12em;margin-bottom:6px;">GENOTYPE RATIO</div>'+gk.map(function(g){ return '<div class="lb-metric"><b>'+g+'</b> — '+r.genoT[g]+'/'+r.total+' ('+(r.genoT[g]/r.total*100).toFixed(0)+'%)</div>'; }).join('');
    document.getElementById('phenoOut').innerHTML='<div style="font-family:Geist Mono,monospace;font-size:10px;color:#5ee7ff;letter-spacing:0.12em;margin-bottom:6px;">PHENOTYPE RATIO</div>'+phList.map(function(p){ return '<div class="lb-metric"><b>'+p+'</b> — '+(r.phenoT[p]/r.total*100).toFixed(0)+'% <span style="color:#8ea0be;">('+r.phenoT[p]+'/'+r.total+')</span></div>'; }).join('');
  }
  document.querySelectorAll('select').forEach(function(e){ e.addEventListener('change',draw); });
  window.addEventListener('resize',function(){ clearTimeout(window._rt); window._rt=setTimeout(draw,120); });
  draw();
})();
</script>
</BaseLayout>
