---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Genetics Lab — AquinTutor" description="Punnett square, dihybrid cross, incomplete dominance, sex-linked inheritance and chi-square goodness-of-fit.">
<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; }
  .wrap { max-width: 1240px; margin: 0 auto; padding: 28px 22px 80px; }
  .eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; }
  h1 { font-family: 'Cormorant Garamond', serif; font-size: 34px; font-weight: 600; letter-spacing: -0.02em; margin: 6px 0 4px; }
  h1 em { color: #67e8f9; font-weight: 500; }
  .lede { color: #9aa0a6; font-size: 13px; max-width: 720px; line-height: 1.55; }
  .grid { display: grid; grid-template-columns: 360px 1fr; gap: 18px; margin-top: 22px; }
  @media (max-width: 1024px) { .grid { grid-template-columns: 1fr; } }
  .panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 16px; }
  .panel h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 12px; }
  label { display: block; font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: #9aa0a6; margin: 10px 0 4px; }
  input, select { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; color: #fff; padding: 7px 10px; border-radius: 5px; font-family: 'Geist Mono', monospace; font-size: 12px; box-sizing: border-box; }
  .row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .btn { background: #67e8f9; color: #04161b; padding: 9px 16px; border-radius: 6px; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; border: none; cursor: pointer; width: 100%; margin-top: 12px; }
  .btn.ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
  .btn:hover { filter: brightness(1.1); }
  .right-col { display: grid; gap: 18px; }
  .top-row { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  @media (max-width: 880px) { .top-row { grid-template-columns: 1fr; } }
  canvas { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 10px; display: block; }
  .square-wrap { display: grid; gap: 2px; background: #0a0a0c; border: 1px solid #2a2a35; padding: 6px; border-radius: 10px; }
  .square-cell { background: #1a1d28; padding: 10px 6px; text-align: center; font-family: 'Geist Mono', monospace; font-size: 13px; color: #e8e8ee; border-radius: 4px; transition: all 0.4s ease; opacity: 0; transform: scale(0.6); }
  .square-cell.shown { opacity: 1; transform: scale(1); }
  .square-cell.header { background: #04161b; color: #67e8f9; font-weight: 700; }
  .square-cell.corner { background: transparent; }
  .square-cell .geno { display: block; font-size: 14px; font-weight: 700; }
  .square-cell .pheno { display: block; font-size: 10px; color: #9aa0a6; margin-top: 3px; }
  .ratio-bar { display: flex; align-items: center; gap: 10px; margin: 8px 0; }
  .ratio-bar .lbl { font-family: 'Geist Mono', monospace; font-size: 11px; width: 160px; color: #cfd6da; flex-shrink: 0; }
  .ratio-bar .track { flex: 1; height: 22px; background: #0a0a0c; border-radius: 4px; overflow: hidden; position: relative; }
  .ratio-bar .fill { height: 100%; background: linear-gradient(90deg, #67e8f9, #22d3ee); transition: width 0.8s ease; }
  .ratio-bar .pct { width: 60px; text-align: right; font-family: 'Geist Mono', monospace; font-size: 11px; color: #67e8f9; }
  .pill { display: inline-block; padding: 3px 8px; background: #04161b; color: #67e8f9; font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; border-radius: 4px; border: 1px solid #2a2a35; }
  .legend-row { display: flex; gap: 14px; flex-wrap: wrap; font-family: 'Geist Mono', monospace; font-size: 11px; color: #cfd6da; margin-top: 8px; }
  .legend-row .sw { display: inline-block; width: 12px; height: 12px; border-radius: 3px; margin-right: 5px; vertical-align: middle; }
  .chi-row { display: grid; grid-template-columns: 1.4fr 1fr 1fr 1fr 1fr; gap: 6px; align-items: center; font-family: 'Geist Mono', monospace; font-size: 11px; padding: 5px 0; border-bottom: 1px solid #1a1d28; }
  .chi-row.head { color: #67e8f9; font-weight: 700; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; }
  .chi-row input { padding: 4px 6px; font-size: 11px; }
  .stat-box { background: #04161b; border: 1px solid #2a2a35; border-radius: 8px; padding: 12px; margin-top: 10px; }
  .stat-box .row { display: flex; justify-content: space-between; padding: 4px 0; font-family: 'Geist Mono', monospace; font-size: 11px; color: #cfd6da; }
  .stat-box .row .v { color: #67e8f9; font-weight: 700; }
  .verdict { margin-top: 8px; padding: 8px 10px; border-radius: 6px; font-family: 'Geist Mono', monospace; font-size: 11px; text-align: center; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
  .verdict.ok { background: rgba(34, 197, 94, 0.12); color: #4ade80; border: 1px solid rgba(34, 197, 94, 0.3); }
  .verdict.bad { background: rgba(239, 68, 68, 0.12); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.3); }
  .mode-btns { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-bottom: 4px; }
  .mode-btn { background: #0a0a0c; border: 1px solid #2a2a35; color: #cfd6da; padding: 7px 6px; border-radius: 5px; font-family: 'Geist Mono', monospace; font-size: 10px; cursor: pointer; text-transform: uppercase; letter-spacing: 0.06em; }
  .mode-btn.active { background: #04161b; border-color: #67e8f9; color: #67e8f9; }
</style>
<main class="wrap">
  <div class="eyebrow">VIRTUAL LAB &middot; 09</div>
  <h1>Genetics &mdash; <em>Punnett</em> Square &amp; Chi-Square Test</h1>
  <p class="lede">Mendelian crosses with full ratio aggregation. Monohybrid, dihybrid (4x4 = 16-cell grid), incomplete dominance, codominance, X-linked inheritance and back-test crosses. Goodness-of-fit chi-squared with a 1/2/3-df critical-value lookup at &alpha;=0.05 and &alpha;=0.01.</p>

  <div class="grid">
    <div class="panel">
      <h3>Cross configuration</h3>

      <label>Mode</label>
      <div class="mode-btns" id="mode-btns">
        <button class="mode-btn active" data-mode="mono">Monohybrid</button>
        <button class="mode-btn" data-mode="di">Dihybrid</button>
        <button class="mode-btn" data-mode="incomp">Incomplete dom.</button>
        <button class="mode-btn" data-mode="codom">Codominance</button>
        <button class="mode-btn" data-mode="xlinked">Sex-linked (X)</button>
        <button class="mode-btn" data-mode="testcross">Test cross</button>
      </div>

      <div class="row2">
        <div>
          <label>Parent 1 genotype</label>
          <input id="p1" value="Aa">
        </div>
        <div>
          <label>Parent 2 genotype</label>
          <input id="p2" value="Aa">
        </div>
      </div>

      <div class="row2">
        <div>
          <label>Trait 1 (dom / rec)</label>
          <input id="trait1" value="Tall / short">
        </div>
        <div>
          <label>Trait 2 (dom / rec)</label>
          <input id="trait2" value="Yellow / green">
        </div>
      </div>

      <button class="btn" id="run-cross">Run cross</button>
      <button class="btn ghost" id="load-example">Load classic 9:3:3:1 example</button>

      <div style="margin-top: 16px;">
        <h3>Notation guide</h3>
        <div style="font-family: 'Geist Mono', monospace; font-size: 11px; line-height: 1.7; color: #9aa0a6;">
          A, B = dominant allele<br>
          a, b = recessive allele<br>
          X^A Y = X-linked male (hemizygous)<br>
          X^A X^a = X-linked female carrier<br>
          IA IB = codominant (e.g. blood type)
        </div>
      </div>
    </div>

    <div class="right-col">
      <div class="top-row">
        <div class="panel">
          <h3>Punnett square</h3>
          <div id="square-host"></div>
          <div class="legend-row" id="legend"></div>
        </div>

        <div class="panel">
          <h3>Phenotype ratio</h3>
          <div id="pheno-bars"></div>
          <h3 style="margin-top: 18px;">Genotype frequency</h3>
          <canvas id="pie" width="320" height="220"></canvas>
        </div>
      </div>

      <div class="panel">
        <h3>Chi-square goodness-of-fit</h3>
        <p style="font-family: 'Geist Mono', monospace; font-size: 11px; color: #9aa0a6; margin: 0 0 12px;">Enter your observed counts from a real cross. We compare against expected ratios from the predicted phenotype distribution and compute &chi;&sup2; = &Sigma;((O&minus;E)&sup2;/E).</p>
        <div id="chi-table"></div>
        <div class="row2" style="margin-top: 10px;">
          <button class="btn" id="run-chi">Compute &chi;&sup2;</button>
          <button class="btn ghost" id="autofill">Autofill expected</button>
        </div>
        <div class="stat-box" id="chi-stats" style="display: none;"></div>
      </div>
    </div>
  </div>
</main>

<script is:inline>
(function () {
  const PHENO_COLOURS = ['#67e8f9', '#fbbf24', '#a78bfa', '#f472b6', '#4ade80', '#fb923c', '#60a5fa', '#f87171'];

  // chi-square critical values, df -> alpha -> crit
  const CHI_CRIT = {
    1: { 0.05: 3.841, 0.01: 6.635 },
    2: { 0.05: 5.991, 0.01: 9.210 },
    3: { 0.05: 7.815, 0.01: 11.345 },
    4: { 0.05: 9.488, 0.01: 13.277 },
    5: { 0.05: 11.070, 0.01: 15.086 },
    6: { 0.05: 12.592, 0.01: 16.812 },
    7: { 0.05: 14.067, 0.01: 18.475 },
  };

  let state = {
    mode: 'mono',
    p1: 'Aa',
    p2: 'Aa',
    trait1: 'Tall / short',
    trait2: 'Yellow / green',
    lastCells: [],
    lastPhenos: [],
  };

  document.querySelectorAll('#mode-btns .mode-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#mode-btns .mode-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      state.mode = btn.dataset.mode;
      // sensible defaults per mode
      const defaults = {
        mono: { p1: 'Aa', p2: 'Aa', t1: 'Tall / short', t2: '' },
        di: { p1: 'AaBb', p2: 'AaBb', t1: 'Tall / short', t2: 'Yellow / green' },
        incomp: { p1: 'Rr', p2: 'Rr', t1: 'Red / white (pink heterozygote)', t2: '' },
        codom: { p1: 'IAIB', p2: 'IAIO', t1: 'Blood type', t2: '' },
        xlinked: { p1: 'X^A X^a', p2: 'X^a Y', t1: 'Colour vision / colour-blind', t2: '' },
        testcross: { p1: 'AaBb', p2: 'aabb', t1: 'Tall / short', t2: 'Yellow / green' },
      }[state.mode];
      document.getElementById('p1').value = defaults.p1;
      document.getElementById('p2').value = defaults.p2;
      document.getElementById('trait1').value = defaults.t1;
      document.getElementById('trait2').value = defaults.t2;
    });
  });

  // Split a genotype like "AaBb" into [["A","a"], ["B","b"]]
  // X-linked input like "X^A X^a" -> [["X^A","X^a"]], "X^a Y" -> [["X^a","Y"]]
  // Codominant "IAIB" -> [["IA","IB"]], "IAIO" -> [["IA","IO"]]
  function parseGenotype(s, mode) {
    s = s.trim();
    if (mode === 'xlinked') {
      // tokens separated by space
      const toks = s.split(/\s+/);
      return [toks];
    }
    if (mode === 'codom') {
      // expect 2 alleles each "I" + letter
      const m = s.match(/(I[ABO])/g) || [];
      return [m];
    }
    // monohybrid: 2 chars
    // dihybrid: 4 chars
    const alleles = s.split('');
    if (alleles.length === 2) return [[alleles[0], alleles[1]]];
    if (alleles.length === 4) return [[alleles[0], alleles[1]], [alleles[2], alleles[3]]];
    return [[alleles[0] || 'A', alleles[1] || 'a']];
  }

  // Generate gametes from a genotype.
  // For dihybrid AaBb -> AB, Ab, aB, ab (4 gametes)
  function gametes(loci) {
    let result = [['']];
    for (const locus of loci) {
      const next = [];
      for (const partial of result) {
        for (const allele of locus) {
          next.push([...partial, allele]);
        }
      }
      result = next;
    }
    // dedupe identical gametes but keep multiplicity counts
    return result;
  }

  // Sort alleles in a genotype to canonical form (e.g. "aA" -> "Aa", "BbAa" -> "AaBb")
  function canonical(alleleArr) {
    // Group by letter (case-insensitive) then sort each group dom-first
    const groups = {};
    for (const a of alleleArr) {
      const key = a.replace(/[\^]/g, '').toUpperCase().charAt(a.startsWith('X') ? 0 : 0);
      // simpler: group by uppercase letter
      const baseKey = a.toUpperCase().replace(/[\^XY]/g, '')[0] || a;
      const k = a.startsWith('X') || a === 'Y' ? 'X' : baseKey;
      if (!groups[k]) groups[k] = [];
      groups[k].push(a);
    }
    const orderedKeys = Object.keys(groups).sort();
    const out = [];
    for (const k of orderedKeys) {
      // dominant (uppercase, non-^) first
      groups[k].sort((a, b) => {
        const aDom = a === a.toUpperCase() && !a.includes('^a') && !a.includes('^b');
        const bDom = b === b.toUpperCase() && !b.includes('^a') && !b.includes('^b');
        if (aDom && !bDom) return -1;
        if (!aDom && bDom) return 1;
        return a.localeCompare(b);
      });
      out.push(...groups[k]);
    }
    return out;
  }

  // Determine phenotype from a genotype array of alleles
  function phenotype(alleleArr, mode, trait1, trait2) {
    const t1 = (trait1 || 'Trait1').split('/').map(s => s.trim());
    const t2 = (trait2 || 'Trait2').split('/').map(s => s.trim());
    const dom1 = t1[0] || 'Dominant1';
    const rec1 = t1[1] || 'recessive1';
    const dom2 = t2[0] || 'Dominant2';
    const rec2 = t2[1] || 'recessive2';

    if (mode === 'xlinked') {
      const hasY = alleleArr.includes('Y');
      if (hasY) {
        // male, look at X allele
        const x = alleleArr.find(a => a.startsWith('X'));
        if (!x) return 'unknown male';
        return x.includes('^A') ? `Male, ${dom1}` : `Male, ${rec1}`;
      } else {
        // female, both X
        const xs = alleleArr.filter(a => a.startsWith('X'));
        const anyDom = xs.some(x => x.includes('^A'));
        const allRec = xs.every(x => x.includes('^a'));
        if (allRec) return `Female, ${rec1}`;
        return `Female, ${dom1}`;
      }
    }

    if (mode === 'codom') {
      // blood-type: IAIA or IAIO -> A; IBIB or IBIO -> B; IAIB -> AB; IOIO -> O
      const hasA = alleleArr.includes('IA');
      const hasB = alleleArr.includes('IB');
      const hasO = alleleArr.every(a => a === 'IO');
      if (hasA && hasB) return 'Type AB';
      if (hasA) return 'Type A';
      if (hasB) return 'Type B';
      return 'Type O';
    }

    // Split into loci-of-2
    const loci = [];
    for (let i = 0; i < alleleArr.length; i += 2) {
      loci.push([alleleArr[i], alleleArr[i + 1]].filter(Boolean));
    }

    const parts = [];
    loci.forEach((locus, idx) => {
      const dom = idx === 0 ? dom1 : dom2;
      const rec = idx === 0 ? rec1 : rec2;
      const hasDom = locus.some(a => a === a.toUpperCase());
      const allRec = locus.every(a => a === a.toLowerCase());

      if (mode === 'incomp') {
        // Rr -> intermediate
        if (locus[0] !== locus[1] && hasDom && !allRec) {
          parts.push(`${dom}-${rec} blend`);
        } else if (hasDom) parts.push(dom);
        else parts.push(rec);
      } else {
        if (hasDom) parts.push(dom);
        else parts.push(rec);
      }
    });
    return parts.join(' & ');
  }

  // Build the Punnett grid
  function buildSquare() {
    const host = document.getElementById('square-host');
    host.innerHTML = '';

    const p1Loci = parseGenotype(state.p1, state.mode);
    const p2Loci = parseGenotype(state.p2, state.mode);

    const p1Gams = gametes(p1Loci);
    const p2Gams = gametes(p2Loci);

    const cols = p1Gams.length;
    const rows = p2Gams.length;

    const wrap = document.createElement('div');
    wrap.className = 'square-wrap';
    wrap.style.gridTemplateColumns = `60px repeat(${cols}, 1fr)`;

    // Top-left corner
    const corner = document.createElement('div');
    corner.className = 'square-cell corner';
    wrap.appendChild(corner);

    // Column headers (p1 gametes)
    p1Gams.forEach(g => {
      const c = document.createElement('div');
      c.className = 'square-cell header';
      c.textContent = g.join('');
      wrap.appendChild(c);
    });

    const cells = [];
    p2Gams.forEach((rowGam, ri) => {
      const rh = document.createElement('div');
      rh.className = 'square-cell header';
      rh.textContent = rowGam.join('');
      wrap.appendChild(rh);

      p1Gams.forEach((colGam, ci) => {
        const cell = document.createElement('div');
        cell.className = 'square-cell';
        const offspring = canonical([...colGam, ...rowGam]);
        const pheno = phenotype(offspring, state.mode, state.trait1, state.trait2);
        cell.innerHTML = `<span class="geno">${offspring.join('')}</span><span class="pheno">${pheno}</span>`;
        // colour by phenotype index later
        wrap.appendChild(cell);
        cells.push({ el: cell, genotype: offspring.join(''), phenotype: pheno });
      });
    });

    host.appendChild(wrap);

    // animate
    cells.forEach((c, i) => {
      setTimeout(() => {
        c.el.classList.add('shown');
      }, 30 + i * 40);
    });

    state.lastCells = cells;

    // assign phenotype colours
    const phenoSet = [...new Set(cells.map(c => c.phenotype))];
    setTimeout(() => {
      cells.forEach(c => {
        const idx = phenoSet.indexOf(c.phenotype);
        c.el.style.borderLeft = `3px solid ${PHENO_COLOURS[idx % PHENO_COLOURS.length]}`;
      });
    }, 30 + cells.length * 40);

    // legend
    const legend = document.getElementById('legend');
    legend.innerHTML = '';
    phenoSet.forEach((p, i) => {
      const s = document.createElement('span');
      s.innerHTML = `<span class="sw" style="background:${PHENO_COLOURS[i % PHENO_COLOURS.length]}"></span>${p}`;
      legend.appendChild(s);
    });

    return { cells, phenoSet };
  }

  function renderPhenoBars(cells, phenoSet) {
    const host = document.getElementById('pheno-bars');
    host.innerHTML = '';
    const total = cells.length;
    const counts = {};
    cells.forEach(c => { counts[c.phenotype] = (counts[c.phenotype] || 0) + 1; });

    // simplify to GCD ratio
    const vals = Object.values(counts);
    const gcd = vals.reduce((a, b) => { while (b) { [a, b] = [b, a % b]; } return a; });
    const ratio = vals.map(v => v / gcd).join(' : ');

    const ratioPill = document.createElement('div');
    ratioPill.innerHTML = `<span class="pill">Ratio ${ratio}</span>`;
    ratioPill.style.marginBottom = '8px';
    host.appendChild(ratioPill);

    phenoSet.forEach((p, i) => {
      const cnt = counts[p] || 0;
      const pct = (cnt / total) * 100;
      const row = document.createElement('div');
      row.className = 'ratio-bar';
      row.innerHTML = `
        <span class="lbl">${p}</span>
        <span class="track"><span class="fill" style="width: 0%; background: ${PHENO_COLOURS[i % PHENO_COLOURS.length]}"></span></span>
        <span class="pct">${cnt}/${total}</span>
      `;
      host.appendChild(row);
      setTimeout(() => {
        row.querySelector('.fill').style.width = pct + '%';
      }, 100 + i * 80);
    });

    state.lastPhenos = phenoSet.map(p => ({ name: p, count: counts[p], expected: (counts[p] / total) }));
  }

  function drawPie(cells) {
    const canvas = document.getElementById('pie');
    const ctx = canvas.getContext('2d');
    const w = canvas.width = canvas.clientWidth * (window.devicePixelRatio || 1);
    const h = canvas.height = 220 * (window.devicePixelRatio || 1);
    ctx.scale(window.devicePixelRatio || 1, window.devicePixelRatio || 1);

    const counts = {};
    cells.forEach(c => { counts[c.genotype] = (counts[c.genotype] || 0) + 1; });
    const total = cells.length;
    const entries = Object.entries(counts);

    const cx = (canvas.clientWidth) / 2;
    const cy = 110;
    const r = 80;

    let angle = -Math.PI / 2;
    entries.forEach(([geno, cnt], i) => {
      const slice = (cnt / total) * Math.PI * 2;
      ctx.beginPath();
      ctx.moveTo(cx, cy);
      ctx.arc(cx, cy, r, angle, angle + slice);
      ctx.closePath();
      ctx.fillStyle = PHENO_COLOURS[i % PHENO_COLOURS.length];
      ctx.fill();

      // label
      const mid = angle + slice / 2;
      const lx = cx + Math.cos(mid) * (r + 14);
      const ly = cy + Math.sin(mid) * (r + 14);
      ctx.fillStyle = '#cfd6da';
      ctx.font = '11px Geist Mono, monospace';
      ctx.textAlign = mid > Math.PI / 2 && mid < 3 * Math.PI / 2 ? 'right' : 'left';
      ctx.fillText(`${geno} (${cnt})`, lx, ly);

      angle += slice;
    });

    // inner hole
    ctx.beginPath();
    ctx.arc(cx, cy, r * 0.45, 0, Math.PI * 2);
    ctx.fillStyle = '#11131a';
    ctx.fill();

    ctx.fillStyle = '#67e8f9';
    ctx.font = 'bold 13px Geist Mono, monospace';
    ctx.textAlign = 'center';
    ctx.fillText(`n=${total}`, cx, cy + 4);
  }

  function renderChiTable() {
    const host = document.getElementById('chi-table');
    host.innerHTML = '';

    const head = document.createElement('div');
    head.className = 'chi-row head';
    head.innerHTML = `<span>Phenotype</span><span>Expected p</span><span>Expected E</span><span>Observed O</span><span>(O&minus;E)&sup2;/E</span>`;
    host.appendChild(head);

    const totalDefault = 100;

    state.lastPhenos.forEach((p, i) => {
      const row = document.createElement('div');
      row.className = 'chi-row';
      row.innerHTML = `
        <span style="color:${PHENO_COLOURS[i % PHENO_COLOURS.length]}">${p.name}</span>
        <span>${p.expected.toFixed(4)}</span>
        <span class="exp-cell">&mdash;</span>
        <input type="number" class="obs-input" min="0" value="">
        <span class="contrib-cell">&mdash;</span>
      `;
      host.appendChild(row);
    });

    // total row
    const totalRow = document.createElement('div');
    totalRow.className = 'chi-row';
    totalRow.style.fontWeight = '700';
    totalRow.style.color = '#67e8f9';
    totalRow.innerHTML = `<span>Total N</span><span>1.0000</span><span class="total-cell">&mdash;</span><input type="number" id="total-input" value="100"><span>&Sigma;</span>`;
    host.appendChild(totalRow);
  }

  function computeChiSquare() {
    const totalInput = document.getElementById('total-input');
    const N = parseInt(totalInput.value, 10) || 100;
    const obsInputs = document.querySelectorAll('#chi-table .obs-input');
    const expCells = document.querySelectorAll('#chi-table .exp-cell');
    const contribCells = document.querySelectorAll('#chi-table .contrib-cell');
    const totalCell = document.querySelector('#chi-table .total-cell');

    let chi = 0;
    let observedTotal = 0;
    let valid = true;

    state.lastPhenos.forEach((p, i) => {
      const E = p.expected * N;
      const O = parseFloat(obsInputs[i].value);
      expCells[i].textContent = E.toFixed(2);
      if (isNaN(O) || O < 0) {
        valid = false;
        contribCells[i].textContent = '—';
        return;
      }
      observedTotal += O;
      const contrib = (O - E) * (O - E) / E;
      chi += contrib;
      contribCells[i].textContent = contrib.toFixed(3);
    });
    totalCell.textContent = observedTotal.toFixed(0);

    const box = document.getElementById('chi-stats');
    if (!valid) {
      box.style.display = 'block';
      box.innerHTML = `<div class="row"><span>Status</span><span class="v">Enter all observed counts</span></div>`;
      return;
    }

    const df = state.lastPhenos.length - 1;
    const crit05 = (CHI_CRIT[df] && CHI_CRIT[df][0.05]) || '—';
    const crit01 = (CHI_CRIT[df] && CHI_CRIT[df][0.01]) || '—';

    box.style.display = 'block';
    const reject05 = typeof crit05 === 'number' && chi > crit05;
    const reject01 = typeof crit01 === 'number' && chi > crit01;

    let verdictClass = 'ok';
    let verdictText = 'Fail to reject H&#8320; &mdash; data fits Mendelian ratio';
    if (reject01) {
      verdictClass = 'bad';
      verdictText = 'Reject H&#8320; at &alpha;=0.01 &mdash; significant deviation';
    } else if (reject05) {
      verdictClass = 'bad';
      verdictText = 'Reject H&#8320; at &alpha;=0.05 &mdash; deviation present';
    }

    box.innerHTML = `
      <div class="row"><span>&chi;&sup2; statistic</span><span class="v">${chi.toFixed(4)}</span></div>
      <div class="row"><span>Degrees of freedom (df)</span><span class="v">${df}</span></div>
      <div class="row"><span>Critical at &alpha;=0.05</span><span class="v">${typeof crit05 === 'number' ? crit05.toFixed(3) : crit05}</span></div>
      <div class="row"><span>Critical at &alpha;=0.01</span><span class="v">${typeof crit01 === 'number' ? crit01.toFixed(3) : crit01}</span></div>
      <div class="row"><span>Observed total</span><span class="v">${observedTotal}</span></div>
      <div class="verdict ${verdictClass}">${verdictText}</div>
    `;
  }

  function autofillExpected() {
    const totalInput = document.getElementById('total-input');
    const N = parseInt(totalInput.value, 10) || 100;
    const obsInputs = document.querySelectorAll('#chi-table .obs-input');
    state.lastPhenos.forEach((p, i) => {
      obsInputs[i].value = Math.round(p.expected * N);
    });
    computeChiSquare();
  }

  function runCross() {
    state.p1 = document.getElementById('p1').value;
    state.p2 = document.getElementById('p2').value;
    state.trait1 = document.getElementById('trait1').value;
    state.trait2 = document.getElementById('trait2').value;

    const { cells, phenoSet } = buildSquare();
    renderPhenoBars(cells, phenoSet);
    drawPie(cells);
    renderChiTable();
    document.getElementById('chi-stats').style.display = 'none';
  }

  document.getElementById('run-cross').addEventListener('click', runCross);
  document.getElementById('run-chi').addEventListener('click', computeChiSquare);
  document.getElementById('autofill').addEventListener('click', autofillExpected);
  document.getElementById('load-example').addEventListener('click', () => {
    document.querySelector('.mode-btn[data-mode="di"]').click();
    setTimeout(runCross, 50);
  });

  // initial
  runCross();
})();
</script>

