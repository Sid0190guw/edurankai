---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Population & transmission genetics lab (advanced level). Three engines:
// (1) Population genetics — the Hardy-Weinberg genotype frequencies evolving
//     under selection (per-genotype fitnesses), recurrent mutation and
//     Wright-Fisher genetic DRIFT at finite N, plotting replicate allele-
//     frequency trajectories and the heterozygote-advantage equilibrium.
// (2) Cross + chi-square — expected Mendelian / epistatic ratios (3:1, 9:3:3:1,
//     9:7, 9:3:4, 12:3:1, 1:2:1) vs a simulated sample, with the chi-square
//     statistic, degrees of freedom and a real p-value from the regularised
//     incomplete gamma function, and an accept/reject verdict.
// (3) Linkage — recombination frequency -> parental/recombinant counts in a
//     test cross and the estimated map distance in centimorgans.
// No libraries.
---
<BaseLayout title="Population & Transmission Genetics · Virtual Labs · AquinTutor" description="Advanced genetics: Hardy-Weinberg under selection, mutation and Wright-Fisher drift with allele-frequency trajectories; a chi-square goodness-of-fit test with a real p-value (incomplete gamma) including epistatic ratios; and linkage mapping in centimorgans. Built from scratch.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1340px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:16px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:310px minmax(0,1fr); gap:18px; } @media(max-width:960px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:15px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 11px; }
  .lb-row{ display:grid; gap:8px; } .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.08em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; }
  .lb-row label span{ color:#5ee7ff; } .lb-row input[type=range]{ width:100%; accent-color:#5ee7ff; } select{ width:100%; background:#080a12; border:1px solid #1e2740; color:#fff; padding:8px 10px; border-radius:6px; font-size:12px; font-family:inherit; }
  .lb-seg{ display:flex; gap:4px; } .lb-seg button{ flex:1; background:#0b1020; border:1px solid #26314f; color:#8ea0be; border-radius:7px; padding:6px 4px; font-family:'Geist Mono',monospace; font-size:10px; cursor:pointer; } .lb-seg button.on{ background:rgba(94,231,255,0.14); color:#5ee7ff; border-color:#3a6b86; }
  .lb-btn{ background:linear-gradient(180deg,#7af0ff,#33cfe6); color:#04161b; padding:9px 15px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:11px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); } .lb-stage canvas{ display:block; width:100%; height:auto; }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11px; padding:4px 0; border-bottom:1px solid #141a2c; } .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#5ee7ff; font-weight:700; text-align:right; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">Biology · Population &amp; Transmission Genetics</p>
      <h1 class="lb-title">Genetics <em>engine</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;"><button id="runBtn" class="lb-btn">Run</button></div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Mode</h3>
        <div class="lb-seg" id="modeSeg"><button data-m="pop" class="on">Population</button><button data-m="chi">χ² test</button><button data-m="link">Linkage</button></div>
      </div>
      <!-- POP GEN -->
      <div id="panPop">
        <div class="lb-panel"><h3>Hardy-Weinberg + forces</h3><div class="lb-row">
          <label>Initial p (freq A) <span id="pV">0.50</span></label><input id="p0" type="range" min="0.01" max="0.99" step="0.01" value="0.5"/>
          <label>Fitness w(AA) <span id="w1V">1.00</span></label><input id="w1" type="range" min="0" max="1.5" step="0.01" value="1"/>
          <label>Fitness w(Aa) <span id="w2V">1.00</span></label><input id="w2" type="range" min="0" max="1.5" step="0.01" value="1"/>
          <label>Fitness w(aa) <span id="w3V">1.00</span></label><input id="w3" type="range" min="0" max="1.5" step="0.01" value="1"/>
          <label>Mutation μ (A→a) <span id="muV">0.000</span></label><input id="mu" type="range" min="0" max="0.05" step="0.001" value="0"/>
          <label>Pop size N (drift) <span id="nV">200</span></label><input id="popN" type="range" min="10" max="5000" step="10" value="200"/>
        </div></div>
      </div>
      <!-- CHI -->
      <div id="panChi" style="display:none;">
        <div class="lb-panel"><h3>Cross ratio</h3>
          <select id="ratio">
            <option value="3,1">Monohybrid 3:1</option>
            <option value="1,2,1">Codominant 1:2:1</option>
            <option value="9,3,3,1" selected>Dihybrid 9:3:3:1</option>
            <option value="9,7">Epistasis 9:7</option>
            <option value="9,3,4">Recessive epistasis 9:3:4</option>
            <option value="12,3,1">Dominant epistasis 12:3:1</option>
            <option value="1,1,1,1">Test cross 1:1:1:1</option>
          </select>
          <div class="lb-row" style="margin-top:10px;"><label>Sample size N <span id="chinV">160</span></label><input id="chiN" type="range" min="20" max="2000" step="20" value="160"/></div>
        </div>
      </div>
      <!-- LINK -->
      <div id="panLink" style="display:none;">
        <div class="lb-panel"><h3>Test cross · AaBb × aabb</h3><div class="lb-row">
          <label>Recombination r <span id="rV">0.15</span></label><input id="rf" type="range" min="0" max="0.5" step="0.01" value="0.15"/>
          <label>Offspring N <span id="lnV">1000</span></label><input id="lnN" type="range" min="50" max="5000" step="50" value="1000"/>
        </div></div>
      </div>
      <div class="lb-panel"><h3>Results</h3><div id="results"></div></div>
    </aside>
    <section><div class="lb-stage"><canvas id="scene" width="960" height="580"></canvas></div></section>
  </div>
</main>
<script is:inline>
(function(){
  function v(id){ return parseFloat(document.getElementById(id).value); }
  function setTxt(id,t){ var e=document.getElementById(id); if(e) e.textContent=t; }
  var mode='pop';
  // ---- stats helpers ----
  function gammln(x){ var c=[76.18009172947146,-86.50532032941677,24.01409824083091,-1.231739572450155,0.1208650973866179e-2,-0.5395239384953e-5]; var y=x,t=x+5.5; t-=(x+0.5)*Math.log(t); var s=1.000000000190015; for(var j=0;j<6;j++){ y++; s+=c[j]/y; } return -t+Math.log(2.5066282746310005*s/x); }
  function gammp(a,x){ if(x<=0) return 0; if(x<a+1){ var ap=a,sum=1/a,del=1/a; for(var n=0;n<300;n++){ ap++; del*=x/ap; sum+=del; if(Math.abs(del)<Math.abs(sum)*1e-13) break; } return sum*Math.exp(-x+a*Math.log(x)-gammln(a)); }
    var b=x+1-a,c=1e30,d=1/b,h=d; for(var i=1;i<=300;i++){ var an=-i*(i-a); b+=2; d=an*d+b; if(Math.abs(d)<1e-30)d=1e-30; c=b+an/c; if(Math.abs(c)<1e-30)c=1e-30; d=1/d; var de=d*c; h*=de; if(Math.abs(de-1)<1e-13) break; } return 1-Math.exp(-x+a*Math.log(x)-gammln(a))*h; }
  function chiP(chi2,df){ return 1-gammp(df/2, chi2/2); }
  function binom(n,p){ var k=0; for(var i=0;i<n;i++){ if(Math.random()<p) k++; } return k; } // exact for small n; fine here
  function multinom(N,probs){ var out=new Array(probs.length).fill(0), rem=N, prem=1; for(var i=0;i<probs.length-1;i++){ var pk=probs[i]/prem; var c=binom(rem,Math.min(1,Math.max(0,pk))); out[i]=c; rem-=c; prem-=probs[i]; } out[probs.length-1]=rem; return out; }

  function hidpi(cv){ var r=cv.getBoundingClientRect(), dp=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w; cv.width=Math.round(w*dp); cv.height=Math.round(h*dp); var ctx=cv.getContext('2d'); ctx.setTransform(dp,0,0,dp,0,0); return {ctx:ctx,w:w,h:h}; }
  function glow(ctx,pts,col,wd,al){ ctx.save(); ctx.globalAlpha=al||1; ctx.shadowColor=col; ctx.shadowBlur=6; ctx.strokeStyle=col; ctx.lineWidth=wd||1.5; ctx.beginPath(); pts.forEach(function(q,i){ i?ctx.lineTo(q[0],q[1]):ctx.moveTo(q[0],q[1]); }); ctx.stroke(); ctx.restore(); }

  // ---- POP GEN ----
  function pop(){ var cv=document.getElementById('scene'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h; ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H);
    var w1=v('w1'),w2=v('w2'),w3=v('w3'),mu=v('mu'),N=Math.round(v('popN')),T=200;
    var padL=44,padB=30; function X(t){ return padL+t/T*(W-padL-14); } function Y(p){ return H-padB-(p)*(H-padB-14); }
    ctx.strokeStyle='rgba(94,231,255,0.07)'; ctx.fillStyle='#5f7597'; ctx.font="10px 'Geist Mono',monospace";
    for(var q=0;q<=1.0001;q+=0.25){ ctx.beginPath(); ctx.moveTo(padL,Y(q)); ctx.lineTo(W-14,Y(q)); ctx.stroke(); ctx.fillText(q.toFixed(2),8,Y(q)+3); }
    ctx.fillText('allele frequency p(A)',padL,16); ctx.fillText('generation →',W-100,H-10);
    // deterministic trajectory
    function nextP(p){ var q=1-p; var wbar=p*p*w1+2*p*q*w2+q*q*w3; if(wbar<=0) return p; var ps=(p*p*w1+p*q*w2)/wbar; ps=ps*(1-mu)+(1-ps)*0.0; return Math.max(0,Math.min(1,ps)); }
    var det=[[X(0),Y(v('p0'))]], p=v('p0'); for(var t=1;t<=T;t++){ p=nextP(p); det.push([X(t),Y(p)]); }
    // drift replicates (Wright-Fisher)
    for(var rep=0;rep<6;rep++){ var pts=[], pp=v('p0'); for(var t=0;t<=T;t++){ pts.push([X(t),Y(pp)]); var ps=nextP(pp); pp=binom(2*N,ps)/(2*N); } glow(ctx,pts,'#a78bfa',1,0.42); }
    glow(ctx,det,'#fbbf24',2.2,1);
    // equilibrium (heterozygote advantage)
    var pstar=(w2-w3)/(2*w2-w1-w3); if(pstar>0&&pstar<1&&(2*w2-w1-w3)!==0){ ctx.strokeStyle='rgba(52,211,153,0.6)'; ctx.setLineDash([5,4]); ctx.beginPath(); ctx.moveTo(padL,Y(pstar)); ctx.lineTo(W-14,Y(pstar)); ctx.stroke(); ctx.setLineDash([]); ctx.fillStyle='#34d399'; ctx.fillText('p* = '+pstar.toFixed(3),W-120,Y(pstar)-4); }
    var wbar=v('p0')*v('p0')*w1+2*v('p0')*(1-v('p0'))*w2+(1-v('p0'))*(1-v('p0'))*w3;
    var pe=det[det.length-1][0]?null:null; var pfin=1-(H-padB-det[det.length-1][1])/(H-padB-14);
    document.getElementById('results').innerHTML=''
      +'<div class="lb-metric"><span class="lb-metric-l">HWE genotypes p²,2pq,q²</span><span class="lb-metric-v">'+(v('p0')*v('p0')).toFixed(2)+', '+(2*v('p0')*(1-v('p0'))).toFixed(2)+', '+((1-v('p0'))*(1-v('p0'))).toFixed(2)+'</span></div>'
      +'<div class="lb-metric"><span class="lb-metric-l">Mean fitness w̄₀</span><span class="lb-metric-v">'+wbar.toFixed(3)+'</span></div>'
      +'<div class="lb-metric"><span class="lb-metric-l">Deterministic p(200)</span><span class="lb-metric-v" style="color:#fbbf24;">'+pfin.toFixed(3)+'</span></div>'
      +'<div class="lb-metric"><span class="lb-metric-l">Regime</span><span class="lb-metric-v" style="color:#a78bfa;">'+((pstar>0&&pstar<1&&(2*w2-w1-w3)<0)?'balanced polymorphism':(w1>w3?'A fixing':(w3>w1?'a fixing':'neutral/drift')))+'</span></div>'
      +'<div class="lb-metric"><span class="lb-metric-l">Drift (violet) at N</span><span class="lb-metric-v">'+N+'</span></div>';
  }

  // ---- CHI SQUARE ----
  var chiData=null;
  function chiRun(){ var parts=document.getElementById('ratio').value.split(',').map(Number); var tot=parts.reduce(function(a,b){return a+b;},0); var probs=parts.map(function(x){return x/tot;}); var N=Math.round(v('chiN'));
    var obs=multinom(N,probs); var exp=probs.map(function(pr){return pr*N;}); var chi2=0; for(var i=0;i<obs.length;i++){ chi2+=(obs[i]-exp[i])*(obs[i]-exp[i])/exp[i]; } var df=obs.length-1; var pval=chiP(chi2,df);
    chiData={parts:parts,obs:obs,exp:exp,chi2:chi2,df:df,pval:pval}; }
  function chi(){ if(!chiData) chiRun(); var d=chiData; var cv=document.getElementById('scene'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h; ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H);
    var n=d.obs.length, padL=40,padB=40, bw=(W-padL-20)/n; var mx=Math.max.apply(null,d.obs.concat(d.exp))*1.15;
    function Y(v_){ return H-padB-(v_/mx)*(H-padB-20); }
    for(var i=0;i<n;i++){ var x=padL+i*bw; // expected outline
      ctx.strokeStyle='rgba(94,231,255,0.7)'; ctx.setLineDash([4,3]); ctx.strokeRect(x+bw*0.14,Y(d.exp[i]),bw*0.72,H-padB-Y(d.exp[i])); ctx.setLineDash([]);
      ctx.save(); ctx.shadowColor='#fbbf24'; ctx.shadowBlur=8; ctx.fillStyle='rgba(251,191,36,0.7)'; ctx.fillRect(x+bw*0.22,Y(d.obs[i]),bw*0.56,H-padB-Y(d.obs[i])); ctx.restore();
      ctx.fillStyle='#8ea0be'; ctx.font="10px 'Geist Mono',monospace"; ctx.textAlign='center'; ctx.fillText('class '+(i+1),x+bw/2,H-padB+14); ctx.fillText(d.obs[i]+' / '+d.exp[i].toFixed(0),x+bw/2,H-padB+28); ctx.textAlign='left'; }
    ctx.fillStyle='#fbbf24'; ctx.font="11px 'Geist Mono',monospace"; ctx.fillText('observed',padL,18); ctx.fillStyle='#5ee7ff'; ctx.fillText('expected (dashed)',padL+80,18);
    var crit={1:3.841,2:5.991,3:7.815,4:9.488,5:11.070,6:12.592}[d.df]||0;
    document.getElementById('results').innerHTML=''
      +'<div class="lb-metric"><span class="lb-metric-l">χ² statistic</span><span class="lb-metric-v" style="color:#fbbf24;">'+d.chi2.toFixed(3)+'</span></div>'
      +'<div class="lb-metric"><span class="lb-metric-l">Degrees of freedom</span><span class="lb-metric-v">'+d.df+'</span></div>'
      +'<div class="lb-metric"><span class="lb-metric-l">Critical χ² (α=0.05)</span><span class="lb-metric-v">'+crit.toFixed(3)+'</span></div>'
      +'<div class="lb-metric"><span class="lb-metric-l">p-value</span><span class="lb-metric-v" style="color:#a78bfa;">'+d.pval.toFixed(4)+'</span></div>'
      +'<div class="lb-metric"><span class="lb-metric-l">Verdict (α=0.05)</span><span class="lb-metric-v" style="color:'+(d.pval<0.05?'#f87171':'#34d399')+';">'+(d.pval<0.05?'reject H₀':'fail to reject')+'</span></div>'; }

  // ---- LINKAGE ----
  var linkData=null;
  function linkRun(){ var r=v('rf'), N=Math.round(v('lnN')); // AaBb(coupling AB/ab) x aabb -> parental (1-r)/2 each, recomb r/2 each
    var probs=[(1-r)/2,(1-r)/2,r/2,r/2]; var o=multinom(N,probs); var par=o[0]+o[1], rec=o[2]+o[3]; var rhat=rec/N; linkData={o:o,par:par,rec:rec,rhat:rhat,N:N,r:r}; }
  function link(){ if(!linkData) linkRun(); var d=linkData; var cv=document.getElementById('scene'), S=hidpi(cv), ctx=S.ctx, W=S.w, H=S.h; ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H);
    var labels=['AB (parental)','ab (parental)','Ab (recomb)','aB (recomb)'], cols=['#34d399','#6ee7a8','#f472b6','#fb923c']; var mx=Math.max.apply(null,d.o)*1.15, padL=40,padB=40, bw=(W-padL-20)/4;
    for(var i=0;i<4;i++){ var x=padL+i*bw; ctx.save(); ctx.shadowColor=cols[i]; ctx.shadowBlur=8; ctx.fillStyle=cols[i]; ctx.fillRect(x+bw*0.2, H-padB-(d.o[i]/mx)*(H-padB-20), bw*0.6, (d.o[i]/mx)*(H-padB-20)); ctx.restore(); ctx.fillStyle='#8ea0be'; ctx.font="10px 'Geist Mono',monospace"; ctx.textAlign='center'; ctx.fillText(labels[i],x+bw/2,H-padB+14); ctx.fillText(''+d.o[i],x+bw/2,H-padB+28); ctx.textAlign='left'; }
    // chromosome map
    ctx.strokeStyle='#5ee7ff'; ctx.lineWidth=3; ctx.beginPath(); ctx.moveTo(padL,40); ctx.lineTo(padL+d.rhat*100/50*(W-padL-60)+40,40); ctx.stroke();
    ctx.fillStyle='#5ee7ff'; ctx.beginPath(); ctx.arc(padL,40,5,0,7); ctx.fill(); ctx.beginPath(); ctx.arc(padL+d.rhat*100/50*(W-padL-60)+40,40,5,0,7); ctx.fill();
    ctx.fillStyle='#8ea0be'; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText('A',padL-4,32); ctx.fillText('B',padL+d.rhat*100/50*(W-padL-60)+40,32); ctx.fillText((d.rhat*100).toFixed(1)+' cM',padL+40,30);
    document.getElementById('results').innerHTML=''
      +'<div class="lb-metric"><span class="lb-metric-l">Parental / recombinant</span><span class="lb-metric-v">'+d.par+' / '+d.rec+'</span></div>'
      +'<div class="lb-metric"><span class="lb-metric-l">Estimated r̂</span><span class="lb-metric-v" style="color:#fbbf24;">'+d.rhat.toFixed(3)+'</span></div>'
      +'<div class="lb-metric"><span class="lb-metric-l">Map distance</span><span class="lb-metric-v" style="color:#a78bfa;">'+(d.rhat*100).toFixed(1)+' cM</span></div>'
      +'<div class="lb-metric"><span class="lb-metric-l">Set r (true)</span><span class="lb-metric-v">'+d.r.toFixed(2)+(d.r>=0.5?' · unlinked':'')+'</span></div>'; }

  function sync(){ setTxt('pV',v('p0').toFixed(2)); setTxt('w1V',v('w1').toFixed(2)); setTxt('w2V',v('w2').toFixed(2)); setTxt('w3V',v('w3').toFixed(2)); setTxt('muV',v('mu').toFixed(3)); setTxt('nV',v('popN').toFixed(0)); setTxt('chinV',v('chiN').toFixed(0)); setTxt('rV',v('rf').toFixed(2)); setTxt('lnV',v('lnN').toFixed(0)); }
  function render(){ if(mode==='pop') pop(); else if(mode==='chi') chi(); else link(); }
  document.querySelectorAll('input,select').forEach(function(e){ e.addEventListener('input',function(){ sync(); if(mode==='pop') render(); }); e.addEventListener('change',function(){ if(mode==='chi'){chiRun();} if(mode==='link'){linkRun();} render(); }); });
  document.querySelectorAll('#modeSeg button').forEach(function(b){ b.addEventListener('click',function(){ document.querySelectorAll('#modeSeg button').forEach(function(x){x.classList.remove('on');}); b.classList.add('on'); mode=b.getAttribute('data-m');
    document.getElementById('panPop').style.display=mode==='pop'?'block':'none'; document.getElementById('panChi').style.display=mode==='chi'?'block':'none'; document.getElementById('panLink').style.display=mode==='link'?'block':'none';
    if(mode==='chi')chiRun(); if(mode==='link')linkRun(); render(); }); });
  document.getElementById('runBtn').addEventListener('click',function(){ if(mode==='chi')chiRun(); else if(mode==='link')linkRun(); render(); });
  sync(); render();
})();
</script>
</BaseLayout>
