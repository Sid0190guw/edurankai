---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Structural Analysis · Virtual Labs · AquinTutor" description="Six computing virtual experiments in structural analysis — plane trusses by joints and sections, shear-force and bending-moment diagrams, beam deflection by Macaulay, influence lines and Euler column buckling — every member force, reaction, diagram and critical load solved live in hand-rolled JavaScript with no libraries.">
<style>
  .stx { background:#0a0a0c; color:#e8e8ee; min-height:100vh; font-family:'Geist Mono',ui-monospace,monospace; }
  .stx .wrap { max-width:1280px; margin:0 auto; padding:36px 22px 90px; }
