    }

    function syncRows() { $('sfP2row').style.display = ($('sfKind').value === 'w') ? 'flex' : 'none'; $('sfP1row').style.display = ($('sfKind').value === 'w') ? 'none' : 'flex'; }

    segGroup($('exp-3').querySelector('[data-sfbeam]').parentNode, 'data-sfbeam', function (v) { beam = v; draw(); });
    $('sfL').addEventListener('input', function () { L = parseFloat(this.value); $('sfLv').textContent = L; draw(); });
    $('sfKind').addEventListener('change', syncRows);
    $('sfAdd').addEventListener('click', addLoad);
    $('sfAdd2').addEventListener('click', addLoad);
    $('sfClr').addEventListener('click', function () { loads = []; rebuildTable(); draw(); });
    $('sfDemo').addEventListener('click', function () {
      beam = 'ss';
      var segs = $('exp-3').querySelectorAll('[data-sfbeam]');
      for (var i = 0; i < segs.length; i++) segs[i].classList.toggle('on', segs[i].getAttribute('data-sfbeam') === 'ss');
      L = 8; $('sfL').value = 8; $('sfLv').textContent = 8;
      loads = [{ kind: 'P', mag: 20, a: 2 }, { kind: 'w', mag: 5, a: 4, b: 8 }];
      rebuildTable(); draw();
    });

    REDRAW['3'] = function () { ctx = makeCtx(cv, 680, 500); syncRows(); draw(); };
    loads = [{ kind: 'P', mag: 20, a: 4 }];
    rebuildTable();
    syncRows();
    draw();
  })();

  // ===================================================================
  // EXPERIMENT 4 — DEFLECTION (Macaulay / standard cases)
  // ===================================================================
  (function Deflection() {
    var cv = $('dfCv'); if (!cv) return;
    var ctx = makeCtx(cv, 680, 430);
    var sup = 'ss';

    var CASES = {
      ss: [ { id: 'central', name: 'Central point load' }, { id: 'offset', name: 'Off-centre point load at a' }, { id: 'udl', name: 'Full UDL' } ],
      cant: [ { id: 'end', name: 'End point load' }, { id: 'offc', name: 'Point load at a' }, { id: 'udl', name: 'Full UDL' } ]
    };

    function fillCases() {
      var sel = $('dfCase'); sel.innerHTML = '';
      var arr = CASES[sup];
      for (var i = 0; i < arr.length; i++) { var o = document.createElement('option'); o.value = arr[i].id; o.textContent = arr[i].name; sel.appendChild(o); }
    }

