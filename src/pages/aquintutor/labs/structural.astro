                <svg id="k_curve" class="sa-svg" viewBox="0 0 760 250" preserveAspectRatio="none"></svg>
                <div class="sa-legend">
                  <span><i style="background:#67e8f9"></i> Euler curve</span>
                  <span><i style="background:#fbbf24"></i> Yield cut-off</span>
                  <span><i style="background:#fca5a5"></i> Current column</span>
                </div>
              </div>
