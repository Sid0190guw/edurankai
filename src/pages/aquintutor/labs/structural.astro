  /* ================================================================
     EXPERIMENT 4: deflection by double integration (Macaulay).
     Compute M(x) then integrate twice (trapezoid) with BCs.
     ================================================================ */
  var d_type='ss';
  function deflSolve(type, L, P, a, w) {
    var N=400, i, x;
    var xs=[], M=[];
    var RA, RB;
    if (a>L) a=L;
    if (type==='ss') {
      var Wt=w*L; RB=(P*a + Wt*(L/2))/L; RA=P+Wt-RB;
    } else { RA=P+w*L; RB=0; }
    for (i=0;i<=N;i++){
      x=L*i/N; xs.push(x);
      var mo;
      if (type==='ss') mo = RA*x - w*x*x/2 - (x>=a?P*(x-a):0);
      else {
        var Pr=(a>=x)?P:0, armP=(a>=x)?(a-x):0;
        var wr=w*(L-x), armw=(L-x)/2;
        mo = -(Pr*armP + wr*armw);
      }
      M.push(mo);
    }
    return {xs:xs,M:M,RA:RA,RB:RB,N:N};
  }
  function deflCurve(type, S, L, EI) {
    var N=S.N, h=L/N, i;
    var theta=new Array(N+1), y=new Array(N+1);
    // integrate M/EI -> theta (trapezoid)
    theta[0]=0;
    for (i=1;i<=N;i++) theta[i]=theta[i-1] + (S.M[i-1]+S.M[i])/2*h/EI;
    // integrate theta -> y with C1 such that BC satisfied
    y[0]=0;
    for (i=1;i<=N;i++) y[i]=y[i-1] + (theta[i-1]+theta[i])/2*h;
    // apply BCs
    if (type==='ss') {
      // y(0)=0 already; enforce y(L)=0 by adding linear C1*x to theta -> shifts y by C1*x
      // y_new(x) = y(x) + C1*x ; need y(L)+C1*L=0 => C1=-y(L)/L
      var C1 = -y[N]/L;
      for (i=0;i<=N;i++){ y[i] += C1 * (i*h); theta[i] += C1; }
    } else {
      // cantilever fixed at left: theta(0)=0, y(0)=0 already enforced.
    }
    return {theta:theta, y:y};
  }
  function deflUpdate() {
    var L=v('d_L'), P=v('d_P'), a=v('d_a'), w=v('d_w');
    var E=v('d_E')*1e9, I=v('d_I')*1e-6;
    if (a>L) a=L;
    setText('d_LV', fmt(L,1)); setText('d_PV', P.toFixed(0)); setText('d_aV', fmt(a,2));
    setText('d_wV', w.toFixed(0)); setText('d_EV', (E/1e9).toFixed(0)); setText('d_IV', (I*1e6).toFixed(0));
    var EI = E*I; // N*m^2
    var S = deflSolve(d_type, L, P, a, w);
    // M in kN*m -> N*m for deflection
    var Mn = []; for (var i=0;i<S.M.length;i++) Mn.push(S.M[i]*1000);
    var C = deflCurve(d_type, {xs:S.xs, M:Mn, N:S.N}, L, EI);
    var ymaxAbs=0, ymaxX=0, slopeMax=0;
    for (var k=0;k<C.y.length;k++){ if (Math.abs(C.y[k])>ymaxAbs){ymaxAbs=Math.abs(C.y[k]); ymaxX=S.xs[k];} if (Math.abs(C.theta[k])>slopeMax) slopeMax=Math.abs(C.theta[k]); }
    // y in metres -> mm
    setHTML('d_EI', (EI/1e6).toFixed(1)+' MN&middot;m&sup2;');
    setText('d_dmax', fmt(ymaxAbs*1000,3)+' mm');
    setText('d_dx', fmt(ymaxX,2)+' m');
    setText('d_slope', (slopeMax*1000).toFixed(3)+' mrad');
    setText('d_ratio', 'L/'+(ymaxAbs>1e-9?Math.round(L/ymaxAbs):'∞'));
    // closed-form check for the relevant standard case
    var cf=NaN, cfLabel='';
    if (d_type==='ss' && Math.abs(a-L/2)<0.26 && w<0.5 && P>0) { cf = P*1000*Math.pow(L,3)/(48*EI); cfLabel='PL^3/48EI'; }
    else if (d_type==='ss' && P<0.5 && w>0) { cf = 5*w*1000*Math.pow(L,4)/(384*EI); cfLabel='5wL^4/384EI'; }
    else if (d_type==='cant' && w<0.5 && P>0 && Math.abs(a-L)<0.26) { cf = P*1000*Math.pow(L,3)/(3*EI); cfLabel='PL^3/3EI'; }
    else if (d_type==='cant' && P<0.5 && w>0) { cf = w*1000*Math.pow(L,4)/(8*EI); cfLabel='wL^4/8EI'; }
    setText('d_cf', isFinite(cf) ? (fmt(cf*1000,3)+' mm ('+cfLabel+')') : 'mixed load');
    // draw BMD and curve
    drawDiagram('d_bmd', S.xs, S.M, L, '#fbbf24', 'M');
    drawDeflCurve('d_curve', S.xs, C.y, L, d_type);
  }
  function drawDeflCurve(id, xs, y, L, type) {
    var view=el(id); clr(view);
