  /* ================================================================
     Linear algebra helper — Gaussian elimination (for joint solver)
     ================================================================ */
  function solveLinear(A, b) {
    var n = b.length, i, j, k;
    // augmented copy
    var M = [];
    for (i = 0; i < n; i++) { M[i] = A[i].slice(); M[i].push(b[i]); }
    for (i = 0; i < n; i++) {
      // partial pivot
      var piv = i;
      for (k = i + 1; k < n; k++) if (Math.abs(M[k][i]) > Math.abs(M[piv][i])) piv = k;
      var tmp = M[i]; M[i] = M[piv]; M[piv] = tmp;
      if (Math.abs(M[i][i]) < 1e-12) return null;
      for (k = i + 1; k < n; k++) {
        var f = M[k][i] / M[i][i];
        for (j = i; j <= n; j++) M[k][j] -= f * M[i][j];
      }
    }
    var x = new Array(n);
    for (i = n - 1; i >= 0; i--) {
      var s = M[i][n];
      for (j = i + 1; j < n; j++) s -= M[i][j] * x[j];
      x[i] = s / M[i][i];
    }
    return x;
  }

  /* ================================================================
     EXPERIMENT 1 & 2 share a general pin-jointed truss solver.
     Build node/member lists, assemble 2j equilibrium equations
     (one per joint, x and y), solve member forces + reactions.
     ================================================================ */
  function buildTruss(kind, L, h, loads) {
    // returns nodes [..], members [[a,b]..], sup {pin,roller}, loads [{node,fy}..]
    // Every configuration below is statically determinate: m + r = 2j with r = 3.
    var nodes = [], members = [], loadList = [];
    var sup = {};
    if (kind === 'king') {
      // King-post: bottom A(0,0) B(L,0), mid bottom M(L/2,0), apex T(L/2,h)
      // j=4, m=5, r=3 -> 5+3 = 2*4. Determinate.
      nodes = [{x:0,y:0},{x:L,y:0},{x:L/2,y:h},{x:L/2,y:0}];
      members = [[0,3],[3,1],[0,2],[2,1],[2,3]];
      sup = {pin:0, roller:1};
      loadList = [{node:2, fy:-(loads[0]+loads[1]+loads[2])}];
    } else if (kind === 'warren') {
      // Warren: 4 equal bottom panels (nodes 0..4), 3 top nodes over 1,2,3.
      // j=8, m=13, r=3 -> 13+3 = 2*8. Determinate.
      var pb = 4, dx = L / pb;
      for (var i = 0; i <= pb; i++) nodes.push({x:i*dx, y:0});  // 0..4 bottom
      var ts = nodes.length;
      nodes.push({x:dx, y:h});    // T1 (idx ts)   over node 1
      nodes.push({x:2*dx, y:h});  // T2 (idx ts+1) over node 2
      nodes.push({x:3*dx, y:h});  // T3 (idx ts+2) over node 3
      members.push([0,1]); members.push([1,2]); members.push([2,3]); members.push([3,4]); // bottom chord
      members.push([ts,ts+1]); members.push([ts+1,ts+2]);    // top chord
      members.push([0,ts]); members.push([4,ts+2]);          // end rafters
      members.push([1,ts]); members.push([2,ts+1]); members.push([3,ts+2]); // verticals
      members.push([ts,2]); members.push([ts+2,2]);          // interior diagonals to centre
      sup = {pin:0, roller:4};
      loadList = [{node:1, fy:-loads[0]},{node:2, fy:-loads[1]},{node:3, fy:-loads[2]}];
    } else {
      // Howe / Pratt: 3 bottom panels (nodes 0..3), 2 top nodes over 1,2.
      // j=6, m=9, r=3 -> 9+3 = 2*6. Determinate. The single interior
      // diagonal direction is what distinguishes a Howe from a Pratt panel.
      var pb2 = 3, dx2 = L / pb2;
      for (var b2 = 0; b2 <= pb2; b2++) nodes.push({x:b2*dx2, y:0}); // 0..3 bottom
      var ts2 = nodes.length;
      nodes.push({x:dx2, y:h});    // T1 (idx ts2)   over node 1
      nodes.push({x:2*dx2, y:h});  // T2 (idx ts2+1) over node 2
      members.push([0,1]); members.push([1,2]); members.push([2,3]);    // bottom chord
      members.push([0,ts2]); members.push([ts2,ts2+1]); members.push([ts2+1,3]); // rafters + ridge (top chord)
      members.push([ts2,1]); members.push([ts2+1,2]);   // verticals
      if (kind === 'howe') members.push([1,ts2+1]);      // Howe diagonal: bottom-1 up to top-2
      else members.push([ts2,2]);                        // Pratt diagonal: top-1 down to bottom-2
      sup = {pin:0, roller:3};
      loadList = [{node:1, fy:-loads[0]},{node:2, fy:-loads[1]}];
      if (loads[2]) { loadList.push({node:ts2, fy:-loads[2]/2}); loadList.push({node:ts2+1, fy:-loads[2]/2}); }
    }
    return {nodes:nodes, members:members, sup:sup, loads:loadList, kind:kind};
  }

  function solveTruss(T) {
    var nodes = T.nodes, members = T.members, sup = T.sup, loads = T.loads;
    var nj = nodes.length, nm = members.length;
    // unknowns: nm member forces + 3 reactions (pin Rx,Ry, roller Ry)
    var nUnk = nm + 3;
    var nEq = 2 * nj;
    if (nUnk !== nEq) return null; // not square -> indeterminate or a mechanism; cannot solve by joints alone
    // Build equation system: for each node, x and y equilibrium.
    var A = [], rhs = [];
    for (var r = 0; r < nEq; r++) { A.push(new Array(nUnk)); for (var c = 0; c < nUnk; c++) A[r][c] = 0; rhs.push(0); }
    // member force columns 0..nm-1 ; pin Rx = nm, pin Ry = nm+1, roller Ry = nm+2
    for (var mi = 0; mi < nm; mi++) {
      var a = members[mi][0], bn = members[mi][1];
      var dx = nodes[bn].x - nodes[a].x, dy = nodes[bn].y - nodes[a].y;
      var len = Math.sqrt(dx*dx + dy*dy);
      var cx = dx/len, cy = dy/len;
      // tension pulls each end toward the other
      // node a: +cx, +cy ; node b: -cx, -cy
      A[2*a][mi]   += cx;  A[2*a+1][mi]   += cy;
      A[2*bn][mi]  += -cx; A[2*bn+1][mi]  += -cy;
    }
    // reactions
    A[2*sup.pin][nm]      += 1;  // pin Rx on its x eq
    A[2*sup.pin+1][nm+1]  += 1;  // pin Ry on its y eq
    A[2*sup.roller+1][nm+2]+= 1; // roller Ry
    // applied loads -> move to rhs (equilibrium: sum forces + applied = 0 => unknown forces = -applied)
    for (var li = 0; li < loads.length; li++) {
      rhs[2*loads[li].node+1] -= loads[li].fy;
    }
    var sol = solveLinear(A, rhs);
    if (!sol) return null;
    var forces = sol.slice(0, nm);
    var React = {pinRx: sol[nm], pinRy: sol[nm+1], rollRy: sol[nm+2]};
    // member geometry
    var geo = [];
    for (var g = 0; g < nm; g++) {
      var aa = members[g][0], bb = members[g][1];
      var ddx = nodes[bb].x - nodes[aa].x, ddy = nodes[bb].y - nodes[aa].y;
      var ll = Math.sqrt(ddx*ddx+ddy*ddy);
      geo.push({cos: ddx/ll, sin: ddy/ll, len: ll});
    }
    // residual check: recompute node force balance
    var res = 0;
    for (var ni = 0; ni < nj; ni++) {
      var fx = 0, fy = 0;
      for (var mm = 0; mm < nm; mm++) {
        if (members[mm][0] === ni) { fx += forces[mm]*geo[mm].cos; fy += forces[mm]*geo[mm].sin; }
        if (members[mm][1] === ni) { fx -= forces[mm]*geo[mm].cos; fy -= forces[mm]*geo[mm].sin; }
      }
      if (ni === sup.pin) { fx += React.pinRx; fy += React.pinRy; }
      if (ni === sup.roller) { fy += React.rollRy; }
      for (var lj = 0; lj < loads.length; lj++) if (loads[lj].node === ni) fy += loads[lj].fy;
      res += Math.abs(fx) + Math.abs(fy);
    }
    return {forces: forces, react: React, geo: geo, res: res, nj: nj, nm: nm};
  }

  /* ---------- EXPERIMENT 1: method of joints render ---------- */
  var j_kind = 'howe';
  function jointsUpdate() {
    var L = v('j_L'), h = v('j_h');
    var P1 = v('j_P1'), P2 = v('j_P2'), P3 = v('j_P3');
    setText('j_LV', fmt(L,1)); setText('j_hV', fmt(h,1));
    setText('j_P1V', P1.toFixed(0)); setText('j_P2V', P2.toFixed(0)); setText('j_P3V', P3.toFixed(0));
    var T = buildTruss(j_kind, L, h, [P1,P2,P3]);
    var S = solveTruss(T);
    var view = el('j_view'); clr(view);
    var tbody = el('j_tbody'); clr(tbody);
    if (!S) { txt(view, 380, 180, 'Indeterminate configuration', {fill:'#fca5a5','font-family':'Geist Mono','font-size':'13','text-anchor':'middle'}); return; }

    // determinacy
    var r = 3;
    var det = S.nm + r - 2*S.nj;
    setText('j_m', String(S.nm)); setText('j_j', String(S.nj));
    setText('j_det', (S.nm + r) + ' vs ' + (2*S.nj) + (det===0?'  det' : (det>0?'  indet':'  unstable')));
    setText('j_RA', fmt(S.react.pinRy,1) + ' kN');
    setText('j_RB', fmt(S.react.rollRy,1) + ' kN');

    var Tmax = 0, Cmax = 0;
    for (var f = 0; f < S.forces.length; f++) {
      if (S.forces[f] > Tmax) Tmax = S.forces[f];
      if (S.forces[f] < Cmax) Cmax = S.forces[f];
    }
    setText('j_Tmax', fmt(Tmax,1) + ' kN');
    setText('j_Cmax', fmt(Math.abs(Cmax),1) + ' kN');
    setText('j_res', S.res.toExponential(1) + ' kN');

    // ---- draw ----
    var nodes = T.nodes, members = T.members;
    var minx=1e9,maxx=-1e9,miny=1e9,maxy=-1e9;
    for (var n=0;n<nodes.length;n++){ minx=Math.min(minx,nodes[n].x); maxx=Math.max(maxx,nodes[n].x); miny=Math.min(miny,nodes[n].y); maxy=Math.max(maxy,nodes[n].y);}
    var W=760,H=360,pad=70;
    var sx = (W-2*pad)/((maxx-minx)||1);
    var sy = (H-2*pad-30)/((maxy-miny)||1);
    var sc = Math.min(sx, sy);
    function PX(x){ return pad + (x-minx)*sc; }
    function PY(y){ return H-pad - (y-miny)*sc; }

    // members
    for (var mi=0; mi<members.length; mi++) {
      var fval = S.forces[mi];
      var col = '#3a3a45';
      if (fval > 0.5) col = '#fca5a5';
      else if (fval < -0.5) col = '#86efac';
      var a=members[mi][0], b=members[mi][1];
      svg(view,'line',{x1:PX(nodes[a].x),y1:PY(nodes[a].y),x2:PX(nodes[b].x),y2:PY(nodes[b].y),stroke:col,'stroke-width': (Math.abs(fval) > 0.5 ? 3.2 : 1.6)});
      var mx=(PX(nodes[a].x)+PX(nodes[b].x))/2, my=(PY(nodes[a].y)+PY(nodes[b].y))/2;
      txt(view, mx, my-3, fmt(fval,0), {fill:col,'font-family':'Geist Mono','font-size':'10','text-anchor':'middle'});
    }
    // joints
    for (var ni=0; ni<nodes.length; ni++) {
      svg(view,'circle',{cx:PX(nodes[ni].x),cy:PY(nodes[ni].y),r:4,fill:'#11131a',stroke:'#67e8f9','stroke-width':1.5});
    }
    // supports
    var pn = nodes[T.sup.pin], rn = nodes[T.sup.roller];
    svg(view,'path',{d:'M'+(PX(pn.x)-9)+' '+(PY(pn.y)+16)+' L'+(PX(pn.x))+' '+(PY(pn.y))+' L'+(PX(pn.x)+9)+' '+(PY(pn.y)+16)+' Z',fill:'none',stroke:'#67e8f9','stroke-width':1.5});
    svg(view,'path',{d:'M'+(PX(rn.x)-9)+' '+(PY(rn.y)+16)+' L'+(PX(rn.x))+' '+(PY(rn.y))+' L'+(PX(rn.x)+9)+' '+(PY(rn.y)+16)+' Z',fill:'none',stroke:'#fbbf24','stroke-width':1.5});
    svg(view,'circle',{cx:PX(rn.x)-4,cy:PY(rn.y)+20,r:2.5,fill:'none',stroke:'#fbbf24'});
    svg(view,'circle',{cx:PX(rn.x)+4,cy:PY(rn.y)+20,r:2.5,fill:'none',stroke:'#fbbf24'});
    // load arrows
    for (var ld=0; ld<T.loads.length; ld++) {
      var L0=T.loads[ld]; if (Math.abs(L0.fy)<0.01) continue;
      var nx=PX(nodes[L0.node].x), ny=PY(nodes[L0.node].y);
      svg(view,'line',{x1:nx,y1:ny-46,x2:nx,y2:ny-6,stroke:'#a78bfa','stroke-width':2});
      svg(view,'path',{d:'M'+(nx-5)+' '+(ny-12)+' L'+nx+' '+(ny-2)+' L'+(nx+5)+' '+(ny-12),fill:'none',stroke:'#a78bfa','stroke-width':2});
      txt(view, nx, ny-50, fmt(Math.abs(L0.fy),0)+' kN', {fill:'#a78bfa','font-family':'Geist Mono','font-size':'10','text-anchor':'middle'});
    }
    // reaction arrows
    txt(view, PX(pn.x), PY(pn.y)+34, 'RA='+fmt(S.react.pinRy,0), {fill:'#67e8f9','font-family':'Geist Mono','font-size':'10','text-anchor':'middle'});
    txt(view, PX(rn.x), PY(rn.y)+34, 'RB='+fmt(S.react.rollRy,0), {fill:'#fbbf24','font-family':'Geist Mono','font-size':'10','text-anchor':'middle'});

    // table
    var names = memberNames(T);
    for (var ti=0; ti<S.forces.length; ti++) {
      var tr = document.createElement('tr');
      var fv = S.forces[ti];
      var state = Math.abs(fv) < 0.5 ? 'Zero' : (fv > 0 ? 'Tension' : 'Compression');
      var cls = Math.abs(fv) < 0.5 ? 'z' : (fv > 0 ? 't' : 'c');
      tr.innerHTML = '<td>'+names[ti]+'</td><td>'+fmt(fv,1)+'</td><td class="'+cls+'">'+state+'</td><td>'+fmt(S.geo[ti].cos,2)+' / '+fmt(S.geo[ti].sin,2)+'</td>';
      tbody.appendChild(tr);
    }
  }
  function memberNames(T) {
    var names = [];
    for (var i=0;i<T.members.length;i++) names.push('U'+(i+1));
    return names;
  }
  seg('j_truss', function (t) { j_kind = t; jointsUpdate(); });
  (function(){ var ids=['j_L','j_h','j_P1','j_P2','j_P3']; for (var n=0;n<ids.length;n++) el(ids[n]).addEventListener('input', jointsUpdate); })();
  jointsUpdate();

  /* ================================================================
     EXPERIMENT 2: method of sections (Warren, 4 equal panels)
     Solve top/bottom chord or diagonal directly, then cross-check
     against the full joints solver from above.
     ================================================================ */
  var x_solveMode = 'top';
  function sectionsUpdate() {
    var L = v('x_L'), h = v('x_h'), P = v('x_P');
    var cut = Math.round(v('x_cut'));
    setText('x_LV', fmt(L,1)); setText('x_hV', fmt(h,1)); setText('x_PV', P.toFixed(0));
    setText('x_cutV', String(cut));

    var pb = 4, dx = L/pb;
    // loads at interior bottom nodes 1,2,3
    var R = 3 * P; // total
    // reactions (symmetric loads at x=dx,2dx,3dx)
    var sumMoment = P*dx + P*2*dx + P*3*dx; // about A
    var RB = sumMoment / L;
    var RA = R - RB;
    setText('x_RA', fmt(RA,1)+' kN');
    setText('x_RB', fmt(RB,1)+' kN');

    // section after panel "cut": cut between bottom node `cut` and `cut+1`
    // beam shear and moment at the cut (just right of node `cut`)
    // loads to left of cut: nodes 1..cut (those with index <= cut)
    var loadsLeft = 0, momLeftAboutCut = 0;
    var xcut = cut*dx; // position of the cut along span (at bottom node cut)
    for (var k=1;k<=cut;k++){ loadsLeft += P; }
    var Vcut = RA - loadsLeft;
    // moment at cut section (about the cut point) from left free body
    var Mcut = RA*xcut;
    for (var k2=1;k2<=cut;k2++){ Mcut -= P*(xcut - k2*dx); }

    // member geometry: diagonal angle
    var diagLen = Math.sqrt(dx*dx + h*h);
    var sinA = h/diagLen;
    var Fmem = 0, label='', arm='', work='';
    if (x_solveMode === 'top') {
      // top chord force from moments about the bottom node under the far end of the panel = node (cut+1)
      // Top chord in panel [cut..cut+1]; take moments about bottom node (cut+1): F_top*h = -M about that node
      // Use standard: F_top = -M_cut / h (compression negative-> but parallel chord: top chord compression)
      Fmem = -Mcut / h;
      label = 'Top chord (panel '+cut+'-'+(cut+1)+')';
      arm = 'lever h = '+fmt(h,2)+' m';
      work = 'Take moments about the bottom node at x = '+fmt(xcut,2)+' m. '
           + 'M_cut = R_A&middot;x = '+fmt(Mcut,1)+' kN&middot;m. '
           + 'F_top &middot; h + M_cut = 0  &rarr;  F_top = -M_cut / h = '+fmt(Fmem,1)+' kN.';
    } else if (x_solveMode === 'bot') {
      // bottom chord: moments about top node above the panel
      Fmem = Mcut / h;
      label = 'Bottom chord (panel '+cut+'-'+(cut+1)+')';
      arm = 'lever h = '+fmt(h,2)+' m';
      work = 'Take moments about the top node above the cut. '
           + 'M_cut = '+fmt(Mcut,1)+' kN&middot;m, lever = h = '+fmt(h,2)+' m. '
           + 'F_bot = +M_cut / h = '+fmt(Fmem,1)+' kN (tension if positive).';
    } else {
      // diagonal: vertical equilibrium F_diag*sinA = Vcut
      Fmem = Vcut / sinA;
      label = 'Diagonal crossing the cut';
      arm = 'sin(alpha) = '+fmt(sinA,3);
      work = 'Vertical equilibrium of the left free body: V_cut = R_A - (loads left) = '+fmt(Vcut,1)+' kN. '
           + 'F_diag &middot; sin(alpha) = V_cut  &rarr;  F_diag = V_cut / sin(alpha) = '+fmt(Fmem,1)+' kN.';
    }
    setText('x_mem', label);
    setText('x_arm', arm);
    setText('x_F', fmt(Fmem,1)+' kN');
    var st = Math.abs(Fmem)<0.5 ? 'Zero' : (Fmem>0?'Tension':'Compression');
    var stEl = el('x_state'); stEl.textContent = st;
    stEl.className = 'sa-metric-v ' + (Fmem>0.5?'red':(Fmem<-0.5?'green':''));

    // cross-check: build same Warren truss in joints solver
    var T = buildTruss('warren', L, h, [P,P,P]);
    var SS = solveTruss(T);
    var checkVal = NaN;
    if (SS) {
      // find corresponding member force by matching geometry
      checkVal = matchMember(T, SS, x_solveMode, cut, dx, h);
    }
    var diff = isFinite(checkVal) ? Math.abs(checkVal - Fmem) : NaN;
    setText('x_chk', isFinite(diff) ? ('OK  d='+fmt(diff,2)+' kN') : 'n/a');

    setHTML('x_work', work);
    drawSection(L, h, P, cut, dx, RA, RB, x_solveMode);
  }
  function matchMember(T, S, mode, cut, dx, h) {
    var nodes = T.nodes, members = T.members;
    for (var i=0;i<members.length;i++){
      var a=members[i][0], b=members[i][1];
      var ya=nodes[a].y, yb=nodes[b].y, xa=nodes[a].x, xb=nodes[b].x;
      var mid=(xa+xb)/2;
      if (mode==='bot' && ya<1e-6 && yb<1e-6) {
        // bottom chord in panel cut..cut+1: midpoint = cut*dx + dx/2
        if (Math.abs(mid - (cut*dx + dx/2)) < dx*0.4 && Math.abs(ya)<1e-6 && Math.abs(yb)<1e-6) return S.forces[i];
      }
      if (mode==='top' && ya>h-1e-6 && yb>h-1e-6) {
        if (Math.abs(mid - (cut*dx + dx/2)) < dx*0.6) return S.forces[i];
      }
      if (mode==='diag') {
        // a diagonal: one end top, one end bottom, crossing the cut at xcut=cut*dx
        var isDiag = (Math.abs(ya-yb) > 1e-6) && (Math.abs(xa-xb) > 1e-6);
        if (isDiag && mid > (cut-1)*dx && mid < (cut+1)*dx) return S.forces[i];
      }
    }
    return NaN;
  }
  function drawSection(L, h, P, cut, dx, RA, RB, mode) {
    var view = el('x_view'); clr(view);
    var W=760,Hh=340,pad=70;
    var minx=0,maxx=L,miny=0,maxy=h;
    var sc = Math.min((W-2*pad)/L, (Hh-2*pad-20)/h);
    function PX(x){ return pad + (x-minx)*sc; }
    function PY(y){ return Hh-pad - y*sc; }
    var pb=4;
    var bottom=[], top=[];
    for (var i=0;i<=pb;i++) bottom.push({x:i*dx,y:0});
    top.push({x:dx,y:h}); top.push({x:2*dx,y:h}); top.push({x:3*dx,y:h});
    function line(a,b,col,wid){ svg(view,'line',{x1:PX(a.x),y1:PY(a.y),x2:PX(b.x),y2:PY(b.y),stroke:col,'stroke-width':wid||1.6}); }
    // bottom chord
    for (var bc=0;bc<pb;bc++) line(bottom[bc],bottom[bc+1], (mode==='bot' && bc===cut)?'#fbbf24':'#5a6270', (mode==='bot'&&bc===cut)?3.4:1.8);
    // top chord
    line(top[0],top[1], (mode==='top' && cut===1)?'#fbbf24':'#5a6270'); // approx
    line(top[1],top[2], (mode==='top' && cut===2)?'#fbbf24':'#5a6270');
    // rafters
    line(bottom[0],top[0], (mode==='top'&&cut===0)?'#fbbf24':'#5a6270');
    line(bottom[4],top[2],'#5a6270');
    // verticals + diagonals (Warren-ish)
    line(top[0],bottom[1],'#5a6270'); line(top[1],bottom[2],'#5a6270'); line(top[2],bottom[3],'#5a6270');
    line(bottom[1],top[1], (mode==='diag'&&cut===1)?'#fbbf24':'#5a6270', (mode==='diag'&&cut===1)?3.4:1.6);
    line(bottom[2],top[2], (mode==='diag'&&cut===2)?'#fbbf24':'#5a6270', (mode==='diag'&&cut===2)?3.4:1.6);
    line(top[1],bottom[3], (mode==='diag'&&cut===3)?'#fbbf24':'#5a6270', (mode==='diag'&&cut===3)?3.4:1.6);
    line(top[0],bottom[2],'#5a6270');
    // nodes
    var allN = bottom.concat(top);
    for (var nn=0;nn<allN.length;nn++) svg(view,'circle',{cx:PX(allN[nn].x),cy:PY(allN[nn].y),r:3.5,fill:'#11131a',stroke:'#67e8f9','stroke-width':1.3});
    // section cut dashed line
    var xc = cut*dx;
    svg(view,'line',{x1:PX(xc)+sc*0.0,y1:PY(h)-22,x2:PX(xc),y2:PY(0)+22,stroke:'#fca5a5','stroke-width':2,'stroke-dasharray':'6 4'});
    txt(view, PX(xc), PY(h)-28, 'section', {fill:'#fca5a5','font-family':'Geist Mono','font-size':'10','text-anchor':'middle'});
    // shade left free body
    svg(view,'rect',{x:PX(0)-12,y:PY(h)-16,width:(PX(xc)-PX(0))+12,height:(PY(0)-PY(h))+34,fill:'rgba(103,232,249,0.05)',stroke:'none'});
    // loads
    for (var k=1;k<=3;k++){
      var nx=PX(k*dx), ny=PY(0);
      svg(view,'line',{x1:nx,y1:ny-40,x2:nx,y2:ny-6,stroke:'#a78bfa','stroke-width':2});
      svg(view,'path',{d:'M'+(nx-4)+' '+(ny-12)+' L'+nx+' '+(ny-2)+' L'+(nx+4)+' '+(ny-12),fill:'none',stroke:'#a78bfa','stroke-width':2});
      txt(view, nx, ny-44, fmt(P,0), {fill:'#a78bfa','font-family':'Geist Mono','font-size':'9','text-anchor':'middle'});
    }
    // reactions
    txt(view, PX(0), PY(0)+34, 'RA='+fmt(RA,0), {fill:'#67e8f9','font-family':'Geist Mono','font-size':'10','text-anchor':'middle'});
    txt(view, PX(L), PY(0)+34, 'RB='+fmt(RB,0), {fill:'#fbbf24','font-family':'Geist Mono','font-size':'10','text-anchor':'middle'});
  }
  function setHTML(id, s) {
    var e = el(id); if (!e) return;
    e.innerHTML = s;
  }
  seg('x_solve', function (t){ x_solveMode = t; sectionsUpdate(); });
  (function(){ var ids=['x_L','x_h','x_P','x_cut']; for (var n=0;n<ids.length;n++) el(ids[n]).addEventListener('input', sectionsUpdate); })();
  sectionsUpdate();

  /* ================================================================
     EXPERIMENT 3: SFD / BMD — sampled statics with point load,
     UDL and an applied couple, SS or cantilever.
     ================================================================ */
  var b_type = 'ss';
  function beamSolveSF(type, L, P, a, w, M0, bpos) {
    var N = 320, i, x;
    var xs=[], V=[], M=[];
    var RA, RB, MA=0;
    if (a > L) a = L; if (bpos > L) bpos = L;
    if (type === 'ss') {
      var Wt = w*L;
      // Sum M about A = 0:  RB*L = P*a + Wt*(L/2) + M0(couple adds +)
      RB = (P*a + Wt*(L/2) + M0) / L;
      RA = P + Wt - RB;
    } else {
      RA = P + w*L; RB = 0;
      // fixed-end moment at A (left fixed): reaction moment balances all loads
      MA = -(P*a + w*L*(L/2) + M0); // hogging
    }
    for (i=0;i<=N;i++){
      x = L*i/N; xs.push(x);
      var sh, mo;
      if (type === 'ss') {
        sh = RA - w*x - (x >= a ? P : 0);
        mo = RA*x - w*x*x/2 - (x >= a ? P*(x-a) : 0) + (x >= bpos ? M0 : 0)*0;
        // applied couple steps the moment: add -M0 for x>=bpos (sign convention: positive M0 increases M after)
        mo += (x >= bpos ? -M0 : 0);
      } else {
        // cantilever fixed at left
        sh = RA - w*x - (x >= a ? P : 0);
        // moment from left free body: MA + RA*x - w x^2/2 - P<x-a> - M0 step
        mo = MA + RA*x - w*x*x/2 - (x >= a ? P*(x-a) : 0) + (x >= bpos ? -M0 : 0);
      }
      V.push(sh); M.push(mo);
    }
    return {xs:xs,V:V,M:M,RA:RA,RB:RB,MA:MA,N:N};
  }
  function beamUpdate() {
    var L=v('b_L'), P=v('b_P'), a=v('b_a'), w=v('b_w'), M0=v('b_M0'), bpos=v('b_b');
    if (a>L) { a=L; }
    if (bpos>L) { bpos=L; }
    setText('b_LV', fmt(L,1)); setText('b_PV', P.toFixed(0)); setText('b_aV', fmt(a,2));
    setText('b_wV', w.toFixed(0)); setText('b_M0V', M0.toFixed(0)); setText('b_bV', fmt(bpos,2));
    var S = beamSolveSF(b_type, L, P, a, w, M0, bpos);
    setText('b_RA', fmt(S.RA,2)+' kN');
    setText('b_RB', b_type==='ss' ? fmt(S.RB,2)+' kN' : 'fixed');
    setHTML('b_MA', b_type==='cant' ? (fmt(S.MA,2)+' kN&middot;m') : '—');
    var Vmax=0, Mmax=-1e9, Mmin=1e9, Mx=0;
    for (var i=0;i<S.V.length;i++){ if (Math.abs(S.V[i])>Vmax) Vmax=Math.abs(S.V[i]); if (S.M[i]>Mmax){Mmax=S.M[i];Mx=S.xs[i];} if (S.M[i]<Mmin) Mmin=S.M[i]; }
    setText('b_Vmax', fmt(Vmax,2)+' kN');
    setHTML('b_Mmax', fmt(Mmax,2)+' kN&middot;m');
    setHTML('b_Mmin', fmt(Mmin,2)+' kN&middot;m');
    setText('b_Mx', fmt(Mx,2)+' m');
    drawBeamLoad('b_beam', L, P, a, w, M0, bpos, b_type, S);
    drawDiagram('b_sfd', S.xs, S.V, L, '#67e8f9', 'V');
    drawDiagram('b_bmd', S.xs, S.M, L, '#fbbf24', 'M');
  }
  function drawBeamLoad(id, L, P, a, w, M0, bpos, type, S) {
    var view = el(id); clr(view);
    var W=760,H=170,pad=60, y0=95;
