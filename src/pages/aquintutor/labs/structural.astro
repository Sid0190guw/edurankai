  /* ================================================================
     EXPERIMENT 5: influence lines for a simply-supported beam.
     ================================================================ */
  var i_quant='RA';
  function ilOrdinate(quant, L, c, x) {
    // unit load at x; returns response ordinate
    var RA=(L-x)/L, RB=x/L;
    if (quant==='RA') return RA;
    if (quant==='RB') return RB;
    if (quant==='V') {
      // shear at section c: if load right of c, V_c = RA ; if load left of c, V_c = RA - 1 = -RB
      return (x > c) ? RA : (RA - 1);
    }
    if (quant==='M') {
      // moment at c
      return (x <= c) ? ((L - c)*x/L) : (c*(L - x)/L);
    }
    return 0;
  }
  function inflUpdate() {
    var L=v('i_L'), c=v('i_c'), x=v('i_x');
    if (c>L) c=L; if (x>L) x=L;
    setText('i_LV', fmt(L,1)); setText('i_cV', fmt(c,2)); setText('i_xV', fmt(x,1));
    // sample IL
    var N=400, xs=[], ys=[];
    var peak=0, peakx=0, areaPos=0, prevx=0, prevy=0;
    for (var k=0;k<=N;k++){
      var xx=L*k/N; var yy=ilOrdinate(i_quant, L, c, xx);
      xs.push(xx); ys.push(yy);
      if (Math.abs(yy)>Math.abs(peak)){ peak=yy; peakx=xx; }
      if (k>0){ var dseg=xx-prevx; var avg=(yy+prevy)/2; if (avg>0) areaPos+=avg*dseg; }
      prevx=xx; prevy=yy;
    }
    var ordAtLoad = ilOrdinate(i_quant, L, c, x);
    setText('i_ord', fmt(ordAtLoad,4));
    setText('i_peak', fmt(peak,4));
    setText('i_peakx', fmt(peakx,2)+' m');
    setText('i_area', fmt(areaPos,3)+' m');
    // example: a single 50 kN moving load effect at current position
    setHTML('i_eff', fmt(50*ordAtLoad,2)+' (50 kN&middot;ord)');
    // formula text
    var f='';
    if (i_quant==='RA') f='IL[R_A] = (L - x)/L. Unit at A gives 1, at B gives 0.';
    else if (i_quant==='RB') f='IL[R_B] = x/L. Unit at B gives 1, at A gives 0.';
    else if (i_quant==='V') f='IL[V_C]: equals R_A for the load right of C, and R_A - 1 to the left. A unit jump occurs at C.';
    else f='IL[M_C] = (L-c)&middot;x/L for x &le; c, and c&middot;(L-x)/L for x &ge; c. Peak c&middot;(L-c)/L at C = '+fmt(c*(L-c)/L,3)+' m.';
    setHTML('i_formula', f);
    drawILBeam('i_beam', L, c, x);
    drawIL('i_il', xs, ys, L, x, ordAtLoad);
  }
  function drawILBeam(id, L, c, x) {
