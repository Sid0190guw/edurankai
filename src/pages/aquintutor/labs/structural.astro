  /* ================================================================
     EXPERIMENT 6: Euler column buckling.
     ================================================================ */
  var k_end='pp';
  var K_FACT = {pp:1.0, ff:0.5, fp:0.699, ffree:2.0};
  var K_NAME = {pp:'Pinned-Pinned', ff:'Fixed-Fixed', fp:'Fixed-Pinned', ffree:'Fixed-Free'};
  function buckUpdate() {
    var L=v('k_L'), E=v('k_E')*1e9, d=v('k_d')/1000, sy=v('k_sy')*1e6;
    setText('k_LV', fmt(L,1)); setText('k_EV', (E/1e9).toFixed(0)); setText('k_dV', (d*1000).toFixed(0)); setText('k_syV', (sy/1e6).toFixed(0));
    var K=K_FACT[k_end];
    var A=Math.PI*d*d/4;
    var I=Math.PI*Math.pow(d,4)/64;
    var rgyr=Math.sqrt(I/A); // = d/4
    var slen=K*L/rgyr;
    var Pcr=Math.PI*Math.PI*E*I/Math.pow(K*L,2); // N
    var scr=Pcr/A; // Pa
    var mode = (scr <= sy) ? 'Elastic Euler buckling' : 'Yields first (short column)';
    setText('k_K', fmt(K,3));
    setHTML('k_I', (I*1e8).toFixed(2)+' &times;10&#8315;&#8312; m&#8308;');
    setText('k_r', (rgyr*1000).toFixed(2)+' mm');
    setText('k_slen', fmt(slen,1));
    setText('k_Pcr', (Pcr/1000).toFixed(2)+' kN');
    setText('k_scr', (scr/1e6).toFixed(1)+' MPa');
    var modeEl=el('k_mode'); modeEl.textContent=mode; modeEl.className='sa-metric-v '+(scr<=sy?'green':'red');
    setHTML('k_formula', 'P_cr = pi&sup2;&middot;E&middot;I / (K&middot;L)&sup2; = '+(Pcr/1000).toFixed(1)+' kN.&nbsp; sigma_cr = pi&sup2;&middot;E / (KL/r)&sup2; = '+(scr/1e6).toFixed(1)+' MPa.&nbsp; Transition slenderness (sigma_cr = sigma_y) = '+fmt(Math.PI*Math.sqrt(E/sy),1)+'.');
    drawBuckCurve('k_curve', E, sy, slen, scr/1e6);
    drawMode('k_mode_svg', k_end, scr<=sy);
  }
  function drawBuckCurve(id, E, sy, curSlen, curScrMPa) {
    var view=el(id); clr(view);
    var W=760,H=250,pad=46;
    var lamMax=200, sMax=sy/1e6*1.25;
    function PX(lam){ return pad + lam/lamMax*(W-2*pad); }
    function PY(s){ return H-pad - s/sMax*(H-2*pad); }
    // axes
    svg(view,'line',{x1:pad,y1:H-pad,x2:W-pad,y2:H-pad,stroke:'#2a2a35','stroke-width':1});
    svg(view,'line',{x1:pad,y1:pad,x2:pad,y2:H-pad,stroke:'#2a2a35','stroke-width':1});
    // yield cut-off
    svg(view,'line',{x1:pad,y1:PY(sy/1e6),x2:W-pad,y2:PY(sy/1e6),stroke:'#fbbf24','stroke-width':1.5,'stroke-dasharray':'5 4'});
    txt(view, W-pad-2, PY(sy/1e6)-5, 'sigma_y='+(sy/1e6).toFixed(0)+' MPa', {fill:'#fbbf24','font-family':'Geist Mono','font-size':'9','text-anchor':'end'});
    // Euler hyperbola sigma = pi^2 E / lam^2
    var d='';
    for (var lam=8; lam<=lamMax; lam+=2) {
      var s=Math.PI*Math.PI*(E/1e6)/(lam*lam);
      if (s>sMax) continue;
      d += (d===''?'M':' L')+PX(lam)+' '+PY(s);
    }
    svg(view,'path',{d:d,fill:'none',stroke:'#67e8f9','stroke-width':2.2});
    // transition slenderness
    var lamTr=Math.PI*Math.sqrt(E/sy);
    svg(view,'line',{x1:PX(lamTr),y1:pad,x2:PX(lamTr),y2:H-pad,stroke:'#5a6270','stroke-width':1,'stroke-dasharray':'3 3'});
    txt(view, PX(lamTr), pad+10, 'transition '+fmt(lamTr,0), {fill:'#9aa6b6','font-family':'Geist Mono','font-size':'9','text-anchor':'middle'});
    // current point (clamp display of scr to plot)
    var plotS=Math.min(curScrMPa, sMax);
    var plotLam=Math.min(curSlen, lamMax);
    svg(view,'circle',{cx:PX(plotLam),cy:PY(plotS),r:5,fill:'#fca5a5',stroke:'#0a0a0c','stroke-width':1.5});
    txt(view, PX(plotLam), PY(plotS)-10, 'KL/r='+fmt(curSlen,0), {fill:'#fca5a5','font-family':'Geist Mono','font-size':'10','text-anchor':'middle'});
    // axis labels
    txt(view, W/2, H-pad+24, 'slenderness  K&middot;L / r', {fill:'#9aa6b6','font-family':'Geist Mono','font-size':'10','text-anchor':'middle'});
    txt(view, pad-6, pad+4, 'sigma_cr (MPa)', {fill:'#9aa6b6','font-family':'Geist Mono','font-size':'9'});
    txt(view, PX(0), H-pad+14, '0', {fill:'#6b7280','font-family':'Geist Mono','font-size':'9','text-anchor':'middle'});
    txt(view, PX(lamMax), H-pad+14, String(lamMax), {fill:'#6b7280','font-family':'Geist Mono','font-size':'9','text-anchor':'middle'});
  }
  function drawMode(id, end, elastic) {
    var view=el(id); clr(view);
    var W=760,H=200, cy=H/2, x0=120, x1=640, len=x1-x0;
    // baseline column position (vertical drawn horizontally for space) -> draw horizontal column buckling vertically
    // We'll draw the column horizontally from x0 to x1, deflect in y.
    var amp=42;
    // mode shape per end condition (first buckling mode)
    function shape(t) { // t in 0..1 along length
      if (end==='pp') return Math.sin(Math.PI*t);
      if (end==='ff') return (1-Math.cos(2*Math.PI*t))/2;
      if (end==='fp') { var bta=4.4934; return Math.sin(bta*t) - bta*t*Math.cos(bta); } // clamped-pinned eigenmode
      if (end==='ffree') return 1-Math.cos(Math.PI*t/2);
      return Math.sin(Math.PI*t);
    }
    // normalise shape to max 1
    var maxs=1e-9; for (var s=0;s<=1.001;s+=0.01){ maxs=Math.max(maxs, Math.abs(shape(s))); }
    var col=elastic ? '#67e8f9' : '#fca5a5';
    // straight reference
    svg(view,'line',{x1:x0,y1:cy,x2:x1,y2:cy,stroke:'#2a2a35','stroke-width':1,'stroke-dasharray':'4 4'});
    // buckled shape
    var d='';
    for (var t=0;t<=1.0001;t+=0.01){
      var px=x0+t*len;
      var py=cy - shape(t)/maxs*amp;
      d += (d===''?'M':' L')+px+' '+py;
    }
    svg(view,'path',{d:d,fill:'none',stroke:col,'stroke-width':3});
    // end supports
    function endMark(x, kind) {
      if (kind==='fix') {
        svg(view,'rect',{x:x-(x===x0?10:0),y:cy-26,width:10,height:52,fill:'#2a2a35',stroke:'#67e8f9'});
      } else if (kind==='pin') {
        svg(view,'path',{d:'M'+(x-10)+' '+(cy+16)+' L'+x+' '+cy+' L'+(x+10)+' '+(cy+16)+' Z',fill:'none',stroke:'#67e8f9','stroke-width':1.5});
      } else {
        svg(view,'circle',{cx:x,cy:cy,r:4,fill:'#fca5a5'}); // free
      }
    }
    var ends = {pp:['pin','pin'], ff:['fix','fix'], fp:['fix','pin'], ffree:['fix','free']};
    var ee=ends[end];
    endMark(x0, ee[0]); endMark(x1, ee[1]);
    // axial load arrows
    svg(view,'line',{x1:x0-44,y1:cy,x2:x0-8,y2:cy,stroke:'#a78bfa','stroke-width':2.4});
    svg(view,'path',{d:'M'+(x0-16)+' '+(cy-5)+' L'+(x0-6)+' '+cy+' L'+(x0-16)+' '+(cy+5),fill:'none',stroke:'#a78bfa','stroke-width':2.4});
    svg(view,'line',{x1:x1+44,y1:cy,x2:x1+8,y2:cy,stroke:'#a78bfa','stroke-width':2.4});
    svg(view,'path',{d:'M'+(x1+16)+' '+(cy-5)+' L'+(x1+6)+' '+cy+' L'+(x1+16)+' '+(cy+5),fill:'none',stroke:'#a78bfa','stroke-width':2.4});
    txt(view, x0-46, cy-12, 'P', {fill:'#a78bfa','font-family':'Geist Mono','font-size':'12','text-anchor':'middle'});
    txt(view, x1+46, cy-12, 'P', {fill:'#a78bfa','font-family':'Geist Mono','font-size':'12','text-anchor':'middle'});
    txt(view, (x0+x1)/2, cy+70, K_NAME[end]+'  (K='+fmt(K_FACT[end],3)+')', {fill:'#9aa6b6','font-family':'Geist Mono','font-size':'11','text-anchor':'middle'});
  }
  seg('k_end', function(t){ k_end=t; buckUpdate(); });
  (function(){ var ids=['k_L','k_E','k_d','k_sy']; for (var n=0;n<ids.length;n++) el(ids[n]).addEventListener('input', buckUpdate); })();
  buckUpdate();

})();
</script>

</BaseLayout>
