---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Cybersecurity · Virtual Labs · AquinTutor" description="Ciphers, RSA, Diffie-Hellman, hashing avalanche and password strength — all computed live.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; }
  .cy-wrap { max-width: 1180px; margin: 0 auto; padding: 18px 4vw 80px; }
  .cy-back { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #67e8f9; text-decoration: none; letter-spacing: 0.08em; }
  .cy-eye { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 12px 0 4px; }
  .cy-title { font-family: 'Cormorant Garamond', serif; font-size: 38px; font-weight: 600; margin: 0; letter-spacing: -0.02em; line-height: 1.05; }
  .cy-title em { color: #a78bfa; font-style: italic; font-weight: 500; }
  .cy-sub { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12px; color: #9aa6b6; margin: 8px 0 0; max-width: 720px; line-height: 1.6; }

  .cy-tabs { display: flex; flex-wrap: wrap; gap: 6px; margin: 22px 0 18px; border-bottom: 1px solid #2a2a35; padding-bottom: 12px; }
  .cy-tab { background: #11131a; border: 1px solid #2a2a35; color: #cfd6da; padding: 8px 14px; border-radius: 8px; cursor: pointer; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; transition: all 0.12s; }
  .cy-tab:hover { border-color: #67e8f9; color: #e8e8ee; }
  .cy-tab.active { background: #67e8f9; color: #04161b; border-color: #67e8f9; }

  .cy-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 18px; margin-bottom: 16px; }
  .cy-panel h3 { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 12px; }
  .cy-grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 820px) { .cy-grid2 { grid-template-columns: 1fr; } }

  .cy-view { display: none; }
  .cy-view.active { display: block; }

  label.cy-lab { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; display: flex; justify-content: space-between; margin: 0 0 5px; }
  label.cy-lab span { color: #67e8f9; }
  .cy-in { width: 100%; box-sizing: border-box; background: #0a0a0c; border: 1px solid #2a2a35; color: #e8e8ee; padding: 9px 11px; border-radius: 6px; font-size: 13px; font-family: 'Geist Mono', ui-monospace, monospace; margin-bottom: 12px; }
  .cy-in:focus { outline: none; border-color: #67e8f9; }
  textarea.cy-in { resize: vertical; min-height: 64px; line-height: 1.5; }
  select.cy-in { cursor: pointer; }
  input[type=range].cy-in { padding: 0; }

  .cy-out { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; padding: 12px 14px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 13px; line-height: 1.7; word-break: break-all; color: #e8e8ee; white-space: pre-wrap; }
  .cy-out.cyan { border-color: #67e8f9; }
  .cy-out.purple { border-color: #a78bfa; }
  .cy-mono { font-family: 'Geist Mono', ui-monospace, monospace; }
  .cy-c { color: #67e8f9; } .cy-p { color: #a78bfa; } .cy-a { color: #fbbf24; } .cy-g { color: #86efac; } .cy-r { color: #fca5a5; } .cy-dim { color: #9aa6b6; }

  .cy-btn { background: #a78bfa; color: #160a2b; padding: 9px 16px; border-radius: 6px; border: none; cursor: pointer; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
  .cy-btn:hover { filter: brightness(1.08); }
  .cy-btn.ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
  .cy-btn.cyan { background: #67e8f9; color: #04161b; }

  .cy-note { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #9aa6b6; line-height: 1.6; margin: 10px 0 0; }
  .cy-kv { display: grid; grid-template-columns: max-content 1fr; gap: 4px 14px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12.5px; line-height: 1.7; }
  .cy-kv .k { color: #9aa6b6; }
  .cy-kv .v { color: #e8e8ee; word-break: break-all; }
  .cy-steps { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12px; color: #cfd6da; line-height: 1.85; margin: 0; }
  .cy-meter { height: 14px; border-radius: 7px; background: #0a0a0c; border: 1px solid #2a2a35; overflow: hidden; margin: 10px 0 6px; }
  .cy-meter > div { height: 100%; transition: width 0.18s, background 0.18s; }
  .cy-bars { width: 100%; height: 200px; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; }
  .cy-dh { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; }
  .cy-pill { display: inline-block; padding: 3px 10px; border-radius: 999px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
</style>

<main class="cy-wrap">
  <a class="cy-back" href="/aquintutor/labs">&larr; Virtual labs</a>
  <p class="cy-eye">Security &middot; Cryptography</p>
  <h1 class="cy-title">Cybersecurity <em>lab</em>.</h1>
  <p class="cy-sub">Hands-on cryptography, computed live in your browser. Break a Caesar cipher with chi-squared analysis, run RSA over real BigInt arithmetic, exchange a Diffie-Hellman key, measure the SHA-256 avalanche effect, and estimate password crack times. Nothing is faked.</p>

  <div class="cy-tabs" id="cyTabs">
    <button class="cy-tab active" data-tab="cipher">Classical ciphers</button>
    <button class="cy-tab" data-tab="rsa">RSA</button>
    <button class="cy-tab" data-tab="dh">Diffie-Hellman</button>
    <button class="cy-tab" data-tab="hash">Hashing &amp; avalanche</button>
    <button class="cy-tab" data-tab="pw">Password strength</button>
  </div>

  <!-- ============ 1. CIPHERS ============ -->
  <section class="cy-view active" data-view="cipher">
    <div class="cy-grid2">
      <div class="cy-panel">
        <h3>Caesar cipher</h3>
        <label class="cy-lab">Shift <span id="caesarKv">3</span></label>
        <input id="caesarShift" class="cy-in" type="range" min="0" max="25" step="1" value="3"/>
        <label class="cy-lab">Plaintext</label>
        <textarea id="caesarPt" class="cy-in" spellcheck="false">The quick brown fox jumps over the lazy dog</textarea>
        <label class="cy-lab">Ciphertext</label>
        <div id="caesarCt" class="cy-out cyan"></div>
        <div style="margin-top:12px;display:flex;gap:8px;flex-wrap:wrap;">
          <button id="caesarCrack" class="cy-btn cyan">Auto-crack (chi-squared)</button>
        </div>
        <div id="caesarCrackOut" style="margin-top:12px;"></div>
      </div>

      <div class="cy-panel">
        <h3>Vigenere cipher</h3>
        <label class="cy-lab">Keyword</label>
        <input id="vigKey" class="cy-in" type="text" value="LEMON" spellcheck="false"/>
        <label class="cy-lab">Plaintext</label>
        <textarea id="vigPt" class="cy-in" spellcheck="false">ATTACK AT DAWN</textarea>
        <label class="cy-lab">Encrypted</label>
        <div id="vigCt" class="cy-out purple"></div>
        <label class="cy-lab" style="margin-top:12px;">Decrypted back</label>
        <div id="vigDt" class="cy-out"></div>
      </div>
    </div>

    <div class="cy-panel">
      <h3>Letter frequency of ciphertext</h3>
      <p class="cy-note">A monoalphabetic cipher (Caesar) preserves the English frequency profile, just shifted &mdash; that is exactly what lets us crack it. Vigenere flattens it. Bars below are for the <span class="cy-c">Caesar ciphertext</span>; the dashed line marks expected English frequency.</p>
      <svg id="freqChart" class="cy-bars" viewBox="0 0 1040 200" preserveAspectRatio="none"></svg>
    </div>
  </section>

  <!-- ============ 2. RSA ============ -->
  <section class="cy-view" data-view="rsa">
    <div class="cy-grid2">
      <div class="cy-panel">
        <h3>Key generation</h3>
        <label class="cy-lab">Prime p</label>
        <input id="rsaP" class="cy-in" type="number" value="61" min="2"/>
        <label class="cy-lab">Prime q</label>
        <input id="rsaQ" class="cy-in" type="number" value="53" min="2"/>
        <label class="cy-lab">Public exponent e (must be coprime to phi)</label>
        <select id="rsaE" class="cy-in">
          <option value="3">3</option>
          <option value="17" selected>17</option>
          <option value="257">257</option>
          <option value="65537">65537</option>
        </select>
        <p class="cy-note">Suggested primes: 53, 59, 61, 67, 71, 101, 137, 211, 257, 1009, 7919, 65521.</p>
        <div id="rsaKeyOut" style="margin-top:8px;"></div>
      </div>

      <div class="cy-panel">
        <h3>Encrypt / decrypt</h3>
        <label class="cy-lab">Message integer m (0 &le; m &lt; n)</label>
        <input id="rsaM" class="cy-in" type="number" value="65" min="0"/>
        <label class="cy-lab">Ciphertext c = m^e mod n</label>
        <div id="rsaC" class="cy-out cyan"></div>
        <label class="cy-lab" style="margin-top:12px;">Recovered m = c^d mod n</label>
        <div id="rsaR" class="cy-out purple"></div>
      </div>
    </div>
    <div class="cy-panel">
      <h3>Worked steps</h3>
      <div id="rsaSteps" class="cy-steps"></div>
    </div>
  </section>

  <!-- ============ 3. DIFFIE-HELLMAN ============ -->
  <section class="cy-view" data-view="dh">
    <div class="cy-panel">
      <h3>Parameters</h3>
      <div class="cy-grid2">
        <div>
          <label class="cy-lab">Public prime p</label>
          <input id="dhP" class="cy-in" type="number" value="23" min="3"/>
          <label class="cy-lab">Public generator g</label>
          <input id="dhG" class="cy-in" type="number" value="5" min="2"/>
        </div>
        <div>
          <label class="cy-lab">Alice private a (secret)</label>
          <input id="dhA" class="cy-in" type="number" value="6" min="1"/>
          <label class="cy-lab">Bob private b (secret)</label>
          <input id="dhB" class="cy-in" type="number" value="15" min="1"/>
        </div>
      </div>
      <div id="dhValid" class="cy-note"></div>
    </div>
    <div class="cy-panel">
      <h3>The exchange</h3>
      <svg id="dhDiagram" class="cy-dh" viewBox="0 0 1040 320" preserveAspectRatio="xMidYMid meet"></svg>
      <div id="dhResult" style="margin-top:14px;"></div>
    </div>
  </section>

  <!-- ============ 4. HASHING ============ -->
  <section class="cy-view" data-view="hash">
    <div class="cy-panel">
      <h3>SHA-256 &mdash; avalanche effect</h3>
      <label class="cy-lab">Input A</label>
      <textarea id="hashA" class="cy-in" spellcheck="false">Hello, world</textarea>
      <label class="cy-lab">SHA-256(A)</label>
      <div id="hashOutA" class="cy-out cyan"></div>

      <div style="margin:14px 0 0;display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
        <button id="hashFlip" class="cy-btn ghost">Flip one bit of A &rarr; B</button>
        <span class="cy-note" style="margin:0;">or edit Input B directly</span>
      </div>
      <label class="cy-lab" style="margin-top:12px;">Input B</label>
      <textarea id="hashB" class="cy-in" spellcheck="false">Hello, World</textarea>
      <label class="cy-lab">SHA-256(B)</label>
      <div id="hashOutB" class="cy-out purple"></div>

      <div id="hashAval" style="margin-top:16px;"></div>
    </div>
  </section>

  <!-- ============ 5. PASSWORD ============ -->
  <section class="cy-view" data-view="pw">
    <div class="cy-panel">
      <h3>Password strength &amp; crack time</h3>
      <label class="cy-lab">Password (computed locally, never sent)</label>
      <input id="pwIn" class="cy-in" type="text" value="P@ssw0rd" spellcheck="false" autocomplete="off"/>
      <label class="cy-lab">Attacker speed</label>
      <select id="pwRate" class="cy-in">
        <option value="1000">Online throttled &mdash; 1,000 guesses/sec</option>
        <option value="1000000000" selected>Single GPU &mdash; 1e9 guesses/sec</option>
        <option value="1000000000000">Cluster &mdash; 1e12 guesses/sec</option>
      </select>
      <div class="cy-meter"><div id="pwBar" style="width:0%;background:#fca5a5;"></div></div>
      <div id="pwVerdict" style="margin:6px 0 14px;"></div>
      <div id="pwDetail" class="cy-kv"></div>
      <p class="cy-note">Entropy assumes a random password drawn from the detected character classes (worst case for the defender). Real human passwords are far weaker because they are not random &mdash; dictionary and pattern attacks beat brute force. This is an upper bound on strength.</p>
    </div>
  </section>
</main>

<script is:inline>
(function () {
  function $(id) { return document.getElementById(id); }
  function el(tag, attrs, text) {
    var e = document.createElement(tag);
    if (attrs) for (var k in attrs) e.setAttribute(k, attrs[k]);
    if (text != null) e.textContent = text;
    return e;
  }
  function svg(tag, attrs) {
    var e = document.createElementNS('http://www.w3.org/2000/svg', tag);
    for (var k in attrs) e.setAttribute(k, attrs[k]);
    return e;
  }

  /* ---------- TABS ---------- */
  var tabs = document.querySelectorAll('.cy-tab');
  var views = document.querySelectorAll('.cy-view');
  for (var t = 0; t < tabs.length; t++) {
    tabs[t].addEventListener('click', function () {
      var name = this.getAttribute('data-tab');
      for (var i = 0; i < tabs.length; i++) tabs[i].classList.toggle('active', tabs[i] === this);
      for (var j = 0; j < views.length; j++) views[j].classList.toggle('active', views[j].getAttribute('data-view') === name);
      if (name === 'rsa') runRSA();
      if (name === 'dh') runDH();
      if (name === 'hash') runHash();
      if (name === 'pw') runPW();
    });
  }

  /* ===================================================================
     1. CLASSICAL CIPHERS
     =================================================================== */
  // Expected English letter frequencies (%) A..Z
  var ENG = [8.167,1.492,2.782,4.253,12.702,2.228,2.015,6.094,6.966,0.153,
             0.772,4.025,2.406,6.749,7.507,1.929,0.095,5.987,6.327,9.056,
             2.758,0.978,2.360,0.150,1.974,0.074];

  function caesarShift(str, k) {
    var out = '';
    for (var i = 0; i < str.length; i++) {
      var c = str.charCodeAt(i);
      if (c >= 65 && c <= 90) out += String.fromCharCode((c - 65 + k) % 26 + 65);
      else if (c >= 97 && c <= 122) out += String.fromCharCode((c - 97 + k) % 26 + 97);
      else out += str[i];
    }
    return out;
  }

  function vigenere(str, key, decrypt) {
    var clean = key.toUpperCase().replace(/[^A-Z]/g, '');
    if (!clean.length) return str;
    var out = '', ki = 0;
    for (var i = 0; i < str.length; i++) {
      var c = str.charCodeAt(i), base, k = clean.charCodeAt(ki % clean.length) - 65;
      if (decrypt) k = (26 - k) % 26;
      if (c >= 65 && c <= 90) { base = 65; }
      else if (c >= 97 && c <= 122) { base = 97; }
      else { out += str[i]; continue; }
      out += String.fromCharCode((c - base + k) % 26 + base);
      ki++;
    }
    return out;
  }

  function letterCounts(str) {
    var counts = new Array(26); for (var i = 0; i < 26; i++) counts[i] = 0;
    var total = 0;
    for (var j = 0; j < str.length; j++) {
      var c = str.charCodeAt(j);
      if (c >= 65 && c <= 90) { counts[c - 65]++; total++; }
      else if (c >= 97 && c <= 122) { counts[c - 97]++; total++; }
    }
    return { counts: counts, total: total };
  }

  // chi-squared statistic between observed letter dist and English
  function chiSquared(str) {
    var lc = letterCounts(str), n = lc.total;
    if (!n) return 1e12;
    var chi = 0;
    for (var i = 0; i < 26; i++) {
      var expected = n * ENG[i] / 100;
      var diff = lc.counts[i] - expected;
      chi += diff * diff / (expected || 0.0001);
    }
    return chi;
  }

  function crackCaesar(ct) {
    var best = { shift: 0, chi: Infinity, pt: '' };
    var table = [];
    for (var s = 0; s < 26; s++) {
      // decrypting by s == encrypting by (26-s)
      var candidate = caesarShift(ct, (26 - s) % 26);
      var chi = chiSquared(candidate);
      table.push({ shift: s, chi: chi, pt: candidate });
      if (chi < best.chi) { best = { shift: s, chi: chi, pt: candidate }; }
    }
    table.sort(function (a, b) { return a.chi - b.chi; });
    return { best: best, table: table };
  }

  function drawFreqChart(str) {
    var s = $('freqChart'); s.innerHTML = '';
    var W = 1040, H = 200, padB = 26, padT = 10, padL = 6;
    var lc = letterCounts(str), n = lc.total || 1;
    var pct = []; var maxP = 13;
    for (var i = 0; i < 26; i++) { pct[i] = lc.counts[i] / n * 100; if (pct[i] > maxP) maxP = pct[i]; }
    var bw = (W - padL * 2) / 26;
    // baseline
    s.appendChild(svg('line', { x1: padL, y1: H - padB, x2: W - padL, y2: H - padB, stroke: '#2a2a35' }));
    for (var i = 0; i < 26; i++) {
      var x = padL + i * bw;
      var h = (pct[i] / maxP) * (H - padB - padT);
      s.appendChild(svg('rect', { x: x + 2, y: H - padB - h, width: bw - 4, height: Math.max(0, h), fill: '#67e8f9', rx: 2 }));
      // expected (dashed) tick
      var eh = (ENG[i] / maxP) * (H - padB - padT);
      s.appendChild(svg('line', { x1: x + 2, y1: H - padB - eh, x2: x + bw - 2, y2: H - padB - eh, stroke: '#fbbf24', 'stroke-width': 1.4, 'stroke-dasharray': '3 2', opacity: 0.85 }));
      var lab = svg('text', { x: x + bw / 2, y: H - 10, fill: '#9aa6b6', 'font-size': 10, 'font-family': 'Geist Mono, monospace', 'text-anchor': 'middle' });
      lab.textContent = String.fromCharCode(65 + i);
      s.appendChild(lab);
    }
  }

  function runCipher() {
    var shift = parseInt($('caesarShift').value, 10);
    $('caesarKv').textContent = shift;
    var pt = $('caesarPt').value;
    var ct = caesarShift(pt, shift);
    $('caesarCt').textContent = ct;

    var vpt = $('vigPt').value, vkey = $('vigKey').value;
    var vct = vigenere(vpt, vkey, false);
    $('vigCt').textContent = vct;
    $('vigDt').textContent = vigenere(vct, vkey, true);

    drawFreqChart(ct);
  }

  $('caesarCrack').addEventListener('click', function () {
    var ct = $('caesarCt').textContent;
    var res = crackCaesar(ct);
    var box = $('caesarCrackOut'); box.innerHTML = '';
    var head = el('div', { class: 'cy-out cyan' });
    head.innerHTML = '';
    head.appendChild(el('div', { class: 'cy-mono cy-g' }, 'Recovered shift k = ' + res.best.shift + '  (chi^2 = ' + res.best.chi.toFixed(2) + ')'));
    head.appendChild(el('div', { class: 'cy-mono', style: 'margin-top:6px;color:#e8e8ee;' }, res.best.pt));
    box.appendChild(head);
    var rank = el('div', { class: 'cy-note', style: 'margin-top:10px;' });
    var lines = 'Top candidates by chi-squared (lower = closer to English):\n';
    for (var i = 0; i < 5; i++) {
      var r = res.table[i];
      lines += '  k=' + (r.shift < 10 ? ' ' : '') + r.shift + '   chi^2=' + r.chi.toFixed(1) + '   "' + r.pt.slice(0, 28) + '"\n';
    }
    rank.textContent = lines;
    box.appendChild(rank);
  });

  ['caesarShift', 'caesarPt', 'vigKey', 'vigPt'].forEach(function (id) {
    $(id).addEventListener('input', runCipher);
  });

  /* ===================================================================
     2. RSA (BigInt from scratch)
     =================================================================== */
  function isPrime(n) {
    n = BigInt(n);
    if (n < 2n) return false;
    if (n < 4n) return true;
    if (n % 2n === 0n) return false;
    for (var i = 3n; i * i <= n; i += 2n) { if (n % i === 0n) return false; }
    return true;
  }
  function gcd(a, b) { a = a < 0n ? -a : a; b = b < 0n ? -b : b; while (b) { var t = a % b; a = b; b = t; } return a; }

  // extended Euclid -> modular inverse of a mod m
  function modInverse(a, m) {
    var g = a % m, x = 1n, x0 = 0n, b = m;
    if (g < 0n) g += m;
    var old_r = g, r = b, old_s = 1n, s = 0n;
    while (r !== 0n) {
      var q = old_r / r;
      var tmp = old_r - q * r; old_r = r; r = tmp;
      tmp = old_s - q * s; old_s = s; s = tmp;
    }
    if (old_r !== 1n) return null; // not invertible
    var inv = old_s % m; if (inv < 0n) inv += m;
    return inv;
  }

  // fast modular exponentiation base^exp mod mod
  function modPow(base, exp, mod) {
    base = base % mod; if (base < 0n) base += mod;
    var result = 1n;
    while (exp > 0n) {
      if (exp & 1n) result = (result * base) % mod;
      exp >>= 1n;
      base = (base * base) % mod;
    }
    return result;
  }

  function runRSA() {
    var keyBox = $('rsaKeyOut'); keyBox.innerHTML = '';
    var stepBox = $('rsaSteps'); stepBox.innerHTML = '';
    var pV = $('rsaP').value, qV = $('rsaQ').value;
    var p, q;
    try { p = BigInt(pV); q = BigInt(qV); } catch (e) { keyBox.appendChild(el('div', { class: 'cy-out cy-r' }, 'Enter valid integers for p and q.')); return; }

    var errs = [];
    if (!isPrime(p)) errs.push('p = ' + p.toString() + ' is not prime.');
    if (!isPrime(q)) errs.push('q = ' + q.toString() + ' is not prime.');
    if (p === q) errs.push('p and q must be different primes.');
    if (errs.length) {
      keyBox.appendChild(el('div', { class: 'cy-out cy-r' }, errs.join(' ')));
      return;
    }

    var n = p * q;
    var phi = (p - 1n) * (q - 1n);
    var e = BigInt($('rsaE').value);
    var gd = gcd(e, phi);
    if (gd !== 1n) {
      keyBox.appendChild(el('div', { class: 'cy-out cy-r' }, 'e = ' + e.toString() + ' is not coprime to phi (gcd = ' + gd.toString() + '). Pick a different e or different primes.'));
      // still show the partial steps
    }
    var d = (gd === 1n) ? modInverse(e, phi) : null;

    var kv = el('div', { class: 'cy-kv' });
    function row(k, v, cls) { kv.appendChild(el('div', { class: 'k' }, k)); kv.appendChild(el('div', { class: 'v ' + (cls || '') }, v)); }
    row('n = p*q', n.toString(), 'cy-c');
    row('phi = (p-1)(q-1)', phi.toString());
    row('e (public)', e.toString());
    row('d (private)', d == null ? 'undefined' : d.toString(), 'cy-p');
    row('Public key', '(n=' + n.toString() + ', e=' + e.toString() + ')', 'cy-c');
    row('Private key', d == null ? '-' : '(n=' + n.toString() + ', d=' + d.toString() + ')', 'cy-p');
    keyBox.appendChild(kv);

    // encrypt / decrypt
    var cBox = $('rsaC'), rBox = $('rsaR');
    var mV = $('rsaM').value, m;
    try { m = BigInt(mV); } catch (e2) { cBox.textContent = 'invalid m'; rBox.textContent = ''; return; }
    if (m < 0n || m >= n) {
      cBox.innerHTML = ''; cBox.appendChild(el('span', { class: 'cy-r' }, 'Require 0 <= m < n (n=' + n.toString() + ').'));
      rBox.textContent = '';
    } else if (d == null) {
      var c0 = modPow(m, e, n);
      cBox.textContent = c0.toString();
      rBox.innerHTML = ''; rBox.appendChild(el('span', { class: 'cy-r' }, 'no valid d - cannot decrypt'));
    } else {
      var c = modPow(m, e, n);
      var rec = modPow(c, d, n);
      cBox.textContent = c.toString();
      rBox.innerHTML = '';
      rBox.appendChild(el('span', { class: rec === m ? 'cy-g' : 'cy-r' }, rec.toString() + (rec === m ? '   (matches original m)' : '   (MISMATCH)')));
    }

    // steps
    var lines = [];
    lines.push('1.  Choose two primes:  p = ' + p.toString() + ',  q = ' + q.toString());
    lines.push('2.  Modulus:            n = p*q = ' + n.toString());
    lines.push('3.  Euler totient:      phi(n) = (p-1)(q-1) = ' + (p - 1n).toString() + ' * ' + (q - 1n).toString() + ' = ' + phi.toString());
    lines.push('4.  Public exponent:    e = ' + e.toString() + ',  gcd(e, phi) = ' + gd.toString() + (gd === 1n ? '  (valid)' : '  (INVALID - not coprime)'));
    if (d != null) {
      lines.push('5.  Private exponent:   d = e^-1 mod phi = ' + d.toString() + '   (since e*d mod phi = ' + ((e * d) % phi).toString() + ')');
      if (m >= 0n && m < n) {
        var cc = modPow(m, e, n), rr = modPow(cc, d, n);
        lines.push('6.  Encrypt:            c = m^e mod n = ' + m.toString() + '^' + e.toString() + ' mod ' + n.toString() + ' = ' + cc.toString());
        lines.push('7.  Decrypt:            m = c^d mod n = ' + cc.toString() + '^' + d.toString() + ' mod ' + n.toString() + ' = ' + rr.toString());
      }
    }
    stepBox.textContent = lines.join('\n');
  }

  ['rsaP', 'rsaQ', 'rsaE', 'rsaM'].forEach(function (id) { $(id).addEventListener('input', runRSA); $(id).addEventListener('change', runRSA); });

  /* ===================================================================
     3. DIFFIE-HELLMAN
     =================================================================== */
  function runDH() {
    var p, g, a, b;
    try { p = BigInt($('dhP').value); g = BigInt($('dhG').value); a = BigInt($('dhA').value); b = BigInt($('dhB').value); }
    catch (e) { $('dhValid').textContent = 'Enter valid integers.'; return; }

    var valid = $('dhValid'); valid.innerHTML = '';
    var warn = [];
    if (!isPrime(p)) warn.push('p = ' + p.toString() + ' is not prime (DH normally uses a large prime modulus).');
    if (g < 2n || g >= p) warn.push('g should satisfy 2 <= g < p.');
    if (a < 1n || a >= p) warn.push('Alice a should satisfy 1 <= a < p.');
    if (b < 1n || b >= p) warn.push('Bob b should satisfy 1 <= b < p.');
    valid.appendChild(el('span', { class: warn.length ? 'cy-a' : 'cy-g' }, warn.length ? warn.join(' ') : 'Parameters valid.'));

    var A = modPow(g, a, p);   // Alice public
    var B = modPow(g, b, p);   // Bob public
    var sA = modPow(B, a, p);  // Alice computes B^a
    var sB = modPow(A, b, p);  // Bob computes A^b

    drawDH(p, g, a, b, A, B, sA, sB);

    var rbox = $('dhResult'); rbox.innerHTML = '';
    var kv = el('div', { class: 'cy-kv' });
    function row(k, v, cls) { kv.appendChild(el('div', { class: 'k' }, k)); kv.appendChild(el('div', { class: 'v ' + (cls || '') }, v)); }
    row('Alice public  A = g^a mod p', A.toString(), 'cy-c');
    row('Bob public    B = g^b mod p', B.toString(), 'cy-p');
    row('Alice secret  B^a mod p', sA.toString(), 'cy-c');
    row('Bob secret    A^b mod p', sB.toString(), 'cy-p');
    rbox.appendChild(kv);
    rbox.appendChild(el('div', { class: 'cy-out ' + (sA === sB ? '' : ''), style: 'margin-top:12px;border-color:' + (sA === sB ? '#86efac' : '#fca5a5') + ';' },
      sA === sB ? 'Shared secret established: ' + sA.toString() + '  (both sides agree without ever transmitting it)' : 'MISMATCH - parameters out of range.'));
  }

  function drawDH(p, g, a, b, A, B, sA, sB) {
    var s = $('dhDiagram'); s.innerHTML = '';
    var W = 1040, H = 320;
    function text(x, y, str, color, size, anchor, weight) {
      var t = svg('text', { x: x, y: y, fill: color, 'font-size': size || 13, 'font-family': 'Geist Mono, monospace', 'text-anchor': anchor || 'start' });
      if (weight) t.setAttribute('font-weight', weight);
      t.textContent = str; s.appendChild(t); return t;
    }
    // columns
    var ax = 150, bx = 890, midx = 520;
    text(ax, 30, 'ALICE', '#67e8f9', 15, 'middle', '700');
    text(bx, 30, 'BOB', '#a78bfa', 15, 'middle', '700');
    text(midx, 30, 'PUBLIC CHANNEL', '#9aa6b6', 12, 'middle', '700');
    // public params box
    s.appendChild(svg('rect', { x: midx - 130, y: 44, width: 260, height: 36, rx: 8, fill: '#0a0a0c', stroke: '#2a2a35' }));
    text(midx, 67, 'p = ' + p.toString() + ',  g = ' + g.toString(), '#fbbf24', 13, 'middle');
    // private
    text(ax, 110, 'private a = ' + a.toString(), '#67e8f9', 12.5, 'middle');
    text(bx, 110, 'private b = ' + b.toString(), '#a78bfa', 12.5, 'middle');
    // compute publics
    text(ax, 145, 'A = g^a mod p = ' + A.toString(), '#67e8f9', 12.5, 'middle');
    text(bx, 145, 'B = g^b mod p = ' + B.toString(), '#a78bfa', 12.5, 'middle');
    // arrows across
    s.appendChild(svg('line', { x1: ax + 70, y1: 175, x2: bx - 70, y2: 175, stroke: '#67e8f9', 'stroke-width': 1.5, 'marker-end': 'url(#arrCy)' }));
    text(midx, 168, 'send A  ->', '#67e8f9', 11.5, 'middle');
    s.appendChild(svg('line', { x1: bx - 70, y1: 205, x2: ax + 70, y2: 205, stroke: '#a78bfa', 'stroke-width': 1.5, 'marker-end': 'url(#arrPu)' }));
    text(midx, 222, '<-  send B', '#a78bfa', 11.5, 'middle');
    // markers
    var defs = svg('defs', {});
    function marker(id, color) {
      var m = svg('marker', { id: id, markerWidth: 8, markerHeight: 8, refX: 6, refY: 3, orient: 'auto' });
      m.appendChild(svg('path', { d: 'M0,0 L6,3 L0,6 Z', fill: color }));
      return m;
    }
    defs.appendChild(marker('arrCy', '#67e8f9'));
    defs.appendChild(marker('arrPu', '#a78bfa'));
    s.appendChild(defs);
    // shared secret
    text(ax, 258, 's = B^a mod p = ' + sA.toString(), '#67e8f9', 12.5, 'middle');
    text(bx, 258, 's = A^b mod p = ' + sB.toString(), '#a78bfa', 12.5, 'middle');
    var ok = sA === sB;
    s.appendChild(svg('rect', { x: midx - 175, y: 278, width: 350, height: 34, rx: 8, fill: '#0a0a0c', stroke: ok ? '#86efac' : '#fca5a5' }));
    text(midx, 300, ok ? 'shared secret = ' + sA.toString() : 'mismatch', ok ? '#86efac' : '#fca5a5', 13.5, 'middle', '700');
  }

  ['dhP', 'dhG', 'dhA', 'dhB'].forEach(function (id) { $(id).addEventListener('input', runDH); });

  /* ===================================================================
     4. HASHING + AVALANCHE
     =================================================================== */
  function toHex(buf) {
    var bytes = new Uint8Array(buf), hex = '';
    for (var i = 0; i < bytes.length; i++) { var h = bytes[i].toString(16); hex += (h.length === 1 ? '0' : '') + h; }
    return hex;
  }
  async function sha256(str) {
    var enc = new TextEncoder().encode(str);
    var buf = await crypto.subtle.digest('SHA-256', enc);
    return new Uint8Array(buf);
  }
  function popcount8(x) { var c = 0; while (x) { c += x & 1; x >>= 1; } return c; }
  function hammingBits(a, b) { var diff = 0; for (var i = 0; i < a.length; i++) diff += popcount8(a[i] ^ b[i]); return diff; }

  async function runHash() {
    var a = $('hashA').value, b = $('hashB').value;
    var ha = await sha256(a), hb = await sha256(b);
    var hexA = toHex(ha.buffer), hexB = toHex(hb.buffer);
    $('hashOutA').textContent = hexA;

    // colourise B differences vs A
    var bOut = $('hashOutB'); bOut.innerHTML = '';
    for (var i = 0; i < hexB.length; i++) {
      var same = hexA[i] === hexB[i];
      bOut.appendChild(el('span', { class: same ? '' : 'cy-r', style: same ? '' : 'font-weight:700;' }, hexB[i]));
    }

    var diffBits = hammingBits(ha, hb);
    var pct = (diffBits / 256 * 100);
    var av = $('hashAval'); av.innerHTML = '';
    av.appendChild(el('div', { class: 'cy-mono', style: 'font-size:13px;color:#cfd6da;margin-bottom:8px;' },
      'Differing output bits: ' + diffBits + ' of 256'));
    var meter = el('div', { class: 'cy-meter' });
    var fill = el('div', { style: 'width:' + pct + '%;background:#86efac;' });
    meter.appendChild(fill); av.appendChild(meter);
    av.appendChild(el('div', { class: 'cy-mono cy-g', style: 'font-size:15px;font-weight:700;margin-top:4px;' },
      'Avalanche: ' + pct.toFixed(1) + '% of bits flipped'));
    av.appendChild(el('div', { class: 'cy-note', style: 'margin-top:8px;' },
      a === b ? 'Inputs are identical, so the hashes match exactly. Change one character to see the avalanche.'
              : 'A strong hash flips about half (~50%) of all output bits when a single input bit changes - so similar inputs give totally unrelated digests.'));
  }

  $('hashFlip').addEventListener('click', function () {
    var a = $('hashA').value;
    if (!a.length) { a = ' '; }
    // flip the lowest bit of the last character
    var idx = a.length - 1;
    var code = a.charCodeAt(idx) ^ 1;
    var b = a.slice(0, idx) + String.fromCharCode(code);
    $('hashB').value = b;
    runHash();
  });
  ['hashA', 'hashB'].forEach(function (id) { $(id).addEventListener('input', runHash); });

  /* ===================================================================
     5. PASSWORD STRENGTH
     =================================================================== */
  function humanTime(seconds) {
    if (!isFinite(seconds)) return 'effectively forever';
    if (seconds < 1e-3) return 'instant';
    var units = [
      ['second', 1],
      ['minute', 60],
      ['hour', 3600],
      ['day', 86400],
      ['year', 31557600],
      ['century', 3155760000],
      ['million years', 31557600000000]
    ];
    if (seconds >= 31557600000000 * 1000) {
      var ey = seconds / 31557600;
      return ey.toExponential(2) + ' years';
    }
    var chosen = units[0];
    for (var i = 0; i < units.length; i++) { if (seconds >= units[i][1]) chosen = units[i]; }
    var val = seconds / chosen[1];
    var name = chosen[0];
    if (val !== 1 && name.indexOf('years') === -1 && name.charAt(name.length - 1) !== 'y') name += 's';
    if (name === 'century' && val !== 1) name = 'centuries';
    return val.toFixed(val < 10 ? 1 : 0) + ' ' + name;
  }

  function runPW() {
    var pw = $('pwIn').value;
    var rate = parseFloat($('pwRate').value);
    var poolLower = /[a-z]/.test(pw) ? 26 : 0;
    var poolUpper = /[A-Z]/.test(pw) ? 26 : 0;
    var poolDigit = /[0-9]/.test(pw) ? 10 : 0;
    var poolSym = /[^a-zA-Z0-9]/.test(pw) ? 33 : 0; // common printable symbols
    var pool = poolLower + poolUpper + poolDigit + poolSym;
    var len = pw.length;
    // entropy bits = len * log2(pool)
    var entropy = (pool > 0 && len > 0) ? len * Math.log2(pool) : 0;
    var combos = Math.pow(2, entropy);
    // average attacker finds it in half the keyspace
    var secs = combos / 2 / rate;

    // verdict
    var verdict, color;
    if (entropy < 28) { verdict = 'Very weak'; color = '#fca5a5'; }
    else if (entropy < 36) { verdict = 'Weak'; color = '#fca5a5'; }
    else if (entropy < 60) { verdict = 'Fair'; color = '#fbbf24'; }
    else if (entropy < 128) { verdict = 'Strong'; color = '#86efac'; }
    else { verdict = 'Very strong'; color = '#86efac'; }

    var barPct = Math.min(100, entropy / 128 * 100);
    var bar = $('pwBar'); bar.style.width = barPct + '%'; bar.style.background = color;

    var v = $('pwVerdict'); v.innerHTML = '';
    var pill = el('span', { class: 'cy-pill', style: 'background:' + color + ';color:#0a0a0c;' }, verdict);
    v.appendChild(pill);
    v.appendChild(el('span', { class: 'cy-mono', style: 'margin-left:10px;color:#cfd6da;font-size:13px;' }, entropy.toFixed(1) + ' bits of entropy'));

    var d = $('pwDetail'); d.innerHTML = '';
    function row(k, val, cls) { d.appendChild(el('div', { class: 'k' }, k)); d.appendChild(el('div', { class: 'v ' + (cls || '') }, val)); }
    var classes = [];
    if (poolLower) classes.push('a-z'); if (poolUpper) classes.push('A-Z'); if (poolDigit) classes.push('0-9'); if (poolSym) classes.push('symbols');
    row('Length', len + ' characters');
    row('Character classes', classes.length ? classes.join(', ') + ' (' + pool + ' symbols)' : 'none');
    row('Keyspace', pool + '^' + len + ' = ' + (combos < 1e15 ? combos.toLocaleString() : combos.toExponential(3)) + ' combinations');
    row('Attacker rate', rate.toExponential(0) + ' guesses/sec');
    row('Avg crack time', humanTime(secs), 'cy-g');
  }
  ['pwIn', 'pwRate'].forEach(function (id) { $(id).addEventListener('input', runPW); $(id).addEventListener('change', runPW); });

  /* ---------- INITIAL RENDER ---------- */
  runCipher();
  runRSA();
  // dh / hash / pw render lazily on first tab open, but prime them now too:
  runDH();
  runHash();
  runPW();
})();
</script>

</BaseLayout>
