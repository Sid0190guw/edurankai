    s.appendChild(svg('line', { x1: padL, y1: H - padB, x2: W - padL, y2: H - padB, stroke: '#2a2a35' }));
    for (var b = 0; b < 26; b++) {
      var x = padL + b * bw;
      var h = (pct[b] / maxP) * (H - padB - padT);
      s.appendChild(svg('rect', { x: x + 2, y: H - padB - h, width: bw - 4, height: Math.max(0, h), fill: '#67e8f9', rx: 2 }));
      var eh = (ENG[b] / maxP) * (H - padB - padT);
      s.appendChild(svg('line', { x1: x + 2, y1: H - padB - eh, x2: x + bw - 2, y2: H - padB - eh, stroke: '#fbbf24', 'stroke-width': 1.4, 'stroke-dasharray': '3 2', opacity: 0.85 }));
      var lab = svg('text', { x: x + bw / 2, y: H - 10, fill: '#9aa6b6', 'font-size': 10, 'font-family': 'Geist Mono, monospace', 'text-anchor': 'middle' });
