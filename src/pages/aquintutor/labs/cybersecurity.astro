      if (weight) t.setAttribute('font-weight', weight);
      t.textContent = str; s.appendChild(t); return t;
    }
    var ax = 150, bx = 890, midx = 520;
    text(ax, 30, 'ALICE', '#67e8f9', 15, 'middle', '700');
    text(bx, 30, 'BOB', '#a78bfa', 15, 'middle', '700');
    text(midx, 30, 'PUBLIC CHANNEL', '#9aa6b6', 12, 'middle', '700');
    s.appendChild(svg('rect', { x: midx - 130, y: 44, width: 260, height: 36, rx: 8, fill: '#0a0a0c', stroke: '#2a2a35' }));
    text(midx, 67, 'p = ' + p.toString() + ',  g = ' + g.toString(), '#fbbf24', 13, 'middle');
    text(ax, 110, 'private a = ' + a.toString(), '#67e8f9', 12.5, 'middle');
    text(bx, 110, 'private b = ' + b.toString(), '#a78bfa', 12.5, 'middle');
    text(ax, 145, 'A = g^a mod p = ' + A.toString(), '#67e8f9', 12.5, 'middle');
    text(bx, 145, 'B = g^b mod p = ' + B.toString(), '#a78bfa', 12.5, 'middle');
    s.appendChild(svg('line', { x1: ax + 70, y1: 175, x2: bx - 70, y2: 175, stroke: '#67e8f9', 'stroke-width': 1.5, 'marker-end': 'url(#arrCy)' }));
    text(midx, 168, 'send A  ->', '#67e8f9', 11.5, 'middle');
    s.appendChild(svg('line', { x1: bx - 70, y1: 205, x2: ax + 70, y2: 205, stroke: '#a78bfa', 'stroke-width': 1.5, 'marker-end': 'url(#arrPu)' }));
    text(midx, 222, '<-  send B', '#a78bfa', 11.5, 'middle');
    var defs = svg('defs', {});
    function marker(id, color) {
      var m = svg('marker', { id: id, markerWidth: 8, markerHeight: 8, refX: 6, refY: 3, orient: 'auto' });
      m.appendChild(svg('path', { d: 'M0,0 L6,3 L0,6 Z', fill: color }));
      return m;
    }
    defs.appendChild(marker('arrCy', '#67e8f9'));
    defs.appendChild(marker('arrPu', '#a78bfa'));
    s.appendChild(defs);
    text(ax, 258, 's = B^a mod p = ' + sA.toString(), '#67e8f9', 12.5, 'middle');
    text(bx, 258, 's = A^b mod p = ' + sB.toString(), '#a78bfa', 12.5, 'middle');
    var ok = sA === sB;
    s.appendChild(svg('rect', { x: midx - 175, y: 278, width: 350, height: 34, rx: 8, fill: '#0a0a0c', stroke: ok ? '#86efac' : '#fca5a5' }));
    text(midx, 300, ok ? 'shared secret = ' + sA.toString() : 'mismatch', ok ? '#86efac' : '#fca5a5', 13.5, 'middle', '700');
  }
  ['dhP', 'dhG', 'dhA', 'dhB'].forEach(function (id) { $(id).addEventListener('input', runDH); });

  /* ===================================================================
     5. HASHING + AVALANCHE  (preserved)
     =================================================================== */
  function toHex(buf) {
    var bytes = new Uint8Array(buf), hex = '';
    for (var i = 0; i < bytes.length; i++) { var h = bytes[i].toString(16); hex += (h.length === 1 ? '0' : '') + h; }
    return hex;
  }
  async function sha256(str) {
    var enc = new TextEncoder().encode(str);
    var buf = await crypto.subtle.digest('SHA-256', enc);
    return new Uint8Array(buf);
  }
  function popcount8(x) { var c = 0; while (x) { c += x & 1; x >>= 1; } return c; }
  function hammingBits(a, b) { var diff = 0; for (var i = 0; i < a.length; i++) diff += popcount8(a[i] ^ b[i]); return diff; }
  async function runHash() {
    var a = $('hashA').value, b = $('hashB').value;
    var ha = await sha256(a), hb = await sha256(b);
    var hexA = toHex(ha.buffer), hexB = toHex(hb.buffer);
    $('hashOutA').textContent = hexA;
    var bOut = $('hashOutB'); bOut.innerHTML = '';
    for (var i = 0; i < hexB.length; i++) {
      var same = hexA[i] === hexB[i];
      bOut.appendChild(el('span', { class: same ? '' : 'cy-r', style: same ? '' : 'font-weight:700;' }, hexB[i]));
    }
    var diffBits = hammingBits(ha, hb);
    var pct = (diffBits / 256 * 100);
    var av = $('hashAval'); av.innerHTML = '';
    av.appendChild(el('div', { class: 'cy-mono', style: 'font-size:13px;color:#cfd6da;margin-bottom:8px;' }, 'Differing output bits: ' + diffBits + ' of 256'));
    var meter = el('div', { class: 'cy-meter' });
    var fill = el('div', { style: 'width:' + pct + '%;background:#86efac;' });
    meter.appendChild(fill); av.appendChild(meter);
    av.appendChild(el('div', { class: 'cy-mono cy-g', style: 'font-size:15px;font-weight:700;margin-top:4px;' }, 'Avalanche: ' + pct.toFixed(1) + '% of bits flipped'));
    av.appendChild(el('div', { class: 'cy-note', style: 'margin-top:8px;' },
      a === b ? 'Inputs are identical, so the hashes match exactly. Change one character to see the avalanche.'
              : 'A strong hash flips about half (~50%) of all output bits when a single input bit changes - so similar inputs give totally unrelated digests.'));
  }
  $('hashFlip').addEventListener('click', function () {
    var a = $('hashA').value;
    if (!a.length) { a = ' '; }
    var idx = a.length - 1;
    var code = a.charCodeAt(idx) ^ 1;
    var b = a.slice(0, idx) + String.fromCharCode(code);
    $('hashB').value = b;
    runHash();
  });
  ['hashA', 'hashB'].forEach(function (id) { $(id).addEventListener('input', runHash); });

  /* ===================================================================
     6. PASSWORD STRENGTH  (preserved)
     =================================================================== */
  function humanTime(seconds) {
    if (!isFinite(seconds)) return 'effectively forever';
    if (seconds < 1e-3) return 'instant';
    var units = [
      ['second', 1], ['minute', 60], ['hour', 3600], ['day', 86400],
      ['year', 31557600], ['century', 3155760000], ['million years', 31557600000000]
    ];
    if (seconds >= 31557600000000 * 1000) {
      var ey = seconds / 31557600;
      return ey.toExponential(2) + ' years';
    }
    var chosen = units[0];
    for (var i = 0; i < units.length; i++) { if (seconds >= units[i][1]) chosen = units[i]; }
    var val = seconds / chosen[1];
    var name = chosen[0];
    if (val !== 1 && name.indexOf('years') === -1 && name.charAt(name.length - 1) !== 'y') name += 's';
    if (name === 'century' && val !== 1) name = 'centuries';
    return val.toFixed(val < 10 ? 1 : 0) + ' ' + name;
  }
  function runPW() {
    var pw = $('pwIn').value;
    var rate = parseFloat($('pwRate').value);
    var poolLower = /[a-z]/.test(pw) ? 26 : 0;
    var poolUpper = /[A-Z]/.test(pw) ? 26 : 0;
    var poolDigit = /[0-9]/.test(pw) ? 10 : 0;
    var poolSym = /[^a-zA-Z0-9]/.test(pw) ? 33 : 0;
    var pool = poolLower + poolUpper + poolDigit + poolSym;
    var len = pw.length;
    var entropy = (pool > 0 && len > 0) ? len * Math.log2(pool) : 0;
    var combos = Math.pow(2, entropy);
    var secs = combos / 2 / rate;
    var verdict, color;
    if (entropy < 28) { verdict = 'Very weak'; color = '#fca5a5'; }
    else if (entropy < 36) { verdict = 'Weak'; color = '#fca5a5'; }
    else if (entropy < 60) { verdict = 'Fair'; color = '#fbbf24'; }
    else if (entropy < 128) { verdict = 'Strong'; color = '#86efac'; }
    else { verdict = 'Very strong'; color = '#86efac'; }
    var barPct = Math.min(100, entropy / 128 * 100);
    var bar = $('pwBar'); bar.style.width = barPct + '%'; bar.style.background = color;
    var v = $('pwVerdict'); v.innerHTML = '';
    var pill = el('span', { class: 'cy-pill', style: 'background:' + color + ';color:#0a0a0c;' }, verdict);
    v.appendChild(pill);
    v.appendChild(el('span', { class: 'cy-mono', style: 'margin-left:10px;color:#cfd6da;font-size:13px;' }, entropy.toFixed(1) + ' bits of entropy'));
    var d = $('pwDetail'); d.innerHTML = '';
    function row(k, val, cls) { d.appendChild(el('div', { class: 'k' }, k)); d.appendChild(el('div', { class: 'v ' + (cls || '') }, val)); }
    var classes = [];
    if (poolLower) classes.push('a-z'); if (poolUpper) classes.push('A-Z'); if (poolDigit) classes.push('0-9'); if (poolSym) classes.push('symbols');
    row('Length', len + ' characters');
    row('Character classes', classes.length ? classes.join(', ') + ' (' + pool + ' symbols)' : 'none');
    row('Keyspace', pool + '^' + len + ' = ' + (combos < 1e15 ? combos.toLocaleString() : combos.toExponential(3)) + ' combinations');
    row('Attacker rate', rate.toExponential(0) + ' guesses/sec');
    row('Avg crack time', humanTime(secs), 'cy-g');
  }
  ['pwIn', 'pwRate'].forEach(function (id) { $(id).addEventListener('input', runPW); $(id).addEventListener('change', runPW); });

  /* ===================================================================
     7. AES-GCM  (NEW: real crypto.subtle + PBKDF2)
     =================================================================== */
  var aesState = null; // { salt, iv, ct }

  function bytesToHex(bytes) {
    var hex = '';
    for (var i = 0; i < bytes.length; i++) { var h = bytes[i].toString(16); hex += (h.length === 1 ? '0' : '') + h; }
    return hex;
  }
  async function deriveKey(pass, salt, iters) {
    var baseKey = await crypto.subtle.importKey(
      'raw', new TextEncoder().encode(pass), { name: 'PBKDF2' }, false, ['deriveKey']
    );
    return crypto.subtle.deriveKey(
      { name: 'PBKDF2', salt: salt, iterations: iters, hash: 'SHA-256' },
      baseKey, { name: 'AES-GCM', length: 256 }, false, ['encrypt', 'decrypt']
    );
  }
  async function aesEncrypt() {
    var out = $('aesEncOut'); out.innerHTML = '';
    var pass = $('aesPass').value, pt = $('aesPt').value;
    var iters = parseInt($('aesIter').value, 10);
    try {
      var salt = crypto.getRandomValues(new Uint8Array(16));
      var iv = crypto.getRandomValues(new Uint8Array(12));
      var key = await deriveKey(pass, salt, iters);
      var ctBuf = await crypto.subtle.encrypt({ name: 'AES-GCM', iv: iv }, key, new TextEncoder().encode(pt));
      var ct = new Uint8Array(ctBuf);
      aesState = { salt: salt, iv: iv, ct: ct, iters: iters };
      var kv = el('div', { class: 'cy-kv' });
      function row(k, v, cls) { kv.appendChild(el('div', { class: 'k' }, k)); kv.appendChild(el('div', { class: 'v ' + (cls || '') }, v)); }
      row('Salt (16 bytes)', bytesToHex(salt), 'cy-a');
      row('IV (12 bytes)', bytesToHex(iv), 'cy-a');
      row('Ciphertext + tag', bytesToHex(ct), 'cy-c');
      row('Length', ct.length + ' bytes (incl. 16-byte GCM tag)', 'cy-dim');
      out.appendChild(kv);
      out.appendChild(el('div', { class: 'cy-note' }, 'Key derived via PBKDF2-SHA256, ' + iters.toLocaleString() + ' iterations. A fresh salt and IV were generated for this message.'));
    } catch (e) {
      out.appendChild(el('div', { class: 'cy-out cy-r' }, 'Encryption failed: ' + e.message));
    }
  }
  async function aesDecrypt() {
    var out = $('aesDecOut'); out.innerHTML = '';
    if (!aesState) { out.appendChild(el('div', { class: 'cy-out cy-a' }, 'Encrypt a message first.')); return; }
    var pass = $('aesPass2').value;
    try {
      var key = await deriveKey(pass, aesState.salt, aesState.iters);
      var ptBuf = await crypto.subtle.decrypt({ name: 'AES-GCM', iv: aesState.iv }, key, aesState.ct);
      var pt = new TextDecoder().decode(ptBuf);
      var okBox = el('div', { class: 'cy-out', style: 'border-color:#86efac;' });
      okBox.appendChild(el('span', { class: 'cy-g' }, 'Decrypted: ' + pt));
      out.appendChild(okBox);
    } catch (e) {
      var failBox = el('div', { class: 'cy-out', style: 'border-color:#fca5a5;' });
      failBox.appendChild(el('span', { class: 'cy-r' }, 'Authentication failed - wrong passphrase or tampered ciphertext. GCM refuses to return plaintext it cannot verify.'));
      out.appendChild(failBox);
    }
  }
  $('aesEnc').addEventListener('click', aesEncrypt);
  $('aesDec').addEventListener('click', aesDecrypt);

  /* ===================================================================
     8. STEGANOGRAPHY  (NEW: LSB hide/extract on a canvas)
     =================================================================== */
  var stegW = 160, stegH = 120;

  function stegDrawCarrier(ctx) {
    var img = ctx.createImageData(stegW, stegH);
    var d = img.data;
    for (var y = 0; y < stegH; y++) {
      for (var x = 0; x < stegW; x++) {
        var i = (y * stegW + x) * 4;
        d[i] = (x * 255 / stegW) | 0;                 // R gradient L->R
        d[i + 1] = (y * 255 / stegH) | 0;             // G gradient T->B
        d[i + 2] = ((x + y) * 255 / (stegW + stegH)) | 0; // B diagonal
        d[i + 3] = 255;
      }
    }
    ctx.putImageData(img, 0, 0);
  }
  function stegCapacityChars() {
    // 3 usable channels (RGB) per pixel, 1 bit each; 8 bits/char; reserve 16 bits for length header
    var totalBits = stegW * stegH * 3;
    return Math.floor((totalBits - 16) / 8);
  }
  function stegInit() {
    var a = $('stegCanvasA'), b = $('stegCanvasB');
    var ca = a.getContext('2d'), cb = b.getContext('2d');
    stegDrawCarrier(ca);
    stegDrawCarrier(cb); // mirror until a message is hidden
    $('stegCap').textContent = 'Up to ' + stegCapacityChars().toLocaleString() + ' characters (LSB of R,G,B over ' + stegW + 'x' + stegH + ' px).';
    $('stegStatus').innerHTML = '';
    $('stegOut').textContent = '';
  }
  function stegHide() {
    var status = $('stegStatus'); status.innerHTML = '';
    var msg = $('stegMsg').value;
    // encode chars to UTF-8 bytes for safety
    var bytes = new TextEncoder().encode(msg);
    var cap = stegCapacityChars();
    if (bytes.length > cap) {
      status.appendChild(el('div', { class: 'cy-out cy-r' }, 'Message too long: ' + bytes.length + ' bytes exceeds capacity of ' + cap + '.'));
      return;
    }
    // build bit stream: 16-bit length header (byte count) + message bytes
    var bits = [];
    var len = bytes.length;
    for (var h = 15; h >= 0; h--) bits.push((len >> h) & 1);
    for (var bi = 0; bi < bytes.length; bi++) {
      for (var k = 7; k >= 0; k--) bits.push((bytes[bi] >> k) & 1);
    }
    var a = $('stegCanvasA'), b = $('stegCanvasB');
    var ca = a.getContext('2d'), cb = b.getContext('2d');
    var src = ca.getImageData(0, 0, stegW, stegH);
    var dst = cb.createImageData(stegW, stegH);
    var sd = src.data, dd = dst.data;
    var bitIdx = 0;
    for (var p = 0; p < stegW * stegH; p++) {
      var base = p * 4;
      for (var ch = 0; ch < 3; ch++) { // R,G,B only; keep alpha
        var val = sd[base + ch];
        if (bitIdx < bits.length) {
          val = (val & 0xFE) | bits[bitIdx];
          bitIdx++;
        }
        dd[base + ch] = val;
      }
      dd[base + 3] = sd[base + 3];
    }
    cb.putImageData(dst, 0, 0);
    var okBox = el('div', { class: 'cy-out', style: 'border-color:#86efac;' });
    okBox.appendChild(el('span', { class: 'cy-g' }, 'Hidden ' + bytes.length + ' bytes (' + bits.length + ' bits) into pixel LSBs. The stego image is visually identical.'));
    status.appendChild(okBox);
  }
  function stegExtract() {
    var out = $('stegOut'); out.textContent = '';
    var b = $('stegCanvasB');
    var cb = b.getContext('2d');
    var img = cb.getImageData(0, 0, stegW, stegH);
    var d = img.data;
    // read bit stream from R,G,B LSBs (skipping the alpha channel)
    var idx = 0;
    function nextBit() {
      // map linear channel index (skipping alpha) to data array
      var pixel = Math.floor(idx / 3);
      var ch = idx % 3;
      idx++;
      return d[pixel * 4 + ch] & 1;
    }
    var len = 0;
    for (var h = 0; h < 16; h++) { len = (len << 1) | nextBit(); }
    if (len <= 0 || len > stegCapacityChars()) {
      out.innerHTML = '';
      out.appendChild(el('span', { class: 'cy-a' }, 'No valid hidden message found (header length = ' + len + '). Hide a message first.'));
      return;
    }
    var bytes = new Uint8Array(len);
    for (var bi = 0; bi < len; bi++) {
      var byte = 0;
      for (var k = 0; k < 8; k++) { byte = (byte << 1) | nextBit(); }
      bytes[bi] = byte;
    }
    var msg = new TextDecoder().decode(bytes);
    out.textContent = msg;
  }
  $('stegGen').addEventListener('click', stegInit);
  $('stegHide').addEventListener('click', stegHide);
  $('stegExtract').addEventListener('click', stegExtract);

  /* ===================================================================
     INITIAL RENDER
     =================================================================== */
  runCipher();
  runCrack();
  runRSA();
  runDH();
  runHash();
  runPW();
})();
</script>

</BaseLayout>
