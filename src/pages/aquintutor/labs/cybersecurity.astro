    var out = '';
    for (var i = 0; i < str.length; i++) {
      var c = str.charCodeAt(i);
      if (c >= 65 && c <= 90) out += String.fromCharCode((c - 65 + k) % 26 + 65);
      else if (c >= 97 && c <= 122) out += String.fromCharCode((c - 97 + k) % 26 + 97);
