  /* ===================================================================
     3. RSA  (preserved)
     =================================================================== */
  function runRSA() {
    var keyBox = $('rsaKeyOut'); keyBox.innerHTML = '';
    var stepBox = $('rsaSteps'); stepBox.innerHTML = '';
    var pV = $('rsaP').value, qV = $('rsaQ').value;
    var p, q;
    try { p = BigInt(pV); q = BigInt(qV); } catch (e) { keyBox.appendChild(el('div', { class: 'cy-out cy-r' }, 'Enter valid integers for p and q.')); return; }
    var errs = [];
    if (!isPrime(p)) errs.push('p = ' + p.toString() + ' is not prime.');
    if (!isPrime(q)) errs.push('q = ' + q.toString() + ' is not prime.');
    if (p === q) errs.push('p and q must be different primes.');
    if (errs.length) { keyBox.appendChild(el('div', { class: 'cy-out cy-r' }, errs.join(' '))); return; }
    var n = p * q;
    var phi = (p - 1n) * (q - 1n);
    var e = BigInt($('rsaE').value);
    var gd = gcd(e, phi);
    if (gd !== 1n) {
      keyBox.appendChild(el('div', { class: 'cy-out cy-r' }, 'e = ' + e.toString() + ' is not coprime to phi (gcd = ' + gd.toString() + '). Pick a different e or different primes.'));
    }
    var d = (gd === 1n) ? modInverse(e, phi) : null;
    var kv = el('div', { class: 'cy-kv' });
    function row(k, v, cls) { kv.appendChild(el('div', { class: 'k' }, k)); kv.appendChild(el('div', { class: 'v ' + (cls || '') }, v)); }
    row('n = p*q', n.toString(), 'cy-c');
    row('phi = (p-1)(q-1)', phi.toString());
    row('e (public)', e.toString());
    row('d (private)', d == null ? 'undefined' : d.toString(), 'cy-p');
    row('Public key', '(n=' + n.toString() + ', e=' + e.toString() + ')', 'cy-c');
    row('Private key', d == null ? '-' : '(n=' + n.toString() + ', d=' + d.toString() + ')', 'cy-p');
    keyBox.appendChild(kv);
    var cBox = $('rsaC'), rBox = $('rsaR');
    var mV = $('rsaM').value, m;
    try { m = BigInt(mV); } catch (e2) { cBox.textContent = 'invalid m'; rBox.textContent = ''; return; }
    if (m < 0n || m >= n) {
      cBox.innerHTML = ''; cBox.appendChild(el('span', { class: 'cy-r' }, 'Require 0 <= m < n (n=' + n.toString() + ').'));
      rBox.textContent = '';
    } else if (d == null) {
      var c0 = modPow(m, e, n);
      cBox.textContent = c0.toString();
      rBox.innerHTML = ''; rBox.appendChild(el('span', { class: 'cy-r' }, 'no valid d - cannot decrypt'));
    } else {
      var c = modPow(m, e, n);
      var rec = modPow(c, d, n);
      cBox.textContent = c.toString();
      rBox.innerHTML = '';
      rBox.appendChild(el('span', { class: rec === m ? 'cy-g' : 'cy-r' }, rec.toString() + (rec === m ? '   (matches original m)' : '   (MISMATCH)')));
    }
    var lines = [];
    lines.push('1.  Choose two primes:  p = ' + p.toString() + ',  q = ' + q.toString());
    lines.push('2.  Modulus:            n = p*q = ' + n.toString());
    lines.push('3.  Euler totient:      phi(n) = (p-1)(q-1) = ' + (p - 1n).toString() + ' * ' + (q - 1n).toString() + ' = ' + phi.toString());
    lines.push('4.  Public exponent:    e = ' + e.toString() + ',  gcd(e, phi) = ' + gd.toString() + (gd === 1n ? '  (valid)' : '  (INVALID - not coprime)'));
    if (d != null) {
      lines.push('5.  Private exponent:   d = e^-1 mod phi = ' + d.toString() + '   (since e*d mod phi = ' + ((e * d) % phi).toString() + ')');
      if (m >= 0n && m < n) {
        var cc = modPow(m, e, n), rr = modPow(cc, d, n);
        lines.push('6.  Encrypt:            c = m^e mod n = ' + m.toString() + '^' + e.toString() + ' mod ' + n.toString() + ' = ' + cc.toString());
        lines.push('7.  Decrypt:            m = c^d mod n = ' + cc.toString() + '^' + d.toString() + ' mod ' + n.toString() + ' = ' + rr.toString());
      }
    }
    stepBox.textContent = lines.join('\n');
  }
  ['rsaP', 'rsaQ', 'rsaE', 'rsaM'].forEach(function (id) { $(id).addEventListener('input', runRSA); $(id).addEventListener('change', runRSA); });

  /* ===================================================================
     4. DIFFIE-HELLMAN  (preserved)
     =================================================================== */
  function runDH() {
    var p, g, a, b;
    try { p = BigInt($('dhP').value); g = BigInt($('dhG').value); a = BigInt($('dhA').value); b = BigInt($('dhB').value); }
    catch (e) { $('dhValid').textContent = 'Enter valid integers.'; return; }
    var valid = $('dhValid'); valid.innerHTML = '';
    var warn = [];
    if (!isPrime(p)) warn.push('p = ' + p.toString() + ' is not prime (DH normally uses a large prime modulus).');
    if (g < 2n || g >= p) warn.push('g should satisfy 2 <= g < p.');
    if (a < 1n || a >= p) warn.push('Alice a should satisfy 1 <= a < p.');
    if (b < 1n || b >= p) warn.push('Bob b should satisfy 1 <= b < p.');
    valid.appendChild(el('span', { class: warn.length ? 'cy-a' : 'cy-g' }, warn.length ? warn.join(' ') : 'Parameters valid.'));
    var A = modPow(g, a, p);
    var B = modPow(g, b, p);
    var sA = modPow(B, a, p);
    var sB = modPow(A, b, p);
    drawDH(p, g, a, b, A, B, sA, sB);
    var rbox = $('dhResult'); rbox.innerHTML = '';
    var kv = el('div', { class: 'cy-kv' });
    function row(k, v, cls) { kv.appendChild(el('div', { class: 'k' }, k)); kv.appendChild(el('div', { class: 'v ' + (cls || '') }, v)); }
    row('Alice public  A = g^a mod p', A.toString(), 'cy-c');
    row('Bob public    B = g^b mod p', B.toString(), 'cy-p');
    row('Alice secret  B^a mod p', sA.toString(), 'cy-c');
    row('Bob secret    A^b mod p', sB.toString(), 'cy-p');
    rbox.appendChild(kv);
    rbox.appendChild(el('div', { class: 'cy-out', style: 'margin-top:12px;border-color:' + (sA === sB ? '#86efac' : '#fca5a5') + ';' },
      sA === sB ? 'Shared secret established: ' + sA.toString() + '  (both sides agree without ever transmitting it)' : 'MISMATCH - parameters out of range.'));
  }
  function drawDH(p, g, a, b, A, B, sA, sB) {
