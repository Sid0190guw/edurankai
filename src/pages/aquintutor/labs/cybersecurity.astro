    var R = null, N = P;
    while (k > 0) {
      if (k & 1) R = ecAdd(R, N, a, p);
      N = ecAdd(N, N, a, p);
      k = Math.floor(k / 2);
    }
    return R;
  }
  function ecPointOrder(P, a, p) {
    // smallest m > 0 with mP = O
    var N = P, m = 1;
    while (N) { N = ecAdd(N, P, a, p); m++; if (m > 4 * p + 10) break; }
    return m;
  }
  function ecPointsOf(a, b, p) {
    var pts = [];
    for (var x = 0; x < p; x++) {
      var rhs = emod(x * x * x + a * x + b, p);
      for (var y = 0; y < p; y++) {
        if (emod(y * y, p) === rhs) pts.push({ x: x, y: y });
      }
    }
    return pts;
  }
  var eccCurPoints = [];
  function ptEq(A, B) { if (!A || !B) return A === B; return A.x === B.x && A.y === B.y; }
  function ptStr(P) { return P ? '(' + P.x + ', ' + P.y + ')' : 'O (infinity)'; }
  function readECCParams() {
    var a = parseInt($('eccA').value, 10);
    var b = parseInt($('eccB').value, 10);
    var p = parseInt($('eccP').value, 10);
    if (isNaN(a) || isNaN(b) || isNaN(p)) return null;
    return { a: a, b: b, p: p };
  }
  function getBaseG() {
    var sel = $('eccG').value;
    if (!sel || sel.indexOf(',') < 0) return eccCurPoints.length ? eccCurPoints[0] : null;
    var parts = sel.split(',');
    return { x: parseInt(parts[0], 10), y: parseInt(parts[1], 10) };
  }
  function eccPopulateG() {
    var sel = $('eccG'); var keep = sel.value;
    sel.innerHTML = '';
    eccCurPoints.forEach(function (P) {
      var o = el('option', { value: P.x + ',' + P.y }, '(' + P.x + ', ' + P.y + ')');
      sel.appendChild(o);
    });
    // restore if still present
    var found = false;
    for (var i = 0; i < sel.options.length; i++) { if (sel.options[i].value === keep) { sel.value = keep; found = true; break; } }
    if (!found && sel.options.length) sel.selectedIndex = 0;
  }
  function eccDrawPlot(prm, highlight) {
    var s = $('eccPlot'); s.innerHTML = '';
    var p = prm.p, W = 360, pad = 28, span = W - pad * 2;
    var step = span / (p > 1 ? p - 1 : 1);
    function gx(x) { return pad + x * step; }
    function gy(y) { return W - pad - y * step; }
    // axes
    s.appendChild(svg('line', { x1: pad, y1: W - pad, x2: W - pad, y2: W - pad, stroke: '#2a2a35' }));
    s.appendChild(svg('line', { x1: pad, y1: pad, x2: pad, y2: W - pad, stroke: '#2a2a35' }));
    var lx = svg('text', { x: W - pad, y: W - pad + 16, fill: '#9aa6b6', 'font-size': 9, 'font-family': 'Geist Mono, monospace', 'text-anchor': 'end' }); lx.textContent = 'x'; s.appendChild(lx);
    var ly = svg('text', { x: pad - 6, y: pad, fill: '#9aa6b6', 'font-size': 9, 'font-family': 'Geist Mono, monospace', 'text-anchor': 'end' }); ly.textContent = 'y'; s.appendChild(ly);
    eccCurPoints.forEach(function (P) {
      s.appendChild(svg('circle', { cx: gx(P.x), cy: gy(P.y), r: 3.4, fill: '#67e8f9', opacity: 0.85 }));
    });
    if (highlight) {
      highlight.forEach(function (h) {
        if (!h.P) return;
        s.appendChild(svg('circle', { cx: gx(h.P.x), cy: gy(h.P.y), r: 5.5, fill: 'none', stroke: h.color, 'stroke-width': 2 }));
        var t = svg('text', { x: gx(h.P.x) + 7, y: gy(h.P.y) - 5, fill: h.color, 'font-size': 9, 'font-family': 'Geist Mono, monospace' });
        t.textContent = h.label; s.appendChild(t);
      });
    }
  }
  function runECC() {
    var prm = readECCParams();
    var msg = $('eccCurveMsg');
    if (!prm) { msg.innerHTML = ''; msg.appendChild(el('span', { class: 'cy-r' }, 'Enter integer a, b and prime p.')); return; }
    var a = prm.a, b = prm.b, p = prm.p;
    msg.innerHTML = '';
    if (!isPrime(p)) { msg.appendChild(el('span', { class: 'cy-r' }, 'p = ' + p + ' is not prime. Use a small prime (5, 7, 11, 13, 17, 19, 23).')); return; }
    var disc = emod(4 * a * a * a + 27 * b * b, p);
    if (disc === 0) { msg.appendChild(el('span', { class: 'cy-r' }, 'Singular curve: 4a^3 + 27b^2 = 0 (mod p). Choose different a, b.')); return; }
    eccCurPoints = ecPointsOf(a, b, p);
    eccPopulateG();
    var grpOrder = eccCurPoints.length + 1; // affine points + O
    msg.appendChild(el('span', { class: 'cy-g' }, 'y^2 = x^3 + ' + a + 'x + ' + b + ' (mod ' + p + '):  ' + eccCurPoints.length + ' affine points, group order ' + grpOrder + ' (with O).'));
    // point list
    var listBox = $('eccPointList');
    var names = [];
    for (var i = 0; i < eccCurPoints.length; i++) names.push('(' + eccCurPoints[i].x + ',' + eccCurPoints[i].y + ')');
    listBox.textContent = 'Points: ' + names.join('  ');
    var G = getBaseG();
    var ord = G ? ecPointOrder(G, a, p) : 0;
    runECCScalar(prm, G, ord);
    runECCDH(prm, G, ord);
  }
  function runECCScalar(prm, G, ord) {
    var a = prm.a, p = prm.p;
    var out = $('eccScalarOut'); out.innerHTML = '';
    var steps = $('eccScalarSteps'); steps.innerHTML = '';
    if (!G) { out.appendChild(el('span', { class: 'cy-r' }, 'No base point available.')); return; }
    var k = parseInt($('eccK').value, 10);
    if (isNaN(k) || k < 1) { out.appendChild(el('span', { class: 'cy-r' }, 'Enter scalar k >= 1.')); return; }
    var result = ecScalar(k, G, a, p);
    out.appendChild(el('div', { class: 'cy-mono cy-c' }, 'G = ' + ptStr(G) + ',  order of G = ' + ord));
    out.appendChild(el('div', { class: 'cy-mono cy-g', style: 'margin-top:4px;font-weight:700;' }, k + 'G = ' + ptStr(result) + (k % ord === 0 ? '   (k is a multiple of the order, so kG = O)' : '')));
    // double-and-add trace
    var bits = k.toString(2);
    var lines = 'double-and-add over bits of k = ' + k + ' (binary ' + bits + '):\n';
    // accumulator after each bit (MSB-first reconstruction)
    var R2 = null;
    for (var bi = 0; bi < bits.length; bi++) {
      R2 = ecAdd(R2, R2, a, p);
      var op = 'double';
      if (bits.charAt(bi) === '1') { R2 = ecAdd(R2, G, a, p); op = 'double + add G'; }
      lines += '  bit ' + bits.charAt(bi) + ' -> ' + op + ' -> R = ' + ptStr(R2) + '\n';
    }
    steps.textContent = lines;
    eccDrawPlot(prm, [
      { P: G, color: '#67e8f9', label: 'G' },
      { P: result, color: '#fbbf24', label: k + 'G' }
    ]);
  }
  function runECCDH(prm, G, ord) {
    var a = prm.a, p = prm.p;
    var out = $('eccDhOut'); out.innerHTML = '';
    if (!G) return;
    var dA = parseInt($('eccDA').value, 10);
    var dB = parseInt($('eccDB').value, 10);
    if (isNaN(dA) || isNaN(dB) || dA < 1 || dB < 1) { out.appendChild(el('div', { class: 'cy-out cy-r' }, 'Enter private scalars dA, dB >= 1.')); return; }
    var QA = ecScalar(dA, G, a, p);     // Alice public
    var QB = ecScalar(dB, G, a, p);     // Bob public
    var sA = ecScalar(dA, QB, a, p);    // Alice computes dA*(dB*G)
    var sB = ecScalar(dB, QA, a, p);    // Bob computes dB*(dA*G)
    var kv = el('div', { class: 'cy-kv' });
    function row(k, v, cls) { kv.appendChild(el('div', { class: 'k' }, k)); kv.appendChild(el('div', { class: 'v ' + (cls || '') }, v)); }
    row('Base point G', ptStr(G), 'cy-a');
    row('Alice public  QA = dA*G', ptStr(QA), 'cy-c');
    row('Bob public    QB = dB*G', ptStr(QB), 'cy-p');
    row('Alice secret  dA*QB', ptStr(sA), 'cy-c');
    row('Bob secret    dB*QA', ptStr(sB), 'cy-p');
    out.appendChild(kv);
    var ok = ptEq(sA, sB);
    out.appendChild(el('div', { class: 'cy-out', style: 'margin-top:12px;border-color:' + (ok ? '#86efac' : '#fca5a5') + ';' },
      ok ? 'Shared ECDH point established: ' + ptStr(sA) + '  (both sides agree without sending dA or dB)'
         : 'Mismatch - check parameters.'));
  }
  ['eccA', 'eccB', 'eccP'].forEach(function (id) { $(id).addEventListener('input', runECC); });
  $('eccG').addEventListener('change', runECC);
  ['eccK', 'eccDA', 'eccDB'].forEach(function (id) { $(id).addEventListener('input', runECC); });

  /* ===================================================================
     11. STACK BUFFER OVERFLOW  (byte-level frame model, defensive)
     =================================================================== */
  var CANARY_BYTES = 4, FP_BYTES = 4, RET_BYTES = 4;
  var ovAnim = null;
  function ovLayout() {
    var N = parseInt($('ovBuf').value, 10);
    var hasCanary = $('ovCanary').value === '1';
    // slot order from low address (written first) to high address:
    // buffer (N) -> [canary] -> saved FP -> return addr
    var slots = [];
    for (var i = 0; i < N; i++) slots.push({ region: 'buf', label: i === 0 ? 'buffer[' + N + ']' : '', orig: 0 });
    if (hasCanary) for (var c = 0; c < CANARY_BYTES; c++) slots.push({ region: 'canary', label: c === 0 ? 'canary' : '', orig: 0 });
    for (var f = 0; f < FP_BYTES; f++) slots.push({ region: 'fp', label: f === 0 ? 'saved FP' : '', orig: 0 });
    for (var r = 0; r < RET_BYTES; r++) slots.push({ region: 'ret', label: r === 0 ? 'return addr' : '', orig: 0 });
    return { N: N, hasCanary: hasCanary, slots: slots };
  }
  function ovRegionColor(region) {
    if (region === 'buf') return '#67e8f9';
    if (region === 'canary') return '#fbbf24';
    if (region === 'fp') return '#a78bfa';
    return '#fca5a5'; // ret
  }
  function ovDraw(lay, filled, input) {
    var s = $('ovStack'); s.innerHTML = '';
    var slots = lay.slots, n = slots.length;
    var W = 1040, rowH = Math.min(34, 440 / n), top = 18, leftX = 360, cellW = 300;
    // address label: high at top -> draw from top = high address. Our slots are low..high, so reverse vertically.
    var t0 = svg('text', { x: leftX + cellW / 2, y: 12, fill: '#9aa6b6', 'font-size': 11, 'font-family': 'Geist Mono, monospace', 'text-anchor': 'middle' });
    t0.textContent = 'high addresses (top)  -  written-into bytes shown as hex'; s.appendChild(t0);
    for (var vi = 0; vi < n; vi++) {
      var si = n - 1 - vi;            // top row = highest address = last slot
      var slot = slots[si];
      var y = top + vi * rowH;
      var written = si < filled;
      var col = ovRegionColor(slot.region);
      s.appendChild(svg('rect', { x: leftX, y: y, width: cellW, height: rowH - 2, rx: 3,
        fill: written ? col : '#0a0a0c', stroke: col, 'stroke-width': 1, opacity: written ? 0.92 : 1 }));
      // byte value text
      var byteVal = '..';
      if (written) {
        var ci = si; // since bytes are written low->high in slot order
        var code = (input && ci < input.length) ? input.charCodeAt(ci) : 0;
        byteVal = hex2(code & 0xFF) + (code >= 32 && code < 127 ? " '" + input.charAt(ci) + "'" : '');
      } else {
        byteVal = (slot.region === 'canary') ? 'guard' : '(orig)';
      }
      var tv = svg('text', { x: leftX + 10, y: y + rowH / 2 + 4, fill: written ? '#0a0a0c' : '#9aa6b6', 'font-size': 11, 'font-family': 'Geist Mono, monospace' });
      tv.textContent = byteVal; s.appendChild(tv);
      // region label on the right
      if (slot.label) {
        var rl = svg('text', { x: leftX + cellW + 12, y: y + rowH / 2 + 4, fill: col, 'font-size': 12, 'font-family': 'Geist Mono, monospace', 'font-weight': 700 });
        rl.textContent = slot.label; s.appendChild(rl);
      }
    }
    // write-direction arrow on the left (low -> high = bottom -> top)
    var ax = leftX - 30;
    s.appendChild(svg('line', { x1: ax, y1: top + n * rowH - rowH / 2, x2: ax, y2: top + rowH / 2, stroke: '#86efac', 'stroke-width': 2, 'marker-end': 'url(#ovArr)' }));
    var defs = svg('defs', {});
    var mk = svg('marker', { id: 'ovArr', markerWidth: 8, markerHeight: 8, refX: 6, refY: 3, orient: 'auto' });
    mk.appendChild(svg('path', { d: 'M0,0 L6,3 L0,6 Z', fill: '#86efac' }));
    defs.appendChild(mk); s.appendChild(defs);
    var wd = svg('text', { x: ax - 8, y: top + n * rowH / 2, fill: '#86efac', 'font-size': 10, 'font-family': 'Geist Mono, monospace', 'text-anchor': 'end' });
    wd.textContent = 'write'; s.appendChild(wd);
    var wd2 = svg('text', { x: ax - 8, y: top + n * rowH / 2 + 13, fill: '#86efac', 'font-size': 10, 'font-family': 'Geist Mono, monospace', 'text-anchor': 'end' });
    wd2.textContent = 'direction'; s.appendChild(wd2);
  }
  function ovVerdict(lay, input) {
    var box = $('ovVerdict'); box.innerHTML = '';
    var N = lay.N, len = input.length, total = lay.slots.length;
    var canaryStart = N;
    var retStart = total - RET_BYTES;
    var reachedCanary = lay.hasCanary && len > canaryStart;
    var reachedRet = len > retStart;
    var verdict, color, detail;
    if (len <= N) {
      verdict = 'SAFE'; color = '#86efac';
      detail = 'Input (' + len + ' bytes) fits within the ' + N + '-byte buffer. No saved metadata is overwritten.';
    } else if (lay.hasCanary && reachedCanary) {
      verdict = 'CANARY ABORT'; color = '#fbbf24';
      detail = 'Overflow of ' + len + ' bytes corrupted the stack canary. The function epilogue detects the changed guard value: *** stack smashing detected *** -> program aborts before returning. The return address is never used, so the hijack fails.';
    } else if (reachedRet) {
      verdict = 'RETURN-ADDRESS HIJACK'; color = '#fca5a5';
      detail = 'No canary present and the ' + len + '-byte input reached the return-address slot (offset ' + retStart + '). The overwritten return address would redirect execution to attacker-chosen bytes when the function returns. This is the classic control-flow hijack stack canaries are designed to stop.';
    } else {
      verdict = 'FRAME PARTIALLY OVERWRITTEN'; color = '#fbbf24';
      detail = 'Input (' + len + ' bytes) overflows the buffer into the saved frame pointer but has not yet reached the return-address slot at offset ' + retStart + '. Add more bytes to reach it.';
    }
    var pill = el('span', { class: 'cy-pill', style: 'background:' + color + ';color:#0a0a0c;' }, verdict);
    box.appendChild(pill);
    box.appendChild(el('div', { class: 'cy-note', style: 'margin-top:8px;color:#cfd6da;' }, detail));
    box.appendChild(el('div', { class: 'cy-note', style: 'margin-top:6px;' },
      'Buffer ' + N + ' B' + (lay.hasCanary ? ' + canary ' + CANARY_BYTES + ' B' : '') + ' + saved FP ' + FP_BYTES + ' B + return addr ' + RET_BYTES + ' B = frame ' + lay.slots.length + ' B. Input ' + len + ' B.'));
  }
  function runOverflow(animate) {
    if (ovAnim) { clearInterval(ovAnim); ovAnim = null; }
    $('ovBufKv').textContent = $('ovBuf').value;
    var lay = ovLayout();
    var input = $('ovInput').value;
    var len = $('ovLen');
    var over = input.length - lay.N;
    len.innerHTML = '';
    len.appendChild(el('span', { class: input.length > lay.N ? 'cy-r' : 'cy-g' },
      'Input length ' + input.length + ' bytes vs buffer ' + lay.N + ' bytes' + (over > 0 ? '  (' + over + ' bytes overflow)' : '  (fits)')));
    var totalWrite = Math.min(input.length, lay.slots.length);
    if (animate) {
      var f = 0;
      ovDraw(lay, 0, input);
      ovAnim = setInterval(function () {
        f++;
        ovDraw(lay, f, input);
        if (f >= totalWrite) { clearInterval(ovAnim); ovAnim = null; ovVerdict(lay, input); }
      }, 70);
    } else {
      ovDraw(lay, totalWrite, input);
      ovVerdict(lay, input);
    }
  }
  $('ovFill').addEventListener('click', function () { runOverflow(true); });
  $('ovReset').addEventListener('click', function () { $('ovInput').value = ''; runOverflow(false); });
  $('ovBuf').addEventListener('input', function () { runOverflow(false); });
  $('ovCanary').addEventListener('change', function () { runOverflow(false); });
  $('ovInput').addEventListener('input', function () { runOverflow(false); });

  /* ===================================================================
     INITIAL RENDER
     =================================================================== */
  runCipher();
  runCrack();
  runRSA();
  runDH();
  runHash();
  runPW();
})();
</script>

</BaseLayout>
