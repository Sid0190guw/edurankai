---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Cybersecurity · Virtual Labs · AquinTutor" description="Eight cryptography experiments — ciphers, cryptanalysis, RSA, Diffie-Hellman, hashing avalanche, password strength, AES-GCM and LSB steganography — all computed live.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; }
  .cy-wrap { max-width: 1280px; margin: 0 auto; padding: 18px 4vw 80px; }
  .cy-back { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #67e8f9; text-decoration: none; letter-spacing: 0.08em; }
  .cy-eye { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 12px 0 4px; }
  .cy-title { font-family: 'Cormorant Garamond', serif; font-size: 38px; font-weight: 600; margin: 0; letter-spacing: -0.02em; line-height: 1.05; }
  .cy-title em { color: #a78bfa; font-style: italic; font-weight: 500; }
  .cy-sub { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12px; color: #9aa6b6; margin: 8px 0 0; max-width: 760px; line-height: 1.6; }

  /* ---- vlabs two-column layout ---- */
  .cy-lab-shell { display: grid; grid-template-columns: 260px 1fr; gap: 20px; margin-top: 24px; align-items: start; }
  @media (max-width: 900px) { .cy-lab-shell { grid-template-columns: 1fr; } }

  .cy-side { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 12px; position: sticky; top: 16px; }
  .cy-side h4 { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9.5px; letter-spacing: 0.18em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; margin: 4px 6px 10px; }
  .cy-exp-btn { display: flex; gap: 10px; align-items: baseline; width: 100%; box-sizing: border-box; text-align: left; background: transparent; border: 1px solid transparent; color: #cfd6da; padding: 9px 10px; border-radius: 8px; cursor: pointer; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12px; line-height: 1.4; margin-bottom: 3px; transition: all 0.12s; }
  .cy-exp-btn:hover { background: #0a0a0c; border-color: #2a2a35; color: #e8e8ee; }
  .cy-exp-btn.active { background: #0a0a0c; border-color: #67e8f9; color: #e8e8ee; }
  .cy-exp-btn .num { color: #67e8f9; font-weight: 700; min-width: 16px; }
  .cy-exp-btn.active .num { color: #fbbf24; }

  /* ---- experiment panel ---- */
  .cy-main { min-width: 0; }
  .cy-exp { display: none; }
  .cy-exp.active { display: block; }
  .cy-exp-title { font-family: 'Cormorant Garamond', serif; font-size: 27px; font-weight: 600; margin: 0 0 4px; letter-spacing: -0.01em; }
  .cy-exp-title em { color: #a78bfa; font-style: italic; }

  .cy-sectabs { display: flex; flex-wrap: wrap; gap: 5px; margin: 14px 0 18px; border-bottom: 1px solid #2a2a35; padding-bottom: 12px; }
  .cy-sectab { background: #11131a; border: 1px solid #2a2a35; color: #cfd6da; padding: 6px 12px; border-radius: 7px; cursor: pointer; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; transition: all 0.12s; }
  .cy-sectab:hover { border-color: #67e8f9; color: #e8e8ee; }
  .cy-sectab.active { background: #67e8f9; color: #04161b; border-color: #67e8f9; }

  .cy-sec { display: none; }
  .cy-sec.active { display: block; }

  .cy-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 18px; margin-bottom: 16px; }
  .cy-panel h3 { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 12px; }
  .cy-grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 820px) { .cy-grid2 { grid-template-columns: 1fr; } }

  .cy-prose { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 13px; color: #cfd6da; line-height: 1.75; margin: 0 0 12px; }
  .cy-prose b { color: #e8e8ee; }
  .cy-formula { background: #0a0a0c; border: 1px solid #2a2a35; border-left: 3px solid #fbbf24; border-radius: 6px; padding: 10px 14px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 13px; color: #fbbf24; line-height: 1.8; margin: 10px 0; white-space: pre-wrap; }
  ol.cy-proc { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 13px; color: #cfd6da; line-height: 1.85; margin: 0; padding-left: 22px; }
  ol.cy-proc li { margin-bottom: 6px; }
  ul.cy-refs { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12.5px; color: #9aa6b6; line-height: 1.8; margin: 0; padding-left: 20px; }
  ul.cy-refs li { margin-bottom: 6px; }
  ul.cy-refs a { color: #67e8f9; text-decoration: none; }
  ul.cy-refs a:hover { text-decoration: underline; }

  label.cy-lab { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; display: flex; justify-content: space-between; margin: 0 0 5px; }
  label.cy-lab span { color: #67e8f9; }
  .cy-in { width: 100%; box-sizing: border-box; background: #0a0a0c; border: 1px solid #2a2a35; color: #e8e8ee; padding: 9px 11px; border-radius: 6px; font-size: 13px; font-family: 'Geist Mono', ui-monospace, monospace; margin-bottom: 12px; }
  .cy-in:focus { outline: none; border-color: #67e8f9; }
  textarea.cy-in { resize: vertical; min-height: 64px; line-height: 1.5; }
  select.cy-in { cursor: pointer; }
  input[type=range].cy-in { padding: 0; }

  .cy-out { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; padding: 12px 14px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 13px; line-height: 1.7; word-break: break-all; color: #e8e8ee; white-space: pre-wrap; }
  .cy-out.cyan { border-color: #67e8f9; }
  .cy-out.purple { border-color: #a78bfa; }
  .cy-mono { font-family: 'Geist Mono', ui-monospace, monospace; }
  .cy-c { color: #67e8f9; } .cy-p { color: #a78bfa; } .cy-a { color: #fbbf24; } .cy-g { color: #86efac; } .cy-r { color: #fca5a5; } .cy-dim { color: #9aa6b6; }

  .cy-btn { background: #a78bfa; color: #160a2b; padding: 9px 16px; border-radius: 6px; border: none; cursor: pointer; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
  .cy-btn:hover { filter: brightness(1.08); }
  .cy-btn.ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
  .cy-btn.cyan { background: #67e8f9; color: #04161b; }

  .cy-note { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #9aa6b6; line-height: 1.6; margin: 10px 0 0; }
  .cy-kv { display: grid; grid-template-columns: max-content 1fr; gap: 4px 14px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12.5px; line-height: 1.7; }
  .cy-kv .k { color: #9aa6b6; }
  .cy-kv .v { color: #e8e8ee; word-break: break-all; }
  .cy-steps { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12px; color: #cfd6da; line-height: 1.85; margin: 0; }
  .cy-meter { height: 14px; border-radius: 7px; background: #0a0a0c; border: 1px solid #2a2a35; overflow: hidden; margin: 10px 0 6px; }
  .cy-meter > div { height: 100%; transition: width 0.18s, background 0.18s; }
  .cy-bars { width: 100%; height: 200px; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; }
  .cy-dh { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; }
  .cy-pill { display: inline-block; padding: 3px 10px; border-radius: 999px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }

  /* ---- self-assessment ---- */
  .cy-q { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; padding: 14px 16px; margin-bottom: 12px; }
  .cy-q .stem { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 13px; color: #e8e8ee; line-height: 1.6; margin: 0 0 10px; font-weight: 700; }
  .cy-opt { display: flex; gap: 9px; align-items: flex-start; padding: 7px 9px; border-radius: 6px; cursor: pointer; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12.5px; color: #cfd6da; line-height: 1.5; border: 1px solid transparent; }
  .cy-opt:hover { background: #11131a; }
  .cy-opt input { margin-top: 2px; accent-color: #67e8f9; }
  .cy-opt.correct { border-color: #86efac; background: rgba(134,239,172,0.08); color: #d7f7e3; }
  .cy-opt.wrong { border-color: #fca5a5; background: rgba(252,165,165,0.08); color: #f9d7d7; }
  .cy-expl { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11.5px; line-height: 1.6; margin-top: 9px; display: none; }
  .cy-expl.show { display: block; }

  .cy-canvas { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; image-rendering: pixelated; max-width: 100%; }
</style>

<main class="cy-wrap">
  <a class="cy-back" href="/aquintutor/labs">&larr; Virtual labs</a>
  <p class="cy-eye">Security &middot; Cryptography</p>
  <h1 class="cy-title">Cybersecurity <em>lab</em>.</h1>
  <p class="cy-sub">Eight self-contained cryptography experiments. Each has an aim, theory, procedure, a live simulation that genuinely computes in your browser, a graded self-assessment, and references. Break a Caesar cipher with chi-squared analysis, run RSA over real BigInt arithmetic, exchange a Diffie-Hellman key, measure the SHA-256 avalanche, encrypt with AES-GCM, and hide a message in image pixels. Nothing is faked.</p>

  <div class="cy-lab-shell">
    <!-- =================== SIDEBAR =================== -->
    <aside class="cy-side">
      <h4>Experiments</h4>
      <div id="cyExpList"></div>
    </aside>

    <!-- =================== MAIN PANEL =================== -->
    <div class="cy-main">

      <!-- ===== EXP 1: CLASSICAL CIPHERS ===== -->
      <section class="cy-exp active" data-exp="cipher">
        <h2 class="cy-exp-title">1 &middot; Classical <em>ciphers</em></h2>
        <div class="cy-sectabs" data-sectabs></div>

        <div class="cy-sec" data-sec="aim">
          <div class="cy-panel"><h3>Aim</h3>
            <p class="cy-prose">To implement and observe two classical substitution ciphers &mdash; the Caesar (shift) cipher and the Vigenere (polyalphabetic) cipher &mdash; and to understand how each transforms plaintext into ciphertext and back.</p>
          </div>
        </div>
        <div class="cy-sec" data-sec="theory">
          <div class="cy-panel"><h3>Theory</h3>
            <p class="cy-prose">A <b>Caesar cipher</b> shifts every letter by a fixed amount k along the alphabet, wrapping around at Z. Because the same shift is used for every letter it is <b>monoalphabetic</b> and has only 25 useful keys. The <b>Vigenere cipher</b> uses a repeating keyword: each plaintext letter is shifted by the corresponding key letter, so the same plaintext letter can encrypt to different ciphertext letters. This <b>polyalphabetic</b> behaviour flattens the letter-frequency profile and was considered unbreakable for centuries.</p>
            <div class="cy-formula">Caesar:    C(i) = (P(i) + k) mod 26
Decrypt:   P(i) = (C(i) - k) mod 26
Vigenere:  C(i) = (P(i) + K(i mod m)) mod 26   (key length m)</div>
          </div>
        </div>
        <div class="cy-sec" data-sec="procedure">
          <div class="cy-panel"><h3>Procedure</h3>
            <ol class="cy-proc">
              <li>Set a Caesar shift k with the slider and type a plaintext message.</li>
              <li>Observe the ciphertext update letter-by-letter as you change k.</li>
              <li>Enter a Vigenere keyword and plaintext, and confirm the decrypted text matches the original.</li>
              <li>Study the letter-frequency chart of the Caesar ciphertext against the expected English profile (dashed amber).</li>
              <li>Press auto-crack to recover the Caesar key from frequency alone (covered fully in Experiment 2).</li>
            </ol>
          </div>
        </div>
        <div class="cy-sec active" data-sec="sim">
          <div class="cy-grid2">
            <div class="cy-panel">
              <h3>Caesar cipher</h3>
              <label class="cy-lab">Shift <span id="caesarKv">3</span></label>
              <input id="caesarShift" class="cy-in" type="range" min="0" max="25" step="1" value="3"/>
              <label class="cy-lab">Plaintext</label>
              <textarea id="caesarPt" class="cy-in" spellcheck="false">The quick brown fox jumps over the lazy dog</textarea>
              <label class="cy-lab">Ciphertext</label>
              <div id="caesarCt" class="cy-out cyan"></div>
              <div style="margin-top:12px;display:flex;gap:8px;flex-wrap:wrap;">
                <button id="caesarCrack" class="cy-btn cyan">Auto-crack (chi-squared)</button>
              </div>
              <div id="caesarCrackOut" style="margin-top:12px;"></div>
            </div>
            <div class="cy-panel">
              <h3>Vigenere cipher</h3>
              <label class="cy-lab">Keyword</label>
              <input id="vigKey" class="cy-in" type="text" value="LEMON" spellcheck="false"/>
              <label class="cy-lab">Plaintext</label>
              <textarea id="vigPt" class="cy-in" spellcheck="false">ATTACK AT DAWN</textarea>
              <label class="cy-lab">Encrypted</label>
              <div id="vigCt" class="cy-out purple"></div>
              <label class="cy-lab" style="margin-top:12px;">Decrypted back</label>
              <div id="vigDt" class="cy-out"></div>
            </div>
          </div>
          <div class="cy-panel">
            <h3>Letter frequency of ciphertext</h3>
            <p class="cy-note">A monoalphabetic cipher (Caesar) preserves the English frequency profile, just shifted &mdash; that is exactly what lets us crack it. Vigenere flattens it. Bars below are for the <span class="cy-c">Caesar ciphertext</span>; the dashed line marks expected English frequency.</p>
            <svg id="freqChart" class="cy-bars" viewBox="0 0 1040 200" preserveAspectRatio="none"></svg>
          </div>
        </div>
        <div class="cy-sec" data-sec="quiz"><div class="cy-panel"><h3>Self-assessment</h3><div data-quiz="cipher"></div></div></div>
        <div class="cy-sec" data-sec="refs"><div class="cy-panel"><h3>References</h3>
          <ul class="cy-refs">
            <li>Stinson &amp; Paterson, <em>Cryptography: Theory and Practice</em>, 4th ed., ch. 1 (classical ciphers).</li>
            <li>Singh, <em>The Code Book</em> &mdash; history of the Caesar and Vigenere ciphers.</li>
            <li>Kahn, <em>The Codebreakers</em> &mdash; substitution and polyalphabetic systems.</li>
          </ul>
        </div></div>
      </section>

      <!-- ===== EXP 2: CRYPTANALYSIS ===== -->
      <section class="cy-exp" data-exp="crack">
        <h2 class="cy-exp-title">2 &middot; <em>Cryptanalysis</em> by frequency</h2>
        <div class="cy-sectabs" data-sectabs></div>

        <div class="cy-sec" data-sec="aim"><div class="cy-panel"><h3>Aim</h3>
          <p class="cy-prose">To break a Caesar cipher without knowing the key, using letter-frequency analysis and the chi-squared statistic to score every candidate shift automatically.</p>
        </div></div>
        <div class="cy-sec" data-sec="theory"><div class="cy-panel"><h3>Theory</h3>
          <p class="cy-prose">English text has a fixed letter-frequency fingerprint (E ~12.7%, T ~9.1%, A ~8.2%, ... Z ~0.07%). A Caesar shift only <b>rotates</b> this fingerprint, so the correct decryption is the one whose frequencies best match English. The <b>chi-squared statistic</b> measures that mismatch: for each candidate shift we compute the observed letter counts, compare them with the counts English predicts, and sum the squared relative error. The shift giving the <b>lowest</b> chi-squared is almost always the key &mdash; all 26 trials run instantly.</p>
          <div class="cy-formula">chi^2 = sum over letters of  (observed - expected)^2 / expected
expected(letter) = N * freq_English(letter)
recovered key = argmin over k of  chi^2( decrypt(C, k) )</div>
        </div></div>
        <div class="cy-sec" data-sec="procedure"><div class="cy-panel"><h3>Procedure</h3>
          <ol class="cy-proc">
            <li>Paste or type an intercepted ciphertext (or reuse the Caesar output from Experiment 1).</li>
            <li>Run the analyser: it decrypts under all 26 shifts and scores each with chi-squared.</li>
            <li>Read the ranked table &mdash; the lowest chi-squared is the recovered key.</li>
            <li>Confirm the recovered plaintext is readable English.</li>
            <li>Try a short ciphertext to see why analysis needs enough letters to be reliable.</li>
          </ol>
        </div></div>
        <div class="cy-sec active" data-sec="sim">
          <div class="cy-panel">
            <h3>Intercepted ciphertext</h3>
            <label class="cy-lab">Ciphertext (unknown key)</label>
            <textarea id="craTxt" class="cy-in" spellcheck="false">Wkh txlfn eurzq ira mxpsv ryhu wkh odcb grj</textarea>
            <button id="craRun" class="cy-btn cyan">Run frequency / chi-squared attack</button>
            <div id="craOut" style="margin-top:14px;"></div>
          </div>
          <div class="cy-panel">
            <h3>Frequency profile of the ciphertext</h3>
            <p class="cy-note">Cyan bars are the ciphertext letter frequencies; the amber dashed line is expected English frequency. Cracking finds the rotation that lines them up.</p>
            <svg id="craChart" class="cy-bars" viewBox="0 0 1040 200" preserveAspectRatio="none"></svg>
          </div>
        </div>
        <div class="cy-sec" data-sec="quiz"><div class="cy-panel"><h3>Self-assessment</h3><div data-quiz="crack"></div></div></div>
        <div class="cy-sec" data-sec="refs"><div class="cy-panel"><h3>References</h3>
          <ul class="cy-refs">
            <li>Friedman, <em>The Index of Coincidence and Its Applications in Cryptography</em> (1922).</li>
            <li>NIST / Practical Cryptography &mdash; chi-squared scoring for monoalphabetic ciphers.</li>
            <li>Stinson &amp; Paterson, <em>Cryptography: Theory and Practice</em>, ch. 2 (cryptanalysis).</li>
          </ul>
        </div></div>
      </section>

      <!-- ===== EXP 3: RSA ===== -->
      <section class="cy-exp" data-exp="rsa">
        <h2 class="cy-exp-title">3 &middot; <em>RSA</em> public-key</h2>
        <div class="cy-sectabs" data-sectabs></div>

        <div class="cy-sec" data-sec="aim"><div class="cy-panel"><h3>Aim</h3>
          <p class="cy-prose">To build the RSA public-key cryptosystem from first principles &mdash; generate a key pair from two primes, encrypt an integer message, and decrypt it back &mdash; using exact BigInt arithmetic.</p>
        </div></div>
        <div class="cy-sec" data-sec="theory"><div class="cy-panel"><h3>Theory</h3>
          <p class="cy-prose">RSA rests on the difficulty of factoring a large modulus n into its two prime factors p and q. The public exponent e and private exponent d are inverses modulo Euler's totient phi(n). Encryption raises the message to e, decryption raises the ciphertext to d, and Euler's theorem guarantees you get the original message back. Security comes from the fact that recovering d requires phi(n), which requires the factorisation of n.</p>
          <div class="cy-formula">n = p * q                      phi(n) = (p-1)(q-1)
choose e with gcd(e, phi) = 1   d = e^(-1) mod phi
encrypt:  c = m^e mod n         decrypt:  m = c^d mod n</div>
        </div></div>
        <div class="cy-sec" data-sec="procedure"><div class="cy-panel"><h3>Procedure</h3>
          <ol class="cy-proc">
            <li>Enter two distinct primes p and q (the tool checks primality).</li>
            <li>Choose a public exponent e that is coprime to phi(n).</li>
            <li>Read the derived modulus n, totient phi, and private exponent d.</li>
            <li>Enter a message integer m with 0 &le; m &lt; n.</li>
            <li>Verify c = m^e mod n encrypts and c^d mod n recovers m exactly.</li>
            <li>Follow the worked steps to see each modular operation.</li>
          </ol>
        </div></div>
        <div class="cy-sec active" data-sec="sim">
          <div class="cy-grid2">
            <div class="cy-panel">
              <h3>Key generation</h3>
              <label class="cy-lab">Prime p</label>
              <input id="rsaP" class="cy-in" type="number" value="61" min="2"/>
              <label class="cy-lab">Prime q</label>
              <input id="rsaQ" class="cy-in" type="number" value="53" min="2"/>
              <label class="cy-lab">Public exponent e (must be coprime to phi)</label>
              <select id="rsaE" class="cy-in">
                <option value="3">3</option>
                <option value="17" selected>17</option>
                <option value="257">257</option>
                <option value="65537">65537</option>
              </select>
              <p class="cy-note">Suggested primes: 53, 59, 61, 67, 71, 101, 137, 211, 257, 1009, 7919, 65521.</p>
              <div id="rsaKeyOut" style="margin-top:8px;"></div>
            </div>
            <div class="cy-panel">
              <h3>Encrypt / decrypt</h3>
              <label class="cy-lab">Message integer m (0 &le; m &lt; n)</label>
              <input id="rsaM" class="cy-in" type="number" value="65" min="0"/>
              <label class="cy-lab">Ciphertext c = m^e mod n</label>
              <div id="rsaC" class="cy-out cyan"></div>
              <label class="cy-lab" style="margin-top:12px;">Recovered m = c^d mod n</label>
              <div id="rsaR" class="cy-out purple"></div>
            </div>
          </div>
          <div class="cy-panel">
            <h3>Worked steps</h3>
            <div id="rsaSteps" class="cy-steps"></div>
          </div>
        </div>
        <div class="cy-sec" data-sec="quiz"><div class="cy-panel"><h3>Self-assessment</h3><div data-quiz="rsa"></div></div></div>
        <div class="cy-sec" data-sec="refs"><div class="cy-panel"><h3>References</h3>
          <ul class="cy-refs">
            <li>Rivest, Shamir &amp; Adleman, <em>A Method for Obtaining Digital Signatures and Public-Key Cryptosystems</em>, CACM 1978.</li>
            <li>Menezes, van Oorschot &amp; Vanstone, <em>Handbook of Applied Cryptography</em>, ch. 8.</li>
            <li>RFC 8017 &mdash; PKCS #1 v2.2 RSA Cryptography Specifications.</li>
          </ul>
        </div></div>
      </section>

      <!-- ===== EXP 4: DIFFIE-HELLMAN ===== -->
      <section class="cy-exp" data-exp="dh">
        <h2 class="cy-exp-title">4 &middot; <em>Diffie-Hellman</em> key exchange</h2>
        <div class="cy-sectabs" data-sectabs></div>

        <div class="cy-sec" data-sec="aim"><div class="cy-panel"><h3>Aim</h3>
          <p class="cy-prose">To let two parties derive a shared secret key over a public channel without ever transmitting the secret, and to confirm both sides compute the identical value.</p>
        </div></div>
        <div class="cy-sec" data-sec="theory"><div class="cy-panel"><h3>Theory</h3>
          <p class="cy-prose">Diffie-Hellman uses a public prime p and generator g. Alice picks a secret a and sends A = g^a mod p; Bob picks a secret b and sends B = g^b mod p. Each then raises the other's public value to their own secret: Alice computes B^a, Bob computes A^b. Both equal g^(ab) mod p &mdash; the shared secret. An eavesdropper sees p, g, A and B but must solve the <b>discrete logarithm problem</b> to recover a or b, which is infeasible for large p.</p>
          <div class="cy-formula">Alice -> Bob:  A = g^a mod p
Bob   -> Alice: B = g^b mod p
shared = B^a mod p = A^b mod p = g^(ab) mod p</div>
        </div></div>
        <div class="cy-sec" data-sec="procedure"><div class="cy-panel"><h3>Procedure</h3>
          <ol class="cy-proc">
            <li>Set a public prime p and generator g (shared openly).</li>
            <li>Give Alice and Bob private exponents a and b.</li>
            <li>Watch the diagram exchange A and B over the public channel.</li>
            <li>Confirm B^a mod p equals A^b mod p &mdash; the agreed secret.</li>
            <li>Change a private value and see the secret change while p, g, A, B stay public.</li>
          </ol>
        </div></div>
        <div class="cy-sec active" data-sec="sim">
          <div class="cy-panel">
            <h3>Parameters</h3>
            <div class="cy-grid2">
              <div>
                <label class="cy-lab">Public prime p</label>
                <input id="dhP" class="cy-in" type="number" value="23" min="3"/>
                <label class="cy-lab">Public generator g</label>
                <input id="dhG" class="cy-in" type="number" value="5" min="2"/>
              </div>
              <div>
                <label class="cy-lab">Alice private a (secret)</label>
                <input id="dhA" class="cy-in" type="number" value="6" min="1"/>
                <label class="cy-lab">Bob private b (secret)</label>
                <input id="dhB" class="cy-in" type="number" value="15" min="1"/>
              </div>
            </div>
            <div id="dhValid" class="cy-note"></div>
          </div>
          <div class="cy-panel">
            <h3>The exchange</h3>
            <svg id="dhDiagram" class="cy-dh" viewBox="0 0 1040 320" preserveAspectRatio="xMidYMid meet"></svg>
            <div id="dhResult" style="margin-top:14px;"></div>
          </div>
        </div>
        <div class="cy-sec" data-sec="quiz"><div class="cy-panel"><h3>Self-assessment</h3><div data-quiz="dh"></div></div></div>
        <div class="cy-sec" data-sec="refs"><div class="cy-panel"><h3>References</h3>
          <ul class="cy-refs">
            <li>Diffie &amp; Hellman, <em>New Directions in Cryptography</em>, IEEE Trans. Inf. Theory, 1976.</li>
            <li>RFC 7919 &mdash; Negotiated Finite Field Diffie-Hellman Ephemeral Parameters.</li>
            <li>Menezes et al., <em>Handbook of Applied Cryptography</em>, ch. 12 (key establishment).</li>
          </ul>
        </div></div>
      </section>

      <!-- ===== EXP 5: HASHING ===== -->
      <section class="cy-exp" data-exp="hash">
        <h2 class="cy-exp-title">5 &middot; Hashing &amp; the <em>avalanche</em> effect</h2>
        <div class="cy-sectabs" data-sectabs></div>

        <div class="cy-sec" data-sec="aim"><div class="cy-panel"><h3>Aim</h3>
          <p class="cy-prose">To compute SHA-256 digests and measure the avalanche effect &mdash; the property that flipping a single input bit changes about half the output bits.</p>
        </div></div>
        <div class="cy-sec" data-sec="theory"><div class="cy-panel"><h3>Theory</h3>
          <p class="cy-prose">A cryptographic hash maps any input to a fixed-length digest (256 bits for SHA-256). Good hashes are <b>deterministic</b>, <b>preimage-resistant</b> (you cannot reverse them), and <b>collision-resistant</b>. The <b>avalanche effect</b> is a key diffusion property: a one-bit change in the input should flip roughly 50% of the output bits, so similar inputs produce completely unrelated digests. We measure this with the <b>Hamming distance</b> &mdash; the number of differing bits between the two 256-bit outputs.</p>
          <div class="cy-formula">digest = SHA-256(message)        (256 bits)
Hamming distance = number of differing bits
avalanche % = Hamming(SHA(A), SHA(B)) / 256 * 100   (~50% ideal)</div>
        </div></div>
        <div class="cy-sec" data-sec="procedure"><div class="cy-panel"><h3>Procedure</h3>
          <ol class="cy-proc">
            <li>Enter input A; the SHA-256 digest is computed via the Web Crypto API.</li>
            <li>Flip one bit of A (button) or edit input B directly.</li>
            <li>Compare the two digests &mdash; differing hex digits are highlighted red.</li>
            <li>Read the Hamming distance and the resulting avalanche percentage.</li>
            <li>Confirm even a one-character change flips close to 50% of the 256 output bits.</li>
          </ol>
        </div></div>
        <div class="cy-sec active" data-sec="sim">
          <div class="cy-panel">
            <h3>SHA-256 &mdash; avalanche effect</h3>
            <label class="cy-lab">Input A</label>
            <textarea id="hashA" class="cy-in" spellcheck="false">Hello, world</textarea>
            <label class="cy-lab">SHA-256(A)</label>
            <div id="hashOutA" class="cy-out cyan"></div>
            <div style="margin:14px 0 0;display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
              <button id="hashFlip" class="cy-btn ghost">Flip one bit of A &rarr; B</button>
              <span class="cy-note" style="margin:0;">or edit Input B directly</span>
            </div>
            <label class="cy-lab" style="margin-top:12px;">Input B</label>
            <textarea id="hashB" class="cy-in" spellcheck="false">Hello, World</textarea>
            <label class="cy-lab">SHA-256(B)</label>
            <div id="hashOutB" class="cy-out purple"></div>
            <div id="hashAval" style="margin-top:16px;"></div>
          </div>
        </div>
        <div class="cy-sec" data-sec="quiz"><div class="cy-panel"><h3>Self-assessment</h3><div data-quiz="hash"></div></div></div>
        <div class="cy-sec" data-sec="refs"><div class="cy-panel"><h3>References</h3>
          <ul class="cy-refs">
            <li>NIST FIPS 180-4 &mdash; Secure Hash Standard (SHA-256).</li>
            <li>Feistel, <em>Cryptography and Computer Privacy</em>, Scientific American 1973 (diffusion / avalanche).</li>
            <li>W3C / WHATWG &mdash; Web Cryptography API, SubtleCrypto.digest.</li>
          </ul>
        </div></div>
      </section>

      <!-- ===== EXP 6: PASSWORD STRENGTH ===== -->
      <section class="cy-exp" data-exp="pw">
        <h2 class="cy-exp-title">6 &middot; Password strength &amp; <em>brute force</em></h2>
        <div class="cy-sectabs" data-sectabs></div>

        <div class="cy-sec" data-sec="aim"><div class="cy-panel"><h3>Aim</h3>
          <p class="cy-prose">To estimate the entropy of a password from its length and character classes, and to convert that into an expected brute-force crack time at various attacker speeds.</p>
        </div></div>
        <div class="cy-sec" data-sec="theory"><div class="cy-panel"><h3>Theory</h3>
          <p class="cy-prose">If a password is drawn at random from a character pool of size R and has length L, the keyspace is R^L and its entropy is L*log2(R) bits. A brute-force attacker testing G guesses per second finds it, on average, after searching half the keyspace. This gives an <b>upper bound</b> on strength: real human passwords are far weaker because they are not random &mdash; dictionary, reuse and pattern attacks beat brute force.</p>
          <div class="cy-formula">pool R = 26(lower)+26(upper)+10(digits)+33(symbols) as used
entropy H = L * log2(R)   bits        keyspace = R^L
avg crack time = (R^L / 2) / G   seconds</div>
        </div></div>
        <div class="cy-sec" data-sec="procedure"><div class="cy-panel"><h3>Procedure</h3>
          <ol class="cy-proc">
            <li>Type a candidate password (computed locally, never transmitted).</li>
            <li>Select an attacker speed: throttled online, single GPU, or cluster.</li>
            <li>Read the detected character classes and resulting pool size.</li>
            <li>Observe the entropy in bits and the strength verdict.</li>
            <li>Add length and classes; note that length dominates entropy growth.</li>
          </ol>
        </div></div>
        <div class="cy-sec active" data-sec="sim">
          <div class="cy-panel">
            <h3>Password strength &amp; crack time</h3>
            <label class="cy-lab">Password (computed locally, never sent)</label>
            <input id="pwIn" class="cy-in" type="text" value="P@ssw0rd" spellcheck="false" autocomplete="off"/>
            <label class="cy-lab">Attacker speed</label>
            <select id="pwRate" class="cy-in">
              <option value="1000">Online throttled &mdash; 1,000 guesses/sec</option>
              <option value="1000000000" selected>Single GPU &mdash; 1e9 guesses/sec</option>
              <option value="1000000000000">Cluster &mdash; 1e12 guesses/sec</option>
            </select>
            <div class="cy-meter"><div id="pwBar" style="width:0%;background:#fca5a5;"></div></div>
            <div id="pwVerdict" style="margin:6px 0 14px;"></div>
            <div id="pwDetail" class="cy-kv"></div>
            <p class="cy-note">Entropy assumes a random password drawn from the detected character classes (worst case for the defender). Real human passwords are far weaker because they are not random &mdash; dictionary and pattern attacks beat brute force. This is an upper bound on strength.</p>
          </div>
        </div>
        <div class="cy-sec" data-sec="quiz"><div class="cy-panel"><h3>Self-assessment</h3><div data-quiz="pw"></div></div></div>
        <div class="cy-sec" data-sec="refs"><div class="cy-panel"><h3>References</h3>
          <ul class="cy-refs">
            <li>NIST SP 800-63B &mdash; Digital Identity Guidelines (memorized secrets).</li>
            <li>Shannon, <em>A Mathematical Theory of Communication</em> (1948) &mdash; entropy.</li>
            <li>Bonneau, <em>The Science of Guessing</em>, IEEE S&amp;P 2012 (password distributions).</li>
          </ul>
        </div></div>
      </section>

      <!-- ===== EXP 7: AES-GCM ===== -->
      <section class="cy-exp" data-exp="aes">
        <h2 class="cy-exp-title">7 &middot; <em>AES-GCM</em> symmetric encryption</h2>
        <div class="cy-sectabs" data-sectabs></div>

        <div class="cy-sec" data-sec="aim"><div class="cy-panel"><h3>Aim</h3>
          <p class="cy-prose">To encrypt and decrypt a message with real AES-256-GCM, using a key derived from a passphrase with PBKDF2, and to observe the ciphertext, the random IV, and the authentication property.</p>
        </div></div>
        <div class="cy-sec" data-sec="theory"><div class="cy-panel"><h3>Theory</h3>
          <p class="cy-prose">AES is the standard symmetric block cipher: the same key encrypts and decrypts. <b>GCM</b> (Galois/Counter Mode) turns it into an authenticated stream cipher, producing ciphertext plus a tag that detects any tampering. Because a passphrase is not a uniform key, we stretch it with <b>PBKDF2</b> &mdash; thousands of hash iterations over the passphrase and a random salt &mdash; to derive a 256-bit key. A fresh random <b>IV</b> (initialization vector) is required for every message so identical plaintexts never produce identical ciphertext.</p>
          <div class="cy-formula">key  = PBKDF2(passphrase, salt, iterations, SHA-256) -> 256 bits
ct   = AES-256-GCM(key, IV, plaintext)   (+ 128-bit auth tag)
pt   = AES-256-GCM-decrypt(key, IV, ct)  (fails if tampered)</div>
        </div></div>
        <div class="cy-sec" data-sec="procedure"><div class="cy-panel"><h3>Procedure</h3>
          <ol class="cy-proc">
            <li>Enter a passphrase and the plaintext message.</li>
            <li>Press Encrypt: PBKDF2 derives the key, a random salt and IV are generated, and AES-GCM produces the ciphertext.</li>
            <li>Inspect the ciphertext hex, IV hex, and salt hex.</li>
            <li>Press Decrypt to recover the plaintext using the same passphrase.</li>
            <li>Change one passphrase character and decrypt &mdash; authentication fails, proving integrity.</li>
          </ol>
        </div></div>
        <div class="cy-sec active" data-sec="sim">
          <div class="cy-grid2">
            <div class="cy-panel">
              <h3>Encrypt</h3>
              <label class="cy-lab">Passphrase</label>
              <input id="aesPass" class="cy-in" type="text" value="correct horse battery staple" spellcheck="false" autocomplete="off"/>
              <label class="cy-lab">PBKDF2 iterations</label>
              <select id="aesIter" class="cy-in">
                <option value="50000">50,000</option>
                <option value="100000" selected>100,000</option>
                <option value="250000">250,000</option>
              </select>
              <label class="cy-lab">Plaintext</label>
              <textarea id="aesPt" class="cy-in" spellcheck="false">Meet at the old library at midnight.</textarea>
              <button id="aesEnc" class="cy-btn cyan">Encrypt (AES-256-GCM)</button>
              <div id="aesEncOut" style="margin-top:12px;"></div>
            </div>
            <div class="cy-panel">
              <h3>Decrypt</h3>
              <label class="cy-lab">Passphrase to decrypt with</label>
              <input id="aesPass2" class="cy-in" type="text" value="correct horse battery staple" spellcheck="false" autocomplete="off"/>
              <p class="cy-note" style="margin-top:0;">Uses the salt + IV from the last encryption. Change a character above to make GCM authentication fail.</p>
              <button id="aesDec" class="cy-btn" style="margin-top:8px;">Decrypt</button>
              <div id="aesDecOut" style="margin-top:12px;"></div>
            </div>
          </div>
        </div>
        <div class="cy-sec" data-sec="quiz"><div class="cy-panel"><h3>Self-assessment</h3><div data-quiz="aes"></div></div></div>
        <div class="cy-sec" data-sec="refs"><div class="cy-panel"><h3>References</h3>
          <ul class="cy-refs">
            <li>NIST FIPS 197 &mdash; Advanced Encryption Standard (AES).</li>
            <li>NIST SP 800-38D &mdash; Galois/Counter Mode (GCM) and GMAC.</li>
            <li>RFC 8018 &mdash; PKCS #5 Password-Based Cryptography (PBKDF2).</li>
          </ul>
        </div></div>
      </section>

      <!-- ===== EXP 8: STEGANOGRAPHY ===== -->
      <section class="cy-exp" data-exp="steg">
        <h2 class="cy-exp-title">8 &middot; <em>Steganography</em> &mdash; LSB image hiding</h2>
        <div class="cy-sectabs" data-sectabs></div>

        <div class="cy-sec" data-sec="aim"><div class="cy-panel"><h3>Aim</h3>
          <p class="cy-prose">To hide a secret text message inside the least-significant bits of an image's pixels (LSB steganography) and then extract the message back, demonstrating data hiding without visible distortion.</p>
        </div></div>
        <div class="cy-sec" data-sec="theory"><div class="cy-panel"><h3>Theory</h3>
          <p class="cy-prose">Where cryptography hides the <b>meaning</b> of a message, steganography hides its <b>existence</b>. Each pixel channel (R, G, B) is one byte; its least-significant bit contributes only 1 of 256 levels, so changing it is imperceptible to the eye. We encode each character as 8 bits and write those bits into successive LSBs across the pixel channels. A length header tells the extractor how many characters to read. The carrier image looks unchanged but secretly carries the payload.</p>
          <div class="cy-formula">message -> bits (8 per char), prefixed with a 16-bit length
for each bit: channel = (channel AND 0xFE) OR bit
extract: read LSB of each channel, regroup into bytes -> chars</div>
        </div></div>
        <div class="cy-sec" data-sec="procedure"><div class="cy-panel"><h3>Procedure</h3>
          <ol class="cy-proc">
            <li>Generate a carrier image (a colour gradient is drawn on the canvas).</li>
            <li>Type a secret message.</li>
            <li>Press Hide: the message bits are written into pixel LSBs and the stego image is drawn.</li>
            <li>Compare the original and stego images &mdash; they look identical.</li>
            <li>Press Extract: the LSBs are read back and the hidden message is recovered.</li>
          </ol>
        </div></div>
        <div class="cy-sec active" data-sec="sim">
          <div class="cy-panel">
            <h3>Carrier and payload</h3>
            <div class="cy-grid2">
              <div>
                <label class="cy-lab">Secret message</label>
                <textarea id="stegMsg" class="cy-in" spellcheck="false">The treasure is buried under the oak.</textarea>
                <div style="display:flex;gap:8px;flex-wrap:wrap;">
                  <button id="stegGen" class="cy-btn ghost">Regenerate carrier</button>
                  <button id="stegHide" class="cy-btn cyan">Hide message (LSB)</button>
                  <button id="stegExtract" class="cy-btn">Extract</button>
                </div>
                <div id="stegStatus" style="margin-top:12px;"></div>
              </div>
              <div>
                <label class="cy-lab">Capacity</label>
                <div id="stegCap" class="cy-out"></div>
                <label class="cy-lab" style="margin-top:12px;">Extracted message</label>
                <div id="stegOut" class="cy-out purple"></div>
              </div>
            </div>
            <div class="cy-grid2" style="margin-top:14px;">
              <div>
                <label class="cy-lab">Original carrier</label>
                <canvas id="stegCanvasA" class="cy-canvas" width="160" height="120" style="width:100%;"></canvas>
              </div>
              <div>
                <label class="cy-lab">Stego image (message hidden)</label>
                <canvas id="stegCanvasB" class="cy-canvas" width="160" height="120" style="width:100%;"></canvas>
              </div>
            </div>
            <p class="cy-note">Both images are 160&times;120 px. The stego image carries your message in pixel LSBs yet is visually indistinguishable from the original.</p>
          </div>
        </div>
        <div class="cy-sec" data-sec="quiz"><div class="cy-panel"><h3>Self-assessment</h3><div data-quiz="steg"></div></div></div>
        <div class="cy-sec" data-sec="refs"><div class="cy-panel"><h3>References</h3>
          <ul class="cy-refs">
            <li>Fridrich, <em>Steganography in Digital Media: Principles, Algorithms, and Applications</em> (2009).</li>
            <li>Johnson &amp; Jajodia, <em>Exploring Steganography: Seeing the Unseen</em>, IEEE Computer 1998.</li>
            <li>Provos &amp; Honeyman, <em>Hide and Seek: An Introduction to Steganography</em>, IEEE S&amp;P 2003.</li>
          </ul>
        </div></div>
      </section>

    </div>
  </div>
</main>

<script is:inline>
