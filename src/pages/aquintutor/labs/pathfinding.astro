---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Pathfinding lab — BFS / Dijkstra / A* on a grid you paint. Records the visit
// order and shortest path, then animates the frontier expanding and the path
// lighting up. Depth-lit high-DPI canvas, no libraries.
---
<BaseLayout title="Pathfinding lab · Virtual Labs · AquinTutor" description="Paint walls, drop a start and goal, and watch BFS, Dijkstra or A* sweep the grid and light up the shortest path.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1320px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:18px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:290px minmax(0,1fr); gap:18px; } @media(max-width:900px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:16px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 12px; }
  .lb-row{ display:grid; gap:9px; } .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.1em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; }
  .lb-row label span{ color:#5ee7ff; } .lb-row input[type=range]{ width:100%; accent-color:#5ee7ff; } .lb-row select{ width:100%; background:#080a12; border:1px solid #1e2740; color:#fff; padding:8px 10px; border-radius:6px; font-size:12px; font-family:inherit; }
  .lb-btn{ background:linear-gradient(180deg,#7af0ff,#33cfe6); color:#04161b; padding:9px 14px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:10.5px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; }
  .lb-btn-ghost{ background:transparent; color:#cfd6da; border:1px solid #26314f; } .lb-btn.on{ outline:2px solid #7af0ff; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); }
  .lb-stage canvas{ display:block; width:100%; height:auto; cursor:crosshair; }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11.5px; padding:5px 0; border-bottom:1px solid #141a2c; }
  .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#5ee7ff; font-weight:700; text-align:right; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">CS · Graph search</p>
      <h1 class="lb-title">Path <em>finding</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;flex-wrap:wrap;"><button id="runBtn" class="lb-btn">Run</button><button id="clearBtn" class="lb-btn lb-btn-ghost">Clear</button><button id="mazeBtn" class="lb-btn lb-btn-ghost">Maze</button></div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Algorithm</h3><div class="lb-row">
        <label>Method</label><select id="algo"><option value="astar" selected>A* (Manhattan)</option><option value="dijkstra">Dijkstra</option><option value="bfs">Breadth-first</option></select>
        <label>Speed <span id="spV">8</span></label><input id="sp" type="range" min="1" max="40" step="1" value="8"/>
      </div></div>
      <div class="lb-panel"><h3>Paint mode</h3>
        <div style="display:flex;gap:6px;flex-wrap:wrap;"><button class="lb-btn mode on" data-m="wall">Wall</button><button class="lb-btn lb-btn-ghost mode" data-m="start">Start</button><button class="lb-btn lb-btn-ghost mode" data-m="end">Goal</button></div>
        <p style="font-family:'Inter Tight',sans-serif;font-size:11.5px;color:#8ea0be;margin:10px 0 0;">Drag on the grid to paint. Start = green, goal = red.</p>
      </div>
      <div class="lb-panel"><h3>Result</h3>
        <div class="lb-metric"><span class="lb-metric-l">Visited</span><span class="lb-metric-v" id="mVis">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Path length</span><span class="lb-metric-v" id="mLen">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Status</span><span class="lb-metric-v" id="mS">draw a map</span></div>
      </div>
    </aside>
    <section><div class="lb-stage"><canvas id="scene" width="900" height="560"></canvas></div></section>
  </div>
</main>
<script is:inline>
(function(){
  var COLS=45, ROWS=28, grid=[], start={r:13,c:6}, end={r:13,c:38}, mode='wall';
  var order=[], path=[], anim=0, phase='idle', visitedSet={};
  function reset(walls){ grid=[]; for(var r=0;r<ROWS;r++){ var row=[]; for(var c=0;c<COLS;c++) row.push(walls?(Math.random()<0.28 && !(r===start.r&&c===start.c) && !(r===end.r&&c===end.c)?1:0):0); grid.push(row); } order=[]; path=[]; anim=0; phase='idle'; visitedSet={}; document.getElementById('mS').textContent='draw a map'; }
  reset(false);
  document.querySelectorAll('.mode').forEach(function(b){ b.addEventListener('click',function(){ mode=b.getAttribute('data-m'); document.querySelectorAll('.mode').forEach(function(x){ x.classList.remove('on'); x.classList.add('lb-btn-ghost'); }); b.classList.add('on'); b.classList.remove('lb-btn-ghost'); }); });
  document.getElementById('clearBtn').addEventListener('click',function(){ reset(false); });
  document.getElementById('mazeBtn').addEventListener('click',function(){ reset(true); });
  document.getElementById('spV').textContent='8'; document.getElementById('sp').addEventListener('input',function(){ document.getElementById('spV').textContent=this.value; });

  function key(r,c){ return r*COLS+c; }
  function run(){ var algo=document.getElementById('algo').value; var astar=algo==='astar';
    var g=function(node){ return node.g; }; var came={}, dist={}, seen={}, ord=[];
    var pq=[{r:start.r,c:start.c,g:0,f:0}]; dist[key(start.r,start.c)]=0;
    function h(r,c){ return Math.abs(r-end.r)+Math.abs(c-end.c); }
    while(pq.length){ // pick min f (astar) or g
      var bi=0; for(var i=1;i<pq.length;i++){ if((astar?pq[i].f:pq[i].g)<(astar?pq[bi].f:pq[bi].g)) bi=i; } var cur=pq.splice(bi,1)[0]; var ck=key(cur.r,cur.c);
      if(seen[ck]) continue; seen[ck]=1; ord.push([cur.r,cur.c]);
      if(cur.r===end.r&&cur.c===end.c) break;
      [[1,0],[-1,0],[0,1],[0,-1]].forEach(function(d){ var nr=cur.r+d[0], nc=cur.c+d[1]; if(nr<0||nc<0||nr>=ROWS||nc>=COLS) return; if(grid[nr][nc]===1) return; var nk=key(nr,nc), ng=cur.g+1; if(dist[nk]===undefined||ng<dist[nk]){ dist[nk]=ng; came[nk]=ck; pq.push({r:nr,c:nc,g:ng,f:ng+(astar?h(nr,nc):0)}); } });
    }
    var pth=[]; var ek=key(end.r,end.c); if(seen[ek]){ var k2=ek; while(k2!==undefined){ pth.unshift([Math.floor(k2/COLS),k2%COLS]); k2=came[k2]; } }
    order=ord; path=pth; anim=0; phase='visiting'; visitedSet={}; document.getElementById('mS').textContent = pth.length?'searching…':'no path';
  }
  document.getElementById('runBtn').addEventListener('click',run);

  var cv=document.getElementById('scene');
  var painting=false;
  function cellAt(e){ var r=cv.getBoundingClientRect(); var x=(e.clientX-r.left)/r.width*COLS, y=(e.clientY-r.top)/r.height*ROWS; return {r:Math.max(0,Math.min(ROWS-1,Math.floor(y))), c:Math.max(0,Math.min(COLS-1,Math.floor(x)))}; }
  function apply(cell){ if(mode==='wall'){ if(!(cell.r===start.r&&cell.c===start.c)&&!(cell.r===end.r&&cell.c===end.c)) grid[cell.r][cell.c]=1; } else if(mode==='start'){ start={r:cell.r,c:cell.c}; grid[cell.r][cell.c]=0; } else { end={r:cell.r,c:cell.c}; grid[cell.r][cell.c]=0; } }
  cv.addEventListener('mousedown',function(e){ painting=true; apply(cellAt(e)); });
  cv.addEventListener('mousemove',function(e){ if(painting) apply(cellAt(e)); });
  window.addEventListener('mouseup',function(){ painting=false; });
  cv.addEventListener('touchstart',function(e){ painting=true; apply(cellAt(e.touches[0])); e.preventDefault(); },{passive:false});
  cv.addEventListener('touchmove',function(e){ if(painting) apply(cellAt(e.touches[0])); e.preventDefault(); },{passive:false});
  window.addEventListener('touchend',function(){ painting=false; });

  function hidpi(c){ var r=c.getBoundingClientRect(), d=window.devicePixelRatio||1; var w=r.width||c.width, h=(c.height/c.width)*w; c.width=Math.round(w*d); c.height=Math.round(h*d); var ctx=c.getContext('2d'); ctx.setTransform(d,0,0,d,0,0); return {ctx:ctx,w:w,h:h}; }
  function draw(){ var s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h; var cw=W/COLS, ch=H/ROWS;
    ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H);
    var pathSet={}; if(phase==='pathing'||phase==='done') for(var i=0;i<Math.min(anim,path.length);i++) pathSet[key(path[i][0],path[i][1])]=1;
    for(var r=0;r<ROWS;r++) for(var c=0;c<COLS;c++){ var x=c*cw, y=r*ch, kk=key(r,c);
      if(grid[r][c]===1){ ctx.fillStyle='#1a2236'; ctx.fillRect(x+1,y+1,cw-2,ch-2); }
      else if(pathSet[kk]){ ctx.save(); ctx.shadowColor='#fbbf24'; ctx.shadowBlur=10; ctx.fillStyle='#fbbf24'; ctx.fillRect(x+1.5,y+1.5,cw-3,ch-3); ctx.restore(); }
      else if(visitedSet[kk]){ var a=visitedSet[kk]; ctx.fillStyle='rgba(94,231,255,'+(0.12+0.35*a)+')'; ctx.fillRect(x+1,y+1,cw-2,ch-2); }
      else { ctx.fillStyle='#0c1120'; ctx.fillRect(x+1,y+1,cw-2,ch-2); }
    }
    function cell(pos,col){ ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=14; ctx.fillStyle=col; ctx.fillRect(pos.c*cw+2,pos.r*ch+2,cw-4,ch-4); ctx.restore(); }
    cell(start,'#34d399'); cell(end,'#f87171');
    document.getElementById('mVis').textContent = Object.keys(visitedSet).length||'—';
    document.getElementById('mLen').textContent = (phase==='done'&&path.length)?path.length:'—';
  }
  function loop(){ var sp=parseFloat(document.getElementById('sp').value);
    if(phase==='visiting'){ for(var k=0;k<sp && anim<order.length;k++){ visitedSet[key(order[anim][0],order[anim][1])]=1; anim++; } if(anim>=order.length){ phase= path.length?'pathing':'done'; anim=0; if(!path.length) document.getElementById('mS').textContent='no path'; } }
    else if(phase==='pathing'){ anim=Math.min(path.length,anim+Math.max(1,sp/6)); if(anim>=path.length){ phase='done'; document.getElementById('mS').textContent='path found'; } }
    draw(); requestAnimationFrame(loop); }
  requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
