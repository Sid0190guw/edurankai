---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Pathfinding Lab — AquinTutor" description="Visualise BFS, DFS, Dijkstra and A* on a 30x30 grid with weighted cells, walls, and live frontier expansion.">
<style>
  body { background:#0a0a0c; color:#e8e8ee; margin:0; font-family:'Inter',system-ui,sans-serif; }
  .wrap { max-width:1280px; margin:0 auto; padding:48px 24px 96px; }
  .eyebrow { font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin-bottom:14px; }
  .title { font-family:'Cormorant Garamond',serif; font-size:34px; font-weight:600; letter-spacing:-0.02em; line-height:1.15; margin:0 0 12px; max-width:760px; }
  .title em { color:#67e8f9; font-weight:500; }
  .lede { color:#9aa0aa; max-width:680px; font-size:14px; line-height:1.6; margin-bottom:32px; }
  .grid { display:grid; grid-template-columns:minmax(0,1fr) 320px; gap:20px; align-items:start; }
  @media (max-width:980px) { .grid { grid-template-columns:1fr; } }
  .panel { background:#11131a; border:1px solid #2a2a35; border-radius:12px; padding:16px; }
  .panel h3 { font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#67e8f9; font-weight:700; margin:0 0 12px; }
  canvas { display:block; width:100%; background:#0a0a0c; border:1px solid #2a2a35; border-radius:10px; image-rendering:pixelated; cursor:crosshair; }
  .row { display:flex; gap:8px; align-items:center; margin-bottom:10px; flex-wrap:wrap; }
  .row > label { font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.12em; text-transform:uppercase; color:#9aa0aa; min-width:80px; }
  select, input[type=range] { background:#0a0a0c; border:1px solid #2a2a35; color:#fff; padding:7px 10px; border-radius:5px; font-family:'Geist Mono',monospace; font-size:12px; flex:1; }
  input[type=range] { padding:0; height:24px; }
  .btn { background:#67e8f9; color:#04161b; padding:9px 14px; border:none; border-radius:6px; font-family:'Geist Mono',monospace; font-size:11px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; cursor:pointer; }
  .btn:hover { background:#7ff0ff; }
  .btn.ghost { background:transparent; color:#cfd6da; border:1px solid #2a2a35; }
  .btn.ghost:hover { border-color:#67e8f9; color:#67e8f9; }
  .btn:disabled { opacity:0.4; cursor:not-allowed; }
  .btns { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:12px; }
  .btns .full { grid-column:1 / -1; }
  .stats { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:12px; }
  .stat { background:#0a0a0c; border:1px solid #2a2a35; border-radius:6px; padding:8px 10px; }
  .stat .label { font-family:'Geist Mono',monospace; font-size:9px; letter-spacing:0.14em; text-transform:uppercase; color:#9aa0aa; }
  .stat .value { font-family:'Geist Mono',monospace; font-size:18px; color:#67e8f9; font-weight:700; margin-top:2px; }
  .legend { display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:12px; font-family:'Geist Mono',monospace; font-size:10px; color:#cfd6da; }
  .legend > div { display:flex; align-items:center; gap:6px; }
  .swatch { width:14px; height:14px; border:1px solid #2a2a35; border-radius:3px; }
  .helptext { font-family:'Geist Mono',monospace; font-size:10px; color:#9aa0aa; line-height:1.6; margin-top:10px; }
  .helptext code { color:#67e8f9; background:#0a0a0c; padding:1px 5px; border-radius:3px; }
  .canvas-wrap { position:relative; }
  .badge { display:inline-block; font-family:'Geist Mono',monospace; font-size:9px; padding:2px 6px; border-radius:3px; background:#1a1a25; color:#67e8f9; letter-spacing:0.1em; margin-left:8px; }
</style>
<main class="wrap">
  <div class="eyebrow">Lab 11 &middot; Algorithms</div>
  <h1 class="title">Pathfinding <em>visualiser</em></h1>
  <p class="lede">Watch BFS, DFS, Dijkstra and A* explore a 30x30 grid in real time. Every cell expansion is a generator yield, so you can step one move at a time or run continuously. Weighted cells cost five units to traverse — only Dijkstra and A* respect them.</p>

  <div class="grid">
    <div class="panel canvas-wrap">
      <h3>Grid <span class="badge" id="modeBadge">drawing walls</span></h3>
      <canvas id="grid" width="600" height="600"></canvas>
      <div class="helptext">
        <strong style="color:#e8e8ee;">Interactions</strong><br>
        <code>click+drag</code> draw walls &nbsp; <code>right+drag</code> weighted cells (cost 5)<br>
        <code>shift+click</code> set start &nbsp; <code>ctrl+click</code> set end<br>
        <code>alt+click</code> erase a cell
      </div>
    </div>

    <div>
      <div class="panel">
        <h3>Controls</h3>
        <div class="row">
          <label>Algorithm</label>
          <select id="algo">
            <option value="bfs">BFS &mdash; Breadth-first</option>
            <option value="dfs">DFS &mdash; Depth-first</option>
            <option value="dijkstra">Dijkstra (weighted)</option>
            <option value="astar" selected>A* &middot; Manhattan</option>
          </select>
        </div>
        <div class="row">
          <label>Speed</label>
          <input type="range" id="speed" min="1" max="100" value="15">
          <span id="speedVal" style="font-family:'Geist Mono';font-size:11px;color:#67e8f9;min-width:42px;text-align:right;">15ms</span>
        </div>
        <div class="btns">
          <button class="btn" id="runBtn">Run</button>
          <button class="btn ghost" id="stepBtn">Step</button>
          <button class="btn ghost" id="resetBtn">Reset Path</button>
          <button class="btn ghost" id="clearBtn">Clear Walls</button>
          <button class="btn ghost full" id="mazeBtn">Generate Maze</button>
        </div>
        <div class="stats">
          <div class="stat"><div class="label">Visited</div><div class="value" id="visitedC">0</div></div>
          <div class="stat"><div class="label">Frontier</div><div class="value" id="frontierC">0</div></div>
          <div class="stat"><div class="label">Path length</div><div class="value" id="pathC">0</div></div>
          <div class="stat"><div class="label">Path cost</div><div class="value" id="costC">0</div></div>
        </div>
        <div class="legend">
          <div><span class="swatch" style="background:#0a0a0c;"></span>Empty</div>
          <div><span class="swatch" style="background:#2a2a35;"></span>Wall</div>
          <div><span class="swatch" style="background:#5b3d1f;"></span>Weighted (5)</div>
          <div><span class="swatch" style="background:#1e3a5f;"></span>Visited</div>
          <div><span class="swatch" style="background:#67e8f9;"></span>Frontier</div>
          <div><span class="swatch" style="background:#facc15;"></span>Current</div>
          <div><span class="swatch" style="background:#22c55e;"></span>Start</div>
          <div><span class="swatch" style="background:#ef4444;"></span>End</div>
          <div><span class="swatch" style="background:#fde047;"></span>Final path</div>
        </div>
      </div>

      <div class="panel" style="margin-top:14px;">
        <h3>Algorithm notes</h3>
        <div class="helptext" id="algoNotes">A* combines Dijkstra's actual-cost-so-far <code>g(n)</code> with a Manhattan-distance heuristic <code>h(n)</code>, expanding the node with smallest <code>f = g + h</code>. Admissible and optimal on a 4-connected grid.</div>
      </div>
    </div>
  </div>
</main>

<script is:inline>
(function () {
  const COLS = 30, ROWS = 30, CELL = 20;
  const canvas = document.getElementById('grid');
  const ctx = canvas.getContext('2d');
  canvas.width = COLS * CELL;
  canvas.height = ROWS * CELL;

  // Cell state: 0 empty, 1 wall, 2 weighted, 3 start, 4 end
  let cells = new Uint8Array(COLS * ROWS);
  let start = [1, 1];
  let end = [COLS - 2, ROWS - 2];
  cells[idx(start[0], start[1])] = 3;
  cells[idx(end[0], end[1])] = 4;

  // Algorithm overlay state
  let visited = new Uint8Array(COLS * ROWS);
  let frontier = new Uint8Array(COLS * ROWS);
  let current = -1;
  let pathSet = new Uint8Array(COLS * ROWS);

  let running = false;
  let gen = null;

  function idx(x, y) { return y * COLS + x; }
  function inBounds(x, y) { return x >= 0 && y >= 0 && x < COLS && y < ROWS; }

  // Drawing -----------------------------------------------------------
  function draw() {
    ctx.fillStyle = '#0a0a0c';
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    for (let y = 0; y < ROWS; y++) {
      for (let x = 0; x < COLS; x++) {
        const i = idx(x, y);
        const c = cells[i];
        let fill = null;
        if (c === 1) fill = '#2a2a35';
        else if (c === 2) fill = '#5b3d1f';

        if (fill) {
          ctx.fillStyle = fill;
          ctx.fillRect(x * CELL + 1, y * CELL + 1, CELL - 2, CELL - 2);
        }

        // overlay (visited / frontier / path / current)
        if (pathSet[i]) {
          ctx.fillStyle = '#fde047';
          ctx.fillRect(x * CELL + 1, y * CELL + 1, CELL - 2, CELL - 2);
        } else if (current === i) {
          ctx.fillStyle = '#facc15';
          ctx.fillRect(x * CELL + 1, y * CELL + 1, CELL - 2, CELL - 2);
        } else if (frontier[i]) {
          ctx.fillStyle = '#67e8f9';
          ctx.fillRect(x * CELL + 1, y * CELL + 1, CELL - 2, CELL - 2);
        } else if (visited[i] && !fill) {
          ctx.fillStyle = '#1e3a5f';
          ctx.fillRect(x * CELL + 1, y * CELL + 1, CELL - 2, CELL - 2);
        }

        if (c === 3) {
          ctx.fillStyle = '#22c55e';
          ctx.fillRect(x * CELL + 2, y * CELL + 2, CELL - 4, CELL - 4);
          ctx.fillStyle = '#04161b';
          ctx.font = 'bold 10px Geist Mono, monospace';
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          ctx.fillText('S', x * CELL + CELL / 2, y * CELL + CELL / 2 + 1);
        } else if (c === 4) {
          ctx.fillStyle = '#ef4444';
          ctx.fillRect(x * CELL + 2, y * CELL + 2, CELL - 4, CELL - 4);
          ctx.fillStyle = '#fff';
          ctx.font = 'bold 10px Geist Mono, monospace';
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          ctx.fillText('E', x * CELL + CELL / 2, y * CELL + CELL / 2 + 1);
        }
      }
    }

    // grid lines
    ctx.strokeStyle = '#1a1a22';
    ctx.lineWidth = 1;
    for (let x = 0; x <= COLS; x++) {
      ctx.beginPath();
      ctx.moveTo(x * CELL + 0.5, 0);
      ctx.lineTo(x * CELL + 0.5, ROWS * CELL);
      ctx.stroke();
    }
    for (let y = 0; y <= ROWS; y++) {
      ctx.beginPath();
      ctx.moveTo(0, y * CELL + 0.5);
      ctx.lineTo(COLS * CELL, y * CELL + 0.5);
      ctx.stroke();
    }
  }

  // Mouse / pointer ---------------------------------------------------
  let mouseDown = false;
  let mouseButton = 0;
  function pickCell(ev) {
    const rect = canvas.getBoundingClientRect();
    const sx = canvas.width / rect.width;
    const sy = canvas.height / rect.height;
    const x = Math.floor(((ev.clientX - rect.left) * sx) / CELL);
    const y = Math.floor(((ev.clientY - rect.top) * sy) / CELL);
    return inBounds(x, y) ? [x, y] : null;
  }
  function applyAt(ev, p) {
    const i = idx(p[0], p[1]);
    if (ev.shiftKey) {
      if (cells[i] === 4) return;
      cells[idx(start[0], start[1])] = 0;
      start = [p[0], p[1]];
      cells[i] = 3;
    } else if (ev.ctrlKey || ev.metaKey) {
      if (cells[i] === 3) return;
      cells[idx(end[0], end[1])] = 0;
      end = [p[0], p[1]];
      cells[i] = 4;
    } else if (ev.altKey) {
      if (cells[i] === 1 || cells[i] === 2) cells[i] = 0;
    } else if (mouseButton === 2) {
      if (cells[i] === 0) cells[i] = 2;
    } else {
      if (cells[i] === 0) cells[i] = 1;
    }
  }
  canvas.addEventListener('contextmenu', e => e.preventDefault());
  canvas.addEventListener('mousedown', e => {
    if (running) return;
    mouseDown = true;
    mouseButton = e.button;
    const p = pickCell(e);
    if (p) { applyAt(e, p); draw(); updateBadge(e); }
  });
  canvas.addEventListener('mousemove', e => {
    updateBadge(e);
    if (!mouseDown || running) return;
    const p = pickCell(e);
    if (p) { applyAt(e, p); draw(); }
  });
  window.addEventListener('mouseup', () => { mouseDown = false; });

  function updateBadge(e) {
    const b = document.getElementById('modeBadge');
    if (e.shiftKey) b.textContent = 'set start';
    else if (e.ctrlKey || e.metaKey) b.textContent = 'set end';
    else if (e.altKey) b.textContent = 'erase';
    else if (mouseButton === 2 || (mouseDown && mouseButton === 2)) b.textContent = 'weighted (5)';
    else b.textContent = 'drawing walls';
  }

  // Algorithms --------------------------------------------------------
  function neighbors(x, y) {
    const out = [];
    const dx = [0, 1, 0, -1];
    const dy = [-1, 0, 1, 0];
    for (let k = 0; k < 4; k++) {
      const nx = x + dx[k], ny = y + dy[k];
      if (!inBounds(nx, ny)) continue;
      if (cells[idx(nx, ny)] === 1) continue;
      out.push([nx, ny]);
    }
    return out;
  }
  function costOf(x, y) {
    return cells[idx(x, y)] === 2 ? 5 : 1;
  }

  function clearOverlay() {
    visited.fill(0);
    frontier.fill(0);
    pathSet.fill(0);
    current = -1;
  }

  function* bfs() {
    const sI = idx(start[0], start[1]);
    const eI = idx(end[0], end[1]);
    const queue = [sI];
    const cameFrom = new Int32Array(COLS * ROWS).fill(-1);
    frontier[sI] = 1;
    while (queue.length) {
      const cur = queue.shift();
      frontier[cur] = 0;
      visited[cur] = 1;
      current = cur;
      const cx = cur % COLS, cy = Math.floor(cur / COLS);
      if (cur === eI) { current = -1; yield { done: true, cameFrom, eI, sI }; return; }
      for (const [nx, ny] of neighbors(cx, cy)) {
        const ni = idx(nx, ny);
        if (visited[ni] || frontier[ni]) continue;
        cameFrom[ni] = cur;
        frontier[ni] = 1;
        queue.push(ni);
      }
      yield { done: false };
    }
    yield { done: true, cameFrom, eI, sI, unreachable: true };
  }

  function* dfs() {
    const sI = idx(start[0], start[1]);
    const eI = idx(end[0], end[1]);
    const stack = [sI];
    const cameFrom = new Int32Array(COLS * ROWS).fill(-1);
    frontier[sI] = 1;
    while (stack.length) {
      const cur = stack.pop();
      frontier[cur] = 0;
      if (visited[cur]) continue;
      visited[cur] = 1;
      current = cur;
      const cx = cur % COLS, cy = Math.floor(cur / COLS);
      if (cur === eI) { current = -1; yield { done: true, cameFrom, eI, sI }; return; }
      const ns = neighbors(cx, cy);
      // randomise to make DFS look organic
      for (let i = ns.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [ns[i], ns[j]] = [ns[j], ns[i]];
      }
      for (const [nx, ny] of ns) {
        const ni = idx(nx, ny);
        if (visited[ni]) continue;
        if (cameFrom[ni] === -1 && ni !== sI) cameFrom[ni] = cur;
        frontier[ni] = 1;
        stack.push(ni);
      }
      yield { done: false };
    }
    yield { done: true, cameFrom, eI, sI, unreachable: true };
  }

  // Tiny binary min-heap for Dijkstra / A*
  class MinHeap {
    constructor() { this.h = []; }
    size() { return this.h.length; }
    push(v) {
      this.h.push(v);
      let i = this.h.length - 1;
      while (i > 0) {
        const p = (i - 1) >> 1;
        if (this.h[p].k <= this.h[i].k) break;
        [this.h[p], this.h[i]] = [this.h[i], this.h[p]];
        i = p;
      }
    }
    pop() {
      const top = this.h[0];
      const last = this.h.pop();
      if (this.h.length) {
        this.h[0] = last;
        let i = 0, n = this.h.length;
        while (true) {
          const l = 2 * i + 1, r = 2 * i + 2;
          let m = i;
          if (l < n && this.h[l].k < this.h[m].k) m = l;
          if (r < n && this.h[r].k < this.h[m].k) m = r;
          if (m === i) break;
          [this.h[m], this.h[i]] = [this.h[i], this.h[m]];
          i = m;
        }
      }
      return top;
    }
  }

  function* dijkstra() {
    const sI = idx(start[0], start[1]);
    const eI = idx(end[0], end[1]);
    const dist = new Float32Array(COLS * ROWS).fill(Infinity);
    const cameFrom = new Int32Array(COLS * ROWS).fill(-1);
    dist[sI] = 0;
    const heap = new MinHeap();
    heap.push({ k: 0, i: sI });
    frontier[sI] = 1;
    while (heap.size()) {
      const { k: d, i: cur } = heap.pop();
      if (visited[cur]) continue;
      frontier[cur] = 0;
      visited[cur] = 1;
      current = cur;
      if (cur === eI) { current = -1; yield { done: true, cameFrom, eI, sI }; return; }
      const cx = cur % COLS, cy = Math.floor(cur / COLS);
      for (const [nx, ny] of neighbors(cx, cy)) {
        const ni = idx(nx, ny);
        if (visited[ni]) continue;
        const nd = d + costOf(nx, ny);
        if (nd < dist[ni]) {
          dist[ni] = nd;
          cameFrom[ni] = cur;
          frontier[ni] = 1;
          heap.push({ k: nd, i: ni });
        }
      }
      yield { done: false };
    }
    yield { done: true, cameFrom, eI, sI, unreachable: true };
  }

  function* astar() {
    const sI = idx(start[0], start[1]);
    const eI = idx(end[0], end[1]);
    const ex = end[0], ey = end[1];
    const g = new Float32Array(COLS * ROWS).fill(Infinity);
    const cameFrom = new Int32Array(COLS * ROWS).fill(-1);
    g[sI] = 0;
    const heap = new MinHeap();
    const h0 = Math.abs(start[0] - ex) + Math.abs(start[1] - ey);
    heap.push({ k: h0, i: sI });
    frontier[sI] = 1;
    while (heap.size()) {
      const { i: cur } = heap.pop();
      if (visited[cur]) continue;
      frontier[cur] = 0;
      visited[cur] = 1;
      current = cur;
      if (cur === eI) { current = -1; yield { done: true, cameFrom, eI, sI }; return; }
      const cx = cur % COLS, cy = Math.floor(cur / COLS);
      for (const [nx, ny] of neighbors(cx, cy)) {
        const ni = idx(nx, ny);
        if (visited[ni]) continue;
        const tentative = g[cur] + costOf(nx, ny);
        if (tentative < g[ni]) {
          g[ni] = tentative;
          cameFrom[ni] = cur;
          const h = Math.abs(nx - ex) + Math.abs(ny - ey);
          frontier[ni] = 1;
          heap.push({ k: tentative + h, i: ni });
        }
      }
      yield { done: false };
    }
    yield { done: true, cameFrom, eI, sI, unreachable: true };
  }

  // Maze generation — recursive backtracker on cell grid ---------------
  function generateMaze() {
    if (running) return;
    // fill with walls except start/end
    cells.fill(1);
    // carve from odd cells (so walls between cells stay)
    const sx = 1, sy = 1;
    const stack = [[sx, sy]];
    cells[idx(sx, sy)] = 0;
    const dirs = [[0, -2], [2, 0], [0, 2], [-2, 0]];
    while (stack.length) {
      const [cx, cy] = stack[stack.length - 1];
      const opts = [];
      for (const [dx, dy] of dirs) {
        const nx = cx + dx, ny = cy + dy;
        if (nx > 0 && ny > 0 && nx < COLS - 1 && ny < ROWS - 1 && cells[idx(nx, ny)] === 1) {
          opts.push([nx, ny, dx, dy]);
        }
      }
      if (!opts.length) { stack.pop(); continue; }
      const [nx, ny, dx, dy] = opts[Math.floor(Math.random() * opts.length)];
      cells[idx(cx + dx / 2, cy + dy / 2)] = 0;
      cells[idx(nx, ny)] = 0;
      stack.push([nx, ny]);
    }
    // sprinkle a few weighted cells in open spaces
    for (let k = 0; k < 30; k++) {
      const rx = Math.floor(Math.random() * COLS);
      const ry = Math.floor(Math.random() * ROWS);
      if (cells[idx(rx, ry)] === 0) cells[idx(rx, ry)] = 2;
    }
    start = [1, 1];
    end = [COLS - 2, ROWS - 2];
    cells[idx(start[0], start[1])] = 3;
    cells[idx(end[0], end[1])] = 4;
    clearOverlay();
    updateStats(0, 0, 0, 0);
    draw();
  }

  function clearWalls() {
    if (running) return;
    for (let i = 0; i < cells.length; i++) {
      if (cells[i] === 1 || cells[i] === 2) cells[i] = 0;
    }
    clearOverlay();
    updateStats(0, 0, 0, 0);
    draw();
  }
  function resetPath() {
    if (running) return;
    clearOverlay();
    updateStats(0, 0, 0, 0);
    draw();
  }

  function reconstruct(cameFrom, eI, sI) {
    if (cameFrom[eI] === -1 && eI !== sI) return [];
    const path = [];
    let cur = eI;
    let guard = 0;
    while (cur !== -1 && guard < COLS * ROWS) {
      path.push(cur);
      if (cur === sI) break;
      cur = cameFrom[cur];
      guard++;
    }
    return path.reverse();
  }

  function updateStats(v, f, p, c) {
    document.getElementById('visitedC').textContent = v;
    document.getElementById('frontierC').textContent = f;
    document.getElementById('pathC').textContent = p;
    document.getElementById('costC').textContent = c.toFixed ? c.toFixed(0) : c;
  }
  function countOverlay() {
    let v = 0, f = 0;
    for (let i = 0; i < cells.length; i++) {
      if (visited[i]) v++;
      if (frontier[i]) f++;
    }
    return { v, f };
  }

  function pickGen() {
    const a = document.getElementById('algo').value;
    if (a === 'bfs') return bfs();
    if (a === 'dfs') return dfs();
    if (a === 'dijkstra') return dijkstra();
    return astar();
  }

  function finalisePath(res) {
    const path = reconstruct(res.cameFrom, res.eI, res.sI);
    let cost = 0;
    for (const i of path) {
      pathSet[i] = 1;
      const x = i % COLS, y = Math.floor(i / COLS);
      if (i !== res.sI) cost += costOf(x, y);
    }
    const { v, f } = countOverlay();
    updateStats(v, f, path.length, cost);
    draw();
  }

  function stepOnce() {
    if (!gen) {
      clearOverlay();
      gen = pickGen();
    }
    const r = gen.next();
    if (r.done || r.value?.done) {
      const res = r.value;
      if (res && res.done && !res.unreachable) finalisePath(res);
      else {
        const { v, f } = countOverlay();
        updateStats(v, f, 0, 0);
        draw();
      }
      gen = null;
      return true;
    }
    const { v, f } = countOverlay();
    updateStats(v, f, 0, 0);
    draw();
    return false;
  }

  async function run() {
    if (running) { running = false; document.getElementById('runBtn').textContent = 'Run'; return; }
    clearOverlay();
    gen = pickGen();
    running = true;
    document.getElementById('runBtn').textContent = 'Stop';
    const speed = () => parseInt(document.getElementById('speed').value, 10);
    while (running) {
      const done = stepOnce();
      if (done) break;
      await new Promise(r => setTimeout(r, speed()));
    }
    running = false;
    document.getElementById('runBtn').textContent = 'Run';
  }

  // Wire up -----------------------------------------------------------
  document.getElementById('runBtn').addEventListener('click', run);
  document.getElementById('stepBtn').addEventListener('click', () => { if (!running) stepOnce(); });
  document.getElementById('resetBtn').addEventListener('click', () => { gen = null; resetPath(); });
  document.getElementById('clearBtn').addEventListener('click', () => { gen = null; clearWalls(); });
  document.getElementById('mazeBtn').addEventListener('click', () => { gen = null; generateMaze(); });
  document.getElementById('speed').addEventListener('input', e => {
    document.getElementById('speedVal').textContent = e.target.value + 'ms';
  });
  const notes = {
    bfs: "Breadth-first search uses a FIFO queue. Guarantees shortest path by edge count, but ignores cell weights — every move costs 1. Visits cells in concentric rings from the start.",
    dfs: "Depth-first search uses a LIFO stack. Explores as far down one branch as possible before backtracking. Does NOT find shortest paths; the path it returns is whatever order it stumbled on the goal.",
    dijkstra: "Dijkstra's algorithm expands the unvisited node with smallest accumulated cost <code>g(n)</code>. Optimal on weighted graphs. Uses a binary min-heap. With uniform weights it degenerates to BFS.",
    astar: "A* combines Dijkstra's actual-cost-so-far <code>g(n)</code> with a Manhattan-distance heuristic <code>h(n)</code>, expanding the node with smallest <code>f = g + h</code>. Admissible and optimal on a 4-connected grid."
  };
  document.getElementById('algo').addEventListener('change', e => {
    document.getElementById('algoNotes').innerHTML = notes[e.target.value];
  });

  // Initial render
  generateMaze();
})();
</script>

