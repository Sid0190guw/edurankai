---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Pathfinding lab (advanced level). Least-cost search on a WEIGHTED grid with a
// real binary-heap priority queue. Compares Dijkstra, A*, Greedy best-first and
// Weighted-A* (epsilon-inflated heuristic) under a chosen admissible heuristic
// (Manhattan / Euclidean / Chebyshev / Octile) and 4- or 8-connectivity. It
// reports nodes expanded, the path cost, Dijkstra's optimal cost and the
// suboptimality ratio — so the classic tradeoff is explicit: Greedy and large
// epsilon expand far fewer nodes but can return non-optimal paths, while A* with
// an admissible heuristic stays optimal. No libraries.
---
<BaseLayout title="Weighted Pathfinding · Virtual Labs · AquinTutor" description="Advanced graph search: least-cost pathfinding on a weighted grid with a binary-heap frontier, comparing Dijkstra / A* / Greedy / Weighted-A* under admissible heuristics with 4- or 8-connectivity, and reporting nodes expanded, path cost and suboptimality vs the optimum. Built from scratch.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1340px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:14px; margin-bottom:16px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-grid{ display:grid; grid-template-columns:300px minmax(0,1fr); gap:18px; } @media(max-width:960px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:15px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 11px; }
  .lb-row{ display:grid; gap:8px; } .lb-row label{ font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.08em; text-transform:uppercase; color:#8ea0be; font-weight:700; display:flex; justify-content:space-between; } .lb-row label span{ color:#5ee7ff; } .lb-row input[type=range]{ width:100%; accent-color:#5ee7ff; } select{ width:100%; background:#080a12; border:1px solid #1e2740; color:#fff; padding:8px 10px; border-radius:6px; font-size:12px; font-family:inherit; }
  .lb-btn{ background:linear-gradient(180deg,#7af0ff,#33cfe6); color:#04161b; padding:9px 14px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:10.5px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; }
  .lb-btn-ghost{ background:transparent; color:#cfd6da; border:1px solid #26314f; } .mode.on{ outline:2px solid #7af0ff; }
  .lb-stage{ position:relative; width:100%; border-radius:16px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 60px rgba(0,0,0,0.5), 0 16px 40px rgba(0,0,0,0.4); } .lb-stage canvas{ display:block; width:100%; height:auto; cursor:crosshair; }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11px; padding:4px 0; border-bottom:1px solid #141a2c; } .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#5ee7ff; font-weight:700; text-align:right; }
</style>
<main class="lb">
  <div class="lb-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="lb-eye" style="margin-top:10px;">CS · Weighted graph search</p>
      <h1 class="lb-title">Weighted <em>pathfinding</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;flex-wrap:wrap;"><button id="runBtn" class="lb-btn">Run</button><button id="clearBtn" class="lb-btn lb-btn-ghost">Clear</button><button id="mazeBtn" class="lb-btn lb-btn-ghost">Terrain</button></div>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Search</h3><div class="lb-row">
        <label>Algorithm</label><select id="algo"><option value="astar" selected>A*</option><option value="dijkstra">Dijkstra</option><option value="greedy">Greedy best-first</option><option value="wastar">Weighted A* (ε)</option><option value="bfs">BFS (unweighted)</option></select>
        <label>Heuristic</label><select id="heur"><option value="manhattan" selected>Manhattan</option><option value="euclid">Euclidean</option><option value="cheby">Chebyshev</option><option value="octile">Octile</option></select>
        <label>Connectivity</label><select id="conn"><option value="4" selected>4-connected</option><option value="8">8-connected (diagonal)</option></select>
        <label id="epsWrap" style="display:none;">Weight ε <span id="epsV">2.0</span></label><input id="eps" type="range" min="1" max="6" step="0.1" value="2" style="display:none;"/>
        <label>Speed <span id="spV">10</span></label><input id="sp" type="range" min="1" max="60" step="1" value="10"/>
      </div></div>
      <div class="lb-panel"><h3>Paint (drag on grid)</h3>
        <div style="display:flex;gap:6px;flex-wrap:wrap;"><button class="lb-btn mode on" data-m="wall">Wall</button><button class="lb-btn lb-btn-ghost mode" data-m="weight">Terrain ×5</button><button class="lb-btn lb-btn-ghost mode" data-m="erase">Erase</button><button class="lb-btn lb-btn-ghost mode" data-m="start">Start</button><button class="lb-btn lb-btn-ghost mode" data-m="end">Goal</button></div>
      </div>
      <div class="lb-panel"><h3>Result</h3>
        <div class="lb-metric"><span class="lb-metric-l">Nodes expanded</span><span class="lb-metric-v" id="mExp">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Path cost</span><span class="lb-metric-v" id="mCost">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Optimal (Dijkstra)</span><span class="lb-metric-v" id="mOpt">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Suboptimality</span><span class="lb-metric-v" id="mRatio" style="color:#fbbf24;">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Heuristic</span><span class="lb-metric-v" id="mAdm" style="color:#a78bfa;">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">Status</span><span class="lb-metric-v" id="mS">draw a map</span></div>
      </div>
    </aside>
    <section><div class="lb-stage"><canvas id="scene" width="960" height="560"></canvas></div></section>
  </div>
</main>
<script is:inline>
(function(){
  var COLS=48, ROWS=30, wall=[], wt=[], start={r:15,c:6}, end={r:15,c:41}, mode='wall';
  var order=[], path=[], anim=0, phase='idle', visited={}, SQRT2=Math.SQRT2;
  function reset(terrain){ wall=[]; wt=[]; for(var r=0;r<ROWS;r++){ var wr=[],tr=[]; for(var c=0;c<COLS;c++){ var s=(r===start.r&&c===start.c)||(r===end.r&&c===end.c);
        wr.push(terrain&&!s&&Math.random()<0.14?1:0); tr.push(terrain&&!s&&Math.random()<0.22?5:1); } wall.push(wr); wt.push(tr); }
    order=[]; path=[]; anim=0; phase='idle'; visited={}; setTxt('mS','draw a map'); }
  function setTxt(id,t){ var e=document.getElementById(id); if(e) e.textContent=t; }
  function key(r,c){ return r*COLS+c; }
  reset(false);
  document.querySelectorAll('.mode').forEach(function(b){ b.addEventListener('click',function(){ mode=b.getAttribute('data-m'); document.querySelectorAll('.mode').forEach(function(x){ x.classList.remove('on'); x.classList.add('lb-btn-ghost'); }); b.classList.add('on'); b.classList.remove('lb-btn-ghost'); }); });
  document.getElementById('clearBtn').addEventListener('click',function(){ reset(false); });
  document.getElementById('mazeBtn').addEventListener('click',function(){ reset(true); });
  document.getElementById('algo').addEventListener('change',function(){ var w=this.value==='wastar'; document.getElementById('epsWrap').style.display=w?'flex':'none'; document.getElementById('eps').style.display=w?'block':'none'; });
  document.querySelectorAll('input').forEach(function(e){ e.addEventListener('input',function(){ setTxt('spV',document.getElementById('sp').value); setTxt('epsV',(+document.getElementById('eps').value).toFixed(1)); }); });

  // binary heap PQ
  function Heap(){ this.a=[]; }
  Heap.prototype.push=function(it,p){ this.a.push({it:it,p:p}); var i=this.a.length-1; while(i>0){ var pa=(i-1)>>1; if(this.a[pa].p<=this.a[i].p)break; var t=this.a[pa];this.a[pa]=this.a[i];this.a[i]=t; i=pa; } };
  Heap.prototype.pop=function(){ if(!this.a.length)return null; var top=this.a[0], last=this.a.pop(); if(this.a.length){ this.a[0]=last; var i=0,n=this.a.length; for(;;){ var l=2*i+1,r=2*i+2,m=i; if(l<n&&this.a[l].p<this.a[m].p)m=l; if(r<n&&this.a[r].p<this.a[m].p)m=r; if(m===i)break; var t=this.a[m];this.a[m]=this.a[i];this.a[i]=t; i=m; } } return top.it; };
  Heap.prototype.size=function(){ return this.a.length; };

  function heurFn(name){ return function(r,c){ var dr=Math.abs(r-end.r), dc=Math.abs(c-end.c);
    if(name==='euclid') return Math.hypot(dr,dc); if(name==='cheby') return Math.max(dr,dc);
    if(name==='octile') return (dr+dc)+(SQRT2-2)*Math.min(dr,dc); return dr+dc; }; }
  function neighbours(r,c,diag){ var out=[[1,0],[-1,0],[0,1],[0,-1]]; if(diag) out=out.concat([[1,1],[1,-1],[-1,1],[-1,-1]]); var res=[]; out.forEach(function(d){ var nr=r+d[0],nc=c+d[1]; if(nr<0||nc<0||nr>=ROWS||nc>=COLS)return; if(wall[nr][nc])return; var diagMove=d[0]!==0&&d[1]!==0; res.push([nr,nc,diagMove]); }); return res; }

  function search(algo,heur,eps,diag){ var h=heurFn(heur); var g={}, came={}, closed={}, ord=[], expanded=0; var open=new Heap();
    var sk=key(start.r,start.c); g[sk]=0; open.push([start.r,start.c], algo==='greedy'?h(start.r,start.c):0);
    var seq=0;
    while(open.size()){ var cur=open.pop(); var ck=key(cur[0],cur[1]); if(closed[ck])continue; closed[ck]=1; ord.push([cur[0],cur[1]]); expanded++;
      if(cur[0]===end.r&&cur[1]===end.c) break;
      neighbours(cur[0],cur[1],diag).forEach(function(nb){ var nr=nb[0],nc=nb[1],dm=nb[2]; var nk=key(nr,nc);
        var step = algo==='bfs' ? 1 : wt[nr][nc]*(dm?SQRT2:1); var ng=g[ck]+step;
        if(g[nk]===undefined || ng<g[nk]){ g[nk]=ng; came[nk]=ck;
          var pri; if(algo==='dijkstra'||algo==='bfs') pri=ng; else if(algo==='greedy') pri=h(nr,nc); else if(algo==='wastar') pri=ng+eps*h(nr,nc); else pri=ng+h(nr,nc);
          open.push([nr,nc],pri); } }); }
    var pth=[], cost=0; var ek=key(end.r,end.c); if(closed[ek]){ var k2=ek; while(k2!==undefined){ pth.unshift([Math.floor(k2/COLS),k2%COLS]); k2=came[k2]; } cost=g[ek]; }
    return { ord:ord, path:pth, cost:cost, expanded:expanded }; }

  function run(){ var algo=document.getElementById('algo').value, heur=document.getElementById('heur').value, diag=document.getElementById('conn').value==='8', eps=+document.getElementById('eps').value;
    var res=search(algo,heur,eps,diag); var opt=search('dijkstra',heur,1,diag);
    order=res.ord; path=res.path; anim=0; phase='visiting'; visited={};
    setTxt('mExp',res.expanded); setTxt('mCost', res.path.length?res.cost.toFixed(2):'—'); setTxt('mOpt', opt.path.length?opt.cost.toFixed(2):'—');
    setTxt('mRatio', (res.path.length&&opt.cost>0)?(res.cost/opt.cost).toFixed(3)+'×':'—');
    var adm = (heur==='manhattan'&&!diag)||heur==='euclid'||(heur==='octile'&&diag)||(heur==='cheby'&&diag);
    setTxt('mAdm', algo==='greedy'?'ignored (greedy)':(algo==='wastar'?('inflated ε='+eps.toFixed(1)+' → '+eps+'-optimal'):(adm?'admissible → optimal':'may be inadmissible')));
    setTxt('mS', res.path.length?'searching…':'no path'); }
  document.getElementById('runBtn').addEventListener('click',run);

  var cv=document.getElementById('scene'), painting=false;
  function cellAt(e){ var r=cv.getBoundingClientRect(); var x=(e.clientX-r.left)/r.width*COLS, y=(e.clientY-r.top)/r.height*ROWS; return {r:Math.max(0,Math.min(ROWS-1,Math.floor(y))),c:Math.max(0,Math.min(COLS-1,Math.floor(x)))}; }
  function apply(cell){ var s=(cell.r===start.r&&cell.c===start.c), e=(cell.r===end.r&&cell.c===end.c);
    if(mode==='wall'){ if(!s&&!e) wall[cell.r][cell.c]=1; } else if(mode==='weight'){ if(!s&&!e){ wall[cell.r][cell.c]=0; wt[cell.r][cell.c]=5; } }
    else if(mode==='erase'){ wall[cell.r][cell.c]=0; wt[cell.r][cell.c]=1; } else if(mode==='start'){ start={r:cell.r,c:cell.c}; wall[cell.r][cell.c]=0; } else { end={r:cell.r,c:cell.c}; wall[cell.r][cell.c]=0; } }
  cv.addEventListener('mousedown',function(e){ painting=true; apply(cellAt(e)); });
  cv.addEventListener('mousemove',function(e){ if(painting) apply(cellAt(e)); });
  window.addEventListener('mouseup',function(){ painting=false; });
  cv.addEventListener('touchstart',function(e){ painting=true; apply(cellAt(e.touches[0])); e.preventDefault(); },{passive:false});
  cv.addEventListener('touchmove',function(e){ if(painting) apply(cellAt(e.touches[0])); e.preventDefault(); },{passive:false});
  window.addEventListener('touchend',function(){ painting=false; });

  function hidpi(c){ var r=c.getBoundingClientRect(), d=window.devicePixelRatio||1; var w=r.width||c.width, h=(c.height/c.width)*w; c.width=Math.round(w*d); c.height=Math.round(h*d); var ctx=c.getContext('2d'); ctx.setTransform(d,0,0,d,0,0); return {ctx:ctx,w:w,h:h}; }
  function draw(){ var s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h; var cw=W/COLS, ch=H/ROWS; ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H);
    var pathSet={}; if(phase==='pathing'||phase==='done') for(var i=0;i<Math.min(anim,path.length);i++) pathSet[key(path[i][0],path[i][1])]=1;
    for(var r=0;r<ROWS;r++)for(var c=0;c<COLS;c++){ var x=c*cw,y=r*ch,kk=key(r,c);
      if(wall[r][c]){ ctx.fillStyle='#1a2236'; ctx.fillRect(x+1,y+1,cw-2,ch-2); }
      else if(pathSet[kk]){ ctx.save(); ctx.shadowColor='#fbbf24'; ctx.shadowBlur=9; ctx.fillStyle='#fbbf24'; ctx.fillRect(x+1.5,y+1.5,cw-3,ch-3); ctx.restore(); }
      else if(visited[kk]!==undefined){ var a=visited[kk]; ctx.fillStyle='rgba(94,231,255,'+(0.10+0.35*a)+')'; ctx.fillRect(x+1,y+1,cw-2,ch-2); }
      else if(wt[r][c]>1){ ctx.fillStyle='rgba(120,80,40,0.5)'; ctx.fillRect(x+1,y+1,cw-2,ch-2); }
      else { ctx.fillStyle='#0c1120'; ctx.fillRect(x+1,y+1,cw-2,ch-2); } }
    function cell(pos,col){ ctx.save(); ctx.shadowColor=col; ctx.shadowBlur=14; ctx.fillStyle=col; ctx.fillRect(pos.c*cw+2,pos.r*ch+2,cw-4,ch-4); ctx.restore(); }
    cell(start,'#34d399'); cell(end,'#f87171'); }
  function loop(){ var sp=parseFloat(document.getElementById('sp').value);
    if(phase==='visiting'){ for(var k=0;k<sp&&anim<order.length;k++){ visited[key(order[anim][0],order[anim][1])]=Math.min(1,anim/Math.max(1,order.length)); anim++; } if(anim>=order.length){ phase=path.length?'pathing':'done'; anim=0; if(!path.length) setTxt('mS','no path'); } }
    else if(phase==='pathing'){ anim=Math.min(path.length,anim+Math.max(1,sp/6)); if(anim>=path.length){ phase='done'; setTxt('mS','path found'); } }
    draw(); requestAnimationFrame(loop); }
  requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
