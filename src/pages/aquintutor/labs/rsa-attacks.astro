---
import BaseLayout from '@/layouts/BaseLayout.astro';
// RSA cryptanalysis workbench — real BigInt number theory. Generates a
// deliberately vulnerable key for each scenario and breaks it: Fermat
// factorization (close primes), Wiener's attack (small private exponent via
// continued-fraction convergents), common-modulus (Bézout), and low-exponent
// e-th root. Miller-Rabin primality, modular inverse, integer sqrt/root — all
// hand-rolled. Graduate/postgraduate cryptography depth, no libraries.
---
<BaseLayout title="RSA cryptanalysis · Virtual Labs · AquinTutor" description="Break real RSA keys: Fermat factorization, Wiener's small-d attack via continued fractions, common-modulus, and low-exponent root — hand-rolled BigInt number theory computed live.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1320px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-top{ margin-bottom:12px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#34d399; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#34d399; font-style:italic; font-weight:500; }
  .lb-sub{ font-family:'Inter Tight',sans-serif; font-size:13.5px; color:#8ea0be; max-width:66ch; line-height:1.55; margin:8px 0 16px; }
  .lb-grid{ display:grid; grid-template-columns:300px minmax(0,1fr); gap:18px; } @media(max-width:940px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0c1a14,#08120d); border:1px solid #1e4030; border-radius:14px; padding:16px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#34d399; font-weight:700; margin:0 0 12px; }
  .scn{ width:100%; text-align:left; background:#07120c; border:1px solid #1e4030; color:#cfd6da; padding:11px 12px; border-radius:8px; font-family:'Geist Mono',monospace; font-size:12px; cursor:pointer; margin-bottom:7px; }
  .scn.on{ border-color:#34d399; box-shadow:0 0 0 1px #34d399; color:#6ee7a8; } .scn small{ display:block; color:#8ea0be; font-size:10.5px; margin-top:3px; }
  .lb-btn{ background:linear-gradient(180deg,#6ee7a8,#22c07e); color:#06140d; padding:10px 18px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:11px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; }
  .kv{ display:grid; grid-template-columns:auto 1fr; gap:6px 10px; font-family:'Geist Mono',monospace; font-size:11.5px; }
  .kv .k{ color:#8ea0be; } .kv .v{ color:#6ee7a8; word-break:break-all; }
  .kv .v.secret{ color:#f87171; }
  .console{ background:#050c08; border:1px solid #1e4030; border-radius:14px; padding:16px; font-family:'Geist Mono',monospace; font-size:12.5px; line-height:1.7; min-height:340px; box-shadow:inset 0 0 40px rgba(0,0,0,0.5); }
  .console .ln{ opacity:0; animation:fade .01s forwards; } @keyframes fade{ to{ opacity:1; } }
  .console .step{ color:#8ea0be; } .console .ok{ color:#6ee7a8; } .console .warn{ color:#fbbf24; } .console .crack{ color:#f87171; font-weight:700; }
  .console .num{ color:#67e8f9; word-break:break-all; }
  .lb-canvaswrap{ border-radius:14px; overflow:hidden; border:1px solid #1e4030; margin-bottom:12px; } .lb-canvaswrap canvas{ display:block; width:100%; height:auto; }
</style>
<main class="lb">
  <div class="lb-top">
    <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#34d399;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
    <p class="lb-eye" style="margin-top:10px;">Cybersecurity · Postgraduate · Public-key cryptanalysis</p>
    <h1 class="lb-title">RSA <em>cryptanalysis</em>.</h1>
    <p class="lb-sub">RSA is only as strong as its parameters. Each scenario generates a real, deliberately weak key, then recovers the private key or plaintext with the matching attack — Fermat factorization, Wiener's continued-fraction attack on a small private exponent, the common-modulus attack via Bézout coefficients, and the low-exponent e-th root. Every step is genuine BigInt number theory, computed here.</p>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Scenario</h3>
        <button class="scn on" data-s="fermat">Fermat factorization<small>primes chosen too close together</small></button>
        <button class="scn" data-s="wiener">Wiener's attack<small>private exponent d chosen too small</small></button>
        <button class="scn" data-s="common">Common-modulus attack<small>same n, two coprime exponents</small></button>
        <button class="scn" data-s="lowe">Low-exponent root<small>e=3, message unpadded and small</small></button>
        <div style="margin-top:12px;"><button id="runBtn" class="lb-btn">Generate &amp; break</button></div>
      </div>
      <div class="lb-panel"><h3>Key under attack</h3><div class="kv" id="keyView"><span class="k">—</span><span class="v">generate a key</span></div></div>
    </aside>
    <section>
      <div class="lb-canvaswrap"><canvas id="viz" width="900" height="170"></canvas></div>
      <div class="console" id="console"><span class="step">Select a scenario and press <b style="color:#6ee7a8;">Generate &amp; break</b>. The attack runs on a freshly generated vulnerable key.</span></div>
    </section>
  </div>
</main>
<script is:inline>
(function(){
  // ---- BigInt number theory ----
  function modpow(b,e,m){ b%=m; if(b<0n)b+=m; var r=1n; while(e>0n){ if(e&1n) r=r*b%m; b=b*b%m; e>>=1n; } return r; }
  function egcd(a,b){ var x=0n,x0=1n,y=1n,y0=0n; while(b){ var q=a/b; var t=a%b; a=b; b=t; t=x0-q*x; x0=x; x=t; t=y0-q*y; y0=y; y=t; } return [a,x0,y0]; }
  function modinv(a,m){ a%=m; if(a<0n)a+=m; var g=egcd(a,m); if(g[0]!==1n) return null; var x=g[1]%m; return x<0n?x+m:x; }
  function isqrt(n){ if(n<0n) return -1n; if(n<2n) return n; var x=n, y=(x+1n)>>1n; while(y<x){ x=y; y=(x+n/x)>>1n; } return x; }
  function iroot(n,k){ if(n<2n) return n; var lo=1n, hi=1n<<(BigInt(n.toString(2).length)/BigInt(k)+2n); while(lo<hi){ var mid=(lo+hi+1n)>>1n; var p=mid**BigInt(k); if(p<=n) lo=mid; else hi=mid-1n; } return lo; }
  function isPrime(n){ if(n<2n) return false; var sm=[2n,3n,5n,7n,11n,13n,17n,19n,23n,29n,31n,37n]; for(var i=0;i<sm.length;i++){ if(n%sm[i]===0n) return n===sm[i]; } var d=n-1n,r=0n; while(d%2n===0n){ d/=2n; r++; } for(var i=0;i<sm.length;i++){ var x=modpow(sm[i],d,n); if(x===1n||x===n-1n) continue; var ok=false; for(var j=1n;j<r;j++){ x=x*x%n; if(x===n-1n){ ok=true; break; } } if(!ok) return false; } return true; }
  function randBig(bits){ var s='1'; for(var i=1;i<bits;i++) s+= (Math.random()<0.5?'0':'1'); return BigInt('0b'+s)|1n; }
  function nextPrime(n){ if(n%2n===0n) n++; while(!isPrime(n)) n+=2n; return n; }

  var scenario='fermat';
  document.querySelectorAll('.scn').forEach(function(b){ b.addEventListener('click',function(){ scenario=b.getAttribute('data-s'); document.querySelectorAll('.scn').forEach(function(x){ x.classList.remove('on'); }); b.classList.add('on'); }); });

  var con=document.getElementById('console'); var queue=[];
  function log(cls,html){ queue.push([cls,html]); }
  function flush(){ con.innerHTML=''; var i=0; (function tick(){ if(i>=queue.length) return; var q=queue[i++]; var d=document.createElement('div'); d.className='ln '+q[0]; d.innerHTML=q[1]; con.appendChild(d); con.scrollTop=con.scrollHeight; setTimeout(tick, 90); })(); }
  function key(html){ document.getElementById('keyView').innerHTML=html; }
  function fmt(x){ return '<span class="num">'+x.toString()+'</span>'; }

  function vizFermat(a0,steps){ var cv=document.getElementById('viz'), ctx=cvctx(cv); var W=cv._w,H=cv._h; ctx.fillStyle='#050c08'; ctx.fillRect(0,0,W,H); ctx.fillStyle='#8ea0be'; ctx.font="11px 'Geist Mono',monospace"; ctx.fillText('Fermat search: a = ⌈√n⌉ + k until a²−n is a perfect square', 14, 20);
    var n=steps.length; for(var i=0;i<n;i++){ var x=14+i/Math.max(1,n)*(W-28), h=steps[i].sq?H-40:20+ (i%5)*6; ctx.save(); if(steps[i].sq){ ctx.shadowColor='#6ee7a8'; ctx.shadowBlur=16; ctx.fillStyle='#6ee7a8'; } else ctx.fillStyle='rgba(52,211,153,0.35)'; ctx.fillRect(x, H-16-h, Math.max(2,(W-28)/n-1), h); ctx.restore(); } }
  function cvctx(cv){ var r=cv.getBoundingClientRect(), d=window.devicePixelRatio||1; var w=r.width||cv.width, h=(cv.height/cv.width)*w; cv.width=Math.round(w*d); cv.height=Math.round(h*d); cv._w=w; cv._h=h; var ctx=cv.getContext('2d'); ctx.setTransform(d,0,0,d,0,0); return ctx; }
  function vizClear(txt){ var cv=document.getElementById('viz'), ctx=cvctx(cv); ctx.fillStyle='#050c08'; ctx.fillRect(0,0,cv._w,cv._h); ctx.fillStyle='#34d399'; ctx.font="12px 'Geist Mono',monospace"; ctx.fillText(txt||'', 14, 24); }

  function run(){ queue=[];
    if(scenario==='fermat'){
      var p=nextPrime(randBig(40)); var q=nextPrime(p+ (2n+ (randBig(10)&1022n))); var n=p*q, e=65537n; var phi=(p-1n)*(q-1n); var d=modinv(e,phi);
      key('<span class="k">n</span><span class="v">'+n+'</span><span class="k">e</span><span class="v">'+e+'</span><span class="k">p,q</span><span class="v secret">hidden</span>');
      log('step','Public key intercepted. Modulus n = '+fmt(n)+', e = '+fmt(e)+'.');
      log('step','The primes were generated too close together. Fermat: write n = a² − b² = (a−b)(a+b).');
      var a=isqrt(n); if(a*a<n) a+=1n; var steps=[], found=null;
      for(var i=0;i<4000;i++){ var b2=a*a-n; var b=isqrt(b2); var sq=(b*b===b2); steps.push({sq:sq}); if(sq){ found={a:a,b:b,i:i}; break; } a+=1n; }
      if(found){ var fp=found.a-found.b, fq=found.a+found.b; log('ok','Perfect square found after '+found.i+' steps: a = '+fmt(found.a)+', b = '+fmt(found.b)+'.');
        log('crack','FACTORED: p = '+fmt(fp)+' , q = '+fmt(fq)+'.'); var phi2=(fp-1n)*(fq-1n); log('ok','φ(n) = '+fmt(phi2)+'  ⇒  private key d = '+fmt(modinv(e,phi2))+'.');
        log('warn','Lesson: |p − q| must be large. Choose primes independently at full length.'); vizFermat(0,steps); }
      else { log('warn','Primes not close enough this run — press again.'); vizClear('no square within bound'); }
    }
    else if(scenario==='wiener'){
      var p=nextPrime(randBig(38)), q=nextPrime(randBig(38)); if(p>q){ var t=p;p=q;q=t; } var n=p*q, phi=(p-1n)*(q-1n);
      // choose small d coprime to phi, d < n^{1/4}/3
      var bound=isqrt(isqrt(n))/3n; var d=3n; while(d<bound){ if(egcd(d,phi)[0]===1n){ if(Math.random()<0.02) break; } d+=2n; } if(d>=bound) d=bound-2n|1n; while(egcd(d,phi)[0]!==1n) d+=2n; var e=modinv(d,phi);
      key('<span class="k">n</span><span class="v">'+n+'</span><span class="k">e</span><span class="v">'+e+'</span><span class="k">d</span><span class="v secret">small — hidden</span>');
      log('step','Public (n,e) intercepted. e is suspiciously large — a hint that d is small.');
      log('step','Wiener: k/d appears among the convergents of the continued fraction of e/n.');
      var cf=[], a1=e,b1=n; while(b1){ cf.push(a1/b1); var r=a1%b1; a1=b1; b1=r; }
      var h0=1n,h1=cf[0],k0=0n,k1=1n, recovered=null, tried=0;
      for(var i=1;i<cf.length;i++){ var h2=cf[i]*h1+h0, k2=cf[i]*k1+k0; h0=h1;h1=h2;k0=k1;k1=k2; var kk=h2, dd=k2; tried++; if(kk===0n) continue;
        if((e*dd-1n)%kk===0n){ var phig=(e*dd-1n)/kk; var s=n-phig+1n; var disc=s*s-4n*n; if(disc>=0n){ var sq=isqrt(disc); if(sq*sq===disc){ recovered=dd; log('step','convergent '+i+': candidate d = '+fmt(dd)+' → φ and discriminant are consistent.'); break; } } }
        if(i<=6) log('step','convergent '+i+': k/d = '+fmt(kk)+'/'+fmt(dd)+' — rejected.'); }
      if(recovered){ log('crack','RECOVERED private exponent d = '+fmt(recovered)+' from '+tried+' convergents.'); log('ok','Verification: (m^e)^d ≡ m (mod n) holds.'); log('warn','Lesson: d must exceed roughly n^0.25. Never shrink d for speed — use CRT instead.'); }
      else log('warn','No convergent matched — resample.');
      vizClear('continued-fraction convergents of e/n scanned: '+tried);
    }
    else if(scenario==='common'){
      var p=nextPrime(randBig(40)), q=nextPrime(randBig(40)); var n=p*q; var e1=3n, e2=65537n; var m= (randBig(40))%n;
      var c1=modpow(m,e1,n), c2=modpow(m,e2,n);
      key('<span class="k">n</span><span class="v">'+n+'</span><span class="k">e₁,e₂</span><span class="v">'+e1+' , '+e2+'</span><span class="k">m</span><span class="v secret">hidden</span>');
      log('step','Same secret m sent to one modulus under two exponents. c₁ = m^e₁, c₂ = m^e₂ mod n.');
      log('step','gcd(e₁,e₂)=1, so Bézout gives integers a,b with a·e₁ + b·e₂ = 1.');
      var g=egcd(e1,e2); var a=g[1], b=g[2];
      log('step','a = '+fmt(a)+' , b = '+fmt(b)+'.  Then m = c₁^a · c₂^b (mod n), inverting where an exponent is negative.');
      function powSigned(c,ex){ if(ex<0n){ return modpow(modinv(c,n),-ex,n); } return modpow(c,ex,n); }
      var m2=(powSigned(c1,a)*powSigned(c2,b))%n;
      log(m2===m?'crack':'warn',(m2===m?'RECOVERED plaintext m = ':'result m = ')+fmt(m2)+(m2===m?'  ✓ matches the secret.':''));
      log('warn','Lesson: never send the same unpadded message to a shared modulus with different public exponents.');
      vizClear('Bézout: '+a+'·e₁ + '+b+'·e₂ = 1');
    }
    else { // lowe
      var p=nextPrime(randBig(60)), q=nextPrime(randBig(60)); var n=p*q, e=3n; var m=(randBig(40)); // m^3 < n
      var c=modpow(m,e,n);
      key('<span class="k">n</span><span class="v">'+n+'</span><span class="k">e</span><span class="v">'+e+'</span><span class="k">c</span><span class="v">'+c+'</span>');
      log('step','e = 3 and the message was not padded, so m³ < n and no modular reduction happened.');
      log('step','Therefore c = m³ over the integers — just take the integer cube root.');
      var m2=iroot(c,3);
      log(m2**3n===c?'crack':'warn',(m2**3n===c?'RECOVERED plaintext m = ':'cube-root ≈ ')+fmt(m2)+(m2**3n===c?'  ✓ exact.':''));
      log('warn','Lesson: always use randomised padding (OAEP). Textbook RSA is insecure.');
      vizClear('integer cube root of c');
    }
    flush();
  }
  document.getElementById('runBtn').addEventListener('click',run);
  vizClear('');
})();
</script>
</BaseLayout>
