---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Digital Logic Workbench · Virtual Labs · AquinTutor" description="Hands-on breadboard: place logic-gate chips, wire them to switches and LEDs, power on, and watch it compute.">
<style>
  /* ===================== REALISTIC BENCH THEME ===================== */
  .lbx {
    --wood1:#3a2a1c; --wood2:#2a1d12; --metal:#c9cdd4; --metal-d:#8c919b;
    --board:#1f6b4f; --board-hole:#0d3025; --rail-red:#c0392b; --rail-blue:#2466b0;
    --copper:#c87f3a; --led-on:#54f078; --ink:#e9e7df; --ink-dim:#a9a59a;
    --accent:#67e8f9; --accent2:#a78bfa; --panel:#14110d; --panel-line:#3a2f22;
    background:
      radial-gradient(1200px 700px at 50% -10%, rgba(60,46,30,0.55), transparent 60%),
      repeating-linear-gradient(96deg, var(--wood1) 0px, var(--wood1) 22px, var(--wood2) 22px, var(--wood2) 46px),
      var(--wood2);
    color:var(--ink); min-height:100vh; font-family:ui-monospace,'Geist Mono','SF Mono',Menlo,monospace;
  }
  .lbx .wrap { max-width:1320px; margin:0 auto; padding:30px 20px 90px; }
  .lbx .back { display:inline-flex; align-items:center; gap:7px; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:#d8cdb8; text-decoration:none; margin-bottom:18px; opacity:.85; }
  .lbx .back:hover { color:var(--accent); opacity:1; }
  .lbx .eyebrow { font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#e0b06a; font-weight:700; margin-bottom:10px; }
  .lbx h1 { font-family:'Cormorant Garamond',Georgia,serif; font-size:38px; font-weight:600; letter-spacing:-0.01em; line-height:1.08; margin:0 0 10px; color:#f5efe2; }
  .lbx h1 em { color:#e0b06a; font-style:italic; }
  .lbx .lede { color:#d6cdba; max-width:880px; font-size:13px; line-height:1.65; margin-bottom:20px; opacity:.92; }

  /* instruction strip */
  .lbx .howto { display:flex; flex-wrap:wrap; gap:9px 18px; background:rgba(20,16,10,0.78); border:1px solid var(--panel-line); border-radius:10px; padding:11px 15px; margin-bottom:18px; font-size:11.5px; color:#cfc7b6; }
  .lbx .howto b { color:#e0b06a; font-weight:700; }
  .lbx .howto .step { display:flex; align-items:center; gap:7px; }
  .lbx .howto .num { display:inline-flex; align-items:center; justify-content:center; width:18px; height:18px; border-radius:50%; background:#e0b06a; color:#1a1206; font-size:10px; font-weight:800; }

  /* control deck */
  .lbx .deck { display:flex; flex-wrap:wrap; gap:10px; align-items:center; margin-bottom:14px; }
  .lbx .btn { background:linear-gradient(#3b3128,#2a2218); color:#efe6d4; padding:9px 14px; border:1px solid #50412e; border-radius:8px; font-family:inherit; font-size:11px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; cursor:pointer; box-shadow:0 2px 0 #1a140c, inset 0 1px 0 rgba(255,255,255,0.06); }
  .lbx .btn:hover { border-color:#7a6340; color:#fff; }
  .lbx .btn:active { transform:translateY(1px); box-shadow:0 1px 0 #1a140c; }
  .lbx .btn.power-on { background:linear-gradient(#2e7d4f,#1e5a38); border-color:#3ea866; color:#eafff0; box-shadow:0 2px 0 #103823, inset 0 1px 0 rgba(255,255,255,0.12), 0 0 18px rgba(84,240,120,0.25); }
  .lbx .btn.power-off { background:linear-gradient(#8a2f24,#5e201a); border-color:#c0392b; color:#ffeae6; }
  .lbx .btn.warn { background:linear-gradient(#5e201a,#451713); border-color:#a0392b; }
  .lbx select { background:#2a2218; border:1px solid #50412e; color:#efe6d4; padding:9px 11px; border-radius:8px; font-family:inherit; font-size:11.5px; cursor:pointer; }
  .lbx select:hover { border-color:#7a6340; }
  .lbx .deck-label { font-size:10px; letter-spacing:0.14em; text-transform:uppercase; color:#b3a98f; margin-right:-4px; }
  .lbx .pill { display:inline-flex; align-items:center; gap:6px; font-size:10.5px; padding:6px 11px; border-radius:20px; background:rgba(20,16,10,0.7); border:1px solid var(--panel-line); color:#cfc7b6; }
  .lbx .pill .dot { width:9px; height:9px; border-radius:50%; background:#5b5448; box-shadow:inset 0 0 0 1px rgba(0,0,0,0.4); }
  .lbx .pill.live .dot { background:var(--led-on); box-shadow:0 0 8px rgba(84,240,120,0.8); }

  /* bench layout */
  .lbx .bench-grid { display:grid; grid-template-columns:minmax(0,1fr) 320px; gap:16px; align-items:start; }
  @media (max-width:1040px) { .lbx .bench-grid { grid-template-columns:1fr; } }

  /* the desk panel that holds the SVG board */
  .lbx .desk {
    position:relative; border-radius:16px; overflow:hidden;
    border:1px solid #4a3a26;
    background:
      radial-gradient(900px 500px at 30% 0%, rgba(70,54,34,0.5), transparent 60%),
      repeating-linear-gradient(88deg, #2c2014 0px, #2c2014 26px, #241a10 26px, #241a10 53px);
    box-shadow:inset 0 0 60px rgba(0,0,0,0.55), 0 16px 50px rgba(0,0,0,0.4);
    padding:0;
  }
  .lbx .bench-svg { display:block; width:100%; height:auto; touch-action:none; user-select:none; }

  /* side column */
  .lbx .side { display:flex; flex-direction:column; gap:14px; }
  .lbx .card { background:rgba(18,14,9,0.82); border:1px solid var(--panel-line); border-radius:12px; padding:14px; }
  .lbx .card h3 { font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#e0b06a; font-weight:700; margin:0 0 11px; display:flex; align-items:center; gap:8px; }
  .lbx .card h3 svg { opacity:.85; }

  /* palette */
  .lbx .palette { display:grid; grid-template-columns:1fr 1fr; gap:7px; }
  .lbx .chip-btn { display:flex; flex-direction:column; align-items:center; gap:4px; background:#241c12; border:1px solid #463720; border-radius:9px; padding:9px 6px; cursor:pointer; transition:all .12s; }
  .lbx .chip-btn:hover { border-color:#e0b06a; background:#2c2114; transform:translateY(-1px); }
  .lbx .chip-btn .gname { font-size:11px; font-weight:800; letter-spacing:0.05em; color:#f1e7d3; }
  .lbx .chip-btn .gsub { font-size:8.5px; color:#a99e85; letter-spacing:0.04em; }
  .lbx .chip-btn svg { display:block; }

  /* truth table */
  .lbx .tt-wrap { overflow:auto; max-height:300px; border:1px solid #3a2f22; border-radius:8px; }
  .lbx table.tt { border-collapse:collapse; width:100%; font-size:11px; }
  .lbx table.tt th, .lbx table.tt td { padding:5px 8px; text-align:center; border-bottom:1px solid #2c2418; white-space:nowrap; }
  .lbx table.tt th { position:sticky; top:0; background:#241c12; color:#e0b06a; font-weight:700; letter-spacing:0.06em; font-size:9.5px; text-transform:uppercase; }
  .lbx table.tt td { color:#d6cdba; font-variant-numeric:tabular-nums; }
  .lbx table.tt td.in { color:#9fc7ff; }
  .lbx table.tt td.out1 { color:var(--led-on); font-weight:800; }
  .lbx table.tt td.out0 { color:#6b6557; }
  .lbx table.tt tr.cur { background:rgba(224,176,106,0.1); }
  .lbx table.tt td.sep { border-left:1px solid #3a2f22; }

  /* status / log */
  .lbx .status-line { font-size:11px; color:#cfc7b6; line-height:1.55; min-height:34px; }
  .lbx .status-line b { color:#e0b06a; }
  .lbx .hint { font-size:10.5px; color:#a99e85; line-height:1.6; margin-top:9px; }
  .lbx .hint b { color:#e0b06a; }
  .lbx .legend { display:flex; flex-wrap:wrap; gap:8px 14px; font-size:10px; color:#b3a98f; margin-top:10px; }
  .lbx .legend span { display:inline-flex; align-items:center; gap:6px; }
  .lbx .legend i { width:14px; height:5px; border-radius:3px; display:inline-block; }

  .lbx .footer-note { margin-top:26px; font-size:11px; color:#b3a98f; line-height:1.7; max-width:920px; }
  .lbx .footer-note b { color:#e0b06a; }
  .lbx a.ext { color:var(--accent); text-decoration:none; }
  .lbx a.ext:hover { text-decoration:underline; }

  /* toast */
  .lbx .bench-toast { position:fixed; left:50%; bottom:26px; transform:translateX(-50%) translateY(20px); background:#241c12; border:1px solid #e0b06a; color:#f1e7d3; padding:10px 18px; border-radius:24px; font-size:12px; opacity:0; pointer-events:none; transition:opacity .25s, transform .25s; z-index:60; box-shadow:0 10px 30px rgba(0,0,0,0.5); }
  .lbx .bench-toast.show { opacity:1; transform:translateX(-50%) translateY(0); }
</style>

<main class="lbx">
  <div class="wrap">
    <a class="back" href="/aquintutor/labs">&#8592; All virtual labs</a>
    <div class="eyebrow">Digital Electronics &middot; Virtual lab</div>
    <h1>Digital Logic <em>Workbench</em></h1>
    <p class="lede">A hands-on breadboard you can actually wire. Drop logic-gate chips onto the board, run jumper wires from switches and the +5V rail to gate inputs, fan outputs into LEDs, then press START and flip the switches to watch your circuit compute. Modelled on the IIT-Guwahati Virtual Labs &ldquo;Half&nbsp;Adder using Logic Gates&rdquo; breadboard experiment &mdash; same apparatus, smoother wiring.</p>

    <div class="howto">
      <span class="step"><span class="num">1</span> Open <b>Components</b> &amp; click a gate to drop a chip</span>
      <span class="step"><span class="num">2</span> Drag a chip by its body to reposition</span>
      <span class="step"><span class="num">3</span> Click an <b>output</b> pin, then an <b>input</b> pin, to lay a wire</span>
      <span class="step"><span class="num">4</span> Press <b>START</b> and flip the switches</span>
      <span class="step"><span class="num">5</span> Click a wire to delete it</span>
    </div>

    <div class="deck">
      <button class="btn power-off" id="powerBtn">START</button>
      <span class="deck-label">Preset</span>
      <select id="presetSel">
        <option value="">&mdash; Load a circuit &mdash;</option>
        <option value="halfadder">Half Adder (A,B &rarr; Sum,Carry)</option>
        <option value="fulladder">Full Adder (A,B,Cin &rarr; Sum,Cout)</option>
        <option value="mux21">2:1 Multiplexer</option>
        <option value="srlatch">SR Latch (cross-coupled NOR)</option>
        <option value="gatetest">Single-gate test bench</option>
      </select>
      <button class="btn" id="clearWiresBtn">Clear wires</button>
      <button class="btn warn" id="clearBoardBtn">Clear board</button>
      <span class="pill" id="powerPill"><span class="dot"></span><span id="powerTxt">Power off</span></span>
    </div>

    <div class="bench-grid">
      <!-- ===================== THE BENCH ===================== -->
      <div class="desk">
        <svg class="bench-svg" id="benchSvg" viewBox="0 0 1000 660" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" aria-label="Logic breadboard bench"></svg>
      </div>

      <!-- ===================== SIDE PANELS ===================== -->
      <div class="side">
        <div class="card">
          <h3>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#e0b06a" stroke-width="2"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 2v3M15 2v3M9 19v3M15 19v3M2 9h3M2 15h3M19 9h3M19 15h3"/></svg>
            Components
          </h3>
          <div class="palette" id="palette"></div>
          <div class="hint" style="margin-top:11px;"><b>Tip:</b> A chip lights its pins green when that net is logic&nbsp;1. NOT has a single input.</div>
        </div>

        <div class="card">
          <h3>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#e0b06a" stroke-width="2"><path d="M3 3v18h18"/><path d="M7 14l3-3 3 3 4-5"/></svg>
            Truth table
          </h3>
          <div class="status-line" id="ttStatus">Build or load a circuit to sweep its inputs.</div>
          <div class="tt-wrap" id="ttWrap" style="display:none;"><table class="tt" id="ttTable"></table></div>
          <div class="legend">
            <span><i style="background:linear-gradient(#54f078,#1f7a3a);"></i> logic 1</span>
            <span><i style="background:#3a3f33;"></i> logic 0</span>
          </div>
        </div>

        <div class="card">
          <h3>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#e0b06a" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
            Bench status
          </h3>
          <div class="status-line" id="statusLine">Idle. Power is off.</div>
          <div class="hint"><b>Wiring rule:</b> each gate input and each LED accepts one wire; an output, switch or rail can feed many.</div>
        </div>
      </div>
    </div>

    <p class="footer-note">
      <b>How the simulation works.</b> Every chip is evaluated from the nets feeding its input pins. The solver re-runs the whole board up to 50 times per change so feedback circuits (like the SR latch) settle to a stable state; an unconnected input reads as logic&nbsp;0. The truth table is produced by sweeping the input switches over all 2<sup>n</sup> combinations and recording each LED &mdash; so the bench doubles as a verifier. Reference apparatus: <a class="ext" href="https://de-iitg.vlabs.ac.in/" target="_blank" rel="noopener">Digital Electronics Virtual Lab, IIT&nbsp;Guwahati</a>.
    </p>
  </div>

  <div class="bench-toast" id="benchToast"></div>
</main>

<script is:inline>
(function () {
  'use strict';

  /* ============================================================= *
   *  Digital Logic Workbench  --  AquinTutor Virtual Labs         *
   *  Single self-contained IIFE. SVG via createElementNS.         *
   * ============================================================= */

  var SVGNS = 'http://www.w3.org/2000/svg';
  var svg = document.getElementById('benchSvg');
  if (!svg) return;

  var VBW = 1000, VBH = 660;

  /* ---------- geometry constants ---------- */
  var BOARD = { x: 240, y: 110, w: 600, h: 470 };          // breadboard rect
  var RAIL_RED_Y = BOARD.y + 26;                            // +5V rail row
  var RAIL_BLUE_Y = BOARD.y + BOARD.h - 26;                // GND rail row
  var SWITCH_X = 70;                                        // input switches column
  var LED_X = 930;                                          // output LEDs column
  var CHIP_W = 116, CHIP_H = 78;                           // gate chip body
  var PIN_R = 6.5;                                          // clickable pin radius

  /* ---------- model state ---------- */
  var state = {
    powered: false,
    switches: [],     // {id,label,x,y,value,el...}
    leds: [],         // {id,label,x,y,el...}
    gates: [],        // {id,type,x,y, inPins:[{x,y}], outPin:{x,y}, value, el...}
    wires: [],        // {id, from:{kind,ref,pin}, to:{kind,ref,pin}, path}
    nextId: 1,
    pending: null,    // a source pin awaiting a destination
  };

  function uid(prefix) { return (prefix || 'n') + (state.nextId++); }

  /* ============================================================= *
   *  GATE DEFINITIONS                                             *
   * ============================================================= */
  var GATES = {
    AND:  { name: 'AND',  ins: 2, sub: '7408', eval: function (a, b) { return (a & b) ? 1 : 0; } },
    OR:   { name: 'OR',   ins: 2, sub: '7432', eval: function (a, b) { return (a | b) ? 1 : 0; } },
    NOT:  { name: 'NOT',  ins: 1, sub: '7404', eval: function (a)    { return a ? 0 : 1; } },
    NAND: { name: 'NAND', ins: 2, sub: '7400', eval: function (a, b) { return (a & b) ? 0 : 1; } },
    NOR:  { name: 'NOR',  ins: 2, sub: '7402', eval: function (a, b) { return (a | b) ? 0 : 1; } },
    XOR:  { name: 'XOR',  ins: 2, sub: '7486', eval: function (a, b) { return (a ^ b) ? 1 : 0; } },
    XNOR: { name: 'XNOR', ins: 2, sub: '74266',eval: function (a, b) { return (a ^ b) ? 0 : 1; } },
    MUX:  { name: 'MUX',  ins: 3, sub: '2:1',  eval: function (s, a, b) { return s ? (b ? 1 : 0) : (a ? 1 : 0); } }
  };
  var PALETTE_ORDER = ['AND', 'OR', 'NOT', 'NAND', 'NOR', 'XOR', 'XNOR', 'MUX'];

  /* ============================================================= *
   *  SMALL SVG HELPERS                                            *
   * ============================================================= */
  function mk(tag, attrs, parent) {
    var e = document.createElementNS(SVGNS, tag);
    if (attrs) for (var k in attrs) { if (attrs.hasOwnProperty(k)) e.setAttribute(k, attrs[k]); }
    if (parent) parent.appendChild(e);
    return e;
  }
  function clear(node) { while (node.firstChild) node.removeChild(node.firstChild); }

  /* layer groups (drawn back to front) */
  var gDesk = mk('g', { id: 'gDesk' }, svg);
  var gBoard = mk('g', { id: 'gBoard' }, svg);
  var gWires = mk('g', { id: 'gWires' }, svg);
  var gParts = mk('g', { id: 'gParts' }, svg);   // switches + leds + power
  var gChips = mk('g', { id: 'gChips' }, svg);
  var gOverlay = mk('g', { id: 'gOverlay' }, svg);

  /* ============================================================= *
   *  STATIC DESK + BREADBOARD                                     *
   * ============================================================= */
  function drawDesk() {
    clear(gDesk); clear(gBoard);

    /* defs: gradients + filters */
    var defs = mk('defs', {}, gDesk);

    var boardGrad = mk('linearGradient', { id: 'boardGrad', x1: '0', y1: '0', x2: '0', y2: '1' }, defs);
    mk('stop', { offset: '0', 'stop-color': '#2a8a66' }, boardGrad);
    mk('stop', { offset: '1', 'stop-color': '#176149' }, boardGrad);

    var ledGlow = mk('radialGradient', { id: 'ledGlowGrad' }, defs);
    mk('stop', { offset: '0', 'stop-color': '#bfffd0' }, ledGlow);
    mk('stop', { offset: '0.4', 'stop-color': '#54f078' }, ledGlow);
    mk('stop', { offset: '1', 'stop-color': '#1f7a3a' }, ledGlow);

    var chipGrad = mk('linearGradient', { id: 'chipGrad', x1: '0', y1: '0', x2: '0', y2: '1' }, defs);
    mk('stop', { offset: '0', 'stop-color': '#3a3a40' }, chipGrad);
    mk('stop', { offset: '0.5', 'stop-color': '#222227' }, chipGrad);
    mk('stop', { offset: '1', 'stop-color': '#15151a' }, chipGrad);

    var metalGrad = mk('linearGradient', { id: 'metalGrad', x1: '0', y1: '0', x2: '0', y2: '1' }, defs);
    mk('stop', { offset: '0', 'stop-color': '#e9edf2' }, metalGrad);
    mk('stop', { offset: '0.5', 'stop-color': '#aeb4bd' }, metalGrad);
    mk('stop', { offset: '1', 'stop-color': '#7c828c' }, metalGrad);

    var glowF = mk('filter', { id: 'softGlow', x: '-60%', y: '-60%', width: '220%', height: '220%' }, defs);
    mk('feGaussianBlur', { stdDeviation: '4', result: 'b' }, glowF);
    var mrg = mk('feMerge', {}, glowF);
    mk('feMergeNode', { in: 'b' }, mrg);
    mk('feMergeNode', { in: 'SourceGraphic' }, mrg);

    /* breadboard body */
    mk('rect', {
      x: BOARD.x, y: BOARD.y, width: BOARD.w, height: BOARD.h, rx: 14,
      fill: 'url(#boardGrad)', stroke: '#0d3b2a', 'stroke-width': '2'
    }, gBoard);
    /* subtle inner bevel */
    mk('rect', {
      x: BOARD.x + 5, y: BOARD.y + 5, width: BOARD.w - 10, height: BOARD.h - 10, rx: 10,
      fill: 'none', stroke: 'rgba(255,255,255,0.06)', 'stroke-width': '1.5'
    }, gBoard);

    /* power rails (red +5V top, blue GND bottom) */
    drawRail(RAIL_RED_Y, '#c0392b', '#e85d4c', '+5V');
    drawRail(RAIL_BLUE_Y, '#2466b0', '#4f93e0', 'GND');

    /* central channel + a field of breadboard holes */
    var channelY = BOARD.y + BOARD.h / 2;
    mk('rect', { x: BOARD.x + 20, y: channelY - 7, width: BOARD.w - 40, height: 14, rx: 4, fill: 'rgba(0,0,0,0.22)' }, gBoard);

    var holeStartX = BOARD.x + 40, holeStartY = RAIL_RED_Y + 36;
    var holeEndY = RAIL_BLUE_Y - 36, holeGap = 17, cols = Math.floor((BOARD.w - 80) / holeGap);
    for (var hy = holeStartY; hy < holeEndY; hy += holeGap) {
      if (Math.abs(hy - channelY) < 12) continue; /* leave the channel clear */
      for (var c = 0; c < cols; c++) {
        var hx = holeStartX + c * holeGap;
        mk('rect', { x: hx - 2.1, y: hy - 2.1, width: 4.2, height: 4.2, rx: 1, fill: '#0e3325', stroke: 'rgba(0,0,0,0.35)', 'stroke-width': '0.6' }, gBoard);
      }
    }

    /* column labels on the board */
    txt(BOARD.x + BOARD.w / 2, BOARD.y - 14, 'BREADBOARD', { fill: '#d8cdb8', size: 12, weight: 700, ls: '0.3em', anchor: 'middle' }, gBoard);

    drawPowerSupply();
  }

  function drawRail(y, dark, light, label) {
    var g = mk('g', {}, gBoard);
    mk('rect', { x: BOARD.x + 16, y: y - 9, width: BOARD.w - 32, height: 18, rx: 6, fill: dark, opacity: '0.9' }, g);
    mk('line', { x1: BOARD.x + 26, y1: y, x2: BOARD.x + BOARD.w - 26, y2: y, stroke: light, 'stroke-width': '2', 'stroke-dasharray': '2 9', 'stroke-linecap': 'round', opacity: '0.85' }, g);
    txt(BOARD.x + 30, y + 4, label, { fill: '#fff', size: 10, weight: 800, anchor: 'start', ls: '0.08em' }, g);
    txt(BOARD.x + BOARD.w - 30, y + 4, label, { fill: '#fff', size: 10, weight: 800, anchor: 'end', ls: '0.08em' }, g);
  }

  function txt(x, y, s, o, parent) {
    o = o || {};
    var t = mk('text', {
      x: x, y: y, 'font-size': (o.size || 11),
      'font-family': 'ui-monospace, Menlo, monospace',
      'font-weight': (o.weight || 400),
      fill: (o.fill || '#e9e7df'),
      'text-anchor': (o.anchor || 'start')
    }, parent || gOverlay);
    if (o.ls) t.setAttribute('letter-spacing', o.ls);
    t.textContent = s;
    return t;
  }

  /* ---------- POWER SUPPLY block (with +5V red, GND black terminals) ---------- */
  var powerNodes = { plus: { x: 0, y: 0 }, gnd: { x: 0, y: 0 } };
  function drawPowerSupply() {
    var px = 60, py = 470, pw = 150, ph = 130;
    var g = mk('g', {}, gBoard);
    mk('rect', { x: px, y: py, width: pw, height: ph, rx: 10, fill: '#1b1b20', stroke: '#3c3c46', 'stroke-width': '2' }, g);
    mk('rect', { x: px + 8, y: py + 8, width: pw - 16, height: 22, rx: 4, fill: '#0c0c10' }, g);
    txt(px + pw / 2, py + 23, 'DC POWER  5V', { fill: '#67e8f9', size: 9.5, weight: 700, anchor: 'middle', ls: '0.12em' }, g);

    /* +5V red terminal */
    var plusX = px + 36, plusY = py + 62;
    powerNodes.plus = { x: plusX, y: plusY };
    mk('circle', { cx: plusX, cy: plusY, r: 13, fill: '#7a1d14', stroke: '#c0392b', 'stroke-width': '2' }, g);
    var pp = mk('circle', { cx: plusX, cy: plusY, r: 8, fill: '#c0392b', stroke: '#e85d4c', 'stroke-width': '1.5', cursor: 'crosshair' }, g);
    txt(plusX, plusY + 32, '+5V', { fill: '#e85d4c', size: 10, weight: 800, anchor: 'middle' }, g);
    registerPin(pp, { kind: 'rail', ref: 'PLUS', pin: 0 }, plusX, plusY, 'out');

    /* GND black terminal */
    var gndX = px + pw - 36, gndY = py + 62;
    powerNodes.gnd = { x: gndX, y: gndY };
    mk('circle', { cx: gndX, cy: gndY, r: 13, fill: '#101013', stroke: '#555', 'stroke-width': '2' }, g);
    var gp = mk('circle', { cx: gndX, cy: gndY, r: 8, fill: '#222', stroke: '#888', 'stroke-width': '1.5', cursor: 'crosshair' }, g);
    txt(gndX, gndY + 32, 'GND', { fill: '#bbb', size: 10, weight: 800, anchor: 'middle' }, g);
    registerPin(gp, { kind: 'rail', ref: 'GND', pin: 0 }, gndX, gndY, 'out');

    /* on/off lamp on the supply */
    powerLamp = mk('circle', { cx: px + pw / 2, cy: py + ph - 18, r: 7, fill: '#3a1010', stroke: '#5a2020', 'stroke-width': '1.5' }, g);
    txt(px + pw / 2, py + ph - 30, 'PWR', { fill: '#7a6f5c', size: 8, weight: 700, anchor: 'middle', ls: '0.1em' }, g);
  }
  var powerLamp = null;

  /* ============================================================= *
   *  PIN REGISTRY  --  every clickable terminal lives here        *
   * ============================================================= */
  /* a pin is identified by {kind, ref, pin}:
     kind 'rail'   ref 'PLUS'|'GND'                 (source)
     kind 'switch' ref switchId                     (source, out)
     kind 'gateOut' ref gateId                      (source, out)
     kind 'gateIn'  ref gateId  pin index           (dest)
     kind 'led'     ref ledId                        (dest)
  */
  var pinIndex = []; // {el, id:{kind,ref,pin}, x, y, dir:'in'|'out'}

  function registerPin(el, idObj, x, y, dir) {
    var rec = { el: el, id: idObj, x: x, y: y, dir: dir };
    pinIndex.push(rec);
    el.style.cursor = 'crosshair';
    el.addEventListener('click', function (ev) {
      ev.stopPropagation();
      onPinClick(rec);
    });
    el.addEventListener('mouseenter', function () {
      el.setAttribute('stroke-width', '3');
    });
    el.addEventListener('mouseleave', function () {
      el.setAttribute('stroke-width', el.getAttribute('data-sw') || '1.5');
    });
    return rec;
  }
  function pinKey(idObj) { return idObj.kind + ':' + idObj.ref + ':' + (idObj.pin || 0); }
  function findPinRec(idObj) {
    var key = pinKey(idObj);
    for (var i = 0; i < pinIndex.length; i++) {
      if (pinKey(pinIndex[i].id) === key) return pinIndex[i];
    }
    return null;
  }

  /* ============================================================= *
   *  INPUT SWITCHES  (metallic toggles)                          *
   * ============================================================= */
  function addSwitch(label, value) {
    var id = uid('sw');
    var idx = state.switches.length;
    var y = 130 + idx * 86;
    var sw = { id: id, label: label, x: SWITCH_X, y: y, value: value ? 1 : 0 };
    state.switches.push(sw);
    return sw;
  }

  function drawSwitch(sw) {
    var g = mk('g', { 'data-sw': sw.id }, gParts);
    sw.g = g;
    var bx = sw.x - 26, by = sw.y - 32, bw = 52, bh = 78;

    /* mounting plate */
    mk('rect', { x: bx - 6, y: by - 6, width: bw + 12, height: bh + 30, rx: 9, fill: '#1c1c20', stroke: '#33333c', 'stroke-width': '1.5' }, g);
    /* metallic body */
    mk('rect', { x: bx, y: by, width: bw, height: bh, rx: 7, fill: 'url(#metalGrad)', stroke: '#5a5f68', 'stroke-width': '1.5' }, g);
    /* slot */
    mk('rect', { x: sw.x - 9, y: by + 9, width: 18, height: bh - 18, rx: 9, fill: '#23262b' }, g);

    /* the moving lever (rendered/refreshed in refreshSwitch) */
    sw.lever = mk('rect', { x: sw.x - 11, width: 22, height: 30, rx: 8, fill: '#d8dde4', stroke: '#9097a0', 'stroke-width': '1.5' }, g);
    sw.leverHi = mk('rect', { x: sw.x - 7, width: 14, height: 6, rx: 3, fill: 'rgba(255,255,255,0.6)' }, g);

    /* state markers */
    txt(bx - 14, by + 14, '1', { fill: '#9aa0aa', size: 10, weight: 800, anchor: 'middle' }, g);
    txt(bx - 14, by + bh - 6, '0', { fill: '#9aa0aa', size: 10, weight: 800, anchor: 'middle' }, g);

    /* label cap */
    txt(sw.x, by - 14, sw.label, { fill: '#f1e7d3', size: 16, weight: 800, anchor: 'middle' }, g);

    /* output terminal pin (right side) -- this is the source you wire FROM */
    var termX = sw.x + 40, termY = sw.y;
    mk('line', { x1: bx + bw, y1: sw.y, x2: termX - 7, y2: termY, stroke: '#7c828c', 'stroke-width': '3' }, g);
    var term = mk('circle', { cx: termX, cy: termY, r: PIN_R, fill: '#c87f3a', stroke: '#f0a85a', 'stroke-width': '1.5' }, g);
    term.setAttribute('data-sw', '1.5');
    registerPin(term, { kind: 'switch', ref: sw.id, pin: 0 }, termX, termY, 'out');
    sw.termX = termX; sw.termY = termY;
    sw.value01 = mk('text', {
      x: termX + 13, y: termY + 4, 'font-size': 12, 'font-weight': 800,
      'font-family': 'ui-monospace, monospace', fill: '#e0b06a', 'text-anchor': 'start'
    }, g);

    /* clicking the metallic body toggles the switch */
    var hit = mk('rect', { x: bx, y: by, width: bw, height: bh, rx: 7, fill: 'transparent', cursor: 'pointer' }, g);
    hit.addEventListener('click', function () { toggleSwitch(sw); });

    refreshSwitch(sw);
  }

  function refreshSwitch(sw) {
    var by = sw.y - 32, bh = 78;
    /* lever up = 1 (near top of slot), down = 0 */
    var leverY = sw.value ? (by + 12) : (by + bh - 42);
    sw.lever.setAttribute('y', leverY);
    sw.leverHi.setAttribute('y', leverY + 6);
    sw.lever.setAttribute('fill', sw.value ? '#eaf4ff' : '#cfd4db');
    sw.value01.textContent = sw.value;
  }

  function toggleSwitch(sw) {
    sw.value = sw.value ? 0 : 1;
    refreshSwitch(sw);
    flashStatus('Switch <b>' + sw.label + '</b> set to <b>' + sw.value + '</b>');
    simulate();
  }

  /* ============================================================= *
   *  OUTPUT LEDS                                                  *
   * ============================================================= */
  function addLed(label) {
    var id = uid('led');
    var idx = state.leds.length;
    var y = 140 + idx * 96;
    var led = { id: id, label: label, x: LED_X, y: y, value: 0 };
    state.leds.push(led);
    return led;
  }

  function drawLed(led) {
    var g = mk('g', {}, gParts);
    led.g = g;
    /* input terminal (left) -- the dest you wire TO */
    var termX = led.x - 52, termY = led.y;
    mk('line', { x1: termX + 6, y1: termY, x2: led.x - 22, y2: led.y, stroke: '#7c828c', 'stroke-width': '3' }, g);
    var term = mk('circle', { cx: termX, cy: termY, r: PIN_R, fill: '#c87f3a', stroke: '#f0a85a', 'stroke-width': '1.5' }, g);
    term.setAttribute('data-sw', '1.5');
    registerPin(term, { kind: 'led', ref: led.id, pin: 0 }, termX, termY, 'in');
    led.termX = termX; led.termY = termY;

    /* socket */
    mk('circle', { cx: led.x, cy: led.y, r: 20, fill: '#1a1a1f', stroke: '#34343d', 'stroke-width': '2.5' }, g);
    /* the glow halo (shown when on) */
    led.halo = mk('circle', { cx: led.x, cy: led.y, r: 26, fill: 'url(#ledGlowGrad)', opacity: '0', filter: 'url(#softGlow)' }, g);
    /* the lens */
    led.lens = mk('circle', { cx: led.x, cy: led.y, r: 15, fill: '#243026', stroke: '#3a4a3c', 'stroke-width': '1.5' }, g);
    /* specular highlight */
    mk('circle', { cx: led.x - 5, cy: led.y - 5, r: 4, fill: 'rgba(255,255,255,0.35)' }, g);

    /* label cap below */
    mk('rect', { x: led.x - 18, y: led.y + 26, width: 36, height: 20, rx: 5, fill: '#1c1c20', stroke: '#3a3a44', 'stroke-width': '1.2' }, g);
    txt(led.x, led.y + 40, led.label, { fill: '#f1e7d3', size: 13, weight: 800, anchor: 'middle' }, g);
    led.valTxt = mk('text', {
      x: led.x + 36, y: led.y + 4, 'font-size': 13, 'font-weight': 800,
      'font-family': 'ui-monospace, monospace', fill: '#6b6557', 'text-anchor': 'start'
    }, g);
    led.valTxt.textContent = '0';
  }

  function refreshLed(led) {
    var on = state.powered && led.value === 1;
    led.halo.setAttribute('opacity', on ? '0.95' : '0');
    led.lens.setAttribute('fill', on ? '#54f078' : '#243026');
    led.lens.setAttribute('stroke', on ? '#bfffd0' : '#3a4a3c');
    led.valTxt.textContent = state.powered ? led.value : '-';
    led.valTxt.setAttribute('fill', on ? '#54f078' : '#6b6557');
  }

  /* ============================================================= *
   *  GATE CHIPS                                                   *
   * ============================================================= */
  function addGate(type, x, y) {
    var def = GATES[type];
    if (!def) return null;
    var id = uid('g');
    var gate = {
      id: id, type: type, x: (x == null ? 430 : x), y: (y == null ? 280 : y),
      value: 0, inVals: []
    };
    state.gates.push(gate);
    return gate;
  }

  function gatePinPositions(gate) {
    var def = GATES[gate.type];
    var ins = def.ins;
    var left = gate.x - CHIP_W / 2, right = gate.x + CHIP_W / 2;
    var inPts = [];
    for (var i = 0; i < ins; i++) {
      var fy = ins === 1 ? gate.y : gate.y - CHIP_H / 2 + (CHIP_H * (i + 1)) / (ins + 1);
      inPts.push({ x: left - 14, y: fy });
    }
    var outPt = { x: right + 14, y: gate.y };
    return { ins: inPts, out: outPt, left: left, right: right };
  }

  function drawGate(gate) {
    var def = GATES[gate.type];
    var g = mk('g', {}, gChips);
    gate.g = g;
    var pos = gatePinPositions(gate);
    var left = pos.left, right = pos.right, top = gate.y - CHIP_H / 2;

    /* shadow */
    mk('rect', { x: left + 3, y: top + 4, width: CHIP_W, height: CHIP_H, rx: 9, fill: 'rgba(0,0,0,0.4)' }, g);
    /* chip body (draggable) */
    var body = mk('rect', {
      x: left, y: top, width: CHIP_W, height: CHIP_H, rx: 9,
      fill: 'url(#chipGrad)', stroke: '#0a0a0d', 'stroke-width': '1.5', cursor: 'grab'
    }, g);
    gate.body = body;
    /* notch (orientation mark) */
    mk('path', { d: 'M' + (gate.x - 9) + ' ' + top + ' a9 9 0 0 0 18 0', fill: '#0a0a0d' }, g);
    /* top bevel */
    mk('rect', { x: left + 3, y: top + 3, width: CHIP_W - 6, height: 8, rx: 4, fill: 'rgba(255,255,255,0.08)' }, g);

    /* gate symbol glyph */
    drawGateGlyph(g, gate, left, top);

    /* name + sublabel */
    txt(gate.x, top + 24, def.name, { fill: '#f1e7d3', size: 15, weight: 800, anchor: 'middle', ls: '0.04em' }, g);
    txt(gate.x, top + CHIP_H - 10, def.sub, { fill: '#8a8f99', size: 8.5, weight: 600, anchor: 'middle', ls: '0.06em' }, g);

    /* input pins */
    gate.inPinRecs = [];
    var inLabels = def.name === 'MUX' ? ['S', 'I0', 'I1'] : (def.ins === 1 ? ['IN'] : ['A', 'B']);
    for (var i = 0; i < pos.ins.length; i++) {
      var p = pos.ins[i];
      mk('line', { x1: left, y1: p.y, x2: p.x + PIN_R, y2: p.y, stroke: '#9097a0', 'stroke-width': '2.5' }, g);
      var dot = mk('circle', { cx: p.x, cy: p.y, r: PIN_R, fill: '#2a2a30', stroke: '#9097a0', 'stroke-width': '1.5' }, g);
      dot.setAttribute('data-sw', '1.5');
      var rec = registerPin(dot, { kind: 'gateIn', ref: gate.id, pin: i }, p.x, p.y, 'in');
      rec.dot = dot;
      gate.inPinRecs.push(rec);
      txt(p.x + 11, p.y - 7, inLabels[i] || ('I' + i), { fill: '#a99e85', size: 8, weight: 700, anchor: 'middle' }, g);
    }
    /* output pin */
    mk('line', { x1: right, y1: gate.y, x2: pos.out.x - PIN_R, y2: gate.y, stroke: '#9097a0', 'stroke-width': '2.5' }, g);
    var odot = mk('circle', { cx: pos.out.x, cy: gate.y, r: PIN_R, fill: '#2a2a30', stroke: '#f0a85a', 'stroke-width': '1.5' }, g);
    odot.setAttribute('data-sw', '1.5');
    var orec = registerPin(odot, { kind: 'gateOut', ref: gate.id, pin: 0 }, pos.out.x, gate.y, 'out');
    orec.dot = odot;
    gate.outPinRec = orec;
    txt(pos.out.x - 11, gate.y - 7, 'Y', { fill: '#e0b06a', size: 8, weight: 700, anchor: 'middle' }, g);

    /* dragging */
    enableGateDrag(gate, body);
  }

  /* simple internal gate symbol so a chip reads like real apparatus */
  function drawGateGlyph(g, gate, left, top) {
    var cx = gate.x, cy = top + CHIP_H / 2 + 4;
    var col = '#5a5f68';
    var sym = mk('g', { opacity: '0.55' }, g);
    var t = gate.type;
    if (t === 'NOT') {
      mk('path', { d: tri(cx - 12, cy, 22, 16), fill: 'none', stroke: col, 'stroke-width': '1.6' }, sym);
      mk('circle', { cx: cx + 13, cy: cy, r: 3, fill: 'none', stroke: col, 'stroke-width': '1.6' }, sym);
    } else if (t === 'AND' || t === 'NAND') {
      mk('path', { d: dShape(cx - 13, cy, 22, 18), fill: 'none', stroke: col, 'stroke-width': '1.6' }, sym);
      if (t === 'NAND') mk('circle', { cx: cx + 13, cy: cy, r: 3, fill: 'none', stroke: col, 'stroke-width': '1.6' }, sym);
    } else if (t === 'OR' || t === 'NOR' || t === 'XOR' || t === 'XNOR') {
      mk('path', { d: orShape(cx - 14, cy, 24, 18), fill: 'none', stroke: col, 'stroke-width': '1.6' }, sym);
      if (t === 'XOR' || t === 'XNOR') mk('path', { d: 'M' + (cx - 18) + ' ' + (cy - 9) + ' q5 9 0 18', fill: 'none', stroke: col, 'stroke-width': '1.6' }, sym);
      if (t === 'NOR' || t === 'XNOR') mk('circle', { cx: cx + 13, cy: cy, r: 3, fill: 'none', stroke: col, 'stroke-width': '1.6' }, sym);
    } else if (t === 'MUX') {
      mk('path', { d: 'M' + (cx - 12) + ' ' + (cy - 11) + ' L' + (cx + 10) + ' ' + (cy - 5) + ' L' + (cx + 10) + ' ' + (cy + 5) + ' L' + (cx - 12) + ' ' + (cy + 11) + ' Z', fill: 'none', stroke: col, 'stroke-width': '1.6' }, sym);
    }
  }
  function tri(x, y, w, h) { return 'M' + x + ' ' + (y - h / 2) + ' L' + (x + w) + ' ' + y + ' L' + x + ' ' + (y + h / 2) + ' Z'; }
  function dShape(x, y, w, h) {
    var r = h / 2;
    return 'M' + x + ' ' + (y - r) + ' L' + (x + w - r) + ' ' + (y - r) +
      ' a' + r + ' ' + r + ' 0 0 1 0 ' + (2 * r) + ' L' + x + ' ' + (y + r) + ' Z';
  }
  function orShape(x, y, w, h) {
    var r = h / 2;
    return 'M' + x + ' ' + (y - r) + ' Q' + (x + w * 0.7) + ' ' + (y - r) + ' ' + (x + w) + ' ' + y +
      ' Q' + (x + w * 0.7) + ' ' + (y + r) + ' ' + x + ' ' + (y + r) +
      ' Q' + (x + w * 0.25) + ' ' + y + ' ' + x + ' ' + (y - r) + ' Z';
  }

  /* ---------- gate dragging ---------- */
  function enableGateDrag(gate, body) {
    var dragging = false, startMouse = null, startPos = null, moved = false;

    function down(ev) {
      ev.preventDefault();
      dragging = true; moved = false;
      body.style.cursor = 'grabbing';
      startMouse = svgPoint(ev);
      startPos = { x: gate.x, y: gate.y };
      window.addEventListener('mousemove', move);
      window.addEventListener('mouseup', up);
      window.addEventListener('touchmove', move, { passive: false });
      window.addEventListener('touchend', up);
    }
    function move(ev) {
      if (!dragging) return;
      ev.preventDefault();
      var p = svgPoint(ev);
      var nx = startPos.x + (p.x - startMouse.x);
      var ny = startPos.y + (p.y - startMouse.y);
      /* clamp to a sensible area */
      nx = Math.max(330, Math.min(820, nx));
      ny = Math.max(150, Math.min(560, ny));
      if (Math.abs(nx - gate.x) > 0.5 || Math.abs(ny - gate.y) > 0.5) moved = true;
      gate.x = nx; gate.y = ny;
      repositionGate(gate);
      redrawWires();
    }
    function up() {
      dragging = false;
      body.style.cursor = 'grab';
      window.removeEventListener('mousemove', move);
      window.removeEventListener('mouseup', up);
      window.removeEventListener('touchmove', move);
      window.removeEventListener('touchend', up);
    }
    body.addEventListener('mousedown', down);
    body.addEventListener('touchstart', function (e) { down(e.touches ? e.touches[0] : e); }, { passive: false });
  }

  /* redraw a single gate group in place (cheap: re-render the whole chip) */
  function repositionGate(gate) {
    if (gate.g && gate.g.parentNode) gate.g.parentNode.removeChild(gate.g);
    /* drop its pins from the index */
    pinIndex = pinIndex.filter(function (r) {
      return !((r.id.kind === 'gateIn' || r.id.kind === 'gateOut') && r.id.ref === gate.id);
    });
    drawGate(gate);
  }

  /* ============================================================= *
   *  PIN CLICK -> WIRING                                          *
   * ============================================================= */
  function onPinClick(rec) {
    if (!state.pending) {
      /* must start a wire from a source (an output / switch / rail) */
      if (rec.dir !== 'out') {
        flashStatus('Start a wire from an <b>output</b> pin, the <b>+5V</b> or <b>GND</b> terminal, or a switch.');
        toast('Click an output / source pin first');
        return;
      }
      state.pending = rec;
      highlightPin(rec, true);
      flashStatus('Wire started from <b>' + describePin(rec) + '</b>. Now click a destination input.');
      return;
    }

    /* we have a pending source; this click is the destination */
    var src = state.pending;
    if (rec === src) { /* clicked same pin -> cancel */
      highlightPin(src, false);
      state.pending = null;
      flashStatus('Wire cancelled.');
      return;
    }
    if (rec.dir !== 'in') {
      /* clicked another source -> retarget the source */
      highlightPin(src, false);
      state.pending = rec;
      highlightPin(rec, true);
      flashStatus('Source changed to <b>' + describePin(rec) + '</b>. Now click a destination input.');
      return;
    }

    /* valid: src(out) -> rec(in) */
    highlightPin(src, false);
    state.pending = null;
    addWire(src, rec);
  }

  function describePin(rec) {
    var id = rec.id;
    if (id.kind === 'rail') return id.ref === 'PLUS' ? '+5V' : 'GND';
    if (id.kind === 'switch') { var s = byId(state.switches, id.ref); return 'Switch ' + (s ? s.label : '?'); }
    if (id.kind === 'gateOut') { var g = byId(state.gates, id.ref); return (g ? g.type : '?') + ' output'; }
    if (id.kind === 'gateIn') { var g2 = byId(state.gates, id.ref); return (g2 ? g2.type : '?') + ' input ' + (id.pin + 1); }
    if (id.kind === 'led') { var l = byId(state.leds, id.ref); return 'LED ' + (l ? l.label : '?'); }
    return '?';
  }

  function highlightPin(rec, on) {
    if (!rec.el) return;
    rec.el.setAttribute('stroke', on ? '#67e8f9' : (rec.dir === 'out' ? '#f0a85a' : '#9097a0'));
    rec.el.setAttribute('stroke-width', on ? '3.5' : (rec.el.getAttribute('data-sw') || '1.5'));
    if (on) rec.el.setAttribute('filter', 'url(#softGlow)'); else rec.el.removeAttribute('filter');
  }

  function byId(arr, id) { for (var i = 0; i < arr.length; i++) if (arr[i].id === id) return arr[i]; return null; }

  /* ---------- create / replace a wire ---------- */
  function addWire(srcRec, dstRec) {
    /* an input / led accepts only one incoming wire -> remove any existing */
    var dKey = pinKey(dstRec.id);
    state.wires = state.wires.filter(function (w) {
      if (pinKey(w.to.id) === dKey) { removeWireEl(w); return false; }
      return true;
    });

    var w = {
      id: uid('w'),
      from: { id: srcRec.id },
      to: { id: dstRec.id },
      color: wireColor(srcRec)
    };
    state.wires.push(w);
    drawWire(w);
    flashStatus('Wired <b>' + describePin(srcRec) + '</b> &rarr; <b>' + describePin(dstRec) + '</b>.');
    rebuildTruthTable();
    simulate();
  }

  function wireColor(srcRec) {
    if (srcRec.id.kind === 'rail') return srcRec.id.ref === 'PLUS' ? '#e85d4c' : '#3a3a40';
    if (srcRec.id.kind === 'switch') return '#e0b06a';
    return '#6fb6ff';
  }

  function removeWireEl(w) { if (w.path && w.path.parentNode) w.path.parentNode.removeChild(w.path); if (w.hit && w.hit.parentNode) w.hit.parentNode.removeChild(w.hit); }

  function endpoint(idObj) {
    var rec = findPinRec(idObj);
    if (rec) return { x: rec.x, y: rec.y };
    return null;
  }

  function drawWire(w) {
    var a = endpoint(w.from.id), b = endpoint(w.to.id);
    if (!a || !b) return;
    var d = bezier(a, b);
    /* invisible fat hit-area for easy deletion */
    var hit = mk('path', { d: d, fill: 'none', stroke: 'transparent', 'stroke-width': '16', cursor: 'pointer' }, gWires);
    var path = mk('path', { d: d, fill: 'none', stroke: w.color, 'stroke-width': '3.2', 'stroke-linecap': 'round', opacity: '0.92' }, gWires);
    /* a thin sheen */
    w.path = path; w.hit = hit; w.sheen = null;
    hit.addEventListener('click', function (ev) { ev.stopPropagation(); deleteWire(w); });
    hit.addEventListener('mouseenter', function () { path.setAttribute('stroke-width', '5'); path.setAttribute('opacity', '1'); });
    hit.addEventListener('mouseleave', function () { path.setAttribute('stroke-width', '3.2'); path.setAttribute('opacity', '0.92'); });
  }

  function bezier(a, b) {
    var dx = Math.abs(b.x - a.x);
    var k = Math.max(40, dx * 0.5);
    return 'M' + a.x + ' ' + a.y + ' C' + (a.x + k) + ' ' + a.y + ' ' + (b.x - k) + ' ' + b.y + ' ' + b.x + ' ' + b.y;
  }

  function deleteWire(w) {
    removeWireEl(w);
    state.wires = state.wires.filter(function (x) { return x !== w; });
    flashStatus('Wire deleted.');
    rebuildTruthTable();
    simulate();
  }

  function redrawWires() {
    for (var i = 0; i < state.wires.length; i++) {
      var w = state.wires[i];
      var a = endpoint(w.from.id), b = endpoint(w.to.id);
      if (a && b && w.path) { var d = bezier(a, b); w.path.setAttribute('d', d); if (w.hit) w.hit.setAttribute('d', d); }
    }
  }

  /* ============================================================= *
   *  SIMULATION ENGINE                                            *
   * ============================================================= */
  /* For a destination pin, find the source net value driving it. */
  function incomingValue(destId, netVals) {
    for (var i = 0; i < state.wires.length; i++) {
      var w = state.wires[i];
      if (pinKey(w.to.id) === pinKey(destId)) {
        return sourceValue(w.from.id, netVals);
      }
    }
    return 0; /* unconnected reads as 0 */
  }

  function sourceValue(srcId, netVals) {
    if (srcId.kind === 'rail') return srcId.ref === 'PLUS' ? 1 : 0;
    if (srcId.kind === 'switch') { var s = byId(state.switches, srcId.ref); return s ? s.value : 0; }
    if (srcId.kind === 'gateOut') { var v = netVals['g:' + srcId.ref]; return v == null ? 0 : v; }
    return 0;
  }

  function simulate() {
    if (!state.powered) {
      for (var i = 0; i < state.leds.length; i++) { state.leds[i].value = 0; refreshLed(state.leds[i]); }
      paintGatePins({});
      return;
    }
    /* iterative settle */
    var netVals = {};
    for (var g = 0; g < state.gates.length; g++) netVals['g:' + state.gates[g].id] = 0;

    var stable = false, iter = 0;
    while (!stable && iter < 50) {
      stable = true; iter++;
      for (var k = 0; k < state.gates.length; k++) {
        var gate = state.gates[k];
        var def = GATES[gate.type];
        var inv = [];
        for (var p = 0; p < def.ins; p++) {
          inv.push(incomingValue({ kind: 'gateIn', ref: gate.id, pin: p }, netVals));
        }
        gate.inVals = inv;
        var out = def.eval.apply(null, inv) ? 1 : 0;
        if (netVals['g:' + gate.id] !== out) { netVals['g:' + gate.id] = out; stable = false; }
        gate.value = out;
      }
    }

    /* leds */
    for (var L = 0; L < state.leds.length; L++) {
      var led = state.leds[L];
      led.value = incomingValue({ kind: 'led', ref: led.id, pin: 0 }, netVals);
      refreshLed(led);
    }

    paintGatePins(netVals);
    updateStatus();
  }

  /* colour gate input/output pins by their live logic value */
  function paintGatePins(netVals) {
    for (var i = 0; i < state.gates.length; i++) {
      var gate = state.gates[i];
      if (!gate.inPinRecs) continue;
      for (var p = 0; p < gate.inPinRecs.length; p++) {
        var rec = gate.inPinRecs[p];
        var on = state.powered && gate.inVals && gate.inVals[p] === 1;
        if (rec.dot) rec.dot.setAttribute('fill', on ? '#54f078' : '#2a2a30');
      }
      if (gate.outPinRec && gate.outPinRec.dot) {
        var oon = state.powered && gate.value === 1;
        gate.outPinRec.dot.setAttribute('fill', oon ? '#54f078' : '#2a2a30');
      }
    }
    /* colour live wires too */
    for (var w = 0; w < state.wires.length; w++) {
      var wire = state.wires[w];
      if (!wire.path) continue;
      var v = state.powered ? sourceValue(wire.from.id, netVals || {}) : -1;
      if (v === 1) { wire.path.setAttribute('stroke', '#54f078'); wire.path.setAttribute('opacity', '1'); }
      else { wire.path.setAttribute('stroke', wire.color); wire.path.setAttribute('opacity', state.powered ? '0.55' : '0.92'); }
    }
  }

  /* ============================================================= *
   *  TRUTH TABLE  (sweeps the switches)                          *
   * ============================================================= */
  function rebuildTruthTable() {
    var ttWrap = document.getElementById('ttWrap');
    var ttTable = document.getElementById('ttTable');
    var ttStatus = document.getElementById('ttStatus');
    if (!ttTable) return;

    var n = state.switches.length;
    var m = state.leds.length;
    if (n === 0 || m === 0) {
      ttWrap.style.display = 'none';
      ttStatus.textContent = 'Add at least one switch and one LED (or load a preset) to sweep a truth table.';
      return;
    }
    if (n > 8) {
      ttWrap.style.display = 'none';
      ttStatus.textContent = 'Truth table disabled above 8 inputs (' + n + ' switches present).';
      return;
    }
    ttStatus.innerHTML = 'Sweeping <b>' + n + '</b> input' + (n > 1 ? 's' : '') + ' over <b>' + (1 << n) + '</b> rows. The active row tracks your live switches.';
    ttWrap.style.display = 'block';

    /* remember live switch values, then sweep all combos */
    var saved = state.switches.map(function (s) { return s.value; });
    var rows = [];
    for (var combo = 0; combo < (1 << n); combo++) {
      for (var b = 0; b < n; b++) state.switches[b].value = (combo >> (n - 1 - b)) & 1;
      var outs = computeOutputs();
      rows.push({ ins: state.switches.map(function (s) { return s.value; }), outs: outs });
    }
    /* restore live values */
    for (var r2 = 0; r2 < n; r2++) state.switches[r2].value = saved[r2];

    /* render */
    clearHtml(ttTable);
    var thead = document.createElement('thead');
    var htr = document.createElement('tr');
    for (var hi = 0; hi < n; hi++) htr.appendChild(thEl(state.switches[hi].label));
    for (var ho = 0; ho < m; ho++) { var th = thEl(state.leds[ho].label); if (ho === 0) th.className = 'sep'; htr.appendChild(th); }
    thead.appendChild(htr); ttTable.appendChild(thead);

    var tbody = document.createElement('tbody');
    var curIdx = 0;
    for (var ci = 0; ci < n; ci++) curIdx = (curIdx << 1) | saved[ci];
    for (var ri = 0; ri < rows.length; ri++) {
      var tr = document.createElement('tr');
      if (ri === curIdx) tr.className = 'cur';
      for (var ii = 0; ii < n; ii++) { var td = tdEl(rows[ri].ins[ii]); td.className = 'in'; tr.appendChild(td); }
      for (var oi = 0; oi < m; oi++) {
        var v = rows[ri].outs[oi];
        var otd = tdEl(v); otd.className = (v === 1 ? 'out1' : 'out0') + (oi === 0 ? ' sep' : '');
        tr.appendChild(otd);
      }
      tbody.appendChild(tr);
    }
    ttTable.appendChild(tbody);
  }

  /* compute LED outputs for the current switch values, ignoring power (pure combinational eval) */
  function computeOutputs() {
    var netVals = {};
    for (var g = 0; g < state.gates.length; g++) netVals['g:' + state.gates[g].id] = 0;
    var stable = false, iter = 0;
    while (!stable && iter < 50) {
      stable = true; iter++;
      for (var k = 0; k < state.gates.length; k++) {
        var gate = state.gates[k];
        var def = GATES[gate.type];
        var inv = [];
        for (var p = 0; p < def.ins; p++) inv.push(incomingValue({ kind: 'gateIn', ref: gate.id, pin: p }, netVals));
        var out = def.eval.apply(null, inv) ? 1 : 0;
        if (netVals['g:' + gate.id] !== out) { netVals['g:' + gate.id] = out; stable = false; }
      }
    }
    var outs = [];
    for (var L = 0; L < state.leds.length; L++) outs.push(incomingValue({ kind: 'led', ref: state.leds[L].id, pin: 0 }, netVals));
    return outs;
  }

  function thEl(s) { var e = document.createElement('th'); e.textContent = s; return e; }
  function tdEl(v) { var e = document.createElement('td'); e.textContent = v; return e; }
  function clearHtml(node) { while (node.firstChild) node.removeChild(node.firstChild); }

  /* ============================================================= *
   *  STATUS / TOAST                                              *
   * ============================================================= */
  var statusEl = document.getElementById('statusLine');
  function flashStatus(html) { if (statusEl) statusEl.innerHTML = html; }
  function updateStatus() {
    if (!statusEl) return;
    var parts = [];
    parts.push('<b>' + state.gates.length + '</b> chip' + (state.gates.length === 1 ? '' : 's'));
    parts.push('<b>' + state.wires.length + '</b> wire' + (state.wires.length === 1 ? '' : 's'));
    var litLeds = state.leds.filter(function (l) { return state.powered && l.value === 1; }).length;
    parts.push('<b>' + litLeds + '</b> LED' + (litLeds === 1 ? '' : 's') + ' lit');
    statusEl.innerHTML = (state.powered ? 'Powered. ' : 'Idle. ') + parts.join(' &middot; ') + '.';
  }

  var toastEl = document.getElementById('benchToast');
  var toastTimer = null;
  function toast(msg) {
    if (!toastEl) return;
    toastEl.textContent = msg;
    toastEl.classList.add('show');
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(function () { toastEl.classList.remove('show'); }, 2200);
  }

  /* ============================================================= *
   *  COORDINATE HELPER (screen -> SVG viewBox)                   *
   * ============================================================= */
  function svgPoint(ev) {
    var rect = svg.getBoundingClientRect();
    var cx = ev.clientX, cy = ev.clientY;
    var x = (cx - rect.left) / rect.width * VBW;
    var y = (cy - rect.top) / rect.height * VBH;
    return { x: x, y: y };
  }

  /* ============================================================= *
   *  POWER                                                        *
   * ============================================================= */
  var powerBtn = document.getElementById('powerBtn');
  var powerPill = document.getElementById('powerPill');
  var powerTxt = document.getElementById('powerTxt');

  function setPower(on) {
    state.powered = !!on;
    if (powerBtn) {
      powerBtn.textContent = on ? 'STOP' : 'START';
      powerBtn.classList.toggle('power-on', on);
      powerBtn.classList.toggle('power-off', !on);
    }
    if (powerPill) powerPill.classList.toggle('live', on);
    if (powerTxt) powerTxt.textContent = on ? 'Power on' : 'Power off';
    if (powerLamp) {
      powerLamp.setAttribute('fill', on ? '#54f078' : '#3a1010');
      powerLamp.setAttribute('stroke', on ? '#bfffd0' : '#5a2020');
      if (on) powerLamp.setAttribute('filter', 'url(#softGlow)'); else powerLamp.removeAttribute('filter');
    }
    simulate();
    if (on) toast('Power on — flip the switches'); else toast('Power off');
  }

  if (powerBtn) powerBtn.addEventListener('click', function () { setPower(!state.powered); });

  /* ============================================================= *
   *  PALETTE                                                      *
   * ============================================================= */
  function buildPalette() {
    var pal = document.getElementById('palette');
    if (!pal) return;
    for (var i = 0; i < PALETTE_ORDER.length; i++) {
      (function (type) {
        var def = GATES[type];
        var btn = document.createElement('div');
        btn.className = 'chip-btn';
        btn.innerHTML = paletteGlyph(type) +
          '<span class="gname">' + def.name + '</span>' +
          '<span class="gsub">' + def.sub + '</span>';
        btn.addEventListener('click', function () { dropGate(type); });
        pal.appendChild(btn);
      })(PALETTE_ORDER[i]);
    }
  }

  /* a little inline-SVG gate symbol for the palette button */
  function paletteGlyph(type) {
    var s = '<svg width="40" height="26" viewBox="0 0 40 26" fill="none" stroke="#e0b06a" stroke-width="1.6">';
    if (type === 'NOT') {
      s += '<path d="M12 6 L26 13 L12 20 Z"/><circle cx="29" cy="13" r="2.5"/><line x1="4" y1="13" x2="12" y2="13"/><line x1="31" y1="13" x2="37" y2="13"/>';
    } else if (type === 'AND' || type === 'NAND') {
      s += '<path d="M12 5 L20 5 a8 8 0 0 1 0 16 L12 21 Z"/>';
      if (type === 'NAND') s += '<circle cx="31" cy="13" r="2.5"/>';
      s += '<line x1="4" y1="9" x2="12" y2="9"/><line x1="4" y1="17" x2="12" y2="17"/>';
    } else if (type === 'OR' || type === 'NOR' || type === 'XOR' || type === 'XNOR') {
      s += '<path d="M11 5 Q22 5 29 13 Q22 21 11 21 Q16 13 11 5 Z"/>';
      if (type === 'XOR' || type === 'XNOR') s += '<path d="M8 5 Q13 13 8 21"/>';
      if (type === 'NOR' || type === 'XNOR') s += '<circle cx="32" cy="13" r="2.5"/>';
      s += '<line x1="3" y1="9" x2="12" y2="9"/><line x1="3" y1="17" x2="12" y2="17"/>';
    } else if (type === 'MUX') {
      s += '<path d="M12 4 L26 9 L26 17 L12 22 Z"/><line x1="4" y1="9" x2="12" y2="9"/><line x1="4" y1="17" x2="12" y2="17"/><line x1="26" y1="13" x2="36" y2="13"/>';
    }
    s += '</svg>';
    return s;
  }

  /* drop a new gate near board centre, slightly offset so they don't stack */
  var dropCount = 0;
  function dropGate(type) {
    var ox = 430 + (dropCount % 3) * 18;
    var oy = 240 + (dropCount % 5) * 30;
    dropCount++;
    var gate = addGate(type, ox, oy);
    drawGate(gate);
    flashStatus('Added <b>' + GATES[type].name + '</b> chip. Drag it into place, then wire its pins.');
    toast(GATES[type].name + ' chip placed');
    updateStatus();
  }

  /* ============================================================= *
   *  CLEAR + RESET                                                *
   * ============================================================= */
  function clearWires() {
    for (var i = 0; i < state.wires.length; i++) removeWireEl(state.wires[i]);
    state.wires = [];
    if (state.pending) { highlightPin(state.pending, false); state.pending = null; }
    rebuildTruthTable();
    simulate();
    flashStatus('All wires removed.');
    toast('Wires cleared');
  }

  function clearBoard() {
    /* remove all chips, wires, switches, leds and rebuild a fresh empty bench */
    clearWires();
    for (var i = 0; i < state.gates.length; i++) { if (state.gates[i].g && state.gates[i].g.parentNode) state.gates[i].g.parentNode.removeChild(state.gates[i].g); }
    state.gates = [];
    clear(gParts);
    state.switches = [];
    state.leds = [];
    /* keep only rail pins in the index */
    pinIndex = pinIndex.filter(function (r) { return r.id.kind === 'rail'; });
    dropCount = 0;
    /* re-seed a default empty workbench: 2 switches + 2 leds so it's usable */
    seedDefault();
    rebuildTruthTable();
    simulate();
    flashStatus('Board cleared. Two switches and two LEDs are ready &mdash; open Components to add gates.');
    toast('Board cleared');
    var sel = document.getElementById('presetSel'); if (sel) sel.value = '';
  }

  function seedDefault() {
    drawSwitch(addSwitch('A', 0));
    drawSwitch(addSwitch('B', 0));
    drawLed(addLed('Y'));
    drawLed(addLed('Z'));
  }

  /* ============================================================= *
   *  PRESETS  --  auto-build complete working circuits           *
   * ============================================================= */
  function loadPreset(name) {
    if (!name) return;
    /* wipe everything (gates/wires/switches/leds) without re-seeding default */
    for (var i = 0; i < state.wires.length; i++) removeWireEl(state.wires[i]);
    state.wires = [];
    for (var j = 0; j < state.gates.length; j++) { if (state.gates[j].g && state.gates[j].g.parentNode) state.gates[j].g.parentNode.removeChild(state.gates[j].g); }
    state.gates = [];
    clear(gParts);
    state.switches = []; state.leds = [];
    pinIndex = pinIndex.filter(function (r) { return r.id.kind === 'rail'; });
    if (state.pending) { state.pending = null; }
    dropCount = 0;

    if (name === 'halfadder') buildHalfAdder();
    else if (name === 'fulladder') buildFullAdder();
    else if (name === 'mux21') buildMux21();
    else if (name === 'srlatch') buildSrLatch();
    else if (name === 'gatetest') buildGateTest();

    rebuildTruthTable();
    setPower(true);
    simulate();
  }

  /* helper: place switch/led/gate and return refs */
  function pSwitch(label, x, y) { var s = addSwitch(label, 0); s.x = x; s.y = y; drawSwitch(s); return s; }
  function pLed(label, x, y) { var l = addLed(label); l.x = x; l.y = y; drawLed(l); return l; }
  function pGate(type, x, y) { var g = addGate(type, x, y); drawGate(g); return g; }
  function wire(srcId, dstId) {
    var w = { id: uid('w'), from: { id: srcId }, to: { id: dstId }, color: wireColorById(srcId) };
    /* enforce single-incoming on dest */
    var dKey = pinKey(dstId);
    state.wires = state.wires.filter(function (x) { if (pinKey(x.to.id) === dKey) { removeWireEl(x); return false; } return true; });
    state.wires.push(w); drawWire(w); return w;
  }
  function wireColorById(srcId) {
    if (srcId.kind === 'rail') return srcId.ref === 'PLUS' ? '#e85d4c' : '#3a3a40';
    if (srcId.kind === 'switch') return '#e0b06a';
    return '#6fb6ff';
  }
  function swOut(s) { return { kind: 'switch', ref: s.id, pin: 0 }; }
  function gOut(g) { return { kind: 'gateOut', ref: g.id, pin: 0 }; }
  function gIn(g, p) { return { kind: 'gateIn', ref: g.id, pin: p }; }
  function ledIn(l) { return { kind: 'led', ref: l.id, pin: 0 }; }

  /* ---- HALF ADDER: S = A XOR B,  C = A AND B ---- */
  function buildHalfAdder() {
    var A = pSwitch('A', SWITCH_X, 200);
    var B = pSwitch('B', SWITCH_X, 360);
    var gX = pGate('XOR', 470, 230);
    var gA = pGate('AND', 470, 410);
    var S = pLed('S', LED_X, 230);
    var C = pLed('C', LED_X, 410);
    wire(swOut(A), gIn(gX, 0));
    wire(swOut(B), gIn(gX, 1));
    wire(swOut(A), gIn(gA, 0));
    wire(swOut(B), gIn(gA, 1));
    wire(gOut(gX), ledIn(S));
    wire(gOut(gA), ledIn(C));
    flashStatus('<b>Half Adder</b> loaded: S = A&oplus;B, C = A&middot;B. Try A=1,B=1 &rarr; S=0, C=1.');
    toast('Half Adder built');
  }

  /* ---- FULL ADDER: Sum = A xor B xor Cin,  Cout = (A.B) + (Cin.(A xor B)) ---- */
  function buildFullAdder() {
    var A = pSwitch('A', SWITCH_X, 160);
    var B = pSwitch('B', SWITCH_X, 320);
    var Ci = pSwitch('Cin', SWITCH_X, 480);
    var x1 = pGate('XOR', 400, 180);   /* A xor B */
    var x2 = pGate('XOR', 600, 250);   /* (A xor B) xor Cin = Sum */
    var a1 = pGate('AND', 400, 380);   /* A and B */
    var a2 = pGate('AND', 600, 450);   /* (A xor B) and Cin */
    var o1 = pGate('OR', 760, 415);    /* Cout */
    var S = pLed('Sum', LED_X, 230);
    var Co = pLed('Cout', LED_X, 430);
    wire(swOut(A), gIn(x1, 0));
    wire(swOut(B), gIn(x1, 1));
    wire(gOut(x1), gIn(x2, 0));
    wire(swOut(Ci), gIn(x2, 1));
    wire(gOut(x2), ledIn(S));
    wire(swOut(A), gIn(a1, 0));
    wire(swOut(B), gIn(a1, 1));
    wire(gOut(x1), gIn(a2, 0));
    wire(swOut(Ci), gIn(a2, 1));
    wire(gOut(a1), gIn(o1, 0));
    wire(gOut(a2), gIn(o1, 1));
    wire(gOut(o1), ledIn(Co));
    flashStatus('<b>Full Adder</b> loaded: Sum = A&oplus;B&oplus;Cin, Cout = AB + Cin(A&oplus;B).');
    toast('Full Adder built');
  }

  /* ---- 2:1 MUX: Y = sel ? I1 : I0 ---- */
  function buildMux21() {
    var Sel = pSwitch('Sel', SWITCH_X, 180);
    var I0 = pSwitch('I0', SWITCH_X, 340);
    var I1 = pSwitch('I1', SWITCH_X, 500);
    var m = pGate('MUX', 500, 320);
    var Y = pLed('Y', LED_X, 320);
    wire(swOut(Sel), gIn(m, 0)); /* S */
    wire(swOut(I0), gIn(m, 1));  /* I0 */
    wire(swOut(I1), gIn(m, 2));  /* I1 */
    wire(gOut(m), ledIn(Y));
    flashStatus('<b>2:1 Multiplexer</b> loaded: Y = Sel ? I1 : I0. Flip Sel to switch the source.');
    toast('2:1 MUX built');
  }

  /* ---- SR LATCH: cross-coupled NOR gates (feedback) ---- */
  function buildSrLatch() {
    var R = pSwitch('R', SWITCH_X, 200);
    var S = pSwitch('S', SWITCH_X, 420);
    var n1 = pGate('NOR', 500, 230);  /* output Q  */
    var n2 = pGate('NOR', 500, 410);  /* output Qb */
    var Q = pLed('Q', LED_X, 230);
    var Qb = pLed('Qb', LED_X, 410);
    /* n1 inputs: R, and Qb (from n2). n2 inputs: S, and Q (from n1) */
    wire(swOut(R), gIn(n1, 0));
    wire(gOut(n2), gIn(n1, 1));
    wire(swOut(S), gIn(n2, 0));
    wire(gOut(n1), gIn(n2, 1));
    wire(gOut(n1), ledIn(Q));
    wire(gOut(n2), ledIn(Qb));
    flashStatus('<b>SR Latch</b> loaded (cross-coupled NOR). Set with S=1, reset with R=1; both 0 holds state.');
    toast('SR Latch built');
  }

  /* ---- single-gate test bench ---- */
  function buildGateTest() {
    var A = pSwitch('A', SWITCH_X, 230);
    var B = pSwitch('B', SWITCH_X, 410);
    var g = pGate('NAND', 500, 320);
    var Y = pLed('Y', LED_X, 320);
    wire(swOut(A), gIn(g, 0));
    wire(swOut(B), gIn(g, 1));
    wire(gOut(g), ledIn(Y));
    flashStatus('<b>Gate test bench</b>: a NAND wired to A, B &rarr; Y. Swap the chip from Components to test any gate.');
    toast('Gate test bench built');
  }

  /* ============================================================= *
   *  WIRE-UP CONTROLS                                            *
   * ============================================================= */
  var clearWiresBtn = document.getElementById('clearWiresBtn');
  var clearBoardBtn = document.getElementById('clearBoardBtn');
  var presetSel = document.getElementById('presetSel');
  if (clearWiresBtn) clearWiresBtn.addEventListener('click', clearWires);
  if (clearBoardBtn) clearBoardBtn.addEventListener('click', clearBoard);
  if (presetSel) presetSel.addEventListener('change', function () { loadPreset(presetSel.value); });

  /* clicking empty board cancels a pending wire */
  svg.addEventListener('click', function () {
    if (state.pending) { highlightPin(state.pending, false); state.pending = null; flashStatus('Wire cancelled.'); }
  });

  /* ============================================================= *
   *  BOOTSTRAP                                                    *
   * ============================================================= */
  drawDesk();
  buildPalette();
  seedDefault();
  setPower(false);
  rebuildTruthTable();
  updateStatus();
  flashStatus('Ready. Open <b>Components</b>, drop a gate, then click an output pin and an input pin to wire it. Or load a preset.');

})();
</script>
</BaseLayout>
