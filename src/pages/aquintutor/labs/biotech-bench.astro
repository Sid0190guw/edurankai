---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Molecular Biology · Virtual Labs · AquinTutor" description="PCR amplification, gel electrophoresis, restriction digestion and enzyme kinetics — live with real models.">
<style>
  body { background:#0a0d0b; color:#e8f0ea; margin:0; font-family:ui-monospace,'Geist Mono',monospace; }
  .wrap { max-width:1240px; margin:0 auto; padding:40px 24px 96px; }
  .back { display:inline-flex; align-items:center; gap:7px; font-family:'Geist Mono',ui-monospace,monospace; font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:#9ab0a2; text-decoration:none; margin-bottom:26px; }
  .back:hover { color:#5eead4; }
  .back svg { width:14px; height:14px; }
  .eyebrow { font-family:'Geist Mono',ui-monospace,monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5eead4; font-weight:700; margin-bottom:12px; }
  h1.title { font-family:'Cormorant Garamond',Georgia,serif; font-size:clamp(34px,5vw,52px); font-weight:600; letter-spacing:-0.02em; line-height:1.05; margin:0 0 12px; }
  h1.title em { color:#86efac; font-style:italic; font-weight:500; }
  .lede { color:#9ab0a2; max-width:780px; font-size:14px; line-height:1.65; margin-bottom:26px; font-family:ui-monospace,'Geist Mono',monospace; }

  /* shell: experiment sidebar + content */
  .shell { display:grid; grid-template-columns:262px minmax(0,1fr); gap:22px; align-items:start; }
  @media (max-width:980px){ .shell { grid-template-columns:1fr; } }
  .explist { background:#101712; border:1px solid #28342b; border-radius:12px; padding:10px; position:sticky; top:18px; }
  .explist h4 { font-family:'Geist Mono',ui-monospace,monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#9ab0a2; font-weight:700; margin:6px 8px 10px; }
  .exitem { display:flex; align-items:flex-start; gap:10px; width:100%; text-align:left; background:transparent; border:1px solid transparent; color:#cbe0d2; padding:9px 10px; border-radius:8px; cursor:pointer; font-family:'Geist Mono',ui-monospace,monospace; font-size:12px; line-height:1.35; margin-bottom:2px; }
  .exitem:hover { background:#0a0d0b; color:#e8f0ea; }
  .exitem.active { background:#5eead4; color:#04201b; font-weight:700; }
  .exitem .ix { font-size:10px; opacity:0.8; min-width:18px; }
  .exitem.active .ix { opacity:0.9; }

  /* content area */
  .content { min-width:0; }
  .exptitle { font-family:'Cormorant Garamond',Georgia,serif; font-size:30px; font-weight:600; letter-spacing:-0.01em; margin:0 0 4px; color:#e8f0ea; }
  .expsub { font-family:'Geist Mono',ui-monospace,monospace; font-size:11px; color:#9ab0a2; margin:0 0 16px; letter-spacing:0.03em; }

  .tabs { display:flex; flex-wrap:wrap; gap:6px; margin-bottom:20px; border-bottom:1px solid #28342b; padding-bottom:0; }
  .tab { background:transparent; border:1px solid transparent; border-bottom:none; color:#9ab0a2; padding:9px 14px; font-family:'Geist Mono',ui-monospace,monospace; font-size:11px; letter-spacing:0.06em; text-transform:uppercase; cursor:pointer; border-radius:8px 8px 0 0; position:relative; top:1px; }
  .tab:hover { color:#e8f0ea; }
  .tab.active { color:#04201b; background:#5eead4; font-weight:700; }

  .sect { display:none; }
  .sect.active { display:block; }
  .prose { font-family:ui-monospace,'Geist Mono',monospace; font-size:13px; color:#cbe0d2; line-height:1.75; max-width:820px; }
  .prose h5 { font-family:'Geist Mono',ui-monospace,monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5eead4; font-weight:700; margin:0 0 12px; }
  .prose p { margin:0 0 14px; }
  .prose ol, .prose ul { margin:0 0 14px; padding-left:22px; }
  .prose li { margin-bottom:8px; }
  .prose strong { color:#e8f0ea; }
  .eq { background:#101712; border:1px solid #28342b; border-left:3px solid #86efac; border-radius:8px; padding:11px 14px; margin:0 0 12px; font-family:'Geist Mono',ui-monospace,monospace; font-size:12.5px; color:#fbbf24; line-height:1.7; overflow-x:auto; }
  .eq .lbl { color:#9ab0a2; }
  .refs { font-family:ui-monospace,'Geist Mono',monospace; font-size:12px; color:#cbe0d2; line-height:1.7; }
  .refs li { margin-bottom:12px; }
  .refs .who { color:#5eead4; }

  .grid { display:grid; grid-template-columns:minmax(0,1fr) 320px; gap:18px; align-items:start; }
  @media (max-width:920px){ .grid { grid-template-columns:1fr; } }
  .panel { background:#101712; border:1px solid #28342b; border-radius:12px; padding:16px; }
  .panel h3 { font-family:'Geist Mono',ui-monospace,monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5eead4; font-weight:700; margin:0 0 12px; }
  canvas { display:block; width:100%; background:#0a0d0b; border:1px solid #28342b; border-radius:10px; }
  canvas.trace { height:170px; margin-top:14px; }
  .row { display:flex; gap:10px; align-items:center; margin-bottom:13px; flex-wrap:wrap; }
  .row > label { font-family:'Geist Mono',ui-monospace,monospace; font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:#9ab0a2; min-width:84px; }
  select, input[type=range], input[type=text] { background:#0a0d0b; border:1px solid #28342b; color:#fff; padding:7px 10px; border-radius:5px; font-family:'Geist Mono',ui-monospace,monospace; font-size:12px; flex:1; }
  input[type=range] { padding:0; height:24px; accent-color:#86efac; }
  input[type=text] { width:100%; box-sizing:border-box; letter-spacing:0.08em; }
  .val { font-family:'Geist Mono',ui-monospace,monospace; font-size:12px; color:#fbbf24; min-width:58px; text-align:right; }
  .btn { background:#5eead4; color:#04201b; padding:9px 14px; border:none; border-radius:6px; font-family:'Geist Mono',ui-monospace,monospace; font-size:11px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; cursor:pointer; }
  .btn:hover { background:#7df5e2; }
  .btn.green { background:#86efac; color:#04201b; }
  .btn.green:hover { background:#a3f7c1; }
  .btn.ghost { background:transparent; color:#cbe0d2; border:1px solid #28342b; }
  .btn.ghost:hover { border-color:#5eead4; color:#5eead4; }
  .btn:disabled { opacity:0.4; cursor:not-allowed; }
  .btns { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:6px; }
  .btns .full { grid-column:1 / -1; }
  .stats { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:14px; }
  .stat { background:#0a0d0b; border:1px solid #28342b; border-radius:6px; padding:8px 10px; }
  .stat .label { font-family:'Geist Mono',ui-monospace,monospace; font-size:9px; letter-spacing:0.13em; text-transform:uppercase; color:#9ab0a2; }
  .stat .value { font-family:'Geist Mono',ui-monospace,monospace; font-size:18px; color:#86efac; font-weight:700; margin-top:2px; word-break:break-all; }
  .stat .value.cy { color:#5eead4; } .stat .value.gr { color:#86efac; } .stat .value.am { color:#fbbf24; }
  .helptext { font-family:'Geist Mono',ui-monospace,monospace; font-size:10px; color:#9ab0a2; line-height:1.7; margin-top:12px; }
  .helptext code { color:#5eead4; background:#0a0d0b; padding:1px 5px; border-radius:3px; }
  .helptext strong { color:#e8f0ea; }
  .legend { display:flex; flex-wrap:wrap; gap:12px; margin-top:12px; font-family:'Geist Mono',ui-monospace,monospace; font-size:10px; color:#cbe0d2; }
  .legend > span { display:inline-flex; align-items:center; gap:6px; }
  .dot { width:11px; height:11px; border-radius:50%; display:inline-block; }
  .seg { display:inline-flex; border:1px solid #28342b; border-radius:6px; overflow:hidden; flex-wrap:wrap; }
  .seg button { background:#0a0d0b; color:#9ab0a2; border:none; padding:7px 12px; font-family:'Geist Mono',ui-monospace,monospace; font-size:11px; cursor:pointer; }
  .seg button.on { background:#86efac; color:#04201b; font-weight:700; }
  .mono { font-family:'Geist Mono',ui-monospace,monospace; font-size:12px; color:#cbe0d2; line-height:1.85; word-break:break-all; }
  .mono b { color:#fbbf24; }
  .readout { background:#0a0d0b; border:1px solid #28342b; border-radius:8px; padding:11px 13px; margin-top:12px; font-family:'Geist Mono',ui-monospace,monospace; font-size:12px; line-height:1.8; color:#cbe0d2; }
  .readout .k { color:#9ab0a2; } .readout .v { color:#86efac; }
  .tag { display:inline-block; padding:1px 6px; border-radius:4px; font-size:10px; font-weight:700; }
  .tag.start { background:rgba(134,239,172,0.18); color:#86efac; }
  .tag.stop { background:rgba(252,165,165,0.18); color:#fca5a5; }

  /* self-assessment */
  .quiz { max-width:820px; }
  .q { background:#101712; border:1px solid #28342b; border-radius:10px; padding:14px 16px; margin-bottom:14px; }
  .q .qq { font-family:ui-monospace,'Geist Mono',monospace; font-size:13px; color:#e8f0ea; line-height:1.6; margin-bottom:10px; }
  .q .opt { display:flex; align-items:flex-start; gap:9px; padding:7px 9px; border:1px solid #28342b; border-radius:7px; margin-bottom:6px; cursor:pointer; font-family:ui-monospace,'Geist Mono',monospace; font-size:12.5px; color:#cbe0d2; }
  .q .opt:hover { border-color:#5eead4; }
  .q .opt input { accent-color:#5eead4; margin-top:2px; }
  .q .opt.correct { border-color:#86efac; background:rgba(134,239,172,0.08); color:#bbf7d0; }
  .q .opt.wrong { border-color:#fca5a5; background:rgba(252,165,165,0.08); color:#fecaca; }
  .q .expl { font-family:'Geist Mono',ui-monospace,monospace; font-size:11px; color:#9ab0a2; line-height:1.6; margin-top:8px; display:none; }
  .q .expl.show { display:block; }
  .q .expl b { color:#86efac; }
  .quizbar { display:flex; align-items:center; gap:14px; margin-top:6px; }
  .quizscore { font-family:'Geist Mono',ui-monospace,monospace; font-size:13px; color:#fbbf24; font-weight:700; }
</style>
<main class="wrap">
  <a class="back" href="/aquintutor/labs">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    All virtual labs
  </a>
  <div class="eyebrow">Lab 21 &middot; Molecular Biology</div>
  <h1 class="title">Biotech <em>Bench</em></h1>
  <p class="lede">Six hands-on molecular-biology experiments that genuinely compute the underlying biology in your browser — no precomputed answers, no libraries. A real thermal cycler amplifies DNA exponentially, fragments migrate through agarose by a true log-size mobility law, restriction enzymes scan an actual ACGT sequence for their recognition site, Michaelis-Menten kinetics are solved live, the genetic code is the real 64-codon table, and Beer-Lambert reads concentration off a fitted standard curve. Pick an experiment, read the theory, then run the live simulation on the apparatus.</p>

  <div class="shell">
    <!-- ===== EXPERIMENT SIDEBAR ===== -->
    <nav class="explist" id="explist">
      <h4>Experiments</h4>
      <button class="exitem active" data-exp="pcr"><span class="ix">01</span><span>PCR thermal cycler &amp; amplification</span></button>
      <button class="exitem" data-exp="gel"><span class="ix">02</span><span>Agarose gel electrophoresis</span></button>
      <button class="exitem" data-exp="rest"><span class="ix">03</span><span>Restriction digestion</span></button>
      <button class="exitem" data-exp="mm"><span class="ix">04</span><span>Enzyme kinetics (Michaelis-Menten)</span></button>
      <button class="exitem" data-exp="trans"><span class="ix">05</span><span>Transcription &amp; translation</span></button>
      <button class="exitem" data-exp="spec"><span class="ix">06</span><span>Spectrophotometry (Beer-Lambert)</span></button>
    </nav>

    <!-- ===== CONTENT ===== -->
    <div class="content">
      <h2 class="exptitle" id="expTitle">PCR thermal cycler and amplification</h2>
      <p class="expsub" id="expSub">Experiment 01 &middot; nucleic-acid amplification &middot; exponential doubling with plateau</p>

      <div class="tabs" id="tabs">
        <button class="tab active" data-tab="aim">Aim</button>
        <button class="tab" data-tab="theory">Theory</button>
        <button class="tab" data-tab="proc">Procedure</button>
        <button class="tab" data-tab="sim">Simulation</button>
        <button class="tab" data-tab="quiz">Self-assessment</button>
        <button class="tab" data-tab="ref">References</button>
      </div>

      <!-- ====================================================== -->
      <!-- EXP 1 : PCR                                            -->
      <!-- ====================================================== -->
      <div class="expbody" id="body-pcr">
        <div class="sect active" data-sect="aim">
          <div class="prose">
            <h5>Aim</h5>
            <p>To simulate the polymerase chain reaction on a programmable thermal cycler — running the three-step <strong>denaturation (94&deg;C) / annealing (~55&deg;C) / extension (72&deg;C)</strong> temperature profile over many cycles — and to observe how the target DNA copy number doubles each cycle, growing exponentially before saturating at a plateau as reagents are consumed.</p>
          </div>
        </div>
        <div class="sect" data-sect="theory">
          <div class="prose">
            <h5>Theory</h5>
            <p>PCR amplifies a specific DNA region using a heat-stable polymerase (Taq), two primers and a thermal cycler that repeats three temperature steps. <strong>Denaturation</strong> near 94&deg;C melts the double helix into single strands. <strong>Annealing</strong> near 55&deg;C lets the short primers bind their complementary sequences. <strong>Extension</strong> at 72&deg;C is Taq's optimum, where it synthesises the new complementary strand from the primer.</p>
            <p>Each complete cycle ideally doubles every target molecule, so after n cycles the copy number is the starting amount times two to the power n. In practice the efficiency E per cycle is below one, and the reaction plateaus once primers, dNTPs or polymerase run low.</p>
            <div class="eq"><span class="lbl">ideal yield</span>  N = N0 &middot; 2^n</div>
            <div class="eq"><span class="lbl">with efficiency</span>  N = N0 &middot; (1 + E)^n ,   0 &lt; E &le; 1</div>
            <div class="eq"><span class="lbl">plateau</span>  N saturates near a maximum N_max (reagent limit)</div>
            <p>Starting from a single molecule, 30 ideal cycles give two to the power thirty, about 1.07 billion copies — the basis of PCR's extraordinary sensitivity.</p>
          </div>
        </div>
        <div class="sect" data-sect="proc">
          <div class="prose">
            <h5>Procedure</h5>
            <ol>
              <li>Set the starting <strong>template copies</strong>, the number of <strong>cycles</strong> and the per-cycle <strong>efficiency</strong> with the sliders.</li>
              <li>Press <strong>Run program</strong> to start the cycler; watch the block temperature trace the 94 / 55 / 72 profile.</li>
              <li>The reaction tube glows brighter and the amplification chart climbs each cycle on a logarithmic axis.</li>
              <li>Read the live copy count; note where the curve bends as it approaches the plateau.</li>
              <li>Lower the efficiency to see fewer copies per cycle, or raise the cycle count to reach saturation.</li>
            </ol>
          </div>
        </div>
        <div class="sect" data-sect="sim">
          <div class="grid">
            <div class="panel">
              <h3>Thermal cycler &middot; temperature profile</h3>
              <canvas id="pcrApp" width="760" height="300"></canvas>
              <canvas id="pcrChart" class="trace" width="760" height="200"></canvas>
              <div class="helptext">The block cycles <strong>94&deg;C denature</strong> then <strong>55&deg;C anneal</strong> then <strong>72&deg;C extend</strong>. Copy number is computed as <code>N0 &middot; (1+E)^n</code> capped at the reagent plateau, plotted on a log axis.</div>
            </div>
            <div>
              <div class="panel">
                <h3>Reaction setup</h3>
                <div class="row"><label>Template N0</label><input type="range" id="pcrN0" min="0" max="6" step="1" value="0"><span class="val" id="pcrN0V">1</span></div>
                <div class="row"><label>Cycles</label><input type="range" id="pcrCyc" min="5" max="40" step="1" value="30"><span class="val" id="pcrCycV">30</span></div>
                <div class="row"><label>Efficiency</label><input type="range" id="pcrEff" min="0.5" max="1" step="0.01" value="1"><span class="val" id="pcrEffV">1.00</span></div>
                <div class="row"><label>Speed</label><input type="range" id="pcrSpd" min="1" max="10" step="1" value="5"><span class="val" id="pcrSpdV">5</span></div>
                <div class="btns">
                  <button class="btn" id="pcrRun">Run program</button>
                  <button class="btn ghost" id="pcrReset">Reset</button>
                </div>
                <div class="stats">
                  <div class="stat"><div class="label">cycle</div><div class="value cy" id="pcrCyN">0</div></div>
                  <div class="stat"><div class="label">phase</div><div class="value am" id="pcrPhase" style="font-size:13px;">idle</div></div>
                  <div class="stat"><div class="label">block temp</div><div class="value gr" id="pcrTemp" style="font-size:15px;">25.0&deg;C</div></div>
                  <div class="stat"><div class="label">copies</div><div class="value" id="pcrN" style="font-size:14px;">1</div></div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="sect" data-sect="quiz"><div class="quiz" data-quiz="pcr"></div></div>
        <div class="sect" data-sect="ref">
          <div class="prose"><h5>References</h5>
            <ul class="refs">
              <li><span class="who">Mullis, K. B.</span> &amp; Faloona, F. A. (1987) <em>Specific synthesis of DNA in vitro via a polymerase-catalyzed chain reaction.</em> Methods in Enzymology 155, 335-350.</li>
              <li><span class="who">Saiki, R. K. et al.</span> (1988) <em>Primer-directed enzymatic amplification of DNA with a thermostable DNA polymerase.</em> Science 239, 487-491.</li>
              <li><span class="who">Alberts et al.</span> <em>Molecular Biology of the Cell</em>, 6th ed., Garland Science 2014 — Ch. 8, Analyzing DNA.</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- ====================================================== -->
      <!-- EXP 2 : GEL ELECTROPHORESIS                            -->
      <!-- ====================================================== -->
      <div class="expbody" id="body-gel" style="display:none;">
        <div class="sect active" data-sect="aim">
          <div class="prose"><h5>Aim</h5>
            <p>To separate DNA fragments of different sizes on an agarose gel under an applied voltage, observe that smaller fragments migrate farther through the gel matrix, and to size an unknown band by comparing its migration against a standard DNA ladder.</p>
          </div>
        </div>
        <div class="sect" data-sect="theory">
          <div class="prose"><h5>Theory</h5>
            <p>DNA is uniformly negatively charged (phosphate backbone), so in an electric field every fragment is pulled toward the positive anode at a force proportional to its charge. But the agarose gel is a molecular sieve: longer fragments are retarded more by the mesh. The result is that migration distance falls roughly linearly with the logarithm of fragment size — <strong>smaller fragments travel farther</strong>.</p>
            <div class="eq"><span class="lbl">mobility</span>  d &prop; -log10(L)   (L = length in base pairs)</div>
            <div class="eq"><span class="lbl">model</span>  d = a - b &middot; log10(L) ,  then d &times; (V / V0) &times; (t / t0)</div>
            <p>A DNA ladder of known sizes is run alongside the samples; plotting log10(size) against migration distance gives a calibration curve from which any unknown band's size can be read by interpolation.</p>
          </div>
        </div>
        <div class="sect" data-sect="proc">
          <div class="prose"><h5>Procedure</h5>
            <ol>
              <li>Enter fragment sizes (in base pairs) for your sample lane, comma-separated, or use the preset.</li>
              <li>Set the <strong>voltage</strong> and press <strong>Run</strong> to apply the field; bands migrate down their lanes over time.</li>
              <li>The first lane is a <strong>DNA ladder</strong> of known sizes for calibration.</li>
              <li>When the run finishes, click any band to read its estimated size (from the ladder calibration) versus its true size.</li>
              <li>Raise the voltage to speed migration; note that band order by size never changes.</li>
            </ol>
          </div>
        </div>
        <div class="sect" data-sect="sim">
          <div class="grid">
            <div class="panel">
              <h3>Agarose gel tank</h3>
              <canvas id="gelApp" width="760" height="520"></canvas>
              <div class="helptext"><strong>Click a band</strong> after the run to size it against the ladder. Migration uses <code>d = a - b&middot;log10(bp)</code> scaled by voltage and time — smaller fragments run farther toward the anode.</div>
            </div>
            <div>
              <div class="panel">
                <h3>Sample &amp; field</h3>
                <div class="row"><label>Fragments bp</label><input type="text" id="gelSizes" value="3000, 1500, 800, 400"></div>
                <div class="row"><label>Unknown bp</label><input type="range" id="gelUnk" min="100" max="5000" step="50" value="1100"><span class="val" id="gelUnkV">1100</span></div>
                <div class="row"><label>Voltage</label><input type="range" id="gelV" min="40" max="150" step="5" value="100"><span class="val" id="gelVV">100 V</span></div>
                <div class="btns">
                  <button class="btn" id="gelRun">Run</button>
                  <button class="btn ghost" id="gelReset">Reset</button>
                </div>
                <div class="readout" id="gelRead">Click a band after the run to estimate its size.</div>
              </div>
            </div>
          </div>
        </div>
        <div class="sect" data-sect="quiz"><div class="quiz" data-quiz="gel"></div></div>
        <div class="sect" data-sect="ref">
          <div class="prose"><h5>References</h5>
            <ul class="refs">
              <li><span class="who">Sambrook, J.</span> &amp; Russell, D. W. <em>Molecular Cloning: A Laboratory Manual</em>, 3rd ed., CSHL Press 2001 — Ch. 5, Gel Electrophoresis of DNA.</li>
              <li><span class="who">Helling, R. B. et al.</span> (1974) <em>Analysis of endonuclease R-EcoRI fragments of DNA from lambda by agarose gel electrophoresis.</em> J. Virology 14, 1235-1244.</li>
              <li><span class="who">Lee, P. Y. et al.</span> (2012) <em>Agarose gel electrophoresis for the separation of DNA fragments.</em> J. Visualized Experiments 62, e3923.</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- ====================================================== -->
      <!-- EXP 3 : RESTRICTION DIGESTION                          -->
      <!-- ====================================================== -->
      <div class="expbody" id="body-rest" style="display:none;">
        <div class="sect active" data-sect="aim">
          <div class="prose"><h5>Aim</h5>
            <p>To digest a DNA sequence with a chosen restriction endonuclease — scanning the sequence for the enzyme's recognition site, locating every cut, computing the resulting fragment sizes, and displaying them as a predicted agarose-gel banding pattern.</p>
          </div>
        </div>
        <div class="sect" data-sect="theory">
          <div class="prose"><h5>Theory</h5>
            <p>Restriction endonucleases are bacterial enzymes that recognise short, usually palindromic DNA sequences and cleave the backbone at a defined position within or near them. <strong>EcoRI</strong> recognises <strong>GAATTC</strong> and cuts between G and A, leaving 5' overhangs (sticky ends). Different enzymes have different sites and cut frequencies.</p>
            <div class="eq"><span class="lbl">EcoRI</span>  5'-G^AATTC-3'   (cuts after position 1)</div>
            <div class="eq"><span class="lbl">fragments</span>  positions sorted; sizes = gaps between successive cuts</div>
            <p>For a linear molecule with k cut sites you obtain k+1 fragments; for a circular plasmid you obtain k fragments. The fragment sizes sum to the total length, and running them on a gel gives a fingerprint used to map and verify constructs.</p>
          </div>
        </div>
        <div class="sect" data-sect="proc">
          <div class="prose"><h5>Procedure</h5>
            <ol>
              <li>Enter or generate a DNA sequence (letters A, C, G, T only).</li>
              <li>Pick a restriction enzyme; its recognition site and cut offset are shown.</li>
              <li>Press <strong>Digest</strong>; every recognition site is highlighted and the molecule is cut.</li>
              <li>Read the fragment sizes and see them rendered as predicted gel bands.</li>
              <li>Switch enzymes to compare cut frequencies and fragment patterns.</li>
            </ol>
          </div>
        </div>
        <div class="sect" data-sect="sim">
          <div class="grid">
            <div class="panel">
              <h3>Sequence map &amp; predicted gel</h3>
              <canvas id="restApp" width="760" height="360"></canvas>
              <div class="mono" id="restSeq" style="margin-top:12px;"></div>
              <div class="helptext">The enzyme scans the sequence for its recognition site and cuts at the defined offset. Fragment sizes are the gaps between successive cut positions and are drawn as a predicted gel.</div>
            </div>
            <div>
              <div class="panel">
                <h3>Digest setup</h3>
                <div class="row"><label>Enzyme</label>
                  <select id="restEnz">
                    <option value="EcoRI">EcoRI (GAATTC)</option>
                    <option value="BamHI">BamHI (GGATCC)</option>
                    <option value="HindIII">HindIII (AAGCTT)</option>
                    <option value="PstI">PstI (CTGCAG)</option>
                    <option value="NotI">NotI (GCGGCCGC)</option>
                    <option value="AluI">AluI (AGCT)</option>
                  </select>
                </div>
                <div class="row"><label>Topology</label>
                  <div class="seg" id="restTopo">
                    <button class="on" data-topo="linear">Linear</button>
                    <button data-topo="circular">Circular</button>
                  </div>
                </div>
                <div class="row"><label>Length bp</label><input type="range" id="restLen" min="40" max="400" step="20" value="200"><span class="val" id="restLenV">200</span></div>
                <div class="btns">
                  <button class="btn full" id="restGen">Generate sequence</button>
                  <button class="btn green" id="restDigest">Digest</button>
                  <button class="btn ghost" id="restClear">Clear</button>
                </div>
                <div class="readout" id="restRead">Generate a sequence, then digest.</div>
              </div>
            </div>
          </div>
        </div>
        <div class="sect" data-sect="quiz"><div class="quiz" data-quiz="rest"></div></div>
        <div class="sect" data-sect="ref">
          <div class="prose"><h5>References</h5>
            <ul class="refs">
              <li><span class="who">Smith, H. O.</span> &amp; Wilcox, K. W. (1970) <em>A restriction enzyme from Hemophilus influenzae.</em> J. Molecular Biology 51, 379-391.</li>
              <li><span class="who">Roberts, R. J. et al.</span> (2015) <em>REBASE — a database for DNA restriction and modification.</em> Nucleic Acids Research 43, D298-D299.</li>
              <li><span class="who">Watson et al.</span> <em>Molecular Biology of the Gene</em>, 7th ed., Pearson 2014 — restriction mapping.</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- ====================================================== -->
      <!-- EXP 4 : MICHAELIS-MENTEN                               -->
      <!-- ====================================================== -->
      <div class="expbody" id="body-mm" style="display:none;">
        <div class="sect active" data-sect="aim">
          <div class="prose"><h5>Aim</h5>
            <p>To study enzyme kinetics under the Michaelis-Menten model — plotting the reaction velocity against substrate concentration as a saturating hyperbola and as a Lineweaver-Burk double-reciprocal line — and to see how competitive and non-competitive inhibitors shift the apparent Vmax and Km.</p>
          </div>
        </div>
        <div class="sect" data-sect="theory">
          <div class="prose"><h5>Theory</h5>
            <p>The Michaelis-Menten equation describes the initial rate of a single-substrate enzyme reaction. At low substrate the rate rises almost linearly; as substrate saturates the enzyme the rate approaches its maximum, <strong>Vmax</strong>. The <strong>Km</strong> is the substrate concentration at which the rate is half of Vmax, an inverse measure of affinity.</p>
            <div class="eq"><span class="lbl">velocity</span>  v = Vmax &middot; [S] / (Km + [S])</div>
            <div class="eq"><span class="lbl">Lineweaver-Burk</span>  1/v = (Km / Vmax) &middot; (1/[S]) + 1/Vmax</div>
            <p>The double-reciprocal plot is a straight line: the y-intercept is 1/Vmax and the x-intercept is -1/Km. A <strong>competitive</strong> inhibitor raises the apparent Km (lines cross on the y-axis, same Vmax); a <strong>non-competitive</strong> inhibitor lowers the apparent Vmax (lines cross on the x-axis, same Km).</p>
            <div class="eq"><span class="lbl">competitive</span>  Km_app = Km &middot; (1 + [I]/Ki)</div>
            <div class="eq"><span class="lbl">non-competitive</span>  Vmax_app = Vmax / (1 + [I]/Ki)</div>
          </div>
        </div>
        <div class="sect" data-sect="proc">
          <div class="prose"><h5>Procedure</h5>
            <ol>
              <li>Set <strong>Vmax</strong> and <strong>Km</strong> with the sliders; the hyperbola and Lineweaver-Burk line redraw instantly.</li>
              <li>Move the <strong>[S]</strong> marker to read the velocity at any substrate concentration.</li>
              <li>Choose an inhibitor type and set <strong>[I]/Ki</strong> to add inhibition; watch the curve shift.</li>
              <li>Confirm the y-intercept of the double-reciprocal plot gives 1/Vmax and the x-intercept gives -1/Km.</li>
              <li>Compare how competitive versus non-competitive inhibition changes the apparent parameters.</li>
            </ol>
          </div>
        </div>
        <div class="sect" data-sect="sim">
          <div class="grid">
            <div class="panel">
              <h3>v vs [S] hyperbola</h3>
              <canvas id="mmHyp" width="760" height="380"></canvas>
              <h3 style="margin-top:16px;">Lineweaver-Burk (1/v vs 1/[S])</h3>
              <canvas id="mmLb" width="760" height="320"></canvas>
              <div class="helptext">Both plots are computed from <code>v = Vmax[S]/(Km+[S])</code>. The dashed grey curve is the uninhibited reference; the green curve includes the selected inhibition.</div>
            </div>
            <div>
              <div class="panel">
                <h3>Kinetic parameters</h3>
                <div class="row"><label>Vmax</label><input type="range" id="mmVmax" min="20" max="200" step="5" value="100"><span class="val" id="mmVmaxV">100</span></div>
                <div class="row"><label>Km</label><input type="range" id="mmKm" min="5" max="120" step="1" value="40"><span class="val" id="mmKmV">40</span></div>
                <div class="row"><label>[S] marker</label><input type="range" id="mmS" min="1" max="400" step="1" value="40"><span class="val" id="mmSV">40</span></div>
                <div class="row"><label>Inhibitor</label>
                  <div class="seg" id="mmInh">
                    <button class="on" data-inh="none">None</button>
                    <button data-inh="comp">Comp.</button>
                    <button data-inh="noncomp">Non-comp.</button>
                  </div>
                </div>
                <div class="row"><label>[I] / Ki</label><input type="range" id="mmI" min="0" max="5" step="0.1" value="0"><span class="val" id="mmIV">0.0</span></div>
                <div class="stats">
                  <div class="stat"><div class="label">v at [S]</div><div class="value cy" id="mmV">--</div></div>
                  <div class="stat"><div class="label">v / Vmax</div><div class="value am" id="mmFrac">--</div></div>
                  <div class="stat"><div class="label">Km app</div><div class="value gr" id="mmKmApp">--</div></div>
                  <div class="stat"><div class="label">Vmax app</div><div class="value gr" id="mmVmaxApp">--</div></div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="sect" data-sect="quiz"><div class="quiz" data-quiz="mm"></div></div>
        <div class="sect" data-sect="ref">
          <div class="prose"><h5>References</h5>
            <ul class="refs">
              <li><span class="who">Michaelis, L.</span> &amp; Menten, M. L. (1913) <em>Die Kinetik der Invertinwirkung.</em> Biochem. Z. 49, 333-369.</li>
              <li><span class="who">Lineweaver, H.</span> &amp; Burk, D. (1934) <em>The determination of enzyme dissociation constants.</em> J. Am. Chem. Soc. 56, 658-666.</li>
              <li><span class="who">Nelson &amp; Cox.</span> <em>Lehninger Principles of Biochemistry</em>, 7th ed., W. H. Freeman 2017 — Ch. 6, Enzymes.</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- ====================================================== -->
      <!-- EXP 5 : TRANSCRIPTION & TRANSLATION                    -->
      <!-- ====================================================== -->
      <div class="expbody" id="body-trans" style="display:none;">
        <div class="sect active" data-sect="aim">
          <div class="prose"><h5>Aim</h5>
            <p>To carry out the central dogma in silico — transcribing a DNA template strand into messenger RNA, then translating the mRNA codon-by-codon into a protein using the real standard genetic code, while highlighting the start codon and stop codons.</p>
          </div>
        </div>
        <div class="sect" data-sect="theory">
          <div class="prose"><h5>Theory</h5>
            <p>In <strong>transcription</strong>, RNA polymerase reads the DNA template strand 3' to 5' and builds an mRNA that is complementary to it and identical to the coding strand except that thymine (T) is replaced by uracil (U). In <strong>translation</strong>, the ribosome reads the mRNA in non-overlapping triplets called codons; each codon specifies one amino acid via the genetic code.</p>
            <div class="eq"><span class="lbl">base pairing</span>  A-U ,  T-A ,  G-C ,  C-G  (DNA template to mRNA)</div>
            <div class="eq"><span class="lbl">start codon</span>  AUG = Methionine (Met, M)</div>
            <div class="eq"><span class="lbl">stop codons</span>  UAA , UAG , UGA  (no amino acid; release)</div>
            <p>The code is degenerate (64 codons, 20 amino acids) and nearly universal. Translation begins at the first AUG and continues in that reading frame until a stop codon is reached.</p>
          </div>
        </div>
        <div class="sect" data-sect="proc">
          <div class="prose"><h5>Procedure</h5>
            <ol>
              <li>Enter a DNA coding sequence (A, C, G, T) or generate one with a start and stop codon.</li>
              <li>Press <strong>Transcribe</strong> to produce the mRNA (T becomes U).</li>
              <li>Press <strong>Translate</strong> to read codons from the first AUG and look up each amino acid.</li>
              <li>The start codon is tagged green and stop codons red; the protein sequence is listed in three-letter and one-letter codes.</li>
              <li>Edit the sequence to introduce a premature stop and watch the protein truncate.</li>
            </ol>
          </div>
        </div>
        <div class="sect" data-sect="sim">
          <div class="grid">
            <div class="panel">
              <h3>Central dogma</h3>
              <div class="readout" id="trDna" style="margin-top:0;"></div>
              <div class="readout" id="trMrna"></div>
              <canvas id="trApp" width="760" height="150" style="margin-top:12px;"></canvas>
              <div class="readout" id="trProt"></div>
              <div class="helptext">Codons are read from the first <code>AUG</code> in frame until a stop. The 64-codon lookup is the real standard genetic code; <span class="tag start">start</span> and <span class="tag stop">stop</span> codons are tagged.</div>
            </div>
            <div>
              <div class="panel">
                <h3>Sequence</h3>
                <div class="row"><label>DNA coding</label><input type="text" id="trSeq" value="ATGGCCAGTTGGTAA"></div>
                <div class="row"><label>Random len</label><input type="range" id="trLen" min="5" max="40" step="1" value="12"><span class="val" id="trLenV">12 aa</span></div>
                <div class="btns">
                  <button class="btn full" id="trRandom">Random ORF</button>
                  <button class="btn" id="trTranscribe">Transcribe</button>
                  <button class="btn green" id="trTranslate">Translate</button>
                </div>
                <div class="stats">
                  <div class="stat"><div class="label">mRNA length</div><div class="value cy" id="trLenN">--</div></div>
                  <div class="stat"><div class="label">codons</div><div class="value am" id="trCod">--</div></div>
                  <div class="stat"><div class="label">amino acids</div><div class="value gr" id="trAa">--</div></div>
                  <div class="stat"><div class="label">stop at</div><div class="value" id="trStop">--</div></div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="sect" data-sect="quiz"><div class="quiz" data-quiz="trans"></div></div>
        <div class="sect" data-sect="ref">
          <div class="prose"><h5>References</h5>
            <ul class="refs">
              <li><span class="who">Crick, F.</span> (1970) <em>Central dogma of molecular biology.</em> Nature 227, 561-563.</li>
              <li><span class="who">Nirenberg, M.</span> &amp; Leder, P. (1964) <em>RNA codewords and protein synthesis.</em> Science 145, 1399-1407.</li>
              <li><span class="who">Alberts et al.</span> <em>Molecular Biology of the Cell</em>, 6th ed., Garland Science 2014 — Ch. 6, From DNA to Protein.</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- ====================================================== -->
      <!-- EXP 6 : SPECTROPHOTOMETRY                              -->
      <!-- ====================================================== -->
      <div class="expbody" id="body-spec" style="display:none;">
        <div class="sect active" data-sect="aim">
          <div class="prose"><h5>Aim</h5>
            <p>To measure the absorbance of a coloured solution in a spectrophotometer, verify the Beer-Lambert law that absorbance is proportional to concentration and path length, build a standard calibration curve from known standards, and read an unknown sample's concentration off that line.</p>
          </div>
        </div>
        <div class="sect" data-sect="theory">
          <div class="prose"><h5>Theory</h5>
            <p>A spectrophotometer passes monochromatic light of intensity I0 through a cuvette of solution and measures the transmitted intensity I. Some light is absorbed by the analyte. <strong>Absorbance</strong> is the logarithm of the ratio of incident to transmitted light, and by the <strong>Beer-Lambert law</strong> it is proportional to the molar absorptivity, the concentration and the path length.</p>
            <div class="eq"><span class="lbl">transmittance</span>  T = I / I0</div>
            <div class="eq"><span class="lbl">absorbance</span>  A = -log10(T) = log10(I0 / I)</div>
            <div class="eq"><span class="lbl">Beer-Lambert</span>  A = &epsilon; &middot; c &middot; l</div>
            <p>Because A is linear in c, a set of known standards gives a straight calibration line A = (&epsilon; l) c through the origin. The unknown's concentration is its absorbance divided by the line's slope. The law holds best at low absorbance (below about A = 1).</p>
          </div>
        </div>
        <div class="sect" data-sect="proc">
          <div class="prose"><h5>Procedure</h5>
            <ol>
              <li>Set the molar absorptivity <strong>&epsilon;</strong> and the cuvette <strong>path length l</strong>.</li>
              <li>Adjust the sample <strong>concentration</strong>; the cuvette tints and the detector shows transmittance and absorbance.</li>
              <li>Press <strong>Read standard</strong> at several concentrations to plot calibration points.</li>
              <li>Fit the line, then enter an unknown absorbance to read back its concentration.</li>
              <li>Push the concentration high and observe the transmitted light fall toward zero as absorbance climbs.</li>
            </ol>
          </div>
        </div>
        <div class="sect" data-sect="sim">
          <div class="grid">
            <div class="panel">
              <h3>Spectrophotometer</h3>
              <canvas id="spApp" width="760" height="260"></canvas>
              <h3 style="margin-top:16px;">Standard calibration curve</h3>
              <canvas id="spCal" width="760" height="300"></canvas>
              <div class="helptext">Absorbance is computed as <code>A = &epsilon;&middot;c&middot;l</code> and transmittance as <code>10^(-A)</code>. Each <strong>Read standard</strong> drops a calibration point; the fitted slope is &epsilon;&middot;l.</div>
            </div>
            <div>
              <div class="panel">
                <h3>Instrument &amp; sample</h3>
                <div class="row"><label>&epsilon; (1/M/cm)</label><input type="range" id="spEps" min="2000" max="20000" step="500" value="6000"><span class="val" id="spEpsV">6000</span></div>
                <div class="row"><label>Path l (cm)</label><input type="range" id="spL" min="0.5" max="2" step="0.1" value="1"><span class="val" id="spLV">1.0</span></div>
                <div class="row"><label>Conc (uM)</label><input type="range" id="spC" min="0" max="200" step="2" value="60"><span class="val" id="spCV">60</span></div>
                <div class="btns">
                  <button class="btn" id="spRead">Read standard</button>
                  <button class="btn ghost" id="spClear">Clear curve</button>
                </div>
                <div class="row" style="margin-top:12px;"><label>Unknown A</label><input type="range" id="spUnk" min="0.05" max="1.5" step="0.01" value="0.4"><span class="val" id="spUnkV">0.40</span></div>
                <div class="stats">
                  <div class="stat"><div class="label">absorbance A</div><div class="value cy" id="spA">--</div></div>
                  <div class="stat"><div class="label">transmittance</div><div class="value am" id="spT">--</div></div>
                  <div class="stat"><div class="label">fit slope &epsilon;l</div><div class="value gr" id="spSlope">--</div></div>
                  <div class="stat"><div class="label">unknown conc</div><div class="value" id="spConc">--</div></div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="sect" data-sect="quiz"><div class="quiz" data-quiz="spec"></div></div>
        <div class="sect" data-sect="ref">
          <div class="prose"><h5>References</h5>
            <ul class="refs">
              <li><span class="who">Beer, A.</span> (1852) <em>Bestimmung der Absorption des rothen Lichts in farbigen Fluessigkeiten.</em> Annalen der Physik 162, 78-88.</li>
              <li><span class="who">Swinehart, D. F.</span> (1962) <em>The Beer-Lambert law.</em> J. Chemical Education 39, 333-335.</li>
              <li><span class="who">Harris, D. C.</span> <em>Quantitative Chemical Analysis</em>, 9th ed., W. H. Freeman 2016 — Ch. 17, Fundamentals of Spectrophotometry.</li>
            </ul>
          </div>
        </div>
      </div>

    </div>
  </div>
</main>

<script is:inline>
(function(){
  "use strict";

  // ---------- shared helpers ----------
  function rnd(a, b){ return a + Math.random() * (b - a); }
  function clamp(x, lo, hi){ return x < lo ? lo : (x > hi ? hi : x); }
  function fmt(x, d){ if (x == null || !isFinite(x)) return "--"; return x.toFixed(d == null ? 3 : d); }
  function el(id){ return document.getElementById(id); }
  function commaNum(n){
    if (n == null || !isFinite(n)) return "--";
    if (n >= 1e9) return (n / 1e9).toFixed(2) + "e9";
    if (n >= 1e6) return (n / 1e6).toFixed(2) + "e6";
    if (n >= 1e3){
      var s = Math.round(n).toString(), out = "", c = 0;
      for (var i = s.length - 1; i >= 0; i--){ out = s.charAt(i) + out; if (++c % 3 === 0 && i > 0) out = "," + out; }
      return out;
    }
    return Math.round(n).toString();
  }
  function evtXY(canvas, e){
    var r = canvas.getBoundingClientRect();
    return { x: (e.clientX - r.left) * (canvas.width / r.width), y: (e.clientY - r.top) * (canvas.height / r.height) };
  }

  var EXP_META = {
    pcr:   ["PCR thermal cycler and amplification", "Experiment 01 · nucleic-acid amplification · exponential doubling with plateau"],
    gel:   ["Agarose gel electrophoresis", "Experiment 02 · separation by size · log-mobility migration"],
    rest:  ["Restriction digestion", "Experiment 03 · sequence scan · recognition site &amp; fragment sizing"],
    mm:    ["Enzyme kinetics (Michaelis-Menten)", "Experiment 04 · saturation kinetics · Lineweaver-Burk &amp; inhibition"],
    trans: ["Transcription and translation", "Experiment 05 · central dogma · real 64-codon genetic code"],
    spec:  ["Spectrophotometry (Beer-Lambert)", "Experiment 06 · A = εcl · standard curve &amp; readout"]
  };
  var EXP_IDS = ["pcr","gel","rest","mm","trans","spec"];

  // ---------- experiment (sidebar) switching ----------
  var explist = el("explist").querySelectorAll(".exitem");
  var bodies = {};
  EXP_IDS.forEach(function(id){ bodies[id] = el("body-" + id); });

  function onShow(id){
    if (id === "pcr") PCR.draw();
    if (id === "gel") GEL.draw();
    if (id === "rest") REST.draw();
    if (id === "mm") MM.draw();
    if (id === "trans") TRANS.render();
    if (id === "spec") SPEC.draw();
  }

  function switchExp(id){
    for (var k in bodies) bodies[k].style.display = (k === id) ? "block" : "none";
    for (var i = 0; i < explist.length; i++) explist[i].classList.toggle("active", explist[i].getAttribute("data-exp") === id);
    var m = EXP_META[id];
    el("expTitle").textContent = m[0];
    el("expSub").innerHTML = m[1];
    resetSections(id);
    onShow(id);
  }
  for (var e = 0; e < explist.length; e++){
    (function(btn){ btn.addEventListener("click", function(){ switchExp(btn.getAttribute("data-exp")); }); })(explist[e]);
  }

  // ---------- section (tab) switching ----------
  var tabs = el("tabs").querySelectorAll(".tab");
  function currentExp(){ for (var k in bodies) if (bodies[k].style.display !== "none") return k; return "pcr"; }
  function showSection(name){
    var id = currentExp();
    var body = bodies[id];
    var sects = body.querySelectorAll(".sect");
    for (var i = 0; i < sects.length; i++) sects[i].classList.toggle("active", sects[i].getAttribute("data-sect") === name);
    for (var t = 0; t < tabs.length; t++) tabs[t].classList.toggle("active", tabs[t].getAttribute("data-tab") === name);
    if (name === "sim") onShow(id);
    if (name === "quiz") buildQuiz(id);
  }
  function resetSections(id){
    var body = bodies[id];
    var sects = body.querySelectorAll(".sect");
    for (var i = 0; i < sects.length; i++) sects[i].classList.toggle("active", sects[i].getAttribute("data-sect") === "aim");
    for (var t = 0; t < tabs.length; t++) tabs[t].classList.toggle("active", tabs[t].getAttribute("data-tab") === "aim");
  }
  for (var ti = 0; ti < tabs.length; ti++){
    (function(tb){ tb.addEventListener("click", function(){ showSection(tb.getAttribute("data-tab")); }); })(tabs[ti]);
  }

  // ======================================================================
  // SELF-ASSESSMENT QUIZZES
  // ======================================================================
  var QUIZ = {
    pcr: [
      { q: "Starting from a single template molecule, how many copies result from 30 ideal PCR cycles?",
        opts: ["About 30", "About 900", "About 2^30, roughly 1.07 billion", "Exactly 60"],
        a: 2, ex: "Each cycle doubles the target, so N = 1 x 2^30 which is about 1.07e9 copies." },
      { q: "At which step does the heat-stable polymerase synthesise the new strand?",
        opts: ["Denaturation at 94 C", "Annealing at 55 C", "Extension at 72 C", "It works at every step equally"],
        a: 2, ex: "Taq polymerase has its optimum near 72 C, where extension occurs." },
      { q: "Why does real PCR eventually plateau instead of doubling forever?",
        opts: ["The DNA degrades to nothing", "Primers, dNTPs and polymerase become limiting", "The temperature stops cycling", "Templates anneal to themselves permanently"],
        a: 1, ex: "As reagents are consumed, efficiency drops and the curve saturates near a reagent-limited maximum." },
      { q: "What is the purpose of the annealing step near 55 C?",
        opts: ["To melt the double helix", "To let the primers bind their complementary target", "To inactivate the polymerase", "To denature the primers"],
        a: 1, ex: "At the annealing temperature the short primers hybridise to the single-stranded template." }
    ],
    gel: [
      { q: "In agarose gel electrophoresis, which fragments migrate the farthest?",
        opts: ["The largest fragments", "The smallest fragments", "All fragments migrate equally", "Only circular DNA"],
        a: 1, ex: "The gel sieves larger molecules more, so smaller fragments travel farther toward the anode." },
      { q: "DNA migrates toward the positive electrode because it is:",
