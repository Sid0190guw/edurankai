  var quizBuilt = {};
  function buildQuiz(id){
    if (quizBuilt[id]) return;
    var host = bodies[id].querySelector(".quiz");
    if (!host) return;
    var qs = QUIZ[id]; var html = "";
    for (var i = 0; i < qs.length; i++){
      html += '<div class="q" data-qi="' + i + '"><div class="qq">' + (i + 1) + ". " + qs[i].q + '</div>';
      for (var j = 0; j < qs[i].opts.length; j++){
        html += '<label class="opt"><input type="radio" name="' + id + '_q' + i + '" value="' + j + '"><span>' + qs[i].opts[j] + '</span></label>';
      }
      html += '<div class="expl"></div></div>';
    }
    html += '<div class="quizbar"><button class="btn" data-check="' + id + '">Check answers</button><span class="quizscore" data-score="' + id + '"></span></div>';
    host.innerHTML = html;
    host.querySelector('[data-check="' + id + '"]').addEventListener("click", function(){ checkQuiz(id, host); });
    quizBuilt[id] = true;
  }
  function checkQuiz(id, host){
    var qs = QUIZ[id]; var correct = 0;
    var blocks = host.querySelectorAll(".q");
    for (var i = 0; i < blocks.length; i++){
      var opts = blocks[i].querySelectorAll(".opt");
      var chosen = -1;
      for (var j = 0; j < opts.length; j++){
        opts[j].classList.remove("correct", "wrong");
        var radio = opts[j].querySelector("input");
        if (radio.checked) chosen = j;
      }
      for (var k = 0; k < opts.length; k++){
        if (k === qs[i].a) opts[k].classList.add("correct");
        else if (k === chosen) opts[k].classList.add("wrong");
      }
      if (chosen === qs[i].a) correct++;
      var ex = blocks[i].querySelector(".expl");
      ex.innerHTML = "<b>" + (chosen === qs[i].a ? "Correct." : "Answer: " + (qs[i].a + 1) + ".") + "</b> " + qs[i].ex;
      ex.classList.add("show");
    }
    host.querySelector('[data-score="' + id + '"]').textContent = "Score: " + correct + " / " + qs.length;
  }

  // ======================================================================
  // 1. PCR THERMAL CYCLER
  // ======================================================================
  var PCR = (function(){
    var app = el("pcrApp"), actx = app.getContext("2d");
    var ch = el("pcrChart"), cctx = ch.getContext("2d");
    var AW = app.width, AH = app.height, CW = ch.width, CH = ch.height;
    var N0 = 1, cycles = 30, eff = 1.0, speed = 5;
    var running = false, raf = null;
    var phaseIdx = 0;            // 0 denature, 1 anneal, 2 extend
    var phaseT = 0;             // 0..1 within a phase
    var curCycle = 0;
    var blockTemp = 25;
    var copies = 1;
    var tempHist = [];          // {t, temp}
    var copyHist = [];          // copies after each completed cycle
    var elapsed = 0;
    var PHASES = [
      { name: "denature", target: 94, col: "#fca5a5" },
      { name: "anneal", target: 55, col: "#93c5fd" },
      { name: "extend", target: 72, col: "#86efac" }
    ];

    function plateau(){ return N0 * Math.pow(2, 35); } // reagent-limited ceiling

    function readControls(){
      N0 = Math.round(Math.pow(10, parseFloat(el("pcrN0").value)));
      el("pcrN0V").textContent = commaNum(N0);
      cycles = parseInt(el("pcrCyc").value, 10); el("pcrCycV").textContent = cycles;
      eff = parseFloat(el("pcrEff").value); el("pcrEffV").textContent = fmt(eff, 2);
      speed = parseInt(el("pcrSpd").value, 10); el("pcrSpdV").textContent = speed;
    }

    function reset(){
      stop();
      readControls();
      curCycle = 0; phaseIdx = 0; phaseT = 0; blockTemp = 25; copies = N0;
      tempHist = []; copyHist = [copies]; elapsed = 0;
      updateStats(); draw();
    }

    function targetCopiesAfter(n){
      var ideal = N0 * Math.pow(1 + eff, n);
      var cap = plateau();
      return ideal > cap ? cap : ideal;
    }

    function updateStats(){
      el("pcrCyN").textContent = curCycle + " / " + cycles;
      el("pcrPhase").textContent = running ? PHASES[phaseIdx].name : "idle";
      el("pcrTemp").textContent = fmt(blockTemp, 1) + "°C";
      el("pcrN").textContent = commaNum(copies);
    }

    function tick(){
      if (!running) return;
      var dt = 0.012 * speed;
      phaseT += dt;
      var tgt = PHASES[phaseIdx].target;
      blockTemp += (tgt - blockTemp) * 0.18; // approach target
      elapsed += dt;
      tempHist.push({ t: elapsed, temp: blockTemp });
      if (tempHist.length > 1400) tempHist.shift();
      if (phaseT >= 1){
        phaseT = 0; phaseIdx++;
        if (phaseIdx > 2){
          phaseIdx = 0; curCycle++;
          copies = targetCopiesAfter(curCycle);
          copyHist.push(copies);
          if (curCycle >= cycles){ stop(); el("pcrPhase").textContent = "done"; }
        }
      }
      updateStats(); draw();
      if (running) raf = requestAnimationFrame(tick);
    }

    function run(){ if (running) return; if (curCycle >= cycles) reset(); running = true; updateStats(); raf = requestAnimationFrame(tick); }
    function stop(){ running = false; if (raf) cancelAnimationFrame(raf); raf = null; }

    function drawApparatus(){
      actx.clearRect(0, 0, AW, AH);
      actx.fillStyle = "#0a0d0b"; actx.fillRect(0, 0, AW, AH);
      // thermal block (left)
      var bx = 30, by = 40, bw = 300, bh = 220;
      var tcol = blockTemp > 80 ? "#fca5a5" : (blockTemp > 65 ? "#86efac" : (blockTemp > 45 ? "#93c5fd" : "#3a4a40"));
      actx.fillStyle = "#15211a"; actx.strokeStyle = "#2a3a30"; actx.lineWidth = 2;
      actx.fillRect(bx, by, bw, bh); actx.strokeRect(bx, by, bw, bh);
      actx.fillStyle = "#9ab0a2"; actx.font = "11px ui-monospace, monospace";
      actx.fillText("THERMAL BLOCK", bx + 10, by - 12);
      // wells with tubes
      var glow = clamp((blockTemp - 30) / 70, 0, 1);
      for (var r = 0; r < 2; r++){
        for (var c = 0; c < 4; c++){
          var wx = bx + 34 + c * 62, wy = by + 50 + r * 95;
          actx.fillStyle = "#0a0d0b"; actx.beginPath(); actx.ellipse(wx, wy, 18, 9, 0, 0, Math.PI * 2); actx.fill();
          // tube
          actx.fillStyle = tcol; actx.globalAlpha = 0.25 + 0.55 * glow;
          actx.beginPath();
          actx.moveTo(wx - 13, wy);
          actx.lineTo(wx + 13, wy);
          actx.lineTo(wx + 7, wy + 52);
          actx.lineTo(wx - 7, wy + 52);
          actx.closePath(); actx.fill();
          actx.globalAlpha = 1;
          actx.strokeStyle = "#3a4a40"; actx.lineWidth = 1.2; actx.stroke();
        }
      }
      // big reaction tube + DNA fill (right) showing accumulation
      var frac = clamp(Math.log(copies) / Math.log(plateau()), 0, 1);
      var tx = 470, ty = 60, tw = 70, th = 190;
      actx.strokeStyle = "#3a4a40"; actx.lineWidth = 2;
      actx.beginPath();
      actx.moveTo(tx, ty); actx.lineTo(tx + tw, ty);
      actx.lineTo(tx + tw, ty + th - 26); actx.quadraticCurveTo(tx + tw, ty + th, tx + tw / 2, ty + th);
      actx.quadraticCurveTo(tx, ty + th, tx, ty + th - 26); actx.closePath(); actx.stroke();
      // fill
      actx.save();
      actx.beginPath();
      actx.moveTo(tx, ty); actx.lineTo(tx + tw, ty);
      actx.lineTo(tx + tw, ty + th - 26); actx.quadraticCurveTo(tx + tw, ty + th, tx + tw / 2, ty + th);
      actx.quadraticCurveTo(tx, ty + th, tx, ty + th - 26); actx.closePath(); actx.clip();
      var fillTop = ty + 18 + (1 - frac) * (th - 30);
      var grd = actx.createLinearGradient(0, fillTop, 0, ty + th);
      grd.addColorStop(0, "rgba(94,234,212," + (0.35 + 0.5 * frac) + ")");
      grd.addColorStop(1, "rgba(134,239,172," + (0.45 + 0.45 * frac) + ")");
      actx.fillStyle = grd; actx.fillRect(tx, fillTop, tw, ty + th - fillTop);
      // little floating DNA marks
      actx.fillStyle = "rgba(255,255,255,0.6)";
      var marks = Math.min(40, Math.round(frac * 40));
      for (var m = 0; m < marks; m++){
        var mx = tx + 8 + ((m * 53) % (tw - 16));
        var my = fillTop + 10 + ((m * 31) % (ty + th - fillTop - 16));
        actx.fillRect(mx, my, 2, 2);
      }
      actx.restore();
      actx.fillStyle = "#9ab0a2"; actx.font = "11px ui-monospace, monospace";
      actx.fillText("REACTION", tx - 4, ty - 12);
      actx.fillStyle = "#86efac"; actx.font = "12px ui-monospace, monospace";
      actx.fillText(commaNum(copies) + " copies", tx - 6, ty + th + 24);

      // current phase legend
      var ly = 50;
      for (var p = 0; p < 3; p++){
        actx.fillStyle = (running && p === phaseIdx) ? PHASES[p].col : "#3a4a40";
        actx.fillRect(600, ly + p * 30, 12, 12);
        actx.fillStyle = (running && p === phaseIdx) ? "#e8f0ea" : "#9ab0a2";
        actx.font = "11px ui-monospace, monospace";
        actx.fillText(PHASES[p].name + " " + PHASES[p].target + "C", 620, ly + p * 30 + 11);
      }
      // temperature trace overlay (recent window)
      drawTempTrace();
    }

    function drawTempTrace(){
      var x0 = 590, y0 = 160, w = 150, h = 90;
      actx.strokeStyle = "#2a3a30"; actx.strokeRect(x0, y0, w, h);
      actx.fillStyle = "#9ab0a2"; actx.font = "9px ui-monospace, monospace";
      actx.fillText("block temp / time", x0, y0 - 4);
      if (tempHist.length < 2) return;
      var win = 6.0;
      var tEnd = tempHist[tempHist.length - 1].t;
      var tStart = tEnd - win;
      actx.strokeStyle = "#fbbf24"; actx.lineWidth = 1.5; actx.beginPath();
      var started = false;
      for (var i = 0; i < tempHist.length; i++){
        var p = tempHist[i];
        if (p.t < tStart) continue;
        var px = x0 + ((p.t - tStart) / win) * w;
        var py = y0 + h - ((p.temp - 20) / 80) * h;
        if (!started){ actx.moveTo(px, py); started = true; } else actx.lineTo(px, py);
      }
      actx.stroke();
    }

    function drawChart(){
      cctx.clearRect(0, 0, CW, CH);
      cctx.fillStyle = "#0a0d0b"; cctx.fillRect(0, 0, CW, CH);
      var ox = 52, oy = 28, w = CW - 80, h = CH - 60;
      // axes
      cctx.strokeStyle = "#2a3a30"; cctx.lineWidth = 1;
      cctx.beginPath(); cctx.moveTo(ox, oy); cctx.lineTo(ox, oy + h); cctx.lineTo(ox + w, oy + h); cctx.stroke();
      cctx.fillStyle = "#9ab0a2"; cctx.font = "10px ui-monospace, monospace";
      cctx.fillText("copies (log10)", ox - 44, oy - 10);
      cctx.fillText("cycle", ox + w - 28, oy + h + 22);
      var maxLog = Math.log10(plateau()) + 0.5;
      for (var g = 0; g <= maxLog; g += 2){
        var gy = oy + h - (g / maxLog) * h;
        cctx.strokeStyle = "#16221a"; cctx.beginPath(); cctx.moveTo(ox, gy); cctx.lineTo(ox + w, gy); cctx.stroke();
        cctx.fillStyle = "#5a6a60"; cctx.fillText("1e" + g, 6, gy + 3);
      }
      // ideal curve (faint)
      cctx.strokeStyle = "#3a4a40"; cctx.lineWidth = 1; cctx.beginPath();
      for (var n = 0; n <= cycles; n++){
        var val = targetCopiesAfter(n);
        var lx = ox + (n / cycles) * w;
        var ly = oy + h - (Math.log10(val) / maxLog) * h;
        if (n === 0) cctx.moveTo(lx, ly); else cctx.lineTo(lx, ly);
      }
      cctx.stroke();
      // actual progress so far
      cctx.strokeStyle = "#86efac"; cctx.lineWidth = 2; cctx.beginPath();
      for (var k = 0; k < copyHist.length; k++){
        var v = copyHist[k];
        var ax = ox + (k / cycles) * w;
        var ay = oy + h - (Math.log10(v) / maxLog) * h;
        if (k === 0) cctx.moveTo(ax, ay); else cctx.lineTo(ax, ay);
      }
      cctx.stroke();
      // marker dot at current cycle
      if (copyHist.length){
        var ci = copyHist.length - 1;
        var mx = ox + (ci / cycles) * w;
        var my = oy + h - (Math.log10(copyHist[ci]) / maxLog) * h;
        cctx.fillStyle = "#5eead4"; cctx.beginPath(); cctx.arc(mx, my, 4, 0, Math.PI * 2); cctx.fill();
      }
    }

    function draw(){ drawApparatus(); drawChart(); }

    el("pcrN0").addEventListener("input", function(){ readControls(); if (!running) reset(); });
    el("pcrCyc").addEventListener("input", function(){ readControls(); if (!running){ updateStats(); draw(); } });
    el("pcrEff").addEventListener("input", function(){ readControls(); if (!running) draw(); });
    el("pcrSpd").addEventListener("input", readControls);
    el("pcrRun").addEventListener("click", run);
    el("pcrReset").addEventListener("click", reset);
    readControls(); reset();
    return { draw: draw };
  })();

  // ======================================================================
  // 2. GEL ELECTROPHORESIS
  // ======================================================================
  var GEL = (function(){
    var cv = el("gelApp"), ctx = cv.getContext("2d");
    var W = cv.width, H = cv.height;
    var LADDER = [5000, 3000, 2000, 1500, 1000, 700, 500, 300, 100];
    var sample = [3000, 1500, 800, 400];
    var unknown = 1100;
    var voltage = 100;
    var progress = 0;        // 0..1 animation
    var running = false, raf = null;
    var picked = null;
    var topY = 60, botY = H - 40;

    // migration model: d (fraction of gel run) = a - b*log10(L), normalised to [0,1]
    // calibrate so 100bp -> ~0.95, 5000bp -> ~0.08 at full run
    function migFrac(L){
      var f = 1.18 - 0.30 * Math.log10(L);
      return clamp(f, 0.02, 0.98);
    }

    function readControls(){
      var raw = el("gelSizes").value.split(",");
      var arr = [];
      for (var i = 0; i < raw.length; i++){
        var v = parseInt(raw[i].replace(/[^0-9]/g, ""), 10);
        if (v && v >= 50 && v <= 10000) arr.push(v);
      }
      if (arr.length) sample = arr;
      unknown = parseInt(el("gelUnk").value, 10); el("gelUnkV").textContent = unknown;
      voltage = parseInt(el("gelV").value, 10); el("gelVV").textContent = voltage + " V";
    }

    function run(){
      readControls(); progress = 0; picked = null; el("gelRead").innerHTML = "Running...";
      if (raf) cancelAnimationFrame(raf); running = true;
      var step = function(){
        progress += 0.006 * (voltage / 100);
        if (progress >= 1){ progress = 1; running = false; el("gelRead").innerHTML = "Run complete. Click any band to size it."; }
        draw();
        if (running) raf = requestAnimationFrame(step); else raf = null;
      };
      raf = requestAnimationFrame(step);
    }
    function reset(){ if (raf) cancelAnimationFrame(raf); running = false; progress = 0; picked = null; el("gelRead").innerHTML = "Click a band after the run to estimate its size."; draw(); }

    // lane x-centres: 0 ladder, 1 sample, 2 unknown
    function laneX(i){ return 130 + i * 190; }
    var laneW = 120;

    function bandY(L){ return topY + migFrac(L) * progress * (botY - topY); }

    function draw(){
      ctx.clearRect(0, 0, W, H);
      // gel background
      ctx.fillStyle = "#0c130e"; ctx.fillRect(0, 0, W, H);
      ctx.fillStyle = "#10180f"; ctx.fillRect(40, 30, W - 80, H - 50);
      ctx.strokeStyle = "#2a3a30"; ctx.lineWidth = 2; ctx.strokeRect(40, 30, W - 80, H - 50);
      // electrodes
      ctx.fillStyle = "#fca5a5"; ctx.font = "11px ui-monospace, monospace"; ctx.fillText("(-) cathode  wells", 50, 22);
      ctx.fillStyle = "#86efac"; ctx.fillText("(+) anode", W - 130, H - 8);
      // lane labels + wells
      var labels = ["LADDER", "SAMPLE", "UNKNOWN"];
      for (var i = 0; i < 3; i++){
        var cx = laneX(i);
        ctx.fillStyle = "#9ab0a2"; ctx.font = "10px ui-monospace, monospace";
        ctx.fillText(labels[i], cx - laneW / 2, 46);
        // well
        ctx.fillStyle = "#0a0d0b"; ctx.fillRect(cx - laneW / 2, topY - 8, laneW, 8);
        ctx.strokeStyle = "#2a3a30"; ctx.strokeRect(cx - laneW / 2, topY - 8, laneW, 8);
      }
      // ladder bands + sizes
      drawLane(0, LADDER, true);
      drawLane(1, sample, false);
      drawLane(2, [unknown], false);
      // picked annotation
      if (picked){
        ctx.strokeStyle = "#fbbf24"; ctx.lineWidth = 1.5; ctx.setLineDash([4, 3]);
        var py = bandY(picked.L);
        ctx.beginPath(); ctx.moveTo(laneX(picked.lane) - laneW / 2, py); ctx.lineTo(W - 50, py); ctx.stroke();
        ctx.setLineDash([]);
      }
    }

    function drawLane(i, sizes, isLadder){
      var cx = laneX(i);
      for (var j = 0; j < sizes.length; j++){
        var L = sizes[j];
        var y = bandY(L);
        var w2 = isLadder ? laneW - 30 : laneW - 16;
        var alpha = 0.85;
        ctx.fillStyle = isLadder ? "rgba(147,197,253," + alpha + ")" : (i === 2 ? "rgba(251,191,36," + alpha + ")" : "rgba(134,239,172," + alpha + ")");
        ctx.shadowColor = ctx.fillStyle; ctx.shadowBlur = 6;
        ctx.fillRect(cx - w2 / 2, y - 3, w2, 6);
        ctx.shadowBlur = 0;
        if (isLadder){
          ctx.fillStyle = "#7a8a80"; ctx.font = "9px ui-monospace, monospace";
          ctx.fillText(L >= 1000 ? (L / 1000) + "kb" : L + "", cx + w2 / 2 + 4, y + 3);
        }
      }
    }

    // calibrate from ladder: linear fit of migFrac(progress) vs log10(L)
    function estimateSize(yFrac){
      // yFrac is observed migration fraction (0..1) at full run -> invert migFrac
      // migFrac = 1.18 - 0.30 log10 L  => log10 L = (1.18 - migFrac)/0.30
      var logL = (1.18 - yFrac) / 0.30;
      return Math.pow(10, logL);
    }

    cv.addEventListener("click", function(ev){
      if (progress < 0.99) return;
      var p = evtXY(cv, ev);
      // find nearest band across lanes
      var best = null, bestD = 14;
      var lanes = [[0, LADDER], [1, sample], [2, [unknown]]];
      for (var a = 0; a < lanes.length; a++){
        var li = lanes[a][0], arr = lanes[a][1], cx = laneX(li);
        if (Math.abs(p.x - cx) > laneW / 2) continue;
        for (var b = 0; b < arr.length; b++){
          var y = bandY(arr[b]);
          var d = Math.abs(p.y - y);
          if (d < bestD){ bestD = d; best = { lane: li, L: arr[b] }; }
        }
      }
      if (!best){ return; }
      picked = best;
      var obsFrac = migFrac(best.L); // observed migration (full run)
      var est = estimateSize(obsFrac);
      var name = best.lane === 0 ? "Ladder band" : (best.lane === 2 ? "Unknown band" : "Sample band");
      el("gelRead").innerHTML =
        '<span class="k">' + name + '</span><br>' +
        '<span class="k">true size:</span> <span class="v">' + best.L + ' bp</span><br>' +
        '<span class="k">estimated (ladder cal):</span> <span class="v">' + Math.round(est) + ' bp</span><br>' +
        '<span class="k">migration:</span> <span class="v">' + fmt(obsFrac * 100, 1) + '% of gel</span>';
      draw();
    });

    el("gelSizes").addEventListener("change", function(){ readControls(); reset(); });
    el("gelUnk").addEventListener("input", function(){ readControls(); if (!running) draw(); });
    el("gelV").addEventListener("input", readControls);
    el("gelRun").addEventListener("click", run);
    el("gelReset").addEventListener("click", reset);
    readControls(); draw();
    return { draw: draw };
  })();

  // ======================================================================
  // 3. RESTRICTION DIGESTION
  // ======================================================================
  var REST = (function(){
    var cv = el("restApp"), ctx = cv.getContext("2d");
    var W = cv.width, H = cv.height;
    var ENZ = {
      EcoRI:   { site: "GAATTC", cut: 1 },
      BamHI:   { site: "GGATCC", cut: 1 },
      HindIII: { site: "AAGCTT", cut: 1 },
      PstI:    { site: "CTGCAG", cut: 5 },
      NotI:    { site: "GCGGCCGC", cut: 2 },
      AluI:    { site: "AGCT", cut: 2 }
    };
    var seq = "";
    var topo = "linear";
    var len = 200;
    var lastCuts = [], lastFrags = [], lastSites = [];

    function readControls(){
      len = parseInt(el("restLen").value, 10); el("restLenV").textContent = len;
    }

    function randSeq(n){
      var b = "ACGT", s = "";
      for (var i = 0; i < n; i++) s += b.charAt((Math.random() * 4) | 0);
      return s;
    }

    function generate(){
      readControls();
      // sprinkle a couple of guaranteed sites so a digest is interesting
      var enz = ENZ[el("restEnz").value];
      var s = randSeq(len);
      var sites = 2 + ((Math.random() * 2) | 0);
      for (var k = 0; k < sites; k++){
        var pos = 6 + ((Math.random() * (len - enz.site.length - 12)) | 0);
        s = s.substring(0, pos) + enz.site + s.substring(pos + enz.site.length);
      }
      seq = s.substring(0, len);
      el("restRead").innerHTML = "Sequence ready (" + seq.length + " bp). Press Digest.";
      lastCuts = []; lastFrags = []; lastSites = [];
      renderSeq(); draw();
    }

    function findSites(site){
      var positions = [];
      var search = seq;
      if (topo === "circular") search = seq + seq.substring(0, site.length - 1);
      var idx = search.indexOf(site);
      while (idx !== -1 && idx < seq.length){
        positions.push(idx);
        idx = search.indexOf(site, idx + 1);
      }
      return positions;
    }

    function digest(){
      if (!seq){ generate(); }
      var enz = ENZ[el("restEnz").value];
      var sites = findSites(enz.site);
      lastSites = sites.slice();
      // absolute cut positions
      var cuts = [];
      for (var i = 0; i < sites.length; i++){
        var c = sites[i] + enz.cut;
        if (topo === "circular") c = c % seq.length;
        cuts.push(c);
      }
      cuts.sort(function(a, b){ return a - b; });
      var frags = [];
      if (topo === "linear"){
        var prev = 0;
        for (var j = 0; j < cuts.length; j++){ frags.push(cuts[j] - prev); prev = cuts[j]; }
        frags.push(seq.length - prev);
      } else {
        if (cuts.length === 0){ frags.push(seq.length); }
        else {
          for (var k = 0; k < cuts.length; k++){
            var a = cuts[k], b2 = cuts[(k + 1) % cuts.length];
            var f = (k + 1 < cuts.length) ? (b2 - a) : (seq.length - a + cuts[0]);
            frags.push(f);
          }
        }
      }
      frags = frags.filter(function(x){ return x > 0; });
      lastCuts = cuts; lastFrags = frags;
      var sorted = frags.slice().sort(function(a, b){ return b - a; });
      var sum = 0; for (var s = 0; s < frags.length; s++) sum += frags[s];
      el("restRead").innerHTML =
        '<span class="k">enzyme:</span> <span class="v">' + el("restEnz").value + " (" + enz.site + ")</span><br>" +
        '<span class="k">cut sites:</span> <span class="v">' + sites.length + "</span><br>" +
        '<span class="k">fragments:</span> <span class="v">' + frags.length + "</span><br>" +
        '<span class="k">sizes (bp):</span> <span class="v">' + sorted.join(", ") + "</span><br>" +
        '<span class="k">total:</span> <span class="v">' + sum + " bp</span>";
      renderSeq(); draw();
    }

    function renderSeq(){
      var host = el("restSeq");
      if (!seq){ host.innerHTML = ""; return; }
      var enz = ENZ[el("restEnz").value];
      var siteSet = {};
      for (var i = 0; i < lastSites.length; i++){
        for (var k = 0; k < enz.site.length; k++) siteSet[lastSites[i] + k] = true;
      }
      var html = "";
      var show = seq.length > 260 ? seq.substring(0, 260) : seq;
      for (var c = 0; c < show.length; c++){
        if (siteSet[c]) html += "<b>" + show.charAt(c) + "</b>";
        else html += show.charAt(c);
      }
      if (seq.length > 260) html += " ...(" + seq.length + " bp)";
      host.innerHTML = html;
    }

    function draw(){
      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = "#0a0d0b"; ctx.fillRect(0, 0, W, H);
      // top: linear DNA map with cut marks
      var mx = 40, mw = W - 80, my = 56;
      ctx.fillStyle = "#9ab0a2"; ctx.font = "11px ui-monospace, monospace";
      ctx.fillText(topo === "linear" ? "DNA molecule (linear)" : "DNA molecule (circular, shown linearised)", mx, my - 16);
      if (seq){
        ctx.fillStyle = "#15211a"; ctx.fillRect(mx, my, mw, 22);
        ctx.strokeStyle = "#2a3a30"; ctx.strokeRect(mx, my, mw, 22);
        // recognition sites
        var enz = ENZ[el("restEnz").value];
        for (var i = 0; i < lastSites.length; i++){
          var sx = mx + (lastSites[i] / seq.length) * mw;
          var sw = (enz.site.length / seq.length) * mw;
          ctx.fillStyle = "rgba(251,191,36,0.35)"; ctx.fillRect(sx, my, Math.max(2, sw), 22);
        }
        // cut marks
        for (var j = 0; j < lastCuts.length; j++){
          var cxp = mx + (lastCuts[j] / seq.length) * mw;
          ctx.strokeStyle = "#fca5a5"; ctx.lineWidth = 2;
          ctx.beginPath(); ctx.moveTo(cxp, my - 8); ctx.lineTo(cxp, my + 30); ctx.stroke();
          ctx.fillStyle = "#fca5a5"; ctx.font = "9px ui-monospace, monospace";
          ctx.fillText(lastCuts[j] + "", cxp - 6, my - 12);
        }
        ctx.fillStyle = "#9ab0a2"; ctx.font = "9px ui-monospace, monospace";
        ctx.fillText("0", mx, my + 36); ctx.fillText(seq.length + " bp", mx + mw - 30, my + 36);
      } else {
        ctx.fillStyle = "#5a6a60"; ctx.fillText("Generate a sequence to begin.", mx, my + 16);
      }
      // bottom: predicted gel of fragments
      var gy = 150, gh = 180, gx = 60, gw = W - 120;
      ctx.fillStyle = "#9ab0a2"; ctx.font = "11px ui-monospace, monospace";
      ctx.fillText("Predicted gel (digest fragments by size)", gx, gy - 10);
      ctx.fillStyle = "#10180f"; ctx.fillRect(gx, gy, gw, gh);
      ctx.strokeStyle = "#2a3a30"; ctx.strokeRect(gx, gy, gw, gh);
      // well
      ctx.fillStyle = "#0a0d0b"; ctx.fillRect(gx + gw / 2 - 40, gy - 6, 80, 6);
      if (lastFrags.length){
        for (var f = 0; f < lastFrags.length; f++){
          var L = lastFrags[f];
          var frac = clamp(1.15 - 0.32 * Math.log10(L), 0.05, 0.95);
          var by = gy + 10 + frac * (gh - 20);
          ctx.fillStyle = "rgba(134,239,172,0.85)"; ctx.shadowColor = "#86efac"; ctx.shadowBlur = 6;
          ctx.fillRect(gx + gw / 2 - 45, by - 3, 90, 6); ctx.shadowBlur = 0;
          ctx.fillStyle = "#cbe0d2"; ctx.font = "9px ui-monospace, monospace";
          ctx.fillText(L + " bp", gx + gw / 2 + 52, by + 3);
        }
      }
    }

    var topoBtns = el("restTopo").querySelectorAll("button");
    for (var t = 0; t < topoBtns.length; t++){
      (function(btn){
        btn.addEventListener("click", function(){
          for (var i = 0; i < topoBtns.length; i++) topoBtns[i].classList.remove("on");
          btn.classList.add("on"); topo = btn.getAttribute("data-topo");
          if (seq) digest();
        });
      })(topoBtns[t]);
    }
    el("restLen").addEventListener("input", readControls);
    el("restEnz").addEventListener("change", function(){ if (seq){ renderSeq(); } });
    el("restGen").addEventListener("click", generate);
    el("restDigest").addEventListener("click", digest);
    el("restClear").addEventListener("click", function(){ seq = ""; lastCuts = []; lastFrags = []; lastSites = []; el("restRead").innerHTML = "Cleared. Generate a sequence."; renderSeq(); draw(); });
    readControls(); generate();
    return { draw: draw };
  })();

  // ======================================================================
  // 4. MICHAELIS-MENTEN KINETICS
  // ======================================================================
  var MM = (function(){
    var hc = el("mmHyp"), hctx = hc.getContext("2d");
    var lc = el("mmLb"), lctx = lc.getContext("2d");
    var HW = hc.width, HH = hc.height, LW = lc.width, LH = lc.height;
    var Vmax = 100, Km = 40, S = 40, inh = "none", IK = 0;
    var Smax = 400;

    function readControls(){
      Vmax = parseFloat(el("mmVmax").value); el("mmVmaxV").textContent = Vmax;
      Km = parseFloat(el("mmKm").value); el("mmKmV").textContent = Km;
      S = parseFloat(el("mmS").value); el("mmSV").textContent = S;
      IK = parseFloat(el("mmI").value); el("mmIV").textContent = fmt(IK, 1);
    }

    function appParams(){
      var kmA = Km, vmA = Vmax;
      if (inh === "comp") kmA = Km * (1 + IK);
      else if (inh === "noncomp") vmA = Vmax / (1 + IK);
      return { km: kmA, vm: vmA };
    }
    function vel(s, p){ return p.vm * s / (p.km + s); }

    function drawHyp(){
      hctx.clearRect(0, 0, HW, HH);
      hctx.fillStyle = "#0a0d0b"; hctx.fillRect(0, 0, HW, HH);
      var ox = 56, oy = 24, w = HW - 86, h = HH - 56;
      var vTop = Vmax * 1.1;
      // grid + axes
      hctx.strokeStyle = "#16221a"; hctx.lineWidth = 1;
      for (var g = 0; g <= 5; g++){
        var gy = oy + h - (g / 5) * h;
        hctx.beginPath(); hctx.moveTo(ox, gy); hctx.lineTo(ox + w, gy); hctx.stroke();
      }
      hctx.strokeStyle = "#2a3a30"; hctx.beginPath(); hctx.moveTo(ox, oy); hctx.lineTo(ox, oy + h); hctx.lineTo(ox + w, oy + h); hctx.stroke();
      hctx.fillStyle = "#9ab0a2"; hctx.font = "10px ui-monospace, monospace";
      hctx.fillText("v", ox - 44, oy + 6); hctx.fillText("[S]", ox + w - 18, oy + h + 20);
      // Vmax line
      var vmY = oy + h - (Vmax / vTop) * h;
      hctx.strokeStyle = "#3a4a40"; hctx.setLineDash([4, 3]); hctx.beginPath(); hctx.moveTo(ox, vmY); hctx.lineTo(ox + w, vmY); hctx.stroke(); hctx.setLineDash([]);
      hctx.fillStyle = "#5a6a60"; hctx.fillText("Vmax", ox + w - 36, vmY - 4);
      // reference (uninhibited) faint
      var ref = { km: Km, vm: Vmax };
      hctx.strokeStyle = "#3a4a40"; hctx.lineWidth = 1.2; hctx.beginPath();
      for (var i = 0; i <= 200; i++){
        var s = (i / 200) * Smax;
        var x = ox + (s / Smax) * w;
        var y = oy + h - (vel(s, ref) / vTop) * h;
        if (i === 0) hctx.moveTo(x, y); else hctx.lineTo(x, y);
      }
      hctx.stroke();
      // active curve
      var p = appParams();
      hctx.strokeStyle = "#86efac"; hctx.lineWidth = 2.2; hctx.beginPath();
      for (var j = 0; j <= 200; j++){
        var s2 = (j / 200) * Smax;
        var x2 = ox + (s2 / Smax) * w;
        var y2 = oy + h - (vel(s2, p) / vTop) * h;
        if (j === 0) hctx.moveTo(x2, y2); else hctx.lineTo(x2, y2);
      }
      hctx.stroke();
      // Km marker (where v = vm/2 -> s = km app)
      var kmX = ox + (p.km / Smax) * w;
      var halfY = oy + h - (p.vm / 2 / vTop) * h;
      hctx.strokeStyle = "#93c5fd"; hctx.setLineDash([3, 3]); hctx.lineWidth = 1;
      hctx.beginPath(); hctx.moveTo(kmX, oy + h); hctx.lineTo(kmX, halfY); hctx.lineTo(ox, halfY); hctx.stroke(); hctx.setLineDash([]);
      hctx.fillStyle = "#93c5fd"; hctx.fillText("Km", kmX - 8, oy + h + 14);
      // [S] marker
      var sX = ox + (S / Smax) * w;
      var vAt = vel(S, p);
      var sY = oy + h - (vAt / vTop) * h;
      hctx.strokeStyle = "#fbbf24"; hctx.setLineDash([2, 2]); hctx.beginPath(); hctx.moveTo(sX, oy + h); hctx.lineTo(sX, sY); hctx.stroke(); hctx.setLineDash([]);
      hctx.fillStyle = "#fbbf24"; hctx.beginPath(); hctx.arc(sX, sY, 4, 0, Math.PI * 2); hctx.fill();
    }

    function drawLb(){
      lctx.clearRect(0, 0, LW, LH);
      lctx.fillStyle = "#0a0d0b"; lctx.fillRect(0, 0, LW, LH);
      // axes with origin shifted in (allow negative x for -1/Km intercept)
      var ox = 120, oy = 28, w = LW - 150, h = LH - 60;
      var invSmax = 1 / 10;  // 1/[S] range up to 0.1
      var p = appParams();
      var invVmax = 1 / p.vm;
      var yTop = invVmax + (Km / p.vm) * invSmax * 1.3 + 0.002;
      lctx.strokeStyle = "#2a3a30"; lctx.lineWidth = 1;
      // y axis at x where 1/S = 0
      var xZero = ox; // place 1/S=0 a bit in to show negative intercept
      // map: x from -0.03..invSmax
      var xMin = -0.04, xMax = invSmax;
      function X(v){ return ox + ((v - xMin) / (xMax - xMin)) * w; }
      function Y(v){ return oy + h - (v / yTop) * h; }
      // grid
      lctx.strokeStyle = "#16221a";
      for (var g = 0; g <= 4; g++){ var gy = oy + (g / 4) * h; lctx.beginPath(); lctx.moveTo(ox, gy); lctx.lineTo(ox + w, gy); lctx.stroke(); }
      // axes
      lctx.strokeStyle = "#2a3a30"; lctx.lineWidth = 1.2;
      lctx.beginPath(); lctx.moveTo(X(0), oy); lctx.lineTo(X(0), oy + h); lctx.stroke(); // y axis at 1/S=0
      lctx.beginPath(); lctx.moveTo(ox, oy + h); lctx.lineTo(ox + w, oy + h); lctx.stroke();
      lctx.fillStyle = "#9ab0a2"; lctx.font = "10px ui-monospace, monospace";
      lctx.fillText("1/v", X(0) - 30, oy + 4); lctx.fillText("1/[S]", ox + w - 30, oy + h + 18);
      // reference line
      var refSlope = Km / Vmax, refInt = 1 / Vmax;
      lctx.strokeStyle = "#3a4a40"; lctx.lineWidth = 1.2;
      lctx.beginPath(); lctx.moveTo(X(xMin), Y(refInt + refSlope * xMin)); lctx.lineTo(X(xMax), Y(refInt + refSlope * xMax)); lctx.stroke();
      // active line: 1/v = (km/vm)(1/S) + 1/vm
      var slope = p.km / p.vm, intc = 1 / p.vm;
      lctx.strokeStyle = "#86efac"; lctx.lineWidth = 2.2;
      lctx.beginPath(); lctx.moveTo(X(xMin), Y(intc + slope * xMin)); lctx.lineTo(X(xMax), Y(intc + slope * xMax)); lctx.stroke();
      // intercepts
      lctx.fillStyle = "#fbbf24"; lctx.font = "9px ui-monospace, monospace";
      lctx.beginPath(); lctx.arc(X(0), Y(intc), 3.5, 0, Math.PI * 2); lctx.fill();
      lctx.fillText("1/Vmax", X(0) + 6, Y(intc) - 4);
      var xInt = -1 / p.km;
      lctx.fillStyle = "#93c5fd"; lctx.beginPath(); lctx.arc(X(xInt), Y(0), 3.5, 0, Math.PI * 2); lctx.fill();
      lctx.fillText("-1/Km", X(xInt) - 8, Y(0) - 6);
    }

    function updateStats(){
      var p = appParams();
      var vAt = vel(S, p);
      el("mmV").textContent = fmt(vAt, 1);
      el("mmFrac").textContent = fmt(vAt / Vmax, 2);
      el("mmKmApp").textContent = fmt(p.km, 1);
      el("mmVmaxApp").textContent = fmt(p.vm, 1);
    }

    function draw(){ readControls(); drawHyp(); drawLb(); updateStats(); }

    var inhBtns = el("mmInh").querySelectorAll("button");
    for (var t = 0; t < inhBtns.length; t++){
      (function(btn){
        btn.addEventListener("click", function(){
          for (var i = 0; i < inhBtns.length; i++) inhBtns[i].classList.remove("on");
          btn.classList.add("on"); inh = btn.getAttribute("data-inh"); draw();
        });
      })(inhBtns[t]);
    }
    ["mmVmax", "mmKm", "mmS", "mmI"].forEach(function(id){ el(id).addEventListener("input", draw); });
    readControls(); draw();
    return { draw: draw };
  })();

  // ======================================================================
  // 5. TRANSCRIPTION & TRANSLATION
  // ======================================================================
  var TRANS = (function(){
    var cv = el("trApp"), ctx = cv.getContext("2d");
    var W = cv.width, H = cv.height;
    // real standard genetic code (mRNA codons)
    var CODON = {
      UUU:"F", UUC:"F", UUA:"L", UUG:"L", CUU:"L", CUC:"L", CUA:"L", CUG:"L",
      AUU:"I", AUC:"I", AUA:"I", AUG:"M", GUU:"V", GUC:"V", GUA:"V", GUG:"V",
      UCU:"S", UCC:"S", UCA:"S", UCG:"S", CCU:"P", CCC:"P", CCA:"P", CCG:"P",
      ACU:"T", ACC:"T", ACA:"T", ACG:"T", GCU:"A", GCC:"A", GCA:"A", GCG:"A",
      UAU:"Y", UAC:"Y", UAA:"*", UAG:"*", CAU:"H", CAC:"H", CAA:"Q", CAG:"Q",
      AAU:"N", AAC:"N", AAA:"K", AAG:"K", GAU:"D", GAC:"D", GAA:"E", GAG:"E",
      UGU:"C", UGC:"C", UGA:"*", UGG:"W", CGU:"R", CGC:"R", CGA:"R", CGG:"R",
      AGU:"S", AGC:"S", AGA:"R", AGG:"R", GGU:"G", GGC:"G", GGA:"G", GGG:"G"
    };
    var THREE = {
      F:"Phe", L:"Leu", I:"Ile", M:"Met", V:"Val", S:"Ser", P:"Pro", T:"Thr",
      A:"Ala", Y:"Tyr", H:"His", Q:"Gln", N:"Asn", K:"Lys", D:"Asp", E:"Glu",
      C:"Cys", W:"Trp", R:"Arg", G:"Gly", "*":"Stop"
    };
    var AMINO_CODONS = []; // codons that are amino acids (not stop), for ORF builder
    for (var c in CODON){ if (CODON[c] !== "*" && c !== "AUG") AMINO_CODONS.push(c); }

    var dna = "ATGGCCAGTTGGTAA";
    var mrna = "";
    var protein = []; // {codon, aa, three, kind}

    function clean(s){ return s.toUpperCase().replace(/[^ACGT]/g, ""); }

    function readControls(){
      el("trLenV").textContent = el("trLen").value + " aa";
    }

    function randomORF(){
      var n = parseInt(el("trLen").value, 10);
      var stops = ["TAA", "TAG", "TGA"];
      var s = "ATG";
      for (var i = 0; i < n; i++){
        var rc = AMINO_CODONS[(Math.random() * AMINO_CODONS.length) | 0];
        s += rc.replace(/U/g, "T");
      }
      s += stops[(Math.random() * 3) | 0];
      dna = s; el("trSeq").value = s;
      mrna = ""; protein = [];
      renderText(); draw();
    }

    function transcribe(){
      dna = clean(el("trSeq").value); el("trSeq").value = dna;
      mrna = dna.replace(/T/g, "U");
      protein = [];
      el("trLenN").textContent = mrna.length;
      renderText(); draw();
    }

    function translate(){
      if (!mrna) transcribe();
      protein = [];
      var start = mrna.indexOf("AUG");
      var codons = 0, stopAt = "--";
      if (start === -1){
        el("trProt").innerHTML = '<span class="k">No start codon (AUG) found.</span>';
        el("trCod").textContent = 0; el("trAa").textContent = 0; el("trStop").textContent = "--";
        draw(); return;
      }
      for (var i = start; i + 3 <= mrna.length; i += 3){
        var cod = mrna.substring(i, i + 3);
        var aa = CODON[cod] || "?";
        codons++;
        if (aa === "*"){ protein.push({ codon: cod, aa: "*", three: "Stop", kind: "stop", pos: i }); stopAt = i + 1; break; }
        protein.push({ codon: cod, aa: aa, three: THREE[aa] || "?", kind: (i === start ? "start" : "aa"), pos: i });
      }
      var aaCount = 0; for (var k = 0; k < protein.length; k++) if (protein[k].kind !== "stop") aaCount++;
      el("trCod").textContent = codons;
      el("trAa").textContent = aaCount;
      el("trStop").textContent = stopAt;
      renderText(); draw();
    }

    function renderText(){
      // DNA
      el("trDna").innerHTML = '<span class="k">DNA coding 5\'-</span> <span class="v">' + (dna || "--") + '</span> <span class="k">-3\'</span>';
      el("trMrna").innerHTML = '<span class="k">mRNA 5\'-</span> <span class="v">' + (mrna || "--") + '</span> <span class="k">-3\'</span>';
      // protein
      if (!protein.length){ el("trProt").innerHTML = '<span class="k">Press Translate to read the protein.</span>'; return; }
      var one = "", three = "";
      for (var i = 0; i < protein.length; i++){
        var p = protein[i];
        if (p.kind === "stop"){ three += "Stop "; }
        else { one += p.aa; three += p.three + " "; }
      }
      el("trProt").innerHTML =
        '<span class="k">Protein (1-letter):</span> <span class="v">' + (one || "(none)") + '</span><br>' +
        '<span class="k">Protein (3-letter):</span> <span class="v">' + three + '</span>';
    }

    function draw(){
      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = "#0a0d0b"; ctx.fillRect(0, 0, W, H);
      ctx.fillStyle = "#9ab0a2"; ctx.font = "11px ui-monospace, monospace";
      ctx.fillText("mRNA codons (reading frame from first AUG)", 12, 18);
      if (!mrna){ ctx.fillStyle = "#5a6a60"; ctx.fillText("Transcribe a sequence first.", 12, 44); return; }
      var start = mrna.indexOf("AUG");
      var x = 12, y = 50, bw = 56, gap = 6;
      // draw pre-start (out of frame) faintly
      var idx = 0;
      // walk in codon units from start
      var drawn = 0;
      var maxPerRow = Math.floor((W - 24) / (bw + gap));
      for (var i = (start === -1 ? 0 : start); i + 3 <= mrna.length && drawn < maxPerRow * 2; i += 3){
        var cod = mrna.substring(i, i + 3);
        var aa = CODON[cod];
        var col = drawn % maxPerRow, row = Math.floor(drawn / maxPerRow);
        var bx = 12 + col * (bw + gap), by = 50 + row * 60;
        var isStart = (i === start);
        var isStop = (aa === "*");
        ctx.fillStyle = isStop ? "rgba(252,165,165,0.18)" : (isStart ? "rgba(134,239,172,0.20)" : "#15211a");
        ctx.strokeStyle = isStop ? "#fca5a5" : (isStart ? "#86efac" : "#2a3a30");
        ctx.lineWidth = 1.4;
        ctx.fillRect(bx, by, bw, 30); ctx.strokeRect(bx, by, bw, 30);
        ctx.fillStyle = "#e8f0ea"; ctx.font = "bold 13px ui-monospace, monospace";
        ctx.fillText(cod, bx + 8, by + 20);
        ctx.fillStyle = isStop ? "#fca5a5" : (isStart ? "#86efac" : "#fbbf24");
        ctx.font = "10px ui-monospace, monospace";
        ctx.fillText(isStop ? "Stop" : (THREE[aa] || "?"), bx + 6, by + 44);
        drawn++;
        if (isStop) break;
        if (start === -1) break;
      }
    }

    el("trRandom").addEventListener("click", randomORF);
    el("trTranscribe").addEventListener("click", transcribe);
    el("trTranslate").addEventListener("click", translate);
    el("trLen").addEventListener("input", readControls);
    el("trSeq").addEventListener("change", function(){ mrna = ""; protein = []; renderText(); draw(); });

    function render(){ readControls(); renderText(); draw(); }
    readControls(); transcribe(); translate();
    return { render: render };
  })();

  // ======================================================================
  // 6. SPECTROPHOTOMETRY (BEER-LAMBERT)
  // ======================================================================
  var SPEC = (function(){
    var ap = el("spApp"), actx = ap.getContext("2d");
    var cal = el("spCal"), cctx = cal.getContext("2d");
    var AW = ap.width, AH = ap.height, CW = cal.width, CH = cal.height;
    var eps = 6000, L = 1, conc = 60, unkA = 0.4;
    var stds = []; // {c, A}

    function readControls(){
      eps = parseFloat(el("spEps").value); el("spEpsV").textContent = eps;
      L = parseFloat(el("spL").value); el("spLV").textContent = fmt(L, 1);
      conc = parseFloat(el("spC").value); el("spCV").textContent = conc;
      unkA = parseFloat(el("spUnk").value); el("spUnkV").textContent = fmt(unkA, 2);
    }

    // A = eps * c * l ; c in mol/L. conc slider is in uM => c = conc*1e-6
    function absorbance(cUM){ return eps * (cUM * 1e-6) * L; }

    function drawApparatus(){
      actx.clearRect(0, 0, AW, AH);
      actx.fillStyle = "#0a0d0b"; actx.fillRect(0, 0, AW, AH);
      var A = absorbance(conc);
      var T = Math.pow(10, -A);
      // lamp
      actx.fillStyle = "#fbbf24"; actx.beginPath(); actx.arc(70, AH / 2, 22, 0, Math.PI * 2); actx.fill();
      actx.fillStyle = "#9ab0a2"; actx.font = "10px ui-monospace, monospace"; actx.fillText("LAMP I0", 46, AH / 2 + 42);
      // incident beam
      actx.strokeStyle = "rgba(251,191,36,0.8)"; actx.lineWidth = 4;
      actx.beginPath(); actx.moveTo(92, AH / 2); actx.lineTo(300, AH / 2); actx.stroke();
      // cuvette
      var cx = 300, cyT = AH / 2 - 70, cw = 110, chh = 140;
      var tint = clamp(A / 1.5, 0, 1);
      actx.fillStyle = "rgba(94,234,212," + (0.12 + 0.6 * tint) + ")";
      actx.fillRect(cx, cyT, cw, chh);
      actx.strokeStyle = "#3a4a40"; actx.lineWidth = 2; actx.strokeRect(cx, cyT, cw, chh);
      actx.fillStyle = "#9ab0a2"; actx.font = "10px ui-monospace, monospace"; actx.fillText("CUVETTE  l=" + fmt(L, 1) + "cm", cx, cyT - 8);
      actx.fillText(conc + " uM", cx + 30, cyT + chh + 18);
      // transmitted beam (thinner = less light)
      actx.strokeStyle = "rgba(251,191,36," + clamp(T, 0.05, 1) + ")"; actx.lineWidth = clamp(4 * T, 0.5, 4);
      actx.beginPath(); actx.moveTo(cx + cw, AH / 2); actx.lineTo(560, AH / 2); actx.stroke();
      // detector
      actx.fillStyle = "#15211a"; actx.strokeStyle = "#2a3a30"; actx.lineWidth = 2;
      actx.fillRect(560, AH / 2 - 40, 90, 80); actx.strokeRect(560, AH / 2 - 40, 90, 80);
      actx.fillStyle = "#9ab0a2"; actx.font = "10px ui-monospace, monospace"; actx.fillText("DETECTOR I", 566, AH / 2 - 48);
      // readout panel on detector
      actx.fillStyle = "#86efac"; actx.font = "bold 14px ui-monospace, monospace";
      actx.fillText("A " + fmt(A, 3), 572, AH / 2 - 6);
      actx.fillStyle = "#5eead4"; actx.font = "12px ui-monospace, monospace";
      actx.fillText("T " + fmt(T * 100, 1) + "%", 572, AH / 2 + 18);
      // bar showing transmitted intensity
      actx.fillStyle = "#1a261c"; actx.fillRect(660, AH / 2 - 40, 14, 80);
      actx.fillStyle = "#fbbf24"; var bh = 80 * clamp(T, 0, 1); actx.fillRect(660, AH / 2 + 40 - bh, 14, bh);

      el("spA").textContent = fmt(A, 3);
      el("spT").textContent = fmt(T * 100, 1) + "%";
    }

    function linfit(){
      // force through origin: slope = sum(c*A)/sum(c*c)
      if (stds.length < 1) return null;
      var sca = 0, scc = 0;
      for (var i = 0; i < stds.length; i++){ sca += stds[i].c * stds[i].A; scc += stds[i].c * stds[i].c; }
      if (scc === 0) return null;
      return sca / scc; // A per uM
    }

    function drawCal(){
      cctx.clearRect(0, 0, CW, CH);
      cctx.fillStyle = "#0a0d0b"; cctx.fillRect(0, 0, CW, CH);
      var ox = 56, oy = 24, w = CW - 86, h = CH - 56;
      var cMax = 200, aMax = 1.6;
      cctx.strokeStyle = "#16221a"; cctx.lineWidth = 1;
      for (var g = 0; g <= 4; g++){ var gy = oy + (g / 4) * h; cctx.beginPath(); cctx.moveTo(ox, gy); cctx.lineTo(ox + w, gy); cctx.stroke(); }
      cctx.strokeStyle = "#2a3a30"; cctx.beginPath(); cctx.moveTo(ox, oy); cctx.lineTo(ox, oy + h); cctx.lineTo(ox + w, oy + h); cctx.stroke();
      cctx.fillStyle = "#9ab0a2"; cctx.font = "10px ui-monospace, monospace";
      cctx.fillText("A", ox - 40, oy + 6); cctx.fillText("conc (uM)", ox + w - 56, oy + h + 20);
      function X(c){ return ox + (c / cMax) * w; }
      function Y(a){ return oy + h - (a / aMax) * h; }
      // fitted line
      var slope = linfit();
      if (slope != null){
        cctx.strokeStyle = "#86efac"; cctx.lineWidth = 2;
        cctx.beginPath(); cctx.moveTo(X(0), Y(0)); cctx.lineTo(X(cMax), Y(slope * cMax)); cctx.stroke();
      }
      // theoretical line (eps*l per uM) faint
      var theo = eps * 1e-6 * L;
      cctx.strokeStyle = "#3a4a40"; cctx.setLineDash([4, 3]); cctx.lineWidth = 1;
      cctx.beginPath(); cctx.moveTo(X(0), Y(0)); cctx.lineTo(X(cMax), Y(theo * cMax)); cctx.stroke(); cctx.setLineDash([]);
      // points
      for (var i = 0; i < stds.length; i++){
        cctx.fillStyle = "#5eead4"; cctx.beginPath(); cctx.arc(X(stds[i].c), Y(stds[i].A), 4, 0, Math.PI * 2); cctx.fill();
      }
      // unknown read-back
      el("spSlope").textContent = slope != null ? fmt(slope, 4) : "--";
      if (slope != null && slope > 0){
        var uc = unkA / slope;
        el("spConc").textContent = fmt(uc, 1) + " uM";
        // draw unknown
        cctx.strokeStyle = "#fbbf24"; cctx.setLineDash([3, 3]); cctx.lineWidth = 1;
        cctx.beginPath(); cctx.moveTo(ox, Y(unkA)); cctx.lineTo(X(uc), Y(unkA)); cctx.lineTo(X(uc), oy + h); cctx.stroke(); cctx.setLineDash([]);
        cctx.fillStyle = "#fbbf24"; cctx.beginPath(); cctx.arc(X(uc), Y(unkA), 4, 0, Math.PI * 2); cctx.fill();
        cctx.font = "9px ui-monospace, monospace"; cctx.fillText("unknown A=" + fmt(unkA, 2), X(uc) + 6, Y(unkA) - 4);
      } else {
        el("spConc").textContent = "need standards";
      }
    }

    function draw(){ readControls(); drawApparatus(); drawCal(); }

    el("spRead").addEventListener("click", function(){
      readControls();
      var A = absorbance(conc);
      // record standard (avoid exact duplicates)
      stds.push({ c: conc, A: A });
      if (stds.length > 12) stds.shift();
      draw();
    });
    el("spClear").addEventListener("click", function(){ stds = []; draw(); });
    ["spEps", "spL", "spC", "spUnk"].forEach(function(id){ el(id).addEventListener("input", draw); });
    // seed a couple of standards for a usable curve
    (function seed(){
      readControls();
      [20, 60, 120].forEach(function(c){ stds.push({ c: c, A: eps * (c * 1e-6) * L }); });
    })();
    readControls(); draw();
    return { draw: draw };
  })();

  // initial render
  onShow("pcr");
})();
</script>
</BaseLayout>
