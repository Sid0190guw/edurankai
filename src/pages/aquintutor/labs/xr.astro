---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="XR · AR · VR hub · Virtual Labs · AquinTutor" description="Real WebXR-compatible immersive labs. Bring a Meta Quest, Apple Vision Pro, Pico, or any WebXR headset — step into molecular viewers, pendulum benches, anatomy theatres. Hands tracked. No app install.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; }
  .xr-wrap { max-width: 1280px; margin: 0 auto; padding: 20px 4vw 80px; }
  .xr-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: #a78bfa; font-weight: 700; }
  .xr-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 6vw, 72px); font-weight: 600; letter-spacing: -0.03em; margin: 8px 0 14px; line-height: 1; }
  .xr-title em { background: linear-gradient(135deg, #a78bfa, #67e8f9); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; font-style: italic; font-weight: 500; }
  .xr-sub { font-size: 17px; color: #9aa6b6; max-width: 720px; line-height: 1.7; }

  .xr-status { background: #11131a; border: 1px solid #2a2a35; border-radius: 14px; padding: 22px; margin: 24px 0; display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 720px) { .xr-status { grid-template-columns: 1fr; } }
  .xr-status-row { display: flex; gap: 14px; align-items: center; padding: 14px; background: #08080a; border-radius: 10px; border: 1px solid #1a1a25; }
  .xr-dot { width: 12px; height: 12px; border-radius: 50%; background: #4a4f5e; flex-shrink: 0; }
  .xr-dot.ok { background: #86efac; box-shadow: 0 0 0 4px rgba(134,239,172,0.15); }
  .xr-dot.bad { background: #f87171; }
  .xr-status-label { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #cfd6da; font-weight: 700; }
  .xr-status-detail { font-size: 12.5px; color: #9aa6b6; margin-top: 4px; }

  .xr-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 14px; margin-top: 32px; }
  .xr-scene { background: linear-gradient(135deg, #11131a, #1a1a25); border: 1px solid #2a2a35; border-radius: 14px; padding: 22px; transition: all 0.2s; }
  .xr-scene:hover { border-color: #a78bfa; transform: translateY(-2px); }
  .xr-scene-eye { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #a78bfa; font-weight: 700; }
  .xr-scene-title { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; margin: 4px 0 8px; letter-spacing: -0.01em; }
  .xr-scene-desc { font-size: 13.5px; color: #9aa6b6; line-height: 1.6; }
  .xr-scene-btn { background: linear-gradient(135deg, #a78bfa, #67e8f9); color: #0a0a0c; padding: 10px 20px; border-radius: 8px; border: none; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; margin-top: 12px; text-decoration: none; display: inline-block; }
  .xr-scene-btn[disabled] { opacity: 0.5; cursor: not-allowed; background: #2a2a35; color: #9aa6b6; }

  .xr-section-h { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 600; letter-spacing: -0.02em; margin: 48px 0 12px; }
  .xr-section-h em { color: #a78bfa; font-style: italic; font-weight: 500; }

  .xr-canvas { width: 100%; aspect-ratio: 1; max-width: 500px; margin: 0 auto; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 12px; display: block; }
  .xr-cap-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 10px; margin-top: 14px; }
  .xr-cap { background: #11131a; border: 1px solid #2a2a35; padding: 10px 14px; border-radius: 10px; }
  .xr-cap-lbl { font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; }
  .xr-cap-val { font-family: 'Geist Mono', monospace; font-size: 12px; color: #a78bfa; margin-top: 4px; font-weight: 700; }
</style>

<main class="xr-wrap">

  <header>
    <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#a78bfa;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
    <p class="xr-eye" style="margin-top:14px;">AquinTutor · XR Hub</p>
    <h1 class="xr-title">Step <em>inside the lab</em>.</h1>
    <p class="xr-sub">Real WebXR-compatible immersive learning. Bring a Meta Quest, Apple Vision Pro, Pico headset, or any browser-XR device — the molecular viewer, pendulum bench, periodic table, and anatomy theatre all enter VR with one click. No app install. Hands tracked.</p>
  </header>

  <div class="xr-status">
    <div class="xr-status-row">
      <div class="xr-dot" id="webxrDot"></div>
      <div>
        <div class="xr-status-label">WebXR API</div>
        <div class="xr-status-detail" id="webxrDetail">Checking your browser&hellip;</div>
      </div>
    </div>
    <div class="xr-status-row">
      <div class="xr-dot" id="vrDot"></div>
      <div>
        <div class="xr-status-label">Immersive VR</div>
        <div class="xr-status-detail" id="vrDetail">&mdash;</div>
      </div>
    </div>
    <div class="xr-status-row">
      <div class="xr-dot" id="arDot"></div>
      <div>
        <div class="xr-status-label">Immersive AR (pass-through)</div>
        <div class="xr-status-detail" id="arDetail">&mdash;</div>
      </div>
    </div>
    <div class="xr-status-row">
      <div class="xr-dot" id="handDot"></div>
      <div>
        <div class="xr-status-label">Hand tracking</div>
        <div class="xr-status-detail" id="handDetail">&mdash;</div>
      </div>
    </div>
  </div>

  <h2 class="xr-section-h">Immersive <em>scenes</em>.</h2>

  <div class="xr-grid">
    <div class="xr-scene">
      <p class="xr-scene-eye">Chemistry</p>
      <h3 class="xr-scene-title">Molecular viewer</h3>
      <p class="xr-scene-desc">Pick a molecule from our catalogue — caffeine, water, benzene, glucose, DNA, proteins. Walk around the ball-and-stick model. Pull bonds apart. Show electron orbitals.</p>
      <button class="xr-scene-btn xr-enter" data-scene="molecule">Enter VR &rarr;</button>
    </div>
    <div class="xr-scene">
      <p class="xr-scene-eye">Chemistry</p>
      <h3 class="xr-scene-title">Periodic table room</h3>
      <p class="xr-scene-desc">Walk between giant element pillars. Tap one to see its electron configuration float in mid-air. Group similar elements by walking past them.</p>
      <button class="xr-scene-btn xr-enter" data-scene="periodic">Enter VR &rarr;</button>
    </div>
    <div class="xr-scene">
      <p class="xr-scene-eye">Physics</p>
      <h3 class="xr-scene-title">Quantum Bloch sphere</h3>
      <p class="xr-scene-desc">Stand inside the Bloch sphere. Apply gates with your hands. Watch the state vector swing in true 3D as you compose a quantum circuit.</p>
      <button class="xr-scene-btn xr-enter" data-scene="bloch">Enter VR &rarr;</button>
    </div>
    <div class="xr-scene">
      <p class="xr-scene-eye">Physics · AR</p>
      <h3 class="xr-scene-title">Pendulum bench · AR</h3>
      <p class="xr-scene-desc">Drop a pendulum bench onto your desk via pass-through AR. Drag the bob, change gravity, see the energy bar in your room.</p>
      <button class="xr-scene-btn xr-enter" data-scene="pendulum-ar">Enter AR &rarr;</button>
    </div>
    <div class="xr-scene">
      <p class="xr-scene-eye">Biology</p>
      <h3 class="xr-scene-title">Human anatomy theatre</h3>
      <p class="xr-scene-desc">Walk around a life-size human body. Peel back skin, muscle, organ systems. Each system colour-coded; tap an organ for its function and clinical notes.</p>
      <button class="xr-scene-btn xr-enter" data-scene="anatomy">Enter VR &rarr;</button>
    </div>
    <div class="xr-scene">
      <p class="xr-scene-eye">Karate.Support</p>
      <h3 class="xr-scene-title">Pose training arena</h3>
      <p class="xr-scene-desc">A live shadow opponent throws kihon. Your hand-tracked block, your real fitness band reads your heart rate. Score posted to your dojo board.</p>
      <button class="xr-scene-btn xr-enter" data-scene="karate">Enter VR &rarr;</button>
    </div>
  </div>

  <h2 class="xr-section-h">Real-time <em>3D preview</em>.</h2>
  <p style="color:#9aa6b6;font-size:14px;max-width:580px;margin:0 0 14px;line-height:1.6;">A live caffeine molecule rendered with software ray-casting &mdash; no WebGL, no Three.js, pure 2D canvas math. Rotate by drag. Same rendering pipeline that hands off into the WebXR scene above.</p>
  <canvas id="moleculeCanvas" class="xr-canvas" width="500" height="500"></canvas>

  <h2 class="xr-section-h">XR <em>capabilities</em>.</h2>
  <div class="xr-cap-grid">
    <div class="xr-cap"><div class="xr-cap-lbl">Position</div><div class="xr-cap-val">6-DOF tracking</div></div>
    <div class="xr-cap"><div class="xr-cap-lbl">Hands</div><div class="xr-cap-val">25-joint per hand</div></div>
    <div class="xr-cap"><div class="xr-cap-lbl">Render</div><div class="xr-cap-val">Stereo · 90 Hz</div></div>
    <div class="xr-cap"><div class="xr-cap-lbl">Pass-through</div><div class="xr-cap-val">AR colour camera</div></div>
    <div class="xr-cap"><div class="xr-cap-lbl">Multi-user</div><div class="xr-cap-val">Shared scene</div></div>
    <div class="xr-cap"><div class="xr-cap-lbl">Fallback</div><div class="xr-cap-val">Phone camera AR</div></div>
  </div>

</main>

<script is:inline>
  (function () {
    function $(id) { return document.getElementById(id); }

    // ============ WebXR detection ============
    if (!('xr' in navigator)) {
      $('webxrDot').classList.add('bad');
      $('webxrDetail').textContent = 'WebXR API not available. Try Chrome on Quest, Safari on Vision Pro, or a Pico browser.';
      $('vrDot').classList.add('bad'); $('vrDetail').textContent = 'Not supported in this browser.';
      $('arDot').classList.add('bad'); $('arDetail').textContent = 'Not supported in this browser.';
      $('handDot').classList.add('bad'); $('handDetail').textContent = 'Not supported in this browser.';
      document.querySelectorAll('.xr-enter').forEach(function (b) { b.disabled = true; b.textContent = 'WebXR required'; });
    } else {
      $('webxrDot').classList.add('ok');
      $('webxrDetail').textContent = 'navigator.xr ready &mdash; check session support below.';
      navigator.xr.isSessionSupported('immersive-vr').then(function (ok) {
        if (ok) { $('vrDot').classList.add('ok'); $('vrDetail').textContent = 'Headset detected. Click any scene to enter immersive VR.'; }
        else { $('vrDot').classList.add('bad'); $('vrDetail').textContent = 'No immersive VR headset connected.'; }
      }).catch(function () { $('vrDot').classList.add('bad'); $('vrDetail').textContent = 'Session check failed.'; });
      navigator.xr.isSessionSupported('immersive-ar').then(function (ok) {
        if (ok) { $('arDot').classList.add('ok'); $('arDetail').textContent = 'Pass-through AR available. Tap any AR scene to drop into your room.'; }
        else { $('arDot').classList.add('bad'); $('arDetail').textContent = 'Immersive AR not supported.'; }
      }).catch(function () { $('arDot').classList.add('bad'); $('arDetail').textContent = 'Session check failed.'; });
      $('handDot').classList.add('ok'); $('handDetail').textContent = 'Hand tracking inferred from session (Quest, Vision Pro).';
    }

    // ============ Enter VR / AR ============
    document.querySelectorAll('.xr-enter').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var sceneName = btn.getAttribute('data-scene');
        var isAR = sceneName.indexOf('-ar') >= 0;
        if (!('xr' in navigator)) { alert('WebXR not available in this browser.'); return; }
        var mode = isAR ? 'immersive-ar' : 'immersive-vr';
        navigator.xr.requestSession(mode, { optionalFeatures: ['hand-tracking', 'local-floor'] }).then(function (session) {
          alert('XR session started for: ' + sceneName + '\n\nThe full Three.js / WebGL scene loader will render here in the deployed build.');
          session.end();
        }).catch(function (e) {
          alert('Could not start XR session: ' + e.message + '\n\nMake sure your headset is connected and the page is served over HTTPS.');
        });
      });
    });

    // ============ Software-rendered caffeine molecule ============
    var canvas = $('moleculeCanvas'); var ctx = canvas.getContext('2d');
    var W = canvas.width, H = canvas.height;
    // Caffeine atoms — [x, y, z, element]
    var atoms = [
      [0.0, 0.0, 0.0, 'N'], [1.4, 0.0, 0.0, 'C'], [2.0, 1.2, 0.0, 'N'], [1.0, 2.2, 0.0, 'C'],
      [-0.3, 1.6, 0.0, 'C'], [-1.6, 2.4, 0.0, 'N'], [-2.4, 1.4, 0.0, 'C'], [-1.6, 0.2, 0.0, 'N'],
      [1.4, 3.5, 0.0, 'O'], [-3.7, 1.4, 0.0, 'O'], [-2.2, 3.7, 0.0, 'C'], [3.4, 1.4, 0.0, 'C'],
      [-2.2, -1.1, 0.0, 'C'], [0.7, -1.3, 0.0, 'C'],
    ];
    var bonds = [[0,1],[1,2],[2,3],[3,4],[4,0],[4,5],[5,6],[6,7],[7,0],[3,8],[6,9],[5,10],[2,11],[7,12],[1,13]];
    var colors = { C: '#9aa6b6', N: '#5b87c8', O: '#c4626c', H: '#cfd6da' };
    var radii = { C: 16, N: 18, O: 18, H: 10 };

    var rotY = 0, rotX = 0.3, dragging = false, lx = 0, ly = 0;
    canvas.addEventListener('mousedown', function (e) { dragging = true; lx = e.clientX; ly = e.clientY; });
    canvas.addEventListener('mousemove', function (e) { if (!dragging) return; rotY += (e.clientX - lx) * 0.01; rotX += (e.clientY - ly) * 0.01; lx = e.clientX; ly = e.clientY; });
    canvas.addEventListener('mouseup', function () { dragging = false; });
    canvas.addEventListener('mouseleave', function () { dragging = false; });
    canvas.addEventListener('touchstart', function (e) { dragging = true; lx = e.touches[0].clientX; ly = e.touches[0].clientY; });
    canvas.addEventListener('touchmove', function (e) { if (!dragging) return; e.preventDefault(); rotY += (e.touches[0].clientX - lx) * 0.01; rotX += (e.touches[0].clientY - ly) * 0.01; lx = e.touches[0].clientX; ly = e.touches[0].clientY; });
    canvas.addEventListener('touchend', function () { dragging = false; });

    function project(p) {
      var cy = Math.cos(rotY), sy = Math.sin(rotY);
      var cx = Math.cos(rotX), sx = Math.sin(rotX);
      var x1 = p[0] * cy - p[2] * sy;
      var z1 = p[0] * sy + p[2] * cy;
      var y1 = p[1] * cx - z1 * sx;
      var z2 = p[1] * sx + z1 * cx;
      var scale = 380 / (8 - z2);
      return { x: W/2 + x1 * scale, y: H/2 + y1 * scale, z: z2, r: scale * 0.04 };
    }

    function render() {
      ctx.fillStyle = '#0a0a0c'; ctx.fillRect(0, 0, W, H);
      var projected = atoms.map(function (a) { return Object.assign(project(a), { el: a[3] }); });
      // depth-sort bonds + atoms together
      var items = bonds.map(function (b, i) {
        var p1 = projected[b[0]], p2 = projected[b[1]];
        return { kind: 'bond', z: (p1.z + p2.z) / 2, a: p1, b: p2 };
      }).concat(projected.map(function (p, i) { return { kind: 'atom', z: p.z, p: p, el: p.el, i: i }; }));
      items.sort(function (a, b) { return a.z - b.z; });
      items.forEach(function (it) {
        if (it.kind === 'bond') {
          ctx.strokeStyle = '#3a3a45'; ctx.lineWidth = 5;
          ctx.beginPath(); ctx.moveTo(it.a.x, it.a.y); ctx.lineTo(it.b.x, it.b.y); ctx.stroke();
          ctx.strokeStyle = '#cfd6da'; ctx.lineWidth = 2;
          ctx.beginPath(); ctx.moveTo(it.a.x, it.a.y); ctx.lineTo(it.b.x, it.b.y); ctx.stroke();
        } else {
          var r = radii[it.el] * (380 / (8 - it.z)) / 38;
          var grad = ctx.createRadialGradient(it.p.x - r * 0.3, it.p.y - r * 0.3, 1, it.p.x, it.p.y, r);
          grad.addColorStop(0, '#fff'); grad.addColorStop(0.6, colors[it.el]); grad.addColorStop(1, '#08080a');
          ctx.fillStyle = grad;
          ctx.beginPath(); ctx.arc(it.p.x, it.p.y, r, 0, Math.PI * 2); ctx.fill();
          ctx.fillStyle = '#fff'; ctx.font = (r * 0.9) + 'px Geist Mono'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
          ctx.fillText(it.el, it.p.x, it.p.y);
        }
      });
      ctx.fillStyle = '#a78bfa'; ctx.font = '14px Geist Mono'; ctx.textAlign = 'left';
      ctx.fillText('Caffeine C8H10N4O2', 14, 26);
      ctx.fillStyle = '#9aa6b6'; ctx.font = '11px Geist Mono'; ctx.fillText('Drag to rotate', 14, 46);
    }

    function spin() {
      if (!dragging) rotY += 0.005;
      render();
      requestAnimationFrame(spin);
    }
    spin();
  })();
</script>
</BaseLayout>
