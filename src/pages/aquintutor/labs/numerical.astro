      return result;
    }

    function render() {
      // sort points by x for clean evaluation
      pts.sort(function (p, q) { return p[0] - q[0]; });
      var n = pts.length;
      $('ipN').textContent = n;
      $('ipDeg').textContent = n >= 1 ? (n - 1) : '--';
      $('ipStat').textContent = n + (n === 1 ? ' point' : ' points');

      var xmin = -5, xmax = 5, ymin = -5, ymax = 5;
      if (n) {
