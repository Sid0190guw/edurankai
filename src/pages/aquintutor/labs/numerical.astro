    function fillTable() {
      var body = $('rfBody'); body.innerHTML = '';
      var lim = (shown > 0) ? Math.min(shown, iters.length) : iters.length;
      for (var i = 0; i < lim; i++) {
        var it = iters[i];
        var tr = document.createElement('tr');
        if (i === lim - 1) tr.className = 'cur';
        tr.innerHTML = '<td>' + it.n + '</td><td>' + fmt(it.a, 4) + '</td><td>' + fmt(it.b, 4) +
          '</td><td>' + fmt(it.x, 6) + '</td><td>' + fmt(it.fx, 4) + '</td><td>' + fmt(it.err, 4) + '</td>';
        body.appendChild(tr);
