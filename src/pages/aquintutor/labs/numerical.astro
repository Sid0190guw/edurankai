  // ===================================================================
  // EXPERIMENT 1 — ROOT FINDING
  // ===================================================================
  (function RootFinding() {
    var cv = $('rfCv'); if (!cv) return;
    var ctx = makeCtx(cv, 680, 430);
    var plot = new Plotter(ctx, 680, 430);
    var f = makeF1($('rfFn').value);
    var method = 'bisect';
    var iters = [];       // each: {n, a, b, x, fx, err}
    var shown = 0;        // how many shown when stepping
    var root = null;

    function parseFn() {
      var src = $('rfFn').value;
      var g = makeF1(src);
      if (g) { f = g; $('rfFn').classList.remove('bad'); } else { f = null; $('rfFn').classList.add('bad'); }
    }

    function computeRange() {
      var a = parseFloat($('rfA').value), b = parseFloat($('rfB').value);
      var lo = Math.min(a, b) - 1, hi = Math.max(a, b) + 1;
      if (!isFinite(lo) || !isFinite(hi) || lo === hi) { lo = -3; hi = 3; }
      var ys = [], n = 120;
      for (var i = 0; i <= n; i++) {
        var x = lo + (hi - lo) * i / n;
        var y = f ? f(x) : 0;
