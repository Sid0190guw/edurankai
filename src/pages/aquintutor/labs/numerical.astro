      return { ssr: ssr, r2: sst > 1e-15 ? 1 - ssr / sst : (ssr < 1e-12 ? 1 : 0), rms: Math.sqrt(ssr / n) };
    }

    function eqStr(c) {
      var terms = [];
      for (var i = 0; i < c.length; i++) {
        var co = c[i];
        var t = fmt(co, 4);
