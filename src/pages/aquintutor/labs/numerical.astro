        for (var i = 0; i < n; i++) { xmin = Math.min(xmin, pts[i][0]); xmax = Math.max(xmax, pts[i][0]); ymin = Math.min(ymin, pts[i][1]); ymax = Math.max(ymax, pts[i][1]); }
