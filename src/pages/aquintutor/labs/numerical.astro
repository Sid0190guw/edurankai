        o: ['Speed up the algorithm', 'Reduce round-off error and avoid tiny pivots', 'Make the matrix symmetric', 'Guarantee a unique solution'], a: 1,
        e: 'Choosing the largest-magnitude pivot limits growth of round-off and avoids dividing by ~0.' },
      { q: 'In an LU factorisation with PA = LU, the matrix L is:',
        o: ['Upper triangular', 'Unit lower triangular (the multipliers)', 'Diagonal', 'Orthogonal'], a: 1,
        e: 'L is unit lower triangular and stores the elimination multipliers; U is upper triangular.' },
      { q: 'Once A = LU is known, solving Ax = b for a new b needs only:',
        o: ['A full re-elimination', 'A forward solve then a back solve', 'A matrix inverse', 'An iterative method'], a: 1,
        e: 'Solve Ly = Pb (forward) then Ux = y (backward) - far cheaper than re-eliminating.' },
      { q: 'Gauss-Seidel iteration is guaranteed to converge when the matrix A is:',
        o: ['Singular', 'Strictly diagonally dominant', 'Upper triangular', 'Symmetric only'], a: 1,
        e: 'Strict diagonal dominance (or symmetric positive definiteness) guarantees convergence.' }
    ],
    '6': [
      { q: 'Least-squares fitting minimises the sum of:',
        o: ['Absolute residuals', 'Squared vertical residuals', 'Perpendicular distances', 'Relative errors'], a: 1,
        e: 'Ordinary least squares minimises the sum of squared vertical residuals y_i minus P(x_i).' },
      { q: 'The coefficients of a least-squares polynomial fit are found by solving the:',
        o: ['Characteristic equation', 'Normal equations (X-transpose X)c = X-transpose y', 'Euler equations', 'Heat equation'], a: 1,
        e: 'Setting the gradient of the squared error to zero yields the normal equations.' },
      { q: 'A coefficient of determination R squared close to 1 indicates that:',
        o: ['The fit explains most of the variance', 'The data are random', 'The degree is too low', 'The residuals are large'], a: 0,
        e: 'R squared = 1 minus SS_res / SS_tot; near one means the model captures most variation.' },
      { q: 'Raising the polynomial degree until it passes through every point typically causes:',
        o: ['Better prediction', 'Over-fitting of the noise', 'Lower R squared', 'A singular design matrix always'], a: 1,
        e: 'High degree drives SS_res to zero by chasing noise, hurting prediction on new data: over-fitting.' }
    ]
  };

  function buildQuiz(host) {
    var qid = host.getAttribute('data-quiz');
    var qs = QUIZZES[qid]; if (!qs) return;
    var selections = new Array(qs.length).fill(-1);
    var checked = false;
    for (var i = 0; i < qs.length; i++) {
      (function (item, idx) {
        var card = document.createElement('div');
        card.className = 'q';
        var qt = document.createElement('div');
        qt.className = 'qt';
        qt.innerHTML = '<b>Q' + (idx + 1) + '.</b> ' + item.q;
        card.appendChild(qt);
        var opts = [];
        for (var j = 0; j < item.o.length; j++) {
          (function (optIdx) {
            var op = document.createElement('div');
            op.className = 'opt-a';
            op.textContent = item.o[optIdx];
            op.addEventListener('click', function () {
              if (checked) return;
              selections[idx] = optIdx;
              for (var m = 0; m < opts.length; m++) opts[m].classList.remove('sel');
              op.classList.add('sel');
            });
            opts.push(op);
            card.appendChild(op);
          })(j);
        }
        var expl = document.createElement('div');
        expl.className = 'expl';
        expl.innerHTML = '<b>Answer:</b> ' + item.o[item.a] + '. ' + item.e;
        card.appendChild(expl);
        host.appendChild(card);
        host._cards = host._cards || []; host._cards.push({ card: card, opts: opts, item: item, idx: idx });
      })(qs[i], i);
    }
    // footer with Check button + score
    var foot = document.createElement('div');
    foot.className = 'quizfoot';
    var btn = document.createElement('button');
    btn.className = 'btn green'; btn.textContent = 'Check answers';
    var score = document.createElement('div'); score.className = 'score';
    foot.appendChild(btn); foot.appendChild(score);
    host.appendChild(foot);

    btn.addEventListener('click', function () {
      if (!checked) {
        checked = true; var correct = 0;
        for (var c = 0; c < host._cards.length; c++) {
          var rec = host._cards[c];
          var sel = selections[rec.idx];
          for (var m = 0; m < rec.opts.length; m++) {
            rec.opts[m].classList.remove('sel');
            if (m === rec.item.a) rec.opts[m].classList.add('correct');
            else if (m === sel) rec.opts[m].classList.add('wrong');
          }
          if (sel === rec.item.a) correct++; else rec.card.classList.add('bad');
          rec.card.querySelector('.expl').classList.add('show');
        }
        score.innerHTML = 'Score: <b>' + correct + ' / ' + host._cards.length + '</b>';
        btn.textContent = 'Reset';
      } else {
        checked = false; selections = new Array(qs.length).fill(-1);
        for (var c2 = 0; c2 < host._cards.length; c2++) {
          var rec2 = host._cards[c2];
          rec2.card.classList.remove('bad');
          rec2.card.querySelector('.expl').classList.remove('show');
          for (var m2 = 0; m2 < rec2.opts.length; m2++) rec2.opts[m2].className = 'opt-a';
        }
        score.innerHTML = ''; btn.textContent = 'Check answers';
      }
    });
  }
  var quizHosts = document.querySelectorAll('.nmx .quiz');
  for (var qh = 0; qh < quizHosts.length; qh++) buildQuiz(quizHosts[qh]);

  // initial draw of experiment 1
  if (REDRAW['1']) { try { REDRAW['1'](); } catch (e) {} }
  window.addEventListener('resize', function () {
    var onExp = document.querySelector('.nmx .exp.on');
    if (onExp) { var n = onExp.id.split('-')[1]; if (REDRAW[n]) { try { REDRAW[n](); } catch (e) {} } }
  });
})();
</script>
</BaseLayout>
