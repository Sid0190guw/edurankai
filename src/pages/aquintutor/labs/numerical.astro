        pts.push([+x.toFixed(3), +y.toFixed(3)]);
      }
      render();
    });

    REDRAW['6'] = function () { ctx = makeCtx(cv, 680, 430); plot = new Plotter(ctx, 680, 430); $('lsqNoisev').textContent = (parseInt($('lsqNoise').value, 10) / 100).toFixed(2); render(); };
    $('lsqNoisev').textContent = (parseInt($('lsqNoise').value, 10) / 100).toFixed(2);
    render();
  })();

