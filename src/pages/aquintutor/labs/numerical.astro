    function stats(c) {
      var n = pts.length, ybar = 0;
      for (var i = 0; i < n; i++) ybar += pts[i][1]; ybar /= n;
      var ssr = 0, sst = 0;
      for (var j = 0; j < n; j++) {
        var pred = evalPoly(c, pts[j][0]);
        ssr += (pts[j][1] - pred) * (pts[j][1] - pred);
        sst += (pts[j][1] - ybar) * (pts[j][1] - ybar);
