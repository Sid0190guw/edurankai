  (function LeastSquares() {
    var cv = $('lsqCv'); if (!cv) return;
    var ctx = makeCtx(cv, 680, 430);
    var plot = new Plotter(ctx, 680, 430);
    var pts = [];
    var deg = 1;
    var coeffs = null;

    // seed with noisy quadratic
    (function seed() {
      for (var i = 0; i < 14; i++) {
        var x = -4 + 8 * i / 13;
        var y = 0.4 * x * x - 0.5 * x + 1 + (Math.random() - 0.5) * 1.6;
        pts.push([+x.toFixed(3), +y.toFixed(3)]);
      }
    })();

    // solve normal equations (X'X)c = X'y via Gaussian elimination
    function solveNormal(d) {
      var m = d + 1, n = pts.length;
      if (n < m) return null;
      // build X'X (m x m) and X'y (m)
      var XtX = [], Xty = [];
      for (var i = 0; i < m; i++) { XtX.push(new Array(m).fill(0)); Xty.push(0); }
      for (var p = 0; p < n; p++) {
        var x = pts[p][0], y = pts[p][1];
        var pw = []; var v = 1; for (var k = 0; k <= 2 * d; k++) { pw.push(v); v *= x; }
        for (var r = 0; r < m; r++) {
          for (var c = 0; c < m; c++) XtX[r][c] += pw[r + c];
          Xty[r] += pw[r] * y;
