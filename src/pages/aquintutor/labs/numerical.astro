      var n = parseInt($('inN').value, 10);
      $('inNv').textContent = n;
      if (!f || !isFinite(a) || !isFinite(b) || a === b) {
        $('inEst').textContent = '--'; $('inRef').textContent = '--'; $('inErr').textContent = '--';
        $('inH').textContent = '--'; $('inNeff').textContent = '--'; $('inOrder').textContent = '--';
        render(a, b, n, null); return;
