      var tol = Math.abs(parseFloat($('rfTol').value)) || 1e-6;
      var maxIt = Math.max(1, Math.min(200, parseInt($('rfMax').value, 10) || 40));
      if (cap !== undefined) maxIt = Math.min(maxIt, cap);
      var a = parseFloat($('rfA').value), b = parseFloat($('rfB').value);

