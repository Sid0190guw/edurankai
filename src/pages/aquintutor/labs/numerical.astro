        var range = xmax - xmin || 2; xmin -= range * 0.15; xmax += range * 0.15;
        ymin = Infinity; ymax = -Infinity;
        for (var i = 0; i < n; i++) { ymin = Math.min(ymin, pts[i][1]); ymax = Math.max(ymax, pts[i][1]); }
