      }
      // Gaussian elimination with partial pivoting
      var M = XtX.map(function (r) { return r.slice(); }), b = Xty.slice();
      for (var col = 0; col < m; col++) {
        var piv = col; for (var rr = col + 1; rr < m; rr++) if (Math.abs(M[rr][col]) > Math.abs(M[piv][col])) piv = rr;
        if (Math.abs(M[piv][col]) < 1e-14) return null;
        if (piv !== col) { var t = M[col]; M[col] = M[piv]; M[piv] = t; var tb = b[col]; b[col] = b[piv]; b[piv] = tb; }
        for (var rr2 = col + 1; rr2 < m; rr2++) {
          var f = M[rr2][col] / M[col][col];
          for (var cc = col; cc < m; cc++) M[rr2][cc] -= f * M[col][cc];
          b[rr2] -= f * b[col];
        }
      }
      var c2 = new Array(m);
      for (var rb = m - 1; rb >= 0; rb--) { var s = b[rb]; for (var cb = rb + 1; cb < m; cb++) s -= M[rb][cb] * c2[cb]; c2[rb] = s / M[rb][rb]; }
      return c2;
    }
