  // ===================================================================
  // EXPERIMENT 4 — ODE SOLVERS
  // ===================================================================
  (function ODE() {
    var cv = $('odCv'); if (!cv) return;
    var ctx = makeCtx(cv, 680, 430);
    var plot = new Plotter(ctx, 680, 430);
    var show = { euler: true, heun: true, rk4: true };

    // each preset: f(x,y), exact(x) or null, default y0,x0
    var presets = [
      { f: function (x, y) { return y; }, exact: function (x, x0, y0) { return y0 * Math.exp(x - x0); }, x0: 0, y0: 1 },
      { f: function (x, y) { return x + y; }, exact: function (x) { return 2 * Math.exp(x) - x - 1; }, x0: 0, y0: 1 },
      { f: function (x, y) { return -2 * y; }, exact: function (x, x0, y0) { return y0 * Math.exp(-2 * (x - x0)); }, x0: 0, y0: 1 },
      { f: function (x, y) { return x - y; }, exact: function (x) { return x - 1 + 2 * Math.exp(-x); }, x0: 0, y0: 1 },
      { f: function (x, y) { return y - x * x + 1; }, exact: function (x) { return (x + 1) * (x + 1) - 0.5 * Math.exp(x); }, x0: 0, y0: 0.5 },
      { f: function (x, y) { return Math.cos(x); }, exact: function (x) { return Math.sin(x); }, x0: 0, y0: 0 }
    ];
    var pid = 0;

    function integrate(f, x0, y0, h, N, method) {
      var xs = [x0], ys = [y0], x = x0, y = y0;
      for (var i = 0; i < N; i++) {
