      if (coeffs) {
        var st = stats(coeffs);
        $('lsqR2').textContent = fmt(st.r2, 5);
        $('lsqSSR').textContent = fmt(st.ssr, 4);
        $('lsqRMS').textContent = fmt(st.rms, 4);
        $('lsqEq').innerHTML = '<div class="mrow">' + eqStr(coeffs) + '</div>';
      } else {
        $('lsqR2').textContent = '--'; $('lsqSSR').textContent = '--'; $('lsqRMS').textContent = '--';
