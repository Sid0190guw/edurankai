---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Neural network playground · Virtual Labs · AquinTutor" description="Build a 3-layer neural net. Watch the decision boundary form as gradient descent runs.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; }
  .nn-wrap { max-width: 1300px; margin: 0 auto; padding: 20px 4vw 60px; }
  .nn-top { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 14px; margin-bottom: 18px; }
  .nn-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .nn-title { font-family: 'Cormorant Garamond', serif; font-size: 36px; font-weight: 600; margin: 4px 0 0; letter-spacing: -0.02em; }
  .nn-title em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .nn-grid { display: grid; grid-template-columns: 260px minmax(0,1fr); gap: 16px; }
  @media (max-width: 1000px) { .nn-grid { grid-template-columns: 1fr; } }
  .nn-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 14px; margin-bottom: 12px; }
  .nn-panel h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin: 0 0 10px; }
  .nn-row label { font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #9aa6b6; display: block; margin: 8px 0 4px; }
  .nn-row input, .nn-row select { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; color: #fff; padding: 6px 10px; border-radius: 5px; font-size: 12px; box-sizing: border-box; font-family: inherit; }
  .nn-btn { background: #FF4F00; color: #fff; padding: 9px 16px; border-radius: 6px; border: none; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
  .nn-btn-ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
  .nn-canvas { width: 100%; aspect-ratio: 1.4 / 1; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 12px; }
  .nn-metric { display: grid; grid-template-columns: 1fr auto; padding: 5px 0; border-bottom: 1px solid #1a1a25; font-family: 'Geist Mono', monospace; font-size: 11.5px; }
  .nn-metric:last-child { border-bottom: none; }
  .nn-metric-l { color: #9aa6b6; }
  .nn-metric-v { color: #FF4F00; font-weight: 700; }
  .nn-arch-pill { display: inline-flex; gap: 8px; margin-top: 8px; flex-wrap: wrap; }
  .nn-arch-pill span { font-family: 'Geist Mono', monospace; font-size: 10px; padding: 3px 8px; background: #1a1a25; border-radius: 100px; color: #67e8f9; letter-spacing: 0.06em; }
</style>

<main class="nn-wrap">
  <div class="nn-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#FF4F00;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="nn-eye" style="margin-top:10px;">AI · Supervised learning</p>
      <h1 class="nn-title">Neural net <em>playground</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;">
      <button id="resetBtn" class="nn-btn nn-btn-ghost">Reset</button>
      <button id="playBtn" class="nn-btn">Pause</button>
    </div>
  </div>

  <div class="nn-grid">
    <aside>
      <div class="nn-panel">
        <h3>Architecture</h3>
        <div class="nn-row">
          <label>Dataset</label>
          <select id="dataset">
            <option value="spiral">Spiral</option>
            <option value="moons">Two moons</option>
            <option value="circles">Concentric circles</option>
            <option value="xor">XOR</option>
            <option value="linear">Linearly separable</option>
          </select>
          <label>Hidden layer 1 size</label>
          <input id="h1" type="number" min="1" max="20" value="6"/>
          <label>Hidden layer 2 size (0 = no L2)</label>
          <input id="h2" type="number" min="0" max="20" value="4"/>
          <label>Activation</label>
          <select id="act"><option value="relu">ReLU</option><option value="tanh" selected>Tanh</option><option value="sigmoid">Sigmoid</option></select>
          <label>Learning rate</label>
          <input id="lr" type="number" min="0.001" max="1" step="0.001" value="0.05"/>
        </div>
        <div class="nn-arch-pill">
          <span>2 input</span><span id="archH1">6 hidden</span><span id="archH2">4 hidden</span><span>1 output</span>
        </div>
      </div>

      <div class="nn-panel">
        <h3>Live metrics</h3>
        <div class="nn-metric"><span class="nn-metric-l">Epoch</span><span class="nn-metric-v" id="mEpoch">0</span></div>
        <div class="nn-metric"><span class="nn-metric-l">Loss</span><span class="nn-metric-v" id="mLoss">—</span></div>
        <div class="nn-metric"><span class="nn-metric-l">Accuracy</span><span class="nn-metric-v" id="mAcc">—</span></div>
        <div class="nn-metric"><span class="nn-metric-l">Parameters</span><span class="nn-metric-v" id="mParams">—</span></div>
      </div>

      <div class="nn-panel">
        <h3>Loss curve</h3>
        <svg id="lossPlot" width="100%" height="120" viewBox="0 0 240 120"></svg>
      </div>
    </aside>

    <section>
      <canvas id="nnCanvas" class="nn-canvas" width="700" height="500"></canvas>
      <p style="font-family:'Geist Mono',monospace;font-size:10.5px;color:#9aa6b6;margin-top:8px;letter-spacing:0.06em;">The shaded background shows the model's predicted class. Dots are training samples — orange = class 0, cyan = class 1. Click + drag to add training points.</p>
    </section>
  </div>
</main>

<script is:inline>
  /* =========================================================
     Vanilla neural network — forward + backward + SGD.
     Architecture: 2 -> H1 -> H2? -> 1
     ========================================================= */
  (function () {
    var act = 'tanh', lr = 0.05;
    var weights = null, biases = null;
    var layers = []; // sizes
    var data = []; // {x, y, label}
    var epoch = 0;
    var paused = false;
    var lossHistory = [];

    function rand() { return (Math.random() * 2 - 1) * 0.5; }
    function initNet() {
      var h1 = Math.max(1, parseInt(document.getElementById('h1').value, 10));
      var h2 = Math.max(0, parseInt(document.getElementById('h2').value, 10));
      layers = [2, h1];
      if (h2 > 0) layers.push(h2);
      layers.push(1);
      weights = []; biases = [];
      for (var i = 0; i < layers.length - 1; i++) {
        var w = []; for (var r = 0; r < layers[i+1]; r++) { var row = []; for (var c = 0; c < layers[i]; c++) row.push(rand()); w.push(row); }
        weights.push(w);
        var bb = []; for (var k = 0; k < layers[i+1]; k++) bb.push(rand());
        biases.push(bb);
      }
      epoch = 0; lossHistory = [];
      var params = 0;
      for (var i = 0; i < weights.length; i++) params += weights[i].length * weights[i][0].length + biases[i].length;
      document.getElementById('mParams').textContent = params;
      document.getElementById('archH1').textContent = h1 + ' hidden';
      document.getElementById('archH2').textContent = h2 > 0 ? (h2 + ' hidden') : '—';
    }

    function activation(z) {
      if (act === 'relu') return Math.max(0, z);
      if (act === 'sigmoid') return 1 / (1 + Math.exp(-z));
      return Math.tanh(z);
    }
    function activationGrad(a) {
      if (act === 'relu') return a > 0 ? 1 : 0;
      if (act === 'sigmoid') return a * (1 - a);
      return 1 - a * a;
    }

    function forward(input) {
      var activations = [input.slice()];
      var zs = [];
      for (var i = 0; i < weights.length; i++) {
        var z = []; var aOut = [];
        for (var r = 0; r < weights[i].length; r++) {
          var sum = biases[i][r];
          for (var c = 0; c < weights[i][r].length; c++) sum += weights[i][r][c] * activations[i][c];
          z.push(sum);
          // last layer = sigmoid (binary classification)
          aOut.push(i === weights.length - 1 ? 1 / (1 + Math.exp(-sum)) : activation(sum));
        }
        zs.push(z); activations.push(aOut);
      }
      return { activations: activations, zs: zs };
    }

    function backward(input, target) {
      var fp = forward(input);
      var a = fp.activations;
      var prediction = a[a.length - 1][0];
      var error = prediction - target;
      var dW = []; var dB = [];
      for (var i = 0; i < weights.length; i++) {
        var rows = weights[i].length, cols = weights[i][0].length;
        var w = []; for (var r = 0; r < rows; r++) { var row = []; for (var c = 0; c < cols; c++) row.push(0); w.push(row); }
        dW.push(w);
        var bb = []; for (var k = 0; k < rows; k++) bb.push(0);
        dB.push(bb);
      }
      // output layer delta
      var delta = [error]; // last layer
      for (var i = weights.length - 1; i >= 0; i--) {
        for (var r = 0; r < weights[i].length; r++) {
          dB[i][r] = delta[r];
          for (var c = 0; c < weights[i][r].length; c++) dW[i][r][c] = delta[r] * a[i][c];
        }
        if (i > 0) {
          var newDelta = [];
          for (var c = 0; c < weights[i][0].length; c++) {
            var s = 0;
            for (var r = 0; r < weights[i].length; r++) s += delta[r] * weights[i][r][c];
            newDelta.push(s * activationGrad(a[i][c]));
          }
          delta = newDelta;
        }
      }
      // apply
      for (var i = 0; i < weights.length; i++) {
        for (var r = 0; r < weights[i].length; r++) {
          biases[i][r] -= lr * dB[i][r];
          for (var c = 0; c < weights[i][r].length; c++) weights[i][r][c] -= lr * dW[i][r][c];
        }
      }
      return 0.5 * error * error;
    }

    function trainEpoch() {
      var totalLoss = 0; var correct = 0;
      for (var i = 0; i < data.length; i++) {
        var d = data[i];
        var loss = backward([d.x, d.y], d.label);
        totalLoss += loss;
        var p = forward([d.x, d.y]).activations.slice(-1)[0][0];
        if ((p > 0.5 ? 1 : 0) === d.label) correct++;
      }
      epoch++;
      var avg = totalLoss / Math.max(1, data.length);
      var acc = correct / Math.max(1, data.length);
      lossHistory.push(avg); if (lossHistory.length > 240) lossHistory.shift();
      document.getElementById('mEpoch').textContent = epoch;
      document.getElementById('mLoss').textContent = avg.toFixed(4);
      document.getElementById('mAcc').textContent = (acc * 100).toFixed(1) + '%';
    }

    function genData() {
      data = [];
      var d = document.getElementById('dataset').value;
      var N = 80;
      if (d === 'spiral') {
        for (var c = 0; c < 2; c++) {
          for (var i = 0; i < N/2; i++) {
            var r = i / (N/2) * 1.2;
            var t = i * 0.3 + c * Math.PI;
            data.push({ x: r * Math.sin(t) + (Math.random()-0.5)*0.1, y: r * Math.cos(t) + (Math.random()-0.5)*0.1, label: c });
          }
        }
      } else if (d === 'moons') {
        for (var i = 0; i < N/2; i++) {
          var t = Math.PI * i / (N/2);
          data.push({ x: Math.cos(t) + (Math.random()-0.5)*0.15, y: Math.sin(t) + (Math.random()-0.5)*0.15, label: 0 });
          data.push({ x: 1 - Math.cos(t) + (Math.random()-0.5)*0.15, y: 0.5 - Math.sin(t) + (Math.random()-0.5)*0.15, label: 1 });
        }
      } else if (d === 'circles') {
        for (var i = 0; i < N/2; i++) {
          var t = Math.random() * Math.PI * 2;
          data.push({ x: 0.4 * Math.cos(t) + (Math.random()-0.5)*0.1, y: 0.4 * Math.sin(t) + (Math.random()-0.5)*0.1, label: 0 });
          data.push({ x: 1.1 * Math.cos(t) + (Math.random()-0.5)*0.1, y: 1.1 * Math.sin(t) + (Math.random()-0.5)*0.1, label: 1 });
        }
      } else if (d === 'xor') {
        for (var i = 0; i < N; i++) {
          var x = (Math.random()*2-1), y = (Math.random()*2-1);
          var lab = (x*y > 0) ? 1 : 0;
          data.push({ x: x, y: y, label: lab });
        }
      } else { // linear
        for (var i = 0; i < N; i++) {
          var x = (Math.random()*2-1), y = (Math.random()*2-1);
          data.push({ x: x, y: y, label: (x + y > 0) ? 1 : 0 });
        }
      }
    }

    function draw() {
      var canvas = document.getElementById('nnCanvas');
      var ctx = canvas.getContext('2d');
      var W = canvas.width, H = canvas.height;
      // decision boundary — downsample
      var step = 8;
      for (var px = 0; px < W; px += step) {
        for (var py = 0; py < H; py += step) {
          var x = (px / W) * 4 - 2;
          var y = (py / H) * 4 - 2;
          var p = forward([x, y]).activations.slice(-1)[0][0];
          var r = Math.round(255 * p);
          ctx.fillStyle = p > 0.5 ? 'rgba(103, 232, 249, ' + (Math.min(1, (p - 0.5) * 1.5)).toFixed(3) + ')' : 'rgba(255, 79, 0, ' + (Math.min(1, (0.5 - p) * 1.5)).toFixed(3) + ')';
          ctx.fillRect(px, py, step, step);
        }
      }
      // data points
      data.forEach(function (d) {
        var px = (d.x + 2) / 4 * W;
        var py = (d.y + 2) / 4 * H;
        ctx.fillStyle = d.label === 1 ? '#67e8f9' : '#FF4F00';
        ctx.beginPath(); ctx.arc(px, py, 5, 0, Math.PI * 2); ctx.fill();
        ctx.strokeStyle = '#fff'; ctx.lineWidth = 1.5; ctx.stroke();
      });
    }

    function drawLossPlot() {
      var svg = document.getElementById('lossPlot'); svg.innerHTML = '';
      if (lossHistory.length < 2) return;
      var max = Math.max.apply(null, lossHistory) || 1;
      var d = '';
      lossHistory.forEach(function (l, i) {
        var x = (i / Math.max(1, lossHistory.length - 1)) * 230 + 5;
        var y = 110 - (l / max) * 100;
        d += (i === 0 ? 'M' : 'L') + x + ',' + y;
      });
      svg.innerHTML = '<path d="' + d + '" fill="none" stroke="#FF4F00" stroke-width="1.5"/>';
    }

    document.getElementById('resetBtn').addEventListener('click', function () { initNet(); });
    document.getElementById('playBtn').addEventListener('click', function () { paused = !paused; this.textContent = paused ? 'Play' : 'Pause'; });
    ['dataset','act','lr','h1','h2'].forEach(function (id) { document.getElementById(id).addEventListener('change', function () {
      act = document.getElementById('act').value;
      lr = parseFloat(document.getElementById('lr').value);
      if (id === 'dataset') genData();
      initNet();
    }); });

    document.getElementById('nnCanvas').addEventListener('click', function (e) {
      var r = e.target.getBoundingClientRect();
      var x = ((e.clientX - r.left) / r.width) * 4 - 2;
      var y = ((e.clientY - r.top) / r.height) * 4 - 2;
      var label = e.shiftKey ? 1 : 0;
      data.push({ x: x, y: y, label: label });
    });

    genData(); initNet();
    function loop() {
      if (!paused) { trainEpoch(); draw(); drawLossPlot(); }
      requestAnimationFrame(loop);
    }
    requestAnimationFrame(loop);
  })();
</script>
</BaseLayout>
