---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Neural network playground · Virtual Labs · AquinTutor" description="Build a real feed-forward net, train it with backpropagation, watch the decision boundary form. 5 datasets, 3 activations, live loss + accuracy. Pure browser.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; }
  .nn-wrap { max-width: 1400px; margin: 0 auto; padding: 18px 4vw 60px; }
  .nn-top { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 14px; margin-bottom: 18px; }
  .nn-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; }
  .nn-title { font-family: 'Cormorant Garamond', serif; font-size: 34px; font-weight: 600; margin: 4px 0 0; letter-spacing: -0.02em; }
  .nn-title em { color: #67e8f9; font-style: italic; font-weight: 500; }
  .nn-grid { display: grid; grid-template-columns: 300px minmax(0,1fr); gap: 18px; }
  @media (max-width: 1000px) { .nn-grid { grid-template-columns: 1fr; } }
  .nn-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 16px; margin-bottom: 12px; }
  .nn-panel h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 10px; }
  .nn-row label { font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; display: flex; justify-content: space-between; margin-bottom: 4px; }
  .nn-row label span { color: #67e8f9; }
  .nn-row input[type=range], .nn-row input[type=number] { width: 100%; box-sizing: border-box; }
  .nn-row input[type=number], .nn-row select { background: #0a0a0c; border: 1px solid #2a2a35; color: #fff; padding: 7px 10px; border-radius: 5px; font-size: 12px; font-family: inherit; margin-bottom: 10px; }
  .nn-btn { background: #67e8f9; color: #04161b; padding: 9px 16px; border-radius: 6px; border: none; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
  .nn-btn-ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
  .nn-canvas-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  @media (max-width: 800px) { .nn-canvas-wrap { grid-template-columns: 1fr; } }
  .nn-canvas { width: 100%; aspect-ratio: 1; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 10px; cursor: crosshair; }
  .nn-plot { width: 100%; height: 160px; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; }
  .nn-metric { display: grid; grid-template-columns: 1fr auto; gap: 8px; font-family: 'Geist Mono', monospace; font-size: 12px; padding: 5px 0; border-bottom: 1px solid #1a1a25; }
  .nn-metric:last-child { border-bottom: none; }
  .nn-metric-l { color: #9aa6b6; }
  .nn-metric-v { color: #67e8f9; font-weight: 700; }
</style>

<main class="nn-wrap">
  <div class="nn-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#67e8f9;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="nn-eye" style="margin-top:10px;">AI · Neural networks</p>
      <h1 class="nn-title">Neural network <em>playground</em>.</h1>
    </div>
    <div style="display:flex;gap:6px;flex-wrap:wrap;">
      <button id="resetBtn" class="nn-btn nn-btn-ghost">Reset weights</button>
      <button id="trainBtn" class="nn-btn">Train</button>
      <button id="stepBtn" class="nn-btn nn-btn-ghost">Step</button>
    </div>
  </div>

  <div class="nn-grid">
    <aside>
      <div class="nn-panel">
        <h3>Architecture</h3>
        <div class="nn-row">
          <label>Hidden layers <span id="hLV">1</span></label>
          <input id="numHidden" type="number" min="0" max="3" value="1" step="1"/>
          <label>Neurons per hidden layer <span id="hUV">8</span></label>
          <input id="hUnits" type="number" min="1" max="16" value="8" step="1"/>
          <label>Activation</label>
          <select id="activation">
            <option value="tanh" selected>tanh</option>
            <option value="relu">ReLU</option>
            <option value="sigmoid">sigmoid</option>
          </select>
        </div>
      </div>
      <div class="nn-panel">
        <h3>Training</h3>
        <div class="nn-row">
          <label>Learning rate <span id="lrV">0.030</span></label>
          <input id="lr" type="range" min="0.001" max="0.3" step="0.001" value="0.03"/>
          <label>Batch size <span id="bsV">16</span></label>
          <input id="bs" type="range" min="1" max="64" step="1" value="16"/>
          <label>L2 regularisation <span id="l2V">0.001</span></label>
          <input id="l2" type="range" min="0" max="0.1" step="0.001" value="0.001"/>
        </div>
      </div>
      <div class="nn-panel">
        <h3>Dataset</h3>
        <select id="dataset">
          <option value="spiral" selected>Spiral · 2 classes</option>
          <option value="moons">Two moons</option>
          <option value="circles">Concentric circles</option>
          <option value="xor">XOR</option>
          <option value="linear">Linear-separable</option>
        </select>
        <p style="font-size:11px;color:#9aa6b6;margin:8px 0 0;line-height:1.55;">Click on the canvas to add a positive (orange) sample. Shift-click for negative (cyan). Right-click to remove nearest point.</p>
      </div>
      <div class="nn-panel">
        <h3>Live metrics</h3>
        <div class="nn-metric"><span class="nn-metric-l">Epoch</span><span class="nn-metric-v" id="mEp">0</span></div>
        <div class="nn-metric"><span class="nn-metric-l">Loss</span><span class="nn-metric-v" id="mLoss">&mdash;</span></div>
        <div class="nn-metric"><span class="nn-metric-l">Accuracy</span><span class="nn-metric-v" id="mAcc">&mdash;</span></div>
        <div class="nn-metric"><span class="nn-metric-l">Training points</span><span class="nn-metric-v" id="mN">0</span></div>
      </div>
    </aside>

    <section>
      <div class="nn-canvas-wrap">
        <div>
          <p class="nn-eye">Data &amp; decision boundary</p>
          <canvas id="dataCanvas" class="nn-canvas" width="400" height="400"></canvas>
        </div>
        <div>
          <p class="nn-eye">Loss &middot; accuracy over epochs</p>
          <svg id="lossPlot" class="nn-plot" viewBox="0 0 600 160"></svg>
          <p class="nn-eye" style="margin-top:10px;">Network topology</p>
          <svg id="topoSvg" class="nn-plot" viewBox="0 0 600 200" style="height:200px;"></svg>
        </div>
      </div>
    </section>
  </div>
</main>

<script is:inline>
  (function () {
    function genSpiral(n) {
      var pts = [];
      for (var c = 0; c < 2; c++) {
        for (var i = 0; i < n; i++) {
          var r = (i / n) * 4;
          var t = (i / n) * 4 * Math.PI + c * Math.PI + (Math.random() - 0.5) * 0.5;
          pts.push([r * Math.sin(t) / 5, r * Math.cos(t) / 5, c]);
        }
      }
      return pts;
    }
    function genMoons(n) {
      var pts = [];
      for (var i = 0; i < n; i++) {
        var t1 = Math.PI * i / n;
        pts.push([Math.cos(t1) * 0.6 + (Math.random() - 0.5) * 0.1 - 0.5, Math.sin(t1) * 0.6 + (Math.random() - 0.5) * 0.1 - 0.15, 0]);
        pts.push([1 - Math.cos(t1) * 0.6 + (Math.random() - 0.5) * 0.1 - 0.5, -Math.sin(t1) * 0.6 + 0.3 + (Math.random() - 0.5) * 0.1 - 0.15, 1]);
      }
      return pts;
    }
    function genCircles(n) {
      var pts = [];
      for (var i = 0; i < n; i++) {
        var t = (i / n) * 2 * Math.PI;
        pts.push([Math.cos(t) * 0.3 + (Math.random() - 0.5) * 0.05, Math.sin(t) * 0.3 + (Math.random() - 0.5) * 0.05, 0]);
        pts.push([Math.cos(t) * 0.7 + (Math.random() - 0.5) * 0.05, Math.sin(t) * 0.7 + (Math.random() - 0.5) * 0.05, 1]);
      }
      return pts;
    }
    function genXor(n) {
      var pts = [];
      for (var i = 0; i < n * 2; i++) {
        var x = (Math.random() - 0.5) * 1.5; var y = (Math.random() - 0.5) * 1.5;
        var c = (x * y > 0) ? 0 : 1;
        pts.push([x, y, c]);
      }
      return pts;
    }
    function genLinear(n) {
      var pts = [];
      for (var i = 0; i < n * 2; i++) {
        var x = (Math.random() - 0.5) * 1.5; var y = (Math.random() - 0.5) * 1.5;
        pts.push([x, y, x + y > 0 ? 1 : 0]);
      }
      return pts;
    }

    var net = null;
    function build(layerSizes, activation) {
      var layers = [];
      for (var l = 1; l < layerSizes.length; l++) {
        var nin = layerSizes[l - 1], nout = layerSizes[l];
        var W = []; var b = [];
        var scale = Math.sqrt(2 / nin);
        for (var i = 0; i < nout; i++) {
          b.push(0);
          var row = [];
          for (var j = 0; j < nin; j++) row.push((Math.random() * 2 - 1) * scale);
          W.push(row);
        }
        layers.push({ W: W, b: b, nin: nin, nout: nout });
      }
      return { layers: layers, activation: activation };
    }
    function act(a, kind) {
      if (kind === 'tanh') return Math.tanh(a);
      if (kind === 'relu') return a > 0 ? a : 0;
      return 1 / (1 + Math.exp(-a));
    }
    function dact(z, a, kind) {
      if (kind === 'tanh') return 1 - a * a;
      if (kind === 'relu') return z > 0 ? 1 : 0;
      return a * (1 - a);
    }
    function sigmoid(x) { return 1 / (1 + Math.exp(-x)); }

    function forward(net, x) {
      var activations = [x.slice()]; var zs = [];
      for (var l = 0; l < net.layers.length; l++) {
        var L = net.layers[l]; var input = activations[activations.length - 1];
        var z = [], a = [];
        for (var i = 0; i < L.nout; i++) {
          var s = L.b[i];
          for (var j = 0; j < L.nin; j++) s += L.W[i][j] * input[j];
          z.push(s);
          if (l === net.layers.length - 1) a.push(sigmoid(s));
          else a.push(act(s, net.activation));
        }
        zs.push(z); activations.push(a);
      }
      return { activations: activations, zs: zs };
    }

    function train(net, batch, lr, l2) {
      var totalLoss = 0;
      var gradsW = net.layers.map(function (L) { return L.W.map(function (r) { return r.map(function () { return 0; }); }); });
      var gradsB = net.layers.map(function (L) { return L.b.map(function () { return 0; }); });
      for (var s = 0; s < batch.length; s++) {
        var sample = batch[s];
        var x = [sample[0], sample[1]]; var y = sample[2];
        var fp = forward(net, x);
        var out = fp.activations[fp.activations.length - 1][0];
        out = Math.max(1e-7, Math.min(1 - 1e-7, out));
        totalLoss += -(y * Math.log(out) + (1 - y) * Math.log(1 - out));
        var deltas = []; var dOut = (out - y);
        deltas[net.layers.length - 1] = [dOut];
        for (var l = net.layers.length - 2; l >= 0; l--) {
          var Lnext = net.layers[l + 1]; var Lthis = net.layers[l];
          var nextDelta = deltas[l + 1]; var z = fp.zs[l]; var a = fp.activations[l + 1];
          var d = [];
          for (var i = 0; i < Lthis.nout; i++) {
            var sum = 0;
            for (var k = 0; k < Lnext.nout; k++) sum += Lnext.W[k][i] * nextDelta[k];
            d.push(sum * dact(z[i], a[i], net.activation));
          }
          deltas[l] = d;
        }
        for (var l = 0; l < net.layers.length; l++) {
          var L = net.layers[l]; var inp = fp.activations[l]; var d = deltas[l];
          for (var i = 0; i < L.nout; i++) {
            gradsB[l][i] += d[i];
            for (var j = 0; j < L.nin; j++) gradsW[l][i][j] += d[i] * inp[j];
          }
        }
      }
      var inv = 1 / batch.length;
      for (var l = 0; l < net.layers.length; l++) {
        var L = net.layers[l];
        for (var i = 0; i < L.nout; i++) {
          L.b[i] -= lr * gradsB[l][i] * inv;
          for (var j = 0; j < L.nin; j++) {
            L.W[i][j] -= lr * (gradsW[l][i][j] * inv + l2 * L.W[i][j]);
          }
        }
      }
      return totalLoss / batch.length;
    }

    function predict(net, x) {
      var fp = forward(net, x);
      return fp.activations[fp.activations.length - 1][0];
    }

    var data = [];
    var epoch = 0; var lossHistory = []; var accHistory = []; var running = false;
    function $(id) { return document.getElementById(id); }

    function readControls() {
      var nH = parseInt($('numHidden').value, 10);
      var hU = parseInt($('hUnits').value, 10);
      $('hLV').textContent = nH; $('hUV').textContent = hU;
      $('lrV').textContent = parseFloat($('lr').value).toFixed(3);
      $('bsV').textContent = $('bs').value;
      $('l2V').textContent = parseFloat($('l2').value).toFixed(3);
      return { nH: nH, hU: hU, act: $('activation').value, lr: parseFloat($('lr').value), bs: parseInt($('bs').value, 10), l2: parseFloat($('l2').value) };
    }

    function resetNet() {
      var c = readControls();
      var sizes = [2];
      for (var i = 0; i < c.nH; i++) sizes.push(c.hU);
      sizes.push(1);
      net = build(sizes, c.act);
      epoch = 0; lossHistory = []; accHistory = [];
      $('mEp').textContent = 0; $('mLoss').textContent = '—'; $('mAcc').textContent = '—';
      drawNet(); drawData();
    }

    function loadDataset() {
      var k = $('dataset').value;
      if (k === 'spiral') data = genSpiral(80);
      else if (k === 'moons') data = genMoons(80);
      else if (k === 'circles') data = genCircles(80);
      else if (k === 'xor') data = genXor(80);
      else data = genLinear(80);
      $('mN').textContent = data.length;
      resetNet();
    }

    var canvas = $('dataCanvas');
    var W = canvas.width, H = canvas.height;
    function toX(d) { return (d + 1.5) / 3 * W; }
    function toY(d) { return (1 - (d + 1.5) / 3) * H; }
    function fromX(p) { return p / W * 3 - 1.5; }
    function fromY(p) { return -(p / H * 3 - 1.5); }

    function drawData() {
      var ctx = canvas.getContext('2d');
      var img = ctx.createImageData(W, H);
      for (var y = 0; y < H; y++) {
        for (var x = 0; x < W; x++) {
          var p = predict(net, [fromX(x), fromY(y)]);
          var idx = (y * W + x) * 4;
          img.data[idx] = Math.round(40 + p * 215);
          img.data[idx+1] = Math.round(140 - Math.abs(p - 0.5) * 60);
          img.data[idx+2] = Math.round(245 - p * 215);
          img.data[idx+3] = 90;
        }
      }
      ctx.putImageData(img, 0, 0);
      ctx.strokeStyle = '#2a2a35'; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(0, H/2); ctx.lineTo(W, H/2); ctx.moveTo(W/2, 0); ctx.lineTo(W/2, H); ctx.stroke();
      data.forEach(function (p) {
        ctx.beginPath();
        ctx.arc(toX(p[0]), toY(p[1]), 5, 0, Math.PI * 2);
        ctx.fillStyle = p[2] === 1 ? '#FF7040' : '#67e8f9';
        ctx.fill();
        ctx.strokeStyle = '#fff'; ctx.lineWidth = 1; ctx.stroke();
      });
    }

    canvas.addEventListener('click', function (e) {
      var rect = canvas.getBoundingClientRect();
      var x = (e.clientX - rect.left) * canvas.width / rect.width;
      var y = (e.clientY - rect.top) * canvas.height / rect.height;
      data.push([fromX(x), fromY(y), e.shiftKey ? 0 : 1]);
      $('mN').textContent = data.length;
      drawData();
    });
    canvas.addEventListener('contextmenu', function (e) {
      e.preventDefault();
      var rect = canvas.getBoundingClientRect();
      var x = (e.clientX - rect.left) * canvas.width / rect.width;
      var y = (e.clientY - rect.top) * canvas.height / rect.height;
      var tx = fromX(x), ty = fromY(y);
      var best = -1, bestD = Infinity;
      data.forEach(function (p, i) { var d = (p[0]-tx)*(p[0]-tx)+(p[1]-ty)*(p[1]-ty); if (d < bestD) { bestD = d; best = i; } });
      if (best >= 0) { data.splice(best, 1); $('mN').textContent = data.length; drawData(); }
    });

    function drawNet() {
      var svg = $('topoSvg'); svg.innerHTML = '';
      var sizes = [2]; for (var i = 0; i < net.layers.length - 1; i++) sizes.push(net.layers[i].nout); sizes.push(1);
      var pad = 18; var w = 600, h = 200;
      var cols = sizes.length;
      function cx(c) { return pad + (w - 2*pad) * c / (cols - 1); }
      function cy(r, n) { return h / 2 - ((n - 1) / 2 - r) * Math.min(28, (h - 30) / Math.max(1, n)); }
      for (var c = 0; c < net.layers.length; c++) {
        var L = net.layers[c];
        for (var i = 0; i < L.nout; i++) {
          for (var j = 0; j < L.nin; j++) {
            var ln = document.createElementNS('http://www.w3.org/2000/svg', 'line');
            ln.setAttribute('x1', cx(c)); ln.setAttribute('y1', cy(j, L.nin));
            ln.setAttribute('x2', cx(c+1)); ln.setAttribute('y2', cy(i, L.nout));
            var weight = L.W[i][j]; var alpha = Math.min(1, Math.abs(weight));
            var col = weight > 0 ? 'rgba(255,112,64,' + alpha + ')' : 'rgba(103,232,249,' + alpha + ')';
            ln.setAttribute('stroke', col); ln.setAttribute('stroke-width', 0.8 + Math.min(2, Math.abs(weight)));
            svg.appendChild(ln);
          }
        }
      }
      for (var c = 0; c < sizes.length; c++) {
        for (var r = 0; r < sizes[c]; r++) {
          var dot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
          dot.setAttribute('cx', cx(c)); dot.setAttribute('cy', cy(r, sizes[c])); dot.setAttribute('r', 7);
          dot.setAttribute('fill', c === 0 ? '#9aa6b6' : c === sizes.length - 1 ? '#fbbf24' : '#67e8f9');
          dot.setAttribute('stroke', '#0a0a0c'); dot.setAttribute('stroke-width', 2);
          svg.appendChild(dot);
        }
      }
    }

    function drawLossPlot() {
      var svg = $('lossPlot'); svg.innerHTML = '';
      if (lossHistory.length < 2) return;
      var pts = lossHistory.slice(-200);
      var aPts = accHistory.slice(-200);
      var maxL = Math.max.apply(null, pts);
      var d1 = '', d2 = '';
      pts.forEach(function (l, i) { var x = 10 + i * (580 / (pts.length - 1)); var y = 150 - l / maxL * 140; d1 += (i === 0 ? 'M' : 'L') + x + ',' + y; });
      aPts.forEach(function (a, i) { var x = 10 + i * (580 / (aPts.length - 1)); var y = 150 - a * 140; d2 += (i === 0 ? 'M' : 'L') + x + ',' + y; });
      var p1 = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      p1.setAttribute('d', d1); p1.setAttribute('fill', 'none'); p1.setAttribute('stroke', '#FF7040'); p1.setAttribute('stroke-width', 1.5);
      svg.appendChild(p1);
      var p2 = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      p2.setAttribute('d', d2); p2.setAttribute('fill', 'none'); p2.setAttribute('stroke', '#86efac'); p2.setAttribute('stroke-width', 1.5);
      svg.appendChild(p2);
      var l1 = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      l1.setAttribute('x', 14); l1.setAttribute('y', 16); l1.setAttribute('fill', '#FF7040'); l1.setAttribute('font-family', 'Geist Mono'); l1.setAttribute('font-size', 10);
      l1.textContent = 'Loss · ' + (pts[pts.length-1] || 0).toFixed(3); svg.appendChild(l1);
      var l2 = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      l2.setAttribute('x', 120); l2.setAttribute('y', 16); l2.setAttribute('fill', '#86efac'); l2.setAttribute('font-family', 'Geist Mono'); l2.setAttribute('font-size', 10);
      l2.textContent = 'Acc · ' + ((aPts[aPts.length-1] || 0) * 100).toFixed(1) + '%'; svg.appendChild(l2);
    }

    function evalAccuracy() {
      if (data.length === 0) return 0;
      var correct = 0;
      data.forEach(function (p) {
        var pred = predict(net, [p[0], p[1]]) > 0.5 ? 1 : 0;
        if (pred === p[2]) correct++;
      });
      return correct / data.length;
    }

    function trainStep() {
      var c = readControls();
      var batch = [];
      for (var i = 0; i < c.bs; i++) batch.push(data[Math.floor(Math.random() * data.length)]);
      var loss = train(net, batch, c.lr, c.l2);
      epoch++;
      lossHistory.push(loss);
      var acc = evalAccuracy();
      accHistory.push(acc);
      $('mEp').textContent = epoch;
      $('mLoss').textContent = loss.toFixed(4);
      $('mAcc').textContent = (acc * 100).toFixed(1) + '%';
      drawData(); drawNet(); drawLossPlot();
    }

    $('trainBtn').addEventListener('click', function () {
      running = !running;
      $('trainBtn').textContent = running ? 'Pause' : 'Train';
      if (running) loop();
    });
    function loop() {
      if (!running) return;
      for (var i = 0; i < 4; i++) trainStep();
      requestAnimationFrame(loop);
    }
    $('stepBtn').addEventListener('click', trainStep);
    $('resetBtn').addEventListener('click', resetNet);
    $('dataset').addEventListener('change', loadDataset);
    ['numHidden','hUnits','activation','lr','bs','l2'].forEach(function (id) {
      $(id).addEventListener('input', function () {
        readControls();
        if (id === 'numHidden' || id === 'hUnits' || id === 'activation') resetNet();
      });
    });

    loadDataset();
  })();
</script>
</BaseLayout>
