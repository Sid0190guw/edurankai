---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Quantum Lab — flagship quantum-computing lab. A genuine statevector simulator:
// complex amplitudes over 2^n basis states, a click-to-build circuit, the full
// common gate set (H/X/Y/Z/S/T/RX/RY/RZ/CNOT/CZ/SWAP/CCX), live amplitude +
// probability readout, per-qubit Bloch spheres (from the reduced density
// matrix), an entanglement measure, and measurement sampling. Named algorithms
// preloaded (Bell, GHZ, Grover). Hand-built, no libraries.
---
<BaseLayout title="Quantum Lab · Virtual Labs · AquinTutor" description="A real quantum circuit simulator in the browser: full statevector simulation over 2^n amplitudes, click-to-build circuits, H/X/Y/Z/S/T/rotations/CNOT/CZ/SWAP/Toffoli, Bloch spheres from the reduced density matrix, entanglement, measurement sampling, and Bell/GHZ/Grover presets. Built from scratch, no libraries.">

<style is:global>
  body { background:#08080a; color:#e8e8ee; margin:0; }
  .era-fab { display:none !important; }
  .q-wrap { display:grid; grid-template-rows:52px 1fr; height:100vh; height:100dvh; }
  .q-bar { background:#11131a; border-bottom:1px solid #2a2a35; display:flex; align-items:center; padding:0 14px; gap:12px; font-family:'Geist Mono',monospace; font-size:11px; color:#cfd6da; flex-wrap:wrap; }
  .q-bar a { color:#c792ea; text-decoration:none; }
  .q-title { font-family:'Cormorant Garamond',Georgia,serif; font-size:17px; color:#fff; font-weight:600; }
  .q-title em { color:#c792ea; font-style:italic; }
  .q-bar-right { margin-left:auto; display:flex; gap:6px; align-items:center; flex-wrap:wrap; }
  .q-btn { background:transparent; border:1px solid #2a2a35; color:#cfd6da; padding:6px 11px; border-radius:6px; cursor:pointer; font-family:inherit; font-size:11px; letter-spacing:0.04em; text-transform:uppercase; font-weight:700; }
  .q-btn:hover { background:#1a1a25; }
  .q-btn.primary { background:#c792ea; color:#1a0a2b; border-color:#c792ea; }
  .q-sel { background:#11131a; color:#e8e8ee; border:1px solid #2a2a35; border-radius:6px; padding:6px 8px; font-family:inherit; font-size:11px; }
  .q-main { display:grid; grid-template-columns:1fr 320px; overflow:hidden; }
  @media (max-width:900px){ .q-main { grid-template-columns:1fr; grid-template-rows:1fr auto; overflow-y:auto; } }
  .q-build { display:flex; flex-direction:column; overflow:auto; }
  .q-palette { display:flex; gap:5px; flex-wrap:wrap; padding:10px 12px; border-bottom:1px solid #1a1a25; }
  .q-gate { width:34px; height:34px; border-radius:7px; border:1px solid #2a2a35; background:#11131a; color:#e8e8ee; font-family:'Geist Mono',monospace; font-size:13px; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; }
  .q-gate:hover { border-color:#c792ea; } .q-gate.on { background:#c792ea; color:#1a0a2b; border-color:#c792ea; }
  .q-gate.two { color:#c792ea; }
  .q-hint { padding:6px 12px; font-family:'Geist Mono',monospace; font-size:10px; color:#89a; border-bottom:1px solid #1a1a25; }
  .q-circuit { padding:16px; overflow-x:auto; }
  .q-wire { display:flex; align-items:center; gap:2px; margin-bottom:4px; }
  .q-wlabel { width:44px; font-family:'Geist Mono',monospace; font-size:12px; color:#c792ea; flex-shrink:0; }
  .q-cell { width:40px; height:40px; flex-shrink:0; border-radius:6px; position:relative; cursor:pointer; display:flex; align-items:center; justify-content:center; }
  .q-cell:hover { background:rgba(199,146,234,0.08); }
  .q-line { position:absolute; left:0; right:0; top:50%; height:2px; background:#2a2a35; z-index:0; }
  .q-g { position:relative; z-index:1; min-width:26px; height:26px; border-radius:6px; background:#1e2230; border:1.5px solid #c792ea; color:#fff; font-family:'Geist Mono',monospace; font-size:12px; font-weight:700; display:flex; align-items:center; justify-content:center; padding:0 4px; }
  .q-ctrl { position:relative; z-index:1; width:12px; height:12px; border-radius:50%; background:#c792ea; }
  .q-tgt { position:relative; z-index:1; width:22px; height:22px; border-radius:50%; border:2px solid #c792ea; display:flex; align-items:center; justify-content:center; color:#c792ea; font-size:15px; }
  .q-vline { position:absolute; left:50%; width:2px; background:#c792ea; z-index:0; transform:translateX(-1px); }
  .q-right { background:#0c0e14; border-left:1px solid #2a2a35; overflow-y:auto; padding:13px; }
  .q-cat { font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.18em; text-transform:uppercase; color:#c792ea; font-weight:700; margin:12px 0 8px; }
  .q-amp { font-family:'Geist Mono',monospace; font-size:10.5px; margin-bottom:3px; }
  .q-amprow { display:flex; align-items:center; gap:6px; }
  .q-ket { color:#7fb3ff; width:70px; }
  .q-bar-bg { flex:1; height:12px; background:#11131a; border-radius:3px; overflow:hidden; }
  .q-bar-fill { height:100%; }
  .q-pct { width:42px; text-align:right; color:#9aa; }
  .q-bloch { display:grid; grid-template-columns:repeat(auto-fill,minmax(88px,1fr)); gap:8px; }
  .q-bloch canvas { width:100%; aspect-ratio:1; background:#0b0d13; border:1px solid #2a2a35; border-radius:8px; }
  .q-bloch .lab { font-family:'Geist Mono',monospace; font-size:9px; color:#9aa; text-align:center; margin-top:2px; }
  .q-ent { font-family:'Geist Mono',monospace; font-size:11px; padding:8px 10px; border-radius:7px; margin-top:8px; }
  .q-ent.yes { background:rgba(199,146,234,0.12); color:#dab6f2; border:1px solid rgba(199,146,234,0.4); }
  .q-ent.no { background:rgba(120,130,150,0.08); color:#9aa; border:1px solid #2a2a35; }
  .q-note { font-size:10px; color:#788; line-height:1.7; border-top:1px solid #2a2a35; margin-top:12px; padding-top:9px; }
  #qHist { width:100%; height:90px; background:#0b0d13; border:1px solid #2a2a35; border-radius:6px; margin-top:6px; }
</style>

<div class="q-wrap">
  <div class="q-bar">
    <a href="/aquintutor/labs">&larr; LABS</a>
    <span class="q-title">Quantum <em>Lab</em></span>
    <span style="opacity:0.5;">STATEVECTOR SIMULATOR</span>
    <div class="q-bar-right">
      <select class="q-sel" id="qPreset">
        <option value="">Load algorithm…</option>
        <option value="bell">Bell state (entangle)</option>
        <option value="ghz">GHZ (3-qubit)</option>
        <option value="super">Uniform superposition</option>
        <option value="grover">Grover search (2-qubit)</option>
        <option value="teleport">Teleportation setup</option>
      </select>
      <select class="q-sel" id="qN"><option>2</option><option selected>3</option><option>4</option><option>5</option></select>
      <button type="button" class="q-btn" id="qMeasure">Measure ×1000</button>
      <button type="button" class="q-btn" id="qClear">Clear</button>
    </div>
  </div>
  <div class="q-main">
    <div class="q-build">
      <div class="q-palette" id="qPalette"></div>
      <div class="q-hint" id="qHint">Click a gate, then a cell. For CNOT/CZ/SWAP: click the gate, then the control cell, then the target cell (same column).</div>
      <div class="q-circuit" id="qCircuit"></div>
    </div>
    <div class="q-right">
      <div class="q-cat">Statevector (amplitudes)</div>
      <div id="qState"></div>
      <div class="q-cat">Per-qubit Bloch spheres</div>
      <div class="q-bloch" id="qBloch"></div>
      <div id="qEnt"></div>
      <div class="q-cat">Measurement histogram</div>
      <canvas id="qHist" width="300" height="90"></canvas>
      <div class="q-note">Amplitudes are complex; bar length is probability |a|², colour is phase. A Bloch vector shorter than 1 means that qubit is entangled with the rest (its reduced state is mixed) — try the Bell preset and watch both spheres collapse to the centre while the two-qubit state stays perfectly correlated. Every number is a real statevector computation.</div>
    </div>
  </div>
</div>

<script is:inline>
(function(){
'use strict';
var N=3, STEPS=10;
var gates=[]; // {type, ctrl:[], tgt, step, param}
var sel=null, pending=null; // pending for multi-qubit placement

var PALETTE=[
  {t:'H'},{t:'X'},{t:'Y'},{t:'Z'},{t:'S'},{t:'T'},
  {t:'RX',two:false,param:true},{t:'RY',param:true},{t:'RZ',param:true},
  {t:'CNOT',two:2},{t:'CZ',two:2},{t:'SWAP',two:2},{t:'CCX',two:3}
];
function buildPalette(){
  var p=document.getElementById('qPalette'); p.innerHTML='';
  PALETTE.forEach(function(g){
    var b=document.createElement('button'); b.className='q-gate'+(g.two?' two':''); b.textContent=g.t==='CNOT'?'⊕':g.t==='CZ'?'CZ':g.t==='SWAP'?'⨯':g.t==='CCX'?'CCX':g.t;
    b.title=g.t; b.addEventListener('click',function(){ sel=g; pending=null; document.querySelectorAll('.q-gate').forEach(function(x){x.classList.remove('on');}); b.classList.add('on'); hint(); });
    p.appendChild(b);
  });
}
function hint(){
  var h=document.getElementById('qHint');
  if(!sel){ h.textContent='Click a gate, then a cell.'; return; }
  if(sel.two){ h.textContent=sel.t+': click the '+(sel.two===3?'first control, second control, then target':'control cell, then the target cell')+' (same column).'; }
  else if(sel.param){ h.textContent=sel.t+': click a cell — you will be asked for the rotation angle.'; }
  else h.textContent=sel.t+': click a cell to place it.';
}

// ---- circuit render ----
function renderCircuit(){
  var host=document.getElementById('qCircuit'); host.innerHTML='';
  for(var q=0;q<N;q++){
    var wire=document.createElement('div'); wire.className='q-wire';
    var lab=document.createElement('div'); lab.className='q-wlabel'; lab.textContent='q'+q+' |0⟩'; wire.appendChild(lab);
    for(var s=0;s<STEPS;s++){
      var cell=document.createElement('div'); cell.className='q-cell'; cell.dataset.q=q; cell.dataset.s=s;
      var line=document.createElement('div'); line.className='q-line'; cell.appendChild(line);
      var g=gateAt(q,s);
      if(g){ cell.appendChild(renderGate(g,q,s)); }
      cell.addEventListener('click',function(){ onCell(+this.dataset.q,+this.dataset.s); });
      wire.appendChild(cell);
    }
    host.appendChild(wire);
  }
}
function gateAt(q,s){ return gates.find(function(g){ return g.step===s && (g.tgt===q || (g.ctrl&&g.ctrl.indexOf(q)>=0)); }); }
function renderGate(g,q,s){
  if(g.type==='CNOT'||g.type==='CZ'||g.type==='SWAP'||g.type==='CCX'){
    // vertical line spanning involved qubits in this column drawn once (from min to max)
    var involved=(g.ctrl||[]).concat([g.tgt]); var mn=Math.min.apply(null,involved),mx=Math.max.apply(null,involved);
    var wrap=document.createElement('div'); wrap.style.cssText='position:relative;z-index:1;display:flex;align-items:center;justify-content:center;width:100%;height:100%;';
    if(q===mn){ var vl=document.createElement('div'); vl.className='q-vline'; vl.style.top='50%'; vl.style.height=((mx-mn)*44)+'px'; wrap.appendChild(vl); }
    if((g.ctrl||[]).indexOf(q)>=0){ var d=document.createElement('div'); d.className='q-ctrl'; wrap.appendChild(d); }
    else if(g.tgt===q){
      if(g.type==='CZ'){ var d=document.createElement('div'); d.className='q-ctrl'; wrap.appendChild(d); }
      else if(g.type==='SWAP'){ var t=document.createElement('div'); t.className='q-tgt'; t.style.border='none'; t.textContent='⨯'; t.style.fontSize='18px'; wrap.appendChild(t); }
      else { var t=document.createElement('div'); t.className='q-tgt'; t.textContent='+'; wrap.appendChild(t); }
    }
    return wrap;
  }
  var el=document.createElement('div'); el.className='q-g'; el.textContent=g.type+(g.param!=null?'':'');
  if(g.param!=null) el.title=g.type+'('+(g.param*180/Math.PI).toFixed(0)+'°)';
  if(g.param!=null){ el.textContent=g.type; var sub=document.createElement('span'); sub.style.cssText='font-size:8px;opacity:0.7;'; }
  return el;
}
function onCell(q,s){
  if(!sel){ // click existing gate to remove
    var g=gateAt(q,s); if(g){ gates=gates.filter(function(x){return x!==g;}); recompute(); } return;
  }
  if(sel.two){
    if(!pending){ pending={ctrl:[q], step:s}; document.getElementById('qHint').textContent='Now click the '+(sel.two===3&&pending.ctrl.length<2?'second control':'target')+' in column '+s+'.'; return; }
    if(s!==pending.step){ document.getElementById('qHint').textContent='Must be the same column. Try again.'; pending=null; return; }
    if(sel.two===3 && pending.ctrl.length<2){ if(pending.ctrl.indexOf(q)<0) pending.ctrl.push(q); document.getElementById('qHint').textContent='Now click the target.'; return; }
    if(pending.ctrl.indexOf(q)>=0){ document.getElementById('qHint').textContent='Target must differ from control.'; return; }
    clearColForQubits(s, pending.ctrl.concat([q]));
    gates.push({type:sel.t, ctrl:pending.ctrl.slice(), tgt:q, step:s}); pending=null; recompute(); hint(); return;
  }
  // single qubit
  var param=null;
  if(sel.param){ var deg=prompt(sel.t+' rotation angle in degrees:', '90'); if(deg===null) return; param=(parseFloat(deg)||0)*Math.PI/180; }
  gates=gates.filter(function(g){ return !(g.step===s && g.tgt===q && (!g.ctrl||g.ctrl.length===0)); });
  gates.push({type:sel.t, tgt:q, step:s, ctrl:[], param:param});
  recompute();
}
function clearColForQubits(s,qs){ gates=gates.filter(function(g){ if(g.step!==s) return true; var inv=(g.ctrl||[]).concat([g.tgt]); return !inv.some(function(x){return qs.indexOf(x)>=0;}); }); }

// ---- statevector engine (complex as re[],im[]) ----
var re,im;
function initState(){ var d=1<<N; re=new Float64Array(d); im=new Float64Array(d); re[0]=1; }
function cmul(ar,ai,br,bi){ return [ar*br-ai*bi, ar*bi+ai*br]; }
function apply1(M,q){ // M = [[m00r,m00i],[m01..],[m10..],[m11..]] flattened as 8 numbers
  var d=1<<N;
  for(var s=0;s<d;s++){ if((s>>q)&1) continue; var s1=s|(1<<q);
    var a0r=re[s],a0i=im[s],a1r=re[s1],a1i=im[s1];
    var r0=cmul(M[0],M[1],a0r,a0i), t0=cmul(M[2],M[3],a1r,a1i);
    var r1=cmul(M[4],M[5],a0r,a0i), t1=cmul(M[6],M[7],a1r,a1i);
    re[s]=r0[0]+t0[0]; im[s]=r0[1]+t0[1];
    re[s1]=r1[0]+t1[0]; im[s1]=r1[1]+t1[1];
  }
}
function applyCX(c,t){ var d=1<<N; for(var s=0;s<d;s++){ if(((s>>c)&1)&&!((s>>t)&1)){ var s1=s|(1<<t); var tr=re[s],ti=im[s]; re[s]=re[s1];im[s]=im[s1]; re[s1]=tr;im[s1]=ti; } } }
function applyCCX(c1,c2,t){ var d=1<<N; for(var s=0;s<d;s++){ if(((s>>c1)&1)&&((s>>c2)&1)&&!((s>>t)&1)){ var s1=s|(1<<t); var tr=re[s],ti=im[s]; re[s]=re[s1];im[s]=im[s1]; re[s1]=tr;im[s1]=ti; } } }
function applyCZ(c,t){ var d=1<<N; for(var s=0;s<d;s++){ if(((s>>c)&1)&&((s>>t)&1)){ re[s]=-re[s]; im[s]=-im[s]; } } }
function applySWAP(a,b){ var d=1<<N; for(var s=0;s<d;s++){ var ba=(s>>a)&1,bb=(s>>b)&1; if(ba&&!bb){ var s1=(s&~(1<<a))|(1<<b); var tr=re[s],ti=im[s]; re[s]=re[s1];im[s]=im[s1];re[s1]=tr;im[s1]=ti; } } }
var R2=1/Math.SQRT2;
function mat(type,p){
  switch(type){
    case 'H': return [R2,0, R2,0, R2,0, -R2,0];
    case 'X': return [0,0, 1,0, 1,0, 0,0];
    case 'Y': return [0,0, 0,-1, 0,1, 0,0];
    case 'Z': return [1,0, 0,0, 0,0, -1,0];
    case 'S': return [1,0, 0,0, 0,0, 0,1];
    case 'T': return [1,0, 0,0, 0,0, Math.cos(Math.PI/4),Math.sin(Math.PI/4)];
    case 'RX': { var c=Math.cos(p/2),s=Math.sin(p/2); return [c,0, 0,-s, 0,-s, c,0]; }
    case 'RY': { var c=Math.cos(p/2),s=Math.sin(p/2); return [c,0, -s,0, s,0, c,0]; }
    case 'RZ': { var c=Math.cos(p/2),s=Math.sin(p/2); return [c,-s, 0,0, 0,0, c,s]; }
  }
  return [1,0,0,0,0,0,1,0];
}
function recompute(){
  initState();
  var cols={}; gates.forEach(function(g){ (cols[g.step]=cols[g.step]||[]).push(g); });
  Object.keys(cols).map(Number).sort(function(a,b){return a-b;}).forEach(function(s){
    cols[s].forEach(function(g){
      if(g.type==='CNOT') applyCX(g.ctrl[0],g.tgt);
      else if(g.type==='CZ') applyCZ(g.ctrl[0],g.tgt);
      else if(g.type==='SWAP') applySWAP(g.ctrl[0],g.tgt);
      else if(g.type==='CCX') applyCCX(g.ctrl[0],g.ctrl[1],g.tgt);
      else apply1(mat(g.type,g.param),g.tgt);
    });
  });
  renderCircuit(); renderState(); renderBloch();
}

// ---- readouts ----
function renderState(){
  var d=1<<N, host=document.getElementById('qState'); host.innerHTML='';
  var shown=0;
  for(var s=0;s<d;s++){ var p=re[s]*re[s]+im[s]*im[s]; if(p<1e-5) continue; shown++;
    var phase=Math.atan2(im[s],re[s]);
    var hue=((phase*180/Math.PI)+360)%360;
    var ket=s.toString(2); while(ket.length<N)ket='0'+ket;
    var row=document.createElement('div'); row.className='q-amp';
    row.innerHTML='<div class="q-amprow"><span class="q-ket">|'+ket+'⟩</span><div class="q-bar-bg"><div class="q-bar-fill" style="width:'+(p*100).toFixed(1)+'%;background:hsl('+hue+',70%,60%);"></div></div><span class="q-pct">'+(p*100).toFixed(1)+'%</span></div>';
    host.appendChild(row);
  }
  if(shown===0) host.innerHTML='<div style="color:#788;font-size:11px;">—</div>';
}
function reducedBloch(q){
  var d=1<<N, p1=0, r01r=0,r01i=0;
  for(var s=0;s<d;s++){ var pr=re[s]*re[s]+im[s]*im[s]; if((s>>q)&1) p1+=pr; if(!((s>>q)&1)){ var s1=s|(1<<q); // rho01 += a_s conj(a_s1)
    r01r += re[s]*re[s1]+im[s]*im[s1]; r01i += im[s]*re[s1]-re[s]*im[s1]; } }
  var z=(1-p1)-p1; var x=2*r01r, y=-2*r01i;
  return {x:x,y:y,z:z,len:Math.sqrt(x*x+y*y+z*z)};
}
function renderBloch(){
  var host=document.getElementById('qBloch');
  if(host.children.length!==N){ host.innerHTML=''; for(var q=0;q<N;q++){ var w=document.createElement('div'); var c=document.createElement('canvas'); c.width=88;c.height=88; var l=document.createElement('div'); l.className='lab'; l.textContent='q'+q; w.appendChild(c); w.appendChild(l); host.appendChild(w); } }
  var minLen=1;
  for(var q=0;q<N;q++){ var b=reducedBloch(q); minLen=Math.min(minLen,b.len); drawBloch(host.children[q].querySelector('canvas'), b); }
  var ent=document.getElementById('qEnt');
  var entangled=minLen<0.98;
  ent.className='q-ent '+(entangled?'yes':'no');
  ent.textContent=entangled?('Entangled — at least one qubit\'s Bloch vector is '+minLen.toFixed(2)+' (mixed). The whole is more than its parts.'):'Product state — every qubit is pure and independent.';
}
function drawBloch(cv,b){
  var x=cv.getContext('2d'),W=cv.width,H=cv.height,cx=W/2,cy=H/2,R=W*0.4;
  x.clearRect(0,0,W,H); x.fillStyle='#0b0d13'; x.fillRect(0,0,W,H);
  x.strokeStyle='#2a2a35'; x.lineWidth=1; x.beginPath(); x.arc(cx,cy,R,0,2*Math.PI); x.stroke();
  x.beginPath(); x.ellipse(cx,cy,R,R*0.32,0,0,2*Math.PI); x.stroke();
  x.strokeStyle='#1a1a25'; x.beginPath(); x.moveTo(cx,cy-R);x.lineTo(cx,cy+R); x.moveTo(cx-R,cy);x.lineTo(cx+R,cy); x.stroke();
  x.fillStyle='#5c6370'; x.font='8px monospace'; x.fillText('|0⟩',cx+2,cy-R+8); x.fillText('|1⟩',cx+2,cy+R-2);
  // project (x right, z up, y into screen -> slight vertical squash)
  var px=cx + b.x*R, py=cy - b.z*R + b.y*R*0.32;
  x.strokeStyle='#c792ea'; x.lineWidth=2; x.beginPath(); x.moveTo(cx,cy); x.lineTo(px,py); x.stroke();
  x.fillStyle='#c792ea'; x.beginPath(); x.arc(px,py,3.5,0,2*Math.PI); x.fill();
}

// ---- measurement ----
document.getElementById('qMeasure').addEventListener('click',function(){
  var d=1<<N, probs=[]; for(var s=0;s<d;s++) probs.push(re[s]*re[s]+im[s]*im[s]);
  var counts=new Array(d).fill(0);
  for(var k=0;k<1000;k++){ var r=Math.random(),acc=0; for(var s=0;s<d;s++){ acc+=probs[s]; if(r<=acc){counts[s]++;break;} } }
  var cv=document.getElementById('qHist'),ctx=cv.getContext('2d'); ctx.clearRect(0,0,cv.width,cv.height); ctx.fillStyle='#0b0d13'; ctx.fillRect(0,0,cv.width,cv.height);
  var nz=[]; for(var s=0;s<d;s++) if(counts[s]>0) nz.push(s);
  var bw=cv.width/Math.max(1,nz.length), mx=Math.max.apply(null,counts)||1;
  nz.forEach(function(s,i){ var h=counts[s]/mx*(cv.height-24); ctx.fillStyle='#c792ea'; ctx.fillRect(i*bw+3,cv.height-16-h,bw-6,h);
    var ket=s.toString(2); while(ket.length<N)ket='0'+ket; ctx.fillStyle='#9aa'; ctx.font='8px monospace'; ctx.save(); ctx.translate(i*bw+bw/2,cv.height-4); ctx.fillText(ket,-ket.length*2.2,0); ctx.restore();
    ctx.fillStyle='#dab6f2'; ctx.fillText(counts[s],i*bw+4,cv.height-18-h);
  });
});

// ---- presets / controls ----
var PRESETS={
  bell:{n:2,g:[{type:'H',tgt:0,ctrl:[],step:0},{type:'CNOT',ctrl:[0],tgt:1,step:1}]},
  ghz:{n:3,g:[{type:'H',tgt:0,ctrl:[],step:0},{type:'CNOT',ctrl:[0],tgt:1,step:1},{type:'CNOT',ctrl:[1],tgt:2,step:2}]},
  super:{n:3,g:[{type:'H',tgt:0,ctrl:[],step:0},{type:'H',tgt:1,ctrl:[],step:0},{type:'H',tgt:2,ctrl:[],step:0}]},
  grover:{n:2,g:[{type:'H',tgt:0,ctrl:[],step:0},{type:'H',tgt:1,ctrl:[],step:0},{type:'CZ',ctrl:[0],tgt:1,step:1},{type:'H',tgt:0,ctrl:[],step:2},{type:'H',tgt:1,ctrl:[],step:2},{type:'X',tgt:0,ctrl:[],step:3},{type:'X',tgt:1,ctrl:[],step:3},{type:'CZ',ctrl:[0],tgt:1,step:4},{type:'X',tgt:0,ctrl:[],step:5},{type:'X',tgt:1,ctrl:[],step:5},{type:'H',tgt:0,ctrl:[],step:6},{type:'H',tgt:1,ctrl:[],step:6}]},
  teleport:{n:3,g:[{type:'H',tgt:1,ctrl:[],step:0},{type:'CNOT',ctrl:[1],tgt:2,step:1},{type:'CNOT',ctrl:[0],tgt:1,step:2},{type:'H',tgt:0,ctrl:[],step:3}]}
};
document.getElementById('qPreset').addEventListener('change',function(){ var p=PRESETS[this.value]; if(!p)return; N=p.n; document.getElementById('qN').value=N; gates=p.g.map(function(g){return Object.assign({},g);}); recompute(); this.value=''; });
document.getElementById('qN').addEventListener('change',function(){ N=+this.value; gates=gates.filter(function(g){ var inv=(g.ctrl||[]).concat([g.tgt]); return Math.max.apply(null,inv)<N; }); document.getElementById('qBloch').innerHTML=''; recompute(); });
document.getElementById('qClear').addEventListener('click',function(){ gates=[]; recompute(); });

buildPalette(); recompute();
})();
</script>

</BaseLayout>
