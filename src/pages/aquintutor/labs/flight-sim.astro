---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Flight Simulator — aerospace lab. Hand-rolled 3D (perspective projection +
// painter's algorithm, flat-shaded low-poly terrain, distance fog) in line
// with the labs philosophy: genuine computation, no third-party library.
// Flight model: four forces (thrust/drag/lift/weight), bank-turn physics
// (turn rate = g·tan(bank)/v), stall dynamics, ground effect on landing.
---
<BaseLayout title="Flight Simulator · Virtual Labs · AquinTutor" description="Real-time 3D flight over procedural terrain - four-forces flight model, bank-turn physics, stall dynamics, landing challenge. Chase, cockpit and orbit cameras. Hand-rolled 3D, no libraries.">

<style is:global>
  body { background:#08080a; color:#e8e8ee; margin:0; }
  body.era-has-fab .era-fab, .era-fab { display:none !important; }
  .fs-wrap { display:grid; grid-template-rows:52px 1fr; height:100vh; height:100dvh; }
  .fs-bar { background:#11131a; border-bottom:1px solid #2a2a35; display:flex; align-items:center; padding:0 14px; gap:12px; font-family:'Geist Mono',monospace; font-size:11px; color:#cfd6da; letter-spacing:0.06em; }
  .fs-bar a { color:#FF9066; text-decoration:none; letter-spacing:0.08em; }
  .fs-title { font-family:'Cormorant Garamond',Georgia,serif; font-size:17px; color:#fff; font-weight:600; }
  .fs-title em { color:#FF7040; font-style:italic; }
  .fs-bar-right { margin-left:auto; display:flex; gap:6px; }
  .fs-btn { background:transparent; border:1px solid #2a2a35; color:#cfd6da; padding:6px 12px; border-radius:6px; cursor:pointer; font-family:inherit; font-size:10.5px; letter-spacing:0.06em; text-transform:uppercase; font-weight:700; }
  .fs-btn:hover { background:#1a1a25; }
  .fs-btn.primary { background:#FF4F00; color:#fff; border-color:#FF4F00; }
  .fs-main { position:relative; overflow:hidden; }
  #fsCanvas { position:absolute; inset:0; width:100%; height:100%; display:block; touch-action:none; }
  .fs-hud { position:absolute; left:14px; top:12px; font-family:'Geist Mono',monospace; font-size:12px; color:#d9f9e8; text-shadow:0 1px 3px rgba(0,0,0,0.8); line-height:1.85; pointer-events:none; }
  .fs-hud b { color:#fff; font-size:15px; }
  .fs-forces { position:absolute; right:14px; top:12px; font-family:'Geist Mono',monospace; font-size:11px; color:#9fd9c0; text-shadow:0 1px 3px rgba(0,0,0,0.8); line-height:1.8; text-align:right; pointer-events:none; }
  .fs-throttle { position:absolute; left:14px; bottom:16px; width:14px; height:130px; border:1px solid rgba(255,255,255,0.35); border-radius:7px; overflow:hidden; }
  .fs-throttle i { position:absolute; left:0; right:0; bottom:0; background:#FF7040; display:block; }
  .fs-warn { position:absolute; left:50%; top:18%; transform:translateX(-50%); font-family:'Geist Mono',monospace; font-size:20px; font-weight:800; letter-spacing:0.25em; color:#f87171; text-shadow:0 0 18px rgba(248,113,113,0.6); display:none; animation:fs-blink 0.5s infinite; pointer-events:none; }
  @keyframes fs-blink { 50% { opacity:0.25; } }
  .fs-msg { position:absolute; left:50%; top:42%; transform:translate(-50%,-50%); background:rgba(10,10,14,0.88); border:1px solid #2a2a35; border-radius:12px; padding:22px 30px; text-align:center; display:none; max-width:min(480px,88vw); }
  .fs-msg h2 { font-family:'Cormorant Garamond',Georgia,serif; margin:0 0 8px; font-size:24px; color:#fff; }
  .fs-msg p { margin:0 0 14px; font-size:13px; color:#aab; line-height:1.6; }
  .fs-help { position:absolute; right:14px; bottom:14px; background:rgba(10,10,14,0.78); border:1px solid #2a2a35; border-radius:10px; padding:12px 16px; font-family:'Geist Mono',monospace; font-size:10.5px; color:#9aa; line-height:1.9; pointer-events:none; }
  .fs-help b { color:#FF9066; }
  @media (max-width:760px){ .fs-help, .fs-forces { display:none; } .fs-hud { font-size:11px; } }
  .fs-stick { position:absolute; bottom:22px; left:50%; transform:translateX(-50%); width:110px; height:110px; border:1px solid rgba(255,255,255,0.25); border-radius:50%; display:none; }
  .fs-stick i { position:absolute; width:40px; height:40px; border-radius:50%; background:rgba(255,112,64,0.55); left:35px; top:35px; }
  @media (pointer:coarse){ .fs-stick { display:block; } }
</style>

<div class="fs-wrap">
  <div class="fs-bar">
    <a href="/aquintutor/labs">&larr; LABS</a>
    <span class="fs-title">Flight <em>Simulator</em></span>
    <span style="opacity:0.55;">AEROSPACE · FOUR-FORCES MODEL</span>
    <div class="fs-bar-right">
      <button type="button" class="fs-btn" id="fsCam">Camera: Chase</button>
      <button type="button" class="fs-btn" id="fsPause">Pause</button>
      <button type="button" class="fs-btn primary" id="fsReset">Reset</button>
    </div>
  </div>
  <div class="fs-main">
    <canvas id="fsCanvas"></canvas>
    <div class="fs-hud">
      SPD <b id="hSpd">0</b> km/h<br/>
      ALT <b id="hAlt">0</b> m<br/>
      HDG <b id="hHdg">0</b>&deg;<br/>
      V/S <b id="hVs">0.0</b> m/s
    </div>
    <div class="fs-forces">
      LIFT <span id="fL">0</span> kN<br/>
      WEIGHT <span id="fW">0</span> kN<br/>
      THRUST <span id="fT">0</span> kN<br/>
      DRAG <span id="fD">0</span> kN<br/>
      BANK <span id="fB">0</span>&deg; · TURN <span id="fTr">0.0</span>&deg;/s
    </div>
    <div class="fs-throttle"><i id="hThr" style="height:60%;"></i></div>
    <div class="fs-warn" id="fsWarn">STALL</div>
    <div class="fs-help">
      <b>&uarr;&darr;</b> pitch &nbsp; <b>&larr;&rarr;</b> roll &nbsp; <b>A/D</b> rudder<br/>
      <b>W/S</b> throttle &nbsp; <b>C</b> camera &nbsp; <b>R</b> reset &nbsp; <b>P</b> pause<br/>
      Bank to turn: turn rate = g&middot;tan(bank)/v. Keep speed above 62 km/h or the wing stalls.
    </div>
    <div class="fs-stick" id="fsStick"><i id="fsKnob"></i></div>
    <div class="fs-msg" id="fsMsg">
      <h2 id="fsMsgTitle">Welcome, pilot</h2>
      <p id="fsMsgBody">You are on the runway with engines idle. Push throttle (W) to full, rotate gently (Down arrow) past 70 km/h, and explore the valley. Land back on the dark runway strip to complete the sortie.</p>
      <button type="button" class="fs-btn primary" id="fsMsgBtn">Fly</button>
    </div>
  </div>
</div>

<script is:inline>
(function(){
  'use strict';
  var cv = document.getElementById('fsCanvas'), ctx = cv.getContext('2d');
  var W = 0, H = 0, DPR = Math.min(2, window.devicePixelRatio || 1);
  function resize(){ W = cv.clientWidth; H = cv.clientHeight; cv.width = W * DPR; cv.height = H * DPR; ctx.setTransform(DPR, 0, 0, DPR, 0, 0); }
  window.addEventListener('resize', resize);

  // ---------- tiny vector kit ----------
  function v3(x,y,z){ return {x:x,y:y,z:z}; }
  function add(a,b){ return v3(a.x+b.x, a.y+b.y, a.z+b.z); }
  function sub(a,b){ return v3(a.x-b.x, a.y-b.y, a.z-b.z); }
  function mul(a,s){ return v3(a.x*s, a.y*s, a.z*s); }
  function dot(a,b){ return a.x*b.x + a.y*b.y + a.z*b.z; }
  function cross(a,b){ return v3(a.y*b.z-a.z*b.y, a.z*b.x-a.x*b.z, a.x*b.y-a.y*b.x); }
  function len(a){ return Math.sqrt(dot(a,a)); }
  function norm(a){ var l = len(a) || 1; return mul(a, 1/l); }

  // ---------- deterministic terrain (value noise, runway kept flat) ----------
  function n2(ix, iz){ var n = Math.sin(ix*127.1 + iz*311.7) * 43758.5453; return n - Math.floor(n); }
  function smooth(x, z){
    var ix = Math.floor(x), iz = Math.floor(z), fx = x-ix, fz = z-iz;
    fx = fx*fx*(3-2*fx); fz = fz*fz*(3-2*fz);
    var a = n2(ix,iz), b = n2(ix+1,iz), c = n2(ix,iz+1), d = n2(ix+1,iz+1);
    return a + (b-a)*fx + (c-a)*fz + (a-b-c+d)*fx*fz;
  }
  function terrainH(x, z){
    var h = smooth(x/900, z/900) * 260 + smooth(x/260, z/260) * 60 + smooth(x/70, z/70) * 12 - 90;
    if (h < 0) h = 0;
    // flatten around the runway (a 900x120 m strip along +z from the origin)
    var rx = Math.abs(x), rz = z;
    if (rx < 260 && rz > -260 && rz < 1250){
      var f = Math.max(rx/260, rz < 0 ? -rz/260 : (rz > 990 ? (rz-990)/260 : 0));
      f = Math.min(1, Math.max(0, f)); f = f*f*(3-2*f);
      h = h * f;
    }
    return h;
  }

  // ---------- aircraft state ----------
  var S; // state
  function reset(){
    S = { pos:v3(0, 1.6, 60), yaw:0, pitch:0, roll:0, speed:0, vs:0, throttle:0.0, t:0, done:false, crashed:false };
  }
  reset();
  var G = 9.81, MASS = 950, VSTALL = 17.2, VMAX = 92; // m/s (62 km/h stall)

  // ---------- input ----------
  var keys = {};
  window.addEventListener('keydown', function(e){
    if (['ArrowUp','ArrowDown','ArrowLeft','ArrowRight',' '].indexOf(e.key) >= 0) e.preventDefault();
    keys[e.key.toLowerCase()] = true;
    if (e.key.toLowerCase() === 'c') cycleCam();
    if (e.key.toLowerCase() === 'r') { reset(); hideMsg(); }
    if (e.key.toLowerCase() === 'p') paused = !paused;
  });
  window.addEventListener('keyup', function(e){ keys[e.key.toLowerCase()] = false; });
  // touch stick (pitch/roll) + right-edge throttle drag
  var stick = document.getElementById('fsStick'), knob = document.getElementById('fsKnob');
  var tPitch = 0, tRoll = 0;
  function bindStick(){
    var active = null;
    cv.addEventListener('touchstart', function(e){
      for (var i=0;i<e.changedTouches.length;i++){
        var t = e.changedTouches[i];
        if (t.clientX > window.innerWidth * 0.72){ active = { id:t.identifier, mode:'thr', y:t.clientY, thr:S.throttle }; }
      }
    }, {passive:true});
    cv.addEventListener('touchmove', function(e){
      if (!active) return;
      for (var i=0;i<e.changedTouches.length;i++){
        var t = e.changedTouches[i];
        if (t.identifier === active.id && active.mode === 'thr'){
          S.throttle = Math.max(0, Math.min(1, active.thr + (active.y - t.clientY)/240));
        }
      }
    }, {passive:true});
    cv.addEventListener('touchend', function(){ active = null; }, {passive:true});
    if (!stick) return;
    var sRect = null, sId = null;
    stick.addEventListener('touchstart', function(e){ sRect = stick.getBoundingClientRect(); sId = e.changedTouches[0].identifier; e.preventDefault(); }, {passive:false});
    stick.addEventListener('touchmove', function(e){
      if (sId === null) return;
      for (var i=0;i<e.changedTouches.length;i++){
        var t = e.changedTouches[i];
        if (t.identifier !== sId) continue;
        var dx = (t.clientX - (sRect.left + 55)) / 55, dy = (t.clientY - (sRect.top + 55)) / 55;
        tRoll = Math.max(-1, Math.min(1, dx)); tPitch = Math.max(-1, Math.min(1, dy));
        knob.style.left = (35 + tRoll*30) + 'px'; knob.style.top = (35 + tPitch*30) + 'px';
      }
      e.preventDefault();
    }, {passive:false});
    stick.addEventListener('touchend', function(){ sId = null; tRoll = 0; tPitch = 0; knob.style.left = '35px'; knob.style.top = '35px'; }, {passive:true});
  }
  bindStick();

  // ---------- physics: four forces + bank-turn kinematics ----------
  function step(dt){
    if (S.done) return;
    S.t += dt;
    // controls
    var pIn = (keys['arrowdown'] ? 1 : 0) - (keys['arrowup'] ? 1 : 0) - tPitch; // pull = nose up
    var rIn = (keys['arrowright'] ? 1 : 0) - (keys['arrowleft'] ? 1 : 0) + tRoll;
    var yIn = (keys['d'] ? 1 : 0) - (keys['a'] ? 1 : 0);
    if (keys['w']) S.throttle = Math.min(1, S.throttle + dt * 0.5);
    if (keys['s']) S.throttle = Math.max(0, S.throttle - dt * 0.5);

    var onGround = S.pos.y <= terrainH(S.pos.x, S.pos.z) + 1.7;
    var effect = Math.min(1, S.speed / (VSTALL * 0.9)); // control authority grows with airspeed
    S.roll += rIn * 1.9 * effect * dt;
    S.roll *= (1 - 0.35*dt); // roll damping toward level
    S.roll = Math.max(-1.35, Math.min(1.35, S.roll));
    S.pitch += pIn * 1.05 * effect * dt;
    S.pitch = Math.max(-1.2, Math.min(1.2, S.pitch));
    // bank-to-turn: psi_dot = g * tan(roll) / v  (+ a little rudder)
    var turn = (S.speed > 3 ? (G * Math.tan(S.roll)) / Math.max(S.speed, 12) : 0) + yIn * 0.25 * effect;
    S.yaw += turn * dt;

    // forces along the flight path (point-mass with attitude)
    var thrust = S.throttle * 5200;                       // N
    var q = S.speed * S.speed;
    var drag = 0.62 * q + (onGround ? 260 : 0);           // parasitic + rolling
    var acc = (thrust - drag) / MASS - G * Math.sin(S.pitch);
    S.speed = Math.max(0, S.speed + acc * dt);
    if (S.speed > VMAX) S.speed = VMAX;

    // vertical: lift vs weight (lift fades in stall, scales with cos(bank))
    var liftRatio = (q / (VSTALL * VSTALL)) * Math.cos(S.roll);
    var stalled = !onGround && S.speed < VSTALL && S.pos.y > terrainH(S.pos.x, S.pos.z) + 3;
    document.getElementById('fsWarn').style.display = stalled ? 'block' : 'none';
    var climb = S.speed * Math.sin(S.pitch) * Math.min(1.15, liftRatio);
    if (stalled){ climb -= (VSTALL - S.speed) * 0.55; S.pitch -= 0.35 * dt; } // nose drops
    if (onGround && climb < 0) climb = 0;
    S.vs = climb;

    // integrate position
    var fwd = v3(Math.sin(S.yaw) * Math.cos(S.pitch), 0, Math.cos(S.yaw) * Math.cos(S.pitch));
    S.pos = add(S.pos, mul(fwd, S.speed * Math.cos(S.pitch) * dt));
    S.pos.y += climb * dt;

    // ground contact
    var gh = terrainH(S.pos.x, S.pos.z);
    if (S.pos.y < gh + 1.6){
      S.pos.y = gh + 1.6;
      var onRunway = Math.abs(S.pos.x) < 60 && S.pos.z > -30 && S.pos.z < 1020;
      if (S.vs < -7.5 || (!onRunway && S.speed > 22)){
        S.done = true; S.crashed = true;
        showMsg('Hard contact', 'Vertical speed ' + S.vs.toFixed(1) + ' m/s at touchdown. A survivable landing needs a sink rate gentler than -7.5 m/s - flare (nose up) just before the ground. Press Reset to fly again.', 'Reset');
      } else if (onRunway && S.speed < 10 && S.t > 20){
        S.done = true;
        showMsg('Sortie complete', 'Landed back on the strip after ' + Math.round(S.t) + ' s and ' + (S.t > 0 ? 'a clean' : 'a') + ' touchdown at ' + S.vs.toFixed(1) + ' m/s. That is the full loop: takeoff, cruise, pattern, landing.', 'Fly again');
      }
    }

    // telemetry (10 Hz-ish handled by frame loop; cheap enough every frame)
    document.getElementById('hSpd').textContent = Math.round(S.speed * 3.6);
    document.getElementById('hAlt').textContent = Math.round(S.pos.y - gh);
    document.getElementById('hHdg').textContent = ((Math.round(S.yaw * 180 / Math.PI) % 360) + 360) % 360;
    document.getElementById('hVs').textContent = S.vs.toFixed(1);
    document.getElementById('hThr').style.height = Math.round(S.throttle * 100) + '%';
    document.getElementById('fL').textContent = ((MASS * G * Math.min(1.15, liftRatio)) / 1000).toFixed(1);
    document.getElementById('fW').textContent = (MASS * G / 1000).toFixed(1);
    document.getElementById('fT').textContent = (thrust / 1000).toFixed(1);
    document.getElementById('fD').textContent = (drag / 1000).toFixed(1);
    document.getElementById('fB').textContent = Math.round(S.roll * 180 / Math.PI);
    document.getElementById('fTr').textContent = (turn * 180 / Math.PI).toFixed(1);
  }

  // ---------- camera ----------
  var camModes = ['Chase', 'Cockpit', 'Orbit'], camI = 0;
  function cycleCam(){ camI = (camI + 1) % camModes.length; document.getElementById('fsCam').textContent = 'Camera: ' + camModes[camI]; }
  document.getElementById('fsCam').addEventListener('click', cycleCam);
  function camera(){
    var fwd = v3(Math.sin(S.yaw) * Math.cos(S.pitch), Math.sin(S.pitch), Math.cos(S.yaw) * Math.cos(S.pitch));
    if (camModes[camI] === 'Cockpit') return { pos: add(S.pos, v3(0, 1.2, 0)), look: add(S.pos, add(v3(0,1.2,0), mul(fwd, 100))) };
    if (camModes[camI] === 'Orbit'){ var a = S.t * 0.25; return { pos: add(S.pos, v3(Math.sin(a)*46, 18, Math.cos(a)*46)), look: S.pos }; }
    return { pos: sub(add(S.pos, v3(0, 7 + S.speed*0.05, 0)), mul(fwd, 26 + S.speed*0.25)), look: add(S.pos, mul(fwd, 40)) };
  }

  // ---------- renderer: painter's algorithm over camera-space polys ----------
  var SKY_TOP = [8,14,26], SKY_BOT = [122,150,170], FOG = [128,148,162];
  function mix(c1, c2, f){ return 'rgb(' + Math.round(c1[0]+(c2[0]-c1[0])*f) + ',' + Math.round(c1[1]+(c2[1]-c1[1])*f) + ',' + Math.round(c1[2]+(c2[2]-c1[2])*f) + ')'; }
  var SUN = norm(v3(0.45, 0.8, 0.35));

  function render(){
    var cam = camera();
    var zAxis = norm(sub(cam.look, cam.pos));
    var xAxis = norm(cross(v3(0,1,0), zAxis));
    var yAxis = cross(zAxis, xAxis);
    // camera roll in chase/cockpit for banking feel
    if (camModes[camI] !== 'Orbit'){
      var cr = -S.roll * (camModes[camI] === 'Cockpit' ? 1 : 0.35);
      var cx2 = add(mul(xAxis, Math.cos(cr)), mul(yAxis, Math.sin(cr)));
      var cy2 = sub(mul(yAxis, Math.cos(cr)), mul(xAxis, Math.sin(cr)));
      xAxis = cx2; yAxis = cy2;
    }
    var f = H * 0.9; // focal
    function proj(p){
      var d = sub(p, cam.pos);
      var z = dot(d, zAxis); if (z < 1.2) return null;
      return { x: W/2 + dot(d, xAxis) * f / z, y: H/2 - dot(d, yAxis) * f / z, z: z };
    }
    // sky
    var g = ctx.createLinearGradient(0, 0, 0, H);
    g.addColorStop(0, mix(SKY_TOP, SKY_BOT, 0.1)); g.addColorStop(0.62, mix(SKY_TOP, SKY_BOT, 0.85)); g.addColorStop(1, mix(SKY_BOT, FOG, 0.8));
    ctx.fillStyle = g; ctx.fillRect(0, 0, W, H);

    var polys = [];
    function quad(a, b, c, d, col, emissive){
      var pa = proj(a), pb = proj(b), pc = proj(c), pd = proj(d);
      if (!pa || !pb || !pc || !pd) return;
      var zAvg = (pa.z + pb.z + pc.z + pd.z) / 4;
      var shade = col;
      if (!emissive){
        var nrm = norm(cross(sub(b, a), sub(c, a)));
        var l = 0.45 + 0.55 * Math.max(0, dot(nrm, SUN));
        shade = [col[0]*l, col[1]*l, col[2]*l];
      }
      var fog = Math.min(1, zAvg / 5200); fog = fog * fog;
      polys.push({ z: zAvg, pts: [pa, pb, pc, pd], fill: mix(shade, FOG, fog) });
    }
    // terrain grid centred under the aircraft, snapped to cells
    var CELL = 110, N = 26;
    var cx0 = Math.floor(S.pos.x / CELL) * CELL, cz0 = Math.floor(S.pos.z / CELL) * CELL;
    for (var gz = -N; gz < N; gz++){
      for (var gx = -N; gx < N; gx++){
        var x0 = cx0 + gx * CELL, z0 = cz0 + gz * CELL;
        // cheap frustum-ish cull: skip cells behind the camera
        var toCell = sub(v3(x0 + CELL/2, 0, z0 + CELL/2), cam.pos);
        if (dot(toCell, zAxis) < -CELL) continue;
        var h00 = terrainH(x0, z0), h10 = terrainH(x0+CELL, z0), h01 = terrainH(x0, z0+CELL), h11 = terrainH(x0+CELL, z0+CELL);
        var hAvg = (h00 + h10 + h01 + h11) / 4;
        var col = hAvg < 2 ? [64,112,58] : hAvg < 60 ? [86,120,62] : hAvg < 140 ? [122,110,80] : [225,228,232];
        // runway strip
        if (Math.abs(x0 + CELL/2) < 60 && z0 + CELL/2 > -30 && z0 + CELL/2 < 1020 && hAvg < 2) col = [52,54,58];
        quad(v3(x0, h00, z0), v3(x0+CELL, h10, z0), v3(x0+CELL, h11, z0+CELL), v3(x0, h01, z0+CELL), col);
      }
    }
    // runway centreline dashes
    for (var rz = 0; rz < 1000; rz += 90){
      quad(v3(-2, 0.35, rz), v3(2, 0.35, rz), v3(2, 0.35, rz+38), v3(-2, 0.35, rz+38), [235,235,235], true);
    }
    // the aircraft (skip in cockpit view): low-poly delta in body frame
    if (camModes[camI] !== 'Cockpit'){
      var cy = Math.cos(S.yaw), sy = Math.sin(S.yaw), cp = Math.cos(S.pitch), sp = Math.sin(S.pitch), cr2 = Math.cos(S.roll), sr = Math.sin(S.roll);
      function body(p){ // roll -> pitch -> yaw -> translate
        var x1 = p.x * cr2 - p.y * sr, y1 = p.x * sr + p.y * cr2, z1 = p.z;
        var y2 = y1 * cp - z1 * sp, z2 = y1 * sp + z1 * cp;
        return add(v3(x1 * cy + z2 * sy, y2, -x1 * sy + z2 * cy), S.pos);
      }
      var nose = body(v3(0, 0, 6.2)), tailL = body(v3(-4.6, 0, -3.6)), tailR = body(v3(4.6, 0, -3.6));
      var tailT = body(v3(0, 2.3, -3.4)), tailB = body(v3(0, -0.5, -3.2));
      quad(nose, tailL, body(v3(0,0,-2.6)), tailL, [255,79,0], true); // left wing
      quad(nose, tailR, body(v3(0,0,-2.6)), tailR, [255,112,64], true); // right wing
      quad(body(v3(0,0.4,5.4)), tailT, body(v3(0,0.4,-3.4)), tailB, [230,232,238], true); // fin
    }
    polys.sort(function(a, b){ return b.z - a.z; });
    for (var i = 0; i < polys.length; i++){
      var p = polys[i];
      ctx.beginPath();
      ctx.moveTo(p.pts[0].x, p.pts[0].y);
      for (var j = 1; j < p.pts.length; j++) ctx.lineTo(p.pts[j].x, p.pts[j].y);
      ctx.closePath();
      ctx.fillStyle = p.fill; ctx.fill();
    }
    // horizon reference in cockpit
    if (camModes[camI] === 'Cockpit'){
      ctx.strokeStyle = 'rgba(255,255,255,0.55)'; ctx.lineWidth = 1.5;
      ctx.beginPath(); ctx.moveTo(W/2 - 60, H/2); ctx.lineTo(W/2 - 18, H/2); ctx.moveTo(W/2 + 18, H/2); ctx.lineTo(W/2 + 60, H/2);
      ctx.moveTo(W/2, H/2 - 6); ctx.lineTo(W/2, H/2 + 6); ctx.stroke();
    }
  }

  // ---------- messages / loop ----------
  var paused = false;
  function showMsg(t, b, btn){
    document.getElementById('fsMsgTitle').textContent = t;
    document.getElementById('fsMsgBody').textContent = b;
    document.getElementById('fsMsgBtn').textContent = btn || 'OK';
    document.getElementById('fsMsg').style.display = 'block';
  }
  function hideMsg(){ document.getElementById('fsMsg').style.display = 'none'; }
  document.getElementById('fsMsgBtn').addEventListener('click', function(){ if (S.done){ reset(); } hideMsg(); });
  document.getElementById('fsReset').addEventListener('click', function(){ reset(); hideMsg(); });
  document.getElementById('fsPause').addEventListener('click', function(){ paused = !paused; this.textContent = paused ? 'Resume' : 'Pause'; });

  var last = performance.now();
  function frame(now){
    var dt = Math.min(0.05, (now - last) / 1000); last = now;
    if (!paused) step(dt);
    render();
    requestAnimationFrame(frame);
  }
  resize();
  showMsg('Welcome, pilot', 'You are on the runway with engines idle. Hold W for full throttle, pull up (Down arrow) past 70 km/h, and explore the valley. Bank with the arrows to turn - real bank-turn physics. Land back on the dark strip, gently, to complete the sortie.', 'Fly');
  requestAnimationFrame(frame);
})();
</script>

</BaseLayout>
