    s.appendChild(txt('Q (' + qVce.toFixed(2) + 'V, ' + (qIc * 1e3).toFixed(2) + 'mA)', qx + 8, qy - 6, '#fff', 10));

    s.appendChild(txt((type === 'bjt' ? 'Vce (V) ->' : 'Vds (V) ->'), Rr - 4, B + 30, '#9aa6b6', 10, 'end'));
    s.appendChild(txt((type === 'bjt' ? 'Ic (mA)' : 'Id (mA)'), L - 30, T + 4, '#9aa6b6', 10));

    $('dvReadout').textContent = readout;
    $('stageCap').textContent = 'Output characteristic family from the ' + device + ' large-signal model, overlaid with the DC load line; the marked Q-point is the simultaneous solution of device curve and load line.';

    $('bigReadout').innerHTML = '<div class="eee-bigval">' + region.split(' ')[0] + '<span> Q-point region</span></div>';
    var h = '<tr><th>Quantity</th><th style="text-align:right">Value</th></tr>';
    h += '<tr><td class="nm">Vcc / Vdd</td><td class="vc">' + Vcc.toFixed(1) + ' V</td></tr>';
    h += '<tr><td class="nm">Rc / Rd</td><td class="vc">' + Rc.toFixed(0) + ' ohm</td></tr>';
    h += '<tr><td class="nm">Q: Vce/Vds</td><td class="vp">' + qVce.toFixed(3) + ' V</td></tr>';
    h += '<tr><td class="nm">Q: Ic/Id</td><td class="vp">' + (qIc * 1e3).toFixed(3) + ' mA</td></tr>';
    h += '<tr><td class="nm">Saturation I (Vce=0)</td><td class="va">' + (iAxis * 1e3).toFixed(2) + ' mA</td></tr>';
    h += '<tr><td class="nm">Region</td><td class="va" style="font-size:9.5px">' + region + '</td></tr>';
    $('resTable').innerHTML = h;
  }

