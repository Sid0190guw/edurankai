---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Electrical & Electronic Engineering · Virtual Labs · AquinTutor" description="Real circuit solver — Ohm's law, Kirchhoff, nodal analysis, Thevenin/Norton, transients, AC phasors, Bode, op-amps.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; }
  .eee-wrap { max-width: 1560px; margin: 0 auto; padding: 18px 3vw 70px; }
  .eee-top { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 12px; margin-bottom: 8px; }
  .eee-back { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #67e8f9; text-decoration: none; letter-spacing: 0.08em; }
  .eee-eye { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 12px 0 0; }
  .eee-title { font-family: 'Cormorant Garamond', serif; font-size: 34px; font-weight: 600; margin: 4px 0 0; letter-spacing: -0.02em; }
  .eee-title em { color: #67e8f9; font-style: italic; font-weight: 500; }
  .eee-lede { color: #9aa6b6; font-size: 13.5px; line-height: 1.55; max-width: 820px; margin: 10px 0 18px; }

  .eee-shell { display: grid; grid-template-columns: 264px minmax(0,1fr); gap: 18px; align-items: start; }
  @media (max-width: 1000px) { .eee-shell { grid-template-columns: 1fr; } }

  /* experiment sidebar */
  .eee-explist { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 10px; position: sticky; top: 14px; }
  .eee-explist h3 { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 4px 6px 10px; }
  .eee-exp { display: flex; gap: 9px; align-items: flex-start; width: 100%; text-align: left; background: transparent; border: 1px solid transparent; border-radius: 9px; padding: 8px 9px; margin-bottom: 3px; cursor: pointer; color: #cfd6da; }
  .eee-exp:hover { background: #0a0a0c; border-color: #2a2a35; }
  .eee-exp.active { background: #0a0a0c; border-color: #67e8f9; }
  .eee-exp .num { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; color: #67e8f9; font-weight: 700; min-width: 16px; padding-top: 1px; }
  .eee-exp .nm { font-family: 'Cormorant Garamond', serif; font-size: 16px; line-height: 1.15; font-weight: 600; }
  .eee-exp.active .nm { color: #fff; }

  /* experiment main */
  .eee-main { min-width: 0; }
  .eee-exhead { font-family: 'Cormorant Garamond', serif; font-size: 27px; font-weight: 600; margin: 2px 0 2px; letter-spacing: -0.01em; }
  .eee-exhead em { color: #67e8f9; font-style: italic; }
  .eee-exsub { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10.5px; color: #6b7280; letter-spacing: 0.06em; margin: 0 0 14px; }

  .eee-tabs { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 16px; border-bottom: 1px solid #2a2a35; padding-bottom: 12px; }
  .eee-tab { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 7px 12px; border-radius: 7px; border: 1px solid #2a2a35; background: #11131a; color: #9aa6b6; cursor: pointer; }
  .eee-tab.active { color: #04161b; background: #67e8f9; border-color: #67e8f9; }

  .eee-sec { display: none; }
  .eee-sec.active { display: block; }

  .eee-prose { color: #cbd2dc; font-size: 14px; line-height: 1.7; max-width: 880px; }
  .eee-prose p { margin: 0 0 12px; }
  .eee-prose ol { margin: 0; padding-left: 22px; line-height: 1.75; font-size: 13.5px; color: #cbd2dc; }
  .eee-prose ol li { margin-bottom: 7px; }
  .eee-eqbox { background: #11131a; border: 1px solid #2a2a35; border-left: 3px solid #67e8f9; border-radius: 8px; padding: 12px 14px; margin: 14px 0; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12.5px; color: #e8e8ee; line-height: 1.9; }
  .eee-eqbox .k { color: #fbbf24; }
  .eee-refs { list-style: none; padding: 0; margin: 0; }
  .eee-refs li { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12px; color: #9aa6b6; padding: 8px 0; border-bottom: 1px solid #1a1a25; line-height: 1.5; }
  .eee-refs li b { color: #cfd6da; font-weight: 700; }

  /* simulation layout */
  .eee-simgrid { display: grid; grid-template-columns: 320px minmax(0,1fr) 280px; gap: 16px; align-items: start; }
  @media (max-width: 1240px) { .eee-simgrid { grid-template-columns: 1fr; } }
  .eee-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 16px; margin-bottom: 14px; }
  .eee-panel h3 { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 12px; }
  .eee-lbl { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #9aa6b6; }
  .eee-val { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12px; color: #67e8f9; font-weight: 700; }
  .eee-btn { background: #67e8f9; color: #04161b; padding: 8px 14px; border-radius: 7px; border: none; cursor: pointer; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
  .eee-btn.ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
  .eee-btn.purple { background: #a78bfa; color: #160a2b; }
  .eee-btn.amber { background: #fbbf24; color: #2b1d00; }
  select, input[type=text], input[type=number] { background: #0a0a0c; border: 1px solid #2a2a35; color: #e8e8ee; border-radius: 6px; padding: 6px 8px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; width: 100%; box-sizing: border-box; }
  input[type=range] { width: 100%; accent-color: #67e8f9; }
  .eee-nl { width: 100%; border-collapse: collapse; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; }
  .eee-nl th { text-align: left; color: #6b7280; font-weight: 600; padding: 4px 5px; border-bottom: 1px solid #2a2a35; font-size: 9.5px; text-transform: uppercase; letter-spacing: 0.06em; }
  .eee-nl td { padding: 4px 5px; border-bottom: 1px solid #1a1a25; color: #cfd6da; }
  .eee-nl td .x { color: #fca5a5; cursor: pointer; font-weight: 700; }
  .eee-add { display: grid; grid-template-columns: 1.3fr 0.6fr 0.6fr 1fr auto; gap: 5px; margin-top: 8px; align-items: center; }
  .eee-canvas-wrap { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 12px; padding: 4px; }
  .eee-stage { width: 100%; display: block; border-radius: 10px; }
  .eee-rt { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; width: 100%; }
  .eee-rt th { text-align: left; color: #6b7280; padding: 5px 6px; border-bottom: 1px solid #2a2a35; font-size: 9.5px; text-transform: uppercase; letter-spacing: 0.05em; }
  .eee-rt td { padding: 5px 6px; border-bottom: 1px solid #1a1a25; }
  .eee-rt .nm { color: #9aa6b6; }
  .eee-rt .vc { color: #86efac; text-align: right; font-weight: 700; }
  .eee-rt .vp { color: #a78bfa; text-align: right; font-weight: 700; }
  .eee-rt .va { color: #fbbf24; text-align: right; font-weight: 700; }
  .eee-note { font-size: 10.5px; color: #6b7280; line-height: 1.5; margin-top: 8px; font-family: 'Geist Mono', ui-monospace, monospace; }
  .eee-err { color: #fca5a5; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; }
  .eee-ok { color: #86efac; }
  .eee-ctrlrow { display: grid; grid-template-columns: 1fr; gap: 4px; padding: 7px 0; }
  .eee-bigval { font-family: 'Cormorant Garamond', serif; font-size: 26px; color: #67e8f9; font-weight: 600; }
  .eee-bigval span { font-size: 13px; color: #9aa6b6; font-family: 'Geist Mono', ui-monospace, monospace; }

  /* self assessment */
  .eee-q { background: #11131a; border: 1px solid #2a2a35; border-radius: 10px; padding: 14px 16px; margin-bottom: 12px; max-width: 880px; }
  .eee-q .qt { font-size: 14px; color: #e8e8ee; line-height: 1.5; margin: 0 0 10px; font-weight: 600; }
  .eee-opt { display: flex; gap: 9px; align-items: flex-start; padding: 7px 9px; border-radius: 7px; cursor: pointer; border: 1px solid transparent; font-size: 13px; color: #cbd2dc; line-height: 1.45; }
  .eee-opt:hover { background: #0a0a0c; }
  .eee-opt input { width: auto; margin-top: 3px; accent-color: #67e8f9; }
  .eee-opt.correct { border-color: #86efac; background: rgba(134,239,172,0.08); }
  .eee-opt.wrong { border-color: #fca5a5; background: rgba(252,165,165,0.08); }
  .eee-expl { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; line-height: 1.5; margin-top: 9px; padding: 8px 10px; border-radius: 7px; display: none; }
  .eee-expl.show { display: block; }
  .eee-expl.good { color: #86efac; background: rgba(134,239,172,0.06); }
  .eee-expl.bad { color: #fca5a5; background: rgba(252,165,165,0.06); }
  .eee-checkbtn { margin-top: 4px; }
</style>

<main class="eee-wrap">
  <div class="eee-top">
    <div>
      <a class="eee-back" href="/aquintutor/labs">&larr; Virtual labs</a>
      <p class="eee-eye">Electrical &amp; Electronic Engineering</p>
      <h1 class="eee-title">Circuits &amp; <em>networks</em> virtual lab.</h1>
    </div>
  </div>
  <p class="eee-lede">Eight self-contained experiments — from Ohm's law to op-amp integrators — in the Virtual Labs format. Each opens with an aim, the underlying theory and equations, a numbered procedure, a genuinely-computing interactive simulator, a marked self-assessment quiz and references. The engine is a hand-rolled Modified Nodal Analysis (MNA) solver with Gaussian elimination, implicit transient integrators and a complex-impedance AC sweep — nothing is pre-baked.</p>

  <div class="eee-shell">
    <aside>
      <nav class="eee-explist" id="expList">
        <h3>Experiments</h3>
        <!-- buttons injected -->
      </nav>
    </aside>

    <section class="eee-main">
      <h2 class="eee-exhead" id="exTitle"></h2>
      <p class="eee-exsub" id="exSub"></p>

      <div class="eee-tabs" id="secTabs">
        <button class="eee-tab active" data-sec="aim">Aim</button>
        <button class="eee-tab" data-sec="theory">Theory</button>
        <button class="eee-tab" data-sec="proc">Procedure</button>
        <button class="eee-tab" data-sec="sim">Simulation</button>
        <button class="eee-tab" data-sec="quiz">Self-assessment</button>
        <button class="eee-tab" data-sec="ref">References</button>
      </div>

      <!-- AIM -->
      <div class="eee-sec active" data-sec="aim">
        <div class="eee-prose" id="secAim"></div>
      </div>

      <!-- THEORY -->
      <div class="eee-sec" data-sec="theory">
        <div class="eee-prose" id="secTheory"></div>
      </div>

      <!-- PROCEDURE -->
      <div class="eee-sec" data-sec="proc">
        <div class="eee-prose"><ol id="secProc"></ol></div>
      </div>

      <!-- SIMULATION (shared shell; panels swapped per experiment) -->
      <div class="eee-sec" data-sec="sim">
        <div class="eee-simgrid">
          <aside id="simControls"></aside>
          <div>
            <div class="eee-canvas-wrap">
              <svg id="stage" class="eee-stage" viewBox="0 0 900 540" preserveAspectRatio="xMidYMid meet"></svg>
            </div>
            <p class="eee-note" id="stageCap"></p>
          </div>
          <aside>
            <div class="eee-panel">
              <h3>Live readouts</h3>
              <div id="bigReadout"></div>
              <table class="eee-rt" style="margin-top:10px;" id="resTable"></table>
            </div>
          </aside>
        </div>
      </div>

      <!-- SELF ASSESSMENT -->
      <div class="eee-sec" data-sec="quiz">
        <div id="secQuiz"></div>
      </div>

      <!-- REFERENCES -->
      <div class="eee-sec" data-sec="ref">
        <ul class="eee-refs" id="secRef"></ul>
      </div>
    </section>
  </div>
</main>

<script is:inline>
(function () {
  'use strict';

  // ==================================================================
  // PART 1 — NUMERIC / LINEAR-ALGEBRA KERNEL  (preserved verbatim)
  // ==================================================================

  // Solve A x = b by Gaussian elimination with partial pivoting.
  function gaussSolve(Ain, bin) {
    var n = bin.length;
    var i, j, k;
    var A = [];
    for (i = 0; i < n; i++) { A[i] = Ain[i].slice(0); }
    var b = bin.slice(0);

    for (k = 0; k < n; k++) {
      var p = k;
      var maxv = Math.abs(A[k][k]);
      for (i = k + 1; i < n; i++) {
        var av = Math.abs(A[i][k]);
        if (av > maxv) { maxv = av; p = i; }
      }
      if (maxv < 1e-14) { return null; }
      if (p !== k) {
        var tmp = A[p]; A[p] = A[k]; A[k] = tmp;
        var tb = b[p]; b[p] = b[k]; b[k] = tb;
      }
      var piv = A[k][k];
      for (i = k + 1; i < n; i++) {
        var f = A[i][k] / piv;
        if (f !== 0) {
          for (j = k; j < n; j++) { A[i][j] -= f * A[k][j]; }
          b[i] -= f * b[k];
        }
      }
    }
    var x = new Array(n);
    for (i = n - 1; i >= 0; i--) {
      var s = b[i];
      for (j = i + 1; j < n; j++) { s -= A[i][j] * x[j]; }
      x[i] = s / A[i][i];
    }
    return x;
  }

  // Modified Nodal Analysis (preserved verbatim).
  function solveMNA(elements) {
    var nodeSet = {};
    var e, i;
    var maxNode = 0;
    for (i = 0; i < elements.length; i++) {
      e = elements[i];
      nodeSet[e.a] = true; nodeSet[e.b] = true;
      if (e.type === 'O') { nodeSet[e.out] = true; }
      maxNode = Math.max(maxNode, e.a, e.b, (e.type === 'O' ? e.out : 0));
    }
    var nodes = [];
    for (var nk in nodeSet) {
      var nn = parseInt(nk, 10);
      if (nn !== 0) { nodes.push(nn); }
    }
    nodes.sort(function (x, y) { return x - y; });
    var idx = {};
    for (i = 0; i < nodes.length; i++) { idx[nodes[i]] = i; }
    var N = nodes.length;

    var extras = [];
    for (i = 0; i < elements.length; i++) {
      e = elements[i];
      if (e.type === 'V' || e.type === 'O') { extras.push(e); }
    }
    var M = extras.length;
    var dim = N + M;
    if (dim === 0) { return { error: 'No nodes to solve.' }; }

    var A = [];
    for (i = 0; i < dim; i++) { A[i] = new Array(dim); for (var jj = 0; jj < dim; jj++) { A[i][jj] = 0; } }
    var z = new Array(dim);
    for (i = 0; i < dim; i++) { z[i] = 0; }

    function gi(node) { return (node === 0) ? -1 : idx[node]; }

    for (i = 0; i < elements.length; i++) {
      e = elements[i];
      if (e.type === 'R') {
        if (!(e.val > 0)) { return { error: 'Resistor value must be > 0.' }; }
        var g = 1 / e.val;
        var ra = gi(e.a), rb = gi(e.b);
        if (ra >= 0) { A[ra][ra] += g; }
        if (rb >= 0) { A[rb][rb] += g; }
        if (ra >= 0 && rb >= 0) { A[ra][rb] -= g; A[rb][ra] -= g; }
      } else if (e.type === 'I') {
        var ia = gi(e.a), ib = gi(e.b);
        if (ia >= 0) { z[ia] -= e.val; }
        if (ib >= 0) { z[ib] += e.val; }
      }
    }

    for (var m = 0; m < extras.length; m++) {
      e = extras[m];
      var col = N + m;
      if (e.type === 'V') {
        var va = gi(e.a), vb = gi(e.b);
        if (va >= 0) { A[va][col] += 1; A[col][va] += 1; }
        if (vb >= 0) { A[vb][col] -= 1; A[col][vb] -= 1; }
        z[col] += e.val;
      } else if (e.type === 'O') {
        var go = gi(e.out);
        if (go >= 0) { A[go][col] += 1; }
        var oa = gi(e.a), ob = gi(e.b);
        if (oa >= 0) { A[col][oa] += 1; }
        if (ob >= 0) { A[col][ob] -= 1; }
      }
    }

    var sol = gaussSolve(A, z);
    if (!sol) { return { error: 'Matrix singular — check for floating nodes, missing ground, or shorted source.' }; }

    var V = {}; V[0] = 0;
    for (i = 0; i < N; i++) { V[nodes[i]] = sol[i]; }

    var branches = [];
    var totalPower = 0;
    for (i = 0; i < elements.length; i++) {
      e = elements[i];
      if (e.type === 'R') {
        var vab = (V[e.a] || 0) - (V[e.b] || 0);
        var cur = vab / e.val;
        var pw = vab * cur;
        totalPower += pw;
        branches.push({ name: 'R(' + e.a + ',' + e.b + ')', label: e.val + ' ohm', current: cur, power: pw, vdrop: vab });
      } else if (e.type === 'I') {
        var vabI = (V[e.a] || 0) - (V[e.b] || 0);
        branches.push({ name: 'I(' + e.a + ',' + e.b + ')', label: e.val + ' A', current: e.val, power: -vabI * e.val, vdrop: vabI });
      }
    }
    for (var mm = 0; mm < extras.length; mm++) {
      e = extras[mm];
      var ic = sol[N + mm];
      if (e.type === 'V') {
        branches.push({ name: 'V(' + e.a + ',' + e.b + ')', label: e.val + ' V', current: ic, power: -e.val * ic, vdrop: e.val });
      } else if (e.type === 'O') {
        branches.push({ name: 'OpAmp out=' + e.out, label: 'V=' + ((V[e.out] || 0)).toFixed(3) + ' V', current: ic, power: 0, vdrop: 0 });
      }
    }

    return { V: V, nodes: nodes, branches: branches, totalPower: totalPower };
  }

  // tiny complex helpers (preserved verbatim)
  function cadd(a, b) { return { re: a.re + b.re, im: a.im + b.im }; }
  function cmul(a, b) { return { re: a.re * b.re - a.im * b.im, im: a.re * b.im + a.im * b.re }; }
  function cdiv(a, b) { var d = b.re * b.re + b.im * b.im; return { re: (a.re * b.re + a.im * b.im) / d, im: (a.im * b.re - a.re * b.im) / d }; }
  function cabs(a) { return Math.sqrt(a.re * a.re + a.im * a.im); }

  // ==================================================================
  // PART 2 — FORMATTING + SVG HELPERS  (preserved verbatim)
  // ==================================================================
  function $(id) { return document.getElementById(id); }
  function fmt(x, d) {
    if (!isFinite(x)) { return '--'; }
    d = (d === undefined) ? 3 : d;
    var ax = Math.abs(x);
    if (ax !== 0 && (ax < 1e-3 || ax >= 1e6)) { return x.toExponential(2); }
    return x.toFixed(d);
  }
  function siVal(x) {
    var ax = Math.abs(x);
    if (ax >= 1e9) { return (x / 1e9).toFixed(2) + ' G'; }
    if (ax >= 1e6) { return (x / 1e6).toFixed(2) + ' M'; }
    if (ax >= 1e3) { return (x / 1e3).toFixed(2) + ' k'; }
    if (ax !== 0 && ax < 1e-6) { return (x * 1e9).toFixed(2) + ' n'; }
    if (ax !== 0 && ax < 1e-3) { return (x * 1e6).toFixed(2) + ' u'; }
    if (ax !== 0 && ax < 1) { return (x * 1e3).toFixed(2) + ' m'; }
    return x.toFixed(2) + ' ';
  }

  var SVGNS = 'http://www.w3.org/2000/svg';
  function svgEl(name, attrs) {
    var el = document.createElementNS(SVGNS, name);
    if (attrs) { for (var k in attrs) { el.setAttribute(k, attrs[k]); } }
    return el;
  }
  function clearStage() {
    var s = $('stage');
    while (s.firstChild) { s.removeChild(s.firstChild); }
    return s;
  }
  function txt(s, x, y, fill, size, anchor, family) {
    var t = svgEl('text', { x: x, y: y, fill: fill, 'font-size': size || 11,
      'font-family': family || "'Geist Mono', ui-monospace, monospace", 'text-anchor': anchor || 'start' });
    t.textContent = s;
    return t;
  }
  var TYPE_LABEL = { R: 'Resistor', V: 'V-source', I: 'I-source', O: 'Op-amp' };

  // ==================================================================
  // PART 3 — SHARED STATE
  // ==================================================================
  var netlist = []; // for the nodal-analysis experiment
  var currentExp = 0;
  var currentSec = 'aim';

  // ==================================================================
  // PART 4 — SIMULATION RENDERERS (one render() per experiment)
  // ==================================================================

  // ---- EXP 1: Ohm's law + series/parallel -------------------------
  function controls_ohm() {
    return '' +
      '<div class="eee-panel">' +
        '<h3>Source &amp; configuration</h3>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">Connection</span>' +
          '<select id="oMode"><option value="series">Series (R1 + R2 + R3)</option><option value="parallel">Parallel (R1 || R2 || R3)</option></select></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">Source V (V) <b id="oVL" class="eee-val">12.0</b></span>' +
          '<input type="range" id="oV" min="1" max="24" step="0.5" value="12"></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">R1 (ohm) <b id="oR1L" class="eee-val">100</b></span>' +
          '<input type="range" id="oR1" min="10" max="2000" step="10" value="100"></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">R2 (ohm) <b id="oR2L" class="eee-val">220</b></span>' +
          '<input type="range" id="oR2" min="10" max="2000" step="10" value="220"></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">R3 (ohm) <b id="oR3L" class="eee-val">330</b></span>' +
          '<input type="range" id="oR3" min="10" max="2000" step="10" value="330"></div>' +
        '<p id="oReadout" class="eee-note"></p>' +
      '</div>';
  }
  function wire_ohm() {
    var ids = ['oMode', 'oV', 'oR1', 'oR2', 'oR3'];
    for (var i = 0; i < ids.length; i++) { $(ids[i]).addEventListener('input', render_ohm); $(ids[i]).addEventListener('change', render_ohm); }
    render_ohm();
  }
  function render_ohm() {
    var mode = $('oMode').value;
    var V = parseFloat($('oV').value);
    var R1 = parseFloat($('oR1').value), R2 = parseFloat($('oR2').value), R3 = parseFloat($('oR3').value);
    $('oVL').textContent = V.toFixed(1); $('oR1L').textContent = R1.toFixed(0);
    $('oR2L').textContent = R2.toFixed(0); $('oR3L').textContent = R3.toFixed(0);

    var Req, I, branchI = [], branchV = [];
    if (mode === 'series') {
      Req = R1 + R2 + R3;
      I = V / Req;
      branchI = [I, I, I];
      branchV = [I * R1, I * R2, I * R3];
    } else {
      Req = 1 / (1 / R1 + 1 / R2 + 1 / R3);
      I = V / Req; // total
      branchV = [V, V, V];
      branchI = [V / R1, V / R2, V / R3];
    }
    var Ptot = V * I;
    $('oReadout').textContent = mode === 'series'
      ? 'Series: Req = R1+R2+R3 = ' + Req.toFixed(1) + ' ohm. Same current I = V/Req everywhere; voltage divides in proportion to R.'
      : 'Parallel: 1/Req = 1/R1+1/R2+1/R3 -> Req = ' + Req.toFixed(2) + ' ohm. Same voltage across each; current divides inversely with R.';

    // schematic
    var s = clearStage();
    var Rs = [R1, R2, R3], cols = ['#67e8f9', '#fbbf24', '#a78bfa'];
    if (mode === 'series') {
      var y0 = 270, x0 = 120, dx = 200;
      s.appendChild(txt('+', x0 - 36, y0 - 30, '#fbbf24', 16, 'middle'));
      s.appendChild(svgEl('line', { x1: x0 - 36, y1: y0 - 18, x2: x0 - 36, y2: y0, stroke: '#fbbf24', 'stroke-width': 2 }));
      s.appendChild(txt(V.toFixed(1) + ' V', x0 - 64, y0 - 8, '#fbbf24', 12, 'middle'));
      s.appendChild(svgEl('line', { x1: x0 - 36, y1: y0, x2: x0, y2: y0, stroke: '#9aa6b6', 'stroke-width': 2 }));
      for (var i = 0; i < 3; i++) {
        var rx = x0 + i * dx;
        s.appendChild(svgEl('rect', { x: rx, y: y0 - 16, width: 120, height: 32, rx: 6, fill: '#11131a', stroke: cols[i], 'stroke-width': 2 }));
        s.appendChild(txt('R' + (i + 1) + ' = ' + Rs[i].toFixed(0) + ' ohm', rx + 60, y0 - 1, cols[i], 11, 'middle'));
        s.appendChild(txt(siVal(branchI[i]) + 'A', rx + 60, y0 + 13, '#86efac', 10, 'middle'));
        s.appendChild(txt('drop ' + branchV[i].toFixed(2) + ' V', rx + 60, y0 + 40, '#cfd6da', 10, 'middle'));
        if (i < 2) { s.appendChild(svgEl('line', { x1: rx + 120, y1: y0, x2: rx + dx, y2: y0, stroke: '#9aa6b6', 'stroke-width': 2 })); }
      }
      s.appendChild(svgEl('line', { x1: x0 + 2 * dx + 120, y1: y0, x2: x0 + 2 * dx + 156, y2: y0, stroke: '#9aa6b6', 'stroke-width': 2 }));
      s.appendChild(txt('current loop I = ' + siVal(I) + 'A (same through every series R)', 450, 470, '#6b7280', 11, 'middle'));
    } else {
      var sx = 250, top = 120, sp = 90;
      s.appendChild(svgEl('line', { x1: sx, y1: top, x2: sx, y2: top + 2 * sp, stroke: '#9aa6b6', 'stroke-width': 2 }));
      s.appendChild(svgEl('line', { x1: sx + 320, y1: top, x2: sx + 320, y2: top + 2 * sp, stroke: '#9aa6b6', 'stroke-width': 2 }));
      s.appendChild(txt(V.toFixed(1) + ' V', sx - 18, top + sp, '#fbbf24', 12, 'end'));
      for (var j = 0; j < 3; j++) {
        var by = top + j * sp;
        s.appendChild(svgEl('line', { x1: sx, y1: by, x2: sx + 100, y2: by, stroke: '#9aa6b6', 'stroke-width': 2 }));
        s.appendChild(svgEl('rect', { x: sx + 100, y: by - 15, width: 120, height: 30, rx: 6, fill: '#11131a', stroke: cols[j], 'stroke-width': 2 }));
        s.appendChild(txt('R' + (j + 1) + ' = ' + Rs[j].toFixed(0) + ' ohm', sx + 160, by - 1, cols[j], 10.5, 'middle'));
        s.appendChild(txt(siVal(branchI[j]) + 'A', sx + 160, by + 12, '#86efac', 9.5, 'middle'));
        s.appendChild(svgEl('line', { x1: sx + 220, y1: by, x2: sx + 320, y2: by, stroke: '#9aa6b6', 'stroke-width': 2 }));
      }
      s.appendChild(txt('Total I = sum of branch currents = ' + siVal(I) + 'A', 450, 470, '#6b7280', 11, 'middle'));
    }
    s.appendChild(txt('Req = ' + Req.toFixed(2) + ' ohm   |   I_total = ' + siVal(I) + 'A   |   P = ' + siVal(Ptot) + 'W', 450, 510, '#67e8f9', 12, 'middle'));
    $('stageCap').textContent = 'Equivalent resistance, branch currents and voltage division computed directly from Ohm\'s law.';

    $('bigReadout').innerHTML = '<div class="eee-bigval">' + Req.toFixed(2) + ' <span>ohm equivalent R</span></div>';
    var h = '<tr><th>Quantity</th><th style="text-align:right">Value</th></tr>';
    h += '<tr><td class="nm">Req</td><td class="vc">' + Req.toFixed(2) + ' ohm</td></tr>';
    h += '<tr><td class="nm">I total</td><td class="vp">' + siVal(I) + 'A</td></tr>';
    h += '<tr><td class="nm">R1 current</td><td class="vp">' + siVal(branchI[0]) + 'A</td></tr>';
    h += '<tr><td class="nm">R2 current</td><td class="vp">' + siVal(branchI[1]) + 'A</td></tr>';
    h += '<tr><td class="nm">R3 current</td><td class="vp">' + siVal(branchI[2]) + 'A</td></tr>';
    h += '<tr><td class="nm">Power</td><td class="va">' + siVal(Ptot) + 'W</td></tr>';
    $('resTable').innerHTML = h;
  }

  // ---- EXP 2: Kirchhoff's laws (two-loop) -------------------------
  function controls_kcl() {
    return '' +
      '<div class="eee-panel">' +
        '<h3>Two-loop network</h3>' +
        '<p class="eee-note" style="margin-top:0">Two sources V1, V2 drive a ladder: R1 from node A to V1, R2 from A to ground, R3 from A to V2. KCL solved at node A; KVL checked around both loops.</p>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">V1 (V) <b id="kV1L" class="eee-val">10.0</b></span>' +
          '<input type="range" id="kV1" min="0" max="20" step="0.5" value="10"></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">V2 (V) <b id="kV2L" class="eee-val">5.0</b></span>' +
          '<input type="range" id="kV2" min="0" max="20" step="0.5" value="5"></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">R1 (ohm) <b id="kR1L" class="eee-val">100</b></span>' +
          '<input type="range" id="kR1" min="10" max="1000" step="10" value="100"></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">R2 (ohm) <b id="kR2L" class="eee-val">200</b></span>' +
          '<input type="range" id="kR2" min="10" max="1000" step="10" value="200"></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">R3 (ohm) <b id="kR3L" class="eee-val">150</b></span>' +
          '<input type="range" id="kR3" min="10" max="1000" step="10" value="150"></div>' +
        '<p id="kReadout" class="eee-note"></p>' +
      '</div>';
  }
  function wire_kcl() {
    var ids = ['kV1', 'kV2', 'kR1', 'kR2', 'kR3'];
    for (var i = 0; i < ids.length; i++) { $(ids[i]).addEventListener('input', render_kcl); $(ids[i]).addEventListener('change', render_kcl); }
    render_kcl();
  }
  function render_kcl() {
    var V1 = parseFloat($('kV1').value), V2 = parseFloat($('kV2').value);
    var R1 = parseFloat($('kR1').value), R2 = parseFloat($('kR2').value), R3 = parseFloat($('kR3').value);
    $('kV1L').textContent = V1.toFixed(1); $('kV2L').textContent = V2.toFixed(1);
    $('kR1L').textContent = R1.toFixed(0); $('kR2L').textContent = R2.toFixed(0); $('kR3L').textContent = R3.toFixed(0);

    // Solve via MNA for rigour: nodes 1=V1 source, 2=node A, 3=V2 source.
    var els = [
      { type: 'V', a: 1, b: 0, val: V1 },
      { type: 'V', a: 3, b: 0, val: V2 },
      { type: 'R', a: 1, b: 2, val: R1 },
      { type: 'R', a: 2, b: 0, val: R2 },
      { type: 'R', a: 3, b: 2, val: R3 }
    ];
    var res = solveMNA(els);
    var Va = res.V[2] || 0;
    // branch currents (defined toward node A as positive)
    var I1 = (V1 - Va) / R1;     // through R1 into A
    var I3 = (V2 - Va) / R3;     // through R3 into A
    var I2 = (Va - 0) / R2;      // out of A through R2 to ground
    var kclResidual = I1 + I3 - I2; // should be ~0

    // KVL loop 1: V1 - I1 R1 - I2 R2 = 0
    var kvl1 = V1 - I1 * R1 - I2 * R2;
    // KVL loop 2: V2 - I3 R3 - I2 R2 = 0
    var kvl2 = V2 - I3 * R3 - I2 * R2;

    $('kReadout').textContent = 'KCL at A: I1 + I3 = I2 -> ' + (I1 * 1000).toFixed(3) + ' + ' + (I3 * 1000).toFixed(3) + ' = ' + (I2 * 1000).toFixed(3) + ' mA (residual ' + (kclResidual * 1e6).toFixed(2) + ' uA). KVL loops close to ' + Math.abs(kvl1).toFixed(4) + ' / ' + Math.abs(kvl2).toFixed(4) + ' V.';

    var s = clearStage();
    // node positions
    var A = { x: 450, y: 280 }, P1 = { x: 160, y: 160 }, P2 = { x: 450, y: 470 }, P3 = { x: 740, y: 160 };
    function wire(p, q, col) { s.appendChild(svgEl('line', { x1: p.x, y1: p.y, x2: q.x, y2: q.y, stroke: col, 'stroke-width': 2, opacity: 0.7 })); }
    wire(P1, A, '#67e8f9'); wire(P3, A, '#a78bfa'); wire(A, P2, '#fbbf24');
    function node(p, label, val, fill) {
      s.appendChild(svgEl('circle', { cx: p.x, cy: p.y, r: 26, fill: fill, stroke: '#0a0a0c', 'stroke-width': 2 }));
      s.appendChild(txt(label, p.x, p.y - 1, '#0a0a0c', 12, 'middle'));
      s.appendChild(txt(val, p.x, p.y + 42, '#e8e8ee', 11, 'middle'));
    }
    node(A, 'A', Va.toFixed(3) + ' V', '#86efac');
    node(P1, 'V1', V1.toFixed(1) + ' V', '#67e8f9');
    node(P3, 'V2', V2.toFixed(1) + ' V', '#a78bfa');
    node(P2, 'GND', '0 V', '#2a2a35');
    // current labels
    s.appendChild(txt('I1 = ' + (I1 * 1000).toFixed(2) + ' mA', 290, 215, '#67e8f9', 11, 'middle'));
    s.appendChild(txt('I3 = ' + (I3 * 1000).toFixed(2) + ' mA', 615, 215, '#a78bfa', 11, 'middle'));
    s.appendChild(txt('I2 = ' + (I2 * 1000).toFixed(2) + ' mA', 530, 390, '#fbbf24', 11, 'middle'));
    s.appendChild(txt('KCL residual at A = ' + (kclResidual * 1e6).toFixed(2) + ' uA  (~ 0)', 450, 515, '#86efac', 11, 'middle'));
    $('stageCap').textContent = 'Currents toward node A computed by MNA; Kirchhoff\'s current and voltage laws verified numerically.';

    $('bigReadout').innerHTML = '<div class="eee-bigval">' + Va.toFixed(3) + ' <span>V at node A</span></div>';
    var h = '<tr><th>Law check</th><th style="text-align:right">Value</th></tr>';
    h += '<tr><td class="nm">I1 (into A)</td><td class="vp">' + (I1 * 1000).toFixed(3) + ' mA</td></tr>';
    h += '<tr><td class="nm">I3 (into A)</td><td class="vp">' + (I3 * 1000).toFixed(3) + ' mA</td></tr>';
    h += '<tr><td class="nm">I2 (out of A)</td><td class="vp">' + (I2 * 1000).toFixed(3) + ' mA</td></tr>';
    h += '<tr><td class="nm">KCL residual</td><td class="vc">' + (kclResidual * 1e6).toFixed(2) + ' uA</td></tr>';
    h += '<tr><td class="nm">KVL loop 1</td><td class="va">' + kvl1.toFixed(4) + ' V</td></tr>';
    h += '<tr><td class="nm">KVL loop 2</td><td class="va">' + kvl2.toFixed(4) + ' V</td></tr>';
    $('resTable').innerHTML = h;
  }

  // ---- EXP 3: Nodal analysis MNA solver (preserved) ---------------
  function controls_mna() {
    return '' +
      '<div class="eee-panel">' +
        '<h3>Presets</h3>' +
        '<button class="eee-btn ghost" style="width:100%;margin-bottom:6px;text-align:left" data-mnap="divider">Voltage divider</button>' +
        '<button class="eee-btn ghost" style="width:100%;margin-bottom:6px;text-align:left" data-mnap="wheatstone">Wheatstone bridge</button>' +
        '<button class="eee-btn ghost" style="width:100%;text-align:left" data-mnap="ladder">3-node ladder</button>' +
      '</div>' +
      '<div class="eee-panel">' +
        '<h3>Netlist</h3>' +
        '<table class="eee-nl"><thead><tr><th>Elem</th><th>Type</th><th>n+</th><th>n-</th><th>Value</th><th></th></tr></thead><tbody id="nlBody"></tbody></table>' +
        '<div class="eee-add">' +
          '<select id="addType"><option value="R">Resistor (ohm)</option><option value="V">DC Voltage (V)</option><option value="I">DC Current (A)</option><option value="O">Op-amp (n+,n-,out)</option></select>' +
          '<input type="number" id="addA" value="1" title="node +" />' +
          '<input type="number" id="addB" value="0" title="node -" />' +
          '<input type="text" id="addVal" value="1000" title="value / out-node for op-amp" />' +
          '<button class="eee-btn" id="addBtn" style="padding:6px 8px;">Add</button>' +
        '</div>' +
        '<p class="eee-note">Node 0 is ground. For an op-amp put the OUTPUT node in the Value field; output is set by the virtual-short V(n+)=V(n-).</p>' +
        '<div style="display:flex;gap:6px;margin-top:10px;">' +
          '<button class="eee-btn" id="solveBtn">Solve MNA</button>' +
          '<button class="eee-btn ghost" id="clearBtn">Clear</button>' +
        '</div>' +
        '<p id="dcMsg" class="eee-note"></p>' +
      '</div>';
  }
  function wire_mna() {
    var ps = $('simControls').querySelectorAll('[data-mnap]');
    for (var i = 0; i < ps.length; i++) {
      ps[i].addEventListener('click', function () { loadMnaPreset(this.getAttribute('data-mnap')); });
    }
    $('addBtn').addEventListener('click', addElement);
    $('solveBtn').addEventListener('click', renderDC);
    $('clearBtn').addEventListener('click', function () { netlist = []; renderNetlist(); renderDC(); });
    if (netlist.length === 0) { loadMnaPreset('divider'); }
    else { renderNetlist(); renderDC(); }
  }
  function loadMnaPreset(name) {
    if (name === 'divider') {
      netlist = [
        { type: 'V', a: 1, b: 0, val: 10 },
        { type: 'R', a: 1, b: 2, val: 1000 },
        { type: 'R', a: 2, b: 0, val: 1000 }
      ];
    } else if (name === 'wheatstone') {
      netlist = [
        { type: 'V', a: 1, b: 0, val: 12 },
        { type: 'R', a: 1, b: 2, val: 1000 },
        { type: 'R', a: 2, b: 0, val: 2000 },
        { type: 'R', a: 1, b: 3, val: 1500 },
        { type: 'R', a: 3, b: 0, val: 3000 },
        { type: 'R', a: 2, b: 3, val: 500 }
      ];
    } else if (name === 'ladder') {
      netlist = [
        { type: 'V', a: 1, b: 0, val: 9 },
        { type: 'R', a: 1, b: 2, val: 1000 },
        { type: 'R', a: 2, b: 0, val: 2200 },
        { type: 'R', a: 2, b: 3, val: 1000 },
        { type: 'R', a: 3, b: 0, val: 2200 }
      ];
    }
    renderNetlist(); renderDC();
  }
  function renderNetlist() {
    var body = $('nlBody');
    if (!body) { return; }
    body.innerHTML = '';
    for (var i = 0; i < netlist.length; i++) {
      var e = netlist[i];
      var tr = document.createElement('tr');
      var valTxt = (e.type === 'O') ? ('out ' + e.out) : siVal(e.val);
      var bcell = e.b;
      tr.innerHTML = '<td>' + (e.type + (i + 1)) + '</td>' +
        '<td>' + TYPE_LABEL[e.type] + '</td>' +
        '<td>' + e.a + '</td>' +
        '<td>' + bcell + '</td>' +
        '<td>' + valTxt + '</td>' +
        '<td><span class="x" data-i="' + i + '">x</span></td>';
      body.appendChild(tr);
    }
    var xs = body.querySelectorAll('.x');
    for (var k = 0; k < xs.length; k++) {
      xs[k].addEventListener('click', function () {
        var ii = parseInt(this.getAttribute('data-i'), 10);
        netlist.splice(ii, 1);
        renderNetlist();
        renderDC();
      });
    }
  }
  function addElement() {
    var t = $('addType').value;
    var a = parseInt($('addA').value, 10) || 0;
    var b = parseInt($('addB').value, 10) || 0;
    var raw = $('addVal').value;
    if (t === 'O') {
      var out = parseInt(raw, 10) || 0;
      netlist.push({ type: 'O', a: a, b: b, out: out });
    } else {
      var v = parseFloat(raw);
      if (!isFinite(v)) { v = 0; }
      netlist.push({ type: t, a: a, b: b, val: v });
    }
    renderNetlist();
    renderDC();
  }
  function renderDC() {
    var msg = $('dcMsg');
    var s = clearStage();
    if (netlist.length === 0) {
      $('resTable').innerHTML = '';
      $('bigReadout').innerHTML = '';
      if (msg) { msg.innerHTML = ''; }
      s.appendChild(txt('Add elements or load a preset to solve.', 450, 270, '#6b7280', 14, 'middle'));
      return;
    }
    var res = solveMNA(netlist);
    if (res.error) {
      if (msg) { msg.innerHTML = '<span class="eee-err">' + res.error + '</span>'; }
      $('resTable').innerHTML = '';
      $('bigReadout').innerHTML = '';
      s.appendChild(txt(res.error, 450, 270, '#fca5a5', 13, 'middle'));
      return;
    }
    if (msg) { msg.innerHTML = '<span class="eee-ok">Solved. ' + res.nodes.length + ' unknown node(s).</span>'; }

    var allNodes = [0];
    for (var i = 0; i < res.nodes.length; i++) { allNodes.push(res.nodes[i]); }
    var cx = 450, cy = 260, rad = 185;
    var pos = {};
    var Vmin = 0, Vmax = 0;
    for (i = 0; i < allNodes.length; i++) {
      var v = res.V[allNodes[i]] || 0;
      if (v < Vmin) { Vmin = v; }
      if (v > Vmax) { Vmax = v; }
    }
    var vrange = (Vmax - Vmin) || 1;
    var nN = allNodes.length;
    for (i = 0; i < nN; i++) {
      var ang = (-Math.PI / 2) + (2 * Math.PI * i / nN);
      pos[allNodes[i]] = { x: cx + rad * Math.cos(ang), y: cy + rad * Math.sin(ang) };
    }
    for (i = 0; i < netlist.length; i++) {
      var e = netlist[i];
      var pa = pos[e.a], pb = (e.type === 'O') ? pos[e.out] : pos[e.b];
      if (!pa || !pb) { continue; }
      var col = e.type === 'R' ? '#67e8f9' : e.type === 'V' ? '#fbbf24' : e.type === 'I' ? '#86efac' : '#a78bfa';
      s.appendChild(svgEl('line', { x1: pa.x, y1: pa.y, x2: pb.x, y2: pb.y, stroke: col, 'stroke-width': 2, opacity: 0.55 }));
      var mx = (pa.x + pb.x) / 2, my = (pa.y + pb.y) / 2;
      var lbl = (e.type === 'O') ? 'OpAmp' : (TYPE_LABEL[e.type][0] + ': ' + siVal(e.val));
      s.appendChild(txt(lbl, mx, my - 4, col, 9.5, 'middle'));
    }
    for (i = 0; i < nN; i++) {
      var nd = allNodes[i];
      var p = pos[nd];
      var vv = res.V[nd] || 0;
      var frac = (vv - Vmin) / vrange;
      var r = Math.round(167 + frac * (103 - 167));
      var g = Math.round(139 + frac * (232 - 139));
      var bcol = Math.round(250 + frac * (249 - 250));
      var fillc = nd === 0 ? '#2a2a35' : 'rgb(' + r + ',' + g + ',' + bcol + ')';
      s.appendChild(svgEl('circle', { cx: p.x, cy: p.y, r: 22, fill: fillc, stroke: '#0a0a0c', 'stroke-width': 2 }));
      s.appendChild(txt(nd === 0 ? 'GND' : ('n' + nd), p.x, p.y - 1, '#0a0a0c', 11, 'middle'));
      s.appendChild(txt(fmt(vv, 2) + ' V', p.x, p.y + 36, nd === 0 ? '#6b7280' : '#e8e8ee', 10, 'middle'));
    }
    s.appendChild(txt('DC operating point — node colour scales with potential (purple low to cyan high).', cx, 510, '#6b7280', 10, 'middle'));
    $('stageCap').textContent = 'Solved DC operating point from the Modified Nodal Analysis matrix; node voltages and branch currents at right.';

    var html = '<tr><th>Node</th><th style="text-align:right">Voltage</th></tr>';
    for (i = 0; i < allNodes.length; i++) {
      var ndx = allNodes[i];
      html += '<tr><td class="nm">' + (ndx === 0 ? 'GND (0)' : ('n' + ndx)) + '</td><td class="vc">' + fmt(res.V[ndx] || 0, 4) + ' V</td></tr>';
    }
    html += '<tr><th>Branch</th><th style="text-align:right">Current</th></tr>';
    for (i = 0; i < res.branches.length; i++) {
      var br = res.branches[i];
      html += '<tr><td class="nm">' + br.name + '</td><td class="vp">' + siVal(br.current) + 'A</td></tr>';
    }
    $('resTable').innerHTML = html;

    var dissip = 0;
    for (i = 0; i < res.branches.length; i++) { if (res.branches[i].power > 0) { dissip += res.branches[i].power; } }
    $('bigReadout').innerHTML = '<div class="eee-bigval">' + siVal(dissip) + 'W <span>total dissipated</span></div>';
  }

  // ---- EXP 4: Thevenin & Norton ----------------------------------
  function controls_thev() {
    return '' +
      '<div class="eee-panel">' +
        '<h3>Source network</h3>' +
        '<p class="eee-note" style="margin-top:0">A real source: Vs behind series Rs, with a bleeder Rp across the terminals. We compute Vth, Rth, the Norton pair, then sweep a load RL to verify.</p>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">Vs (V) <b id="thVsL" class="eee-val">12.0</b></span>' +
          '<input type="range" id="thVs" min="1" max="24" step="0.5" value="12"></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">Rs (ohm) <b id="thRsL" class="eee-val">100</b></span>' +
          '<input type="range" id="thRs" min="10" max="1000" step="10" value="100"></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">Rp / bleeder (ohm) <b id="thRpL" class="eee-val">300</b></span>' +
          '<input type="range" id="thRp" min="20" max="2000" step="10" value="300"></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">Load RL for spot check (ohm) <b id="thRLL" class="eee-val">150</b></span>' +
          '<input type="range" id="thRL" min="10" max="2000" step="10" value="150"></div>' +
        '<p id="thReadout" class="eee-note"></p>' +
      '</div>';
  }
  function wire_thev() {
    var ids = ['thVs', 'thRs', 'thRp', 'thRL'];
    for (var i = 0; i < ids.length; i++) { $(ids[i]).addEventListener('input', render_thev); $(ids[i]).addEventListener('change', render_thev); }
    render_thev();
  }
  function render_thev() {
    var Vs = parseFloat($('thVs').value), Rs = parseFloat($('thRs').value), Rp = parseFloat($('thRp').value), RL = parseFloat($('thRL').value);
    $('thVsL').textContent = Vs.toFixed(1); $('thRsL').textContent = Rs.toFixed(0);
    $('thRpL').textContent = Rp.toFixed(0); $('thRLL').textContent = RL.toFixed(0);

    // Open-circuit voltage = divider of Vs across Rp: Vth = Vs * Rp/(Rs+Rp)
    var Vth = Vs * Rp / (Rs + Rp);
    // Rth = Rs || Rp (source killed)
    var Rth = (Rs * Rp) / (Rs + Rp);
    // Norton
    var In = Vth / Rth; // = Vs/Rs short-circuit current
    var Rn = Rth;

    // verify with the chosen load via the original circuit (MNA) vs Thevenin model
    var els = [
      { type: 'V', a: 1, b: 0, val: Vs },
      { type: 'R', a: 1, b: 2, val: Rs },
      { type: 'R', a: 2, b: 0, val: Rp },
      { type: 'R', a: 2, b: 0, val: RL }
    ];
    var res = solveMNA(els);
    var VL_full = res.V[2] || 0;
    var IL_full = VL_full / RL;
    // Thevenin prediction
    var VL_th = Vth * RL / (Rth + RL);
    var IL_th = Vth / (Rth + RL);
    var err = Math.abs(VL_full - VL_th);

    $('thReadout').textContent = 'Vth = Vs*Rp/(Rs+Rp) = ' + Vth.toFixed(3) + ' V, Rth = Rs||Rp = ' + Rth.toFixed(2) + ' ohm. Norton: In = Vth/Rth = ' + (In * 1000).toFixed(2) + ' mA, Rn = Rth. At RL = ' + RL.toFixed(0) + ': full circuit VL = ' + VL_full.toFixed(3) + ' V, Thevenin model VL = ' + VL_th.toFixed(3) + ' V (match, err ' + (err * 1e3).toFixed(3) + ' mV).';

    // load sweep curve
    var s = clearStage();
    var Lx = 80, Rr = 600, T = 40, B = 470;
    var W = Rr - Lx, H = B - T;
    s.appendChild(svgEl('rect', { x: Lx, y: T, width: W, height: H, fill: '#070709', stroke: '#2a2a35' }));
    var RLmax = 2000;
    var npts = 120;
    var pmax = 0;
    var pts = [];
    for (var k = 0; k <= npts; k++) {
      var rl = 5 + (RLmax - 5) * k / npts;
      var il = Vth / (Rth + rl);
      var pl = il * il * rl; // power in load
      if (pl > pmax) { pmax = pl; }
      pts.push({ rl: rl, p: pl, il: il });
    }
    function px(rl) { return Lx + (rl / RLmax) * W; }
    function py(p) { return B - (p / (pmax * 1.1)) * H; }
    // power transfer curve
    var dp = '';
    for (k = 0; k < pts.length; k++) { dp += (k === 0 ? 'M' : 'L') + px(pts[k].rl).toFixed(1) + ' ' + py(pts[k].p).toFixed(1) + ' '; }
    s.appendChild(svgEl('path', { d: dp, fill: 'none', stroke: '#67e8f9', 'stroke-width': 2.2 }));
    // max power transfer at RL = Rth
    var mx = px(Rth);
    s.appendChild(svgEl('line', { x1: mx, y1: T, x2: mx, y2: B, stroke: '#a78bfa', 'stroke-width': 1.4, 'stroke-dasharray': '4 4' }));
    s.appendChild(txt('RL = Rth (max power)', mx + 4, T + 14, '#a78bfa', 10));
    // chosen load marker
    var cx = px(RL);
    s.appendChild(svgEl('line', { x1: cx, y1: T, x2: cx, y2: B, stroke: '#fbbf24', 'stroke-width': 1.2, 'stroke-dasharray': '3 3', opacity: 0.7 }));
    s.appendChild(txt('RL=' + RL.toFixed(0), cx + 4, B - 6, '#fbbf24', 9.5));
    s.appendChild(txt('Load power P_L vs RL (Thevenin model)', Lx + 6, T + 16, '#67e8f9', 11));
    s.appendChild(txt('RL ->', Rr - 4, B + 16, '#6b7280', 10, 'end'));
    // Thevenin / Norton boxes
    var bx = 650;
    s.appendChild(svgEl('rect', { x: bx, y: 70, width: 200, height: 100, rx: 8, fill: '#11131a', stroke: '#fbbf24', 'stroke-width': 1.5 }));
    s.appendChild(txt('THEVENIN', bx + 100, 92, '#fbbf24', 11, 'middle'));
    s.appendChild(txt('Vth = ' + Vth.toFixed(3) + ' V', bx + 100, 118, '#e8e8ee', 12, 'middle'));
    s.appendChild(txt('Rth = ' + Rth.toFixed(2) + ' ohm', bx + 100, 144, '#e8e8ee', 12, 'middle'));
    s.appendChild(svgEl('rect', { x: bx, y: 200, width: 200, height: 100, rx: 8, fill: '#11131a', stroke: '#86efac', 'stroke-width': 1.5 }));
    s.appendChild(txt('NORTON', bx + 100, 222, '#86efac', 11, 'middle'));
    s.appendChild(txt('In = ' + (In * 1000).toFixed(2) + ' mA', bx + 100, 248, '#e8e8ee', 12, 'middle'));
    s.appendChild(txt('Rn = ' + Rn.toFixed(2) + ' ohm', bx + 100, 274, '#e8e8ee', 12, 'middle'));
    $('stageCap').textContent = 'Thevenin/Norton reduction plus a load-power sweep; maximum power transfer at RL = Rth is marked.';

    $('bigReadout').innerHTML = '<div class="eee-bigval">' + Vth.toFixed(3) + ' <span>V Thevenin</span></div>';
    var h = '<tr><th>Quantity</th><th style="text-align:right">Value</th></tr>';
    h += '<tr><td class="nm">Vth</td><td class="vc">' + Vth.toFixed(3) + ' V</td></tr>';
    h += '<tr><td class="nm">Rth = Rn</td><td class="vc">' + Rth.toFixed(2) + ' ohm</td></tr>';
    h += '<tr><td class="nm">In (Norton)</td><td class="vp">' + (In * 1000).toFixed(3) + ' mA</td></tr>';
    h += '<tr><td class="nm">VL full circuit</td><td class="va">' + VL_full.toFixed(3) + ' V</td></tr>';
    h += '<tr><td class="nm">VL Thevenin</td><td class="va">' + VL_th.toFixed(3) + ' V</td></tr>';
    h += '<tr><td class="nm">IL at RL</td><td class="vp">' + (IL_th * 1000).toFixed(3) + ' mA</td></tr>';
    $('resTable').innerHTML = h;
  }

  // ---- EXP 5: Transient RC/RL/RLC (preserved integrators) --------
  function controls_tran() {
    return '' +
      '<div class="eee-panel">' +
        '<h3>Transient source &amp; circuit</h3>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">Topology</span>' +
          '<select id="tTopo"><option value="rc">RC low-pass (step)</option><option value="rl">RL (step)</option><option value="rlc">Series RLC (step)</option></select></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">Step amplitude Vin (V) <b id="tVinL" class="eee-val">5.00</b></span>' +
          '<input type="range" id="tVin" min="1" max="12" step="0.5" value="5"></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">R (ohm) <b id="tRL" class="eee-val">1000</b></span>' +
          '<input type="range" id="tR" min="100" max="10000" step="50" value="1000"></div>' +
        '<div class="eee-ctrlrow" id="tCrow"><span class="eee-lbl">C (uF) <b id="tCL" class="eee-val">1.00</b></span>' +
          '<input type="range" id="tC" min="0.1" max="20" step="0.1" value="1"></div>' +
        '<div class="eee-ctrlrow" id="tLrow"><span class="eee-lbl">L (mH) <b id="tLL" class="eee-val">100</b></span>' +
          '<input type="range" id="tL" min="1" max="1000" step="1" value="100"></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">Time base (x time-const) <b id="tSpanL" class="eee-val">6</b></span>' +
          '<input type="range" id="tSpan" min="2" max="12" step="1" value="6"></div>' +
        '<p id="tReadout" class="eee-note"></p>' +
      '</div>';
  }
  function wire_tran() {
    var ids = ['tTopo', 'tVin', 'tR', 'tC', 'tL', 'tSpan'];
    for (var i = 0; i < ids.length; i++) { $(ids[i]).addEventListener('input', render_tran); $(ids[i]).addEventListener('change', render_tran); }
    render_tran();
  }
  function render_tran() {
    var topo = $('tTopo').value;
    var Vin = parseFloat($('tVin').value);
    var R = parseFloat($('tR').value);
    var C = parseFloat($('tC').value) * 1e-6;
    var L = parseFloat($('tL').value) * 1e-3;
    var spanMul = parseFloat($('tSpan').value);

    $('tVinL').textContent = Vin.toFixed(2);
    $('tRL').textContent = R.toFixed(0);
    $('tCL').textContent = (C * 1e6).toFixed(2);
    $('tLL').textContent = (L * 1e3).toFixed(0);
    $('tSpanL').textContent = spanMul.toFixed(0);
    $('tLrow').style.display = (topo === 'rlc' || topo === 'rl') ? '' : 'none';
    $('tCrow').style.display = (topo === 'rl') ? 'none' : '';

    var series = [];
    var tau, tEnd, readout;
    var dt, t, steps;

    if (topo === 'rc') {
      tau = R * C;
      tEnd = spanMul * tau;
      steps = 600;
      dt = tEnd / steps;
      var vc = 0;
      for (var k = 0; k <= steps; k++) {
        t = k * dt;
        if (k > 0) {
          var alpha = dt / (R * C);
          vc = (vc + alpha * Vin) / (1 + alpha);
        }
        var iR = (Vin - vc) / R;
        series.push({ t: t, v: vc, i: iR });
      }
      readout = 'RC step response. tau = RC = ' + siVal(tau) + 's. At t = tau the capacitor reaches 63.2% of Vin = ' + (0.632 * Vin).toFixed(3) + ' V. 5 tau settling = ' + siVal(5 * tau) + 's.';
    } else if (topo === 'rl') {
      // RL series: L di/dt = Vin - i R ; i(t) = (Vin/R)(1 - e^{-t/tau}), tau = L/R.
      tau = L / R;
      tEnd = spanMul * tau;
      steps = 600;
      dt = tEnd / steps;
      var iL0 = 0;
      var Ifinal = Vin / R;
      for (var kr = 0; kr <= steps; kr++) {
        t = kr * dt;
        if (kr > 0) {
          var beta = dt / tau; // backward Euler: i = (i + beta*Ifinal)/(1+beta)
          iL0 = (iL0 + beta * Ifinal) / (1 + beta);
        }
        var vL = Vin - iL0 * R; // voltage across inductor
        series.push({ t: t, v: vL, i: iL0 });
      }
      readout = 'RL step response. tau = L/R = ' + siVal(tau) + 's. Inductor current rises to Vin/R = ' + (Ifinal * 1000).toFixed(2) + ' mA; reaches 63.2% at t = tau. Inductor voltage (cyan) decays from Vin to 0.';
    } else {
      var wn = 1 / Math.sqrt(L * C);
      var zeta = (R / 2) * Math.sqrt(C / L);
      tau = 1 / (zeta * wn);
      tEnd = spanMul * Math.max(tau, 1 / wn);
      steps = 900;
      dt = tEnd / steps;
      var iLr = 0, vC = 0;
      for (var kk = 0; kk <= steps; kk++) {
        t = kk * dt;
        if (kk > 0) {
          var denom = 1 + (dt * R / L) + (dt * dt / (L * C));
          var inew = (iLr + (dt / L) * (Vin - vC)) / denom;
          var vcnew = vC + (dt / C) * inew;
          iLr = inew; vC = vcnew;
        }
        series.push({ t: t, v: vC, i: iLr });
      }
      var damp = zeta < 1 ? 'under-damped (oscillatory)' : (zeta > 1 ? 'over-damped' : 'critically damped');
      readout = 'Series RLC step. omega_n = ' + siVal(wn) + 'rad/s, f_n = ' + siVal(wn / (2 * Math.PI)) + 'Hz, zeta = ' + zeta.toFixed(3) + ' (' + damp + '). Envelope tau = 2L/R = ' + siVal(2 * L / R) + 's.';
    }

    $('tReadout').textContent = readout;
    drawScope(series, Vin, topo);

    var vmaxv = 0;
    for (var z = 0; z < series.length; z++) { if (Math.abs(series[z].v) > vmaxv) { vmaxv = Math.abs(series[z].v); } }
    $('bigReadout').innerHTML = '<div class="eee-bigval">' + siVal(tau) + 's <span>time constant</span></div>';
    var rh = '<tr><th>Quantity</th><th style="text-align:right">Value</th></tr>';
    rh += '<tr><td class="nm">Vin step</td><td class="vc">' + Vin.toFixed(2) + ' V</td></tr>';
    rh += '<tr><td class="nm">Peak signal</td><td class="vp">' + vmaxv.toFixed(3) + ' V</td></tr>';
    rh += '<tr><td class="nm">tau</td><td class="va">' + siVal(tau) + 's</td></tr>';
    rh += '<tr><td class="nm">Window</td><td class="va">' + siVal(series[series.length - 1].t) + 's</td></tr>';
    $('resTable').innerHTML = rh;
    $('stageCap').textContent = 'Oscilloscope traces integrated by implicit backward Euler: state variable (cyan) and branch current (amber).';
  }

  function drawScope(series, Vin, topo) {
    var s = clearStage();
    var L = 60, Rr = 870, T = 30, B = 480;
    var W = Rr - L, H = B - T;
    s.appendChild(svgEl('rect', { x: L, y: T, width: W, height: H, fill: '#070709', stroke: '#2a2a35' }));
    var gi;
    for (gi = 0; gi <= 10; gi++) {
      var gx = L + W * gi / 10;
      s.appendChild(svgEl('line', { x1: gx, y1: T, x2: gx, y2: B, stroke: '#161821', 'stroke-width': 1 }));
    }
    for (gi = 0; gi <= 8; gi++) {
      var gy = T + H * gi / 8;
      s.appendChild(svgEl('line', { x1: L, y1: gy, x2: Rr, y2: gy, stroke: '#161821', 'stroke-width': 1 }));
    }
    var n = series.length;
    var tEnd = series[n - 1].t;
    var vmax = 0, imax = 0;
    for (var i = 0; i < n; i++) {
      if (Math.abs(series[i].v) > vmax) { vmax = Math.abs(series[i].v); }
      if (Math.abs(series[i].i) > imax) { imax = Math.abs(series[i].i); }
    }
    vmax = vmax * 1.15 || 1; imax = imax * 1.15 || 1;
    function vy(v) { return B - (H / 2) - (v / vmax) * (H / 2); }
    function iy(ii) { return B - (H / 2) - (ii / imax) * (H / 2); }
    function px(t) { return L + (t / tEnd) * W; }
    s.appendChild(svgEl('line', { x1: L, y1: vy(0), x2: Rr, y2: vy(0), stroke: '#2a2a35', 'stroke-width': 1, 'stroke-dasharray': '4 4' }));

    var dv = '';
    for (i = 0; i < n; i++) { dv += (i === 0 ? 'M' : 'L') + px(series[i].t).toFixed(1) + ' ' + vy(series[i].v).toFixed(1) + ' '; }
    s.appendChild(svgEl('path', { d: dv, fill: 'none', stroke: '#67e8f9', 'stroke-width': 2 }));
    var di = '';
    for (i = 0; i < n; i++) { di += (i === 0 ? 'M' : 'L') + px(series[i].t).toFixed(1) + ' ' + iy(series[i].i).toFixed(1) + ' '; }
    s.appendChild(svgEl('path', { d: di, fill: 'none', stroke: '#fbbf24', 'stroke-width': 1.6, opacity: 0.9 }));

    var vlbl = (topo === 'rl') ? 'V_L(t)' : 'V(t)';
    s.appendChild(txt(vlbl + ' [cyan, full-scale ' + vmax.toFixed(2) + ' V]', L + 6, T + 16, '#67e8f9', 11));
    s.appendChild(txt('I(t) [amber, full-scale ' + siVal(imax) + 'A]', L + 6, T + 32, '#fbbf24', 11));
    s.appendChild(txt('t -> ' + siVal(tEnd) + 's', Rr - 4, B + 16, '#6b7280', 10, 'end'));
    s.appendChild(txt('0', L, B + 16, '#6b7280', 10, 'middle'));
  }

  // ---- EXP 6: AC steady-state & phasor diagram -------------------
  function controls_phasor() {
    return '' +
      '<div class="eee-panel">' +
        '<h3>Series RLC at one frequency</h3>' +
        '<p class="eee-note" style="margin-top:0">A sinusoidal source drives a series RLC. We compute the complex impedance and draw the phasor diagram of VR, VL, VC and the source.</p>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">Source Vm (V peak) <b id="phVmL" class="eee-val">10.0</b></span>' +
          '<input type="range" id="phVm" min="1" max="20" step="0.5" value="10"></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">Frequency f (Hz) <b id="phFL" class="eee-val">1000</b></span>' +
          '<input type="range" id="phF" min="50" max="20000" step="50" value="1000"></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">R (ohm) <b id="phRL" class="eee-val">100</b></span>' +
          '<input type="range" id="phR" min="10" max="1000" step="10" value="100"></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">L (mH) <b id="phLL" class="eee-val">10.0</b></span>' +
          '<input type="range" id="phL" min="0.5" max="100" step="0.5" value="10"></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">C (uF) <b id="phCL" class="eee-val">2.50</b></span>' +
          '<input type="range" id="phC" min="0.1" max="20" step="0.1" value="2.5"></div>' +
        '<p id="phReadout" class="eee-note"></p>' +
      '</div>';
  }
  function wire_phasor() {
    var ids = ['phVm', 'phF', 'phR', 'phL', 'phC'];
    for (var i = 0; i < ids.length; i++) { $(ids[i]).addEventListener('input', render_phasor); $(ids[i]).addEventListener('change', render_phasor); }
    render_phasor();
  }
  function render_phasor() {
    var Vm = parseFloat($('phVm').value);
    var f = parseFloat($('phF').value);
    var R = parseFloat($('phR').value);
    var L = parseFloat($('phL').value) * 1e-3;
    var C = parseFloat($('phC').value) * 1e-6;
    $('phVmL').textContent = Vm.toFixed(1); $('phFL').textContent = f.toFixed(0);
    $('phRL').textContent = R.toFixed(0); $('phLL').textContent = (L * 1e3).toFixed(1); $('phCL').textContent = (C * 1e6).toFixed(2);

    var w = 2 * Math.PI * f;
    var XL = w * L;            // inductive reactance
    var XC = 1 / (w * C);      // capacitive reactance
    var X = XL - XC;           // net reactance
    var Z = { re: R, im: X };
    var Zmag = cabs(Z);
    var phaseZ = Math.atan2(X, R); // impedance angle (rad)
    // current phasor I = V/Z, take source V along +real axis (reference)
    var Vsrc = { re: Vm, im: 0 };
    var Iph = cdiv(Vsrc, Z);
    var Imag = cabs(Iph);
    var Iangle = Math.atan2(Iph.im, Iph.re); // current angle rel. to V (negative if lagging)
    // element voltage phasors = I * Z_element
    var VR = cmul(Iph, { re: R, im: 0 });
    var VL = cmul(Iph, { re: 0, im: XL });
    var VC = cmul(Iph, { re: 0, im: -XC });
    var f0 = 1 / (2 * Math.PI * Math.sqrt(L * C));
    var pf = Math.cos(-Iangle); // power factor

    var lead = X > 0 ? 'current LAGS voltage (inductive)' : (X < 0 ? 'current LEADS voltage (capacitive)' : 'resistive — at resonance');
    $('phReadout').textContent = 'XL = wL = ' + XL.toFixed(1) + ' ohm, XC = 1/(wC) = ' + XC.toFixed(1) + ' ohm. Z = ' + R.toFixed(0) + ' + j' + X.toFixed(1) + ' ohm, |Z| = ' + Zmag.toFixed(1) + ' ohm, angle = ' + (phaseZ * 180 / Math.PI).toFixed(1) + ' deg. |I| = ' + (Imag * 1000).toFixed(2) + ' mA, ' + lead + '. PF = ' + pf.toFixed(3) + '. Resonance f0 = ' + siVal(f0) + 'Hz.';

    // phasor diagram
    var s = clearStage();
    var ox = 320, oy = 280; // origin
    var sc = 14; // px per volt
    s.appendChild(svgEl('line', { x1: ox - 220, y1: oy, x2: ox + 220, y2: oy, stroke: '#2a2a35', 'stroke-width': 1 }));
    s.appendChild(svgEl('line', { x1: ox, y1: oy - 200, x2: ox, y2: oy + 200, stroke: '#2a2a35', 'stroke-width': 1 }));
    s.appendChild(txt('Re', ox + 224, oy + 4, '#6b7280', 10));
    s.appendChild(txt('Im', ox + 6, oy - 200, '#6b7280', 10));
    function phasor(ph, col, label) {
      var ex = ox + ph.re * sc, ey = oy - ph.im * sc;
      s.appendChild(svgEl('line', { x1: ox, y1: oy, x2: ex, y2: ey, stroke: col, 'stroke-width': 2.4 }));
      // arrowhead
      var ang = Math.atan2(oy - ey, ex - ox);
      var ah = 8;
      s.appendChild(svgEl('line', { x1: ex, y1: ey, x2: ex - ah * Math.cos(ang - 0.4), y2: ey + ah * Math.sin(ang - 0.4), stroke: col, 'stroke-width': 2 }));
      s.appendChild(svgEl('line', { x1: ex, y1: ey, x2: ex - ah * Math.cos(ang + 0.4), y2: ey + ah * Math.sin(ang + 0.4), stroke: col, 'stroke-width': 2 }));
      s.appendChild(txt(label, ex + 6, ey - 4, col, 10.5));
    }
    // source voltage = VR + VL + VC (should equal Vsrc); draw component voltages
    phasor(VR, '#67e8f9', 'VR ' + cabs(VR).toFixed(1) + 'V');
    phasor(VL, '#fbbf24', 'VL ' + cabs(VL).toFixed(1) + 'V');
    phasor(VC, '#a78bfa', 'VC ' + cabs(VC).toFixed(1) + 'V');
    phasor(Vsrc, '#e8e8ee', 'Vs ' + Vm.toFixed(1) + 'V');
    // current phasor scaled to be visible (different scale)
    var iScale = 80 / (Imag || 1);
    phasor({ re: Iph.re * iScale / sc, im: Iph.im * iScale / sc }, '#86efac', 'I ' + (Imag * 1000).toFixed(1) + 'mA');
    s.appendChild(txt('Phasor diagram (voltage at ' + sc + ' px/V; current arrow not to scale)', 320, 510, '#6b7280', 10, 'middle'));

    // impedance triangle on the right
    var tx = 640, ty = 160, tsc = 110 / (Zmag || 1);
    s.appendChild(txt('Impedance triangle', tx + 20, ty - 20, '#9aa6b6', 11));
    var rEnd = { x: tx + R * tsc, y: ty };
    var zEnd = { x: tx + R * tsc, y: ty - X * tsc };
    s.appendChild(svgEl('line', { x1: tx, y1: ty, x2: rEnd.x, y2: rEnd.y, stroke: '#67e8f9', 'stroke-width': 2.4 }));
    s.appendChild(svgEl('line', { x1: rEnd.x, y1: rEnd.y, x2: zEnd.x, y2: zEnd.y, stroke: (X >= 0 ? '#fbbf24' : '#a78bfa'), 'stroke-width': 2.4 }));
    s.appendChild(svgEl('line', { x1: tx, y1: ty, x2: zEnd.x, y2: zEnd.y, stroke: '#e8e8ee', 'stroke-width': 2.4 }));
    s.appendChild(txt('R=' + R.toFixed(0), tx + R * tsc / 2, ty + 16, '#67e8f9', 10, 'middle'));
    s.appendChild(txt('X=' + X.toFixed(0), rEnd.x + 6, rEnd.y - X * tsc / 2, (X >= 0 ? '#fbbf24' : '#a78bfa'), 10));
    s.appendChild(txt('|Z|=' + Zmag.toFixed(0), tx + 4, ty - X * tsc - 8, '#e8e8ee', 10));
    $('stageCap').textContent = 'AC steady-state phasors from complex impedance: VR + VL + VC = Vs (KVL in phasor form), with the impedance triangle.';

    $('bigReadout').innerHTML = '<div class="eee-bigval">' + Zmag.toFixed(1) + ' <span>ohm |Z|</span></div>';
    var h = '<tr><th>Quantity</th><th style="text-align:right">Value</th></tr>';
    h += '<tr><td class="nm">XL = wL</td><td class="vc">' + XL.toFixed(1) + ' ohm</td></tr>';
    h += '<tr><td class="nm">XC = 1/wC</td><td class="vc">' + XC.toFixed(1) + ' ohm</td></tr>';
    h += '<tr><td class="nm">|Z|</td><td class="vp">' + Zmag.toFixed(2) + ' ohm</td></tr>';
    h += '<tr><td class="nm">Z angle</td><td class="va">' + (phaseZ * 180 / Math.PI).toFixed(1) + ' deg</td></tr>';
    h += '<tr><td class="nm">|I|</td><td class="vp">' + (Imag * 1000).toFixed(3) + ' mA</td></tr>';
    h += '<tr><td class="nm">Power factor</td><td class="va">' + pf.toFixed(3) + '</td></tr>';
    h += '<tr><td class="nm">f0 resonance</td><td class="vc">' + siVal(f0) + 'Hz</td></tr>';
    $('resTable').innerHTML = h;
  }

  // ---- EXP 7: Frequency response / Bode (preserved AC sweep) -----
  function controls_ac() {
    return '' +
      '<div class="eee-panel">' +
        '<h3>AC sweep filter</h3>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">Topology</span>' +
          '<select id="aTopo"><option value="rc">RC low-pass</option><option value="rchp">RC high-pass</option><option value="rlc">Series RLC band-pass</option></select></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">R (ohm) <b id="aRL" class="eee-val">1000</b></span>' +
          '<input type="range" id="aR" min="50" max="10000" step="50" value="1000"></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">C (uF) <b id="aCL" class="eee-val">0.10</b></span>' +
          '<input type="range" id="aC" min="0.01" max="10" step="0.01" value="0.1"></div>' +
        '<div class="eee-ctrlrow" id="aLrow"><span class="eee-lbl">L (mH) <b id="aLL" class="eee-val">10</b></span>' +
          '<input type="range" id="aL" min="0.1" max="500" step="0.1" value="10"></div>' +
        '<p id="aReadout" class="eee-note"></p>' +
      '</div>';
  }
  function wire_ac() {
    var ids = ['aTopo', 'aR', 'aC', 'aL'];
    for (var i = 0; i < ids.length; i++) { $(ids[i]).addEventListener('input', render_ac); $(ids[i]).addEventListener('change', render_ac); }
    render_ac();
  }
  function render_ac() {
    var topo = $('aTopo').value;
    var R = parseFloat($('aR').value);
    var C = parseFloat($('aC').value) * 1e-6;
    var L = parseFloat($('aL').value) * 1e-3;
    $('aRL').textContent = R.toFixed(0);
    $('aCL').textContent = (C * 1e6).toFixed(2);
    $('aLL').textContent = (L * 1e3).toFixed(1);
    $('aLrow').style.display = (topo === 'rlc') ? '' : 'none';

    var fStart = 1, fStop = 1e6;
    var npts = 400;
    var data = [];
    var fc, readout;

    for (var k = 0; k <= npts; k++) {
      var f = fStart * Math.pow(fStop / fStart, k / npts);
      var w = 2 * Math.PI * f;
      var H;
      if (topo === 'rc') {
        var den = { re: 1, im: w * R * C };
        H = cdiv({ re: 1, im: 0 }, den);
      } else if (topo === 'rchp') {
        var num = { re: 0, im: w * R * C };
        var den2 = { re: 1, im: w * R * C };
        H = cdiv(num, den2);
      } else {
        var zReact = w * L - 1 / (w * C);
        var zTot = { re: R, im: zReact };
        H = cdiv({ re: R, im: 0 }, zTot);
      }
      var mag = cabs(H);
      var dB = 20 * Math.log10(mag <= 0 ? 1e-12 : mag);
      data.push({ f: f, mag: mag, dB: dB });
    }

    if (topo === 'rc' || topo === 'rchp') {
      fc = 1 / (2 * Math.PI * R * C);
      readout = (topo === 'rc' ? 'RC low-pass.' : 'RC high-pass.') + ' Cutoff f_c = 1/(2 pi R C) = ' + siVal(fc) + 'Hz, where |H| = 0.707 (-3 dB). Roll-off 20 dB/decade.';
    } else {
      fc = 1 / (2 * Math.PI * Math.sqrt(L * C));
      var Q = (1 / R) * Math.sqrt(L / C);
      readout = 'Series RLC band-pass. Resonance f_0 = 1/(2 pi sqrt(LC)) = ' + siVal(fc) + 'Hz, Q = ' + Q.toFixed(2) + '. Peak gain 0 dB at f_0.';
    }
    $('aReadout').textContent = readout;
    drawBode(data, fStart, fStop, fc, topo);

    $('bigReadout').innerHTML = '<div class="eee-bigval">' + siVal(fc) + 'Hz <span>' + ((topo === 'rlc') ? 'resonance f0' : '-3 dB cutoff') + '</span></div>';
    var rh = '<tr><th>Quantity</th><th style="text-align:right">Value</th></tr>';
    rh += '<tr><td class="nm">f (corner/res)</td><td class="vc">' + siVal(fc) + 'Hz</td></tr>';
    var nearest = data[0];
    for (var z = 0; z < data.length; z++) { if (Math.abs(data[z].f - fc) < Math.abs(nearest.f - fc)) { nearest = data[z]; } }
    rh += '<tr><td class="nm">|H| at corner</td><td class="vp">' + nearest.dB.toFixed(2) + ' dB</td></tr>';
    rh += '<tr><td class="nm">DC gain</td><td class="va">' + data[0].dB.toFixed(2) + ' dB</td></tr>';
    rh += '<tr><td class="nm">HF gain</td><td class="va">' + data[data.length - 1].dB.toFixed(2) + ' dB</td></tr>';
    $('resTable').innerHTML = rh;
    $('stageCap').textContent = 'Bode magnitude from complex impedance division. Dashed line marks the -3 dB corner / resonance.';
  }

  function drawBode(data, fStart, fStop, fc, topo) {
    var s = clearStage();
    var L = 64, Rr = 870, T = 30, B = 470;
    var W = Rr - L, H = B - T;
    var dBmax = 6, dBmin = -60;
    s.appendChild(svgEl('rect', { x: L, y: T, width: W, height: H, fill: '#070709', stroke: '#2a2a35' }));
    var decades = Math.log10(fStop / fStart);
    var d;
    for (d = 0; d <= decades; d++) {
      var gx = L + W * d / decades;
      s.appendChild(svgEl('line', { x1: gx, y1: T, x2: gx, y2: B, stroke: '#161821', 'stroke-width': 1 }));
      var fv = fStart * Math.pow(10, d);
      s.appendChild(txt(siVal(fv) + 'Hz', gx, B + 16, '#6b7280', 9.5, 'middle'));
    }
    var ng = 6;
    for (var gi = 0; gi <= ng; gi++) {
      var dbv = dBmax + (dBmin - dBmax) * gi / ng;
      var gy = T + H * gi / ng;
      s.appendChild(svgEl('line', { x1: L, y1: gy, x2: Rr, y2: gy, stroke: '#161821', 'stroke-width': 1 }));
      s.appendChild(txt(dbv.toFixed(0) + ' dB', L - 6, gy + 3, '#6b7280', 9.5, 'end'));
    }
    function px(f) { return L + (Math.log10(f / fStart) / decades) * W; }
    function py(db) { var c = (db - dBmax) / (dBmin - dBmax); if (c < 0) { c = 0; } if (c > 1) { c = 1; } return T + c * H; }

    s.appendChild(svgEl('line', { x1: L, y1: py(-3), x2: Rr, y2: py(-3), stroke: '#fca5a5', 'stroke-width': 1, 'stroke-dasharray': '5 4', opacity: 0.6 }));
    s.appendChild(txt('-3 dB', Rr - 4, py(-3) - 4, '#fca5a5', 9.5, 'end'));

    var fcx = px(fc);
    s.appendChild(svgEl('line', { x1: fcx, y1: T, x2: fcx, y2: B, stroke: '#a78bfa', 'stroke-width': 1.4, 'stroke-dasharray': '4 4' }));
    s.appendChild(txt((topo === 'rlc' ? 'f0=' : 'fc=') + siVal(fc) + 'Hz', fcx + 4, T + 14, '#a78bfa', 10));

    var dpath = '';
    for (var i = 0; i < data.length; i++) {
      dpath += (i === 0 ? 'M' : 'L') + px(data[i].f).toFixed(1) + ' ' + py(data[i].dB).toFixed(1) + ' ';
    }
    s.appendChild(svgEl('path', { d: dpath, fill: 'none', stroke: '#67e8f9', 'stroke-width': 2.2 }));
    s.appendChild(txt('|H(f)| magnitude (dB) vs log frequency', L + 8, T + 16, '#67e8f9', 11));
  }

  // ---- EXP 8: Op-amp circuits (preserved presets + integrator) ---
  function controls_op() {
    return '' +
      '<div class="eee-panel">' +
        '<h3>Op-amp configuration</h3>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">Circuit</span>' +
          '<select id="opMode"><option value="inv">Inverting (gain = -Rf/Rin)</option><option value="noninv">Non-inverting (gain = 1+Rf/Rg)</option><option value="integ">Integrator (Vout = -1/RC integral Vin)</option></select></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">Vin (V) <b id="opVinL" class="eee-val">1.00</b></span>' +
          '<input type="range" id="opVin" min="-3" max="3" step="0.1" value="1"></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">Rin / Rg (ohm) <b id="opRinL" class="eee-val">1000</b></span>' +
          '<input type="range" id="opRin" min="100" max="10000" step="100" value="1000"></div>' +
        '<div class="eee-ctrlrow"><span class="eee-lbl">Rf (ohm) <b id="opRfL" class="eee-val">10000</b></span>' +
          '<input type="range" id="opRf" min="100" max="100000" step="100" value="10000"></div>' +
        '<div class="eee-ctrlrow" id="opCrow"><span class="eee-lbl">C feedback (uF) <b id="opCL" class="eee-val">1.00</b></span>' +
          '<input type="range" id="opC" min="0.1" max="10" step="0.1" value="1"></div>' +
        '<p id="opReadout" class="eee-note"></p>' +
      '</div>';
  }
  function wire_op() {
    var ids = ['opMode', 'opVin', 'opRin', 'opRf', 'opC'];
    for (var i = 0; i < ids.length; i++) { $(ids[i]).addEventListener('input', render_op); $(ids[i]).addEventListener('change', render_op); }
    render_op();
  }
  function render_op() {
    var mode = $('opMode').value;
    var Vin = parseFloat($('opVin').value);
    var Rin = parseFloat($('opRin').value), Rf = parseFloat($('opRf').value), C = parseFloat($('opC').value) * 1e-6;
    $('opVinL').textContent = Vin.toFixed(2); $('opRinL').textContent = Rin.toFixed(0);
    $('opRfL').textContent = Rf.toFixed(0); $('opCL').textContent = (C * 1e6).toFixed(2);
    $('opCrow').style.display = (mode === 'integ') ? '' : 'none';

    if (mode === 'inv' || mode === 'noninv') {
      // use the preserved MNA op-amp solver to get the operating point
      var els;
      if (mode === 'inv') {
        els = [
          { type: 'V', a: 1, b: 0, val: Vin },
          { type: 'R', a: 1, b: 2, val: Rin },
          { type: 'R', a: 2, b: 3, val: Rf },
          { type: 'O', a: 0, b: 2, out: 3 }
        ];
      } else {
        els = [
          { type: 'V', a: 1, b: 0, val: Vin },
          { type: 'R', a: 2, b: 0, val: Rin },
          { type: 'R', a: 2, b: 3, val: Rf },
          { type: 'O', a: 1, b: 2, out: 3 }
        ];
      }
      var res = solveMNA(els);
      var Vout = res.V[3] || 0;
      var gain = mode === 'inv' ? (-Rf / Rin) : (1 + Rf / Rin);
      $('opReadout').textContent = (mode === 'inv' ? 'Inverting amplifier. Virtual ground at the - input.' : 'Non-inverting amplifier. Virtual short forces V- = Vin.') + ' Gain = ' + gain.toFixed(2) + ', Vout = gain*Vin = ' + Vout.toFixed(3) + ' V (MNA-solved).';
      drawOpStatic(mode, Vin, Vout, gain, Rin, Rf);

      $('bigReadout').innerHTML = '<div class="eee-bigval">' + Vout.toFixed(3) + ' <span>V out</span></div>';
      var h = '<tr><th>Quantity</th><th style="text-align:right">Value</th></tr>';
      h += '<tr><td class="nm">Vin</td><td class="vc">' + Vin.toFixed(3) + ' V</td></tr>';
      h += '<tr><td class="nm">Closed-loop gain</td><td class="vp">' + gain.toFixed(3) + '</td></tr>';
      h += '<tr><td class="nm">Vout</td><td class="va">' + Vout.toFixed(3) + ' V</td></tr>';
      h += '<tr><td class="nm">V- (node 2)</td><td class="vc">' + (res.V[2] || 0).toFixed(4) + ' V</td></tr>';
      $('resTable').innerHTML = h;
      $('stageCap').textContent = 'Ideal op-amp operating point from the MNA virtual-short constraint V(n+) = V(n-).';
    } else {
      // Integrator: feed Vin(t) (a square wave) and integrate. Vout = -1/(RC) integral Vin dt.
      var RC = Rin * C;
      var period = 4 * RC; // a few RC per half period
      var tEnd = 4 * period;
      var steps = 800, dt = tEnd / steps;
      var series = [];
      var vout = 0;
      for (var k = 0; k <= steps; k++) {
        var t = k * dt;
        var vinT = (Math.floor(t / (period / 2)) % 2 === 0) ? Vin : -Vin; // square wave +/-Vin
        if (k > 0) { vout += -(1 / RC) * vinT * dt; } // ideal integrator update
        // clamp to a plausible rail
        if (vout > 12) { vout = 12; } if (vout < -12) { vout = -12; }
        series.push({ t: t, vin: vinT, vout: vout });
      }
      var slope = -Vin / RC; // ramp slope during +Vin half (V/s)
      $('opReadout').textContent = 'Integrator with R = ' + Rin.toFixed(0) + ' ohm, C = ' + (C * 1e6).toFixed(2) + ' uF -> RC = ' + siVal(RC) + 's. A +/-' + Math.abs(Vin).toFixed(1) + ' V square wave integrates into a triangle: ramp slope = -Vin/RC = ' + slope.toFixed(1) + ' V/s. Vout = -(1/RC) integral Vin dt.';
      drawIntegrator(series);

      var vpk = 0;
      for (var z = 0; z < series.length; z++) { if (Math.abs(series[z].vout) > vpk) { vpk = Math.abs(series[z].vout); } }
      $('bigReadout').innerHTML = '<div class="eee-bigval">' + siVal(RC) + 's <span>RC time constant</span></div>';
      var hh = '<tr><th>Quantity</th><th style="text-align:right">Value</th></tr>';
      hh += '<tr><td class="nm">RC</td><td class="vc">' + siVal(RC) + 's</td></tr>';
      hh += '<tr><td class="nm">Ramp slope</td><td class="vp">' + slope.toFixed(1) + ' V/s</td></tr>';
      hh += '<tr><td class="nm">Vout peak</td><td class="va">' + vpk.toFixed(3) + ' V</td></tr>';
      $('resTable').innerHTML = hh;
      $('stageCap').textContent = 'Inverting integrator: a square wave (amber) integrates into a triangle (cyan); slope set by 1/RC.';
    }
  }
  function drawOpStatic(mode, Vin, Vout, gain, Rin, Rf) {
    var s = clearStage();
    // triangle op-amp symbol
    var tx = 420, ty = 270;
    s.appendChild(svgEl('polygon', { points: tx + ',' + (ty - 60) + ' ' + tx + ',' + (ty + 60) + ' ' + (tx + 120) + ',' + ty, fill: '#11131a', stroke: '#a78bfa', 'stroke-width': 2 }));
    s.appendChild(txt('-', tx + 14, ty - 26, '#e8e8ee', 16));
    s.appendChild(txt('+', tx + 14, ty + 34, '#e8e8ee', 16));
    // input
    s.appendChild(svgEl('line', { x1: 120, y1: ty - 30, x2: tx, y2: ty - 30, stroke: '#9aa6b6', 'stroke-width': 2 }));
    s.appendChild(txt('Vin = ' + Vin.toFixed(2) + ' V', 120, ty - 42, '#67e8f9', 12));
    // feedback
    s.appendChild(svgEl('line', { x1: tx + 120, y1: ty, x2: tx + 200, y2: ty, stroke: '#9aa6b6', 'stroke-width': 2 }));
    s.appendChild(svgEl('rect', { x: tx - 20, y: ty - 130, width: 160, height: 26, rx: 5, fill: '#11131a', stroke: '#fbbf24', 'stroke-width': 1.5 }));
    s.appendChild(txt('Rf = ' + siVal(Rf) + 'ohm', tx + 60, ty - 112, '#fbbf24', 11, 'middle'));
    s.appendChild(svgEl('rect', { x: 200, y: ty - 44, width: 130, height: 26, rx: 5, fill: '#11131a', stroke: '#67e8f9', 'stroke-width': 1.5 }));
    s.appendChild(txt((mode === 'inv' ? 'Rin = ' : 'Rg = ') + siVal(Rin) + 'ohm', 265, ty - 26, '#67e8f9', 11, 'middle'));
    // output
    s.appendChild(svgEl('circle', { cx: tx + 200, cy: ty, r: 6, fill: '#86efac' }));
    s.appendChild(txt('Vout = ' + Vout.toFixed(3) + ' V', tx + 210, ty + 4, '#86efac', 13));
    s.appendChild(txt('Closed-loop gain = ' + gain.toFixed(2), 450, 470, '#a78bfa', 13, 'middle'));
    s.appendChild(txt('Ideal op-amp: infinite open-loop gain, virtual short V+ = V-', 450, 500, '#6b7280', 10, 'middle'));
  }
  function drawIntegrator(series) {
    var s = clearStage();
    var L = 60, Rr = 870, T = 30, B = 480;
    var W = Rr - L, H = B - T;
    s.appendChild(svgEl('rect', { x: L, y: T, width: W, height: H, fill: '#070709', stroke: '#2a2a35' }));
    for (var gi = 0; gi <= 8; gi++) { var gy = T + H * gi / 8; s.appendChild(svgEl('line', { x1: L, y1: gy, x2: Rr, y2: gy, stroke: '#161821', 'stroke-width': 1 })); }
    var n = series.length;
    var tEnd = series[n - 1].t;
    var vmax = 0;
    for (var i = 0; i < n; i++) { if (Math.abs(series[i].vin) > vmax) { vmax = Math.abs(series[i].vin); } if (Math.abs(series[i].vout) > vmax) { vmax = Math.abs(series[i].vout); } }
    vmax = vmax * 1.15 || 1;
    function vy(v) { return B - (H / 2) - (v / vmax) * (H / 2); }
    function px(t) { return L + (t / tEnd) * W; }
    s.appendChild(svgEl('line', { x1: L, y1: vy(0), x2: Rr, y2: vy(0), stroke: '#2a2a35', 'stroke-width': 1, 'stroke-dasharray': '4 4' }));
    var din = '';
    for (i = 0; i < n; i++) { din += (i === 0 ? 'M' : 'L') + px(series[i].t).toFixed(1) + ' ' + vy(series[i].vin).toFixed(1) + ' '; }
    s.appendChild(svgEl('path', { d: din, fill: 'none', stroke: '#fbbf24', 'stroke-width': 1.6, opacity: 0.9 }));
    var dout = '';
    for (i = 0; i < n; i++) { dout += (i === 0 ? 'M' : 'L') + px(series[i].t).toFixed(1) + ' ' + vy(series[i].vout).toFixed(1) + ' '; }
    s.appendChild(svgEl('path', { d: dout, fill: 'none', stroke: '#67e8f9', 'stroke-width': 2.2 }));
    s.appendChild(txt('Vin square wave [amber]', L + 6, T + 16, '#fbbf24', 11));
    s.appendChild(txt('Vout triangle = integral [cyan, full-scale ' + vmax.toFixed(1) + ' V]', L + 6, T + 32, '#67e8f9', 11));
    s.appendChild(txt('t -> ' + siVal(tEnd) + 's', Rr - 4, B + 16, '#6b7280', 10, 'end'));
  }

  // ==================================================================
  // PART 5 — EXPERIMENT DEFINITIONS (content + sim wiring)
  // ==================================================================
  var EXPS = [
    {
      title: 'Ohm’s law & series/parallel resistors',
      sub: 'Compute equivalent resistance, current and voltage division',
