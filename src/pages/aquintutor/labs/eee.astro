    var qx = px(qVce), qy = py(qIc);
    s.appendChild(svgEl('circle', { cx: qx, cy: qy, r: 6, fill: '#fff', stroke: '#f87171', 'stroke-width': 2 }));
    s.appendChild(svgEl('line', { x1: qx, y1: qy, x2: qx, y2: B, stroke: '#fff', 'stroke-width': 0.8, 'stroke-dasharray': '2 3', opacity: 0.5 }));
