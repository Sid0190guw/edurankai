---
import BaseLayout from '@/layouts/BaseLayout.astro';
// CAD Workbench (Aerospace) — parametric part design in the browser, hand-
// rolled per the labs philosophy (no third-party library). Real engineering
// content: NACA 4-digit airfoil equations, surface-of-revolution nozzles,
// Pappus-theorem mass properties, material densities, section view, vertex
// measurement, and ASCII STL export that opens in any real CAD package.
---
<BaseLayout title="CAD Workbench · Virtual Labs · AquinTutor" description="Parametric aerospace CAD in the browser: NACA wing ribs, bell nozzles, fuselage frames. Mass properties, section view, measurement, STL export. Hand-rolled 3D, no libraries.">

<style is:global>
  body { background:#08080a; color:#e8e8ee; margin:0; }
  .era-fab { display:none !important; }
  .cb-wrap { display:grid; grid-template-rows:52px 1fr; height:100vh; height:100dvh; }
  .cb-bar { background:#11131a; border-bottom:1px solid #2a2a35; display:flex; align-items:center; padding:0 14px; gap:12px; font-family:'Geist Mono',monospace; font-size:11px; color:#cfd6da; }
  .cb-bar a { color:#FF9066; text-decoration:none; }
  .cb-title { font-family:'Cormorant Garamond',Georgia,serif; font-size:17px; color:#fff; font-weight:600; }
  .cb-title em { color:#FF7040; font-style:italic; }
  .cb-bar-right { margin-left:auto; display:flex; gap:6px; flex-wrap:wrap; }
  .cb-btn { background:transparent; border:1px solid #2a2a35; color:#cfd6da; padding:6px 11px; border-radius:6px; cursor:pointer; font-family:inherit; font-size:10.5px; letter-spacing:0.05em; text-transform:uppercase; font-weight:700; }
  .cb-btn:hover { background:#1a1a25; }
  .cb-btn.on { background:#FF4F00; color:#fff; border-color:#FF4F00; }
  .cb-main { display:grid; grid-template-columns:250px 1fr 260px; overflow:hidden; }
  @media (max-width:900px){ .cb-main { grid-template-columns:1fr; grid-template-rows:auto 1fr auto; } .cb-tree,.cb-props { max-height:32vh; overflow-y:auto; } }
  .cb-tree { background:#0c0e14; border-right:1px solid #2a2a35; overflow-y:auto; padding:12px; }
  .cb-cat { font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.18em; text-transform:uppercase; color:#FF9066; font-weight:700; margin:6px 0; }
  .cb-part { padding:8px 10px; cursor:pointer; font-size:12.5px; color:#cfd6da; border-left:3px solid transparent; border-radius:0 6px 6px 0; }
  .cb-part:hover { background:#11131a; }
  .cb-part.on { border-left-color:#FF4F00; color:#fff; background:#151018; }
  .cb-param { margin:10px 0 2px; }
  .cb-param label { display:flex; justify-content:space-between; font-family:'Geist Mono',monospace; font-size:10px; color:#9aa; letter-spacing:0.04em; margin-bottom:3px; }
  .cb-param label b { color:#d9f9e8; }
  .cb-param input[type=range] { width:100%; accent-color:#FF4F00; }
  .cb-view { position:relative; overflow:hidden; }
  #cbCanvas { position:absolute; inset:0; width:100%; height:100%; display:block; touch-action:none; cursor:grab; }
  .cb-props { background:#0c0e14; border-left:1px solid #2a2a35; overflow-y:auto; padding:14px; font-family:'Geist Mono',monospace; font-size:11px; color:#cfd6da; line-height:2; }
  .cb-props h3 { font-family:'Cormorant Garamond',Georgia,serif; font-size:15px; color:#fff; margin:0 0 6px; font-weight:600; }
  .cb-props b { color:#d9f9e8; float:right; }
  .cb-props select { width:100%; background:#11131a; color:#e8e8ee; border:1px solid #2a2a35; border-radius:6px; padding:6px 8px; font-family:inherit; font-size:11px; margin-bottom:8px; }
  .cb-note { font-size:10px; color:#788; line-height:1.7; border-top:1px solid #2a2a35; margin-top:10px; padding-top:10px; }
  .cb-hint { position:absolute; left:12px; bottom:10px; font-family:'Geist Mono',monospace; font-size:10px; color:#89a; pointer-events:none; text-shadow:0 1px 2px #000; }
  .cb-measure { position:absolute; left:12px; top:10px; font-family:'Geist Mono',monospace; font-size:11.5px; color:#fde68a; pointer-events:none; text-shadow:0 1px 3px #000; line-height:1.8; }
</style>

<div class="cb-wrap">
  <div class="cb-bar">
    <a href="/aquintutor/labs">&larr; LABS</a>
    <span class="cb-title">CAD <em>Workbench</em></span>
    <span style="opacity:0.55;">AEROSPACE · PARAMETRIC</span>
    <div class="cb-bar-right">
      <button type="button" class="cb-btn on" id="bShade">Shaded</button>
      <button type="button" class="cb-btn" id="bWire">Wireframe</button>
      <button type="button" class="cb-btn" id="bSect">Section</button>
      <button type="button" class="cb-btn" id="bMeas">Measure</button>
      <button type="button" class="cb-btn" id="bStl">Export STL</button>
      <button type="button" class="cb-btn" id="bFit">Fit view</button>
    </div>
  </div>
  <div class="cb-main">
    <div class="cb-tree" id="cbTree">
      <div class="cb-cat">Part library</div>
      <div class="cb-part on" data-part="rib">NACA wing rib</div>
      <div class="cb-part" data-part="nozzle">Bell nozzle</div>
      <div class="cb-part" data-part="frame">Fuselage frame</div>
      <div class="cb-cat" style="margin-top:14px;">Parameters</div>
      <div id="cbParams"></div>
    </div>
    <div class="cb-view">
      <canvas id="cbCanvas"></canvas>
      <div class="cb-measure" id="cbMeasure"></div>
      <div class="cb-hint">drag: rotate &middot; wheel / pinch: zoom &middot; shift-drag: pan &middot; measure: click two vertices</div>
    </div>
    <div class="cb-props">
      <h3>Mass properties</h3>
      <select id="cbMat">
        <option value="2810">Aluminium 7075-T6 (2810 kg/m3)</option>
        <option value="2700">Aluminium 6061 (2700 kg/m3)</option>
        <option value="4430">Titanium Ti-6Al-4V (4430 kg/m3)</option>
        <option value="1600">Carbon fibre laminate (1600 kg/m3)</option>
        <option value="7850">Steel 4130 (7850 kg/m3)</option>
      </select>
      <div>Volume <b id="pVol">-</b></div>
      <div>Mass <b id="pMass">-</b></div>
      <div>Surface <b id="pSurf">-</b></div>
      <div>Bounding box <b id="pBox">-</b></div>
      <div>Triangles <b id="pTris">-</b></div>
      <div class="cb-note" id="cbNote"></div>
    </div>
  </div>
</div>

<script is:inline>
(function(){
  'use strict';
  var cv = document.getElementById('cbCanvas'), ctx = cv.getContext('2d');
  var W = 0, H = 0, DPR = Math.min(2, window.devicePixelRatio || 1);
  function resize(){ W = cv.clientWidth; H = cv.clientHeight; cv.width = W*DPR; cv.height = H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); draw(); }
  window.addEventListener('resize', resize);

  function v3(x,y,z){ return {x:x,y:y,z:z}; }
  function sub(a,b){ return v3(a.x-b.x,a.y-b.y,a.z-b.z); }
  function add(a,b){ return v3(a.x+b.x,a.y+b.y,a.z+b.z); }
  function mul(a,s){ return v3(a.x*s,a.y*s,a.z*s); }
  function dot(a,b){ return a.x*b.x+a.y*b.y+a.z*b.z; }
  function cross(a,b){ return v3(a.y*b.z-a.z*b.y, a.z*b.x-a.x*b.z, a.x*b.y-a.y*b.x); }
  function len(a){ return Math.sqrt(dot(a,a)); }
  function norm(a){ var l=len(a)||1; return mul(a,1/l); }

  // ================= PART GENERATORS (all dimensions in mm) =================
  // Each returns { tris:[[a,b,c],...], props:{vol_mm3, surf_mm2}, note }
  function fanCap(outline, z, flip){
    var c = v3(0,0,z), n = outline.length, tris = [];
    var cx=0, cy=0; for (var i=0;i<n;i++){ cx+=outline[i].x; cy+=outline[i].y; }
    c = v3(cx/n, cy/n, z);
    for (var i=0;i<n;i++){
      var a = v3(outline[i].x, outline[i].y, z), b = v3(outline[(i+1)%n].x, outline[(i+1)%n].y, z);
      tris.push(flip ? [c,b,a] : [c,a,b]);
    }
    return tris;
  }
  function shoelace(pts){ var a=0; for (var i=0;i<pts.length;i++){ var p=pts[i], q=pts[(i+1)%pts.length]; a += p.x*q.y - q.x*p.y; } return Math.abs(a)/2; }
  function perimeter(pts){ var s=0; for (var i=0;i<pts.length;i++){ var p=pts[i], q=pts[(i+1)%pts.length]; s += Math.hypot(q.x-p.x, q.y-p.y); } return s; }

  // NACA 4-digit airfoil rib: the real equations.
  function genRib(P){
    var chord = P.chord, m = P.camber/100, p = P.camberPos/10, t = P.thick/100, span = P.width;
    var N = 48, up = [], lo = [];
    for (var i=0;i<=N;i++){
      var x = i/N, xr = 0.5*(1-Math.cos(Math.PI*x)); // cosine spacing (real CAD practice)
      var yt = 5*t*(0.2969*Math.sqrt(xr) - 0.1260*xr - 0.3516*xr*xr + 0.2843*xr*xr*xr - 0.1036*xr*xr*xr*xr);
      var yc = xr < p ? (m/(p*p))*(2*p*xr - xr*xr) : (m/((1-p)*(1-p)))*((1-2*p) + 2*p*xr - xr*xr);
      var th = Math.atan(xr < p ? (2*m/(p*p))*(p-xr) : (2*m/((1-p)*(1-p)))*(p-xr));
      up.push({ x:(xr - yt*Math.sin(th))*chord, y:(yc + yt*Math.cos(th))*chord });
      lo.push({ x:(xr + yt*Math.sin(th))*chord, y:(yc - yt*Math.cos(th))*chord });
    }
    var outline = up.slice().reverse().concat(lo.slice(1, N)); // TE -> upper -> LE -> lower -> TE
    var tris = [];
    var z0 = -span/2, z1 = span/2, n = outline.length;
    for (var i=0;i<n;i++){
      var a = outline[i], b = outline[(i+1)%n];
      var A0 = v3(a.x,a.y,z0), B0 = v3(b.x,b.y,z0), A1 = v3(a.x,a.y,z1), B1 = v3(b.x,b.y,z1);
      tris.push([A0,B0,B1],[A0,B1,A1]);
    }
    tris = tris.concat(fanCap(outline, z0, true), fanCap(outline, z1, false));
    // spar lightening holes: visual bores + exact area subtraction
    var holes = Math.round(P.holes), holeA = 0, rH = chord*0.055;
    for (var h=0; h<holes; h++){
      var hx = chord*(0.22 + 0.55*h/Math.max(1,holes-1)), hy = 0;
      holeA += Math.PI*rH*rH;
      var SEG = 18;
      for (var s2=0;s2<SEG;s2++){
        var a1 = s2/SEG*2*Math.PI, a2 = (s2+1)/SEG*2*Math.PI;
        var p1 = v3(hx+rH*Math.cos(a1), hy+rH*Math.sin(a1), z0), p2 = v3(hx+rH*Math.cos(a2), hy+rH*Math.sin(a2), z0);
        var p3 = v3(p2.x,p2.y,z1), p4 = v3(p1.x,p1.y,z1);
        tris.push([p1,p2,p3],[p1,p3,p4]);
      }
    }
    var area = shoelace(outline) - holeA;
    return { tris:tris, props:{ vol: area*span, surf: 2*shoelace(outline) + perimeter(outline)*span + holes*2*Math.PI*rH*span },
      note:'NACA ' + Math.round(P.camber) + Math.round(P.camberPos) + (P.thick<10?'0':'') + Math.round(P.thick)
        + ' section, cosine-spaced sampling. Rib area by the shoelace formula minus lightening holes; extruded volume = area x span. These are the exact 4-digit series equations used in real aerodynamic design.' };
  }

  // Bell nozzle: profile revolved about the axis (surface of revolution).
  function genNozzle(P){
    var Rt = P.throat, Re = P.exit, Rc = P.inlet, L = P.length, t = P.wall;
    var prof = [], NP = 34;
    for (var i=0;i<=NP;i++){
      var u = i/NP, z = u*L, r;
      if (u < 0.28){ var q = u/0.28; r = Rc + (Rt-Rc)*(q*q*(3-2*q)); }               // converging
      else { var q2 = (u-0.28)/0.72; r = Rt + (Re-Rt)*(1.5*q2 - 0.5*q2*q2*q2); }     // 80% bell approx
      prof.push({ z:z, r:r });
    }
    var SEG = 40, tris = [], volume = 0, surf = 0;
    function ring(zr, R){ var pts=[]; for (var s2=0;s2<SEG;s2++){ var a=s2/SEG*2*Math.PI; pts.push(v3(R*Math.cos(a), R*Math.sin(a), zr)); } return pts; }
    var prevO = ring(prof[0].z, prof[0].r + t), prevI = ring(prof[0].z, prof[0].r);
    for (var i=1;i<prof.length;i++){
      var dz = prof[i].z - prof[i-1].z, r0 = prof[i-1].r, r1 = prof[i].r;
      volume += Math.PI*dz/3*(((r0+t)*(r0+t)+(r0+t)*(r1+t)+(r1+t)*(r1+t)) - (r0*r0+r0*r1+r1*r1)); // frustum shells
      surf += Math.PI*(r0+r1+t)*Math.hypot(dz, r1-r0)*2;
      var curO = ring(prof[i].z, r1 + t), curI = ring(prof[i].z, r1);
      for (var s2=0;s2<SEG;s2++){
        var s3 = (s2+1)%SEG;
        tris.push([prevO[s2],prevO[s3],curO[s3]],[prevO[s2],curO[s3],curO[s2]]);   // outer wall
        tris.push([prevI[s3],prevI[s2],curI[s2]],[prevI[s3],curI[s2],curI[s3]]);   // inner wall
      }
      prevO = curO; prevI = curI;
    }
    // exit lip + inlet lip
    var lipO = ring(L, prof[NP].r + t), lipI = ring(L, prof[NP].r);
    var inO = ring(0, prof[0].r + t), inI = ring(0, prof[0].r);
    for (var s2=0;s2<SEG;s2++){
      var s3 = (s2+1)%SEG;
      tris.push([lipI[s2],lipI[s3],lipO[s3]],[lipI[s2],lipO[s3],lipO[s2]]);
      tris.push([inO[s2],inO[s3],inI[s3]],[inO[s2],inI[s3],inI[s2]]);
    }
    var eps = (Re/Rt)*(Re/Rt);
    return { tris:tris, props:{ vol:volume, surf:surf },
      note:'Surface of revolution (lathe) with an 80%-bell contour approximation. Expansion ratio = (Re/Rt)^2 = ' + eps.toFixed(1) + '. Wall volume integrated as conical frustum shells - the same quadrature a real CAD kernel applies to revolved solids.' };
  }

  // Fuselage frame: C-channel section revolved 360 deg. Volume by Pappus.
  function genFrame(P){
    var R = P.radius, h = P.depth, w = P.flange, t = P.web;
    // C-section in (r, y): outer radius R .. R-h
    var sec = [ {r:R, y:-w/2}, {r:R, y:w/2}, {r:R-t, y:w/2}, {r:R-t, y:t/2}, {r:R-h, y:t/2}, {r:R-h, y:-t/2}, {r:R-t, y:-t/2}, {r:R-t, y:-w/2} ];
    var A = 0, rc = 0; // section area + centroid radius (shoelace in r-y plane)
    for (var i=0;i<sec.length;i++){
      var p = sec[i], q = sec[(i+1)%sec.length];
      var cr2 = p.r*q.y - q.r*p.y;
      A += cr2; rc += (p.r + q.r) * cr2;
    }
    A = A/2; rc = rc/(6*A); A = Math.abs(A);
    var SEG = 48, tris = [];
    function pt(s2, k){ var a = s2/SEG*2*Math.PI; return v3(sec[k].r*Math.cos(a), sec[k].y, sec[k].r*Math.sin(a)); }
    for (var s2=0;s2<SEG;s2++){
      for (var k=0;k<sec.length;k++){
        var k2 = (k+1)%sec.length;
        tris.push([pt(s2,k), pt(s2,k2), pt(s2+1,k2)], [pt(s2,k), pt(s2+1,k2), pt(s2+1,k)]);
      }
    }
    var per = 0; for (var i=0;i<sec.length;i++){ var p=sec[i], q=sec[(i+1)%sec.length]; per += Math.hypot(q.r-p.r, q.y-p.y); }
    return { tris:tris, props:{ vol: A*2*Math.PI*Math.abs(rc), surf: per*2*Math.PI*Math.abs(rc) },
      note:'C-channel section revolved about the fuselage axis. Volume by the theorem of Pappus: V = A x 2(pi)R(centroid) = ' + (A).toFixed(0) + ' mm2 x 2(pi) x ' + Math.abs(rc).toFixed(0) + ' mm. Exactly how CAD kernels evaluate revolved features.' };
  }

  // ================= parameter definitions =================
  var PARTS = {
    rib:    { label:'NACA wing rib', gen:genRib, params:[
      ['chord','Chord (mm)',200,900,420,10],['thick','Thickness (%)',6,18,12,1],['camber','Camber (%)',0,6,2,1],['camberPos','Camber pos (x/10)',2,6,4,1],['width','Rib width (mm)',6,40,14,2],['holes','Lightening holes',0,5,3,1] ] },
    nozzle: { label:'Bell nozzle', gen:genNozzle, params:[
      ['inlet','Inlet radius (mm)',40,120,80,2],['throat','Throat radius (mm)',18,70,34,2],['exit','Exit radius (mm)',60,220,130,2],['length','Length (mm)',160,520,320,10],['wall','Wall (mm)',2,12,4,1] ] },
    frame:  { label:'Fuselage frame', gen:genFrame, params:[
      ['radius','Outer radius (mm)',150,600,320,10],['depth','Section depth (mm)',20,90,48,2],['flange','Flange width (mm)',16,70,34,2],['web','Web thickness (mm)',2,10,4,1] ] },
  };
  var curPart = 'rib', P = {}, MODEL = null;

  function buildParams(){
    var host = document.getElementById('cbParams'); host.innerHTML = '';
    P = {};
    PARTS[curPart].params.forEach(function(def){
      P[def[0]] = def[4];
      var w = document.createElement('div'); w.className = 'cb-param';
      w.innerHTML = '<label>' + def[1] + ' <b data-val>' + def[4] + '</b></label>';
      var r = document.createElement('input'); r.type = 'range'; r.min = def[2]; r.max = def[3]; r.step = def[5]; r.value = def[4];
      r.addEventListener('input', function(){ P[def[0]] = Number(r.value); w.querySelector('[data-val]').textContent = r.value; regen(); });
      w.appendChild(r); host.appendChild(w);
    });
  }
  document.querySelectorAll('.cb-part').forEach(function(el){
    el.addEventListener('click', function(){
      document.querySelectorAll('.cb-part').forEach(function(x){ x.classList.remove('on'); });
      el.classList.add('on'); curPart = el.getAttribute('data-part');
      buildParams(); regen(); fit();
    });
  });

  // ================= mass properties =================
  function regen(){
    MODEL = PARTS[curPart].gen(P);
    var dens = Number(document.getElementById('cbMat').value); // kg/m3
    var volM3 = MODEL.props.vol * 1e-9, mass = volM3 * dens;
    document.getElementById('pVol').textContent = (MODEL.props.vol/1000).toFixed(1) + ' cm3';
    document.getElementById('pMass').textContent = mass >= 1 ? mass.toFixed(2) + ' kg' : (mass*1000).toFixed(0) + ' g';
    document.getElementById('pSurf').textContent = (MODEL.props.surf/100).toFixed(0) + ' cm2';
    var bb = bbox(); document.getElementById('pBox').textContent = bb.dx.toFixed(0) + ' x ' + bb.dy.toFixed(0) + ' x ' + bb.dz.toFixed(0) + ' mm';
    document.getElementById('pTris').textContent = String(MODEL.tris.length);
    document.getElementById('cbNote').textContent = MODEL.note;
    draw();
  }
  document.getElementById('cbMat').addEventListener('change', regen);
  function bbox(){
    var mn = v3(1e9,1e9,1e9), mx = v3(-1e9,-1e9,-1e9);
    MODEL.tris.forEach(function(t){ t.forEach(function(p){
      mn.x=Math.min(mn.x,p.x); mn.y=Math.min(mn.y,p.y); mn.z=Math.min(mn.z,p.z);
      mx.x=Math.max(mx.x,p.x); mx.y=Math.max(mx.y,p.y); mx.z=Math.max(mx.z,p.z); }); });
    return { mn:mn, mx:mx, dx:mx.x-mn.x, dy:mx.y-mn.y, dz:mx.z-mn.z, c:mul(add(mn,mx),0.5) };
  }

  // ================= viewport =================
  var yaw = 0.7, pitch = 0.45, dist = 900, target = v3(0,0,0), panX = 0, panY = 0;
  var wire = false, section = false, measure = false, mPts = [];
  function fit(){ var bb = bbox(); target = bb.c; dist = Math.max(bb.dx, bb.dy, bb.dz) * 1.9 + 60; panX = 0; panY = 0; draw(); }
  document.getElementById('bFit').addEventListener('click', fit);
  document.getElementById('bShade').addEventListener('click', function(){ wire=false; tgl(); });
  document.getElementById('bWire').addEventListener('click', function(){ wire=true; tgl(); });
  document.getElementById('bSect').addEventListener('click', function(){ section=!section; this.classList.toggle('on', section); draw(); });
  document.getElementById('bMeas').addEventListener('click', function(){ measure=!measure; mPts=[]; this.classList.toggle('on', measure); document.getElementById('cbMeasure').textContent = measure ? 'Measure: click the first vertex' : ''; cv.style.cursor = measure ? 'crosshair' : 'grab'; draw(); });
  function tgl(){ document.getElementById('bShade').classList.toggle('on', !wire); document.getElementById('bWire').classList.toggle('on', wire); draw(); }

  var SUN = norm(v3(0.5, 0.75, 0.42));
  var lastProj = []; // projected vertices for measuring
  function draw(){
    if (!MODEL || !W) return;
    ctx.fillStyle = '#0b0d13'; ctx.fillRect(0,0,W,H);
    var cp = Math.cos(pitch), sp = Math.sin(pitch), cy = Math.cos(yaw), sy = Math.sin(yaw);
    var eye = add(target, v3(dist*cp*sy, dist*sp, dist*cp*cy));
    var zA = norm(sub(target, eye)), xA = norm(cross(v3(0,1,0), zA)), yA = cross(zA, xA);
    var f = H*1.1;
    function proj(p){ var d = sub(p, eye); var z = dot(d,zA); if (z < 1) return null; return { x: W/2 + panX + dot(d,xA)*f/z, y: H/2 + panY - dot(d,yA)*f/z, z:z }; }
    // ground grid + axes
    ctx.strokeStyle = 'rgba(120,130,150,0.12)'; ctx.lineWidth = 1;
    var bb = bbox(), g = Math.pow(10, Math.round(Math.log10(Math.max(bb.dx,bb.dz)/4 || 100)));
    for (var i=-6;i<=6;i++){
      var a1 = proj(v3(target.x+i*g, bb.mn.y-10, target.z-6*g)), a2 = proj(v3(target.x+i*g, bb.mn.y-10, target.z+6*g));
      var b1 = proj(v3(target.x-6*g, bb.mn.y-10, target.z+i*g)), b2 = proj(v3(target.x+6*g, bb.mn.y-10, target.z+i*g));
      if (a1&&a2){ ctx.beginPath(); ctx.moveTo(a1.x,a1.y); ctx.lineTo(a2.x,a2.y); ctx.stroke(); }
      if (b1&&b2){ ctx.beginPath(); ctx.moveTo(b1.x,b1.y); ctx.lineTo(b2.x,b2.y); ctx.stroke(); }
    }
    [['#e5484d', v3(g*2,0,0)], ['#46a758', v3(0,g*2,0)], ['#0091ff', v3(0,0,g*2)]].forEach(function(ax){
      var o = proj(target), e = proj(add(target, ax[1]));
      if (o && e){ ctx.strokeStyle = ax[0]; ctx.lineWidth = 1.6; ctx.beginPath(); ctx.moveTo(o.x,o.y); ctx.lineTo(e.x,e.y); ctx.stroke(); }
    });
    // triangles
    var polys = [], secX = bb.c.x;
    lastProj = [];
    for (var i=0;i<MODEL.tris.length;i++){
      var t = MODEL.tris[i];
      if (section && (t[0].x + t[1].x + t[2].x)/3 > secX) continue;
      var p0 = proj(t[0]), p1 = proj(t[1]), p2 = proj(t[2]);
      if (!p0||!p1||!p2) continue;
      var n = norm(cross(sub(t[1],t[0]), sub(t[2],t[0])));
      if (!wire && dot(n, sub(eye, t[0])) <= 0) continue; // backface cull (shaded only)
      var l = 0.34 + 0.66*Math.max(0, dot(n, SUN));
      polys.push({ z:(p0.z+p1.z+p2.z)/3, p:[p0,p1,p2], l:l, v:t });
    }
    polys.sort(function(a,b){ return b.z - a.z; });
    for (var i=0;i<polys.length;i++){
      var q = polys[i];
      ctx.beginPath(); ctx.moveTo(q.p[0].x,q.p[0].y); ctx.lineTo(q.p[1].x,q.p[1].y); ctx.lineTo(q.p[2].x,q.p[2].y); ctx.closePath();
      if (wire){ ctx.strokeStyle = 'rgba(255,144,102,0.5)'; ctx.lineWidth = 0.7; ctx.stroke(); }
      else { var c = Math.round(155*q.l)+60, c2 = Math.round(120*q.l)+40; ctx.fillStyle = 'rgb(' + c + ',' + (c2+28) + ',' + (c2+50) + ')'; ctx.fill(); }
      if (measure){ q.v.forEach(function(vv, k){ lastProj.push({ s:q.p[k], w:vv }); }); }
    }
    if (section){
      ctx.fillStyle = 'rgba(255,79,0,0.10)'; ctx.font = '10px monospace'; ctx.fillStyle = '#FF9066';
      ctx.fillText('SECTION VIEW - cut at part mid-plane (x = ' + secX.toFixed(0) + ' mm)', 12, H-28);
    }
    // measure markers
    mPts.forEach(function(mp){
      var s2 = proj(mp); if (!s2) return;
      ctx.strokeStyle = '#fde68a'; ctx.lineWidth = 1.6;
      ctx.beginPath(); ctx.arc(s2.x, s2.y, 6, 0, 2*Math.PI); ctx.stroke();
    });
    if (mPts.length === 2){
      var s0 = proj(mPts[0]), s1 = proj(mPts[1]);
      if (s0 && s1){ ctx.strokeStyle = '#fde68a'; ctx.setLineDash([5,4]); ctx.beginPath(); ctx.moveTo(s0.x,s0.y); ctx.lineTo(s1.x,s1.y); ctx.stroke(); ctx.setLineDash([]); }
    }
  }

  // ================= interaction =================
  var drag = null;
  cv.addEventListener('pointerdown', function(e){
    if (measure){
      var best = null, bd = 14;
      lastProj.forEach(function(c){ var d = Math.hypot(c.s.x - e.offsetX, c.s.y - e.offsetY); if (d < bd){ bd = d; best = c.w; } });
      if (best){
        mPts.push(best);
        if (mPts.length > 2) mPts = [best];
        var el = document.getElementById('cbMeasure');
        if (mPts.length === 2){
          var d3 = sub(mPts[1], mPts[0]);
          el.innerHTML = 'Distance: <b>' + len(d3).toFixed(2) + ' mm</b><br/>dx ' + Math.abs(d3.x).toFixed(1) + ' &middot; dy ' + Math.abs(d3.y).toFixed(1) + ' &middot; dz ' + Math.abs(d3.z).toFixed(1);
        } else el.textContent = 'Measure: click the second vertex';
        draw();
      }
      return;
    }
    drag = { x:e.clientX, y:e.clientY, pan:e.shiftKey }; cv.setPointerCapture(e.pointerId); cv.style.cursor = 'grabbing';
  });
  cv.addEventListener('pointermove', function(e){
    if (!drag) return;
    var dx = e.clientX - drag.x, dy = e.clientY - drag.y; drag.x = e.clientX; drag.y = e.clientY;
    if (drag.pan){ panX += dx; panY += dy; }
    else { yaw -= dx*0.008; pitch = Math.max(-1.45, Math.min(1.45, pitch + dy*0.008)); }
    draw();
  });
  cv.addEventListener('pointerup', function(){ drag = null; cv.style.cursor = measure ? 'crosshair' : 'grab'; });
  cv.addEventListener('wheel', function(e){ e.preventDefault(); dist *= (1 + Math.sign(e.deltaY)*0.09); dist = Math.max(60, Math.min(9000, dist)); draw(); }, { passive:false });
  // pinch zoom
  var pinch = null;
  cv.addEventListener('touchstart', function(e){ if (e.touches.length === 2) pinch = Math.hypot(e.touches[0].clientX-e.touches[1].clientX, e.touches[0].clientY-e.touches[1].clientY); }, {passive:true});
  cv.addEventListener('touchmove', function(e){
    if (pinch && e.touches.length === 2){
      var d = Math.hypot(e.touches[0].clientX-e.touches[1].clientX, e.touches[0].clientY-e.touches[1].clientY);
      dist *= pinch/d; dist = Math.max(60, Math.min(9000, dist)); pinch = d; draw();
    }
  }, {passive:true});
  cv.addEventListener('touchend', function(){ pinch = null; }, {passive:true});

  // ================= STL export (ASCII - opens in any CAD tool) =============
  document.getElementById('bStl').addEventListener('click', function(){
    var out = ['solid edurankai_' + curPart];
    MODEL.tris.forEach(function(t){
      var n = norm(cross(sub(t[1],t[0]), sub(t[2],t[0])));
      out.push(' facet normal ' + n.x.toFixed(6) + ' ' + n.y.toFixed(6) + ' ' + n.z.toFixed(6));
      out.push('  outer loop');
      t.forEach(function(p){ out.push('   vertex ' + p.x.toFixed(4) + ' ' + p.y.toFixed(4) + ' ' + p.z.toFixed(4)); });
      out.push('  endloop'); out.push(' endfacet');
    });
    out.push('endsolid edurankai_' + curPart);
    var blob = new Blob([out.join('\n')], { type:'model/stl' });
    var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = curPart + '-parametric.stl';
    document.body.appendChild(a); a.click();
    setTimeout(function(){ URL.revokeObjectURL(a.href); a.remove(); }, 400);
  });

  buildParams(); regen(); resize(); fit();
})();
</script>

</BaseLayout>
