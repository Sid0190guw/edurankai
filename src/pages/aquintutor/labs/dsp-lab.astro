---
import BaseLayout from '@/layouts/BaseLayout.astro';
// DSP / Spectrum Lab — flagship signal-processing lab. A from-scratch radix-2
// FFT drives a live oscilloscope, magnitude spectrum and scrolling spectrogram.
// A windowed-sinc FIR filter designer (LP/HP/BP) shows its impulse + frequency
// response and acts on the signal in real time. Optional microphone input.
// No libraries — the FFT, windows and filters are all computed here.
---
<BaseLayout title="DSP Spectrum Lab · Virtual Labs · AquinTutor" description="Real-time digital signal processing in the browser: a from-scratch FFT driving a live oscilloscope, spectrum analyser and scrolling spectrogram, plus a windowed-sinc FIR filter designer (low/high/band-pass) with impulse and frequency response and optional microphone input. Built from scratch, no libraries.">

<style is:global>
  body { background:#08080a; color:#e8e8ee; margin:0; }
  .era-fab { display:none !important; }
  .ds-wrap { display:grid; grid-template-rows:52px 1fr; height:100vh; height:100dvh; }
  .ds-bar { background:#11131a; border-bottom:1px solid #2a2a35; display:flex; align-items:center; padding:0 14px; gap:12px; font-family:'Geist Mono',monospace; font-size:11px; color:#cfd6da; flex-wrap:wrap; }
  .ds-bar a { color:#34d399; text-decoration:none; }
  .ds-title { font-family:'Cormorant Garamond',Georgia,serif; font-size:17px; color:#fff; font-weight:600; }
  .ds-title em { color:#34d399; font-style:italic; }
  .ds-bar-right { margin-left:auto; display:flex; gap:6px; align-items:center; }
  .ds-btn { background:transparent; border:1px solid #2a2a35; color:#cfd6da; padding:6px 12px; border-radius:6px; cursor:pointer; font-family:inherit; font-size:11px; letter-spacing:0.04em; text-transform:uppercase; font-weight:700; }
  .ds-btn:hover { background:#1a1a25; } .ds-btn.on { background:#34d399; color:#04160e; border-color:#34d399; }
  .ds-main { display:grid; grid-template-columns:250px 1fr; overflow:hidden; }
  @media (max-width:900px){ .ds-main { grid-template-columns:1fr; grid-template-rows:auto 1fr; overflow-y:auto; } }
  .ds-left { background:#0c0e14; border-right:1px solid #2a2a35; overflow-y:auto; padding:14px; }
  .ds-cat { font-family:'Geist Mono',monospace; font-size:9.5px; letter-spacing:0.18em; text-transform:uppercase; color:#34d399; font-weight:700; margin:12px 0 7px; }
  .ds-left label { display:block; font-size:11px; color:#9aa; margin-bottom:10px; }
  .ds-left select { width:100%; margin-top:3px; background:#11131a; color:#e8e8ee; border:1px solid #2a2a35; border-radius:6px; padding:6px 8px; font-size:12px; font-family:inherit; }
  input[type=range] { width:100%; accent-color:#34d399; }
  .ds-row { display:flex; gap:5px; flex-wrap:wrap; margin-bottom:8px; }
  .ds-chip { background:#11131a; border:1px solid #2a2a35; color:#cfd6da; border-radius:6px; padding:5px 9px; font-size:11px; cursor:pointer; font-family:inherit; }
  .ds-chip.on { background:#34d399; color:#04160e; border-color:#34d399; font-weight:700; }
  .ds-view { position:relative; overflow:hidden; display:flex; flex-direction:column; gap:8px; padding:12px; background:#0b0d13; }
  .ds-panel { position:relative; border:1px solid #1a1a25; border-radius:8px; overflow:hidden; flex:1; min-height:0; }
  .ds-panel canvas { width:100%; height:100%; display:block; }
  .ds-panel .cap { position:absolute; left:8px; top:6px; font-family:'Geist Mono',monospace; font-size:10px; color:#34d399; letter-spacing:0.1em; text-transform:uppercase; z-index:2; text-shadow:0 1px 2px #000; }
  .ds-readout { position:absolute; right:8px; top:6px; font-family:'Geist Mono',monospace; font-size:10px; color:#9aa; z-index:2; }
</style>

<div class="ds-wrap">
  <div class="ds-bar">
    <a href="/aquintutor/labs">&larr; LABS</a>
    <span class="ds-title">DSP <em>Spectrum Lab</em></span>
    <span style="opacity:0.5;">FFT · FILTERS · REAL-TIME</span>
    <div class="ds-bar-right">
      <button type="button" class="ds-btn" id="dsMic">Microphone</button>
      <button type="button" class="ds-btn on" id="dsPlay">Running</button>
    </div>
  </div>
  <div class="ds-main">
    <div class="ds-left">
      <div class="ds-cat">Signal source</div>
      <div class="ds-row" id="waveRow">
        <button class="ds-chip on" data-w="sine">Sine</button>
        <button class="ds-chip" data-w="square">Square</button>
        <button class="ds-chip" data-w="saw">Saw</button>
        <button class="ds-chip" data-w="tri">Triangle</button>
      </div>
      <label>Tone 1 <b id="f1V" style="color:#34d399;float:right;">440 Hz</b><input type="range" id="f1" min="20" max="3800" step="1" value="440" /></label>
      <label>Tone 2 <b id="f2V" style="color:#34d399;float:right;">off</b><input type="range" id="f2" min="0" max="3800" step="1" value="0" /></label>
      <label>Noise <b id="nzV" style="color:#34d399;float:right;">0.00</b><input type="range" id="nz" min="0" max="0.5" step="0.01" value="0" /></label>

      <div class="ds-cat">FIR filter</div>
      <div class="ds-row" id="filtRow">
        <button class="ds-chip on" data-ft="none">None</button>
        <button class="ds-chip" data-ft="lp">Low-pass</button>
        <button class="ds-chip" data-ft="hp">High-pass</button>
        <button class="ds-chip" data-ft="bp">Band-pass</button>
      </div>
      <label>Cutoff <b id="cutV" style="color:#34d399;float:right;">1000 Hz</b><input type="range" id="cut" min="50" max="3800" step="10" value="1000" /></label>
      <label>Band width (BP) <b id="bwV" style="color:#34d399;float:right;">400 Hz</b><input type="range" id="bw" min="50" max="1500" step="10" value="400" /></label>
      <label>Taps <b id="tapV" style="color:#34d399;float:right;">63</b><input type="range" id="tap" min="9" max="151" step="2" value="63" /></label>

      <div class="ds-cat">Analysis</div>
      <label>Window
        <select id="win"><option value="hann">Hann</option><option value="hamming">Hamming</option><option value="blackman">Blackman</option><option value="rect">Rectangular</option></select>
      </label>
      <label>FFT size
        <select id="fft"><option>256</option><option selected>512</option><option>1024</option><option>2048</option></select>
      </label>
      <label>Sample rate
        <select id="fs"><option value="8000" selected>8 kHz</option><option value="16000">16 kHz</option><option value="44100">44.1 kHz</option></select>
      </label>
    </div>

    <div class="ds-view">
      <div class="ds-panel" style="flex:0.8;"><span class="cap">Oscilloscope · time</span><canvas id="scope"></canvas></div>
      <div class="ds-panel"><span class="cap">Spectrum · FFT (dB)</span><span class="ds-readout" id="specRead"></span><canvas id="spec"></canvas></div>
      <div class="ds-panel"><span class="cap">Spectrogram</span><canvas id="sgram"></canvas></div>
    </div>
  </div>
</div>

<script is:inline>
(function(){
'use strict';
// ---------- FFT (in-place iterative radix-2) ----------
function fft(re,im){
  var n=re.length, j=0;
  for(var i=1;i<n;i++){ var bit=n>>1; for(;j&bit;bit>>=1) j^=bit; j^=bit; if(i<j){ var tr=re[i];re[i]=re[j];re[j]=tr; var ti=im[i];im[i]=im[j];im[j]=ti; } }
  for(var len=2;len<=n;len<<=1){ var ang=-2*Math.PI/len, wr=Math.cos(ang), wi=Math.sin(ang);
    for(var s=0;s<n;s+=len){ var cwr=1,cwi=0;
      for(var k=0;k<len/2;k++){ var ur=re[s+k],ui=im[s+k]; var vr=re[s+k+len/2]*cwr-im[s+k+len/2]*cwi, vi=re[s+k+len/2]*cwi+im[s+k+len/2]*cwr;
        re[s+k]=ur+vr; im[s+k]=ui+vi; re[s+k+len/2]=ur-vr; im[s+k+len/2]=ui-vi;
        var nwr=cwr*wr-cwi*wi; cwi=cwr*wi+cwi*wr; cwr=nwr; }
    }
  }
}
function windowFn(type,n){ var w=new Float64Array(n); for(var i=0;i<n;i++){ var x=i/(n-1);
  w[i]= type==='hamming'?0.54-0.46*Math.cos(2*Math.PI*x)
      : type==='blackman'?0.42-0.5*Math.cos(2*Math.PI*x)+0.08*Math.cos(4*Math.PI*x)
      : type==='rect'?1 : 0.5-0.5*Math.cos(2*Math.PI*x); } return w; }

// ---------- state ----------
var st={ wave:'sine', f1:440, f2:0, nz:0, filt:'none', cut:1000, bw:400, taps:63, win:'hann', N:512, fs:8000, running:true, mic:false };
var phase1=0, phase2=0, coeffs=null;
function designFIR(){
  if(st.filt==='none'){ coeffs=null; return; }
  var M=st.taps, fc=st.cut/st.fs, w=windowFn('blackman',M), h=new Float64Array(M), mid=(M-1)/2, sum=0;
  function sinc(x){ return x===0?1:Math.sin(Math.PI*x)/(Math.PI*x); }
  for(var i=0;i<M;i++){ var k=i-mid;
    if(st.filt==='lp'){ h[i]=2*fc*sinc(2*fc*k)*w[i]; }
    else if(st.filt==='hp'){ h[i]=(sinc(k)- 2*fc*sinc(2*fc*k))*w[i]; }
    else { var f2=(st.cut+st.bw)/st.fs, f1=Math.max(1,st.cut-st.bw)/st.fs; h[i]=(2*f2*sinc(2*f2*k)-2*f1*sinc(2*f1*k))*w[i]; }
  }
  // normalise (unity gain at passband centre)
  if(st.filt==='hp'){ } // leave
  coeffs=h;
}
// ---------- signal generation ----------
var histBuf=new Float64Array(256); var histIdx=0;
function genFrame(N){
  var buf=new Float64Array(N), fs=st.fs;
  for(var i=0;i<N;i++){
    var s=osc(st.wave, phase1) ;
    if(st.f2>0) s+= 0.6*osc(st.wave, phase2);
    if(st.nz>0) s+= st.nz*(Math.random()*2-1);
    buf[i]=s*0.7;
    phase1+= st.f1/fs; if(phase1>=1)phase1-=1;
    if(st.f2>0){ phase2+= st.f2/fs; if(phase2>=1)phase2-=1; }
  }
  if(coeffs){ buf=convolve(buf,coeffs); }
  return buf;
}
function osc(type,p){ if(type==='square')return p<0.5?1:-1; if(type==='saw')return 2*p-1; if(type==='tri')return 4*Math.abs(p-0.5)-1; return Math.sin(2*Math.PI*p); }
function convolve(x,h){ var y=new Float64Array(x.length), M=h.length; // carry tail across frames
  for(var i=0;i<x.length;i++){ var acc=0; for(var k=0;k<M;k++){ var idx=i-k; var xv = idx>=0?x[idx]:tail[M-1+idx]; acc+=h[k]*xv; } y[i]=acc; }
  for(var k=0;k<M-1;k++) tail[k]=x[x.length-M+1+k]!==undefined?x[x.length-M+1+k]:0;
  return y;
}
var tail=new Float64Array(256);

// ---------- mic ----------
var micStream=null, audioCtx=null, micData=null, micReady=false;
document.getElementById('dsMic').addEventListener('click',function(){
  var self=this;
  if(st.mic){ st.mic=false; self.classList.remove('on'); if(micStream){micStream.getTracks().forEach(function(t){t.stop();});} return; }
  navigator.mediaDevices.getUserMedia({audio:true}).then(function(stream){
    micStream=stream; audioCtx=new (window.AudioContext||window.webkitAudioContext)(); st.fs=audioCtx.sampleRate;
    document.getElementById('fs').value=[8000,16000,44100].indexOf(st.fs)>=0?st.fs:'44100';
    var src=audioCtx.createMediaStreamSource(stream); var proc=audioCtx.createScriptProcessor(2048,1,1);
    micData=new Float64Array(2048); proc.onaudioprocess=function(e){ var d=e.inputBuffer.getChannelData(0); for(var i=0;i<d.length;i++)micData[i]=d[i]; micReady=true; };
    src.connect(proc); proc.connect(audioCtx.destination); st.mic=true; self.classList.add('on');
  }).catch(function(){ alert('Microphone unavailable or denied.'); });
});

// ---------- render ----------
var scope=document.getElementById('scope'), spec=document.getElementById('spec'), sg=document.getElementById('sgram');
var sc=scope.getContext('2d'), sp=spec.getContext('2d'), sgc=sg.getContext('2d');
function fitCanvas(cv){ var r=cv.getBoundingClientRect(),d=Math.min(2,window.devicePixelRatio||1); cv.width=r.width*d; cv.height=r.height*d; cv.getContext('2d').setTransform(d,0,0,d,0,0); return {w:r.width,h:r.height}; }
var dim={};
function resize(){ dim.scope=fitCanvas(scope); dim.spec=fitCanvas(spec); dim.sg=fitCanvas(sg); sgc.fillStyle='#05070c'; sgc.fillRect(0,0,dim.sg.w,dim.sg.h); }
window.addEventListener('resize',resize);
function heat(v){ // 0..1 magnitude -> dark->green->yellow->white
  v=Math.max(0,Math.min(1,v)); var stops=[[5,7,12],[16,80,60],[52,211,153],[240,220,80],[255,255,255]];
  var f=v*(stops.length-1),i=Math.floor(f),fr=f-i; if(i>=stops.length-1)i=stops.length-2,fr=1; var a=stops[i],b=stops[i+1];
  return 'rgb('+Math.round(a[0]+(b[0]-a[0])*fr)+','+Math.round(a[1]+(b[1]-a[1])*fr)+','+Math.round(a[2]+(b[2]-a[2])*fr)+')';
}
function frame(){
  var N=st.N;
  var buf;
  if(st.mic && micReady){ buf=new Float64Array(N); for(var i=0;i<N;i++) buf[i]=micData[i%2048]; if(coeffs)buf=convolve(buf,coeffs); }
  else buf=genFrame(N);
  // scope
  var W=dim.scope.w,H=dim.scope.h; sc.fillStyle='#0b0d13'; sc.fillRect(0,0,W,H);
  sc.strokeStyle='#1a1a25'; sc.beginPath(); sc.moveTo(0,H/2); sc.lineTo(W,H/2); sc.stroke();
  sc.strokeStyle='#34d399'; sc.lineWidth=1.4; sc.beginPath();
  var show=Math.min(N,Math.round(st.fs/80));
  for(var i=0;i<show;i++){ var x=i/show*W, y=H/2 - buf[i]*H*0.42; i?sc.lineTo(x,y):sc.moveTo(x,y); } sc.stroke();
  // fft
  var win=windowFn(st.win,N), re=new Float64Array(N), im=new Float64Array(N);
  for(var i=0;i<N;i++){ re[i]=buf[i]*win[i]; im[i]=0; }
  fft(re,im);
  var half=N/2, mags=new Float64Array(half), maxDb=-200;
  for(var i=0;i<half;i++){ var m=Math.sqrt(re[i]*re[i]+im[i]*im[i])/N; mags[i]= 20*Math.log10(m+1e-9); }
  // spectrum draw
  var W2=dim.spec.w,H2=dim.spec.h; sp.fillStyle='#0b0d13'; sp.fillRect(0,0,W2,H2);
  sp.strokeStyle='#12141c'; for(var g=1;g<8;g++){ var xx=g/8*W2; sp.beginPath(); sp.moveTo(xx,0); sp.lineTo(xx,H2); sp.stroke(); }
  var minDb=-90,maxD=0;
  sp.strokeStyle='#34d399'; sp.lineWidth=1.3; sp.beginPath();
  var peakBin=0,peak=-999;
  for(var i=0;i<half;i++){ var x=i/half*W2; var db=Math.max(minDb,Math.min(maxD,mags[i])); var y=H2-(db-minDb)/(maxD-minDb)*H2; i?sp.lineTo(x,y):sp.moveTo(x,y); if(mags[i]>peak){peak=mags[i];peakBin=i;} }
  sp.stroke();
  // freq axis labels
  sp.fillStyle='#5c6370'; sp.font='9px monospace'; for(var g=1;g<8;g++){ sp.fillText(((g/8*st.fs/2)/1000).toFixed(1)+'k',g/8*W2-8,H2-3); }
  var peakHz=peakBin/half*st.fs/2;
  document.getElementById('specRead').textContent='peak '+peakHz.toFixed(0)+' Hz';
  // filter response overlay
  if(coeffs){ drawFilterResp(sp,W2,H2,minDb,maxD); }
  // spectrogram scroll
  var Ws=dim.sg.w,Hs=dim.sg.h; var img=sgc.getImageData(1,0,Ws-1,Hs); sgc.putImageData(img,0,0);
  for(var y=0;y<Hs;y++){ var bin=Math.floor((1-y/Hs)*half); var db=mags[bin]; var v=(db-minDb)/(maxD-minDb); sgc.fillStyle=heat(v); sgc.fillRect(Ws-1,y,1,1); }
  if(st.running) raf=requestAnimationFrame(frame);
}
function drawFilterResp(ctx,W,H,minDb,maxD){
  var M=512, re=new Float64Array(M), im=new Float64Array(M);
  for(var i=0;i<coeffs.length;i++){ re[i]=coeffs[i]; }
  fft(re,im);
  ctx.strokeStyle='rgba(255,220,80,0.6)'; ctx.lineWidth=1.1; ctx.beginPath();
  for(var i=0;i<M/2;i++){ var m=Math.sqrt(re[i]*re[i]+im[i]*im[i]); var db=20*Math.log10(m+1e-9); db=Math.max(minDb,Math.min(maxD,db+0));
    var x=i/(M/2)*W; var y=H-(db-minDb)/(maxD-minDb)*H; i?ctx.lineTo(x,y):ctx.moveTo(x,y); }
  ctx.stroke();
  ctx.fillStyle='rgba(255,220,80,0.8)'; ctx.font='9px monospace'; ctx.fillText('filter response',W-90,12);
}
var raf=null;

// ---------- controls ----------
function bindChips(row,attr,fn){ document.querySelectorAll('#'+row+' .ds-chip').forEach(function(b){ b.addEventListener('click',function(){ document.querySelectorAll('#'+row+' .ds-chip').forEach(function(x){x.classList.remove('on');}); b.classList.add('on'); fn(b.getAttribute(attr)); }); }); }
bindChips('waveRow','data-w',function(v){ st.wave=v; });
bindChips('filtRow','data-ft',function(v){ st.filt=v; designFIR(); });
function bind(id,fn,fmt){ var el=document.getElementById(id); el.addEventListener('input',function(){ fn(parseFloat(el.value)); var v=document.getElementById(id+'V'); if(v)v.textContent=fmt(parseFloat(el.value)); }); }
bind('f1',function(v){st.f1=v;},function(v){return v.toFixed(0)+' Hz';});
bind('f2',function(v){st.f2=v;},function(v){return v>0?v.toFixed(0)+' Hz':'off';});
bind('nz',function(v){st.nz=v;},function(v){return v.toFixed(2);});
bind('cut',function(v){st.cut=v;designFIR();},function(v){return v.toFixed(0)+' Hz';});
bind('bw',function(v){st.bw=v;designFIR();},function(v){return v.toFixed(0)+' Hz';});
bind('tap',function(v){st.taps=v;designFIR();},function(v){return v.toFixed(0);});
document.getElementById('win').addEventListener('change',function(){st.win=this.value;});
document.getElementById('fft').addEventListener('change',function(){st.N=+this.value;});
document.getElementById('fs').addEventListener('change',function(){st.fs=+this.value;designFIR();});
document.getElementById('dsPlay').addEventListener('click',function(){ st.running=!st.running; this.textContent=st.running?'Running':'Paused'; this.classList.toggle('on',st.running); if(st.running){raf=requestAnimationFrame(frame);} });

designFIR(); resize(); requestAnimationFrame(frame);
})();
</script>

</BaseLayout>
