    REF.stopcock.setAttribute("transform","rotate(0 "+cx+" "+(scY+10)+")");
    bench.appendChild(REF.stopcock);
    bench.appendChild(el("circle",{cx:cx,cy:scY+10,r:5,fill:"#8a4a1d"}));
    // delivery tip
