  // ===================================================================
  //  TICK (flash decay + stirrer spin)
  // ===================================================================
  var spin = 0;
  function tick(){
    if (S.flashTimer > 0){
      S.flashTimer--;
      renderBench();
      if (S.flashTimer === 0){ renderBench(); updateReadouts(); }
    }
    // spin stir bar
    if (REF.stirbar){
      spin += 18;
      var f = REF.flask;
      REF.stirbar.setAttribute("transform","rotate("+spin+" "+f.cx+" "+(f.bodyBot-7)+")");
    }
    requestAnimationFrame(function(){ setTimeout(tick, 110); });
  }

  // ===================================================================
  //  WIRING
  // ===================================================================
  function wire(){
    // tabs
    var tabs = document.querySelectorAll("#tbTabs .tb-tab");
    for (var i=0;i<tabs.length;i++){
      (function(tb){
        tb.addEventListener("click", function(){
          for (var k=0;k<tabs.length;k++) tabs[k].classList.remove("active");
          tb.classList.add("active");
          var secs = document.querySelectorAll(".tb-sec");
          for (var s=0;s<secs.length;s++){
            secs[s].classList.toggle("active", secs[s].getAttribute("data-sec") === tb.getAttribute("data-sec"));
          }
          if (tb.getAttribute("data-sec") === "sim"){ drawCurve(); }
        });
      })(tabs[i]);
    }

    // dispense chips
    var chips = document.querySelectorAll(".tb-dchip");
    for (var c=0;c<chips.length;c++){
      (function(ch){
        ch.addEventListener("click", function(){
          if (!validatePair()) return;
          dispense(parseFloat(ch.getAttribute("data-step")));
        });
      })(chips[c]);
    }

    // hold stopcock
    var hb = $("btnHold");
    hb.addEventListener("mousedown", function(){ if (validatePair()) startHold(); });
    hb.addEventListener("mouseup", stopHold);
    hb.addEventListener("mouseleave", stopHold);
    hb.addEventListener("touchstart", function(e){ e.preventDefault(); if (validatePair()) startHold(); });
    hb.addEventListener("touchend", function(e){ e.preventDefault(); stopHold(); });

    // refill / reset
    $("btnFill").addEventListener("click", function(){ resetRun(); $("endFlag").classList.add("hidden"); });

    // setup inputs
    $("anSpecies").addEventListener("change", function(){
      // if user picks an acid as analyte, that's fine; just re-validate
      S.hideConc = false; onSetupChange();
    });
    $("tiSpecies").addEventListener("change", function(){ onSetupChange(); });
    $("indSel").addEventListener("change", function(){ S.indKey = $("indSel").value; updateIndInfo(); renderBench(); updateReadouts(); drawCurve(); });
    $("anConc").addEventListener("change", onSetupChange);
    $("anVol").addEventListener("change", onSetupChange);
    $("tiConc").addEventListener("change", onSetupChange);
  }

  // ===================================================================
  //  INIT
  // ===================================================================
  function init(){
    populateSelects();
    buildPresetButtons();
    buildQuiz();
    applyPreset(PRESETS[0]);   // strong-strong by default
    buildBench();
    syncInputsFromState();
    wire();
    updateReadouts();
    drawCurve();
    tick();
  }

  if (document.readyState === "loading"){
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }

})();
</script>

</BaseLayout>
