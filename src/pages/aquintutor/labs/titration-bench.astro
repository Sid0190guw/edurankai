    },
    bromo: {
      name: "Bromothymol blue", lo: 6.0, hi: 7.6,
      // yellow -> blue
      acidColor: [223,196,40], baseColor: [40,110,200],
      desc: "yellow below 6.0, blue above 7.6"
    }
  };

  // ---------- presets ----------
  var PRESETS = [
    { id:"ss",  title:"Strong acid vs strong base",
      desc:"25 mL 0.10 M HCl titrated with 0.10 M NaOH",
      an:"HCl", anC:0.1, anV:25, ti:"NaOH", tiC:0.1, ind:"phenol", hide:false },
    { id:"wa",  title:"Weak acid (acetic) vs NaOH",
      desc:"25 mL 0.10 M CH3COOH, pKa 4.76, vs 0.10 M NaOH",
      an:"CH3COOH", anC:0.1, anV:25, ti:"NaOH", tiC:0.1, ind:"phenol", hide:false },
    { id:"wb",  title:"Strong acid vs weak base",
      desc:"25 mL 0.10 M HCl titrated with 0.10 M NH3",
      an:"HCl", anC:0.1, anV:25, ti:"NH3", tiC:0.1, ind:"methyl", hide:false },
    { id:"task",title:"Find the unknown concentration",
      desc:"Hidden-concentration acid vs 0.100 M NaOH",
      an:"HCl", anC:0.0837, anV:25, ti:"NaOH", tiC:0.1, ind:"phenol", hide:true }
  ];

  // ---------- state ----------
  var S = {
    anKey:"HCl", anC:0.1, anV:25,
    tiKey:"NaOH", tiC:0.1,
    indKey:"phenol",
    added:0,          // mL titrant dispensed
    curve:[],         // [{v, ph}]
    hideConc:false,
    trueConc:0.1,
    endpointVol:null, // mL when indicator first crossed
    flashTimer:0
  };

  // ---------- helpers ----------
  function $(id){ return document.getElementById(id); }
  function clamp(x,a,b){ return x<a?a:(x>b?b:x); }
  function fmt(x,d){ if(!isFinite(x)) return "--"; return x.toFixed(d===undefined?2:d); }

  function lib(key){ return SPECIES[key]; }
  function isAcid(key){ return lib(key).role === "acid"; }
  function isStrong(key){ var t=lib(key).type; return t==="sa"||t==="sb"; }

  // ---------- CORE CHEMISTRY ENGINE ----------
  // Given the current state, return pH at the given added volume (mL).
  function computePH(addedML){
    var an = lib(S.anKey), ti = lib(S.tiKey);
    var Va = S.anV / 1000;          // L
    var Vt = addedML / 1000;        // L
    var Vtot = Va + Vt;             // L
    var nA = S.anC * Va;            // mol analyte (initial)
    var nT = S.tiC * Vt;            // mol titrant added

    // Decide acid/base orientation: which is acid, which base.
    // analyte+titrant: one is acid, one is base (validated on setup)
    var acidKey, baseKey, nAcid, nBase, acidStrong, baseStrong, acidObj, baseObj;
    if (an.role === "acid"){
      acidKey=S.anKey; acidObj=an; nAcid=nA; acidStrong=isStrong(S.anKey);
      baseKey=S.tiKey; baseObj=ti; nBase=nT; baseStrong=isStrong(S.tiKey);
    } else {
      baseKey=S.anKey; baseObj=an; nBase=nA; baseStrong=isStrong(S.anKey);
      acidKey=S.tiKey; acidObj=ti; nAcid=nT; acidStrong=isStrong(S.tiKey);
    }

    // ---- CASE A: strong acid + strong base ----
    if (acidStrong && baseStrong){
      var net = nAcid - nBase;       // mol excess H+ (positive) or OH- (negative)
      if (Math.abs(net) < 1e-12){
        return 7.0;                  // neutral salt
      }
      if (net > 0){
        var H = net / Vtot;
        return -log10(H);
      } else {
        var OH = (-net) / Vtot;
        return 14 + log10(OH);       // 14 - (-log10 OH)
      }
    }

    // ---- CASE B: weak acid + strong base ----
    if (!acidStrong && baseStrong){
      var Ka = Math.pow(10, -acidObj.pKa);
      // moles: nAcid total weak acid; nBase strong base converts HA -> A-
      if (nBase < 1e-15){
        // pure weak acid: solve Ka = x^2/(C-x)
        var C0 = nAcid / Vtot;
        return weakAcidPH(C0, Ka);
      }
      if (nBase < nAcid - 1e-15){
        // buffer region: HA and A- both present
        var nHA = nAcid - nBase;
        var nAm = nBase;
        // Henderson-Hasselbalch
        return acidObj.pKa + log10(nAm / nHA);
      }
      if (Math.abs(nBase - nAcid) < 1e-12 || (nBase >= nAcid - 1e-15 && nBase <= nAcid + 1e-15)){
        // equivalence: all A- ; weak base hydrolysis
        var Csalt = nAcid / Vtot;
        return saltOfWeakAcidPH(Csalt, Ka);
      }
      // past equivalence: excess strong base dominates
      var excessOH = nBase - nAcid;
      var OHb = excessOH / Vtot;
      // tiny contribution from A- hydrolysis negligible vs excess strong OH-
      return 14 + log10(OHb);
    }

    // ---- CASE C: strong acid + weak base ----
    if (acidStrong && !baseStrong){
      var Kb = Math.pow(10, -baseObj.pKb);
      var Ka_conj = KW / Kb;          // Ka of conjugate acid
      if (nAcid < 1e-15){
        // pure weak base
        var Cb0 = nBase / Vtot;
        return weakBasePH(Cb0, Kb);
      }
      if (nAcid < nBase - 1e-15){
        // buffer of weak base B and conjugate acid BH+
        var nB = nBase - nAcid;
        var nBH = nAcid;
        // pH = pKa(conj) + log([B]/[BH+])
        var pKaConj = -log10(Ka_conj);
        return pKaConj + log10(nB / nBH);
      }
      if (Math.abs(nAcid - nBase) < 1e-12 || (nAcid >= nBase - 1e-15 && nAcid <= nBase + 1e-15)){
        // equivalence: all BH+ (weak acid) -> acidic
        var Cconj = nBase / Vtot;
        return saltOfWeakBasePH(Cconj, Ka_conj);
      }
      // past equivalence: excess strong acid dominates
      var excessH = nAcid - nBase;
      var Hx = excessH / Vtot;
      return -log10(Hx);
    }

    // fallback (weak+weak not offered) -> approximate neutral
    return 7.0;
  }

  function log10(x){ return Math.log(x) / Math.LN10; }

  // pure weak acid: Ka = x^2/(C-x) -> x^2 + Ka x - Ka C = 0
  function weakAcidPH(C, Ka){
    if (C <= 0) return 7.0;
    var x = (-Ka + Math.sqrt(Ka*Ka + 4*Ka*C)) / 2; // [H+]
    if (x <= 0) return 7.0;
    return -log10(x);
  }
  // pure weak base: Kb = x^2/(C-x), x=[OH-]
  function weakBasePH(C, Kb){
    if (C <= 0) return 7.0;
    var x = (-Kb + Math.sqrt(Kb*Kb + 4*Kb*C)) / 2; // [OH-]
    if (x <= 0) return 7.0;
    return 14 + log10(x);
  }
  // salt of weak acid (A-): hydrolysis Kb = Kw/Ka, [OH-]=sqrt(Kb*C) refined
  function saltOfWeakAcidPH(C, Ka){
    var Kb = KW / Ka;
    if (C <= 0) return 7.0;
    var x = (-Kb + Math.sqrt(Kb*Kb + 4*Kb*C)) / 2; // [OH-]
    if (x <= 0) return 7.0;
    return 14 + log10(x);
  }
  // salt of weak base (BH+): hydrolysis Ka(conj) given, [H+]=sqrt(Ka*C)
  function saltOfWeakBasePH(C, Ka){
    if (C <= 0) return 7.0;
    var x = (-Ka + Math.sqrt(Ka*Ka + 4*Ka*C)) / 2; // [H+]
    if (x <= 0) return 7.0;
    return -log10(x);
  }

  // equivalence volume (mL) from stoichiometry C_a V_a = C_b V_b
  function equivVolML(){
    var nAnalyte = S.anC * (S.anV/1000);  // mol
    var Veq = nAnalyte / S.tiC * 1000;    // mL titrant
    return Veq;
  }

  // ---------- indicator colour from pH ----------
  function lerp(a,b,t){ return a + (b-a)*t; }
  function indicatorColor(ph){
    var ind = INDICATORS[S.indKey];
    var t;
    if (ph <= ind.lo) t = 0;
    else if (ph >= ind.hi) t = 1;
    else t = (ph - ind.lo) / (ind.hi - ind.lo);
    // smoothstep for a nicer visual transition
    t = t*t*(3 - 2*t);
    var c = [
      Math.round(lerp(ind.acidColor[0], ind.baseColor[0], t)),
      Math.round(lerp(ind.acidColor[1], ind.baseColor[1], t)),
      Math.round(lerp(ind.acidColor[2], ind.baseColor[2], t))
    ];
    return c;
  }
  function rgb(c){ return "rgb("+c[0]+","+c[1]+","+c[2]+")"; }
  function rgba(c,a){ return "rgba("+c[0]+","+c[1]+","+c[2]+","+a+")"; }

  // is current pH inside the indicator transition band?
  function inTransition(ph){
    var ind = INDICATORS[S.indKey];
    return ph > ind.lo && ph < ind.hi;
  }
  function pastEndpoint(ph){
    // endpoint reached when fully crossed to the "base" side for acid-in-flask,
    // or generally past the midpoint of the band toward final colour.
    var ind = INDICATORS[S.indKey];
    return ph >= (ind.lo + ind.hi)/2;
  }

  // ===================================================================
