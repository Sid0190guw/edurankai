      opts: ["Exactly 7", "Below 7", "Above 7", "Equal to the pKa"],
      a: 2,
      x: "At equivalence all the acid is converted to its conjugate base A-, which hydrolyses water to give OH-. The solution is basic, so pH > 7."
    },
    {
      q: "Which indicator is most appropriate for titrating a strong acid with a weak base (ammonia)?",
      opts: ["Phenolphthalein (8.2-10.0)", "Methyl orange (3.1-4.4)", "Litmus", "Any indicator works equally"],
      a: 1,
      x: "The equivalence point of a strong acid - weak base titration is below 7 (acidic salt). Methyl orange, transitioning in the acidic range 3.1-4.4, brackets that endpoint; phenolphthalein would change far too late."
    }
  ];

  function buildQuiz(){
    var host = $("quizHost");
    host.innerHTML = "";
    for (var i=0;i<QUIZ.length;i++){
      (function(item, idx){
        var card = document.createElement("div");
        card.className = "tb-q";
        var q = document.createElement("p");
        q.className = "qq";
        q.textContent = (idx+1) + ". " + item.q;
        card.appendChild(q);
        var ex = document.createElement("div");
        ex.className = "qx";
        ex.textContent = item.x;
        var answered = false;
        for (var j=0;j<item.opts.length;j++){
          (function(optIdx){
            var o = document.createElement("button");
            o.className = "qo";
            o.textContent = item.opts[optIdx];
            o.addEventListener("click", function(){
              if (answered) return;
              answered = true;
