  // update animated parts to reflect state
  function renderBench(){
    var b = REF.burette;
    // burette liquid: top of liquid corresponds to "added" mL from 0 mark
    var frac = clamp(S.added / BURETTE_MAX, 0, 1);
    var liqTopY = b.top + (b.bot - b.top) * frac;
    REF.buretteLiquid.setAttribute("y", liqTopY);
    REF.buretteLiquid.setAttribute("height", (b.bot - liqTopY) + 8);
    REF.meniscus.setAttribute("cy", liqTopY);

    // titrant liquid colour tint (faint, based on whether titrant is base/acid - just a wash)
    var tiObj = lib(S.tiKey);
    var tint = tiObj.role === "base" ? "rgba(150,205,225,0.30)" : "rgba(225,180,150,0.28)";
    REF.buretteLiquid.setAttribute("fill", tint);

    // flask liquid colour from current pH
    var ph = currentPH();
    var col = indicatorColor(ph);
    // flashing near endpoint
    if (S.flashTimer > 0){
      var ind = INDICATORS[S.indKey];
      var fcol = indicatorColor(ind.hi); // flash toward final colour
      var a = (S.flashTimer % 2 === 0);
      col = a ? fcol : col;
    }
    REF.flaskLiquid.setAttribute("fill", rgb(col));

    // flask fill level grows with total volume (cap visually)
    var f = REF.flask;
    var totalML = S.anV + S.added;
    var visFrac = clamp(totalML / 90, 0.10, 0.92); // 90 mL ~ full body visually
    var maxRise = (f.bodyBot - (f.neckBot+6)); // available height in cone
    var h = maxRise * visFrac + 10;
    var topY = f.bodyBot - h;
    REF.flaskLiquid.setAttribute("y", topY);
    REF.flaskLiquid.setAttribute("height", h);
    REF.flaskSwirl.setAttribute("cy", topY + 4);
    REF.flaskSwirl.setAttribute("fill", "rgba(255,255,255,0.10)");
    REF.stirbar.setAttribute("y", f.bodyBot - 9);

    // labels
    REF.tiLabel.textContent = lib(S.tiKey).name.split(" (")[0] + "  " + fmt(S.tiC,2) + " M";
    var anName = lib(S.anKey).name.split(" (")[0];
    REF.anLabel.textContent = S.hideConc ? (anName + "  ? M  " + fmt(S.anV,0) + " mL")
                                          : (anName + "  " + fmt(S.anC,2) + " M  " + fmt(S.anV,0) + " mL");

    // empty burette indicator
    if (S.added >= BURETTE_MAX - 1e-6){
      REF.tiLabel.textContent += "  (refill)";
    }
  }

  // current pH at current added volume (cached convenience)
  function currentPH(){
    return computePH(S.added);
  }

  // ---------- drop animation ----------
  var animBusy = false;
  function animateDrop(steps, doneCb){
    // animate a single visual drop falling from tip into flask mouth
    var b = REF.burette;
    var startX = REF.tipX, startY = REF.tipY;
    var flaskMouthX = REF.flask.cx, flaskMouthY = REF.flask.neckTop - 2;
    var t = 0;
    REF.drop.setAttribute("r", 3.2);
    function frame(){
      t += 0.10;
      if (t >= 1){
        REF.drop.setAttribute("r", 0);
        if (doneCb) doneCb();
        return;
      }
      var x = lerp(startX, flaskMouthX, t);
      var y = lerp(startY, flaskMouthY, t*t); // accelerate
      REF.drop.setAttribute("cx", x);
      REF.drop.setAttribute("cy", y);
      REF.drop.setAttribute("r", 3.2 * (1 - 0.3*t));
      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
  }

  // ---------- dispense logic ----------
  function dispense(stepML){
    if (S.added >= BURETTE_MAX - 1e-9){
      flashEmpty();
      return;
    }
    var actual = Math.min(stepML, BURETTE_MAX - S.added);
    var phBefore = currentPH();
    S.added = round4(S.added + actual);
    var phAfter = currentPH();

    // record curve point
    S.curve.push({ v: S.added, ph: phAfter });

    // detect endpoint (indicator crossing) on the appropriate side
    detectEndpoint(phBefore, phAfter);

    // brief flash if we're within transition band (indicator flickering)
    if (inTransition(phAfter)){
      S.flashTimer = 4;
    }

    // animate a drop then refresh
    animateDrop(1, function(){
      renderBench();
      updateReadouts();
      drawCurve();
    });
    // immediate visual update too (curve/readouts don't need to wait)
    renderBench();
    updateReadouts();
    drawCurve();
  }

  function round4(x){ return Math.round(x*10000)/10000; }

  function detectEndpoint(phBefore, phAfter){
    var ind = INDICATORS[S.indKey];
    var mid = (ind.lo + ind.hi)/2;
    // analyte determines direction: acid in flask -> pH rises; base in flask -> pH falls
    var anAcid = lib(S.anKey).role === "acid";
    if (S.endpointVol == null){
      if (anAcid){
        if (phBefore < mid && phAfter >= mid){
          S.endpointVol = S.added;
        }
      } else {
        if (phBefore > mid && phAfter <= mid){
          S.endpointVol = S.added;
        }
      }
    }
  }

  // ---------- hold stopcock (continuous flow) ----------
  var holdTimer = null;
  function startHold(){
    if (holdTimer) return;
    REF.stopcock.setAttribute("transform","rotate(90 "+REF.tipX+" "+(REF.burette.bot+18)+")");
    holdTimer = setInterval(function(){
      if (S.added >= BURETTE_MAX - 1e-9){ stopHold(); flashEmpty(); return; }
      dispenseSilent(0.15); // 0.15 mL per tick
    }, 90);
  }
  function stopHold(){
    if (holdTimer){ clearInterval(holdTimer); holdTimer = null; }
    if (REF.stopcock) REF.stopcock.setAttribute("transform","rotate(0 "+REF.tipX+" "+(REF.burette.bot+18)+")");
  }
  // like dispense but no per-drop fall animation (used for streaming)
  function dispenseSilent(stepML){
    var actual = Math.min(stepML, BURETTE_MAX - S.added);
    var phBefore = currentPH();
    S.added = round4(S.added + actual);
    var phAfter = currentPH();
    S.curve.push({ v: S.added, ph: phAfter });
    detectEndpoint(phBefore, phAfter);
    if (inTransition(phAfter)) S.flashTimer = 3;
    REF.drop.setAttribute("r", 3.0);
    REF.drop.setAttribute("cx", REF.tipX);
    REF.drop.setAttribute("cy", REF.tipY + 6);
    renderBench();
    updateReadouts();
    drawCurve();
  }

  function flashEmpty(){
    var f = $("endFlag");
    f.className = "tb-flag endpoint";
    f.textContent = "Burette empty - refill to continue.";
    f.classList.remove("hidden");
  }

  // ---------- readouts ----------
  function updateReadouts(){
    var ph = currentPH();
    $("roVol").textContent = fmt(S.added,2) + " mL";
    $("roBurette").textContent = fmt(S.added,2) + " mL";
    $("roPh").textContent = fmt(ph,2);
    $("roFlask").textContent = fmt(S.anV + S.added,1) + " mL";

    // moles
    var Va = S.anV/1000;
    var nA0 = S.anC * Va; // mol
    var nT = S.tiC * (S.added/1000);
    // analyte remaining (unreacted) - depends on stoich 1:1
    var anAcid = lib(S.anKey).role === "acid";
    var remaining;
    if (anAcid){ remaining = Math.max(0, nA0 - nT); }
    else { remaining = Math.max(0, nA0 - nT); }
    $("roMolA").textContent = fmt(remaining*1000,3) + " mmol";
    $("roMolT").textContent = fmt(nT*1000,3) + " mmol";

    // pH marker on bar (0..14)
    var pos = clamp(ph/14,0,1)*100;
    $("phMarker").style.left = pos + "%";

    // endpoint / equivalence flags
    var flag = $("endFlag");
    var ind = INDICATORS[S.indKey];
    if (S.flashTimer > 0){
      flag.className = "tb-flag endpoint";
      flag.textContent = "Indicator flashing - approaching endpoint. Add dropwise.";
      flag.classList.remove("hidden");
    } else if (S.endpointVol != null){
      flag.className = "tb-flag equiv";
      flag.textContent = "Endpoint reached at " + fmt(S.endpointVol,2) + " mL (permanent colour change).";
      flag.classList.remove("hidden");
      showResult();
    } else if (S.added > 0 && pastEndpoint(ph)){
      flag.className = "tb-flag equiv";
      flag.textContent = "Past endpoint - indicator colour is now permanent.";
      flag.classList.remove("hidden");
    } else {
      flag.classList.add("hidden");
    }
  }

  function showResult(){
    var Veq = equivVolML();
    // computed unknown concentration FROM the endpoint volume the user reached
    var endVol = S.endpointVol != null ? S.endpointVol : S.added;
    var nT = S.tiC * (endVol/1000);
    var computedC = nT / (S.anV/1000);
    var box = $("resultBox");
    box.classList.remove("hidden");
    var trueC = S.anC;
    var err = Math.abs(computedC - trueC)/trueC*100;
    var html =
      "<b>Result</b><br>" +
      "Equivalence vol (theory): " + fmt(Veq,2) + " mL<br>" +
      "Your endpoint vol: " + fmt(endVol,2) + " mL<br>" +
      "Computed analyte conc: <b>" + fmt(computedC,4) + " M</b><br>";
    if (!S.hideConc){
      html += "True analyte conc: " + fmt(trueC,4) + " M<br>" +
              "Titration error: " + fmt(err,2) + " %";
    }
    box.innerHTML = html;

    if (S.hideConc){
      var tbox = $("taskBox");
      tbox.classList.remove("hidden");
      tbox.innerHTML = "<b>Task</b><br>Report your computed concentration above. " +
        "The true value is revealed once you reset.";
    }
  }

  // ===================================================================
  //  CURVE CANVAS
  // ===================================================================
  var cv = $("curve");
  var ctx = cv.getContext("2d");

  function drawCurve(){
    var W = cv.width, H = cv.height;
    ctx.clearRect(0,0,W,H);
    ctx.fillStyle = "#0a0a0c";
    ctx.fillRect(0,0,W,H);

    var padL = 42, padR = 14, padT = 14, padB = 30;
    var plotW = W - padL - padR;
    var plotH = H - padT - padB;

    // x range: 0 .. max(volume so far, 1.6*Veq, 5)
    var Veq = equivVolML();
    var maxV = Math.max(S.added*1.05, Veq*1.7, 5);
    maxV = Math.min(maxV, BURETTE_MAX);
    var xOf = function(v){ return padL + (v/maxV)*plotW; };
    var yOf = function(ph){ return padT + (1 - ph/14)*plotH; };

    // grid + axes
    ctx.strokeStyle = "#1a1d24";
    ctx.lineWidth = 1;
    ctx.fillStyle = "#6b7280";
    ctx.font = "9px 'Geist Mono', monospace";
    var phh;
    for (phh=0; phh<=14; phh+=2){
      var yy = yOf(phh);
      ctx.beginPath(); ctx.moveTo(padL, yy); ctx.lineTo(W-padR, yy); ctx.stroke();
      ctx.textAlign = "right"; ctx.textBaseline = "middle";
      ctx.fillText(String(phh), padL-6, yy);
    }
    var vtick = niceTick(maxV);
    var vv;
    for (vv=0; vv<=maxV+1e-6; vv+=vtick){
      var xx = xOf(vv);
      ctx.strokeStyle = "#15181e";
      ctx.beginPath(); ctx.moveTo(xx, padT); ctx.lineTo(xx, H-padB); ctx.stroke();
      ctx.fillStyle = "#6b7280";
      ctx.textAlign = "center"; ctx.textBaseline = "top";
      ctx.fillText(fmt(vv, vtick<1?1:0), xx, H-padB+4);
    }

    // axis labels
    ctx.save();
    ctx.fillStyle = "#9aa6b6";
    ctx.font = "10px 'Geist Mono', monospace";
    ctx.textAlign = "center";
    ctx.fillText("Volume of titrant (mL)", padL + plotW/2, H-9);
    ctx.translate(11, padT + plotH/2);
    ctx.rotate(-Math.PI/2);
    ctx.fillText("pH", 0, 0);
    ctx.restore();

    // indicator transition band (horizontal)
    var ind = INDICATORS[S.indKey];
    ctx.fillStyle = "rgba(240,163,107,0.10)";
    var yhi = yOf(ind.hi), ylo = yOf(ind.lo);
    ctx.fillRect(padL, yhi, plotW, ylo - yhi);
    ctx.strokeStyle = "rgba(240,163,107,0.5)";
    ctx.setLineDash([4,4]);
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(padL, yOf((ind.lo+ind.hi)/2)); ctx.lineTo(W-padR, yOf((ind.lo+ind.hi)/2)); ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle = "rgba(240,163,107,0.85)";
    ctx.textAlign = "left"; ctx.textBaseline = "bottom";
    ctx.font = "8.5px 'Geist Mono', monospace";
    ctx.fillText(ind.name + " " + ind.lo + "-" + ind.hi, padL+4, yhi-1);

    // theoretical full curve (faint guide) computed densely
    ctx.strokeStyle = "rgba(103,232,249,0.22)";
    ctx.lineWidth = 1.4;
    ctx.beginPath();
    var first = true;
    var step = maxV/240;
    for (var v=0; v<=maxV+1e-9; v+=step){
      var p = computePH(v);
      var px = xOf(v), py = yOf(p);
      if (first){ ctx.moveTo(px,py); first=false; } else ctx.lineTo(px,py);
    }
    ctx.stroke();

    // user's measured curve (bright, point by point)
    if (S.curve.length > 0){
      ctx.strokeStyle = "#67e8f9";
      ctx.lineWidth = 2;
      ctx.beginPath();
      // start at (0, pH at 0)
      var p0 = computePH(0);
      ctx.moveTo(xOf(0), yOf(p0));
      for (var i=0;i<S.curve.length;i++){
        ctx.lineTo(xOf(S.curve[i].v), yOf(S.curve[i].ph));
      }
      ctx.stroke();
      // points
      ctx.fillStyle = "#67e8f9";
      for (var j=0;j<S.curve.length;j++){
        ctx.beginPath();
        ctx.arc(xOf(S.curve[j].v), yOf(S.curve[j].ph), 2.0, 0, Math.PI*2);
        ctx.fill();
      }
      // current point larger
      var last = S.curve[S.curve.length-1];
      ctx.fillStyle = "#fff";
      ctx.beginPath();
      ctx.arc(xOf(last.v), yOf(last.ph), 3.2, 0, Math.PI*2);
      ctx.fill();
    }

    // equivalence point marker (theoretical Veq, from max dpH/dV of dense curve)
    var eqV = findEquivalenceFromCurve(maxV);
    if (eqV != null){
      var eqPh = computePH(eqV);
      var ex = xOf(eqV), ey = yOf(eqPh);
      ctx.strokeStyle = "rgba(134,239,172,0.55)";
      ctx.setLineDash([3,3]);
      ctx.beginPath(); ctx.moveTo(ex, padT); ctx.lineTo(ex, H-padB); ctx.stroke();
      ctx.setLineDash([]);
      ctx.fillStyle = "#86efac";
      ctx.beginPath(); ctx.arc(ex, ey, 4.5, 0, Math.PI*2); ctx.fill();
      ctx.strokeStyle = "#0a0a0c"; ctx.lineWidth = 1.4; ctx.stroke();
      ctx.fillStyle = "#86efac";
      ctx.font = "9px 'Geist Mono', monospace";
      ctx.textAlign = "left"; ctx.textBaseline = "bottom";
      ctx.fillText("eq " + fmt(eqV,2) + " mL", ex+6, ey-4);
    }
  }

  function niceTick(maxV){
    if (maxV <= 6) return 1;
    if (maxV <= 12) return 2;
    if (maxV <= 30) return 5;
    return 10;
  }

  // locate equivalence volume by maximum numerical derivative of the dense theoretical curve
  function findEquivalenceFromCurve(maxV){
    var n = 600;
    var dv = maxV/n;
    if (dv <= 0) return null;
    var bestV = null, bestSlope = -1;
    var prevPh = computePH(0);
    for (var i=1;i<=n;i++){
      var v = i*dv;
      var ph = computePH(v);
      var slope = Math.abs(ph - prevPh)/dv;
      if (slope > bestSlope){ bestSlope = slope; bestV = v - dv/2; }
      prevPh = ph;
    }
    // refine: the analytic equivalence is exact for our 1:1 stoichiometry
    var analytic = equivVolML();
    if (analytic <= maxV) return analytic;
    return bestV;
  }

  // ===================================================================
  //  SETUP / RESET
  // ===================================================================
  function resetRun(refillOnly){
    S.added = 0;
    S.curve = [];
    S.endpointVol = null;
    S.flashTimer = 0;
    $("resultBox").classList.add("hidden");
    $("taskBox").classList.add("hidden");
    $("endFlag").classList.add("hidden");
    renderBench();
    updateReadouts();
    drawCurve();
  }

  // populate species selects based on role filtering
  function populateSelects(){
    var anSel = $("anSpecies"), tiSel = $("tiSpecies"), indSel = $("indSel");
    anSel.innerHTML = ""; tiSel.innerHTML = ""; indSel.innerHTML = "";
    var k;
    for (k in SPECIES){ if(SPECIES.hasOwnProperty(k)){
      var o = document.createElement("option");
      o.value = k; o.textContent = SPECIES[k].name;
      anSel.appendChild(o);
      var o2 = document.createElement("option");
      o2.value = k; o2.textContent = SPECIES[k].name;
      tiSel.appendChild(o2);
    }}
    for (k in INDICATORS){ if(INDICATORS.hasOwnProperty(k)){
      var oi = document.createElement("option");
      oi.value = k; oi.textContent = INDICATORS[k].name + " (" + INDICATORS[k].lo + "-" + INDICATORS[k].hi + ")";
      indSel.appendChild(oi);
    }}
  }

  function syncInputsFromState(){
    $("anSpecies").value = S.anKey;
    $("anConc").value = S.hideConc ? "" : S.anC;
    $("anConc").disabled = S.hideConc;
    $("anConc").placeholder = S.hideConc ? "hidden" : "";
    $("anVol").value = S.anV;
    $("tiSpecies").value = S.tiKey;
    $("tiConc").value = S.tiC;
    $("indSel").value = S.indKey;
    updateIndInfo();
    updateConcLabels();
  }

  function updateIndInfo(){
    var ind = INDICATORS[S.indKey];
    var swA = "<span class='tb-swatch' style='background:"+rgb(ind.acidColor)+"'></span>";
    var swB = "<span class='tb-swatch' style='background:"+rgb(ind.baseColor)+"'></span>";
    $("indInfo").innerHTML = swA + "acid form &nbsp; " + swB + "base form<br>" + ind.desc;
  }
  function updateConcLabels(){
    $("anConcLbl").textContent = "Concentration (mol/L)" + (S.hideConc ? " - HIDDEN (task)" : "");
  }

  // validate analyte/titrant: must be one acid + one base
  function validatePair(){
    var anAcid = lib(S.anKey).role === "acid";
    var tiAcid = lib(S.tiKey).role === "acid";
    return anAcid !== tiAcid; // one acid one base
  }

  function applyPreset(p){
    S.anKey = p.an; S.anC = p.anC; S.anV = p.anV;
    S.tiKey = p.ti; S.tiC = p.tiC;
    S.indKey = p.ind;
    S.hideConc = !!p.hide;
    S.trueConc = p.anC;
    syncInputsFromState();
    resetRun();
  }

  function buildPresetButtons(){
    var host = $("presetList");
    host.innerHTML = "";
    for (var i=0;i<PRESETS.length;i++){
      (function(p){
        var b = document.createElement("button");
        b.className = "tb-preset";
        b.innerHTML = "<div class='pt'>"+p.title+"</div><div class='pd'>"+p.desc+"</div>";
        b.addEventListener("click", function(){ applyPreset(p); });
        host.appendChild(b);
      })(PRESETS[i]);
    }
  }

  // ---------- read inputs into state ----------
  function readInputs(){
    var anKey = $("anSpecies").value;
    var tiKey = $("tiSpecies").value;
    S.anKey = anKey;
    S.tiKey = tiKey;
    if (!S.hideConc){
      var c = parseFloat($("anConc").value);
      if (isFinite(c) && c>0) S.anC = c;
    }
    var v = parseFloat($("anVol").value);
    if (isFinite(v) && v>0) S.anV = v;
    var tc = parseFloat($("tiConc").value);
    if (isFinite(tc) && tc>0) S.tiC = tc;
    S.indKey = $("indSel").value;
    S.trueConc = S.anC;

    if (!validatePair()){
      $("endFlag").className = "tb-flag endpoint";
      $("endFlag").textContent = "Pick one acid and one base (flask vs burette).";
      $("endFlag").classList.remove("hidden");
    }
  }

  function onSetupChange(){
    readInputs();
    updateIndInfo();
    updateConcLabels();
    resetRun();
  }

