---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Titration Bench · Virtual Labs · AquinTutor" description="Hands-on acid-base titration: fill the burette, add titrant drop by drop, watch the indicator turn and the pH curve build to the endpoint.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; }
  .tb-wrap { max-width: 1560px; margin: 0 auto; padding: 18px 3vw 70px; }
  .tb-top { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 12px; margin-bottom: 8px; }
  .tb-back { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #67e8f9; text-decoration: none; letter-spacing: 0.08em; }
  .tb-eye { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 12px 0 0; }
  .tb-title { font-family: 'Cormorant Garamond', serif; font-size: 34px; font-weight: 600; margin: 4px 0 0; letter-spacing: -0.02em; }
  .tb-title em { color: #67e8f9; font-style: italic; font-weight: 500; }
  .tb-lede { color: #9aa6b6; font-size: 13.5px; line-height: 1.55; max-width: 880px; margin: 10px 0 18px; }

  .tb-tabs { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 16px; border-bottom: 1px solid #2a2a35; padding-bottom: 12px; }
  .tb-tab { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 7px 12px; border-radius: 7px; border: 1px solid #2a2a35; background: #11131a; color: #9aa6b6; cursor: pointer; }
  .tb-tab.active { color: #04161b; background: #67e8f9; border-color: #67e8f9; }
  .tb-sec { display: none; }
  .tb-sec.active { display: block; }

  .tb-prose { color: #cbd2dc; font-size: 14px; line-height: 1.7; max-width: 900px; }
  .tb-prose p { margin: 0 0 12px; }
  .tb-prose h4 { font-family: 'Cormorant Garamond', serif; font-size: 21px; font-weight: 600; margin: 18px 0 6px; color: #e8e8ee; }
  .tb-prose ol, .tb-prose ul { margin: 0 0 12px; padding-left: 22px; line-height: 1.75; font-size: 13.5px; color: #cbd2dc; }
  .tb-prose li { margin-bottom: 7px; }
  .tb-eqbox { background: #11131a; border: 1px solid #2a2a35; border-left: 3px solid #67e8f9; border-radius: 8px; padding: 12px 14px; margin: 14px 0; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12.5px; color: #e8e8ee; line-height: 1.9; }
  .tb-eqbox .k { color: #fbbf24; }
  .tb-eqbox .c { color: #86efac; }
  .tb-refs { list-style: none; padding: 0; margin: 0; }
  .tb-refs li { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12px; color: #9aa6b6; padding: 8px 0; border-bottom: 1px solid #1a1a25; line-height: 1.5; }
  .tb-refs li b { color: #cfd6da; font-weight: 700; }

  /* simulation layout */
  .tb-simgrid { display: grid; grid-template-columns: 300px minmax(0,1fr) 300px; gap: 16px; align-items: start; }
  @media (max-width: 1280px) { .tb-simgrid { grid-template-columns: 1fr; } }
  .tb-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 16px; margin-bottom: 14px; }
  .tb-panel h3 { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 0 0 12px; display: flex; align-items: center; gap: 6px; }
  .tb-field { margin-bottom: 11px; }
  .tb-field label { display: block; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px; color: #9aa6b6; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 4px; }
  .tb-lbl { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #9aa6b6; }
  .tb-val { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12px; color: #67e8f9; font-weight: 700; }
  .tb-btn { background: #67e8f9; color: #04161b; padding: 8px 14px; border-radius: 7px; border: none; cursor: pointer; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
  .tb-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .tb-btn.ghost { background: transparent; color: #cfd6da; border: 1px solid #2a2a35; }
  .tb-btn.amber { background: #fbbf24; color: #2b1d00; }
  .tb-btn.rust { background: #f0a36b; color: #2b1500; }
  .tb-btn.full { width: 100%; box-sizing: border-box; }
  .tb-btnrow { display: flex; gap: 6px; flex-wrap: wrap; }
  select, input[type=text], input[type=number] { background: #0a0a0c; border: 1px solid #2a2a35; color: #e8e8ee; border-radius: 6px; padding: 7px 8px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; width: 100%; box-sizing: border-box; }
  input[type=range] { width: 100%; accent-color: #67e8f9; }
  .tb-presets { display: flex; flex-direction: column; gap: 6px; }
  .tb-preset { text-align: left; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; padding: 9px 10px; cursor: pointer; color: #cfd6da; }
  .tb-preset:hover { border-color: #67e8f9; }
  .tb-preset .pt { font-family: 'Cormorant Garamond', serif; font-size: 16px; font-weight: 600; line-height: 1.15; }
  .tb-preset .pd { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 9.5px; color: #6b7280; margin-top: 2px; letter-spacing: 0.03em; }

  /* bench stage */
  .tb-stage-wrap { background: linear-gradient(180deg, #0d0f15 0%, #0a0a0c 100%); border: 1px solid #2a2a35; border-radius: 12px; padding: 6px; }
  .tb-stage { width: 100%; display: block; border-radius: 10px; }
  .tb-dispense { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; margin-top: 10px; }
  .tb-dchip { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; font-weight: 700; padding: 9px 4px; border-radius: 7px; border: 1px solid #2a2a35; background: #11131a; color: #cfd6da; cursor: pointer; text-align: center; }
  .tb-dchip:hover { border-color: #67e8f9; }
  .tb-dchip.fine { color: #f0a36b; }
  .tb-stopcock { margin-top: 8px; }

  /* readouts */
  .tb-ro { width: 100%; border-collapse: collapse; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; }
  .tb-ro td { padding: 6px 4px; border-bottom: 1px solid #1a1a25; }
  .tb-ro td.k { color: #9aa6b6; }
  .tb-ro td.v { text-align: right; font-weight: 700; color: #e8e8ee; }
  .tb-ro td.v.ph { color: #67e8f9; font-size: 14px; }
  .tb-ph-bar { height: 10px; border-radius: 5px; margin: 6px 0 2px; background: linear-gradient(90deg,#e2002a 0%,#f0541e 14%,#f0a000 28%,#e8d200 36%,#9bd000 50%,#1f9e4a 64%,#1f8fb0 78%,#2956c0 90%,#5b1fb0 100%); position: relative; }
  .tb-ph-marker { position: absolute; top: -3px; width: 3px; height: 16px; background: #fff; border-radius: 2px; box-shadow: 0 0 4px rgba(0,0,0,0.8); transform: translateX(-1.5px); }
  .tb-ph-scale { display: flex; justify-content: space-between; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 8.5px; color: #6b7280; }

  .tb-result { background: #0a0a0c; border: 1px solid #2a2a35; border-left: 3px solid #86efac; border-radius: 8px; padding: 10px 12px; margin-top: 10px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #cbd2dc; line-height: 1.7; }
  .tb-result.hidden { display: none; }
  .tb-result b { color: #86efac; }
  .tb-result.task { border-left-color: #fbbf24; }
  .tb-result.task b { color: #fbbf24; }

  .tb-note { font-size: 10.5px; color: #6b7280; line-height: 1.5; margin-top: 8px; font-family: 'Geist Mono', ui-monospace, monospace; }
  .tb-flag { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; font-weight: 700; padding: 8px 10px; border-radius: 7px; text-align: center; margin-bottom: 10px; }
  .tb-flag.endpoint { background: rgba(240,163,107,0.14); border: 1px solid #f0a36b; color: #f0a36b; }
  .tb-flag.equiv { background: rgba(134,239,172,0.12); border: 1px solid #86efac; color: #86efac; }
  .tb-flag.hidden { display: none; }

  .tb-swatch { display: inline-block; width: 12px; height: 12px; border-radius: 3px; vertical-align: middle; border: 1px solid rgba(255,255,255,0.2); margin-right: 5px; }

  /* quiz */
  .tb-q { background: #11131a; border: 1px solid #2a2a35; border-radius: 10px; padding: 14px 16px; margin-bottom: 12px; max-width: 820px; }
  .tb-q .qq { font-size: 14px; color: #e8e8ee; margin: 0 0 10px; line-height: 1.5; }
  .tb-q .qo { display: block; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12.5px; color: #cbd2dc; padding: 8px 10px; border: 1px solid #2a2a35; border-radius: 7px; margin-bottom: 6px; cursor: pointer; background: #0a0a0c; }
  .tb-q .qo:hover { border-color: #67e8f9; }
  .tb-q .qo.right { border-color: #86efac; color: #86efac; background: rgba(134,239,172,0.08); }
  .tb-q .qo.wrong { border-color: #fca5a5; color: #fca5a5; background: rgba(252,165,165,0.08); }
  .tb-q .qx { font-family: 'Geist Mono', ui-monospace, monospace; font-size: 11px; color: #9aa6b6; margin-top: 8px; line-height: 1.6; display: none; }
  .tb-q .qx.show { display: block; }
</style>

<main class="tb-wrap">
  <div class="tb-top">
    <div>
      <a class="tb-back" href="/aquintutor/labs">&larr; Virtual labs</a>
      <p class="tb-eye">Chemistry &middot; Quantitative Analysis</p>
      <h1 class="tb-title">Acid&ndash;base <em>titration</em> bench.</h1>
    </div>
  </div>
  <p class="tb-lede">A skeuomorphic titration apparatus &mdash; a graduated 50 mL burette on a stand over a conical flask on a magnetic stirrer. Fill the burette, open the stopcock and dispense titrant in measured aliquots (or dropwise near the end). The flask colour turns with the indicator, a real equilibrium engine computes the pH after every drop, and the titration curve builds point by point to the equivalence point. Nothing is pre-baked: strong&ndash;strong, weak-acid buffer regions via Ka, and weak-base hydrolysis are all solved live.</p>

  <div class="tb-tabs" id="tbTabs">
    <button class="tb-tab active" data-sec="sim">Bench</button>
    <button class="tb-tab" data-sec="aim">Aim &amp; theory</button>
    <button class="tb-tab" data-sec="proc">Procedure</button>
    <button class="tb-tab" data-sec="quiz">Self-assessment</button>
    <button class="tb-tab" data-sec="ref">References</button>
  </div>

  <!-- ===================== BENCH (simulation) ===================== -->
  <div class="tb-sec active" data-sec="sim">
    <div class="tb-simgrid">

      <!-- LEFT: setup -->
      <div>
        <div class="tb-panel">
          <h3>Presets</h3>
          <div class="tb-presets" id="presetList"></div>
        </div>

        <div class="tb-panel">
          <h3>Flask &mdash; analyte</h3>
          <div class="tb-field">
            <label>Substance in the flask</label>
            <select id="anSpecies"></select>
          </div>
          <div class="tb-field">
            <label id="anConcLbl">Concentration (mol/L)</label>
            <input type="number" id="anConc" step="0.005" min="0.001" max="2" value="0.1">
          </div>
          <div class="tb-field">
            <label>Volume in flask (mL)</label>
            <input type="number" id="anVol" step="1" min="5" max="100" value="25">
          </div>
        </div>

        <div class="tb-panel">
          <h3>Burette &mdash; titrant</h3>
          <div class="tb-field">
            <label>Substance in the burette</label>
            <select id="tiSpecies"></select>
          </div>
          <div class="tb-field">
            <label id="tiConcLbl">Concentration (mol/L)</label>
            <input type="number" id="tiConc" step="0.005" min="0.001" max="2" value="0.1">
          </div>
          <div class="tb-field">
            <label>Indicator</label>
            <select id="indSel"></select>
          </div>
          <div id="indInfo" class="tb-note"></div>
        </div>

        <div class="tb-panel">
          <h3>Bench controls</h3>
          <div class="tb-btnrow">
            <button class="tb-btn ghost full" id="btnFill">Refill burette &amp; reset flask</button>
          </div>
        </div>
      </div>

      <!-- CENTER: glassware -->
      <div>
        <div class="tb-stage-wrap">
          <svg id="bench" class="tb-stage" viewBox="0 0 560 720" preserveAspectRatio="xMidYMid meet" aria-label="Titration apparatus"></svg>
        </div>

        <div class="tb-panel" style="margin-top:14px;">
          <h3>Dispense titrant</h3>
          <div class="tb-dispense">
            <button class="tb-dchip" data-step="1">+1.0 mL</button>
            <button class="tb-dchip" data-step="0.5">+0.5 mL</button>
            <button class="tb-dchip" data-step="0.1">+0.1 mL</button>
            <button class="tb-dchip fine" data-step="0.025">drop</button>
          </div>
          <div class="tb-stopcock">
            <button class="tb-btn rust full" id="btnHold">Hold stopcock open (flow)</button>
          </div>
          <p class="tb-note">Use the 1.0 mL chip to advance quickly, then switch to 0.1 mL and the dropwise mode (~0.025 mL/drop) as the indicator starts to flash near the endpoint. Holding the stopcock streams titrant continuously.</p>
        </div>
      </div>

      <!-- RIGHT: readouts + curve -->
      <div>
        <div class="tb-panel">
          <h3>Live readout</h3>
          <div id="endFlag" class="tb-flag hidden"></div>
          <table class="tb-ro">
            <tr><td class="k">Titrant added</td><td class="v" id="roVol">0.00 mL</td></tr>
            <tr><td class="k">Burette reading</td><td class="v" id="roBurette">0.00 mL</td></tr>
            <tr><td class="k">pH</td><td class="v ph" id="roPh">7.00</td></tr>
            <tr><td class="k">Flask volume</td><td class="v" id="roFlask">25.0 mL</td></tr>
            <tr><td class="k">Moles analyte left</td><td class="v" id="roMolA">2.50 mmol</td></tr>
            <tr><td class="k">Moles titrant added</td><td class="v" id="roMolT">0.00 mmol</td></tr>
          </table>
          <div class="tb-ph-bar"><div class="tb-ph-marker" id="phMarker" style="left:50%"></div></div>
          <div class="tb-ph-scale"><span>0</span><span>2</span><span>4</span><span>6</span><span>8</span><span>10</span><span>12</span><span>14</span></div>
          <div id="resultBox" class="tb-result hidden"></div>
          <div id="taskBox" class="tb-result task hidden"></div>
        </div>

        <div class="tb-panel">
          <h3>Titration curve</h3>
          <canvas id="curve" width="540" height="380" style="width:100%;display:block;border-radius:8px;background:#0a0a0c;"></canvas>
          <p class="tb-note">pH (y) versus volume of titrant (x). The dashed orange line marks the indicator endpoint colour change; the green dot is the computed equivalence point (the maximum of dpH/dV).</p>
        </div>
      </div>

    </div>
  </div>

  <!-- ===================== AIM & THEORY ===================== -->
  <div class="tb-sec" data-sec="aim">
    <div class="tb-prose">
      <h4>Aim</h4>
      <p>To determine the unknown concentration of an acid or base by titrating it against a standard solution of accurately known concentration, using an acid&ndash;base indicator (or the pH curve) to locate the equivalence point, and to understand how pH evolves through the four regions of a titration.</p>

      <h4>The reaction and the equivalence point</h4>
      <p>A neutralisation reaction combines hydrogen ions with hydroxide ions to form water. For a monoprotic acid HA titrated with a strong base, the net stoichiometry is one mole of base per mole of acid. The <b>equivalence point</b> is the volume of titrant at which the moles of added titrant exactly equal the moles of analyte originally present &mdash; it is a property of the chemistry. The <b>endpoint</b> is where the chosen indicator changes colour; a well-chosen indicator places the endpoint within the steep part of the curve so the two nearly coincide.</p>
      <div class="tb-eqbox">
        At equivalence: <span class="k">C_a &middot; V_a</span> = <span class="k">C_b &middot; V_b</span><br>
        so the unknown <span class="c">C_a = (C_b &middot; V_b) / V_a</span>
      </div>

      <h4>Strong acid versus strong base</h4>
      <p>Both are fully dissociated. The pH is found purely from the moles of whichever ion is in excess, divided by the total volume. Before equivalence there is excess strong acid; at equivalence the solution is just water plus a neutral salt, giving pH 7 at 25 degrees Celsius; after equivalence there is excess strong base.</p>
      <div class="tb-eqbox">
        Before eq: <span class="k">[H+] = (mol H+ &minus; mol OH&minus; added) / V_total</span><br>
        At eq: <span class="k">pH = 7.00</span> (neutral salt, no hydrolysis)<br>
        After eq: <span class="k">[OH&minus;] = (excess mol OH&minus;) / V_total</span>, pH = 14 &minus; pOH
      </div>

      <h4>Weak acid versus strong base &mdash; the buffer region</h4>
      <p>A weak acid only partially dissociates, governed by its acid dissociation constant Ka (here expressed as pKa). As strong base is added, it converts HA into its conjugate base A&minus;, creating a buffer mixture. In this region the Henderson&ndash;Hasselbalch equation applies. At the <b>half-equivalence point</b> the amounts of HA and A&minus; are equal, so pH equals pKa exactly &mdash; a convenient way to read off pKa from the curve. At the equivalence point all the acid has been converted to A&minus;, which is a weak base that hydrolyses water, so the pH is <b>above 7</b>.</p>
      <div class="tb-eqbox">
        Buffer region: <span class="k">pH = pKa + log10([A&minus;] / [HA])</span><br>
        Half-equivalence: <span class="k">pH = pKa</span><br>
        At equivalence: <span class="c">[OH&minus;] = sqrt(Kw / Ka &middot; C_salt)</span>, pH &gt; 7
      </div>

      <h4>Strong acid versus weak base</h4>
      <p>By symmetry, titrating a strong acid with a weak base (such as ammonia) builds a buffer of the weak base and its conjugate acid. The equivalence point here lies <b>below 7</b>, because the conjugate acid hydrolyses to give an acidic solution. The engine solves this with the base dissociation constant Kb and the analogous hydrolysis expression.</p>

      <h4>How the engine computes pH</h4>
      <p>After every increment the simulator recomputes total moles of acid and base, decides which region the system is in, and applies the exact closed-form expression for that region &mdash; excess-ion for strong&ndash;strong, Henderson&ndash;Hasselbalch in the buffer zone, and the appropriate hydrolysis square-root at and beyond equivalence (with a robust quadratic for the very first and last points to avoid log singularities). The equivalence point is independently located as the maximum of the numerical derivative dpH/dV of the recorded curve.</p>
    </div>
  </div>

  <!-- ===================== PROCEDURE ===================== -->
  <div class="tb-sec" data-sec="proc">
    <div class="tb-prose">
      <h4>Procedure</h4>
      <ol>
        <li>Pick a preset, or set up your own: choose the analyte in the flask (acid or base), its concentration and volume, and the standard titrant in the burette.</li>
        <li>Choose an indicator whose transition range sits inside the steep part of the expected curve. Phenolphthalein (8.2&ndash;10.0) suits strong&ndash;strong and weak-acid titrations; methyl orange (3.1&ndash;4.4) suits strong acid with a weak base.</li>
        <li>Press <b>Refill burette &amp; reset flask</b>. The burette fills to 0.00 mL and the flask shows the starting indicator colour for its pH.</li>
        <li>Open the stopcock with the dispense chips. Add titrant in 1.0 mL steps at first and watch the curve rise gently through the buffer plateau.</li>
        <li>As the indicator begins to flash a transient colour on each drop, switch to 0.1 mL and finally the dropwise mode. Stop at the first <b>permanent</b> colour change &mdash; that is your endpoint.</li>
        <li>Read the burette volume at the endpoint. Compare it with the green equivalence point on the curve, and read the computed unknown concentration in the readout panel.</li>
        <li>For the <b>find-the-unknown</b> task, the analyte concentration is hidden; titrate to the endpoint and report the concentration you calculate from your endpoint volume.</li>
      </ol>
      <h4>Good practice modelled here</h4>
      <ul>
        <li>The burette is read to the bottom of the meniscus to 0.01 mL.</li>
        <li>Adding past the endpoint overshoots; the curve and pH show the consequence immediately.</li>
        <li>The endpoint (indicator) and equivalence point (chemistry) are reported separately so you can see the small titration error between them.</li>
      </ul>
    </div>
  </div>

  <!-- ===================== QUIZ ===================== -->
  <div class="tb-sec" data-sec="quiz">
    <div class="tb-prose" style="margin-bottom:14px;"><p>Five questions, marked instantly with a worked explanation.</p></div>
    <div id="quizHost"></div>
  </div>

  <!-- ===================== REFERENCES ===================== -->
  <div class="tb-sec" data-sec="ref">
    <ul class="tb-refs">
      <li><b>Skoog, West, Holler &amp; Crouch</b> &mdash; Fundamentals of Analytical Chemistry, 9th ed., Ch. 14&ndash;16 (neutralisation titrations and titration curves).</li>
      <li><b>Harris</b> &mdash; Quantitative Chemical Analysis, 9th ed., Ch. 10&ndash;11 (acid&ndash;base equilibria, buffers, the Henderson&ndash;Hasselbalch equation).</li>
      <li><b>Atkins &amp; de Paula</b> &mdash; Physical Chemistry, equilibria and the autoprotolysis of water (Kw).</li>
      <li><b>IIT / Virtual Labs (vlab.co.in)</b> &mdash; Acid&ndash;Base Titration experiment, the apparatus and procedure modelled here.</li>
      <li><b>IUPAC</b> &mdash; recommended pKa values: acetic acid 4.76, ammonia conjugate acid 9.25 at 25 degrees Celsius.</li>
    </ul>
  </div>
</main>

<script is:inline>
(function(){
  "use strict";

  // ---------- constants ----------
  var KW = 1e-14;          // autoprotolysis of water at 25 C
  var BURETTE_MAX = 50;    // mL
  var SVGNS = "http://www.w3.org/2000/svg";

  // ---------- species library ----------
  // type: 'sa' strong acid, 'wa' weak acid, 'sb' strong base, 'wb' weak base
  var SPECIES = {
    HCl:    { name: "Hydrochloric acid (HCl)",   role: "acid", type: "sa" },
    CH3COOH:{ name: "Acetic acid (CH3COOH)",     role: "acid", type: "wa", pKa: 4.76 },
    H2SO4w: { name: "Sulfuric (as monoprotic)",  role: "acid", type: "sa" },
    HCOOH:  { name: "Formic acid (HCOOH)",       role: "acid", type: "wa", pKa: 3.75 },
    NaOH:   { name: "Sodium hydroxide (NaOH)",   role: "base", type: "sb" },
    KOH:    { name: "Potassium hydroxide (KOH)", role: "base", type: "sb" },
    NH3:    { name: "Ammonia (NH3)",             role: "base", type: "wb", pKb: 4.75 }, // pKa(NH4+) = 9.25
    Na2CO3w:{ name: "Sodium carbonate (weak b.)",role: "base", type: "wb", pKb: 3.67 }
  };

  // ---------- indicators (real transition ranges) ----------
  var INDICATORS = {
    phenol: {
      name: "Phenolphthalein", lo: 8.2, hi: 10.0,
