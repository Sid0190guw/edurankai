---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Periodic table · Virtual Labs · AquinTutor" description="All 118 elements with full data: electron configurations, atomic mass, electronegativity, group and period trends, orbital diagrams, search, trend heat-maps.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; }
  .pt-wrap { max-width: 1500px; margin: 0 auto; padding: 18px 3vw 60px; }
  .pt-top { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 12px; margin-bottom: 16px; }
  .pt-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; }
  .pt-title { font-family: 'Cormorant Garamond', serif; font-size: 36px; font-weight: 600; margin: 4px 0 0; letter-spacing: -0.02em; }
  .pt-title em { color: #67e8f9; font-style: italic; font-weight: 500; }
  .pt-controls { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; margin-bottom: 14px; }
  .pt-controls input, .pt-controls select { background: #11131a; border: 1px solid #2a2a35; color: #fff; padding: 8px 14px; border-radius: 8px; font-family: inherit; font-size: 13px; }
  .pt-controls input { width: 200px; }

  .pt-grid { display: grid; grid-template-columns: repeat(18, 1fr); gap: 3px; }
  .pt-cell { aspect-ratio: 1; border-radius: 4px; padding: 4px 5px; cursor: pointer; transition: all 0.12s; display: flex; flex-direction: column; justify-content: space-between; border: 1px solid transparent; min-height: 56px; position: relative; }
  .pt-cell:hover { transform: scale(1.12); z-index: 10; border-color: #fff; box-shadow: 0 0 18px rgba(255,255,255,0.18); }
  .pt-cell.dim { opacity: 0.15; }
  .pt-num { font-family: 'Geist Mono', monospace; font-size: 9px; color: #fff; font-weight: 700; }
  .pt-sym { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 700; color: #fff; line-height: 1; margin-top: 2px; }
  .pt-mass { font-family: 'Geist Mono', monospace; font-size: 7.5px; color: rgba(255,255,255,0.7); }
  .pt-empty { background: transparent; pointer-events: none; }
  .pt-grid-lanth { display: grid; grid-template-columns: repeat(18, 1fr); gap: 3px; margin-top: 14px; }

  .pt-detail { background: linear-gradient(135deg, #11131a, #1a1a25); border: 1px solid #2a2a35; border-radius: 14px; padding: 22px; margin-top: 22px; display: grid; grid-template-columns: 220px 1fr; gap: 22px; }
  @media (max-width: 720px) { .pt-detail { grid-template-columns: 1fr; } }
  .pt-big-cell { background: linear-gradient(135deg, var(--cat-color, #67e8f9), #2a2a35); border-radius: 14px; padding: 18px; aspect-ratio: 1; display: flex; flex-direction: column; justify-content: space-between; }
  .pt-big-num { font-family: 'Geist Mono', monospace; font-size: 14px; color: #fff; font-weight: 700; }
  .pt-big-sym { font-family: 'Cormorant Garamond', serif; font-size: 78px; font-weight: 700; color: #fff; line-height: 1; }
  .pt-big-name { font-family: 'Cormorant Garamond', serif; font-size: 22px; color: #fff; margin-top: 2px; font-weight: 500; }
  .pt-big-mass { font-family: 'Geist Mono', monospace; font-size: 13px; color: rgba(255,255,255,0.85); }

  .pt-info { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 8px; }
  .pt-info-card { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; padding: 10px 12px; }
  .pt-info-lbl { font-family: 'Geist Mono', monospace; font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; }
  .pt-info-val { font-family: 'Geist Mono', monospace; font-size: 13px; color: #67e8f9; margin-top: 4px; font-weight: 700; }

  .pt-orbital { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 10px; padding: 14px; margin-top: 14px; }
  .pt-orbital-row { display: flex; gap: 4px; flex-wrap: wrap; align-items: center; margin: 4px 0; }
  .pt-shell-lbl { font-family: 'Geist Mono', monospace; font-size: 11px; color: #9aa6b6; min-width: 30px; }
  .pt-electron { width: 10px; height: 10px; border-radius: 50%; background: #67e8f9; }
  .pt-orbital-box { display: inline-flex; gap: 3px; padding: 4px 6px; border: 1px solid #2a2a35; border-radius: 4px; margin-right: 4px; }
  .pt-spin-up::after { content: '↑'; color: #fbbf24; font-weight: 700; font-size: 12px; }
  .pt-spin-down::after { content: '↓'; color: #f87171; font-weight: 700; font-size: 12px; }
  .pt-spin-slot { width: 12px; text-align: center; }

  .pt-legend { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 18px; }
  .pt-leg-item { display: inline-flex; align-items: center; gap: 6px; font-family: 'Geist Mono', monospace; font-size: 10.5px; color: #cfd6da; }
  .pt-leg-swatch { width: 12px; height: 12px; border-radius: 3px; }

  .cat-alkali { background: #c4626c; --cat-color: #c4626c; }
  .cat-alkaline { background: #c98562; --cat-color: #c98562; }
  .cat-transition { background: #5b87c8; --cat-color: #5b87c8; }
  .cat-postmetal { background: #6b8e9e; --cat-color: #6b8e9e; }
  .cat-metalloid { background: #8a7ec4; --cat-color: #8a7ec4; }
  .cat-nonmetal { background: #4a9b78; --cat-color: #4a9b78; }
  .cat-halogen { background: #c4a64a; --cat-color: #c4a64a; }
  .cat-noble { background: #a04ec9; --cat-color: #a04ec9; }
  .cat-lanthanide { background: #c46298; --cat-color: #c46298; }
  .cat-actinide { background: #c45e7c; --cat-color: #c45e7c; }
</style>

<main class="pt-wrap">
  <div class="pt-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#67e8f9;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="pt-eye" style="margin-top:10px;">Chemistry · Atomic structure</p>
      <h1 class="pt-title">The <em>periodic table</em>.</h1>
    </div>
  </div>

  <div class="pt-controls">
    <input id="search" type="text" placeholder="Search · symbol, name, atomic number"/>
    <select id="colorBy">
      <option value="category">Color by category</option>
      <option value="electronegativity">Electronegativity</option>
      <option value="phase">Phase at STP</option>
      <option value="period">Period</option>
    </select>
  </div>

  <div id="ptGrid" class="pt-grid"></div>
  <div id="ptLanthGrid" class="pt-grid-lanth"></div>

  <div class="pt-legend">
    <span class="pt-leg-item"><span class="pt-leg-swatch cat-alkali"></span>Alkali metal</span>
    <span class="pt-leg-item"><span class="pt-leg-swatch cat-alkaline"></span>Alkaline earth</span>
    <span class="pt-leg-item"><span class="pt-leg-swatch cat-transition"></span>Transition</span>
    <span class="pt-leg-item"><span class="pt-leg-swatch cat-postmetal"></span>Post-transition</span>
    <span class="pt-leg-item"><span class="pt-leg-swatch cat-metalloid"></span>Metalloid</span>
    <span class="pt-leg-item"><span class="pt-leg-swatch cat-nonmetal"></span>Nonmetal</span>
    <span class="pt-leg-item"><span class="pt-leg-swatch cat-halogen"></span>Halogen</span>
    <span class="pt-leg-item"><span class="pt-leg-swatch cat-noble"></span>Noble gas</span>
    <span class="pt-leg-item"><span class="pt-leg-swatch cat-lanthanide"></span>Lanthanide</span>
    <span class="pt-leg-item"><span class="pt-leg-swatch cat-actinide"></span>Actinide</span>
  </div>

  <div id="ptDetail" class="pt-detail" style="display:none;"></div>
</main>

