];
const CATS = [['alkali','Alkali metal'],['alkaline','Alkaline earth'],['transition','Transition'],['post','Post-transition'],['metalloid','Metalloid'],['nonmetal','Nonmetal'],['halogen','Halogen'],['noble','Noble gas'],['lanthanide','Lanthanide'],['actinide','Actinide']];
---
<BaseLayout title="Periodic table · Virtual Labs · AquinTutor" description="Every element, category-coloured, interactive. Hover to glow, click for detail — the whole periodic table in one high-graphics grid.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .pt{ max-width:1320px; margin:0 auto; padding:20px 3vw 70px; }
  .pt-top{ margin-bottom:16px; }
  .pt-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .pt-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .pt-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .pt-scroll{ overflow-x:auto; padding-bottom:8px; }
  .pt-grid{ display:grid; grid-template-columns:repeat(18, minmax(44px,1fr)); grid-auto-rows:52px; gap:4px; min-width:840px; }
  .el{ border-radius:7px; padding:4px 5px; cursor:pointer; position:relative; border:1px solid rgba(255,255,255,0.08); transition:transform .1s, box-shadow .15s; display:flex; flex-direction:column; justify-content:space-between; }
  .el:hover{ transform:translateY(-3px) scale(1.06); z-index:5; box-shadow:0 0 0 1px #fff, 0 8px 22px rgba(0,0,0,0.6); }
  .el .z{ font-family:'Geist Mono',monospace; font-size:8.5px; opacity:0.8; }
  .el .s{ font-family:'Cormorant Garamond',serif; font-size:19px; font-weight:600; line-height:1; }
  .el .nm{ font-size:6.5px; letter-spacing:0.02em; opacity:0.85; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .cat-alkali{ background:linear-gradient(160deg,#7a2f2f,#4a1c1c); color:#ffd9d9; } .cat-alkaline{ background:linear-gradient(160deg,#7a5322,#4a3212); color:#ffe6c4; }
  .cat-transition{ background:linear-gradient(160deg,#234a6b,#132a3f); color:#cfe6ff; } .cat-post{ background:linear-gradient(160deg,#2a5148,#16302a); color:#c7f0e2; }
  .cat-metalloid{ background:linear-gradient(160deg,#4a3a6b,#2a2140); color:#e0d4ff; } .cat-nonmetal{ background:linear-gradient(160deg,#1f5a3f,#123424); color:#c8f5dd; }
  .cat-halogen{ background:linear-gradient(160deg,#245e6b,#12363f); color:#c4f0ff; } .cat-noble{ background:linear-gradient(160deg,#4a2f6b,#2a1a40); color:#ecd8ff; }
  .cat-lanthanide{ background:linear-gradient(160deg,#6b2f52,#3f1a30); color:#ffd4ea; } .cat-actinide{ background:linear-gradient(160deg,#6b273a,#3f1622); color:#ffcdd8; }
  .pt-legend{ display:flex; gap:8px; flex-wrap:wrap; margin:14px 0; }
  .pt-legend span{ font-family:'Geist Mono',monospace; font-size:10px; padding:3px 9px; border-radius:5px; }
  .pt-detail{ margin-top:10px; background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:18px; min-height:74px; display:flex; align-items:center; gap:18px; }
  .pt-detail .big{ font-family:'Cormorant Garamond',serif; font-size:52px; font-weight:600; line-height:1; }
  .pt-detail .meta{ font-family:'Geist Mono',monospace; font-size:12px; color:#8ea0be; line-height:1.9; }
  .pt-detail .meta b{ color:#5ee7ff; }
</style>
<main class="pt">
  <div class="pt-top">
    <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
    <p class="pt-eye" style="margin-top:10px;">Chemistry · Reference</p>
    <h1 class="pt-title">Periodic <em>table</em>.</h1>
  </div>
  <div class="pt-scroll"><div class="pt-grid">
    {ELEMENTS.map((el) => (
      <div class={'el cat-' + el.c} data-z={el.z} data-n={el.n} data-s={el.s} data-c={el.c}
        style={`grid-column:${el.col}; grid-row:${Math.round(el.row)};` + (el.row % 1 ? '' : '')}>
        <span class="z">{el.z}</span>
        <span class="s">{el.s}</span>
        <span class="nm">{el.n}</span>
      </div>
    ))}
  </div></div>
  <div class="pt-legend">
    {CATS.map((c) => (<span class={'cat-' + c[0]}>{c[1]}</span>))}
  </div>
  <div class="pt-detail" id="detail">
    <div class="big" id="dBig" style="color:#5ee7ff;">?</div>
    <div class="meta" id="dMeta">Hover any element to glow it; click to pin its details here.</div>
  </div>
</main>
<script is:inline>
(function(){
  var CATN={alkali:'Alkali metal',alkaline:'Alkaline earth metal',transition:'Transition metal',post:'Post-transition metal',metalloid:'Metalloid',nonmetal:'Reactive nonmetal',halogen:'Halogen',noble:'Noble gas',lanthanide:'Lanthanide',actinide:'Actinide'};
  function show(el){ var z=el.getAttribute('data-z'), n=el.getAttribute('data-n'), s=el.getAttribute('data-s'), c=el.getAttribute('data-c');
    var period = Math.round(parseFloat(el.style.gridRow)||1); var group = parseInt(el.style.gridColumn)||'—';
    document.getElementById('dBig').textContent=s;
    document.getElementById('dMeta').innerHTML='<b>'+n+'</b> &middot; atomic number <b>'+z+'</b><br>'+CATN[c]+' &middot; group '+(group>18?'—':group)+' &middot; period '+(period>7?(c==='lanthanide'?6:7):period); }
  document.querySelectorAll('.el').forEach(function(el){ el.addEventListener('click',function(){ show(el); }); el.addEventListener('mouseenter',function(){ show(el); }); });
})();
</script>
</BaseLayout>
