import BaseLayout from '@/layouts/BaseLayout.astro';
// Periodic / electronic-structure lab (graduate level). Beyond a lookup grid:
// everything is computed from first principles. For any element it builds the
// Aufbau electron configuration (Madelung order, with the standard d/f
// exceptions), the noble-gas shorthand, the four quantum numbers of the
// differentiating electron (Hund), an orbital box diagram, and the effective
// nuclear charge Z_eff by SLATER'S RULES (screening constant sigma from the
// configuration). The table can be heat-mapped by the computed Z_eff or valence
// count, and a trend plot shows the property across the whole series. No data
// tables, no libraries — pure computation.
type El = { z: number; s: string; n: string; c: string; col: number; row: number };
const E = (z: number, s: string, n: string, c: string, col: number, row: number): El => ({ z, s, n, c, col, row });
const ELEMENTS: El[] = [
  E(1,'H','Hydrogen','nonmetal',1,1), E(2,'He','Helium','noble',18,1),
  E(3,'Li','Lithium','alkali',1,2), E(4,'Be','Beryllium','alkaline',2,2), E(5,'B','Boron','metalloid',13,2), E(6,'C','Carbon','nonmetal',14,2), E(7,'N','Nitrogen','nonmetal',15,2), E(8,'O','Oxygen','nonmetal',16,2), E(9,'F','Fluorine','halogen',17,2), E(10,'Ne','Neon','noble',18,2),
  E(11,'Na','Sodium','alkali',1,3), E(12,'Mg','Magnesium','alkaline',2,3), E(13,'Al','Aluminium','post',13,3), E(14,'Si','Silicon','metalloid',14,3), E(15,'P','Phosphorus','nonmetal',15,3), E(16,'S','Sulfur','nonmetal',16,3), E(17,'Cl','Chlorine','halogen',17,3), E(18,'Ar','Argon','noble',18,3),
  E(19,'K','Potassium','alkali',1,4), E(20,'Ca','Calcium','alkaline',2,4), E(21,'Sc','Scandium','transition',3,4), E(22,'Ti','Titanium','transition',4,4), E(23,'V','Vanadium','transition',5,4), E(24,'Cr','Chromium','transition',6,4), E(25,'Mn','Manganese','transition',7,4), E(26,'Fe','Iron','transition',8,4), E(27,'Co','Cobalt','transition',9,4), E(28,'Ni','Nickel','transition',10,4), E(29,'Cu','Copper','transition',11,4), E(30,'Zn','Zinc','transition',12,4), E(31,'Ga','Gallium','post',13,4), E(32,'Ge','Germanium','metalloid',14,4), E(33,'As','Arsenic','metalloid',15,4), E(34,'Se','Selenium','nonmetal',16,4), E(35,'Br','Bromine','halogen',17,4), E(36,'Kr','Krypton','noble',18,4),
  E(37,'Rb','Rubidium','alkali',1,5), E(38,'Sr','Strontium','alkaline',2,5), E(39,'Y','Yttrium','transition',3,5), E(40,'Zr','Zirconium','transition',4,5), E(41,'Nb','Niobium','transition',5,5), E(42,'Mo','Molybdenum','transition',6,5), E(43,'Tc','Technetium','transition',7,5), E(44,'Ru','Ruthenium','transition',8,5), E(45,'Rh','Rhodium','transition',9,5), E(46,'Pd','Palladium','transition',10,5), E(47,'Ag','Silver','transition',11,5), E(48,'Cd','Cadmium','transition',12,5), E(49,'In','Indium','post',13,5), E(50,'Sn','Tin','post',14,5), E(51,'Sb','Antimony','metalloid',15,5), E(52,'Te','Tellurium','metalloid',16,5), E(53,'I','Iodine','halogen',17,5), E(54,'Xe','Xenon','noble',18,5),
  E(55,'Cs','Caesium','alkali',1,6), E(56,'Ba','Barium','alkaline',2,6), E(72,'Hf','Hafnium','transition',4,6), E(73,'Ta','Tantalum','transition',5,6), E(74,'W','Tungsten','transition',6,6), E(75,'Re','Rhenium','transition',7,6), E(76,'Os','Osmium','transition',8,6), E(77,'Ir','Iridium','transition',9,6), E(78,'Pt','Platinum','transition',10,6), E(79,'Au','Gold','transition',11,6), E(80,'Hg','Mercury','transition',12,6), E(81,'Tl','Thallium','post',13,6), E(82,'Pb','Lead','post',14,6), E(83,'Bi','Bismuth','post',15,6), E(84,'Po','Polonium','post',16,6), E(85,'At','Astatine','metalloid',17,6), E(86,'Rn','Radon','noble',18,6),
  E(87,'Fr','Francium','alkali',1,7), E(88,'Ra','Radium','alkaline',2,7), E(104,'Rf','Rutherfordium','transition',4,7), E(105,'Db','Dubnium','transition',5,7), E(106,'Sg','Seaborgium','transition',6,7), E(107,'Bh','Bohrium','transition',7,7), E(108,'Hs','Hassium','transition',8,7), E(109,'Mt','Meitnerium','transition',9,7), E(110,'Ds','Darmstadtium','transition',10,7), E(111,'Rg','Roentgenium','transition',11,7), E(112,'Cn','Copernicium','transition',12,7), E(113,'Nh','Nihonium','post',13,7), E(114,'Fl','Flerovium','post',14,7), E(115,'Mc','Moscovium','post',15,7), E(116,'Lv','Livermorium','post',16,7), E(117,'Ts','Tennessine','halogen',17,7), E(118,'Og','Oganesson','noble',18,7),
  E(57,'La','Lanthanum','lanthanide',3,8.5), E(58,'Ce','Cerium','lanthanide',4,8.5), E(59,'Pr','Praseodymium','lanthanide',5,8.5), E(60,'Nd','Neodymium','lanthanide',6,8.5), E(61,'Pm','Promethium','lanthanide',7,8.5), E(62,'Sm','Samarium','lanthanide',8,8.5), E(63,'Eu','Europium','lanthanide',9,8.5), E(64,'Gd','Gadolinium','lanthanide',10,8.5), E(65,'Tb','Terbium','lanthanide',11,8.5), E(66,'Dy','Dysprosium','lanthanide',12,8.5), E(67,'Ho','Holmium','lanthanide',13,8.5), E(68,'Er','Erbium','lanthanide',14,8.5), E(69,'Tm','Thulium','lanthanide',15,8.5), E(70,'Yb','Ytterbium','lanthanide',16,8.5), E(71,'Lu','Lutetium','lanthanide',17,8.5),
  E(89,'Ac','Actinium','actinide',3,9.5), E(90,'Th','Thorium','actinide',4,9.5), E(91,'Pa','Protactinium','actinide',5,9.5), E(92,'U','Uranium','actinide',6,9.5), E(93,'Np','Neptunium','actinide',7,9.5), E(94,'Pu','Plutonium','actinide',8,9.5), E(95,'Am','Americium','actinide',9,9.5), E(96,'Cm','Curium','actinide',10,9.5), E(97,'Bk','Berkelium','actinide',11,9.5), E(98,'Cf','Californium','actinide',12,9.5), E(99,'Es','Einsteinium','actinide',13,9.5), E(100,'Fm','Fermium','actinide',14,9.5), E(101,'Md','Mendelevium','actinide',15,9.5), E(102,'No','Nobelium','actinide',16,9.5), E(103,'Lr','Lawrencium','actinide',17,9.5),
];
---
<BaseLayout title="Periodic Table & Electronic Structure · Virtual Labs · AquinTutor" description="Graduate periodicity: Aufbau electron configuration with exceptions, the four quantum numbers, an orbital box diagram, and Slater's-rules effective nuclear charge Z_eff — all computed from first principles — with a periodic-trend heatmap and plot. Built from scratch.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .pt{ max-width:1340px; margin:0 auto; padding:20px 3vw 70px; }
  .pt-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .pt-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 12px; letter-spacing:-0.02em; } .pt-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .pt-seg{ display:flex; gap:4px; flex-wrap:wrap; margin-bottom:12px; } .pt-seg button{ background:#0b1020; border:1px solid #26314f; color:#8ea0be; border-radius:7px; padding:6px 12px; font-family:'Geist Mono',monospace; font-size:10.5px; cursor:pointer; } .pt-seg button.on{ background:rgba(94,231,255,0.14); color:#5ee7ff; border-color:#3a6b86; }
  .pt-scroll{ overflow-x:auto; padding-bottom:8px; }
  .pt-grid{ display:grid; grid-template-columns:repeat(18, minmax(42px,1fr)); grid-auto-rows:50px; gap:4px; min-width:820px; }
  .el{ border-radius:7px; padding:4px 5px; cursor:pointer; position:relative; border:1px solid rgba(255,255,255,0.08); transition:transform .1s, box-shadow .15s; display:flex; flex-direction:column; justify-content:space-between; overflow:hidden; }
  .el:hover{ transform:translateY(-3px) scale(1.06); z-index:5; box-shadow:0 0 0 1px #fff, 0 8px 22px rgba(0,0,0,0.6); }
  .el.sel{ box-shadow:0 0 0 2px #5ee7ff; }
  .el .z{ font-family:'Geist Mono',monospace; font-size:8px; opacity:0.8; } .el .s{ font-family:'Cormorant Garamond',serif; font-size:18px; font-weight:600; line-height:1; } .el .val{ font-family:'Geist Mono',monospace; font-size:8px; opacity:0.9; }
  .cat-alkali{ background:linear-gradient(160deg,#7a2f2f,#4a1c1c); } .cat-alkaline{ background:linear-gradient(160deg,#7a5322,#4a3212); } .cat-transition{ background:linear-gradient(160deg,#234a6b,#132a3f); } .cat-post{ background:linear-gradient(160deg,#2a5148,#16302a); } .cat-metalloid{ background:linear-gradient(160deg,#4a3a6b,#2a2140); } .cat-nonmetal{ background:linear-gradient(160deg,#1f5a3f,#123424); } .cat-halogen{ background:linear-gradient(160deg,#245e6b,#12363f); } .cat-noble{ background:linear-gradient(160deg,#4a2f6b,#2a1a40); } .cat-lanthanide{ background:linear-gradient(160deg,#6b2f52,#3f1a30); } .cat-actinide{ background:linear-gradient(160deg,#6b273a,#3f1622); }
  .pt-main{ display:grid; grid-template-columns:1fr 360px; gap:16px; margin-top:14px; } @media(max-width:900px){ .pt-main{ grid-template-columns:1fr; } }
  .pt-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:16px; }
  .pt-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 10px; }
  .pt-big{ font-family:'Cormorant Garamond',serif; font-size:46px; font-weight:600; line-height:1; color:#5ee7ff; }
  .pt-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11px; padding:4px 0; border-bottom:1px solid #141a2c; } .pt-metric:last-child{ border-bottom:none; } .pt-metric-l{ color:#8ea0be; } .pt-metric-v{ color:#5ee7ff; font-weight:700; text-align:right; }
  .pt-cfg{ font-family:'Geist Mono',monospace; font-size:12px; color:#a9b6cf; line-height:1.7; margin:6px 0; word-break:break-word; } .pt-cfg sup{ color:#5ee7ff; }
  .pt-box{ display:flex; gap:8px; flex-wrap:wrap; margin-top:6px; } .pt-orb{ display:flex; gap:2px; } .pt-orb .cell{ width:16px; height:16px; border:1px solid #2a3450; border-radius:3px; display:flex; align-items:center; justify-content:center; font-size:9px; color:#fbbf24; } .pt-orb-l{ font-family:'Geist Mono',monospace; font-size:9px; color:#8ea0be; text-align:center; margin-top:2px; }
</style>
<main class="pt">
  <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
  <p class="pt-eye" style="margin-top:10px;">Chemistry · Electronic structure</p>
  <h1 class="pt-title">Periodicity from <em>first principles</em>.</h1>
  <div class="pt-seg" id="modeSeg">
    <button data-m="cat" class="on">Category</button>
    <button data-m="zeff">Z_eff (Slater)</button>
    <button data-m="valence">Valence e⁻</button>
    <button data-m="shield">Shielding σ</button>
  </div>
  <div class="pt-scroll"><div class="pt-grid" id="grid">
    {ELEMENTS.map((el) => (
      <div class={'el cat-' + el.c} data-z={el.z} data-s={el.s} data-n={el.n} data-c={el.c} data-grp={el.col} data-per={Math.floor(el.row)}
        style={`grid-column:${el.col}; grid-row:${Math.round(el.row)};`}>
        <span class="z">{el.z}</span>
        <span class="s">{el.s}</span>
        <span class="val" data-val></span>
      </div>
    ))}
  </div></div>

  <div class="pt-main">
    <div class="pt-panel">
      <h3>Periodic trend · <span id="trendName" style="color:#a78bfa;">select a property</span></h3>
      <canvas id="trend" width="720" height="240" style="width:100%;height:auto;border-radius:8px;"></canvas>
      <p style="font-size:11px;color:#7e8aa3;line-height:1.6;margin:10px 0 0;">Everything is computed live: the Aufbau filling (Madelung n+l order) with the standard Cr/Cu/Mo/Ag/Au/Pd/Pt exceptions, and the screening constant σ by Slater's rules → Z_eff = Z − σ for the valence electron. Z_eff rises across a period and jumps down at each new shell — the origin of every periodic trend.</p>
    </div>
    <div class="pt-panel" id="detail">
      <div style="display:flex;align-items:baseline;gap:14px;"><span class="pt-big" id="dSym">?</span><div><div id="dName" style="font-family:'Cormorant Garamond',serif;font-size:20px;">Select an element</div><div id="dSub" style="font-family:'Geist Mono',monospace;font-size:11px;color:#8ea0be;"></div></div></div>
      <div class="pt-cfg" id="dCfg" style="margin-top:12px;"></div>
      <div class="pt-cfg" id="dShort"></div>
      <div id="dBoxes" class="pt-box"></div>
      <div style="margin-top:12px;">
        <div class="pt-metric"><span class="pt-metric-l">Block · valence e⁻</span><span class="pt-metric-v" id="dBlock">—</span></div>
        <div class="pt-metric"><span class="pt-metric-l">Quantum n,ℓ,mₗ,mₛ</span><span class="pt-metric-v" id="dQn">—</span></div>
        <div class="pt-metric"><span class="pt-metric-l">Shielding σ (Slater)</span><span class="pt-metric-v" id="dSig">—</span></div>
        <div class="pt-metric"><span class="pt-metric-l">Z_eff = Z − σ</span><span class="pt-metric-v" id="dZeff" style="color:#fbbf24;">—</span></div>
        <div class="pt-metric"><span class="pt-metric-l">Slater radius ∝ n*²/Z_eff</span><span class="pt-metric-v" id="dRad">—</span></div>
      </div>
    </div>
  </div>
</main>
<script is:inline>
(function(){
  var ORDER=[[1,0],[2,0],[2,1],[3,0],[3,1],[4,0],[3,2],[4,1],[5,0],[4,2],[5,1],[6,0],[4,3],[5,2],[6,1],[7,0],[5,3],[6,2],[7,1]];
  var LCAP=[2,6,10,14], LNAME=['s','p','d','f'];
  // classic Aufbau exceptions (full valence overrides expressed as {"n l":count})
  var EXC={ 24:{'3d':5,'4s':1}, 29:{'3d':10,'4s':1}, 41:{'4d':4,'5s':1}, 42:{'4d':5,'5s':1}, 44:{'4d':7,'5s':1}, 45:{'4d':8,'5s':1}, 46:{'4d':10,'5s':0}, 47:{'4d':10,'5s':1}, 78:{'5d':9,'6s':1}, 79:{'5d':10,'6s':1} };
  function config(Z){ var left=Z, sub={}; for(var i=0;i<ORDER.length&&left>0;i++){ var n=ORDER[i][0],l=ORDER[i][1],cap=LCAP[l]; var c=Math.min(cap,left); sub[n+' '+l]=c; left-=c; }
    if(EXC[Z]){ var ex=EXC[Z]; for(var key in ex){ var n=+key[0], l=LNAME.indexOf(key[1]); sub[n+' '+l]=ex[key]; } }
    return sub; }
  // Slater group ordering: (1s)(2s2p)(3s3p)(3d)(4s4p)(4d)(4f)(5s5p)(5d)(5f)(6s6p)(6d)(7s7p)
  var SLORDER=[[1,0],[2,0],[3,0],[3,2],[4,0],[4,2],[4,3],[5,0],[5,2],[5,3],[6,0],[6,2],[7,0]];
  function grank(n,l){ var gt=l<=1?0:l; for(var i=0;i<SLORDER.length;i++){ if(SLORDER[i][0]===n && SLORDER[i][1]===gt) return i; } return 99; }
  function orderedSubshells(sub){ // sort by n then l for display
    var arr=Object.keys(sub).map(function(k){ var p=k.split(' '); return {n:+p[0],l:+p[1],c:sub[k]}; }).filter(function(x){return x.c>0;});
    arr.sort(function(a,b){ return a.n-b.n || a.l-b.l; }); return arr; }
  function fillOrder(Z){ // the actual Aufbau sequence of subshells (for differentiating electron)
    var left=Z, seq=[]; for(var i=0;i<ORDER.length&&left>0;i++){ var n=ORDER[i][0],l=ORDER[i][1],cap=LCAP[l]; var c=Math.min(cap,left); seq.push({n:n,l:l,c:c}); left-=c; } return seq; }
  function nobleShorthand(Z){ var nobles=[[2,'He'],[10,'Ne'],[18,'Ar'],[36,'Kr'],[54,'Xe'],[86,'Rn']]; var pick=null; for(var i=0;i<nobles.length;i++){ if(nobles[i][0]<Z) pick=nobles[i]; } return pick; }

  // Slater's rules: screening σ for the differentiating (valence) electron.
  // Same group: 0.35 (0.30 for 1s). s/p valence: n−1 shell 0.85, ≤n−2 shell 1.00.
  // d/f valence: every electron in a LOWER Slater group 1.00; higher groups 0.
  function slater(Z){ var sub=config(Z); var arr=orderedSubshells(sub);
    var seq=fillOrder(Z); var diff=seq[seq.length-1];
    var vn=diff.n, vl=diff.l, sp=(vl<=1), rv=grank(vn,vl);
    var groupTotal=0; arr.forEach(function(x){ if(grank(x.n,x.l)===rv) groupTotal+=x.c; });
    var sigma=Math.max(0,groupTotal-1)*(vn===1?0.30:0.35);
    arr.forEach(function(x){ var rx=grank(x.n,x.l); if(rx===rv) return;
      if(sp){ if(x.n===vn-1) sigma+=x.c*0.85; else if(x.n<=vn-2) sigma+=x.c*1.00; }
      else { if(rx<rv) sigma+=x.c*1.00; } });
    var zeff=Z - sigma;
    var nstar=[1,2,3,3.7,4.0,4.2][vn-1] || vn;
    return { sub:sub, arr:arr, diff:diff, sigma:sigma, zeff:zeff, nstar:nstar, valence:valCount(arr) };
  }
  function valCount(arr){ var maxN=0; arr.forEach(function(x){ if((x.l<=1)&&x.n>maxN) maxN=x.n; }); var v=0; arr.forEach(function(x){ if(x.n===maxN && x.l<=1) v+=x.c; }); return v; }

  function cfgStr(arr){ return arr.map(function(x){ return x.n+LNAME[x.l]+'<sup>'+x.c+'</sup>'; }).join(' '); }
  function qNumbers(diff){ var l=diff.l, no=2*l+1, e=diff.c; var idx=e<=no?e:e-no; var ml=-l+(idx-1); var ms=e<=no?'+½':'−½'; return {n:diff.n,l:l,ml:ml,ms:ms}; }

  var SEL=null, mode='cat';
  function paintTiles(){ document.querySelectorAll('.el').forEach(function(el){ var Z=+el.getAttribute('data-z'); var val=el.querySelector('[data-val]');
    var S=slater(Z);
    val.textContent = mode==='valence'? S.valence : (mode==='zeff'? S.zeff.toFixed(1) : (mode==='shield'? S.sigma.toFixed(1) : ''));
    if(mode==='cat'){ el.style.background=''; el.className='el cat-'+el.getAttribute('data-c')+(el===SEL?' sel':''); }
    else { el.className='el'+(el===SEL?' sel':''); var q = mode==='valence'? S.valence/8 : (mode==='zeff'? Math.min(1,S.zeff/12) : Math.min(1,S.sigma/90));
      var r=Math.round(20+q*(94-20)), g=Math.round(30+q*(231-30)), b=Math.round(60+q*(255-60)); el.style.background='rgb('+r+','+g+','+b+')'; el.style.color = q>0.6?'#04161b':'#e8ecf4'; }
  }); }

  function drawTrend(){ var cv=document.getElementById('trend'); var dp=window.devicePixelRatio||1; var r=cv.getBoundingClientRect(); var W=r.width||720, H=(240/720)*W; cv.width=Math.round(W*dp); cv.height=Math.round(H*dp); var ctx=cv.getContext('2d'); ctx.setTransform(dp,0,0,dp,0,0);
    ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H); var prop = mode==='cat'?'zeff':mode;
    document.getElementById('trendName').textContent = prop==='zeff'?'effective nuclear charge Z_eff':prop==='valence'?'valence electrons':'shielding σ';
    var padL=30,padB=18, N=86; var vals=[]; for(var z=1;z<=N;z++){ var S=slater(z); vals.push(prop==='valence'?S.valence:(prop==='shield'?S.sigma:S.zeff)); }
    var mx=Math.max.apply(null,vals)||1; function X(z){ return padL+(z-1)/(N-1)*(W-padL-8); } function Y(v){ return H-padB-(v/mx)*(H-padB-10); }
    // period boundaries
    [2,10,18,36,54].forEach(function(z){ ctx.strokeStyle='rgba(94,231,255,0.08)'; ctx.beginPath(); ctx.moveTo(X(z+0.5),8); ctx.lineTo(X(z+0.5),H-padB); ctx.stroke(); });
    ctx.save(); ctx.shadowColor='#fbbf24'; ctx.shadowBlur=6; ctx.strokeStyle='#fbbf24'; ctx.lineWidth=1.7; ctx.beginPath(); vals.forEach(function(v,i){ i?ctx.lineTo(X(i+1),Y(v)):ctx.moveTo(X(i+1),Y(v)); }); ctx.stroke(); ctx.restore();
    if(SEL){ var z=+SEL.getAttribute('data-z'); if(z<=N){ ctx.fillStyle='#5ee7ff'; ctx.beginPath(); ctx.arc(X(z),Y(vals[z-1]),4,0,7); ctx.fill(); } }
    ctx.fillStyle='#5f7597'; ctx.font="9px 'Geist Mono',monospace"; ctx.fillText('Z=1',padL-6,H-6); ctx.fillText('Z=86',W-40,H-6);
  }

  function select(el){ if(SEL) SEL.classList.remove('sel'); SEL=el; paintTiles(); el.classList.add('sel');
    var Z=+el.getAttribute('data-z'), sym=el.getAttribute('data-s'), name=el.getAttribute('data-n');
    var S=slater(Z); var arr=S.arr; var q=qNumbers(S.diff);
    document.getElementById('dSym').textContent=sym; document.getElementById('dName').textContent=name;
    document.getElementById('dSub').textContent='Z = '+Z+' · group '+el.getAttribute('data-grp')+' · period '+el.getAttribute('data-per')+' · '+LNAME[S.diff.l]+'-block';
    document.getElementById('dCfg').innerHTML=cfgStr(arr);
    var nob=nobleShorthand(Z); if(nob){ var core=slater(nob[0]); var coreKeys={}; core.arr.forEach(function(x){ coreKeys[x.n+' '+x.l]=x.c; }); var val=arr.filter(function(x){ return coreKeys[x.n+' '+x.l]!==x.c; }); document.getElementById('dShort').innerHTML='['+nob[1]+'] '+cfgStr(val); } else document.getElementById('dShort').innerHTML='';
    // orbital boxes for the differentiating subshell
    var d=S.diff, no=2*d.l+1, boxes=''; for(var o=0;o<no;o++){ var up=(o< (d.c<=no?d.c:no))?'↑':''; var dn=(d.c>no && o<(d.c-no))?'↓':''; boxes+='<div class="cell">'+(up+dn||'')+'</div>'; }
    document.getElementById('dBoxes').innerHTML='<div><div class="pt-orb">'+boxes+'</div><div class="pt-orb-l">'+d.n+LNAME[d.l]+'</div></div>';
    document.getElementById('dBlock').textContent=LNAME[S.diff.l]+' · '+S.valence;
    document.getElementById('dQn').textContent='('+q.n+', '+q.l+', '+q.ml+', '+q.ms+')';
    document.getElementById('dSig').textContent=S.sigma.toFixed(2);
    document.getElementById('dZeff').textContent=S.zeff.toFixed(2);
    document.getElementById('dRad').textContent=(S.nstar*S.nstar/S.zeff*53).toFixed(0)+' pm (est.)';
    drawTrend();
  }
  document.querySelectorAll('.el').forEach(function(el){ el.addEventListener('click',function(){ select(el); }); });
  document.querySelectorAll('#modeSeg button').forEach(function(b){ b.addEventListener('click',function(){ document.querySelectorAll('#modeSeg button').forEach(function(x){x.classList.remove('on');}); b.classList.add('on'); mode=b.getAttribute('data-m'); paintTiles(); drawTrend(); }); });
  paintTiles(); drawTrend();
  var fe=document.querySelector('.el[data-z="6"]'); if(fe) select(fe);
})();
</script>
</BaseLayout>
