    var mainGrid = document.getElementById('ptGrid');
    var lanthGrid = document.getElementById('ptLanthGrid');

    function buildGrid() {
      var matrix = Array(7).fill(null).map(function () { return Array(18).fill(null); });
      E.forEach(function (e) {
        var num = e[0], group = e[4], period = e[5];
        if (group != null && period >= 1 && period <= 7) {
          matrix[period - 1][group - 1] = e;
        }
      });
      matrix[5][2] = E[56]; // La anchor
      matrix[6][2] = E[88]; // Ac anchor
      for (var p = 0; p < 7; p++) {
        for (var g = 0; g < 18; g++) {
          var e = matrix[p][g];
          if (e) mainGrid.appendChild(cellEl(e));
          else { var sp = document.createElement('div'); sp.className = 'pt-cell pt-empty'; mainGrid.appendChild(sp); }
        }
      }
      var lanthRow = E.slice(57, 71);
      var actRow = E.slice(89, 103);
      function buildSubRow(row) {
        var sp1 = document.createElement('div'); sp1.className = 'pt-cell pt-empty'; sp1.style.gridColumn = '1 / 3';
        lanthGrid.appendChild(sp1);
        row.forEach(function (e) { lanthGrid.appendChild(cellEl(e)); });
        var sp2 = document.createElement('div'); sp2.className = 'pt-cell pt-empty'; lanthGrid.appendChild(sp2);
      }
      buildSubRow(lanthRow);
      buildSubRow(actRow);
    }

    function cellEl(e) {
      var div = document.createElement('div');
      div.className = 'pt-cell cat-' + e[6];
      div.setAttribute('data-num', e[0]);
      div.innerHTML = '<div class="pt-num">' + e[0] + '</div><div class="pt-sym">' + e[1] + '</div><div class="pt-mass">' + (typeof e[3] === 'number' ? e[3].toFixed(2) : e[3]) + '</div>';
      div.addEventListener('click', function () { showDetail(e); });
      return div;
    }

    function phaseOf(num) {
      if ([1,2,7,8,9,10,17,18,36,54,86].indexOf(num) >= 0) return 'Gas';
      if ([35,80].indexOf(num) >= 0) return 'Liquid';
      return 'Solid';
    }

    function buildOrbitalDiagram(num) {
      var subshells = [['1s',2],['2s',2],['2p',6],['3s',2],['3p',6],['4s',2],['3d',10],['4p',6],['5s',2],['4d',10],['5p',6],['6s',2],['4f',14],['5d',10],['6p',6],['7s',2],['5f',14],['6d',10],['7p',6]];
      var fills = [], left = num;
      for (var i = 0; i < subshells.length && left > 0; i++) {
        var cap = subshells[i][1]; var take = Math.min(cap, left);
        fills.push([subshells[i][0], take, cap]); left -= take;
      }
      return fills.map(function (f) {
        var nOrb = f[2] / 2; var boxes = '';
        for (var i = 0; i < nOrb; i++) {
          var up = i < Math.min(nOrb, f[1]);
          var dn = i < f[1] - nOrb;
          boxes += '<div class="pt-orbital-box"><span class="pt-spin-slot ' + (up ? 'pt-spin-up' : '') + '"></span><span class="pt-spin-slot ' + (dn ? 'pt-spin-down' : '') + '"></span></div>';
        }
        return '<div class="pt-orbital-row"><span class="pt-shell-lbl">' + f[0] + '</span>' + boxes + '</div>';
      }).join('');
    }

    function showDetail(e) {
      var d = document.getElementById('ptDetail'); d.style.display = 'grid';
      var en = e[8] == null ? '&mdash;' : e[8].toFixed(2);
      var phase = phaseOf(e[0]);
      d.innerHTML =
        '<div class="pt-big-cell cat-' + e[6] + '">' +
          '<div><div class="pt-big-num">' + e[0] + '</div></div>' +
          '<div><div class="pt-big-sym">' + e[1] + '</div><div class="pt-big-name">' + e[2] + '</div><div class="pt-big-mass">' + (typeof e[3] === 'number' ? e[3].toFixed(3) : e[3]) + ' u</div></div>' +
        '</div>' +
        '<div>' +
          '<div class="pt-info">' +
            '<div class="pt-info-card"><div class="pt-info-lbl">Group</div><div class="pt-info-val">' + (e[4] || '&mdash;') + '</div></div>' +
            '<div class="pt-info-card"><div class="pt-info-lbl">Period</div><div class="pt-info-val">' + e[5] + '</div></div>' +
            '<div class="pt-info-card"><div class="pt-info-lbl">Category</div><div class="pt-info-val">' + e[6].replace(/^./, function (c) { return c.toUpperCase(); }) + '</div></div>' +
            '<div class="pt-info-card"><div class="pt-info-lbl">Phase · STP</div><div class="pt-info-val">' + phase + '</div></div>' +
            '<div class="pt-info-card"><div class="pt-info-lbl">Electronegativity</div><div class="pt-info-val">' + en + '</div></div>' +
            '<div class="pt-info-card" style="grid-column:1 / -1;"><div class="pt-info-lbl">Electron configuration</div><div class="pt-info-val" style="font-size:14px;">' + e[7] + '</div></div>' +
          '</div>' +
          '<div class="pt-orbital"><div class="pt-info-lbl" style="margin-bottom:8px;">Orbital filling · Aufbau order</div>' + buildOrbitalDiagram(e[0]) + '</div>' +
        '</div>';
      d.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    // Search filter
    document.getElementById('search').addEventListener('input', function (ev) {
      var q = (ev.target.value || '').toLowerCase().trim();
      document.querySelectorAll('.pt-cell[data-num]').forEach(function (c) {
        var num = c.getAttribute('data-num');
        var e = E[parseInt(num, 10) - 1];
        var match = !q || e[1].toLowerCase().indexOf(q) >= 0 || e[2].toLowerCase().indexOf(q) >= 0 || String(e[0]) === q;
        c.classList.toggle('dim', !match);
      });
    });

    // Color by selector — re-tint cells based on chosen property
    document.getElementById('colorBy').addEventListener('change', function (ev) {
      var mode = ev.target.value;
      document.querySelectorAll('.pt-cell[data-num]').forEach(function (c) {
        var num = c.getAttribute('data-num');
        var e = E[parseInt(num, 10) - 1];
        c.className = 'pt-cell';
        c.setAttribute('data-num', num);
        if (mode === 'category') c.classList.add('cat-' + e[6]);
        else if (mode === 'electronegativity') {
          var v = e[8]; if (v == null) c.style.background = '#2a2a35';
          else { var t = (v - 0.7) / (4.0 - 0.7); c.style.background = 'hsl(' + (220 - t * 220) + ',70%,50%)'; }
        }
        else if (mode === 'phase') {
          var p = phaseOf(e[0]);
          c.style.background = p === 'Gas' ? '#a04ec9' : p === 'Liquid' ? '#67e8f9' : '#5b87c8';
        }
        else if (mode === 'period') {
          var hue = (e[5] - 1) * 50;
          c.style.background = 'hsl(' + hue + ',60%,45%)';
        }
      });
    });

    buildGrid();
    showDetail(E[0]);
  })();
</script>

<div id="demoHint" style="position:fixed;left:16px;bottom:16px;max-width:330px;background:#11131a;color:#e8e8ee;border:1px solid #FF4F00;border-radius:12px;padding:14px 16px;z-index:9999;box-shadow:0 12px 34px rgba(0,0,0,0.45);">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:7px;gap:10px;">
    <span style="font-family:'Geist Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#FF4F00;font-weight:700;">Try this &middot; demo</span>
    <button onclick="this.closest('#demoHint').remove()" style="background:transparent;border:none;color:#9aa6b6;cursor:pointer;font-size:18px;line-height:1;padding:0;">&times;</button>
  </div>
  <p style="margin:0;font-size:12.5px;line-height:1.55;color:#cfd6da;font-family:'Inter Tight',sans-serif,system-ui;">Change "Color by" to <b>Electronegativity</b> to see the trend sweep across the table. Then click any element — its orbital filling diagram appears with Hund’s rule.</p>
</div>

</BaseLayout>
