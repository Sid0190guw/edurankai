---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Periodic table · Virtual Labs · AquinTutor" description="Interactive periodic table — all 118 elements with electron configuration, orbital diagram, and trends.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; }
  .pt-wrap { max-width: 1400px; margin: 0 auto; padding: 20px 4vw 60px; }
  .pt-top { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 14px; margin-bottom: 18px; }
  .pt-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #f87171; font-weight: 700; }
  .pt-title { font-family: 'Cormorant Garamond', serif; font-size: 36px; font-weight: 600; margin: 4px 0 0; letter-spacing: -0.02em; }
  .pt-title em { color: #f87171; font-style: italic; font-weight: 500; }
  .pt-grid { display: grid; grid-template-columns: minmax(0,1fr) 320px; gap: 18px; }
  @media (max-width: 1100px) { .pt-grid { grid-template-columns: 1fr; } }
  .pt-table { display: grid; grid-template-columns: repeat(18, 1fr); gap: 2px; }
  .pt-cell { background: #11131a; border: 1px solid #2a2a35; border-radius: 4px; aspect-ratio: 1; padding: 4px; display: flex; flex-direction: column; justify-content: space-between; cursor: pointer; transition: all 0.12s; }
  .pt-cell:hover { transform: scale(1.1); z-index: 10; box-shadow: 0 4px 16px rgba(0,0,0,0.5); }
  .pt-cell.active { outline: 2px solid #f87171; outline-offset: 1px; }
  .pt-num { font-family: 'Geist Mono', monospace; font-size: 8px; color: #9aa6b6; }
  .pt-sym { font-family: 'Cormorant Garamond', serif; font-size: 16px; font-weight: 700; color: #fff; text-align: center; line-height: 1; }
  .pt-mass { font-family: 'Geist Mono', monospace; font-size: 7px; color: #9aa6b6; text-align: center; }
  .pt-empty { background: transparent; border: none; cursor: default; }
  .pt-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 18px; }
  .pt-panel h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #f87171; font-weight: 700; margin: 0 0 12px; }
  .pt-cat-legend { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; font-family: 'Geist Mono', monospace; font-size: 10px; margin-bottom: 10px; }
  .pt-cat-legend > div { display: flex; align-items: center; gap: 5px; color: #cfd6da; }
  .pt-cat-legend > div::before { content: ''; width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; }

  .pt-cat-alkali::before, .pt-cell.cat-alkali { background: #fb923c; }
  .pt-cat-alkaline::before, .pt-cell.cat-alkaline { background: #fbbf24; }
  .pt-cat-transition::before, .pt-cell.cat-transition { background: #a78bfa; }
  .pt-cat-post::before, .pt-cell.cat-post { background: #67e8f9; }
  .pt-cat-metalloid::before, .pt-cell.cat-metalloid { background: #14b8a6; }
  .pt-cat-nonmetal::before, .pt-cell.cat-nonmetal { background: #86efac; }
  .pt-cat-halogen::before, .pt-cell.cat-halogen { background: #f87171; }
  .pt-cat-noble::before, .pt-cell.cat-noble { background: #d946ef; }
  .pt-cat-lanthanide::before, .pt-cell.cat-lanthanide { background: #ec4899; }
  .pt-cat-actinide::before, .pt-cell.cat-actinide { background: #fb7185; }
  .pt-cell { color: #fff !important; }
  .pt-detail-sym { font-family: 'Cormorant Garamond', serif; font-size: 64px; font-weight: 600; color: #fff; line-height: 1; }
  .pt-detail-name { font-family: 'Cormorant Garamond', serif; font-size: 22px; color: #fff; margin: 6px 0 0; }
  .pt-detail-row { display: grid; grid-template-columns: 1fr auto; padding: 6px 0; border-bottom: 1px solid #1a1a25; font-family: 'Geist Mono', monospace; font-size: 11.5px; }
  .pt-detail-row:last-child { border-bottom: none; }
  .pt-detail-l { color: #9aa6b6; }
  .pt-detail-v { color: #f87171; font-weight: 700; text-align: right; }
</style>

<main class="pt-wrap">
  <div class="pt-top">
    <div>
      <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#f87171;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
      <p class="pt-eye" style="margin-top:10px;">Chemistry · Periodic trends</p>
      <h1 class="pt-title">All 118 <em>elements</em>.</h1>
    </div>
  </div>

  <div class="pt-grid">
    <section>
      <div id="ptable" class="pt-table"></div>
      <div class="pt-panel" style="margin-top:14px;">
        <h3>Legend</h3>
        <div class="pt-cat-legend">
          <div class="pt-cat-alkali">Alkali</div><div class="pt-cat-alkaline">Alkaline earth</div>
          <div class="pt-cat-transition">Transition</div><div class="pt-cat-post">Post-transition</div>
          <div class="pt-cat-metalloid">Metalloid</div><div class="pt-cat-nonmetal">Non-metal</div>
          <div class="pt-cat-halogen">Halogen</div><div class="pt-cat-noble">Noble gas</div>
          <div class="pt-cat-lanthanide">Lanthanide</div><div class="pt-cat-actinide">Actinide</div>
        </div>
      </div>
    </section>

    <aside>
      <div class="pt-panel">
        <h3>Selected element</h3>
        <div id="detail">
          <p style="font-size:13px;color:#9aa6b6;line-height:1.6;">Click any element on the table to see its details.</p>
        </div>
      </div>
    </aside>
  </div>
</main>

