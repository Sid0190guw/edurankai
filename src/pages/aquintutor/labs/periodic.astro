import BaseLayout from '@/layouts/BaseLayout.astro';
// Interactive periodic table — all 118 elements, category-coloured, glow on
// hover, click for detail. Rendered server-side so scoped styles apply; only
// interaction is client-side. High-graphics tile grid, no libraries.
type El = { z: number; s: string; n: string; c: string; col: number; row: number };
const E = (z: number, s: string, n: string, c: string, col: number, row: number): El => ({ z, s, n, c, col, row });
const ELEMENTS: El[] = [
  E(1,'H','Hydrogen','nonmetal',1,1), E(2,'He','Helium','noble',18,1),
