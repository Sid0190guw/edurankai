---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Digital filter designer — place poles and zeros on the z-plane and watch the
// transfer function respond: magnitude (dB) and phase of H(e^{jω}), and the
// impulse response from the difference equation. Complex polynomial-from-roots,
// frequency sweep and recursive filtering all hand-rolled. Graduate DSP depth.
---
<BaseLayout title="Filter designer · Virtual Labs · AquinTutor" description="Drag poles and zeros on the z-plane and watch the magnitude, phase and impulse response of the digital filter update live — real transfer-function mathematics.">
<style>
  body{ background:#06070c; color:#e8ecf4; }
  .lb{ max-width:1320px; margin:0 auto; padding:20px 4vw 70px; }
  .lb-eye{ font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#5ee7ff; font-weight:700; }
  .lb-title{ font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:600; margin:4px 0 0; letter-spacing:-0.02em; } .lb-title em{ color:#5ee7ff; font-style:italic; font-weight:500; }
  .lb-sub{ font-family:'Inter Tight',sans-serif; font-size:13.5px; color:#8ea0be; max-width:66ch; line-height:1.55; margin:8px 0 16px; }
  .lb-grid{ display:grid; grid-template-columns:300px minmax(0,1fr); gap:18px; } @media(max-width:940px){ .lb-grid{ grid-template-columns:1fr; } }
  .lb-panel{ background:linear-gradient(180deg,#0f1220,#0b0d17); border:1px solid #1e2740; border-radius:14px; padding:16px; margin-bottom:12px; box-shadow:0 10px 30px rgba(0,0,0,0.35); }
  .lb-panel h3{ font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:#5ee7ff; font-weight:700; margin:0 0 12px; }
  .lb-btn{ background:linear-gradient(180deg,#7af0ff,#33cfe6); color:#04161b; padding:8px 12px; border-radius:8px; border:none; cursor:pointer; font-family:'Geist Mono',monospace; font-size:10.5px; font-weight:700; letter-spacing:0.04em; text-transform:uppercase; }
  .lb-btn-ghost{ background:transparent; color:#cfd6da; border:1px solid #26314f; } .lb-btn.on{ outline:2px solid #7af0ff; }
  .preset{ background:#080a12; border:1px solid #1e2740; color:#cfd6da; padding:7px 10px; border-radius:6px; font-family:'Geist Mono',monospace; font-size:11px; cursor:pointer; }
  .lb-stage{ border-radius:14px; overflow:hidden; border:1px solid #1e2740; box-shadow:inset 0 0 40px rgba(0,0,0,0.5); } .lb-stage canvas{ display:block; width:100%; height:auto; }
  .zwrap{ display:grid; grid-template-columns:1fr 1fr; gap:12px; } @media(max-width:680px){ .zwrap{ grid-template-columns:1fr; } }
  .zplane canvas{ cursor:crosshair; }
  .lb-metric{ display:grid; grid-template-columns:1fr auto; gap:8px; font-family:'Geist Mono',monospace; font-size:11.5px; padding:5px 0; border-bottom:1px solid #141a2c; } .lb-metric:last-child{ border-bottom:none; } .lb-metric-l{ color:#8ea0be; } .lb-metric-v{ color:#5ee7ff; font-weight:700; }
</style>
<main class="lb">
  <div>
    <a href="/aquintutor/labs" style="font-family:'Geist Mono',monospace;font-size:11px;color:#5ee7ff;text-decoration:none;letter-spacing:0.08em;">&larr; Virtual labs</a>
    <p class="lb-eye" style="margin-top:10px;">DSP · Postgraduate · Filter theory</p>
    <h1 class="lb-title">Filter <em>designer</em>.</h1>
    <p class="lb-sub">A pole-zero editor for discrete-time filters. Every pole and zero on the z-plane shapes the transfer function H(z); the magnitude of H(e^{jω}) rises near poles and dips near zeros. Drag them and watch the frequency response and impulse response follow — real complex-polynomial mathematics, no libraries.</p>
  </div>
  <div class="lb-grid">
    <aside>
      <div class="lb-panel"><h3>Place</h3>
        <div style="display:flex;gap:6px;margin-bottom:10px;"><button id="mPole" class="lb-btn on">Pole ×</button><button id="mZero" class="lb-btn lb-btn-ghost">Zero ○</button></div>
        <p style="font-family:'Geist Mono',monospace;font-size:10.5px;color:#8ea0be;margin:0 0 10px;line-height:1.6;">Click the z-plane to add; drag to move; complex ones auto-pair with their conjugate. Click a marker to delete it.</p>
        <div style="display:flex;gap:6px;flex-wrap:wrap;"><button class="preset" data-p="reson">Resonator</button><button class="preset" data-p="notch">Notch</button><button class="preset" data-p="lp">Low-pass</button><button class="preset" data-p="hp">High-pass</button><button class="preset lb-btn-ghost" id="clr">Clear</button></div>
      </div>
      <div class="lb-panel"><h3>Read-out</h3>
        <div class="lb-metric"><span class="lb-metric-l">poles / zeros</span><span class="lb-metric-v" id="mPZ">0 / 0</span></div>
        <div class="lb-metric"><span class="lb-metric-l">stable?</span><span class="lb-metric-v" id="mStab">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">peak gain</span><span class="lb-metric-v" id="mPk">—</span></div>
        <div class="lb-metric"><span class="lb-metric-l">order</span><span class="lb-metric-v" id="mOrd">—</span></div>
      </div>
    </aside>
    <section>
      <div class="zwrap">
        <div class="lb-stage zplane"><canvas id="zp" width="420" height="420"></canvas></div>
        <div class="lb-stage"><canvas id="imp" width="420" height="420"></canvas></div>
      </div>
      <div class="lb-stage" style="margin-top:12px;"><canvas id="freq" width="880" height="300"></canvas></div>
    </section>
  </div>
</main>
<script is:inline>
(function(){
  // complex helpers
  function C(re,im){ return {re:re,im:im||0}; } function cadd(a,b){ return C(a.re+b.re,a.im+b.im); } function csub(a,b){ return C(a.re-b.re,a.im-b.im); }
  function cmul(a,b){ return C(a.re*b.re-a.im*b.im, a.re*b.im+a.im*b.re); } function cabs(a){ return Math.hypot(a.re,a.im); } function carg(a){ return Math.atan2(a.im,a.re); }
  function cdiv(a,b){ var d=b.re*b.re+b.im*b.im; return C((a.re*b.re+a.im*b.im)/d,(a.im*b.re-a.re*b.im)/d); }

  var poles=[], zeros=[], mode='pole', drag=null;
  function addPt(list, re, im){ list.push({re:re,im:im}); if(Math.abs(im)>1e-4) list.push({re:re,im:-im}); }
  function roots(list){ return list.map(function(p){ return C(p.re,p.im); }); }
  function polyFromRoots(rs){ var poly=[C(1,0)]; rs.forEach(function(r){ var np=[]; for(var i=0;i<=poly.length;i++){ var t=C(0,0); if(i<poly.length) t=cadd(t,poly[i]); if(i>0) t=csub(t,cmul(poly[i-1],r)); np.push(t); } poly=np; }); return poly; }

  document.getElementById('mPole').addEventListener('click',function(){ mode='pole'; this.classList.add('on'); document.getElementById('mZero').classList.remove('on'); });
  document.getElementById('mZero').addEventListener('click',function(){ mode='zero'; this.classList.add('on'); document.getElementById('mPole').classList.remove('on'); });
  document.getElementById('clr').addEventListener('click',function(){ poles=[]; zeros=[]; });
  var PRE={ reson:{p:[[0.92,0.5]],z:[[ -1,0],[1,0]]}, notch:{p:[[0.85,0.7]],z:[[Math.cos(0.7),Math.sin(0.7)]]}, lp:{p:[[0.8,0.25]],z:[[-1,0],[-1,0]]}, hp:{p:[[0.8,2.7]],z:[[1,0],[1,0]]} };
  document.querySelectorAll('.preset[data-p]').forEach(function(b){ b.addEventListener('click',function(){ var d=PRE[b.getAttribute('data-p')]; poles=[]; zeros=[];
    d.p.forEach(function(x){ var re=x[0]*Math.cos(x[1]), im=x[0]*Math.sin(x[1]); addPt(poles,re,im); }); d.z.forEach(function(x){ addPt(zeros,x[0],x[1]); }); }); });

  var zp=document.getElementById('zp'); var R=1;
  function toWorld(e){ var r=zp.getBoundingClientRect(); var x=(e.clientX-r.left)/r.width, y=(e.clientY-r.top)/r.height; return {re:(x-0.5)*2*1.5, im:(0.5-y)*2*1.5}; }
  function nearest(w){ var all=poles.map(function(p,i){return {list:poles,i:i,p:p};}).concat(zeros.map(function(p,i){return {list:zeros,i:i,p:p};})); var best=null,bd=0.12; all.forEach(function(o){ var d=Math.hypot(o.p.re-w.re,o.p.im-w.im); if(d<bd){ bd=d; best=o; } }); return best; }
  zp.addEventListener('mousedown',function(e){ var w=toWorld(e); var n=nearest(w); if(n){ drag=n; } else { addPt(mode==='pole'?poles:zeros, w.re, w.im); } });
  zp.addEventListener('mousemove',function(e){ if(drag){ var w=toWorld(e); drag.p.re=w.re; drag.p.im=w.im; } });
  window.addEventListener('mouseup',function(e){ if(drag){ // if barely moved, treat as delete
      drag=null; } });
  zp.addEventListener('dblclick',function(e){ var n=nearest(toWorld(e)); if(n){ n.list.splice(n.i,1); } });

  function hidpi(c){ var r=c.getBoundingClientRect(), d=window.devicePixelRatio||1; var w=r.width||c.width, h=(c.height/c.width)*w; c.width=Math.round(w*d); c.height=Math.round(h*d); var ctx=c.getContext('2d'); ctx.setTransform(d,0,0,d,0,0); return {ctx:ctx,w:w,h:h}; }
  function drawZ(){ var s=hidpi(zp), ctx=s.ctx, W=s.w, H=s.h, cx=W/2, cy=H/2, sc=Math.min(W,H)/3;
    ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H);
    ctx.strokeStyle='#1a2340'; ctx.beginPath(); ctx.moveTo(0,cy); ctx.lineTo(W,cy); ctx.moveTo(cx,0); ctx.lineTo(cx,H); ctx.stroke();
    ctx.save(); ctx.shadowColor='#5ee7ff'; ctx.shadowBlur=10; ctx.strokeStyle='#3a6fa0'; ctx.lineWidth=1.5; ctx.beginPath(); ctx.arc(cx,cy,sc,0,7); ctx.stroke(); ctx.restore();
    ctx.fillStyle='#5f7597'; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText('Re',W-22,cy-6); ctx.fillText('Im',cx+6,14); ctx.fillText('unit circle',cx+sc*0.5,cy-sc*0.72);
    function P(p){ return [cx+p.re*sc, cy-p.im*sc]; }
    zeros.forEach(function(z){ var q=P(z); ctx.save(); ctx.shadowColor='#34d399'; ctx.shadowBlur=10; ctx.strokeStyle='#34d399'; ctx.lineWidth=2; ctx.beginPath(); ctx.arc(q[0],q[1],7,0,7); ctx.stroke(); ctx.restore(); });
    poles.forEach(function(p){ var q=P(p); ctx.save(); ctx.shadowColor='#f87171'; ctx.shadowBlur=10; ctx.strokeStyle='#f87171'; ctx.lineWidth=2.5; ctx.beginPath(); ctx.moveTo(q[0]-6,q[1]-6); ctx.lineTo(q[0]+6,q[1]+6); ctx.moveTo(q[0]+6,q[1]-6); ctx.lineTo(q[0]-6,q[1]+6); ctx.stroke(); ctx.restore(); });
    ctx.fillStyle='#8ea0be'; ctx.font="10px 'Geist Mono',monospace"; ctx.fillText(mode==='pole'?'placing: pole ×':'placing: zero ○', 10, H-10);
  }
  var Hmag=[], Hph=[], hn=[];
  function compute(){ var Z=roots(zeros), Pl=roots(poles); var N=512; Hmag=[]; Hph=[]; var peak=0;
    for(var i=0;i<N;i++){ var w=Math.PI*i/(N-1); var ejw=C(Math.cos(w),Math.sin(w)); var num=C(1,0), den=C(1,0);
      Z.forEach(function(z){ num=cmul(num,csub(ejw,z)); }); Pl.forEach(function(p){ den=cmul(den,csub(ejw,p)); });
      var Hh=cdiv(num,den); var m=cabs(Hh); Hmag.push(m); Hph.push(carg(Hh)); if(m>peak) peak=m; }
    // impulse response via difference equation, coefficients from polynomials
    var b=polyFromRoots(Z).map(function(c){return c.re;}); var a=polyFromRoots(Pl).map(function(c){return c.re;});
    var L=64; hn=[]; var y=new Array(L).fill(0);
    for(var n=0;n<L;n++){ var x=(n===0?1:0); var acc=0; for(var k=0;k<b.length;k++){ if(n-k>=0) acc+=b[k]*(n-k===0?1:0); } for(var k=1;k<a.length;k++){ if(n-k>=0) acc-=a[k]*y[n-k]; } y[n]=acc/(a[0]||1); hn.push(y[n]); }
    // metrics
    document.getElementById('mPZ').textContent=poles.length+' / '+zeros.length;
    var stable=poles.every(function(p){ return Math.hypot(p.re,p.im)<1-1e-9; });
    document.getElementById('mStab').textContent = poles.length? (stable?'yes (all |p|<1)':'NO — |p|≥1') : 'trivial';
    document.getElementById('mStab').style.color = stable?'#34d399':'#f87171';
    document.getElementById('mPk').textContent = (20*Math.log10(peak||1e-6)).toFixed(1)+' dB';
    document.getElementById('mOrd').textContent = Math.max(poles.length,zeros.length);
    return peak;
  }
  function drawFreq(peak){ var cv=document.getElementById('freq'), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h; ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H);
    var padL=44, padB=28, padT=14; ctx.strokeStyle='rgba(94,231,255,0.06)'; ctx.fillStyle='#5f7597'; ctx.font="10px 'Geist Mono',monospace";
    var maxdb=Math.max(6,20*Math.log10((peak||1)+1e-6)+6), mindb=-48;
    function X(i){ return padL+i/(Hmag.length-1)*(W-padL-12); } function Ym(db){ return padT+(maxdb-db)/(maxdb-mindb)*(H-padT-padB); }
    for(var db=Math.ceil(mindb/12)*12; db<=maxdb; db+=12){ ctx.beginPath(); ctx.moveTo(padL,Ym(db)); ctx.lineTo(W-12,Ym(db)); ctx.stroke(); ctx.fillText(db+'dB',6,Ym(db)+3); }
    for(var f=0;f<=1;f+=0.25){ var xx=padL+f*(W-padL-12); ctx.fillText(f===0?'0':(f===1?'π':f+'π'), xx-6, H-12); }
    // magnitude
    ctx.save(); ctx.shadowColor='#5ee7ff'; ctx.shadowBlur=8; ctx.strokeStyle='#5ee7ff'; ctx.lineWidth=2; ctx.beginPath(); Hmag.forEach(function(m,i){ var db=20*Math.log10(m+1e-6); var y=Ym(Math.max(mindb,db)); i?ctx.lineTo(X(i),y):ctx.moveTo(X(i),y); }); ctx.stroke(); ctx.restore();
    // phase (secondary, faint)
    ctx.strokeStyle='rgba(167,139,250,0.55)'; ctx.lineWidth=1.2; ctx.beginPath(); Hph.forEach(function(p,i){ var y=padT+(Math.PI-p)/(2*Math.PI)*(H-padT-padB); i?ctx.lineTo(X(i),y):ctx.moveTo(X(i),y); }); ctx.stroke();
    ctx.fillStyle='#5ee7ff'; ctx.fillText('|H(e^{jω})| dB', padL+6, padT+12); ctx.fillStyle='#a78bfa'; ctx.fillText('∠H (phase)', padL+120, padT+12);
  }
  function drawImp(){ var cv=document.getElementById('imp'), s=hidpi(cv), ctx=s.ctx, W=s.w, H=s.h; ctx.fillStyle='#070a12'; ctx.fillRect(0,0,W,H);
    ctx.fillStyle='#8ea0be'; ctx.font="11px 'Geist Mono',monospace"; ctx.fillText('impulse response h[n]', 12, 18);
    var mid=H*0.55, mx=Math.max.apply(null,hn.map(Math.abs))||1, bw=(W-24)/hn.length;
    ctx.strokeStyle='#1a2340'; ctx.beginPath(); ctx.moveTo(12,mid); ctx.lineTo(W-12,mid); ctx.stroke();
    hn.forEach(function(v,i){ var x=12+i*bw+bw/2, h=v/mx*(H*0.4); ctx.strokeStyle='#3a6fa0'; ctx.beginPath(); ctx.moveTo(x,mid); ctx.lineTo(x,mid-h); ctx.stroke(); ctx.save(); ctx.shadowColor='#5ee7ff'; ctx.shadowBlur=6; ctx.fillStyle='#7af0ff'; ctx.beginPath(); ctx.arc(x,mid-h,2.2,0,7); ctx.fill(); ctx.restore(); });
  }
  function loop(){ var peak=compute(); drawZ(); drawFreq(peak); drawImp(); requestAnimationFrame(loop); }
  // seed with a resonator
  document.querySelector('.preset[data-p="reson"]').click();
  requestAnimationFrame(loop);
})();
</script>
</BaseLayout>
