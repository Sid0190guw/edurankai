---
// /aquintutor/vod — the student VOD library (Prompt AP1b). Lists published recordings the learner can
// open; each replays the spec timeline at their tier. Server-rendered, zero client JS.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { can } from '@/lib/rbac';
import { vodService, labelAllows } from '@/lib/vod';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/vod');
const faculty = (await can(user, 'read', { type: 'AnimationObject' })).allow;
const all = await vodService().list(true).catch(() => []);   // published only for the library
const visible = all.filter((v: any) => labelAllows(v.labels || [], { enrolled: true, examMode: false }));
function mins(ms: number) { const s = Math.round(ms / 1000); return Math.floor(s / 60) + 'm ' + (s % 60) + 's'; }
---
<AquintutorLayout title="Recordings">
  <main style="max-width:820px;margin:0 auto;padding:40px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Library</p>
    <h1 style="font-family:Fraunces,serif;font-size:30px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 6px;">Recordings &amp; replays</h1>
    <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#6b6455;margin:0 0 24px;">Watch past broadcasts and classes on demand. The animations re-render live on your device — scrub, resume, and jump by chapter.</p>
    {visible.length ? (
      <div style="display:flex;flex-direction:column;gap:10px;">
        {visible.map((v: any) => (
          <a href={'/aquintutor/vod/' + v.id} style="text-decoration:none;display:flex;justify-content:space-between;align-items:center;background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:12px;padding:14px 18px;">
            <span style="font-family:Fraunces,serif;font-size:17px;color:var(--ink,#1a1712);">{v.title}</span>
            <span style="font-family:'Geist Mono',monospace;font-size:12px;color:#8a8378;">{mins(v.durationMs)} · {v.events} steps</span>
          </a>
        ))}
      </div>
    ) : (
      <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#8a8378;">No recordings published yet. When your teacher saves a broadcast, it appears here.</p>
    )}
  </main>
</AquintutorLayout>
