---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

const initialTheta = 60;
const initialPhi = 45;

const moreLabs = [
  { title: 'Entanglement explorer',    code: 'QT-407 L2', desc: 'Two-qubit Bell states; concurrence and entanglement entropy.', color: '#5b4a92' },
  { title: "Grover's search · 4 qubit", code: 'QT-407 L3', desc: 'Amplitude amplification over a 16-element search space.', color: '#5b4a92' },
  { title: 'QFT visualizer',           code: 'QT-407 L4', desc: 'The Quantum Fourier Transform unrolled on the Bloch sphere.', color: '#5b4a92' },
  { title: "Shor's algorithm walk",    code: 'QT-407 L5', desc: 'Period finding via QFT, with classical post-processing.', color: '#5b4a92' },
];

const otherLabs = [
  { title: 'Robotic arm kinematics',   code: 'RB-211 L1', desc: 'Inverse kinematics for a 6-DOF arm; jog the end-effector.', color: '#946322' },
  { title: 'Transformer attention map',code: 'AI-512 L4', desc: 'Visualise QKV attention heads across BERT layers.', color: '#2b577e' },
  { title: 'Materials phase diagram',  code: 'PH-204 L2', desc: 'Equation of state, supercritical fluids, triple point.', color: '#a8472c' },
  { title: 'Surgical simulator',       code: 'MD-301 L1', desc: 'Laparoscopic appendectomy on a virtual cadaver.', color: '#a04330' },
];

const gates = ['X','Y','Z','H','S','T','Rx','Ry'];
const history = [
  { label: '|0⟩ initial', kind: 'state' },
  { label: 'H · Hadamard', kind: 'gate' },
  { label: 'Rx(π/3)', kind: 'gate' },
  { label: 'Z', kind: 'gate' },
];
---
<AquintutorLayout title="Virtual lab" description="Interactive virtual labs - Bloch sphere playground for quantum mechanics, transformer attention maps, kinematics, surgical simulator.">

  <!-- BREADCRUMB -->
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1320px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a>
      <span style="margin:0 8px;">/</span>
      <a href="/aquintutor/dashboard" style="color:var(--ink-500); text-decoration:none;">DASHBOARD</a>
      <span style="margin:0 8px;">/</span>
      <span style="color:#5b4a92; font-weight:600;">VIRTUAL LAB &middot; QT-407</span>
    </div>
  </div>

  <!-- PAGE HEADER -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1320px; margin:0 auto; padding:32px 28px 28px;">
      <div style="display:flex; align-items:start; justify-content:space-between; gap:24px; flex-wrap:wrap;">
        <div>
          <div style="display:inline-flex; align-items:center; gap:8px; padding:4px 12px; background:rgba(91,74,146,0.08); border:1px solid rgba(91,74,146,0.3); border-radius:999px; color:#5b4a92; font-family:'JetBrains Mono',monospace; font-size:10.5px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin-bottom:14px;">QUANTUM LAB &middot; QT-407</div>
          <h1 class="font-display" style="font-size:clamp(2rem, 4.5vw, 3.25rem); line-height:1.05; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--ink);">Bloch playground</h1>
          <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.05rem, 1.4vw, 1.25rem); line-height:1.5; color:var(--ink-500); margin:14px 0 0; max-width:44rem;">Drag the sliders to manipulate |ψ⟩. Save state, fork a copy, or hand it to Aquin for a walkthrough. The state vector updates in real time and any history step can be re-run.</p>
        </div>
        <div style="display:flex; gap:8px; flex-wrap:wrap;">
          <button type="button" style="background:transparent; color:var(--ink); padding:10px 18px; border:1px solid var(--ink); border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13.5px; font-weight:600; cursor:pointer;">Fork lab</button>
          <button type="button" style="background:transparent; color:#3d6b76; padding:10px 18px; border:1px solid #3d6b76; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13.5px; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:7px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M8 11s.5-2 4-2 4 2 4 2"/></svg>
            Ask Aquin
          </button>
          <button type="button" style="background:var(--rust); color:#fff; padding:10px 18px; border:1px solid var(--rust); border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13.5px; font-weight:600; cursor:pointer;">Save state</button>
        </div>
      </div>
    </div>
  </section>

  <!-- LAB STAGE + RIGHT RAIL -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1320px; margin:0 auto; padding:24px 28px;">
      <div style="display:grid; grid-template-columns:1fr; gap:18px;" class="lab-grid">

        <!-- BLOCH SPHERE STAGE -->
        <div style="background:#0b0d10; border:1px solid #1a1f28; border-radius:14px; padding:0; min-height:520px; position:relative; overflow:hidden;">
          <!-- Stage label -->
          <div style="position:absolute; top:14px; left:18px; z-index:2; display:flex; align-items:center; gap:10px;">
            <span style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.18em; text-transform:uppercase; color:rgba(244,241,234,0.55); font-weight:600;">Bloch sphere &middot; |ψ⟩</span>
            <span style="display:inline-flex; align-items:center; gap:5px; padding:3px 9px; background:rgba(167,139,250,0.10); border:1px solid rgba(167,139,250,0.35); border-radius:999px; color:#a78bfa; font-family:'JetBrains Mono',monospace; font-size:9.5px; letter-spacing:0.14em; text-transform:uppercase; font-weight:600;">interactive</span>
          </div>

          <!-- The SVG sphere; recalculated by JS -->
          <svg id="blochSvg" width="100%" height="100%" viewBox="0 0 720 520" preserveAspectRatio="xMidYMid meet" style="display:block;">
            <defs>
              <radialGradient id="sphere-fill" cx="50%" cy="40%" r="60%">
                <stop offset="0" stop-color="rgba(167,139,250,0.22)"/>
                <stop offset="1" stop-color="rgba(167,139,250,0.02)"/>
              </radialGradient>
              <radialGradient id="halo-q" cx="50%" cy="50%" r="50%">
                <stop offset="0" stop-color="rgba(167,139,250,0.4)"/>
                <stop offset="1" stop-color="rgba(167,139,250,0)"/>
              </radialGradient>
            </defs>
            <!-- ambient halo -->
            <circle cx="360" cy="260" r="240" fill="url(#halo-q)" opacity="0.4"/>
            <!-- sphere shell -->
            <ellipse cx="360" cy="260" rx="200" ry="200" fill="url(#sphere-fill)" stroke="rgba(167,139,250,0.42)"/>
            <!-- equator + meridian dashed -->
            <ellipse cx="360" cy="260" rx="200" ry="64" fill="none" stroke="rgba(167,139,250,0.5)" stroke-dasharray="4 3"/>
            <ellipse cx="360" cy="260" rx="64" ry="200" fill="none" stroke="rgba(167,139,250,0.35)" stroke-dasharray="4 3"/>
            <!-- axes -->
            <line x1="130" y1="260" x2="590" y2="260" stroke="rgba(255,255,255,0.2)"/>
            <line x1="360" y1="30" x2="360" y2="490" stroke="rgba(255,255,255,0.2)"/>
            <text x="600" y="265" font-family="JetBrains Mono" font-size="12" fill="#9a8e76">X &middot; |+&rang;</text>
            <text x="370" y="28" font-family="JetBrains Mono" font-size="12" fill="#9a8e76">Z &middot; |0&rang;</text>
            <text x="370" y="505" font-family="JetBrains Mono" font-size="12" fill="#9a8e76">|1&rang;</text>
            <!-- state vector (placeholders; JS will update) -->
            <line id="blochVec" x1="360" y1="260" x2="540" y2="180" stroke="#a78bfa" stroke-width="3"/>
            <circle id="blochTip" cx="540" cy="180" r="10" fill="#a78bfa"/>
            <circle id="blochRing" cx="540" cy="180" r="22" fill="none" stroke="#a78bfa" stroke-width="1.2" opacity="0.55"/>
            <text id="blochLabel" x="560" y="172" font-family="JetBrains Mono" font-size="12" fill="#a78bfa">|ψ&rang;</text>
          </svg>

          <!-- Tool strip -->
          <div style="position:absolute; bottom:14px; left:50%; transform:translateX(-50%); display:flex; gap:4px; padding:6px; background:rgba(0,0,0,0.65); border:1px solid rgba(167,139,250,0.2); border-radius:999px; backdrop-filter:blur(8px);">
            <button id="btnReset" type="button" style="padding:6px 14px; background:transparent; border:none; border-radius:999px; color:#c8c3b8; font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.1em; cursor:pointer;">&#x21bb; reset</button>
            <button id="btnSnap" type="button" style="padding:6px 14px; background:transparent; border:none; border-radius:999px; color:#c8c3b8; font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.1em; cursor:pointer;">&#x2913; snapshot</button>
            <button id="btnRun" type="button" style="padding:6px 14px; background:transparent; border:none; border-radius:999px; color:#a78bfa; font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.1em; cursor:pointer; font-weight:600;">&#x25b7; run circuit</button>
            <button id="btnExport" type="button" style="padding:6px 14px; background:transparent; border:none; border-radius:999px; color:#c8c3b8; font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.1em; cursor:pointer;">&#x2197; export</button>
          </div>
        </div>

        <!-- RIGHT RAIL -->
        <div style="display:flex; flex-direction:column; gap:14px;">
          <!-- Parameters -->
          <div style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:18px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 12px;">Parameters</p>

            <div style="margin-bottom:14px;">
              <div style="display:flex; justify-content:space-between; margin-bottom:6px;">
                <span style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-500);">&theta; &middot; polar</span>
                <span id="thetaVal" style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#5b4a92; font-weight:600;">{initialTheta}&deg;</span>
              </div>
              <input id="sliderTheta" type="range" min="0" max="180" value={initialTheta} style="width:100%; accent-color:#5b4a92; cursor:pointer;" />
            </div>

            <div>
              <div style="display:flex; justify-content:space-between; margin-bottom:6px;">
                <span style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-500);">&phi; &middot; azimuth</span>
                <span id="phiVal" style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#5b4a92; font-weight:600;">{initialPhi}&deg;</span>
              </div>
              <input id="sliderPhi" type="range" min="0" max="360" value={initialPhi} style="width:100%; accent-color:#5b4a92; cursor:pointer;" />
            </div>
          </div>

          <!-- State readout -->
          <div style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:18px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 12px;">State vector</p>
            <div style="font-family:'JetBrains Mono',monospace; font-size:12.5px; color:var(--ink); line-height:2;">
              <div>|&psi;&rang; = &alpha;|0&rang; + &beta;|1&rang;</div>
              <div style="color:var(--ink-500);">&alpha; = <span id="alphaR" style="color:#5b4a92;">0.500</span></div>
              <div style="color:var(--ink-500);">&beta; = <span id="betaR" style="color:#5b4a92;">0.612</span> + <span id="betaI" style="color:#5b4a92;">0.612</span><i>i</i></div>
              <div style="color:var(--ink-500); font-size:10.5px; margin-top:4px;">P(|0&rang;) = <span id="prob0">0.250</span> &middot; P(|1&rang;) = <span id="prob1">0.750</span></div>
            </div>
          </div>

          <!-- Apply gate -->
          <div style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:18px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 12px;">Apply gate</p>
            <div style="display:grid; grid-template-columns:repeat(4, 1fr); gap:6px;">
              {gates.map((g) => (
                <button type="button" class="gate-btn" data-gate={g} style="padding:10px 0; background:rgba(91,74,146,0.06); border:1px solid rgba(91,74,146,0.3); border-radius:6px; color:#5b4a92; font-family:'JetBrains Mono',monospace; font-size:13px; font-weight:600; cursor:pointer; transition:background 0.12s;">{g}</button>
              ))}
            </div>
          </div>

          <!-- History -->
          <div style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:18px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 10px;">History</p>
            <ol id="historyList" style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:5px;">
              {history.map((h, i) => (
                <li style="padding:7px 10px; background:var(--sand-100); border:1px solid var(--rule); border-radius:4px; font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--ink); display:flex; justify-content:space-between; align-items:center;">
                  <span>{i + 1}. {h.label}</span>
                  <span style="color:var(--ink-500); cursor:pointer;">&#x21b6;</span>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- METHODOLOGY (4-step explainer) -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1320px; margin:0 auto; padding:56px 28px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:#5b4a92; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">How the lab works</p>
      <h2 class="font-display" style="font-size:clamp(1.65rem, 3vw, 2.25rem); font-weight:500; line-height:1.12; letter-spacing:-0.015em; margin:0 0 32px; color:var(--ink); max-width:38rem;">
        Manipulate, observe,<br/>
        <span style="font-style:italic; font-weight:300; color:var(--ink-500);">save, hand off.</span>
      </h2>

      <div style="display:grid; grid-template-columns:1fr; gap:18px;" class="how-grid">
        {[
          { n: '01', t: 'Set the state', b: 'Drag the polar and azimuthal sliders to put |ψ⟩ anywhere on the Bloch sphere. The state-vector panel updates in real time with α, β components and measurement probabilities.', glyph: 'M12 2v20M2 12h20' },
          { n: '02', t: 'Apply a gate', b: 'Click any gate (Pauli X/Y/Z, Hadamard, S, T, parametric Rx/Ry) to transform the state. The trajectory animates and the history log records every step.', glyph: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z' },
          { n: '03', t: 'Read the math', b: 'Every panel shows the underlying linear algebra - amplitudes, complex components, measurement probabilities. No hidden state, no black box.', glyph: 'M4 4h12a4 4 0 014 4v12H4V4zM8 9h8M8 13h6M8 17h4' },
          { n: '04', t: 'Save or ask Aquin', b: 'Snapshot the state to your portfolio, fork the lab to experiment without losing the original, or open it inside the Aquin tutor for a step-by-step walkthrough.', glyph: 'M21 12c0 4.97-4.03 9-9 9-1.5 0-2.91-.36-4.15-1l-4.85 1 1-4.85A8.96 8.96 0 013 12c0-4.97 4.03-9 9-9s9 4.03 9 9z' },
        ].map((s) => (
          <article style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:24px; display:flex; flex-direction:column; gap:14px;">
            <div style="display:flex; align-items:center; gap:14px;">
              <span style="display:inline-flex; align-items:center; justify-content:center; width:46px; height:46px; border-radius:50%; background:#5b4a9214; color:#5b4a92; border:1px solid rgba(91,74,146,0.3); font-family:'Fraunces',serif; font-weight:500; font-size:1.1rem; letter-spacing:-0.02em;">{s.n}</span>
              <span style="color:#5b4a92;"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d={s.glyph}/></svg></span>
            </div>
            <h3 class="font-display" style="font-size:1.15rem; font-weight:500; margin:0; line-height:1.18; letter-spacing:-0.015em; color:var(--ink);">{s.t}</h3>
            <p style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink-500); line-height:1.6; margin:0;">{s.b}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- MORE LABS IN THIS COURSE -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1320px; margin:0 auto; padding:56px 28px;">
      <div style="display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:14px; margin-bottom:24px;">
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:#5b4a92; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">More labs in this course</p>
          <h2 class="font-display" style="font-size:clamp(1.5rem, 2.5vw, 2rem); font-weight:500; line-height:1.12; letter-spacing:-0.015em; margin:0; color:var(--ink);">Quantum Foundations &middot; QT-407</h2>
        </div>
        <a href="/aquintutor/courses" style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--rust); text-decoration:none; font-weight:500;">All courses &rarr;</a>
      </div>

      <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="lab-gallery">
        {moreLabs.map((l) => (
          <a href="#" style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:18px; text-decoration:none; color:var(--ink); display:flex; flex-direction:column; gap:10px; transition:transform 0.15s, box-shadow 0.15s;" class="lab-card">
            <span style={'display:inline-flex; align-items:center; gap:5px; padding:3px 9px; background:' + l.color + '14; border:1px solid ' + l.color + '40; border-radius:999px; color:' + l.color + '; font-family:JetBrains Mono,monospace; font-size:9.5px; letter-spacing:0.14em; text-transform:uppercase; font-weight:600; align-self:flex-start;'}>{l.code}</span>
            <h3 class="font-display" style="font-size:1.05rem; font-weight:500; margin:0; line-height:1.22; letter-spacing:-0.015em;">{l.title}</h3>
            <p style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500); line-height:1.55; margin:0;">{l.desc}</p>
            <p style="font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--ink-500); letter-spacing:0.12em; margin:auto 0 0;">OPEN LAB &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- OTHER LABS ACROSS THE INSTITUTION -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1320px; margin:0 auto; padding:56px 28px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">Across the institution</p>
      <h2 class="font-display" style="font-size:clamp(1.5rem, 2.5vw, 2rem); font-weight:500; line-height:1.12; letter-spacing:-0.015em; margin:0 0 24px; color:var(--ink); max-width:36rem;">
        Other working labs<br/>
        <span style="font-style:italic; font-weight:300; color:var(--ink-500);">in catalogue today.</span>
      </h2>

      <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="lab-gallery">
        {otherLabs.map((l) => (
          <a href="#" style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:18px; text-decoration:none; color:var(--ink); display:flex; flex-direction:column; gap:10px; transition:transform 0.15s, box-shadow 0.15s;" class="lab-card">
            <span style={'display:inline-flex; align-items:center; gap:5px; padding:3px 9px; background:' + l.color + '14; border:1px solid ' + l.color + '40; border-radius:999px; color:' + l.color + '; font-family:JetBrains Mono,monospace; font-size:9.5px; letter-spacing:0.14em; text-transform:uppercase; font-weight:600; align-self:flex-start;'}>{l.code}</span>
            <h3 class="font-display" style="font-size:1.05rem; font-weight:500; margin:0; line-height:1.22; letter-spacing:-0.015em;">{l.title}</h3>
            <p style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500); line-height:1.55; margin:0;">{l.desc}</p>
            <p style="font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--ink-500); letter-spacing:0.12em; margin:auto 0 0;">OPEN LAB &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- INFRASTRUCTURE NOTE -->
  <section style="background:#0b0d10; color:#f4f1ea; border-bottom:1px solid #1a1f28; position:relative; overflow:hidden;">
    <div aria-hidden="true" style="position:absolute; inset:0; background:repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(167,139,250,0.02) 3px, rgba(167,139,250,0.02) 4px); pointer-events:none;"></div>
    <div style="max-width:1320px; margin:0 auto; padding:56px 28px; position:relative; z-index:1;">
      <p style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.2em; color:#a78bfa; font-weight:600; margin:0 0 14px; text-transform:uppercase;">Infrastructure</p>
      <h2 class="font-display" style="font-size:clamp(1.65rem, 3vw, 2.35rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500; margin:0 0 14px; color:#f4f1ea; max-width:38rem;">Every lab runs in the browser.</h2>
      <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.05rem, 1.4vw, 1.25rem); line-height:1.55; color:#c8c3b8; margin:0 0 24px; max-width:36rem;">No GPU on your side, no software install, no licence cost. The Bloch sphere, the kinematic solver, the transformer attention map - all run client-side on plain JavaScript, with deterministic math, on whatever device you have.</p>
      <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="infra-grid">
        {[
          { l: 'Browser-only', v: 'No install', d: 'WebGL where useful; vanilla SVG everywhere else.' },
          { l: 'Determinism', v: 'Bit-exact', d: 'Same input, same output. Snapshot-comparable.' },
          { l: 'Latency', v: '<16ms', d: 'Every interaction renders in one frame.' },
          { l: 'Privacy', v: 'Client-side', d: 'State never leaves your tab unless you save it.' },
        ].map((s) => (
          <div style="background:#161b22; border:1px solid #21262d; border-radius:12px; padding:18px;">
            <p style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.18em; text-transform:uppercase; color:#a78bfa; font-weight:600; margin:0 0 8px;">{s.l}</p>
            <p class="font-display" style="font-size:1.45rem; font-weight:500; margin:0; line-height:1; color:#f4f1ea; letter-spacing:-0.02em;">{s.v}</p>
            <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:#9a8e76; line-height:1.5; margin:8px 0 0;">{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <style>
    .gate-btn:hover { background: rgba(91,74,146,0.14) !important; }
    .lab-card:hover { transform: translateY(-3px); box-shadow: 0 10px 24px rgba(11,14,20,0.08); }
    @media (min-width: 900px) {
      .lab-grid { grid-template-columns: minmax(0, 1fr) 340px !important; }
      .how-grid { grid-template-columns: repeat(2, 1fr) !important; }
      .lab-gallery { grid-template-columns: repeat(2, 1fr) !important; }
      .infra-grid { grid-template-columns: repeat(4, 1fr) !important; }
    }
    @media (min-width: 1100px) {
      .how-grid { grid-template-columns: repeat(4, 1fr) !important; }
      .lab-gallery { grid-template-columns: repeat(4, 1fr) !important; }
    }
  </style>

  <script is:inline>
    (function() {
      var cx = 360, cy = 260, R = 200;
      var thetaEl = document.getElementById('sliderTheta');
      var phiEl = document.getElementById('sliderPhi');
      var thetaVal = document.getElementById('thetaVal');
      var phiVal = document.getElementById('phiVal');
      var vec = document.getElementById('blochVec');
      var tip = document.getElementById('blochTip');
      var ring = document.getElementById('blochRing');
      var label = document.getElementById('blochLabel');
      var alphaR = document.getElementById('alphaR');
      var betaR = document.getElementById('betaR');
      var betaI = document.getElementById('betaI');
      var prob0 = document.getElementById('prob0');
      var prob1 = document.getElementById('prob1');

      function update() {
        var theta = +thetaEl.value;
        var phi = +phiEl.value;
        var thR = theta * Math.PI / 180;
        var phR = phi * Math.PI / 180;
        var x = R * Math.sin(thR) * Math.cos(phR);
        var y = R * Math.sin(thR) * Math.sin(phR);
        var z = R * Math.cos(thR);
        var px = cx + x * 0.95 - y * 0.55;
        var py = cy - z * 0.85 + y * 0.4;
        if (vec) { vec.setAttribute('x2', px); vec.setAttribute('y2', py); }
        if (tip) { tip.setAttribute('cx', px); tip.setAttribute('cy', py); }
        if (ring) { ring.setAttribute('cx', px); ring.setAttribute('cy', py); }
        if (label) { label.setAttribute('x', px + 18); label.setAttribute('y', py - 8); }
        if (thetaVal) thetaVal.textContent = theta + '°';
        if (phiVal) phiVal.textContent = phi + '°';
        var alpha = Math.cos(thR / 2);
        var br = Math.sin(thR / 2) * Math.cos(phR);
        var bi = Math.sin(thR / 2) * Math.sin(phR);
        if (alphaR) alphaR.textContent = alpha.toFixed(3);
        if (betaR) betaR.textContent = br.toFixed(3);
        if (betaI) betaI.textContent = bi.toFixed(3);
        if (prob0) prob0.textContent = (alpha * alpha).toFixed(3);
        if (prob1) prob1.textContent = (1 - alpha * alpha).toFixed(3);
      }

      if (thetaEl) thetaEl.addEventListener('input', update);
      if (phiEl) phiEl.addEventListener('input', update);
      update();

      // Gate application: pre-set angles for visual demo
      var gatePresets = {
        X:  { theta: 180, phi: 0 },
        Y:  { theta: 180, phi: 90 },
        Z:  { theta: 0, phi: 180 },
        H:  { theta: 90, phi: 0 },
        S:  { theta: null, phi: 90 },
        T:  { theta: null, phi: 45 },
        Rx: { theta: 120, phi: 0 },
        Ry: { theta: 120, phi: 90 },
      };
      var gateBtns = document.querySelectorAll('.gate-btn');
      gateBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var g = btn.getAttribute('data-gate');
          var p = gatePresets[g];
          if (!p) return;
          if (p.theta !== null) thetaEl.value = p.theta;
          phiEl.value = p.phi;
          update();
        });
      });

      var btnReset = document.getElementById('btnReset');
      if (btnReset) btnReset.addEventListener('click', function() { thetaEl.value = 0; phiEl.value = 0; update(); });
    })();
  </script>
</AquintutorLayout>
