---
// /aquintutor/access — "Your access" (Prompt 2b, main surface). Shows the signed-in user
// their roles, stage, minor/guardian status, and the capabilities they hold — read from the
// REAL backend via resolvePrincipal(). Also the in-app hub to the guardian / partner areas
// and (for staff) the admin console, shown only for roles the user actually holds.
// Server-rendered: zero client JS. Every view is audited via can().
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { resolvePrincipal, can } from '@/lib/rbac';
import { accessSummary } from '@/lib/rbac/access';
import { ADMIN_ROLE_KEYS } from '@/lib/rbac/roles';
import { resumeList } from '@/lib/edu-runtime';
import { userSyncStatus } from '@/lib/knowledge-sync';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/access');

const principal = await resolvePrincipal(user);
await can(user, 'read', { type: 'access' });   // audit the page view
const a = accessSummary(principal);
const hasAdmin = a.roles.some((r) => ADMIN_ROLE_KEYS.includes(r));
const canDrive = (await can(user, 'write', { type: 'AnimationObject' })).allow;   // faculty drive the live board
const resume = await resumeList(user.id, 5).catch(() => []);
const sync = await userSyncStatus(user.id).catch(() => ({ pending: 0, conflicts: 0 }));

const CHIP = 'display:inline-block;background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:100px;padding:4px 12px;margin:3px 4px 3px 0;font-size:13px;color:var(--ink,#1a1712);font-family:Inter Tight,sans-serif;';
const CARD = 'background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:14px;padding:22px 24px;margin-bottom:18px;';
---
<AquintutorLayout title="Your access">
  <main style="max-width:860px;margin:0 auto;padding:48px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Your access</p>
    <h1 style="font-family:Fraunces,serif;font-size:34px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 6px;line-height:1.1;">{user.name || 'Your account'}</h1>
    <p style="font-family:Inter Tight,sans-serif;font-size:15px;color:#6b6455;margin:0 0 28px;">This is exactly what your account can do on the platform. Access is decided by the permission engine and every check is recorded.</p>

    <p style={'font-family:Inter Tight,sans-serif;font-size:13px;margin:0 0 18px;color:' + (sync.conflicts ? '#9b2c2c' : '#2f7d5b') + ';'}>
      {sync.conflicts ? sync.conflicts + ' change(s) need your attention (a conflict is being reviewed).' : sync.pending ? sync.pending + ' change(s) syncing.' : 'All your learning is up to date.'}
    </p>

    {resume.length ? (
      <div style={CARD}>
        <h2 style="font-family:Fraunces,serif;font-size:19px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 12px;">Continue learning</h2>
        <div style="display:flex;flex-direction:column;gap:8px;">
          {resume.map((r) => (
            <a href={'/aquintutor/lesson/' + r.koId} style="display:flex;justify-content:space-between;align-items:center;gap:10px;text-decoration:none;border:1px solid var(--line,#e6e1d6);border-radius:10px;padding:11px 15px;">
              <span style="font-family:Inter Tight,sans-serif;font-size:14.5px;color:var(--ink,#1a1712);font-weight:600;">{r.title || 'Lesson'}</span>
              <span style="font-family:Inter Tight,sans-serif;font-size:12px;color:#8a8478;">{r.completed ? 'completed' : 'in progress'} &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    ) : null}

    {a.needsGuardian ? (
      <div style="background:#fdecec;border:1px solid #f0b4b4;border-radius:12px;padding:14px 18px;margin-bottom:18px;">
        <p style="font-family:Inter Tight,sans-serif;font-size:14px;color:#9b2c2c;margin:0;font-weight:600;">A guardian must be linked to your account.</p>
        <p style="font-family:Inter Tight,sans-serif;font-size:13.5px;color:#8a3a3a;margin:5px 0 0;">Your learning stage is a minor stage, so sensitive actions are paused until a parent or guardian is linked. Ask your coordinator to link a guardian.</p>
      </div>
    ) : null}

    <div style={CARD}>
      <h2 style="font-family:Fraunces,serif;font-size:19px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 12px;">Roles</h2>
      {a.roles.length ? <div>{a.roles.map((r) => <span style={CHIP}>{r}</span>)}</div> : <p style="color:#6b6455;font-size:14px;margin:0;">No roles assigned yet.</p>}
      {a.stage ? <p style="font-family:Inter Tight,sans-serif;font-size:14px;color:#6b6455;margin:14px 0 0;">Learning stage: <b style="color:var(--ink,#1a1712);">{a.stage}</b>{a.isMinor ? (a.hasGuardian ? ' (minor, guardian linked)' : ' (minor)') : ''}</p> : null}
    </div>

    <div style={CARD}>
      <h2 style="font-family:Fraunces,serif;font-size:19px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 4px;">What you can do</h2>
      <p style="font-family:Inter Tight,sans-serif;font-size:13.5px;color:#6b6455;margin:0 0 14px;">{a.isSuperadmin ? 'You hold full control (administer).' : a.capabilities.length + ' capabilities, combined across all your roles.'}</p>
      <ul style="list-style:none;margin:0;padding:0;">
        {a.capabilities.map((c) => (
          <li style="display:flex;align-items:baseline;gap:10px;padding:7px 0;border-top:1px solid #f0ece2;font-family:Inter Tight,sans-serif;">
            <span style="font-family:'Geist Mono',monospace;font-size:12px;color:var(--rust,#b3541e);min-width:92px;">{c.key}</span>
            <span style="font-size:14px;color:var(--ink,#1a1712);">{c.label}</span>
          </li>
        ))}
      </ul>
    </div>

    <div style={CARD}>
      <h2 style="font-family:Fraunces,serif;font-size:19px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 12px;">Your areas</h2>
      <div style="display:flex;flex-wrap:wrap;gap:10px;">
        <a href="/aquintutor/hub" style="text-decoration:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;color:var(--sand-50,#fbfaf4);background:var(--ink,#1a1712);padding:10px 18px;border-radius:8px;">Campus hub</a>
        {a.roles.includes('guardian') ? <a href="/aquintutor/guardian" style="text-decoration:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;color:var(--sand-50,#fbfaf4);background:var(--ink,#1a1712);padding:10px 18px;border-radius:8px;">Guardian oversight</a> : null}
        {a.roles.includes('partner') ? <a href="/aquintutor/partner" style="text-decoration:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;color:var(--ink,#1a1712);background:#fff;border:1px solid var(--ink,#1a1712);padding:10px 18px;border-radius:8px;">Partner area</a> : null}
        {hasAdmin ? <a href="/admin/rbac" style="text-decoration:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;color:var(--ink,#1a1712);background:#fff;border:1px solid var(--line,#e6e1d6);padding:10px 18px;border-radius:8px;">Admin: permission console</a> : null}
        {canDrive ? <a href="/aquintutor/board" style="text-decoration:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;color:var(--ink,#1a1712);background:#fff;border:1px solid var(--line,#e6e1d6);padding:10px 18px;border-radius:8px;">Teaching board</a> : null}
        <a href="/aquintutor/study-calendar" style="text-decoration:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;color:var(--ink,#1a1712);background:#fff;border:1px solid var(--line,#e6e1d6);padding:10px 18px;border-radius:8px;">Calendar</a>
        <a href="/aquintutor/alerts" style="text-decoration:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;color:var(--ink,#1a1712);background:#fff;border:1px solid var(--line,#e6e1d6);padding:10px 18px;border-radius:8px;">Notifications</a>
        <a href="/aquintutor/xp" style="text-decoration:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;color:var(--ink,#1a1712);background:#fff;border:1px solid var(--line,#e6e1d6);padding:10px 18px;border-radius:8px;">XP &amp; rewards</a>
        <a href="/aquintutor/settings" style="text-decoration:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;color:var(--ink,#1a1712);background:#fff;border:1px solid var(--line,#e6e1d6);padding:10px 18px;border-radius:8px;">Settings</a>
        <a href="/aquintutor/analytics" style="text-decoration:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;color:var(--ink,#1a1712);background:#fff;border:1px solid var(--line,#e6e1d6);padding:10px 18px;border-radius:8px;">My progress</a>
        <a href="/aquintutor/search" style="text-decoration:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;color:var(--ink,#1a1712);background:#fff;border:1px solid var(--line,#e6e1d6);padding:10px 18px;border-radius:8px;">Search &amp; discover</a>
        <a href="/aquintutor/vod" style="text-decoration:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;color:var(--ink,#1a1712);background:#fff;border:1px solid var(--line,#e6e1d6);padding:10px 18px;border-radius:8px;">Recordings</a>
        <a href="/aquintutor/language" style="text-decoration:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;color:var(--ink,#1a1712);background:#fff;border:1px solid var(--line,#e6e1d6);padding:10px 18px;border-radius:8px;">Language</a>
        <a href="/aquintutor/accessibility" style="text-decoration:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;color:var(--ink,#1a1712);background:#fff;border:1px solid var(--line,#e6e1d6);padding:10px 18px;border-radius:8px;">Accessibility</a>
        <a href="/aquintutor/billing" style="text-decoration:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;color:var(--ink,#1a1712);background:#fff;border:1px solid var(--line,#e6e1d6);padding:10px 18px;border-radius:8px;">Plans &amp; billing</a>
        <a href="/aquintutor/record" style="text-decoration:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;color:var(--ink,#1a1712);background:#fff;border:1px solid var(--line,#e6e1d6);padding:10px 18px;border-radius:8px;">Academic record</a>
        <a href="/aquintutor/credentials" style="text-decoration:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;color:var(--ink,#1a1712);background:#fff;border:1px solid var(--line,#e6e1d6);padding:10px 18px;border-radius:8px;">My credentials</a>
        <a href="/aquintutor/courses" style="text-decoration:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;color:var(--ink,#1a1712);background:#fff;border:1px solid var(--line,#e6e1d6);padding:10px 18px;border-radius:8px;">Browse courses</a>
      </div>
    </div>
  </main>
</AquintutorLayout>
