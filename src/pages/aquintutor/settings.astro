---
// /aquintutor/settings — self-serve student settings + profile (Prompt 14, main surface). Feeds the
// runtime (language/accessibility/learning style). Consent-gated settings are locked for a MINOR and
// managed by a linked GUARDIAN (?for=<minorId>). Server-rendered; one inline save script.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { isMinorStage } from '@/lib/rbac/roles';
import { getProfile, isGuardianOf, LANGUAGES, LEARNING_STYLES, THEMES } from '@/lib/student-settings';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/settings');
const rows = (r: any): any[] => (Array.isArray(r) ? r : (r?.rows || []));
const forId = (Astro.url.searchParams.get('for') || '').trim();
const target = forId && forId !== user.id && (await isGuardianOf(user.id, forId).catch(() => false)) ? forId : user.id;
const guardianView = target !== user.id;
let stage: string | null = null;
try { stage = rows(await db.execute(sql`SELECT stage FROM rbac_user_roles WHERE user_id = ${target} AND role_key = 'student' LIMIT 1`))[0]?.stage || null; } catch {}
const isMinor = isMinorStage(stage);
const consentLocked = isMinor && !guardianView;   // the minor themselves cannot change consent settings
const p = await getProfile(target);
const targetName = guardianView ? (rows(await db.execute(sql`SELECT name FROM users WHERE id = ${target} LIMIT 1`))[0]?.name || 'learner') : (user.name || 'you');

const CARD = 'background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:14px;padding:20px 22px;margin-bottom:16px;';
const LBL = 'font-family:Inter Tight,sans-serif;font-size:13.5px;color:var(--ink,#1a1712);';
const IN = 'font-family:Inter Tight,sans-serif;font-size:14px;padding:9px 11px;border:1px solid var(--line,#e6e1d6);border-radius:9px;';
---
<AquintutorLayout title="Settings">
  <main style="max-width:680px;margin:0 auto;padding:44px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Settings</p>
    <h1 style="font-family:Fraunces,serif;font-size:32px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 6px;line-height:1.15;">{guardianView ? 'Settings for ' + targetName : 'Your settings'}</h1>
    <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#6b6455;margin:0 0 22px;">These take effect in the next learning session. {consentLocked ? 'Some settings are managed by your guardian.' : guardianView ? 'You are managing these as a linked guardian.' : ''}</p>
    <div id="msg" style="display:none;margin:0 0 16px;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style={CARD}>
      <h2 style="font-family:Fraunces,serif;font-size:18px;font-weight:600;margin:0 0 14px;">Learning</h2>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <label style={LBL}>Language<br/><select id="sLang" style={IN + 'width:100%;margin-top:4px;'}>{LANGUAGES.map((l) => <option value={l} selected={p.language === l}>{l}</option>)}</select></label>
        <label style={LBL}>Learning style<br/><select id="sStyle" style={IN + 'width:100%;margin-top:4px;'}>{LEARNING_STYLES.map((l) => <option value={l} selected={p.learningStyle === l}>{l}</option>)}</select></label>
        <label style={LBL}>Theme<br/><select id="sTheme" style={IN + 'width:100%;margin-top:4px;'}>{THEMES.map((t) => <option value={t} selected={p.theme === t}>{t}</option>)}</select></label>
      </div>
    </div>

    <div style={CARD}>
      <h2 style="font-family:Fraunces,serif;font-size:18px;font-weight:600;margin:0 0 14px;">Accessibility</h2>
      <label style={LBL + 'display:block;margin-bottom:8px;'}><input type="checkbox" id="aReduce" checked={!!p.accessibility.reduceMotion} /> Reduce motion (calmer animations)</label>
      <label style={LBL + 'display:block;margin-bottom:8px;'}><input type="checkbox" id="aContrast" checked={!!p.accessibility.highContrast} /> Higher contrast</label>
      <label style={LBL + 'display:block;'}><input type="checkbox" id="aReader" checked={!!p.accessibility.screenReader} /> Optimised for screen readers</label>
    </div>

    <div style={CARD}>
      <h2 style="font-family:Fraunces,serif;font-size:18px;font-weight:600;margin:0 0 4px;">Notifications</h2>
      <label style={LBL + 'display:block;margin:8px 0;'}><input type="checkbox" id="nDeadlines" checked={p.notifications.deadlines !== false} /> Deadline reminders</label>
      <label style={LBL + 'display:block;margin:8px 0;'}><input type="checkbox" id="nResults" checked={p.notifications.results !== false} /> Assessment results</label>
      <label style={LBL + 'display:block;margin:8px 0;'}><input type="checkbox" id="nEmail" checked={!!p.notifications.email} /> Also email me</label>
    </div>

    <div style={CARD}>
      <h2 style="font-family:Fraunces,serif;font-size:18px;font-weight:600;margin:0 0 4px;">Consent {consentLocked ? '(guardian-managed)' : ''}</h2>
      <label style={LBL + 'display:block;margin:8px 0;' + (consentLocked ? 'opacity:.55;' : '')}><input type="checkbox" id="cTutor" checked={p.consent.aiTutor !== false} disabled={consentLocked} /> Use the AI tutor (Ask Aquin)</label>
      <label style={LBL + 'display:block;margin:8px 0;' + (consentLocked ? 'opacity:.55;' : '')}><input type="checkbox" id="cCommunity" checked={!!p.consent.community} disabled={consentLocked} /> Participate in community discussion</label>
      {consentLocked ? <p style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#8a5a1a;margin:8px 0 0;">A linked guardian manages these settings for you.</p> : null}
    </div>

    <button id="saveBtn" type="button" style="background:var(--ink,#1a1712);color:var(--sand-50,#fbfaf4);border:none;border-radius:10px;padding:12px 24px;font-family:'Inter Tight',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">Save settings</button>
  </main>

  <script is:inline define:vars={{ target: guardianView ? target : '' }}>
    (function () {
      var msg = document.getElementById('msg'), q = function (id) { return document.getElementById(id); };
      q('saveBtn').addEventListener('click', function () {
        var patch = {
          language: q('sLang').value, learningStyle: q('sStyle').value, theme: q('sTheme').value,
          accessibility: { reduceMotion: q('aReduce').checked, highContrast: q('aContrast').checked, screenReader: q('aReader').checked },
          notifications: { deadlines: q('nDeadlines').checked, results: q('nResults').checked, email: q('nEmail').checked },
          consent: { aiTutor: q('cTutor').checked, community: q('cCommunity').checked },
        };
        fetch('/api/aquintutor/settings', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ targetUserId: target || undefined, patch: patch }) })
          .then(function (r) { return r.json(); }).then(function (j) { msg.style.display = 'block'; msg.textContent = j.ok ? 'Saved — effective next session.' : (j.error || 'Failed'); msg.style.background = j.ok ? '#eef8f1' : '#fdecec'; msg.style.color = j.ok ? '#2f7d5b' : '#9b2c2c'; window.scrollTo({ top: 0, behavior: 'smooth' }); });
      });
    })();
  </script>
</AquintutorLayout>
