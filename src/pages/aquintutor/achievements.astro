---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { getUserAchievements } from '@/lib/achievements';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/achievements'));

const items = await getUserAchievements(user.id);
const earnedCount = items.filter(a => a.earned).length;
const groups: Record<string, typeof items> = {};
for (const a of items) { (groups[a.category] = groups[a.category] || []).push(a); }
const labels: Record<string, string> = { streak: 'Streak', xp: 'XP milestones', tests: 'Tests', courses: 'Courses', practice: 'Practice & daily', social: 'Social' };

function tierColor(t: string) {
  if (t === 'platinum') return '#e5e4e2';
  if (t === 'gold') return '#facc15';
  if (t === 'silver') return '#94a3b8';
  return '#b45309';
}
---
<AquintutorLayout title="Achievements" description="Earned badges + milestones.">
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:980px; margin:0 auto; padding:48px 28px;">
      <p style="font-family:'Inter Tight',monospace; font-size:12px; color:var(--rust); font-weight:700; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Achievements</p>
      <h1 class="font-display" style="font-size:clamp(2rem,4vw,3rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500; margin:0 0 8px;">{earnedCount} of {items.length} earned.</h1>
      <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); line-height:1.6;">Badges reflect your actual work — not vanity. Each unlocks automatically when the underlying metric passes its threshold.</p>
    </div>
  </section>

  <section>
    <div style="max-width:980px; margin:0 auto; padding:36px 28px 80px;">
      {Object.keys(groups).map(cat => (
        <div style="margin-bottom:36px;">
          <p style="font-family:'Inter Tight',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:700; margin:0 0 14px;">{labels[cat] || cat}</p>
          <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(220px, 1fr)); gap:14px;">
            {groups[cat].map(a => (
              <div style={'background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:18px; opacity:' + (a.earned ? '1' : '0.55') + ';'}>
                <div style="display:flex; gap:12px; align-items:center; margin-bottom:10px;">
                  <span style={'font-size:32px; filter:' + (a.earned ? 'none' : 'grayscale(0.7)') + ';'}>{a.icon}</span>
                  <div style="flex:1; min-width:0;">
                    <p style="font-family:'Fraunces',serif; font-size:1.05rem; font-weight:600; color:var(--ink); margin:0; line-height:1.2;">{a.name}</p>
                    <span style={'display:inline-block; font-family:JetBrains Mono,monospace; font-size:9.5px; text-transform:uppercase; letter-spacing:0.14em; font-weight:700; padding:2px 7px; border-radius:100px; margin-top:5px; background:' + tierColor(a.tier) + '22; color:' + tierColor(a.tier) + ';'}>{a.tier}</span>
                  </div>
                </div>
                <p style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500); line-height:1.55; margin:0 0 8px;">{a.description}</p>
                <div style="height:6px; background:var(--sand-100); border-radius:100px; overflow:hidden;">
                  <div style={'height:100%; background:' + (a.earned ? '#10b981' : 'var(--rust)') + '; width:' + Math.round(a.progress * 100) + '%; transition:width .4s;'}></div>
                </div>
                <p style="font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--ink-500); margin:5px 0 0;">{a.earned ? 'Earned ✓' : Math.round(a.progress * 100) + '% there'}</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</AquintutorLayout>
