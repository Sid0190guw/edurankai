---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/rewards'));

let attempts: any[] = [];
let enrollments: any[] = [];
let certificates: any[] = [];
let cohortTop: any[] = [];

try {
  const r = await db.execute(sql`
    SELECT a.id, a.test_id, a.percentage, a.total_score, a.status, a.tab_switches, a.fullscreen_exits, a.submitted_at,
      t.title as test_title, t.slug as test_slug, t.test_type, t.total_marks
    FROM test_attempts a LEFT JOIN tests t ON a.test_id = t.id
    WHERE a.candidate_id = ${user.id} AND a.status IN ('submitted','auto_submitted')
    ORDER BY a.submitted_at DESC NULLS LAST LIMIT 100
  `);
  attempts = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT e.id, e.progress_pct, c.slug, c.title, c.school_id, s.name as school_name
    FROM training_enrollments e LEFT JOIN training_courses c ON e.course_id = c.id LEFT JOIN schools s ON c.school_id = s.id
    WHERE e.user_id = ${user.id}
  `);
  enrollments = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`SELECT certificate_number as credential_number, (SELECT title FROM training_courses WHERE id = c.course_id) as course_title, c.issued_at FROM training_certificates c WHERE c.user_id = ${user.id} ORDER BY c.issued_at DESC LIMIT 12`);
  certificates = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

let xpTotal = 0;
let perfectCount = 0;
let cleanCount = 0;
let distinctionCount = 0;
let bestStreak = 0;
let currentStreak = 0;
let totalScore = 0;
let maxScore = 0;

for (const a of attempts as any[]) {
  const pct = parseFloat(a.percentage || 0);
  const marks = parseFloat(a.total_score || 0);
  totalScore += marks;
  maxScore += parseFloat(a.total_marks || 0);
  let xp = 50 + Math.round(pct * 5);
  if (pct >= 100) { xp += 200; perfectCount++; }
  if (pct >= 80)  { xp += 100; distinctionCount++; }
  if ((a.tab_switches || 0) === 0 && (a.fullscreen_exits || 0) === 0) { xp += 30; cleanCount++; }
  xpTotal += xp;
  if (pct >= 60) {
    currentStreak++;
    bestStreak = Math.max(bestStreak, currentStreak);
  } else {
    currentStreak = 0;
  }
}

const level = Math.max(1, Math.floor(xpTotal / 500) + 1);
const levelXpFloor = (level - 1) * 500;
const levelXpCeil = level * 500;
const levelProgress = xpTotal - levelXpFloor;
const levelDenom = levelXpCeil - levelXpFloor;
const tier = level >= 30 ? 'Scholar' : level >= 20 ? 'Adept' : level >= 10 ? 'Practitioner' : level >= 5 ? 'Apprentice' : 'Initiate';

const totalSchools = new Set(enrollments.filter((e: any) => e.school_name).map((e: any) => e.school_name)).size;

try {
  const r = await db.execute(sql`
    SELECT u.id, u.name, COUNT(a.id)::int as attempts, ROUND(AVG(a.percentage)::numeric, 1) as avg_pct
    FROM users u
    JOIN test_attempts a ON a.candidate_id = u.id AND a.status IN ('submitted','auto_submitted')
    GROUP BY u.id, u.name
    ORDER BY attempts DESC, avg_pct DESC NULLS LAST
    LIMIT 8
  `);
  cohortTop = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const myRank = cohortTop.findIndex((u: any) => u.id === user.id);

const BADGES = [
  { id: 'first-attempt', name: 'First attempt', desc: 'Complete any examination', earned: attempts.length >= 1, rarity: 'common' },
  { id: 'ten-attempts', name: 'Decathlete', desc: 'Complete ten examinations', earned: attempts.length >= 10, rarity: 'uncommon' },
  { id: 'distinction', name: 'Distinction', desc: 'Score 80% on any examination', earned: distinctionCount >= 1, rarity: 'uncommon' },
  { id: 'perfect', name: 'Perfect score', desc: 'Score 100% on any examination', earned: perfectCount >= 1, rarity: 'rare' },
  { id: 'clean-3', name: 'Clean three', desc: 'Three sessions with zero proctor flags', earned: cleanCount >= 3, rarity: 'rare' },
  { id: 'streak-5', name: 'Five-in-a-row', desc: 'Five consecutive passing attempts', earned: bestStreak >= 5, rarity: 'epic' },
  { id: 'enrolled-3', name: 'Three schools', desc: 'Enrol in courses from three schools', earned: totalSchools >= 3, rarity: 'uncommon' },
  { id: 'certified', name: 'Credentialled', desc: 'Earn any verifiable credential', earned: certificates.length >= 1, rarity: 'epic' },
  { id: 'scholar', name: 'Scholar tier', desc: 'Reach level 30', earned: level >= 30, rarity: 'legendary' },
];
const earnedCount = BADGES.filter(b => b.earned).length;

const RARITY_COLOR: Record<string, string> = {
  common: '#9c9a85', uncommon: '#4a7048', rare: '#3b5675', epic: '#5b4a92', legendary: '#a87526',
};

const TREE_NODES = [
  { id: 'foundations', name: 'Foundations', tier: 1, unlocked: attempts.length >= 1 },
  { id: 'reasoning', name: 'Reasoning', tier: 2, unlocked: distinctionCount >= 1 },
  { id: 'composition', name: 'Composition', tier: 2, unlocked: attempts.length >= 3 },
  { id: 'craft', name: 'Craft', tier: 2, unlocked: cleanCount >= 1 },
  { id: 'mastery', name: 'Mastery', tier: 3, unlocked: perfectCount >= 1 },
  { id: 'integrity', name: 'Integrity', tier: 3, unlocked: cleanCount >= 3 },
  { id: 'apex', name: 'Apex', tier: 4, unlocked: level >= 20 },
];

const pct = Math.min(100, Math.max(2, Math.round((levelProgress / Math.max(1, levelDenom)) * 100)));
---
<AquintutorLayout title="Rewards" description="XP, streak, skill tree, badges, and cohort leaderboard - the gamified record of your AquinTutor progress.">

  <!-- BREADCRUMB -->
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1400px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a>
      <span style="margin:0 8px;">/</span>
      <a href="/aquintutor/dashboard" style="color:var(--ink-500); text-decoration:none;">DASHBOARD</a>
      <span style="margin:0 8px;">/</span>
      <span style="color:var(--rust); font-weight:600;">REWARDS &middot; LEVEL {level} &middot; {tier.toUpperCase()}</span>
    </div>
  </div>

  <!-- HERO -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:48px 28px 36px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 14px;">Level up &middot; your record</p>
      <h1 class="font-display" style="font-size:clamp(2.5rem, 6vw, 4.5rem); line-height:1; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--ink);">
        Mastery, <span style="font-style:italic; font-weight:300; color:var(--ink-500);">recorded.</span>
      </h1>
      <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.1rem, 1.5vw, 1.35rem); line-height:1.5; color:var(--ink-500); margin:22px 0 0; max-width:42rem;">
        XP, streaks, skill trees, and seasonal ranks &mdash; computed from your real attempts, enrolments, and credentials. No fake numbers.
      </p>
    </div>
  </section>

  <!-- XP CARD -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1400px; margin:0 auto; padding:40px 28px;">
      <div style="display:grid; grid-template-columns:1fr; gap:24px; align-items:end; margin-bottom:28px;" class="xp-grid">
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 6px;">XP &middot; Level</p>
          <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500); letter-spacing:0.1em; margin:0;">{xpTotal.toLocaleString()} TOTAL XP</p>
        </div>
        <div>
          <div style="display:flex; align-items:baseline; gap:18px; flex-wrap:wrap;">
            <span class="font-display" style="font-size:clamp(2.5rem, 6vw, 4.5rem); line-height:0.95; font-weight:500; letter-spacing:-0.025em;">Level {level}</span>
            <span style="display:inline-flex; align-items:center; padding:5px 12px; background:rgba(160,66,30,0.08); border:1px solid rgba(160,66,30,0.4); border-radius:999px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--rust); font-weight:600;">{tier} tier</span>
          </div>
          <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.05rem; color:var(--ink-500); margin:8px 0 0;">
            {levelDenom - levelProgress} XP to level {level + 1} &middot; best streak {bestStreak}{currentStreak > 0 ? ' (current ' + currentStreak + ')' : ''}
          </p>
        </div>
      </div>

      <!-- XP bar -->
      <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:18px 22px;">
        <div style="display:flex; justify-content:space-between; margin-bottom:10px; font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.1em;">
          <span style="color:var(--ink-500);">{levelXpFloor.toLocaleString()} XP</span>
          <span style="color:var(--rust); font-weight:600;">{levelProgress.toLocaleString()} / {levelDenom.toLocaleString()}</span>
          <span style="color:var(--ink-500);">{levelXpCeil.toLocaleString()} XP</span>
        </div>
        <div style="height:14px; background:var(--rule); border-radius:7px; overflow:hidden; position:relative;">
          <div style={'height:100%; width:' + pct + '%; background:linear-gradient(90deg, var(--rust), #d9a060); border-radius:7px; transition:width 0.6s;'}></div>
        </div>
      </div>

      <!-- KPI tiles -->
      <div style="display:grid; grid-template-columns:repeat(2, 1fr); gap:10px; margin-top:14px;" class="kpi-grid">
        {[
          ['Attempts', attempts.length],
          ['Perfect', perfectCount],
          ['Distinctions', distinctionCount],
          ['Clean sessions', cleanCount],
          ['Best streak', bestStreak],
          ['Credentials', certificates.length],
        ].map(([k, v]) => (
          <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:12px 16px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">{k}</p>
            <p class="font-display" style="font-size:1.55rem; font-weight:500; margin:0; line-height:1; font-variant-numeric:tabular-nums; letter-spacing:-0.02em; color:var(--ink);">{v}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Skill tree + Badges + Leaderboard -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:48px 28px;">
      <div style="display:grid; grid-template-columns:1fr; gap:18px;" class="rewards-grid">

        <!-- Skill tree -->
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:22px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0;">Skill tree</p>
          <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500); letter-spacing:0.1em; margin:6px 0 16px;">{TREE_NODES.filter((n: any) => n.unlocked).length} / {TREE_NODES.length} UNLOCKED</p>
          <svg viewBox="0 0 400 360" width="100%" style="height:auto; max-height:380px;">
            <line x1="200" y1="50" x2="120" y2="140" stroke="var(--rule)" stroke-width="1.5"/>
            <line x1="200" y1="50" x2="200" y2="140" stroke="var(--rule)" stroke-width="1.5"/>
            <line x1="200" y1="50" x2="280" y2="140" stroke="var(--rule)" stroke-width="1.5"/>
            <line x1="120" y1="160" x2="160" y2="240" stroke="var(--rule)" stroke-width="1.5"/>
            <line x1="280" y1="160" x2="240" y2="240" stroke="var(--rule)" stroke-width="1.5"/>
            <line x1="200" y1="160" x2="200" y2="240" stroke="var(--rule)" stroke-width="1.5"/>
            <line x1="200" y1="260" x2="200" y2="330" stroke="var(--rule)" stroke-width="1.5"/>
            {TREE_NODES.map((n: any) => {
              const pos: any = {
                foundations: [200, 50], reasoning: [120, 160], composition: [200, 160],
                craft: [280, 160], mastery: [160, 260], integrity: [240, 260], apex: [200, 330],
              };
              const coords = pos[n.id] || [200, 200];
              const cx = coords[0]; const cy = coords[1];
              return (
                <g>
                  <circle cx={cx} cy={cy} r="22" fill={n.unlocked ? 'var(--rust)' : 'var(--sand-100)'} stroke={n.unlocked ? 'var(--rust)' : 'var(--rule)'} stroke-width="2" />
                  {n.unlocked && <circle cx={cx} cy={cy} r="26" fill="none" stroke="var(--rust)" stroke-width="1" opacity="0.4" />}
                  <text x={cx} y={cy + 4} text-anchor="middle" font-family="JetBrains Mono" font-size="10" font-weight="600" fill={n.unlocked ? '#fff' : 'var(--ink-500)'}>{n.tier}</text>
                  <text x={cx} y={cy + 42} text-anchor="middle" font-family="JetBrains Mono" font-size="9.5" letter-spacing="0.1em" fill={n.unlocked ? 'var(--ink)' : 'var(--ink-500)'}>{n.name.toUpperCase()}</text>
                </g>
              );
            })}
          </svg>
        </div>

        <!-- Badges -->
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:22px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0;">Badges</p>
          <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500); letter-spacing:0.1em; margin:6px 0 16px;">{earnedCount} / {BADGES.length} EARNED</p>
          <div style="display:grid; grid-template-columns:repeat(3, 1fr); gap:10px;">
            {BADGES.map((b: any) => {
              const color = b.earned ? RARITY_COLOR[b.rarity] : 'var(--ink-500)';
              return (
                <div style={'padding:12px 10px; border-radius:10px; text-align:center; background:' + (b.earned ? color + '14' : 'var(--sand-100)') + '; border:1px solid ' + (b.earned ? color + '55' : 'var(--rule)') + '; ' + (b.earned ? '' : 'opacity:0.55;')}>
                  <div style={'width:42px; height:42px; border-radius:50%; background:' + (b.earned ? color + '30' : 'var(--paper)') + '; margin:0 auto 6px; display:flex; align-items:center; justify-content:center; border:1px solid ' + (b.earned ? color + '60' : 'var(--rule)') + ';'}>
                    {b.earned ? (
                      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/></svg>
                    ) : (
                      <span style="font-family:'JetBrains Mono',monospace; color:var(--ink-500); font-size:18px;">?</span>
                    )}
                  </div>
                  <p style="font-family:'Inter Tight',sans-serif; font-size:11px; font-weight:600; margin:0; color:var(--ink); line-height:1.25;">{b.name}</p>
                  {b.earned && <p style={'font-family:JetBrains Mono,monospace; font-size:8.5px; letter-spacing:0.14em; text-transform:uppercase; color:' + color + '; margin:4px 0 0; font-weight:600;'}>{b.rarity}</p>}
                </div>
              );
            })}
          </div>
        </div>

        <!-- Leaderboard -->
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:22px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0;">Cohort leaderboard</p>
          <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500); letter-spacing:0.1em; margin:6px 0 16px;">TOP {cohortTop.length} OF THIS SEASON</p>
          {cohortTop.length === 0 && <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:14px; color:var(--ink-500); margin:0;">No attempts in the cohort yet.</p>}
          {cohortTop.map((u: any, i: number) => {
            const isYou = u.id === user.id;
            const bg = isYou ? 'rgba(160,66,30,0.10)' : 'var(--sand-100)';
            const border = isYou ? 'var(--rust)' : 'var(--rule)';
            return (
              <div style={'display:grid; grid-template-columns:30px 30px 1fr 50px 50px; gap:10px; align-items:center; padding:9px 12px; border-radius:8px; background:' + bg + '; border:1px solid ' + border + '; margin-bottom:6px;'}>
                <span style={'font-family:JetBrains Mono,monospace; font-size:12px; font-weight:700; color:' + (i < 3 ? 'var(--rust)' : 'var(--ink-500)') + ';'}>{String(i + 1).padStart(2, '0')}</span>
                <span style={'display:inline-flex; align-items:center; justify-content:center; width:26px; height:26px; border-radius:50%; background:' + (isYou ? 'var(--rust)' : 'var(--ink)') + '; color:var(--sand-50); font-family:Fraunces,serif; font-size:12px; font-weight:500;'}>{(u.name || '?').substring(0, 1).toUpperCase()}</span>
                <span style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{isYou ? 'You' : (u.name || 'Anonymous')}</span>
                <span style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--ink-500); text-align:right;">{u.attempts}A</span>
                <span style="font-family:'JetBrains Mono',monospace; font-size:11.5px; color:var(--rust); text-align:right; font-weight:600;">{u.avg_pct ? Math.round(u.avg_pct) + '%' : '-'}</span>
              </div>
            );
          })}
          {myRank === -1 && attempts.length === 0 && (
            <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:13px; color:var(--ink-500); margin:12px 0 0;">Complete your first examination to enter the leaderboard.</p>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section>
    <div style="max-width:1400px; margin:0 auto; padding:48px 28px 72px; display:flex; gap:10px; justify-content:center; flex-wrap:wrap;">
      <a href="/aquintutor/test/quantum-challenge-100" style="background:var(--rust); color:#fff; padding:13px 22px; border:none; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13.5px; font-weight:600; text-decoration:none;">Sit the Quantum Challenge &rarr;</a>
      <a href="/aquintutor/dashboard" style="background:transparent; color:var(--ink); padding:13px 22px; border:1px solid var(--rule); border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13.5px; font-weight:600; text-decoration:none;">Back to dashboard</a>
      <a href="/aquintutor/courses" style="background:transparent; color:var(--ink); padding:13px 22px; border:1px solid var(--rule); border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13.5px; font-weight:600; text-decoration:none;">Browse the catalogue</a>
    </div>
  </section>

  <style>
    @media (min-width: 640px) { .kpi-grid { grid-template-columns: repeat(3, 1fr) !important; } }
    @media (min-width: 900px) { .xp-grid { grid-template-columns: 3fr 9fr !important; } .kpi-grid { grid-template-columns: repeat(6, 1fr) !important; } }
    @media (min-width: 1024px) { .rewards-grid { grid-template-columns: 1.2fr 1fr 1fr !important; } }
  </style>
</AquintutorLayout>
