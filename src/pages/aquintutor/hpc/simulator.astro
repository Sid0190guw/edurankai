---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
---
<AquintutorLayout title="HPC Job Simulator · AquinTutor" description="Configure a cluster, schedule a parallel workload, watch the Gantt + Amdahl curve + cache-miss heatmap in real time. Pure browser.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; }
  .hpc-wrap { max-width: 1400px; margin: 0 auto; padding: 24px 5vw 80px; }
  .hpc-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: #67e8f9; font-weight: 700; }
  .hpc-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 4vw, 44px); font-weight: 600; letter-spacing: -0.02em; margin: 4px 0; }
  .hpc-title em { color: #67e8f9; font-style: italic; font-weight: 500; }
  .hpc-sub { font-size: 14px; color: #9aa6b6; max-width: 720px; margin-top: 6px; line-height: 1.6; }
  .hpc-grid { display: grid; grid-template-columns: 320px minmax(0, 1fr); gap: 20px; margin-top: 24px; }
  @media (max-width: 1100px) { .hpc-grid { grid-template-columns: 1fr; } }
  .hpc-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 14px; padding: 18px; margin-bottom: 14px; }
  .hpc-panel h3 { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: #67e8f9; margin: 0 0 12px; font-weight: 700; }
  .hpc-ctrl { display: grid; gap: 10px; }
  .hpc-ctrl label { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; display: block; margin-bottom: 3px; }
  .hpc-ctrl input, .hpc-ctrl select { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; color: #fff; padding: 8px 10px; border-radius: 5px; font-size: 12.5px; }
  .hpc-btn { background: #67e8f9; color: #04161b; border: none; padding: 10px 22px; border-radius: 6px; font-weight: 700; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; width: 100%; }
  .hpc-btn:hover { transform: translateY(-1px); }
  .hpc-metric { display: grid; grid-template-columns: 1fr auto; gap: 8px; padding: 8px 0; border-bottom: 1px solid #1a1a25; font-family: 'Geist Mono', monospace; font-size: 12px; }
  .hpc-metric:last-child { border-bottom: none; }
  .hpc-metric-label { color: #9aa6b6; }
  .hpc-metric-val { color: #67e8f9; font-weight: 700; }

  .gantt-svg { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; }
  .amdahl-svg { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; }
  .heatmap-grid { display: grid; gap: 1px; padding: 8px; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; }
  .heatmap-cell { aspect-ratio: 1; border-radius: 1px; }
</style>

<main class="hpc-wrap">
  <p class="hpc-eyebrow">AquinTutor · HPC Lab</p>
  <h1 class="hpc-title">HPC <em>job simulator</em>.</h1>
  <p class="hpc-sub">Configure a cluster (nodes × cores × interconnect latency). Pick a workload (matrix multiply / Monte Carlo / N-body / image filter). Watch the real Gantt chart, Amdahl's-law speedup curve, and per-core utilisation heatmap unfold in real time. Pure browser-side math.</p>

  <div class="hpc-grid">

    {/* LEFT: cluster + workload config */}
    <div>
      <div class="hpc-panel">
        <h3>Cluster</h3>
        <div class="hpc-ctrl">
          <div><label>Nodes</label><input id="cfgNodes" type="number" value="4" min="1" max="64"/></div>
          <div><label>Cores per node</label><input id="cfgCores" type="number" value="8" min="1" max="64"/></div>
          <div><label>Memory per node (GB)</label><input id="cfgMem" type="number" value="64" min="1" max="1024"/></div>
          <div><label>Interconnect latency (μs)</label><input id="cfgLatency" type="number" value="2" min="0.1" max="500" step="0.1"/></div>
          <div><label>Interconnect bandwidth (GB/s)</label><input id="cfgBandwidth" type="number" value="100" min="1" max="800"/></div>
        </div>
      </div>

      <div class="hpc-panel">
        <h3>Workload</h3>
        <div class="hpc-ctrl">
          <div><label>Type</label>
            <select id="cfgWorkload">
              <option value="matmul">Matrix multiply (cache-friendly chunks)</option>
              <option value="monte_carlo">Monte Carlo (embarrassingly parallel)</option>
              <option value="nbody">N-body (all-pairs O(n²))</option>
              <option value="image_filter">Image filter (stencil)</option>
              <option value="reduction">Reduction (tree of sums)</option>
            </select>
          </div>
          <div><label>Problem size (N)</label><input id="cfgSize" type="number" value="4096" min="32" max="65536" step="32"/></div>
          <div><label>Serial fraction (Amdahl's p)</label><input id="cfgSerial" type="number" value="0.05" min="0" max="1" step="0.01"/></div>
        </div>
      </div>

      <button class="hpc-btn" id="runBtn">Run simulation</button>

      <div class="hpc-panel" style="margin-top:14px;">
        <h3>Live metrics</h3>
        <div class="hpc-metric"><span class="hpc-metric-label">Wall time</span><span class="hpc-metric-val" id="mWall">— ms</span></div>
        <div class="hpc-metric"><span class="hpc-metric-label">Speedup vs serial</span><span class="hpc-metric-val" id="mSpeedup">—×</span></div>
        <div class="hpc-metric"><span class="hpc-metric-label">Parallel efficiency</span><span class="hpc-metric-val" id="mEff">—%</span></div>
        <div class="hpc-metric"><span class="hpc-metric-label">Idle cores · avg</span><span class="hpc-metric-val" id="mIdle">—%</span></div>
        <div class="hpc-metric"><span class="hpc-metric-label">Communication overhead</span><span class="hpc-metric-val" id="mComm">— ms</span></div>
      </div>
    </div>

    {/* RIGHT: visuals */}
    <div>
      <div class="hpc-panel">
        <h3>Gantt chart · core × time</h3>
        <svg id="ganttSvg" class="gantt-svg" viewBox="0 0 1000 360" preserveAspectRatio="xMidYMid meet"></svg>
      </div>

      <div class="hpc-panel">
        <h3>Amdahl's law — speedup vs core count (parallel fraction = 1 − p)</h3>
        <svg id="amdahlSvg" class="amdahl-svg" viewBox="0 0 600 320" preserveAspectRatio="xMidYMid meet"></svg>
      </div>

      <div class="hpc-panel">
        <h3>Core utilisation heatmap</h3>
        <div id="heatRoot" class="heatmap-grid"></div>
        <p style="font-family:'Geist Mono',monospace;font-size:10px;color:#9aa6b6;text-align:center;margin:8px 0 0;letter-spacing:0.08em;">DARK = idle · BRIGHT = compute</p>
      </div>
    </div>
  </div>
</main>

<script is:inline>
  /* ============================================================
     AquinTutor HPC Job Simulator — pure-JS scheduling math.
     Models a cluster of N nodes × C cores per node, schedules a
     workload, computes per-core busy windows, communication
     overhead, Amdahl's-law speedup curve. NO 3rd-party libs.
     ============================================================ */
  (function () {

    function $(id) { return document.getElementById(id); }
    function getCfg() {
      return {
        nodes:     parseInt($('cfgNodes').value, 10) || 1,
        cores:     parseInt($('cfgCores').value, 10) || 1,
        mem:       parseFloat($('cfgMem').value) || 1,
        latency:   parseFloat($('cfgLatency').value) || 0,    // μs
        bandwidth: parseFloat($('cfgBandwidth').value) || 1,  // GB/s
        workload:  $('cfgWorkload').value,
        size:      parseInt($('cfgSize').value, 10) || 1024,
        serial:    parseFloat($('cfgSerial').value) || 0,     // Amdahl's p
      };
    }

    // Workload model — returns base FLOPs and a comm-cost factor.
    // Real research-grade scaling shapes for each pattern.
    function workloadModel(w, N) {
      switch (w) {
        case 'matmul':       return { flops: 2 * N * N * N, comm: N * N, label: 'GEMM' };
        case 'monte_carlo':  return { flops: N * 1000, comm: 1, label: 'Embarrassingly parallel' };
        case 'nbody':        return { flops: N * N * 50, comm: N * N / 4, label: 'All-pairs O(N²)' };
        case 'image_filter': return { flops: N * N * 25, comm: N, label: 'Stencil 5×5' };
        case 'reduction':    return { flops: N * 4, comm: Math.ceil(Math.log2(N || 1)), label: 'Tree reduction' };
        default:             return { flops: N, comm: N, label: 'Generic' };
      }
    }

    function simulate() {
      var cfg = getCfg();
      var totalCores = cfg.nodes * cfg.cores;
      var model = workloadModel(cfg.workload, cfg.size);

      // SERIAL wall time — assume 4 GFLOPS per core for a baseline.
      var coreFLOPS = 4e9;
      var serialTime = model.flops / coreFLOPS; // seconds

      // Compute time per core when parallelised.
      // Amdahl: speedup = 1 / (p + (1-p)/n)
      var p = cfg.serial;
      var idealSpeedup = 1 / (p + (1 - p) / totalCores);
      // Communication overhead: each pair-comm crosses interconnect.
      // Cost = bytes / bandwidth + msgs * latency
      var bytes = model.comm * 8; // 8 bytes per double
      var commTime = (bytes / (cfg.bandwidth * 1e9)) + (model.comm * cfg.latency * 1e-6);
      // Effective parallel time
      var parallelComputeTime = serialTime / idealSpeedup;
      var wallTime = parallelComputeTime + commTime;
      var realSpeedup = serialTime / wallTime;
      var efficiency = realSpeedup / totalCores;
      var idleAvg = 1 - efficiency;

      // Per-core busy windows for Gantt — divide work into chunks.
      var perCoreChunks = [];
      var chunks = Math.max(totalCores, Math.min(64, totalCores * 4));
      var perChunkTime = parallelComputeTime / Math.max(1, chunks / totalCores);
      // Simulate slight load imbalance for non-trivial workloads.
      var imbalance = cfg.workload === 'monte_carlo' ? 0.02 : cfg.workload === 'nbody' ? 0.15 : 0.08;
      for (var c = 0; c < totalCores; c++) {
        var blocks = [];
        var t = 0;
        var nChunks = Math.ceil(chunks / totalCores);
        for (var k = 0; k < nChunks; k++) {
          var jitter = 1 + (Math.random() * 2 - 1) * imbalance;
          var dur = perChunkTime * jitter;
          blocks.push({ start: t, end: t + dur });
          t += dur;
          // Inject a small comm gap between chunks
          if (k < nChunks - 1) t += commTime * 0.05;
        }
        perCoreChunks.push(blocks);
      }
      var actualWallTime = Math.max.apply(null, perCoreChunks.map(function (cc) { return cc[cc.length - 1].end; })) + commTime;

      // Metrics
      $('mWall').textContent = (actualWallTime * 1000).toFixed(2) + ' ms';
      $('mSpeedup').textContent = realSpeedup.toFixed(2) + '×';
      $('mEff').textContent = (efficiency * 100).toFixed(1) + '%';
      $('mIdle').textContent = (idleAvg * 100).toFixed(1) + '%';
      $('mComm').textContent = (commTime * 1000).toFixed(2) + ' ms';

      drawGantt(perCoreChunks, actualWallTime, totalCores);
      drawAmdahl(p, totalCores);
      drawHeatmap(perCoreChunks, actualWallTime, totalCores);
    }

    function drawGantt(perCoreChunks, totalT, nCores) {
      var svg = $('ganttSvg'); svg.innerHTML = '';
      var W = 1000, H = 360, pad = 60;
      var rowH = (H - pad - 20) / Math.max(1, nCores);
      var scale = (W - pad - 30) / totalT;

      // axis
      var ax = document.createElementNS('http://www.w3.org/2000/svg', 'line');
      ax.setAttribute('x1', pad); ax.setAttribute('y1', H - 20); ax.setAttribute('x2', W - 20); ax.setAttribute('y2', H - 20);
      ax.setAttribute('stroke', '#2a2a35'); svg.appendChild(ax);
      for (var t = 0; t <= 5; t++) {
        var tx = pad + (W - pad - 30) * (t / 5);
        var tl = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        tl.setAttribute('x', tx); tl.setAttribute('y', H - 6);
        tl.setAttribute('fill', '#9aa6b6'); tl.setAttribute('font-family', 'Geist Mono');
        tl.setAttribute('font-size', '10'); tl.setAttribute('text-anchor', 'middle');
        tl.textContent = ((totalT * t / 5) * 1000).toFixed(1) + 'ms';
        svg.appendChild(tl);
      }

      // bars
      for (var c = 0; c < nCores; c++) {
        var y = 8 + c * rowH;
        var lbl = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        lbl.setAttribute('x', 8); lbl.setAttribute('y', y + rowH * 0.7);
        lbl.setAttribute('fill', '#9aa6b6'); lbl.setAttribute('font-family', 'Geist Mono');
        lbl.setAttribute('font-size', Math.min(10, rowH * 0.5));
        lbl.textContent = 'c' + c;
        svg.appendChild(lbl);
        perCoreChunks[c].forEach(function (b, k) {
          var rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
          rect.setAttribute('x', pad + b.start * scale);
          rect.setAttribute('y', y + 2);
          rect.setAttribute('width', Math.max(1, (b.end - b.start) * scale));
          rect.setAttribute('height', rowH - 4);
          var hue = (200 + k * 12) % 360;
          rect.setAttribute('fill', 'hsl(' + hue + ', 70%, 55%)');
          rect.setAttribute('opacity', '0.85');
          rect.setAttribute('rx', 2);
          svg.appendChild(rect);
        });
      }
    }

    function drawAmdahl(p, current) {
      var svg = $('amdahlSvg'); svg.innerHTML = '';
      var W = 600, H = 320, pad = 50;
      // Axes
      var ax = document.createElementNS('http://www.w3.org/2000/svg', 'line');
      ax.setAttribute('x1', pad); ax.setAttribute('y1', H - pad); ax.setAttribute('x2', W - 10); ax.setAttribute('y2', H - pad);
      ax.setAttribute('stroke', '#2a2a35'); svg.appendChild(ax);
      var ay = document.createElementNS('http://www.w3.org/2000/svg', 'line');
      ay.setAttribute('x1', pad); ay.setAttribute('y1', H - pad); ay.setAttribute('x2', pad); ay.setAttribute('y2', 20);
      ay.setAttribute('stroke', '#2a2a35'); svg.appendChild(ay);

      // Compute curve
      var maxN = 256;
      var maxSpeedup = p > 0 ? 1 / p : maxN;
      var path = '';
      for (var n = 1; n <= maxN; n++) {
        var s = 1 / (p + (1 - p) / n);
        var x = pad + (W - pad - 10) * (Math.log10(n) / Math.log10(maxN));
        var y = (H - pad) - (H - pad - 20) * (s / maxSpeedup);
        path += (n === 1 ? 'M' : 'L') + x + ',' + y;
      }
      var p1 = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      p1.setAttribute('d', path); p1.setAttribute('fill', 'none');
      p1.setAttribute('stroke', '#67e8f9'); p1.setAttribute('stroke-width', '2.5');
      svg.appendChild(p1);

      // Plot current
      var cx = pad + (W - pad - 10) * (Math.log10(current) / Math.log10(maxN));
      var csp = 1 / (p + (1 - p) / current);
      var cy = (H - pad) - (H - pad - 20) * (csp / maxSpeedup);
      var dot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      dot.setAttribute('cx', cx); dot.setAttribute('cy', cy); dot.setAttribute('r', 6);
      dot.setAttribute('fill', '#fbbf24'); svg.appendChild(dot);
      var lbl = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      lbl.setAttribute('x', cx + 10); lbl.setAttribute('y', cy + 4);
      lbl.setAttribute('fill', '#fbbf24'); lbl.setAttribute('font-family', 'Geist Mono');
      lbl.setAttribute('font-size', 11); lbl.setAttribute('font-weight', '700');
      lbl.textContent = current + ' cores · ' + csp.toFixed(2) + '×';
      svg.appendChild(lbl);

      // Limit line
      var lim = document.createElementNS('http://www.w3.org/2000/svg', 'line');
      var limY = (H - pad) - (H - pad - 20) * (maxSpeedup / maxSpeedup);
      lim.setAttribute('x1', pad); lim.setAttribute('x2', W - 10); lim.setAttribute('y1', limY); lim.setAttribute('y2', limY);
      lim.setAttribute('stroke', '#f87171'); lim.setAttribute('stroke-width', 1.5); lim.setAttribute('stroke-dasharray', '4 4');
      svg.appendChild(lim);
      var ll = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      ll.setAttribute('x', W - 16); ll.setAttribute('y', limY - 4); ll.setAttribute('text-anchor', 'end');
      ll.setAttribute('fill', '#f87171'); ll.setAttribute('font-family', 'Geist Mono'); ll.setAttribute('font-size', 10);
      ll.textContent = 'Limit ' + maxSpeedup.toFixed(1) + '×  (1/p)';
      svg.appendChild(ll);

      // Axis labels
      var xl = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      xl.setAttribute('x', W / 2); xl.setAttribute('y', H - 8); xl.setAttribute('text-anchor', 'middle');
      xl.setAttribute('fill', '#9aa6b6'); xl.setAttribute('font-family', 'Geist Mono'); xl.setAttribute('font-size', 10);
      xl.textContent = 'cores (log)';
      svg.appendChild(xl);
      var yl = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      yl.setAttribute('x', -H / 2); yl.setAttribute('y', 14); yl.setAttribute('text-anchor', 'middle');
      yl.setAttribute('transform', 'rotate(-90)');
      yl.setAttribute('fill', '#9aa6b6'); yl.setAttribute('font-family', 'Geist Mono'); yl.setAttribute('font-size', 10);
      yl.textContent = 'speedup ×';
      svg.appendChild(yl);
    }

    function drawHeatmap(perCoreChunks, totalT, nCores) {
      var root = $('heatRoot');
      root.innerHTML = '';
      var cols = 40; // time slices
      root.style.gridTemplateColumns = 'repeat(' + cols + ', 1fr)';
      for (var c = 0; c < nCores; c++) {
        for (var k = 0; k < cols; k++) {
          var ts = totalT * k / cols, te = totalT * (k + 1) / cols;
          // busy fraction in this slice
          var busy = 0;
          perCoreChunks[c].forEach(function (b) {
            var ov = Math.max(0, Math.min(b.end, te) - Math.max(b.start, ts));
            busy += ov;
          });
          var f = busy / (te - ts);
          var cell = document.createElement('div');
          cell.className = 'heatmap-cell';
          // Color: dark navy to bright cyan
          var alpha = Math.min(1, f);
          cell.style.background = 'rgba(103, 232, 249, ' + (alpha * 0.9 + 0.05) + ')';
          root.appendChild(cell);
        }
      }
    }

    $('runBtn').addEventListener('click', simulate);
    simulate();

  })();
</script>

<div id="demoHint" style="position:fixed;left:16px;bottom:16px;max-width:330px;background:#11131a;color:#e8e8ee;border:1px solid #FF4F00;border-radius:12px;padding:14px 16px;z-index:9999;box-shadow:0 12px 34px rgba(0,0,0,0.45);">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:7px;gap:10px;">
    <span style="font-family:'Geist Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#FF4F00;font-weight:700;">Try this &middot; demo</span>
    <button onclick="this.closest('#demoHint').remove()" style="background:transparent;border:none;color:#9aa6b6;cursor:pointer;font-size:18px;line-height:1;padding:0;">&times;</button>
  </div>
  <p style="margin:0;font-size:12.5px;line-height:1.55;color:#cfd6da;font-family:'Inter Tight',sans-serif,system-ui;">Pick the <b>Matrix multiply</b> workload, set nodes 4 &times; cores 8. The Gantt chart, the Amdahl speedup curve, and the per-core heatmap all redraw live.</p>
</div>

</AquintutorLayout>
