---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/practice-hub'));

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

// All practice-enabled subjects (neutral order — no hardcoded Sanskrit default).
let subjects: any[] = [];
try {
  subjects = rows(await db.execute(sql`
    SELECT slug, title FROM tests
    WHERE is_published = true AND COALESCE(practice_enabled, true) = true
    ORDER BY title ASC
    LIMIT 60
  `));
} catch (_) {}

// The learner's enrolled courses — so we can default to THEIR track, not Sanskrit.
let enrolled: any[] = [];
try {
  enrolled = rows(await db.execute(sql`
    SELECT c.title, c.slug, c.school_code
    FROM training_enrollments e JOIN training_courses c ON c.id = e.course_id
    WHERE e.user_id = ${user.id}
    ORDER BY e.enrolled_at DESC LIMIT 8
  `));
} catch (_) {}
---
<AquintutorLayout title="Practice Hub" description="Choose what you'd like to practise.">
  <section style="max-width:920px; margin:0 auto; padding:40px 24px 60px;">
    <p style="font-family:'Inter Tight',monospace; font-size:12px; color:var(--rust); font-weight:700; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">Practice Hub</p>
    <h1 class="font-display" style="font-size:clamp(1.9rem,4vw,2.8rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500; margin:0 0 8px;">What would you like to practise today?</h1>
    <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); line-height:1.6; margin:0 0 28px;">Pick a subject below. We'll remember your choice for next time.</p>

    <a href="/aquintutor/learn" style="display:flex; align-items:center; gap:14px; background:var(--sand-100,#f7f2ea); border:1.5px solid var(--rust); border-radius:14px; padding:16px 18px; margin-bottom:26px; text-decoration:none;">
      <div style="width:40px; height:40px; border-radius:11px; background:var(--rust); color:#fff; display:flex; align-items:center; justify-content:center; flex-shrink:0;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg></div>
      <div style="flex:1;"><div style="font-family:'Fraunces',Georgia,serif; font-size:1.1rem; font-weight:600; color:var(--ink-900,#1a1510);">Your Mastery Tree</div><div style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink-500);">Verified, forward-only learning — hints not answers, teach-it-back, exit tickets.</div></div>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--rust)" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </a>

    <div id="lastWrap" style="display:none; margin-bottom:24px;">
      <p style="font-family:'Inter Tight',monospace; font-size:11px; color:var(--ink-500); letter-spacing:0.12em; text-transform:uppercase; margin:0 0 8px;">Continue where you left off</p>
      <a id="lastLink" href="#" style="display:inline-flex; align-items:center; gap:10px; background:var(--rust); color:#fff; padding:12px 20px; border-radius:10px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:700; text-decoration:none;">
        <span id="lastLabel">Continue</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>

    {enrolled.length > 0 && (
      <div style="margin-bottom:30px;">
        <p style="font-family:'Inter Tight',monospace; font-size:11px; color:var(--ink-500); letter-spacing:0.12em; text-transform:uppercase; margin:0 0 10px;">From your enrolled courses</p>
        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:10px;">
          {enrolled.map((c) => (
            <a href={'/aquintutor/courses/' + c.slug} class="ph-card" data-practice="course" data-slug={c.slug} data-label={c.title} style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:14px 16px; text-decoration:none; color:inherit; display:block;">
              {c.school_code && <span style="font-family:'Inter Tight',monospace; font-size:10px; font-weight:700; color:var(--rust); letter-spacing:0.08em;">{c.school_code}</span>}
              <p style="font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; margin:4px 0 0; color:var(--ink);">{c.title}</p>
            </a>
          ))}
        </div>
      </div>
    )}

    <p style="font-family:'Inter Tight',monospace; font-size:11px; color:var(--ink-500); letter-spacing:0.12em; text-transform:uppercase; margin:0 0 10px;">All subjects</p>
    {subjects.length === 0 ? (
      <div style="background:var(--paper); border:1px dashed var(--rule); border-radius:12px; padding:28px; text-align:center;">
        <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); margin:0 0 12px;">No practice subjects are published yet.</p>
        <a href="/aquintutor/tests" style="color:var(--rust); font-family:'Inter Tight',sans-serif; font-weight:600; text-decoration:none;">Browse the test catalogue &rarr;</a>
      </div>
    ) : (
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:10px;">
        <a href="/aquintutor/practice" class="ph-card" data-practice="coding" data-slug="__coding" data-label="Coding practice" style="background:var(--ink); color:#fff; border-radius:12px; padding:16px; text-decoration:none; display:block;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:700; margin:0;">Coding practice</p>
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; opacity:0.7; margin:4px 0 0;">DSA, languages, contests</p>
        </a>
        {subjects.map((s) => (
          <a href={'/aquintutor/practice/' + s.slug} class="ph-card" data-practice="test" data-slug={s.slug} data-label={s.title} style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:16px; text-decoration:none; color:inherit; display:block;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; margin:0; color:var(--ink);">{s.title}</p>
            <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink-500); margin:4px 0 0;">Practise &rarr;</p>
          </a>
        ))}
      </div>
    )}
  </section>

  <script is:inline>
    (function () {
      var KEY = 'aqt_practice_last';
      // Remember the choice when a card is clicked.
      document.querySelectorAll('.ph-card').forEach(function (a) {
        a.addEventListener('click', function () {
          try { localStorage.setItem(KEY, JSON.stringify({ href: a.getAttribute('href'), label: a.getAttribute('data-label') })); } catch (_) {}
        });
      });
      // Surface "continue" if we have a remembered, still-valid choice.
      try {
        var last = JSON.parse(localStorage.getItem(KEY) || 'null');
        if (last && last.href) {
          var exists = Array.prototype.some.call(document.querySelectorAll('.ph-card'), function (a) { return a.getAttribute('href') === last.href; });
          if (exists) {
            var wrap = document.getElementById('lastWrap');
            var link = document.getElementById('lastLink');
            document.getElementById('lastLabel').textContent = 'Continue ' + (last.label || 'practice');
            link.setAttribute('href', last.href);
            wrap.style.display = 'block';
          }
        }
      } catch (_) {}
    })();
  </script>
</AquintutorLayout>
