---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/start'));

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
async function n(q: any): Promise<number> { try { const r = rows(await db.execute(q)); return r[0]?.c ?? 0; } catch { return 0; } }

const hasFace = (await n(sql`SELECT COUNT(*)::int AS c FROM user_face_enrollments WHERE user_id = ${user.id} AND is_active = true`)) > 0;
const enrolCount = await n(sql`SELECT COUNT(*)::int AS c FROM training_enrollments WHERE user_id = ${user.id}`);
const lessonDone = (await n(sql`SELECT COUNT(*)::int AS c FROM training_lesson_progress WHERE user_id = ${user.id} AND completed_at IS NOT NULL`)) > 0
  || (await n(sql`SELECT COUNT(*)::int AS c FROM training_lesson_completions WHERE user_id = ${user.id}`)) > 0;
const certCount = await n(sql`SELECT COUNT(*)::int AS c FROM course_certificates WHERE user_id = ${user.id}`);
// "tried a lab" — we log it via activity; approximate with any activity event of type that hints at labs, else false
const triedLab = (await n(sql`SELECT COUNT(*)::int AS c FROM activity_events WHERE user_id = ${user.id} AND event_type IN ('session_start','minute_activity') AND journey_stage = 'learn'`)) > 0;

const steps = [
  { done: hasFace, title: 'Secure your account', body: 'Set up Face 2FA so your certificates and exams are provably yours.', cta: 'Set up 2FA', href: '/portal/face-setup?next=/aquintutor/start' },
  { done: enrolCount > 0, title: 'Enrol in your first course', body: 'Pick something from the catalogue. The showcase course is a great 10-minute start.', cta: 'Browse courses', href: '/aquintutor/courses' },
  { done: lessonDone, title: 'Complete a lesson', body: 'Open a course and finish one lesson — you will see text, a worked example, and a live simulator embedded right in the page.', cta: 'Open a course', href: '/aquintutor/courses' },
  { done: triedLab, title: 'Drive a live lab', body: 'Open any of the 22 simulators and move the controls - hands-on work a video lecture can never give you.', cta: 'Open the labs', href: '/aquintutor/labs' },
  { done: certCount > 0, title: 'Earn your first certificate', body: 'Finish a course to receive a blockchain-verifiable certificate anyone can check.', cta: 'See the ledger', href: '/verify' },
];
const doneCount = steps.filter((s) => s.done).length;
const pct = Math.round((doneCount / steps.length) * 100);
const firstName = (user.name || '').split(' ')[0] || 'there';
---
<AquintutorLayout title="Start here" description="Your guided first steps on AquinTutor." noindex={true}>
<style>
  .st { max-width: 920px; margin: 0 auto; padding: 0 28px; }
  .st-crumb { border-bottom: 1px solid var(--rule); background: var(--sand-100); margin: 0 -28px; }
  .st-crumb-in { max-width: 920px; margin: 0 auto; padding: 10px 28px; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.08em; color: var(--ink-500); }
  .st-crumb-in a { color: var(--ink-500); text-decoration: none; } .st-crumb-in .cur { color: var(--rust); font-weight: 600; }
  .st-hero { padding: 44px 0 10px; }
  .st-eye { font-family: 'JetBrains Mono', monospace; font-size: 10.5px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--rust); font-weight: 700; margin: 0; }
  .st-h1 { font-family: 'Fraunces', serif; font-size: clamp(2.2rem, 5vw, 3.2rem); font-weight: 500; letter-spacing: -0.025em; margin: 8px 0 6px; line-height: 1.02; }
  .st-h1 em { font-style: italic; color: var(--rust); }
  .st-sub { font-size: 16px; color: var(--ink-500); }

  .st-prog { background: var(--paper); border: 1px solid var(--rule); border-radius: 16px; padding: 18px 22px; margin: 22px 0; display: flex; align-items: center; gap: 18px; }
  .st-prog-bar { flex: 1; background: var(--sand-100); height: 12px; border-radius: 100px; overflow: hidden; }
  .st-prog-fill { height: 100%; background: linear-gradient(90deg, #1A6B35, #86efac); border-radius: 100px; transition: width .4s; }
  .st-prog-n { font-family: 'Fraunces', serif; font-size: 28px; font-weight: 600; color: var(--ink); }

  .st-step { background: var(--paper); border: 1px solid var(--rule); border-radius: 16px; padding: 20px 22px; margin-bottom: 12px; display: flex; gap: 16px; align-items: flex-start; }
  .st-step.done { border-color: rgba(26,107,53,0.4); background: linear-gradient(135deg, rgba(26,107,53,0.05), var(--paper)); }
  .st-check { width: 34px; height: 34px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; border: 2px solid var(--rule); color: var(--ink-500); font-family: 'JetBrains Mono', monospace; font-weight: 700; }
  .st-step.done .st-check { background: #1A6B35; border-color: #1A6B35; color: #fff; }
  .st-step-t { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; line-height: 1.15; margin: 0; }
  .st-step.done .st-step-t { color: var(--ink-500); }
  .st-step-b { font-size: 14px; color: var(--ink-500); line-height: 1.5; margin: 5px 0 12px; }
  .st-cta { background: var(--rust); color: #fff; padding: 9px 18px; border-radius: 8px; text-decoration: none; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 700; display: inline-block; }
  .st-step.done .st-cta { background: transparent; border: 1px solid var(--rule); color: var(--ink-500); }
  .st-done-badge { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: #1A6B35; font-weight: 700; }

  .st-explore { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px; margin-top: 28px; }
  .st-ex { background: var(--paper); border: 1px solid var(--rule); border-radius: 12px; padding: 16px; text-decoration: none; color: inherit; }
  .st-ex:hover { border-color: var(--rust); }
  .st-ex-t { font-family: 'Cormorant Garamond', serif; font-size: 17px; font-weight: 600; }
  .st-ex-d { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--ink-500); margin-top: 3px; text-transform: uppercase; letter-spacing: 0.05em; }
  .st-celebrate { background: linear-gradient(135deg, #1A6B35, #2E7D4F); color: #fff; border-radius: 16px; padding: 24px; text-align: center; margin: 22px 0; }
  .st-celebrate h2 { font-family: 'Cormorant Garamond', serif; font-size: 28px; margin: 0 0 6px; font-weight: 600; }
</style>

<div class="st-crumb"><div class="st-crumb-in"><a href="/aquintutor">AQUINTUTOR</a> <span style="margin:0 8px;">/</span> <span class="cur">START HERE</span></div></div>

<main class="st">
  <div class="st-hero">
    <p class="st-eye">AquinTutor · Get started</p>
    <h1 class="st-h1">Welcome, <em>{firstName}</em>.</h1>
    <p class="st-sub">Five steps to go from new account to a verified credential. We track your progress so you always know what's next.</p>
  </div>

  {pct === 100 ? (
    <div class="st-celebrate"><h2>You're all set.</h2><p style="opacity:0.9;margin:0;">Every onboarding step done. Now go deep — the whole institution is open to you.</p></div>
  ) : (
    <div class="st-prog">
      <span class="st-prog-n">{pct}%</span>
      <div class="st-prog-bar"><div class="st-prog-fill" style={'width:' + pct + '%'}></div></div>
      <span style="font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--ink-500);">{doneCount} of {steps.length}</span>
    </div>
  )}

  {steps.map((s, i) => (
    <div class={"st-step" + (s.done ? " done" : "")}>
      <div class="st-check">{s.done ? '✓' : (i + 1)}</div>
      <div style="flex:1;">
        <p class="st-step-t">{s.title}</p>
        <p class="st-step-b">{s.body}</p>
        {s.done ? <span class="st-done-badge">Done</span> : <a href={s.href} class="st-cta">{s.cta} &rarr;</a>}
      </div>
    </div>
  ))}

  <h2 style="font-family:'Fraunces',serif;font-size:1.4rem;font-weight:500;margin:30px 0 12px;">While you're here, <em style="font-style:italic;color:var(--rust);">explore</em></h2>
  <div class="st-explore">
    <a href="/aquintutor/teach" class="st-ex"><div class="st-ex-t">Live teaching canvas</div><div class="st-ex-d">Type → visual</div></a>
    <a href="/aquintutor/quantum/composer" class="st-ex"><div class="st-ex-t">Quantum composer</div><div class="st-ex-d">Real circuits</div></a>
    <a href="/aquintutor/labs/xr" class="st-ex"><div class="st-ex-t">XR · VR labs</div><div class="st-ex-d">Enter a headset</div></a>
    <a href="/portal/wellbeing" class="st-ex"><div class="st-ex-t">Wellbeing</div><div class="st-ex-d">Focus + breaks</div></a>
    <a href="/aquintutor/progress" class="st-ex"><div class="st-ex-t">My progress</div><div class="st-ex-d">Health score</div></a>
    <a href="/aquintutor/incubation" class="st-ex"><div class="st-ex-t">Incubation</div><div class="st-ex-d">Build a startup</div></a>
  </div>
  <div style="height:50px;"></div>
</main>
</AquintutorLayout>
