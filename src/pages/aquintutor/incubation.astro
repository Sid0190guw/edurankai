---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;

let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const name = (fd.get('name') as string || '').trim();
    const email = (fd.get('email') as string || '').trim();
    const education = (fd.get('education') as string || '').trim();
    const prior_work_url = (fd.get('prior_work_url') as string || '').trim();
    const prototype_url = (fd.get('prototype_url') as string || '').trim();
    const idea_summary = (fd.get('idea_summary') as string || '').trim();
    const target_market = (fd.get('target_market') as string || '').trim();
    const plan_12mo = (fd.get('plan_12mo') as string || '').trim();
    if (!name || !email || idea_summary.length < 300 || plan_12mo.length < 300) errMsg = 'All fields required. Idea summary and 12-month plan must be 300+ characters each.';
    else {
      await db.execute(sql`CREATE TABLE IF NOT EXISTS eir_applications (
        id UUID PRIMARY KEY DEFAULT gen_random_uuid(), user_id UUID, name VARCHAR(200), email VARCHAR(200),
        education TEXT, prior_work_url TEXT, prototype_url TEXT, idea_summary TEXT, target_market TEXT,
        plan_12mo TEXT, status VARCHAR(20) NOT NULL DEFAULT 'pending', created_at TIMESTAMPTZ DEFAULT NOW())`);
      await db.execute(sql`INSERT INTO eir_applications (user_id, name, email, education, prior_work_url, prototype_url, idea_summary, target_market, plan_12mo)
        VALUES (${user?.id || null}, ${name}, ${email}, ${education}, ${prior_work_url || null}, ${prototype_url || null}, ${idea_summary}, ${target_market}, ${plan_12mo})`);
      okMsg = 'Application received. The Entrepreneur-in-Residence committee reviews monthly. Next cycle decision: end of next month.';
    }
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 240); }
}
---
<AquintutorLayout title="Incubation · AquinTutor" description="From learning to building — tinkering labs, incubation centres, EIR fellowships, fab labs, and a mentor network of 1,000+.">

<style>
  body { background: #FAF8F5; }
  .ic-wrap { max-width: 1280px; margin: 0 auto; padding: 24px 5vw 100px; }
  .ic-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .ic-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 6vw, 72px); font-weight: 600; letter-spacing: -0.03em; margin: 8px 0 14px; line-height: 1; }
  .ic-title em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .ic-sub { font-size: 17px; color: #2E2520; max-width: 720px; line-height: 1.65; }

  .ic-strip { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px; margin: 32px 0 56px; }
  .ic-stat { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 10px; padding: 16px 18px; }
  .ic-stat-val { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 600; color: #0E0B08; line-height: 1; letter-spacing: -0.02em; }
  .ic-stat-lbl { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: #7A6F68; margin-top: 5px; font-weight: 700; }

  .ic-section { padding: 36px 0; border-top: 1px solid rgba(14,11,8,0.10); }
  .ic-section-head { display: flex; gap: 18px; align-items: flex-start; margin-bottom: 18px; }
  .ic-section-icon { width: 52px; height: 52px; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: #fff; flex-shrink: 0; }
  .ic-section-num { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin: 0; }
  .ic-section-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(26px, 3.5vw, 34px); font-weight: 600; letter-spacing: -0.02em; margin: 4px 0 6px; line-height: 1.1; }
  .ic-section-sub { font-size: 15px; color: #2E2520; max-width: 740px; line-height: 1.65; }

  .ic-chips { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 12px; }
  .ic-chip { font-family: 'Geist Mono', monospace; font-size: 11px; padding: 5px 12px; border-radius: 100px; background: #FFF3EE; color: #FF4F00; border: 1px solid #FFD4BC; font-weight: 600; }

  .ic-tier-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 14px; margin-top: 16px; }
  .ic-tier { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 22px; }
  .ic-tier-eye { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .ic-tier-title { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 600; margin: 6px 0 8px; line-height: 1.2; letter-spacing: -0.01em; }
  .ic-tier-desc { font-size: 13.5px; color: #2E2520; line-height: 1.65; }

  .ic-cta { display: inline-flex; align-items: center; gap: 6px; background: transparent; border: 1px solid rgba(14,11,8,0.15); color: #0E0B08; padding: 8px 16px; border-radius: 8px; text-decoration: none; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 700; margin-top: 14px; }
  .ic-cta:hover { background: #FF4F00; color: #fff; border-color: #FF4F00; }

  .ic-challenge { background: linear-gradient(135deg, #fff, #FFF3EE); border: 1px solid rgba(255,79,0,0.2); border-radius: 12px; padding: 18px; }
  .ic-challenge-title { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; margin: 0 0 6px; line-height: 1.2; }
  .ic-challenge-meta { display: flex; justify-content: space-between; font-family: 'Geist Mono', monospace; font-size: 11px; color: #FF4F00; margin-top: 10px; padding-top: 8px; border-top: 1px solid rgba(255,79,0,0.15); }

  .ic-mentor-cat { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 10px; padding: 16px; text-align: center; }
  .ic-mentor-cat-icon { display: inline-flex; width: 44px; height: 44px; border-radius: 50%; background: #FFF3EE; color: #FF4F00; align-items: center; justify-content: center; margin-bottom: 8px; }
  .ic-mentor-cat-title { font-weight: 700; font-size: 13.5px; color: #0E0B08; }

  .ic-form { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 22px; margin-top: 18px; }
  .ic-form input, .ic-form textarea { width: 100%; box-sizing: border-box; background: #FAF8F5; border: 1px solid rgba(14,11,8,0.15); padding: 10px 14px; border-radius: 8px; font-family: inherit; font-size: 14px; margin-bottom: 10px; }
  .ic-form label { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #7A6F68; font-weight: 700; margin-bottom: 5px; display: block; }
  .ic-form button { background: #FF4F00; color: #fff; padding: 11px 26px; border-radius: 8px; border: none; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700; }
</style>

<main class="ic-wrap">

  <header style="padding:20px 0 0;">
    <p class="ic-eyebrow">AquinTutor · Incubation</p>
    <h1 class="ic-title">From learning to <em>building</em>.</h1>
    <p class="ic-sub">Four-layer innovation infrastructure: national missions, university incubators, public-private hubs, and lab facilities. We connect learners to every layer — from school tinkering kits to a million-rupee prototype grant.</p>
  </header>

  <div class="ic-strip">
    <div class="ic-stat"><p class="ic-stat-val">10,000+</p><p class="ic-stat-lbl">Tinkering labs</p></div>
    <div class="ic-stat"><p class="ic-stat-val">72+</p><p class="ic-stat-lbl">Incubation centres</p></div>
    <div class="ic-stat"><p class="ic-stat-val">Up to ₹40 L</p><p class="ic-stat-lbl">Prototype grant</p></div>
    <div class="ic-stat"><p class="ic-stat-val">1,000+</p><p class="ic-stat-lbl">Mentor network</p></div>
    <div class="ic-stat"><p class="ic-stat-val">₹30k/mo</p><p class="ic-stat-lbl">EIR stipend</p></div>
  </div>

  <section class="ic-section">
    <div class="ic-section-head">
      <div class="ic-section-icon" style="background:#2b577e;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></div>
      <div>
        <p class="ic-section-num">01 · School tier</p>
        <h2 class="ic-section-title">Tinkering labs · grades 6 to 12.</h2>
        <p class="ic-section-sub">State-of-the-art tinkering spaces in schools. 3D printers, robotics kits, IoT sensors, miniaturised electronics, rapid-prototyping tools — bundled with a structured tinkering curriculum in English and 12 vernacular languages plus teacher guides.</p>
      </div>
    </div>
    <div class="ic-chips"><span class="ic-chip">3D printers</span><span class="ic-chip">Robotics kits</span><span class="ic-chip">IoT sensors</span><span class="ic-chip">Electronics benches</span><span class="ic-chip">Rapid prototyping</span><span class="ic-chip">AR/VR kits</span><span class="ic-chip">Maker kits</span></div>
    <div class="ic-tier-grid">
      <div class="ic-tier"><p class="ic-tier-eye">Marathon</p><p class="ic-tier-title">Annual innovation race</p><p class="ic-tier-desc">A nationwide 4-month make-a-thon. School teams submit working prototypes; top 100 win mentorship + prize purses.</p></div>
      <div class="ic-tier"><p class="ic-tier-eye">Tinkerpreneur</p><p class="ic-tier-title">Entrepreneurship for kids</p><p class="ic-tier-desc">Year-long programme: identify a real problem, build a prototype, pitch to a panel. 10,000+ student-teams ran it last year.</p></div>
      <div class="ic-tier"><p class="ic-tier-eye">Mega day</p><p class="ic-tier-title">National tinkering day</p><p class="ic-tier-desc">One-day mass tinkering event. Open-source challenge brief released 24 hours ahead.</p></div>
    </div>
  </section>

  <section class="ic-section">
    <div class="ic-section-head">
      <div class="ic-section-icon" style="background:#a04330;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4"/><path d="M21 12c0 5-3.6 9-9 9-3.5 0-6.7-2-8.3-5"/><path d="M3 12c0-5 3.6-9 9-9 3.5 0 6.7 2 8.3 5"/></svg></div>
      <div>
        <p class="ic-section-num">02 · Start-up tier</p>
        <h2 class="ic-section-title">Incubation centres &mdash; idea to scale.</h2>
        <p class="ic-section-sub">Three tiers of incubation support. Physical space + mentoring + seed funding + technical infrastructure.</p>
      </div>
    </div>
    <div class="ic-tier-grid">
      <div class="ic-tier"><p class="ic-tier-eye">Pre-incubation</p><p class="ic-tier-title">Idea to prototype</p><p class="ic-tier-desc">Up to ₹10 lakh prototype grant. 6-month track. For individuals and pre-incorporated start-ups — no institutional backing required.</p></div>
      <div class="ic-tier"><p class="ic-tier-eye">Incubation</p><p class="ic-tier-title">Seed to scale</p><p class="ic-tier-desc">12-month program. Seed funding access. Mentor pool, technical labs, network, demo days.</p></div>
      <div class="ic-tier"><p class="ic-tier-eye">Community</p><p class="ic-tier-title">Rural · tribal · frontier</p><p class="ic-tier-desc">Vernacular delivery, in-language mentor matching, regional problem statements.</p></div>
    </div>
    <div class="ic-chips" style="margin-top:16px;"><span class="ic-chip">Mentor pool</span><span class="ic-chip">Seed funding</span><span class="ic-chip">Technical labs</span><span class="ic-chip">Investor network</span><span class="ic-chip">Legal + IP</span><span class="ic-chip">Demo days</span></div>
  </section>

  <section class="ic-section">
    <div class="ic-section-head">
      <div class="ic-section-icon" style="background:#5b4a92;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 0 0-16 0"/></svg></div>
      <div>
        <p class="ic-section-num">03 · Fellowship</p>
        <h2 class="ic-section-title">Entrepreneur-in-Residence.</h2>
        <p class="ic-section-sub">Monthly fellowship of ~₹30,000 for up to 12 months. Lets founders work full-time on their idea without financial pressure.</p>
      </div>
    </div>

    {okMsg && <div style="background:rgba(26,107,53,0.08);border:1px solid #1A6B35;padding:14px 18px;border-radius:10px;margin-top:14px;"><p style="color:#1A6B35;font-weight:600;margin:0;">{okMsg}</p></div>}
    {errMsg && <div style="background:rgba(239,68,68,0.08);border:1px solid #b91c1c;padding:14px 18px;border-radius:10px;margin-top:14px;"><p style="color:#b91c1c;font-weight:600;margin:0;">{errMsg}</p></div>}

    {!okMsg && (
      <form method="POST" class="ic-form">
        <p class="ic-section-num" style="margin:0 0 12px;">Apply for EIR fellowship</p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
          <div><label>Full name *</label><input name="name" required maxlength="200" value={user?.name || ''}/></div>
          <div><label>Email *</label><input name="email" type="email" required maxlength="200" value={user?.email || ''}/></div>
        </div>
        <label>Education + current status</label>
        <input name="education" maxlength="400" placeholder="e.g. BTech CSE 2024 · 1 yr at startup X"/>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
          <div><label>Prior work URL</label><input name="prior_work_url" type="url" placeholder="GitHub / portfolio"/></div>
          <div><label>Prototype URL</label><input name="prototype_url" type="url" placeholder="Demo / video / repo"/></div>
        </div>
        <label>Idea summary (300+ chars) *</label>
        <textarea name="idea_summary" rows="5" minlength="300" maxlength="3000" required placeholder="What you want to build. The problem. The non-obvious insight."></textarea>
        <label>Target market</label>
        <input name="target_market" maxlength="200" placeholder="e.g. SME manufacturers in Maharashtra, language learners in tier-2 cities"/>
        <label>12-month plan (300+ chars) *</label>
        <textarea name="plan_12mo" rows="5" minlength="300" maxlength="3000" required placeholder="Q1 milestones. Q2 goals. Q3 fundraise / pivot. Q4 validation criteria."></textarea>
        <button type="submit">Submit application</button>
      </form>
    )}
  </section>

  <section class="ic-section">
    <div class="ic-section-head">
      <div class="ic-section-icon" style="background:#4a7048;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg></div>
      <div>
        <p class="ic-section-num">04 · Fab labs</p>
        <h2 class="ic-section-title">Fabrication &amp; prototyping.</h2>
        <p class="ic-section-sub">Shared high-end instrumentation via partner-of-record agreements. Subsidised access to CAD/CAM, 3D printing, CNC milling, laser cutting, PCB fabrication.</p>
      </div>
    </div>
    <div class="ic-chips" style="margin-top:14px;"><span class="ic-chip">CAD / CAM</span><span class="ic-chip">3D print · FDM</span><span class="ic-chip">3D print · SLA</span><span class="ic-chip">CNC mill</span><span class="ic-chip">Laser cutter</span><span class="ic-chip">PCB fab</span><span class="ic-chip">Soldering benches</span><span class="ic-chip">Optical bench</span><span class="ic-chip">Vacuum chamber</span></div>
    <a href="/aquintutor/facility" class="ic-cta">Browse equipment catalogue &rarr;</a>
  </section>

  <section class="ic-section">
    <div class="ic-section-head">
      <div class="ic-section-icon" style="background:#946322;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></div>
      <div>
        <p class="ic-section-num">05 · Challenges</p>
        <h2 class="ic-section-title">National grand challenges.</h2>
        <p class="ic-section-sub">Problem-led innovation contests. Open call. Cross-disciplinary teams. Domain experts on the judging panel.</p>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px;margin-top:16px;">
      <div class="ic-challenge"><p class="ic-challenge-title">Climate adaptation</p><p style="font-size:13px;color:#2E2520;line-height:1.55;margin:0;">Tools for smallholder farmers facing erratic monsoons. Cheap sensors, advisories in vernacular.</p><div class="ic-challenge-meta"><span>₹50 L pool</span><span>Q3 deadline</span></div></div>
      <div class="ic-challenge"><p class="ic-challenge-title">Healthcare access</p><p style="font-size:13px;color:#2E2520;line-height:1.55;margin:0;">Diagnostic devices for tier-3 PHCs. Sub-₹10k per unit, durable for 5+ years.</p><div class="ic-challenge-meta"><span>₹40 L pool</span><span>Q4 deadline</span></div></div>
      <div class="ic-challenge"><p class="ic-challenge-title">Educational equity</p><p style="font-size:13px;color:#2E2520;line-height:1.55;margin:0;">Vernacular tooling for first-generation learners. Offline-first. Solar-friendly.</p><div class="ic-challenge-meta"><span>₹30 L pool</span><span>Q2 deadline</span></div></div>
      <div class="ic-challenge"><p class="ic-challenge-title">Frontier compute</p><p style="font-size:13px;color:#2E2520;line-height:1.55;margin:0;">Indigenous quantum / HPC tooling. Open algorithms, reproducible benchmarks.</p><div class="ic-challenge-meta"><span>₹60 L pool</span><span>Q4 deadline</span></div></div>
    </div>
  </section>

  <section class="ic-section">
    <div class="ic-section-head">
      <div class="ic-section-icon" style="background:#8a486b;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
      <div>
        <p class="ic-section-num">06 · Mentors</p>
        <h2 class="ic-section-title">Mentor network · 1,000+ reach.</h2>
        <p class="ic-section-sub">Request a mentor in any of five categories. Matched in 48 hours. First call is free.</p>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px;margin-top:14px;">
      <div class="ic-mentor-cat"><div class="ic-mentor-cat-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/></svg></div><p class="ic-mentor-cat-title">Technical</p></div>
      <div class="ic-mentor-cat"><div class="ic-mentor-cat-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg></div><p class="ic-mentor-cat-title">Business</p></div>
      <div class="ic-mentor-cat"><div class="ic-mentor-cat-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></div><p class="ic-mentor-cat-title">Funding</p></div>
      <div class="ic-mentor-cat"><div class="ic-mentor-cat-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div><p class="ic-mentor-cat-title">Legal</p></div>
      <div class="ic-mentor-cat"><div class="ic-mentor-cat-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg></div><p class="ic-mentor-cat-title">Go-to-market</p></div>
    </div>
    <a href="/portal/mentors" class="ic-cta">Browse mentors &rarr;</a>
  </section>

</main>
</AquintutorLayout>
