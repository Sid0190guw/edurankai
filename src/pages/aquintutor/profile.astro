---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { users } from '@/lib/db/schema';
import { eq } from 'drizzle-orm';
import { hashPassword, verifyPassword } from '@/lib/auth/password';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/profile'));

let okMsg = '';
let errMsg = '';
let activeTab: 'profile' | 'password' = 'profile';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = (fd.get('action') as string || '').trim();

  if (action === 'update_profile') {
    const name = (fd.get('name') as string || '').trim();
    if (!name || name.length < 2) {
      errMsg = 'Please enter your full name.';
    } else if (name.length > 200) {
      errMsg = 'Name is too long.';
    } else {
      try {
        await db.update(users).set({ name }).where(eq(users.id, user.id));
        user.name = name;
        okMsg = 'Profile updated.';
      } catch (e: any) { errMsg = 'Could not save: ' + (e?.message || 'unknown'); }
    }
  } else if (action === 'change_password') {
    activeTab = 'password';
    const current = (fd.get('current_password') as string || '');
    const next = (fd.get('new_password') as string || '');
    const confirm = (fd.get('confirm_password') as string || '');
    if (!current || !next) {
      errMsg = 'Both current and new password are required.';
    } else if (next.length < 8) {
      errMsg = 'New password must be at least 8 characters.';
    } else if (next !== confirm) {
      errMsg = 'New password and confirmation do not match.';
    } else {
      try {
        const r = await db.execute(sql`SELECT password_hash FROM users WHERE id = ${user.id} LIMIT 1`);
        const rows = Array.isArray(r) ? r : (r?.rows || []);
        const stored = (rows[0] as any)?.password_hash;
        if (!stored) {
          errMsg = 'Account not found.';
        } else {
          const ok = await verifyPassword(stored, current);
          if (!ok) {
            errMsg = 'Current password is incorrect.';
          } else {
            const newHash = await hashPassword(next);
            await db.update(users).set({ passwordHash: newHash }).where(eq(users.id, user.id));
            okMsg = 'Password changed.';
          }
        }
      } catch (e: any) { errMsg = 'Could not change password: ' + (e?.message || 'unknown'); }
    }
  }
}

let stats = { enrolments: 0, attempts: 0, credentials: 0 };
try {
  const r = await db.execute(sql`
    SELECT
      (SELECT COUNT(*)::int FROM training_enrollments WHERE user_id = ${user.id}) as enrolments,
      (SELECT COUNT(*)::int FROM test_attempts WHERE candidate_id = ${user.id}) as attempts,
      (SELECT COUNT(*)::int FROM training_certificates WHERE user_id = ${user.id}) as credentials
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  if (rows[0]) stats = rows[0] as any;
} catch (_) {}

function fmtDate(d: any) {
  if (!d) return '-';
  try { return new Date(d).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short', year: 'numeric' }); }
  catch { return '-'; }
}
---
<AquintutorLayout title="Profile" description="Your AquinTutor account - name, email, password.">

  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:880px; margin:0 auto; padding:56px 28px 36px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); font-weight:600; letter-spacing:0.04em; margin:0 0 14px;">Your account</p>
      <h1 class="font-display" style="font-size:clamp(2rem, 4vw, 3rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500; margin:0; color:var(--ink);">{user.name}</h1>
      <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); margin:10px 0 0;">{user.email}</p>
    </div>
  </section>

  <section style="background:var(--sand-100); border-bottom:1px solid var(--rule);">
    <div style="max-width:880px; margin:0 auto; padding:36px 28px;">
      <div style="display:grid; grid-template-columns:repeat(3, 1fr); gap:14px;">
        {[
          { l: 'Enrolments', v: stats.enrolments, href: '/aquintutor/dashboard' },
          { l: 'Examinations', v: stats.attempts, href: '/aquintutor/dashboard' },
          { l: 'Credentials', v: stats.credentials, href: '/aquintutor/dashboard' },
        ].map((s) => (
          <a href={s.href} style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:18px 20px; text-decoration:none; color:var(--ink);">
            <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">{s.l}</p>
            <p class="font-display" style="font-size:1.85rem; font-weight:500; margin:0; line-height:1; color:var(--ink); letter-spacing:-0.02em;">{s.v}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div style="max-width:880px; margin:0 auto; padding:48px 28px 80px;">

      {okMsg && (
        <div style="background:rgba(125,211,168,0.14); border:1px solid #7dd3a8; color:#3f8a64; border-radius:8px; padding:14px 18px; font-family:'Inter Tight',sans-serif; font-size:14px; margin-bottom:24px;">{okMsg}</div>
      )}
      {errMsg && (
        <div style="background:rgba(160,66,30,0.10); border:1px solid rgba(160,66,30,0.4); color:var(--rust); border-radius:8px; padding:14px 18px; font-family:'Inter Tight',sans-serif; font-size:14px; margin-bottom:24px;">{errMsg}</div>
      )}

      <div style="display:flex; gap:8px; border-bottom:1px solid var(--rule); margin-bottom:28px;">
        <button type="button" id="tabProfile" style={'background:transparent; border:none; padding:12px 4px; font-family:Inter Tight,sans-serif; font-size:14px; font-weight:600; cursor:pointer; margin-right:18px; ' + (activeTab === 'profile' ? 'color:var(--ink); border-bottom:2px solid var(--ink);' : 'color:var(--ink-500);')}>Profile</button>
        <button type="button" id="tabPassword" style={'background:transparent; border:none; padding:12px 4px; font-family:Inter Tight,sans-serif; font-size:14px; font-weight:600; cursor:pointer; ' + (activeTab === 'password' ? 'color:var(--ink); border-bottom:2px solid var(--ink);' : 'color:var(--ink-500);')}>Password</button>
      </div>

      <div id="paneProfile" style={activeTab === 'profile' ? '' : 'display:none;'}>
        <form method="post" style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:28px; display:flex; flex-direction:column; gap:16px;">
          <input type="hidden" name="action" value="update_profile" />
          <div>
            <label for="name" style="display:block; font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin-bottom:6px;">Full name</label>
            <input id="name" name="name" type="text" maxlength="200" required value={user.name || ''} style="width:100%; padding:11px 14px; border:1px solid var(--rule); border-radius:8px; background:var(--paper); font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink); outline:none;" />
          </div>
          <div>
            <label style="display:block; font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin-bottom:6px;">Email address</label>
            <p style="margin:0; font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink);">{user.email}</p>
            <p style="margin:6px 0 0; font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500);">Email cannot be changed here. Contact <a href="mailto:hr@edurankai.in" style="color:var(--rust); text-decoration:underline;">hr@edurankai.in</a> if you need to update your registered address.</p>
          </div>
          <div>
            <label style="display:block; font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin-bottom:6px;">Role</label>
            <p style="margin:0; font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink); text-transform:capitalize;">{(user.role || 'applicant').replace('_',' ')}</p>
          </div>
          <button type="submit" style="background:var(--ink); color:var(--sand-50); padding:12px 22px; border:none; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; cursor:pointer; align-self:flex-start;">Save changes</button>
        </form>
      </div>

      <div id="panePassword" style={activeTab === 'password' ? '' : 'display:none;'}>
        <form method="post" style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:28px; display:flex; flex-direction:column; gap:16px;">
          <input type="hidden" name="action" value="change_password" />
          <div>
            <label for="current_password" style="display:block; font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin-bottom:6px;">Current password</label>
            <input id="current_password" name="current_password" type="password" required style="width:100%; padding:11px 14px; border:1px solid var(--rule); border-radius:8px; background:var(--paper); font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink); outline:none;" />
          </div>
          <div>
            <label for="new_password" style="display:block; font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin-bottom:6px;">New password</label>
            <input id="new_password" name="new_password" type="password" required minlength="8" style="width:100%; padding:11px 14px; border:1px solid var(--rule); border-radius:8px; background:var(--paper); font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink); outline:none;" />
            <p style="margin:6px 0 0; font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500);">At least 8 characters.</p>
          </div>
          <div>
            <label for="confirm_password" style="display:block; font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin-bottom:6px;">Confirm new password</label>
            <input id="confirm_password" name="confirm_password" type="password" required minlength="8" style="width:100%; padding:11px 14px; border:1px solid var(--rule); border-radius:8px; background:var(--paper); font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink); outline:none;" />
          </div>
          <button type="submit" style="background:var(--ink); color:var(--sand-50); padding:12px 22px; border:none; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; cursor:pointer; align-self:flex-start;">Change password</button>
        </form>
      </div>

      <div style="margin-top:32px; padding-top:28px; border-top:1px solid var(--rule);">
        <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 12px;">Session</p>
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
          <a href="/aquintutor/dashboard" style="background:transparent; color:var(--ink); padding:11px 20px; border-radius:6px; border:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Dashboard</a>
          <form method="post" action="/aquintutor/logout" style="margin:0;">
            <button type="submit" style="background:transparent; color:var(--rust); padding:11px 20px; border-radius:6px; border:1px solid rgba(160,66,30,0.5); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; cursor:pointer;">Sign out</button>
          </form>
        </div>
      </div>

    </div>
  </section>

  <script is:inline>
    (function() {
      var tProf = document.getElementById('tabProfile');
      var tPass = document.getElementById('tabPassword');
      var pProf = document.getElementById('paneProfile');
      var pPass = document.getElementById('panePassword');
      function show(which) {
        if (which === 'password') {
          pProf.style.display = 'none'; pPass.style.display = '';
          tProf.style.color = 'var(--ink-500)'; tProf.style.borderBottom = 'none';
          tPass.style.color = 'var(--ink)'; tPass.style.borderBottom = '2px solid var(--ink)';
        } else {
          pPass.style.display = 'none'; pProf.style.display = '';
          tPass.style.color = 'var(--ink-500)'; tPass.style.borderBottom = 'none';
          tProf.style.color = 'var(--ink)'; tProf.style.borderBottom = '2px solid var(--ink)';
        }
      }
      if (tProf) tProf.addEventListener('click', function() { show('profile'); });
      if (tPass) tPass.addEventListener('click', function() { show('password'); });
    })();
  </script>

</AquintutorLayout>
