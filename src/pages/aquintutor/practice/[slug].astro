---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const { slug } = Astro.params;
const user = Astro.locals.user;

let test: any = null;
try {
  const r = await db.execute(sql`
    SELECT id, slug, title, description, COALESCE(practice_enabled, true) AS practice_enabled
    FROM tests WHERE slug = ${slug} AND is_published = true LIMIT 1
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  test = rows[0] || null;
} catch (_) {}

if (!test) return Astro.redirect('/aquintutor');

let xp: any = { totalXp: 0, level: 1, streakDays: 0 };
if (user) {
  try {
    const { getUserXp } = await import('@/lib/xp');
    xp = await getUserXp(user.id);
  } catch (_) {}
}
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{test.title} — Practice</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&display=swap" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #fafaf7; color: #1c1d22; min-height: 100vh; font-family: 'Inter Tight', -apple-system, BlinkMacSystemFont, system-ui, sans-serif; }
    .top { background: #fff; border-bottom: 1px solid #e6e3da; padding: 14px 22px; display: flex; align-items: center; gap: 18px; flex-wrap: wrap; position: sticky; top: 0; z-index: 5; }
    .top .home { font-size: 22px; font-weight: 700; text-decoration: none; color: #1c1d22; font-family: 'Fraunces', serif; }
    .top .stats { display: flex; gap: 14px; margin-left: auto; }
    .stat { display: flex; align-items: center; gap: 6px; font-family: 'Inter Tight', monospace; font-size: 13px; font-weight: 700; }
    .stat .ic { width: 22px; height: 22px; }
    .stat.heart { color: #ef4444; }
    .stat.streak { color: #f97316; }
    .stat.xp { color: #d97757; }
    .progress-bar { height: 12px; background: #e6e3da; border-radius: 100px; overflow: hidden; width: 100%; }
    .progress-bar > div { height: 100%; background: linear-gradient(90deg, #d97757, #f97316); transition: width .4s cubic-bezier(.4,.0,.2,1); }
    .wrap { max-width: 720px; margin: 0 auto; padding: 28px 22px 120px; }
    .card { background: #fff; border: 1px solid #e6e3da; border-radius: 18px; padding: 28px 32px; margin-top: 20px; box-shadow: 0 6px 24px rgba(0,0,0,0.04); }
    .cat { font-family: 'Inter Tight', monospace; font-size: 11px; font-weight: 700; color: #d97757; letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 10px; }
    .qtext { font-family: 'Fraunces', serif; font-size: clamp(20px, 3vw, 26px); font-weight: 500; color: #1c1d22; line-height: 1.35; margin-bottom: 20px; }
    .opt { display: block; width: 100%; padding: 14px 16px; background: #fff; border: 2px solid #e6e3da; border-radius: 12px; margin-bottom: 10px; font-family: inherit; font-size: 15px; font-weight: 500; cursor: pointer; text-align: left; transition: all .15s; }
    .opt:hover { border-color: #c8c3b8; background: #faf8f3; }
    .opt.selected { border-color: #d97757; background: rgba(217,119,87,0.08); }
    .opt.correct { border-color: #10b981; background: rgba(16,185,129,0.12); }
    .opt.wrong { border-color: #ef4444; background: rgba(239,68,68,0.10); }
    .opt:disabled { cursor: default; }
    .ti { width: 100%; padding: 14px 16px; border: 2px solid #e6e3da; border-radius: 12px; font-family: inherit; font-size: 15px; outline: none; background: #fff; }
    .ti:focus { border-color: #d97757; }
    .check-btn { width: 100%; padding: 16px; background: #d97757; color: #fff; border: none; border-radius: 14px; font-family: inherit; font-size: 15px; font-weight: 700; cursor: pointer; letter-spacing: 0.02em; box-shadow: 0 4px 14px rgba(217,119,87,0.3); }
    .check-btn:hover { background: #b85e3f; }
    .check-btn:disabled { background: #c8c3b8; cursor: not-allowed; box-shadow: none; }
    .feedback { padding: 16px 20px; border-radius: 14px; margin-top: 14px; font-size: 14px; line-height: 1.55; }
    .feedback.ok { background: rgba(16,185,129,0.12); border-left: 4px solid #10b981; color: #047857; }
    .feedback.bad { background: rgba(239,68,68,0.10); border-left: 4px solid #ef4444; color: #991b1b; }
    .feedback b { display: block; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 6px; }
    .xp-pop { position: fixed; right: 22px; bottom: 22px; background: #d97757; color: #fff; padding: 10px 18px; border-radius: 100px; font-family: monospace; font-weight: 700; font-size: 14px; box-shadow: 0 8px 24px rgba(217,119,87,0.4); transform: translateY(80px); opacity: 0; transition: all .35s; z-index: 30; }
    .xp-pop.show { transform: translateY(0); opacity: 1; }
    .summary { text-align: center; padding: 30px 24px; }
    .summary .big { font-family: 'Fraunces', serif; font-size: 56px; font-weight: 600; color: #d97757; }
    .summary .sub { font-size: 14px; color: #5b5b5b; margin-top: 8px; }
    .summary-actions { display: flex; gap: 10px; justify-content: center; margin-top: 20px; flex-wrap: wrap; }
    .summary-actions a, .summary-actions button { padding: 12px 24px; border-radius: 12px; font-family: inherit; font-size: 14px; font-weight: 700; text-decoration: none; cursor: pointer; border: none; }
    .summary-actions .primary { background: #d97757; color: #fff; }
    .summary-actions .secondary { background: #fff; color: #1c1d22; border: 2px solid #e6e3da; }
    .empty { text-align: center; padding: 40px 22px; }
  </style>
</head>
<body>
  <header class="top">
    <a href="/aquintutor" class="home">AquinTutor</a>
    <div class="stats">
      <span class="stat streak" title="Daily streak" style="display:inline-flex;align-items:center;gap:5px;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg><span id="streakVal">{xp.streakDays}</span></span>
      <span class="stat xp" title="Total XP" style="display:inline-flex;align-items:center;gap:5px;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg><span id="xpVal">{xp.totalXp}</span></span>
    </div>
  </header>

  <div class="wrap">
    <div style="display:flex;align-items:center;gap:14px;margin-bottom:6px;">
      <a href={'/aquintutor/test/' + slug} style="font-size:11.5px;color:#5b5b5b;text-decoration:none;font-weight:600;">← Back</a>
      <p style="font-family:'Inter Tight',monospace;font-size:10.5px;letter-spacing:0.14em;text-transform:uppercase;color:#d97757;font-weight:700;">Practice · free · no record</p>
    </div>
    <h1 style="font-family:'Fraunces',serif;font-size:clamp(28px,3.5vw,38px);font-weight:600;line-height:1.15;margin:6px 0 4px;">{test.title}</h1>
    <p style="font-size:14px;color:#5b5b5b;line-height:1.6;max-width:48ch;">Practice mode: instant feedback, no time pressure, no score saved. Each correct answer earns XP toward your daily streak. The official test sits at <a href={'/aquintutor/test/' + slug} style="color:#d97757;font-weight:600;">/aquintutor/test/{slug}</a>.</p>

    <div class="progress-bar" style="margin-top:18px;"><div id="progressFill" style="width:0%;"></div></div>

    <div id="root"></div>
  </div>

  <div class="xp-pop" id="xpPop">+0 XP</div>

  <script is:inline define:vars={{ slug }}>
  (function () {
    var root = document.getElementById('root');
    var progressFill = document.getElementById('progressFill');
    var xpPop = document.getElementById('xpPop');
    var xpVal = document.getElementById('xpVal');
    var streakVal = document.getElementById('streakVal');
    var state = { idx: 0, questions: [], correct: 0, sessionId: null, answer: undefined, answered: false };

    function html(s) {
      var t = document.createElement('template');
      t.innerHTML = s.trim();
      return t.content.firstChild;
    }
    function esc(s) {
      return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) { return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]; });
    }

    function fetchBatch(attempt) {
      attempt = attempt || 1;
      var MAX_ATTEMPTS = 3;
      // Loading state shown to the user instead of leaving the page blank
      // (the first attempt commonly cold-starts the serverless function).
      root.innerHTML = '<div class="card empty"><p style="font-size:14px;color:#5b5b5b;">' + (attempt === 1 ? 'Preparing your practice round...' : 'Retrying (' + attempt + '/' + MAX_ATTEMPTS + ')...') + '</p></div>';
      fetch('/api/aquintutor/practice/start', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ testSlug: slug, n: 10 }) })
        .then(function (r) {
          if (!r.ok) throw new Error('HTTP ' + r.status);
          return r.json();
        })
        .then(function (d) {
          if (!d.ok) {
            if (attempt < MAX_ATTEMPTS) {
              setTimeout(function () { fetchBatch(attempt + 1); }, 600 * attempt);
              return;
            }
            root.innerHTML = '<div class="card empty"><p style="font-size:15px;font-weight:600;margin-bottom:8px;">Practice unavailable</p><p style="color:#5b5b5b;font-size:13px;margin-bottom:12px;">' + esc(d.error || 'Try again later.') + '</p><button onclick="window.location.reload()" style="background:#FF4F00;color:#fff;border:none;padding:9px 18px;border-radius:7px;font-size:13px;font-weight:700;cursor:pointer;">Reload page</button></div>';
            return;
          }
          if (!d.questions || d.questions.length === 0) {
            root.innerHTML = '<div class="card empty"><p style="font-size:15px;font-weight:600;margin-bottom:8px;">No questions yet</p><p style="color:#5b5b5b;font-size:13px;">This test does not have any questions published. Check back soon.</p></div>';
            return;
          }
          state.questions = d.questions;
          state.sessionId = d.sessionId;
          state.idx = 0;
          state.correct = 0;
          render();
        })
        .catch(function (err) {
          if (attempt < MAX_ATTEMPTS) {
            setTimeout(function () { fetchBatch(attempt + 1); }, 800 * attempt);
            return;
          }
          root.innerHTML = '<div class="card empty"><p style="font-size:15px;font-weight:600;margin-bottom:8px;">Could not load</p><p style="color:#5b5b5b;font-size:13px;margin-bottom:12px;">Network or server error. ' + esc((err && err.message) || '') + '</p><button onclick="window.location.reload()" style="background:#FF4F00;color:#fff;border:none;padding:9px 18px;border-radius:7px;font-size:13px;font-weight:700;cursor:pointer;">Reload page</button></div>';
        });
    }

    function render() {
      if (state.idx >= state.questions.length) return showSummary();
      var q = state.questions[state.idx];
      progressFill.style.width = (state.idx / state.questions.length * 100) + '%';
      var card = document.createElement('div');
      card.className = 'card';

      var top = '';
      if (q.category) top += '<p class="cat">' + esc(q.category) + '</p>';
      if (q.image_url) top += '<img src="' + esc(q.image_url) + '" alt="" style="max-width:100%;border-radius:12px;margin-bottom:14px;" />';
      top += '<p class="qtext">' + esc(q.question_text) + '</p>';
      card.innerHTML = top;

      state.answered = false;
      state.answer = undefined;

      if (q.question_type === 'mcq_single' || q.question_type === 'true_false') {
        (q.options || []).forEach(function (o, i) {
          var btn = html('<button type="button" class="opt" data-i="' + i + '">' + esc(o.text || o) + '</button>');
          btn.addEventListener('click', function () {
            if (state.answered) return;
            card.querySelectorAll('.opt').forEach(function (b) { b.classList.remove('selected'); });
            btn.classList.add('selected');
            state.answer = i;
            updateCheck();
          });
          card.appendChild(btn);
        });
      } else if (q.question_type === 'mcq_multi') {
        state.answer = [];
        (q.options || []).forEach(function (o, i) {
          var btn = html('<button type="button" class="opt" data-i="' + i + '">' + esc(o.text || o) + '</button>');
          btn.addEventListener('click', function () {
            if (state.answered) return;
            btn.classList.toggle('selected');
            var idx = state.answer.indexOf(i);
            if (idx === -1) state.answer.push(i); else state.answer.splice(idx, 1);
            updateCheck();
          });
          card.appendChild(btn);
        });
      } else if (q.question_type === 'fill_in_blank' || q.question_type === 'short_answer') {
        var input = html('<input type="text" class="ti" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" placeholder="Type your answer…" />');
        input.addEventListener('input', function (e) { state.answer = e.target.value; updateCheck(); });
        card.appendChild(input);
        setTimeout(function () { input.focus(); }, 50);
      } else if (q.question_type === 'numeric') {
        var input = html('<input type="number" step="any" class="ti" placeholder="Enter a number…" />');
        input.addEventListener('input', function (e) { state.answer = e.target.value; updateCheck(); });
        card.appendChild(input);
        setTimeout(function () { input.focus(); }, 50);
      }

      var btn = html('<button type="button" class="check-btn" id="checkBtn" disabled>Check answer</button>');
      btn.addEventListener('click', function () { check(card, q); });
      card.appendChild(btn);

      root.innerHTML = '';
      root.appendChild(card);
    }

    function updateCheck() {
      var btn = document.getElementById('checkBtn');
      if (!btn) return;
      var has = state.answer !== undefined && state.answer !== '' && !(Array.isArray(state.answer) && state.answer.length === 0);
      btn.disabled = !has || state.answered;
    }

    function check(card, q) {
      if (state.answered) return next(card);
      state.answered = true;
      var btn = document.getElementById('checkBtn');
      btn.disabled = true;
      btn.textContent = 'Checking…';

      fetch('/api/aquintutor/practice/answer', {
        method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sessionId: state.sessionId, questionId: q.id, answer: state.answer }),
      }).then(function (r) { return r.json(); }).then(function (d) {
        if (!d.ok) { btn.disabled = false; btn.textContent = 'Check answer'; state.answered = false; return; }
        var fb = document.createElement('div');
        fb.className = 'feedback ' + (d.correct ? 'ok' : 'bad');
        var modelLine = d.correct ? '' : ('<div style="margin-top:6px;"><b>Correct answer:</b> ' + esc(String(d.modelAnswer || '')) + '</div>');
        fb.innerHTML = '<b>' + (d.correct ? '✓ Correct' : '✗ Not quite') + '</b>' + (d.explanation ? esc(d.explanation) : '') + modelLine;
        card.insertBefore(fb, btn);
        if (d.correct) state.correct++;

        // Mark selected option for MCQ
        card.querySelectorAll('.opt.selected').forEach(function (o) { o.classList.add(d.correct ? 'correct' : 'wrong'); });
        card.querySelectorAll('.opt').forEach(function (o) { o.disabled = true; });
        var ti = card.querySelector('.ti'); if (ti) ti.disabled = true;

        if (d.xpDelta) {
          xpVal.textContent = (parseInt(xpVal.textContent || '0', 10) + d.xpDelta);
          xpPop.textContent = '+' + d.xpDelta + ' XP';
          xpPop.classList.add('show');
          setTimeout(function () { xpPop.classList.remove('show'); }, 1200);
        }

        btn.textContent = state.idx === state.questions.length - 1 ? 'Finish →' : 'Continue →';
        btn.disabled = false;
      });
    }

    function next(card) { state.idx++; render(); }

    function showSummary() {
      progressFill.style.width = '100%';
      var pct = state.questions.length > 0 ? Math.round(state.correct / state.questions.length * 100) : 0;
      var msg = pct >= 80 ? 'Strong run.' : pct >= 50 ? 'Solid. Keep going.' : 'Keep practising — every wrong answer is a lesson.';
      root.innerHTML = '<div class="card summary">'
        + '<p style="font-family:Inter Tight,monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.16em;color:#d97757;font-weight:700;">Session complete</p>'
        + '<p class="big">' + state.correct + '/' + state.questions.length + '</p>'
        + '<p class="sub">' + pct + '%  ·  ' + esc(msg) + '</p>'
        + '<div class="summary-actions">'
          + '<button class="primary" onclick="window.location.reload()">Another round</button>'
          + '<a class="secondary" href="/aquintutor/test/' + slug + '">Take the official test →</a>'
          + '<a class="secondary" href="/aquintutor">Dashboard</a>'
        + '</div></div>';
    }

    fetchBatch();
  })();
  </script>
</body>
</html>
