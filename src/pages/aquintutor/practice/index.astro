---
import BaseLayout from '@/layouts/BaseLayout.astro';

const TOPICS = [
  { slug: 'arrays', cat: 'DSA', label: 'Arrays', count: 320, easy: 120, med: 140, hard: 60 },
  { slug: 'strings', cat: 'DSA', label: 'Strings', count: 240, easy: 90, med: 110, hard: 40 },
  { slug: 'linked-lists', cat: 'DSA', label: 'Linked lists', count: 140, easy: 50, med: 60, hard: 30 },
  { slug: 'trees', cat: 'DSA', label: 'Trees', count: 210, easy: 70, med: 100, hard: 40 },
  { slug: 'graphs', cat: 'DSA', label: 'Graphs', count: 180, easy: 40, med: 90, hard: 50 },
  { slug: 'dp', cat: 'DSA', label: 'Dynamic programming', count: 250, easy: 60, med: 130, hard: 60 },
  { slug: 'greedy', cat: 'DSA', label: 'Greedy', count: 120, easy: 40, med: 60, hard: 20 },
  { slug: 'sorting', cat: 'DSA', label: 'Sorting + searching', count: 160, easy: 70, med: 70, hard: 20 },
  { slug: 'sql', cat: 'DB', label: 'SQL queries', count: 180, easy: 80, med: 80, hard: 20 },
  { slug: 'os', cat: 'CS Core', label: 'Operating systems', count: 140, easy: 50, med: 70, hard: 20 },
  { slug: 'dbms', cat: 'CS Core', label: 'DBMS', count: 130, easy: 50, med: 60, hard: 20 },
  { slug: 'networks', cat: 'CS Core', label: 'Computer networks', count: 110, easy: 50, med: 50, hard: 10 },
  { slug: 'oop', cat: 'CS Core', label: 'Object-oriented', count: 100, easy: 40, med: 50, hard: 10 },
  { slug: 'system-design', cat: 'Design', label: 'System design', count: 80, easy: 10, med: 40, hard: 30 },
  { slug: 'aptitude-quant', cat: 'Aptitude', label: 'Quantitative aptitude', count: 220, easy: 100, med: 90, hard: 30 },
  { slug: 'aptitude-logical', cat: 'Aptitude', label: 'Logical reasoning', count: 180, easy: 80, med: 80, hard: 20 },
  { slug: 'aptitude-verbal', cat: 'Aptitude', label: 'Verbal ability', count: 150, easy: 70, med: 60, hard: 20 },
  { slug: 'maths', cat: 'Math', label: 'Pre-college maths', count: 280, easy: 120, med: 110, hard: 50 },
  { slug: 'physics-jee', cat: 'Physics', label: 'JEE-grade physics', count: 320, easy: 100, med: 140, hard: 80 },
  { slug: 'chemistry-jee', cat: 'Chemistry', label: 'JEE-grade chemistry', count: 280, easy: 100, med: 130, hard: 50 },
];

const SAMPLE_PROBLEMS = [
  { slug: 'two-sum', topic: 'arrays', diff: 'Easy', label: 'Two-sum', sub: 'Find indices of two numbers adding to target. O(n) hash.', acc: 92.4, solved: 184320 },
  { slug: 'longest-substring', topic: 'strings', diff: 'Medium', label: 'Longest substring · no repeat', sub: 'Sliding-window over a Set.', acc: 76.2, solved: 92100 },
  { slug: 'reverse-list', topic: 'linked-lists', diff: 'Easy', label: 'Reverse a linked list', sub: 'Three-pointer rewire.', acc: 88.0, solved: 124800 },
  { slug: 'lowest-common-ancestor', topic: 'trees', diff: 'Medium', label: 'Lowest common ancestor', sub: 'Recursive descent.', acc: 71.5, solved: 68400 },
  { slug: 'dijkstra', topic: 'graphs', diff: 'Hard', label: "Dijkstra's shortest path", sub: 'Min-heap relaxation.', acc: 54.0, solved: 23700 },
  { slug: 'climb-stairs', topic: 'dp', diff: 'Easy', label: 'Climb stairs', sub: 'Tabulate Fibonacci.', acc: 94.1, solved: 198400 },
  { slug: 'lis', topic: 'dp', diff: 'Hard', label: 'Longest increasing subsequence', sub: 'O(n log n) patience.', acc: 58.3, solved: 41200 },
  { slug: 'producer-consumer', topic: 'os', diff: 'Medium', label: 'Producer-consumer with semaphores', sub: 'Classic synchronisation.', acc: 64.8, solved: 18900 },
];
---
<BaseLayout title="Practice · AquinTutor" description="20+ topic tracks, 4,000+ problems, instant judge, leaderboards. Learn by solving.">

<style>
  body { background: #FAF8F5; }
  .pr-wrap { max-width: 1280px; margin: 0 auto; padding: 24px 5vw 80px; }
  .pr-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .pr-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 6vw, 64px); font-weight: 600; letter-spacing: -0.025em; margin: 8px 0 14px; line-height: 1; }
  .pr-title em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .pr-sub { font-size: 16px; color: #2E2520; max-width: 700px; line-height: 1.65; }

  .pr-strip { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px; margin: 28px 0 36px; }
  .pr-stat { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 10px; padding: 14px 16px; }
  .pr-stat-val { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 600; color: #0E0B08; line-height: 1; }
  .pr-stat-lbl { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: #7A6F68; margin-top: 5px; font-weight: 700; }

  .pr-section-head { display: flex; align-items: baseline; justify-content: space-between; padding: 14px 0; }
  .pr-section-head h2 { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 600; letter-spacing: -0.02em; margin: 0; line-height: 1.1; }
  .pr-section-head h2 em { color: #FF4F00; font-style: italic; font-weight: 500; }

  .pr-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 10px; }
  .pr-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 12px; padding: 18px; text-decoration: none; color: inherit; transition: all 0.15s; display: block; }
  .pr-card:hover { transform: translateY(-1px); box-shadow: 0 10px 24px rgba(14,11,8,0.06); border-color: #FF4F00; }
  .pr-card-cat { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .pr-card-title { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; margin: 4px 0 10px; line-height: 1.2; letter-spacing: -0.01em; }
  .pr-card-bar { background: rgba(14,11,8,0.06); height: 6px; border-radius: 100px; overflow: hidden; margin: 4px 0 8px; display: flex; }
  .pr-card-bar > div { height: 100%; }
  .pr-bar-easy { background: #1A6B35; }
  .pr-bar-med { background: #C49A00; }
  .pr-bar-hard { background: #b91c1c; }
  .pr-card-counts { display: flex; justify-content: space-between; font-family: 'Geist Mono', monospace; font-size: 10.5px; color: #7A6F68; letter-spacing: 0.04em; }

  .pr-prob-row { display: grid; grid-template-columns: 90px 1fr 90px 90px 100px; gap: 12px; padding: 12px 14px; align-items: center; background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 10px; margin-bottom: 6px; text-decoration: none; color: inherit; transition: all 0.12s; }
  .pr-prob-row:hover { border-color: #FF4F00; }
  @media (max-width: 800px) { .pr-prob-row { grid-template-columns: 1fr; gap: 4px; } }
  .pr-diff { font-family: 'Geist Mono', monospace; font-size: 10px; padding: 3px 9px; border-radius: 100px; font-weight: 700; letter-spacing: 0.06em; text-align: center; text-transform: uppercase; }
  .pr-diff-Easy { background: rgba(26,107,53,0.12); color: #1A6B35; border: 1px solid rgba(26,107,53,0.3); }
  .pr-diff-Medium { background: rgba(196,154,0,0.12); color: #C49A00; border: 1px solid rgba(196,154,0,0.3); }
  .pr-diff-Hard { background: rgba(185,28,28,0.12); color: #b91c1c; border: 1px solid rgba(185,28,28,0.3); }
  .pr-prob-lbl { font-weight: 700; color: #0E0B08; font-size: 14px; }
  .pr-prob-sub { font-size: 12px; color: #7A6F68; line-height: 1.4; }
  .pr-prob-meta { font-family: 'Geist Mono', monospace; font-size: 11px; color: #7A6F68; }

  .pr-feat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px; margin-top: 18px; }
  .pr-feat { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 12px; padding: 18px; }
  .pr-feat-icon { display: inline-flex; width: 36px; height: 36px; border-radius: 8px; background: #FFF3EE; color: #FF4F00; align-items: center; justify-content: center; margin-bottom: 10px; }
  .pr-feat-t { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; margin: 0 0 6px; }
  .pr-feat-d { font-size: 13px; color: #2E2520; line-height: 1.55; }
</style>

<main class="pr-wrap">

  <header>
    <p class="pr-eye">AquinTutor · Practice</p>
    <h1 class="pr-title">Learn by <em>solving</em>.</h1>
    <p class="pr-sub">20+ topic tracks. 4,000+ problems with editorial solutions in 7 languages. Instant judge. Discussion board per problem. Submit code, get a verdict in seconds.</p>
  </header>

  <div class="pr-strip">
    <div class="pr-stat"><p class="pr-stat-val">20+</p><p class="pr-stat-lbl">Topic tracks</p></div>
    <div class="pr-stat"><p class="pr-stat-val">4,090</p><p class="pr-stat-lbl">Problems</p></div>
    <div class="pr-stat"><p class="pr-stat-val">7</p><p class="pr-stat-lbl">Languages judged</p></div>
    <div class="pr-stat"><p class="pr-stat-val">Live</p><p class="pr-stat-lbl">Discussion + editorials</p></div>
    <div class="pr-stat"><p class="pr-stat-val">Weekly</p><p class="pr-stat-lbl">Contests</p></div>
  </div>

  <section>
    <div class="pr-section-head"><h2>Featured <em>problems</em>.</h2></div>
    <div>
      {SAMPLE_PROBLEMS.map((p) => (
        <a href={'/aquintutor/practice/' + p.topic + '/' + p.slug} class="pr-prob-row">
          <span class={'pr-diff pr-diff-' + p.diff}>{p.diff}</span>
          <div>
            <p class="pr-prob-lbl">{p.label}</p>
            <p class="pr-prob-sub">{p.sub}</p>
          </div>
          <span class="pr-prob-meta">{p.acc}% acc</span>
          <span class="pr-prob-meta">{p.solved.toLocaleString()}</span>
          <span style="font-family:'Geist Mono',monospace;font-size:10px;color:#FF4F00;text-align:right;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;">Solve &rarr;</span>
        </a>
      ))}
    </div>
  </section>

  <section style="margin-top:36px;">
    <div class="pr-section-head"><h2>Topic <em>tracks</em>.</h2></div>
    <div class="pr-grid">
      {TOPICS.map((t) => {
        const total = t.easy + t.med + t.hard;
        return (
          <a href={'/aquintutor/practice/' + t.slug} class="pr-card">
            <p class="pr-card-cat">{t.cat}</p>
            <p class="pr-card-title">{t.label}</p>
            <div class="pr-card-bar">
              <div class="pr-bar-easy" style={'width:' + (t.easy/total*100) + '%;'}></div>
              <div class="pr-bar-med" style={'width:' + (t.med/total*100) + '%;'}></div>
              <div class="pr-bar-hard" style={'width:' + (t.hard/total*100) + '%;'}></div>
            </div>
            <div class="pr-card-counts"><span>{t.easy} easy</span><span>{t.med} med</span><span>{t.hard} hard</span></div>
            <p style="font-family:'Geist Mono',monospace;font-size:11px;color:#FF4F00;margin:8px 0 0;letter-spacing:0.04em;font-weight:700;">{t.count} problems</p>
          </a>
        );
      })}
    </div>
  </section>

  <section style="margin-top:36px;">
    <div class="pr-section-head"><h2>Built-in <em>tooling</em>.</h2></div>
    <div class="pr-feat-grid">
      <div class="pr-feat"><div class="pr-feat-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg></div><p class="pr-feat-t">Browser editor</p><p class="pr-feat-d">Hand-rolled multi-language editor with syntax highlight. C / C++ / Java / Python / JS / Go / Rust.</p></div>
      <div class="pr-feat"><div class="pr-feat-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg></div><p class="pr-feat-t">Instant judge</p><p class="pr-feat-d">Sandboxed runner. Time + memory + verdict in under 2 seconds for most problems.</p></div>
      <div class="pr-feat"><div class="pr-feat-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 8h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-9a2 2 0 0 1 2-2h2"/><polyline points="9 12 11 14 15 10"/><path d="M12 2v10"/></svg></div><p class="pr-feat-t">Editorial solutions</p><p class="pr-feat-d">Every problem ships with a step-by-step solution in 7 languages.</p></div>
      <div class="pr-feat"><div class="pr-feat-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div><p class="pr-feat-t">Discussion board</p><p class="pr-feat-d">Per-problem discussion thread. Editorials. Most-upvoted solutions.</p></div>
      <div class="pr-feat"><div class="pr-feat-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg></div><p class="pr-feat-t">Leaderboard</p><p class="pr-feat-d">Global rank. Topic rank. Streak rank. Country + institution rank.</p></div>
      <div class="pr-feat"><div class="pr-feat-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div><p class="pr-feat-t">Weekly contests</p><p class="pr-feat-d">3-hour rated contests every Sunday. 5 problems. Penalty-time rules.</p></div>
    </div>
  </section>

</main>
</BaseLayout>
