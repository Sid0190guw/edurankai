---
// /aquintutor/guardian — guardian oversight (Prompt 2b, main surface). Server-side gated to
// the 'guardian' role: a non-guardian is redirected, not merely hidden. Reads the REAL linked
// minor accounts from rbac_guardian_links (empty-state if none) and shows each minor's stage
// and roles — the settings a guardian is permitted to oversee. No fabricated progress numbers.
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { resolvePrincipal, can } from '@/lib/rbac';
import { isMinorStage } from '@/lib/rbac/roles';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/guardian');
const principal = await resolvePrincipal(user);
if (!principal.roles.includes('guardian')) return Astro.redirect('/aquintutor/access');
const gate = await can(user, 'configure', { type: 'guardian' });   // audited role-area access
if (!gate.allow) return Astro.redirect('/aquintutor/access');

const rows = (r: any): any[] => (Array.isArray(r) ? r : (r?.rows || []));
const minors = rows(await db.execute(sql`SELECT gl.minor_user_id, m.name, m.email,
    COALESCE(json_agg(json_build_object('role', ur.role_key, 'stage', ur.stage)) FILTER (WHERE ur.role_key IS NOT NULL), '[]') AS roles
  FROM rbac_guardian_links gl LEFT JOIN users m ON m.id = gl.minor_user_id
  LEFT JOIN rbac_user_roles ur ON ur.user_id = gl.minor_user_id
  WHERE gl.guardian_user_id = ${user.id}
  GROUP BY gl.minor_user_id, m.name, m.email ORDER BY m.name`));

function stageOf(r: any): string | null {
  const s = (r.roles || []).find((x: any) => x.role === 'student');
  return s?.stage || null;
}
const CARD = 'background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:14px;padding:20px 22px;margin-bottom:14px;';
---
<AquintutorLayout title="Guardian oversight">
  <main style="max-width:860px;margin:0 auto;padding:48px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Guardian</p>
    <h1 style="font-family:Fraunces,serif;font-size:34px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 6px;line-height:1.1;">Oversight of your linked learners</h1>
    <p style="font-family:Inter Tight,sans-serif;font-size:15px;color:#6b6455;margin:0 0 28px;">You can view the learning stage of each minor linked to you and manage the settings you are permitted to. Linking is done by a coordinator.</p>

    {minors.length === 0 ? (
      <div style={CARD}>
        <p style="font-family:Inter Tight,sans-serif;font-size:15px;color:#6b6455;margin:0;">No learners are linked to your account yet. Once a coordinator links a minor student to you, they appear here.</p>
      </div>
    ) : minors.map((m: any) => {
      const stage = stageOf(m);
      const minor = isMinorStage(stage);
      return (
      <div style={CARD}>
        <div style="display:flex;justify-content:space-between;align-items:baseline;gap:10px;flex-wrap:wrap;">
          <h2 style="font-family:Fraunces,serif;font-size:20px;font-weight:600;color:var(--ink,#1a1712);margin:0;">{m.name}</h2>
          {stage ? <span style="font-family:'Geist Mono',monospace;font-size:11px;color:var(--rust,#b3541e);border:1px solid var(--line,#e6e1d6);border-radius:100px;padding:3px 10px;">{stage}{minor ? ' · minor' : ''}</span> : null}
        </div>
        <p style="font-family:Inter Tight,sans-serif;font-size:13.5px;color:#8a8478;margin:4px 0 12px;">{m.email}</p>
        <div style="display:flex;flex-wrap:wrap;gap:6px;">
          {(m.roles || []).map((r: any) => <span style="display:inline-block;background:#faf8f2;border:1px solid var(--line,#e6e1d6);border-radius:100px;padding:3px 11px;font-size:12.5px;color:var(--ink,#1a1712);font-family:Inter Tight,sans-serif;">{r.role}{r.stage ? ' · ' + r.stage : ''}</span>)}
        </div>
        <div style="margin-top:14px;padding-top:12px;border-top:1px solid #f0ece2;">
          <p style="font-family:Inter Tight,sans-serif;font-size:13px;color:#6b6455;margin:0;">Settings you may manage: consent for sensitive actions, notification preferences, and progress visibility. {minor ? 'This learner is a minor; your linked consent unblocks their guarded actions.' : ''}</p>
        </div>
      </div>);
    })}
  </main>
</AquintutorLayout>
