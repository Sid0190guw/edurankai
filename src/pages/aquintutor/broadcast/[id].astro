---
// /aquintutor/broadcast/[id] — the viewer's PULL player (Prompt H3a). The viewer SUBSCRIBES to the
// broadcast fan-out (SSE) and renders the animation SPEC + slides LOCALLY at their Prompt-5 tier.
// It is NOT a WebRTC publish peer — reaching a huge audience leans on this cheap pull channel, not
// per-viewer video. Late-joiners get the current board state at connect (SSE sends it immediately).
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import SceneGL from '@/components/SceneGL.astro';
import { can } from '@/lib/rbac';
import { getBroadcast } from '@/lib/broadcast';

const user = Astro.locals.user;
const { id } = Astro.params as { id: string };
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/broadcast/' + id));
await can(user, 'read', { type: 'AnimationObject' });   // audit the view
const bc = await getBroadcast(id).catch(() => null);
---
<AquintutorLayout title={bc ? bc.title : 'Live broadcast'}>
  <main style="max-width:820px;margin:0 auto;padding:32px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Live broadcast</p>
    <h1 style="font-family:Fraunces,serif;font-size:26px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 4px;">{bc ? bc.title : 'Live session'}</h1>
    <p id="status" style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#6b6455;margin:0 0 14px;">Connecting to the live feed…</p>

    <div style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:14px;overflow:hidden;">
      <svg id="anim" viewBox="0 0 320 200" style="display:none;width:100%;height:auto;aspect-ratio:16/10;"></svg>
      <div id="sceneStage" style="display:none;background:#0e0f13;min-height:120px;"></div>
      <div id="slide" style="display:none;padding:26px 28px;min-height:120px;">
        <h2 id="slideTitle" style="font-family:Fraunces,serif;font-size:22px;color:var(--ink,#1a1712);margin:0 0 14px;"></h2>
        <ul id="slideBullets" style="font-family:'Inter Tight',sans-serif;font-size:16px;color:#3a352c;line-height:1.7;margin:0;padding-left:20px;"></ul>
      </div>
    </div>
    <p style="font-family:'Inter Tight',sans-serif;font-size:11.5px;color:#8a8378;margin:10px 0 0;">You are watching a live pull stream — your device renders the slides and animations locally and does not publish any camera or audio.</p>
  </main>

  <script src="/aquin-anim-templates.js" defer></script>
  <script src="/aquin-scene-engine.js" defer></script>
  <script src="/aquin-broadcast-transport.js" defer></script>
  <SceneGL />
  <script is:inline define:vars={{ id }}>
    (function () {
      function ready(fn) { if (window.AquinScene && window.AquinBroadcast && window.AquinAnim) fn(); else setTimeout(function () { ready(fn); }, 50); }
      ready(function () {
        var B = window.AquinBroadcast, anim = document.getElementById('anim'), sceneStage = document.getElementById('sceneStage'), slide = document.getElementById('slide'), status = document.getElementById('status');
        var tier = 'standard';
        var c = (navigator.connection || {}), sig = new URLSearchParams();
        if (navigator.deviceMemory) sig.set('dm', navigator.deviceMemory); if (c.effectiveType) sig.set('ect', c.effectiveType); if (c.saveData) sig.set('sd', '1'); sig.set('vw', window.innerWidth || 0);
        function showOnly(el) { [anim, sceneStage, slide].forEach(function (x) { x.style.display = x === el ? 'block' : 'none'; }); }
        function renderSpec(ev, kind) {
          if (kind === 'scene') { showOnly(sceneStage); var out = window.AquinScene.render(sceneStage, ev.params.scene, tier); status.textContent = 'Live — 3D scene (' + out.renderer + ', ' + tier + ')'; }
          else if (kind === 'ink') { showOnly(anim); while (anim.firstChild) anim.removeChild(anim.firstChild); (ev.params.strokes || []).forEach(function (s) { if (!s.length) return; var pl = document.createElementNS('http://www.w3.org/2000/svg', 'polyline'); pl.setAttribute('points', s.map(function (p) { return (p[0] * 320) + ',' + (p[1] * 200); }).join(' ')); pl.setAttribute('fill', 'none'); pl.setAttribute('stroke', '#1a1712'); pl.setAttribute('stroke-width', '2'); anim.appendChild(pl); }); status.textContent = 'Live — board ink'; }
          else { showOnly(anim); if (window.AquinAnim.get(ev.templateId)) window.AquinAnim.renderSVG(anim, { templateId: ev.templateId, params: ev.params, playState: 'playing', timelinePos: 0.5 }, tier); status.textContent = 'Live — ' + ev.templateId; }
        }
        function renderSlide(s) { if (!s) return; showOnly(slide); document.getElementById('slideTitle').textContent = s.title || ''; var ul = document.getElementById('slideBullets'); ul.innerHTML = ''; (s.bullets || []).forEach(function (b) { var li = document.createElement('li'); li.textContent = b; ul.appendChild(li); }); status.textContent = 'Live — slide'; }
        B.viewerSubscribe(id, {
          signals: sig.toString(),
          onReady: function (d) { tier = d.tier || 'standard'; status.textContent = 'Connected at ' + tier + ' quality — waiting for the presenter.'; status.style.color = '#2f7d5b'; },
          onSpec: renderSpec, onSlide: renderSlide,
          onError: function () { status.textContent = 'Reconnecting…'; status.style.color = '#b3541e'; },
        });
      });
    })();
  </script>
</AquintutorLayout>
