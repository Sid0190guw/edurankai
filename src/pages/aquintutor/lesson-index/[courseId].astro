---
// /aquintutor/lesson-index/[courseId] — a course's ordered, published KnowledgeObjects
// (Prompt 3, main surface). The param resolves as EITHER a kernel CourseObject id (lesson
// back-links) OR a training_courses id (course-detail link). Students see published units they
// are permitted to (securityLabel via can()); staff also see drafts. Server-rendered, no JS.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { can } from '@/lib/rbac';
import { contentService } from '@/lib/kernel-content';

const user = Astro.locals.user;
const courseId = Astro.params.courseId!;
const svc = contentService();

const courses = await svc.listCourses().catch(() => []);
const courseObj: any = courses.find((c: any) => c.id === courseId || (c.data as any)?.trainingCourseId === courseId);

const isStaff = (await can(user, 'write', { type: 'KnowledgeObject' })).allow;
let visible: any[] = [];
if (courseObj) {
  const units = await svc.listCourseUnits(courseObj.id, !isStaff);   // students: published only
  for (const u of units) {
    const g = await can(user, 'read', { type: 'KnowledgeObject', securityLabels: u.securityLabels || ['public'] });
    if (g.allow) visible.push({ id: u.id, title: (u.data as any).title, state: u.lifecycleState, label: (u.securityLabels || ['public'])[0], minutes: (u.learningMetadata as any)?.estimatedMinutes });
  }
}
const courseTitle = courseObj ? (courseObj.data as any).title : 'Course';
---
<AquintutorLayout title={courseTitle + ' — knowledge units'}>
  <main style="max-width:760px;margin:0 auto;padding:44px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Knowledge units</p>
    <h1 style="font-family:Fraunces,serif;font-size:30px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 22px;line-height:1.15;">{courseTitle}</h1>

    {!courseObj || visible.length === 0 ? (
      <div style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:14px;padding:22px 24px;">
        <p style="font-family:'Inter Tight',sans-serif;font-size:15px;color:#6b6455;margin:0;">No published knowledge units for this course yet. Check back soon.</p>
      </div>
    ) : (
      <ol style="list-style:none;margin:0;padding:0;counter-reset:u;">
        {visible.map((u) => (
          <li style="counter-increment:u;margin-bottom:10px;">
            <a href={'/aquintutor/lesson/' + u.id} style="display:flex;align-items:center;gap:14px;text-decoration:none;background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:12px;padding:14px 18px;">
              <span style="font-family:Fraunces,serif;font-size:18px;color:var(--rust,#b3541e);min-width:26px;">{String(visible.indexOf(u) + 1).padStart(2, '0')}</span>
              <span style="flex:1;">
                <span style="display:block;font-family:'Inter Tight',sans-serif;font-size:16px;font-weight:600;color:var(--ink,#1a1712);">{u.title}</span>
                <span style="display:block;font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#8a8478;margin-top:2px;">{u.minutes ? u.minutes + ' min · ' : ''}{u.label}{u.state !== 'published' ? ' · ' + u.state : ''}</span>
              </span>
              <span style="color:var(--rust,#b3541e);font-size:18px;">&rarr;</span>
            </a>
          </li>
        ))}
      </ol>
    )}
  </main>
</AquintutorLayout>
