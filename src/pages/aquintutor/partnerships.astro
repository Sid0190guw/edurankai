---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;

let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const partner_kind = (fd.get('partner_kind') as string || '').trim();
    const org_name = (fd.get('org_name') as string || '').trim();
    const contact_name = (fd.get('contact_name') as string || '').trim();
    const contact_email = (fd.get('contact_email') as string || '').trim();
    const contact_phone = (fd.get('contact_phone') as string || '').trim();
    const country = (fd.get('country') as string || '').trim();
    const website_url = (fd.get('website_url') as string || '').trim();
    const intended_course_title = (fd.get('intended_course_title') as string || '').trim();
    const intended_course_summary = (fd.get('intended_course_summary') as string || '').trim();
    const target_learners = (fd.get('target_learners') as string || '').trim();
    const existing_content = (fd.get('existing_content') as string || '').trim();
    const co_branding = (fd.get('co_branding') as string || '').trim();
    const tier = (fd.get('tier') as string || 'starter').trim();
    if (!org_name || !contact_email || !intended_course_title || intended_course_summary.length < 120) {
      errMsg = 'Organisation, email, intended course title, and a 120+ character course summary are required.';
    } else {
      await db.execute(sql`CREATE TABLE IF NOT EXISTS partnership_applications (
        id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
        user_id UUID,
        partner_kind VARCHAR(40) NOT NULL DEFAULT 'institution',
          -- university | company | government | non-profit | individual-expert | publisher | media-house
        org_name VARCHAR(300) NOT NULL,
        contact_name VARCHAR(200),
        contact_email VARCHAR(200) NOT NULL,
        contact_phone VARCHAR(40),
        country VARCHAR(80),
        website_url TEXT,
        intended_course_title TEXT NOT NULL,
        intended_course_summary TEXT NOT NULL,
        target_learners TEXT,
        existing_content TEXT,
        co_branding TEXT,
        tier VARCHAR(20) NOT NULL DEFAULT 'starter',
          -- starter (one-off CHF 100) | scale (rev-share 15% per additional course)
        status VARCHAR(20) NOT NULL DEFAULT 'submitted',
          -- submitted | reviewing | approved | declined | onboarded
        signed_msa_at TIMESTAMPTZ,
        approved_at TIMESTAMPTZ,
        reviewer_notes TEXT,
        created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
        updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
      )`);
      await db.execute(sql`INSERT INTO partnership_applications
        (user_id, partner_kind, org_name, contact_name, contact_email, contact_phone, country, website_url,
         intended_course_title, intended_course_summary, target_learners, existing_content, co_branding, tier)
        VALUES (${user?.id || null}, ${partner_kind || 'institution'}, ${org_name}, ${contact_name || null}, ${contact_email},
         ${contact_phone || null}, ${country || null}, ${website_url || null},
         ${intended_course_title}, ${intended_course_summary}, ${target_learners || null},
         ${existing_content || null}, ${co_branding || null}, ${tier})`);
      okMsg = 'Application received. Our partnerships team reviews every submission within 5 business days and sends sandbox credentials with the next steps.';
    }
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 240); }
}
---
<BaseLayout title="Partnerships · AquinTutor" description="Host your courses on AquinTutor. Starter tier at CHF 100 covers one course end-to-end. Continuing partnership: 15% revenue share on additional courses, exclusive of taxes.">

<style>
  body { background: #FAF8F5; color: #0E0B08; }
  .pn-wrap { max-width: 1280px; margin: 0 auto; padding: 0; }

  .pn-hero { padding: 80px 5vw 60px; max-width: 1280px; margin: 0 auto; }
  .pn-eyebrow { font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.22em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin: 0; }
  .pn-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(44px, 7vw, 84px); font-weight: 600; letter-spacing: -0.035em; margin: 16px 0 18px; line-height: 0.96; max-width: 1000px; }
  .pn-title em { font-style: italic; font-weight: 500; color: #FF4F00; }
  .pn-sub { font-size: 17px; color: #2E2520; max-width: 720px; line-height: 1.7; }

  .pn-cta-row { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 30px; }
  .pn-btn { background: #FF4F00; color: #fff; padding: 14px 28px; border-radius: 10px; text-decoration: none; font-weight: 800; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; display: inline-block; border: none; cursor: pointer; }
  .pn-btn-ghost { background: transparent; border: 1px solid rgba(14,11,8,0.15); color: #0E0B08; }
  .pn-btn:hover { transform: translateY(-1px); }

  .pn-strip { padding: 32px 5vw; max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; border-top: 1px solid rgba(14,11,8,0.10); border-bottom: 1px solid rgba(14,11,8,0.10); }
  .pn-stat { padding: 4px 0; }
  .pn-stat-val { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 600; color: #0E0B08; line-height: 1; letter-spacing: -0.02em; }
  .pn-stat-lbl { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #7A6F68; margin-top: 6px; font-weight: 700; }

  .pn-section { padding: 70px 5vw; max-width: 1280px; margin: 0 auto; border-bottom: 1px solid rgba(14,11,8,0.10); }
  .pn-section-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .pn-section-h { font-family: 'Cormorant Garamond', serif; font-size: clamp(32px, 5vw, 52px); font-weight: 600; letter-spacing: -0.03em; margin: 8px 0 16px; line-height: 1.05; }
  .pn-section-h em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .pn-section-sub { font-size: 16px; color: #2E2520; max-width: 720px; line-height: 1.7; }

  .pn-kinds { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; margin-top: 32px; }
  .pn-kind { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 22px; }
  .pn-kind-icon { width: 44px; height: 44px; border-radius: 10px; background: #FFF3EE; color: #FF4F00; display: flex; align-items: center; justify-content: center; margin-bottom: 14px; }
  .pn-kind-title { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 600; margin: 4px 0 8px; letter-spacing: -0.01em; line-height: 1.2; }
  .pn-kind-desc { font-size: 13.5px; color: #2E2520; line-height: 1.6; }

  .pn-value-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 14px; margin-top: 32px; }
  .pn-value { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 22px; }
  .pn-value-num { font-family: 'Geist Mono', monospace; font-size: 28px; color: #FF4F00; font-weight: 700; line-height: 1; }
  .pn-value-h { font-family: 'Cormorant Garamond', serif; font-size: 19px; font-weight: 600; margin: 10px 0 6px; letter-spacing: -0.01em; line-height: 1.25; }
  .pn-value-p { font-size: 13.5px; color: #2E2520; line-height: 1.65; }

  /* Pricing */
  .pn-pricing-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-top: 32px; }
  @media (max-width: 800px) { .pn-pricing-grid { grid-template-columns: 1fr; } }
  .pn-price { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 18px; padding: 32px; }
  .pn-price.featured { background: linear-gradient(135deg, #0E0B08, #2E2520); color: #FAF8F5; border: 2px solid #FF4F00; box-shadow: 0 14px 40px rgba(255,79,0,0.18); }
  .pn-price-tag { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .pn-price-name { font-family: 'Cormorant Garamond', serif; font-size: 32px; font-weight: 600; margin: 6px 0 12px; letter-spacing: -0.02em; }
  .pn-price-amt { font-family: 'Cormorant Garamond', serif; font-size: 56px; font-weight: 600; color: #FF4F00; letter-spacing: -0.025em; line-height: 1; }
  .pn-price.featured .pn-price-amt { color: #FF7040; }
  .pn-price-per { font-family: 'Geist Mono', monospace; font-size: 12px; color: #7A6F68; }
  .pn-price.featured .pn-price-per { color: rgba(250,248,245,0.7); }
  .pn-price-sub { font-size: 14px; color: #2E2520; margin: 8px 0 18px; line-height: 1.55; }
  .pn-price.featured .pn-price-sub { color: rgba(250,248,245,0.75); }
  .pn-price ul { margin: 0; padding: 0; list-style: none; }
  .pn-price li { padding: 8px 0; font-size: 14px; line-height: 1.55; display: flex; gap: 10px; align-items: flex-start; border-bottom: 1px solid rgba(14,11,8,0.06); }
  .pn-price.featured li { border-bottom-color: rgba(250,248,245,0.10); }
  .pn-price li:last-child { border-bottom: none; }
  .pn-price li::before { content: ''; width: 16px; height: 16px; flex-shrink: 0; background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="%231A6B35" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>'); background-size: contain; background-repeat: no-repeat; margin-top: 2px; }
  .pn-price.featured li::before { background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="%23FF7040" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>'); }
  .pn-price-cta { background: #FF4F00; color: #fff; padding: 12px 24px; border-radius: 10px; border: none; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; margin-top: 18px; display: inline-block; text-decoration: none; }

  .pn-revshare-note { background: #FFF3EE; border: 1px solid #FFD4BC; border-radius: 14px; padding: 22px 26px; margin-top: 26px; font-size: 14px; color: #0E0B08; line-height: 1.7; }
  .pn-revshare-note strong { color: #FF4F00; font-weight: 700; }
  .pn-revshare-formula { background: #fff; border: 1px dashed #FFD4BC; border-radius: 8px; padding: 12px 16px; margin: 12px 0; font-family: ui-monospace, monospace; font-size: 13.5px; color: #2E2520; }

  /* Process / timeline */
  .pn-timeline { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 12px; margin-top: 28px; }
  .pn-step { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 12px; padding: 18px; }
  .pn-step-n { font-family: 'Geist Mono', monospace; font-size: 22px; color: #FF4F00; font-weight: 700; line-height: 1; }
  .pn-step-h { font-family: 'Cormorant Garamond', serif; font-size: 17px; font-weight: 600; margin: 6px 0 4px; line-height: 1.2; }
  .pn-step-p { font-size: 12.5px; color: #2E2520; line-height: 1.5; }
  .pn-step-when { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: #7A6F68; font-weight: 700; margin-top: 8px; }

  /* Apply form */
  .pn-form { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 18px; padding: 32px; margin-top: 26px; }
  .pn-form input, .pn-form textarea, .pn-form select { width: 100%; box-sizing: border-box; background: #FAF8F5; border: 1px solid rgba(14,11,8,0.15); padding: 10px 14px; border-radius: 8px; font-family: inherit; font-size: 14px; color: #0E0B08; margin-bottom: 10px; }
  .pn-form label { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #7A6F68; font-weight: 700; margin-bottom: 5px; display: block; margin-top: 6px; }
  .pn-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .pn-form-row3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; }
  @media (max-width: 700px) { .pn-form-row, .pn-form-row3 { grid-template-columns: 1fr; } }
  .pn-form-tier { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
  .pn-form-tier label { display: block; cursor: pointer; padding: 14px 18px; border: 1.5px solid rgba(14,11,8,0.15); border-radius: 10px; font-family: inherit; font-size: 14px; color: #0E0B08; text-transform: none; letter-spacing: 0; margin: 0; }
  .pn-form-tier label.active { border-color: #FF4F00; background: #FFF3EE; }
  .pn-form-tier input { display: none; }
  .pn-form-tier strong { color: #FF4F00; font-weight: 700; }

  /* FAQ */
  .pn-faq { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 12px; padding: 18px 22px; margin-top: 10px; }
  .pn-faq summary { font-family: 'Cormorant Garamond', serif; font-size: 19px; font-weight: 600; cursor: pointer; padding: 6px 0; letter-spacing: -0.01em; }
  .pn-faq p { font-size: 14px; color: #2E2520; line-height: 1.7; margin: 8px 0 0; }
</style>

<main>

  <section class="pn-hero">
    <p class="pn-eyebrow">AquinTutor · Partnerships</p>
    <h1 class="pn-title">Host your courses on <em>AquinTutor</em>.</h1>
    <p class="pn-sub">Universities, companies, governments, publishers, and individual experts — bring your content to learners across India and the Global South. We handle hosting, identity, payments, proctoring, certificates, and discovery. You bring the curriculum and the faculty.</p>
    <div class="pn-cta-row">
      <a href="#apply" class="pn-btn">Apply to host &rarr;</a>
      <a href="#pricing" class="pn-btn pn-btn-ghost">See pricing</a>
    </div>
  </section>

  <div class="pn-strip">
    <div class="pn-stat"><p class="pn-stat-val">CHF 100</p><p class="pn-stat-lbl">Starter · one course</p></div>
    <div class="pn-stat"><p class="pn-stat-val">15%</p><p class="pn-stat-lbl">Rev share · additional</p></div>
    <div class="pn-stat"><p class="pn-stat-val">5 days</p><p class="pn-stat-lbl">Review SLA</p></div>
    <div class="pn-stat"><p class="pn-stat-val">12</p><p class="pn-stat-lbl">Indic languages</p></div>
    <div class="pn-stat"><p class="pn-stat-val">Global</p><p class="pn-stat-lbl">Learner reach</p></div>
  </div>

  <section class="pn-section">
    <p class="pn-section-eye">Who hosts here</p>
    <h2 class="pn-section-h">Open to <em>every kind</em> of educator.</h2>
    <p class="pn-section-sub">We do not list partner names publicly until a signed partnership agreement is on file. That protects everyone&mdash;you, your learners, and us. Apply, sign, then we list.</p>

    <div class="pn-kinds">
      <div class="pn-kind">
        <div class="pn-kind-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
        <h3 class="pn-kind-title">Universities &amp; institutes</h3>
        <p class="pn-kind-desc">Open lectures, assessed tracks, full degree streams. Your seal on the certificate, our discovery and proctoring underneath.</p>
      </div>
      <div class="pn-kind">
        <div class="pn-kind-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg></div>
        <h3 class="pn-kind-title">Companies &amp; teams</h3>
        <p class="pn-kind-desc">Technical academies, sales enablement, compliance training. Public or behind your own corporate domain.</p>
      </div>
      <div class="pn-kind">
        <div class="pn-kind-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></div>
        <h3 class="pn-kind-title">Governments &amp; NGOs</h3>
        <p class="pn-kind-desc">Workforce skilling, citizen training, vernacular literacy. State-scale rollouts with verifiable credentials.</p>
      </div>
      <div class="pn-kind">
        <div class="pn-kind-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 0 0-16 0"/></svg></div>
        <h3 class="pn-kind-title">Individual experts</h3>
        <p class="pn-kind-desc">Subject-matter experts, retired professors, working practitioners. Author a course; we handle everything else.</p>
      </div>
      <div class="pn-kind">
        <div class="pn-kind-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg></div>
        <h3 class="pn-kind-title">Publishers</h3>
        <p class="pn-kind-desc">Textbook publishers, journals, archives. Layer assessments and certificates over existing content libraries.</p>
      </div>
      <div class="pn-kind">
        <div class="pn-kind-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg></div>
        <h3 class="pn-kind-title">Media houses</h3>
        <p class="pn-kind-desc">News outlets, podcast networks, video creators. Turn existing media into structured learning paths.</p>
      </div>
    </div>
  </section>

  <section class="pn-section">
    <p class="pn-section-eye">What's included</p>
    <h2 class="pn-section-h">Everything <em>except the course itself</em>.</h2>
    <p class="pn-section-sub">You bring the curriculum, the lectures, the faculty. We bring the rails that turn it into a real, deployable, monetisable learning surface.</p>

    <div class="pn-value-grid">
      <div class="pn-value"><div class="pn-value-num">01</div><h3 class="pn-value-h">Authoring system</h3><p class="pn-value-p">Block-based lesson editor with 13 content kinds: text, headings, video, callouts, code, MCQ, fill-blank, ordered steps, file attachments, quotes, LaTeX, dividers.</p></div>
      <div class="pn-value"><div class="pn-value-num">02</div><h3 class="pn-value-h">Identity &amp; auth</h3><p class="pn-value-p">Email + phone + face 2FA. Government-grade. Optional KYC. Single sign-on across all your courses.</p></div>
      <div class="pn-value"><div class="pn-value-num">03</div><h3 class="pn-value-h">Payments</h3><p class="pn-value-p">Razorpay in India, Stripe globally. INR + CHF + 8 other currencies. Coupons, scholarships, fee-waivers built-in.</p></div>
      <div class="pn-value"><div class="pn-value-num">04</div><h3 class="pn-value-h">ATLAS proctoring</h3><p class="pn-value-p">28 event types, severity-weighted integrity score, browser-side detection. Advisory-only by default &mdash; humans decide.</p></div>
      <div class="pn-value"><div class="pn-value-num">05</div><h3 class="pn-value-h">Certificates</h3><p class="pn-value-p">Verifiable certificates with your seal, public verification URL, blockchain-anchorable. Auto-issued on course completion.</p></div>
      <div class="pn-value"><div class="pn-value-num">06</div><h3 class="pn-value-h">Discovery</h3><p class="pn-value-p">Listed in the AquinTutor catalogue, the global MOOC federation, and the AI tutor's recommendation graph.</p></div>
      <div class="pn-value"><div class="pn-value-num">07</div><h3 class="pn-value-h">Vernacular delivery</h3><p class="pn-value-p">12 Indic languages out of the box. Auto-captioning, dubbing pipelines, native-script lesson rendering.</p></div>
      <div class="pn-value"><div class="pn-value-num">08</div><h3 class="pn-value-h">Analytics</h3><p class="pn-value-p">Cohort dashboards. Lesson-level completion. Drop-off pinpointing. Outcome forecasts. Cohort A/B testing.</p></div>
      <div class="pn-value"><div class="pn-value-num">09</div><h3 class="pn-value-h">Support</h3><p class="pn-value-p">Onboarding engineer for 2 weeks. Private community channel + email. Quarterly business review.</p></div>
    </div>
  </section>

  <section class="pn-section" id="pricing">
    <p class="pn-section-eye">Pricing</p>
    <h2 class="pn-section-h">Two tiers. <em>That's it.</em></h2>
    <p class="pn-section-sub">No setup fee. No seat licences. No surprise invoices. The Starter tier is a one-off CHF 100 to host your first course end-to-end. Continue past the first course and you join the Scale tier &mdash; 15% revenue share on each additional course, exclusive of taxes.</p>

    <div class="pn-pricing-grid">
      <div class="pn-price">
        <p class="pn-price-tag">Starter</p>
        <p class="pn-price-name">First course</p>
        <p><span class="pn-price-amt">CHF 100</span><span class="pn-price-per"> &middot; one-time</span></p>
        <p class="pn-price-sub">Bring one course to launch. Get start-level support, sandbox credentials, and a live integration engineer for the first two weeks.</p>
        <ul>
          <li>One course, no enrolment cap</li>
          <li>Full authoring system + lesson player</li>
          <li>Payments (you keep 100% of course revenue)</li>
          <li>ATLAS proctoring on quizzes &amp; tests</li>
          <li>Verifiable certificates with your seal</li>
          <li>Listed in AquinTutor catalogue</li>
          <li>Onboarding engineer for 2 weeks</li>
          <li>Email + private community channel</li>
        </ul>
        <a href="#apply" class="pn-price-cta">Start with one course &rarr;</a>
      </div>

      <div class="pn-price featured">
        <p class="pn-price-tag">Scale &middot; partnership</p>
        <p class="pn-price-name">Multiple courses</p>
        <p><span class="pn-price-amt">15%</span><span class="pn-price-per"> &middot; revenue share, per additional course</span></p>
        <p class="pn-price-sub">After your first course is live and you want to publish more, you join the partnership tier. Revenue share is 15% of total fees charged on each additional course, exclusive of taxes.</p>
        <ul>
          <li>Unlimited additional courses</li>
          <li>Co-branding + your own subdomain</li>
          <li>Custom learning paths &amp; bundles</li>
          <li>Cohort analytics + outcome dashboards</li>
          <li>Priority placement in discovery</li>
          <li>Vernacular dubbing pipeline (12 languages)</li>
          <li>Dedicated partnership manager</li>
          <li>Quarterly business review</li>
        </ul>
        <a href="#apply" class="pn-price-cta" style="background:#FF7040;color:#0E0B08;">Apply for partnership &rarr;</a>
      </div>
    </div>

    <div class="pn-revshare-note">
      <strong>How the 15% revenue share works.</strong> For each additional course you publish after your first one, we take 15% of the fees you charge learners (paid in CHF, INR, or any supported currency). Revenue share is calculated on the gross fee paid by the learner, <strong>exclusive of GST, VAT, and any local taxes</strong> which pass through to the relevant authority untouched. We disburse the remaining 85% to you within 7 business days of learner payment clearance. There is no minimum guarantee &mdash; if a course earns nothing, you owe nothing.
      <div class="pn-revshare-formula">your_payout = gross_fee_paid_by_learner &minus; taxes &minus; (0.15 &times; (gross_fee_paid_by_learner &minus; taxes))</div>
      Free courses pay no revenue share, but still get full hosting, identity, and certificates included. Government &amp; non-profit partners on national-scale programmes qualify for a reduced 5% rate &mdash; please mention this in your application.
    </div>
  </section>

  <section class="pn-section">
    <p class="pn-section-eye">Quality criteria</p>
    <h2 class="pn-section-h">Same admissions bar as the <em>top global open-learning platforms</em>.</h2>
    <p class="pn-section-sub">Pricing is open. Quality is not. We do not relax the criteria for any tier &mdash; CHF 100 buys you hosting and support, it does not buy a free pass into the catalogue. Courses that fail review get specific feedback and one resubmission per cycle.</p>

    <div class="pn-value-grid" style="margin-top:26px;">
      <div class="pn-value"><div class="pn-value-num">A</div><h3 class="pn-value-h">Faculty credentials</h3><p class="pn-value-p">Terminal degree in the subject (PhD, MD, or equivalent) <em>or</em> verifiable senior industry practice (8+ years at a recognised employer or as a published founder/practitioner). Identity verified, public CV on file.</p></div>
      <div class="pn-value"><div class="pn-value-num">B</div><h3 class="pn-value-h">Learning outcomes</h3><p class="pn-value-p">Every course states what a learner can <em>do</em> at the end &mdash; observable, assessable, measurable. We reject vague outcomes like "understand X". We accept "compute X", "build X", "diagnose X", "prove X".</p></div>
      <div class="pn-value"><div class="pn-value-num">C</div><h3 class="pn-value-h">Assessment rigour</h3><p class="pn-value-p">Real assessments: graded problem sets, proctored exams, peer review, or capstone projects. No participation-only certificates. We benchmark difficulty against established global open-learning platforms in the same subject &mdash; a passing learner here should pass there.</p></div>
      <div class="pn-value"><div class="pn-value-num">D</div><h3 class="pn-value-h">Original or licensed</h3><p class="pn-value-p">All content original to you or licensed with documentation. We run plagiarism + AI-content detection on every lesson. Borrowed content without attribution is grounds for immediate de-listing and revocation of certificates issued.</p></div>
      <div class="pn-value"><div class="pn-value-num">E</div><h3 class="pn-value-h">Production quality</h3><p class="pn-value-p">Audio at 48&nbsp;kHz, video at 1080p minimum, captions in your delivery language, slides legible at mobile sizes. We provide a production checklist; courses that fail it go to revision.</p></div>
      <div class="pn-value"><div class="pn-value-num">F</div><h3 class="pn-value-h">Pedagogical structure</h3><p class="pn-value-p">Each lesson runs 6 to 18 minutes &mdash; the proven attention-span band. Concepts introduced with a worked example, followed by a practice, followed by a reflection. Course mapped to a constructive-alignment grid.</p></div>
      <div class="pn-value"><div class="pn-value-num">G</div><h3 class="pn-value-h">Accessibility</h3><p class="pn-value-p">WCAG 2.1 AA. Closed captions in the lecture language. Transcripts for every video. Alt text on every figure. Vernacular subtitle commitment (at least one Indic language for courses launching in India).</p></div>
      <div class="pn-value"><div class="pn-value-num">H</div><h3 class="pn-value-h">Academic integrity</h3><p class="pn-value-p">Proctoring on summative assessments. ID verification on certificate issuance. Honour code accepted on enrolment. Suspended-for-cause learner records kept for 5 years.</p></div>
      <div class="pn-value"><div class="pn-value-num">I</div><h3 class="pn-value-h">Continuous improvement</h3><p class="pn-value-p">Quarterly review of completion rates, NPS, and learner reviews. Courses below benchmark for two consecutive quarters go to mandatory revision before the next cohort.</p></div>
    </div>

    <div class="pn-revshare-note" style="margin-top:30px;">
      <strong>Same bar, no exceptions.</strong> A Tier-1 university and an individual expert face the same review committee. The committee is composed of three reviewers: a domain expert, a pedagogy expert, and a production-quality expert. A simple majority approves. We publish the criteria so partners know exactly what we look for &mdash; no opaque rejections.
    </div>
  </section>

  <section class="pn-section">
    <p class="pn-section-eye">From application to first learner</p>
    <h2 class="pn-section-h">Five steps. <em>Two to three weeks.</em></h2>

    <div class="pn-timeline">
      <div class="pn-step"><div class="pn-step-n">01</div><h3 class="pn-step-h">Apply</h3><p class="pn-step-p">Submit the form below with your intended course title, summary, and target learners.</p><p class="pn-step-when">Day 0</p></div>
      <div class="pn-step"><div class="pn-step-n">02</div><h3 class="pn-step-h">Review</h3><p class="pn-step-p">Our partnerships team reviews. We may ask for a sample lesson or a video pilot.</p><p class="pn-step-when">Day 1 to 5</p></div>
      <div class="pn-step"><div class="pn-step-n">03</div><h3 class="pn-step-h">Sign</h3><p class="pn-step-p">Counter-signed MSA, sandbox credentials issued, integration engineer assigned.</p><p class="pn-step-when">Day 5 to 7</p></div>
      <div class="pn-step"><div class="pn-step-n">04</div><h3 class="pn-step-h">Author</h3><p class="pn-step-p">Build your course in the block editor. Engineering office hours twice a week.</p><p class="pn-step-when">Day 7 to 14</p></div>
      <div class="pn-step"><div class="pn-step-n">05</div><h3 class="pn-step-h">Launch</h3><p class="pn-step-p">Course goes live, certificate template stamped, discovery enabled, first learners enrolled.</p><p class="pn-step-when">Day 14 to 21</p></div>
    </div>
  </section>

  <section class="pn-section" id="apply">
    <p class="pn-section-eye">Apply</p>
    <h2 class="pn-section-h">Tell us about your <em>course</em>.</h2>
    <p class="pn-section-sub">A real human reads every application. We do not auto-approve. You will hear back within 5 business days with either an offer to onboard or specific feedback on what we would need to see.</p>

    {okMsg && <div style="background:rgba(26,107,53,0.08);border:1px solid #1A6B35;padding:14px 18px;border-radius:10px;margin-top:14px;"><p style="color:#1A6B35;font-weight:600;margin:0;">{okMsg}</p></div>}
    {errMsg && <div style="background:rgba(239,68,68,0.08);border:1px solid #b91c1c;padding:14px 18px;border-radius:10px;margin-top:14px;"><p style="color:#b91c1c;font-weight:600;margin:0;">{errMsg}</p></div>}

    {!okMsg && (
      <form method="POST" class="pn-form">
        <p class="pn-section-eye" style="margin-bottom:6px;">Tier you are starting with</p>
        <div class="pn-form-tier">
          <label class="tier-opt active" data-tier="starter">
            <input type="radio" name="tier" value="starter" checked/>
            <strong>Starter</strong> &middot; CHF 100 one-time<br/>
            <span style="font-size:12.5px;color:#7A6F68;">Host one course end-to-end</span>
          </label>
          <label class="tier-opt" data-tier="scale">
            <input type="radio" name="tier" value="scale"/>
            <strong>Scale partnership</strong> &middot; 15% rev share<br/>
            <span style="font-size:12.5px;color:#7A6F68;">Multiple courses, co-branded</span>
          </label>
        </div>

        <label>Organisation name *</label>
        <input name="org_name" required maxlength="300" placeholder="Your university / company / publisher / your name if individual"/>

        <label>Partner kind</label>
        <select name="partner_kind">
          <option value="university">University or institute</option>
          <option value="company">Company or team</option>
          <option value="government">Government or NGO</option>
          <option value="publisher">Publisher</option>
          <option value="media-house">Media house</option>
          <option value="individual-expert">Individual expert</option>
        </select>

        <div class="pn-form-row">
          <div><label>Contact name *</label><input name="contact_name" required maxlength="200" value={user?.name || ''}/></div>
          <div><label>Contact email *</label><input name="contact_email" type="email" required maxlength="200" value={user?.email || ''}/></div>
        </div>

        <div class="pn-form-row3">
          <div><label>Phone</label><input name="contact_phone" type="tel" maxlength="40"/></div>
          <div><label>Country</label><input name="country" maxlength="80" placeholder="India / Switzerland / etc."/></div>
          <div><label>Website</label><input name="website_url" type="url" placeholder="https://..."/></div>
        </div>

        <label>Intended course title *</label>
        <input name="intended_course_title" required maxlength="300" placeholder="e.g. Foundations of Vedic Mathematics &middot; for first-year undergraduates"/>

        <label>Course summary * (120+ characters)</label>
        <textarea name="intended_course_summary" rows="5" minlength="120" maxlength="3000" required placeholder="What the course teaches. Who it's for. Why it matters. What learners will be able to do at the end."></textarea>

        <label>Target learners</label>
        <input name="target_learners" maxlength="300" placeholder="e.g. UG students, working professionals in finance, government officers"/>

        <label>Existing content / faculty</label>
        <input name="existing_content" maxlength="500" placeholder="Do you have video lectures, slides, problem sets already? URL or note."/>

        <label>Co-branding preferences</label>
        <input name="co_branding" maxlength="300" placeholder="e.g. our logo on certificate, our seal on landing page, subdomain courses.yourname.org"/>

        <button type="submit" class="pn-price-cta" style="margin-top:18px;">Send application &rarr;</button>
        <p style="font-family:'Geist Mono',monospace;font-size:11px;color:#7A6F68;margin:10px 0 0;letter-spacing:0.04em;">By submitting you agree we may contact you about your application. We will not list your organisation publicly until a signed agreement is on file.</p>
      </form>
    )}
  </section>

  <section class="pn-section" style="border-bottom:none;">
    <p class="pn-section-eye">Common questions</p>
    <h2 class="pn-section-h">Things partners <em>actually ask</em>.</h2>

    <details class="pn-faq" open>
      <summary>Does the 15% include taxes?</summary>
      <p>No. The 15% revenue share is computed on the gross fee paid by the learner <em>minus</em> any applicable taxes (GST, VAT, etc.). Taxes always pass through to the relevant authority. You pay 15% of the net pre-tax revenue per additional course.</p>
    </details>
    <details class="pn-faq">
      <summary>What happens if my first course earns nothing?</summary>
      <p>The CHF 100 starter fee is a one-off hosting commitment, not a refundable deposit. If your first course earns no revenue, you owe no further fees. If you choose to publish a second course later, that course goes onto the 15% revenue share &mdash; only on what it actually earns.</p>
    </details>
    <details class="pn-faq">
      <summary>Can I host a free course?</summary>
      <p>Yes. Free courses pay no revenue share and still get full hosting, identity, certificates, and discovery included. The CHF 100 starter fee still applies to onboard your first course.</p>
    </details>
    <details class="pn-faq">
      <summary>Who owns the course content?</summary>
      <p>You do. AquinTutor is granted a non-exclusive license to host, transmit, and display your course for the duration of the partnership. You can withdraw your course with 30 days notice. Your IP stays yours.</p>
    </details>
    <details class="pn-faq">
      <summary>Do you list partner names publicly?</summary>
      <p>Only after a signed partnership agreement is on file. Until then your application is confidential. This protects everyone &mdash; us, you, and learners &mdash; from any implied claim of partnership before it is real.</p>
    </details>
    <details class="pn-faq">
      <summary>Government &amp; NGO discount?</summary>
      <p>Yes. National-scale citizen-training, workforce-skilling, and vernacular literacy programmes run by government departments or registered non-profits qualify for a reduced 5% revenue share. Mention this in your application.</p>
    </details>
    <details class="pn-faq">
      <summary>What about KYC and verification?</summary>
      <p>We verify every partner. Universities and government bodies: official letterhead and a verifiable institutional email. Companies: incorporation certificate. Individual experts: a public CV or portfolio plus identity verification. The CHF 100 starter fee is held in escrow until verification clears.</p>
    </details>
    <details class="pn-faq">
      <summary>When do I get paid?</summary>
      <p>Course revenue is disbursed weekly. Your 85% share (or 95% if you qualify for the government/NGO rate) is paid within 7 business days of the learner payment clearing through the payment processor. Statements are itemised by course and by learner.</p>
    </details>
  </section>

</main>

<script is:inline>
  (function () {
    document.querySelectorAll('.tier-opt').forEach(function (label) {
      label.addEventListener('click', function () {
        document.querySelectorAll('.tier-opt').forEach(function (l) { l.classList.remove('active'); });
        label.classList.add('active');
      });
    });
  })();
</script>
</BaseLayout>
