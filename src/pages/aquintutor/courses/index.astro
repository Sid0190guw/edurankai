---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { SITE } from '@/lib/site';

const url = new URL(Astro.request.url);
const q = (url.searchParams.get('q') || '').trim();
const catFilter = url.searchParams.get('cat') || '';
const levelFilter = url.searchParams.get('level') || '';
const priceFilter = url.searchParams.get('price') || '';
const durationFilter = url.searchParams.get('duration') || '';
const sort = url.searchParams.get('sort') || 'popular';
const view = url.searchParams.get('view') === 'list' ? 'list' : 'grid';
const ratingFilter = url.searchParams.get('rating') || '';

let courses: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT c.id, c.title, c.slug, c.short_desc, c.category, c.level, c.duration_hours,
      c.is_free, c.enrolled_count, c.created_at,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as total_lessons,
      (SELECT ROUND(AVG(rating)::numeric, 1) FROM training_reviews WHERE course_id = c.id) as avg_rating,
      (SELECT COUNT(*)::int FROM training_reviews WHERE course_id = c.id) as review_count
    FROM training_courses c
    WHERE c.is_published = true AND c.access_type IN ('public', 'both')
  `);
  courses = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

let filtered = courses;
if (catFilter) filtered = filtered.filter((c) => c.category === catFilter);
if (levelFilter) filtered = filtered.filter((c) => c.level === levelFilter);
if (priceFilter === 'free') filtered = filtered.filter((c) => c.is_free === true);
if (priceFilter === 'paid') filtered = filtered.filter((c) => c.is_free === false);
if (durationFilter === 'short') filtered = filtered.filter((c) => (c.duration_hours || 0) < 5);
if (durationFilter === 'medium') filtered = filtered.filter((c) => (c.duration_hours || 0) >= 5 && (c.duration_hours || 0) <= 20);
if (durationFilter === 'long') filtered = filtered.filter((c) => (c.duration_hours || 0) > 20);
if (ratingFilter) {
  const min = parseFloat(ratingFilter);
  if (Number.isFinite(min)) filtered = filtered.filter((c) => (c.avg_rating || 0) >= min);
}
if (q) {
  const ql = q.toLowerCase();
  filtered = filtered.filter((c) =>
    (c.title || '').toLowerCase().includes(ql) ||
    (c.short_desc || '').toLowerCase().includes(ql)
  );
}

if (sort === 'newest') filtered = filtered.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());
else if (sort === 'rating') filtered = filtered.sort((a, b) => (b.avg_rating || 0) - (a.avg_rating || 0));
else if (sort === 'shortest') filtered = filtered.sort((a, b) => (a.duration_hours || 0) - (b.duration_hours || 0));
else if (sort === 'longest') filtered = filtered.sort((a, b) => (b.duration_hours || 0) - (a.duration_hours || 0));
else filtered = filtered.sort((a, b) => (b.enrolled_count || 0) - (a.enrolled_count || 0));

const categories = Array.from(new Set(courses.map((c) => c.category).filter(Boolean)));
const LEVELS = ['beginner', 'intermediate', 'advanced'];
const SORT_OPTIONS = [
  { value: 'popular', label: 'Most popular' },
  { value: 'newest', label: 'Newest' },
  { value: 'rating', label: 'Highest rated' },
  { value: 'shortest', label: 'Shortest first' },
  { value: 'longest', label: 'Longest first' },
];

const totalAll = courses.length;
const totalFiltered = filtered.length;
const pageDesc = 'Browse ' + totalAll + ' open online courses from AquinTutor by EduRankAI. Free where possible. Verifiable certificates.';

const courseSchemaList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: filtered.slice(0, 50).map((c, i) => ({
    '@type': 'ListItem', position: i + 1,
    url: SITE.url + '/aquintutor/courses/' + c.slug,
    name: c.title,
  })),
};

function qs(o: Record<string, string | null>) {
  const params = new URLSearchParams();
  const map: Record<string, string> = { q, cat: catFilter, level: levelFilter, price: priceFilter, duration: durationFilter, rating: ratingFilter, sort, view };
  for (const [k, v] of Object.entries(map)) {
    const ov = o[k];
    const val = ov === undefined ? v : (ov === null ? '' : ov);
    if (val) params.set(k, val);
  }
  const s = params.toString();
  return '/aquintutor/courses' + (s ? '?' + s : '');
}
function starRow(n: number) {
  const filled = Math.round(n);
  return Array.from({ length: 5 }, (_, i) => i < filled);
}
---
<AquintutorLayout title="Courses" description={pageDesc}>
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(courseSchemaList)} />

  <style>
    .chip { display:inline-flex; align-items:center; gap:5px; padding:6px 12px; border-radius:100px; font-size:12px; font-weight:500; border:1px solid var(--ac-border); background:var(--ac-surface); color:var(--ac-ink-soft); text-decoration:none; transition:all 0.15s; white-space:nowrap; font-family:'Inter',sans-serif; }
    .chip.active { background:var(--ac-ink); color:var(--ac-surface); border-color:var(--ac-ink); }
    .chip:not(.active):hover { border-color:var(--ac-amber); color:var(--ac-amber); }
    .facet { padding:16px 0; border-bottom:1px solid var(--ac-rule); }
    .facet:last-child { border-bottom:0; }
    .facet-label { font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.14em; font-weight:700; color:var(--ac-ink-muted); text-transform:uppercase; margin-bottom:10px; display:block; }
    .search-row { display:flex; gap:10px; align-items:center; background:var(--ac-surface); border:1px solid var(--ac-border); border-radius:100px; padding:10px 18px; transition:border-color 0.15s; }
    .search-row:focus-within { border-color:var(--ac-amber); }
    .search-row input { flex:1; background:transparent; border:0; outline:0; font-family:'Inter',sans-serif; color:var(--ac-ink); font-size:14px; }
    .search-row input::placeholder { color:var(--ac-ink-muted); }
  </style>

  <!-- HERO -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:56px 24px 40px;">
      <div style="display:flex; align-items:center; gap:16px; margin-bottom:24px;" class="numplate">
        <span style="height:1px; width:48px; background:var(--ink);"></span>
        <span style="color:var(--ink-500);">THE CATALOGUE &middot; CURRENT TERM</span>
      </div>
      <h1 class="font-display" style="font-size:clamp(3rem,8vw,8rem); line-height:0.92; letter-spacing:-0.025em; font-weight:500; margin:0;">
        All courses<br/>
        <span style="font-style:italic; font-weight:300; color:var(--ink-500);">on the register.</span>
      </h1>
      <p class="font-serif" style="font-size:clamp(1.25rem, 2vw, 1.875rem); line-height:1.3; color:var(--ink-500); margin-top:24px; max-width:48rem;">
        {totalAll} courses currently open across six schools. New offerings each term. Every completion is recorded against your 1 CHF enrolment; sit the proctored examination when you are ready and the credential is yours.
      </p>
    </div>
  </section>

  <!-- SEARCH BAR -->
  <section class="ac-container" style="padding:0 5vw 24px; max-width:1180px;">
    <form method="GET">
      <input type="hidden" name="view" value={view} />
      <input type="hidden" name="sort" value={sort} />
      <div class="search-row">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--ac-ink-muted);"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" name="q" value={q} placeholder="Search courses by title, topic, or skill..." autocomplete="off" />
        <button type="submit" class="ac-btn" style="padding:6px 14px; min-height:0; font-size:12px;">Search</button>
      </div>
    </form>
  </section>

  <!-- FACETS + RESULTS -->
  <section class="ac-container" style="padding:24px 5vw 80px;">
    <div style="display:grid; grid-template-columns:1fr; gap:32px;" class="grid-cols-1 lg:grid-cols-4">
      <aside style="grid-column:span 1;">
        <div class="ac-card" style="position:sticky; top:90px;">
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
            <p style="font-family:'Fraunces',serif; font-size:1.1rem; font-weight:500; color:var(--ac-ink);">Filters</p>
            {(catFilter || levelFilter || priceFilter || durationFilter || ratingFilter) && (
              <a href={qs({ cat: null, level: null, price: null, duration: null, rating: null })} style="font-size:12px; color:var(--ac-amber); font-weight:500; text-decoration:none;">Clear all</a>
            )}
          </div>

          <div class="facet">
            <span class="facet-label">Price</span>
            <div class="ac-flex ac-wrap ac-gap-2">
              <a href={qs({ price: null })} class={'chip ' + (!priceFilter ? 'active' : '')}>Any</a>
              <a href={qs({ price: 'free' })} class={'chip ' + (priceFilter === 'free' ? 'active' : '')}>Free</a>
              <a href={qs({ price: 'paid' })} class={'chip ' + (priceFilter === 'paid' ? 'active' : '')}>Paid</a>
            </div>
          </div>

          <div class="facet">
            <span class="facet-label">Level</span>
            <div class="ac-flex ac-wrap ac-gap-2">
              <a href={qs({ level: null })} class={'chip ' + (!levelFilter ? 'active' : '')}>Any</a>
              {LEVELS.map((lv) => (
                <a href={qs({ level: lv })} class={'chip ' + (levelFilter === lv ? 'active' : '')}>{lv}</a>
              ))}
            </div>
          </div>

          <div class="facet">
            <span class="facet-label">Duration</span>
            <div class="ac-flex ac-wrap ac-gap-2">
              <a href={qs({ duration: null })} class={'chip ' + (!durationFilter ? 'active' : '')}>Any</a>
              <a href={qs({ duration: 'short' })} class={'chip ' + (durationFilter === 'short' ? 'active' : '')}>&lt;5h</a>
              <a href={qs({ duration: 'medium' })} class={'chip ' + (durationFilter === 'medium' ? 'active' : '')}>5-20h</a>
              <a href={qs({ duration: 'long' })} class={'chip ' + (durationFilter === 'long' ? 'active' : '')}>20h+</a>
            </div>
          </div>

          {categories.length > 0 && (
            <div class="facet">
              <span class="facet-label">Category</span>
              <div class="ac-flex ac-wrap ac-gap-2">
                <a href={qs({ cat: null })} class={'chip ' + (!catFilter ? 'active' : '')}>All</a>
                {categories.map((c) => (
                  <a href={qs({ cat: c })} class={'chip ' + (catFilter === c ? 'active' : '')}>{c}</a>
                ))}
              </div>
            </div>
          )}

          <div class="facet">
            <span class="facet-label">Min rating</span>
            <div class="ac-flex ac-wrap ac-gap-2">
              <a href={qs({ rating: null })} class={'chip ' + (!ratingFilter ? 'active' : '')}>Any</a>
              <a href={qs({ rating: '4.5' })} class={'chip ' + (ratingFilter === '4.5' ? 'active' : '')}>4.5+</a>
              <a href={qs({ rating: '4' })} class={'chip ' + (ratingFilter === '4' ? 'active' : '')}>4+</a>
              <a href={qs({ rating: '3' })} class={'chip ' + (ratingFilter === '3' ? 'active' : '')}>3+</a>
            </div>
          </div>
        </div>
      </aside>

      <div style="grid-column:span 1;" class="lg-cols-3">
        <div class="ac-card" style="padding:14px 20px; margin-bottom:18px; display:flex; flex-wrap:wrap; justify-content:space-between; align-items:center; gap:12px;">
          <p style="font-size:13.5px; color:var(--ac-ink-soft);">
            <strong style="color:var(--ac-ink); font-weight:600;">{totalFiltered}</strong> course{totalFiltered === 1 ? '' : 's'}
            {totalFiltered !== totalAll && <span style="color:var(--ac-ink-muted);"> of {totalAll}</span>}
          </p>
          <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
            <label style="font-size:11.5px; font-family:'Geist Mono',monospace; color:var(--ac-ink-muted); text-transform:uppercase; letter-spacing:0.1em;">Sort</label>
            <form method="GET" style="display:inline;">
              {q && <input type="hidden" name="q" value={q} />}
              {catFilter && <input type="hidden" name="cat" value={catFilter} />}
              {levelFilter && <input type="hidden" name="level" value={levelFilter} />}
              {priceFilter && <input type="hidden" name="price" value={priceFilter} />}
              {durationFilter && <input type="hidden" name="duration" value={durationFilter} />}
              {ratingFilter && <input type="hidden" name="rating" value={ratingFilter} />}
              <input type="hidden" name="view" value={view} />
              <select name="sort" onchange="this.form.submit()" style="background:var(--ac-surface); border:1px solid var(--ac-border); border-radius:6px; padding:6px 10px; font-family:'Inter',sans-serif; font-size:13px; color:var(--ac-ink); outline:none;">
                {SORT_OPTIONS.map((s) => (
                  <option value={s.value} selected={sort === s.value}>{s.label}</option>
                ))}
              </select>
            </form>
          </div>
        </div>

        {filtered.length === 0 && (
          <div class="ac-card" style="text-align:center; padding:60px 20px;">
            <p style="font-family:'Fraunces',serif; font-size:1.4rem; color:var(--ac-ink); margin-bottom:8px;">No courses match these filters.</p>
            <p style="font-size:14px; color:var(--ac-ink-soft); margin-bottom:20px; max-width:480px; margin-left:auto; margin-right:auto;">Try clearing some filters, or request a course on a topic we don't cover yet.</p>
            <div class="ac-flex ac-wrap ac-gap-3" style="justify-content:center;">
              <a href="/aquintutor/courses" class="ac-btn">Clear filters</a>
              <a href="/contact" class="ac-btn ac-btn-ghost">Request a course</a>
            </div>
          </div>
        )}

        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:16px;">
          {filtered.map((c) => (
            <a href={'/aquintutor/courses/' + c.slug} class="ac-course">
              <div class="ac-flex ac-gap-2 ac-mb-3">
                <span class="ac-pill ac-pill-amber">{c.level || 'beginner'}</span>
                {c.is_free && <span class="ac-pill ac-pill-leaf">Free</span>}
                {c.category && <span class="ac-pill">{c.category}</span>}
              </div>
              <h3 class="ac-course-title">{c.title}</h3>
              <p class="ac-course-desc">{c.short_desc || ''}</p>
              {c.avg_rating && (
                <div style="display:flex; align-items:center; gap:8px; margin-bottom:8px;">
                  <span style="font-size:13px; font-weight:600; color:var(--ac-amber); font-family:'Fraunces',serif;">{Number(c.avg_rating).toFixed(1)}</span>
                  <div style="display:flex; gap:1px;">
                    {starRow(Number(c.avg_rating)).map((on) => (
                      <svg width="11" height="11" viewBox="0 0 24 24" fill={on ? '#B8512E' : 'none'} stroke={on ? '#B8512E' : 'rgba(26,22,18,0.15)'} stroke-width="2"><polygon points="12 2 15 9 22 9 17 14 19 22 12 18 5 22 7 14 2 9 9 9"/></svg>
                    ))}
                  </div>
                  <span style="font-size:11.5px; color:var(--ac-ink-muted);">({c.review_count})</span>
                </div>
              )}
              <div class="ac-course-meta">
                <span>{c.total_lessons || 0} lessons</span>
                {c.duration_hours > 0 && <span>{c.duration_hours}h</span>}
                {c.enrolled_count > 0 && <span>{c.enrolled_count} learners</span>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <style is:global>
    @media (min-width: 1024px) {
      .academy .lg-cols-3 { }
      .academy section > div[style*="grid-template-columns:1fr"] { grid-template-columns: 1fr 3fr !important; }
    }
  </style>
</AquintutorLayout>
