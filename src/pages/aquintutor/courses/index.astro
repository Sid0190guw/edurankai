---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { SITE } from '@/lib/site';

const url = new URL(Astro.request.url);
const q = (url.searchParams.get('q') || '').trim();
const catFilter = url.searchParams.get('cat') || '';
const levelFilter = url.searchParams.get('level') || '';
const priceFilter = url.searchParams.get('price') || '';
const durationFilter = url.searchParams.get('duration') || '';
const schoolFilter = url.searchParams.get('school') || '';
const sort = url.searchParams.get('sort') || 'popular';
const ratingFilter = url.searchParams.get('rating') || '';

let courses: any[] = [];
let schools: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT c.id, c.title, c.slug, c.subtitle, c.short_desc, c.category, c.level, c.duration_hours, c.duration_weeks,
      c.is_free, c.is_paid_course, c.price_inr_paise, c.price_chf, c.enrolled_count, c.created_at, c.credit_hours, c.course_code, c.instructor_name,
      s.id as school_id, s.code as school_code, s.name as school_name, s.slug as school_slug,
      d.name as dept_name,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as total_lessons,
      (SELECT ROUND(AVG(rating)::numeric, 1) FROM training_reviews WHERE course_id = c.id) as avg_rating,
      (SELECT COUNT(*)::int FROM training_reviews WHERE course_id = c.id) as review_count
    FROM training_courses c
    LEFT JOIN schools s ON c.school_id = s.id
    LEFT JOIN academic_departments d ON c.department_id = d.id
    WHERE c.is_published = true AND c.access_type IN ('public', 'both')
  `);
  courses = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`SELECT id, slug, code, name FROM schools WHERE is_published = true ORDER BY display_order`);
  schools = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

let filtered = courses;
if (catFilter) filtered = filtered.filter((c) => c.category === catFilter);
if (levelFilter) filtered = filtered.filter((c) => c.level === levelFilter);
if (schoolFilter) filtered = filtered.filter((c) => c.school_code === schoolFilter || c.school_slug === schoolFilter);
if (priceFilter === 'free') filtered = filtered.filter((c) => c.is_free === true);
if (priceFilter === 'paid') filtered = filtered.filter((c) => c.is_free === false);
if (durationFilter === 'short') filtered = filtered.filter((c) => (c.duration_hours || 0) < 5);
if (durationFilter === 'medium') filtered = filtered.filter((c) => (c.duration_hours || 0) >= 5 && (c.duration_hours || 0) <= 20);
if (durationFilter === 'long') filtered = filtered.filter((c) => (c.duration_hours || 0) > 20);
if (ratingFilter) {
  const min = parseFloat(ratingFilter);
  if (Number.isFinite(min)) filtered = filtered.filter((c) => (c.avg_rating || 0) >= min);
}
if (q) {
  const ql = q.toLowerCase();
  filtered = filtered.filter((c) =>
    (c.title || '').toLowerCase().includes(ql) ||
    (c.short_desc || '').toLowerCase().includes(ql) ||
    (c.subtitle || '').toLowerCase().includes(ql)
  );
}

if (sort === 'newest') filtered = filtered.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());
else if (sort === 'rating') filtered = filtered.sort((a, b) => (b.avg_rating || 0) - (a.avg_rating || 0));
else if (sort === 'shortest') filtered = filtered.sort((a, b) => (a.duration_hours || 0) - (b.duration_hours || 0));
else if (sort === 'longest') filtered = filtered.sort((a, b) => (b.duration_hours || 0) - (a.duration_hours || 0));
else if (sort === 'alpha') filtered = filtered.sort((a, b) => (a.title || '').localeCompare(b.title || ''));
else filtered = filtered.sort((a, b) => (b.enrolled_count || 0) - (a.enrolled_count || 0));

const categories = Array.from(new Set(courses.map((c) => c.category).filter(Boolean)));
const LEVELS = ['beginner', 'intermediate', 'advanced'];
const SORT_OPTIONS = [
  { value: 'popular', label: 'Most popular' },
  { value: 'newest', label: 'Newest' },
  { value: 'rating', label: 'Highest rated' },
  { value: 'shortest', label: 'Shortest first' },
  { value: 'longest', label: 'Longest first' },
  { value: 'alpha', label: 'A-Z by title' },
];

const totalAll = courses.length;
const totalFiltered = filtered.length;
const freeCount = courses.filter(c => c.is_free).length;
const paidCount = totalAll - freeCount;
const totalLessons = courses.reduce((s, c) => s + (c.total_lessons || 0), 0);
const featured = filtered.find(c => (c.avg_rating || 0) >= 4) || filtered[0] || null;

const pageDesc = 'Browse ' + totalAll + ' open online courses from AquinTutor by EduRankAI. Free where possible. Verifiable certificates.';

const courseSchemaList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: filtered.slice(0, 50).map((c, i) => ({
    '@type': 'ListItem', position: i + 1,
    url: SITE.url + '/aquintutor/courses/' + c.slug,
    name: c.title,
  })),
};

function qs(o: Record<string, string | null>) {
  const params = new URLSearchParams();
  const map: Record<string, string> = { q, cat: catFilter, level: levelFilter, price: priceFilter, duration: durationFilter, rating: ratingFilter, school: schoolFilter, sort };
  for (const [k, v] of Object.entries(map)) {
    const ov = o[k];
    const val = ov === undefined ? v : (ov === null ? '' : ov);
    if (val) params.set(k, val);
  }
  const s = params.toString();
  return '/aquintutor/courses' + (s ? '?' + s : '');
}

const anyFilter = !!(catFilter || levelFilter || priceFilter || durationFilter || ratingFilter || schoolFilter || q);
const chipBase = 'display:inline-flex; align-items:center; gap:5px; padding:7px 13px; border-radius:999px; font-family:Inter Tight,sans-serif; font-size:12.5px; font-weight:500; text-decoration:none; transition:background 0.12s,border-color 0.12s; white-space:nowrap; text-transform:capitalize;';
const chipOff = chipBase + ' background:var(--paper); border:1px solid var(--rule); color:var(--ink-500);';
const chipOn = chipBase + ' background:var(--ink); color:var(--sand-50); border:1px solid var(--ink);';

function starRow(n: number) {
  const filled = Math.round(n);
  return Array.from({ length: 5 }, (_, i) => i < filled);
}

// Per-course price for display. Paid courses carry a CHF base for live-FX; free/included show no figure.
function priceOf(c: any): { paid: boolean; inr: number; chf: number } {
  const paid = c.is_paid_course === true && c.is_free !== true;
  if (!paid) return { paid: false, inr: 0, chf: 0 };
  const inr = Math.max(1, Math.floor((c.price_inr_paise || 100) / 100));
  const chf = Number(c.price_chf) > 0 ? Number(c.price_chf) : Math.max(1, Math.round((inr / 95) * 100) / 100);
  return { paid: true, inr, chf };
}
---
<AquintutorLayout title="Courses" description={pageDesc}>
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(courseSchemaList)} />

  <!-- HERO -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1320px; margin:0 auto; padding:64px 28px 36px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); font-weight:600; letter-spacing:0.04em; margin:0 0 16px;">The catalogue &middot; current term</p>
      <h1 class="font-display" style="font-size:clamp(2.25rem, 5vw, 4.25rem); line-height:1; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--ink); max-width:46rem;">
        Every course<br/>
        <span style="font-style:italic; font-weight:300; color:var(--ink-500);">on the register.</span>
      </h1>
      <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.1rem, 1.5vw, 1.35rem); line-height:1.5; color:var(--ink-500); margin:24px 0 0; max-width:42rem;">
        {totalAll} courses currently open across {schools.length} schools. New offerings each term &mdash; Vedic sciences, advanced computing, quantum technology and ASI tracks. Enrolment is by application; sit the proctored examination when you are ready and the credential is yours.
      </p>
    </div>
  </section>

  <!-- STAT STRIP -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1320px; margin:0 auto; padding:28px 28px;">
      <div style="display:grid; grid-template-columns:repeat(2, 1fr); gap:12px;" class="stat-row">
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px 18px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">In catalogue</p>
          <p class="font-display" style="font-size:1.55rem; font-weight:500; margin:0; line-height:1; letter-spacing:-0.02em; color:var(--ink);">{totalAll}</p>
        </div>
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px 18px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">Free</p>
          <p class="font-display" style="font-size:1.55rem; font-weight:500; margin:0; line-height:1; letter-spacing:-0.02em; color:var(--ink);">{freeCount}</p>
        </div>
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px 18px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">Credentialled</p>
          <p class="font-display" style="font-size:1.55rem; font-weight:500; margin:0; line-height:1; letter-spacing:-0.02em; color:var(--ink);">{paidCount}</p>
        </div>
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px 18px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">Lessons authored</p>
          <p class="font-display" style="font-size:1.55rem; font-weight:500; margin:0; line-height:1; letter-spacing:-0.02em; color:var(--ink);">{totalLessons}</p>
        </div>
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px 18px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">Schools</p>
          <p class="font-display" style="font-size:1.55rem; font-weight:500; margin:0; line-height:1; letter-spacing:-0.02em; color:var(--ink);">{schools.length}</p>
        </div>
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px 18px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">Admission</p>
          <p class="font-display" style="font-size:1.35rem; font-weight:500; margin:0; line-height:1.05; letter-spacing:-0.02em; color:var(--rust);">By application</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SEARCH + FILTERS -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1320px; margin:0 auto; padding:32px 28px 24px;">

      <!-- Search -->
      <form method="GET" style="display:flex; gap:10px; align-items:center; background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:8px 8px 8px 16px; margin-bottom:22px;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="color:var(--ink-500); flex-shrink:0;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" name="q" value={q} placeholder="Search the catalogue by title, topic, or skill" autocomplete="off" style="flex:1; background:transparent; border:0; outline:0; font-family:'Inter Tight',sans-serif; color:var(--ink); font-size:14.5px; padding:8px 0;" />
        {catFilter && <input type="hidden" name="cat" value={catFilter} />}
        {levelFilter && <input type="hidden" name="level" value={levelFilter} />}
        {priceFilter && <input type="hidden" name="price" value={priceFilter} />}
        {durationFilter && <input type="hidden" name="duration" value={durationFilter} />}
        {ratingFilter && <input type="hidden" name="rating" value={ratingFilter} />}
        {schoolFilter && <input type="hidden" name="school" value={schoolFilter} />}
        {sort && <input type="hidden" name="sort" value={sort} />}
        <button type="submit" style="background:var(--ink); color:var(--sand-50); padding:9px 18px; border:none; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; cursor:pointer;">Search</button>
      </form>

      <!-- Filter rows -->
      <div style="display:flex; flex-direction:column; gap:14px;">
        <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
          <span style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; min-width:64px;">School</span>
          <a href={qs({ school: null })} style={!schoolFilter ? chipOn : chipOff}>All</a>
          {schools.map((s: any) => (
            <a href={qs({ school: s.code })} style={schoolFilter === s.code ? chipOn : chipOff}>{s.name.replace('School of ', '')}</a>
          ))}
        </div>

        <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
          <span style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; min-width:64px;">Level</span>
          <a href={qs({ level: null })} style={!levelFilter ? chipOn : chipOff}>Any</a>
          {LEVELS.map((lv) => (<a href={qs({ level: lv })} style={levelFilter === lv ? chipOn : chipOff}>{lv}</a>))}
        </div>

        <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
          <span style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; min-width:64px;">Duration</span>
          <a href={qs({ duration: null })} style={!durationFilter ? chipOn : chipOff}>Any</a>
          <a href={qs({ duration: 'short' })} style={durationFilter === 'short' ? chipOn : chipOff}>&lt;5h</a>
          <a href={qs({ duration: 'medium' })} style={durationFilter === 'medium' ? chipOn : chipOff}>5-20h</a>
          <a href={qs({ duration: 'long' })} style={durationFilter === 'long' ? chipOn : chipOff}>20h+</a>
        </div>

        <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
          <span style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; min-width:64px;">Fee</span>
          <a href={qs({ price: null })} style={!priceFilter ? chipOn : chipOff}>Any</a>
          <a href={qs({ price: 'free' })} style={priceFilter === 'free' ? chipOn : chipOff}>Open courses</a>
          <a href={qs({ price: 'paid' })} style={priceFilter === 'paid' ? chipOn : chipOff}>Credentialled</a>
        </div>

        {categories.length > 0 && (
          <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
            <span style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; min-width:64px;">Topic</span>
            <a href={qs({ cat: null })} style={!catFilter ? chipOn : chipOff}>All</a>
            {categories.slice(0, 12).map((c) => (<a href={qs({ cat: c })} style={catFilter === c ? chipOn : chipOff}>{c}</a>))}
          </div>
        )}
      </div>

      {anyFilter && (
        <div style="display:flex; align-items:center; gap:14px; flex-wrap:wrap; margin-top:20px; padding-top:18px; border-top:1px solid var(--rule);">
          <span style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500);">{totalFiltered} of {totalAll} courses match</span>
          <a href="/aquintutor/courses" style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--rust); text-decoration:underline; font-weight:500;">Clear all filters</a>
        </div>
      )}
    </div>
  </section>

  {featured && !anyFilter && (
    <!-- FEATURED -->
    <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
      <div style="max-width:1320px; margin:0 auto; padding:48px 28px;">
        <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 14px;">Editor's pick</p>
        <a href={'/aquintutor/courses/' + featured.slug} style="display:grid; grid-template-columns:1fr; gap:24px; background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:30px; text-decoration:none; color:var(--ink); align-items:center;" class="featured-card">
          <div>
            <div style="display:flex; gap:6px; flex-wrap:wrap; margin-bottom:14px;">
              <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.16em; color:var(--rust); font-weight:600;">{(featured.school_code || 'SCR').toUpperCase()}</span>
              <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.16em; color:var(--ink-500);">&middot; {(featured.level || 'beginner').toUpperCase()}</span>
              {featured.course_code && <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.16em; color:var(--ink-500);">&middot; {featured.course_code}</span>}
            </div>
            <h2 class="font-display" style="font-size:clamp(1.85rem, 3.5vw, 2.65rem); font-weight:500; line-height:1.1; letter-spacing:-0.02em; margin:0 0 14px; color:var(--ink);">{featured.title}</h2>
            {featured.subtitle && <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.2rem; line-height:1.4; color:var(--ink-500); margin:0 0 16px;">{featured.subtitle}</p>}
            <p style="font-family:'Inter Tight',sans-serif; font-size:15px; line-height:1.6; color:var(--ink-500); margin:0; max-width:36rem;">{featured.short_desc}</p>
          </div>
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px;">
            <div style="background:var(--sand-100); border:1px solid var(--rule); border-radius:10px; padding:14px;">
              <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">Lessons</p>
              <p class="font-display" style="font-size:1.85rem; font-weight:500; margin:0; line-height:1; color:var(--ink); letter-spacing:-0.02em;">{featured.total_lessons || 0}</p>
            </div>
            <div style="background:var(--sand-100); border:1px solid var(--rule); border-radius:10px; padding:14px;">
              <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">{featured.credit_hours ? 'Credit hrs' : 'Hours'}</p>
              <p class="font-display" style="font-size:1.85rem; font-weight:500; margin:0; line-height:1; color:var(--ink); letter-spacing:-0.02em;">{featured.credit_hours || featured.duration_hours || '-'}</p>
            </div>
            {featured.avg_rating && (
              <div style="background:var(--sand-100); border:1px solid var(--rule); border-radius:10px; padding:14px; grid-column:1/-1;">
                <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 8px;">Rating</p>
                <div style="display:flex; align-items:center; gap:8px;">
                  <span class="font-display" style="font-size:1.35rem; color:var(--rust); font-weight:500; letter-spacing:-0.02em;">{Number(featured.avg_rating).toFixed(1)}</span>
                  <div style="display:flex; gap:1px;">
                    {starRow(Number(featured.avg_rating)).map((on) => (<svg width="12" height="12" viewBox="0 0 24 24" fill={on ? 'var(--rust)' : 'none'} stroke={on ? 'var(--rust)' : 'var(--rule)'} stroke-width="2"><polygon points="12 2 15 9 22 9 17 14 19 22 12 18 5 22 7 14 2 9 9 9"/></svg>))}
                  </div>
                  <span style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink-500);">({featured.review_count})</span>
                </div>
              </div>
            )}
            <div style="grid-column:1/-1;">
              <span style="background:var(--ink); color:var(--sand-50); padding:11px 20px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13.5px; font-weight:600; display:inline-block;">Open the course &rarr;</span>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- RESULTS -->
  <section>
    <div style="max-width:1320px; margin:0 auto; padding:36px 28px 80px;">

      <div style="display:flex; align-items:center; justify-content:space-between; gap:14px; flex-wrap:wrap; margin-bottom:24px;">
        <p style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink); margin:0;"><strong>{totalFiltered}</strong> <span style="color:var(--ink-500);">course{totalFiltered === 1 ? '' : 's'}</span>{totalFiltered !== totalAll && <span style="color:var(--ink-500);"> of {totalAll}</span>}</p>
        <div style="display:flex; gap:14px; align-items:center; flex-wrap:wrap;">
        <div style="display:flex; gap:7px; align-items:center;">
          <label style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600;">Currency</label>
          <span id="era-currency" style="font-size:12px;"></span>
        </div>
        <form method="GET" style="display:flex; gap:8px; align-items:center;">
          {q && <input type="hidden" name="q" value={q} />}
          {catFilter && <input type="hidden" name="cat" value={catFilter} />}
          {levelFilter && <input type="hidden" name="level" value={levelFilter} />}
          {priceFilter && <input type="hidden" name="price" value={priceFilter} />}
          {durationFilter && <input type="hidden" name="duration" value={durationFilter} />}
          {ratingFilter && <input type="hidden" name="rating" value={ratingFilter} />}
          {schoolFilter && <input type="hidden" name="school" value={schoolFilter} />}
          <label style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600;">Sort</label>
          <select name="sort" onchange="this.form.submit()" style="background:var(--paper); border:1px solid var(--rule); border-radius:6px; padding:7px 11px; font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink); outline:none; cursor:pointer;">
            {SORT_OPTIONS.map((s) => (<option value={s.value} selected={sort === s.value}>{s.label}</option>))}
          </select>
        </form>
        </div>
      </div>

      {filtered.length === 0 ? (
        <div style="background:var(--paper); border:1px dashed var(--rule); border-radius:14px; padding:60px 24px; text-align:center;">
          <p class="font-display" style="font-size:1.45rem; font-weight:500; line-height:1.2; letter-spacing:-0.015em; margin:0 0 10px; color:var(--ink);">No courses match these filters.</p>
          <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1rem; color:var(--ink-500); margin:0 0 22px; max-width:38rem; margin-left:auto; margin-right:auto;">Try clearing some filters, or request a course on a topic we don't cover yet.</p>
          <div style="display:flex; gap:10px; flex-wrap:wrap; justify-content:center;">
            <a href="/aquintutor/courses" style="background:var(--ink); color:var(--sand-50); padding:12px 22px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Clear filters</a>
            <a href="mailto:hr@edurankai.in?subject=Course%20request" style="background:transparent; color:var(--ink); padding:12px 22px; border-radius:6px; border:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Request a course</a>
          </div>
        </div>
      ) : (
        <div style="display:grid; grid-template-columns:1fr; gap:16px;" class="courses-grid">
          {filtered.map((c) => (
            <a href={'/aquintutor/courses/' + c.slug} class="course-card" style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:0; overflow:hidden; text-decoration:none; color:var(--ink); display:flex; flex-direction:column; transition:transform 0.15s, box-shadow 0.15s;">
              <div style="height:5px; background:var(--rust);"></div>
              <div style="padding:22px 22px 18px; display:flex; flex-direction:column; gap:11px; flex:1;">
                <div style="display:flex; justify-content:space-between; gap:8px; font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.12em; color:var(--ink-500); text-transform:uppercase;">
                  <span>{c.course_code || (c.level || 'GEN')}</span>
                  <span style="color:var(--rust); font-weight:600;">{c.school_code || ''}</span>
                </div>
                <h3 class="font-display" style="font-size:1.18rem; font-weight:500; margin:0; line-height:1.22; letter-spacing:-0.015em; color:var(--ink);">{c.title}</h3>
                {c.subtitle && <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:0.98rem; line-height:1.38; color:var(--ink-500); margin:0;">{c.subtitle}</p>}
                {c.short_desc && <p style="font-family:'Inter Tight',sans-serif; font-size:13px; line-height:1.55; color:var(--ink-500); margin:0;">{c.short_desc.slice(0, 130)}{c.short_desc.length > 130 ? '...' : ''}</p>}

                <div style="display:flex; flex-wrap:wrap; gap:6px; margin-top:auto;">
                  {c.level && <span style="font-family:'Inter Tight',sans-serif; font-size:11px; padding:3px 8px; background:var(--sand-100); border:1px solid var(--rule); border-radius:999px; color:var(--ink-500); text-transform:capitalize;">{c.level}</span>}
                  {c.category && <span style="font-family:'Inter Tight',sans-serif; font-size:11px; padding:3px 8px; background:var(--sand-100); border:1px solid var(--rule); border-radius:999px; color:var(--ink-500);">{c.category}</span>}
                  {c.is_free && <span style="font-family:'Inter Tight',sans-serif; font-size:11px; padding:3px 8px; background:rgba(125,211,168,0.15); border:1px solid #7dd3a8; border-radius:999px; color:#3f8a64; font-weight:500;">Open</span>}
                </div>

                {c.avg_rating && (
                  <div style="display:flex; align-items:center; gap:8px; padding-top:10px; border-top:1px dashed var(--rule);">
                    <span style="font-family:'JetBrains Mono',monospace; font-size:12px; font-weight:600; color:var(--rust);">{Number(c.avg_rating).toFixed(1)}</span>
                    <div style="display:flex; gap:1px;">
                      {starRow(Number(c.avg_rating)).map((on) => (<svg width="11" height="11" viewBox="0 0 24 24" fill={on ? 'var(--rust)' : 'none'} stroke={on ? 'var(--rust)' : 'var(--rule)'} stroke-width="2"><polygon points="12 2 15 9 22 9 17 14 19 22 12 18 5 22 7 14 2 9 9 9"/></svg>))}
                    </div>
                    <span style="font-family:'Inter Tight',sans-serif; font-size:11px; color:var(--ink-500);">({c.review_count})</span>
                  </div>
                )}

                <div style="display:flex; justify-content:space-between; gap:8px; padding-top:12px; border-top:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink-500);">
                  <span>{c.total_lessons || 0} lessons</span>
                  {c.duration_hours > 0 && <span>{c.duration_hours}h</span>}
                  {c.enrolled_count > 0 && <span>{c.enrolled_count} learners</span>}
                </div>

                {(() => { const p = priceOf(c); return (
                  <div style="display:flex; align-items:baseline; justify-content:space-between; gap:8px; padding-top:10px;">
                    {p.paid
                      ? <span class="font-display era-price" data-chf={p.chf} style="font-size:1.15rem; font-weight:500; color:var(--ink); letter-spacing:-0.01em;">{'INR ' + p.inr}</span>
                      : <span class="font-display" style="font-size:1.05rem; font-weight:500; color:#3f8a64; letter-spacing:-0.01em;">Open</span>}
                    <span style="font-family:'Inter Tight',sans-serif; font-size:11px; color:var(--ink-500);">{p.paid ? 'lifetime · verifiable cert' : 'free to enrol'}</span>
                  </div>
                ); })()}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section style="background:var(--ink); color:var(--sand-50);">
    <div style="max-width:1200px; margin:0 auto; padding:64px 28px; display:grid; grid-template-columns:1fr; gap:32px; align-items:center;" class="cta-grid">
      <div>
        <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:#d97757; font-weight:600; letter-spacing:0.04em; margin:0 0 14px;">Open enrolment</p>
        <h2 class="font-display" style="font-size:clamp(1.75rem, 3vw, 2.5rem); line-height:1.1; letter-spacing:-0.02em; font-weight:500; margin:0 0 14px; color:var(--sand-50);">Pick a course. Begin.</h2>
        <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.05rem; line-height:1.55; color:rgba(251,250,244,0.78); margin:0 0 22px; max-width:34rem;">Frontier research programmes &mdash; Vedic sciences, ASI, quantum technology, advanced computing. Admission by application; faculty-led from day one.</p>
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
          <a href="/aquintutor/signup" style="background:#d97757; color:#1a0f08; padding:13px 22px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Apply for admission</a>
          <a href="/aquintutor/schools" style="background:transparent; color:var(--sand-50); padding:13px 22px; border-radius:6px; border:1px solid rgba(251,250,244,0.4); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Browse by school</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .course-card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(11,14,20,0.08); }
    @media (min-width: 640px) { .stat-row { grid-template-columns: repeat(3, 1fr) !important; } }
    @media (min-width: 900px) { .stat-row { grid-template-columns: repeat(6, 1fr) !important; } }
    @media (min-width: 700px) { .courses-grid { grid-template-columns: repeat(2, 1fr) !important; } .featured-card { grid-template-columns: 1.6fr 1fr !important; } }
    @media (min-width: 1100px) { .courses-grid { grid-template-columns: repeat(3, 1fr) !important; } }
  </style>
  <script src="/era-fx.js" defer></script>
</AquintutorLayout>
