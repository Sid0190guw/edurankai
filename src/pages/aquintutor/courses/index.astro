---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { SITE } from '@/lib/site';

const url = new URL(Astro.request.url);
const q = url.searchParams.get('q') || '';
const catFilter = url.searchParams.get('cat') || '';
const levelFilter = url.searchParams.get('level') || '';

let courses: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT id, title, slug, short_desc, description, category, level, duration_hours,
      thumbnail_url, instructor_name, instructor_title, language, is_free,
      learning_outcomes, prerequisites, enrolled_count, rating,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = training_courses.id) as total_lessons
    FROM training_courses
    WHERE is_published = true AND access_type IN ('public', 'both')
    ORDER BY enrolled_count DESC NULLS LAST, created_at DESC
  `);
  courses = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

let filtered = courses;
if (catFilter) filtered = filtered.filter((c) => c.category === catFilter);
if (levelFilter) filtered = filtered.filter((c) => c.level === levelFilter);
if (q) filtered = filtered.filter((c) =>
  (c.title || '').toLowerCase().includes(q.toLowerCase()) ||
  (c.short_desc || '').toLowerCase().includes(q.toLowerCase())
);

const categories = Array.from(new Set(courses.map((c) => c.category).filter(Boolean)));
const LEVELS = ['beginner', 'intermediate', 'advanced'];

const LEVEL_COLORS: Record<string, string> = {
  beginner: 'bg-[#dcfce7] text-[#166534] border-[#86efac]',
  intermediate: 'bg-[#fef3c7] text-[#92400e] border-[#fcd34d]',
  advanced: 'bg-[#fee2e2] text-[#991b1b] border-[#fca5a5]',
};

// SEO: ItemList of Course objects (Google Search "Course" rich results)
const courseSchemaList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: filtered.slice(0, 50).map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: SITE.url + '/aquintutor/courses/' + c.slug,
    name: c.title,
  })),
};

const pageDesc = filtered.length > 0
  ? 'Browse ' + courses.length + ' open online courses from AquinTutor, an institution of EduRankAI. Beginner to advanced. Free where possible. Certificates on completion.'
  : 'AquinTutor courses are coming. Sign up to be notified.';
---
<BaseLayout title="Courses - AquinTutor" description={pageDesc}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(courseSchemaList)} />

  <section class="px-[5vw] pt-12 md:pt-20 pb-8 max-w-6xl mx-auto">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-4">AquinTutor courses</p>
    <h1 class="font-display text-[clamp(2rem,5vw,3.5rem)] font-semibold text-ink leading-[1.05] tracking-tight mb-5">
      Learn at your <em class="italic text-burn font-medium">own pace.</em>
    </h1>
    <p class="text-[1rem] text-ink-soft leading-[1.85] max-w-2xl mb-2">
      Open online courses across technology, design, business, and the liberal arts. Free where possible. Certificate-issuing on completion.
    </p>
    <p class="text-[0.85rem] text-ink-soft/80">
      {courses.length} open course{courses.length === 1 ? '' : 's'} - new ones added monthly.
    </p>
  </section>

  <section class="px-[5vw] pb-20 max-w-6xl mx-auto">
    <form method="GET" class="bg-white border border-ink/10 rounded-2xl p-4 md:p-5 mb-10 flex flex-col md:flex-row gap-3 items-stretch md:items-center">
      <div class="flex-1 flex items-center gap-3 bg-cream-2 border border-ink/10 rounded-lg px-4 py-2.5">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-ink-soft/60 flex-shrink-0"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" name="q" value={q} placeholder="Search courses..." class="flex-1 bg-transparent border-0 outline-none text-[0.9rem] text-ink placeholder:text-ink-soft/60" />
      </div>
      <select name="cat" class="border border-ink/15 bg-white rounded-lg px-3 py-2.5 text-[0.85rem] text-ink-2 outline-none focus:border-burn">
        <option value="">All categories</option>
        {categories.map((c) => (
          <option value={c} selected={catFilter === c}>{c}</option>
        ))}
      </select>
      <select name="level" class="border border-ink/15 bg-white rounded-lg px-3 py-2.5 text-[0.85rem] text-ink-2 outline-none focus:border-burn">
        <option value="">All levels</option>
        {LEVELS.map((lv) => (
          <option value={lv} selected={levelFilter === lv}>{lv}</option>
        ))}
      </select>
      <button type="submit" class="btn-primary whitespace-nowrap">Filter</button>
      {(q || catFilter || levelFilter) && (
        <a href="/aquintutor/courses" class="btn-ghost whitespace-nowrap">Clear</a>
      )}
    </form>

    {filtered.length === 0 && (
      <div class="bg-cream-2 border border-ink/10 rounded-2xl p-10 md:p-16 text-center">
        <p class="font-display text-2xl font-medium text-ink mb-3">No courses match your filters yet.</p>
        <p class="text-[0.9rem] text-ink-soft mb-6 max-w-md mx-auto leading-relaxed">
          We add new courses monthly. Sign up to be notified, or contact us with a topic you want covered.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/portal/signup" class="btn-primary">Create free account</a>
          <a href="/contact" class="btn-ghost">Request a course</a>
        </div>
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {filtered.map((c) => {
        const levelClass = LEVEL_COLORS[c.level] || 'bg-cream-2 text-ink-soft border-ink/15';
        return (
          <a href={'/aquintutor/courses/' + c.slug} class="group bg-white border border-ink/10 rounded-2xl p-5 transition-all hover:-translate-y-1 hover:shadow-xl hover:border-burn-dim flex flex-col">
            <div class="flex gap-2 mb-3">
              <span class={'text-[0.65rem] font-bold uppercase tracking-wider px-2 py-0.5 rounded border ' + levelClass}>{c.level || 'beginner'}</span>
              {c.is_free && <span class="text-[0.65rem] font-semibold text-leaf bg-leaf-bg border border-leaf-border px-2 py-0.5 rounded">FREE</span>}
              {c.category && <span class="text-[0.65rem] font-semibold text-ink-soft bg-cream-2 border border-ink/10 px-2 py-0.5 rounded">{c.category}</span>}
            </div>
            <h2 class="font-display text-[1.1rem] font-semibold text-ink mb-2 leading-snug group-hover:text-burn transition-colors">{c.title}</h2>
            <p class="text-[0.85rem] text-ink-soft font-light leading-relaxed mb-4 flex-1">{c.short_desc || ''}</p>
            <div class="flex items-center justify-between text-[0.72rem] text-ink-soft/80 font-mono pt-3 border-t border-ink/8">
              <span>{c.total_lessons || 0} lessons</span>
              {c.duration_hours > 0 && <span>{c.duration_hours}h</span>}
              {c.enrolled_count > 0 && <span>{c.enrolled_count} enrolled</span>}
            </div>
          </a>
        );
      })}
    </div>

    <div class="mt-16 bg-cream-2 border border-ink/10 rounded-2xl p-8 md:p-12 text-center">
      <p class="eyebrow mb-3">About AquinTutor</p>
      <h3 class="font-display text-2xl md:text-3xl font-medium text-ink mb-4">A virtual institution built on AI tutoring.</h3>
      <p class="text-[0.95rem] text-ink-soft font-light leading-[1.85] max-w-2xl mx-auto mb-6">
        AquinTutor is the educational arm of EduRankAI. Every course has an AI tutor grounded in the lesson content. Every completion issues a verifiable digital certificate. Free for students from low-income backgrounds.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/portal/signup" class="btn-primary">Start learning</a>
        <a href="/about" class="btn-ghost">About EduRankAI</a>
      </div>
    </div>
  </section>
</BaseLayout>
