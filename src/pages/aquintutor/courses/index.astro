---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { SITE } from '@/lib/site';

const url = new URL(Astro.request.url);
const q = (url.searchParams.get('q') || '').trim();
const catFilter = url.searchParams.get('cat') || '';
const levelFilter = url.searchParams.get('level') || '';
const priceFilter = url.searchParams.get('price') || '';
const durationFilter = url.searchParams.get('duration') || '';
const sort = url.searchParams.get('sort') || 'popular';
const view = url.searchParams.get('view') === 'list' ? 'list' : 'grid';
const ratingFilter = url.searchParams.get('rating') || '';

let courses: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT c.id, c.title, c.slug, c.short_desc, c.description, c.category, c.level, c.duration_hours,
      c.thumbnail_url, c.instructor_name, c.language, c.is_free, c.enrolled_count,
      c.created_at,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as total_lessons,
      (SELECT ROUND(AVG(rating)::numeric, 1) FROM training_reviews WHERE course_id = c.id) as avg_rating,
      (SELECT COUNT(*)::int FROM training_reviews WHERE course_id = c.id) as review_count
    FROM training_courses c
    WHERE c.is_published = true AND c.access_type IN ('public', 'both')
  `);
  courses = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

// Filter
let filtered = courses;
if (catFilter) filtered = filtered.filter((c) => c.category === catFilter);
if (levelFilter) filtered = filtered.filter((c) => c.level === levelFilter);
if (priceFilter === 'free') filtered = filtered.filter((c) => c.is_free === true);
if (priceFilter === 'paid') filtered = filtered.filter((c) => c.is_free === false);
if (durationFilter === 'short') filtered = filtered.filter((c) => (c.duration_hours || 0) < 5);
if (durationFilter === 'medium') filtered = filtered.filter((c) => (c.duration_hours || 0) >= 5 && (c.duration_hours || 0) <= 20);
if (durationFilter === 'long') filtered = filtered.filter((c) => (c.duration_hours || 0) > 20);
if (ratingFilter) {
  const min = parseFloat(ratingFilter);
  if (Number.isFinite(min)) filtered = filtered.filter((c) => (c.avg_rating || 0) >= min);
}
if (q) {
  const ql = q.toLowerCase();
  filtered = filtered.filter((c) =>
    (c.title || '').toLowerCase().includes(ql) ||
    (c.short_desc || '').toLowerCase().includes(ql) ||
    (c.description || '').toLowerCase().includes(ql)
  );
}

// Sort
if (sort === 'newest') {
  filtered = filtered.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());
} else if (sort === 'rating') {
  filtered = filtered.sort((a, b) => (b.avg_rating || 0) - (a.avg_rating || 0));
} else if (sort === 'shortest') {
  filtered = filtered.sort((a, b) => (a.duration_hours || 0) - (b.duration_hours || 0));
} else if (sort === 'longest') {
  filtered = filtered.sort((a, b) => (b.duration_hours || 0) - (a.duration_hours || 0));
} else {
  // popular = enrolled_count desc
  filtered = filtered.sort((a, b) => (b.enrolled_count || 0) - (a.enrolled_count || 0));
}

const categories = Array.from(new Set(courses.map((c) => c.category).filter(Boolean)));
const LEVELS = ['beginner', 'intermediate', 'advanced'];
const SORT_OPTIONS = [
  { value: 'popular', label: 'Most popular' },
  { value: 'newest', label: 'Newest' },
  { value: 'rating', label: 'Highest rated' },
  { value: 'shortest', label: 'Shortest first' },
  { value: 'longest', label: 'Longest first' },
];

const LEVEL_COLORS: Record<string, string> = {
  beginner: 'bg-[#dcfce7] text-[#166534] border-[#86efac]',
  intermediate: 'bg-[#fef3c7] text-[#92400e] border-[#fcd34d]',
  advanced: 'bg-[#fee2e2] text-[#991b1b] border-[#fca5a5]',
};

const totalAllPublished = courses.length;
const totalFiltered = filtered.length;

const courseSchemaList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: filtered.slice(0, 50).map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: SITE.url + '/aquintutor/courses/' + c.slug,
    name: c.title,
  })),
};

const pageDesc = 'Browse ' + totalAllPublished + ' open online courses from AquinTutor by EduRankAI. Free where possible. Verifiable certificates. Faceted search by level, duration, price, rating.';

// Build a query-string helper for filter links
function qs(overrides: Record<string, string | null>) {
  const params = new URLSearchParams();
  const map: Record<string, string> = { q, cat: catFilter, level: levelFilter, price: priceFilter, duration: durationFilter, rating: ratingFilter, sort, view };
  for (const [k, v] of Object.entries(map)) {
    const ov = overrides[k];
    const val = ov === undefined ? v : (ov === null ? '' : ov);
    if (val) params.set(k, val);
  }
  const s = params.toString();
  return '/aquintutor/courses' + (s ? '?' + s : '');
}

function starRow(n: number) {
  const filled = Math.round(n);
  return Array.from({ length: 5 }, (_, i) => i < filled);
}
---
<BaseLayout title="Courses - AquinTutor" description={pageDesc}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(courseSchemaList)} />

  <style>
    .filter-chip {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 6px 12px;
      border-radius: 100px;
      font-size: 12.5px;
      font-weight: 600;
      border: 1px solid;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.15s;
      white-space: nowrap;
    }
    .filter-chip.active { background: #FF4F00; color: #fff; border-color: #FF4F00; }
    .filter-chip:not(.active) { background: #fff; color: #6b7280; border-color: rgba(0,0,0,0.12); }
    .filter-chip:not(.active):hover { border-color: #FF4F00; color: #FF4F00; }
    .facet-section { padding: 14px 0; border-bottom: 1px solid rgba(0,0,0,0.06); }
    .facet-section:last-child { border-bottom: none; }
    .facet-label { font-size: 10.5px; font-family: 'Geist Mono', monospace; letter-spacing: 0.12em; font-weight: 700; color: #FF4F00; margin-bottom: 10px; text-transform: uppercase; display: block; }

    .card-row .course-card { display: flex; flex-direction: row; align-items: stretch; gap: 16px; padding: 16px; }
    .card-row .course-thumb { flex-shrink: 0; width: 160px; aspect-ratio: 16/9; border-radius: 8px; }
    @media (max-width: 640px) { .card-row .course-card { flex-direction: column; } .card-row .course-thumb { width: 100%; } }
  </style>

  <!-- HERO -->
  <section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-6xl mx-auto">
    <a href="/aquintutor" class="inline-flex items-center gap-2 text-[0.78rem] font-mono text-ink-soft hover:text-burn transition-colors mb-4">
      &larr; AquinTutor
    </a>
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-3">Course catalogue</p>
    <h1 class="font-display text-[clamp(2rem,5vw,3rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-3">
      Find a course. <em class="italic text-burn font-medium">Start tonight.</em>
    </h1>
    <p class="text-[0.98rem] text-ink-soft leading-[1.7] max-w-2xl">
      {totalAllPublished} open courses. Free where possible. Self-paced. Every completion issues a verifiable certificate.
    </p>
  </section>

  <!-- SEARCH BAR -->
  <section class="px-[5vw] max-w-6xl mx-auto mb-6">
    <form method="GET" class="flex flex-col md:flex-row gap-2 items-stretch md:items-center">
      <input type="hidden" name="view" value={view} />
      <input type="hidden" name="sort" value={sort} />
      <div class="flex-1 flex items-center gap-3 bg-white border border-ink/10 rounded-lg px-4 py-3 focus-within:border-burn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-ink-soft/60 flex-shrink-0"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" name="q" value={q} placeholder="Search courses by title, topic, or skill..." class="flex-1 bg-transparent border-0 outline-none text-[0.95rem] text-ink placeholder:text-ink-soft/60" autocomplete="off" />
      </div>
      <button type="submit" class="btn-primary whitespace-nowrap">Search</button>
      {q && <a href={qs({ q: null })} class="btn-ghost whitespace-nowrap">Clear search</a>}
    </form>
  </section>

  <!-- MAIN GRID: facets on left, results on right -->
  <section class="px-[5vw] pb-20 max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">

      <!-- FACETS COLUMN -->
      <aside class="lg:col-span-1">
        <div class="bg-white border border-ink/10 rounded-2xl p-5 lg:sticky lg:top-4">
          <div class="flex items-center justify-between mb-4">
            <p class="font-display text-[1rem] font-semibold text-ink">Filters</p>
            {(catFilter || levelFilter || priceFilter || durationFilter || ratingFilter) && (
              <a href={qs({ cat: null, level: null, price: null, duration: null, rating: null })} class="text-[0.78rem] text-burn font-semibold hover:underline">Clear all</a>
            )}
          </div>

          <div class="facet-section">
            <span class="facet-label">Price</span>
            <div class="flex flex-wrap gap-2">
              <a href={qs({ price: null })} class={'filter-chip ' + (!priceFilter ? 'active' : '')}>Any</a>
              <a href={qs({ price: 'free' })} class={'filter-chip ' + (priceFilter === 'free' ? 'active' : '')}>Free</a>
              <a href={qs({ price: 'paid' })} class={'filter-chip ' + (priceFilter === 'paid' ? 'active' : '')}>Paid</a>
            </div>
          </div>

          <div class="facet-section">
            <span class="facet-label">Level</span>
            <div class="flex flex-wrap gap-2">
              <a href={qs({ level: null })} class={'filter-chip ' + (!levelFilter ? 'active' : '')}>Any</a>
              {LEVELS.map((lv) => (
                <a href={qs({ level: lv })} class={'filter-chip ' + (levelFilter === lv ? 'active' : '')}>{lv}</a>
              ))}
            </div>
          </div>

          <div class="facet-section">
            <span class="facet-label">Duration</span>
            <div class="flex flex-wrap gap-2">
              <a href={qs({ duration: null })} class={'filter-chip ' + (!durationFilter ? 'active' : '')}>Any</a>
              <a href={qs({ duration: 'short' })} class={'filter-chip ' + (durationFilter === 'short' ? 'active' : '')}>&lt;5h</a>
              <a href={qs({ duration: 'medium' })} class={'filter-chip ' + (durationFilter === 'medium' ? 'active' : '')}>5-20h</a>
              <a href={qs({ duration: 'long' })} class={'filter-chip ' + (durationFilter === 'long' ? 'active' : '')}>20h+</a>
            </div>
          </div>

          {categories.length > 0 && (
            <div class="facet-section">
              <span class="facet-label">Category</span>
              <div class="flex flex-wrap gap-2">
                <a href={qs({ cat: null })} class={'filter-chip ' + (!catFilter ? 'active' : '')}>All</a>
                {categories.map((c) => (
                  <a href={qs({ cat: c })} class={'filter-chip ' + (catFilter === c ? 'active' : '')}>{c}</a>
                ))}
              </div>
            </div>
          )}

          <div class="facet-section">
            <span class="facet-label">Min rating</span>
            <div class="flex flex-wrap gap-2">
              <a href={qs({ rating: null })} class={'filter-chip ' + (!ratingFilter ? 'active' : '')}>Any</a>
              <a href={qs({ rating: '4.5' })} class={'filter-chip ' + (ratingFilter === '4.5' ? 'active' : '')}>4.5+</a>
              <a href={qs({ rating: '4' })} class={'filter-chip ' + (ratingFilter === '4' ? 'active' : '')}>4+</a>
              <a href={qs({ rating: '3' })} class={'filter-chip ' + (ratingFilter === '3' ? 'active' : '')}>3+</a>
            </div>
          </div>
        </div>
      </aside>

      <!-- RESULTS COLUMN -->
      <div class="lg:col-span-3">
        <!-- Sort + view toggle bar -->
        <div class="bg-white border border-ink/10 rounded-xl p-3 md:p-4 mb-4 flex flex-wrap items-center justify-between gap-3">
          <p class="text-[0.85rem] text-ink-soft">
            <strong class="text-ink font-semibold">{totalFiltered}</strong> course{totalFiltered === 1 ? '' : 's'}
            {totalFiltered !== totalAllPublished && <span class="text-ink-soft/70"> of {totalAllPublished}</span>}
          </p>
          <div class="flex items-center gap-2 flex-wrap">
            <label class="text-[0.78rem] text-ink-soft font-mono">Sort:</label>
            <form method="GET" class="inline-flex">
              {q && <input type="hidden" name="q" value={q} />}
              {catFilter && <input type="hidden" name="cat" value={catFilter} />}
              {levelFilter && <input type="hidden" name="level" value={levelFilter} />}
              {priceFilter && <input type="hidden" name="price" value={priceFilter} />}
              {durationFilter && <input type="hidden" name="duration" value={durationFilter} />}
              {ratingFilter && <input type="hidden" name="rating" value={ratingFilter} />}
              <input type="hidden" name="view" value={view} />
              <select name="sort" onchange="this.form.submit()" class="border border-ink/15 bg-white rounded-md px-2.5 py-1.5 text-[0.82rem] text-ink-2 outline-none focus:border-burn">
                {SORT_OPTIONS.map((s) => (
                  <option value={s.value} selected={sort === s.value}>{s.label}</option>
                ))}
              </select>
            </form>
            <span class="text-ink-soft/30 mx-1">|</span>
            <a href={qs({ view: 'grid' })} title="Grid view" class={'p-1.5 rounded ' + (view === 'grid' ? 'bg-burn text-white' : 'text-ink-soft hover:text-burn')} aria-label="Grid view">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            </a>
            <a href={qs({ view: 'list' })} title="List view" class={'p-1.5 rounded ' + (view === 'list' ? 'bg-burn text-white' : 'text-ink-soft hover:text-burn')} aria-label="List view">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><circle cx="4" cy="6" r="1"/><circle cx="4" cy="12" r="1"/><circle cx="4" cy="18" r="1"/></svg>
            </a>
          </div>
        </div>

        {filtered.length === 0 && (
          <div class="bg-cream-2 border border-ink/10 rounded-2xl p-10 md:p-16 text-center">
            <p class="font-display text-xl font-medium text-ink mb-3">No courses match these filters.</p>
            <p class="text-[0.9rem] text-ink-soft mb-6 max-w-md mx-auto leading-relaxed">
              Try clearing some filters, or request a course on a topic we don't cover yet.
            </p>
            <div class="flex flex-wrap gap-3 justify-center">
              <a href="/aquintutor/courses" class="btn-primary">Clear filters</a>
              <a href="/contact" class="btn-ghost">Request a course</a>
            </div>
          </div>
        )}

        <div class={view === 'list' ? 'card-row space-y-3' : 'grid grid-cols-1 md:grid-cols-2 gap-4'}>
          {filtered.map((c) => {
            const levelClass = LEVEL_COLORS[c.level] || 'bg-cream-2 text-ink-soft border-ink/15';
            return (
              <a href={'/aquintutor/courses/' + c.slug} class="course-card group bg-white border border-ink/10 rounded-2xl p-5 transition-all hover:-translate-y-1 hover:shadow-xl hover:border-burn-dim flex flex-col">
                {view === 'list' && (
                  <div class="course-thumb bg-cream-2 border border-ink/10 flex items-center justify-center text-ink-soft/40">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                  </div>
                )}
                <div class="flex-1 flex flex-col">
                  <div class="flex gap-2 mb-2 flex-wrap">
                    <span class={'text-[0.62rem] font-bold uppercase tracking-wider px-2 py-0.5 rounded border ' + levelClass}>{c.level || 'beginner'}</span>
                    {c.is_free && <span class="text-[0.62rem] font-semibold text-leaf bg-leaf-bg border border-leaf-border px-2 py-0.5 rounded">FREE</span>}
                    {c.category && <span class="text-[0.62rem] font-semibold text-ink-soft bg-cream-2 border border-ink/10 px-2 py-0.5 rounded">{c.category}</span>}
                  </div>
                  <h2 class="font-display text-[1.05rem] font-semibold text-ink mb-1.5 leading-snug group-hover:text-burn transition-colors">{c.title}</h2>
                  <p class="text-[0.82rem] text-ink-soft font-light leading-relaxed mb-3 flex-1">{c.short_desc || ''}</p>
                  {c.avg_rating && (
                    <div class="flex items-center gap-2 mb-2">
                      <span class="text-[0.82rem] font-bold text-burn">{Number(c.avg_rating).toFixed(1)}</span>
                      <div class="flex gap-0.5">
                        {starRow(Number(c.avg_rating)).map((on) => (
                          <svg width="11" height="11" viewBox="0 0 24 24" fill={on ? '#FBBF24' : 'none'} stroke={on ? '#FBBF24' : '#cbd5e1'} stroke-width="2"><polygon points="12 2 15 9 22 9 17 14 19 22 12 18 5 22 7 14 2 9 9 9"/></svg>
                        ))}
                      </div>
                      <span class="text-[0.72rem] text-ink-soft">({c.review_count})</span>
                    </div>
                  )}
                  <div class="flex items-center justify-between text-[0.7rem] text-ink-soft/80 font-mono pt-2 border-t border-ink/8">
                    <span>{c.total_lessons || 0} lessons</span>
                    {c.duration_hours > 0 && <span>{c.duration_hours}h</span>}
                    {c.enrolled_count > 0 && <span>{c.enrolled_count} learners</span>}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
