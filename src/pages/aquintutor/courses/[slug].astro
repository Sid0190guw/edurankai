---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { SITE } from '@/lib/site';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/aquintutor/courses');

let course: any = null;
let lessons: any[] = [];
let modules: any[] = [];
let reviews: any[] = [];
let reviewStats: any = null;
let relatedCourses: any[] = [];

try {
  const r = await db.execute(sql`SELECT * FROM training_courses WHERE slug = ${slug} AND is_published = true AND access_type IN ('public', 'both') LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  course = rows[0] || null;
} catch (_) {}
if (!course) return Astro.redirect('/aquintutor/courses');

try {
  const r = await db.execute(sql`SELECT id, title, type, duration_mins, is_preview, sort_order, module_id FROM training_lessons WHERE course_id = ${course.id} ORDER BY sort_order ASC, created_at ASC`);
  lessons = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT id, title, description, sort_order FROM training_modules WHERE course_id = ${course.id} ORDER BY sort_order ASC`);
  modules = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}
try {
  const r = await db.execute(sql`SELECT r.id, r.rating, r.review, r.created_at, u.name as reviewer_name FROM training_reviews r JOIN users u ON r.user_id = u.id WHERE r.course_id = ${course.id} ORDER BY r.created_at DESC LIMIT 6`);
  reviews = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}
try {
  const r = await db.execute(sql`
    SELECT COUNT(*)::int as total, ROUND(AVG(rating)::numeric, 1) as avg_rating,
      COUNT(*) FILTER (WHERE rating = 5)::int as r5,
      COUNT(*) FILTER (WHERE rating = 4)::int as r4,
      COUNT(*) FILTER (WHERE rating = 3)::int as r3,
      COUNT(*) FILTER (WHERE rating = 2)::int as r2,
      COUNT(*) FILTER (WHERE rating = 1)::int as r1
    FROM training_reviews WHERE course_id = ${course.id}
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  reviewStats = rows[0] || null;
} catch (_) {}
try {
  const r = await db.execute(sql`
    SELECT slug, title, short_desc, level, duration_hours FROM training_courses
    WHERE is_published = true AND access_type IN ('public', 'both') AND id != ${course.id}
      AND (category = ${course.category} OR level = ${course.level})
    ORDER BY enrolled_count DESC NULLS LAST LIMIT 3
  `);
  relatedCourses = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const lessonsByModule: Record<string, any[]> = {};
const unmoduledLessons: any[] = [];
for (const l of lessons) {
  if (l.module_id) { (lessonsByModule[l.module_id] = lessonsByModule[l.module_id] || []).push(l); }
  else { unmoduledLessons.push(l); }
}

const totalDurationMin = lessons.reduce((sum, l) => sum + (l.duration_mins || 0), 0);
const totalHours = totalDurationMin > 0 ? (totalDurationMin / 60).toFixed(1) : (course.duration_hours || 0);
const avgRating = reviewStats?.avg_rating ? Number(reviewStats.avg_rating).toFixed(1) : null;
const totalReviews = reviewStats?.total || 0;

const courseSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: course.title,
  description: course.description || course.short_desc || '',
  provider: { '@type': 'Organization', name: 'AquinTutor (EduRankAI)', sameAs: SITE.url },
  educationalLevel: course.level || 'beginner',
  inLanguage: course.language || 'en',
  ...(course.is_free && { offers: { '@type': 'Offer', price: '0', priceCurrency: 'INR', category: 'Free' } }),
  ...(avgRating && { aggregateRating: { '@type': 'AggregateRating', ratingValue: avgRating, reviewCount: totalReviews } }),
  hasCourseInstance: { '@type': 'CourseInstance', courseMode: 'online', courseWorkload: 'PT' + Math.ceil(Number(totalHours) || 1) + 'H' },
};

const LEVEL_LABELS: Record<string, string> = { beginner: 'Beginner', intermediate: 'Intermediate', advanced: 'Advanced' };
const learningOutcomes: string[] = Array.isArray(course.learning_outcomes) ? course.learning_outcomes : [];
const prerequisites: string[] = Array.isArray(course.prerequisites) ? course.prerequisites : [];
const tags: string[] = Array.isArray(course.tags) ? course.tags : [];

const pageTitle = course.title;
const pageDesc = (course.short_desc || course.description || '').substring(0, 160);
const enrolUrl = '/portal/login?next=' + encodeURIComponent('/portal/courses/' + slug);

function timeAgo(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const days = Math.floor(diff / 86400000);
  if (days < 1) return 'today';
  if (days < 7) return days + 'd ago';
  if (days < 30) return Math.floor(days / 7) + 'w ago';
  if (days < 365) return Math.floor(days / 30) + 'mo ago';
  return Math.floor(days / 365) + 'y ago';
}
function starRow(n: number) {
  const filled = Math.round(n);
  return Array.from({ length: 5 }, (_, i) => i < filled);
}
---
<AquintutorLayout title={pageTitle} description={pageDesc}>
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(courseSchema)} />

  <style>
    .tab-btn { padding:14px 4px; font-size:14px; font-weight:500; color:var(--ac-ink-muted); border-bottom:2px solid transparent; cursor:pointer; background:none; border-left:0; border-right:0; border-top:0; transition:color 0.15s, border-color 0.15s; font-family:'Inter',sans-serif; }
    .tab-btn.active { color:var(--ac-amber); border-bottom-color:var(--ac-amber); }
    .tab-btn:hover { color:var(--ac-amber); }
    .tab-panel { display:none; }
    .tab-panel.active { display:block; }
    .check { width:18px; height:18px; color:var(--ac-leaf); flex-shrink:0; margin-top:2px; }
    .skill { display:inline-block; background:var(--ac-amber-bg); color:var(--ac-amber); border:1px solid rgba(184,81,46,0.25); padding:5px 12px; border-radius:100px; font-size:12.5px; font-weight:500; margin:3px; }
    .enrol { background:var(--ac-surface); border:1px solid var(--ac-border); border-radius:14px; padding:24px; box-shadow:var(--ac-shadow); }
    .enrol-incl { display:flex; align-items:center; gap:10px; font-size:13.5px; color:var(--ac-ink-soft); padding:6px 0; }
    @media (min-width:1024px) { .enrol-sticky { position:sticky; top:90px; } }
  </style>

  <!-- HERO -->
  <section class="ac-container" style="padding:50px 5vw 32px; border-bottom:1px solid var(--ac-rule);">
    <a href="/aquintutor/courses" style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--ac-ink-muted); text-decoration:none; margin-bottom:18px; display:inline-block; letter-spacing:0.08em;">&larr; AquinTutor courses</a>
    <div style="display:grid; grid-template-columns:1fr; gap:32px;" class="hero-grid">
      <div>
        <div class="ac-flex ac-wrap ac-gap-2 ac-mb-4">
          <span class="ac-pill ac-pill-amber">{LEVEL_LABELS[course.level] || 'Beginner'}</span>
          {course.is_free && <span class="ac-pill ac-pill-leaf">Free</span>}
          {course.category && <span class="ac-pill">{course.category}</span>}
          {course.language && <span class="ac-pill">{course.language}</span>}
        </div>
        <h1 class="ac-display ac-mb-4">{course.title}</h1>
        {course.short_desc && (
          <p class="ac-lead ac-mb-6" style="max-width:640px;">{course.short_desc}</p>
        )}

        {avgRating && (
          <div style="display:flex; align-items:center; gap:14px; margin-bottom:18px; flex-wrap:wrap;">
            <div style="display:flex; align-items:center; gap:8px;">
              <span style="font-size:1.4rem; font-weight:500; color:var(--ac-amber); font-family:'Fraunces',serif;">{avgRating}</span>
              <div style="display:flex; gap:2px;">
                {starRow(Number(avgRating)).map((on) => (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill={on ? '#B8512E' : 'none'} stroke={on ? '#B8512E' : 'rgba(26,22,18,0.2)'} stroke-width="2"><polygon points="12 2 15 9 22 9 17 14 19 22 12 18 5 22 7 14 2 9 9 9"/></svg>
                ))}
              </div>
            </div>
            <span style="font-size:13px; color:var(--ac-ink-soft);">({totalReviews} review{totalReviews === 1 ? '' : 's'})</span>
            {course.enrolled_count > 0 && <span style="font-size:13px; color:var(--ac-ink-soft);">&middot; {course.enrolled_count} enrolled</span>}
          </div>
        )}

        {course.instructor_name && (
          <div style="display:flex; align-items:center; gap:12px;">
            <div style="width:42px; height:42px; border-radius:50%; background:var(--ac-amber-bg); border:1px solid rgba(184,81,46,0.3); display:flex; align-items:center; justify-content:center; font-family:'Fraunces',serif; font-weight:500; color:var(--ac-amber); font-size:18px;">
              {(course.instructor_name as string).substring(0, 1).toUpperCase()}
            </div>
            <div>
              <p style="font-family:'Geist Mono',monospace; font-size:10px; color:var(--ac-ink-muted); text-transform:uppercase; letter-spacing:0.12em;">Taught by</p>
              <p style="font-size:14px; font-weight:500; color:var(--ac-ink);">{course.instructor_name}</p>
            </div>
          </div>
        )}
      </div>

      <div>
        <div class="enrol enrol-sticky">
          <div style="aspect-ratio:16/9; background:var(--ac-paper-deep); border-radius:8px; margin-bottom:18px; display:flex; align-items:center; justify-content:center; color:var(--ac-ink-muted); border:1px solid var(--ac-border);">
            <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          </div>
          <p style="font-family:'Fraunces',serif; font-size:2rem; font-weight:500; color:var(--ac-ink); line-height:1; margin-bottom:4px;">{course.is_free ? 'Free' : 'Premium'}</p>
          <p style="font-size:12.5px; color:var(--ac-ink-soft); margin-bottom:18px;">{course.is_free ? 'No payment required to enrol' : 'Paid course - one-time fee'}</p>
          <a href={enrolUrl} class="ac-btn" style="width:100%; justify-content:center; margin-bottom:8px;">Enrol &amp; start learning</a>
          <a href="/portal/signup" class="ac-btn ac-btn-ghost" style="width:100%; justify-content:center;">Create free account</a>

          <div style="margin-top:20px; padding-top:18px; border-top:1px solid var(--ac-rule);">
            <div class="enrol-incl"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4A6B2E" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><span>{lessons.length} lessons, {totalHours}h total</span></div>
            <div class="enrol-incl"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4A6B2E" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><span>AI tutor (course-context-aware)</span></div>
            <div class="enrol-incl"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4A6B2E" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><span>Verifiable certificate on completion</span></div>
            <div class="enrol-incl"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4A6B2E" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><span>Lifetime access, learn at your pace</span></div>
            <div class="enrol-incl"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4A6B2E" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><span>Mobile + desktop</span></div>
          </div>
          <p style="margin-top:16px; text-align:center; font-size:11.5px; color:var(--ac-ink-muted);">Need a human tutor? <a href="/contact" style="color:var(--ac-amber); text-decoration:underline;">Request one</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- TAB NAV -->
  <section style="border-bottom:1px solid var(--ac-rule); background:var(--ac-surface); position:sticky; top:80px; z-index:30;">
    <div class="ac-container" style="display:flex; gap:28px; overflow-x:auto; padding:0 5vw;">
      <button type="button" class="tab-btn active" data-tab="overview">Overview</button>
      <button type="button" class="tab-btn" data-tab="outcomes">What you'll learn</button>
      <button type="button" class="tab-btn" data-tab="syllabus">Syllabus</button>
      <button type="button" class="tab-btn" data-tab="instructor">Instructor</button>
      <button type="button" class="tab-btn" data-tab="reviews">Reviews</button>
      <button type="button" class="tab-btn" data-tab="faq">FAQ</button>
    </div>
  </section>

  <!-- TAB PANELS -->
  <section class="ac-container" style="padding:48px 5vw 80px;">
    <div style="display:grid; grid-template-columns:1fr; gap:32px;" class="content-grid">
      <div>

        <div class="tab-panel active" id="panel-overview">
          {course.description && (
            <div class="ac-mb-8">
              <h2 class="ac-display ac-mb-4" style="font-size:1.6rem;">About this course</h2>
              <div style="font-size:15px; color:var(--ac-ink-soft); line-height:1.85; white-space:pre-line;">{course.description}</div>
            </div>
          )}
          {tags.length > 0 && (
            <div class="ac-mb-8">
              <h3 style="font-family:'Fraunces',serif; font-size:1.15rem; font-weight:500; color:var(--ac-ink); margin-bottom:12px;">Skills you'll gain</h3>
              <div>{tags.map((t: string) => <span class="skill">{t}</span>)}</div>
            </div>
          )}
          {prerequisites.length > 0 && (
            <div class="ac-mb-8">
              <h3 style="font-family:'Fraunces',serif; font-size:1.15rem; font-weight:500; color:var(--ac-ink); margin-bottom:12px;">Prerequisites</h3>
              <ul style="list-style:none; padding:0; margin:0;">
                {prerequisites.map((p: string) => (
                  <li style="display:flex; gap:12px; font-size:14.5px; color:var(--ac-ink-soft); line-height:1.7; padding:6px 0;">
                    <span style="color:var(--ac-ink-muted); margin-top:2px;">&middot;</span>
                    <span>{p}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>

        <div class="tab-panel" id="panel-outcomes">
          <h2 class="ac-display ac-mb-6" style="font-size:1.6rem;">What you'll learn</h2>
          {learningOutcomes.length === 0 ? (
            <p style="font-size:14.5px; color:var(--ac-ink-soft); font-style:italic;">Learning outcomes will be added soon.</p>
          ) : (
            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:16px;">
              {learningOutcomes.map((o: string) => (
                <div style="display:flex; gap:12px; padding:18px; background:var(--ac-paper-deep); border:1px solid var(--ac-border); border-radius:10px;">
                  <svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  <p style="font-size:14px; color:var(--ac-ink); line-height:1.65;">{o}</p>
                </div>
              ))}
            </div>
          )}
        </div>

        <div class="tab-panel" id="panel-syllabus">
          <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:20px;">
            <h2 class="ac-display" style="font-size:1.6rem;">Syllabus</h2>
            <span style="font-family:'Geist Mono',monospace; font-size:12px; color:var(--ac-ink-muted);">{lessons.length} lessons &middot; {totalHours}h</span>
          </div>
          <div style="display:flex; flex-direction:column; gap:10px;">
            {modules.map((m, mi) => {
              const ml = lessonsByModule[m.id] || [];
              return (
                <details open={mi === 0} class="ac-card" style="padding:0;">
                  <summary style="cursor:pointer; list-style:none; padding:18px 22px; display:flex; align-items:center; justify-content:space-between; gap:14px; font-family:'Fraunces',serif; font-size:1.05rem; font-weight:500; color:var(--ac-ink);">
                    <span><span style="color:var(--ac-amber); font-family:'Geist Mono',monospace; font-size:11px; margin-right:12px;">{String(mi + 1).padStart(2, '0')}</span>{m.title}</span>
                    <span style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--ac-ink-muted);">{ml.length} lessons</span>
                  </summary>
                  {m.description && <p style="padding:0 22px; font-size:13px; color:var(--ac-ink-soft); line-height:1.6; margin:-4px 0 8px;">{m.description}</p>}
                  <ul style="list-style:none; padding:0 22px 18px; margin:0;">
                    {ml.map((l: any, li: number) => (
                      <li style="display:flex; align-items:center; gap:14px; font-size:13.5px; color:var(--ac-ink); padding:10px 0; border-top:1px solid var(--ac-rule);">
                        <span style="color:var(--ac-ink-muted); font-family:'Geist Mono',monospace; font-size:11px; width:28px;">{String(li + 1).padStart(2, '0')}</span>
                        <span style="flex:1;">{l.title}</span>
                        {l.is_preview && <span class="ac-pill ac-pill-amber" style="font-size:9px;">Free preview</span>}
                        {l.duration_mins > 0 && <span style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--ac-ink-muted);">{l.duration_mins}m</span>}
                      </li>
                    ))}
                  </ul>
                </details>
              );
            })}
            {unmoduledLessons.length > 0 && (
              <details open={modules.length === 0} class="ac-card" style="padding:0;">
                <summary style="cursor:pointer; list-style:none; padding:18px 22px; display:flex; align-items:center; justify-content:space-between; gap:14px; font-family:'Fraunces',serif; font-size:1.05rem; font-weight:500; color:var(--ac-ink);">
                  <span>Lessons</span>
                  <span style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--ac-ink-muted);">{unmoduledLessons.length} lessons</span>
                </summary>
                <ul style="list-style:none; padding:0 22px 18px; margin:0;">
                  {unmoduledLessons.map((l: any, li: number) => (
                    <li style="display:flex; align-items:center; gap:14px; font-size:13.5px; color:var(--ac-ink); padding:10px 0; border-top:1px solid var(--ac-rule);">
                      <span style="color:var(--ac-ink-muted); font-family:'Geist Mono',monospace; font-size:11px; width:28px;">{String(li + 1).padStart(2, '0')}</span>
                      <span style="flex:1;">{l.title}</span>
                      {l.is_preview && <span class="ac-pill ac-pill-amber" style="font-size:9px;">Free preview</span>}
                      {l.duration_mins > 0 && <span style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--ac-ink-muted);">{l.duration_mins}m</span>}
                    </li>
                  ))}
                </ul>
              </details>
            )}
            {lessons.length === 0 && (
              <p style="font-size:14.5px; color:var(--ac-ink-soft); font-style:italic; text-align:center; padding:40px 0;">Lessons coming soon.</p>
            )}
          </div>
        </div>

        <div class="tab-panel" id="panel-instructor">
          <h2 class="ac-display ac-mb-6" style="font-size:1.6rem;">About the instructor</h2>
          {course.instructor_name ? (
            <div class="ac-card">
              <div style="display:flex; align-items:center; gap:16px; margin-bottom:14px;">
                <div style="width:64px; height:64px; border-radius:50%; background:var(--ac-amber-bg); border:1px solid rgba(184,81,46,0.3); display:flex; align-items:center; justify-content:center; font-family:'Fraunces',serif; font-size:1.6rem; font-weight:500; color:var(--ac-amber);">
                  {(course.instructor_name as string).substring(0, 1).toUpperCase()}
                </div>
                <div>
                  <p style="font-family:'Fraunces',serif; font-size:1.2rem; font-weight:500; color:var(--ac-ink);">{course.instructor_name}</p>
                  {course.instructor_title && <p style="font-size:13.5px; color:var(--ac-ink-soft); margin-top:3px;">{course.instructor_title}</p>}
                </div>
              </div>
              <p style="font-size:14.5px; color:var(--ac-ink-soft); line-height:1.75;">Senior instructor at AquinTutor with deep practice in {course.category || 'this field'}. Each lesson is reviewed by domain experts before publication.</p>
            </div>
          ) : (
            <p style="font-size:14.5px; color:var(--ac-ink-soft); font-style:italic;">Instructor profile will be added soon.</p>
          )}
        </div>

        <div class="tab-panel" id="panel-reviews">
          <h2 class="ac-display ac-mb-6" style="font-size:1.6rem;">Reviews</h2>
          {totalReviews === 0 ? (
            <div class="ac-card" style="text-align:center; padding:48px 20px;">
              <p style="font-size:15px; color:var(--ac-ink-soft); margin-bottom:6px;">No reviews yet.</p>
              <p style="font-size:13px; color:var(--ac-ink-muted);">Enrolled students can rate the course on completion.</p>
            </div>
          ) : (
            <div class="ac-card" style="padding:24px;">
              <div style="display:grid; grid-template-columns:1fr 2fr; gap:24px;">
                <div style="text-align:center;">
                  <p style="font-family:'Fraunces',serif; font-size:3rem; font-weight:500; color:var(--ac-amber); line-height:1;">{avgRating}</p>
                  <div style="display:flex; justify-content:center; gap:2px; margin:8px 0;">
                    {starRow(Number(avgRating)).map((on) => (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill={on ? '#B8512E' : 'none'} stroke={on ? '#B8512E' : '#cbd5e1'} stroke-width="2"><polygon points="12 2 15 9 22 9 17 14 19 22 12 18 5 22 7 14 2 9 9 9"/></svg>
                    ))}
                  </div>
                  <p style="font-size:13px; color:var(--ac-ink-soft);">{totalReviews} review{totalReviews === 1 ? '' : 's'}</p>
                </div>
                <div>
                  {[5,4,3,2,1].map((n) => {
                    const cnt = reviewStats['r' + n] || 0;
                    const pct = totalReviews > 0 ? (cnt / totalReviews) * 100 : 0;
                    return (
                      <div style="display:flex; align-items:center; gap:10px; font-size:12.5px; margin-bottom:5px;">
                        <span style="width:12px; color:var(--ac-ink-soft);">{n}</span>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="#B8512E" stroke="#B8512E" stroke-width="2"><polygon points="12 2 15 9 22 9 17 14 19 22 12 18 5 22 7 14 2 9 9 9"/></svg>
                        <div style="flex:1; background:var(--ac-paper-deep); border-radius:100px; height:6px; overflow:hidden;">
                          <div style={`width:${pct}%; height:100%; background:var(--ac-amber);`}></div>
                        </div>
                        <span style="width:30px; text-align:right; color:var(--ac-ink-muted); font-size:11.5px;">{cnt}</span>
                      </div>
                    );
                  })}
                </div>
              </div>
            </div>
          )}
          <div style="margin-top:18px; display:flex; flex-direction:column; gap:14px;">
            {reviews.map((rv: any) => (
              <div class="ac-card">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px; flex-wrap:wrap; gap:10px;">
                  <div style="display:flex; align-items:center; gap:12px;">
                    <div style="width:38px; height:38px; border-radius:50%; background:var(--ac-paper-deep); border:1px solid var(--ac-border); display:flex; align-items:center; justify-content:center; font-family:'Fraunces',serif; font-weight:500; color:var(--ac-ink); font-size:14px;">
                      {(rv.reviewer_name || '?').substring(0, 1).toUpperCase()}
                    </div>
                    <div>
                      <p style="font-size:13.5px; font-weight:600; color:var(--ac-ink);">{rv.reviewer_name}</p>
                      <p style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--ac-ink-muted);">{timeAgo(rv.created_at)}</p>
                    </div>
                  </div>
                  <div style="display:flex; gap:1px;">
                    {starRow(rv.rating).map((on) => (
                      <svg width="13" height="13" viewBox="0 0 24 24" fill={on ? '#B8512E' : 'none'} stroke={on ? '#B8512E' : '#cbd5e1'} stroke-width="2"><polygon points="12 2 15 9 22 9 17 14 19 22 12 18 5 22 7 14 2 9 9 9"/></svg>
                    ))}
                  </div>
                </div>
                {rv.review && <p style="font-size:14px; color:var(--ac-ink-soft); line-height:1.7;">{rv.review}</p>}
              </div>
            ))}
          </div>
        </div>

        <div class="tab-panel" id="panel-faq">
          <h2 class="ac-display ac-mb-6" style="font-size:1.6rem;">Frequently asked</h2>
          <div style="display:flex; flex-direction:column; gap:10px;">
            {[
              { q: 'Is this course really free?', a: course.is_free ? 'Yes. Foundational AquinTutor courses are free with no time limit, no paywall, and no required upgrades. The certificate is also included.' : 'This is a premium course. You can preview the syllabus and free-preview lessons before paying.' },
              { q: 'What do I get when I complete this course?', a: 'A verifiable digital certificate at a public URL anyone can check. You can add it to LinkedIn directly via the certificate page, or print/save it as PDF.' },
              { q: 'Do I need to study at a fixed time?', a: 'No. AquinTutor is fully self-paced. Start when you sign in, pick it up wherever you left off.' },
              { q: 'How is the AI tutor different from a search engine?', a: 'The tutor is grounded in this specific course content - it can reference exact lessons, generate practice questions on the spot, and explain a concept multiple ways without you leaving the page.' },
              { q: 'What happens if I get stuck?', a: 'You can request a human tutor for any course via Contact - we route the request to a domain expert. The AI tutor is available immediately on every lesson.' },
              { q: 'How do you handle my data?', a: 'Per our public Privacy Policy. We never sell learner data. You can export or delete your account at any time.' },
            ].map((f, i) => (
              <details open={i === 0} class="ac-card" style="padding:0;">
                <summary style="cursor:pointer; list-style:none; padding:18px 22px; display:flex; align-items:center; justify-content:space-between; gap:14px; font-family:'Fraunces',serif; font-size:1.02rem; font-weight:500; color:var(--ac-ink);">
                  <span>{f.q}</span>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--ac-amber); flex-shrink:0;"><path d="M12 5v14M5 12h14"/></svg>
                </summary>
                <div style="padding:0 22px 18px; font-size:14px; color:var(--ac-ink-soft); line-height:1.75;">{f.a}</div>
              </details>
            ))}
          </div>
        </div>
      </div>

      <aside style="display:flex; flex-direction:column; gap:16px;">
        <div class="ac-card">
          <p style="font-family:'Geist Mono',monospace; font-size:10px; color:var(--ac-amber); font-weight:700; text-transform:uppercase; letter-spacing:0.14em; margin-bottom:14px;">Course at a glance</p>
          <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:12px; font-size:13.5px;">
            <li style="display:flex; justify-content:space-between;"><span style="color:var(--ac-ink-soft);">Level</span><span style="color:var(--ac-ink); font-weight:500;">{LEVEL_LABELS[course.level] || 'Beginner'}</span></li>
            <li style="display:flex; justify-content:space-between;"><span style="color:var(--ac-ink-soft);">Lessons</span><span style="color:var(--ac-ink); font-weight:500;">{lessons.length}</span></li>
            <li style="display:flex; justify-content:space-between;"><span style="color:var(--ac-ink-soft);">Duration</span><span style="color:var(--ac-ink); font-weight:500;">{totalHours}h</span></li>
            <li style="display:flex; justify-content:space-between;"><span style="color:var(--ac-ink-soft);">Language</span><span style="color:var(--ac-ink); font-weight:500;">{course.language || 'English'}</span></li>
            <li style="display:flex; justify-content:space-between;"><span style="color:var(--ac-ink-soft);">Enrolled</span><span style="color:var(--ac-ink); font-weight:500;">{course.enrolled_count || 0}</span></li>
            <li style="display:flex; justify-content:space-between;"><span style="color:var(--ac-ink-soft);">Certificate</span><span style="color:var(--ac-ink); font-weight:500;">Yes</span></li>
          </ul>
        </div>

        {relatedCourses.length > 0 && (
          <div class="ac-card">
            <p style="font-family:'Geist Mono',monospace; font-size:10px; color:var(--ac-amber); font-weight:700; text-transform:uppercase; letter-spacing:0.14em; margin-bottom:14px;">You might also like</p>
            <div style="display:flex; flex-direction:column; gap:14px;">
              {relatedCourses.map((rc: any) => (
                <a href={'/aquintutor/courses/' + rc.slug} style="text-decoration:none;">
                  <p style="font-family:'Fraunces',serif; font-size:1rem; font-weight:500; color:var(--ac-ink); line-height:1.3; margin-bottom:4px;">{rc.title}</p>
                  <p style="font-size:12.5px; color:var(--ac-ink-soft); line-height:1.5;">{rc.short_desc || ''}</p>
                  <div style="font-family:'Geist Mono',monospace; font-size:10.5px; color:var(--ac-ink-muted); margin-top:6px; display:flex; gap:10px;">
                    <span>{rc.level}</span>
                    {rc.duration_hours > 0 && <span>{rc.duration_hours}h</span>}
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="ac-card" style="background:var(--ac-indigo); border-color:var(--ac-indigo); color:var(--ac-surface);">
          <p style="font-family:'Geist Mono',monospace; font-size:10px; color:var(--ac-amber-light); font-weight:700; text-transform:uppercase; letter-spacing:0.14em; margin-bottom:10px;">Share</p>
          <p style="font-size:13.5px; opacity:0.85; line-height:1.6; margin-bottom:14px;">Found this useful? Share it.</p>
          <div style="display:flex; gap:8px;">
            <a href={'https://twitter.com/intent/tweet?text=' + encodeURIComponent(course.title + ' - AquinTutor course') + '&url=' + encodeURIComponent(SITE.url + '/aquintutor/courses/' + slug)} target="_blank" rel="noopener" style="flex:1; text-align:center; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.16); color:var(--ac-surface); text-decoration:none; padding:8px; border-radius:6px; font-size:12.5px; font-weight:500;">Twitter</a>
            <a href={'https://www.linkedin.com/sharing/share-offsite/?url=' + encodeURIComponent(SITE.url + '/aquintutor/courses/' + slug)} target="_blank" rel="noopener" style="flex:1; text-align:center; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.16); color:var(--ac-surface); text-decoration:none; padding:8px; border-radius:6px; font-size:12.5px; font-weight:500;">LinkedIn</a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <style is:global>
    @media (min-width: 1024px) {
      .academy .hero-grid { grid-template-columns: 2fr 1fr !important; }
      .academy .content-grid { grid-template-columns: 2fr 1fr !important; }
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var tabs = document.querySelectorAll('.tab-btn');
      var panels = document.querySelectorAll('.tab-panel');
      tabs.forEach(function(t) {
        t.addEventListener('click', function() {
          var name = t.getAttribute('data-tab');
          tabs.forEach(function(x) { x.classList.remove('active'); });
          t.classList.add('active');
          panels.forEach(function(p) { p.classList.remove('active'); });
          var target = document.getElementById('panel-' + name);
          if (target) target.classList.add('active');
        });
      });
    });
  </script>
</AquintutorLayout>
