---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { SITE } from '@/lib/site';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/aquintutor/courses');

let course: any = null;
let lessons: any[] = [];
let modules: any[] = [];

try {
  const r = await db.execute(sql`
    SELECT * FROM training_courses
    WHERE slug = ${slug} AND is_published = true AND access_type IN ('public', 'both')
    LIMIT 1
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  course = rows[0] || null;
} catch (_) {}

if (!course) return Astro.redirect('/aquintutor/courses');

try {
  const r = await db.execute(sql`
    SELECT id, title, type, duration_mins, is_preview, sort_order, module_id
    FROM training_lessons WHERE course_id = ${course.id} ORDER BY sort_order ASC, created_at ASC
  `);
  lessons = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT id, title, description, sort_order FROM training_modules
    WHERE course_id = ${course.id} ORDER BY sort_order ASC
  `);
  modules = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const lessonsByModule: Record<string, any[]> = {};
const unmoduledLessons: any[] = [];
for (const l of lessons) {
  if (l.module_id) {
    if (!lessonsByModule[l.module_id]) lessonsByModule[l.module_id] = [];
    lessonsByModule[l.module_id].push(l);
  } else {
    unmoduledLessons.push(l);
  }
}

const totalDurationMin = lessons.reduce((sum, l) => sum + (l.duration_mins || 0), 0);
const totalHours = totalDurationMin > 0 ? (totalDurationMin / 60).toFixed(1) : (course.duration_hours || 0);

// Google "Course" rich result schema (https://developers.google.com/search/docs/appearance/structured-data/course)
const courseSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: course.title,
  description: course.description || course.short_desc || '',
  provider: {
    '@type': 'Organization',
    name: 'AquinTutor (EduRankAI)',
    sameAs: SITE.url,
  },
  educationalLevel: course.level || 'beginner',
  inLanguage: course.language || 'en',
  ...(course.is_free && {
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'INR',
      category: 'Free',
    },
  }),
  hasCourseInstance: {
    '@type': 'CourseInstance',
    courseMode: 'online',
    courseWorkload: 'PT' + Math.ceil(Number(totalHours) || 1) + 'H',
  },
};

const pageTitle = course.title + ' - AquinTutor';
const pageDesc = (course.short_desc || course.description || '').substring(0, 160);

const LEVEL_LABELS: Record<string, string> = {
  beginner: 'Beginner', intermediate: 'Intermediate', advanced: 'Advanced',
};
const learningOutcomes: string[] = Array.isArray(course.learning_outcomes) ? course.learning_outcomes : [];
const prerequisites: string[] = Array.isArray(course.prerequisites) ? course.prerequisites : [];
const tags: string[] = Array.isArray(course.tags) ? course.tags : [];
---
<BaseLayout title={pageTitle} description={pageDesc}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(courseSchema)} />

  <section class="px-[5vw] pt-12 md:pt-16 pb-8 max-w-5xl mx-auto">
    <a href="/aquintutor/courses" class="inline-flex items-center gap-2 text-[0.78rem] font-mono text-ink-soft hover:text-burn transition-colors mb-6">
      &larr; All courses
    </a>

    <div class="flex flex-wrap gap-2 mb-4">
      <span class="text-[0.65rem] font-bold uppercase tracking-wider text-burn bg-burn-pale border border-burn-dim px-2.5 py-0.5 rounded">{LEVEL_LABELS[course.level] || 'Beginner'}</span>
      {course.is_free && <span class="text-[0.65rem] font-semibold text-leaf bg-leaf-bg border border-leaf-border px-2.5 py-0.5 rounded">FREE</span>}
      {course.category && <span class="text-[0.65rem] font-semibold text-ink-soft bg-cream-2 border border-ink/10 px-2.5 py-0.5 rounded">{course.category}</span>}
      {course.language && <span class="text-[0.65rem] font-semibold text-ink-soft bg-cream-2 border border-ink/10 px-2.5 py-0.5 rounded">{course.language}</span>}
    </div>

    <h1 class="font-display text-[clamp(1.8rem,4.5vw,3rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-5">
      {course.title}
    </h1>

    {course.short_desc && (
      <p class="text-[1rem] md:text-[1.1rem] text-ink-soft leading-[1.85] max-w-3xl mb-6">{course.short_desc}</p>
    )}

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-8">
      <div class="bg-cream-2 border border-ink/10 rounded-xl p-3 md:p-4">
        <p class="text-[0.6rem] font-mono uppercase tracking-wider text-ink-soft font-bold">Lessons</p>
        <p class="text-[1.15rem] font-semibold text-ink mt-1">{lessons.length}</p>
      </div>
      <div class="bg-cream-2 border border-ink/10 rounded-xl p-3 md:p-4">
        <p class="text-[0.6rem] font-mono uppercase tracking-wider text-ink-soft font-bold">Duration</p>
        <p class="text-[1.15rem] font-semibold text-ink mt-1">{totalHours}h</p>
      </div>
      <div class="bg-cream-2 border border-ink/10 rounded-xl p-3 md:p-4">
        <p class="text-[0.6rem] font-mono uppercase tracking-wider text-ink-soft font-bold">Enrolled</p>
        <p class="text-[1.15rem] font-semibold text-ink mt-1">{course.enrolled_count || 0}</p>
      </div>
      <div class="bg-cream-2 border border-ink/10 rounded-xl p-3 md:p-4">
        <p class="text-[0.6rem] font-mono uppercase tracking-wider text-ink-soft font-bold">Certificate</p>
        <p class="text-[1.15rem] font-semibold text-ink mt-1">Yes</p>
      </div>
    </div>

    <div class="flex flex-wrap gap-3 mb-12">
      <a href={'/portal/login?next=' + encodeURIComponent('/portal/courses/' + slug)} class="btn-primary">Enrol &amp; start learning</a>
      <a href="/portal/signup" class="btn-ghost">Create free account</a>
    </div>
  </section>

  {course.description && (
    <section class="px-[5vw] py-8 max-w-5xl mx-auto border-t border-ink/8">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn mb-2 font-bold">About this course</p>
      <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-5">What you'll explore</h2>
      <div class="text-[0.95rem] text-ink-2 leading-[1.85] font-light whitespace-pre-line max-w-3xl">{course.description}</div>
    </section>
  )}

  {learningOutcomes.length > 0 && (
    <section class="px-[5vw] py-8 max-w-5xl mx-auto border-t border-ink/8">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn mb-2 font-bold">Learning outcomes</p>
      <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-5">By the end, you will</h2>
      <ul class="space-y-3 max-w-2xl">
        {learningOutcomes.map((o: string) => (
          <li class="flex gap-3 text-[0.95rem] text-ink-2 leading-[1.7]">
            <span class="text-burn flex-shrink-0 mt-1 font-bold">-&gt;</span>
            <span>{o}</span>
          </li>
        ))}
      </ul>
    </section>
  )}

  {(modules.length > 0 || unmoduledLessons.length > 0) && (
    <section class="px-[5vw] py-8 max-w-5xl mx-auto border-t border-ink/8">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn mb-2 font-bold">Syllabus</p>
      <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-5">{lessons.length} lessons, organised</h2>

      <div class="space-y-3">
        {modules.map((m, mi) => {
          const moduleLessons = lessonsByModule[m.id] || [];
          return (
            <details open={mi === 0} class="bg-white border border-ink/10 rounded-xl group">
              <summary class="cursor-pointer list-none p-4 md:p-5 flex items-center justify-between gap-4 font-display text-[1rem] font-semibold text-ink">
                <span><span class="text-burn font-mono text-[0.72rem] mr-3">{String(mi + 1).padStart(2, '0')}</span>{m.title}</span>
                <span class="text-[0.7rem] font-mono text-ink-soft/70">{moduleLessons.length} lessons</span>
              </summary>
              {m.description && <p class="px-4 md:px-5 text-[0.85rem] text-ink-soft leading-relaxed mb-2 -mt-1">{m.description}</p>}
              <ul class="px-4 md:px-5 pb-4 md:pb-5 space-y-2">
                {moduleLessons.map((l: any, li: number) => (
                  <li class="flex items-center gap-3 text-[0.88rem] text-ink-2 py-2 border-t border-ink/5">
                    <span class="text-ink-soft/60 font-mono text-[0.7rem] w-8">{String(li + 1).padStart(2, '0')}</span>
                    <span class="flex-1">{l.title}</span>
                    {l.is_preview && <span class="text-[0.6rem] font-bold text-burn bg-burn-pale px-2 py-0.5 rounded">FREE PREVIEW</span>}
                    {l.duration_mins > 0 && <span class="text-[0.72rem] font-mono text-ink-soft/60">{l.duration_mins}m</span>}
                  </li>
                ))}
              </ul>
            </details>
          );
        })}
        {unmoduledLessons.length > 0 && (
          <details open={modules.length === 0} class="bg-white border border-ink/10 rounded-xl">
            <summary class="cursor-pointer list-none p-4 md:p-5 flex items-center justify-between gap-4 font-display text-[1rem] font-semibold text-ink">
              <span>Lessons</span>
              <span class="text-[0.7rem] font-mono text-ink-soft/70">{unmoduledLessons.length} lessons</span>
            </summary>
            <ul class="px-4 md:px-5 pb-4 md:pb-5 space-y-2">
              {unmoduledLessons.map((l: any, li: number) => (
                <li class="flex items-center gap-3 text-[0.88rem] text-ink-2 py-2 border-t border-ink/5">
                  <span class="text-ink-soft/60 font-mono text-[0.7rem] w-8">{String(li + 1).padStart(2, '0')}</span>
                  <span class="flex-1">{l.title}</span>
                  {l.is_preview && <span class="text-[0.6rem] font-bold text-burn bg-burn-pale px-2 py-0.5 rounded">FREE PREVIEW</span>}
                  {l.duration_mins > 0 && <span class="text-[0.72rem] font-mono text-ink-soft/60">{l.duration_mins}m</span>}
                </li>
              ))}
            </ul>
          </details>
        )}
      </div>
    </section>
  )}

  {prerequisites.length > 0 && (
    <section class="px-[5vw] py-8 max-w-5xl mx-auto border-t border-ink/8">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn mb-2 font-bold">Before you start</p>
      <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-5">Prerequisites</h2>
      <ul class="space-y-2 max-w-2xl">
        {prerequisites.map((p: string) => (
          <li class="text-[0.92rem] text-ink-2 leading-[1.7]">- {p}</li>
        ))}
      </ul>
    </section>
  )}

  {course.instructor_name && (
    <section class="px-[5vw] py-8 max-w-5xl mx-auto border-t border-ink/8">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn mb-2 font-bold">Instructor</p>
      <div class="flex items-center gap-4 max-w-2xl">
        <div class="w-14 h-14 rounded-full bg-cream-2 border border-ink/15 flex items-center justify-center font-display text-[1.2rem] font-semibold text-ink flex-shrink-0">
          {(course.instructor_name as string).substring(0, 1).toUpperCase()}
        </div>
        <div>
          <p class="font-display text-[1.05rem] font-semibold text-ink">{course.instructor_name}</p>
          {course.instructor_title && <p class="text-[0.85rem] text-ink-soft mt-0.5">{course.instructor_title}</p>}
        </div>
      </div>
    </section>
  )}

  <section class="px-[5vw] py-12 max-w-5xl mx-auto border-t border-ink/8">
    <div class="bg-white border-2 border-burn rounded-2xl p-6 md:p-10 text-center">
      <h3 class="font-display text-2xl md:text-3xl font-semibold text-ink mb-3">Ready to begin?</h3>
      <p class="text-[0.95rem] text-ink-soft mb-6 max-w-xl mx-auto leading-relaxed">
        Sign in to enrol and start. You'll get an AI tutor that knows this course, a public certificate on completion, and access to the AquinTutor community.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href={'/portal/login?next=' + encodeURIComponent('/portal/courses/' + slug)} class="btn-primary">Enrol &amp; start</a>
        <a href="/portal/signup" class="btn-ghost">Create free account</a>
      </div>
    </div>
  </section>
</BaseLayout>
