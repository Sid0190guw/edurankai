---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { SITE } from '@/lib/site';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/aquintutor/courses');

let course: any = null;
let lessons: any[] = [];
let modules: any[] = [];
let reviews: any[] = [];
let reviewStats: any = null;
let relatedCourses: any[] = [];

try {
  const r = await db.execute(sql`
    SELECT * FROM training_courses
    WHERE slug = ${slug} AND is_published = true AND access_type IN ('public', 'both')
    LIMIT 1
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  course = rows[0] || null;
} catch (_) {}

if (!course) return Astro.redirect('/aquintutor/courses');

try {
  const r = await db.execute(sql`
    SELECT id, title, type, duration_mins, is_preview, sort_order, module_id
    FROM training_lessons WHERE course_id = ${course.id} ORDER BY sort_order ASC, created_at ASC
  `);
  lessons = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT id, title, description, sort_order FROM training_modules
    WHERE course_id = ${course.id} ORDER BY sort_order ASC
  `);
  modules = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT r.id, r.rating, r.review, r.created_at, u.name as reviewer_name
    FROM training_reviews r JOIN users u ON r.user_id = u.id
    WHERE r.course_id = ${course.id} ORDER BY r.created_at DESC LIMIT 6
  `);
  reviews = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT
      COUNT(*)::int as total,
      ROUND(AVG(rating)::numeric, 1) as avg_rating,
      COUNT(*) FILTER (WHERE rating = 5)::int as r5,
      COUNT(*) FILTER (WHERE rating = 4)::int as r4,
      COUNT(*) FILTER (WHERE rating = 3)::int as r3,
      COUNT(*) FILTER (WHERE rating = 2)::int as r2,
      COUNT(*) FILTER (WHERE rating = 1)::int as r1
    FROM training_reviews WHERE course_id = ${course.id}
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  reviewStats = rows[0] || null;
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT slug, title, short_desc, level, duration_hours
    FROM training_courses
    WHERE is_published = true AND access_type IN ('public', 'both')
      AND id != ${course.id}
      AND (category = ${course.category} OR level = ${course.level})
    ORDER BY enrolled_count DESC NULLS LAST
    LIMIT 3
  `);
  relatedCourses = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const lessonsByModule: Record<string, any[]> = {};
const unmoduledLessons: any[] = [];
for (const l of lessons) {
  if (l.module_id) {
    if (!lessonsByModule[l.module_id]) lessonsByModule[l.module_id] = [];
    lessonsByModule[l.module_id].push(l);
  } else {
    unmoduledLessons.push(l);
  }
}

const totalDurationMin = lessons.reduce((sum, l) => sum + (l.duration_mins || 0), 0);
const totalHours = totalDurationMin > 0 ? (totalDurationMin / 60).toFixed(1) : (course.duration_hours || 0);
const avgRating = reviewStats?.avg_rating ? Number(reviewStats.avg_rating).toFixed(1) : null;
const totalReviews = reviewStats?.total || 0;

const courseSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: course.title,
  description: course.description || course.short_desc || '',
  provider: { '@type': 'Organization', name: 'AquinTutor (EduRankAI)', sameAs: SITE.url },
  educationalLevel: course.level || 'beginner',
  inLanguage: course.language || 'en',
  ...(course.is_free && {
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'INR', category: 'Free' },
  }),
  ...(avgRating && {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: avgRating,
      reviewCount: totalReviews,
    },
  }),
  hasCourseInstance: {
    '@type': 'CourseInstance',
    courseMode: 'online',
    courseWorkload: 'PT' + Math.ceil(Number(totalHours) || 1) + 'H',
  },
};

const LEVEL_LABELS: Record<string, string> = {
  beginner: 'Beginner', intermediate: 'Intermediate', advanced: 'Advanced',
};
const learningOutcomes: string[] = Array.isArray(course.learning_outcomes) ? course.learning_outcomes : [];
const prerequisites: string[] = Array.isArray(course.prerequisites) ? course.prerequisites : [];
const tags: string[] = Array.isArray(course.tags) ? course.tags : [];

const pageTitle = course.title + ' - AquinTutor';
const pageDesc = (course.short_desc || course.description || '').substring(0, 160);
const enrolUrl = '/portal/login?next=' + encodeURIComponent('/portal/courses/' + slug);

function timeAgo(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const days = Math.floor(diff / 86400000);
  if (days < 1) return 'today';
  if (days < 7) return days + 'd ago';
  if (days < 30) return Math.floor(days / 7) + 'w ago';
  if (days < 365) return Math.floor(days / 30) + 'mo ago';
  return Math.floor(days / 365) + 'y ago';
}

function starRow(n: number) {
  const filled = Math.round(n);
  return Array.from({ length: 5 }, (_, i) => i < filled);
}
---
<BaseLayout title={pageTitle} description={pageDesc}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(courseSchema)} />

  <style>
    .star { width: 14px; height: 14px; display: inline-block; }
    .star-row svg { vertical-align: middle; }
    .check-icon { width: 18px; height: 18px; color: #10b981; flex-shrink: 0; margin-top: 2px; }
    .skill-pill {
      display: inline-block;
      background: rgba(255,79,0,0.08);
      color: #FF4F00;
      border: 1px solid rgba(255,79,0,0.25);
      padding: 5px 11px;
      border-radius: 100px;
      font-size: 12.5px;
      font-weight: 600;
      margin: 3px;
    }
    .enrol-card {
      background: #fff;
      border: 1px solid rgba(0,0,0,0.08);
      border-radius: 16px;
      padding: 22px;
      box-shadow: 0 8px 30px rgba(0,0,0,0.05);
    }
    @media (min-width: 1024px) {
      .enrol-card.sticky { position: sticky; top: 24px; }
    }
    .tab-btn {
      padding: 12px 4px;
      font-size: 14px;
      font-weight: 600;
      color: #6b7280;
      border-bottom: 2px solid transparent;
      cursor: pointer;
      background: none;
      border-left: 0; border-right: 0; border-top: 0;
      transition: color 0.15s, border-color 0.15s;
    }
    .tab-btn.active { color: #FF4F00; border-bottom-color: #FF4F00; }
    .tab-btn:hover { color: #FF4F00; }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }
  </style>

  <!-- HERO ------------------------------------------------------------ -->
  <section class="bg-ink text-white">
    <div class="px-[5vw] py-10 md:py-14 max-w-6xl mx-auto">
      <a href="/aquintutor/courses" class="inline-flex items-center gap-2 text-[0.78rem] font-mono text-white/60 hover:text-burn transition-colors mb-6">
        &larr; AquinTutor courses
      </a>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- LEFT: Hero info -->
        <div class="lg:col-span-2">
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="text-[0.65rem] font-bold uppercase tracking-wider text-burn bg-burn/15 border border-burn/30 px-2.5 py-1 rounded">{LEVEL_LABELS[course.level] || 'Beginner'}</span>
            {course.is_free && <span class="text-[0.65rem] font-bold uppercase tracking-wider text-leaf-soft bg-leaf-soft/15 border border-leaf-soft/40 px-2.5 py-1 rounded">FREE</span>}
            {course.category && <span class="text-[0.65rem] font-semibold uppercase tracking-wider text-white/70 bg-white/8 border border-white/15 px-2.5 py-1 rounded">{course.category}</span>}
            {course.language && <span class="text-[0.65rem] font-semibold text-white/70 bg-white/8 border border-white/15 px-2.5 py-1 rounded">{course.language}</span>}
          </div>
          <h1 class="font-display text-[clamp(1.8rem,4vw,2.8rem)] font-semibold leading-[1.1] tracking-tight mb-5">
            {course.title}
          </h1>
          {course.short_desc && (
            <p class="text-[1rem] md:text-[1.05rem] text-white/75 leading-[1.75] mb-6">{course.short_desc}</p>
          )}

          {avgRating && (
            <div class="flex items-center gap-3 mb-5 flex-wrap">
              <div class="flex items-center gap-1.5">
                <span class="text-[1.2rem] font-bold text-burn">{avgRating}</span>
                <div class="star-row flex gap-0.5">
                  {starRow(Number(avgRating)).map((on) => (
                    <svg class="star" viewBox="0 0 24 24" fill={on ? '#FBBF24' : 'none'} stroke={on ? '#FBBF24' : 'rgba(255,255,255,0.3)'} stroke-width="2"><polygon points="12 2 15 9 22 9 17 14 19 22 12 18 5 22 7 14 2 9 9 9"/></svg>
                  ))}
                </div>
              </div>
              <span class="text-[0.85rem] text-white/60">({totalReviews} review{totalReviews === 1 ? '' : 's'})</span>
              {course.enrolled_count > 0 && (
                <span class="text-[0.85rem] text-white/60">&middot; {course.enrolled_count} enrolled</span>
              )}
            </div>
          )}

          {course.instructor_name && (
            <div class="flex items-center gap-3 mb-2">
              <div class="w-10 h-10 rounded-full bg-burn/20 border border-burn/40 flex items-center justify-center font-display font-semibold text-burn">
                {(course.instructor_name as string).substring(0, 1).toUpperCase()}
              </div>
              <div>
                <p class="text-[0.78rem] text-white/60">Taught by</p>
                <p class="text-[0.92rem] font-semibold text-white">{course.instructor_name}</p>
              </div>
            </div>
          )}
        </div>

        <!-- RIGHT: Enrol card -->
        <div class="lg:col-span-1">
          <div class="enrol-card sticky">
            <div class="aspect-video bg-cream-2 rounded-lg mb-4 flex items-center justify-center text-ink-soft/50 border border-ink/8">
              <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="5 3 19 12 5 21 5 3" /></svg>
            </div>
            <p class="text-[2rem] font-bold text-ink leading-none mb-1">{course.is_free ? 'Free' : 'Premium'}</p>
            <p class="text-[0.82rem] text-ink-soft mb-5">{course.is_free ? 'No payment required to enrol' : 'Paid course - one-time fee'}</p>
            <a href={enrolUrl} class="btn-primary w-full justify-center mb-2 inline-flex items-center" style="display:flex;">Enrol &amp; start learning</a>
            <a href="/portal/signup" class="btn-ghost w-full justify-center inline-flex items-center" style="display:flex;">Create free account</a>

            <div class="mt-5 pt-5 border-t border-ink/10 space-y-2.5 text-[0.85rem] text-ink-soft">
              <div class="flex items-center gap-2.5">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                <span>{lessons.length} lessons, {totalHours}h total</span>
              </div>
              <div class="flex items-center gap-2.5">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                <span>AI tutor (course-context-aware)</span>
              </div>
              <div class="flex items-center gap-2.5">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Verifiable certificate on completion</span>
              </div>
              <div class="flex items-center gap-2.5">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Lifetime access, learn at your pace</span>
              </div>
              <div class="flex items-center gap-2.5">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Mobile + desktop</span>
              </div>
            </div>

            <p class="mt-5 text-center text-[0.75rem] text-ink-soft/70">
              Need a human tutor? <a href="/contact" class="text-burn hover:underline">Request one</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TAB NAV --------------------------------------------------------- -->
  <section class="border-b border-ink/10 bg-cream-2/60 sticky top-0 z-30" id="tabNav">
    <div class="px-[5vw] max-w-6xl mx-auto flex gap-7 overflow-x-auto">
      <button type="button" class="tab-btn active" data-tab="overview">Overview</button>
      <button type="button" class="tab-btn" data-tab="outcomes">What you'll learn</button>
      <button type="button" class="tab-btn" data-tab="syllabus">Syllabus</button>
      <button type="button" class="tab-btn" data-tab="instructor">Instructor</button>
      <button type="button" class="tab-btn" data-tab="reviews">Reviews</button>
      <button type="button" class="tab-btn" data-tab="faq">FAQ</button>
    </div>
  </section>

  <!-- TAB PANELS ------------------------------------------------------ -->
  <section class="px-[5vw] py-10 md:py-12 max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">

        <!-- OVERVIEW -->
        <div class="tab-panel active" id="panel-overview">
          {course.description && (
            <div class="mb-8">
              <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-4">About this course</h2>
              <div class="text-[0.95rem] text-ink-2 leading-[1.85] font-light whitespace-pre-line">{course.description}</div>
            </div>
          )}

          {tags.length > 0 && (
            <div class="mb-8">
              <h3 class="font-display text-[1.05rem] font-semibold text-ink mb-3">Skills you'll gain</h3>
              <div class="flex flex-wrap">
                {tags.map((t: string) => <span class="skill-pill">{t}</span>)}
              </div>
            </div>
          )}

          {prerequisites.length > 0 && (
            <div class="mb-8">
              <h3 class="font-display text-[1.05rem] font-semibold text-ink mb-3">Prerequisites</h3>
              <ul class="space-y-2 text-[0.93rem] text-ink-2 leading-[1.7]">
                {prerequisites.map((p: string) => (
                  <li class="flex gap-3">
                    <span class="text-ink-soft/60 mt-1">&bull;</span>
                    <span>{p}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>

        <!-- OUTCOMES -->
        <div class="tab-panel" id="panel-outcomes">
          <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-5">What you'll learn</h2>
          {learningOutcomes.length === 0 ? (
            <p class="text-[0.92rem] text-ink-soft italic">Learning outcomes will be added soon.</p>
          ) : (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {learningOutcomes.map((o: string) => (
                <div class="flex gap-3 items-start bg-cream-2/50 border border-ink/8 rounded-xl p-4">
                  <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  <p class="text-[0.92rem] text-ink-2 leading-[1.65]">{o}</p>
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- SYLLABUS -->
        <div class="tab-panel" id="panel-syllabus">
          <div class="flex items-baseline justify-between mb-5">
            <h2 class="font-display text-xl md:text-2xl font-semibold text-ink">Syllabus</h2>
            <span class="text-[0.78rem] font-mono text-ink-soft">{lessons.length} lessons &middot; {totalHours}h</span>
          </div>
          <div class="space-y-3">
            {modules.map((m, mi) => {
              const moduleLessons = lessonsByModule[m.id] || [];
              return (
                <details open={mi === 0} class="bg-white border border-ink/10 rounded-xl">
                  <summary class="cursor-pointer list-none p-4 md:p-5 flex items-center justify-between gap-4 font-display text-[1rem] font-semibold text-ink">
                    <span><span class="text-burn font-mono text-[0.72rem] mr-3">{String(mi + 1).padStart(2, '0')}</span>{m.title}</span>
                    <span class="text-[0.72rem] font-mono text-ink-soft/70">{moduleLessons.length} lessons</span>
                  </summary>
                  {m.description && <p class="px-4 md:px-5 text-[0.85rem] text-ink-soft leading-relaxed mb-2 -mt-1">{m.description}</p>}
                  <ul class="px-4 md:px-5 pb-4 md:pb-5 space-y-1">
                    {moduleLessons.map((l: any, li: number) => (
                      <li class="flex items-center gap-3 text-[0.88rem] text-ink-2 py-2 border-t border-ink/5">
                        <span class="text-ink-soft/60 font-mono text-[0.7rem] w-8">{String(li + 1).padStart(2, '0')}</span>
                        <span class="flex-1">{l.title}</span>
                        {l.is_preview && <span class="text-[0.6rem] font-bold text-burn bg-burn-pale px-2 py-0.5 rounded">FREE PREVIEW</span>}
                        {l.duration_mins > 0 && <span class="text-[0.72rem] font-mono text-ink-soft/60">{l.duration_mins}m</span>}
                      </li>
                    ))}
                  </ul>
                </details>
              );
            })}
            {unmoduledLessons.length > 0 && (
              <details open={modules.length === 0} class="bg-white border border-ink/10 rounded-xl">
                <summary class="cursor-pointer list-none p-4 md:p-5 flex items-center justify-between gap-4 font-display text-[1rem] font-semibold text-ink">
                  <span>Lessons</span>
                  <span class="text-[0.72rem] font-mono text-ink-soft/70">{unmoduledLessons.length} lessons</span>
                </summary>
                <ul class="px-4 md:px-5 pb-4 md:pb-5 space-y-1">
                  {unmoduledLessons.map((l: any, li: number) => (
                    <li class="flex items-center gap-3 text-[0.88rem] text-ink-2 py-2 border-t border-ink/5">
                      <span class="text-ink-soft/60 font-mono text-[0.7rem] w-8">{String(li + 1).padStart(2, '0')}</span>
                      <span class="flex-1">{l.title}</span>
                      {l.is_preview && <span class="text-[0.6rem] font-bold text-burn bg-burn-pale px-2 py-0.5 rounded">FREE PREVIEW</span>}
                      {l.duration_mins > 0 && <span class="text-[0.72rem] font-mono text-ink-soft/60">{l.duration_mins}m</span>}
                    </li>
                  ))}
                </ul>
              </details>
            )}
            {lessons.length === 0 && (
              <p class="text-[0.92rem] text-ink-soft italic text-center py-8">Lessons coming soon.</p>
            )}
          </div>
        </div>

        <!-- INSTRUCTOR -->
        <div class="tab-panel" id="panel-instructor">
          <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-5">About the instructor</h2>
          {course.instructor_name ? (
            <div class="bg-white border border-ink/10 rounded-xl p-6">
              <div class="flex items-center gap-4 mb-4">
                <div class="w-16 h-16 rounded-full bg-burn-pale border border-burn-dim flex items-center justify-center font-display text-[1.4rem] font-semibold text-burn flex-shrink-0">
                  {(course.instructor_name as string).substring(0, 1).toUpperCase()}
                </div>
                <div>
                  <p class="font-display text-[1.15rem] font-semibold text-ink">{course.instructor_name}</p>
                  {course.instructor_title && <p class="text-[0.88rem] text-ink-soft mt-0.5">{course.instructor_title}</p>}
                </div>
              </div>
              <p class="text-[0.92rem] text-ink-2 leading-[1.75]">Senior instructor at AquinTutor with deep practice in {course.category || 'this field'}. Each lesson is reviewed by domain experts before publication.</p>
            </div>
          ) : (
            <p class="text-[0.92rem] text-ink-soft italic">Instructor profile will be added soon.</p>
          )}
        </div>

        <!-- REVIEWS -->
        <div class="tab-panel" id="panel-reviews">
          <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-5">Reviews</h2>
          {totalReviews === 0 ? (
            <div class="bg-cream-2/50 border border-ink/8 rounded-xl p-8 text-center">
              <p class="text-[0.95rem] text-ink-soft mb-2">No reviews yet.</p>
              <p class="text-[0.85rem] text-ink-soft/80">Enrolled students can rate the course on completion.</p>
            </div>
          ) : (
            <div class="bg-white border border-ink/10 rounded-xl p-6 mb-6">
              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="text-center">
                  <p class="text-[3rem] font-bold text-burn leading-none">{avgRating}</p>
                  <div class="flex justify-center gap-0.5 my-2">
                    {starRow(Number(avgRating)).map((on) => (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill={on ? '#FBBF24' : 'none'} stroke={on ? '#FBBF24' : '#cbd5e1'} stroke-width="2"><polygon points="12 2 15 9 22 9 17 14 19 22 12 18 5 22 7 14 2 9 9 9"/></svg>
                    ))}
                  </div>
                  <p class="text-[0.82rem] text-ink-soft">{totalReviews} review{totalReviews === 1 ? '' : 's'}</p>
                </div>
                <div class="md:col-span-2 space-y-1.5">
                  {[5,4,3,2,1].map((n) => {
                    const cnt = reviewStats['r' + n] || 0;
                    const pct = totalReviews > 0 ? (cnt / totalReviews) * 100 : 0;
                    return (
                      <div class="flex items-center gap-3 text-[0.82rem]">
                        <span class="w-3 text-ink-soft">{n}</span>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="#FBBF24" stroke="#FBBF24" stroke-width="2"><polygon points="12 2 15 9 22 9 17 14 19 22 12 18 5 22 7 14 2 9 9 9"/></svg>
                        <div class="flex-1 bg-cream-2 rounded-full h-2 overflow-hidden">
                          <div style={`width:${pct}%;height:100%;background:#FBBF24;`}></div>
                        </div>
                        <span class="w-8 text-right text-ink-soft text-[0.78rem]">{cnt}</span>
                      </div>
                    );
                  })}
                </div>
              </div>
            </div>
          )}

          <div class="space-y-4">
            {reviews.map((rv: any) => (
              <div class="bg-white border border-ink/10 rounded-xl p-5">
                <div class="flex items-center justify-between mb-2 flex-wrap gap-2">
                  <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full bg-cream-2 border border-ink/10 flex items-center justify-center font-display font-semibold text-ink text-[0.92rem]">
                      {(rv.reviewer_name || '?').substring(0, 1).toUpperCase()}
                    </div>
                    <div>
                      <p class="text-[0.92rem] font-semibold text-ink">{rv.reviewer_name}</p>
                      <p class="text-[0.72rem] font-mono text-ink-soft">{timeAgo(rv.created_at)}</p>
                    </div>
                  </div>
                  <div class="flex gap-0.5">
                    {starRow(rv.rating).map((on) => (
                      <svg width="13" height="13" viewBox="0 0 24 24" fill={on ? '#FBBF24' : 'none'} stroke={on ? '#FBBF24' : '#cbd5e1'} stroke-width="2"><polygon points="12 2 15 9 22 9 17 14 19 22 12 18 5 22 7 14 2 9 9 9"/></svg>
                    ))}
                  </div>
                </div>
                {rv.review && <p class="text-[0.9rem] text-ink-2 leading-[1.7] mt-2">{rv.review}</p>}
              </div>
            ))}
          </div>
        </div>

        <!-- FAQ -->
        <div class="tab-panel" id="panel-faq">
          <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-5">Frequently asked</h2>
          <div class="space-y-3">
            {[
              { q: 'Is this course really free?', a: course.is_free ? 'Yes. Foundational AquinTutor courses are free with no time limit, no paywall, and no required upgrades. The certificate is also included.' : 'This is a premium course. You can preview the syllabus and free-preview lessons before paying.' },
              { q: 'What do I get when I complete this course?', a: 'A verifiable digital certificate at a public URL anyone can check. You can add it to LinkedIn directly via the certificate page, or print/save it as PDF.' },
              { q: 'Do I need to study at a fixed time?', a: 'No. AquinTutor is fully self-paced. Start when you sign in, pick it up wherever you left off.' },
              { q: 'How is the AI tutor different from a search engine?', a: 'The tutor is grounded in this specific course content - it can reference exact lessons, generate practice questions on the spot, and explain a concept multiple ways without you leaving the page.' },
              { q: 'What happens if I get stuck?', a: 'You can request a human tutor for any course via Contact - we route the request to a domain expert. The AI tutor is available immediately on every lesson.' },
              { q: 'How do you handle my data?', a: 'Per our public Privacy Policy. We never sell learner data. You can export or delete your account at any time.' },
            ].map((f, i) => (
              <details open={i === 0} class="bg-white border border-ink/10 rounded-xl">
                <summary class="cursor-pointer list-none p-4 md:p-5 flex items-center justify-between gap-4 font-display text-[0.98rem] font-semibold text-ink hover:text-burn">
                  <span>{f.q}</span>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-burn shrink-0"><path d="M12 5v14M5 12h14"/></svg>
                </summary>
                <div class="px-4 md:px-5 pb-4 md:pb-5 text-[0.9rem] text-ink-soft leading-[1.75]">{f.a}</div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <!-- RIGHT RAIL: Stats + Related -->
      <aside class="lg:col-span-1 space-y-4">
        <div class="bg-cream-2/40 border border-ink/8 rounded-xl p-5">
          <p class="text-[0.62rem] font-mono uppercase tracking-wider text-burn font-bold mb-3">Course at a glance</p>
          <ul class="space-y-3 text-[0.85rem]">
            <li class="flex justify-between"><span class="text-ink-soft">Level</span><span class="text-ink font-semibold">{LEVEL_LABELS[course.level] || 'Beginner'}</span></li>
            <li class="flex justify-between"><span class="text-ink-soft">Lessons</span><span class="text-ink font-semibold">{lessons.length}</span></li>
            <li class="flex justify-between"><span class="text-ink-soft">Duration</span><span class="text-ink font-semibold">{totalHours}h</span></li>
            <li class="flex justify-between"><span class="text-ink-soft">Language</span><span class="text-ink font-semibold">{course.language || 'English'}</span></li>
            <li class="flex justify-between"><span class="text-ink-soft">Enrolled</span><span class="text-ink font-semibold">{course.enrolled_count || 0}</span></li>
            <li class="flex justify-between"><span class="text-ink-soft">Certificate</span><span class="text-ink font-semibold">Yes</span></li>
          </ul>
        </div>

        {relatedCourses.length > 0 && (
          <div class="bg-white border border-ink/10 rounded-xl p-5">
            <p class="text-[0.62rem] font-mono uppercase tracking-wider text-burn font-bold mb-3">You might also like</p>
            <div class="space-y-3">
              {relatedCourses.map((rc: any) => (
                <a href={'/aquintutor/courses/' + rc.slug} class="block group">
                  <p class="font-display text-[0.95rem] font-semibold text-ink group-hover:text-burn transition-colors leading-snug mb-1">{rc.title}</p>
                  <p class="text-[0.78rem] text-ink-soft line-clamp-2 leading-snug">{rc.short_desc || ''}</p>
                  <div class="text-[0.7rem] font-mono text-ink-soft/70 mt-1.5 flex gap-3">
                    <span>{rc.level}</span>
                    {rc.duration_hours > 0 && <span>{rc.duration_hours}h</span>}
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="bg-ink text-white rounded-xl p-5">
          <p class="text-[0.62rem] font-mono uppercase tracking-wider text-burn font-bold mb-2">Share</p>
          <p class="text-[0.85rem] text-white/70 leading-relaxed mb-3">Found this useful? Share it.</p>
          <div class="flex gap-2">
            <a href={'https://twitter.com/intent/tweet?text=' + encodeURIComponent(course.title + ' - AquinTutor course') + '&url=' + encodeURIComponent(SITE.url + '/aquintutor/courses/' + slug)} target="_blank" rel="noopener" class="flex-1 text-center bg-white/8 border border-white/15 hover:border-burn text-white text-[0.78rem] py-2 rounded-md font-semibold">Twitter</a>
            <a href={'https://www.linkedin.com/sharing/share-offsite/?url=' + encodeURIComponent(SITE.url + '/aquintutor/courses/' + slug)} target="_blank" rel="noopener" class="flex-1 text-center bg-white/8 border border-white/15 hover:border-burn text-white text-[0.78rem] py-2 rounded-md font-semibold">LinkedIn</a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var tabs = document.querySelectorAll('.tab-btn');
      var panels = document.querySelectorAll('.tab-panel');
      tabs.forEach(function(t) {
        t.addEventListener('click', function() {
          var name = t.getAttribute('data-tab');
          tabs.forEach(function(x) { x.classList.remove('active'); });
          t.classList.add('active');
          panels.forEach(function(p) { p.classList.remove('active'); });
          var target = document.getElementById('panel-' + name);
          if (target) target.classList.add('active');
        });
      });
    });
  </script>
</BaseLayout>
