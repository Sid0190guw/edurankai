---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { ensureAquintutorAuthoringSchema, listBlocks } from '@/lib/aquintutor-authoring';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const { slug, lessonSlug } = Astro.params;
if (!slug || !lessonSlug) return Astro.redirect('/aquintutor');

await ensureAquintutorAuthoringSchema();
function rowsOf(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

const course = rowsOf(await db.execute(sql`SELECT * FROM training_courses WHERE slug = ${slug} AND is_published = true LIMIT 1`))[0] as any;
if (!course) return Astro.redirect('/aquintutor');

const lesson = rowsOf(await db.execute(sql`SELECT * FROM training_lessons WHERE slug = ${lessonSlug} AND course_id = ${course.id} LIMIT 1`))[0] as any;
if (!lesson) return Astro.redirect('/aquintutor/courses/' + slug);

const blocks = await listBlocks(lesson.id);

// Course syllabus for the right sidebar (resilient to legacy module schema)
let modules: any[] = [];
try { modules = rowsOf(await db.execute(sql`SELECT * FROM training_modules WHERE course_id = ${course.id} ORDER BY order_in_course ASC, created_at ASC`)); }
catch { try { modules = rowsOf(await db.execute(sql`SELECT * FROM training_modules WHERE course_id = ${course.id} ORDER BY created_at ASC`)); } catch { modules = []; } }
const lessonsByModule: { [k: string]: any[] } = {};
for (const m of modules) {
  try { lessonsByModule[m.id] = rowsOf(await db.execute(sql`SELECT id, slug, title, status, order_in_module FROM training_lessons WHERE module_id = ${m.id} AND status = 'published' ORDER BY order_in_module ASC, created_at ASC`)); }
  catch { try { lessonsByModule[m.id] = rowsOf(await db.execute(sql`SELECT id, slug, title FROM training_lessons WHERE module_id = ${m.id} ORDER BY created_at ASC`)); } catch { lessonsByModule[m.id] = []; } }
}

// Progress
const progressRow = rowsOf(await db.execute(sql`SELECT * FROM training_lesson_progress WHERE user_id = ${user.id} AND lesson_id = ${lesson.id} LIMIT 1`))[0] as any;
const completed = !!progressRow?.completed_at;

// Adjacent lessons (prev / next in module order)
const flatLessons: any[] = [];
modules.forEach((m: any) => (lessonsByModule[m.id] || []).forEach((l: any) => flatLessons.push(l)));
const idx = flatLessons.findIndex((l: any) => l.id === lesson.id);
const prevL = idx > 0 ? flatLessons[idx - 1] : null;
const nextL = idx >= 0 && idx < flatLessons.length - 1 ? flatLessons[idx + 1] : null;
---
<BaseLayout title={lesson.title + ' · ' + course.title} description={course.short_desc || ''}>

<style>
  body { background: #FAF8F5; }
  .lp-wrap { max-width: 1400px; margin: 0 auto; padding: 0 16px 60px; }
  .lp-top { padding: 18px 0; border-bottom: 1px solid rgba(14,11,8,0.10); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; }
  .lp-top-meta { font-family: 'Geist Mono', monospace; font-size: 11px; color: #7A6F68; letter-spacing: 0.06em; }
  .lp-top-title { font-family: 'Cormorant Garamond', serif; font-size: 22px; color: #0E0B08; font-weight: 600; margin: 4px 0 0; }
  .lp-grid { display: grid; grid-template-columns: minmax(0,1fr) 320px; gap: 32px; margin-top: 28px; }
  @media (max-width: 1024px) { .lp-grid { grid-template-columns: 1fr; } }

  .lp-prose { font-family: 'DM Sans', sans-serif; font-size: 16px; line-height: 1.7; color: #2E2520; max-width: 720px; }
  .lp-prose h1, .lp-prose h2, .lp-prose h3 { font-family: 'Cormorant Garamond', serif; color: #0E0B08; line-height: 1.2; margin: 32px 0 12px; }
  .lp-prose h1 { font-size: 36px; font-weight: 600; }
  .lp-prose h2 { font-size: 28px; font-weight: 600; }
  .lp-prose h3 { font-size: 22px; font-weight: 600; }
  .lp-prose p { margin: 14px 0; }
  .lp-prose img { max-width: 100%; border-radius: 10px; margin: 18px 0; }
  .lp-prose pre { background: #08080a; color: #cfd6da; padding: 18px; border-radius: 8px; margin: 18px 0; overflow-x: auto; font-family: ui-monospace, monospace; font-size: 13.5px; line-height: 1.6; }
  .lp-prose blockquote { border-left: 3px solid #1A6B35; padding: 8px 16px; margin: 18px 0; font-style: italic; font-family: 'Cormorant Garamond', serif; font-size: 20px; }
  .lp-prose hr { border: none; border-top: 1px solid #e5dcc6; margin: 32px 0; }
  .callout { background: #FFF3EE; border-left: 3px solid #FF4F00; padding: 14px 18px; margin: 18px 0; border-radius: 0 8px 8px 0; }
  .callout-info { background: #EBF0FF; border-left-color: #1045BB; }
  .callout-warning { background: #FFFBEA; border-left-color: #C49A00; }
  .callout-success { background: #EBF5EF; border-left-color: #1A6B35; }
  .callout-tip { background: #F2EAFF; border-left-color: #6B1FBE; }
  .callout-title { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 700; margin-bottom: 6px; color: #FF4F00; }
  .callout-info .callout-title { color: #1045BB; }
  .callout-warning .callout-title { color: #C49A00; }
  .callout-success .callout-title { color: #1A6B35; }
  .callout-tip .callout-title { color: #6B1FBE; }

  .mcq { background: #FFF3EE; border: 1px solid #FFD4BC; padding: 16px; border-radius: 10px; margin: 18px 0; }
  .mcq-q { font-weight: 700; color: #0E0B08; margin: 0 0 10px; }
  .mcq-opt { display: flex; align-items: center; gap: 8px; padding: 8px 10px; border-radius: 6px; cursor: pointer; transition: background 0.15s; }
  .mcq-opt:hover { background: rgba(255,79,0,0.08); }
  .mcq-opt input { margin: 0; }
  .mcq-check { background: #FF4F00; color: #fff; border: none; padding: 8px 16px; border-radius: 6px; font-weight: 700; cursor: pointer; margin-top: 8px; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; }
  .mcq-result { margin-top: 10px; font-size: 13.5px; padding: 10px; border-radius: 6px; display: none; }
  .mcq-result.correct { background: rgba(26,107,53,0.10); color: #1A6B35; }
  .mcq-result.incorrect { background: rgba(239,68,68,0.10); color: #b91c1c; }

  .lp-side { position: sticky; top: 20px; align-self: start; }
  .lp-side-panel { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 12px; padding: 16px; margin-bottom: 12px; }
  .lp-side-eyebrow { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .lp-side h3 { font-family: 'Cormorant Garamond', serif; font-size: 18px; color: #0E0B08; margin: 4px 0 12px; }
  .lp-side-syllabus { font-size: 13px; line-height: 1.5; max-height: 360px; overflow-y: auto; }
  .lp-side-syllabus details { margin-bottom: 6px; }
  .lp-side-syllabus summary { cursor: pointer; font-weight: 600; color: #0E0B08; padding: 4px 0; font-family: 'Geist Mono', monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; list-style: none; }
  .lp-side-syllabus a { display: block; padding: 5px 8px 5px 16px; color: #2E2520; text-decoration: none; border-radius: 4px; font-size: 12.5px; }
  .lp-side-syllabus a:hover { background: rgba(255,79,0,0.06); }
  .lp-side-syllabus a.active { background: rgba(255,79,0,0.12); color: #FF4F00; font-weight: 700; }
  .lp-side-syllabus a.done::before { content: '✓ '; color: #1A6B35; font-weight: 700; }

  .lp-progress { background: rgba(14,11,8,0.06); height: 6px; border-radius: 100px; overflow: hidden; margin: 6px 0 10px; }
  .lp-progress-fill { background: #FF4F00; height: 100%; transition: width 0.4s; }

  .lp-mark { display: inline-flex; align-items: center; gap: 8px; background: #FF4F00; color: #fff; border: none; padding: 12px 22px; border-radius: 8px; font-weight: 700; font-size: 13px; cursor: pointer; letter-spacing: 0.04em; text-transform: uppercase; font-family: 'Geist Mono', monospace; }
  .lp-mark.done { background: #1A6B35; }
  .lp-mark[disabled] { opacity: 0.5; cursor: default; }

  .lp-nav { display: flex; justify-content: space-between; margin-top: 32px; padding-top: 24px; border-top: 1px solid rgba(14,11,8,0.10); gap: 12px; flex-wrap: wrap; }
  .lp-nav a { color: #FF4F00; text-decoration: none; font-weight: 700; font-size: 13px; padding: 10px 18px; border: 1px solid rgba(255,79,0,0.3); border-radius: 8px; }
  .lp-nav a:hover { background: rgba(255,79,0,0.08); }
</style>

<main class="lp-wrap">

  <div class="lp-top">
    <div>
      <p class="lp-top-meta"><a href={'/aquintutor/courses/' + slug} style="color:inherit;text-decoration:none;">← {course.title}</a></p>
      <h1 class="lp-top-title">{lesson.title}</h1>
    </div>
    <button class={"lp-mark" + (completed ? ' done' : '')} id="markCompleteBtn" data-lesson-id={lesson.id} data-course-id={course.id}>
      {completed ? '✓ Completed' : 'Mark as complete'}
    </button>
  </div>

  <div class="lp-grid">
    <article class="lp-prose">
      <div id="blockRoot"></div>

      <div class="lp-nav">
        {prevL ? <a href={'/aquintutor/courses/' + slug + '/learn/' + prevL.slug}>← {prevL.title}</a> : <span></span>}
        {nextL && <a href={'/aquintutor/courses/' + slug + '/learn/' + nextL.slug}>{nextL.title} →</a>}
      </div>
    </article>

    <aside class="lp-side">
      <div class="lp-side-panel">
        <p class="lp-side-eyebrow">Lesson</p>
        <p style="font-size:13px;color:#7A6F68;margin:4px 0;">{lesson.estimated_minutes || 10} min · {idx + 1} of {flatLessons.length}</p>
        <div class="lp-progress"><div class="lp-progress-fill" style={`width:${((idx + 1) / Math.max(1, flatLessons.length)) * 100}%`}></div></div>
      </div>
      <div class="lp-side-panel">
        <p class="lp-side-eyebrow">Course outline</p>
        <h3>{course.title}</h3>
        <div class="lp-side-syllabus">
          {modules.map((m: any) => (
            <details open={(lessonsByModule[m.id] || []).some((l: any) => l.id === lesson.id)}>
              <summary>{m.title}</summary>
              {(lessonsByModule[m.id] || []).map((l: any) => (
                <a href={'/aquintutor/courses/' + slug + '/learn/' + l.slug} class={l.id === lesson.id ? 'active' : ''}>{l.title}</a>
              ))}
            </details>
          ))}
        </div>
      </div>
    </aside>
  </div>
</main>

<script is:inline define:vars={{ blocks, lessonId: lesson.id, courseId: course.id }}>
  (function () {
    var root = document.getElementById('blockRoot');
    function esc(s) { return (s || '').toString().replace(/[<>&"]/g, function (c) { return { '<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;' }[c]; }); }
    function md(s) { return esc(s).replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>').replace(/\*(.+?)\*/g, '<em>$1</em>').replace(/`(.+?)`/g, '<code style="background:#f3efe8;padding:1px 5px;border-radius:3px;font-family:ui-monospace,monospace;font-size:14px;">$1</code>').replace(/\n\n/g, '</p><p>'); }

    blocks.forEach(function (b) {
      var c = b.content || {};
      var html = '';
      switch (b.kind) {
        case 'text': html = '<p>' + md(c.md || '') + '</p>'; break;
        case 'heading': var lvl = c.level || 2; html = '<h' + lvl + '>' + esc(c.text || '') + '</h' + lvl + '>'; break;
        case 'image': if (c.url) html = '<figure><img src="' + esc(c.url) + '" alt="' + esc(c.alt || '') + '"/>' + (c.caption ? '<figcaption style="font-size:13px;color:#7A6F68;margin-top:6px;text-align:center;font-style:italic;">' + esc(c.caption) + '</figcaption>' : '') + '</figure>'; break;
        case 'video_embed': if (c.url) {
          var u = c.url;
          if (u.indexOf('youtube.com/watch') >= 0) u = u.replace('youtube.com/watch?v=', 'youtube.com/embed/').split('&')[0];
          if (u.indexOf('youtu.be/') >= 0) u = u.replace('youtu.be/', 'youtube.com/embed/');
          html = '<div style="margin:18px 0;"><iframe src="' + esc(u) + '" frameborder="0" allowfullscreen style="width:100%;aspect-ratio:16/9;border-radius:10px;"></iframe>' + (c.caption ? '<p style="font-size:13px;color:#7A6F68;margin-top:6px;text-align:center;font-style:italic;">' + esc(c.caption) + '</p>' : '') + '</div>';
        } break;
        case 'callout': var tone = c.tone || 'info'; html = '<div class="callout callout-' + esc(tone) + '"><p class="callout-title">' + esc(c.title || tone) + '</p><p>' + md(c.body || '') + '</p></div>'; break;
        case 'code': html = '<pre><code>' + esc(c.code || '') + '</code></pre>'; break;
        case 'mcq': var opts = (c.options || []).map(function (o, i) { return '<label class="mcq-opt"><input type="radio" name="mcq-' + b.id + '" value="' + i + '"/> ' + esc(o) + '</label>'; }).join('');
          html = '<div class="mcq" data-bid="' + b.id + '" data-correct="' + (c.correct || 0) + '" data-explanation="' + esc(c.explanation || '') + '"><p class="mcq-q">' + esc(c.question || '') + '</p>' + opts + '<button class="mcq-check">Check answer</button><div class="mcq-result"></div></div>';
          break;
        case 'fill_blank': html = '<div class="mcq" data-bid="' + b.id + '" data-correct-text="' + esc((c.answer||'').toLowerCase().trim()) + '"><p class="mcq-q">' + esc(c.prompt || '') + '</p><input type="text" name="fb-' + b.id + '" placeholder="Your answer..." style="padding:8px 12px;border:1px solid #e5dcc6;border-radius:6px;width:280px;font-size:14px;"/><br/><button class="mcq-check" style="margin-top:10px;">Check</button><div class="mcq-result"></div></div>'; break;
        case 'order_steps': var s = (c.steps || []).slice(); for (var i = s.length - 1; i > 0; i--) { var j = Math.floor(Math.random() * (i + 1)); var t = s[i]; s[i] = s[j]; s[j] = t; } html = '<div class="mcq"><p class="mcq-q">' + esc(c.question || '') + '</p><ol style="padding-left:22px;">' + s.map(function (st) { return '<li style="padding:4px 0;">' + esc(st) + '</li>'; }).join('') + '</ol><p style="font-size:12px;color:#7A6F68;font-style:italic;">[ drag-reorder will arrive in next polish push ]</p></div>'; break;
        case 'quote': html = '<blockquote>' + esc(c.text || '') + (c.attribution ? '<footer style="font-size:14px;color:#7A6F68;font-style:normal;margin-top:6px;font-family:DM Sans;">— ' + esc(c.attribution) + '</footer>' : '') + '</blockquote>'; break;
        case 'latex': html = '<div style="background:#fbf5f3;border:1px solid #e5dcc6;padding:14px;border-radius:8px;margin:18px 0;font-family:ui-monospace,monospace;font-size:15px;text-align:center;">' + esc(c.tex || '') + '</div>'; break;
        case 'divider': html = '<hr/>'; break;
        case 'file_attachment': if (c.url) html = '<a href="' + esc(c.url) + '" download style="display:inline-flex;align-items:center;gap:8px;background:#FFF3EE;color:#FF4F00;padding:12px 18px;border-radius:8px;text-decoration:none;font-weight:700;margin:18px 0;">↓ ' + esc(c.name || 'Download') + '</a>'; break;
        case 'embed_lab': {
          var src = '/aquintutor/labs/' + esc(c.slug || 'pendulum');
          html = '<figure style="margin:20px 0;"><iframe src="' + src + '" loading="lazy" style="width:100%;height:' + (parseInt(c.height,10) || 620) + 'px;border:1px solid #e5dcc6;border-radius:12px;background:#0a0a0c;"></iframe>' + (c.caption ? '<figcaption style="font-size:13px;color:#7A6F68;margin-top:6px;text-align:center;font-style:italic;">' + esc(c.caption) + '</figcaption>' : '') + '<p style="font-size:12px;color:#7A6F68;margin-top:4px;text-align:center;"><a href="' + src + '" target="_blank" rel="noopener" style="color:#FF4F00;">Open the lab full-screen ↗</a></p></figure>';
          break;
        }
        case 'embed_simulator': {
          var src = '/aquintutor/' + esc(c.target || 'quantum/composer');
          html = '<figure style="margin:20px 0;"><iframe src="' + src + '" loading="lazy" style="width:100%;height:' + (parseInt(c.height,10) || 700) + 'px;border:1px solid #e5dcc6;border-radius:12px;background:#0a0a0c;"></iframe>' + (c.caption ? '<figcaption style="font-size:13px;color:#7A6F68;margin-top:6px;text-align:center;font-style:italic;">' + esc(c.caption) + '</figcaption>' : '') + '<p style="font-size:12px;color:#7A6F68;margin-top:4px;text-align:center;"><a href="' + src + '" target="_blank" rel="noopener" style="color:#FF4F00;">Open full-screen ↗</a></p></figure>';
          break;
        }
        case 'embed_animation': {
          html = '<figure style="margin:20px 0;"><iframe src="/aquintutor/labs/animator" loading="lazy" style="width:100%;height:' + (parseInt(c.height,10) || 640) + 'px;border:1px solid #e5dcc6;border-radius:12px;background:#08080a;"></iframe>' + (c.caption ? '<figcaption style="font-size:13px;color:#7A6F68;margin-top:6px;text-align:center;font-style:italic;">' + esc(c.caption) + '</figcaption>' : '') + '</figure>';
          break;
        }
        case 'embed_test': if (c.slug) html = '<div style="margin:20px 0;padding:22px;border:1px solid #B0C4F8;background:#EBF0FF;border-radius:12px;text-align:center;"><p style="font-family:ui-monospace,monospace;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:#1045BB;font-weight:700;margin:0 0 8px;">Proctored assessment</p><a href="/aquintutor/test/' + esc(c.slug) + '" style="display:inline-block;background:#1045BB;color:#fff;padding:12px 28px;border-radius:10px;text-decoration:none;font-weight:700;">' + esc(c.label || 'Take the test') + ' →</a></div>'; break;
        case 'embed_liveclass': if (c.roomId) html = '<div style="margin:20px 0;padding:22px;border:1px solid #A7D7B9;background:#EBF5EF;border-radius:12px;text-align:center;"><p style="font-family:ui-monospace,monospace;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:#1A6B35;font-weight:700;margin:0 0 8px;">Live class · real-time teaching</p><a href="/portal/meet/' + esc(c.roomId) + '" style="display:inline-block;background:#1A6B35;color:#fff;padding:12px 28px;border-radius:10px;text-decoration:none;font-weight:700;">' + esc(c.label || 'Join the live class') + ' →</a></div>'; break;
      }
      var el = document.createElement('div');
      el.innerHTML = html;
      while (el.firstChild) root.appendChild(el.firstChild);
    });

    // MCQ checking
    document.querySelectorAll('.mcq').forEach(function (mcq) {
      var btn = mcq.querySelector('.mcq-check'); if (!btn) return;
      btn.addEventListener('click', function () {
        var res = mcq.querySelector('.mcq-result');
        var isCorrect = false;
        var chosen = null;
        if (mcq.hasAttribute('data-correct')) {
          var correct = parseInt(mcq.getAttribute('data-correct'), 10);
          var sel = mcq.querySelector('input[type="radio"]:checked');
          if (!sel) { res.textContent = 'Pick an option first.'; res.className = 'mcq-result incorrect'; res.style.display = 'block'; return; }
          chosen = parseInt(sel.value, 10);
          isCorrect = chosen === correct;
        } else if (mcq.hasAttribute('data-correct-text')) {
          var inp = mcq.querySelector('input[type="text"]');
          var v = (inp.value || '').toLowerCase().trim();
          chosen = v;
          isCorrect = v === mcq.getAttribute('data-correct-text');
        }
        res.textContent = isCorrect ? ('Correct. ' + (mcq.getAttribute('data-explanation') || '')) : ('Not quite. Try again.');
        res.className = 'mcq-result ' + (isCorrect ? 'correct' : 'incorrect');
        res.style.display = 'block';
        if (mcq.getAttribute('data-bid')) {
          fetch('/api/aquintutor/quiz-attempt', { method: 'POST', headers: { 'Content-Type':'application/json' }, credentials: 'same-origin', body: JSON.stringify({ lessonId: lessonId, blockId: mcq.getAttribute('data-bid'), chosen: chosen, isCorrect: isCorrect }) });
        }
      });
    });

    // Mark complete
    var mb = document.getElementById('markCompleteBtn');
    if (mb && !mb.classList.contains('done')) {
      mb.addEventListener('click', function () {
        mb.disabled = true;
        fetch('/api/aquintutor/lesson-complete', { method:'POST', headers:{'Content-Type':'application/json'}, credentials:'same-origin', body: JSON.stringify({ lessonId: lessonId, courseId: courseId }) }).then(function(r){return r.json();}).then(function(d){
          if (d.ok) { mb.classList.add('done'); mb.innerHTML = '✓ Completed'; if (d.certificate) alert('You completed the course! Certificate: ' + d.certificate); }
          else { mb.disabled = false; alert(d.error || 'Failed'); }
        });
      });
    }
  })();
</script>
</BaseLayout>
