---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { TIERS, getProfile } from '@/lib/aquintutor-learn';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/onboarding'));
const existing = await getProfile(user.id);
// Deep-link: /aquintutor/onboarding?tier=<id> preselects the stage (from the
// home stage-picker or a stages card), so the segment choice is explicit.
const preTier = (Astro.url.searchParams.get('tier') || '').trim();
---
<AquintutorLayout title="Set up your learning" description="Tell AquinTutor who is learning and what you want, so we can build a path that fits.">
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1100px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a>
      <span style="margin:0 8px;">/</span><span style="color:var(--rust); font-weight:600;">SET UP</span>
    </div>
  </div>

  <section style="max-width:1100px; margin:0 auto; padding:44px 28px 90px;">
    <p style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--rust); font-weight:700; margin:0 0 8px;">Step 1 · Who is learning</p>
    <h1 style="font-family:'Fraunces',Georgia,serif; font-size:clamp(1.9rem,4vw,2.7rem); font-weight:600; color:var(--ink-900,#1a1510); margin:0 0 6px; letter-spacing:-0.01em;">Let's build your path.</h1>
    <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); line-height:1.6; margin:0 0 30px; max-width:640px;">AquinTutor supports one learner from the earliest years through advanced research. Pick the stage that fits, choose a goal, and we set up a personalised path — verified learning, not passive video.</p>

    <div id="tierGrid" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(230px,1fr)); gap:12px; margin-bottom:34px;">
      {TIERS.map((t) => (
        <button type="button" class="aq-tier" data-tier={t.id} data-name={t.name} data-goals={JSON.stringify(t.goals)}
          style="text-align:left; background:#fff; border:1.5px solid var(--rule); border-radius:14px; padding:15px 16px; cursor:pointer; transition:border-color .15s, transform .1s;">
          <div style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.1em; color:var(--ink-500); text-transform:uppercase;">{t.tag} · {t.ages}</div>
          <div style="font-family:'Fraunces',Georgia,serif; font-size:1.15rem; font-weight:600; color:var(--ink-900,#1a1510); margin-top:3px;">{t.name}</div>
        </button>
      ))}
    </div>

    <div id="goalBlock" style="display:none;">
      <p style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--rust); font-weight:700; margin:0 0 8px;">Step 2 · Your goal</p>
      <h2 style="font-family:'Fraunces',Georgia,serif; font-size:1.4rem; font-weight:600; color:var(--ink-900,#1a1510); margin:0 0 14px;">What do you want from <span id="goalTierName">AquinTutor</span>?</h2>
      <div id="goalGrid" style="display:flex; flex-wrap:wrap; gap:10px; margin-bottom:20px;"></div>
      <label style="display:block; font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink-500); margin-bottom:20px;">Daily time limit (optional, minutes)
        <input id="dailyLimit" type="number" min="5" max="240" step="5" placeholder="e.g. 30" style="display:block; margin-top:5px; width:160px; background:#fff; border:1.5px solid var(--rule); border-radius:9px; padding:9px 11px; font-size:14px; color:var(--ink-900,#1a1510); outline:none;" />
      </label>
      <button id="finishBtn" type="button" disabled style="background:var(--rust,#c2410c); color:#fff; border:none; font-family:'Inter Tight',sans-serif; font-size:15px; font-weight:600; padding:13px 30px; border-radius:11px; cursor:pointer; opacity:0.5;">Start learning</button>
      <p id="obMsg" style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); margin:12px 0 0; min-height:1.1em;"></p>
    </div>
  </section>

  <script is:inline define:vars={{ existingTier: (existing?.tier || preTier || ''), existingGoal: existing?.goal || '' }}>
    (function () {
      var tier = '', goal = '', tierName = '';
      var goalBlock = document.getElementById('goalBlock'), goalGrid = document.getElementById('goalGrid'), finish = document.getElementById('finishBtn');
      function pickTier(btn) {
        document.querySelectorAll('.aq-tier').forEach(function (b) { b.style.borderColor = 'var(--rule)'; b.style.transform = ''; });
        btn.style.borderColor = 'var(--rust, #c2410c)'; btn.style.transform = 'translateY(-2px)';
        tier = btn.getAttribute('data-tier'); tierName = btn.getAttribute('data-name');
        document.getElementById('goalTierName').textContent = tierName;
        var goals = JSON.parse(btn.getAttribute('data-goals') || '[]');
        goalGrid.innerHTML = '';
        goals.forEach(function (g) {
          var gb = document.createElement('button'); gb.type = 'button'; gb.textContent = g;
          gb.style.cssText = 'background:#fff; border:1.5px solid var(--rule); border-radius:10px; padding:10px 16px; font-family:"Inter Tight",sans-serif; font-size:14px; color:var(--ink-900,#1a1510); cursor:pointer;';
          gb.addEventListener('click', function () {
            goal = g; Array.prototype.forEach.call(goalGrid.children, function (x) { x.style.borderColor = 'var(--rule)'; x.style.background = '#fff'; });
            gb.style.borderColor = 'var(--rust,#c2410c)'; gb.style.background = 'var(--sand-100,#f7f2ea)';
            finish.disabled = false; finish.style.opacity = '1';
          });
          goalGrid.appendChild(gb);
        });
        goalBlock.style.display = 'block';
        goalBlock.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
      document.querySelectorAll('.aq-tier').forEach(function (b) {
        b.addEventListener('click', function () { pickTier(b); });
        if (existingTier && b.getAttribute('data-tier') === existingTier) pickTier(b);
      });
      finish.addEventListener('click', function () {
        if (!tier || !goal) return;
        finish.disabled = true; finish.textContent = 'Setting up…';
        fetch('/api/aquintutor/learn', { method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin',
          body: JSON.stringify({ action: 'profile', tier: tier, goal: goal, dailyLimitMin: Number(document.getElementById('dailyLimit').value) || null }) })
          .then(function (r) { return r.json(); }).then(function (j) {
            if (!j.ok) { document.getElementById('obMsg').textContent = j.error || 'Could not save.'; finish.disabled = false; finish.textContent = 'Start learning'; return; }
            window.location.href = '/aquintutor/learn';
          }).catch(function () { document.getElementById('obMsg').textContent = 'Network error. Try again.'; finish.disabled = false; finish.textContent = 'Start learning'; });
      });
    })();
  </script>
</AquintutorLayout>
