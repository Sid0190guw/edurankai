---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

const cols = [
  { id: 'backlog', title: 'Backlog', count: 7, accent: '#6b5f4c', items: [
    { course: 'AI-512', c: '#2b577e', title: 'Code review · attention masking', due: '1d', xp: 150, type: 'review', meta: 'peer · 2 reviewers' },
    { course: 'QT-407', c: '#5b4a92', title: 'Problem set 5 · density matrices', due: '4d', xp: 220, type: 'problem-set', meta: '12 problems' },
    { course: 'VS-118', c: '#a8472c', title: 'Vastu site analysis · field report', due: '5d', xp: 300, type: 'essay', meta: '800–1,200 words' },
    { course: 'DA-201', c: '#a04330', title: 'Studio crit · prep slides', due: '6d', xp: 100, type: 'presentation' },
    { course: 'RB-330', c: '#946322', title: 'Midterm · IK gauntlet', due: '7d', xp: 600, type: 'exam', meta: 'proctored · ATLAS', exam: true },
    { course: 'BA-260', c: '#4a7048', title: 'Case study · forecasting', due: '9d', xp: 280, type: 'case' },
    { course: 'LA-118', c: '#8a486b', title: 'Reading response · Arendt', due: '11d', xp: 120, type: 'response' },
  ]},
  { id: 'inprog', title: 'In progress', count: 4, accent: '#3d6b76', items: [
    { course: 'QT-407', c: '#5b4a92', title: 'Problem set 4 · linear algebra', due: '6h', xp: 220, type: 'problem-set', progress: 0.7, urgent: true, meta: '8 / 12 problems done' },
    { course: 'AI-512', c: '#2b577e', title: 'Lab notebook · masked attention', due: '2d', xp: 250, type: 'lab', progress: 0.4 },
    { course: 'DA-201', c: '#a04330', title: 'Studio critique writeup', due: '3d', xp: 180, type: 'essay', progress: 0.3 },
    { course: 'VS-118', c: '#a8472c', title: 'Vastu reading · Mandala Vidya', due: '5d', xp: 80, type: 'reading', progress: 0.6 },
  ]},
  { id: 'review', title: 'Under review', count: 3, accent: '#a87526', items: [
    { course: 'LA-118', c: '#8a486b', title: 'Habermas paper · 1st draft', due: 'submitted', xp: 320, type: 'paper', state: 'with Aquin', aquin: true },
    { course: 'BA-260', c: '#4a7048', title: 'Quarterly model · v3', due: 'submitted', xp: 280, type: 'model', state: 'with Prof. Khan' },
    { course: 'AI-512', c: '#2b577e', title: 'PS3 · auto-grade', due: 'submitted', xp: 220, type: 'problem-set', state: 'grading' },
  ]},
  { id: 'done', title: 'Done', count: 4, accent: '#4a7048', items: [
    { course: 'QT-407', c: '#5b4a92', title: 'Problem set 3', xp: 220, grade: 'A', pct: 94 },
    { course: 'AI-512', c: '#2b577e', title: 'PS2 · tokenization', xp: 200, grade: 'A-', pct: 89 },
    { course: 'DA-201', c: '#a04330', title: 'Sketch portfolio · wk 6', xp: 150, grade: 'A', pct: 96 },
    { course: 'LA-118', c: '#8a486b', title: 'Reading response 3', xp: 100, grade: 'B+', pct: 86 },
  ]},
];
---
<AquintutorLayout title="Assignments" description="What you owe, what you are doing, what is done. Kanban view of your assignments across all enrolled courses.">

  <!-- BREADCRUMB -->
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1400px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a>
      <span style="margin:0 8px;">/</span>
      <a href="/aquintutor/dashboard" style="color:var(--ink-500); text-decoration:none;">DASHBOARD</a>
      <span style="margin:0 8px;">/</span>
      <span style="color:var(--rust); font-weight:600;">ASSIGNMENTS · 18 ACTIVE</span>
    </div>
  </div>

  <!-- HEADER -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:32px 28px 24px;">
      <div style="display:flex; align-items:start; justify-content:space-between; gap:18px; flex-wrap:wrap;">
        <div>
          <div style="display:inline-flex; align-items:center; gap:8px; padding:4px 12px; background:rgba(160,66,30,0.08); border:1px solid rgba(160,66,30,0.3); border-radius:999px; font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.16em; text-transform:uppercase; color:var(--rust); font-weight:600; margin-bottom:12px;">ASSIGNMENTS &middot; 18 ACTIVE</div>
          <h1 class="font-display" style="font-size:clamp(1.85rem, 4vw, 2.85rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0; color:var(--ink);">What you owe, what you're doing, what's done.</h1>
          <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1rem, 1.3vw, 1.2rem); color:var(--ink-500); line-height:1.5; margin:14px 0 0; max-width:44rem;">Drag cards across columns. Click any card to open the submission view. Aquin reviews drafts on request.</p>
        </div>
        <div style="display:flex; gap:8px; flex-wrap:wrap;">
          <button type="button" style="background:transparent; color:var(--ink); padding:10px 18px; border:1px solid var(--rule); border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; cursor:pointer;">Calendar view</button>
          <button type="button" style="background:transparent; color:#3d6b76; padding:10px 18px; border:1px solid #3d6b76; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; cursor:pointer;">Review with Aquin</button>
          <button type="button" style="background:var(--rust); color:#fff; padding:10px 18px; border:none; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; cursor:pointer;">Submit something</button>
        </div>
      </div>
    </div>
  </section>

  <!-- STAT STRIP -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1400px; margin:0 auto; padding:24px 28px;">
      <div style="display:grid; grid-template-columns:repeat(2, 1fr); gap:12px;" class="stat-row">
        {[
          { l: 'Active assignments', v: '18' },
          { l: 'Due in 24h', v: '2', accent: '#a04330' },
          { l: 'Under review', v: '3' },
          { l: 'XP this week', v: '1,140', accent: 'var(--rust)' },
          { l: 'Avg grade · semester', v: '91%', accent: '#4a7048' },
          { l: 'On-time rate', v: '94%' },
        ].map((s) => (
          <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px 18px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">{s.l}</p>
            <p class="font-display" style={'font-size:1.5rem; font-weight:500; margin:0; line-height:1; letter-spacing:-0.02em; ' + (s.accent ? 'color:' + s.accent + ';' : 'color:var(--ink);')}>{s.v}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- KANBAN -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:36px 28px 48px;">
      <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="kanban">
        {cols.map((col) => (
          <div style="display:flex; flex-direction:column; gap:10px;">
            <div style={'display:flex; align-items:center; justify-content:space-between; padding:11px 14px; background:var(--paper); border:1px solid var(--rule); border-left:3px solid ' + col.accent + '; border-radius:8px;'}>
              <div>
                <p style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0;">{col.title}</p>
                <p style={'font-family:Fraunces,serif; font-size:1.45rem; font-weight:500; margin:2px 0 0; line-height:1; letter-spacing:-0.02em; color:' + col.accent + ';'}>{col.count}</p>
              </div>
              <button type="button" style="width:26px; height:26px; background:transparent; border:1px solid var(--rule); border-radius:6px; cursor:pointer; color:var(--ink-500); display:inline-flex; align-items:center; justify-content:center;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></button>
            </div>

            <div style="display:flex; flex-direction:column; gap:8px;">
              {col.items.map((it: any) => {
                const colors: any = { problemset: '#5b4a92', exam: '#a04330', essay: '#a8472c' };
                return (
                  <article style={'background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px; display:flex; flex-direction:column; gap:8px; cursor:grab; ' + (it.urgent ? 'border-color:#a04330; box-shadow:0 0 0 1px rgba(160,67,48,0.3);' : '') + (it.exam ? ' border-color:#a04330;' : '')}>
                    <div style="display:flex; align-items:center; justify-content:space-between; gap:8px;">
                      <span style={'font-family:JetBrains Mono,monospace; font-size:10px; letter-spacing:0.14em; color:' + it.c + '; font-weight:600;'}>{it.course}</span>
                      {it.exam && <span style="font-family:'JetBrains Mono',monospace; font-size:8.5px; padding:2px 7px; background:rgba(160,67,48,0.10); border:1px solid #a04330; border-radius:999px; color:#a04330; letter-spacing:0.14em; font-weight:600;">ATLAS</span>}
                      {it.aquin && <span style="font-family:'JetBrains Mono',monospace; font-size:8.5px; padding:2px 7px; background:rgba(61,107,118,0.10); border:1px solid #3d6b76; border-radius:999px; color:#3d6b76; letter-spacing:0.14em; font-weight:600;">AI</span>}
                    </div>
                    <p style="font-family:'Inter Tight',sans-serif; font-size:13.5px; font-weight:600; line-height:1.3; margin:0; color:var(--ink);">{it.title}</p>
                    {it.meta && <p style="font-family:'Inter Tight',sans-serif; font-size:11.5px; color:var(--ink-500); margin:0; line-height:1.4;">{it.meta}</p>}
                    {it.progress != null && (
                      <div>
                        <div style="display:flex; justify-content:space-between; font-family:'JetBrains Mono',monospace; font-size:9.5px; color:var(--ink-500); margin-bottom:3px;"><span>PROGRESS</span><span>{Math.round(it.progress * 100)}%</span></div>
                        <div style="height:4px; background:var(--rule); border-radius:2px; overflow:hidden;"><div style={'width:' + (it.progress * 100) + '%; height:100%; background:' + it.c + ';'}></div></div>
                      </div>
                    )}
                    <div style="display:flex; align-items:center; justify-content:space-between; gap:8px; padding-top:8px; border-top:1px solid var(--rule); font-family:'JetBrains Mono',monospace; font-size:10.5px;">
                      <span style={'color:' + (it.urgent ? '#a04330' : 'var(--ink-500)') + '; font-weight:' + (it.urgent ? 600 : 400) + ';'}>{it.state ? '◷ ' + it.state : it.grade ? '★ ' + it.grade + ' · ' + it.pct + '%' : 'due ' + it.due}</span>
                      <span style="color:var(--rust); font-weight:600;">+{it.xp} XP</span>
                    </div>
                  </article>
                );
              })}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INFO ROW -->
  <section style="background:var(--sand-100); border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:48px 28px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">How assignments work</p>
      <h2 class="font-display" style="font-size:clamp(1.5rem, 2.5vw, 2rem); font-weight:500; line-height:1.15; letter-spacing:-0.015em; margin:0 0 28px; color:var(--ink); max-width:36rem;">From assignment to credential, in four steps.</h2>
      <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="how-grid">
        {[
          { n: 'I', t: 'Backlog', d: 'New assignments land here. Aquin tags difficulty and prerequisites; you decide the order.' },
          { n: 'II', t: 'In progress', d: 'Start work in the browser. Progress is auto-saved, every paragraph or problem solved.' },
          { n: 'III', t: 'Under review', d: 'Submitted work goes to Aquin first for a red-pen pass, then to faculty for the grade.' },
          { n: 'IV', t: 'Done', d: 'Graded work shows percentage and letter grade. Counts toward the course credential.' },
        ].map((p) => (
          <article style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:22px;">
            <div style="display:flex; align-items:baseline; gap:12px; margin-bottom:10px;">
              <span class="font-display" style="font-style:italic; font-weight:300; font-size:1.85rem; color:var(--rust); line-height:1; letter-spacing:-0.02em;">{p.n}</span>
              <h3 class="font-display" style="font-size:1.1rem; font-weight:500; margin:0; line-height:1.2; letter-spacing:-0.015em;">{p.t}</h3>
            </div>
            <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink-500); line-height:1.6; margin:0;">{p.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <style>
    @media (min-width: 640px) { .stat-row { grid-template-columns: repeat(3, 1fr) !important; } .kanban { grid-template-columns: repeat(2, 1fr) !important; } .how-grid { grid-template-columns: repeat(2, 1fr) !important; } }
    @media (min-width: 1000px) { .stat-row { grid-template-columns: repeat(6, 1fr) !important; } .kanban { grid-template-columns: repeat(4, 1fr) !important; } .how-grid { grid-template-columns: repeat(4, 1fr) !important; } }
  </style>
</AquintutorLayout>
