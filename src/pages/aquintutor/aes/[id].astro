---
// /aquintutor/aes/[id] — a single AES module, rendered from the specification itself:
// its dependency chain, engineering mission, repository structure and object model.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { moduleById, allModules, roman } from '@/lib/aes-spec';

const { id } = Astro.params as { id: string };
const m = moduleById(id);
if (!m) return Astro.redirect('/aquintutor/aes');
const all = allModules();
const idx = all.findIndex((x) => x.id === m.id);
const prev = idx > 0 ? all[idx - 1] : null;
const next = idx >= 0 && idx < all.length - 1 ? all[idx + 1] : null;
---
<AquintutorLayout title={m.id}>
  <main style="max-width:900px;margin:0 auto;padding:48px 22px 90px;">
    <a href="/aquintutor/aes" style="font-family:'Inter Tight',sans-serif;font-size:13px;color:var(--rust,#b3541e);text-decoration:none;">&larr; All modules</a>

    <p style="font-family:'Geist Mono',monospace;font-size:12px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:18px 0 10px;">Volume {roman(m.volume)} &middot; Part {m.part} &middot; Chapter {m.chapter}</p>
    <h1 style="font-family:Fraunces,serif;font-size:clamp(24px,3.6vw,36px);font-weight:600;color:var(--ink,#1a1712);margin:0 0 10px;line-height:1.15;">{m.title}</h1>
    <p style="font-family:'Geist Mono',monospace;font-size:12px;color:#8a8378;margin:0 0 26px;">{m.id}</p>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:12px;margin-bottom:26px;">
      {m.dependsOn && <div style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:12px;padding:14px 16px;"><p style="font-family:'Geist Mono',monospace;font-size:10.5px;letter-spacing:0.1em;text-transform:uppercase;color:#8a8378;margin:0 0 6px;">Depends on</p><p style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:#3a352c;margin:0;line-height:1.5;">{m.dependsOn}</p></div>}
      {m.produces && <div style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:12px;padding:14px 16px;"><p style="font-family:'Geist Mono',monospace;font-size:10.5px;letter-spacing:0.1em;text-transform:uppercase;color:#8a8378;margin:0 0 6px;">Produces</p><p style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:#3a352c;margin:0;line-height:1.5;">{m.produces}</p></div>}
    </div>

    {m.mission && (
      <section style="margin-bottom:30px;">
        <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:#8a8378;margin:0 0 10px;">Engineering mission</p>
        <p style="font-family:'Inter Tight',sans-serif;font-size:15.5px;color:#3a352c;line-height:1.7;margin:0;">{m.mission}</p>
      </section>
    )}

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:18px;">
      {m.fields.length > 0 && (
        <section style="background:var(--ink,#1a1712);border-radius:16px;padding:22px 24px;">
          <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:#e0a878;margin:0 0 4px;">Object model</p>
          <p style="font-family:Fraunces,serif;font-size:19px;color:var(--sand-50,#fbfaf4);margin:0 0 14px;">{m.objectName || 'Object'}</p>
          <div style="display:flex;flex-direction:column;gap:5px;">
            {m.fields.map((f) => <span style="font-family:'Geist Mono',monospace;font-size:12.5px;color:rgba(251,250,244,0.86);">{f}</span>)}
          </div>
        </section>
      )}
      {m.repository.length > 0 && (
        <section style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:16px;padding:22px 24px;">
          <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:#8a8378;margin:0 0 12px;">Repository structure</p>
          <div style="display:flex;flex-direction:column;gap:4px;">
            {m.repository.map((r) => <span style="font-family:'Geist Mono',monospace;font-size:12.5px;color:#3a352c;">{r}</span>)}
          </div>
        </section>
      )}
    </div>

    <nav style="display:flex;justify-content:space-between;gap:12px;margin-top:34px;padding-top:20px;border-top:1px solid var(--line,#e6e1d6);">
      {prev ? <a href={'/aquintutor/aes/' + prev.id} style="font-family:'Inter Tight',sans-serif;font-size:13px;color:var(--ink,#1a1712);text-decoration:none;max-width:45%;">&larr; Ch {prev.chapter}</a> : <span></span>}
      {next ? <a href={'/aquintutor/aes/' + next.id} style="font-family:'Inter Tight',sans-serif;font-size:13px;color:var(--ink,#1a1712);text-decoration:none;text-align:right;max-width:45%;">Ch {next.chapter} &rarr;</a> : <span></span>}
    </nav>
  </main>
</AquintutorLayout>
