---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const { slug } = Astro.params;
const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/stories/' + slug));

let story: any = null;
let segments: any[] = [];
try {
  const r = await db.execute(sql`SELECT * FROM stories WHERE slug = ${slug} AND is_published = true LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  story = rows[0] || null;
} catch (_) {}
if (!story) return Astro.redirect('/aquintutor');
try {
  const r = await db.execute(sql`SELECT id, sort_order, segment_type, text, translation, payload, correct_answer FROM story_segments WHERE story_id = ${story.id} ORDER BY sort_order ASC`);
  segments = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const langCode = story.language || 'en-IN';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{story.title} — Story</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&display=swap" />
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{background:#fafaf7;color:#1c1d22;min-height:100vh;font-family:'Inter Tight',-apple-system,system-ui,sans-serif}
    .top{background:#fff;border-bottom:1px solid #e6e3da;padding:14px 22px;display:flex;gap:14px;align-items:center;position:sticky;top:0;z-index:5;}
    .top a{color:#5b5b5b;font-size:14px;text-decoration:none;}
    .wrap{max-width:680px;margin:0 auto;padding:36px 22px 140px;}
    .seg{margin-bottom:16px;}
    .narration{background:#fff;border:1px solid #e6e3da;border-radius:14px;padding:18px 22px;}
    .dialogue{background:#fff8f3;border:1px solid #f0d2bc;border-radius:14px;padding:18px 22px;}
    .seg p.text{font-family:'Fraunces',serif;font-size:20px;font-weight:500;line-height:1.4;color:#1c1d22;}
    .seg p.tr{font-family:'Inter Tight',sans-serif;font-size:13px;color:#5b5b5b;margin-top:6px;font-style:italic;}
    .speak{background:none;border:1px solid #e6e3da;border-radius:8px;padding:5px 10px;font-size:12px;cursor:pointer;margin-top:8px;}
    .question{background:#fff;border:2px solid #d97757;border-radius:14px;padding:22px;}
    .question p.text{font-family:'Fraunces',serif;font-size:18px;}
    .qopt{display:block;width:100%;padding:13px 16px;background:#fff;border:2px solid #e6e3da;border-radius:10px;margin-top:8px;font-family:inherit;font-size:14px;cursor:pointer;text-align:left;}
    .qopt:hover{border-color:#c8c3b8;}
    .qopt.correct{border-color:#10b981;background:rgba(16,185,129,0.10);color:#047857;}
    .qopt.wrong{border-color:#ef4444;background:rgba(239,68,68,0.08);color:#991b1b;}
    .qopt:disabled{cursor:default;}
    .done{background:#10b981;color:#fff;padding:18px;border-radius:14px;text-align:center;font-family:inherit;font-size:15px;font-weight:700;margin-top:24px;}
  </style>
</head>
<body>
  <header class="top">
    <a href="/aquintutor/dashboard">← Dashboard</a>
    <div style="flex:1;text-align:center;">
      <p style="font-family:'Fraunces',serif;font-size:16px;font-weight:600;">{story.title}</p>
      <p style="font-size:11px;color:#5b5b5b;">{story.subtitle}</p>
    </div>
  </header>

  <div class="wrap">
    {segments.map((s: any) => {
      if (s.segment_type === 'question') {
        const opts = ((s.payload || {}).options || []) as string[];
        return (
          <div class="seg question" data-q={s.id} data-correct={s.correct_answer}>
            <p class="text">{s.text}</p>
            <div style="margin-top:14px;">
              {opts.map((o: string, i: number) => (
                <button type="button" class="qopt" data-i={i}>{o}</button>
              ))}
            </div>
          </div>
        );
      }
      return (
        <div class={'seg ' + (s.segment_type === 'dialogue' ? 'dialogue' : 'narration')}>
          <p class="text">{s.text}</p>
          {s.translation && <p class="tr">{s.translation}</p>}
          <button type="button" class="speak" data-speak={s.text} data-lang={langCode} style="display:inline-flex;align-items:center;gap:6px;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>Hear</button>
        </div>
      );
    })}
    <div id="done" class="done" style="display:none;align-items:center;gap:8px;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg><span id="doneMsg">Story complete — XP added to your account.</span></div>
  </div>

  <script is:inline define:vars={{ storyId: story.id, xpReward: story.xp_reward || 30, totalQs: segments.filter((s:any)=>s.segment_type==='question').length }}>
  (function () {
    document.querySelectorAll('button.speak').forEach(function (b) {
      b.addEventListener('click', function () {
        try {
          if ('speechSynthesis' in window) { window.speechSynthesis.cancel();
            var u = new SpeechSynthesisUtterance(b.getAttribute('data-speak'));
            u.lang = b.getAttribute('data-lang') || 'en-IN'; u.rate = 0.85;
            window.speechSynthesis.speak(u);
          }
        } catch (_) {}
      });
    });
    var correctCount = 0;
    document.querySelectorAll('.question').forEach(function (q) {
      var answered = false;
      var correct = parseInt(q.getAttribute('data-correct'), 10);
      q.querySelectorAll('.qopt').forEach(function (b) {
        b.addEventListener('click', function () {
          if (answered) return;
          answered = true;
          var i = parseInt(b.getAttribute('data-i'), 10);
          if (i === correct) { b.classList.add('correct'); correctCount++; }
          else {
            b.classList.add('wrong');
            var c = q.querySelector('.qopt[data-i="' + correct + '"]'); if (c) c.classList.add('correct');
          }
          q.querySelectorAll('.qopt').forEach(function (x) { x.disabled = true; });
          // If all questions answered, finalize
          var qs = document.querySelectorAll('.question');
          var done = Array.from(qs).every(function (qq) { return qq.querySelectorAll('.qopt.correct, .qopt.wrong').length > 0; });
          if (done) {
            fetch('/api/aquintutor/story-complete', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ storyId: storyId, correct: correctCount, total: totalQs })})
              .then(function (r) { return r.json(); })
              .then(function (d) { document.getElementById('doneMsg').textContent = correctCount + '/' + totalQs + ' correct — +' + (d.xpAwarded || xpReward) + ' XP earned'; document.getElementById('done').style.display = 'flex'; });
          }
        });
      });
    });
  })();
  </script>
</body>
</html>
