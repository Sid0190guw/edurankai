---
// /aquintutor/credentials — a student's "my credentials" (Prompt 10, main surface). Lists the
// student's issued course credentials with a link to the PUBLIC verification page they can share.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { listUserCredentials, verifyRow } from '@/lib/credential';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/credentials');
const creds = await listUserCredentials(user.id).catch(() => []);
function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' }); } catch { return '-'; } }
const CARD = 'background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:14px;padding:20px 22px;margin-bottom:14px;';
---
<AquintutorLayout title="My credentials">
  <main style="max-width:760px;margin:0 auto;padding:44px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Credentials</p>
    <h1 style="font-family:Fraunces,serif;font-size:32px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 22px;line-height:1.15;">My credentials</h1>

    {creds.length === 0 ? (
      <div style={CARD}><p style="font-family:'Inter Tight',sans-serif;font-size:15px;color:#6b6455;margin:0;">You don't have any course credentials yet. Complete a course's required assessments and a coordinator can issue one — it will appear here with a shareable, publicly verifiable link.</p></div>
    ) : creds.map((c: any) => { const v = verifyRow(c); return (
      <div style={CARD}>
        <div style="display:flex;justify-content:space-between;align-items:baseline;gap:10px;flex-wrap:wrap;">
          <h2 style="font-family:Fraunces,serif;font-size:20px;font-weight:600;color:var(--ink,#1a1712);margin:0;">{c.course_title}</h2>
          <span style={'font-family:Inter Tight,sans-serif;font-size:11.5px;font-weight:700;border-radius:100px;padding:3px 11px;' + (c.revoked ? 'background:#fdecec;color:#9b2c2c;' : v.valid ? 'background:#eef8f1;color:#1f7a4d;' : 'background:#fdecec;color:#9b2c2c;')}>{c.revoked ? 'Revoked' : v.valid ? 'Verified' : 'Invalid'}</span>
        </div>
        <p style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#8a8478;margin:4px 0 14px;">Issued {fmt(c.issued_at)} · ID <b style="font-family:'Geist Mono',monospace;color:var(--ink,#1a1712);">{c.code}</b></p>
        <a href={'/credentials/course/' + c.code} style="display:inline-block;text-decoration:none;font-family:'Inter Tight',sans-serif;font-size:13.5px;font-weight:600;color:var(--ink,#1a1712);border:1px solid var(--ink,#1a1712);border-radius:8px;padding:9px 16px;">View public verification &rarr;</a>
      </div>
    ); })}
  </main>
</AquintutorLayout>
