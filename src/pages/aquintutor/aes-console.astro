---
// /aquintutor/aes-console — the AES engines, RUNNING. Every panel on this page
// executes a real, Node-tested algorithm core from the AES chapters, live in the
// browser, on input you control. Nothing here is a mockup or a canned string: the
// output you see is what the engine actually computed. This is the answer to
// "you built a library, not a system" — the library, made reachable and alive.
import AquinTutorLayout from '@/layouts/AquintutorLayout.astro';

const panels = [
  { id: 'consensus', chapter: 'Vol II · Ch42 — Distributed Consensus', name: 'Raft Consensus', proves: 'A minority cannot elect a leader or commit. Kill nodes and watch quorum refuse — the safety property that stops split-brain.', scope: 'The election/quorum/commit logic is real; the network transport between nodes is a declared substrate.' },
  { id: 'federated', chapter: 'Vol II · Ch — Federated Learning', name: 'Federated Averaging', proves: 'Two parties train a shared model without ever sharing their raw data. Each trains locally; only weights are averaged (FedAvg).', scope: 'The SGD training + weighted aggregation are real; secure aggregation crypto is a declared substrate.' },
  { id: 'search', chapter: 'Vol II · Ch — Retrieval', name: 'BM25 + RAG Retrieval', proves: 'Ranked lexical retrieval over real passages, then the grounded context a RAG answer would be built on. Type any query.', scope: 'Ranking + context assembly are real; the answer-generating LLM that consumes the context is a declared substrate.' },
  { id: 'db', chapter: 'Vol III · Ch — MVCC Database', name: 'Snapshot Isolation (MVCC)', proves: 'Two concurrent transactions write the same row. One commits; the other is aborted on a write-write conflict — optimistic concurrency, for real.', scope: 'Versioning + conflict detection are real; on-disk pages, WAL and fsync are declared substrates.' },
  { id: 'planetary', chapter: 'Vol III P3 · Ch11 — Planetary Education', name: 'Cross-System Credit Transfer', proves: 'A credential from one system is recognised (or not) by another, with grade + credits converted across GPA/ECTS and credit-hour systems.', scope: 'Recognition policy + equivalence math are real; cryptographic credential signing is a declared substrate.' },
  { id: 'dpi', chapter: 'Vol III P3 · Ch12 — Educational DPI', name: 'Delegated Trust + Once-Only', proves: 'Trust is a graph that decays along a chain; the engine finds the strongest path. And a verified record is reused only with consent.', scope: 'The trust-graph search + consent logic are real; inter-institution API transport is a declared substrate.' },
  { id: 'governance', chapter: 'Vol IV P2 · Ch85 — AI Governance', name: 'Fairness, Drift & Certification', proves: 'Toggle a biased vs balanced admissions model: the disparate-impact ratio (80% rule) flags the bias, PSI catches distribution drift, and the certification gate refuses to ship until controls + human approval are in place.', scope: 'Classification, fairness/PSI math, safety pipeline and gating are real; the underlying model and the human reviewers are declared substrates.' },
  { id: 'mlops', chapter: 'Vol IV P2 · Ch86 — MLOps', name: 'ROC-AUC + Promotion Gate', proves: 'Switch a model between separable and noisy scores: ROC-AUC (Mann-Whitney) recomputes for real, and the CI/CD gate only promotes a certified model that beats the deployed baseline.', scope: 'Versioning, metrics, search and gating are real; GPU training kernels and object storage are declared substrates.' },
  { id: 'feature', chapter: 'Vol IV P2 · Ch87 — Feature Store', name: 'Point-in-Time Correctness', proves: 'A learner GPA changes over time. Ask for it "as of" any timestamp — the store returns the value valid then, never a future one. That is what makes training/serving skew (label leakage) impossible.', scope: 'Registry, point-in-time join, skew/quality/lineage are real over an in-memory store; the distributed KV + warehouse are declared substrates.' },
];
---
<AquinTutorLayout title="AES Live Console">
  <main class="aes">
    <header class="aes-hd">
      <div class="tag">AES-100 · Live Console</div>
      <h1>The engines, running.</h1>
      <p class="lede">Every panel below executes a real, Node-tested algorithm core from the AES chapters &mdash; live, in your browser, on input you control. The output is what the engine actually computed. Nothing here is a mockup or a canned string.</p>
    </header>

    <section class="grid">
      {panels.map((p) => (
        <article class="card" data-panel={p.id}>
          <div class="ch">{p.chapter}</div>
          <h3>{p.name}</h3>
          <p class="pr">{p.proves}</p>
          <div class="ctl" id={`ctl-${p.id}`}></div>
          <button class="run" data-run={p.id}>Run</button>
          <pre class="out" id={`out-${p.id}`}>Press Run.</pre>
          <div class="sc">{p.scope}</div>
        </article>
      ))}
    </section>
  </main>

  <script src="/aquin-consensus.js" is:inline></script>
  <script src="/aquin-federated.js" is:inline></script>
  <script src="/aquin-search.js" is:inline></script>
  <script src="/aquin-db.js" is:inline></script>
  <script src="/aquin-planetary-edu.js" is:inline></script>
  <script src="/aquin-edu-dpi.js" is:inline></script>
  <script src="/aquin-ai-governance.js" is:inline></script>
  <script src="/aquin-mlops.js" is:inline></script>
  <script src="/aquin-feature-store.js" is:inline></script>
  <script is:inline>
  (function(){
    function out(id, o){ var el=document.getElementById('out-'+id); el.textContent = (typeof o==='string')? o : JSON.stringify(o, null, 2); }
    function missing(id, name){ out(id, 'Engine '+name+' did not load.'); }

    // ---- controls: build the interactive inputs for panels that need them ----
    // Consensus: five node up/down checkboxes
    var cc = document.getElementById('ctl-consensus');
    if (cc){ ['n1','n2','n3','n4','n5'].forEach(function(n){ var l=document.createElement('label'); l.className='chk'; l.innerHTML='<input type="checkbox" checked data-node="'+n+'"> '+n; cc.appendChild(l); }); }
    // Search: a free-text query box
    var sc = document.getElementById('ctl-search');
    if (sc){ sc.innerHTML='<input type="text" id="qbox" placeholder="e.g. why does pressure drop when flow speeds up" value="why does pressure drop when flow speeds up">'; }
    // Governance: biased vs balanced admissions model
    var gc = document.getElementById('ctl-governance');
    if (gc){ gc.innerHTML='<label class="chk"><input type="checkbox" id="biasBox" checked> use a biased model</label>'; }
    // MLOps: separable vs noisy scores
    var mc = document.getElementById('ctl-mlops');
    if (mc){ mc.innerHTML='<label class="chk"><input type="checkbox" id="sepBox" checked> separable scores</label>'; }
    // Feature store: "as of" timestamp
    var fc = document.getElementById('ctl-feature');
    if (fc){ fc.innerHTML='<input type="text" id="asOf" value="3000" style="width:120px"> <span style="font-size:11px;color:var(--aqt-ink3,#8a8178)">as-of time (GPA: 3.0@1000, 3.6@5000)</span>'; }

    var RUN = {
      consensus: function(){
        if(!window.AquinConsensus) return missing('consensus','AquinConsensus');
        var cl = AquinConsensus.createCluster({ nodes:['n1','n2','n3','n4','n5'] });
        var up = {}; document.querySelectorAll('#ctl-consensus input[data-node]').forEach(function(b){ up[b.getAttribute('data-node')]=b.checked; if(!b.checked) cl.setNodeUp(b.getAttribute('data-node'), false); });
        var liveIds = Object.keys(up).filter(function(k){return up[k];});
        var cand = liveIds[0] || 'n1';
        var elect = cl.elect(cand);
        var res = { up: liveIds.length+'/5', quorumNeeded: cl.quorum(), candidate: cand, election: elect };
        if (elect.ok){ res.commit = cl.propose({ set:'x=1' }); }
        out('consensus', res);
      },
      federated: function(){
        if(!window.AquinFederated) return missing('federated','AquinFederated');
        var fed = AquinFederated.createFederation({ dim:2 });
        fed.registerParticipant('clinicA', {}); fed.registerParticipant('clinicB', {});
        // Each clinic's OWN data — never pooled. Two linearly-separable sets.
        var A = [ {x:[2,1],y:1},{x:[3,2],y:1},{x:[2,2],y:1},{x:[-2,-1],y:0},{x:[-1,-2],y:0},{x:[-3,-2],y:0} ];
        var B = [ {x:[1,3],y:1},{x:[2,3],y:1},{x:[3,1],y:1},{x:[-3,-1],y:0},{x:[-2,-2],y:0},{x:[-1,-3],y:0} ];
        var agg = fed.round({ clinicA:A, clinicB:B }, { epochs:250, lr:0.3 });
        var test = [ {x:[2.5,1.5],y:1},{x:[1,2],y:1},{x:[-2,-2],y:0},{x:[-1,-1],y:0} ];
        out('federated', { aggregation: agg, globalAccuracyOnHeldOutTest: fed.evaluate(test), note: 'clinicA and clinicB raw rows never left either party — only weight vectors were averaged.' });
      },
      search: function(){
        if(!window.AquinSearch) return missing('search','AquinSearch');
        var idx = AquinSearch.createSearchIndex();
        idx.index('bernoulli', 'Bernoulli principle: as the velocity of a fluid increases, its pressure decreases along a streamline because total mechanical energy is conserved.');
        idx.index('continuity', 'Continuity equation: for an incompressible fluid the volume flow rate area times velocity is constant, so a narrower pipe forces higher speed.');
        idx.index('venturi', 'A Venturi meter narrows the pipe; the fluid speeds up at the throat and the pressure there drops, which is used to measure flow rate.');
        idx.index('pitot', 'A Pitot tube compares stagnation and static pressure to compute airspeed from the pressure difference.');
        idx.index('lift', 'Aerodynamic lift arises as air moves faster over the curved top of a wing, lowering pressure above relative to below.');
        var q = (document.getElementById('qbox')||{}).value || 'pressure velocity';
        var hits = idx.searchText(q, 3);
        var rag = idx.rag(q, null, { topK: 2 });
        out('search', { query:q, bm25Ranking: hits, ragContext: rag.context, note: rag.note });
      },
      db: function(){
        if(!window.AquinDB) return missing('db','AquinDB');
        var db = AquinDB.createDatabase(); db.createTable('acct', { pk:'id' });
        var t0 = db.begin(); db.put(t0,'acct','alice',{ id:'alice', bal:100 }); db.commit(t0);   // committed baseline
        var t1 = db.begin(), t2 = db.begin();                                                     // both snapshot the same version
        db.put(t1,'acct','alice',{ id:'alice', bal:120 }); var r1 = db.commit(t1);                // first writer wins
        db.put(t2,'acct','alice',{ id:'alice', bal:150 }); var r2 = db.commit(t2);                // second aborts on conflict
        out('db', { tx1_commit: r1, tx2_commit: r2, note: 'Both transactions read the same snapshot; the second is aborted so no lost update — snapshot isolation.' });
      },
      planetary: function(){
        if(!window.AquinPlanetaryEdu) return missing('planetary','AquinPlanetaryEdu');
        var net = AquinPlanetaryEdu.createNetwork();
        net.institution('inst-US', { country:'US', gradeSystem:'gpa4', creditSystem:'us', accreditation:'AccrX' });
        net.institution('inst-EU', { country:'DE', gradeSystem:'ects100', creditSystem:'ects', accreditation:'AccrY' });
        net.recognize('inst-EU', 'inst-US');
        var c = net.issueCredential('inst-US', 'learner-1', { type:'course', credits:3, grade:3.6 });
        out('planetary', { recognisedByEU: net.recognizedBy(c.id, 'inst-EU'), equivalence: net.equivalence(c.id, 'inst-EU'), mobility: net.mobility('learner-1', 'inst-EU') });
      },
      dpi: function(){
        if(!window.AquinEduDPI) return missing('dpi','AquinEduDPI');
        var dpi = AquinEduDPI.createDPI();
        // trust graph: national authority -> accreditor -> university -> provider (weights decay along the chain)
        dpi.trust('authority','accreditor',1).trust('accreditor','university',0.95).trust('university','provider',0.8);
        var path = dpi.trustPath('authority','provider');
        // once-only: a verified transcript reused across services, consent-gated
        dpi.registerService('svc-scholarship','service');
        dpi.submitRecord('rec-1','learner-1','transcript',{ gpa:3.6 },'accreditor');
        var denied = dpi.reuseRecord('rec-1','svc-scholarship');
        dpi.grantConsent('learner-1','svc-scholarship');
        var allowed = dpi.reuseRecord('rec-1','svc-scholarship');
        out('dpi', { strongestTrustPath: path, reuseWithoutConsent: denied, reuseWithConsent: allowed });
      },
      governance: function(){
        if(!window.AquinAIGovernance) return missing('governance','AquinAIGovernance');
        var g = AquinAIGovernance.createGovernor();
        var biased = (document.getElementById('biasBox')||{}).checked;
        // an admissions model's selection outcomes by group (biased vs balanced)
        var outcomes = biased
          ? { groupA:{positive:60,total:100,truePos:50,actualPos:60}, groupB:{positive:30,total:100,truePos:25,actualPos:40} }
          : { groupA:{positive:52,total:100,truePos:44,actualPos:50}, groupB:{positive:50,total:100,truePos:43,actualPos:50} };
        var fair = g.fairness(outcomes);
        var drift = g.psi([25,25,25,25], biased ? [5,10,35,50] : [24,26,25,25]);
        // certification gate on an admissions service (high risk)
        g.register('admissions-ai', { impacts:['admissions'], humanControlled:true });
        var beforeControls = g.certify('admissions-ai');
        ['audit','monitoring','explainability','human-review','fairness','certification'].forEach(function(c){ g.satisfyControl('admissions-ai', c, true); });
        g.approve('admissions-ai','dean');
        var afterControls = g.certify('admissions-ai');
        out('governance', { risk: g.service('admissions-ai').risk, fairness: fair, drift: drift, certificationBeforeControls: beforeControls, certificationAfterControls: afterControls });
      },
      mlops: function(){
        if(!window.AquinMLOps) return missing('mlops','AquinMLOps');
        var R = AquinMLOps.createRegistry();
        var separable = (document.getElementById('sepBox')||{}).checked;
        var rows = separable
          ? [{score:.92,label:1},{score:.81,label:1},{score:.74,label:1},{score:.33,label:0},{score:.19,label:0},{score:.08,label:0}]
          : [{score:.60,label:0},{score:.58,label:1},{score:.52,label:0},{score:.49,label:1},{score:.44,label:0},{score:.41,label:1}];
        var ds = R.registerDataset('applicants', rows);
        var m = R.registerModel({ id:'dropout-v1', domain:'dropout', algorithm:'logreg' });
        var metrics = R.attachEvaluation('dropout-v1', rows, 0.5);
        R.transition('dropout-v1','trained'); R.transition('dropout-v1','evaluated'); R.transition('dropout-v1','certified');
        var promote = R.promote('dropout-v1', metrics.f1);
        // a worse, certified challenger must be refused
        R.registerModel({ id:'dropout-v2', domain:'dropout' }); R.transition('dropout-v2','trained'); R.transition('dropout-v2','evaluated'); R.transition('dropout-v2','certified');
        var challenger = R.promote('dropout-v2', Math.max(0, metrics.f1 - 0.2));
        out('mlops', { dataset: ds, evaluation: metrics, promoteBest: promote, worseChallenger: challenger });
      },
      feature: function(){
        if(!window.AquinFeatureStore) return missing('feature','AquinFeatureStore');
        var S = AquinFeatureStore.createFeatureStore();
        S.registerFeature('gpa', { owner:'registrar', type:'numeric', sources:['grades'], transform:'avg', tags:['academic'] });
        S.push('gpa','stu1',3.0,1000); S.push('gpa','stu1',3.6,5000);
        var asOf = parseInt((document.getElementById('asOf')||{}).value,10); if(isNaN(asOf)) asOf=3000;
        out('feature', {
          online_latest: S.getOnline('stu1',['gpa']),
          historical_asOf: { asOf: asOf, value: S.getHistorical('stu1',['gpa'], asOf) },
          skew_vs_asOf: S.skew('stu1','gpa', asOf),
          quality: S.quality('gpa'),
          lineage: S.explain('gpa')
        });
      }
    };

    document.querySelectorAll('.run').forEach(function(btn){
      btn.addEventListener('click', function(){ var id=btn.getAttribute('data-run'); try{ RUN[id](); }catch(e){ out(id, 'Error: '+(e&&e.message?e.message:e)); } });
    });
    // enter-to-run in the search box
    var qb=document.getElementById('qbox'); if(qb) qb.addEventListener('keydown', function(e){ if(e.key==='Enter') RUN.search(); });
  })();
  </script>
</AquinTutorLayout>

<style>
  .aes{ max-width:1180px; margin:0 auto; padding:38px 20px 80px; }
  .aes-hd{ margin-bottom:26px; }
  .aes-hd .tag{ font:600 12px/1 var(--aqt-sans, system-ui); letter-spacing:.12em; text-transform:uppercase; color:var(--aqt-rust,#c65d3b); }
  .aes-hd h1{ font-family:var(--aqt-serif,'Fraunces',Georgia,serif); font-size:clamp(30px,5vw,46px); line-height:1.05; margin:.28em 0 .3em; color:var(--aqt-ink,#211d1a); }
  .aes-hd .lede{ max-width:64ch; color:var(--aqt-ink2,#5b534c); font:400 16px/1.55 var(--aqt-sans,system-ui); }
  .grid{ display:grid; grid-template-columns:repeat(auto-fit,minmax(330px,1fr)); gap:16px; }
  .card{ background:var(--aqt-paper,#fbf8f3); border:1px solid var(--aqt-line,#e6ded3); border-radius:14px; padding:18px 18px 16px; display:flex; flex-direction:column; }
  .card .ch{ font:600 11px/1 var(--aqt-sans,system-ui); letter-spacing:.06em; text-transform:uppercase; color:var(--aqt-rust,#c65d3b); opacity:.9; }
  .card h3{ font-family:var(--aqt-serif,'Fraunces',Georgia,serif); font-size:21px; margin:.35em 0 .3em; color:var(--aqt-ink,#211d1a); }
  .card .pr{ font:400 13.5px/1.5 var(--aqt-sans,system-ui); color:var(--aqt-ink2,#5b534c); margin:0 0 12px; }
  .ctl{ display:flex; flex-wrap:wrap; gap:8px; margin-bottom:10px; }
  .ctl .chk{ font:500 13px/1 var(--aqt-sans,system-ui); color:var(--aqt-ink,#211d1a); display:inline-flex; align-items:center; gap:5px; padding:5px 9px; border:1px solid var(--aqt-line,#e6ded3); border-radius:7px; cursor:pointer; }
  .ctl input[type=text]{ width:100%; font:400 14px/1.4 var(--aqt-sans,system-ui); padding:9px 11px; border:1px solid var(--aqt-line,#e6ded3); border-radius:8px; background:#fff; color:var(--aqt-ink,#211d1a); }
  .run{ align-self:flex-start; font:600 13px/1 var(--aqt-sans,system-ui); color:#fff; background:var(--aqt-rust,#c65d3b); border:none; border-radius:8px; padding:9px 18px; cursor:pointer; }
  .run:hover{ filter:brightness(1.07); }
  .out{ margin:12px 0 10px; background:#221f1c; color:#e9e2d6; border-radius:10px; padding:12px 13px; font:500 12px/1.5 ui-monospace,'JetBrains Mono',Menlo,monospace; overflow:auto; max-height:340px; white-space:pre-wrap; word-break:break-word; }
  .sc{ font:400 11.5px/1.45 var(--aqt-sans,system-ui); color:var(--aqt-ink3,#8a8178); border-top:1px dashed var(--aqt-line,#e6ded3); padding-top:9px; margin-top:auto; }
  @media (max-width:520px){ .aes{ padding:24px 14px 60px; } .grid{ grid-template-columns:1fr; } }
</style>
