---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

let counts = { schools: 0, departments: 0, courses: 0, lessons: 0, faculty: 0, paths: 0 };
try {
  const r = await db.execute(sql`
    SELECT
      (SELECT COUNT(*)::int FROM training_schools) as schools,
      (SELECT COUNT(*)::int FROM academic_departments) as departments,
      (SELECT COUNT(*)::int FROM training_courses WHERE is_published = true) as courses,
      (SELECT COUNT(*)::int FROM training_lessons) as lessons,
      (SELECT COUNT(*)::int FROM training_instructors WHERE is_active = true) as faculty,
      (SELECT COUNT(*)::int FROM training_paths WHERE is_published = true) as paths
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  if (rows[0]) counts = rows[0] as any;
} catch (_) {}

const milestones = [
  {
    period: 'Trimester I, 2026',
    status: 'shipped',
    label: 'Shipped',
    title: 'Foundations of the virtual university',
    items: [
      'Six schools and ' + counts.departments + ' academic departments named and chartered.',
      counts.courses + ' courses published, ' + counts.lessons + ' lessons authored across the catalogue.',
      'AquinTutor sign-in and Apply pages live at one Swiss franc minimum.',
      'ATLAS proctored examinations with text-only event logging.',
      'Verifiable credentials at /credentials/[number].',
    ],
  },
  {
    period: 'Trimester II, 2026',
    status: 'underway',
    label: 'Underway',
    title: 'Voice, vision and faculty presence',
    items: [
      'AI-conducted screening interviews in 17 languages with live transcript.',
      'Face and microphone proctoring during examinations - text events only, no media stored.',
      'Faculty pages with named research interests and office hours.',
      'Programme-level roadmaps with prerequisite trees.',
    ],
  },
  {
    period: 'Trimester III, 2026',
    status: 'planned',
    label: 'Planned',
    title: 'Tutorial week and grading panels',
    items: [
      'Live tutorial week: synchronous office hours in cohorts of ten, transcribed automatically.',
      'Two-marker grading on long-form answers with reconciliation panel.',
      'Honour code dossier issued alongside each credential.',
      'Outbound transcripts in PDF for institutional partners.',
    ],
  },
  {
    period: 'Trimester IV, 2026',
    status: 'planned',
    label: 'Planned',
    title: 'Research and named scholarships',
    items: [
      'Independent study contracts with a named faculty supervisor.',
      'Two annual scholarship rounds funded from credential fees.',
      'Open research notes published under a permissive licence.',
      'Public assembly twice a year, archived.',
    ],
  },
  {
    period: '2027',
    status: 'horizon',
    label: 'Horizon',
    title: 'Recognition and partnership',
    items: [
      'Articulation agreements with credit-bearing institutions.',
      'Open accreditation review with published evidence binder.',
      'Endowed chairs in mathematics, computer science and liberal arts.',
    ],
  },
];

function chip(status: string) {
  if (status === 'shipped') return 'background:rgba(125,211,168,0.18); color:#3f8a64; border:1px solid #7dd3a8;';
  if (status === 'underway') return 'background:rgba(160,66,30,0.10); color:var(--rust); border:1px solid rgba(160,66,30,0.3);';
  if (status === 'planned') return 'background:var(--sand-100); color:var(--ink-500); border:1px solid var(--rule);';
  return 'background:transparent; color:var(--ink-500); border:1px dashed var(--rule);';
}
---
<AquintutorLayout title="Roadmap" description="A standing record of what AquinTutor has shipped, what is underway, and what is planned across the next four trimesters.">

  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1024px; margin:0 auto; padding:80px 28px 48px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); font-weight:600; letter-spacing:0.04em; margin:0 0 14px;">Institutional roadmap</p>
      <h1 class="font-display" style="font-size:clamp(2.25rem, 5vw, 3.75rem); line-height:1.05; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--ink); max-width:42rem;">What we have shipped. What is next.</h1>
      <p style="font-family:'Inter Tight',sans-serif; font-size:clamp(1.05rem, 1.4vw, 1.2rem); line-height:1.6; color:var(--ink-500); margin:22px 0 0; max-width:40rem;">A working institution earns trust by saying out loud what it intends to build, by what date, and at what fidelity. This page is updated each trimester.</p>
    </div>
  </section>

  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1024px; margin:0 auto; padding:40px 28px;">
      <div style="display:grid; grid-template-columns:repeat(2, 1fr); gap:16px;" class="roadmap-stats">
        {[
          { l: 'Schools', v: counts.schools },
          { l: 'Departments', v: counts.departments },
          { l: 'Courses', v: counts.courses },
          { l: 'Lessons', v: counts.lessons },
          { l: 'Faculty', v: counts.faculty },
          { l: 'Programmes', v: counts.paths },
        ].map((s) => (
          <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:18px 20px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">{s.l}</p>
            <p class="font-display" style="font-size:1.85rem; font-weight:500; margin:0; line-height:1; color:var(--ink); letter-spacing:-0.02em;">{s.v}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div style="max-width:1024px; margin:0 auto; padding:64px 28px 80px;">
      <div style="display:flex; flex-direction:column; gap:32px;">
        {milestones.map((m, idx) => (
          <article style="display:grid; grid-template-columns:1fr; gap:18px; padding:28px; background:var(--paper); border:1px solid var(--rule); border-radius:14px;" class="milestone">
            <div style="display:flex; gap:14px; align-items:center; flex-wrap:wrap;">
              <span style={'display:inline-flex; align-items:center; gap:6px; padding:5px 12px; border-radius:999px; font-family:Inter Tight,sans-serif; font-size:11.5px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; ' + chip(m.status)}>{m.label}</span>
              <p style="font-family:'JetBrains Mono',monospace; font-size:12.5px; color:var(--ink-500); margin:0; letter-spacing:0.04em;">{m.period}</p>
            </div>
            <h2 class="font-display" style="font-size:clamp(1.4rem, 2.5vw, 1.85rem); font-weight:500; line-height:1.2; letter-spacing:-0.015em; margin:0; color:var(--ink);">{m.title}</h2>
            <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:10px;">
              {m.items.map((it) => (
                <li style="font-family:'Inter Tight',sans-serif; font-size:15px; line-height:1.6; color:var(--ink-500); padding-left:18px; position:relative;">
                  <span style="position:absolute; left:0; top:10px; width:6px; height:6px; border-radius:50%; background:var(--rust);"></span>
                  {it}
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section style="border-top:1px solid var(--rule); background:var(--ink); color:var(--sand-50);">
    <div style="max-width:1024px; margin:0 auto; padding:64px 28px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:rgba(251,250,244,0.65); font-weight:600; letter-spacing:0.04em; margin:0 0 14px;">Direct correspondence</p>
      <h2 class="font-display" style="font-size:clamp(1.6rem, 3vw, 2.25rem); line-height:1.2; letter-spacing:-0.02em; font-weight:500; margin:0 0 16px; max-width:36rem;">If a line in the roadmap matters to you, write to us.</h2>
      <p style="font-family:'Inter Tight',sans-serif; font-size:15.5px; line-height:1.65; color:rgba(251,250,244,0.75); margin:0 0 24px; max-width:34rem;">Stakeholders, prospective faculty, and institutional partners can reach the registrar at <a href="mailto:hr@edurankai.in" style="color:var(--sand-50); text-decoration:underline;">hr@edurankai.in</a>. We answer within five working days.</p>
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <a href="/aquintutor/about" style="background:var(--sand-50); color:var(--ink); padding:13px 22px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">About AquinTutor</a>
        <a href="/aquintutor/courses" style="background:transparent; color:var(--sand-50); padding:13px 22px; border-radius:6px; border:1px solid rgba(251,250,244,0.4); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Browse the catalogue</a>
      </div>
    </div>
  </section>

  <style>
    @media (min-width: 640px) {
      .roadmap-stats { grid-template-columns: repeat(3, 1fr) !important; }
      .milestone { grid-template-columns: 1fr !important; }
    }
    @media (min-width: 900px) {
      .roadmap-stats { grid-template-columns: repeat(6, 1fr) !important; }
    }
  </style>
</AquintutorLayout>
