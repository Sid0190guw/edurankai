  { dist: 'LABS',      chip: 'Surgery',      title: 'Laparoscopic appendectomy · 4 stations open',   meta: 'Faculty supervising', age: '4 min',  tone: '#a04330' },
  { dist: 'LANGUAGE',  chip: 'Exchange',     title: 'Sanskrit ↔ English conversation circle',        meta: '6 native partners',  age: '2 min',  tone: '#5b4a92' },
  { dist: 'LANGUAGE',  chip: 'Exchange',     title: 'Hindi ↔ English conversation circle',           meta: '9 native partners',  age: '4 min',  tone: '#a8472c' },
  { dist: 'LANGUAGE',  chip: 'Exchange',     title: 'Mandarin ↔ English conversation circle',        meta: '7 native partners',  age: '6 min',  tone: '#a8472c' },
