const districts = [
  { slug: 'halls',            code: 'HALLS', name: 'Holographic Halls',     tag: 'Volumetric lectures · 24 venues · 12k seats',           tone: '#5b4a92', live: 9,  facilities: ['Volumetric capture', 'Spatial Q&A', 'Replay in VR', 'Heatmap attention'] },
  { slug: 'labs',             code: 'LABS',  name: 'Virtual Labs',          tag: '412 simulators · wet, dry, surgical, fabrication',      tone: '#2b577e', live: 31, facilities: ['Physics & chemistry', 'Surgical procedures', 'CAD/CAM benches', 'Quantum sandbox'] },
  { slug: 'forge',            code: 'FORGE', name: 'The Forge',             tag: 'Operate real CNC, printers, robotic arms remotely',     tone: '#946322', live: 6,  facilities: ['18 mill suites', '6 print farms', 'UR5 + Franka arms', 'Materials shipped'] },
  { slug: 'library-archives', code: 'LIB',   name: 'Library & Archives',    tag: '4.2M sources · papers, datasets, Vedic primaries',      tone: '#3d352a', live: 24, facilities: ['Peer-reviewed catalogue', 'Primary text archive', 'Datasets · 47k', 'Patent index'] },
  { slug: 'test-centres',     code: 'TESTS', name: 'Test Centres',          tag: '148 systems · proctored, adaptive, fair',               tone: '#3b5675', live: 18, facilities: ['Language proficiency', 'Entrance examinations', 'Professional licensure', 'Adaptive practice'] },
  { slug: 'cultural',         code: 'CULT',  name: 'Cultural Pavilions',    tag: 'Museum residencies · archaeological VR · concerts',     tone: '#a04330', live: 8,  facilities: ['Heritage VR walks', 'Live performance', 'Curator talks', 'Residency rotations'] },
  { slug: 'language-houses',  code: 'LANG',  name: 'Language Houses',       tag: '92 traditions · 24-hour conversation circles',          tone: '#a8472c', live: 14, facilities: ['Native circles', 'Kitchen modules', 'Cinema nights', 'Slang exchange'] },
  { slug: 'wellness',         code: 'WELL',  name: 'Wellness Quarter',      tag: 'Counsel · yoga · sport · sleep · esports',              tone: '#4a7048', live: 7,  facilities: ['Counselling 1:1', 'Daily yoga', 'Sleep coaching', 'Athletic clubs'] },
  { slug: 'commons',          code: 'COMM',  name: 'Student Commons',       tag: 'Clubs · dining · open mic · coffee matching',           tone: '#a87526', live: 22, facilities: ['340+ student clubs', 'Daily café matches', 'Film + open mic', 'Dorm-style circles'] },
  { slug: 'research-commons', code: 'RES',   name: 'Research Commons',      tag: '2,400 labs · 3,200 graduates · weekly seminars',         tone: '#8a486b', live: 11, facilities: ['Lab rotations', 'Seminar series', 'Pre-print exchange', 'Grant clinics'] },
];

const culturalAnchors = [
  { region: 'Bharat',   tone: '#a04330', traditions: ['Sanskrit grammar circle', 'Hindustani classical evening', 'Kalaripayattu live class', 'Temple-architecture VR walk'] },
  { region: 'East Asia', tone: '#3b5675', traditions: ['Tea ceremony residency', 'Calligraphy clinic', 'Noh theatre archive', 'Beijing alley field-walk'] },
  { region: 'Europe',   tone: '#5b4a92', traditions: ['Vermeer reading room', 'Baroque chamber recital', 'Latin philology table', 'Alpine cartography studio'] },
  { region: 'Africa',   tone: '#a87526', traditions: ['Yoruba drumming circle', 'Nubian textile lab', 'Swahili poetry slam', 'Sahel astronomy night'] },
  { region: 'Americas', tone: '#946322', traditions: ['Andean weaving studio', 'Jazz improvisation seminar', 'Mesoamerican codex room', 'Appalachian fiddle session'] },
  { region: 'Pacific',  tone: '#4a7048', traditions: ['Polynesian navigation lab', 'Maori carving residency', 'Reef ecology dive sim', 'Wayfinding star chart'] },
];

const infra = [
  { code: 'CAPTURE', title: 'Holographic capture rigs', body: 'Sixty-four-camera volumetric studios in three regions feed every hall lecture. Depth-accurate, 90 fps, replayable from any seat.' },
  { code: 'GPU',     title: 'GPU pool · 4,096 accelerators', body: 'Burst-capable compute scheduled district-by-district. Notebooks request seconds; jobs request hours. Fair-share queueing.' },
  { code: 'EDGE',    title: 'Edge nodes · 142 cities',       body: 'Tutorial latency targets twenty-eight milliseconds end-to-end. Cache, render, and codec close to the learner.' },
  { code: 'RENDER',  title: 'Render farms · 8 sites',         body: 'On-demand scene baking for Aquin diagrams, archaeological reconstructions, and physics visualisations. Queue depth public.' },
  { code: 'TELEOP',  title: 'Tele-op latency · sub-28 ms',    body: 'Forge tele-operations run on a deterministic transport with frame-correlated haptic feedback. You feel the chuck bite.' },
  { code: 'PRIVACY', title: 'On-device privacy',              body: 'Camera, microphone, and gaze stay on the learner device by default. Aggregated signals only; raw video never leaves your machine without consent.' },
];

const cityList = ['Bengaluru', 'Mumbai', 'Pune', 'Hyderabad', 'Delhi', 'Chennai', 'Kolkata', 'Singapore', 'Tokyo', 'Seoul', 'Hong Kong', 'London', 'Berlin', 'Zurich', 'Paris', 'Amsterdam', 'Dubai', 'Lagos', 'Cape Town', 'Nairobi', 'Sao Paulo', 'Mexico City', 'New York', 'Toronto', 'Sydney'];

// Booking time slots (next 7 days, mornings + afternoons)
function dateLabel(addDays: number) {
  const d = new Date();
  d.setDate(d.getDate() + addDays);
  return d.toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', weekday: 'short', month: 'short', day: 'numeric' });
}
const tourSlots = [
  { d: dateLabel(1), t: '09:00 IST', guide: 'Second-year, Computer Science', district: 'halls + labs' },
  { d: dateLabel(1), t: '15:30 IST', guide: 'Final-year, Biomedical Engg.',   district: 'labs + research' },
  { d: dateLabel(2), t: '11:00 IST', guide: 'First-year, Liberal Arts',       district: 'cultural + lang' },
  { d: dateLabel(2), t: '18:00 IST', guide: 'Graduate fellow, Physics',       district: 'research + halls' },
  { d: dateLabel(3), t: '08:30 IST', guide: 'Third-year, Mechanical Engg.',   district: 'forge + labs' },
  { d: dateLabel(3), t: '16:00 IST', guide: 'Second-year, Sanskrit Studies',  district: 'library + cultural' },
  { d: dateLabel(4), t: '10:00 IST', guide: 'Final-year, Architecture',       district: 'cultural + commons' },
  { d: dateLabel(5), t: '14:00 IST', guide: 'First-year, Pre-Med',            district: 'labs + wellness' },
];
---
<AquintutorLayout title="Virtual campus" description="AquinTutor's virtual campus across ten districts — holographic halls, virtual labs, the Forge, language houses, cultural pavilions, and a research commons that never closes.">

<style>
  :root { --ink:#0E0B08; --paper:#FAF8F5; --rust:#FF4F00; --mute:#7A6F68; --line:rgba(14,11,8,0.10); }
  body { background:#FAF8F5; color:#0E0B08; }
  main { background:#FAF8F5; }

  .crumb { max-width:1280px; margin:0 auto; padding:20px 5vw 0; font-family:'Geist Mono','SF Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#7A6F68; }
  .crumb a { color:#7A6F68; text-decoration:none; }
  .crumb a:hover { color:#FF4F00; }
  .crumb .sep { margin:0 8px; opacity:0.5; }

  .hero { max-width:1280px; margin:0 auto; padding:60px 5vw 40px; }
  .eyebrow { font-family:'Geist Mono','SF Mono',monospace; font-size:11.5px; letter-spacing:0.18em; text-transform:uppercase; color:#FF4F00; font-weight:700; }
  .h-title { font-family:'Cormorant Garamond','Fraunces',serif; font-size:clamp(40px,7vw,84px); font-weight:600; letter-spacing:-0.035em; line-height:1.02; margin:14px 0 18px; }
  .h-title em { font-style:italic; color:#FF4F00; font-weight:500; }
  .h-sub { font-size:17px; color:#2E2520; max-width:720px; line-height:1.7; }
  .h-actions { display:flex; gap:14px; margin-top:26px; flex-wrap:wrap; }
  .btn-primary { background:#FF4F00; color:#fff; padding:14px 28px; border-radius:10px; font-family:'Geist Mono','SF Mono',monospace; font-size:12px; letter-spacing:0.08em; text-transform:uppercase; font-weight:800; text-decoration:none; border:none; cursor:pointer; display:inline-flex; align-items:center; gap:8px; }
  .btn-primary:hover { background:#e64500; }
  .btn-ghost { background:transparent; color:#0E0B08; padding:13px 26px; border-radius:10px; font-family:'Geist Mono','SF Mono',monospace; font-size:12px; letter-spacing:0.08em; text-transform:uppercase; font-weight:800; text-decoration:none; border:1px solid rgba(14,11,8,0.22); display:inline-flex; align-items:center; gap:8px; }
  .btn-ghost:hover { border-color:#0E0B08; }

  .strip { max-width:1280px; margin:0 auto; padding:32px 5vw; border-top:1px solid var(--line); border-bottom:1px solid var(--line); display:grid; grid-template-columns:repeat(6,1fr); gap:24px; }
  .stat-val { font-family:'Cormorant Garamond',serif; font-size:30px; line-height:1; }
  .stat-lbl { font-family:'Geist Mono',monospace; font-size:10.5px; letter-spacing:0.1em; text-transform:uppercase; color:#7A6F68; margin-top:8px; }
  @media (max-width:900px){ .strip { grid-template-columns:repeat(2,1fr); } }

  section.block { max-width:1280px; margin:0 auto; padding:64px 5vw; border-bottom:1px solid var(--line); }
  .sec-head { display:flex; align-items:flex-end; justify-content:space-between; gap:24px; margin-bottom:28px; flex-wrap:wrap; }
  .sec-eye { font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:#FF4F00; font-weight:700; }
  .sec-title { font-family:'Cormorant Garamond',serif; font-size:clamp(28px,4.4vw,46px); font-weight:600; letter-spacing:-0.025em; line-height:1.04; margin-top:10px; }
  .sec-title em { color:#FF4F00; font-style:italic; font-weight:500; }
  .sec-sub { font-size:15px; color:#2E2520; max-width:640px; line-height:1.7; margin-top:10px; }

  /* LIVE strip */
  .live-wrap { position:relative; }
  .live-rail { display:flex; gap:14px; overflow-x:auto; padding:4px 4px 18px; scroll-snap-type:x mandatory; -webkit-overflow-scrolling:touch; }
  .live-rail::-webkit-scrollbar { height:6px; }
  .live-rail::-webkit-scrollbar-track { background:transparent; }
  .live-rail::-webkit-scrollbar-thumb { background:rgba(14,11,8,0.15); border-radius:4px; }
  .live-card { flex:0 0 320px; scroll-snap-align:start; background:#fff; border:1px solid rgba(14,11,8,0.10); border-radius:14px; padding:20px; display:flex; flex-direction:column; gap:10px; }
  .live-top { display:flex; align-items:center; gap:8px; justify-content:space-between; }
  .live-dist { display:inline-flex; align-items:center; gap:6px; font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.14em; text-transform:uppercase; color:#fff; padding:4px 8px; border-radius:5px; font-weight:700; }
  .live-pulse { width:7px; height:7px; border-radius:50%; background:#FF4F00; box-shadow:0 0 0 0 rgba(255,79,0,0.6); animation: pulse 1.8s infinite; }
  @keyframes pulse { 0%{ box-shadow:0 0 0 0 rgba(255,79,0,0.6);} 70%{ box-shadow:0 0 0 9px rgba(255,79,0,0);} 100%{ box-shadow:0 0 0 0 rgba(255,79,0,0);} }
  .live-chip { font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:#0E0B08; background:#F1ECE4; padding:4px 8px; border-radius:5px; }
  .live-title { font-family:'Cormorant Garamond',serif; font-size:19px; line-height:1.28; letter-spacing:-0.012em; color:#0E0B08; }
  .live-meta { font-size:13px; color:#2E2520; line-height:1.5; }
  .live-foot { display:flex; justify-content:space-between; align-items:center; margin-top:6px; }
  .live-age { font-family:'Geist Mono',monospace; font-size:11px; color:#7A6F68; }
  .live-join { font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.08em; text-transform:uppercase; font-weight:800; color:#FF4F00; text-decoration:none; }
  .live-join:hover { text-decoration:underline; }
  .rail-arrows { position:absolute; top:-46px; right:0; display:flex; gap:6px; }
  .rail-btn { width:36px; height:36px; border-radius:50%; border:1px solid rgba(14,11,8,0.22); background:#fff; display:flex; align-items:center; justify-content:center; cursor:pointer; color:#0E0B08; }
  .rail-btn:hover { border-color:#0E0B08; }

  /* MAP */
  .map-frame { background:#fff; border:1px solid rgba(14,11,8,0.10); border-radius:18px; padding:16px; overflow:hidden; position:relative; }
  .map-frame svg { display:block; width:100%; height:auto; max-height:720px; }
  .map-legend { display:flex; flex-wrap:wrap; gap:10px 16px; margin-top:14px; padding:10px 4px 4px; border-top:1px solid var(--line); }
  .legend-item { display:flex; align-items:center; gap:8px; font-family:'Geist Mono',monospace; font-size:10.5px; letter-spacing:0.06em; text-transform:uppercase; color:#2E2520; }
  .legend-dot { width:11px; height:11px; border-radius:3px; }
  .map-popover { position:absolute; pointer-events:none; background:#0E0B08; color:#fff; padding:10px 14px; border-radius:8px; font-family:'Inter Tight',sans-serif; font-size:13px; line-height:1.45; opacity:0; transform:translate(-50%,-110%); transition:opacity 0.12s ease; max-width:240px; box-shadow:0 8px 24px rgba(0,0,0,0.18); }
  .map-popover strong { display:block; font-family:'Cormorant Garamond',serif; font-size:16px; font-weight:600; }
  .map-popover .pp-meta { font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:#FF4F00; margin-top:4px; }

  /* DISTRICT GRID */
  .grid-dist { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:18px; }
  .dist-card { background:#fff; border:1px solid rgba(14,11,8,0.10); border-radius:14px; padding:22px; position:relative; transition:transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease; text-decoration:none; color:inherit; display:flex; flex-direction:column; }
  .dist-card:hover { transform:translateY(-3px); box-shadow:0 14px 36px rgba(14,11,8,0.08); border-color:rgba(14,11,8,0.22); }
  .dist-band { position:absolute; left:0; right:0; top:0; height:4px; border-top-left-radius:14px; border-top-right-radius:14px; }
  .dist-code { font-family:'Geist Mono',monospace; font-size:10.5px; letter-spacing:0.14em; text-transform:uppercase; color:#7A6F68; margin-top:6px; }
  .dist-name { font-family:'Cormorant Garamond',serif; font-size:26px; line-height:1.1; margin:6px 0 6px; letter-spacing:-0.02em; }
  .dist-tag { font-size:13.5px; color:#2E2520; line-height:1.55; min-height:46px; }
  .dist-live { display:inline-flex; align-items:center; gap:7px; font-family:'Geist Mono',monospace; font-size:10.5px; letter-spacing:0.1em; text-transform:uppercase; color:#0E0B08; background:#F1ECE4; padding:5px 9px; border-radius:6px; align-self:flex-start; margin:12px 0 14px; }
  .dist-live-dot { width:7px; height:7px; border-radius:50%; background:#FF4F00; box-shadow:0 0 0 0 rgba(255,79,0,0.6); animation: pulse 1.8s infinite; }
  .dist-bullets { list-style:none; padding:0; margin:0 0 18px; display:grid; grid-template-columns:1fr 1fr; gap:6px 14px; }
  .dist-bullets li { font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.04em; color:#0E0B08; padding-left:14px; position:relative; }
  .dist-bullets li::before { content:''; position:absolute; left:0; top:7px; width:6px; height:6px; background:#FF4F00; border-radius:1px; }
  .dist-cta { font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.1em; text-transform:uppercase; font-weight:800; color:#FF4F00; display:inline-flex; align-items:center; gap:6px; margin-top:auto; }

  /* CULTURAL */
  .grid-cult { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:18px; }
  .cult-card { background:#fff; border:1px solid rgba(14,11,8,0.10); border-radius:14px; padding:22px; }
  .cult-band { width:34px; height:4px; border-radius:2px; margin-bottom:14px; }
  .cult-region { font-family:'Cormorant Garamond',serif; font-size:28px; letter-spacing:-0.025em; line-height:1.05; }
  .cult-list { list-style:none; padding:0; margin:16px 0 0; display:flex; flex-direction:column; gap:8px; }
  .cult-list li { display:flex; align-items:flex-start; gap:10px; font-size:13.5px; color:#2E2520; line-height:1.55; }
  .cult-list li svg { flex:0 0 18px; margin-top:2px; color:#FF4F00; }

  /* INFRA */
  .grid-infra { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:18px; }
  .infra-card { background:#fff; border:1px solid rgba(14,11,8,0.10); border-radius:14px; padding:22px; }
  .infra-code { font-family:'Geist Mono',monospace; font-size:10.5px; letter-spacing:0.14em; text-transform:uppercase; color:#FF4F00; font-weight:700; }
  .infra-title { font-family:'Cormorant Garamond',serif; font-size:24px; letter-spacing:-0.02em; line-height:1.15; margin:8px 0 10px; }
  .infra-body { font-size:14px; color:#2E2520; line-height:1.6; }
  .infra-icon { width:38px; height:38px; border-radius:9px; background:#F1ECE4; display:flex; align-items:center; justify-content:center; color:#0E0B08; margin-bottom:14px; }

  /* TOUR */
  .tour { display:grid; grid-template-columns:1.1fr 1fr; gap:32px; align-items:start; }
  @media (max-width:980px){ .tour { grid-template-columns:1fr; } }
  .tour-panel { background:#fff; border:1px solid rgba(14,11,8,0.10); border-radius:14px; padding:26px; }
  .tour-slots { display:grid; grid-template-columns:1fr; gap:8px; max-height:340px; overflow:auto; padding-right:6px; }
  .slot { display:grid; grid-template-columns:auto 1fr auto; align-items:center; gap:14px; padding:12px 14px; border:1px solid rgba(14,11,8,0.10); border-radius:10px; cursor:pointer; background:#fff; transition:border-color 0.15s ease, background 0.15s ease; }
  .slot:hover { border-color:#0E0B08; }
  .slot.selected { border-color:#FF4F00; background:#FFF6F0; }
  .slot-date { font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.06em; text-transform:uppercase; color:#0E0B08; }
  .slot-time { font-family:'Geist Mono',monospace; font-size:10.5px; color:#7A6F68; margin-top:2px; }
  .slot-meta { font-size:13px; color:#2E2520; line-height:1.4; }
  .slot-meta .guide { font-weight:600; color:#0E0B08; }
  .slot-pick { font-family:'Geist Mono',monospace; font-size:10.5px; letter-spacing:0.08em; text-transform:uppercase; color:#FF4F00; font-weight:800; }
  form.tour-form { display:flex; flex-direction:column; gap:14px; }
  .field { display:flex; flex-direction:column; gap:6px; }
  .field label { font-family:'Geist Mono',monospace; font-size:10.5px; letter-spacing:0.12em; text-transform:uppercase; color:#7A6F68; font-weight:700; }
  .field input, .field select, .field textarea { font-family:'Inter Tight',sans-serif; font-size:14px; padding:11px 13px; border:1px solid rgba(14,11,8,0.18); border-radius:9px; background:#fff; color:#0E0B08; }
  .field input:focus, .field select:focus, .field textarea:focus { outline:none; border-color:#FF4F00; box-shadow:0 0 0 3px rgba(255,79,0,0.12); }
  .tour-note { font-family:'Geist Mono',monospace; font-size:11px; letter-spacing:0.06em; color:#7A6F68; margin-top:6px; }

  /* SEARCH */
  .search-row { display:flex; gap:10px; align-items:center; background:#fff; border:1px solid rgba(14,11,8,0.14); border-radius:12px; padding:8px 10px; margin-bottom:18px; }
  .search-row input { flex:1; border:none; outline:none; font-family:'Inter Tight',sans-serif; font-size:15px; padding:8px; background:transparent; color:#0E0B08; }
  .search-tags { display:flex; gap:6px; flex-wrap:wrap; }
  .tag-btn { font-family:'Geist Mono',monospace; font-size:10.5px; letter-spacing:0.1em; text-transform:uppercase; padding:6px 10px; border-radius:6px; border:1px solid rgba(14,11,8,0.16); background:#fff; color:#0E0B08; cursor:pointer; }
  .tag-btn.active { background:#0E0B08; color:#fff; border-color:#0E0B08; }

  /* FOOTER nav */
  .foot-nav { display:flex; justify-content:space-between; align-items:center; gap:20px; padding:48px 5vw 64px; max-width:1280px; margin:0 auto; flex-wrap:wrap; }
  .foot-l { font-family:'Cormorant Garamond',serif; font-size:30px; letter-spacing:-0.02em; }
  .foot-l em { color:#FF4F00; font-style:italic; }
  .foot-r { display:flex; gap:12px; align-items:center; flex-wrap:wrap; }

  /* Calendar pill chips on tour */
  .pill { display:inline-flex; align-items:center; gap:6px; font-family:'Geist Mono',monospace; font-size:10.5px; letter-spacing:0.08em; text-transform:uppercase; color:#0E0B08; background:#F1ECE4; padding:5px 9px; border-radius:6px; }

  .marker-line { stroke:#FF4F00; stroke-width:1.2; stroke-dasharray:3 4; opacity:0.45; }
  .marker-dot circle { fill:#FF4F00; }

  .city-chip { display:inline-block; font-family:'Geist Mono',monospace; font-size:10.5px; letter-spacing:0.08em; text-transform:uppercase; color:#2E2520; background:#F1ECE4; padding:5px 9px; border-radius:6px; margin:3px 4px 0 0; }

  /* SVG district hover */
  .dist-shape { cursor:pointer; transition:filter 0.2s ease, transform 0.2s ease; transform-origin:center; transform-box:fill-box; }
  .dist-shape:hover { filter:brightness(1.06) drop-shadow(0 6px 18px rgba(14,11,8,0.18)); }
  .dist-label { font-family:'Cormorant Garamond',serif; font-size:15px; font-weight:600; fill:#fff; letter-spacing:-0.01em; pointer-events:none; }
  .dist-label-sub { font-family:'Geist Mono',monospace; font-size:8px; letter-spacing:0.12em; text-transform:uppercase; fill:rgba(255,255,255,0.78); pointer-events:none; }
  .map-grid line { stroke:rgba(14,11,8,0.06); stroke-width:0.5; }
  .compass { font-family:'Geist Mono',monospace; font-size:10px; fill:#7A6F68; letter-spacing:0.16em; }

  .form-status { font-family:'Geist Mono',monospace; font-size:11.5px; letter-spacing:0.06em; padding:10px 12px; border-radius:8px; }
  .form-status.ok { background:#F1F7EE; color:#3a6b2f; border:1px solid #c7e0bc; }
  .form-status.err { background:#FBEEEA; color:#a04330; border:1px solid #f0c8b8; }

  .quick-row { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:10px; margin-top:14px; }
  .quick-card { background:#fff; border:1px solid rgba(14,11,8,0.10); border-radius:10px; padding:14px; }
  .quick-k { font-family:'Geist Mono',monospace; font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:#7A6F68; }
  .quick-v { font-family:'Cormorant Garamond',serif; font-size:22px; letter-spacing:-0.02em; margin-top:6px; }
</style>

<main>

  <div class="crumb">
    <a href="/aquintutor">AquinTutor</a><span class="sep">/</span><span>Virtual campus</span>
  </div>

  <!-- HERO -->
  <section class="hero">
    <div class="eyebrow">AquinTutor · Virtual campus</div>
    <h1 class="h-title">A campus <em>without walls</em>.</h1>
    <p class="h-sub">
      Ten districts. Twenty-four-hour access from every time zone. Holographic, physical, and spatial layers braided together so a lecture, a surgical drill, a Sanskrit recitation, and a CNC tele-operation can all happen at the same minute, on the same campus, in ninety-two living traditions.
    </p>
    <div class="h-actions">
      <a href="#tour" class="btn-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
        Book a tour
      </a>
      <a href="#map" class="btn-ghost">
        <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M1 6l8-3 6 3 8-3v15l-8 3-6-3-8 3z"/><path d="M9 3v15M15 6v15"/></svg>
        Explore the map
      </a>
    </div>
  </section>

  <div class="strip">
    {stats.map(s => (
      <div>
        <div class="stat-val">{s.v}</div>
        <div class="stat-lbl">{s.l}</div>
      </div>
    ))}
  </div>

  <!-- LIVE NOW -->
  <section class="block">
    <div class="sec-head">
      <div>
        <div class="sec-eye">Live across campus · right now</div>
        <h2 class="sec-title">What is <em>happening</em> this minute.</h2>
        <p class="sec-sub">A real cross-section. Lectures, sims, language tandems, a CNC mill running in Pune. Click join to walk in — most sessions are open by default.</p>
      </div>
      <div class="rail-arrows">
        <button class="rail-btn" data-rail="left" aria-label="Scroll left">
          <svg width="16" height="16" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="rail-btn" data-rail="right" aria-label="Scroll right">
          <svg width="16" height="16" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
        </button>
      </div>
    </div>
    <div class="live-wrap">
      <div class="live-rail" id="liveRail">
        {liveNow.map(card => (
          <article class="live-card">
            <div class="live-top">
              <span class="live-dist" style={`background:${card.tone}`}>
                <span class="live-pulse"></span>{card.dist}
              </span>
              <span class="live-chip">{card.chip}</span>
            </div>
            <div class="live-title">{card.title}</div>
            <div class="live-meta">{card.meta}</div>
            <div class="live-foot">
              <span class="live-age">Started {card.age} ago</span>
              <a href="#" class="live-join">Join session →</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

