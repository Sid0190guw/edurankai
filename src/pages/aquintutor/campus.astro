---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

const capabilities = [
  ['24', 'holographic halls'],
  ['412', 'live simulators'],
  ['92', 'languages · cultural houses'],
  ['148', 'testing systems'],
  ['2.4M', 'lab hours run this year'],
  ['1', 'culture passport'],
];

const liveNow = [
  { icon: 'AR', label: 'Holographic lecture', what: 'General Relativity · Prof. Penrose-Hayes', meta: '2,140 attending · started 12 min ago', color: '#5b4a92' },
  { icon: 'VR', label: 'Surgical sim open', what: 'Laparoscopic appendectomy · 4 stations free', meta: 'Dr. Reema Khan supervising', color: '#a04330' },
  { icon: 'LX', label: 'Language exchange', what: 'JP ↔ EN circle starts in 3 min', meta: '5 native partners standing by', color: '#a8472c' },
  { icon: 'XR', label: 'VR field trip', what: 'Ajanta Caves with Acharya Sharma', meta: 'Departs 16:00 IST · 90 min · 18 spots', color: '#3b5675' },
  { icon: 'AI', label: 'Live simulator', what: 'Aquin generating diagrams in Quantum 4.3', meta: 'Class running · open to drop in', color: '#3d6b76' },
];

const districts = [
  { id: 'halls', x: 22, y: 28, w: 28, h: 22, color: '#5b4a92', label: 'Holographic Halls', sub: '24 venues · 12k seats' },
  { id: 'labs', x: 54, y: 18, w: 30, h: 18, color: '#2b577e', label: 'Virtual Labs', sub: '412 simulators' },
  { id: 'forge', x: 88, y: 22, w: 18, h: 14, color: '#946322', label: 'The Forge', sub: 'remote real equipment' },
  { id: 'library', x: 22, y: 56, w: 30, h: 18, color: '#a8472c', label: 'Library & Archives', sub: '4.2M sources' },
  { id: 'tests', x: 56, y: 42, w: 26, h: 14, color: '#3b5675', label: 'Test Centers', sub: '148 systems' },
  { id: 'cultural', x: 86, y: 42, w: 22, h: 18, color: '#a04330', label: 'Cultural Pavilions', sub: '92 traditions' },
  { id: 'lang', x: 56, y: 62, w: 26, h: 14, color: '#a8472c', label: 'Language Houses', sub: '92 native circles' },
  { id: 'wellness', x: 22, y: 80, w: 26, h: 12, color: '#4a7048', label: 'Wellness Quarter', sub: 'yoga · counsel · sport' },
  { id: 'commons', x: 54, y: 80, w: 28, h: 12, color: '#a87526', label: 'Student Commons', sub: 'clubs · dining · events' },
  { id: 'research', x: 86, y: 64, w: 22, h: 26, color: '#8a486b', label: 'Research Commons', sub: '2,400 labs · 3,200 grads' },
];

const facilities = [
  { id: 'halls', code: 'HALLS', color: '#5b4a92', icon: 'XR', title: 'Holographic Lecture Halls', tagline: 'AR/VR enabled · 24 venues · capacity 12,400', blurb: "Penrose-Hayes's general relativity lecture renders spacetime as a 3-D mesh around you. You walk through it. The professor sees a heatmap of where every student is looking.", bullets: ['Volumetric capture · live', 'Spatial Q&A - raise hand from your seat', 'Recorded with depth, replayable in VR'] },
  { id: 'labs', code: 'LABS', color: '#2b577e', icon: 'VL', title: 'Virtual Labs & Simulators', tagline: '412 simulators · wet, dry, surgical, fabrication', blurb: 'Run a chemistry experiment that would cost large amounts in reagents. Practice a laparoscopic appendectomy 200 times before your first cadaver. Build a Bloch playground for free.', bullets: ['Physics, Chem, Bio, EE, ME, CS', 'Surgical sims · 84 procedures', 'CAD/CAM · physically accurate'] },
  { id: 'forge', code: 'FORGE', color: '#946322', icon: 'FR', title: 'The Forge · remote real equipment', tagline: 'Operate physical 3D printers, CNC, robotic arms remotely', blurb: 'You write the G-code from anywhere. A CNC mill in our Pune workshop machines your part. It ships to your door in 72 hours. Real fabrication, no commute.', bullets: ['18 mill-suites · 6 print farms', 'UR5 + Franka arms for tele-op', 'Materials shipped to your door'] },
  { id: 'aquin', code: 'AQUIN', color: '#3d6b76', icon: 'AI', title: 'Real-time teaching co-pilot', tagline: 'Aquin generates diagrams, animations, & code mid-lecture', blurb: 'When Dr. Iyer says "let me show you what masked attention looks like," Aquin renders the matrix live. When you ask "what if n=64?", the figure reshapes in 200 ms.', bullets: ['Live diagram generation', 'On-demand 3D visualisations', 'Personal replay with your edits saved'] },
  { id: 'tests', code: 'EXAMS', color: '#3b5675', icon: 'TC', title: 'Test Centers · 148 systems', tagline: 'TOEFL · IELTS · JEE · NEET · MCAT · USMLE · Bar · CFA · 130+ more', blurb: 'Every credential a learner needs, proctored on ATLAS. Identity verified. Adaptive engine fair to every level. Results land before you close the tab.', bullets: ['Standardised: SAT · GRE · GMAT · MCAT · LSAT', 'India: JEE · NEET · CAT · UPSC · GATE', '92 language proficiency exams'] },
  { id: 'lang', code: 'LANG', color: '#a8472c', icon: 'LX', title: 'Language Houses · 92 traditions', tagline: 'Native speakers · 24-hour conversation circles', blurb: 'Every language has a "house" - a virtual space where native speakers, food, music, films, slang, and customs live together. You don\'t study Japanese. You move to Tokyo for three months without a visa.', bullets: ['Daily conversation circles', 'Cooking + literature + cinema modules', 'Cultural exchange partners'] },
  { id: 'cultural', code: 'CULT', color: '#a04330', icon: 'CP', title: 'Cultural Pavilions', tagline: 'Museum partnerships · archaeological VR · live performance', blurb: 'Walk the Ajanta caves with the curator. Sit in the Met during a midnight talk on Vermeer. Watch a Kathakali rehearsal from the wings. Cultural literacy as a side effect of being on campus.', bullets: ['Partners: Met · Louvre · CSMVS · Tate', 'VR archaeological reconstructions', 'Live performance · weekly residencies'] },
  { id: 'library', code: 'LIB', color: '#3d352a', icon: 'LB', title: 'Library & Archives', tagline: '4.2M sources · papers, books, datasets, Vedic primary texts', blurb: 'Whatever you might need to cite. Aquin will run a literature review while you make tea.', bullets: ['1.4M peer-reviewed papers', '8,400 Vedic primary sources', '47,000 datasets · 410,000 patents'] },
  { id: 'wellness', code: 'WELL', color: '#4a7048', icon: 'WL', title: 'Wellness Quarter', tagline: 'Counselling · meditation · yoga · sport · sleep', blurb: 'University is intense. Free, confidential counselling. Sunrise yoga from a Mysore studio. Sleep coaching from MIT-trained chronobiologists. We track wellness alongside grades.', bullets: ['Confidential 1:1 counselling', 'Daily yoga & meditation', 'Sports clubs · esports leagues'] },
  { id: 'commons', code: 'COMM', color: '#a87526', icon: 'SC', title: 'Student Commons', tagline: 'Clubs · dining · events · dorm circles · open mic', blurb: "The reason students remember college isn't the lectures. It's the 2 a.m. arguments. We built spaces for those too - debate clubs, code jams, film nights, virtual cafés that match you with three classmates over coffee.", bullets: ['340+ clubs · run by students', 'Daily coffee matching', 'Weekly open mic + film nights'] },
];

const testGroups = [
  { title: 'Languages', subtitle: '92 languages · proficiency, conversational, literary', color: '#a8472c', count: 96, examples: ['TOEFL iBT', 'IELTS', 'DELE Spanish', 'DELF / DALF', 'HSK Mandarin', 'JLPT'] },
  { title: 'Higher education entry', subtitle: 'SAT · ACT · GRE · GMAT · CLT · India: JEE · NEET · CAT · CLAT', color: '#3b5675', count: 32, examples: ['SAT', 'GRE General', 'GMAT', 'JEE Main + Advanced', 'NEET-UG', 'UCEED'] },
  { title: 'Professional licensure', subtitle: 'MCAT · USMLE · Bar · CFA · CPA · 28 more', color: '#5b4a92', count: 28, examples: ['MCAT', 'USMLE Step 1-3', 'Multistate Bar', 'CFA L1-L3', 'CPA Uniform', 'PMP'] },
];

const computeNodes = [
  { l: 'Holographic capture', v: '24', sub: 'volumetric stages live' },
  { l: 'GPU pool', v: '4,096', sub: 'A100/H100 equivalent' },
  { l: 'Edge nodes', v: '142', sub: 'in 36 countries' },
  { l: 'Render farms', v: '8', sub: '24×7 generative load' },
  { l: 'Tele-op latency', v: '<28ms', sub: '5G + fibre dual-path' },
  { l: 'Privacy', v: 'On-device', sub: 'no media bytes uploaded' },
];

const culturalAnchors = [
  { region: 'Bharat', items: ['Vedic chant chambers', 'Ajanta + Ellora VR', 'Kathak / Bharatanatyam', 'Sanskrit primary texts'] },
  { region: 'East Asia', items: ['Tea ceremony rooms', 'Tang poetry circle', 'Noh + Kabuki stages', 'Calligraphy studio'] },
  { region: 'Europe', items: ['Louvre · Met partnerships', 'Latin paleography', 'Baroque score readings', 'Cathedral acoustics'] },
  { region: 'Africa', items: ['Griot oral traditions', 'Benin bronze archive', 'Swahili poetry', 'Drumming circles'] },
  { region: 'Americas', items: ['Quipu reading', 'Aztec codex archive', 'Jazz improvisation lab', 'Indigenous languages'] },
  { region: 'Pacific', items: ['Polynesian navigation', 'Wayfinding star chart', 'Aboriginal art VR', 'Maori haka studio'] },
];
---
<AquintutorLayout title="Virtual campus" description="AquinTutor's virtual campus - holographic halls, AR/VR labs, the Forge, language houses, test centres, cultural pavilions, library and wellness quarter.">

  <!-- BREADCRUMB -->
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1400px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a>
      <span style="margin:0 8px;">/</span>
      <span style="color:var(--rust); font-weight:600;">VIRTUAL CAMPUS</span>
    </div>
  </div>

  <!-- HERO -->
  <section style="border-bottom:1px solid var(--rule); position:relative; overflow:hidden;">
    <div aria-hidden="true" style="position:absolute; top:-120px; right:-80px; width:480px; height:480px; border-radius:50%; background:radial-gradient(circle, rgba(91,74,146,0.22), transparent 65%); pointer-events:none;"></div>
    <div aria-hidden="true" style="position:absolute; bottom:-100px; left:200px; width:360px; height:360px; border-radius:50%; background:radial-gradient(circle, rgba(61,107,118,0.20), transparent 65%); pointer-events:none;"></div>
    <div style="max-width:1400px; margin:0 auto; padding:60px 28px 40px; position:relative; z-index:1;">
      <div style="display:flex; align-items:center; gap:14px; margin-bottom:20px; flex-wrap:wrap;">
        <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.22em; text-transform:uppercase; color:var(--ink-500);">The campus &middot; open now</span>
        <span style="width:4px; height:4px; border-radius:50%; background:var(--ink-300);"></span>
        <span style="display:inline-flex; align-items:center; gap:6px; padding:3px 11px; background:rgba(74,112,72,0.12); border:1px solid #4a7048; border-radius:999px;">
          <span style="width:6px; height:6px; border-radius:50%; background:#4a7048; box-shadow:0 0 5px #4a7048; animation:pulse 1.6s infinite;"></span>
          <span style="font-family:'JetBrains Mono',monospace; font-size:9.5px; letter-spacing:0.18em; text-transform:uppercase; color:#4a7048; font-weight:700;">14,820 inside right now</span>
        </span>
      </div>
      <h1 class="font-display" style="font-size:clamp(2.5rem, 6vw, 5rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--ink); max-width:54rem;">
        Your campus is <em style="color:var(--rust); font-weight:400;">everywhere</em>.
      </h1>
      <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.15rem, 1.5vw, 1.4rem); line-height:1.5; color:var(--ink-500); margin:24px 0 0; max-width:48rem;">
        Holographic lecture halls. AR/VR labs that wire up to real instruments. Simulators that generate the diagram while the professor is speaking. Ninety-two language houses with native partners. Test centres for every credential on Earth.
      </p>
      <div style="display:flex; flex-wrap:wrap; gap:18px; margin-top:32px;">
        {capabilities.map(([v, l]) => (
          <div style="display:flex; align-items:baseline; gap:8px;">
            <span class="font-display" style="font-size:clamp(1.65rem, 2.6vw, 2.25rem); color:var(--ink); line-height:1; letter-spacing:-0.02em; font-weight:500;">{v}</span>
            <span style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500);">{l}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LIVE NOW STRIP -->
  <section style="background:var(--sand-100); border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:24px 28px;">
      <div style="display:flex; align-items:center; gap:14px; margin-bottom:14px;">
        <span style="display:inline-flex; align-items:center; gap:6px;">
          <span style="width:7px; height:7px; border-radius:50%; background:#a04330; box-shadow:0 0 6px #a04330; animation:pulse 1.4s infinite;"></span>
          <span style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.22em; text-transform:uppercase; color:#a04330; font-weight:700;">Live now</span>
        </span>
        <span style="width:4px; height:4px; border-radius:50%; background:var(--ink-300);"></span>
        <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500); letter-spacing:0.16em; text-transform:uppercase;">Open sessions across campus</span>
      </div>
      <div style="display:grid; grid-template-columns:1fr; gap:10px;" class="live-grid">
        {liveNow.map((it) => (
          <article style="padding:14px 16px; background:var(--paper); border:1px solid var(--rule); border-radius:10px; display:flex; flex-direction:column; gap:8px; cursor:pointer;">
            <div style="display:flex; align-items:center; justify-content:space-between;">
              <span style={'display:inline-flex; align-items:center; justify-content:center; width:30px; height:22px; background:' + it.color + '14; border:1px solid ' + it.color + '40; border-radius:5px; font-family:JetBrains Mono,monospace; font-size:10px; letter-spacing:0.1em; color:' + it.color + '; font-weight:700;'}>{it.icon}</span>
              <span style="display:inline-block; width:5px; height:5px; border-radius:50%; background:#a04330; box-shadow:0 0 4px #a04330; animation:pulse 1.4s infinite;"></span>
            </div>
            <p style={'font-family:JetBrains Mono,monospace; font-size:9.5px; letter-spacing:0.14em; text-transform:uppercase; color:' + it.color + '; font-weight:600; margin:0;'}>{it.label}</p>
            <p style="font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; color:var(--ink); margin:0; line-height:1.35;">{it.what}</p>
            <p style="font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--ink-500); margin:auto 0 0; letter-spacing:0.04em;">{it.meta}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CAMPUS MAP -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:48px 28px;">
      <div style="display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:14px; margin-bottom:22px;">
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.22em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">Campus plan &middot; 12 districts</p>
          <h2 class="font-display" style="font-size:clamp(1.75rem, 3vw, 2.5rem); font-weight:500; line-height:1.15; letter-spacing:-0.02em; margin:0; color:var(--ink);">Walk the grounds.</h2>
        </div>
        <div style="display:flex; gap:8px;">
          <button type="button" style="background:transparent; color:var(--ink); padding:9px 16px; border:1px solid var(--rule); border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:12.5px; font-weight:600; cursor:pointer;">2D plan</button>
          <button type="button" style="background:var(--rust); color:#fff; padding:9px 16px; border:none; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:12.5px; font-weight:600; cursor:pointer;">Enter in VR</button>
        </div>
      </div>

      <div style="position:relative; background:var(--paper); border:1px solid var(--rule); border-radius:14px; overflow:hidden; aspect-ratio:12/7;">
        <svg viewBox="0 0 120 100" width="100%" height="100%" preserveAspectRatio="none" style="display:block;">
          <defs>
            <pattern id="cmp-dots" patternUnits="userSpaceOnUse" width="3" height="3">
              <circle cx="1.5" cy="1.5" r="0.3" fill="var(--ink-300)" opacity="0.4"/>
            </pattern>
          </defs>
          <rect width="120" height="100" fill="url(#cmp-dots)"/>
          <path d="M 50 5 L 50 95 M 5 50 L 115 50" stroke="var(--ink-300)" stroke-width="0.3" stroke-dasharray="0.8 0.5"/>
          <path d="M 26 5 L 26 95 M 84 5 L 84 95 M 5 28 L 115 28 M 5 72 L 115 72" stroke="var(--ink-300)" stroke-width="0.2" stroke-dasharray="0.6 0.4" opacity="0.7"/>
          {districts.map((d) => (
            <g>
              <rect x={d.x - d.w/2} y={d.y - d.h/2} width={d.w} height={d.h} rx="1" fill={d.color} fill-opacity="0.12" stroke={d.color} stroke-width="0.32"/>
              <text x={d.x} y={d.y - 0.6} text-anchor="middle" font-family="Fraunces" font-size="2.7" fill="var(--ink)" font-weight="500">{d.label}</text>
              <text x={d.x} y={d.y + 3} text-anchor="middle" font-family="JetBrains Mono" font-size="1.55" fill="var(--ink-500)" letter-spacing="0.06em">{d.sub.toUpperCase()}</text>
            </g>
          ))}
          <g transform="translate(5, 90)">
            <line x1="0" y1="0" x2="6" y2="0" stroke="var(--ink-500)" stroke-width="0.3"/>
            <text x="0" y="-1" font-family="JetBrains Mono" font-size="1.6" fill="var(--ink-500)" letter-spacing="0.16em">CAMPUS PLAN</text>
            <text x="0" y="3" font-family="JetBrains Mono" font-size="1.4" fill="var(--ink-300)" letter-spacing="0.16em">·  TAP A DISTRICT TO ENTER</text>
          </g>
          <g transform="translate(110, 90)">
            <circle cx="0" cy="0" r="2.5" fill="none" stroke="var(--ink-500)" stroke-width="0.3"/>
            <line x1="0" y1="-2.5" x2="0" y2="-3.4" stroke="var(--ink)" stroke-width="0.4"/>
            <text x="0" y="-4.5" text-anchor="middle" font-family="JetBrains Mono" font-size="1.6" fill="var(--ink-500)">N</text>
          </g>
        </svg>
      </div>
    </div>
  </section>

  <!-- FACILITY GRID -->
  <section style="background:var(--sand-100); border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:56px 28px;">
      <div style="display:flex; align-items:baseline; justify-content:space-between; margin-bottom:24px; flex-wrap:wrap; gap:10px;">
        <h2 class="font-display" style="font-size:clamp(1.65rem, 3vw, 2.4rem); font-weight:500; line-height:1.15; letter-spacing:-0.02em; margin:0; color:var(--ink);">Every district, virtually.</h2>
        <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-500);">10 of 12 districts shown</span>
      </div>
      <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="dist-grid">
        {facilities.map((f) => (
          <article style={'background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:22px; display:grid; grid-template-columns:64px 1fr; gap:16px; cursor:pointer; transition:transform 0.15s, box-shadow 0.15s; border-left:4px solid ' + f.color + ';'} class="dist-card">
            <div style={'width:64px; height:64px; border-radius:10px; background:' + f.color + '15; border:1px solid ' + f.color + '40; display:flex; align-items:center; justify-content:center; flex-shrink:0;'}>
              <span style={'font-family:JetBrains Mono,monospace; font-size:13px; letter-spacing:0.12em; color:' + f.color + '; font-weight:700;'}>{f.icon}</span>
            </div>
            <div style="display:flex; flex-direction:column; gap:7px; min-width:0;">
              <span style={'font-family:JetBrains Mono,monospace; font-size:9.5px; letter-spacing:0.18em; text-transform:uppercase; color:' + f.color + '; font-weight:700;'}>{f.code}</span>
              <h3 class="font-display" style="font-size:1.2rem; font-weight:500; line-height:1.18; letter-spacing:-0.015em; color:var(--ink); margin:0;">{f.title}</h3>
              <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500); margin:0; letter-spacing:0.04em;">{f.tagline}</p>
              <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:13.5px; color:var(--ink); line-height:1.55; margin:4px 0 0;">{f.blurb}</p>
              <ul style="list-style:none; padding:0; margin:6px 0 0; display:flex; flex-direction:column; gap:5px;">
                {f.bullets.map((b) => (
                  <li style="display:flex; align-items:start; gap:8px; font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink-500); line-height:1.5;">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke={f.color} stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- REALTIME TEACHING -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:56px 28px; display:grid; grid-template-columns:1fr; gap:36px; align-items:center;" class="rt-grid">
      <div>
        <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.22em; text-transform:uppercase; color:#3d6b76; font-weight:700; margin:0 0 8px;">Real-time generation</p>
        <h2 class="font-display" style="font-size:clamp(1.85rem, 3.5vw, 2.85rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0 0 16px; color:var(--ink);">The diagram appears <em style="color:#3d6b76; font-weight:400;">as the professor speaks</em>.</h2>
        <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.05rem, 1.3vw, 1.2rem); color:var(--ink); line-height:1.55; margin:0 0 14px;">Aquin listens to the lecture in real time. When Dr. Iyer says "the attention weights for token <em>i</em> only see tokens up to <em>i</em>", a causal mask matrix renders on the whiteboard before he finishes the sentence. Students ask "what if n is 64?" - the figure reshapes in 200 ms.</p>
        <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); line-height:1.65; margin:0 0 20px;">Every animation is saved to your notes with the timestamp it appeared. Aquin annotates what each variable means in the margin. You leave with a textbook chapter, not just a recording.</p>
        <div style="display:flex; gap:8px; flex-wrap:wrap;">
          <button type="button" style="background:#3d6b76; color:#fff; padding:10px 18px; border:none; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; cursor:pointer;">See it in action</button>
          <button type="button" style="background:transparent; color:var(--ink); padding:10px 18px; border:1px solid var(--rule); border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; cursor:pointer;">Read the technical paper</button>
        </div>
      </div>

      <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:18px;">
        <div style="display:flex; align-items:center; gap:10px; margin-bottom:12px;">
          <span style="width:8px; height:8px; border-radius:50%; background:#a04330; box-shadow:0 0 5px #a04330; animation:pulse 1.6s infinite;"></span>
          <span style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500);">AI-512 &middot; live &middot; captured 00:14:08</span>
        </div>
        <div style="padding:14px; background:var(--sand-100); border:1px solid var(--rule); border-radius:8px; margin-bottom:12px;">
          <p style="font-family:'JetBrains Mono',monospace; font-size:9px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); margin:0 0 6px;">Prof. Iyer &middot; transcript</p>
          <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:14px; color:var(--ink); line-height:1.5; margin:0;">"...now the attention weights for token <span style="background:rgba(168,71,44,0.18); padding:0 5px; border-radius:3px; color:var(--rust); font-weight:600;">i</span> only see tokens up to <span style="background:rgba(168,71,44,0.18); padding:0 5px; border-radius:3px; color:var(--rust); font-weight:600;">i</span>. That's the mask - a lower-triangular matrix..."</p>
        </div>
        <div style="display:flex; align-items:center; gap:8px; margin-bottom:8px;">
          <span style="display:inline-flex; align-items:center; justify-content:center; width:22px; height:22px; border-radius:50%; background:#3d6b76; color:#fff; font-family:'Fraunces',serif; font-weight:500; font-size:11px;">A</span>
          <span style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.12em; text-transform:uppercase; color:#3d6b76; font-weight:700;">Aquin &middot; generating &middot; 184 ms</span>
        </div>
        <div style="background:var(--sand-100); padding:16px; border-radius:8px; border:1px solid var(--rule);">
          <svg viewBox="0 0 320 130" width="100%" style="display:block;">
            {Array.from({length:8}).map((_, i) => (
              Array.from({length:8}).map((_, j) => (
                <rect x={40 + j * 30} y={5 + i * 14} width="26" height="10"
                  fill={j <= i ? 'rgba(168,71,44,' + (0.2 + (j / 8) * 0.5) + ')' : 'rgba(28,22,14,0.04)'}
                  stroke="var(--rule)" stroke-width="0.4"/>
              ))
            ))}
            <text x="40" y="125" font-family="JetBrains Mono" font-size="9" letter-spacing="0.12em" fill="var(--ink-500)">CAUSAL MASK · n=8</text>
          </svg>
        </div>
        <div style="display:flex; gap:5px; margin-top:10px; flex-wrap:wrap;">
          {['What if n=64?', 'Show me the math', 'Save to notes', 'Walk it again'].map((t) => (
            <span style="padding:4px 10px; background:var(--paper); border:1px solid var(--rule); border-radius:999px; font-family:'Inter Tight',sans-serif; font-size:11px; color:var(--ink-500); cursor:pointer;">{t}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- TESTING SYSTEMS -->
  <section style="background:var(--sand-100); border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:56px 28px;">
      <div style="margin-bottom:24px;">
        <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.22em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 8px;">Test centres &middot; 148 systems</p>
        <h2 class="font-display" style="font-size:clamp(1.65rem, 3vw, 2.4rem); font-weight:500; line-height:1.15; letter-spacing:-0.02em; margin:0; color:var(--ink); max-width:42rem;">
          Every credential a learner needs,<br/>
          <span style="font-style:italic; font-weight:300; color:var(--ink-500);">proctored on ATLAS.</span>
        </h2>
      </div>
      <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="test-grid">
        {testGroups.map((g) => (
          <article style={'background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:22px; border-top:4px solid ' + g.color + ';'}>
            <div style="display:flex; align-items:baseline; justify-content:space-between; margin-bottom:14px;">
              <h3 class="font-display" style="font-size:1.2rem; font-weight:500; line-height:1.18; letter-spacing:-0.015em; color:var(--ink); margin:0;">{g.title}</h3>
              <span style={'font-family:JetBrains Mono,monospace; font-size:1rem; font-weight:700; color:' + g.color + ';'}>{g.count}</span>
            </div>
            <p style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500); line-height:1.5; margin:0 0 14px;">{g.subtitle}</p>
            <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:5px;">
              {g.examples.map((ex) => (
                <li style="display:flex; align-items:center; gap:8px; font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--ink); padding:5px 9px; background:var(--sand-100); border:1px solid var(--rule); border-radius:6px;">
                  <span style={'display:inline-block; width:5px; height:5px; border-radius:50%; background:' + g.color + ';'}></span>
                  <span>{ex}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- COMPUTE LATTICE -->
  <section style="background:#0b0d10; color:#f4f1ea; border-bottom:1px solid #1a1f28; position:relative; overflow:hidden;">
    <div aria-hidden="true" style="position:absolute; inset:0; background:repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(127,179,255,0.018) 3px, rgba(127,179,255,0.018) 4px); pointer-events:none;"></div>
    <div style="max-width:1400px; margin:0 auto; padding:56px 28px; position:relative; z-index:1;">
      <p style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.22em; text-transform:uppercase; color:#7fb3ff; font-weight:700; margin:0 0 12px;">Compute lattice</p>
      <h2 class="font-display" style="font-size:clamp(1.85rem, 3.5vw, 2.85rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0 0 18px; color:#f4f1ea; max-width:38rem;">The infrastructure underneath every district.</h2>
      <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.05rem, 1.3vw, 1.2rem); color:#c8c3b8; line-height:1.55; margin:0 0 28px; max-width:36rem;">Holographic capture, GPU pools, edge nodes in 36 countries, generative render farms. Tele-operation latency held below 28ms via 5G + fibre dual-path. Privacy promise: no media bytes leave the candidate machine.</p>
      <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="compute-grid">
        {computeNodes.map((s) => (
          <div style="background:#161b22; border:1px solid #21262d; border-radius:12px; padding:16px;">
            <p style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.18em; text-transform:uppercase; color:#7fb3ff; font-weight:700; margin:0;">{s.l}</p>
            <p class="font-display" style="font-size:1.65rem; font-weight:500; margin:6px 0 0; line-height:1; color:#f4f1ea; letter-spacing:-0.02em;">{s.v}</p>
            <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:#9a8e76; line-height:1.5; margin:8px 0 0;">{s.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CULTURAL GATEWAY -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:56px 28px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.22em; text-transform:uppercase; color:#a04330; font-weight:600; margin:0 0 8px;">Cultural gateway</p>
      <h2 class="font-display" style="font-size:clamp(1.65rem, 3vw, 2.4rem); font-weight:500; line-height:1.15; letter-spacing:-0.02em; margin:0 0 28px; color:var(--ink); max-width:42rem;">
        Six regions, ninety-two cultures,<br/>
        <span style="font-style:italic; font-weight:300; color:var(--ink-500);">one passport.</span>
      </h2>
      <div style="display:grid; grid-template-columns:1fr; gap:12px;" class="cult-grid">
        {culturalAnchors.map((c) => (
          <article style="padding:18px 20px; background:var(--paper); border:1px solid var(--rule); border-radius:12px;">
            <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.16em; text-transform:uppercase; color:#a04330; font-weight:700; margin:0 0 12px;">{c.region}</p>
            <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:6px;">
              {c.items.map((it) => (
                <li style="display:flex; align-items:start; gap:8px; font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink); line-height:1.5;">
                  <span style="display:inline-block; width:4px; height:4px; min-width:4px; border-radius:50%; background:#a04330; margin-top:7px;"></span>
                  <span>{it}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CLOSING MANIFESTO -->
  <section style="background:#0b0d10; color:#f4f1ea; position:relative; overflow:hidden;">
    <div aria-hidden="true" style="position:absolute; top:60px; left:28px; font-family:'Fraunces',serif; font-size:11rem; line-height:1; color:#a78bfa; opacity:0.08; font-weight:500; pointer-events:none;">&ldquo;</div>
    <div style="max-width:1100px; margin:0 auto; padding:72px 28px; position:relative; z-index:1;">
      <p style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.22em; text-transform:uppercase; color:#d97757; font-weight:700; margin:0 0 18px;">A working campus</p>
      <blockquote class="font-display" style="font-style:italic; font-weight:300; font-size:clamp(1.5rem, 2.8vw, 2.25rem); line-height:1.3; letter-spacing:-0.015em; color:#f4f1ea; max-width:54rem; margin:0 0 28px;">
        The university used to be a place. It is now a contract: open admission, named faculty, faithful teaching, proctored assessment, and a credential that someone outside the institution can verify in fifteen seconds. AquinTutor is what happens when you keep the contract and drop the geography.
      </blockquote>
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <a href="/aquintutor/signup" style="background:#d97757; color:#1a0f08; padding:13px 24px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Apply for admission</a>
        <a href="/aquintutor/facility" style="background:transparent; color:#f4f1ea; padding:13px 24px; border-radius:6px; border:1px solid rgba(244,241,234,0.4); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Tour the facilities &rarr;</a>
        <a href="/aquintutor/systems" style="background:transparent; color:#f4f1ea; padding:13px 24px; border-radius:6px; border:1px solid rgba(244,241,234,0.4); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">See the 12 institutional systems &rarr;</a>
      </div>
    </div>
  </section>

  <style>
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }
    .dist-card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(11,14,20,0.08); }
    @media (min-width: 640px) { .live-grid { grid-template-columns: repeat(2, 1fr) !important; } .dist-grid { grid-template-columns: repeat(2, 1fr) !important; } .test-grid { grid-template-columns: repeat(3, 1fr) !important; } .compute-grid { grid-template-columns: repeat(3, 1fr) !important; } .cult-grid { grid-template-columns: repeat(2, 1fr) !important; } }
    @media (min-width: 1000px) { .live-grid { grid-template-columns: repeat(5, 1fr) !important; } .rt-grid { grid-template-columns: 1fr 1.1fr !important; } .compute-grid { grid-template-columns: repeat(6, 1fr) !important; } .cult-grid { grid-template-columns: repeat(3, 1fr) !important; } }
  </style>
</AquintutorLayout>
