  { dist: 'WELLNESS',  chip: 'Yoga',         title: 'Sunrise pranayama · 30-min anchor',             meta: '210 mats unrolled',  age: '3 min',  tone: '#4a7048' },
  { dist: 'COMMONS',   chip: 'Open mic',     title: 'Spoken word night · five readers signed up',    meta: 'Listeners 184',      age: '24 min', tone: '#a87526' },
  { dist: 'HALLS',     chip: 'Lecture',      title: 'Sanskrit grammar foundations · introductory',   meta: '880 attending',      age: '9 min',  tone: '#5b4a92' },
  { dist: 'FORGE',     chip: 'Tele-op',      title: 'CNC mill run · part shipping Friday',           meta: 'Live camera feed',   age: '46 min', tone: '#946322' },
  { dist: 'LIBRARY',   chip: 'Reading room', title: 'Quiet co-study · 124 desks taken',              meta: 'Ambient soundtrack', age: '1 hr',   tone: '#3d352a' },
  { dist: 'TESTS',     chip: 'Mock window',  title: 'National engineering entrance · adaptive set',   meta: '420 candidates',     age: '8 min',  tone: '#3b5675' },
  { dist: 'RESEARCH',  chip: 'Office hours', title: 'Cosmology faculty · queue at 3 students',        meta: 'Walk-ins open',      age: '12 min', tone: '#8a486b' },
  { dist: 'CULTURAL',  chip: 'Concert',      title: 'Hindustani classical · evening raga',           meta: 'Free seating',       age: '5 min',  tone: '#a04330' },
  { dist: 'LANGUAGE',  chip: 'Cooking',      title: 'Italian kitchen circle · ragù method',          meta: '24 cooks in chat',   age: '18 min', tone: '#a8472c' },
  { dist: 'COMMONS',   chip: 'Coffee match', title: 'Daily three-way coffee · matchmaker running',   meta: 'Sign up by :30',     age: '11 min', tone: '#a87526' },
