      <div class="map-legend">
        {districts.map(d => (
          <span class="legend-item"><span class="legend-dot" style={`background:${d.tone}`}></span>{d.code} · {d.name}</span>
        ))}
        <span class="legend-item"><span class="legend-dot" style="background:#FF4F00; border-radius:50%;"></span>Learner moving between districts</span>
      </div>
    </div>
  </section>

  <!-- DISTRICT GRID -->
  <section class="block">
    <div class="sec-head">
      <div>
        <div class="sec-eye">Ten districts</div>
        <h2 class="sec-title">Each <em>district</em> is its own world.</h2>
        <p class="sec-sub">Search by what you want to do. Filter by district. Walk in to whichever fits the next hour of your day.</p>
      </div>
    </div>

    <div class="search-row">
      <svg width="18" height="18" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      <input type="text" id="distSearch" placeholder="Search a district, facility, or activity..." />
      <div class="search-tags" id="distTags">
        <button class="tag-btn active" data-filter="all">All</button>
        <button class="tag-btn" data-filter="halls">Halls</button>
        <button class="tag-btn" data-filter="labs">Labs</button>
        <button class="tag-btn" data-filter="forge">Forge</button>
        <button class="tag-btn" data-filter="library-archives">Library</button>
        <button class="tag-btn" data-filter="test-centres">Tests</button>
        <button class="tag-btn" data-filter="cultural">Cultural</button>
        <button class="tag-btn" data-filter="language-houses">Language</button>
        <button class="tag-btn" data-filter="wellness">Wellness</button>
        <button class="tag-btn" data-filter="commons">Commons</button>
        <button class="tag-btn" data-filter="research-commons">Research</button>
      </div>
    </div>

    <div class="grid-dist" id="distGrid">
      {districts.map(d => (
        <a class="dist-card" href={`/aquintutor/campus/${d.slug}`} data-slug={d.slug} data-text={(d.name + ' ' + d.tag + ' ' + d.facilities.join(' ')).toLowerCase()}>
          <div class="dist-band" style={`background:${d.tone}`}></div>
          <div class="dist-code">{d.code}</div>
          <div class="dist-name">{d.name}</div>
          <div class="dist-tag">{d.tag}</div>
          <div class="dist-live"><span class="dist-live-dot"></span>{d.live} live now</div>
          <ul class="dist-bullets">
            {d.facilities.map(f => <li>{f}</li>)}
          </ul>
          <span class="dist-cta">Visit district
            <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- CULTURAL ANCHORS -->
  <section class="block">
    <div class="sec-head">
      <div>
        <div class="sec-eye">Cultural anchors</div>
        <h2 class="sec-title">A campus that <em>speaks</em> ninety-two languages.</h2>
        <p class="sec-sub">Six regional pavilions hold ongoing residencies, recitals, and rituals. Every learner who enrols receives a culture passport that stamps each tradition they sit with.</p>
      </div>
    </div>
    <div class="grid-cult">
      {culturalAnchors.map(r => (
        <article class="cult-card">
          <div class="cult-band" style={`background:${r.tone}`}></div>
          <div class="cult-region">{r.region}</div>
          <ul class="cult-list">
            {r.traditions.map(t => (
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L4 6v6c0 4.5 3.5 8.5 8 10 4.5-1.5 8-5.5 8-10V6l-8-4z"/></svg>
                {t}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <!-- COMPUTE / INFRA -->
  <section class="block">
    <div class="sec-head">
      <div>
        <div class="sec-eye">Compute &amp; infrastructure</div>
        <h2 class="sec-title">The <em>plumbing</em> the lectures stand on.</h2>
        <p class="sec-sub">A virtual campus rests on physical pipes. These are ours.</p>
      </div>
    </div>
    <div class="grid-infra">
      {infra.map(i => (
        <article class="infra-card">
          <div class="infra-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              {i.code === 'CAPTURE' && (<><circle cx="12" cy="12" r="3"/><path d="M12 1v3M12 20v3M4.2 4.2l2.1 2.1M17.7 17.7l2.1 2.1M1 12h3M20 12h3M4.2 19.8l2.1-2.1M17.7 6.3l2.1-2.1"/></>)}
              {i.code === 'GPU' && (<><rect x="3" y="6" width="18" height="12" rx="2"/><path d="M7 10h2M11 10h2M15 10h2M7 14h2M11 14h2M15 14h2"/></>)}
              {i.code === 'EDGE' && (<><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/></>)}
              {i.code === 'RENDER' && (<><path d="M3 6l9-4 9 4-9 4-9-4z"/><path d="M3 12l9 4 9-4M3 18l9 4 9-4"/></>)}
              {i.code === 'TELEOP' && (<><circle cx="12" cy="12" r="3"/><path d="M12 1v6M12 17v6M1 12h6M17 12h6"/></>)}
              {i.code === 'PRIVACY' && (<><path d="M12 2l8 4v6c0 5-3.5 9-8 10-4.5-1-8-5-8-10V6l8-4z"/><path d="M9 12l2 2 4-4"/></>)}
            </svg>
          </div>
          <div class="infra-code">{i.code}</div>
          <h3 class="infra-title">{i.title}</h3>
          <p class="infra-body">{i.body}</p>
        </article>
      ))}
    </div>

    <div class="quick-row">
      <div class="quick-card"><div class="quick-k">Median frame latency</div><div class="quick-v">23 ms</div></div>
      <div class="quick-card"><div class="quick-k">Concurrent learners peak</div><div class="quick-v">38,420</div></div>
      <div class="quick-card"><div class="quick-k">Aquin tokens / day</div><div class="quick-v">1.42 B</div></div>
      <div class="quick-card"><div class="quick-k">Render queue depth · now</div><div class="quick-v" id="queueDepth">17</div></div>
      <div class="quick-card"><div class="quick-k">Edge node uptime</div><div class="quick-v">99.984%</div></div>
      <div class="quick-card"><div class="quick-k">Forge jobs · this week</div><div class="quick-v">486</div></div>
    </div>
  </section>

  <!-- TOUR / CTA -->
  <section class="block" id="tour">
    <div class="sec-head">
      <div>
        <div class="sec-eye">Visit before you enrol</div>
        <h2 class="sec-title">Take a <em>tour</em> with a current student.</h2>
        <p class="sec-sub">Sixty minutes. A real student, not a salesperson. Two districts of your choosing. Bring questions — they will not be moderated.</p>
      </div>
    </div>

    <div class="tour">
      <div class="tour-panel">
        <div class="sec-eye" style="margin-bottom:14px;">Open slots · next seven days</div>
        <div class="tour-slots" id="tourSlots">
          {tourSlots.map((s, i) => (
            <div class="slot" data-i={i}>
              <div>
                <div class="slot-date">{s.d}</div>
                <div class="slot-time">{s.t}</div>
              </div>
              <div class="slot-meta">
                <span class="guide">{s.guide}</span><br/>
                <span style="color:#7A6F68;">Tour districts: {s.district}</span>
              </div>
              <span class="slot-pick">Select</span>
            </div>
          ))}
        </div>
        <p class="tour-note">All times shown in IST. Pick a slot then submit the form to confirm — we will email a calendar invite.</p>
      </div>

      <div class="tour-panel">
        <form class="tour-form" id="tourForm">
          <div class="field">
            <label for="t-name">Your name</label>
            <input id="t-name" name="name" required placeholder="As you would like to be greeted" />
          </div>
          <div class="field">
            <label for="t-email">Email</label>
            <input id="t-email" name="email" type="email" required placeholder="we.will@send-an-invite.here" />
          </div>
          <div class="field">
            <label for="t-from">Joining from</label>
            <select id="t-from" name="city">
              <option value="">Select city / region</option>
              {cityList.map(c => <option value={c}>{c}</option>)}
              <option value="other">Other / will type</option>
            </select>
          </div>
          <div class="field">
            <label for="t-interest">What district matters most to you?</label>
            <select id="t-interest" name="interest">
              {districts.map(d => <option value={d.slug}>{d.name}</option>)}
            </select>
          </div>
          <div class="field">
            <label for="t-q">A question for your student guide (optional)</label>
            <textarea id="t-q" name="question" rows="3" placeholder="What do you wish you had known before week one?"></textarea>
          </div>
          <input type="hidden" id="t-slot" name="slot" />
          <button type="submit" class="btn-primary" style="justify-content:center;">
            <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4z"/></svg>
            Book my virtual tour
          </button>
          <div id="tourStatus"></div>
          <p class="tour-note">No card. No salesperson. Your guide will email you a private link. If you decide to apply afterwards, that path opens from inside the tour.</p>
        </form>
      </div>
    </div>
  </section>

  <!-- FOOTER NAV -->
  <section style="border-bottom:1px solid var(--line);">
    <div class="foot-nav">
      <div class="foot-l">Already <em>convinced</em>? Walk in.</div>
      <div class="foot-r">
        <a class="btn-ghost" href="/aquintutor">Back to AquinTutor</a>
        <a class="btn-primary" href="/careers">
          Begin your application
          <svg width="14" height="14" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

</main>

<script is:inline>
  // -------- LIVE RAIL scroll buttons --------
  const rail = document.getElementById('liveRail');
  document.querySelectorAll('[data-rail]').forEach(btn => {
    btn.addEventListener('click', () => {
      if (!rail) return;
      const dir = btn.getAttribute('data-rail') === 'left' ? -1 : 1;
      rail.scrollBy({ left: dir * 360, behavior: 'smooth' });
    });
  });

  // -------- MAP popover --------
  const popover = document.getElementById('mapPopover');
  const mapSvg = document.getElementById('campusMap');
  if (popover && mapSvg) {
    const frame = mapSvg.closest('.map-frame');
    const shapes = mapSvg.querySelectorAll('.dist-shape');
    const subMap = {
      halls: '9 sessions live · holographic capture',
      labs: '31 simulators running',
      forge: '6 tele-op jobs streaming',
      library: '24 reading rooms open · 124 desks',
      tests: '18 windows live · 420 candidates',
      cultural: '8 residencies · concert at 19:30',
      wellness: '7 anchors · yoga + counsel',
      commons: '22 clubs · coffee-match at :30',
      lang: '14 conversation circles open',
      research: '11 seminars · office hours queue 3'
    };
    shapes.forEach(s => {
      s.addEventListener('mousemove', (e) => {
        const rect = frame.getBoundingClientRect();
        const id = s.getAttribute('data-id');
        const name = s.getAttribute('data-name') || '';
        const live = s.getAttribute('data-live') || '0';
        popover.querySelector('strong').textContent = name;
        popover.querySelector('div:nth-of-type(1)').textContent = subMap[id] || (live + ' live now');
        popover.querySelector('.pp-meta').textContent = live + ' LIVE · CLICK TO ENTER';
        popover.style.left = (e.clientX - rect.left) + 'px';
        popover.style.top = (e.clientY - rect.top) + 'px';
        popover.style.opacity = '1';
      });
      s.addEventListener('mouseleave', () => { popover.style.opacity = '0'; });
    });
  }

  // -------- DISTRICT SEARCH + FILTER --------
  const distSearch = document.getElementById('distSearch');
  const distTags = document.getElementById('distTags');
  const distGrid = document.getElementById('distGrid');
  let activeFilter = 'all';
  let activeQuery = '';

  function applyFilters() {
    if (!distGrid) return;
    distGrid.querySelectorAll('.dist-card').forEach(card => {
      const slug = card.getAttribute('data-slug') || '';
      const text = card.getAttribute('data-text') || '';
      const tagOk = activeFilter === 'all' || slug === activeFilter;
      const qOk = !activeQuery || text.indexOf(activeQuery) !== -1;
      card.style.display = (tagOk && qOk) ? '' : 'none';
    });
  }
  if (distSearch) {
    distSearch.addEventListener('input', () => {
      activeQuery = distSearch.value.toLowerCase().trim();
      applyFilters();
    });
  }
  if (distTags) {
    distTags.querySelectorAll('.tag-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        distTags.querySelectorAll('.tag-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeFilter = btn.getAttribute('data-filter') || 'all';
        applyFilters();
      });
    });
  }

  // -------- LIVE QUEUE flicker --------
  const queue = document.getElementById('queueDepth');
  if (queue) {
    let q = 17;
    setInterval(() => {
      q = Math.max(4, Math.min(34, q + Math.round((Math.random() - 0.5) * 6)));
      queue.textContent = String(q);
    }, 2200);
  }

  // -------- TOUR slot selection + form --------
  const slotsEl = document.getElementById('tourSlots');
  const slotInput = document.getElementById('t-slot');
  if (slotsEl && slotInput) {
    slotsEl.querySelectorAll('.slot').forEach(s => {
      s.addEventListener('click', () => {
        slotsEl.querySelectorAll('.slot').forEach(o => o.classList.remove('selected'));
        s.classList.add('selected');
        slotInput.value = s.getAttribute('data-i') || '';
      });
    });
  }
  const tourForm = document.getElementById('tourForm');
  const tourStatus = document.getElementById('tourStatus');
  if (tourForm) {
    tourForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const slot = slotInput && slotInput.value;
      if (!slot) {
        tourStatus.className = 'form-status err';
        tourStatus.textContent = 'Please pick an open slot from the panel on the left.';
        return;
      }
      // Local-only confirmation; server endpoint can be wired later.
      tourStatus.className = 'form-status ok';
      tourStatus.textContent = 'Tour requested — a confirmation will arrive in your inbox within five minutes.';
      tourForm.reset();
      if (slotsEl) slotsEl.querySelectorAll('.slot').forEach(o => o.classList.remove('selected'));
    });
  }
</script>

</AquintutorLayout>
