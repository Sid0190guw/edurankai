---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/review'));
---
<AquintutorLayout title="Review your mistakes" description="Spaced-repetition review of questions you've missed.">
  <section style="border-bottom:1px solid var(--rule); background:linear-gradient(180deg,#fff8f3 0%, var(--paper) 100%);">
    <div style="max-width:680px; margin:0 auto; padding:36px 28px;">
      <p style="font-family:'Inter Tight',monospace; font-size:12px; color:var(--rust); font-weight:700; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">SRS · spaced repetition</p>
      <h1 class="font-display" style="font-size:clamp(1.8rem,3.5vw,2.6rem); line-height:1.1; font-weight:500; margin:0;">Review your mistakes.</h1>
      <p style="font-family:'Inter Tight',sans-serif; font-size:14.5px; color:var(--ink-500); line-height:1.6; margin-top:8px;">Questions you got wrong return at expanding intervals — 1 day → 2 → 4 → 9 → 21 → 51 days. Get them right enough times and they leave the queue.</p>
    </div>
  </section>

  <section>
    <div style="max-width:680px; margin:0 auto; padding:24px 28px 80px;">
      <div id="root">
        <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500);">Loading your review queue…</p>
      </div>
    </div>
  </section>

  <script is:inline>
  (function () {
    var root = document.getElementById('root');
    var state = { idx: 0, qs: [], correct: 0, total: 0, answer: undefined, answered: false };
    function esc(s) { return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) { return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]; }); }
    function html(s) { var t = document.createElement('template'); t.innerHTML = s.trim(); return t.content.firstChild; }

    fetch('/api/aquintutor/srs-review', { credentials: 'same-origin' })
      .then(function (r) { return r.json(); })
      .then(function (d) {
        if (!d.ok || !d.questions || !d.questions.length) {
          root.innerHTML = '<div style="background:var(--paper);border:1px solid var(--rule);border-radius:14px;padding:30px;text-align:center;"><p style="font-family:Fraunces,serif;font-size:18px;font-weight:500;">No reviews due. 🎯</p><p style="font-family:Inter Tight,sans-serif;font-size:13.5px;color:var(--ink-500);margin-top:8px;">Take a <a href="/aquintutor/practice/sanskrit-awareness" style="color:var(--rust);font-weight:600;">practice round</a> to seed the queue.</p></div>';
          return;
        }
        state.qs = d.questions; state.total = d.questions.length;
        render();
      });

    function render() {
      if (state.idx >= state.qs.length) return summary();
      var q = state.qs[state.idx];
      state.answer = undefined; state.answered = false;
      var card = document.createElement('div');
      card.style.cssText = 'background:var(--paper);border:1px solid var(--rule);border-radius:14px;padding:24px 28px;';
      var head = '<p style="font-family:Inter Tight,monospace;font-size:11px;letter-spacing:0.14em;color:var(--rust);font-weight:700;margin-bottom:8px;">Review ' + (state.idx + 1) + '/' + state.qs.length + (q.category ? ' · ' + esc(q.category) : '') + '</p>';
      head += '<p style="font-family:Fraunces,serif;font-size:18px;line-height:1.4;margin-bottom:14px;">' + esc(q.question_text) + '</p>';
      card.innerHTML = head;

      if (q.question_type === 'mcq_single' || q.question_type === 'true_false') {
        (q.options || []).forEach(function (o, i) {
          var b = html('<button type="button" data-i="' + i + '" style="display:block;width:100%;padding:12px 14px;background:#fff;border:2px solid var(--rule);border-radius:10px;margin-bottom:8px;font-family:inherit;font-size:14px;cursor:pointer;text-align:left;">' + esc(o.text || o) + '</button>');
          b.addEventListener('click', function () {
            if (state.answered) return;
            card.querySelectorAll('button[data-i]').forEach(function (x) { x.style.borderColor = 'var(--rule)'; x.style.background = '#fff'; });
            b.style.borderColor = 'var(--rust)'; b.style.background = 'rgba(217,119,87,0.08)';
            state.answer = i; checkBtn.disabled = false;
          });
          card.appendChild(b);
        });
      } else if (q.question_type === 'fill_in_blank' || q.question_type === 'numeric') {
        var ti = html('<input type="' + (q.question_type === 'numeric' ? 'number' : 'text') + '" style="width:100%;padding:12px 16px;border:2px solid var(--rule);border-radius:10px;font-family:inherit;font-size:14px;outline:none;" placeholder="Type your answer…" />');
        ti.addEventListener('input', function (e) { state.answer = e.target.value; checkBtn.disabled = !e.target.value; });
        card.appendChild(ti);
        setTimeout(function () { ti.focus(); }, 30);
      }

      var checkBtn = html('<button type="button" style="margin-top:14px;width:100%;padding:14px;background:var(--ink);color:#fff;border:none;border-radius:12px;font-family:inherit;font-size:14px;font-weight:700;cursor:pointer;" disabled>Check</button>');
      checkBtn.addEventListener('click', function () { onCheck(card, q, checkBtn); });
      card.appendChild(checkBtn);
      root.innerHTML = ''; root.appendChild(card);
    }

    function onCheck(card, q, btn) {
      if (state.answered) return next();
      state.answered = true; btn.disabled = true; btn.textContent = 'Checking…';
      // Grade by reusing the practice answer endpoint
      fetch('/api/aquintutor/practice/answer', { method:'POST', credentials:'same-origin', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ questionId: q.id, answer: state.answer })})
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (!d.ok) { btn.disabled = false; btn.textContent = 'Check'; state.answered = false; return; }
          var fb = document.createElement('div');
          fb.style.cssText = 'padding:14px 18px;border-radius:10px;margin-top:10px;font-size:13.5px;line-height:1.55;' + (d.correct ? 'background:rgba(16,185,129,0.12);color:#047857;' : 'background:rgba(239,68,68,0.10);color:#991b1b;');
          fb.innerHTML = '<b>' + (d.correct ? '✓ Correct' : '✗ Not quite') + '</b>' + (d.explanation ? '<br>' + esc(d.explanation) : '') + (!d.correct ? '<br><b>Correct:</b> ' + esc(String(d.modelAnswer || '')) : '');
          card.insertBefore(fb, btn);
          if (d.correct) state.correct++;
          // Schedule next SRS review based on result
          fetch('/api/aquintutor/srs-review', { method:'POST', credentials:'same-origin', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ questionId: q.id, correct: d.correct })});
          btn.disabled = false; btn.textContent = state.idx === state.qs.length - 1 ? 'Finish →' : 'Continue →';
        });
    }
    function next() { state.idx++; render(); }
    function summary() {
      root.innerHTML = '<div style="background:var(--paper);border:1px solid var(--rule);border-radius:14px;padding:30px;text-align:center;">'
        + '<p style="font-family:Inter Tight,monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.14em;color:var(--rust);font-weight:700;">Review complete</p>'
        + '<p class="font-display" style="font-size:48px;font-weight:600;color:var(--rust);margin:14px 0 6px;">' + state.correct + '/' + state.total + '</p>'
        + '<p style="font-family:Inter Tight,sans-serif;font-size:14px;color:var(--ink-500);">Questions you got right come back later. Questions you missed come back tomorrow.</p>'
        + '<div style="margin-top:18px;display:flex;gap:8px;justify-content:center;flex-wrap:wrap;">'
          + '<a href="/aquintutor/dashboard" style="background:var(--ink);color:#fff;padding:11px 22px;border-radius:10px;font-family:inherit;font-size:13px;font-weight:700;text-decoration:none;">Dashboard</a>'
          + '<a href="/aquintutor/practice/sanskrit-awareness" style="background:var(--paper);color:var(--ink);padding:11px 22px;border-radius:10px;border:1px solid var(--rule);font-family:inherit;font-size:13px;font-weight:700;text-decoration:none;">Take a practice round</a>'
        + '</div></div>';
    }
  })();
  </script>
</AquintutorLayout>
