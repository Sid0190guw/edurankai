---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { getClassroomRoster } from '@/lib/classrooms';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/classrooms'));

const { id } = Astro.params;
const data = id ? await getClassroomRoster(id, user.id) : null;
if (!data) return Astro.redirect('/aquintutor/classrooms');

function shorten(n: string): string {
  if (!n) return 'anonymous';
  const p = String(n).trim().split(/\s+/);
  return p.length === 1 ? p[0] : (p[0] + ' ' + p[p.length - 1][0] + '.');
}

const totalXp = data.roster.reduce((s: number, r: any) => s + Number(r.total_xp || 0), 0);
const weekXp = data.roster.reduce((s: number, r: any) => s + Number(r.week_xp || 0), 0);
const avgStreak = data.roster.length ? Math.round(data.roster.reduce((s: number, r: any) => s + Number(r.streak || 0), 0) / data.roster.length) : 0;
---
<AquintutorLayout title={data.classroom.name} description="Class roster and progress.">
  <section style="border-bottom:1px solid var(--rule); background:linear-gradient(180deg,#fff8f3 0%, var(--paper) 100%);">
    <div style="max-width:1100px; margin:0 auto; padding:36px 28px;">
      <a href="/aquintutor/classrooms" style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500); text-decoration:none;">← All classrooms</a>
      <h1 class="font-display" style="font-size:clamp(1.8rem,3.5vw,2.6rem); line-height:1.1; font-weight:500; margin:12px 0 6px;">{data.classroom.name}</h1>
      <p style="font-family:'Inter Tight',sans-serif; font-size:14.5px; color:var(--ink-500);">{data.classroom.description}</p>
      <div style="display:flex; gap:14px; margin-top:18px; flex-wrap:wrap;">
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:10px 16px;">
          <p style="font-family:'Inter Tight',monospace; font-size:10px; letter-spacing:0.14em; color:var(--ink-500); font-weight:700;">JOIN CODE</p>
          <p style="font-family:'JetBrains Mono',monospace; font-size:22px; font-weight:700; color:var(--rust); letter-spacing:0.1em;">{data.classroom.join_code}</p>
        </div>
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:10px 16px;">
          <p style="font-family:'Inter Tight',monospace; font-size:10px; letter-spacing:0.14em; color:var(--ink-500); font-weight:700;">STUDENTS</p>
          <p style="font-family:'Fraunces',serif; font-size:22px; font-weight:600;">{data.roster.length}</p>
        </div>
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:10px 16px;">
          <p style="font-family:'Inter Tight',monospace; font-size:10px; letter-spacing:0.14em; color:var(--ink-500); font-weight:700;">XP THIS WEEK</p>
          <p style="font-family:'Fraunces',serif; font-size:22px; font-weight:600; color:#d97757;">{weekXp.toLocaleString()}</p>
        </div>
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:10px 16px;">
          <p style="font-family:'Inter Tight',monospace; font-size:10px; letter-spacing:0.14em; color:var(--ink-500); font-weight:700;">AVG STREAK</p>
          <p style="font-family:'Fraunces',serif; font-size:22px; font-weight:600; color:#f97316; display:flex; align-items:center; gap:6px;"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>{avgStreak}</p>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div style="max-width:1100px; margin:0 auto; padding:28px 28px 80px;">
      <p style="font-family:'Inter Tight',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:700; margin:0 0 14px;">Roster · sorted by weekly XP</p>
      {data.roster.length === 0 ? (
        <div style="background:var(--paper); border:1px dashed var(--rule); border-radius:14px; padding:30px; text-align:center; color:var(--ink-500);">
          <p style="font-family:'Fraunces',serif; font-size:1.1rem; color:var(--ink); margin-bottom:6px;">No students yet.</p>
          <p>Share the join code <b>{data.classroom.join_code}</b> with your students.</p>
        </div>
      ) : (
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; overflow:hidden;">
          <div style="display:grid; grid-template-columns:60px 1fr 100px 100px 80px; gap:14px; padding:12px 18px; background:var(--sand-100); border-bottom:1px solid var(--rule); font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-500); font-weight:700;">
            <div>RANK</div><div>STUDENT</div><div style="text-align:right;">WEEK XP</div><div style="text-align:right;">TOTAL XP</div><div style="text-align:right;">STREAK</div>
          </div>
          {data.roster.map((r: any, i: number) => (
            <div style="display:grid; grid-template-columns:60px 1fr 100px 100px 80px; gap:14px; padding:14px 18px; border-bottom:1px solid var(--rule); align-items:center;">
              <span style="font-family:'JetBrains Mono',monospace; font-size:14px; font-weight:700; color:var(--ink-500);">#{i + 1}</span>
              <span style="font-family:'Inter Tight',sans-serif; font-size:14.5px; font-weight:600;">{shorten(r.name)} <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500); font-weight:400;">Lv {r.level}</span></span>
              <span style="font-family:'JetBrains Mono',monospace; font-size:14px; font-weight:700; color:var(--rust); text-align:right;">{Number(r.week_xp).toLocaleString()}</span>
              <span style="font-family:'JetBrains Mono',monospace; font-size:13px; color:var(--ink); text-align:right;">{Number(r.total_xp).toLocaleString()}</span>
              <span style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#f97316; display:inline-flex; align-items:center; justify-content:flex-end; gap:5px;"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>{r.streak}</span>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
</AquintutorLayout>
