---
// /aquintutor/broadcast — host a mass broadcast (Prompt H3a, faculty-gated). One teacher -> many
// viewers who PULL. The animation SPEC + slides fan out over the board channel (session bcast-<id>);
// every viewer renders locally at their tier. HD video egress needs a CDN (see the follow-up note) —
// the low-bitrate default (slides + specs) is what makes reaching a huge audience cheap.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import SceneGL from '@/components/SceneGL.astro';
import { can } from '@/lib/rbac';
import { exampleList, exampleScene, SCENE_EXAMPLE_IDS } from '@/lib/scene-examples';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/broadcast');
const gate = await can(user, 'write', { type: 'AnimationObject' });
if (!gate.allow) return Astro.redirect('/aquintutor/hub');
const scenes = exampleList();
const sceneSpecs: Record<string, any> = {};
for (const id of SCENE_EXAMPLE_IDS) sceneSpecs[id] = exampleScene(id);
const origin = Astro.url.origin;
---
<AquintutorLayout title="Go live">
  <main style="max-width:860px;margin:0 auto;padding:32px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Mass broadcast</p>
    <h1 style="font-family:Fraunces,serif;font-size:28px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 4px;">Go live to many</h1>
    <p style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#6b6455;margin:0 0 8px;">Viewers watch by pulling your slides + animations and rendering them locally — cheap at scale. HD teacher video needs a streaming CDN (a provisioning step, not built here); the low-bitrate default sends slides + animation specs.</p>
    <div id="msg" style="display:none;margin:0 0 12px;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-bottom:14px;">
      <input id="bcTitle" placeholder="Broadcast title" style="flex:1;min-width:180px;font-family:'Inter Tight',sans-serif;font-size:14px;padding:9px 11px;border:1px solid var(--line,#e6e1d6);border-radius:9px;" />
      <label style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#6b6455;"><input type="checkbox" id="bcLowBitrate" checked /> Low-bitrate (slides + specs)</label>
      <button id="goLive" type="button" style="background:var(--rust,#b3541e);color:#fff;border:none;border-radius:9px;padding:9px 18px;font-family:'Inter Tight',sans-serif;font-size:14px;font-weight:700;cursor:pointer;">Go live</button>
      <button id="stopLive" type="button" disabled style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:9px;padding:9px 14px;font-family:'Inter Tight',sans-serif;font-size:13px;cursor:pointer;opacity:0.5;">Stop</button>
    </div>

    <div id="liveInfo" style="display:none;background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:12px;padding:12px 14px;margin-bottom:14px;">
      <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
        <input id="viewerLink" readonly style="flex:1;min-width:200px;font-family:'Geist Mono',monospace;font-size:12px;padding:8px 10px;border:1px solid var(--line,#e6e1d6);border-radius:8px;background:#faf9f4;" />
        <button id="copyViewer" type="button" style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:8px;padding:8px 12px;font-size:12.5px;cursor:pointer;">Copy</button>
        <span id="viewerCount" style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#2f7d5b;">0 watching</span>
      </div>
    </div>

    <div style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:14px;padding:16px 18px;">
      <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 10px;">Drive the broadcast</p>
      <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-bottom:10px;">
        <select id="bcScene" style="font-size:13px;padding:7px 9px;border-radius:8px;border:1px solid var(--line,#e6e1d6);">{scenes.map((s) => <option value={s.id}>{s.title}</option>)}</select>
        <button class="mt-btn" id="bcCastScene" type="button" style="background:var(--ink,#1a1712);color:#fff;border:none;border-radius:8px;padding:8px 13px;font-size:13px;cursor:pointer;">Cast 3D scene</button>
        <button id="bcProjectile" type="button" style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:8px;padding:8px 12px;font-size:13px;cursor:pointer;">Projectile</button>
      </div>
      <div id="bcStage" style="background:#0e0f13;border-radius:10px;overflow:hidden;min-height:120px;"></div>
      <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--line,#e6e1d6);">
        <p style="font-family:'Geist Mono',monospace;font-size:11px;color:#8a8378;margin:0 0 6px;">Publish a slide (text — no image upload)</p>
        <input id="slideTitle" placeholder="Slide title" style="width:100%;font-size:13px;padding:7px 9px;border:1px solid var(--line,#e6e1d6);border-radius:8px;margin-bottom:6px;box-sizing:border-box;" />
        <textarea id="slideBullets" placeholder="One bullet per line" rows="3" style="width:100%;font-size:13px;padding:7px 9px;border:1px solid var(--line,#e6e1d6);border-radius:8px;box-sizing:border-box;"></textarea>
        <button id="bcSlide" type="button" style="margin-top:6px;background:var(--ink,#1a1712);color:#fff;border:none;border-radius:8px;padding:8px 13px;font-size:13px;cursor:pointer;">Publish slide</button>
      </div>
    </div>
  </main>

  <script src="/aquin-anim-templates.js" defer></script>
  <script src="/aquin-scene-engine.js" defer></script>
  <script src="/aquin-broadcast-transport.js" defer></script>
  <SceneGL />
  <script is:inline define:vars={{ sceneSpecs, origin }}>
    (function () {
      function ready(fn) { if (window.AquinScene && window.AquinBroadcast) fn(); else setTimeout(function () { ready(fn); }, 50); }
      ready(function () {
        var T = window.AquinBroadcast.createFanoutTransport({}), stage = document.getElementById('bcStage'), msg = document.getElementById('msg');
        var bid = null, poll = null;
        function flash(t, ok) { msg.style.display = 'block'; msg.textContent = t; msg.style.background = ok ? '#eef8f1' : '#fdecec'; msg.style.color = ok ? '#2f7d5b' : '#9b2c2c'; }
        document.getElementById('goLive').addEventListener('click', function () {
          fetch('/api/aquintutor/broadcast', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'create', title: document.getElementById('bcTitle').value, lowBitrate: document.getElementById('bcLowBitrate').checked }) })
            .then(function (r) { return r.json(); }).then(function (j) {
              if (!j.ok) { flash(j.error || 'failed', false); return; }
              bid = j.id; document.getElementById('liveInfo').style.display = 'block';
              document.getElementById('viewerLink').value = origin + '/aquintutor/broadcast/' + bid;
              document.getElementById('stopLive').disabled = false; document.getElementById('stopLive').style.opacity = '1';
              document.getElementById('goLive').disabled = true; flash('You are live', true);
              poll = setInterval(function () { fetch('/api/aquintutor/broadcast', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'state', id: bid }) }).then(function (r) { return r.json(); }).then(function (s) { if (s.ok) document.getElementById('viewerCount').textContent = s.viewers + ' watching'; }); }, 4000);
            });
        });
        document.getElementById('stopLive').addEventListener('click', function () { if (!bid) return; fetch('/api/aquintutor/broadcast', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'stop', id: bid }) }).then(function () { clearInterval(poll); flash('Broadcast ended', true); document.getElementById('stopLive').disabled = true; }); });
        document.getElementById('copyViewer').addEventListener('click', function () { var i = document.getElementById('viewerLink'); i.select(); navigator.clipboard && navigator.clipboard.writeText(i.value); flash('Viewer link copied', true); });

        function need() { if (!bid) { flash('Go live first', false); return false; } return true; }
        document.getElementById('bcCastScene').addEventListener('click', function () { if (!need()) return; var id = document.getElementById('bcScene').value; window.AquinScene.render(stage, sceneSpecs[id], 'rich'); T.publishSpec(bid, 'scene', sceneSpecs[id]); flash('Cast ' + id, true); });
        document.getElementById('bcProjectile').addEventListener('click', function () { if (!need()) return; T.publishSpec(bid, 'projectile', { angle: 50, v0: 22, gravity: 9.8 }); flash('Cast projectile', true); });
        document.getElementById('bcSlide').addEventListener('click', function () { if (!need()) return; var bullets = document.getElementById('slideBullets').value.split('\n').map(function (s) { return s.trim(); }).filter(Boolean); T.publishSlide(bid, { title: document.getElementById('slideTitle').value, bullets: bullets }); flash('Slide published', true); });
      });
    })();
  </script>
</AquintutorLayout>
