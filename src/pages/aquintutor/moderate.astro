---
// /aquintutor/moderate — the moderator live console (Prompt AP2a). Moderators work the real-time
// queue (remove/allow/dismiss) and mute/remove participants in live rooms. Gated by the moderator
// capability (delete); every action is audited server-side.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { can } from '@/lib/rbac';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/moderate');
const gate = await can(user, 'delete', { type: 'moderation' });
if (!gate.allow) return Astro.redirect('/aquintutor/hub');
---
<AquintutorLayout title="Moderation">
  <main style="max-width:840px;margin:0 auto;padding:32px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Live safety</p>
    <h1 style="font-family:Fraunces,serif;font-size:26px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 4px;">Moderation queue</h1>
    <p style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#6b6455;margin:0 0 16px;">Flagged and reported messages from live rooms. Text is stored redacted and data-minimized. Removing hides the message; mute/remove applies to the participant in that room.</p>
    <div id="msg" style="display:none;margin:0 0 12px;padding:9px 13px;border-radius:8px;font-size:13px;"></div>
    <div id="queue" style="display:flex;flex-direction:column;gap:10px;"><p style="font-family:'Inter Tight',sans-serif;color:#8a8378;">Loading…</p></div>
  </main>

  <script is:inline>
    (function () {
      var box = document.getElementById('queue'), msg = document.getElementById('msg');
      function flash(t, ok) { msg.style.display = 'block'; msg.textContent = t; msg.style.background = ok ? '#eef8f1' : '#fdecec'; msg.style.color = ok ? '#2f7d5b' : '#9b2c2c'; }
      function post(body) { return fetch('/api/aquintutor/moderate', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }).then(function (r) { return r.json(); }); }
      function load() {
        post({ action: 'queue', status: 'pending' }).then(function (j) {
          if (!j.ok) { box.innerHTML = '<p style="color:#9b2c2c;">' + (j.error || 'error') + '</p>'; return; }
          if (!j.queue.length) { box.innerHTML = '<p style="font-family:Inter Tight,sans-serif;color:#8a8378;">Queue is clear.</p>'; return; }
          box.innerHTML = '';
          j.queue.forEach(function (q) {
            var card = document.createElement('div'); card.style.cssText = 'background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:12px;padding:12px 14px;';
            var sev = q.severity === 'severe' ? '#9b2c2c' : '#b3541e';
            card.innerHTML = '<div style="display:flex;justify-content:space-between;font-family:Geist Mono,monospace;font-size:11px;color:' + sev + ';margin-bottom:6px;"><span>' + q.severity + ' · ' + (q.categories || []).join(', ') + ' · ' + q.surface + '</span><span>#' + q.id + '</span></div><div style="font-family:Inter Tight,sans-serif;font-size:14px;color:#1a1712;margin-bottom:8px;">' + (q.redacted || '(reported)') + '</div>';
            var bar = document.createElement('div'); bar.style.cssText = 'display:flex;gap:6px;flex-wrap:wrap;';
            [['Remove', 'remove', '#9b2c2c'], ['Allow', 'allow', '#2f7d5b'], ['Dismiss', 'dismiss', '#8a8378']].forEach(function (a) {
              var btn = document.createElement('button'); btn.textContent = a[0]; btn.style.cssText = 'border:1px solid ' + a[2] + ';color:' + a[2] + ';background:#fff;border-radius:8px;padding:6px 12px;font-size:12.5px;cursor:pointer;';
              btn.addEventListener('click', function () { post({ action: 'act', id: q.id, decision: a[1] }).then(function () { flash('#' + q.id + ' ' + a[1] + 'ed', true); load(); }); });
              bar.appendChild(btn);
            });
            if (q.room_id && q.user_id) {
              [['Mute', 'mute'], ['Remove from room', 'remove']].forEach(function (a) {
                var btn = document.createElement('button'); btn.textContent = a[0]; btn.style.cssText = 'border:1px solid #b3541e;color:#b3541e;background:#fff;border-radius:8px;padding:6px 12px;font-size:12.5px;cursor:pointer;';
                btn.addEventListener('click', function () { post({ action: a[1], roomId: q.room_id, userId: q.user_id }).then(function () { flash('participant ' + a[1] + 'd', true); }); });
                bar.appendChild(btn);
              });
            }
            card.appendChild(bar); box.appendChild(card);
          });
        });
      }
      load(); setInterval(load, 6000);
    })();
  </script>
</AquintutorLayout>
