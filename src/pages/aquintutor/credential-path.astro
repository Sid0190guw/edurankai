---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { getTrackState, getProgressByTrack, TRACKS } from '@/lib/aquintutor-atelier';
// Credential Path — the Atelier (vocational / lifelong) tier signature. Pick a
// trade credential track and work through its practical competencies, logging
// evidence for each until the track is portfolio-ready. Server-persisted, no LLM.
const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/credential-path'));
const trackId = (Astro.url.searchParams.get('track') || 'web-dev');
const valid = TRACKS.some((t) => t.id === trackId) ? trackId : 'web-dev';
const [state, progress] = await Promise.all([getTrackState(user.id, valid), getProgressByTrack(user.id)]);
const tracksMeta = TRACKS.map((t) => ({ id: t.id, name: t.name, field: t.field, blurb: t.blurb, total: t.competencies.length }));
---
<AquintutorLayout title="Credential Path" description="Pick a trade credential and prove each practical competency with logged evidence — a real apprenticeship-style portfolio, not passive video, that ends portfolio-ready.">
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:900px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a><span style="margin:0 8px;">/</span><span style="color:var(--rust); font-weight:600;">CREDENTIAL PATH</span>
    </div>
  </div>

  <section style="max-width:760px; margin:0 auto; padding:34px 24px 80px;">
    <p style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--rust); font-weight:700; margin:0 0 8px;">AquinTutor Atelier · Vocational · Lifelong</p>
    <h1 class="font-display" style="font-size:clamp(1.8rem,4vw,2.5rem); font-weight:500; margin:0 0 6px; color:var(--ink);">Prove the skill. Build the portfolio.</h1>
    <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); line-height:1.6; margin:0 0 22px; max-width:640px;">Switching careers isn't about watching lectures — it's about being able to <em>do</em> the job. Pick a trade, then demonstrate each competency and log your evidence. When every competency is signed off, your portfolio is ready to show an employer or assessor.</p>

    <div id="trackPicker" style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:22px;"></div>

    <div style="background:#fff; border:1.5px solid var(--rule); border-radius:16px; padding:18px; margin-bottom:20px;">
      <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:6px;">
        <h2 class="font-display" id="tkName" style="font-size:1.3rem; font-weight:600; color:var(--ink); margin:0;"></h2>
        <span id="tkProg" style="font-family:'JetBrains Mono',monospace; font-size:12px; font-weight:700; color:var(--rust);"></span>
      </div>
      <div style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-500); margin-bottom:12px;" id="tkField"></div>
      <div style="height:8px; background:var(--sand-100); border-radius:99px; overflow:hidden;"><div id="tkBar" style="height:100%; background:#1c7a45; width:0; transition:width .3s;"></div></div>
      <div id="tkReady" style="display:none; margin-top:12px; background:#eef3ee; border:1.5px solid #1c7a45; border-radius:10px; padding:10px 12px; font-family:'Inter Tight',sans-serif; font-size:13.5px; color:#1c7a45; font-weight:600;">Portfolio-ready. Every competency is evidenced — you can present this to an employer or assessor.</div>
    </div>

    <div id="compList"></div>
  </section>

  <style is:global>
    .tk-chip { background:var(--sand-50); border:1.5px solid var(--rule); color:var(--ink); border-radius:10px; padding:9px 14px; font-family:'Inter Tight',sans-serif; font-size:13.5px; cursor:pointer; text-align:left; }
    .tk-chip.on { background:var(--ink); color:var(--sand-50); border-color:var(--ink); font-weight:600; }
    .tk-chip small { display:block; font-family:'JetBrains Mono',monospace; font-size:10px; opacity:0.7; margin-top:1px; }
    .cp-ev { width:100%; background:var(--sand-50); border:1.5px solid var(--rule); border-radius:9px; padding:9px 11px; font-size:13.5px; font-family:inherit; color:var(--ink); outline:none; resize:vertical; margin-top:8px; }
  </style>

  <script is:inline define:vars={{ initState: state, initProgress: progress, tracks: tracksMeta, activeId: valid }}>
  (function(){
    var cur=activeId, state=initState, progress=Object.assign({}, initProgress||{});
    var picker=document.getElementById('trackPicker'), list=document.getElementById('compList');

    function renderPicker(){
      picker.innerHTML='';
      tracks.forEach(function(t){
        var done=progress[t.id]||0;
        var b=document.createElement('button'); b.className='tk-chip'+(t.id===cur?' on':'');
        b.innerHTML=t.name+'<small>'+t.field+' · '+done+'/'+t.total+'</small>';
        b.addEventListener('click', function(){ if(t.id===cur) return; switchTrack(t.id); });
        picker.appendChild(b);
      });
    }
    function switchTrack(id){
      cur=id; renderPicker();
      list.innerHTML='<p style="font-family:Inter Tight,sans-serif;font-size:14px;color:var(--ink-500);padding:14px 0;">Loading…</p>';
      fetch('/api/aquintutor/atelier?track='+encodeURIComponent(id),{credentials:'same-origin'}).then(function(r){return r.json();}).then(function(j){
        if(j&&j.ok){ state=j.state; progress=j.progress||progress; renderPicker(); renderTrack(); }
      }).catch(function(){});
      try{ history.replaceState(null,'', '/aquintutor/credential-path?track='+id); }catch(e){}
    }
    function esc(s){ return (s==null?'':String(s)).replace(/[&<>"]/g,function(m){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[m];}); }

    function renderTrack(){
      var t=state.track, items=state.items, done=items.filter(function(i){return i.demonstrated;}).length;
      document.getElementById('tkName').textContent=t.name;
      document.getElementById('tkField').textContent=t.field;
      var pct=Math.round(done/items.length*100);
      document.getElementById('tkBar').style.width=pct+'%';
      document.getElementById('tkProg').textContent=done+' / '+items.length+' ('+pct+'%)';
      document.getElementById('tkReady').style.display=(done===items.length)?'block':'none';
      progress[t.id]=done; renderPicker();

      list.innerHTML='';
      items.forEach(function(it,idx){
        var d=document.createElement('div'); d.style.cssText='background:#fff;border:1.5px solid '+(it.demonstrated?'#1c7a45':'var(--rule)')+';border-radius:14px;padding:14px 16px;margin-bottom:10px;';
        d.innerHTML='<div style="display:flex;gap:12px;align-items:flex-start;">'
          +'<button class="cp-toggle" data-key="'+it.key+'" title="Mark demonstrated" style="flex-shrink:0;width:26px;height:26px;border-radius:8px;border:2px solid '+(it.demonstrated?'#1c7a45':'var(--rule)')+';background:'+(it.demonstrated?'#1c7a45':'#fff')+';cursor:pointer;display:flex;align-items:center;justify-content:center;">'+(it.demonstrated?'<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>':'')+'</button>'
          +'<div style="flex:1;"><div style="font-family:Inter Tight,sans-serif;font-size:15px;font-weight:600;color:var(--ink);">'+esc(it.label)+'</div>'
          +'<div style="font-family:Inter Tight,sans-serif;font-size:13px;color:var(--ink-500);margin-top:2px;line-height:1.5;">'+esc(it.detail)+'</div>'
          +'<textarea class="cp-ev" data-key="'+it.key+'" rows="2" placeholder="Log your evidence — what you did, links, photos described, sign-off…">'+esc(it.evidence)+'</textarea>'
          +'<div style="display:flex;align-items:center;gap:8px;margin-top:6px;"><button class="cp-save" data-key="'+it.key+'" style="background:transparent;border:1px solid var(--rule);border-radius:8px;padding:5px 12px;font-family:Inter Tight,sans-serif;font-size:12px;font-weight:600;color:var(--ink-500);cursor:pointer;">Save evidence</button><span class="cp-msg" data-key="'+it.key+'" style="font-family:Inter Tight,sans-serif;font-size:12px;color:#1c7a45;"></span></div>'
          +'</div></div>';
        list.appendChild(d);
      });
      Array.prototype.forEach.call(list.querySelectorAll('.cp-toggle'), function(b){ b.addEventListener('click', function(){ toggle(b.getAttribute('data-key')); }); });
      Array.prototype.forEach.call(list.querySelectorAll('.cp-save'), function(b){ b.addEventListener('click', function(){ saveEv(b.getAttribute('data-key')); }); });
    }
    function itemByKey(k){ for(var i=0;i<state.items.length;i++) if(state.items[i].key===k) return state.items[i]; return null; }
    function toggle(k){ var it=itemByKey(k); if(!it) return; it.demonstrated=!it.demonstrated; renderTrack(); save(k,it.demonstrated,it.evidence); }
    function saveEv(k){ var it=itemByKey(k); if(!it) return; var ta=list.querySelector('.cp-ev[data-key="'+k+'"]'); it.evidence=ta?ta.value:it.evidence; save(k,it.demonstrated,it.evidence,true); }
    function save(k,dem,ev,showMsg){
      fetch('/api/aquintutor/atelier',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'same-origin',body:JSON.stringify({action:'evidence',track:cur,key:k,demonstrated:dem,evidence:ev})}).then(function(r){return r.json();}).then(function(j){
        if(showMsg){ var m=list.querySelector('.cp-msg[data-key="'+k+'"]'); if(m){ m.textContent=(j&&j.ok)?'Saved':'Save failed'; m.style.color=(j&&j.ok)?'#1c7a45':'#b3271c'; setTimeout(function(){m.textContent='';},1400); } }
      }).catch(function(){});
    }

    renderPicker(); renderTrack();
  })();
  </script>
</AquintutorLayout>
