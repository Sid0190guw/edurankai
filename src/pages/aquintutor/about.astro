---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

let stats = { schools: 0, departments: 0, courses: 0, instructors: 0, lessons: 0, enrolled: 0, credentials: 0, exams: 0 };
try {
  const r = await db.execute(sql`
    SELECT
      (SELECT COUNT(*) FROM schools WHERE is_published = true)::int as schools,
      (SELECT COUNT(*) FROM academic_departments WHERE is_published = true)::int as departments,
      (SELECT COUNT(*) FROM training_courses WHERE is_published = true)::int as courses,
      (SELECT COUNT(*) FROM training_instructors)::int as instructors,
      (SELECT COUNT(*) FROM training_lessons l JOIN training_courses c ON l.course_id = c.id WHERE c.is_published = true)::int as lessons,
      (SELECT COUNT(DISTINCT user_id) FROM training_enrollments)::int as enrolled,
      (SELECT COUNT(*) FROM training_certificates)::int as credentials,
      (SELECT COUNT(*) FROM test_attempts WHERE status IN ('submitted','auto_submitted'))::int as exams
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  stats = { ...stats, ...(rows[0] as any) };
} catch (_) {}

const principles = [
  { num: 'I', label: 'Honest scope', body: 'We publish a public roadmap. We do not advertise features that are not yet live; we do not retire features quietly. What is shipped, is shipped.', detail: 'See /aquintutor/roadmap for every milestone, every quarter, in writing.' },
  { num: 'II', label: 'Frontier research focus', body: 'We work on the problems that define the next century - Vedic sciences, artificial super-intelligence, quantum technology, advanced computing. Each programme is selective and led by named faculty.', detail: 'Admission is by application. Two intakes per year - autumn and spring.' },
  { num: 'III', label: 'Verifiable credentials', body: 'Every passing credential publishes at a permanent public URL with the recipient, course, date, and proctor record. Employers can verify without an account.', detail: 'Schema.org EducationalOccupationalCredential JSON-LD on every credential page.' },
  { num: 'IV', label: 'Named faculty', body: 'Every course is authored, reviewed, or supervised by a named member of the faculty roll. No anonymous content, no licensed third-party catalogues.', detail: 'All faculty members listed at /aquintutor/instructors with research interests and office hours.' },
  { num: 'V', label: 'Text-only proctoring', body: 'During proctored examinations we run face and microphone analysis in-browser, but nothing is uploaded. Only typed event logs leave the candidate machine.', detail: 'Candidates can audit their own event log at the end of every attempt.' },
  { num: 'VI', label: 'Annual review', body: 'Every course is reviewed every twelve months. Material that does not hold up is rewritten or retired. The retirement log is public.', detail: 'No course is kept in catalogue just because it sells.' },
];

const timeline = [
  { y: '2025 Q4', label: 'Charter drafted', body: 'EduRank&middot;AI commits to launch a working virtual unEuropean MOOC consortium by autumn 2026.' },
  { y: '2026 Q1', label: 'Faculty seeded', body: 'First six faculty members sign letters of appointment; school structure committed.' },
  { y: '2026 Q2', label: 'Open enrolment', body: 'Catalogue published; first cohort enrolled; first credentials issued; ATLAS examinations live.' },
  { y: '2026 Q3', label: 'AI screening interview', body: 'Multilingual screening interview opened in 17 languages with live transcription.' },
  { y: '2026 Q4', label: 'Tutorial week', body: 'First synchronous tutorial cohorts of ten; office hours begin in scheduled slots.' },
  { y: '2027 Q1', label: 'Research notes', body: 'First public research notes from named faculty under permissive licence.' },
];

const faqs = [
  { q: 'Is AquinTutor accredited?', a: 'We are not currently affiliated with a state accreditation body. The credential is a verified record of completed work, issued by a named institution with a public roadmap and named faculty. Partnerships with credit-bearing institutions are listed under Roadmap.' },
  { q: 'Who reviews my work?', a: 'Module quizzes are auto-graded. Long-form answers are reviewed by faculty within five working days. Final examinations are proctored under ATLAS; the proctor log is auditable by the candidate.' },
  { q: 'Can I take just one course?', a: 'Yes. Admission is per programme; you can enrol in a single course and sit its credential examination without committing to a full path. Application details on the admissions page.' },
  { q: 'Where do credentials live?', a: 'At /credentials/[number] under our own domain. The page renders structured JSON-LD that LinkedIn, Google, and most CRMs parse without intervention.' },
  { q: 'Who runs the institution?', a: 'AquinTutor is operated by EduRank&middot;AI. The registrar answers institutional correspondence at hr@edurankai.in. Faculty have public profile pages.' },
];
---
<AquintutorLayout title="About the institution" description="AquinTutor is a virtual unEuropean MOOC consortium by EduRank-AI. Six schools, faculty-written curriculum, proctored examinations, and verifiable credentials.">

  <!-- HERO -->
  <section style="border-bottom:1px solid var(--rule); position:relative; overflow:hidden;">
    <div aria-hidden="true" style="position:absolute; left:50%; transform:translateX(-50%); top:-40px; opacity:0.04; pointer-events:none;">
      <svg width="900" height="500" viewBox="0 0 900 500" fill="none">
        <text x="50%" y="50%" text-anchor="middle" dominant-baseline="middle" font-family="Fraunces, serif" font-size="380" font-style="italic" font-weight="300" fill="var(--ink)">A.</text>
      </svg>
    </div>
    <div style="max-width:1280px; margin:0 auto; padding:88px 28px 56px; position:relative; z-index:1;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); font-weight:600; letter-spacing:0.04em; margin:0 0 18px;">About the institution</p>
      <h1 class="font-display" style="font-size:clamp(2.5rem, 6vw, 5rem); line-height:0.98; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--ink); max-width:46rem;">
        A working institution.<br/>
        <span style="font-style:italic; font-weight:300; color:var(--ink-500);">Not a marketplace, not a credential mill.</span>
      </h1>
      <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.15rem, 1.5vw, 1.4rem); line-height:1.5; color:var(--ink-500); margin:28px 0 0; max-width:40rem;">
        AquinTutor is the virtual unEuropean MOOC consortium operated by EduRank&middot;AI - established 2026, headquartered in Bharat, open to applicants worldwide. The faculty writes the courses. The AI runs the office hours. The proctor watches the examination. The credential is verifiable at a permanent public URL.
      </p>
    </div>
  </section>

  <!-- MANIFESTO -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1100px; margin:0 auto; padding:80px 28px; position:relative;">
      <div aria-hidden="true" style="position:absolute; top:48px; left:28px; font-family:'Fraunces',serif; font-size:9rem; line-height:1; color:var(--ink); opacity:0.07; font-weight:500;">&ldquo;</div>
      <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 18px; position:relative; z-index:1;">Our position</p>
      <blockquote class="font-display" style="font-style:italic; font-weight:300; font-size:clamp(1.5rem, 2.8vw, 2.35rem); line-height:1.3; letter-spacing:-0.015em; color:var(--ink); max-width:54rem; margin:0; position:relative; z-index:1;">
        For nine centuries the unEuropean MOOC consortium has answered three questions - <span style="font-style:normal; font-weight:400;">what to study, how to study it, and who certifies that you did.</span> We keep the academic rigour, remove the gatekeeping that has historically priced students out, and give every enrolled student a private AI tutor who is awake at every hour, fluent in every prerequisite, and patient with every obvious question.
      </blockquote>
    </div>
  </section>

  <!-- STAT BAR -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1280px; margin:0 auto; padding:48px 28px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 22px;">The institution today &middot; live counts</p>
      <div style="display:grid; grid-template-columns:repeat(2, 1fr); gap:14px;" class="num-grid">
        {[
          { l: 'Schools', v: stats.schools },
          { l: 'Departments', v: stats.departments },
          { l: 'Open courses', v: stats.courses },
          { l: 'Lessons published', v: stats.lessons },
          { l: 'Faculty', v: stats.instructors },
          { l: 'Enrolled students', v: stats.enrolled },
          { l: 'Credentials issued', v: stats.credentials },
          { l: 'Research focus', v: 'Frontier', accent: true },
        ].map((s) => (
          <div style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:18px 20px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); margin:0 0 8px; font-weight:600;">{s.l}</p>
            <p class="font-display" style={'font-size:1.85rem; font-weight:500; margin:0; line-height:1; letter-spacing:-0.02em; ' + (s.accent ? 'color:var(--rust);' : 'color:var(--ink);')}>{s.v}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRINCIPLES -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1280px; margin:0 auto; padding:72px 28px;">
      <div style="display:grid; grid-template-columns:1fr; gap:24px; margin-bottom:36px;" class="thesis-grid">
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">Operating principles</p>
          <h2 class="font-display" style="font-size:clamp(1.75rem, 3vw, 2.5rem); font-weight:500; line-height:1.12; letter-spacing:-0.015em; margin:0; color:var(--ink);">
            What we hold to,<br/>
            <span style="font-style:italic; font-weight:300; color:var(--ink-500);">in six articles.</span>
          </h2>
        </div>
        <p style="font-family:'Inter Tight',sans-serif; font-size:14.5px; color:var(--ink-500); line-height:1.65; margin:0; max-width:34rem; justify-self:end;" class="thesis-rhs">These are not aspirational. They are the rules under which the institution runs. Every faculty appointment, course publication, and credential issuance is reviewed against them annually.</p>
      </div>

      <div style="display:grid; grid-template-columns:1fr; gap:18px;" class="principles-grid">
        {principles.map((p) => (
          <article style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:26px;">
            <div style="display:flex; align-items:baseline; gap:14px; margin-bottom:12px;">
              <span class="font-display" style="font-style:italic; font-weight:300; font-size:2.25rem; color:var(--rust); line-height:1; letter-spacing:-0.02em;">{p.num}</span>
              <h3 class="font-display" style="font-size:1.2rem; font-weight:500; margin:0; line-height:1.2; letter-spacing:-0.015em; color:var(--ink);">{p.label}</h3>
            </div>
            <p style="font-family:'Inter Tight',sans-serif; font-size:14.5px; color:var(--ink); line-height:1.6; margin:0 0 10px;">{p.body}</p>
            <p style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500); line-height:1.5; margin:0; padding-top:10px; border-top:1px dashed var(--rule); font-style:italic;">{p.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- TIMELINE -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1280px; margin:0 auto; padding:72px 28px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">Institutional record</p>
      <h2 class="font-display" style="font-size:clamp(1.75rem, 3vw, 2.5rem); font-weight:500; line-height:1.12; letter-spacing:-0.015em; margin:0 0 36px; color:var(--ink); max-width:36rem;">
        From charter<br/>
        <span style="font-style:italic; font-weight:300; color:var(--ink-500);">to current term.</span>
      </h2>

      <ol style="list-style:none; padding:0; margin:0; position:relative;" class="timeline-list">
        <div aria-hidden="true" style="position:absolute; left:120px; top:14px; bottom:14px; width:1px; background:var(--rule);" class="hide-mobile"></div>
        {timeline.map((t) => (
          <li style="display:grid; grid-template-columns:1fr; gap:8px; padding:20px 0; border-bottom:1px solid var(--rule);" class="timeline-row">
            <span style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.06em; position:relative;">
              <span aria-hidden="true" style="display:inline-block; width:10px; height:10px; border-radius:50%; background:var(--rust); margin-right:10px; position:relative; z-index:1;" class="timeline-dot"></span>{t.y}
            </span>
            <div>
              <p class="font-display" style="font-size:1.15rem; font-weight:500; margin:0 0 4px; line-height:1.25; letter-spacing:-0.015em; color:var(--ink);">{t.label}</p>
              <p style="font-family:'Inter Tight',sans-serif; font-size:14px; line-height:1.6; color:var(--ink-500); margin:0;" set:html={t.body}></p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- FAQ -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1280px; margin:0 auto; padding:72px 28px;">
      <div style="display:grid; grid-template-columns:1fr; gap:32px;" class="faq-grid">
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">Questions we hear most</p>
          <h2 class="font-display" style="font-size:clamp(1.65rem, 2.6vw, 2.15rem); font-weight:500; line-height:1.18; letter-spacing:-0.015em; margin:0 0 18px; color:var(--ink);">A short FAQ.</h2>
          <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); line-height:1.65; margin:0; max-width:24rem;">If your question isn't here, write to the registrar at <a href="mailto:hr@edurankai.in" style="color:var(--rust); text-decoration:underline;">hr@edurankai.in</a>.</p>
        </div>
        <div>
          {faqs.map((f) => (
            <details style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:18px 22px; margin-bottom:10px;">
              <summary style="font-family:'Inter Tight',sans-serif; font-size:15px; font-weight:600; cursor:pointer; color:var(--ink); list-style:none;">{f.q}</summary>
              <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); line-height:1.65; margin:12px 0 0;" set:html={f.a}></p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CORRESPONDENCE -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1280px; margin:0 auto; padding:72px 28px;">
      <div style="display:grid; grid-template-columns:1fr; gap:48px;" class="contact-grid">
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">Correspondence</p>
          <h2 class="font-display" style="font-size:clamp(1.65rem, 2.6vw, 2.15rem); font-weight:500; line-height:1.18; letter-spacing:-0.015em; margin:0 0 16px; color:var(--ink);">Reach the institution.</h2>
          <p style="font-family:'Inter Tight',sans-serif; font-size:14.5px; color:var(--ink-500); line-height:1.65; margin:0; max-width:30rem;">All institutional correspondence is read by a human and answered within five working days.</p>
        </div>
        <dl style="display:grid; grid-template-columns:1fr; gap:18px; margin:0; font-family:'Inter Tight',sans-serif;" class="contact-list">
          {[
            { k: 'Registrar', v: 'hr@edurankai.in', href: 'mailto:hr@edurankai.in', d: 'Admissions, faculty appointments, transcripts.' },
            { k: 'Technical support', v: 'support@edurankai.in', href: 'mailto:support@edurankai.in', d: 'Examinations, credentials, account.' },
            { k: 'Press', v: 'press@edurankai.in', href: 'mailto:press@edurankai.in', d: 'Media queries, partnership announcements.' },
          ].map((c) => (
            <div style="padding-bottom:18px; border-bottom:1px solid var(--rule);">
              <dt style="font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 4px;">{c.k}</dt>
              <dd style="margin:0;"><a href={c.href} style="font-size:15.5px; color:var(--ink); text-decoration:underline; font-weight:500;">{c.v}</a></dd>
              <p style="margin:6px 0 0; font-size:13px; color:var(--ink-500); line-height:1.55;">{c.d}</p>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:var(--ink); color:var(--sand-50);">
    <div style="max-width:1100px; margin:0 auto; padding:64px 28px; display:grid; grid-template-columns:1fr; gap:32px; align-items:center;" class="cta-grid">
      <div>
        <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:#d97757; font-weight:600; letter-spacing:0.04em; margin:0 0 14px;">Admissions are open &middot; rolling intake</p>
        <h2 class="font-display" style="font-size:clamp(1.85rem, 3.5vw, 2.85rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0 0 14px; color:var(--sand-50);">Begin a term.</h2>
        <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.05rem, 1.4vw, 1.2rem); line-height:1.55; color:rgba(251,250,244,0.75); margin:0; max-width:36rem;">Pick a school, choose a course, do the work. The credential at the end is yours.</p>
      </div>
      <div style="display:flex; flex-direction:column; gap:10px; max-width:340px; justify-self:end;">
        <a href="/aquintutor/signup" style="background:#d97757; color:#1a0f08; padding:14px 24px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none; text-align:center;">Apply for admission &rarr;</a>
        <a href="/aquintutor/courses" style="background:transparent; color:var(--sand-50); padding:14px 24px; border-radius:6px; border:1px solid rgba(251,250,244,0.4); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none; text-align:center;">Browse the catalogue</a>
      </div>
    </div>
  </section>

  <style>
    details summary::after { content: '+'; float: right; color: var(--rust); font-weight: 600; font-size: 18px; line-height: 1; }
    details[open] summary::after { content: '-'; }
    @media (min-width: 768px) {
      .num-grid { grid-template-columns: repeat(4, 1fr) !important; }
      .thesis-grid { grid-template-columns: 1fr 1fr !important; }
      .principles-grid { grid-template-columns: repeat(2, 1fr) !important; }
      .timeline-row { grid-template-columns: 160px 1fr !important; }
      .faq-grid { grid-template-columns: 1fr 2fr !important; }
      .contact-grid { grid-template-columns: 1fr 2fr !important; }
      .contact-list { grid-template-columns: repeat(3, 1fr) !important; }
      .cta-grid { grid-template-columns: 1.5fr 1fr !important; }
    }
    @media (min-width: 1000px) {
      .principles-grid { grid-template-columns: repeat(3, 1fr) !important; }
    }
  </style>
</AquintutorLayout>
