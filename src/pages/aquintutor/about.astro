---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

let stats = { schools: 0, departments: 0, courses: 0, instructors: 0, lessons: 0 };
try {
  const r = await db.execute(sql`
    SELECT
      (SELECT COUNT(*) FROM schools WHERE is_published = true)::int as schools,
      (SELECT COUNT(*) FROM academic_departments WHERE is_published = true)::int as departments,
      (SELECT COUNT(*) FROM training_courses WHERE is_published = true)::int as courses,
      (SELECT COUNT(*) FROM training_instructors)::int as instructors,
      (SELECT COUNT(*) FROM training_lessons l JOIN training_courses c ON l.course_id = c.id WHERE c.is_published = true)::int as lessons
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  stats = { ...stats, ...(rows[0] as any) };
} catch (_) {}
---
<AquintutorLayout title="About the institution" description="AquinTutor is a virtual university by EduRank-AI. Six schools, faculty-written curriculum, proctored examinations, and verifiable credentials.">

  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1280px; margin:0 auto; padding:80px 28px 48px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); font-weight:600; letter-spacing:0.04em; margin:0 0 16px;">About the institution</p>
      <h1 class="font-display" style="font-size:clamp(2.5rem, 5vw, 4.5rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0; color:var(--ink); max-width:42rem;">
        A virtual university built for the students the existing system never had room for.
      </h1>
    </div>
  </section>

  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1280px; margin:0 auto; padding:64px 28px; display:grid; grid-template-columns:1fr; gap:48px;" class="about-grid">
      <aside>
        <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Our position</p>
        <h2 class="font-display" style="font-size:1.5rem; font-weight:500; line-height:1.2; letter-spacing:-0.01em; margin:0;">What kind of institution this is.</h2>
      </aside>
      <div>
        <p style="font-family:'Inter Tight',sans-serif; font-size:17px; line-height:1.7; color:var(--ink); margin:0 0 18px;">
          AquinTutor is an operating virtual university by EduRank&middot;AI, headquartered in Bharat and open to applicants worldwide. We were established in 2026 with a deliberate scope: to make a real university education available to anyone with an internet connection and twelve hours a week.
        </p>
        <p style="font-family:'Inter Tight',sans-serif; font-size:16.5px; line-height:1.7; color:var(--ink-500); margin:0 0 18px;">
          For nine centuries the university has answered three questions &mdash; <em>what to study, how to study it, and who certifies that you did.</em> AquinTutor keeps the academic rigour, removes the gatekeeping that has historically priced students out, and provides every enrolled student with a private AI tutor who is awake at every hour, fluent in every prerequisite, and patient with every obvious question.
        </p>
        <p style="font-family:'Inter Tight',sans-serif; font-size:16.5px; line-height:1.7; color:var(--ink-500); margin:0;">
          The faculty writes the courses. The AI runs the office hours. The proctor watches the examination. The credential is verifiable at a permanent public URL. It is a working institution &mdash; not a marketplace, not a credential mill, not an aggregator of someone else's content.
        </p>
      </div>
    </div>
  </section>

  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1280px; margin:0 auto; padding:64px 28px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">The institution today</p>
      <h2 class="font-display" style="font-size:clamp(1.75rem, 3vw, 2.5rem); line-height:1.15; letter-spacing:-0.015em; font-weight:500; margin:0 0 36px; color:var(--ink);">Live counts.</h2>
      <div style="display:grid; grid-template-columns:repeat(2, 1fr); gap:14px;" class="num-grid">
        {[
          ['Schools', stats.schools],
          ['Departments', stats.departments],
          ['Open courses', stats.courses],
          ['Lessons published', stats.lessons],
          ['Faculty appointments', stats.instructors],
          ['Enrolment fee', '1 CHF'],
        ].map(([k, v]) => (
          <div style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:24px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); margin:0 0 8px; font-weight:600;">{k}</p>
            <p class="font-display" style="font-size:2.5rem; font-weight:500; margin:0; line-height:1; color:var(--ink);">{v}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1280px; margin:0 auto; padding:64px 28px; display:grid; grid-template-columns:1fr; gap:48px;" class="about-grid">
      <aside>
        <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Principles</p>
        <h2 class="font-display" style="font-size:1.5rem; font-weight:500; line-height:1.2; letter-spacing:-0.01em; margin:0;">What we hold to.</h2>
      </aside>
      <div style="display:grid; grid-template-columns:1fr; gap:24px;">
        {[
          ['Honest scope', 'We publish a public roadmap. We do not advertise features that are not yet live; we do not retire features quietly. What is shipped, is shipped.'],
          ['Accessible enrolment', 'A single one Swiss franc enrolment opens the entire institution. Proctored examinations are billed separately, only for credentials a student chooses to sit.'],
          ['Verifiable credentials', 'Every passing credential publishes at a permanent public URL with the recipient, course, date, and proctor record. Employers can verify without an account.'],
          ['Named faculty', 'Every course is authored, reviewed, or supervised by a named member of the faculty roll. No anonymous content, no licensed third-party catalogues.'],
        ].map(([t, b]) => (
          <div style="display:grid; grid-template-columns:1fr; gap:6px;">
            <h3 class="font-display" style="font-size:1.2rem; font-weight:500; margin:0; line-height:1.25; letter-spacing:-0.01em;">{t}</h3>
            <p style="font-family:'Inter Tight',sans-serif; font-size:15.5px; color:var(--ink-500); line-height:1.6; margin:0;">{b}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div style="max-width:1280px; margin:0 auto; padding:64px 28px; display:grid; grid-template-columns:1fr; gap:32px; align-items:center;" class="cta-grid">
      <div>
        <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Admissions are open</p>
        <h2 class="font-display" style="font-size:clamp(1.75rem, 3vw, 2.5rem); line-height:1.15; letter-spacing:-0.015em; font-weight:500; margin:0; color:var(--ink);">Begin a term.</h2>
        <p style="font-family:'Inter Tight',sans-serif; font-size:15.5px; color:var(--ink-500); line-height:1.55; margin:14px 0 0; max-width:36rem;">Pick a school, choose a course, do the work. The credential at the end is yours.</p>
      </div>
      <div style="display:flex; flex-direction:column; gap:10px; max-width:340px;">
        <a href="/aquintutor/signup" style="background:var(--ink); color:var(--sand-50); padding:14px 24px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none; text-align:center;">Apply &middot; 1 CHF &rarr;</a>
        <a href="/aquintutor/courses" style="background:transparent; color:var(--ink); padding:14px 24px; border-radius:6px; border:1px solid var(--ink); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none; text-align:center;">Browse the catalogue</a>
      </div>
    </div>
  </section>

  <style>
    @media (min-width: 768px) {
      .about-grid { grid-template-columns: 1fr 2fr !important; }
      .num-grid { grid-template-columns: repeat(3, 1fr) !important; }
      .cta-grid { grid-template-columns: 2fr 1fr !important; }
    }
  </style>
</AquintutorLayout>
