---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

const upcoming = [
  { course: 'RB-330', title: 'Midterm · Robotics IK gauntlet', date: 'Tue May 13', time: '14:00-16:00', readiness: 78, color: '#946322', kind: 'midterm', practice: 3 },
  { course: 'QT-407', title: 'Final · Quantum Foundations', date: 'Fri Jun 6', time: '09:00-12:00', readiness: 62, color: '#5b4a92', kind: 'final', practice: 2 },
  { course: 'AI-512', title: 'Practical · Build a transformer', date: 'Wed Jun 11', time: '10:00-13:00', readiness: 85, color: '#2b577e', kind: 'practical', practice: 5 },
];

const past = [
  { course: 'CS-201', title: 'Final · Data Structures', date: 'Dec 12 · 2025', score: 94, grade: 'A', color: '#2b577e' },
  { course: 'MA-205', title: 'Midterm · Linear Algebra', date: 'Oct 23 · 2025', score: 88, grade: 'A-', color: '#5b4a92' },
  { course: 'CS-201', title: 'Midterm · Data Structures', date: 'Oct 12 · 2025', score: 91, grade: 'A', color: '#2b577e' },
  { course: 'CS-101', title: 'Final · Intro to Computing', date: 'May 6 · 2025', score: 96, grade: 'A', color: '#2b577e' },
];

const integrity = [
  { l: 'Identity verification', d: 'Government ID + live face match; never stored.' },
  { l: 'Tab focus tracking', d: 'Every switch logged as a text event with timestamp.' },
  { l: 'Voice envelope', d: 'RMS only; no audio bytes leave the browser.' },
  { l: 'Face & multi-face', d: 'On-device face-api; flagged events written to log.' },
  { l: 'Network drops', d: 'Logged. Auto-resume on reconnect within 60s.' },
  { l: 'Honour-code dossier', d: 'Issued alongside the credential, candidate-visible.' },
];

const accommodations = [
  ['Extra time', '1.5x / 2x by IEP'],
  ['Reader software', 'Screen reader, captions, mathjax'],
  ['Quiet room', 'Dedicated proctor session, no shared queue'],
  ['Calculator', 'Permitted per syllabus rules'],
];

function readinessColor(r: number) {
  if (r >= 80) return '#4a7048';
  if (r >= 65) return '#a87526';
  return '#a04330';
}
---
<AquintutorLayout title="Proctored exams" description="ATLAS - AquinTutor's proctored testing infrastructure. Identity, adaptive engine, AI sentinel, debrief. SOC 2 / FERPA / WCAG 2.2 AA.">

  <!-- BREADCRUMB -->
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1400px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a>
      <span style="margin:0 8px;">/</span>
      <a href="/aquintutor/dashboard" style="color:var(--ink-500); text-decoration:none;">DASHBOARD</a>
      <span style="margin:0 8px;">/</span>
      <span style="color:#2b577e; font-weight:600;">PROCTORED EXAMS · ATLAS</span>
    </div>
  </div>

  <!-- HEADER -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:32px 28px 24px;">
      <div style="display:flex; align-items:start; justify-content:space-between; gap:18px; flex-wrap:wrap;">
        <div>
          <div style="display:inline-flex; align-items:center; gap:8px; padding:4px 12px; background:rgba(43,87,126,0.08); border:1px solid rgba(43,87,126,0.3); border-radius:999px; font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.16em; text-transform:uppercase; color:#2b577e; font-weight:600; margin-bottom:12px;">ATLAS &middot; PROCTORED TESTING INFRASTRUCTURE</div>
          <h1 class="font-display" style="font-size:clamp(1.85rem, 4vw, 2.85rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0; color:var(--ink); max-width:42rem;">Exams run on ATLAS.</h1>
          <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1rem, 1.3vw, 1.2rem); color:var(--ink-500); line-height:1.5; margin:14px 0 0; max-width:42rem;">AquinTutor's proctored testing layer. Identity verification, adaptive engine, AI sentinel, candidate-auditable debrief. SOC 2, FERPA, WCAG 2.2 AA.</p>
        </div>
        <div style="display:flex; gap:8px; flex-wrap:wrap;">
          <button type="button" style="background:transparent; color:var(--ink); padding:10px 18px; border:1px solid var(--rule); border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; cursor:pointer;">Practice mode</button>
          <button type="button" style="background:#2b577e; color:#fff; padding:10px 18px; border:none; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; cursor:pointer;">ATLAS overview &rarr;</button>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN GRID -->
  <section style="background:var(--sand-100); border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:24px 28px 48px; display:grid; grid-template-columns:1fr; gap:18px;" class="ex-grid">

      <!-- LEFT: upcoming + past -->
      <div style="display:flex; flex-direction:column; gap:18px; min-width:0;">

        <!-- Upcoming -->
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; overflow:hidden;">
          <div style="display:flex; align-items:center; justify-content:space-between; padding:16px 20px; border-bottom:1px solid var(--rule); background:var(--sand-100); flex-wrap:wrap; gap:8px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0;">Upcoming exams &middot; 3</p>
            <span style="display:inline-flex; align-items:center; padding:3px 9px; background:rgba(43,87,126,0.10); border:1px solid #2b577e; border-radius:999px; font-family:'JetBrains Mono',monospace; font-size:9.5px; letter-spacing:0.1em; color:#2b577e; font-weight:600;">ALL PROCTORED ON ATLAS</span>
          </div>
          <div style="padding:14px; display:flex; flex-direction:column; gap:10px;">
            {upcoming.map((e) => (
              <article style={'position:relative; padding:16px 18px; background:var(--sand-100); border:1px solid var(--rule); border-left:3px solid ' + e.color + '; border-radius:10px; display:grid; grid-template-columns:1fr; gap:12px; align-items:center;'} class="ex-row">
                <div>
                  <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap; margin-bottom:6px;">
                    <span style={'display:inline-flex; align-items:center; padding:2px 9px; background:' + e.color + '14; border:1px solid ' + e.color + '40; border-radius:999px; font-family:JetBrains Mono,monospace; font-size:10px; letter-spacing:0.14em; text-transform:uppercase; color:' + e.color + '; font-weight:600;'}>{e.course}</span>
                    <span style="display:inline-flex; align-items:center; padding:2px 9px; background:var(--paper); border:1px solid var(--rule); border-radius:999px; font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-500);">{e.kind}</span>
                  </div>
                  <p class="font-display" style="font-size:1.1rem; font-weight:500; line-height:1.25; letter-spacing:-0.015em; color:var(--ink); margin:0;">{e.title}</p>
                  <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500); margin:5px 0 0; letter-spacing:0.04em;">{e.date} &middot; {e.time} &middot; {e.practice} practice runs available</p>
                </div>
                <div style="display:flex; align-items:center; justify-content:space-between; gap:14px; flex-wrap:wrap;">
                  <div style="text-align:center;">
                    <p style="font-family:'JetBrains Mono',monospace; font-size:9.5px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0;">Readiness</p>
                    <p style={'font-family:JetBrains Mono,monospace; font-size:1.55rem; color:' + readinessColor(e.readiness) + '; font-weight:700; margin:4px 0 0; line-height:1;'}>{e.readiness}%</p>
                  </div>
                  <div style="display:flex; gap:6px; flex-wrap:wrap;">
                    <button type="button" style="background:transparent; color:var(--ink-500); padding:8px 14px; border:1px solid var(--rule); border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:11.5px; font-weight:600; cursor:pointer;">Practice</button>
                    <button type="button" style={'background:' + e.color + '; color:#fff; padding:8px 14px; border:none; border-radius:6px; font-family:Inter Tight,sans-serif; font-size:11.5px; font-weight:600; cursor:pointer;'}>Prep with Aquin</button>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>

        <!-- Past exams -->
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; overflow:hidden;">
          <div style="padding:14px 20px; border-bottom:1px solid var(--rule); background:var(--sand-100); display:flex; justify-content:space-between; align-items:center;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0;">Past exams &middot; 12</p>
            <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:#4a7048; font-weight:600;">AVG 89%</span>
          </div>
          {past.map((e, i) => (
            <div style={'display:grid; grid-template-columns:auto 1fr auto auto; gap:14px; align-items:center; padding:14px 20px; ' + (i < past.length - 1 ? 'border-bottom:1px solid var(--rule);' : '')}>
              <span style={'display:inline-flex; align-items:center; padding:3px 9px; background:' + e.color + '14; border:1px solid ' + e.color + '40; border-radius:999px; font-family:JetBrains Mono,monospace; font-size:10px; letter-spacing:0.14em; color:' + e.color + '; font-weight:600;'}>{e.course}</span>
              <div>
                <p style="font-family:'Inter Tight',sans-serif; font-size:13.5px; font-weight:500; margin:0; color:var(--ink); line-height:1.3;">{e.title}</p>
                <p style="font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--ink-500); margin:2px 0 0; letter-spacing:0.04em;">{e.date}</p>
              </div>
              <span class="font-display" style="font-size:1.35rem; color:var(--ink); font-weight:500; line-height:1; letter-spacing:-0.02em;">{e.score}%</span>
              <span style="display:inline-flex; align-items:center; justify-content:center; width:34px; height:34px; border-radius:50%; background:#4a7048; color:#fff; font-family:'Fraunces',serif; font-weight:500; font-size:14px;">{e.grade}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- RIGHT: ATLAS hero + integrity + accommodations -->
      <aside style="display:flex; flex-direction:column; gap:18px; min-width:0;">

        <!-- ATLAS hero -->
        <div style="background:#0b0d10; color:#f4f1ea; border-radius:14px; padding:24px; position:relative; overflow:hidden;">
          <div aria-hidden="true" style="position:absolute; inset:0; background:repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(43,87,126,0.02) 3px, rgba(43,87,126,0.02) 4px); pointer-events:none;"></div>
          <div style="position:relative; z-index:1;">
            <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.2em; text-transform:uppercase; color:#7fb3ff; font-weight:600; margin:0 0 12px;">ATLAS</p>
            <h2 class="font-display" style="font-size:1.45rem; font-weight:500; line-height:1.15; letter-spacing:-0.015em; color:#f4f1ea; margin:0 0 12px;">Proctored, text-only, candidate-auditable.</h2>
            <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:14px; color:#c8c3b8; line-height:1.55; margin:0 0 16px;">Camera and microphone run in your browser. The event stream is recorded but no audio or video bytes ever leave your machine. Every flag is auditable by you before submission.</p>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">
              {[
                { k: 'BYTES UPLOADED', v: '0' },
                { k: 'LATENCY', v: '<16ms' },
                { k: 'SIGNALS', v: '11' },
                { k: 'AUDIT LOG', v: 'Open' },
              ].map((s) => (
                <div style="background:#161b22; border:1px solid #21262d; border-radius:8px; padding:10px 12px;">
                  <p style="font-family:'JetBrains Mono',monospace; font-size:9px; letter-spacing:0.14em; text-transform:uppercase; color:#7fb3ff; font-weight:600; margin:0;">{s.k}</p>
                  <p style="font-family:'JetBrains Mono',monospace; font-size:1.1rem; color:#f4f1ea; font-weight:700; line-height:1; margin:4px 0 0;">{s.v}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Integrity -->
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:20px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 12px;">Integrity layer</p>
          <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:9px;">
            {integrity.map((it) => (
              <li style="display:flex; align-items:start; gap:10px;">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4a7048" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg>
                <div>
                  <p style="font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; color:var(--ink); margin:0; line-height:1.3;">{it.l}</p>
                  <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink-500); margin:2px 0 0; line-height:1.45;">{it.d}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

        <!-- Accommodations -->
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:20px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 12px;">Accommodations available</p>
          <dl style="display:grid; grid-template-columns:1fr; gap:8px; margin:0;">
            {accommodations.map(([k, v]) => (
              <div style="display:flex; justify-content:space-between; gap:14px; padding:9px 12px; background:var(--sand-100); border:1px solid var(--rule); border-radius:6px;">
                <dt style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink); font-weight:500; margin:0;">{k}</dt>
                <dd style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--ink-500); margin:0; text-align:right;">{v}</dd>
              </div>
            ))}
          </dl>
          <a href="mailto:hr@edurankai.in?subject=Exam%20accommodations" style="display:inline-block; margin-top:12px; font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--rust); text-decoration:underline; font-weight:500;">Request an accommodation &rarr;</a>
        </div>
      </aside>
    </div>
  </section>

  <style>
    @media (min-width: 1000px) {
      .ex-grid { grid-template-columns: 1fr 380px !important; }
      .ex-row { grid-template-columns: 1.4fr 1fr !important; }
    }
  </style>
</AquintutorLayout>
