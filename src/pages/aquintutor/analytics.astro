---
// /aquintutor/analytics — a student's own learning analytics (Prompt 13, main surface). Real data
// only (mastery, completion, assessments, mastery timeline). Server-rendered; exportable as CSV.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { studentAnalytics } from '@/lib/analytics';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/analytics');
const a = await studentAnalytics(user.id).catch(() => null);
const CARD = 'background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:14px;padding:20px 22px;';
const maxT = Math.max(1, ...(a?.timeline || []).map((t: any) => t.n));
---
<AquintutorLayout title="My progress">
  <main style="max-width:820px;margin:0 auto;padding:44px 22px 80px;">
    <div style="display:flex;justify-content:space-between;align-items:baseline;gap:10px;flex-wrap:wrap;">
      <div>
        <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">My progress</p>
        <h1 style="font-family:Fraunces,serif;font-size:32px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 18px;line-height:1.15;">Learning analytics</h1>
      </div>
      <a href="/api/aquintutor/my-data" style="font-family:'Inter Tight',sans-serif;font-size:13px;font-weight:600;color:var(--ink,#1a1712);border:1px solid var(--line,#e6e1d6);border-radius:8px;padding:8px 14px;text-decoration:none;">Export my data (CSV)</a>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:16px;">
      <div style={CARD}><p style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#8a8478;margin:0;">Concepts mastered</p><p style="font-family:Fraunces,serif;font-size:30px;font-weight:600;color:var(--ink,#1a1712);margin:4px 0 0;">{a?.mastery.mastered || 0}<span style="font-size:16px;color:#8a8478;"> / {a?.mastery.total || 0}</span></p></div>
      <div style={CARD}><p style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#8a8478;margin:0;">Lessons completed</p><p style="font-family:Fraunces,serif;font-size:30px;font-weight:600;color:var(--ink,#1a1712);margin:4px 0 0;">{a?.completion.completed || 0}<span style="font-size:16px;color:#8a8478;"> ({a?.completion.rate || 0}%)</span></p></div>
      <div style={CARD}><p style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#8a8478;margin:0;">Official assessments</p><p style="font-family:Fraunces,serif;font-size:30px;font-weight:600;color:var(--ink,#1a1712);margin:4px 0 0;">{a?.assessments.official.avgPct || 0}%<span style="font-size:15px;color:#8a8478;"> avg · {a?.assessments.official.passRate || 0}% pass</span></p></div>
    </div>

    <div style={CARD}>
      <p style="font-family:'Inter Tight',sans-serif;font-size:12px;color:#8a8478;text-transform:uppercase;letter-spacing:0.06em;margin:0 0 14px;">Mastery over the last days</p>
      {(a?.timeline || []).length === 0 ? <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#6b6455;margin:0;">Complete lessons and pass assessments to build your mastery record.</p> :
        <div style="display:flex;align-items:flex-end;gap:6px;height:120px;">{[...(a?.timeline || [])].reverse().map((t: any) => (
          <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;">
            <div style={'width:100%;background:var(--rust,#b3541e);border-radius:4px 4px 0 0;height:' + Math.round((t.n / maxT) * 96) + 'px;'} title={t.day + ': ' + t.n}></div>
            <span style="font-family:'Geist Mono',monospace;font-size:8.5px;color:#8a8478;">{t.day.slice(5)}</span>
          </div>
        ))}</div>}
    </div>
    <p style="font-family:'Inter Tight',sans-serif;font-size:12px;color:#8a8478;margin:16px 0 0;">All figures are computed from your real activity — nothing here is estimated.</p>
  </main>
</AquintutorLayout>
