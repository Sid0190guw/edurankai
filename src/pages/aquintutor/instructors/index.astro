---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

let instructors: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT i.id, i.slug, i.name, i.title, i.bio, i.photo_url, i.specialties, i.years_experience, i.is_featured,
      (SELECT COUNT(*)::int FROM training_course_instructors WHERE instructor_id = i.id) as course_count
    FROM training_instructors i
    ORDER BY i.is_featured DESC, i.sort_order ASC, i.name ASC
  `);
  instructors = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const featured = instructors.filter((i: any) => i.is_featured);
const rest = instructors.filter((i: any) => !i.is_featured);
const totalYears = instructors.reduce((s: number, i: any) => s + (i.years_experience || 0), 0);

const pageDesc = 'AquinTutor faculty - the practitioners and researchers who author and review every course on the register.';
---
<AquintutorLayout title="Faculty" description={pageDesc}>

  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:56px 24px 40px;">
      <div style="display:flex; align-items:center; gap:14px; margin-bottom:20px;" class="numplate">
        <span style="height:1px; width:48px; background:var(--ink);"></span>
        <span style="color:var(--ink-500);">FACULTY &middot; THE ACADEMIC ROLL</span>
      </div>
      <h1 class="font-display" style="font-size:clamp(3rem,8vw,8rem); line-height:0.92; letter-spacing:-0.025em; font-weight:500; margin:0;">
        Authored<br/>
        <span style="font-style:italic; font-weight:300; color:var(--ink-500);">by named faculty.</span>
      </h1>
      <p class="font-serif" style="font-size:clamp(1.25rem, 2vw, 1.875rem); line-height:1.3; color:var(--ink-500); margin-top:24px; max-width:48rem;">
        Every published course is written, reviewed, or supervised by a named member of the faculty roll. {instructors.length} active appointments, {totalYears} cumulative years of teaching practice, every credential traceable back to a real person.
      </p>
    </div>
  </section>

  {featured.length > 0 && (
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:1400px; margin:0 auto; padding:64px 24px;">
        <div style="display:grid; grid-template-columns:1fr; gap:32px; margin-bottom:36px;" class="thesis-grid">
          <div>
            <p class="eyebrow">&sect; I &mdash; Senior faculty</p>
            <p class="numplate" style="color:var(--ink-300); margin-top:8px;">{String(featured.length).padStart(2, '0')} APPOINTMENTS</p>
          </div>
          <div>
            <h2 class="font-display" style="font-size:clamp(2rem,5vw,4rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0;">
              Senior faculty.<br/>
              <span style="font-style:italic; font-weight:300; color:var(--ink-500);">Anchor each programme.</span>
            </h2>
          </div>
        </div>

        <div style="display:grid; grid-template-columns:1fr; gap:1px; background:rgba(11,14,20,0.15); border:1px solid rgba(11,14,20,0.15);" class="schools-grid">
          {featured.map((i: any) => (
            <a href={'/aquintutor/instructors/' + i.slug} class="tile" style="padding:32px; min-height:280px;">
              <div>
                <div style="display:flex; align-items:center; gap:14px; margin-bottom:16px;">
                  {i.photo_url ? (
                    <img src={i.photo_url} alt={i.name} style="width:56px; height:56px; border-radius:50%; object-fit:cover; border:1px solid var(--rule);" />
                  ) : (
                    <div style="width:56px; height:56px; border-radius:50%; background:var(--rust); color:var(--sand-50); display:flex; align-items:center; justify-content:center; font-family:'Instrument Serif', serif; font-size:1.8rem; font-weight:400; flex-shrink:0;">
                      {(i.name || '?').substring(0, 1).toUpperCase()}
                    </div>
                  )}
                  <div style="min-width:0; flex:1;">
                    <p class="font-display" style="font-size:1.5rem; font-weight:500; margin:0; line-height:1.1; letter-spacing:-0.02em;">{i.name}</p>
                    {i.title && <p class="numplate" style="margin:6px 0 0; color:var(--ink-500);">{i.title}</p>}
                  </div>
                </div>
                {i.bio && <p class="font-serif" style="font-size:1.0625rem; font-style:italic; color:var(--ink-500); line-height:1.45; margin:0 0 14px;">{i.bio}</p>}
                {Array.isArray(i.specialties) && i.specialties.length > 0 && (
                  <div style="display:flex; flex-wrap:wrap; gap:6px; margin-top:10px;">
                    {i.specialties.slice(0, 4).map((s: string) => (
                      <span class="numplate" style="background:var(--sand-100); border:1px solid var(--rule); padding:3px 9px; border-radius:999px; color:var(--ink-500);">{s}</span>
                    ))}
                  </div>
                )}
              </div>
              <div style="margin-top:24px; padding-top:14px; border-top:1px solid var(--rule); display:flex; justify-content:space-between;" class="numplate">
                <span style="color:var(--ink-300);">{i.course_count || 0} COURSE{i.course_count === 1 ? '' : 'S'}</span>
                {i.years_experience > 0 && <span style="color:var(--ink-300);">{i.years_experience}Y EXPERIENCE</span>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {rest.length > 0 && (
    <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
      <div style="max-width:1400px; margin:0 auto; padding:64px 24px;">
        <div style="display:grid; grid-template-columns:1fr; gap:32px; margin-bottom:36px;" class="thesis-grid">
          <div>
            <p class="eyebrow">&sect; II &mdash; Visiting roll</p>
            <p class="numplate" style="color:var(--ink-300); margin-top:8px;">{String(rest.length).padStart(2, '0')} APPOINTMENTS</p>
          </div>
          <div>
            <h2 class="font-display" style="font-size:clamp(2rem,5vw,4rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0;">
              Visiting faculty.
            </h2>
          </div>
        </div>

        <div style="display:grid; grid-template-columns:1fr; gap:1px; background:rgba(11,14,20,0.15); border:1px solid rgba(11,14,20,0.15);" class="schools-grid">
          {rest.map((i: any) => (
            <a href={'/aquintutor/instructors/' + i.slug} class="tile" style="padding:24px;">
              <div>
                <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px;">
                  {i.photo_url ? (
                    <img src={i.photo_url} alt={i.name} style="width:44px; height:44px; border-radius:50%; object-fit:cover; border:1px solid var(--rule);" />
                  ) : (
                    <div style="width:44px; height:44px; border-radius:50%; background:var(--ink); color:var(--sand-50); display:flex; align-items:center; justify-content:center; font-family:'Instrument Serif', serif; font-size:1.4rem; flex-shrink:0;">
                      {(i.name || '?').substring(0, 1).toUpperCase()}
                    </div>
                  )}
                  <div style="min-width:0;">
                    <p class="font-display" style="font-size:1.15rem; font-weight:500; margin:0; line-height:1.15;">{i.name}</p>
                    {i.title && <p class="numplate" style="margin:4px 0 0; color:var(--ink-500); font-size:9.5px;">{i.title}</p>}
                  </div>
                </div>
                {i.bio && <p class="font-serif" style="font-size:0.95rem; font-style:italic; color:var(--ink-500); line-height:1.4; margin:0;">{i.bio.substring(0, 140)}{i.bio.length > 140 ? '...' : ''}</p>}
              </div>
              <div style="margin-top:18px; padding-top:10px; border-top:1px solid var(--rule); display:flex; justify-content:space-between;" class="numplate">
                <span style="color:var(--ink-300);">{i.course_count || 0} COURSES</span>
                {i.years_experience > 0 && <span style="color:var(--ink-300);">{i.years_experience}Y</span>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {instructors.length === 0 && (
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:1400px; margin:0 auto; padding:80px 24px; text-align:center;">
        <p class="font-serif" style="font-size:1.5rem; font-style:italic; color:var(--ink-500); margin:0 0 22px; max-width:36rem; margin-left:auto; margin-right:auto;">The faculty roll is being built. If you teach at frontier quality and want to publish on AquinTutor, write to us.</p>
        <a href="/contact" class="btn-pill outline">Apply to teach &rarr;</a>
      </div>
    </section>
  )}

  <section class="invert">
    <div style="max-width:1400px; margin:0 auto; padding:80px 24px; display:grid; grid-template-columns:1fr; gap:32px;" class="thesis-grid">
      <div>
        <p class="eyebrow" style="color:rgba(251,250,244,0.5);">&sect; Final &mdash; Apply</p>
        <p class="numplate" style="color:rgba(251,250,244,0.4); margin-top:8px;">OPEN APPOINTMENTS</p>
      </div>
      <div>
        <h2 class="font-display" style="font-size:clamp(2.5rem,6vw,5rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--sand-50);">
          Join the roll.<br/>
          <span style="font-style:italic; font-weight:300; color:var(--gold);">Publish a course.</span>
        </h2>
        <p class="font-serif" style="font-size:1.5rem; color:rgba(251,250,244,0.8); margin-top:24px; max-width:42rem; line-height:1.3;">
          We pay faculty appointments per course taught, with annual reviews. Curriculum proposals open every term; named co-authors are credited on the credential.
        </p>
        <div style="margin-top:36px; display:flex; gap:14px; flex-wrap:wrap;">
          <a href="/contact" class="btn-pill filled" style="background:var(--sand-50); color:var(--ink); border-color:var(--sand-50);">Apply to teach &rarr;</a>
          <a href="/aquintutor/courses" class="btn-pill outline" style="color:var(--sand-50); border-color:var(--sand-50);">Browse the catalogue</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    @media (min-width: 768px) { .schools-grid { grid-template-columns: repeat(2, 1fr) !important; } .thesis-grid { grid-template-columns: 3fr 9fr !important; } }
    @media (min-width: 1024px) { .schools-grid { grid-template-columns: repeat(3, 1fr) !important; } }
  </style>
</AquintutorLayout>
