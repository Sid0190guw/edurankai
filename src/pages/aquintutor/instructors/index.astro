---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

let instructors: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT i.id, i.slug, i.name, i.title, i.bio, i.photo_url, i.specialties, i.years_experience, i.is_featured,
      (SELECT COUNT(*)::int FROM training_course_instructors WHERE instructor_id = i.id) as course_count
    FROM training_instructors i
    ORDER BY i.is_featured DESC, i.sort_order ASC, i.name ASC
  `);
  instructors = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const featured = instructors.filter((i: any) => i.is_featured);
const rest = instructors.filter((i: any) => !i.is_featured);
const totalYears = instructors.reduce((s: number, i: any) => s + (i.years_experience || 0), 0);
const totalCourses = instructors.reduce((s: number, i: any) => s + (i.course_count || 0), 0);
const allSpecialties = Array.from(new Set(instructors.flatMap((i: any) => i.specialties || []))).slice(0, 18);

function initials(n: string) {
  const parts = (n || '').split(' ').filter(Boolean);
  if (parts.length === 0) return 'F';
  if (parts.length === 1) return parts[0][0];
  return parts[0][0] + parts.slice(-1)[0][0];
}

const pageDesc = 'AquinTutor faculty - the practitioners and researchers who author and review every course on the register.';
---
<AquintutorLayout title="Faculty" description={pageDesc}>

  <!-- HERO -->
  <section style="border-bottom:1px solid var(--rule); position:relative; overflow:hidden;">
    <div aria-hidden="true" style="position:absolute; right:-40px; top:40px; opacity:0.05; pointer-events:none;" class="hide-mobile">
      <svg width="340" height="340" viewBox="0 0 100 100" fill="none">
        {Array.from({length:6}).map((_, i) => <circle cx={20 + (i%3)*30} cy={20 + Math.floor(i/3)*40} r="14" stroke="var(--ink)" stroke-width="0.5" fill="none"/>)}
      </svg>
    </div>
    <div style="max-width:1320px; margin:0 auto; padding:72px 28px 40px; position:relative; z-index:1;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); font-weight:600; letter-spacing:0.04em; margin:0 0 16px;">Faculty &middot; the academic roll</p>
      <h1 class="font-display" style="font-size:clamp(2.5rem, 5.5vw, 4.5rem); line-height:0.98; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--ink); max-width:44rem;">
        Authored<br/>
        <span style="font-style:italic; font-weight:300; color:var(--ink-500);">by named faculty.</span>
      </h1>
      <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.1rem, 1.5vw, 1.35rem); line-height:1.5; color:var(--ink-500); margin:24px 0 0; max-width:40rem;">
        Every published course is written, reviewed, or supervised by a named member of the faculty roll. {instructors.length} active appointments, {totalYears} cumulative years of teaching practice, every credential traceable back to a real person.
      </p>
    </div>
  </section>

  <!-- STAT STRIP -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1320px; margin:0 auto; padding:28px 28px;">
      <div style="display:grid; grid-template-columns:repeat(2, 1fr); gap:12px;" class="stat-row">
        {[
          { l: 'Active appointments', v: instructors.length },
          { l: 'Cumulative years', v: totalYears },
          { l: 'Courses authored', v: totalCourses },
          { l: 'Senior faculty', v: featured.length },
          { l: 'Visiting roll', v: rest.length },
          { l: 'Office hours', v: 'Weekly', accent: true },
        ].map((s) => (
          <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px 18px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">{s.l}</p>
            <p class="font-display" style={'font-size:1.55rem; font-weight:500; margin:0; line-height:1; letter-spacing:-0.02em; ' + (s.accent ? 'color:var(--rust);' : 'color:var(--ink);')}>{s.v}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {allSpecialties.length > 0 && (
    <!-- SPECIALTIES -->
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:1320px; margin:0 auto; padding:40px 28px;">
        <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 14px;">Research interests across the roll</p>
        <div style="display:flex; flex-wrap:wrap; gap:7px;">
          {allSpecialties.map((s: string) => (
            <span style="display:inline-flex; align-items:center; padding:6px 12px; border-radius:999px; font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink); background:var(--paper); border:1px solid var(--rule);">{s}</span>
          ))}
        </div>
      </div>
    </section>
  )}

  {featured.length > 0 && (
    <!-- SENIOR FACULTY -->
    <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
      <div style="max-width:1320px; margin:0 auto; padding:64px 28px;">
        <div style="display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:14px; margin-bottom:30px;">
          <div>
            <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">Senior faculty</p>
            <h2 class="font-display" style="font-size:clamp(1.65rem, 3vw, 2.4rem); font-weight:500; line-height:1.1; letter-spacing:-0.02em; margin:0; color:var(--ink);">
              Anchor each programme.
            </h2>
          </div>
          <p style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--ink-500); letter-spacing:0.1em; margin:0;">{featured.length} APPOINTMENTS</p>
        </div>

        <div style="display:grid; grid-template-columns:1fr; gap:18px;" class="senior-grid">
          {featured.map((i: any) => (
            <a href={'/aquintutor/instructors/' + i.slug} class="faculty-card senior" style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:0; text-decoration:none; color:var(--ink); display:flex; flex-direction:column; overflow:hidden; transition:transform 0.18s, border-color 0.18s, box-shadow 0.18s;">
              <div style="padding:24px 24px 18px; display:flex; gap:18px; align-items:start; border-bottom:1px solid var(--rule);">
                {i.photo_url ? (
                  <img src={i.photo_url} alt={i.name} style="width:64px; height:64px; border-radius:50%; object-fit:cover; border:1px solid var(--rule); flex-shrink:0;" />
                ) : (
                  <span style="display:inline-flex; align-items:center; justify-content:center; width:64px; height:64px; min-width:64px; border-radius:50%; background:var(--ink); color:var(--sand-50); font-family:'Fraunces',serif; font-weight:500; font-size:1.5rem; letter-spacing:-0.02em; flex-shrink:0;">{initials(i.name)}</span>
                )}
                <div style="min-width:0; flex:1;">
                  <p class="font-display" style="font-size:1.3rem; font-weight:500; margin:0; line-height:1.18; letter-spacing:-0.015em; color:var(--ink);">{i.name}</p>
                  {i.title && <p style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500); margin:4px 0 0; line-height:1.4;">{i.title}</p>}
                </div>
              </div>

              <div style="padding:18px 24px 22px; display:flex; flex-direction:column; gap:12px; flex:1;">
                {i.bio && <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1rem; color:var(--ink-500); line-height:1.5; margin:0;">{i.bio}</p>}
                {Array.isArray(i.specialties) && i.specialties.length > 0 && (
                  <div style="display:flex; flex-direction:column; gap:6px;">
                    <p style="font-family:'Inter Tight',sans-serif; font-size:10px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0;">Specialties</p>
                    <div style="display:flex; flex-wrap:wrap; gap:5px;">
                      {i.specialties.slice(0, 5).map((s: string) => (
                        <span style="font-family:'Inter Tight',sans-serif; font-size:11.5px; padding:3px 9px; background:var(--sand-100); border:1px solid var(--rule); border-radius:999px; color:var(--ink-500);">{s}</span>
                      ))}
                    </div>
                  </div>
                )}
                <div style="margin-top:auto; padding-top:14px; border-top:1px solid var(--rule); display:flex; justify-content:space-between; gap:8px; font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.14em; color:var(--ink-500);">
                  <span>{i.course_count || 0} COURSE{i.course_count === 1 ? '' : 'S'}</span>
                  {i.years_experience > 0 && <span>{i.years_experience}Y EXPERIENCE</span>}
                  <span style="color:var(--rust); font-weight:600;">PROFILE &rarr;</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {rest.length > 0 && (
    <!-- VISITING ROLL -->
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:1320px; margin:0 auto; padding:64px 28px;">
        <div style="display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:14px; margin-bottom:30px;">
          <div>
            <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">Visiting roll</p>
            <h2 class="font-display" style="font-size:clamp(1.65rem, 3vw, 2.4rem); font-weight:500; line-height:1.1; letter-spacing:-0.02em; margin:0; color:var(--ink);">
              Visiting faculty.
            </h2>
          </div>
          <p style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--ink-500); letter-spacing:0.1em; margin:0;">{rest.length} APPOINTMENTS</p>
        </div>

        <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="visit-grid">
          {rest.map((i: any) => (
            <a href={'/aquintutor/instructors/' + i.slug} class="faculty-card" style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:20px; text-decoration:none; color:var(--ink); display:flex; flex-direction:column; gap:12px; transition:transform 0.18s, border-color 0.18s, box-shadow 0.18s;">
              <div style="display:flex; gap:14px; align-items:start;">
                {i.photo_url ? (
                  <img src={i.photo_url} alt={i.name} style="width:48px; height:48px; border-radius:50%; object-fit:cover; border:1px solid var(--rule); flex-shrink:0;" />
                ) : (
                  <span style="display:inline-flex; align-items:center; justify-content:center; width:48px; height:48px; min-width:48px; border-radius:50%; background:var(--sand-100); border:1px solid var(--rule); color:var(--ink); font-family:'Fraunces',serif; font-weight:500; font-size:1.2rem; flex-shrink:0;">{initials(i.name)}</span>
                )}
                <div style="min-width:0; flex:1;">
                  <p class="font-display" style="font-size:1.1rem; font-weight:500; margin:0; line-height:1.18; letter-spacing:-0.015em;">{i.name}</p>
                  {i.title && <p style="font-family:'Inter Tight',sans-serif; font-size:11.5px; color:var(--ink-500); margin:3px 0 0; line-height:1.4;">{i.title}</p>}
                </div>
              </div>
              {i.bio && <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink-500); line-height:1.55; margin:0;">{i.bio.substring(0, 150)}{i.bio.length > 150 ? '...' : ''}</p>}
              <div style="margin-top:auto; padding-top:10px; border-top:1px solid var(--rule); display:flex; justify-content:space-between; gap:8px; font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.12em; color:var(--ink-500);">
                <span>{i.course_count || 0} COURSE{i.course_count === 1 ? '' : 'S'}</span>
                {i.years_experience > 0 && <span>{i.years_experience}Y</span>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {instructors.length === 0 && (
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:1100px; margin:0 auto; padding:80px 28px; text-align:center;">
        <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.4rem; color:var(--ink-500); margin:0 0 22px; max-width:36rem; margin-left:auto; margin-right:auto;">The faculty roll is being built. If you teach at frontier quality and want to publish on AquinTutor, write to us.</p>
        <a href="mailto:hr@edurankai.in?subject=Faculty%20appointment" style="background:var(--ink); color:var(--sand-50); padding:13px 24px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none; display:inline-block;">Apply to teach &rarr;</a>
      </div>
    </section>
  )}

  <!-- APPLY TO TEACH CTA -->
  <section style="background:var(--ink); color:var(--sand-50);">
    <div style="max-width:1200px; margin:0 auto; padding:64px 28px; display:grid; grid-template-columns:1fr; gap:32px; align-items:center;" class="cta-grid">
      <div>
        <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:#d97757; font-weight:600; letter-spacing:0.04em; margin:0 0 14px;">Open appointments</p>
        <h2 class="font-display" style="font-size:clamp(1.85rem, 3.5vw, 2.85rem); line-height:1.06; letter-spacing:-0.02em; font-weight:500; margin:0 0 14px; color:var(--sand-50);">
          Publish a course.<br/>
          <span style="font-style:italic; font-weight:300; color:rgba(251,250,244,0.65);">Join the roll.</span>
        </h2>
        <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.05rem, 1.4vw, 1.2rem); line-height:1.55; color:rgba(251,250,244,0.78); margin:0 0 22px; max-width:36rem;">
          We pay faculty appointments per course taught, with annual reviews. Curriculum proposals open every term; named co-authors are credited on the credential.
        </p>
      </div>
      <div style="display:flex; flex-direction:column; gap:10px; max-width:300px; justify-self:end;">
        <a href="mailto:hr@edurankai.in?subject=Faculty%20appointment" style="background:#d97757; color:#1a0f08; padding:13px 24px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none; text-align:center;">Apply to teach &rarr;</a>
        <a href="/aquintutor/courses" style="background:transparent; color:var(--sand-50); padding:13px 24px; border-radius:6px; border:1px solid rgba(251,250,244,0.4); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none; text-align:center;">Browse catalogue</a>
      </div>
    </div>
  </section>

  <style>
    .faculty-card:hover { transform: translateY(-3px); border-color: var(--ink); box-shadow: 0 12px 28px rgba(11,14,20,0.08); }
    @media (min-width: 640px) { .stat-row { grid-template-columns: repeat(3, 1fr) !important; } }
    @media (min-width: 900px) { .stat-row { grid-template-columns: repeat(6, 1fr) !important; } .cta-grid { grid-template-columns: 1.6fr 1fr !important; } }
    @media (min-width: 768px) { .senior-grid { grid-template-columns: repeat(2, 1fr) !important; } .visit-grid { grid-template-columns: repeat(2, 1fr) !important; } }
    @media (min-width: 1100px) { .senior-grid { grid-template-columns: repeat(2, 1fr) !important; } .visit-grid { grid-template-columns: repeat(3, 1fr) !important; } }
  </style>
</AquintutorLayout>
