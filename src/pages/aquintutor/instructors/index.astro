---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

let instructors: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT i.id, i.slug, i.name, i.title, i.bio, i.photo_url, i.specialties, i.years_experience,
      (SELECT COUNT(*)::int FROM training_course_instructors WHERE instructor_id = i.id) as course_count
    FROM training_instructors i
    ORDER BY i.is_featured DESC, i.sort_order ASC, i.name ASC
  `);
  instructors = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const pageDesc = 'AquinTutor faculty - instructors and domain experts who author and review our courses. Bharat-built, globally credentialled.';
---
<BaseLayout title="Faculty - AquinTutor" description={pageDesc}>
  <section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-6xl mx-auto">
    <a href="/aquintutor" class="inline-flex items-center gap-2 text-[0.78rem] font-mono text-ink-soft hover:text-burn mb-4">
      &larr; AquinTutor
    </a>
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-3">Faculty</p>
    <h1 class="font-display text-[clamp(2rem,5vw,3rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-3">
      The people <em class="italic text-burn font-medium">behind the courses.</em>
    </h1>
    <p class="text-[0.98rem] text-ink-soft leading-[1.7] max-w-2xl">
      Domain practitioners, researchers, and teachers. Every course we publish is authored or reviewed by someone on this list.
    </p>
  </section>

  <section class="px-[5vw] pb-20 max-w-6xl mx-auto">
    {instructors.length === 0 && (
      <div class="bg-cream-2 border border-ink/10 rounded-2xl p-10 md:p-16 text-center">
        <p class="font-display text-xl font-medium text-ink mb-3">Faculty roster is being built.</p>
        <p class="text-[0.9rem] text-ink-soft mb-6 max-w-md mx-auto leading-relaxed">
          We're onboarding the first cohort of instructors. If you teach at a frontier-quality level and want to publish on AquinTutor, get in touch.
        </p>
        <a href="/contact" class="btn-primary">Apply to teach</a>
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {instructors.map((i) => (
        <a href={'/aquintutor/instructors/' + i.slug} class="group bg-white border border-ink/10 rounded-2xl p-5 transition-all hover:-translate-y-1 hover:shadow-xl hover:border-burn-dim flex flex-col">
          <div class="flex items-center gap-4 mb-4">
            {i.photo_url ? (
              <img src={i.photo_url} alt={i.name} class="w-16 h-16 rounded-full object-cover border border-ink/10" />
            ) : (
              <div class="w-16 h-16 rounded-full bg-burn-pale border border-burn-dim flex items-center justify-center font-display text-[1.4rem] font-semibold text-burn flex-shrink-0">
                {(i.name || '?').substring(0, 1).toUpperCase()}
              </div>
            )}
            <div class="min-w-0">
              <p class="font-display text-[1.05rem] font-semibold text-ink group-hover:text-burn transition-colors leading-tight">{i.name}</p>
              {i.title && <p class="text-[0.78rem] text-ink-soft mt-1 leading-snug">{i.title}</p>}
            </div>
          </div>
          {i.bio && <p class="text-[0.85rem] text-ink-soft font-light leading-relaxed mb-3 line-clamp-3 flex-1">{i.bio}</p>}
          <div class="flex items-center justify-between text-[0.72rem] text-ink-soft/80 font-mono pt-3 border-t border-ink/8">
            <span>{i.course_count || 0} course{i.course_count === 1 ? '' : 's'}</span>
            {i.years_experience > 0 && <span>{i.years_experience}y experience</span>}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
