---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

let instructors: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT i.id, i.slug, i.name, i.title, i.bio, i.photo_url, i.specialties, i.years_experience,
      (SELECT COUNT(*)::int FROM training_course_instructors WHERE instructor_id = i.id) as course_count
    FROM training_instructors i
    ORDER BY i.is_featured DESC, i.sort_order ASC, i.name ASC
  `);
  instructors = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const pageDesc = 'AquinTutor faculty - instructors and domain experts who author and review our courses.';
---
<AquintutorLayout title="Faculty" description={pageDesc}>
  <section class="ac-container" style="padding:50px 5vw 24px;">
    <a href="/aquintutor" style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--ac-ink-muted); text-decoration:none; margin-bottom:14px; display:inline-block; letter-spacing:0.08em;">&larr; AquinTutor</a>
    <p class="ac-eyebrow ac-mb-3">Faculty</p>
    <h1 class="ac-display ac-mb-4">
      The people <em class="ac-em">behind the courses.</em>
    </h1>
    <p class="ac-lead" style="max-width:680px;">
      Domain practitioners, researchers, and teachers. Every course we publish is authored or reviewed by someone on this list.
    </p>
  </section>

  <section class="ac-container" style="padding:24px 5vw 80px;">
    {instructors.length === 0 ? (
      <div class="ac-card" style="text-align:center; padding:60px 20px;">
        <p style="font-family:'Fraunces',serif; font-size:1.4rem; color:var(--ac-ink); margin-bottom:10px;">Faculty roster is being built.</p>
        <p style="font-size:14px; color:var(--ac-ink-soft); margin-bottom:20px; max-width:480px; margin-left:auto; margin-right:auto;">We're onboarding the first cohort of instructors. If you teach at a frontier-quality level and want to publish on AquinTutor, get in touch.</p>
        <a href="/contact" class="ac-btn">Apply to teach</a>
      </div>
    ) : (
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(290px, 1fr)); gap:16px;">
        {instructors.map((i) => (
          <a href={'/aquintutor/instructors/' + i.slug} class="ac-card" style="text-decoration:none; display:flex; flex-direction:column;">
            <div style="display:flex; align-items:center; gap:16px; margin-bottom:14px;">
              {i.photo_url ? (
                <img src={i.photo_url} alt={i.name} style="width:60px; height:60px; border-radius:50%; object-fit:cover; border:1px solid var(--ac-border);" />
              ) : (
                <div style="width:60px; height:60px; border-radius:50%; background:var(--ac-amber-bg); border:1px solid rgba(184,81,46,0.3); display:flex; align-items:center; justify-content:center; font-family:'Fraunces',serif; font-size:1.5rem; font-weight:500; color:var(--ac-amber); flex-shrink:0;">
                  {(i.name || '?').substring(0, 1).toUpperCase()}
                </div>
              )}
              <div style="min-width:0;">
                <p style="font-family:'Fraunces',serif; font-size:1.08rem; font-weight:500; color:var(--ac-ink); line-height:1.25;">{i.name}</p>
                {i.title && <p style="font-size:12.5px; color:var(--ac-ink-soft); margin-top:4px; line-height:1.4;">{i.title}</p>}
              </div>
            </div>
            {i.bio && <p style="font-size:13.5px; color:var(--ac-ink-soft); line-height:1.65; margin-bottom:14px; flex:1; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden;">{i.bio}</p>}
            <div style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--ac-ink-muted); display:flex; justify-content:space-between; padding-top:14px; border-top:1px solid var(--ac-rule);">
              <span>{i.course_count || 0} course{i.course_count === 1 ? '' : 's'}</span>
              {i.years_experience > 0 && <span>{i.years_experience}y experience</span>}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</AquintutorLayout>
