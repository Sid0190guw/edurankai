---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { SITE } from '@/lib/site';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/aquintutor/instructors');

let instructor: any = null;
let courses: any[] = [];

try {
  const r = await db.execute(sql`SELECT * FROM training_instructors WHERE slug = ${slug} LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  instructor = rows[0] || null;
} catch (_) {}
if (!instructor) return Astro.redirect('/aquintutor/instructors');

try {
  const r = await db.execute(sql`
    SELECT c.id, c.slug, c.title, c.subtitle, c.short_desc, c.level, c.duration_hours, c.is_free, c.course_code,
      s.code as school_code, s.name as school_name,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as lesson_count
    FROM training_course_instructors ci
    JOIN training_courses c ON ci.course_id = c.id
    LEFT JOIN schools s ON c.school_id = s.id
    WHERE ci.instructor_id = ${instructor.id} AND c.is_published = true AND c.access_type IN ('public', 'both')
    ORDER BY c.created_at DESC
  `);
  courses = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const specialties: string[] = Array.isArray(instructor.specialties) ? instructor.specialties : [];
const totalLessons = courses.reduce((s, c) => s + (c.lesson_count || 0), 0);
const totalHours = courses.reduce((s, c) => s + (c.duration_hours || 0), 0);

const pageTitle = instructor.name + ' - faculty';
const pageDesc = (instructor.bio || '').substring(0, 160);

function initials(n: string) {
  const parts = (n || '').split(' ').filter(Boolean);
  if (parts.length === 0) return 'F';
  if (parts.length === 1) return parts[0][0];
  return parts[0][0] + parts.slice(-1)[0][0];
}

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: instructor.name,
  jobTitle: instructor.title || 'Instructor at AquinTutor',
  description: instructor.bio || '',
  url: SITE.url + '/aquintutor/instructors/' + instructor.slug,
  ...(instructor.photo_url && { image: instructor.photo_url }),
  ...(instructor.linkedin_url && { sameAs: [instructor.linkedin_url, instructor.twitter_url, instructor.website_url].filter(Boolean) }),
  worksFor: { '@type': 'EducationalOrganization', name: 'AquinTutor', url: SITE.url + '/aquintutor' },
};
---
<AquintutorLayout title={pageTitle} description={pageDesc}>
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <!-- BREADCRUMB -->
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1280px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a>
      <span style="margin:0 8px;">/</span>
      <a href="/aquintutor/instructors" style="color:var(--ink-500); text-decoration:none;">FACULTY</a>
      <span style="margin:0 8px;">/</span>
      <span style="color:var(--rust); font-weight:600;">{(instructor.name || '').toUpperCase()}</span>
    </div>
  </div>

  <!-- HERO -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1280px; margin:0 auto; padding:64px 28px 40px;">
      <div style="display:grid; grid-template-columns:1fr; gap:32px; align-items:start;" class="profile-grid">
        <div style="display:flex; flex-direction:column; align-items:start; gap:16px;">
          {instructor.photo_url ? (
            <img src={instructor.photo_url} alt={instructor.name} style="width:160px; height:160px; border-radius:14px; object-fit:cover; border:1px solid var(--rule);" />
          ) : (
            <div style="width:160px; height:160px; border-radius:14px; background:var(--ink); color:var(--sand-50); display:flex; align-items:center; justify-content:center; font-family:'Fraunces',serif; font-size:3.5rem; font-weight:500; letter-spacing:-0.02em;">{initials(instructor.name)}</div>
          )}
          <div style="display:flex; gap:10px; flex-wrap:wrap;">
            {instructor.linkedin_url && <a href={instructor.linkedin_url} target="_blank" rel="noopener" style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--rust); text-decoration:underline; font-weight:500;">LinkedIn &rarr;</a>}
            {instructor.twitter_url && <a href={instructor.twitter_url} target="_blank" rel="noopener" style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--rust); text-decoration:underline; font-weight:500;">Twitter / X &rarr;</a>}
            {instructor.website_url && <a href={instructor.website_url} target="_blank" rel="noopener" style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--rust); text-decoration:underline; font-weight:500;">Website &rarr;</a>}
          </div>
        </div>

        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); font-weight:600; letter-spacing:0.04em; margin:0 0 12px;">Faculty {instructor.is_featured ? '&middot; Senior appointment' : '&middot; Visiting roll'}</p>
          <h1 class="font-display" style="font-size:clamp(2rem, 4.5vw, 3.5rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0; color:var(--ink);">{instructor.name}</h1>
          {instructor.title && <p style="font-family:'Inter Tight',sans-serif; font-size:clamp(0.95rem, 1.2vw, 1.1rem); color:var(--ink-500); margin:14px 0 0; line-height:1.5;">{instructor.title}</p>}
          {instructor.bio && <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.05rem, 1.4vw, 1.25rem); color:var(--ink); line-height:1.5; margin:22px 0 0; max-width:38rem;">{instructor.bio}</p>}
        </div>
      </div>
    </div>
  </section>

  <!-- STAT STRIP -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1280px; margin:0 auto; padding:24px 28px;">
      <div style="display:grid; grid-template-columns:repeat(2, 1fr); gap:12px;" class="stat-row">
        {[
          { l: 'Courses authored', v: courses.length },
          { l: 'Lessons', v: totalLessons },
          { l: 'Years teaching', v: instructor.years_experience || '-' },
          { l: 'Total hours', v: totalHours > 0 ? totalHours + 'h' : '-' },
          { l: 'Specialties', v: specialties.length },
          { l: 'Appointment', v: instructor.is_featured ? 'Senior' : 'Visiting', accent: true },
        ].map((s) => (
          <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px 18px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">{s.l}</p>
            <p class="font-display" style={'font-size:1.45rem; font-weight:500; margin:0; line-height:1; letter-spacing:-0.02em; ' + (s.accent ? 'color:var(--rust);' : 'color:var(--ink);')}>{s.v}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {specialties.length > 0 && (
    <!-- SPECIALTIES -->
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:1280px; margin:0 auto; padding:48px 28px;">
        <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 14px;">Research interests &amp; specialties</p>
        <div style="display:flex; flex-wrap:wrap; gap:8px;">
          {specialties.map((s: string) => (
            <span style="display:inline-flex; align-items:center; padding:8px 14px; border-radius:999px; background:var(--paper); border:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink); font-weight:500;">{s}</span>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- COURSES -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1280px; margin:0 auto; padding:56px 28px;">
      <div style="display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:14px; margin-bottom:28px;">
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">Authored work</p>
          <h2 class="font-display" style="font-size:clamp(1.5rem, 2.6vw, 2.15rem); font-weight:500; line-height:1.12; letter-spacing:-0.015em; margin:0; color:var(--ink);">Courses by {(instructor.name || '').split(' ').slice(-1)[0]}.</h2>
        </div>
        <a href="/aquintutor/courses" style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--rust); text-decoration:none; font-weight:500;">Browse all courses &rarr;</a>
      </div>
      {courses.length === 0 ? (
        <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1rem; color:var(--ink-500); margin:0;">No published courses yet. Watch this space.</p>
      ) : (
        <div style="display:grid; grid-template-columns:1fr; gap:14px;" class="course-grid">
          {courses.map((c: any) => (
            <a href={'/aquintutor/courses/' + c.slug} class="course-card" style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:0; overflow:hidden; text-decoration:none; color:var(--ink); display:flex; flex-direction:column; transition:transform 0.18s, box-shadow 0.18s;">
              <div style="height:4px; background:var(--rust);"></div>
              <div style="padding:20px 22px 18px; display:flex; flex-direction:column; gap:10px; flex:1;">
                <div style="display:flex; justify-content:space-between; gap:8px; font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.12em; color:var(--ink-500); text-transform:uppercase;">
                  <span>{c.course_code || (c.level || 'COURSE')}</span>
                  <span style="color:var(--rust);">{c.school_code || ''}</span>
                </div>
                <h3 class="font-display" style="font-size:1.15rem; font-weight:500; margin:0; line-height:1.22; letter-spacing:-0.015em;">{c.title}</h3>
                {c.subtitle && <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:0.95rem; color:var(--ink-500); line-height:1.38; margin:0;">{c.subtitle}</p>}
                {c.short_desc && <p style="font-family:'Inter Tight',sans-serif; font-size:13px; line-height:1.55; color:var(--ink-500); margin:0;">{c.short_desc.substring(0, 130)}{c.short_desc.length > 130 ? '...' : ''}</p>}
                <div style="margin-top:auto; padding-top:12px; border-top:1px solid var(--rule); display:flex; justify-content:space-between; gap:8px; font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink-500);">
                  <span>{c.lesson_count || 0} lessons{c.duration_hours ? ' &middot; ' + c.duration_hours + 'h' : ''}</span>
                  <span style="color:var(--rust); font-weight:600;">{c.is_free ? 'Open' : 'Paid'}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section>
    <div style="max-width:1100px; margin:0 auto; padding:56px 28px 80px; text-align:center;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 14px;">Next step</p>
      <h2 class="font-display" style="font-size:clamp(1.5rem, 2.6vw, 2.1rem); font-weight:500; line-height:1.18; letter-spacing:-0.015em; margin:0 0 18px; color:var(--ink); max-width:34rem; margin-left:auto; margin-right:auto;">
        Take a course authored by {(instructor.name || '').split(' ').slice(-1)[0]}.
      </h2>
      <div style="display:flex; gap:10px; flex-wrap:wrap; justify-content:center;">
        <a href="/aquintutor/signup" style="background:var(--ink); color:var(--sand-50); padding:13px 24px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Apply for admission</a>
        <a href="/aquintutor/instructors" style="background:transparent; color:var(--ink); padding:13px 24px; border-radius:6px; border:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">All faculty</a>
      </div>
    </div>
  </section>

  <style>
    .course-card:hover { transform: translateY(-3px); box-shadow: 0 10px 28px rgba(11,14,20,0.08); }
    @media (min-width: 640px) { .stat-row { grid-template-columns: repeat(3, 1fr) !important; } }
    @media (min-width: 900px) { .stat-row { grid-template-columns: repeat(6, 1fr) !important; } .profile-grid { grid-template-columns: auto 1fr !important; gap: 48px !important; align-items: center !important; } }
    @media (min-width: 768px) { .course-grid { grid-template-columns: repeat(2, 1fr) !important; } }
    @media (min-width: 1100px) { .course-grid { grid-template-columns: repeat(3, 1fr) !important; } }
  </style>
</AquintutorLayout>
