---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { SITE } from '@/lib/site';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/aquintutor/instructors');

let instructor: any = null;
let courses: any[] = [];

try {
  const r = await db.execute(sql`SELECT * FROM training_instructors WHERE slug = ${slug} LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  instructor = rows[0] || null;
} catch (_) {}

if (!instructor) return Astro.redirect('/aquintutor/instructors');

try {
  const r = await db.execute(sql`
    SELECT c.id, c.slug, c.title, c.short_desc, c.level, c.duration_hours, c.is_free,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as lesson_count
    FROM training_course_instructors ci
    JOIN training_courses c ON ci.course_id = c.id
    WHERE ci.instructor_id = ${instructor.id} AND c.is_published = true AND c.access_type IN ('public', 'both')
    ORDER BY c.created_at DESC
  `);
  courses = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const specialties: string[] = Array.isArray(instructor.specialties) ? instructor.specialties : [];
const pageTitle = instructor.name + ' - faculty - AquinTutor';
const pageDesc = (instructor.bio || '').substring(0, 160);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: instructor.name,
  jobTitle: instructor.title || 'Instructor at AquinTutor',
  description: instructor.bio || '',
  url: SITE.url + '/aquintutor/instructors/' + instructor.slug,
  ...(instructor.photo_url && { image: instructor.photo_url }),
  ...(instructor.linkedin_url && { sameAs: [instructor.linkedin_url, instructor.twitter_url, instructor.website_url].filter(Boolean) }),
  worksFor: {
    '@type': 'EducationalOrganization',
    name: 'AquinTutor',
    url: SITE.url + '/aquintutor',
  },
};
---
<BaseLayout title={pageTitle} description={pageDesc}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-5xl mx-auto">
    <a href="/aquintutor/instructors" class="inline-flex items-center gap-2 text-[0.78rem] font-mono text-ink-soft hover:text-burn mb-6">
      &larr; All faculty
    </a>

    <div class="flex flex-col md:flex-row items-start gap-6 md:gap-8 mb-8">
      {instructor.photo_url ? (
        <img src={instructor.photo_url} alt={instructor.name} class="w-28 h-28 md:w-36 md:h-36 rounded-2xl object-cover border border-ink/10 flex-shrink-0" />
      ) : (
        <div class="w-28 h-28 md:w-36 md:h-36 rounded-2xl bg-burn-pale border border-burn-dim flex items-center justify-center font-display text-[2.5rem] md:text-[3rem] font-semibold text-burn flex-shrink-0">
          {(instructor.name || '?').substring(0, 1).toUpperCase()}
        </div>
      )}
      <div class="flex-1 min-w-0">
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-2">Faculty</p>
        <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-tight mb-2">{instructor.name}</h1>
        {instructor.title && <p class="text-[1rem] text-ink-soft leading-relaxed mb-3">{instructor.title}</p>}
        <div class="flex flex-wrap gap-2 mb-3">
          {instructor.years_experience > 0 && <span class="text-[0.72rem] font-semibold text-ink-soft bg-cream-2 border border-ink/10 px-2.5 py-1 rounded">{instructor.years_experience}+ years experience</span>}
          <span class="text-[0.72rem] font-semibold text-ink-soft bg-cream-2 border border-ink/10 px-2.5 py-1 rounded">{courses.length} course{courses.length === 1 ? '' : 's'}</span>
        </div>
        <div class="flex flex-wrap gap-2 text-[0.85rem]">
          {instructor.linkedin_url && <a href={instructor.linkedin_url} target="_blank" rel="noopener" class="text-burn hover:underline font-semibold">LinkedIn</a>}
          {instructor.twitter_url && <a href={instructor.twitter_url} target="_blank" rel="noopener" class="text-burn hover:underline font-semibold">Twitter / X</a>}
          {instructor.website_url && <a href={instructor.website_url} target="_blank" rel="noopener" class="text-burn hover:underline font-semibold">Website</a>}
        </div>
      </div>
    </div>

    {instructor.bio && (
      <div class="mb-10">
        <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-4">About</h2>
        <div class="text-[0.95rem] text-ink-2 leading-[1.85] font-light whitespace-pre-line max-w-3xl">{instructor.bio}</div>
      </div>
    )}

    {specialties.length > 0 && (
      <div class="mb-10">
        <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-4">Specialties</h2>
        <div class="flex flex-wrap gap-2">
          {specialties.map((s: string) => <span class="text-[0.85rem] text-burn bg-burn-pale border border-burn-dim px-3 py-1.5 rounded-full font-semibold">{s}</span>)}
        </div>
      </div>
    )}

    <div>
      <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-5">Courses by {instructor.name.split(' ')[0]}</h2>
      {courses.length === 0 ? (
        <p class="text-[0.92rem] text-ink-soft italic">No published courses yet.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {courses.map((c: any) => (
            <a href={'/aquintutor/courses/' + c.slug} class="group bg-white border border-ink/10 rounded-xl p-5 transition-all hover:-translate-y-1 hover:shadow-md hover:border-burn flex flex-col">
              <div class="flex gap-2 mb-2 flex-wrap">
                <span class="text-[0.62rem] font-bold uppercase tracking-wider text-ink-soft bg-cream-2 border border-ink/10 px-2 py-0.5 rounded">{c.level}</span>
                {c.is_free && <span class="text-[0.62rem] font-semibold text-leaf bg-leaf-bg border border-leaf-border px-2 py-0.5 rounded">FREE</span>}
              </div>
              <h3 class="font-display text-[1rem] font-semibold text-ink mb-1.5 group-hover:text-burn">{c.title}</h3>
              <p class="text-[0.82rem] text-ink-soft leading-relaxed flex-1 mb-2">{c.short_desc}</p>
              <div class="flex gap-3 text-[0.7rem] font-mono text-ink-soft/70 pt-2 border-t border-ink/8">
                <span>{c.lesson_count || 0} lessons</span>
                {c.duration_hours > 0 && <span>{c.duration_hours}h</span>}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
