---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { SITE } from '@/lib/site';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/aquintutor/instructors');

let instructor: any = null;
let courses: any[] = [];

try {
  const r = await db.execute(sql`SELECT * FROM training_instructors WHERE slug = ${slug} LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  instructor = rows[0] || null;
} catch (_) {}
if (!instructor) return Astro.redirect('/aquintutor/instructors');

try {
  const r = await db.execute(sql`
    SELECT c.id, c.slug, c.title, c.short_desc, c.level, c.duration_hours, c.is_free,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as lesson_count
    FROM training_course_instructors ci
    JOIN training_courses c ON ci.course_id = c.id
    WHERE ci.instructor_id = ${instructor.id} AND c.is_published = true AND c.access_type IN ('public', 'both')
    ORDER BY c.created_at DESC
  `);
  courses = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const specialties: string[] = Array.isArray(instructor.specialties) ? instructor.specialties : [];
const pageTitle = instructor.name + ' - faculty';
const pageDesc = (instructor.bio || '').substring(0, 160);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: instructor.name,
  jobTitle: instructor.title || 'Instructor at AquinTutor',
  description: instructor.bio || '',
  url: SITE.url + '/aquintutor/instructors/' + instructor.slug,
  ...(instructor.photo_url && { image: instructor.photo_url }),
  ...(instructor.linkedin_url && { sameAs: [instructor.linkedin_url, instructor.twitter_url, instructor.website_url].filter(Boolean) }),
  worksFor: { '@type': 'EducationalOrganization', name: 'AquinTutor', url: SITE.url + '/aquintutor' },
};
---
<AquintutorLayout title={pageTitle} description={pageDesc}>
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <section class="ac-container" style="padding:50px 5vw 24px;">
    <a href="/aquintutor/instructors" style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--ac-ink-muted); text-decoration:none; margin-bottom:18px; display:inline-block; letter-spacing:0.08em;">&larr; All faculty</a>

    <div style="display:flex; flex-direction:column; gap:24px; align-items:flex-start;" class="profile-flex">
      {instructor.photo_url ? (
        <img src={instructor.photo_url} alt={instructor.name} style="width:120px; height:120px; border-radius:14px; object-fit:cover; border:1px solid var(--ac-border); flex-shrink:0;" />
      ) : (
        <div style="width:120px; height:120px; border-radius:14px; background:var(--ac-amber-bg); border:1px solid rgba(184,81,46,0.3); display:flex; align-items:center; justify-content:center; font-family:'Fraunces',serif; font-size:2.8rem; font-weight:500; color:var(--ac-amber); flex-shrink:0;">
          {(instructor.name || '?').substring(0, 1).toUpperCase()}
        </div>
      )}
      <div style="flex:1; min-width:0;">
        <p class="ac-eyebrow ac-mb-3">Faculty</p>
        <h1 class="ac-display ac-mb-3" style="line-height:1.15;">{instructor.name}</h1>
        {instructor.title && <p class="ac-lead" style="margin-bottom:14px;">{instructor.title}</p>}
        <div class="ac-flex ac-wrap ac-gap-2 ac-mb-4">
          {instructor.years_experience > 0 && <span class="ac-pill">{instructor.years_experience}+ years</span>}
          <span class="ac-pill">{courses.length} course{courses.length === 1 ? '' : 's'}</span>
        </div>
        <div class="ac-flex ac-wrap ac-gap-3" style="font-size:13.5px;">
          {instructor.linkedin_url && <a href={instructor.linkedin_url} target="_blank" rel="noopener" style="color:var(--ac-amber); font-weight:500; text-decoration:underline;">LinkedIn</a>}
          {instructor.twitter_url && <a href={instructor.twitter_url} target="_blank" rel="noopener" style="color:var(--ac-amber); font-weight:500; text-decoration:underline;">Twitter / X</a>}
          {instructor.website_url && <a href={instructor.website_url} target="_blank" rel="noopener" style="color:var(--ac-amber); font-weight:500; text-decoration:underline;">Website</a>}
        </div>
      </div>
    </div>
  </section>

  {instructor.bio && (
    <section class="ac-container" style="padding:32px 5vw; border-top:1px solid var(--ac-rule);">
      <h2 class="ac-display ac-mb-4" style="font-size:1.5rem;">About</h2>
      <div style="font-size:15px; color:var(--ac-ink-soft); line-height:1.85; white-space:pre-line; max-width:720px;">{instructor.bio}</div>
    </section>
  )}

  {specialties.length > 0 && (
    <section class="ac-container" style="padding:32px 5vw; border-top:1px solid var(--ac-rule);">
      <h2 class="ac-display ac-mb-4" style="font-size:1.5rem;">Specialties</h2>
      <div class="ac-flex ac-wrap ac-gap-2">
        {specialties.map((s: string) => <span style="display:inline-block; background:var(--ac-amber-bg); color:var(--ac-amber); border:1px solid rgba(184,81,46,0.3); padding:6px 14px; border-radius:100px; font-size:13px; font-weight:500;">{s}</span>)}
      </div>
    </section>
  )}

  <section class="ac-container" style="padding:40px 5vw 80px; border-top:1px solid var(--ac-rule);">
    <h2 class="ac-display ac-mb-6" style="font-size:1.5rem;">Courses by {instructor.name.split(' ')[0]}</h2>
    {courses.length === 0 ? (
      <p style="font-size:14.5px; color:var(--ac-ink-soft); font-style:italic;">No published courses yet.</p>
    ) : (
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:16px;">
        {courses.map((c: any) => (
          <a href={'/aquintutor/courses/' + c.slug} class="ac-course">
            <div class="ac-flex ac-gap-2 ac-mb-3">
              <span class="ac-pill ac-pill-amber">{c.level}</span>
              {c.is_free && <span class="ac-pill ac-pill-leaf">Free</span>}
            </div>
            <h3 class="ac-course-title">{c.title}</h3>
            <p class="ac-course-desc">{c.short_desc}</p>
            <div class="ac-course-meta">
              <span>{c.lesson_count || 0} lessons</span>
              {c.duration_hours > 0 && <span>{c.duration_hours}h</span>}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

  <style is:global>
    @media (min-width: 720px) {
      .academy .profile-flex { flex-direction: row !important; gap: 32px !important; align-items: center !important; }
    }
  </style>
</AquintutorLayout>
