---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

const lessons = [
  { n: '4.1', title: 'Postulates of quantum mechanics', d: '12m', state: 'done' },
  { n: '4.2', title: 'Operators and observables', d: '18m', state: 'done' },
  { n: '4.3', title: 'Measurement postulates', d: '14m', state: 'current' },
  { n: '4.4', title: 'Composite systems and tensor products', d: '22m', state: 'next' },
  { n: '4.5', title: 'Entanglement and Bell inequalities', d: '28m', state: 'locked' },
  { n: '4.6', title: 'Quiz · week 4', d: '12 questions', state: 'locked', kind: 'quiz' },
  { n: '5.1', title: 'Hilbert space refresher', d: '16m', state: 'locked' },
];

const transcript = [
  { t: '00:12', text: 'Last lesson we set up the postulates as axioms; today we ask what happens when you actually measure the system.' },
  { t: '00:34', text: 'The third postulate says: the act of measurement collapses |psi> onto an eigenvector of the observable.', highlight: true },
  { t: '01:02', text: 'In the lab this is the difference between predicting probabilities and reading a number off the meter.' },
  { t: '01:48', text: 'So if you measure an observable A with eigenvalues a_i, the post-measurement state is |a_i> with probability |<a_i|psi>|^2.' },
];

const notes = [
  { t: '01:14', text: 'Ask Aquin: is the collapse postulate testable in principle?' },
  { t: '03:42', text: 'Postulate 3 = projective measurement; later we will see POVMs.' },
];

const quizQs = [
  { q: 'After measuring observable A and obtaining a_2, the state is:', opts: ['|psi>', '|a_2>', 'Sum_i c_i |a_i>', 'Undefined'], correct: 1 },
  { q: 'P(a_i) is given by:', opts: ['|<psi|a_i>|', '|<a_i|psi>|^2', '<a_i|A|a_i>', '|c_i|'], correct: 1 },
];
---
<AquintutorLayout title="Player · Measurement postulates" description="Self-paced lesson player - quantum foundations, week 4, lesson 4.3 - measurement postulates.">

  <!-- BREADCRUMB -->
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1400px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a>
      <span style="margin:0 8px;">/</span>
      <a href="/aquintutor/dashboard" style="color:var(--ink-500); text-decoration:none;">DASHBOARD</a>
      <span style="margin:0 8px;">/</span>
      <a href="/aquintutor/courses" style="color:var(--ink-500); text-decoration:none;">COURSES</a>
      <span style="margin:0 8px;">/</span>
      <span style="color:#5b4a92; font-weight:600;">QT-407 · LESSON 4.3</span>
    </div>
  </div>

  <!-- HEADER -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:28px 28px 24px;">
      <div style="display:flex; align-items:start; justify-content:space-between; gap:18px; flex-wrap:wrap;">
        <div>
          <div style="display:inline-flex; align-items:center; gap:8px; padding:4px 12px; background:rgba(91,74,146,0.08); border:1px solid rgba(91,74,146,0.3); border-radius:999px; font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.16em; text-transform:uppercase; color:#5b4a92; font-weight:600; margin-bottom:12px;">QUANTUM FOUNDATIONS &middot; QT-407</div>
          <h1 class="font-display" style="font-size:clamp(1.65rem, 3.5vw, 2.5rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0; color:var(--ink);">4.3 &middot; Measurement postulates</h1>
          <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); margin:8px 0 0;">Week 4 of 12 &middot; Lecture &middot; 14 minutes &middot; adaptive replay enabled</p>
        </div>
        <div style="display:flex; gap:8px; flex-wrap:wrap;">
          <button type="button" style="background:transparent; color:var(--ink); padding:10px 18px; border:1px solid var(--rule); border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; cursor:pointer;">&larr; 4.2</button>
          <button type="button" style="background:transparent; color:#3d6b76; padding:10px 18px; border:1px solid #3d6b76; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; cursor:pointer;">Ask Aquin</button>
          <button type="button" style="background:var(--rust); color:#fff; padding:10px 18px; border:none; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; cursor:pointer;">Mark complete</button>
        </div>
      </div>
    </div>
  </section>

  <!-- VIDEO STAGE + LESSON LIST -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1400px; margin:0 auto; padding:24px 28px; display:grid; grid-template-columns:1fr; gap:18px;" class="pl-grid">

      <div style="display:flex; flex-direction:column; gap:14px;">
        <!-- Video stage -->
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; overflow:hidden;">
          <div style="aspect-ratio:16/9; background:radial-gradient(ellipse at center, #1a1f26 0%, #07090b 100%); position:relative; display:flex; align-items:center; justify-content:center;">
            <div style="text-align:center; max-width:72%;">
              <p style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.24em; color:#a78bfa; margin:0 0 12px; text-transform:uppercase;">POSTULATE 3 &middot; MEASUREMENT</p>
              <p class="font-display" style="font-style:italic; font-size:clamp(1.25rem, 2vw, 1.95rem); color:#f4f1ea; line-height:1.3; font-weight:400; margin:0 0 22px;">"Measurement collapses the state onto an eigenvector of the observable."</p>
              <div style="display:inline-flex; align-items:center; gap:10px; padding:7px 16px; background:rgba(167,139,250,0.10); border:1px solid rgba(167,139,250,0.3); border-radius:999px;">
                <span style="display:inline-flex; align-items:center; justify-content:center; width:22px; height:22px; border-radius:50%; background:#a78bfa; color:#1a0f08; font-family:'Fraunces',serif; font-weight:500; font-size:10px;">P</span>
                <span style="font-family:'JetBrains Mono',monospace; font-size:11px; color:#a78bfa; letter-spacing:0.06em;">Prof. Penrose-Hayes &middot; AquinTutor</span>
              </div>
            </div>

            <!-- Chapter badge -->
            <div style="position:absolute; top:14px; right:14px; display:flex; align-items:center; gap:8px; padding:5px 11px; background:rgba(0,0,0,0.6); border:1px solid rgba(255,255,255,0.12); border-radius:4px;">
              <span style="font-family:'JetBrains Mono',monospace; font-size:9px; letter-spacing:0.18em; color:rgba(244,241,234,0.55); text-transform:uppercase;">CHAPTER</span>
              <span style="font-family:'JetBrains Mono',monospace; font-size:11px; color:#f4f1ea;">3 of 6</span>
            </div>

            <!-- Play button -->
            <button type="button" style="position:absolute; width:78px; height:78px; border-radius:50%; background:rgba(217,119,87,0.92); border:none; display:flex; align-items:center; justify-content:center; cursor:pointer; box-shadow:0 0 30px rgba(217,119,87,0.4);">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="#0b0d10"><path d="M6 4l16 8-16 8V4z"/></svg>
            </button>
          </div>

          <!-- Player controls -->
          <div style="padding:12px 16px; background:var(--sand-100); border-top:1px solid var(--rule);">
            <!-- progress -->
            <div style="position:relative; height:4px; background:var(--rule); border-radius:2px; margin-bottom:12px;">
              {[0.12, 0.28, 0.45, 0.62, 0.81].map((p) => (
                <span style={'position:absolute; left:' + (p * 100) + '%; top:-2px; width:1px; height:8px; background:var(--ink-300);'}></span>
              ))}
              <div style="width:38%; height:100%; background:var(--rust); border-radius:2px;"></div>
              <div style="position:absolute; left:38%; top:50%; width:12px; height:12px; margin-left:-6px; margin-top:-6px; background:#fff; border-radius:50%; box-shadow:0 0 0 1px var(--rust);"></div>
            </div>

            <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
              <button type="button" style="width:32px; height:32px; background:var(--paper); border:1px solid var(--rule); border-radius:6px; cursor:pointer; display:inline-flex; align-items:center; justify-content:center; color:var(--ink);"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h2v12H6zm3.5 6l8.5-6v12z"/></svg></button>
              <button type="button" style="width:36px; height:36px; background:var(--ink); color:var(--sand-50); border:none; border-radius:50%; cursor:pointer; display:inline-flex; align-items:center; justify-content:center;"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6 4l16 8-16 8V4z"/></svg></button>
              <button type="button" style="width:32px; height:32px; background:var(--paper); border:1px solid var(--rule); border-radius:6px; cursor:pointer; display:inline-flex; align-items:center; justify-content:center; color:var(--ink);"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M16 6h2v12h-2zm-2.5 6L5 18V6z"/></svg></button>
              <span style="font-family:'JetBrains Mono',monospace; font-size:11.5px; color:var(--ink); font-variant-numeric:tabular-nums; letter-spacing:0.04em;">05:18 / 14:02</span>
              <span style="flex:1;"></span>
              <button type="button" style="padding:6px 12px; background:transparent; border:1px solid var(--rule); border-radius:6px; font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500); cursor:pointer; letterspacing:0.1em;">1.0x</button>
              <button type="button" style="padding:6px 12px; background:transparent; border:1px solid var(--rule); border-radius:6px; font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500); cursor:pointer;">CC</button>
              <button type="button" style="padding:6px 12px; background:transparent; border:1px solid var(--rule); border-radius:6px; font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--ink-500); cursor:pointer;">EN</button>
            </div>
          </div>
        </div>

        <!-- Tabs: Transcript / Notes / Quiz -->
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; overflow:hidden;">
          <div style="display:flex; border-bottom:1px solid var(--rule);">
            {[{ id: 'tr', label: 'Transcript', active: true }, { id: 'nt', label: 'Your notes' }, { id: 'qz', label: 'Checkpoint quiz' }].map((t) => (
              <button type="button" data-tab={t.id} class="pl-tab" style={'flex:1; padding:13px 8px; background:' + (t.active ? 'var(--sand-100)' : 'transparent') + '; border:none; border-bottom:2px solid ' + (t.active ? 'var(--rust)' : 'transparent') + '; color:' + (t.active ? 'var(--ink)' : 'var(--ink-500)') + '; font-family:Inter Tight,sans-serif; font-size:13px; font-weight:600; cursor:pointer;'}>{t.label}</button>
            ))}
          </div>
          <!-- Transcript -->
          <div id="pl-tr" class="pl-pane" style="padding:20px; display:flex; flex-direction:column; gap:14px;">
            {transcript.map((tr) => (
              <div style={'display:grid; grid-template-columns:56px 1fr; gap:14px; padding:10px 12px; border-radius:8px; ' + (tr.highlight ? 'background:rgba(91,74,146,0.06); border:1px solid rgba(91,74,146,0.25);' : '')}>
                <span style="font-family:'JetBrains Mono',monospace; font-size:11.5px; color:var(--rust); font-weight:600; letter-spacing:0.04em;">{tr.t}</span>
                <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:15px; color:var(--ink); line-height:1.55; margin:0;">{tr.text}</p>
              </div>
            ))}
          </div>
          <!-- Notes -->
          <div id="pl-nt" class="pl-pane" style="display:none; padding:20px;">
            <div style="display:flex; flex-direction:column; gap:10px; margin-bottom:18px;">
              {notes.map((n) => (
                <div style="display:grid; grid-template-columns:56px 1fr; gap:14px; padding:10px 12px; background:var(--sand-100); border:1px solid var(--rule); border-radius:8px;">
                  <span style="font-family:'JetBrains Mono',monospace; font-size:11.5px; color:var(--rust); font-weight:600;">{n.t}</span>
                  <p style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink); line-height:1.5; margin:0;">{n.text}</p>
                </div>
              ))}
            </div>
            <textarea placeholder="Type a note at the current timestamp..." rows="3" style="width:100%; padding:12px 14px; background:var(--paper); border:1px solid var(--rule); border-radius:8px; font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink); outline:none; resize:vertical;"></textarea>
            <button type="button" style="margin-top:8px; background:var(--ink); color:var(--sand-50); padding:9px 18px; border:none; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:12.5px; font-weight:600; cursor:pointer;">Save note &middot; 05:18</button>
          </div>
          <!-- Quiz -->
          <div id="pl-qz" class="pl-pane" style="display:none; padding:20px; display:flex; flex-direction:column; gap:18px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--rust); font-weight:600; margin:0;">CHECKPOINT &middot; 2 of 3 QUESTIONS</p>
            {quizQs.map((q, qi) => (
              <div>
                <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.1rem; color:var(--ink); margin:0 0 12px; line-height:1.4;">Q{qi+1}. {q.q}</p>
                <div style="display:flex; flex-direction:column; gap:7px;">
                  {q.opts.map((o, oi) => (
                    <label style={'display:flex; align-items:center; gap:12px; padding:11px 14px; background:' + (oi === q.correct ? 'rgba(74,112,72,0.07)' : 'var(--sand-100)') + '; border:1px solid ' + (oi === q.correct ? '#4a7048' : 'var(--rule)') + '; border-radius:8px; cursor:pointer;'}>
                      <span style={'display:inline-flex; align-items:center; justify-content:center; width:26px; height:26px; min-width:26px; border-radius:6px; background:var(--paper); border:1px solid ' + (oi === q.correct ? '#4a7048' : 'var(--rule)') + '; font-family:JetBrains Mono,monospace; font-size:11px; font-weight:600; color:' + (oi === q.correct ? '#4a7048' : 'var(--ink-500)') + ';'}>{String.fromCharCode(65 + oi)}</span>
                      <span style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink);">{o}</span>
                    </label>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- LESSON LIST RIGHT RAIL -->
      <aside style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:0; overflow:hidden; align-self:start;">
        <div style="padding:16px 18px; border-bottom:1px solid var(--rule); background:var(--sand-100);">
          <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0;">Week 4 &middot; lessons</p>
          <p style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--rust); margin:4px 0 0; font-weight:600;">3 of 6 complete</p>
          <div style="height:4px; background:var(--rule); border-radius:2px; overflow:hidden; margin-top:8px;">
            <div style="width:50%; height:100%; background:var(--rust);"></div>
          </div>
        </div>
        <ol style="list-style:none; padding:0; margin:0;">
          {lessons.map((l) => (
            <li style={'display:grid; grid-template-columns:36px 1fr auto; gap:12px; align-items:center; padding:13px 18px; border-bottom:1px solid var(--rule); ' + (l.state === 'current' ? 'background:rgba(160,66,30,0.06); border-left:3px solid var(--rust);' : '')}>
              <span style={'display:inline-flex; align-items:center; justify-content:center; width:28px; height:28px; border-radius:50%; font-family:JetBrains Mono,monospace; font-size:10px; font-weight:600; ' + (l.state === 'done' ? 'background:#4a7048; color:#fff;' : l.state === 'current' ? 'background:var(--rust); color:#fff;' : 'background:var(--sand-100); border:1px solid var(--rule); color:var(--ink-500);')}>{l.state === 'done' ? '✓' : l.n}</span>
              <div style="min-width:0;">
                <p style="font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:500; margin:0; color:var(--ink); line-height:1.35; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{l.title}</p>
                <p style="font-family:'JetBrains Mono',monospace; font-size:9.5px; color:var(--ink-500); margin:2px 0 0; letter-spacing:0.06em;">{l.kind === 'quiz' ? 'QUIZ &middot; ' : 'LECTURE &middot; '}{l.d}</p>
              </div>
              {l.state === 'current' && <span style="font-family:'JetBrains Mono',monospace; font-size:9px; letter-spacing:0.14em; text-transform:uppercase; color:var(--rust); font-weight:600;">PLAYING</span>}
              {l.state === 'locked' && <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--ink-500)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 018 0v4"/></svg>}
            </li>
          ))}
        </ol>
      </aside>
    </div>
  </section>

  <style>
    @media (min-width: 1000px) { .pl-grid { grid-template-columns: minmax(0, 1fr) 340px !important; } }
  </style>

  <script is:inline>
    (function() {
      var tabs = document.querySelectorAll('.pl-tab');
      var panes = document.querySelectorAll('.pl-pane');
      tabs.forEach(function(t) {
        t.addEventListener('click', function() {
          var id = t.getAttribute('data-tab');
          tabs.forEach(function(x) {
            var active = x.getAttribute('data-tab') === id;
            x.style.background = active ? 'var(--sand-100)' : 'transparent';
            x.style.borderBottom = '2px solid ' + (active ? 'var(--rust)' : 'transparent');
            x.style.color = active ? 'var(--ink)' : 'var(--ink-500)';
          });
          panes.forEach(function(p) {
            p.style.display = p.id === ('pl-' + id) ? 'flex' : 'none';
          });
        });
      });
    })();
  </script>
</AquintutorLayout>
