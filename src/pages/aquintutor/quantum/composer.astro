---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
---
<BaseLayout title="Quantum Circuit Composer · EduRankAI" description="Build quantum circuits in the browser. Real state-vector simulation up to 6 qubits, with live amplitude visualization, Bloch sphere, and QASM 2.0 export.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; }
  .qcomp-wrap { max-width: 1400px; margin: 0 auto; padding: 24px 5vw 80px; }
  .qcomp-header { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 16px; margin-bottom: 24px; }
  .qcomp-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 4vw, 44px); font-weight: 600; letter-spacing: -0.02em; margin: 0; }
  .qcomp-title em { color: #a78bfa; font-style: italic; font-weight: 500; }
  .qcomp-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: #a78bfa; font-weight: 700; }
  .qcomp-sub { font-size: 14px; color: #9aa6b6; max-width: 600px; margin-top: 8px; line-height: 1.6; }
  .qcomp-grid { display: grid; grid-template-columns: minmax(0, 1fr) 400px; gap: 24px; }
  @media (max-width: 1100px) { .qcomp-grid { grid-template-columns: 1fr; } }

  .qcomp-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 14px; padding: 18px; }
  .qcomp-panel h3 { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: #a78bfa; margin: 0 0 12px; font-weight: 700; }

  .gate-palette { display: grid; grid-template-columns: repeat(auto-fit, minmax(70px, 1fr)); gap: 8px; margin-bottom: 16px; }
  .gate-btn { background: #1a1a25; border: 1px solid #2a2a35; color: #fff; padding: 12px 8px; border-radius: 8px; cursor: grab; font-family: 'Geist Mono', monospace; font-weight: 700; text-align: center; font-size: 14px; transition: all 0.15s; }
  .gate-btn:hover { background: #2a2a35; transform: translateY(-1px); border-color: #a78bfa; }
  .gate-btn[data-gate="H"] { color: #fbbf24; }
  .gate-btn[data-gate="X"] { color: #f87171; }
  .gate-btn[data-gate="Y"] { color: #86efac; }
  .gate-btn[data-gate="Z"] { color: #67e8f9; }
  .gate-btn[data-gate="S"], .gate-btn[data-gate="T"] { color: #c4b5fd; }
  .gate-btn[data-gate="CNOT"], .gate-btn[data-gate="CCNOT"], .gate-btn[data-gate="SWAP"] { color: #fb923c; }
  .gate-btn[data-gate="M"] { color: #fff; background: #6b21a8; }

  .circuit-svg { width: 100%; border: 1px solid #2a2a35; border-radius: 10px; background: #0a0a0c; min-height: 360px; cursor: crosshair; }

  .ctrl-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 12px; }
  .ctrl-row label { display: block; font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; margin-bottom: 4px; }
  .ctrl-row input, .ctrl-row select { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; color: #fff; padding: 8px 10px; border-radius: 5px; font-size: 12.5px; }

  .qbtn { background: #a78bfa; color: #0a0a0c; border: none; padding: 9px 18px; border-radius: 6px; font-weight: 700; cursor: pointer; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; font-family: 'Geist Mono', monospace; }
  .qbtn-ghost { background: transparent; border: 1px solid #2a2a35; color: #cfd6da; }
  .qbtn:hover { transform: translateY(-1px); }

  .amp-row { display: grid; grid-template-columns: 60px 1fr 110px; gap: 8px; align-items: center; padding: 6px 0; border-bottom: 1px solid #1a1a25; font-family: 'Geist Mono', monospace; font-size: 11.5px; }
  .amp-row:last-child { border-bottom: none; }
  .amp-state { color: #a78bfa; font-weight: 700; }
  .amp-bar-wrap { background: #1a1a25; border-radius: 100px; height: 8px; overflow: hidden; }
  .amp-bar { background: linear-gradient(90deg, #a78bfa, #67e8f9); height: 100%; transition: width 0.3s ease; }
  .amp-cplx { color: #9aa6b6; text-align: right; font-size: 10.5px; }

  .bloch-svg { width: 200px; height: 200px; background: radial-gradient(circle at 30% 30%, #1a1a25, #0a0a0c); border-radius: 50%; border: 1px solid #2a2a35; margin: 0 auto; }

  .qasm-text { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 6px; padding: 12px; font-family: 'Geist Mono', monospace; font-size: 11px; color: #67e8f9; line-height: 1.55; max-height: 200px; overflow-y: auto; }

  .gate-label { font-family: 'Geist Mono', monospace; font-size: 14px; font-weight: 700; user-select: none; }
  .wire-line { stroke: #2a2a35; stroke-width: 1.5; }
  .wire-label { font-family: 'Geist Mono', monospace; font-size: 11px; fill: #9aa6b6; }
  .gate-rect { fill: #1a1a25; stroke: #a78bfa; stroke-width: 1.5; cursor: pointer; }
  .gate-rect:hover { fill: #2a2a35; }
  .ctrl-dot { fill: #fb923c; }
  .ctrl-line { stroke: #fb923c; stroke-width: 2; }
</style>

<main class="qcomp-wrap">
  <div class="qcomp-header">
    <div>
      <p class="qcomp-eyebrow">AquinTutor · Quantum Lab</p>
      <h1 class="qcomp-title">Quantum <em>circuit composer</em>.</h1>
      <p class="qcomp-sub">Build circuits up to 6 qubits. Real state-vector math runs in your browser — 64-amplitude superposition, live Bloch sphere, QASM 2.0 export. No cloud, no API call.</p>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
      <button class="qbtn qbtn-ghost" id="clearBtn">Clear</button>
      <button class="qbtn qbtn-ghost" id="resetBtn">Reset state</button>
      <button class="qbtn" id="runBtn">Run circuit</button>
    </div>
  </div>

  <div class="qcomp-grid">

    {/* LEFT: gate palette + circuit canvas */}
    <div>
      <div class="qcomp-panel" style="margin-bottom:16px;">
        <h3>Gate palette · drag onto a wire</h3>
        <div class="gate-palette">
          <button class="gate-btn" data-gate="H">H</button>
          <button class="gate-btn" data-gate="X">X</button>
          <button class="gate-btn" data-gate="Y">Y</button>
          <button class="gate-btn" data-gate="Z">Z</button>
          <button class="gate-btn" data-gate="S">S</button>
          <button class="gate-btn" data-gate="T">T</button>
          <button class="gate-btn" data-gate="CNOT">CNOT</button>
          <button class="gate-btn" data-gate="SWAP">SWAP</button>
          <button class="gate-btn" data-gate="M">M</button>
        </div>

        <div class="ctrl-row">
          <div><label>Qubits</label>
            <select id="qubitCount"><option>1</option><option>2</option><option selected>3</option><option>4</option><option>5</option><option>6</option></select>
          </div>
          <div><label>Rotation angle (RX/RY/RZ)</label>
            <input id="rotAngle" type="number" value="1.5707963" step="0.01" />
          </div>
        </div>

        <p style="font-size:11px;color:#9aa6b6;margin:6px 0 0;">Click a gate then click a wire position to place it. For CNOT/SWAP: control wire first, then target wire.</p>
      </div>

      <div class="qcomp-panel">
        <h3>Circuit</h3>
        <svg id="circuitSvg" class="circuit-svg" viewBox="0 0 1000 360" preserveAspectRatio="xMidYMid meet"></svg>
      </div>
    </div>

    {/* RIGHT: state vector + Bloch + QASM */}
    <div>
      <div class="qcomp-panel" style="margin-bottom:16px;">
        <h3>State vector · probability</h3>
        <div id="ampList" style="max-height:340px;overflow-y:auto;"></div>
      </div>

      <div class="qcomp-panel" style="margin-bottom:16px;">
        <h3>Bloch sphere · qubit
          <select id="blochQubit" style="background:#0a0a0c;border:1px solid #2a2a35;color:#a78bfa;padding:3px 8px;border-radius:4px;font-family:inherit;font-size:11px;margin-left:6px;"></select>
        </h3>
        <svg id="blochSvg" class="bloch-svg" viewBox="-110 -110 220 220">
          <circle cx="0" cy="0" r="100" fill="none" stroke="#2a2a35" stroke-width="1.5"/>
          <ellipse cx="0" cy="0" rx="100" ry="30" fill="none" stroke="#2a2a35" stroke-width="0.8" stroke-dasharray="3 3"/>
          <line x1="-100" y1="0" x2="100" y2="0" stroke="#2a2a35" stroke-width="0.8"/>
          <line x1="0" y1="-100" x2="0" y2="100" stroke="#2a2a35" stroke-width="0.8"/>
          <text x="6" y="-100" fill="#a78bfa" font-family="Geist Mono" font-size="12" font-weight="700">|0⟩</text>
          <text x="6" y="110" fill="#67e8f9" font-family="Geist Mono" font-size="12" font-weight="700">|1⟩</text>
          <text x="100" y="-4" fill="#9aa6b6" font-family="Geist Mono" font-size="11">+x</text>
          <text x="-110" y="-4" fill="#9aa6b6" font-family="Geist Mono" font-size="11">-x</text>
          <line id="blochVec" x1="0" y1="0" x2="0" y2="-100" stroke="#fbbf24" stroke-width="2.5" />
          <circle id="blochTip" cx="0" cy="-100" r="4.5" fill="#fbbf24"/>
        </svg>
        <p style="font-family:'Geist Mono',monospace;font-size:10.5px;color:#9aa6b6;text-align:center;margin:8px 0 0;">θ = <span id="blochTheta">0.0</span> rad · φ = <span id="blochPhi">0.0</span> rad</p>
      </div>

      <div class="qcomp-panel">
        <h3>QASM 2.0 export</h3>
        <pre id="qasmOut" class="qasm-text">OPENQASM 2.0;
include "qelib1.inc";
qreg q[3];
creg c[3];</pre>
        <div style="display:flex;gap:6px;margin-top:8px;">
          <button class="qbtn qbtn-ghost" id="copyQasmBtn">Copy</button>
          <button class="qbtn qbtn-ghost" id="dlQasmBtn">Download .qasm</button>
        </div>
      </div>
    </div>
  </div>
</main>

<script is:inline>
  /* ============================================================
     EduRankAI Quantum Circuit Composer — pure-JS state-vector sim.
     Up to 6 qubits (64 complex amplitudes). Gates: H, X, Y, Z, S, T,
     CNOT, SWAP, M (measurement). Real math — apply each gate as a
     2^n × 2^n unitary to the global state vector. NO external calls.
     ============================================================ */
  (function () {

    // ============ Complex number helpers ============
    function c(re, im) { return { re: re, im: im || 0 }; }
    function cadd(a, b) { return c(a.re + b.re, a.im + b.im); }
    function cmul(a, b) { return c(a.re * b.re - a.im * b.im, a.re * b.im + a.im * b.re); }
    function cabs2(a) { return a.re * a.re + a.im * a.im; }
    function cnorm(a) { return Math.sqrt(cabs2(a)); }

    // ============ State ============
    var nq = 3;
    var N = 1 << nq;       // 2^nq amplitudes
    var psi = [];           // state vector (Array of {re,im})
    var gates = [];         // sequence of placed gates: { kind, targets:[wireIdx], control?:wireIdx, angle? }
    var selectedGate = null;
    var pendingMulti = null; // for CNOT/SWAP — first wire becomes control

    function resetState() {
      psi = new Array(N);
      for (var i = 0; i < N; i++) psi[i] = c(0, 0);
      psi[0] = c(1, 0); // |0...0>
    }
    resetState();

    // ============ Gate matrices (2x2) ============
    var inv2 = 1 / Math.sqrt(2);
    var GATES = {
      H: [ c(inv2, 0), c(inv2, 0), c(inv2, 0), c(-inv2, 0) ],
      X: [ c(0, 0), c(1, 0), c(1, 0), c(0, 0) ],
      Y: [ c(0, 0), c(0, -1), c(0, 1), c(0, 0) ],
      Z: [ c(1, 0), c(0, 0), c(0, 0), c(-1, 0) ],
      S: [ c(1, 0), c(0, 0), c(0, 0), c(0, 1) ],
      T: [ c(1, 0), c(0, 0), c(0, 0), c(Math.cos(Math.PI / 4), Math.sin(Math.PI / 4)) ],
    };

    // Apply a single-qubit gate `G` (2x2 matrix as 4 complex entries [g00,g01,g10,g11]) to qubit `t` of the state.
    function applySingle(G, t) {
      var newPsi = new Array(N);
      for (var i = 0; i < N; i++) newPsi[i] = c(0, 0);
      for (var i = 0; i < N; i++) {
        var bit = (i >> t) & 1;
        var partner = i ^ (1 << t);
        var iPair = bit === 0 ? i : partner;
        var pPair = bit === 0 ? partner : i;
        var g0 = bit === 0 ? G[0] : G[2];
        var g1 = bit === 0 ? G[1] : G[3];
        newPsi[i] = cadd(cmul(g0, psi[iPair]), cmul(g1, psi[pPair]));
      }
      psi = newPsi;
    }

    // Apply CNOT: control c, target t. Flips amp pairs only where control bit = 1.
    function applyCNOT(ctrl, tgt) {
      var newPsi = psi.slice();
      for (var i = 0; i < N; i++) {
        var cbit = (i >> ctrl) & 1;
        if (cbit === 1) {
          var partner = i ^ (1 << tgt);
          if (partner > i) {
            var tmp = newPsi[i]; newPsi[i] = psi[partner]; newPsi[partner] = psi[i];
            // Actually swap correctly:
            newPsi[i] = psi[partner];
            newPsi[partner] = psi[i];
          }
        }
      }
      psi = newPsi;
    }

    function applySWAP(a, b) {
      var newPsi = psi.slice();
      for (var i = 0; i < N; i++) {
        var ba = (i >> a) & 1, bb = (i >> b) & 1;
        if (ba !== bb) {
          var partner = i ^ (1 << a) ^ (1 << b);
          if (partner > i) {
            newPsi[i] = psi[partner];
            newPsi[partner] = psi[i];
          }
        }
      }
      psi = newPsi;
    }

    function measure(t) {
      // Project onto |0> and |1>; randomly collapse weighted by probability.
      var p1 = 0;
      for (var i = 0; i < N; i++) {
        if ((i >> t) & 1) p1 += cabs2(psi[i]);
      }
      var r = Math.random();
      var outcome = r < p1 ? 1 : 0;
      var norm = outcome === 1 ? Math.sqrt(p1) : Math.sqrt(1 - p1);
      if (norm === 0) return outcome;
      for (var i = 0; i < N; i++) {
        if (((i >> t) & 1) === outcome) {
          psi[i] = c(psi[i].re / norm, psi[i].im / norm);
        } else {
          psi[i] = c(0, 0);
        }
      }
      return outcome;
    }

    // ============ Run the placed gate sequence ============
    function runCircuit() {
      resetState();
      var measurementResults = [];
      gates.forEach(function (g) {
        if (g.kind === 'H' || g.kind === 'X' || g.kind === 'Y' || g.kind === 'Z' || g.kind === 'S' || g.kind === 'T') {
          applySingle(GATES[g.kind], g.targets[0]);
        } else if (g.kind === 'CNOT') {
          applyCNOT(g.control, g.targets[0]);
        } else if (g.kind === 'SWAP') {
          applySWAP(g.targets[0], g.targets[1]);
        } else if (g.kind === 'M') {
          var out = measure(g.targets[0]);
          measurementResults.push({ qubit: g.targets[0], outcome: out });
        }
      });
      renderState();
    }

    // ============ Render state vector + Bloch + QASM ============
    function renderState() {
      var ampList = document.getElementById('ampList');
      ampList.innerHTML = '';
      for (var i = 0; i < N; i++) {
        var prob = cabs2(psi[i]);
        if (prob < 1e-9 && i !== 0) continue;
        var bits = i.toString(2).padStart(nq, '0');
        var row = document.createElement('div');
        row.className = 'amp-row';
        var re = psi[i].re; var im = psi[i].im;
        var cplxStr = (re.toFixed(3)) + (im >= 0 ? ' + ' : ' − ') + Math.abs(im).toFixed(3) + 'i';
        row.innerHTML = '<span class="amp-state">|' + bits + '⟩</span>'
          + '<div class="amp-bar-wrap"><div class="amp-bar" style="width:' + (prob * 100).toFixed(2) + '%"></div></div>'
          + '<span class="amp-cplx">' + (prob * 100).toFixed(2) + '%<br/>' + cplxStr + '</span>';
        ampList.appendChild(row);
      }

      // Bloch sphere — only meaningful for the SELECTED qubit's reduced density matrix.
      var q = parseInt(document.getElementById('blochQubit').value, 10) || 0;
      // For an isolated qubit (no entanglement) Bloch coords are <X>,<Y>,<Z>.
      var bx = 0, by = 0, bz = 0;
      for (var i = 0; i < N; i++) {
        var bit = (i >> q) & 1;
        var partner = i ^ (1 << q);
        if (bit === 0) {
          // <X>: 2 Re(a0* a1)
          bx += 2 * (psi[i].re * psi[partner].re + psi[i].im * psi[partner].im);
          // <Y>: 2 Im(a0* a1)
          by += 2 * (psi[i].re * psi[partner].im - psi[i].im * psi[partner].re);
        }
        bz += (bit === 0 ? 1 : -1) * cabs2(psi[i]);
      }
      // Project to (theta, phi). Bloch: z = cos(theta), x = sin(theta)cos(phi), y = sin(theta)sin(phi).
      var theta = Math.acos(Math.max(-1, Math.min(1, bz)));
      var phi = Math.atan2(by, bx);
      var R = 100;
      // SVG 2D projection — y axis flipped, x and z visible, y goes into page (use cos(phi) and sin(theta) for screen-x).
      var screenX = R * Math.sin(theta) * Math.cos(phi);
      var screenY = -R * bz;
      var vec = document.getElementById('blochVec');
      var tip = document.getElementById('blochTip');
      vec.setAttribute('x2', screenX); vec.setAttribute('y2', screenY);
      tip.setAttribute('cx', screenX); tip.setAttribute('cy', screenY);
      document.getElementById('blochTheta').textContent = theta.toFixed(3);
      document.getElementById('blochPhi').textContent = phi.toFixed(3);

      // QASM export
      var qasm = 'OPENQASM 2.0;\ninclude "qelib1.inc";\nqreg q[' + nq + '];\ncreg c[' + nq + '];\n';
      gates.forEach(function (g) {
        var name = g.kind.toLowerCase();
        if (g.kind === 'CNOT') qasm += 'cx q[' + g.control + '],q[' + g.targets[0] + '];\n';
        else if (g.kind === 'SWAP') qasm += 'swap q[' + g.targets[0] + '],q[' + g.targets[1] + '];\n';
        else if (g.kind === 'M') qasm += 'measure q[' + g.targets[0] + '] -> c[' + g.targets[0] + '];\n';
        else qasm += name + ' q[' + g.targets[0] + '];\n';
      });
      document.getElementById('qasmOut').textContent = qasm;
    }

    // ============ Circuit canvas — SVG render + click to place ============
    var svg = document.getElementById('circuitSvg');
    function renderCircuit() {
      svg.innerHTML = '';
      var w = 1000, h = 360;
      var wireY = function (i) { return 40 + i * ((h - 80) / Math.max(1, nq - 1 || 1)); };
      if (nq === 1) wireY = function () { return h / 2; };

      // wires
      for (var i = 0; i < nq; i++) {
        var line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        line.setAttribute('x1', 60); line.setAttribute('x2', w - 20);
        line.setAttribute('y1', wireY(i)); line.setAttribute('y2', wireY(i));
        line.setAttribute('class', 'wire-line');
        svg.appendChild(line);
        var label = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        label.setAttribute('x', 10); label.setAttribute('y', wireY(i) + 5);
        label.setAttribute('class', 'wire-label');
        label.textContent = 'q' + i;
        svg.appendChild(label);
      }

      // gates
      var xStep = 56;
      var startX = 80;
      gates.forEach(function (g, gi) {
        var gx = startX + gi * xStep;
        if (g.kind === 'CNOT') {
          var cy = wireY(g.control); var ty = wireY(g.targets[0]);
          var l = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          l.setAttribute('x1', gx); l.setAttribute('x2', gx); l.setAttribute('y1', cy); l.setAttribute('y2', ty);
          l.setAttribute('class', 'ctrl-line');
          svg.appendChild(l);
          var dot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
          dot.setAttribute('cx', gx); dot.setAttribute('cy', cy); dot.setAttribute('r', 6);
          dot.setAttribute('class', 'ctrl-dot');
          svg.appendChild(dot);
          var ring = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
          ring.setAttribute('cx', gx); ring.setAttribute('cy', ty); ring.setAttribute('r', 14);
          ring.setAttribute('fill', 'none'); ring.setAttribute('stroke', '#fb923c'); ring.setAttribute('stroke-width', 2);
          svg.appendChild(ring);
          var cross1 = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          cross1.setAttribute('x1', gx - 14); cross1.setAttribute('x2', gx + 14); cross1.setAttribute('y1', ty); cross1.setAttribute('y2', ty);
          cross1.setAttribute('stroke', '#fb923c'); cross1.setAttribute('stroke-width', 2);
          svg.appendChild(cross1);
        } else if (g.kind === 'SWAP') {
          var y1 = wireY(g.targets[0]); var y2 = wireY(g.targets[1]);
          [y1, y2].forEach(function (y) {
            var c1 = document.createElementNS('http://www.w3.org/2000/svg', 'line');
            c1.setAttribute('x1', gx - 8); c1.setAttribute('x2', gx + 8); c1.setAttribute('y1', y - 8); c1.setAttribute('y2', y + 8);
            c1.setAttribute('stroke', '#fb923c'); c1.setAttribute('stroke-width', 2); svg.appendChild(c1);
            var c2 = document.createElementNS('http://www.w3.org/2000/svg', 'line');
            c2.setAttribute('x1', gx - 8); c2.setAttribute('x2', gx + 8); c2.setAttribute('y1', y + 8); c2.setAttribute('y2', y - 8);
            c2.setAttribute('stroke', '#fb923c'); c2.setAttribute('stroke-width', 2); svg.appendChild(c2);
          });
          var sl = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          sl.setAttribute('x1', gx); sl.setAttribute('x2', gx); sl.setAttribute('y1', y1); sl.setAttribute('y2', y2);
          sl.setAttribute('stroke', '#fb923c'); sl.setAttribute('stroke-width', 1.5); sl.setAttribute('stroke-dasharray', '3 3');
          svg.appendChild(sl);
        } else if (g.kind === 'M') {
          var y = wireY(g.targets[0]);
          var rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
          rect.setAttribute('x', gx - 18); rect.setAttribute('y', y - 18); rect.setAttribute('width', 36); rect.setAttribute('height', 36);
          rect.setAttribute('rx', 6); rect.setAttribute('fill', '#6b21a8'); rect.setAttribute('stroke', '#a78bfa'); rect.setAttribute('stroke-width', 1.5);
          svg.appendChild(rect);
          var arc = document.createElementNS('http://www.w3.org/2000/svg', 'path');
          arc.setAttribute('d', 'M ' + (gx - 10) + ' ' + (y + 5) + ' A 10 10 0 0 1 ' + (gx + 10) + ' ' + (y + 5));
          arc.setAttribute('fill', 'none'); arc.setAttribute('stroke', '#fff'); arc.setAttribute('stroke-width', 1.5);
          svg.appendChild(arc);
          var needle = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          needle.setAttribute('x1', gx); needle.setAttribute('y1', y + 5); needle.setAttribute('x2', gx + 7); needle.setAttribute('y2', y - 7);
          needle.setAttribute('stroke', '#fff'); needle.setAttribute('stroke-width', 1.5);
          svg.appendChild(needle);
        } else {
          var rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
          rect.setAttribute('x', gx - 18); rect.setAttribute('y', wireY(g.targets[0]) - 18);
          rect.setAttribute('width', 36); rect.setAttribute('height', 36); rect.setAttribute('rx', 6);
          rect.setAttribute('class', 'gate-rect');
          rect.setAttribute('data-gi', gi);
          svg.appendChild(rect);
          var txt = document.createElementNS('http://www.w3.org/2000/svg', 'text');
          txt.setAttribute('x', gx); txt.setAttribute('y', wireY(g.targets[0]) + 5);
          txt.setAttribute('text-anchor', 'middle'); txt.setAttribute('fill', '#a78bfa');
          txt.setAttribute('class', 'gate-label');
          txt.textContent = g.kind;
          svg.appendChild(txt);
        }
      });

      // Hover / right-click delete
      svg.querySelectorAll('[data-gi]').forEach(function (el) {
        el.addEventListener('contextmenu', function (e) {
          e.preventDefault();
          var gi = +el.getAttribute('data-gi');
          gates.splice(gi, 1);
          renderCircuit();
          runCircuit();
        });
      });
    }

    function setQubitCount(n) {
      nq = Math.max(1, Math.min(6, n));
      N = 1 << nq;
      resetState();
      gates = []; // clear circuit when changing qubit count (state-vector size changes)
      var sel = document.getElementById('blochQubit');
      sel.innerHTML = '';
      for (var i = 0; i < nq; i++) { var o = document.createElement('option'); o.value = i; o.textContent = 'q' + i; sel.appendChild(o); }
      renderCircuit();
      renderState();
    }

    // ============ Wiring ============
    document.querySelectorAll('.gate-btn').forEach(function (b) {
      b.addEventListener('click', function () {
        selectedGate = b.getAttribute('data-gate');
        pendingMulti = null;
        document.querySelectorAll('.gate-btn').forEach(function (x) { x.style.outline = ''; });
        b.style.outline = '2px solid #a78bfa';
      });
    });

    svg.addEventListener('click', function (e) {
      if (!selectedGate) return;
      // Decode which wire was clicked.
      var pt = svg.createSVGPoint(); pt.x = e.clientX; pt.y = e.clientY;
      var ctm = svg.getScreenCTM().inverse(); var sp = pt.matrixTransform(ctm);
      // wire indexes by Y
      var wireH = (360 - 80) / Math.max(1, nq - 1 || 1);
      var wireIdx;
      if (nq === 1) wireIdx = 0;
      else wireIdx = Math.round((sp.y - 40) / wireH);
      if (wireIdx < 0 || wireIdx >= nq) return;

      if (selectedGate === 'CNOT' || selectedGate === 'SWAP') {
        if (pendingMulti == null) { pendingMulti = wireIdx; alert('Selected ' + (selectedGate === 'CNOT' ? 'control' : 'first') + ' = q' + wireIdx + '. Click target wire next.'); return; }
        if (pendingMulti === wireIdx) { alert('Target must differ from control.'); return; }
        if (selectedGate === 'CNOT') gates.push({ kind: 'CNOT', control: pendingMulti, targets: [wireIdx] });
        else gates.push({ kind: 'SWAP', targets: [pendingMulti, wireIdx] });
        pendingMulti = null;
      } else {
        gates.push({ kind: selectedGate, targets: [wireIdx] });
      }
      renderCircuit();
      runCircuit();
    });

    document.getElementById('qubitCount').addEventListener('change', function (e) { setQubitCount(parseInt(e.target.value, 10)); });
    document.getElementById('clearBtn').addEventListener('click', function () { gates = []; resetState(); renderCircuit(); renderState(); });
    document.getElementById('resetBtn').addEventListener('click', function () { resetState(); renderState(); });
    document.getElementById('runBtn').addEventListener('click', runCircuit);
    document.getElementById('blochQubit').addEventListener('change', renderState);
    document.getElementById('copyQasmBtn').addEventListener('click', function () { navigator.clipboard.writeText(document.getElementById('qasmOut').textContent); });
    document.getElementById('dlQasmBtn').addEventListener('click', function () {
      var blob = new Blob([document.getElementById('qasmOut').textContent], { type: 'text/plain' });
      var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'circuit-' + Date.now() + '.qasm'; a.click();
    });

    setQubitCount(3);

  })();
</script>
</BaseLayout>
