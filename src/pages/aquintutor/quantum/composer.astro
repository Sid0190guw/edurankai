---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Quantum Circuit Composer · EduRankAI" description="Qiskit-class browser quantum circuit composer. Full gate set, QASM 2.0 import + export, shot-based simulation, circuit presets (Bell / GHZ / Grover / Teleportation / QFT). 100% in-browser, no cloud.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; }
  .qc { max-width: 1500px; margin: 0 auto; padding: 24px 5vw 80px; }
  .qc-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: #a78bfa; font-weight: 700; }
  .qc-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 4vw, 44px); font-weight: 600; letter-spacing: -0.02em; margin: 4px 0; }
  .qc-title em { color: #a78bfa; font-style: italic; font-weight: 500; }
  .qc-sub { font-size: 14px; color: #9aa6b6; max-width: 720px; margin-top: 6px; line-height: 1.6; }

  .qc-top { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 16px; margin-bottom: 22px; }
  .qc-btn { background: #a78bfa; color: #0a0a0c; border: none; padding: 9px 16px; border-radius: 6px; font-weight: 800; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; }
  .qc-btn-ghost { background: transparent; border: 1px solid #2a2a35; color: #cfd6da; }
  .qc-btn:hover { transform: translateY(-1px); }

  .qc-grid { display: grid; grid-template-columns: minmax(0, 1fr) 420px; gap: 20px; }
  @media (max-width: 1200px) { .qc-grid { grid-template-columns: 1fr; } }
  .qc-panel { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 16px; margin-bottom: 14px; }
  .qc-panel h3 { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: #a78bfa; margin: 0 0 12px; font-weight: 700; }

  .gate-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(60px, 1fr)); gap: 6px; }
  .gate-btn { background: #1a1a25; border: 1px solid #2a2a35; color: #fff; padding: 9px 6px; border-radius: 6px; cursor: pointer; font-family: 'Geist Mono', monospace; font-weight: 700; font-size: 12px; }
  .gate-btn:hover { border-color: #a78bfa; }
  .gate-btn.active { background: #a78bfa; color: #0a0a0c; border-color: #a78bfa; }

  .qc-ctrl { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 10px; }
  .qc-ctrl label { display: block; font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #9aa6b6; margin-bottom: 3px; font-weight: 700; }
  .qc-ctrl input, .qc-ctrl select, .qc-ctrl textarea { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; color: #fff; padding: 7px 9px; border-radius: 5px; font-size: 11.5px; font-family: inherit; box-sizing: border-box; }

  .circuit-svg { width: 100%; min-height: 420px; background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; cursor: crosshair; }

  .preset-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
  .preset-btn { background: #1a1a25; border: 1px solid #2a2a35; color: #fff; padding: 8px 10px; border-radius: 6px; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 10.5px; font-weight: 600; text-align: left; letter-spacing: 0.04em; }
  .preset-btn:hover { background: #2a2a35; border-color: #a78bfa; }

  .qasm-area { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 6px; padding: 10px; font-family: ui-monospace, monospace; font-size: 11px; color: #67e8f9; line-height: 1.55; min-height: 100px; max-height: 200px; width: 100%; box-sizing: border-box; resize: vertical; }

  .amp-row { display: grid; grid-template-columns: 60px 1fr 110px; gap: 8px; align-items: center; padding: 5px 0; border-bottom: 1px solid #1a1a25; font-family: 'Geist Mono', monospace; font-size: 11px; }
  .amp-row:last-child { border-bottom: none; }
  .amp-state { color: #a78bfa; font-weight: 700; }
  .amp-bar-wrap { background: #1a1a25; border-radius: 100px; height: 7px; overflow: hidden; }
  .amp-bar { background: linear-gradient(90deg, #a78bfa, #67e8f9); height: 100%; transition: width 0.3s; }
  .amp-cplx { color: #9aa6b6; text-align: right; font-size: 10px; }

  .bloch-svg { width: 200px; height: 200px; background: radial-gradient(circle at 30% 30%, #1a1a25, #0a0a0c); border-radius: 50%; border: 1px solid #2a2a35; margin: 0 auto; }
  .histo-bar { display: grid; grid-template-columns: 70px 1fr 70px; gap: 8px; align-items: center; padding: 3px 0; font-family: 'Geist Mono', monospace; font-size: 11px; }
  .histo-fill-wrap { background: #1a1a25; border-radius: 100px; height: 16px; overflow: hidden; }
  .histo-fill { background: linear-gradient(90deg, #fb923c, #fbbf24); height: 100%; }

  .gate-rect { fill: #1a1a25; stroke: #a78bfa; stroke-width: 1.5; }
  .gate-rect.rot { stroke: #67e8f9; }
  .gate-rect.measure { fill: #6b21a8; stroke: #a78bfa; }
  .gate-label { font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; pointer-events: none; }
  .wire-line { stroke: #2a2a35; stroke-width: 1.5; }
  .wire-label { font-family: 'Geist Mono', monospace; font-size: 11px; fill: #9aa6b6; }
  .creg-line { stroke: #2a2a35; stroke-width: 1; stroke-dasharray: 3 3; }
</style>

<main class="qc">
  <div class="qc-top">
    <div>
      <p class="qc-eyebrow">AquinTutor · Quantum Lab</p>
      <h1 class="qc-title">Quantum <em>circuit composer</em> · Qiskit-class.</h1>
      <p class="qc-sub">Real state-vector simulation up to 8 qubits (256 amplitudes). Full Qiskit gate set: H · X · Y · Z · S · S† · T · T† · Rx · Ry · Rz · U3 · CX · CZ · CCX (Toffoli) · CSWAP (Fredkin) · SWAP · Measure. <strong>Paste any Qiskit-output QASM 2.0 and run it.</strong> Shot-based simulation with histogram. 100% browser, no cloud.</p>
    </div>
    <div style="display:flex;gap:6px;flex-wrap:wrap;">
      <button class="qc-btn qc-btn-ghost" id="clearBtn">Clear</button>
      <button class="qc-btn qc-btn-ghost" id="undoBtn">Undo</button>
      <button class="qc-btn" id="runBtn">Run · 1024 shots</button>
    </div>
  </div>

  <div class="qc-grid">

    {/* LEFT — circuit canvas + gate palette */}
    <div>
      <div class="qc-panel">
        <h3>Gate palette · click then click a wire</h3>
        <div class="gate-grid">
          <button class="gate-btn" data-gate="I">I</button>
          <button class="gate-btn" data-gate="H">H</button>
          <button class="gate-btn" data-gate="X">X</button>
          <button class="gate-btn" data-gate="Y">Y</button>
          <button class="gate-btn" data-gate="Z">Z</button>
          <button class="gate-btn" data-gate="S">S</button>
          <button class="gate-btn" data-gate="SDG">S†</button>
          <button class="gate-btn" data-gate="T">T</button>
          <button class="gate-btn" data-gate="TDG">T†</button>
          <button class="gate-btn" data-gate="RX">Rx</button>
          <button class="gate-btn" data-gate="RY">Ry</button>
          <button class="gate-btn" data-gate="RZ">Rz</button>
          <button class="gate-btn" data-gate="U3">U3</button>
          <button class="gate-btn" data-gate="CX">CX</button>
          <button class="gate-btn" data-gate="CY">CY</button>
          <button class="gate-btn" data-gate="CZ">CZ</button>
          <button class="gate-btn" data-gate="CH">CH</button>
          <button class="gate-btn" data-gate="SWAP">SWAP</button>
          <button class="gate-btn" data-gate="CCX">CCX</button>
          <button class="gate-btn" data-gate="CSWAP">CSWAP</button>
          <button class="gate-btn" data-gate="M">M</button>
        </div>

        <div class="qc-ctrl">
          <div><label>Qubits</label>
            <select id="qubitCount"><option>1</option><option>2</option><option selected>3</option><option>4</option><option>5</option><option>6</option><option>7</option><option>8</option></select>
          </div>
          <div><label>θ (radians) · for Rx/Ry/Rz/U3</label>
            <input id="thetaInput" type="number" value="1.5707963" step="0.01"/>
          </div>
          <div><label>φ (U3 only)</label>
            <input id="phiInput" type="number" value="0" step="0.01"/>
          </div>
          <div><label>λ (U3 only)</label>
            <input id="lambdaInput" type="number" value="0" step="0.01"/>
          </div>
        </div>
        <p style="font-size:11px;color:#9aa6b6;margin:8px 0 0;">For multi-qubit gates (CX/CZ/SWAP/etc): click control first, then target. Toffoli (CCX): two clicks for controls, third for target. Right-click any gate to delete.</p>
      </div>

      <div class="qc-panel">
        <h3>Circuit</h3>
        <svg id="circuitSvg" class="circuit-svg" viewBox="0 0 1300 420" preserveAspectRatio="xMidYMid meet"></svg>
      </div>

      <div class="qc-panel">
        <h3>QASM 2.0 · paste + run any Qiskit output</h3>
        <textarea id="qasmIn" class="qasm-area" placeholder="OPENQASM 2.0;
include 'qelib1.inc';
qreg q[3];
creg c[3];
h q[0];
cx q[0],q[1];
cx q[1],q[2];
measure q -> c;"></textarea>
        <div style="display:flex;gap:6px;margin-top:8px;flex-wrap:wrap;">
          <button class="qc-btn qc-btn-ghost" id="parseBtn">Parse + load</button>
          <button class="qc-btn qc-btn-ghost" id="copyQasmBtn">Copy current</button>
          <button class="qc-btn qc-btn-ghost" id="dlQasmBtn">Download .qasm</button>
        </div>
      </div>

      <div class="qc-panel">
        <h3>Circuit presets · double-click to load</h3>
        <div class="preset-grid">
          <button class="preset-btn" data-preset="bell">Bell pair · entangle 2 qubits</button>
          <button class="preset-btn" data-preset="ghz">GHZ state · 3-qubit</button>
          <button class="preset-btn" data-preset="grover2">Grover · 2-qubit search</button>
          <button class="preset-btn" data-preset="deutsch">Deutsch–Jozsa · constant vs balanced</button>
          <button class="preset-btn" data-preset="teleport">Quantum teleportation · 3 qubits</button>
          <button class="preset-btn" data-preset="qft3">Quantum Fourier · 3 qubits</button>
          <button class="preset-btn" data-preset="bernstein">Bernstein–Vazirani · 3-bit secret</button>
          <button class="preset-btn" data-preset="superdense">Superdense coding</button>
        </div>
      </div>
    </div>

    {/* RIGHT — state vector, Bloch sphere, shot histogram, QASM export */}
    <div>
      <div class="qc-panel">
        <h3>State vector · post-circuit</h3>
        <div id="ampList" style="max-height:300px;overflow-y:auto;"></div>
      </div>

      <div class="qc-panel">
        <h3>Shot histogram · 1024 trials</h3>
        <div id="histoList"></div>
      </div>

      <div class="qc-panel">
        <h3>Bloch sphere ·
          <select id="blochQubit" style="background:#0a0a0c;border:1px solid #2a2a35;color:#a78bfa;padding:3px 6px;border-radius:4px;font-family:inherit;font-size:11px;margin-left:6px;"></select>
        </h3>
        <svg class="bloch-svg" viewBox="-110 -110 220 220">
          <circle cx="0" cy="0" r="100" fill="none" stroke="#2a2a35"/>
          <ellipse cx="0" cy="0" rx="100" ry="30" fill="none" stroke="#2a2a35" stroke-dasharray="3 3"/>
          <line x1="-100" y1="0" x2="100" y2="0" stroke="#2a2a35"/>
          <line x1="0" y1="-100" x2="0" y2="100" stroke="#2a2a35"/>
          <text x="6" y="-100" fill="#a78bfa" font-family="Geist Mono" font-size="12" font-weight="700">|0⟩</text>
          <text x="6" y="110" fill="#67e8f9" font-family="Geist Mono" font-size="12" font-weight="700">|1⟩</text>
          <text x="100" y="-4" fill="#9aa6b6" font-family="Geist Mono" font-size="11">+x</text>
          <text x="-110" y="-4" fill="#9aa6b6" font-family="Geist Mono" font-size="11">-x</text>
          <line id="blochVec" x1="0" y1="0" x2="0" y2="-100" stroke="#fbbf24" stroke-width="2.5"/>
          <circle id="blochTip" cx="0" cy="-100" r="4.5" fill="#fbbf24"/>
        </svg>
        <p style="font-family:'Geist Mono',monospace;font-size:10.5px;color:#9aa6b6;text-align:center;margin:8px 0 0;">θ = <span id="blochTheta">0.0</span> · φ = <span id="blochPhi">0.0</span></p>
      </div>

      <div class="qc-panel">
        <h3>Circuit metrics</h3>
        <p style="font-family:'Geist Mono',monospace;font-size:11.5px;line-height:1.7;margin:0;">
          Depth: <span id="mDepth" style="color:#a78bfa;font-weight:700;">0</span> ·
          Gates: <span id="mGates" style="color:#a78bfa;font-weight:700;">0</span> ·
          Qubits: <span id="mQubits" style="color:#a78bfa;font-weight:700;">3</span><br/>
          CX-count: <span id="mCx" style="color:#67e8f9;font-weight:700;">0</span> ·
          T-count: <span id="mT" style="color:#67e8f9;font-weight:700;">0</span> ·
          Single-q: <span id="mSq" style="color:#67e8f9;font-weight:700;">0</span>
        </p>
      </div>
    </div>
  </div>
</main>

<script is:inline>
  /* ============================================================
     EduRankAI Quantum Circuit Composer — Qiskit-class.
     Pure-JS state-vector simulation up to 8 qubits (256 amplitudes).
     Full Qiskit gate set including parametrised rotations and U3.
     QASM 2.0 parser. Shot-based simulation. Circuit presets.
     No 3rd-party libraries.
     ============================================================ */
  (function () {

    // ============ Complex algebra ============
    function c(re, im) { return { re: re, im: im || 0 }; }
    function cadd(a, b) { return c(a.re + b.re, a.im + b.im); }
    function cmul(a, b) { return c(a.re * b.re - a.im * b.im, a.re * b.im + a.im * b.re); }
    function cscale(a, s) { return c(a.re * s, a.im * s); }
    function cabs2(a) { return a.re * a.re + a.im * a.im; }

    // ============ State ============
    var nq = 3, N = 8;
    var psi = [];
    var gates = [];
    var selectedGate = null;
    var pendingMulti = []; // accumulates wire indices for multi-qubit gates
    var lastShots = null;
    var history = []; // for undo

    function resetState() {
      psi = new Array(N);
      for (var i = 0; i < N; i++) psi[i] = c(0, 0);
      psi[0] = c(1, 0);
    }
    resetState();

    var inv2 = 1 / Math.sqrt(2);
    // Build a 2x2 matrix for parametrised gates.
    function rxMatrix(theta) { var co = Math.cos(theta / 2), si = Math.sin(theta / 2); return [ c(co, 0), c(0, -si), c(0, -si), c(co, 0) ]; }
    function ryMatrix(theta) { var co = Math.cos(theta / 2), si = Math.sin(theta / 2); return [ c(co, 0), c(-si, 0), c(si, 0), c(co, 0) ]; }
    function rzMatrix(theta) { var co = Math.cos(theta / 2), si = Math.sin(theta / 2); return [ c(co, -si), c(0, 0), c(0, 0), c(co, si) ]; }
    function u3Matrix(theta, phi, lam) {
      var co = Math.cos(theta / 2), si = Math.sin(theta / 2);
      return [
        c(co, 0),
        c(-Math.cos(lam) * si, -Math.sin(lam) * si),
        c(Math.cos(phi) * si, Math.sin(phi) * si),
        c(Math.cos(phi + lam) * co, Math.sin(phi + lam) * co),
      ];
    }
    var GATE_MATRICES = {
      I:   [ c(1, 0), c(0, 0), c(0, 0), c(1, 0) ],
      H:   [ c(inv2, 0), c(inv2, 0), c(inv2, 0), c(-inv2, 0) ],
      X:   [ c(0, 0), c(1, 0), c(1, 0), c(0, 0) ],
      Y:   [ c(0, 0), c(0, -1), c(0, 1), c(0, 0) ],
      Z:   [ c(1, 0), c(0, 0), c(0, 0), c(-1, 0) ],
      S:   [ c(1, 0), c(0, 0), c(0, 0), c(0, 1) ],
      SDG: [ c(1, 0), c(0, 0), c(0, 0), c(0, -1) ],
      T:   [ c(1, 0), c(0, 0), c(0, 0), c(Math.cos(Math.PI/4), Math.sin(Math.PI/4)) ],
      TDG: [ c(1, 0), c(0, 0), c(0, 0), c(Math.cos(Math.PI/4), -Math.sin(Math.PI/4)) ],
    };

    // ============ Gate application ============
    function applySingle(M, t) {
      var newPsi = new Array(N);
      for (var i = 0; i < N; i++) {
        var bit = (i >> t) & 1;
        var partner = i ^ (1 << t);
        var g0 = bit === 0 ? M[0] : M[2];
        var g1 = bit === 0 ? M[1] : M[3];
        newPsi[i] = cadd(cmul(g0, psi[bit === 0 ? i : partner]), cmul(g1, psi[bit === 0 ? partner : i]));
      }
      psi = newPsi;
    }

    function applyControlled(ctrlBits, tgt, M) {
      // Apply single-qubit M to target only when ALL ctrlBits are 1.
      var mask = 0; ctrlBits.forEach(function (cb) { mask |= (1 << cb); });
      var newPsi = psi.slice();
      for (var i = 0; i < N; i++) {
        if ((i & mask) !== mask) continue; // controls not all 1
        var bit = (i >> tgt) & 1;
        if (bit !== 0) continue; // process each pair once
        var partner = i | (1 << tgt);
        var a = psi[i], b = psi[partner];
        newPsi[i] = cadd(cmul(M[0], a), cmul(M[1], b));
        newPsi[partner] = cadd(cmul(M[2], a), cmul(M[3], b));
      }
      psi = newPsi;
    }

    function applySWAP(a, b) {
      var newPsi = psi.slice();
      for (var i = 0; i < N; i++) {
        var ba = (i >> a) & 1, bb = (i >> b) & 1;
        if (ba !== bb) {
          var partner = i ^ (1 << a) ^ (1 << b);
          if (partner > i) { newPsi[i] = psi[partner]; newPsi[partner] = psi[i]; }
        }
      }
      psi = newPsi;
    }

    function applyCSWAP(ctrl, a, b) {
      var newPsi = psi.slice();
      for (var i = 0; i < N; i++) {
        if (((i >> ctrl) & 1) !== 1) continue;
        var ba = (i >> a) & 1, bb = (i >> b) & 1;
        if (ba !== bb) {
          var partner = i ^ (1 << a) ^ (1 << b);
          if (partner > i) { newPsi[i] = psi[partner]; newPsi[partner] = psi[i]; }
        }
      }
      psi = newPsi;
    }

    function measure(t) {
      var p1 = 0;
      for (var i = 0; i < N; i++) if ((i >> t) & 1) p1 += cabs2(psi[i]);
      var outcome = Math.random() < p1 ? 1 : 0;
      var norm = outcome === 1 ? Math.sqrt(p1) : Math.sqrt(Math.max(1e-15, 1 - p1));
      for (var i = 0; i < N; i++) {
        if (((i >> t) & 1) === outcome) psi[i] = cscale(psi[i], 1 / norm);
        else psi[i] = c(0, 0);
      }
      return outcome;
    }

    function applyGate(g) {
      if (g.kind === 'H' || g.kind === 'X' || g.kind === 'Y' || g.kind === 'Z' || g.kind === 'S' || g.kind === 'SDG' || g.kind === 'T' || g.kind === 'TDG' || g.kind === 'I') {
        applySingle(GATE_MATRICES[g.kind], g.targets[0]);
      } else if (g.kind === 'RX') applySingle(rxMatrix(g.theta), g.targets[0]);
      else if (g.kind === 'RY') applySingle(ryMatrix(g.theta), g.targets[0]);
      else if (g.kind === 'RZ') applySingle(rzMatrix(g.theta), g.targets[0]);
      else if (g.kind === 'U3') applySingle(u3Matrix(g.theta || 0, g.phi || 0, g.lam || 0), g.targets[0]);
      else if (g.kind === 'CX') applyControlled([g.control], g.targets[0], GATE_MATRICES.X);
      else if (g.kind === 'CY') applyControlled([g.control], g.targets[0], GATE_MATRICES.Y);
      else if (g.kind === 'CZ') applyControlled([g.control], g.targets[0], GATE_MATRICES.Z);
      else if (g.kind === 'CH') applyControlled([g.control], g.targets[0], GATE_MATRICES.H);
      else if (g.kind === 'CCX') applyControlled([g.controls[0], g.controls[1]], g.targets[0], GATE_MATRICES.X);
      else if (g.kind === 'SWAP') applySWAP(g.targets[0], g.targets[1]);
      else if (g.kind === 'CSWAP') applyCSWAP(g.control, g.targets[0], g.targets[1]);
      else if (g.kind === 'M') return measure(g.targets[0]);
    }

    function runCircuit() {
      resetState();
      gates.forEach(function (g) { if (g.kind !== 'M') applyGate(g); });
      renderStateAndBloch();
      runShots();
      renderMetrics();
    }

    function runShots(N_SHOTS) {
      N_SHOTS = N_SHOTS || 1024;
      var stateSnap = psi.map(function (a) { return c(a.re, a.im); });
      var measuredQubits = [];
      gates.forEach(function (g) { if (g.kind === 'M') measuredQubits.push(g.targets[0]); });
      if (measuredQubits.length === 0) {
        // Sample all qubits implicitly for the histogram.
        for (var q = 0; q < nq; q++) measuredQubits.push(q);
      }
      var counts = {};
      for (var s = 0; s < N_SHOTS; s++) {
        psi = stateSnap.map(function (a) { return c(a.re, a.im); });
        var bits = '';
        measuredQubits.forEach(function (q) { bits = (measure(q) ? '1' : '0') + bits; });
        counts[bits] = (counts[bits] || 0) + 1;
      }
      lastShots = counts;
      psi = stateSnap.map(function (a) { return c(a.re, a.im); });
      renderHistogram(counts, N_SHOTS);
    }

    // ============ Rendering ============
    function renderStateAndBloch() {
      var ampEl = document.getElementById('ampList'); ampEl.innerHTML = '';
      for (var i = 0; i < N; i++) {
        var prob = cabs2(psi[i]);
        if (prob < 1e-9 && i !== 0) continue;
        var bits = i.toString(2).padStart(nq, '0');
        var row = document.createElement('div'); row.className = 'amp-row';
        var re = psi[i].re, im = psi[i].im;
        var cplx = re.toFixed(3) + (im >= 0 ? ' + ' : ' − ') + Math.abs(im).toFixed(3) + 'i';
        row.innerHTML = '<span class="amp-state">|' + bits + '⟩</span>'
          + '<div class="amp-bar-wrap"><div class="amp-bar" style="width:' + (prob * 100).toFixed(2) + '%"></div></div>'
          + '<span class="amp-cplx">' + (prob * 100).toFixed(2) + '%<br/>' + cplx + '</span>';
        ampEl.appendChild(row);
      }
      var q = parseInt(document.getElementById('blochQubit').value, 10) || 0;
      var bx = 0, by = 0, bz = 0;
      for (var i = 0; i < N; i++) {
        var bit = (i >> q) & 1, partner = i ^ (1 << q);
        if (bit === 0) {
          bx += 2 * (psi[i].re * psi[partner].re + psi[i].im * psi[partner].im);
          by += 2 * (psi[i].re * psi[partner].im - psi[i].im * psi[partner].re);
        }
        bz += (bit === 0 ? 1 : -1) * cabs2(psi[i]);
      }
      var theta = Math.acos(Math.max(-1, Math.min(1, bz)));
      var phi = Math.atan2(by, bx);
      var R = 100;
      var sx = R * Math.sin(theta) * Math.cos(phi);
      var sy = -R * bz;
      document.getElementById('blochVec').setAttribute('x2', sx);
      document.getElementById('blochVec').setAttribute('y2', sy);
      document.getElementById('blochTip').setAttribute('cx', sx);
      document.getElementById('blochTip').setAttribute('cy', sy);
      document.getElementById('blochTheta').textContent = theta.toFixed(3);
      document.getElementById('blochPhi').textContent = phi.toFixed(3);
      document.getElementById('qasmIn').setAttribute('placeholder', generateQasm());
    }

    function renderHistogram(counts, total) {
      var el = document.getElementById('histoList'); el.innerHTML = '';
      var sortedKeys = Object.keys(counts).sort(function (a, b) { return counts[b] - counts[a]; });
      var maxC = sortedKeys.length ? counts[sortedKeys[0]] : 1;
      sortedKeys.slice(0, 16).forEach(function (k) {
        var pct = (counts[k] / total * 100).toFixed(1);
        var row = document.createElement('div'); row.className = 'histo-bar';
        row.innerHTML = '<span style="color:#fbbf24;">|' + k + '⟩</span>'
          + '<div class="histo-fill-wrap"><div class="histo-fill" style="width:' + ((counts[k] / maxC) * 100) + '%"></div></div>'
          + '<span style="text-align:right;color:#9aa6b6;">' + counts[k] + ' · ' + pct + '%</span>';
        el.appendChild(row);
      });
    }

    function renderMetrics() {
      var totalGates = gates.length;
      var cxCount = gates.filter(function (g) { return g.kind === 'CX'; }).length;
      var tCount = gates.filter(function (g) { return g.kind === 'T' || g.kind === 'TDG'; }).length;
      var sq = gates.filter(function (g) { return ['I','H','X','Y','Z','S','SDG','T','TDG','RX','RY','RZ','U3'].indexOf(g.kind) >= 0; }).length;
      // Depth: greedy parallel scheduler
      var slots = []; // slot[q] = depth used so far
      for (var q = 0; q < nq; q++) slots.push(0);
      gates.forEach(function (g) {
        var wires = [];
        if (g.targets) g.targets.forEach(function (t) { wires.push(t); });
        if (g.control != null) wires.push(g.control);
        if (g.controls) g.controls.forEach(function (cw) { wires.push(cw); });
        var maxSlot = 0; wires.forEach(function (w) { maxSlot = Math.max(maxSlot, slots[w]); });
        wires.forEach(function (w) { slots[w] = maxSlot + 1; });
      });
      var depth = Math.max.apply(null, slots);
      document.getElementById('mDepth').textContent = depth || 0;
      document.getElementById('mGates').textContent = totalGates;
      document.getElementById('mQubits').textContent = nq;
      document.getElementById('mCx').textContent = cxCount;
      document.getElementById('mT').textContent = tCount;
      document.getElementById('mSq').textContent = sq;
    }

    // ============ Circuit SVG render ============
    var svg = document.getElementById('circuitSvg');
    function renderCircuit() {
      svg.innerHTML = '';
      var w = 1300, h = 420, padTop = 40, padBot = 40;
      var rowH = (h - padTop - padBot) / Math.max(1, nq);
      function wireY(i) { return padTop + rowH * (i + 0.5); }

      for (var i = 0; i < nq; i++) {
        var line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        line.setAttribute('x1', 60); line.setAttribute('x2', w - 30);
        line.setAttribute('y1', wireY(i)); line.setAttribute('y2', wireY(i));
        line.setAttribute('class', 'wire-line');
        svg.appendChild(line);
        var lbl = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        lbl.setAttribute('x', 10); lbl.setAttribute('y', wireY(i) + 4);
        lbl.setAttribute('class', 'wire-label');
        lbl.textContent = 'q' + i + ' |0⟩';
        svg.appendChild(lbl);
      }

      var xStep = Math.max(50, Math.min(70, (w - 100) / Math.max(1, gates.length + 1)));
      var startX = 90;

      gates.forEach(function (g, gi) {
        var gx = startX + gi * xStep;
        function drawBox(wire, label, cls) {
          var rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
          rect.setAttribute('x', gx - 22); rect.setAttribute('y', wireY(wire) - 18);
          rect.setAttribute('width', 44); rect.setAttribute('height', 36); rect.setAttribute('rx', 6);
          rect.setAttribute('class', 'gate-rect ' + (cls || ''));
          rect.setAttribute('data-gi', gi);
          svg.appendChild(rect);
          var txt = document.createElementNS('http://www.w3.org/2000/svg', 'text');
          txt.setAttribute('x', gx); txt.setAttribute('y', wireY(wire) + 5);
          txt.setAttribute('text-anchor', 'middle');
          txt.setAttribute('fill', cls === 'measure' ? '#fff' : '#a78bfa');
          txt.setAttribute('class', 'gate-label');
          txt.textContent = label;
          svg.appendChild(txt);
        }
        function drawCtrlDot(wire) {
          var dot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
          dot.setAttribute('cx', gx); dot.setAttribute('cy', wireY(wire)); dot.setAttribute('r', 6);
          dot.setAttribute('fill', '#fb923c');
          svg.appendChild(dot);
        }
        function drawVerticalConn(wires) {
          var ys = wires.map(wireY); var minY = Math.min.apply(null, ys), maxY = Math.max.apply(null, ys);
          var l = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          l.setAttribute('x1', gx); l.setAttribute('x2', gx); l.setAttribute('y1', minY); l.setAttribute('y2', maxY);
          l.setAttribute('stroke', '#fb923c'); l.setAttribute('stroke-width', 2);
          svg.appendChild(l);
        }

        if (g.kind === 'CX' || g.kind === 'CY' || g.kind === 'CZ' || g.kind === 'CH') {
          drawVerticalConn([g.control, g.targets[0]]);
          drawCtrlDot(g.control);
          if (g.kind === 'CX') {
            var ring = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
            ring.setAttribute('cx', gx); ring.setAttribute('cy', wireY(g.targets[0])); ring.setAttribute('r', 14);
            ring.setAttribute('fill', 'none'); ring.setAttribute('stroke', '#fb923c'); ring.setAttribute('stroke-width', 2);
            svg.appendChild(ring);
            var l1 = document.createElementNS('http://www.w3.org/2000/svg', 'line');
            l1.setAttribute('x1', gx - 14); l1.setAttribute('x2', gx + 14); l1.setAttribute('y1', wireY(g.targets[0])); l1.setAttribute('y2', wireY(g.targets[0]));
            l1.setAttribute('stroke', '#fb923c'); l1.setAttribute('stroke-width', 2);
            svg.appendChild(l1);
          } else {
            drawBox(g.targets[0], g.kind.replace('C', ''));
          }
        } else if (g.kind === 'CCX') {
          drawVerticalConn([g.controls[0], g.controls[1], g.targets[0]]);
          drawCtrlDot(g.controls[0]); drawCtrlDot(g.controls[1]);
          var ring = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
          ring.setAttribute('cx', gx); ring.setAttribute('cy', wireY(g.targets[0])); ring.setAttribute('r', 14);
          ring.setAttribute('fill', 'none'); ring.setAttribute('stroke', '#fb923c'); ring.setAttribute('stroke-width', 2);
          svg.appendChild(ring);
        } else if (g.kind === 'SWAP') {
          drawVerticalConn(g.targets);
          [g.targets[0], g.targets[1]].forEach(function (t) {
            var c1 = document.createElementNS('http://www.w3.org/2000/svg', 'line');
            c1.setAttribute('x1', gx - 8); c1.setAttribute('x2', gx + 8); c1.setAttribute('y1', wireY(t) - 8); c1.setAttribute('y2', wireY(t) + 8);
            c1.setAttribute('stroke', '#fb923c'); c1.setAttribute('stroke-width', 2); svg.appendChild(c1);
            var c2 = document.createElementNS('http://www.w3.org/2000/svg', 'line');
            c2.setAttribute('x1', gx - 8); c2.setAttribute('x2', gx + 8); c2.setAttribute('y1', wireY(t) + 8); c2.setAttribute('y2', wireY(t) - 8);
            c2.setAttribute('stroke', '#fb923c'); c2.setAttribute('stroke-width', 2); svg.appendChild(c2);
          });
        } else if (g.kind === 'CSWAP') {
          drawVerticalConn([g.control, g.targets[0], g.targets[1]]);
          drawCtrlDot(g.control);
          [g.targets[0], g.targets[1]].forEach(function (t) {
            var c1 = document.createElementNS('http://www.w3.org/2000/svg', 'line');
            c1.setAttribute('x1', gx - 8); c1.setAttribute('x2', gx + 8); c1.setAttribute('y1', wireY(t) - 8); c1.setAttribute('y2', wireY(t) + 8);
            c1.setAttribute('stroke', '#fb923c'); c1.setAttribute('stroke-width', 2); svg.appendChild(c1);
            var c2 = document.createElementNS('http://www.w3.org/2000/svg', 'line');
            c2.setAttribute('x1', gx - 8); c2.setAttribute('x2', gx + 8); c2.setAttribute('y1', wireY(t) + 8); c2.setAttribute('y2', wireY(t) - 8);
            c2.setAttribute('stroke', '#fb923c'); c2.setAttribute('stroke-width', 2); svg.appendChild(c2);
          });
        } else if (g.kind === 'M') {
          drawBox(g.targets[0], 'M', 'measure');
        } else if (g.kind === 'RX' || g.kind === 'RY' || g.kind === 'RZ') {
          drawBox(g.targets[0], g.kind.replace('R', 'R') + '(' + g.theta.toFixed(2) + ')', 'rot');
        } else if (g.kind === 'U3') {
          drawBox(g.targets[0], 'U3', 'rot');
        } else if (g.kind === 'SDG') drawBox(g.targets[0], 'S†');
        else if (g.kind === 'TDG') drawBox(g.targets[0], 'T†');
        else {
          drawBox(g.targets[0], g.kind);
        }
      });

      // Right-click delete
      svg.querySelectorAll('[data-gi]').forEach(function (el) {
        el.addEventListener('contextmenu', function (e) {
          e.preventDefault();
          gates.splice(+el.getAttribute('data-gi'), 1);
          renderCircuit(); runCircuit();
        });
      });
    }

    // ============ Wire click handler ============
    svg.addEventListener('click', function (e) {
      if (!selectedGate) return;
      var pt = svg.createSVGPoint(); pt.x = e.clientX; pt.y = e.clientY;
      var sp = pt.matrixTransform(svg.getScreenCTM().inverse());
      var padTop = 40, rowH = (420 - 80) / Math.max(1, nq);
      var wireIdx = Math.floor((sp.y - padTop) / rowH);
      if (wireIdx < 0 || wireIdx >= nq) return;

      var theta = parseFloat(document.getElementById('thetaInput').value) || 0;
      var phi = parseFloat(document.getElementById('phiInput').value) || 0;
      var lam = parseFloat(document.getElementById('lambdaInput').value) || 0;

      function addAndRender(g) {
        history.push(JSON.parse(JSON.stringify(gates)));
        gates.push(g);
        pendingMulti = [];
        renderCircuit(); runCircuit();
      }

      var SINGLE = ['I','H','X','Y','Z','S','SDG','T','TDG'];
      var SINGLE_ROT = ['RX','RY','RZ'];
      var CTRL_SINGLE = ['CX','CY','CZ','CH'];

      if (selectedGate === 'M') { addAndRender({ kind: 'M', targets: [wireIdx] }); return; }
      if (SINGLE.indexOf(selectedGate) >= 0) { addAndRender({ kind: selectedGate, targets: [wireIdx] }); return; }
      if (SINGLE_ROT.indexOf(selectedGate) >= 0) { addAndRender({ kind: selectedGate, targets: [wireIdx], theta: theta }); return; }
      if (selectedGate === 'U3') { addAndRender({ kind: 'U3', targets: [wireIdx], theta: theta, phi: phi, lam: lam }); return; }
      if (CTRL_SINGLE.indexOf(selectedGate) >= 0) {
        if (pendingMulti.length === 0) { pendingMulti = [wireIdx]; return; }
        if (pendingMulti[0] === wireIdx) return;
        addAndRender({ kind: selectedGate, control: pendingMulti[0], targets: [wireIdx] });
        return;
      }
      if (selectedGate === 'SWAP') {
        if (pendingMulti.length === 0) { pendingMulti = [wireIdx]; return; }
        if (pendingMulti[0] === wireIdx) return;
        addAndRender({ kind: 'SWAP', targets: [pendingMulti[0], wireIdx] });
        return;
      }
      if (selectedGate === 'CCX') {
        if (pendingMulti.length < 2) { pendingMulti.push(wireIdx); return; }
        if (pendingMulti.indexOf(wireIdx) >= 0) return;
        addAndRender({ kind: 'CCX', controls: [pendingMulti[0], pendingMulti[1]], targets: [wireIdx] });
        return;
      }
      if (selectedGate === 'CSWAP') {
        if (pendingMulti.length === 0) { pendingMulti = [wireIdx]; return; } // control
        if (pendingMulti.length === 1) { if (pendingMulti[0] === wireIdx) return; pendingMulti.push(wireIdx); return; }
        if (pendingMulti.indexOf(wireIdx) >= 0) return;
        addAndRender({ kind: 'CSWAP', control: pendingMulti[0], targets: [pendingMulti[1], wireIdx] });
        return;
      }
    });

    // ============ Gate palette ============
    document.querySelectorAll('.gate-btn').forEach(function (b) {
      b.addEventListener('click', function () {
        selectedGate = b.getAttribute('data-gate');
        pendingMulti = [];
        document.querySelectorAll('.gate-btn').forEach(function (x) { x.classList.remove('active'); });
        b.classList.add('active');
      });
    });

    // ============ Qubit count change ============
    function setQubitCount(n) {
      nq = Math.max(1, Math.min(8, n)); N = 1 << nq;
      resetState(); gates = []; pendingMulti = []; history = [];
      var sel = document.getElementById('blochQubit'); sel.innerHTML = '';
      for (var i = 0; i < nq; i++) { var o = document.createElement('option'); o.value = i; o.textContent = 'q' + i; sel.appendChild(o); }
      renderCircuit(); runCircuit();
    }

    document.getElementById('qubitCount').addEventListener('change', function (e) { setQubitCount(parseInt(e.target.value, 10)); });
    document.getElementById('blochQubit').addEventListener('change', renderStateAndBloch);
    document.getElementById('clearBtn').addEventListener('click', function () { history.push(JSON.parse(JSON.stringify(gates))); gates = []; runCircuit(); renderCircuit(); });
    document.getElementById('undoBtn').addEventListener('click', function () { if (history.length) { gates = history.pop(); renderCircuit(); runCircuit(); } });
    document.getElementById('runBtn').addEventListener('click', runCircuit);

    // ============ QASM 2.0 export ============
    function generateQasm() {
      var s = 'OPENQASM 2.0;\ninclude "qelib1.inc";\nqreg q[' + nq + '];\ncreg c[' + nq + '];\n';
      gates.forEach(function (g) {
        if (g.kind === 'CX') s += 'cx q[' + g.control + '],q[' + g.targets[0] + '];\n';
        else if (g.kind === 'CY') s += 'cy q[' + g.control + '],q[' + g.targets[0] + '];\n';
        else if (g.kind === 'CZ') s += 'cz q[' + g.control + '],q[' + g.targets[0] + '];\n';
        else if (g.kind === 'CH') s += 'ch q[' + g.control + '],q[' + g.targets[0] + '];\n';
        else if (g.kind === 'CCX') s += 'ccx q[' + g.controls[0] + '],q[' + g.controls[1] + '],q[' + g.targets[0] + '];\n';
        else if (g.kind === 'SWAP') s += 'swap q[' + g.targets[0] + '],q[' + g.targets[1] + '];\n';
        else if (g.kind === 'CSWAP') s += 'cswap q[' + g.control + '],q[' + g.targets[0] + '],q[' + g.targets[1] + '];\n';
        else if (g.kind === 'M') s += 'measure q[' + g.targets[0] + '] -> c[' + g.targets[0] + '];\n';
        else if (g.kind === 'RX') s += 'rx(' + g.theta.toFixed(4) + ') q[' + g.targets[0] + '];\n';
        else if (g.kind === 'RY') s += 'ry(' + g.theta.toFixed(4) + ') q[' + g.targets[0] + '];\n';
        else if (g.kind === 'RZ') s += 'rz(' + g.theta.toFixed(4) + ') q[' + g.targets[0] + '];\n';
        else if (g.kind === 'U3') s += 'u3(' + (g.theta||0).toFixed(4) + ',' + (g.phi||0).toFixed(4) + ',' + (g.lam||0).toFixed(4) + ') q[' + g.targets[0] + '];\n';
        else if (g.kind === 'SDG') s += 'sdg q[' + g.targets[0] + '];\n';
        else if (g.kind === 'TDG') s += 'tdg q[' + g.targets[0] + '];\n';
        else if (g.kind === 'I') s += 'id q[' + g.targets[0] + '];\n';
        else s += g.kind.toLowerCase() + ' q[' + g.targets[0] + '];\n';
      });
      return s;
    }

    // ============ QASM 2.0 parser ============
    function parseQasm(src) {
      var lines = src.split('\n').map(function (l) { return l.trim(); }).filter(function (l) { return l && l.indexOf('//') !== 0; });
      var parsedGates = [];
      var parsedNq = nq;
      for (var li = 0; li < lines.length; li++) {
        var line = lines[li].replace(/;$/, '').trim();
        if (!line || line.indexOf('OPENQASM') === 0 || line.indexOf('include') === 0 || line.indexOf('creg') === 0) continue;
        var m = line.match(/^qreg\s+\w+\[(\d+)\]/);
        if (m) { parsedNq = parseInt(m[1], 10); continue; }
        // Try gate w/ angle: name(theta) q[i]; or name(t,p,l) q[i];
        var rot = line.match(/^(\w+)\s*\(([^)]+)\)\s+q\[(\d+)\]/);
        if (rot) {
          var name = rot[1].toLowerCase(); var params = rot[2].split(',').map(function (s) { return parseFloat(s.trim().replace('pi', '3.141592653589793')); });
          var tgt = parseInt(rot[3], 10);
          if (name === 'rx') parsedGates.push({ kind: 'RX', targets: [tgt], theta: params[0] });
          else if (name === 'ry') parsedGates.push({ kind: 'RY', targets: [tgt], theta: params[0] });
          else if (name === 'rz') parsedGates.push({ kind: 'RZ', targets: [tgt], theta: params[0] });
          else if (name === 'u3' || name === 'u') parsedGates.push({ kind: 'U3', targets: [tgt], theta: params[0]||0, phi: params[1]||0, lam: params[2]||0 });
          else if (name === 'u1') parsedGates.push({ kind: 'RZ', targets: [tgt], theta: params[0] });
          else if (name === 'u2') parsedGates.push({ kind: 'U3', targets: [tgt], theta: Math.PI/2, phi: params[0], lam: params[1] });
          continue;
        }
        // Two-qubit / three-qubit gates
        var multi = line.match(/^(\w+)\s+([^;]+)/);
        if (!multi) continue;
        var name = multi[1].toLowerCase();
        var args = multi[2].split(',').map(function (s) { var mm = s.trim().match(/q\[(\d+)\]/); return mm ? parseInt(mm[1], 10) : null; }).filter(function (x) { return x != null; });
        if (name === 'h' || name === 'x' || name === 'y' || name === 'z' || name === 's' || name === 't' || name === 'id' || name === 'i') parsedGates.push({ kind: name.toUpperCase() === 'ID' || name === 'i' ? 'I' : name.toUpperCase(), targets: [args[0]] });
        else if (name === 'sdg') parsedGates.push({ kind: 'SDG', targets: [args[0]] });
        else if (name === 'tdg') parsedGates.push({ kind: 'TDG', targets: [args[0]] });
        else if (name === 'cx') parsedGates.push({ kind: 'CX', control: args[0], targets: [args[1]] });
        else if (name === 'cy') parsedGates.push({ kind: 'CY', control: args[0], targets: [args[1]] });
        else if (name === 'cz') parsedGates.push({ kind: 'CZ', control: args[0], targets: [args[1]] });
        else if (name === 'ch') parsedGates.push({ kind: 'CH', control: args[0], targets: [args[1]] });
        else if (name === 'ccx' || name === 'toffoli') parsedGates.push({ kind: 'CCX', controls: [args[0], args[1]], targets: [args[2]] });
        else if (name === 'swap') parsedGates.push({ kind: 'SWAP', targets: [args[0], args[1]] });
        else if (name === 'cswap' || name === 'fredkin') parsedGates.push({ kind: 'CSWAP', control: args[0], targets: [args[1], args[2]] });
        else if (name === 'measure') parsedGates.push({ kind: 'M', targets: [args[0]] });
        else if (name === 'barrier' || name === 'reset') {} // ignore for sim
      }
      if (parsedNq !== nq) {
        nq = parsedNq; N = 1 << nq;
        document.getElementById('qubitCount').value = nq;
        var sel = document.getElementById('blochQubit'); sel.innerHTML = '';
        for (var i = 0; i < nq; i++) { var o = document.createElement('option'); o.value = i; o.textContent = 'q' + i; sel.appendChild(o); }
      }
      gates = parsedGates;
      resetState();
      renderCircuit(); runCircuit();
    }

    document.getElementById('parseBtn').addEventListener('click', function () {
      try { parseQasm(document.getElementById('qasmIn').value); }
      catch (e) { alert('QASM parse failed: ' + e.message); }
    });
    document.getElementById('copyQasmBtn').addEventListener('click', function () { navigator.clipboard.writeText(generateQasm()); });
    document.getElementById('dlQasmBtn').addEventListener('click', function () {
      var blob = new Blob([generateQasm()], { type: 'text/plain' });
      var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'circuit-' + Date.now() + '.qasm'; a.click();
    });

    // ============ Presets ============
    var PRESETS = {
      bell: 'OPENQASM 2.0;\ninclude "qelib1.inc";\nqreg q[2];\ncreg c[2];\nh q[0];\ncx q[0],q[1];\nmeasure q[0] -> c[0];\nmeasure q[1] -> c[1];',
      ghz: 'OPENQASM 2.0;\ninclude "qelib1.inc";\nqreg q[3];\ncreg c[3];\nh q[0];\ncx q[0],q[1];\ncx q[1],q[2];\nmeasure q[0] -> c[0];\nmeasure q[1] -> c[1];\nmeasure q[2] -> c[2];',
      grover2: 'OPENQASM 2.0;\ninclude "qelib1.inc";\nqreg q[2];\ncreg c[2];\nh q[0];\nh q[1];\ncz q[0],q[1];\nh q[0];\nh q[1];\nx q[0];\nx q[1];\ncz q[0],q[1];\nx q[0];\nx q[1];\nh q[0];\nh q[1];\nmeasure q[0] -> c[0];\nmeasure q[1] -> c[1];',
      deutsch: 'OPENQASM 2.0;\ninclude "qelib1.inc";\nqreg q[2];\ncreg c[2];\nx q[1];\nh q[0];\nh q[1];\ncx q[0],q[1];\nh q[0];\nmeasure q[0] -> c[0];',
