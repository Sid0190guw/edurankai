---
// /aquintutor/receipt/[id] — a payment receipt / invoice (Prompt AP5b). Owner-only; shows the real
// payment record. Printable. Not a tax invoice unless the platform issues GST — labelled honestly.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { paymentById } from '@/lib/course-payments';
import { planById } from '@/lib/payment-gateway';

const user = Astro.locals.user;
const { id } = Astro.params as { id: string };
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/receipt/' + id));
const p = await paymentById(Number(id)).catch(() => null);
if (!p || String(p.user_id) !== String(user.id)) return Astro.redirect('/aquintutor/billing');
const plan = planById(String(p.plan));
function inr(paise: number) { return '₹' + (paise / 100).toLocaleString('en-IN'); }
---
<AquintutorLayout title="Receipt">
  <main style="max-width:600px;margin:0 auto;padding:40px 22px 80px;">
    <div style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:14px;padding:28px 30px;">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;">
        <div><span style="font-family:Fraunces,serif;font-size:22px;font-weight:600;color:var(--ink,#1a1712);">AquinTutor</span><br><span style="font-family:'Inter Tight',sans-serif;font-size:12px;color:#8a8378;">by EduRank&middot;AI</span></div>
        <div style="text-align:right;"><span style="font-family:'Geist Mono',monospace;font-size:11px;color:#8a8378;">RECEIPT #{p.id}</span><br><span style={'font-family:Inter Tight,sans-serif;font-size:13px;font-weight:700;color:' + (p.status === 'paid' ? '#2f7d5b' : '#b3541e')}>{String(p.status).toUpperCase()}</span></div>
      </div>
      <table style="width:100%;font-family:'Inter Tight',sans-serif;font-size:14px;color:var(--ink,#1a1712);border-collapse:collapse;">
        <tr><td style="padding:8px 0;color:#6b6455;">Plan</td><td style="padding:8px 0;text-align:right;">{plan ? plan.label : p.plan}</td></tr>
        <tr style="border-top:1px solid var(--line,#e6e1d6);"><td style="padding:8px 0;color:#6b6455;">Amount</td><td style="padding:8px 0;text-align:right;font-weight:600;">{inr(p.amount_paise)} {p.currency}</td></tr>
        <tr style="border-top:1px solid var(--line,#e6e1d6);"><td style="padding:8px 0;color:#6b6455;">Payment ref</td><td style="padding:8px 0;text-align:right;font-family:'Geist Mono',monospace;font-size:12px;">{p.payment_id || '—'}</td></tr>
        <tr style="border-top:1px solid var(--line,#e6e1d6);"><td style="padding:8px 0;color:#6b6455;">Mode</td><td style="padding:8px 0;text-align:right;">{p.mode}</td></tr>
        <tr style="border-top:1px solid var(--line,#e6e1d6);"><td style="padding:8px 0;color:#6b6455;">Date</td><td style="padding:8px 0;text-align:right;">{new Date(p.created_at).toLocaleString('en-IN')}</td></tr>
      </table>
      {p.mode !== 'live' && <p style="font-family:'Inter Tight',sans-serif;font-size:12px;color:#9b2c2c;margin:16px 0 0;">This was a {p.mode} transaction, not a real payment.</p>}
      <p style="font-family:'Inter Tight',sans-serif;font-size:11px;color:#8a8378;margin:16px 0 0;">This is a payment receipt, not a GST tax invoice.</p>
    </div>
    <button onclick="window.print()" style="margin-top:16px;background:var(--ink,#1a1712);color:#fff;border:none;border-radius:9px;padding:10px 20px;font-family:'Inter Tight',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">Print / save PDF</button>
  </main>
</AquintutorLayout>
