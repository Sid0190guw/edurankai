---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { createClassroom, joinClassroom, getMyClassrooms } from '@/lib/classrooms';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/classrooms'));

let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = (fd.get('action') as string || '').trim();
  if (action === 'create') {
    const r = await createClassroom(user.id, (fd.get('name') as string || '').trim(), (fd.get('description') as string || '').trim());
    if (r.ok) okMsg = 'Class created. Share join code ' + r.joinCode + ' with your students.';
    else errMsg = r.error || 'Failed';
  } else if (action === 'join') {
    const r = await joinClassroom(user.id, (fd.get('code') as string || '').trim());
    if (r.ok) okMsg = 'Joined ' + r.name + '.'; else errMsg = r.error || 'Failed';
  }
}

const my = await getMyClassrooms(user.id);
---
<AquintutorLayout title="Classrooms" description="Create a classroom or join your teacher's.">
  <section style="border-bottom:1px solid var(--rule); background:linear-gradient(180deg,#fff8f3 0%, var(--paper) 100%);">
    <div style="max-width:920px; margin:0 auto; padding:36px 28px;">
      <p style="font-family:'Inter Tight',monospace; font-size:12px; color:var(--rust); font-weight:700; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Classrooms</p>
      <h1 class="font-display" style="font-size:clamp(1.8rem,3.5vw,2.6rem); line-height:1.1; font-weight:500; margin:0;">Teachers and students.</h1>
      <p style="font-family:'Inter Tight',sans-serif; font-size:14.5px; color:var(--ink-500); line-height:1.6; margin-top:8px;">Teachers create a class and share the 6-character code. Students join and the teacher sees the whole class's XP, streaks, and progress in real time.</p>
    </div>
  </section>

  <section>
    <div style="max-width:920px; margin:0 auto; padding:24px 28px 80px;">
      {okMsg && <div style="background:rgba(16,185,129,0.10); border:1px solid rgba(16,185,129,0.3); color:#047857; font-size:13px; padding:10px 14px; border-radius:8px; margin-bottom:16px;">{okMsg}</div>}
      {errMsg && <div style="background:rgba(239,68,68,0.10); border:1px solid rgba(239,68,68,0.3); color:#991b1b; font-size:13px; padding:10px 14px; border-radius:8px; margin-bottom:16px;">{errMsg}</div>}

      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:14px; margin-bottom:24px;">
        <form method="POST" style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:20px;">
          <input type="hidden" name="action" value="create" />
          <p style="font-family:'Inter Tight',monospace; font-size:11px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-500); font-weight:700; margin:0 0 12px;">Teacher · create a class</p>
          <input type="text" name="name" required placeholder="Class 9B · English" maxlength="200" style="width:100%; padding:11px 14px; border:1px solid var(--rule); border-radius:8px; font-family:inherit; font-size:14px; outline:none; margin-bottom:8px;" />
          <textarea name="description" rows="2" placeholder="Optional description" maxlength="1000" style="width:100%; padding:11px 14px; border:1px solid var(--rule); border-radius:8px; font-family:inherit; font-size:13px; outline:none; resize:vertical;"></textarea>
          <button type="submit" style="margin-top:10px; background:var(--rust); color:#fff; padding:10px 18px; border:none; border-radius:10px; font-family:inherit; font-size:13px; font-weight:700; cursor:pointer;">Create class →</button>
        </form>
        <form method="POST" style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:20px;">
          <input type="hidden" name="action" value="join" />
          <p style="font-family:'Inter Tight',monospace; font-size:11px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-500); font-weight:700; margin:0 0 12px;">Student · join with a code</p>
          <input type="text" name="code" required placeholder="ABCDEF" maxlength="20" style="width:100%; padding:11px 14px; border:1px solid var(--rule); border-radius:8px; font-family:'JetBrains Mono',monospace; font-size:18px; outline:none; letter-spacing:0.08em; text-transform:uppercase;" />
          <button type="submit" style="margin-top:10px; background:var(--ink); color:#fff; padding:10px 18px; border:none; border-radius:10px; font-family:inherit; font-size:13px; font-weight:700; cursor:pointer;">Join →</button>
        </form>
      </div>

      {my.owned.length > 0 && (
        <div style="margin-bottom:24px;">
          <p style="font-family:'Inter Tight',monospace; font-size:11px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-500); font-weight:700; margin:0 0 12px;">Your classes (you teach)</p>
          {my.owned.map((c: any) => (
            <a href={'/aquintutor/classrooms/' + c.id} style="display:flex; gap:14px; padding:16px 18px; background:var(--paper); border:1px solid var(--rule); border-radius:14px; margin-bottom:10px; text-decoration:none; color:inherit;">
              <div style="flex:1; min-width:0;">
                <p style="font-family:'Fraunces',serif; font-size:1.05rem; font-weight:600; margin:0 0 4px;">{c.name}</p>
                <p style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500); margin:0;">{c.description || 'No description'}</p>
              </div>
              <div style="text-align:right; flex-shrink:0;">
                <p style="font-family:'JetBrains Mono',monospace; font-size:18px; font-weight:700; color:var(--rust); letter-spacing:0.08em;">{c.join_code}</p>
                <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink-500);">{c.member_count} student{c.member_count === 1 ? '' : 's'}</p>
              </div>
            </a>
          ))}
        </div>
      )}

      {my.joined.length > 0 && (
        <div>
          <p style="font-family:'Inter Tight',monospace; font-size:11px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-500); font-weight:700; margin:0 0 12px;">Joined classes (you are a student)</p>
          {my.joined.map((c: any) => (
            <div style="display:flex; gap:14px; padding:16px 18px; background:var(--paper); border:1px solid var(--rule); border-radius:14px; margin-bottom:10px;">
              <div style="flex:1; min-width:0;">
                <p style="font-family:'Fraunces',serif; font-size:1.05rem; font-weight:600; margin:0 0 4px;">{c.name}</p>
                <p style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500); margin:0;">Teacher: {c.teacher_name} · {c.member_count} student{c.member_count === 1 ? '' : 's'}</p>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
</AquintutorLayout>
