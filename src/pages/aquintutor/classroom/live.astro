  <!-- MOBILE ACTION BAR (phone only) -->
  <nav class="mobabar" aria-label="Class controls">
    <button class="mb off" data-mob="mic"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="1" y1="1" x2="23" y2="23"/><path d="M9 9v3a3 3 0 005.12 2.12M15 9.34V4a3 3 0 00-5.94-.6"/><path d="M17 16.95A7 7 0 015 12v-2m14 0v2a7 7 0 01-.11 1.23"/></svg>Mic</button>
    <button class="mb" data-mob="cam"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>Camera</button>
    <button class="mb" data-mob="raise"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 11V6a2 2 0 00-4 0v5M14 10V4a2 2 0 00-4 0v6M10 10.5V6a2 2 0 00-4 0v8a8 8 0 0016 0v-3a2 2 0 00-4 0v1"/></svg>Raise</button>
    <button class="mb" data-mob="share"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>Share</button>
    <button class="mb" data-mob="tutor"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 2"/></svg>AI Tutor</button>
    <button class="mb end" data-mob="end"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.68 13.31a16 16 0 003.41 2.6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.4 2 2 0 012 2v1.72a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h1.72a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.9 9.91" transform="rotate(135 12 12)"/></svg>End</button>
  </nav>
</div>

<script is:inline>
(function(){
  // ===== live clock =====
  var sec = 28*60+47;
  setInterval(function(){ sec++; var h=Math.floor(sec/3600), m=Math.floor((sec%3600)/60), s=sec%60;
    document.getElementById('clock').textContent = String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(s).padStart(2,'0'); }, 1000);

  // ===== Bernoulli venturi flow (real physics: continuity A1v1=A2v2) =====
  var cv = document.getElementById('flow'), ctx = cv.getContext('2d');
  var W = cv.width, H = cv.height, mid = H/2;
  // pipe half-height profile along x: wide -> throat -> wide
  function halfH(x){ var f = x/W; var throat = 0.5; var narrow = 0.42; // 0..1 of full
    var t = Math.exp(-Math.pow((f-throat)/0.13,2)); // gaussian dip at centre
    return H*(0.34 - narrow*0.34*t); }
  function speedAt(x){ // continuity: v ∝ 1/area ∝ 1/halfH
    return 1.0/(halfH(x)/(H*0.34)); }
  var streams = [];
  for (var i=0;i<26;i++){ streams.push({ y0:(i+0.5)/26, x:Math.random()*W }); }
  var paused = false;
  function draw(){
    ctx.clearRect(0,0,W,H);
    // pipe body
    ctx.beginPath(); ctx.moveTo(0, mid-halfH(0));
    for (var x=0;x<=W;x+=6) ctx.lineTo(x, mid-halfH(x));
    for (var x2=W;x2>=0;x2-=6) ctx.lineTo(x2, mid+halfH(x2));
    ctx.closePath();
    var grad = ctx.createLinearGradient(0,0,W,0);
    grad.addColorStop(0,'#0b2a44'); grad.addColorStop(0.5,'#0e3a5f'); grad.addColorStop(1,'#0b2a44');
    ctx.fillStyle = grad; ctx.fill();
    ctx.strokeStyle = '#1f4b70'; ctx.lineWidth = 2; ctx.stroke();
    // pressure indicators: red (high) at wide ends, blue (low) at throat
    ['0.14','0.86'].forEach(function(fx){ var x=W*parseFloat(fx); ctx.fillStyle='rgba(239,68,68,0.9)'; tube(x); });
    var xt=W*0.5; ctx.fillStyle='rgba(59,130,246,0.9)'; tube(xt);
    function tube(x){ var top=mid-halfH(x); ctx.fillRect(x-4, top-46, 8, 46); ctx.beginPath(); ctx.arc(x,top-46,7,0,7); ctx.fill(); }
    // streamlines
    streams.forEach(function(s){
      if (!paused){ s.x += speedAt(s.x)*2.4; if (s.x>W) s.x-=W; }
      var y = mid + (s.y0-0.5)*2*halfH(s.x);
      var sp = speedAt(s.x);
      ctx.beginPath(); ctx.arc(s.x, y, 1.7+sp*0.5, 0, 7);
      var c = sp>1.5? '#7dd3fc' : '#38bdf8';
      ctx.fillStyle = c; ctx.fill();
      // little trailing tick to imply direction/speed
      ctx.strokeStyle = 'rgba(125,211,252,'+Math.min(0.5,0.15*sp)+')'; ctx.lineWidth=1.4;
      ctx.beginPath(); ctx.moveTo(s.x, y); ctx.lineTo(s.x-6*sp, y); ctx.stroke();
    });
    // central flow arrow
    ctx.strokeStyle='#e5e7eb'; ctx.lineWidth=2; ctx.beginPath(); ctx.moveTo(W*0.3,mid); ctx.lineTo(W*0.62,mid); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(W*0.62,mid); ctx.lineTo(W*0.6,mid-4); ctx.lineTo(W*0.6,mid+4); ctx.closePath(); ctx.fillStyle='#e5e7eb'; ctx.fill();
    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);

  // ===== airfoil mini-sim =====
  var af = document.getElementById('airfoil'); if (af){ var ax=af.getContext('2d'); var afT=0, afRun=false;
    function afDraw(){ ax.clearRect(0,0,af.width,af.height); var w=af.width,h=af.height;
      // airfoil shape
      ax.beginPath(); ax.moveTo(w*0.25,h*0.55); ax.bezierCurveTo(w*0.4,h*0.3,w*0.65,h*0.35,w*0.8,h*0.52); ax.bezierCurveTo(w*0.6,h*0.6,w*0.4,h*0.62,w*0.25,h*0.55); ax.closePath(); ax.fillStyle='#243449'; ax.fill(); ax.strokeStyle='#3b82f6'; ax.stroke();
      for (var i=0;i<7;i++){ var y=h*(0.15+i*0.1); var over = y<h*0.5; ax.strokeStyle= over?'#7dd3fc':'#38bdf8'; ax.lineWidth=1.2; ax.beginPath();
        for (var x=0;x<=w;x+=4){ var bend = Math.exp(-Math.pow((x/w-0.5)/0.2,2))*(over?-8:5); var off=(afRun?afT*(over?2.2:1.4):0); ax.lineTo(x, y+bend+Math.sin((x+off)*0.15)*0.6); } ax.stroke(); }
      if (afRun) afT+=2; requestAnimationFrame(afDraw); }
    requestAnimationFrame(afDraw);
    document.getElementById('airfoilBtn').addEventListener('click', function(){ afRun=!afRun; this.innerHTML = afRun? 'Pause Simulation' : '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>Run Simulation'; });
  }

  // ===== slide content =====
  var SLIDES = {
    continuity:{title:'Continuity Equation',desc:'Mass is conserved: for an incompressible fluid the volume flow rate is constant along the pipe.',formula:'A&#8321;v&#8321; = A&#8322;v&#8322;',app:'A garden hose sprays faster when you narrow the opening with your thumb — same flow, smaller area, higher speed.'},
    energy:{title:'Energy Equation',desc:'The steady-flow energy equation balances pressure, kinetic and potential energy per unit volume.',formula:'p + &frac12;&rho;v&sup2; + &rho;gz = E',app:'Hydroelectric dams convert the potential energy of stored water into kinetic energy and then electrical energy.'},
    bernoulli:{title:"Bernoulli's Principle",desc:'For an ideal incompressible fluid, the total mechanical energy is constant along a streamline.',formula:'P + &frac12;&rho;v&sup2; + &rho;gh = constant',app:'Airplane wings generate lift because air moves faster over the top surface, creating lower pressure than below the wing.'},
    applications:{title:'Applications',desc:'Bernoulli explains lift, carburettors, atomisers, chimneys, and the curve of a spinning ball.',formula:'&Delta;P = &frac12;&rho;(v&#8322;&sup2; &minus; v&#8321;&sup2;)',app:'A perfume atomiser: fast air across a tube lowers pressure and draws liquid up to be sprayed.'},
    pitot:{title:'Pitot Tube',desc:'A Pitot tube measures flow speed from the difference between stagnation and static pressure.',formula:'v = &radic;(2(p&#8320; &minus; p) / &rho;)',app:'Every aircraft measures its airspeed with a Pitot tube mounted on the fuselage or wing.'},
    summary:{title:'Summary',desc:'Continuity conserves mass; Bernoulli conserves energy along a streamline. Faster flow means lower pressure.',formula:'A&#8321;v&#8321;=A&#8322;v&#8322; &nbsp;&amp;&nbsp; P+&frac12;&rho;v&sup2;+&rho;gh=const',app:'Together these two laws underpin flight, plumbing, weather, and blood flow in arteries.'},
  };
  document.querySelectorAll('.thumb').forEach(function(th){
    th.addEventListener('click', function(){
      document.querySelectorAll('.thumb').forEach(function(x){x.classList.remove('on');}); th.classList.add('on');
      var d = SLIDES[th.getAttribute('data-scene')]; if(!d) return;
      document.getElementById('lzTitle').textContent = d.title;
      document.getElementById('lzDesc').textContent = d.desc;
      document.getElementById('lzFormula').innerHTML = d.formula;
      document.getElementById('lzApp').textContent = d.app;
      document.getElementById('slideCount').textContent = 'Slide '+th.getAttribute('data-n')+' / 24';
    });
  });
  document.getElementById('nextSlide').addEventListener('click',function(){ var on=document.querySelector('.thumb.on'); if(on&&on.nextElementSibling) on.nextElementSibling.click(); });
  document.getElementById('prevSlide').addEventListener('click',function(){ var on=document.querySelector('.thumb.on'); if(on&&on.previousElementSibling) on.previousElementSibling.click(); });

  // ===== AI tutor tabs + translation =====
  var TAB = {
    explain:{hi:'बर्नौली के सिद्धांत के अनुसार, यदि किसी द्रव का वेग बढ़ता है, तो उसका दाब कम हो जाता है। इसका कारण यह है कि हर स्ट्रीमलाइन के साथ कुल ऊर्जा समान रहती है।', en:"According to Bernoulli's principle, if the velocity of a fluid increases, its pressure decreases because the total mechanical energy remains constant along a streamline."},
    ask:{hi:'कोई भी प्रश्न पूछें — मैं इस पाठ के संदर्भ में उत्तर दूँगा।', en:'Ask any question — I will answer in the context of this lesson.'},
    doubt:{hi:'सामान्य भ्रांति: कई छात्र वेग और त्वरण को एक ही मान लेते हैं। ये अलग हैं।', en:'Common misconception: many students confuse velocity with acceleration. They are different quantities.'},
    summary:{hi:'सारांश: द्रव तेज़ बहता है → दाब घटता है। द्रव्यमान और ऊर्जा दोनों संरक्षित रहते हैं।', en:'Summary: fluid flows faster → pressure drops. Both mass and energy are conserved.'},
    translate:{hi:'रीयल-टाइम अनुवाद चालू है। व्याख्यान हिंदी में एक साथ दिखाया जा रहा है।', en:'Real-time translation is on. The lecture is shown in Hindi simultaneously.'},
  };
  var curTab='explain';
  document.querySelectorAll('.tab').forEach(function(t){ t.addEventListener('click',function(){
    document.querySelectorAll('.tab').forEach(function(x){x.classList.remove('on');}); t.classList.add('on');
    curTab=t.getAttribute('data-tt'); renderExpl(); }); });
  var rtOn=true;
  function renderExpl(){ var d=TAB[curTab];
    document.getElementById('explHi').textContent = d.hi;
    document.getElementById('explHi').style.display = rtOn? '' : 'none';
    document.getElementById('explEnWrap').querySelector('.expl-lbl').textContent = rtOn? 'English (original)' : 'English';
    document.getElementById('explEn').textContent = d.en;
  }
  document.getElementById('rtBtn').addEventListener('click',function(){ rtOn=!rtOn; document.getElementById('rtState').textContent=rtOn?'ON':'OFF'; this.classList.toggle('off',!rtOn); renderExpl(); });

  // ===== low-bandwidth mode =====
  document.getElementById('lowbwBtn').addEventListener('click',function(){ var on=document.body.classList.toggle('lowbw'); paused=on; this.classList.toggle('on',on);
    document.getElementById('netLbl').textContent = on? 'Poor · saving data' : 'Poor'; });

  // ===== offline pack =====
  document.getElementById('offBtn').addEventListener('click',function(){
    var st=document.getElementById('offSt'); if(st.textContent==='Ready'){ var p=0; st.textContent='Downloading…';
      var iv=setInterval(function(){ p+=8; st.textContent='Downloading… '+Math.min(100,p)+'%'; if(p>=100){ clearInterval(iv); st.textContent='Saved — works offline'; } }, 160); }
  });

  // ===== quiz + verify feedback =====
  document.querySelectorAll('.opt').forEach(function(o){ o.addEventListener('click',function(){ if(o.getAttribute('data-c')==='1'){} else { o.style.borderColor='var(--red)'; setTimeout(function(){o.style.borderColor='';},900);} }); });
  document.getElementById('verifyBtn').addEventListener('click',function(){ this.textContent='All 5 sources verified · High reliability'; this.style.color='var(--green)'; this.style.borderColor='var(--green)'; });
  document.querySelectorAll('.tool').forEach(function(t){ t.addEventListener('click',function(){ t.classList.toggle('act'); }); });

  // ===== AI Tutor "Ask" — real, lesson-scoped contextual answers =====
  // Honest scope: this is a curated knowledge responder for THIS fluid-mechanics
  // lesson, not a general LLM. It matches the question against the concepts on
  // screen and answers correctly (with Hindi), or says plainly when it can't.
  var KB = [
    { k:['lift','wing','aeroplane','airplane','aircraft','fly','flight'],
      en:'Lift comes from Bernoulli plus Newton: air travels faster over the curved top of the wing, so by P + ½ρv² = const the pressure on top is lower than underneath. That pressure difference, integrated over the wing area, is the upward lift force.',
      hi:'लिफ्ट बर्नौली और न्यूटन दोनों से आती है: पंख की घुमावदार ऊपरी सतह पर हवा तेज़ बहती है, इसलिए P + ½ρv² = स्थिर के अनुसार ऊपर का दाब नीचे से कम होता है। यही दाब-अंतर ऊपर की ओर लिफ्ट बल देता है।' },
    { k:['pressure','why','velocity','faster','slow','decrease'],
      en:'Because energy is conserved along a streamline. The sum P + ½ρv² + ρgh stays constant, so if v (and thus ½ρv²) rises, P must fall to keep the total fixed. Faster flow ⇒ lower pressure.',
      hi:'क्योंकि ऊर्जा एक स्ट्रीमलाइन के साथ संरक्षित रहती है। योग P + ½ρv² + ρgh स्थिर रहता है, इसलिए यदि v बढ़ता है तो P को घटना पड़ता है। तेज़ प्रवाह ⇒ कम दाब।' },
    { k:['venturi','throat','narrow','constriction','pipe'],
      en:'In a Venturi the pipe narrows, so by continuity A₁v₁ = A₂v₂ the fluid speeds up at the throat. Faster speed means lower pressure there — which is exactly what the blue indicator on the animation shows.',
      hi:'वेंचुरी में पाइप सँकरा होता है, इसलिए सातत्य A₁v₁ = A₂v₂ के अनुसार गले पर द्रव तेज़ हो जाता है। अधिक गति का अर्थ है वहाँ कम दाब — जो एनिमेशन का नीला संकेतक दिखाता है।' },
    { k:['pitot','airspeed','measure speed','speed of'],
      en:'A Pitot tube compares stagnation pressure (flow brought to rest) with static pressure. Their difference gives v = √(2(p₀ − p)/ρ). Aircraft use it to read airspeed.',
      hi:'पिटो ट्यूब ठहराव दाब और स्थैतिक दाब की तुलना करती है। उनका अंतर v = √(2(p₀ − p)/ρ) देता है। विमान इससे वायुगति मापते हैं।' },
    { k:['continuity','mass','flow rate','a1v1','conserv'],
      en:'Continuity is conservation of mass: for an incompressible fluid the volume flow rate A·v is the same everywhere in the pipe, so a smaller area forces a higher speed.',
      hi:'सातत्य द्रव्यमान का संरक्षण है: असंपीड्य द्रव के लिए आयतन प्रवाह दर A·v पाइप में हर जगह समान रहती है, इसलिए छोटा क्षेत्रफल अधिक गति देता है।' },
    { k:['density','rho','incompress'],
      en:'ρ (rho) is the fluid density in kg/m³. Bernoulli in this form assumes it is constant (incompressible flow) — a good approximation for water and for air below ~0.3 Mach.',
      hi:'ρ द्रव का घनत्व है (kg/m³)। इस रूप में बर्नौली इसे स्थिर मानता है (असंपीड्य प्रवाह) — जल के लिए और लगभग 0.3 मैक से कम वायु के लिए अच्छा सन्निकटन।' },
  ];
  var askInput = document.getElementById('askInput');
  var sendBtn = document.querySelector('.askrow .send');
  function answer(q){
    var ql = (q||'').toLowerCase().trim(); if(!ql) return;
    var best=null, bestScore=0;
    KB.forEach(function(e){ var s=0; e.k.forEach(function(kw){ if(ql.indexOf(kw)!==-1) s+=kw.length; }); if(s>bestScore){bestScore=s;best=e;} });
    // switch to Ask tab visual
    document.querySelectorAll('.tab').forEach(function(x){x.classList.remove('on'); if(x.getAttribute('data-tt')==='ask')x.classList.add('on');});
    curTab='ask';
    var en = best ? best.en : "I'm scoped to this fluid-mechanics lesson right now. Try asking about lift, why pressure drops when flow speeds up, the Venturi throat, the Pitot tube, continuity, or density.";
    var hi = best ? best.hi : 'मैं अभी इस द्रव-यांत्रिकी पाठ तक सीमित हूँ। लिफ्ट, दाब घटने का कारण, वेंचुरी गला, पिटो ट्यूब, सातत्य, या घनत्व के बारे में पूछें।';
    document.getElementById('explHi').textContent = hi; document.getElementById('explHi').style.display = rtOn? '' : 'none';
    document.getElementById('explEnWrap').querySelector('.expl-lbl').textContent = 'You asked: "'+q+'"';
    document.getElementById('explEn').textContent = en;
    askInput.value='';
  }
  if(sendBtn) sendBtn.addEventListener('click', function(){ answer(askInput.value); });
  if(askInput) askInput.addEventListener('keydown', function(e){ if(e.key==='Enter') answer(askInput.value); });

  // ===== mobile bottom action bar (phone) =====
  document.querySelectorAll('.mobabar .mb').forEach(function(b){
    b.addEventListener('click', function(){
      var k = b.getAttribute('data-mob');
      if(k==='tutor'){ var c=document.getElementById('aiTutorCard'); if(c){ c.scrollIntoView({behavior:'smooth',block:'start'}); askInput && askInput.focus({preventScroll:true}); } return; }
      if(k==='end'){ if(confirm('Leave the live class?')) location.href='/aquintutor/classrooms'; return; }
      if(k==='mic'){ b.classList.toggle('off'); return; } // starts muted; tap to unmute
      b.classList.toggle('act');
    });
  });
})();
</script>
</body>
</html>
