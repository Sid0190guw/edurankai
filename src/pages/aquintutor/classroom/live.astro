---
// /aquintutor/classroom/live — the AquinTutor live-classroom interface.
// High-fidelity teaching surface: live class + AI tutor + auto lesson plan +
// source verification + 3D lab/simulation + offline pack + low-bandwidth mode.
//
// What is REAL here (interactive, no backend needed):
//   - the Bernoulli venturi flow animation (hand-written canvas physics)
//   - slide navigation (6 lesson slides with distinct canvases)
//   - AI-Tutor tab switching + real Hindi/English translation toggle
//   - Low-Bandwidth Mode (pauses heavy render, drops to lightweight view)
//   - Offline-Pack download simulation + status
// What is PRESENTATIONAL (would need real backend/WebRTC/LLM to be live):
//   - student video tiles, live AI inference, live source crawling.
// Kept honest: nothing here claims to be live data that isn't.
const students = [
  { name: 'Ananya', muted: false }, { name: 'Rohit', muted: true }, { name: 'Megha', muted: true },
];
const slides = [
  { n: 10, t: 'Continuity Equation', scene: 'continuity' },
  { n: 11, t: 'Energy Equation', scene: 'energy' },
  { n: 12, t: "Bernoulli's Principle", scene: 'bernoulli', active: true },
  { n: 13, t: 'Applications', scene: 'applications' },
  { n: 14, t: 'Pitot Tube', scene: 'pitot' },
  { n: 15, t: 'Summary', scene: 'summary' },
];
const lessonPlan = [
  ['Introduction', '5 min'], ['Derivation of Equation', '10 min'], ['Concept Visualization', '10 min'],
  ['Real-life Applications', '10 min'], ['Numerical Examples', '15 min'], ['Practice Questions', '10 min'], ['Summary', '5 min'],
];
const sources = [
  ['NASA Glenn Research Center', 'High Reliability'], ['MIT OpenCourseWare', 'High Reliability'],
  ['NPTEL', 'High Reliability'], ['Encyclopedia Britannica', 'High Reliability'], ['OpenStax College Physics', 'High Reliability'],
];
const nav = {
  campus: ['Dashboard', 'My Classroom', 'Course Manager', 'Live Classes', 'Virtual Library', 'Virtual Labs', 'Assessments', 'Analytics', 'Calendar'],
  content: ['Lesson Plan', 'Modules', 'Resources', 'Assignments', 'Quizzes', 'Discussions', 'Projects'],
  tools: ['AI Content Studio', 'Slide & Board Studio', 'Question Generator', '3D Lab Builder', 'Simulation Builder', 'Exam Builder', 'Rubric Builder'],
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex" />
  <title>Live Classroom · AquinTutor</title>
  <style>
    :root{
      --bg:#0a0e17; --bg2:#0e1420; --panel:#111a2b; --panel2:#0d1524; --card:#131d2f;
      --stroke:#1e2a40; --stroke2:#26344d; --ink:#e6ecf7; --ink2:#aab6cc; --mut:#6c7b96;
      --blue:#3b82f6; --blue2:#60a5fa; --blueDim:#1e3a5f; --green:#22c55e; --red:#ef4444; --amber:#f59e0b;
    }
    *{box-sizing:border-box;}
    html,body{margin:0;height:100%;}
    body{background:var(--bg);color:var(--ink);font-family:'Inter Tight',system-ui,-apple-system,sans-serif;font-size:13px;overflow:hidden;}
    a{color:inherit;text-decoration:none;}
    .app{display:grid;grid-template-rows:52px 1fr 34px;height:100vh;}
    /* ---- top bar ---- */
    .top{display:flex;align-items:center;gap:16px;padding:0 16px;background:var(--bg2);border-bottom:1px solid var(--stroke);}
    .brand{display:flex;align-items:center;gap:10px;}
    .logo{width:30px;height:30px;border-radius:8px;background:linear-gradient(135deg,#3b82f6,#8b5cf6);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:15px;}
    .brand b{font-size:15px;font-weight:700;letter-spacing:-0.01em;} .brand span{display:block;font-size:9.5px;color:var(--mut);}
    .live-pill{display:flex;align-items:center;gap:9px;padding:5px 12px;border-radius:8px;background:var(--panel);border:1px solid var(--stroke);font-size:12.5px;}
    .live-dot{background:var(--red);color:#fff;font-size:9px;font-weight:800;padding:1px 6px;border-radius:4px;letter-spacing:0.05em;}
    .live-time{font-family:'Geist Mono',monospace;color:var(--ink2);font-size:12px;}
    .top-right{margin-left:auto;display:flex;align-items:center;gap:10px;}
    .lowbw{display:flex;align-items:center;gap:7px;padding:5px 11px;border-radius:8px;border:1px solid var(--stroke2);color:var(--green);font-size:12px;font-weight:600;cursor:pointer;background:transparent;font-family:inherit;}
    .lowbw.on{background:rgba(34,197,94,0.12);}
    .tbtn{width:32px;height:32px;border-radius:8px;border:1px solid var(--stroke);background:var(--panel);color:var(--ink2);display:flex;align-items:center;justify-content:center;cursor:pointer;}
    .tbtn:hover{color:var(--ink);border-color:var(--stroke2);}
    .lang{display:flex;align-items:center;gap:5px;padding:5px 9px;border-radius:8px;border:1px solid var(--stroke);background:var(--panel);font-size:12px;cursor:pointer;}
    .me{display:flex;align-items:center;gap:8px;} .me img,.me .av{width:30px;height:30px;border-radius:50%;object-fit:cover;background:linear-gradient(135deg,#3b82f6,#8b5cf6);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;color:#fff;}
    .me b{font-size:12.5px;} .me span{display:block;font-size:9.5px;color:var(--mut);}
    /* ---- body grid ---- */
    .body{display:grid;grid-template-columns:224px minmax(0,1fr) 336px;min-height:0;}
    /* sidebar */
    .side{background:var(--bg2);border-right:1px solid var(--stroke);overflow-y:auto;padding:10px 0;}
    .side::-webkit-scrollbar{width:6px;} .side::-webkit-scrollbar-thumb{background:var(--stroke2);border-radius:3px;}
    .navgrp{padding:6px 0;}
    .navlbl{font-size:9px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--mut);padding:10px 16px 6px;}
    .navi{display:flex;align-items:center;gap:10px;padding:7px 16px;font-size:12.5px;color:var(--ink2);cursor:pointer;border-left:2px solid transparent;}
    .navi:hover{background:var(--panel);color:var(--ink);}
    .navi.on{background:var(--panel);color:var(--blue2);border-left-color:var(--blue);font-weight:600;}
    .navi svg{opacity:0.75;flex-shrink:0;}
    .offcard{margin:12px;padding:12px;border-radius:12px;background:linear-gradient(160deg,#0f2a1e,#0d1a2a);border:1px solid #1c4a34;display:flex;align-items:center;gap:11px;}
    .offcard .oi{width:38px;height:38px;border-radius:10px;background:rgba(34,197,94,0.15);color:var(--green);display:flex;align-items:center;justify-content:center;flex-shrink:0;cursor:pointer;}
    .offcard b{font-size:12px;} .offcard .st{font-size:10.5px;color:var(--green);} .offcard .sz{font-size:10.5px;color:var(--mut);}
    /* center */
    .center{overflow-y:auto;padding:12px;min-width:0;}
    .center::-webkit-scrollbar{width:8px;} .center::-webkit-scrollbar-thumb{background:var(--stroke2);border-radius:4px;}
    .vidrow{display:flex;gap:10px;margin-bottom:12px;align-items:stretch;}
    .vid{position:relative;border-radius:12px;overflow:hidden;border:1px solid var(--stroke);background:linear-gradient(135deg,#16233a,#0e1726);flex:0 0 auto;}
    .vid.me-vid{width:230px;height:132px;} .vid.stu{width:112px;height:132px;}
    .vid .fill{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:#2c3c5a;}
    .vid .tag{position:absolute;left:8px;bottom:7px;font-size:11px;background:rgba(6,10,18,0.7);padding:2px 8px;border-radius:5px;font-weight:600;}
    .vid .mic{position:absolute;right:7px;bottom:7px;color:#fff;opacity:0.85;}
    .vid .mic.off{color:var(--red);}
    .vid.more{width:96px;height:132px;background:var(--panel);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;color:var(--ink2);}
    .vid.more b{font-size:18px;color:var(--ink);}
    .tools{margin-left:auto;background:var(--panel);border:1px solid var(--stroke);border-radius:12px;padding:10px 12px;min-width:210px;}
    .tools .th{font-size:9px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--mut);margin-bottom:8px;}
    .tools-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;}
    .tool{display:flex;flex-direction:column;align-items:center;gap:4px;font-size:9.5px;color:var(--ink2);cursor:pointer;padding:6px 2px;border-radius:8px;}
    .tool:hover{background:var(--card);color:var(--ink);} .tool.act{color:var(--blue2);} .tool svg{opacity:0.85;}
    /* lesson canvas */
    .canvas-card{background:var(--panel);border:1px solid var(--stroke);border-radius:14px;padding:20px;margin-bottom:12px;}
    .canvas-head{display:grid;grid-template-columns:1.1fr 1.3fr;gap:20px;}
    .lz-title{font-family:'Cormorant Garamond',Georgia,serif;font-size:30px;font-weight:600;margin:0 0 8px;letter-spacing:-0.01em;}
    .lz-desc{font-size:13.5px;color:var(--ink2);line-height:1.55;margin:0 0 14px;}
    .formula{background:var(--panel2);border:1px solid var(--stroke2);border-radius:10px;padding:14px 18px;font-family:'Cambria Math','Times New Roman',serif;font-size:22px;text-align:center;margin-bottom:14px;letter-spacing:0.02em;}
    .vardefs{font-size:12.5px;color:var(--ink2);line-height:1.9;}
    .vardefs b{color:var(--ink);font-family:'Geist Mono',monospace;}
    .applic{margin-top:14px;padding-top:12px;border-top:1px solid var(--stroke);}
    .applic .h{color:var(--amber);font-weight:700;font-size:12.5px;margin-bottom:5px;}
    .applic p{font-size:12.5px;color:var(--ink2);line-height:1.6;margin:0;}
    .stage-box{position:relative;}
    #flow{width:100%;border-radius:10px;background:#060b14;display:block;border:1px solid var(--stroke2);}
    .legend{display:flex;flex-wrap:wrap;gap:12px;margin-top:10px;font-size:11px;color:var(--ink2);}
    .legend i{display:inline-block;width:16px;height:3px;border-radius:2px;margin-right:5px;vertical-align:middle;}
    .srcbox{margin-top:12px;background:var(--panel2);border:1px solid var(--stroke2);border-radius:10px;padding:10px 12px;}
    .srcbox .sh{display:flex;justify-content:space-between;align-items:center;font-size:11px;color:var(--ink2);font-weight:600;cursor:pointer;}
    .srcbox ol{margin:8px 0 0;padding-left:20px;font-size:11.5px;color:var(--ink2);line-height:1.7;}
    .verify{margin-top:9px;width:100%;padding:7px;border-radius:7px;border:1px solid var(--blueDim);background:rgba(59,130,246,0.1);color:var(--blue2);font-size:11.5px;font-weight:600;cursor:pointer;font-family:inherit;}
    .slidebar{display:flex;align-items:center;gap:8px;padding:8px 12px;background:var(--panel2);border:1px solid var(--stroke);border-radius:10px;margin-bottom:10px;font-size:11.5px;color:var(--ink2);}
    .slidebar .tb{width:26px;height:26px;border-radius:6px;display:flex;align-items:center;justify-content:center;color:var(--mut);cursor:pointer;}
    .slidebar .tb:hover{background:var(--card);color:var(--ink);}
    .slidebar .sp{margin-left:auto;display:flex;align-items:center;gap:10px;}
    .thumbs{display:flex;gap:8px;overflow-x:auto;padding-bottom:6px;margin-bottom:12px;}
    .thumb{flex:0 0 132px;border-radius:9px;border:1px solid var(--stroke);background:var(--card);cursor:pointer;overflow:hidden;}
    .thumb.on{border-color:var(--blue);box-shadow:0 0 0 1px var(--blue);}
    .thumb .tv{height:74px;background:linear-gradient(135deg,#0e1726,#16233a);display:flex;align-items:center;justify-content:center;color:#2c3c5a;font-size:10px;position:relative;}
    .thumb .tn{position:absolute;top:5px;left:6px;font-size:10px;color:var(--mut);font-family:'Geist Mono',monospace;}
    .thumb .tt{padding:6px 8px;font-size:10.5px;color:var(--ink2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .thumb.on .tt{color:var(--blue2);}
    .quad{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;}
    .qcard{background:var(--panel);border:1px solid var(--stroke);border-radius:12px;padding:12px;min-height:150px;display:flex;flex-direction:column;}
    .qcard .qh{font-size:9px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--blue2);margin-bottom:8px;}
    .qcard .qt{font-size:13px;font-weight:600;margin-bottom:8px;}
    .lab-img,.sim-img{flex:1;border-radius:8px;background:#0a1220;border:1px solid var(--stroke2);position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;color:#2c3c5a;margin-bottom:8px;}
    .runbtn{width:100%;padding:8px;border-radius:8px;border:1px solid var(--blueDim);background:rgba(59,130,246,0.14);color:var(--blue2);font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:6px;}
    .runbtn:hover{background:rgba(59,130,246,0.24);}
    .quiz-q{font-size:12px;color:var(--ink2);line-height:1.5;margin-bottom:8px;}
    .opt{display:flex;align-items:center;gap:8px;font-size:12px;padding:6px 8px;border-radius:7px;border:1px solid var(--stroke);margin-bottom:5px;cursor:pointer;color:var(--ink2);}
    .opt:hover{border-color:var(--stroke2);}
    .opt.correct{border-color:var(--green);background:rgba(34,197,94,0.1);color:#86efac;}
    .notes{font-family:'Kalam','Comic Sans MS',cursive;font-size:13px;color:var(--ink2);line-height:1.8;}
    /* right panel */
    .rail{background:var(--bg2);border-left:1px solid var(--stroke);overflow-y:auto;padding:12px;}
    .rail::-webkit-scrollbar{width:6px;} .rail::-webkit-scrollbar-thumb{background:var(--stroke2);border-radius:3px;}
    .rcard{background:var(--panel);border:1px solid var(--stroke);border-radius:12px;padding:14px;margin-bottom:12px;}
    .rcard-h{display:flex;align-items:center;gap:8px;margin-bottom:12px;}
    .rcard-h .ic{width:26px;height:26px;border-radius:7px;background:rgba(59,130,246,0.15);color:var(--blue2);display:flex;align-items:center;justify-content:center;}
    .rcard-h b{font-size:13px;flex:1;} .rcard-h .act{font-size:10.5px;color:var(--green);display:flex;align-items:center;gap:5px;}
    .tabs{display:flex;gap:4px;margin-bottom:12px;overflow-x:auto;}
    .tab{font-size:11.5px;padding:5px 10px;border-radius:7px;color:var(--ink2);cursor:pointer;white-space:nowrap;}
    .tab.on{background:var(--card);color:var(--blue2);font-weight:600;}
    .transbar{display:flex;align-items:center;gap:8px;margin-bottom:12px;flex-wrap:wrap;}
    .selpill{display:flex;align-items:center;gap:6px;padding:5px 10px;border-radius:8px;border:1px solid var(--stroke2);background:var(--panel2);font-size:12px;cursor:pointer;}
    .rtpill{display:flex;align-items:center;gap:6px;padding:5px 11px;border-radius:100px;background:rgba(59,130,246,0.14);color:var(--blue2);font-size:11px;font-weight:600;cursor:pointer;border:none;font-family:inherit;}
    .rtpill.off{background:var(--panel2);color:var(--mut);}
    .expl{font-size:13.5px;line-height:1.7;color:var(--ink);}
    .expl.hi{font-family:'Noto Sans Devanagari','Inter Tight',sans-serif;}
    .expl-lbl{font-size:10.5px;color:var(--mut);text-transform:uppercase;letter-spacing:0.08em;margin:16px 0 6px;}
    .askrow{display:flex;gap:8px;margin-top:14px;}
    .askrow input{flex:1;background:var(--panel2);border:1px solid var(--stroke2);border-radius:9px;padding:9px 11px;color:var(--ink);font-family:inherit;font-size:12.5px;}
    .askrow .send{width:38px;border-radius:9px;background:var(--blue);border:none;color:#fff;display:flex;align-items:center;justify-content:center;cursor:pointer;}
    .plan-row{display:flex;align-items:center;gap:10px;font-size:12.5px;padding:6px 0;border-bottom:1px solid var(--stroke);color:var(--ink2);}
    .plan-row:last-child{border-bottom:none;} .plan-row .pn{color:var(--blue2);font-family:'Geist Mono',monospace;font-size:11px;width:14px;}
    .plan-row .pt{flex:1;color:var(--ink);} .plan-row .pd{color:var(--mut);font-size:11px;}
    .plan-actions{display:flex;gap:8px;margin-top:12px;}
    .plan-actions button{flex:1;padding:7px;border-radius:8px;border:1px solid var(--stroke2);background:var(--panel2);color:var(--ink2);font-size:11.5px;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:6px;}
    .plan-actions button:hover{color:var(--ink);}
    .src-row{display:flex;align-items:center;gap:9px;font-size:12px;padding:7px 0;border-bottom:1px solid var(--stroke);}
    .src-row:last-child{border-bottom:none;} .src-row .sn{flex:1;color:var(--ink);}
    .src-row .rel{display:flex;align-items:center;gap:4px;color:var(--green);font-size:10.5px;font-weight:600;}
    /* status bar */
    .status{display:flex;align-items:center;gap:18px;padding:0 16px;background:var(--bg2);border-top:1px solid var(--stroke);font-size:11.5px;color:var(--ink2);}
    .status .s{display:flex;align-items:center;gap:6px;} .status .dot{width:7px;height:7px;border-radius:50%;}
    .status .right{margin-left:auto;display:flex;gap:14px;}
    .status .right .s{cursor:pointer;} .status .right .s:hover{color:var(--ink);}
    .lowbw-note{display:none;}
    body.lowbw #flow{opacity:0.25;filter:grayscale(0.6);}
    body.lowbw .lowbw-note{display:flex;position:absolute;inset:0;align-items:center;justify-content:center;flex-direction:column;gap:6px;color:var(--amber);font-size:12px;background:rgba(6,11,20,0.55);border-radius:10px;text-align:center;padding:0 20px;}
    /* ---- mobile bottom action bar (phone only) ---- */
    .mobabar{display:none;position:fixed;left:0;right:0;bottom:0;z-index:60;background:rgba(9,13,22,0.96);-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);border-top:1px solid var(--stroke);align-items:center;justify-content:space-around;gap:4px;padding:7px 8px calc(7px + env(safe-area-inset-bottom,0px));}
    .mobabar .mb{display:flex;flex-direction:column;align-items:center;gap:3px;background:none;border:none;color:var(--ink2);font-family:inherit;font-size:9.5px;font-weight:600;cursor:pointer;padding:4px 8px;border-radius:10px;}
    .mobabar .mb svg{opacity:0.9;}
    .mobabar .mb.act{color:var(--blue2);}
    .mobabar .mb.off{color:var(--red);}
    .mobabar .mb.end{color:#fff;background:var(--red);padding:9px 16px;}
    /* ---- responsive: laptop / tablet ---- */
    @media (max-width:1160px){ .body{grid-template-columns:196px minmax(0,1fr) 300px;} }
    @media (max-width:1000px){ .body{grid-template-columns:minmax(0,1fr) 300px;} .side{display:none;} }
    /* ---- responsive: phone — the mobile-first live classroom ---- */
    @media (max-width:800px){
      html,body{height:auto;overflow:auto;-webkit-text-size-adjust:100%;}
      .app{display:block;height:auto;padding-bottom:78px;}
      .top{position:sticky;top:0;z-index:40;flex-wrap:wrap;height:auto;min-height:52px;gap:9px;padding:8px 12px;}
      .brand span{display:none;} .brand b{font-size:14px;}
      .lowbw{font-size:0;gap:0;padding:6px 9px;} .lowbw svg{width:16px;height:16px;}
      .top-right{gap:7px;} .top-right .tbtn{display:none;}
      .me b,.me span{display:none;}
      .live-pill{font-size:11px;padding:4px 8px;order:5;}
      .body{display:block;}
      .side{display:none;}
      .center{overflow:visible;padding:10px;}
      .rail{display:block;overflow:visible;border-left:none;border-top:1px solid var(--stroke);padding:12px 10px 0;}
      .vidrow{flex-wrap:wrap;gap:8px;}
      .vid.me-vid{width:100%;height:188px;}
      .vid.stu,.vid.more{width:calc(33.333% - 6px);height:84px;}
      .tools{display:none;}
      .canvas-card{padding:14px;}
      .canvas-head{grid-template-columns:1fr;gap:12px;}
      .lz-title{font-size:23px;}
      #flow{height:auto;}
      .quad{grid-template-columns:1fr;}
      .status{display:none;}
      .mobabar{display:flex;}
    }
    @media (max-width:420px){ .vid.stu,.vid.more{width:calc(50% - 4px);height:92px;} }
  </style>
</head>
<body>
<div class="app">
  <!-- TOP BAR -->
  <header class="top">
    <div class="brand"><div class="logo">A</div><div><b>AquinTutor</b><span>Intelligent Learning for All</span></div></div>
    <div class="live-pill">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#aab6cc" stroke-width="2"><path d="M15 10l4.55-2.28A1 1 0 0121 8.62v6.76a1 1 0 01-1.45.9L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
      Live Class — Fluid Mechanics <span class="live-dot">LIVE</span> <span class="live-time" id="clock">00:28:47</span>
    </div>
    <div class="top-right">
      <button class="lowbw on" id="lowbwBtn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12.55a11 11 0 0114.08 0M1.42 9a16 16 0 0121.16 0M8.53 16.11a6 6 0 016.95 0M12 20h.01"/></svg>Low Bandwidth Mode</button>
      <div class="lang">EN <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></div>
      <button class="tbtn" title="Proctor"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/></svg></button>
