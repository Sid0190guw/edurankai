---
// /aquintutor/alerts — in-app notification center (Prompt 18, main surface). Lightweight: server-
// rendered, no polling. Real events only. Preferences live at /aquintutor/settings.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { listNotifications } from '@/lib/edu-notify';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/alerts');
const items = await listNotifications(user.id, 50).catch(() => []);
const unread = items.filter((n: any) => !n.read).length;
function fmt(d: any) { try { return new Date(d).toLocaleString('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); } catch { return '-'; } }
const icon: Record<string, string> = { credential: 'var(--rust,#b3541e)', admission: '#5a5aa8', result: '#2f7d5b', deadline: '#8a5a1a', guardian: '#b3541e', general: '#8a8478' };
---
<AquintutorLayout title="Notifications">
  <main style="max-width:680px;margin:0 auto;padding:44px 22px 80px;">
    <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:18px;">
      <h1 style="font-family:Fraunces,serif;font-size:30px;font-weight:600;color:var(--ink,#1a1712);margin:0;">Notifications{unread ? ' (' + unread + ')' : ''}</h1>
      {unread ? <button id="markRead" type="button" style="background:#fff;border:1px solid var(--line,#e6e1d6);color:var(--ink,#1a1712);border-radius:8px;padding:8px 14px;font-family:'Inter Tight',sans-serif;font-size:13px;font-weight:600;cursor:pointer;">Mark all read</button> : null}
    </div>
    {items.length === 0 ? <p style="font-family:'Inter Tight',sans-serif;font-size:15px;color:#6b6455;">No notifications yet.</p> :
      <div style="display:flex;flex-direction:column;gap:8px;">{items.map((n: any) => (
        <a href={n.link || '#'} style={'display:block;text-decoration:none;background:#fff;border:1px solid var(--line,#e6e1d6);border-left:3px solid ' + (icon[n.type] || '#8a8478') + ';border-radius:10px;padding:12px 16px;' + (n.read ? 'opacity:.7;' : '')}>
          <p style="font-family:'Inter Tight',sans-serif;font-size:14.5px;font-weight:600;color:var(--ink,#1a1712);margin:0;">{n.title}</p>
          {n.body ? <p style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#6b6455;margin:3px 0 0;">{n.body}</p> : null}
          <p style="font-family:'Geist Mono',monospace;font-size:10.5px;color:#8a8478;margin:5px 0 0;">{n.type} · {fmt(n.at)}</p>
        </a>
      ))}</div>}
  </main>
  <script is:inline>
    (function () { var b = document.getElementById('markRead'); if (b) b.addEventListener('click', function () { fetch('/api/aquintutor/notifications-read', { method: 'POST' }).then(function () { location.reload(); }); }); })();
  </script>
</AquintutorLayout>
