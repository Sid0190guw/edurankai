---
// /aquintutor/offline — Offline lesson viewer (Prompt 6, main surface). Renders lessons from the
// IndexedDB package with NO network (content was pre-rendered at compile time). Records progress
// locally offline; syncs (enqueues) on reconnect. This surface is intentionally client-driven —
// offline learning requires it — but stays lean for low-end Android.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { EQUATION_CSS } from '@/lib/content-render';
---
<AquintutorLayout title="Offline lessons">
  <style set:html={EQUATION_CSS}></style>
  <main style="max-width:900px;margin:0 auto;padding:44px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Offline</p>
    <h1 style="font-family:Fraunces,serif;font-size:32px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 6px;line-height:1.15;">Your downloaded lessons</h1>
    <p id="ofStatus" style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#6b6455;margin:0 0 24px;">Loading your offline package&hellip;</p>

    <div style="display:grid;grid-template-columns:1fr;gap:20px;">
      <div>
        <div id="ofList" style="display:flex;flex-direction:column;gap:8px;"></div>
        <div style="margin-top:14px;display:flex;gap:8px;flex-wrap:wrap;">
          <button id="ofSync" type="button" style="background:#fff;border:1px solid var(--line,#e6e1d6);color:var(--ink,#1a1712);border-radius:8px;padding:9px 16px;font-family:'Inter Tight',sans-serif;font-size:13px;font-weight:600;cursor:pointer;">Sync now</button>
          <a href="/aquintutor/courses" style="background:#fff;border:1px solid var(--line,#e6e1d6);color:var(--ink,#1a1712);border-radius:8px;padding:9px 16px;font-family:'Inter Tight',sans-serif;font-size:13px;font-weight:600;text-decoration:none;">Browse courses</a>
        </div>
      </div>
      <article id="ofPane" style="display:none;background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:14px;padding:22px 24px;"></article>
    </div>
  </main>

  <script src="/offline-package.js" defer></script>
  <script is:inline>
    (function () {
      function ready(fn) { if (window.AquinOffline) fn(); else setTimeout(function () { ready(fn); }, 60); }
      ready(function () {
        var O = window.AquinOffline, statusEl = document.getElementById('ofStatus'), listEl = document.getElementById('ofList'), pane = document.getElementById('ofPane');
        Promise.all([O.listUnits(), O.meta()]).then(function (r) {
          var units = r[0] || [], meta = r[1];
          if (!units.length) { statusEl.textContent = 'No lessons downloaded yet. Open a course and choose "Download for offline".'; return; }
          statusEl.textContent = (meta ? ('Package: ' + meta.unitCount + ' units · ' + Math.round((meta.bytes || 0) / 1024) + ' KB · tier ' + meta.tier + (navigator.onLine ? ' · online' : ' · OFFLINE')) : units.length + ' lessons');
          units.forEach(function (u) {
            var b = document.createElement('button');
            b.type = 'button'; b.style.cssText = 'text-align:left;background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:10px;padding:12px 16px;font-family:Inter Tight,sans-serif;font-size:15px;font-weight:600;color:#1a1712;cursor:pointer;';
            b.textContent = u.title;
            b.addEventListener('click', function () { showUnit(u); });
            listEl.appendChild(b);
          });
        });
        function esc(s) { return String(s == null ? '' : s); }
        function showUnit(u) {
          var html = '<h2 style="font-family:Fraunces,serif;font-size:24px;font-weight:600;margin:0 0 14px;">' + esc(u.title) + '</h2>';
          html += '<div class="lesson-body" style="font-family:Inter Tight,sans-serif;line-height:1.7;color:#2a251d;">' + (u.bodyHtml || '') + '</div>';
          if (u.equations && u.equations.length) { html += '<h3 style="font-family:Fraunces,serif;margin:22px 0 10px;">Equations</h3>'; u.equations.forEach(function (e) { html += '<div style="padding:12px 16px;background:#faf8f2;border:1px solid var(--line,#e6e1d6);border-radius:10px;margin-bottom:10px;overflow-x:auto;">' + (e.html || '') + (e.caption ? '<p style="font-size:12.5px;color:#6b6455;margin:6px 0 0;">' + esc(e.caption) + '</p>' : '') + '</div>'; }); }
          if (u.examples && u.examples.length) { html += '<h3 style="font-family:Fraunces,serif;margin:22px 0 10px;">Worked examples</h3>'; u.examples.forEach(function (ex, i) { html += '<details style="border:1px solid var(--line,#e6e1d6);border-radius:10px;padding:12px 16px;margin-bottom:10px;"><summary style="cursor:pointer;font-weight:600;">Example ' + (i + 1) + '</summary><div style="margin-top:8px;">' + (ex.promptHtml || '') + (ex.solutionHtml || '') + '</div></details>'; }); }
          html += '<button id="ofDone" type="button" style="margin-top:22px;background:#1a1712;color:#fbfaf4;border:none;border-radius:10px;padding:11px 22px;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;cursor:pointer;">Mark complete (offline)</button> <span id="ofDoneMsg" style="font-family:Inter Tight,sans-serif;font-size:13px;color:#2f7d5b;margin-left:8px;"></span>';
          pane.innerHTML = html; pane.style.display = 'block'; pane.scrollIntoView({ behavior: 'smooth' });
          document.getElementById('ofDone').addEventListener('click', function () { O.recordProgress(u.id, true).then(function () { document.getElementById('ofDoneMsg').textContent = navigator.onLine ? 'Saved — will sync.' : 'Saved offline — will sync when back online.'; if (navigator.onLine) O.syncNow(); }); });
        }
        document.getElementById('ofSync').addEventListener('click', function () { O.syncNow().then(function (j) { statusEl.textContent = 'Synced ' + ((j && j.enqueued) || 0) + ' change(s).'; }); });
      });
    })();
  </script>
</AquintutorLayout>
