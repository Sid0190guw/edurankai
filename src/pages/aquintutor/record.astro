---
// /aquintutor/record — a student's academic record (Prompt 17, main surface). Aggregates real
// enrolments, completions (P4), official assessment results (P8), and credentials (P10). Own only.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { academicRecord } from '@/lib/enrolment';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/record');
const rec = await academicRecord(user.id).catch(() => ({ enrolments: [], completions: 0, results: [], credentials: [] }));
const CARD = 'background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:14px;padding:20px 22px;margin-bottom:16px;';
const HD = 'font-family:Fraunces,serif;font-size:18px;font-weight:600;margin:0 0 12px;color:var(--ink,#1a1712);';
function fmt(d: any) { try { return d ? new Date(d).toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' }) : '-'; } catch { return '-'; } }
---
<AquintutorLayout title="Academic record">
  <main style="max-width:760px;margin:0 auto;padding:44px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Record</p>
    <h1 style="font-family:Fraunces,serif;font-size:32px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 4px;line-height:1.15;">{user.name}</h1>
    <p style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:#6b6455;margin:0 0 22px;">Your academic record — every entry is real activity on the platform.</p>

    <div style={CARD}>
      <h2 style={HD}>Enrolments</h2>
      {rec.enrolments.length === 0 ? <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#6b6455;margin:0;">Not enrolled in any course yet. <a href="/aquintutor/enrol" style="color:var(--rust,#b3541e);">Enrol</a>.</p> :
        rec.enrolments.map((e: any) => <div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid #f0ece2;font-family:'Inter Tight',sans-serif;font-size:14px;"><span>{e.title}</span><span style="color:#8a8478;">{e.status} · {fmt(e.enrolled_at)}</span></div>)}
      <p style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#8a8478;margin:12px 0 0;">{rec.completions} lessons completed.</p>
    </div>

    <div style={CARD}>
      <h2 style={HD}>Official assessment results</h2>
      {rec.results.length === 0 ? <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#6b6455;margin:0;">No official results yet.</p> :
        rec.results.map((r: any) => <div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid #f0ece2;font-family:'Inter Tight',sans-serif;font-size:14px;"><span style="font-family:'Geist Mono',monospace;font-size:12px;color:#8a8478;">{String(r.assessment_id).slice(0, 8)}</span><span style={'font-weight:700;color:' + (r.passed ? '#2f7d5b' : '#9b2c2c')}>{r.pct}% {r.passed ? 'pass' : ''}</span></div>)}
    </div>

    <div style={CARD}>
      <h2 style={HD}>Credentials</h2>
      {rec.credentials.length === 0 ? <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#6b6455;margin:0;">No credentials yet.</p> :
        rec.credentials.map((c: any) => <div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid #f0ece2;font-family:'Inter Tight',sans-serif;font-size:14px;"><a href={'/credentials/course/' + c.code} style="color:var(--ink,#1a1712);text-decoration:none;">{c.course_title}</a><span style={c.revoked ? 'color:#9b2c2c;' : 'color:#2f7d5b;'}>{c.revoked ? 'revoked' : fmt(c.issued_at)}</span></div>)}
    </div>
  </main>
</AquintutorLayout>
