---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { ensureUserInLeague, getLeagueRoster, getLeague, refreshLeagueXp, TIERS, PROMOTE_TOP, DEMOTE_BOTTOM } from '@/lib/leagues';
import { ic } from '@/lib/policy-icons';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/league'));

const placement = await ensureUserInLeague(user.id);
let league: any = null, roster: any[] = [];
if (placement?.leagueId) {
  await refreshLeagueXp(placement.leagueId);
  league = await getLeague(placement.leagueId);
  roster = await getLeagueRoster(placement.leagueId);
}
const tier = TIERS.find(t => t.level === placement?.tier) || TIERS[0];
function shorten(n: string): string {
  if (!n) return 'anonymous';
  const parts = String(n).trim().split(/\s+/);
  if (parts.length === 1) return parts[0];
  return parts[0] + ' ' + parts[parts.length - 1][0] + '.';
}
function nextWeekStart(): string {
  const r = new Date();
  const day = r.getDay();
  const diff = (day === 0 ? 1 : (8 - day));
  r.setDate(r.getDate() + diff);
  return r.toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short' });
}
---
<AquintutorLayout title="Your league" description="Weekly cohort competition.">
  <section style="border-bottom:1px solid var(--rule); background:linear-gradient(180deg,#fff8f3 0%, var(--paper) 100%);">
    <div style="max-width:880px; margin:0 auto; padding:48px 28px;">
      <p style="font-family:'Inter Tight',monospace; font-size:12px; color:var(--rust); font-weight:700; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Weekly league</p>
      <div style="display:flex; gap:18px; align-items:center; flex-wrap:wrap;">
        <span style={'font-size:52px; line-height:1; display:inline-flex; color:' + tier.color + ';'} set:html={ic(tier.icon)}></span>
        <div>
          <h1 class="font-display" style={'font-size:clamp(2rem,4vw,3rem); line-height:1; letter-spacing:-0.02em; font-weight:500; margin:0; color:' + tier.color + ';'}>{tier.name} League</h1>
          <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); margin:6px 0 0;">Cohort #{placement?.cohort || 1} · {roster.length} learners · ends next Monday {nextWeekStart()}</p>
        </div>
      </div>
      <p style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink-500); line-height:1.65; margin-top:18px; max-width:54ch;">Top {PROMOTE_TOP} promote to the next tier. Bottom {DEMOTE_BOTTOM} demote one tier. Rest hold. Earn XP through practice, daily challenges, lessons, and official tests to climb.</p>
    </div>
  </section>

  <section>
    <div style="max-width:880px; margin:0 auto; padding:36px 28px 80px;">
      <div style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; overflow:hidden;">
        {roster.map((r: any, i: number) => {
          const isMe = r.user_id === user.id;
          const promo = i < PROMOTE_TOP;
          const demo = i >= roster.length - DEMOTE_BOTTOM && roster.length >= 20;
          const bg = isMe ? 'rgba(217,119,87,0.07)' : (promo ? 'rgba(16,185,129,0.06)' : (demo ? 'rgba(239,68,68,0.04)' : 'transparent'));
          const stripe = promo ? '#10b981' : (demo ? '#ef4444' : 'transparent');
          return (
            <div style={'display:grid; grid-template-columns:6px 50px 1fr 110px; gap:14px; align-items:center; padding:14px 18px; border-bottom:1px solid var(--rule); background:' + bg + ';'}>
              <div style={'width:6px; height:36px; background:' + stripe + '; border-radius:100px;'}></div>
              <span style="font-family:JetBrains Mono,monospace; font-size:14px; font-weight:700; color:var(--ink); display:flex; justify-content:flex-end;">{i < 3 ? <Fragment set:html={'<span style="display:inline-flex;align-items:center;justify-content:center;width:26px;height:26px;border-radius:50%;background:' + ['#facc15','#cbd5e1','#d97706'][i] + '33;color:' + ['#b8860b','#64748b','#b45309'][i] + ';font-size:12px;font-weight:800;">' + (i + 1) + '</span>'} /> : ('#' + (i + 1))}</span>
              <span style={'font-family:Inter Tight,sans-serif; font-size:15px; font-weight:' + (isMe ? '700;color:var(--rust)' : '500;color:var(--ink)') + ';'}>{shorten(r.name)}{isMe ? ' · you' : ''}</span>
              <span style="font-family:JetBrains Mono,monospace; font-size:14px; font-weight:700; color:var(--rust); text-align:right;">{r.week_xp} XP</span>
            </div>
          );
        })}
        {roster.length === 0 && (
          <div style="padding:30px; text-align:center; color:var(--ink-500); font-family:'Inter Tight',sans-serif; font-size:14px;">Your cohort is filling up — take a practice round to claim your seed XP.</div>
        )}
      </div>

      <div style="display:flex; gap:8px; margin-top:22px; flex-wrap:wrap;">
        <a href="/aquintutor/practice/sanskrit-awareness" style="background:var(--rust); color:#fff; padding:11px 18px; border-radius:10px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:700; text-decoration:none;">Practise to earn XP →</a>
        <a href="/aquintutor/daily" style="background:#10b981; color:#fff; padding:11px 18px; border-radius:10px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:700; text-decoration:none; display:inline-flex; align-items:center; gap:7px;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>Daily challenge</a>
        <a href="/aquintutor/leaderboard" style="background:var(--paper); color:var(--ink); padding:11px 18px; border-radius:10px; border:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:700; text-decoration:none;">Global leaderboard</a>
      </div>
    </div>
  </section>
</AquintutorLayout>
