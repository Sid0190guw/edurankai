---
// /aquintutor/enrol — self-service enrolment (Prompt 17, main surface). An accepted applicant
// activates their student status, then enrols in courses (prereqs + capacity enforced server-side).
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { contentService } from '@/lib/kernel-content';
import { myApplication, isEnrolmentEligible } from '@/lib/admissions';
import { myEnrolments } from '@/lib/enrolment';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/enrol');
const rows = (r: any): any[] => (Array.isArray(r) ? r : (r?.rows || []));
const isStudent = rows(await db.execute(sql`SELECT 1 FROM rbac_user_roles WHERE user_id = ${user.id} AND role_key = 'student' LIMIT 1`).catch(() => [])).length > 0;
const app = await myApplication(user.id).catch(() => null);
const accepted = app && isEnrolmentEligible(app.status);
const courses = isStudent ? (await contentService().listCourses().catch(() => [])).map((c: any) => ({ id: c.id, title: (c.data as any).title })) : [];
const enrolled = new Set((await myEnrolments(user.id).catch(() => [])).map((e: any) => e.course_obj_id));
const CARD = 'background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:14px;padding:20px 22px;margin-bottom:16px;';
---
<AquintutorLayout title="Enrol">
  <main style="max-width:720px;margin:0 auto;padding:44px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Enrolment</p>
    <h1 style="font-family:Fraunces,serif;font-size:32px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 18px;line-height:1.15;">Enrolment</h1>
    <div id="msg" style="display:none;margin:0 0 16px;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    {!isStudent && !accepted ? (
      <div style={CARD}><p style="font-family:'Inter Tight',sans-serif;font-size:15px;color:#6b6455;margin:0;">You need an accepted application to enrol. <a href="/aquintutor/admission" style="color:var(--rust,#b3541e);">Apply here</a>.</p></div>
    ) : !isStudent && accepted ? (
      <div style={CARD}><p style="font-family:'Inter Tight',sans-serif;font-size:15px;color:#2f7d5b;margin:0 0 12px;">Your application to <b>{app.program}</b> was accepted. Activate your enrolment to begin.</p>
        <button id="activateBtn" type="button" style="background:var(--ink,#1a1712);color:var(--sand-50,#fbfaf4);border:none;border-radius:10px;padding:11px 22px;font-family:'Inter Tight',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">Activate my enrolment</button></div>
    ) : (
      <div style={CARD}>
        <h2 style="font-family:Fraunces,serif;font-size:18px;font-weight:600;margin:0 0 12px;">Courses</h2>
        {courses.length === 0 ? <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#6b6455;margin:0;">No courses are available to enrol in yet.</p> :
          courses.map((c: any) => (
            <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid #f0ece2;">
              <span style="font-family:'Inter Tight',sans-serif;font-size:14.5px;font-weight:600;color:var(--ink,#1a1712);">{c.title}</span>
              {enrolled.has(c.id) ? <span style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#2f7d5b;">Enrolled</span> :
                <button class="enrolBtn" data-id={c.id} type="button" style="background:#fff;border:1px solid var(--ink,#1a1712);color:var(--ink,#1a1712);border-radius:8px;padding:7px 14px;font-family:'Inter Tight',sans-serif;font-size:13px;font-weight:600;cursor:pointer;">Enrol</button>}
            </div>
          ))}
        <p style="margin-top:16px;"><a href="/aquintutor/record" style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:var(--rust,#b3541e);text-decoration:none;">View my academic record &rarr;</a></p>
      </div>
    )}
  </main>
  <script is:inline>
    (function () {
      var msg = document.getElementById('msg');
      function post(body) { return fetch('/api/aquintutor/enrol', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }).then(function (r) { return r.json(); }); }
      function flash(t, ok) { msg.style.display = 'block'; msg.textContent = t; msg.style.background = ok ? '#eef8f1' : '#fdecec'; msg.style.color = ok ? '#2f7d5b' : '#9b2c2c'; }
      var a = document.getElementById('activateBtn'); if (a) a.addEventListener('click', function () { post({ action: 'activate' }).then(function (j) { if (j.ok) location.reload(); else flash(j.error || 'Failed', false); }); });
      document.querySelectorAll('.enrolBtn').forEach(function (b) { b.addEventListener('click', function () { post({ action: 'enrol', courseObjId: b.getAttribute('data-id') }).then(function (j) { if (j.ok) location.reload(); else flash(j.error || 'Failed', false); }); }); });
    })();
  </script>
</AquintutorLayout>
