---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
// Knowledge Graph — the Aquin Juniors signature (Grades 8-10, Boards + JEE
// foundation). Concepts are a real dependency DAG, not a flat list: a node is
// LOCKED until its prerequisites are mastered, OPEN when they are, and MASTERED
// once its check is passed — which visibly lights up everything downstream. The
// student sees WHY each concept matters and what it unlocks. Authored content,
// real graph engine, persisted, no LLM.
const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=' + encodeURIComponent('/aquintutor/knowledge-graph'));
---
<AquintutorLayout title="Knowledge Graph" description="See how every concept connects. Master a topic and watch it unlock the ones that depend on it — the Boards + JEE mechanics foundation as a living dependency map.">
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:900px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a><span style="margin:0 8px;">/</span><span style="color:var(--rust); font-weight:600;">KNOWLEDGE GRAPH</span>
    </div>
  </div>

  <section style="max-width:820px; margin:0 auto; padding:34px 24px 80px;">
    <p style="font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--rust); font-weight:700; margin:0 0 8px;">Aquin Juniors · Boards + JEE foundation</p>
    <h1 class="font-display" style="font-size:clamp(1.8rem,4vw,2.5rem); font-weight:500; margin:0 0 6px; color:var(--ink);">Every concept unlocks the next.</h1>
    <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink-500); line-height:1.6; margin:0 0 8px; max-width:640px;">This is Mechanics as a dependency map, not a syllabus list. A greyed topic is locked until you master what it's built on. Master it and watch what it opens up — so you always know <em>why</em> you're learning something.</p>

    <div style="display:flex; gap:16px; flex-wrap:wrap; align-items:center; margin:14px 0 18px; font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500);">
      <span style="display:inline-flex; align-items:center; gap:6px;"><span style="width:14px; height:14px; border-radius:4px; background:#eef3ee; border:2px solid #1c7a45;"></span> Mastered</span>
      <span style="display:inline-flex; align-items:center; gap:6px;"><span style="width:14px; height:14px; border-radius:4px; background:#fff; border:2px solid var(--rust);"></span> Open — you can learn it now</span>
      <span style="display:inline-flex; align-items:center; gap:6px;"><span style="width:14px; height:14px; border-radius:4px; background:#eee9e0; border:2px solid #c9c0b2;"></span> Locked</span>
      <span id="kgProg" style="margin-left:auto; font-family:'JetBrains Mono',monospace; font-weight:700; color:var(--rust);"></span>
    </div>

    <div id="kgGraph" style="background:#fff; border:1.5px solid var(--rule); border-radius:16px; padding:10px; overflow-x:auto;"></div>
    <div id="kgPanel" style="margin-top:16px;"></div>
  </section>

  <script is:inline define:vars={{ uid: user.id }}>
  (function(){
    var NODES=[
      { id:'units', name:'Units & Measurement', x:360, y:40, pre:[],
        refresher:'Physics starts with units. Convert carefully: 1 km = 1000 m, 1 hour = 3600 s. Every answer needs the right unit.',
        check:{ q:'How many metres are in 2.5 kilometres?', a:2500 } },
      { id:'kin1d', name:'Kinematics (1D)', x:200, y:150, pre:['units'],
        refresher:'Motion in a line. Acceleration a = (v − u)/t. From rest, u = 0, so a = v/t.',
        check:{ q:'A car speeds up from rest to 20 m/s in 4 s. Acceleration (m/s²)?', a:5 } },
      { id:'vectors', name:'Vectors', x:520, y:150, pre:['units'],
        refresher:'Vectors have size and direction. Perpendicular vectors combine by Pythagoras: |R| = √(a² + b²).',
        check:{ q:'Forces 3 N east and 4 N north act at a point. Resultant magnitude (N)?', a:5 } },
      { id:'newton', name:"Newton's Laws", x:150, y:262, pre:['kin1d'],
        refresher:'F = ma. Net force equals mass times acceleration. Rearrange as a = F/m.',
        check:{ q:'A net force of 10 N acts on a 2 kg mass. Acceleration (m/s²)?', a:5 } },
      { id:'proj', name:'Projectile Motion', x:360, y:262, pre:['kin1d','vectors'],
        refresher:'Horizontal and vertical motion are independent. Dropped/horizontal launch: h = ½gt², so t = √(2h/g).',
        check:{ q:'A ball is thrown horizontally from 20 m high (g = 10). Time to land (s)?', a:2 } },
      { id:'circ', name:'Circular Motion', x:560, y:262, pre:['newton','vectors'],
        refresher:'Circular motion needs a centre-pointing force. Centripetal force F = m·v²/r.',
        check:{ q:'A 2 kg object circles r = 1 m at v = 2 m/s. Centripetal force (N)?', a:8 } },
      { id:'friction', name:'Friction', x:90, y:374, pre:['newton'],
        refresher:'Friction opposes motion. f = μ·N, where N is the normal force and μ the coefficient.',
        check:{ q:'Normal force 20 N, coefficient μ = 0.3. Friction force (N)?', a:6 } },
      { id:'work', name:'Work & Energy', x:250, y:374, pre:['newton'],
        refresher:'Work = force × distance moved in the force direction. W = F·d.',
        check:{ q:'A 5 N force moves an object 4 m in its direction. Work done (J)?', a:20 } },
      { id:'mom', name:'Momentum', x:430, y:374, pre:['newton'],
        refresher:'Momentum p = mass × velocity. It is conserved in collisions.',
        check:{ q:'A 3 kg trolley moves at 4 m/s. Its momentum (kg·m/s)?', a:12 } },
    ];
    var EDGES=[]; NODES.forEach(function(n){ n.pre.forEach(function(p){ EDGES.push([p,n.id]); }); });
    var byId={}; NODES.forEach(function(n){ byId[n.id]=n; });

    var KEY='aq_kg_mech_'+uid, mastered={};
    try{ (JSON.parse(localStorage.getItem(KEY))||[]).forEach(function(id){ mastered[id]=1; }); }catch(e){}
    function save(){ try{ localStorage.setItem(KEY, JSON.stringify(Object.keys(mastered))); }catch(e){} }
    function isOpen(n){ return n.pre.every(function(p){ return mastered[p]; }); }
    function state(n){ return mastered[n.id]?'mastered':(isOpen(n)?'open':'locked'); }

    var g=document.getElementById('kgGraph'), panel=document.getElementById('kgPanel'), prog=document.getElementById('kgProg');
    function render(){
      var s='<svg viewBox="0 0 720 430" width="100%" style="max-width:720px; height:auto; display:block; margin:0 auto; font-family:Inter Tight,sans-serif;">';
      EDGES.forEach(function(e){ var a=byId[e[0]], b=byId[e[1]]; var live=mastered[a.id]; s+='<line x1="'+a.x+'" y1="'+(a.y+22)+'" x2="'+b.x+'" y2="'+(b.y-22)+'" stroke="'+(live?'#1c7a45':'#d9d0c2')+'" stroke-width="'+(live?2.4:1.6)+'" '+(live?'':'stroke-dasharray="4 4"')+'/>'; });
      NODES.forEach(function(n){ var st=state(n);
        var fill=st==='mastered'?'#eef3ee':st==='open'?'#ffffff':'#eee9e0';
        var stroke=st==='mastered'?'#1c7a45':st==='open'?'#c2410c':'#c9c0b2';
        var tcol=st==='locked'?'#9a9184':'#1a1510';
        s+='<g data-node="'+n.id+'" style="cursor:'+(st==='locked'?'not-allowed':'pointer')+';">';
        s+='<rect x="'+(n.x-66)+'" y="'+(n.y-22)+'" width="132" height="44" rx="11" fill="'+fill+'" stroke="'+stroke+'" stroke-width="2"/>';
        var words=n.name.split(' '), l1=n.name, l2='';
        if(n.name.length>14){ var mid=Math.ceil(words.length/2); l1=words.slice(0,mid).join(' '); l2=words.slice(mid).join(' '); }
        if(l2){ s+='<text x="'+n.x+'" y="'+(n.y-3)+'" text-anchor="middle" font-size="12" font-weight="600" fill="'+tcol+'">'+l1+'</text><text x="'+n.x+'" y="'+(n.y+13)+'" text-anchor="middle" font-size="12" font-weight="600" fill="'+tcol+'">'+l2+'</text>'; }
        else { s+='<text x="'+n.x+'" y="'+(n.y+4)+'" text-anchor="middle" font-size="12.5" font-weight="600" fill="'+tcol+'">'+l1+'</text>'; }
        if(st==='mastered') s+='<circle cx="'+(n.x+58)+'" cy="'+(n.y-14)+'" r="8" fill="#1c7a45"/><path d="M'+(n.x+54)+' '+(n.y-14)+'l3 3 5-5" stroke="#fff" stroke-width="1.8" fill="none"/>';
        if(st==='locked'){ var lx=n.x+52, ly=n.y-16; s+='<rect x="'+lx+'" y="'+ly+'" width="11" height="8" rx="1.5" fill="#c9c0b2"/><path d="M'+(lx+2)+' '+ly+' v-2 a3.5 3.5 0 017 0 v2" fill="none" stroke="#9a9184" stroke-width="1.4"/>'; }
        s+='</g>';
      });
      s+='</svg>';
      g.innerHTML=s;
      var m=Object.keys(mastered).length; prog.textContent=m+' / '+NODES.length+' mastered';
    }
    g.addEventListener('click', function(e){ var t=e.target.closest('[data-node]'); if(!t) return; open(byId[t.getAttribute('data-node')]); });

    function open(n){
      var st=state(n);
      if(st==='locked'){ var need=n.pre.filter(function(p){ return !mastered[p]; }).map(function(p){ return byId[p].name; }).join(' and ');
        panel.innerHTML='<div style="background:#faf6ef;border:1.5px solid var(--rule);border-radius:14px;padding:16px;"><div style="font-family:JetBrains Mono,monospace;font-size:10.5px;letter-spacing:0.12em;text-transform:uppercase;color:#9a9184;font-weight:700;margin-bottom:6px;">Locked</div><p style="font-family:Inter Tight,sans-serif;font-size:14.5px;color:var(--ink);margin:0;">To open <b>'+n.name+'</b>, first master <b>'+need+'</b>. That is what this concept is built on.</p></div>';
        panel.scrollIntoView({behavior:'smooth',block:'nearest'}); return; }
      if(st==='mastered'){ var unlocks=NODES.filter(function(x){ return x.pre.indexOf(n.id)>=0; }).map(function(x){ return x.name; });
        panel.innerHTML='<div style="background:#eef3ee;border:1.5px solid #1c7a45;border-radius:14px;padding:16px;"><div style="font-family:JetBrains Mono,monospace;font-size:10.5px;letter-spacing:0.12em;text-transform:uppercase;color:#1c7a45;font-weight:700;margin-bottom:6px;">Mastered</div><h3 class="font-display" style="font-size:1.2rem;font-weight:600;color:var(--ink);margin:0 0 6px;">'+n.name+'</h3><p style="font-family:Inter Tight,sans-serif;font-size:14px;color:var(--ink);line-height:1.6;margin:0 0 8px;">'+n.refresher+'</p>'+(unlocks.length?'<p style="font-family:Inter Tight,sans-serif;font-size:13px;color:var(--ink-500);margin:0;">This unlocked: '+unlocks.join(', ')+'.</p>':'<p style="font-family:Inter Tight,sans-serif;font-size:13px;color:var(--ink-500);margin:0;">A capstone concept — nothing further depends on it here.</p>')+'</div>';
        panel.scrollIntoView({behavior:'smooth',block:'nearest'}); return; }
      // open -> learn + check
      panel.innerHTML='<div style="background:#fff;border:1.5px solid var(--rust);border-radius:14px;padding:18px;">'
        +'<div style="font-family:JetBrains Mono,monospace;font-size:10.5px;letter-spacing:0.12em;text-transform:uppercase;color:var(--rust);font-weight:700;margin-bottom:6px;">Learn &amp; master</div>'
        +'<h3 class="font-display" style="font-size:1.3rem;font-weight:600;color:var(--ink);margin:0 0 8px;">'+n.name+'</h3>'
        +'<p style="font-family:Inter Tight,sans-serif;font-size:14.5px;color:var(--ink);line-height:1.7;background:rgba(43,87,126,0.06);border-left:3px solid #2b577e;border-radius:0 8px 8px 0;padding:11px 13px;margin:0 0 14px;">'+n.refresher+'</p>'
        +'<p style="font-family:Inter Tight,sans-serif;font-size:15px;font-weight:600;color:var(--ink);margin:0 0 8px;">'+n.check.q+'</p>'
        +'<div style="display:flex;gap:8px;"><input id="kgAns" inputmode="numeric" placeholder="Your answer" style="flex:1;max-width:220px;background:var(--sand-50);border:1.5px solid var(--rule);border-radius:9px;padding:10px 12px;font-size:16px;font-family:Geist Mono,monospace;color:var(--ink);outline:none;" />'
        +'<button id="kgCk" style="background:var(--rust);color:#fff;border:none;font-family:Inter Tight,sans-serif;font-size:14px;font-weight:600;padding:10px 20px;border-radius:9px;cursor:pointer;">Master it</button></div>'
        +'<p id="kgMsg" style="font-family:Inter Tight,sans-serif;font-size:13.5px;margin:12px 0 0;min-height:1em;"></p></div>';
      var inp=document.getElementById('kgAns'); inp.focus();
      function ck(){ var v=parseFloat((inp.value||'').replace(/[, ]/g,'')), m=document.getElementById('kgMsg');
        if(isNaN(v)){ m.style.color='var(--rust)'; m.textContent='Type a number.'; return; }
        if(Math.abs(v-n.check.a)<1e-6){ mastered[n.id]=1; save(); render();
          fetch('/api/aquintutor/learn',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'same-origin',body:JSON.stringify({action:'verify',skillId:'kg-mech-'+n.id,verified:true})}).catch(function(){});
          var opened=NODES.filter(function(x){ return x.pre.indexOf(n.id)>=0 && isOpen(x); }).map(function(x){ return x.name; });
          m.style.color='#1c7a45'; m.innerHTML='<b>Mastered.</b> '+(opened.length?'You just unlocked: '+opened.join(', ')+'.':'Well done.');
        } else { m.style.color='var(--rust)'; m.textContent='Not quite — re-read the idea above and try again.'; }
      }
      document.getElementById('kgCk').addEventListener('click', ck); inp.addEventListener('keydown', function(e){ if(e.key==='Enter') ck(); });
      panel.scrollIntoView({behavior:'smooth',block:'nearest'});
    }
    render();
  })();
  </script>
</AquintutorLayout>
