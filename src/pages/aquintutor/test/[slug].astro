---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { COUNTRIES } from '@/lib/phone-validate';

const { slug } = Astro.params;
const user = Astro.locals.user;

let test: any = null;
try {
  const r = await db.execute(sql`SELECT * FROM tests WHERE slug = ${slug} AND is_published = true LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  test = rows[0] || null;
} catch(e) {}

if (!test) return Astro.redirect('/aquintutor');

const isPremium = test.is_premium === true && (test.price_inr_paise || 0) >= 1;
const displayCurrency = (test.currency || 'INR').toUpperCase();
const displayAmountMinor = Math.max(1, parseInt(test.price_inr_paise || 100));
const displayAmountMajor = (displayAmountMinor / 100).toFixed(displayAmountMinor % 100 === 0 ? 0 : 2);

// Live FX preview for non-INR display currencies
let fxPreview: { inrPaise: number; rate: number; date: string; live: boolean } | null = null;
if (isPremium && displayCurrency !== 'INR') {
  try {
    const { convertToInrPaise } = await import('@/lib/fx');
    const r = await convertToInrPaise(displayCurrency, displayAmountMinor);
    fxPreview = { inrPaise: r.paise, rate: r.rate, date: r.date, live: r.live };
  } catch (_) {}
}
const priceLabel = displayCurrency + ' ' + displayAmountMajor;
const inrPreviewLabel = fxPreview ? '~Rs ' + Math.round(fxPreview.inrPaise / 100).toLocaleString('en-IN') : '';
const isAdmin = user && user.role && ['admin','super_admin','editor','reviewer'].includes(user.role);

let alreadyPaid = false;
if (isPremium && user && !isAdmin) {
  try {
    const r = await db.execute(sql`
      SELECT id FROM payments
      WHERE user_id = ${user.id} AND reference_type = 'test' AND reference_id = ${test.id}
        AND status = 'paid'
      LIMIT 1
    `);
    const rows = Array.isArray(r) ? r : (r?.rows || []);
    alreadyPaid = rows.length > 0;
  } catch (_) {}
}
// Admins always treated as paid for UI purposes (server enforces override too)
if (isAdmin) alreadyPaid = true;

let attemptCount = 0;
let userBestScore: number | null = null;
let myInProgress: any = null;
try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as c FROM test_attempts WHERE test_id = ${test.id} AND status IN ('submitted','auto_submitted')`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  attemptCount = (rows[0] as any)?.c || 0;

  if (user) {
    const mybest = await db.execute(sql`SELECT MAX(percentage) as best FROM test_attempts WHERE test_id = ${test.id} AND candidate_id = ${user.id} AND status IN ('submitted','auto_submitted')`);
    const r2 = Array.isArray(mybest) ? mybest : (mybest?.rows || []);
    userBestScore = (r2[0] as any)?.best || null;

    const inprog = await db.execute(sql`SELECT * FROM test_attempts WHERE test_id = ${test.id} AND candidate_id = ${user.id} AND status = 'in_progress' ORDER BY started_at DESC LIMIT 1`);
    const r3 = Array.isArray(inprog) ? inprog : (inprog?.rows || []);
    myInProgress = r3[0] || null;
  }
} catch(e) {}

// Canvas-style availability / attempts / access-code state for the CTA.
const sp = new URL(Astro.request.url).searchParams;
const blockedReason = sp.get('blocked') || '';
const nowMs = Date.now();
const notOpen = !!(test.available_from && nowMs < new Date(test.available_from).getTime());
const closed = !!(test.available_until && nowMs > new Date(test.available_until).getTime());
let myAttemptsUsed = 0;
if (user) {
  try {
    const r = await db.execute(sql`SELECT COUNT(*)::int AS c FROM test_attempts WHERE test_id = ${test.id} AND candidate_id = ${user.id} AND status IN ('submitted','auto_submitted')`);
    const rows = Array.isArray(r) ? r : (r?.rows || []);
    myAttemptsUsed = (rows[0] as any)?.c || 0;
  } catch (_) {}
}
const attemptsExhausted = test.allowed_attempts != null && myAttemptsUsed >= test.allowed_attempts && !isAdmin;
const needsCode = !!test.access_code;
const canBegin = !notOpen && !closed && !attemptsExhausted;
function fmtWhen(d: any): string { return d ? new Date(d).toLocaleString('en-IN', { day: 'numeric', month: 'short', year: 'numeric', hour: 'numeric', minute: '2-digit' }) : ''; }
const blockMsg = blockedReason === 'code' ? 'Incorrect access code.'
  : blockedReason === 'attempts' ? 'You have used all allowed attempts.'
  : blockedReason === 'not_open' ? 'This test is not open yet.'
  : blockedReason === 'closed' ? 'This test has closed.' : '';

// Languages offered (only show codes that actually have approved translations + English).
const LANG_LABELS: Record<string, string> = { en: 'English', hi: 'Hindi', bn: 'Bengali', ta: 'Tamil', te: 'Telugu', mr: 'Marathi', gu: 'Gujarati', kn: 'Kannada', ml: 'Malayalam', pa: 'Punjabi', ur: 'Urdu', as: 'Assamese', es: 'Spanish', fr: 'French', de: 'German', pt: 'Portuguese', ar: 'Arabic', zh: 'Mandarin', ja: 'Japanese', ru: 'Russian' };
let offeredLangs: string[] = Array.isArray(test.languages) ? test.languages : ['en'];
if (offeredLangs.length > 1) {
  try {
    const r = await db.execute(sql`SELECT DISTINCT lang FROM test_question_translations WHERE test_id = ${test.id} AND status = 'approved'`);
    const live = (Array.isArray(r) ? r : (r?.rows || [])).map((x: any) => x.lang);
    offeredLangs = ['en', ...offeredLangs.filter((c: string) => c !== 'en' && live.includes(c))];
  } catch (_) { offeredLangs = ['en']; }
}

const CAT_THEMES: Record<string, { bg: string; fg: string; accent: string; pattern: string; vibe: string }> = {
  coding: { bg: '#020c08', fg: '#10b981', accent: '#34d399', pattern: 'matrix', vibe: 'enter the code lab' },
  aptitude: { bg: '#03081a', fg: '#60a5fa', accent: '#93c5fd', pattern: 'grid', vibe: 'sharpen your mind' },
  mcq: { bg: '#1a0a02', fg: '#FF7040', accent: '#FFB088', pattern: 'orbs', vibe: 'fast and focused' },
  subjective: { bg: '#150828', fg: '#a78bfa', accent: '#c4b5fd', pattern: 'waves', vibe: 'think deeply' },
  personality: { bg: '#1a1408', fg: '#fbbf24', accent: '#fcd34d', pattern: 'rings', vibe: 'discover yourself' },
  video: { bg: '#1a0808', fg: '#ef4444', accent: '#fca5a5', pattern: 'pulse', vibe: 'speak up' },
  mixed: { bg: '#1a0a00', fg: '#FF4F00', accent: '#FF7040', pattern: 'mixed', vibe: 'all skills tested' },
};
const theme = (CAT_THEMES as any)[test.test_type] || CAT_THEMES.mixed;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>{test.title} - Aquintutor</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Instrument+Serif:ital@0;1&display=swap');

    :root {
      --atlas-bg: #0b0d10;
      --atlas-surface: #14181d;
      --atlas-surface-2: #1c2128;
      --atlas-surface-3: #242a32;
      --atlas-border: #2a3038;
      --atlas-ink: #f4f1ea;
      --atlas-ink-2: #c8c3b8;
      --atlas-ink-3: #8a8579;
      --atlas-ink-4: #5a5650;
      --terracotta: #d97757;
      --terracotta-d: #b85e3f;
      --font-sans: "Space Grotesk", system-ui, -apple-system, sans-serif;
      --font-mono: "JetBrains Mono", ui-monospace, SFMono-Regular, monospace;
      --font-serif: "Instrument Serif", "Times New Roman", serif;
    }

    body {
      background: var(--atlas-bg);
      color: var(--atlas-ink);
      font-family: var(--font-sans);
      min-height: 100vh;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* Animated background patterns */
    .bg-fx { position: fixed; inset: 0; pointer-events: none; opacity: 0.12; }

    /* Top bar */
    .topbar { background: var(--atlas-surface); border-bottom: 1px solid var(--atlas-border); padding: 14px 24px; position: sticky; top: 0; z-index: 10; display: flex; align-items: center; gap: 16px; }
    .topbar a { color: var(--atlas-ink-2); text-decoration: none; font-size: 12px; font-family: var(--font-mono); }
    .topbar .brand-word { font-family: var(--font-serif); font-size: 20px; line-height: 0.9; letter-spacing: 0.06em; color: var(--atlas-ink); display: inline-flex; align-items: baseline; gap: 4px; }
    .topbar .brand-word .pin { width: 5px; height: 5px; border-radius: 50%; background: var(--fg); align-self: center; box-shadow: 0 0 8px var(--fg); }
    .topbar .brand-divider { width: 1px; height: 18px; background: var(--atlas-border); }

    .container { max-width: 760px; margin: 0 auto; padding: 56px 24px 80px; position: relative; z-index: 1; }

    .breadcrumb { font-size: 10px; color: var(--atlas-ink-3); font-family: var(--font-mono); letter-spacing: 0.16em; text-transform: uppercase; margin-bottom: 20px; font-weight: 500; }
    .breadcrumb a { color: var(--fg); text-decoration: none; }

    h1 {
      font-family: var(--font-serif);
      font-size: clamp(36px, 5vw, 56px);
      font-weight: 400;
      letter-spacing: 0;
      line-height: 1.05;
      margin-bottom: 16px;
      color: var(--atlas-ink);
    }
    .lead { font-size: 16px; color: var(--atlas-ink-2); line-height: 1.6; margin-bottom: 32px; max-width: 600px; }

    .meta-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 10px; margin-bottom: 32px; }
    .meta-tile { background: var(--atlas-surface); border: 1px solid var(--atlas-border); border-radius: 10px; padding: 14px; }
    .meta-num { font-family: var(--font-mono); font-size: 22px; font-weight: 600; color: var(--fg); margin-bottom: 4px; font-variant-numeric: tabular-nums; }
    .meta-lbl { font-family: var(--font-mono); font-size: 9px; color: var(--atlas-ink-3); text-transform: uppercase; letter-spacing: 0.16em; font-weight: 500; }

    .info-box { background: var(--atlas-surface); border: 1px solid var(--atlas-border); border-radius: 14px; padding: 22px; margin-bottom: 22px; }
    .info-box h3 { font-family: var(--font-mono); font-size: 10px; font-weight: 500; color: var(--atlas-ink-3); margin-bottom: 14px; letter-spacing: 0.16em; text-transform: uppercase; }
    .info-list { list-style: none; padding: 0; margin: 0; }
    .info-list li { padding: 6px 0; padding-left: 22px; position: relative; font-size: 14px; color: var(--atlas-ink-2); line-height: 1.55; }
    .info-list li::before { content: '+'; position: absolute; left: 0; color: var(--fg); font-weight: 600; font-family: var(--font-mono); }

    .cta-row { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
    .btn-start {
      flex: 1;
      min-width: 220px;
      background: var(--fg);
      color: #1a0f08;
      border: none;
      font-size: 14px;
      font-weight: 600;
      padding: 14px 22px;
      border-radius: 8px;
      cursor: pointer;
      letter-spacing: 0.04em;
      transition: background 0.12s, transform 0.12s, box-shadow 0.12s;
      text-decoration: none;
      text-align: center;
      display: block;
      font-family: var(--font-sans);
      box-shadow: 0 0 24px rgba(217,119,87,0.25);
    }
    .btn-start:hover {
      transform: translateY(-1px);
      background: var(--terracotta-d);
      box-shadow: 0 0 32px rgba(217,119,87,0.4);
    }
    .btn-secondary {
      background: var(--atlas-surface-2);
      color: var(--atlas-ink-2);
      border: 1px solid var(--atlas-border);
      font-size: 13px;
      font-weight: 500;
      padding: 12px 18px;
      border-radius: 8px;
      cursor: pointer;
      text-decoration: none;
      font-family: var(--font-sans);
    }
    .btn-secondary:hover { background: var(--atlas-surface-3); border-color: var(--atlas-ink-4); }

    .badge { display: inline-flex; align-items: center; gap: 6px; background: var(--atlas-surface); border: 1px solid var(--atlas-border); border-radius: 999px; padding: 5px 12px; font-size: 10px; color: var(--fg); margin-bottom: 18px; font-weight: 500; font-family: var(--font-mono); letter-spacing: 0.16em; text-transform: uppercase; }

    .your-best { background: var(--atlas-surface); border: 1px solid var(--fg); border-radius: 14px; padding: 16px 20px; margin-bottom: 22px; display: flex; align-items: center; justify-content: space-between; gap: 10px; box-shadow: 0 0 24px rgba(217,119,87,0.12); }
    .your-best-label { font-family: var(--font-mono); font-size: 10px; color: var(--atlas-ink-3); text-transform: uppercase; letter-spacing: 0.16em; }
    .your-best-num { font-family: var(--font-mono); font-size: 32px; font-weight: 600; color: var(--fg); line-height: 1; font-variant-numeric: tabular-nums; }

    /* Matrix code rain effect for coding theme */
    .matrix-canvas { width: 100%; height: 100%; }
  </style>
</head>
<body style={`--bg:${theme.bg};--fg:${theme.fg};--accent:${theme.accent};`}>
  <canvas class="bg-fx" id="bgCanvas"></canvas>

  <nav class="topbar">
    <span class="brand-word"><span>ATLAS</span><span class="pin"></span></span>
    <span class="brand-divider"></span>
    <a href="/aquintutor">&lt; Back to AquinTutor</a>
  </nav>

  <div class="container">
    <div class="breadcrumb">
      <a href="/aquintutor">Aquintutor</a> / {test.test_type}
    </div>

    <div class="badge">
      <span style="width:6px;height:6px;background:var(--fg);border-radius:50%;display:inline-block;"></span>
      {theme.vibe}
    </div>

    <h1>{test.title}</h1>
    {test.description && <p class="lead">{test.description}</p>}

    <div class="meta-grid">
      <div class="meta-tile">
        <p class="meta-num">{test.duration_mins}</p>
        <p class="meta-lbl">minutes</p>
      </div>
      <div class="meta-tile">
        <p class="meta-num">{test.total_questions}</p>
        <p class="meta-lbl">questions</p>
      </div>
      <div class="meta-tile">
        <p class="meta-num">{test.total_marks}</p>
        <p class="meta-lbl">points max</p>
      </div>
      <div class="meta-tile">
        <p class="meta-num">{attemptCount}</p>
        <p class="meta-lbl">takers</p>
      </div>
    </div>

    {userBestScore !== null && (
      <div class="your-best">
        <div>
          <p class="your-best-label">Your best</p>
          <p class="your-best-num">{Math.round(userBestScore)}%</p>
        </div>
        <p style="font-size:12px;color:rgba(255,255,255,0.6);max-width:200px;text-align:right;">Beat your record? Take it again.</p>
      </div>
    )}

    {test.instructions && (
      <div class="info-box">
        <h3>How it works</h3>
        <ul class="info-list">
          {test.instructions.split('\n').filter((l: string) => l.trim()).map((line: string) => <li>{line.trim()}</li>)}
        </ul>
      </div>
    )}

    <div class="info-box">
      <h3>Rules</h3>
      <ul class="info-list">
        <li>You have {test.duration_mins} minutes to complete all questions.</li>
        {test.proctoring_enabled && <li>Webcam access required for face verification.</li>}
        {test.tab_switch_limit > 0 && <li>Switching tabs is tracked. After {test.tab_switch_limit} switches, the test auto-submits.</li>}
        {test.copy_paste_blocked && <li>Copy and paste are disabled.</li>}
        <li>Answers auto-save. If you disconnect, you can resume where you left off.</li>
        {test.show_results_to_candidate && <li>You will see your score immediately after submitting.</li>}
        {!test.show_results_to_candidate && <li>Results will not be shown directly. You can view them in your portal.</li>}
      </ul>
    </div>

    {(blockMsg || notOpen || closed || attemptsExhausted) && (
      <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.35);color:#fca5a5;font-size:13px;padding:10px 14px;border-radius:8px;margin-bottom:12px;text-align:center;">
        {blockMsg || (notOpen ? ('Opens ' + fmtWhen(test.available_from)) : closed ? ('Closed ' + fmtWhen(test.available_until)) : attemptsExhausted ? 'No attempts remaining.' : '')}
      </div>
    )}
    {test.allowed_attempts != null && !attemptsExhausted && (
      <p style="font-size:12px;color:rgba(255,255,255,0.55);text-align:center;margin-bottom:8px;">Attempt {myAttemptsUsed + 1} of {test.allowed_attempts}{test.available_until ? ' · closes ' + fmtWhen(test.available_until) : ''}</p>
    )}

    {offeredLangs.length > 1 && (
      <div style="margin-bottom:12px;text-align:center;">
        <label style="font-size:12px;color:rgba(255,255,255,0.6);margin-right:8px;">Take this test in</label>
        <select id="langSel" style="background:rgba(0,0,0,0.3);border:1px solid rgba(255,255,255,0.2);color:#fff;padding:7px 12px;border-radius:8px;font-size:13px;">
          {offeredLangs.map((c: string) => <option value={c}>{LANG_LABELS[c] || c}</option>)}
        </select>
      </div>
    )}

    {!user && canBegin && !myInProgress && (
      <div style="width:100%;background:rgba(0,0,0,0.25);border:1px solid rgba(255,255,255,0.15);border-radius:12px;padding:14px;margin-bottom:12px;display:flex;flex-direction:column;gap:8px;">
        <p style="font-size:12px;color:rgba(255,255,255,0.7);margin:0 0 2px;">Enter your details to take this test{isPremium && !alreadyPaid ? ' (one-time ' + priceLabel + ')' : ''} - no account needed.</p>
        <input id="gName" type="text" placeholder="Full name" style="width:100%;padding:10px 12px;border-radius:9px;border:1px solid rgba(255,255,255,0.2);background:rgba(0,0,0,0.3);color:#fff;font-size:14px;" />
        <input id="gEmail" type="email" placeholder="Email" style="width:100%;padding:10px 12px;border-radius:9px;border:1px solid rgba(255,255,255,0.2);background:rgba(0,0,0,0.3);color:#fff;font-size:14px;" />
        <div style="display:flex;gap:8px;">
          <select id="gPhoneCountry" style="max-width:42%;padding:10px 8px;border-radius:9px;border:1px solid rgba(255,255,255,0.2);background:rgba(0,0,0,0.3);color:#fff;font-size:13px;">
            {COUNTRIES.map((c: any) => <option value={c.iso} selected={c.iso === 'IN'}>{c.label}</option>)}
          </select>
          <input id="gPhone" type="tel" placeholder="Phone number" style="flex:1;padding:10px 12px;border-radius:9px;border:1px solid rgba(255,255,255,0.2);background:rgba(0,0,0,0.3);color:#fff;font-size:14px;" />
        </div>
        <button type="button" id="guestBeginBtn" class="btn-start" style="border:none;font:inherit;width:100%;">{isPremium && !alreadyPaid ? 'Pay ' + priceLabel + ' & Begin' : 'Begin Test >'}</button>
        <p style="font-size:11px;color:rgba(255,255,255,0.45);margin:2px 0 0;text-align:center;">Have an account? <a href={'/aquintutor/login?next=' + encodeURIComponent('/aquintutor/test/' + slug)} style="color:#fbbf24;text-decoration:underline;">Sign in instead</a></p>
        <p id="guestErr" style="font-size:12px;color:#fca5a5;margin:0;text-align:center;"></p>
      </div>
    )}

    <div class="cta-row">
      {myInProgress ? (
        <a id="beginLink" href={`/aquintutor/test/${slug}/run?resume=1`} class="btn-start">Resume Test</a>
      ) : !canBegin ? (
        <button type="button" class="btn-start" disabled style="opacity:0.5;cursor:not-allowed;border:none;font:inherit;width:100%;">Begin Test &gt;</button>
      ) : !user ? null : (isPremium && !alreadyPaid) ? (
        <button id="enrolBtn" type="button" class="btn-start" style="border:none;font:inherit;width:100%;">
          Pay {priceLabel} &amp; Begin
        </button>
      ) : needsCode ? (
        <div style="width:100%;display:flex;flex-direction:column;gap:8px;">
          <input id="accessCode" type="text" placeholder="Enter access code to begin" style="width:100%;padding:11px 14px;border-radius:10px;border:1px solid rgba(255,255,255,0.2);background:rgba(0,0,0,0.3);color:#fff;font-size:14px;text-align:center;letter-spacing:0.1em;" />
          <button type="button" id="codeBeginBtn" class="btn-start" style="border:none;font:inherit;width:100%;">Begin Test &gt;</button>
        </div>
      ) : (
        <a id="beginLink" href={`/aquintutor/test/${slug}/run`} class="btn-start">Begin Test &gt;</a>
      )}
      <a href="/aquintutor" class="btn-secondary">Browse other tests</a>
    </div>
    <script is:inline define:vars={{ slug }}>
      (function () {
        function lang() { var s = document.getElementById('langSel'); return s && s.value && s.value !== 'en' ? s.value : ''; }
        function withLang(base) { var l = lang(); return l ? (base + (base.indexOf('?') === -1 ? '?' : '&') + 'lang=' + encodeURIComponent(l)) : base; }
        var beginLink = document.getElementById('beginLink');
        var sel = document.getElementById('langSel');
        function syncBegin() { if (beginLink) beginLink.href = withLang(beginLink.getAttribute('href').split('?')[0] + (beginLink.getAttribute('href').indexOf('resume=1') !== -1 ? '?resume=1' : '')); }
        if (sel && beginLink) { sel.addEventListener('change', syncBegin); syncBegin(); }
        var b = document.getElementById('codeBeginBtn');
        if (b) b.addEventListener('click', function () {
          var c = (document.getElementById('accessCode') || {}).value || '';
          window.location.href = withLang('/aquintutor/test/' + slug + '/run?code=' + encodeURIComponent(c.trim()));
        });
      })();
    </script>

    {!user && canBegin && !myInProgress && (
      <>
        {isPremium && !alreadyPaid && <script is:inline src="https://checkout.razorpay.com/v1/checkout.js"></script>}
        <script is:inline define:vars={{ slug }}>
          (function () {
            var btn = document.getElementById('guestBeginBtn'); if (!btn) return;
            var err = document.getElementById('guestErr');
            function lang() { var s = document.getElementById('langSel'); return s && s.value && s.value !== 'en' ? s.value : ''; }
            function go(url) { var l = lang(); window.location.href = l ? (url + (url.indexOf('?') === -1 ? '?' : '&') + 'lang=' + encodeURIComponent(l)) : url; }
            btn.addEventListener('click', function () {
              var name = ((document.getElementById('gName') || {}).value || '').trim();
              var email = ((document.getElementById('gEmail') || {}).value || '').trim();
              var phone = ((document.getElementById('gPhone') || {}).value || '').trim();
              var country = (document.getElementById('gPhoneCountry') || {}).value || 'IN';
              if (err) err.textContent = '';
              var prev = btn.textContent; btn.disabled = true; btn.textContent = 'Starting...';
              fetch('/api/tests/guest-start', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ testSlug: slug, name: name, email: email, phone: phone, phoneCountry: country }) })
                .then(function (r) { return r.json(); }).then(function (d) {
                  if (!d.ok) { btn.disabled = false; btn.textContent = prev; if (err) err.textContent = d.error || 'Could not start.'; return; }
                  if (d.free) { go(d.redirect); return; }
                  if (typeof Razorpay === 'undefined') { btn.disabled = false; btn.textContent = prev; if (err) err.textContent = 'Razorpay failed to load.'; return; }
                  var rzp = new Razorpay({ key: d.keyId, amount: d.amountPaise, currency: d.currency, name: 'EduRankAI', description: d.testTitle || 'Test', order_id: d.orderId, prefill: d.prefill || {}, theme: { color: '#FF4F00' },
                    handler: function (resp) { btn.textContent = 'Verifying...';
                      fetch('/api/tests/guest-confirm', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ razorpay_order_id: resp.razorpay_order_id, razorpay_payment_id: resp.razorpay_payment_id, razorpay_signature: resp.razorpay_signature, testSlug: slug, name: name, email: email, phone: phone }) })
                        .then(function (r) { return r.json(); }).then(function (c) { if (c.ok) { go(c.redirect); } else { btn.disabled = false; btn.textContent = prev; if (err) err.textContent = c.error || 'Verify failed.'; } })
                        .catch(function () { btn.disabled = false; btn.textContent = prev; if (err) err.textContent = 'Network error.'; });
                    },
                    modal: { ondismiss: function () { btn.disabled = false; btn.textContent = prev; } } });
                  rzp.open();
                }).catch(function () { btn.disabled = false; btn.textContent = prev; if (err) err.textContent = 'Network error.'; });
            });
          })();
        </script>
      </>
    )}

    {isPremium && (
      <p style="font-size:11px;color:rgba(255,255,255,0.55);margin-top:10px;text-align:center;">
        {isAdmin ? 'Admin preview - paywall bypassed for staff accounts.' :
         alreadyPaid ? 'Paid - unlimited attempts.' :
         displayCurrency === 'INR'
           ? ('One-time fee of ' + priceLabel + '. Razorpay secure checkout.')
           : ('One-time fee of ' + priceLabel + (inrPreviewLabel ? ' (' + inrPreviewLabel + ' today)' : '') + '. Razorpay charges the INR equivalent at the live ECB rate.')}
      </p>
    )}
    {isPremium && !user && (
      <p style="font-size:12px;color:#fbbf24;margin-top:8px;text-align:center;">
        <a href="/aquintutor/login" style="color:#fbbf24;text-decoration:underline;font-weight:600;">Sign in</a> to start.
      </p>
    )}

    <p style="font-size:11px;color:rgba(255,255,255,0.4);margin-top:20px;text-align:center;">By starting, you agree to take this test honestly. Cheating disqualifies your attempt.</p>
  </div>

  {isPremium && !alreadyPaid && user && (
    <>
      <script is:inline src="https://checkout.razorpay.com/v1/checkout.js"></script>
      <script is:inline define:vars={{ slug, priceLabel, userName: user.name || '', userEmail: user.email || '' }}>
        (function() {
          var btn = document.getElementById('enrolBtn');
          if (!btn) return;
          btn.addEventListener('click', function() {
            var prev = btn.textContent; btn.disabled = true; btn.textContent = 'Starting...';
            fetch('/api/aquintutor/start-test-enrollment', {
              method: 'POST', credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ testSlug: slug }),
            }).then(function(r) { return r.json(); }).then(function(d) {
              if (!d.ok) { btn.disabled = false; btn.textContent = prev; alert(d.error || 'Could not start.'); return; }
              if (d.redirect) { window.location.href = d.redirect; return; }
              if (!d.paid || !d.orderId) { btn.disabled = false; btn.textContent = prev; alert('Unexpected response.'); return; }
              if (typeof Razorpay === 'undefined') { btn.disabled = false; btn.textContent = prev; alert('Razorpay failed to load.'); return; }
              var rzp = new Razorpay({
                key: d.keyId, amount: d.amountPaise, currency: d.currency,
                name: 'EduRankAI - Quantum Challenge', description: d.testTitle, order_id: d.orderId,
                prefill: d.prefill || {},
                theme: { color: '#FF4F00' },
                handler: function(resp) {
                  btn.textContent = 'Verifying...';
                  fetch('/api/aquintutor/confirm-test-payment', {
                    method: 'POST', credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                      razorpay_order_id: resp.razorpay_order_id,
                      razorpay_payment_id: resp.razorpay_payment_id,
                      razorpay_signature: resp.razorpay_signature,
                      testSlug: slug,
                    }),
                  }).then(function(r) { return r.json(); }).then(function(c) {
                    if (c.ok) { window.location.href = c.redirect; }
                    else { btn.disabled = false; btn.textContent = prev; alert(c.error || 'Payment verify failed.'); }
                  }).catch(function() { btn.disabled = false; btn.textContent = prev; alert('Network error.'); });
                },
                modal: { ondismiss: function() { btn.disabled = false; btn.textContent = prev; } },
              });
              rzp.open();
            }).catch(function() { btn.disabled = false; btn.textContent = prev; alert('Network error.'); });
          });
        })();
      </script>
    </>
  )}

  <script is:inline define:vars={{ pattern: theme.pattern, fg: theme.fg }}>
    // Background animations based on theme
    var canvas = document.getElementById('bgCanvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    function hex2rgb(h) {
      h = h.replace('#','');
      var n = parseInt(h, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }
    var rgb = hex2rgb(fg);

    if (pattern === 'matrix') {
      // Matrix code rain for coding theme
      var chars = '01';
      var fontSize = 14;
      var columns = Math.floor(canvas.width / fontSize);
      var drops = Array(columns).fill(1);
      function draw() {
        ctx.fillStyle = 'rgba(0,0,0,0.05)';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = 'rgb(' + rgb.join(',') + ')';
        ctx.font = fontSize + 'px monospace';
        for (var i = 0; i < drops.length; i++) {
          var c = chars[Math.floor(Math.random() * chars.length)];
          ctx.fillText(c, i * fontSize, drops[i] * fontSize);
          if (drops[i] * fontSize > canvas.height && Math.random() > 0.975) drops[i] = 0;
          drops[i]++;
        }
      }
      setInterval(draw, 50);
    } else if (pattern === 'grid') {
      // Grid pattern for aptitude
      function drawGrid() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.strokeStyle = 'rgba(' + rgb.join(',') + ',0.15)';
        ctx.lineWidth = 1;
        var s = 40;
        for (var x = 0; x < canvas.width; x += s) {
          ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, canvas.height); ctx.stroke();
        }
        for (var y = 0; y < canvas.height; y += s) {
          ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(canvas.width, y); ctx.stroke();
        }
      }
      drawGrid();
      window.addEventListener('resize', function() { canvas.width = innerWidth; canvas.height = innerHeight; drawGrid(); });
    } else {
      // Default: floating orbs
      var orbs = [];
      for (var i = 0; i < 25; i++) {
        orbs.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          r: Math.random() * 80 + 20,
          dx: (Math.random() - 0.5) * 0.3,
          dy: (Math.random() - 0.5) * 0.3,
        });
      }
      function drawOrbs() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        for (var o of orbs) {
          var gradient = ctx.createRadialGradient(o.x, o.y, 0, o.x, o.y, o.r);
          gradient.addColorStop(0, 'rgba(' + rgb.join(',') + ',0.15)');
          gradient.addColorStop(1, 'rgba(' + rgb.join(',') + ',0)');
          ctx.fillStyle = gradient;
          ctx.beginPath(); ctx.arc(o.x, o.y, o.r, 0, Math.PI * 2); ctx.fill();
          o.x += o.dx; o.y += o.dy;
          if (o.x < 0 || o.x > canvas.width) o.dx *= -1;
          if (o.y < 0 || o.y > canvas.height) o.dy *= -1;
        }
        requestAnimationFrame(drawOrbs);
      }
      drawOrbs();
      window.addEventListener('resize', function() { canvas.width = innerWidth; canvas.height = innerHeight; });
    }
  </script>
</body>
</html>
