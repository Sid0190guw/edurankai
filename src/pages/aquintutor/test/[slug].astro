---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const { slug } = Astro.params;
const user = Astro.locals.user;

let test: any = null;
try {
  const r = await db.execute(sql`SELECT * FROM tests WHERE slug = ${slug} AND is_published = true LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  test = rows[0] || null;
} catch(e) {}

if (!test) return Astro.redirect('/aquintutor');

let attemptCount = 0;
let userBestScore: number | null = null;
let myInProgress: any = null;
try {
  const r = await db.execute(sql`SELECT COUNT(*)::int as c FROM test_attempts WHERE test_id = ${test.id} AND status IN ('submitted','auto_submitted')`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  attemptCount = (rows[0] as any)?.c || 0;

  if (user) {
    const mybest = await db.execute(sql`SELECT MAX(percentage) as best FROM test_attempts WHERE test_id = ${test.id} AND candidate_id = ${user.id} AND status IN ('submitted','auto_submitted')`);
    const r2 = Array.isArray(mybest) ? mybest : (mybest?.rows || []);
    userBestScore = (r2[0] as any)?.best || null;

    const inprog = await db.execute(sql`SELECT * FROM test_attempts WHERE test_id = ${test.id} AND candidate_id = ${user.id} AND status = 'in_progress' ORDER BY started_at DESC LIMIT 1`);
    const r3 = Array.isArray(inprog) ? inprog : (inprog?.rows || []);
    myInProgress = r3[0] || null;
  }
} catch(e) {}

const CAT_THEMES: Record<string, { bg: string; fg: string; accent: string; pattern: string; vibe: string }> = {
  coding: { bg: '#020c08', fg: '#10b981', accent: '#34d399', pattern: 'matrix', vibe: 'enter the code lab' },
  aptitude: { bg: '#03081a', fg: '#60a5fa', accent: '#93c5fd', pattern: 'grid', vibe: 'sharpen your mind' },
  mcq: { bg: '#1a0a02', fg: '#FF7040', accent: '#FFB088', pattern: 'orbs', vibe: 'fast and focused' },
  subjective: { bg: '#150828', fg: '#a78bfa', accent: '#c4b5fd', pattern: 'waves', vibe: 'think deeply' },
  personality: { bg: '#1a1408', fg: '#fbbf24', accent: '#fcd34d', pattern: 'rings', vibe: 'discover yourself' },
  video: { bg: '#1a0808', fg: '#ef4444', accent: '#fca5a5', pattern: 'pulse', vibe: 'speak up' },
  mixed: { bg: '#1a0a00', fg: '#FF4F00', accent: '#FF7040', pattern: 'mixed', vibe: 'all skills tested' },
};
const theme = (CAT_THEMES as any)[test.test_type] || CAT_THEMES.mixed;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>{test.title} - Aquintutor</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: var(--bg, #08080a);
      color: #fff;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
      --bg: ${theme.bg};
      --fg: ${theme.fg};
      --accent: ${theme.accent};
    }

    /* Animated background patterns */
    .bg-fx { position: fixed; inset: 0; pointer-events: none; opacity: 0.25; }

    /* Top bar */
    .topbar { background: rgba(0,0,0,0.4); border-bottom: 1px solid rgba(255,255,255,0.05); padding: 12px 20px; position: sticky; top: 0; z-index: 10; backdrop-filter: blur(10px); }
    .topbar a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 12px; }

    /* Hero card */
    .container { max-width: 720px; margin: 0 auto; padding: 40px 20px; position: relative; z-index: 1; }

    .breadcrumb { font-size: 11px; color: rgba(255,255,255,0.5); font-family: monospace; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 16px; }
    .breadcrumb a { color: var(--accent); text-decoration: none; }

    h1 { font-size: clamp(32px, 5vw, 48px); font-weight: 900; letter-spacing: -0.02em; line-height: 1.1; margin-bottom: 14px; }
    .lead { font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.6; margin-bottom: 28px; max-width: 560px; }

    .meta-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px; margin-bottom: 32px; }
    .meta-tile { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 14px; text-align: center; }
    .meta-num { font-size: 22px; font-weight: 800; color: var(--fg); font-family: monospace; margin-bottom: 2px; }
    .meta-lbl { font-size: 10px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.1em; }

    .info-box { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 22px; margin-bottom: 24px; }
    .info-box h3 { font-size: 13px; font-weight: 700; color: var(--accent); margin-bottom: 12px; letter-spacing: 0.08em; text-transform: uppercase; }
    .info-list { list-style: none; }
    .info-list li { padding: 6px 0; padding-left: 22px; position: relative; font-size: 14px; color: rgba(255,255,255,0.85); line-height: 1.5; }
    .info-list li::before { content: '>'; position: absolute; left: 0; color: var(--fg); font-weight: bold; }

    .cta-row { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
    .btn-start {
      flex: 1;
      min-width: 200px;
      background: var(--fg);
      color: #000;
      border: none;
      font-size: 16px;
      font-weight: 800;
      padding: 16px 24px;
      border-radius: 12px;
      cursor: pointer;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      transition: transform 0.15s, box-shadow 0.15s;
      text-decoration: none;
      text-align: center;
      display: block;
    }
    .btn-start:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px var(--fg);
    }
    .btn-secondary {
      background: transparent;
      color: rgba(255,255,255,0.7);
      border: 1px solid rgba(255,255,255,0.15);
      font-size: 13px;
      font-weight: 500;
      padding: 14px 20px;
      border-radius: 10px;
      cursor: pointer;
      text-decoration: none;
    }

    .badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; padding: 5px 12px; font-size: 11px; color: var(--accent); margin-bottom: 18px; font-weight: 600; }

    .your-best { background: linear-gradient(135deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02)); border: 1px solid var(--fg); border-radius: 14px; padding: 16px 20px; margin-bottom: 18px; display: flex; align-items: center; justify-content: space-between; gap: 10px; }
    .your-best-label { font-size: 11px; color: rgba(255,255,255,0.6); text-transform: uppercase; letter-spacing: 0.1em; }
    .your-best-num { font-size: 32px; font-weight: 900; color: var(--fg); font-family: monospace; line-height: 1; }

    /* Matrix code rain effect for coding theme */
    .matrix-canvas { width: 100%; height: 100%; }
  </style>
</head>
<body>
  <canvas class="bg-fx" id="bgCanvas"></canvas>

  <nav class="topbar">
    <a href="/aquintutor">&lt; Back to Aquintutor</a>
  </nav>

  <div class="container">
    <div class="breadcrumb">
      <a href="/aquintutor">Aquintutor</a> / {test.test_type}
    </div>

    <div class="badge">
      <span style="width:6px;height:6px;background:var(--fg);border-radius:50%;display:inline-block;"></span>
      {theme.vibe}
    </div>

    <h1>{test.title}</h1>
    {test.description && <p class="lead">{test.description}</p>}

    <div class="meta-grid">
      <div class="meta-tile">
        <p class="meta-num">{test.duration_mins}</p>
        <p class="meta-lbl">minutes</p>
      </div>
      <div class="meta-tile">
        <p class="meta-num">{test.total_questions}</p>
        <p class="meta-lbl">questions</p>
      </div>
      <div class="meta-tile">
        <p class="meta-num">{test.total_marks}</p>
        <p class="meta-lbl">points max</p>
      </div>
      <div class="meta-tile">
        <p class="meta-num">{attemptCount}</p>
        <p class="meta-lbl">takers</p>
      </div>
    </div>

    {userBestScore !== null && (
      <div class="your-best">
        <div>
          <p class="your-best-label">Your best</p>
          <p class="your-best-num">{Math.round(userBestScore)}%</p>
        </div>
        <p style="font-size:12px;color:rgba(255,255,255,0.6);max-width:200px;text-align:right;">Beat your record? Take it again.</p>
      </div>
    )}

    {test.instructions && (
      <div class="info-box">
        <h3>How it works</h3>
        <ul class="info-list">
          {test.instructions.split('\n').filter((l: string) => l.trim()).map((line: string) => <li>{line.trim()}</li>)}
        </ul>
      </div>
    )}

    <div class="info-box">
      <h3>Rules</h3>
      <ul class="info-list">
        <li>You have {test.duration_mins} minutes to complete all questions.</li>
        {test.proctoring_enabled && <li>Webcam access required for face verification.</li>}
        {test.tab_switch_limit > 0 && <li>Switching tabs is tracked. After {test.tab_switch_limit} switches, the test auto-submits.</li>}
        {test.copy_paste_blocked && <li>Copy and paste are disabled.</li>}
        <li>Answers auto-save. If you disconnect, you can resume where you left off.</li>
        {test.show_results_to_candidate && <li>You will see your score immediately after submitting.</li>}
        {!test.show_results_to_candidate && <li>Results will not be shown directly. You can view them in your portal.</li>}
      </ul>
    </div>

    <div class="cta-row">
      {myInProgress ? (
        <a href={`/aquintutor/test/${slug}/run?resume=1`} class="btn-start">Resume Test</a>
      ) : (
        <a href={`/aquintutor/test/${slug}/run`} class="btn-start">Begin Test &gt;</a>
      )}
      <a href="/aquintutor" class="btn-secondary">Browse other tests</a>
    </div>

    <p style="font-size:11px;color:rgba(255,255,255,0.4);margin-top:20px;text-align:center;">By starting, you agree to take this test honestly. Cheating disqualifies your attempt.</p>
  </div>

  <script is:inline define:vars={{ pattern: theme.pattern, fg: theme.fg }}>
    // Background animations based on theme
    var canvas = document.getElementById('bgCanvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    function hex2rgb(h) {
      h = h.replace('#','');
      var n = parseInt(h, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }
    var rgb = hex2rgb(fg);

    if (pattern === 'matrix') {
      // Matrix code rain for coding theme
      var chars = '01';
      var fontSize = 14;
      var columns = Math.floor(canvas.width / fontSize);
      var drops = Array(columns).fill(1);
      function draw() {
        ctx.fillStyle = 'rgba(0,0,0,0.05)';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = 'rgb(' + rgb.join(',') + ')';
        ctx.font = fontSize + 'px monospace';
        for (var i = 0; i < drops.length; i++) {
          var c = chars[Math.floor(Math.random() * chars.length)];
          ctx.fillText(c, i * fontSize, drops[i] * fontSize);
          if (drops[i] * fontSize > canvas.height && Math.random() > 0.975) drops[i] = 0;
          drops[i]++;
        }
      }
      setInterval(draw, 50);
    } else if (pattern === 'grid') {
      // Grid pattern for aptitude
      function drawGrid() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.strokeStyle = 'rgba(' + rgb.join(',') + ',0.15)';
        ctx.lineWidth = 1;
        var s = 40;
        for (var x = 0; x < canvas.width; x += s) {
          ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, canvas.height); ctx.stroke();
        }
        for (var y = 0; y < canvas.height; y += s) {
          ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(canvas.width, y); ctx.stroke();
        }
      }
      drawGrid();
      window.addEventListener('resize', function() { canvas.width = innerWidth; canvas.height = innerHeight; drawGrid(); });
    } else {
      // Default: floating orbs
      var orbs = [];
      for (var i = 0; i < 25; i++) {
        orbs.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          r: Math.random() * 80 + 20,
          dx: (Math.random() - 0.5) * 0.3,
          dy: (Math.random() - 0.5) * 0.3,
        });
      }
      function drawOrbs() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        for (var o of orbs) {
          var gradient = ctx.createRadialGradient(o.x, o.y, 0, o.x, o.y, o.r);
          gradient.addColorStop(0, 'rgba(' + rgb.join(',') + ',0.15)');
          gradient.addColorStop(1, 'rgba(' + rgb.join(',') + ',0)');
          ctx.fillStyle = gradient;
          ctx.beginPath(); ctx.arc(o.x, o.y, o.r, 0, Math.PI * 2); ctx.fill();
          o.x += o.dx; o.y += o.dy;
          if (o.x < 0 || o.x > canvas.width) o.dx *= -1;
          if (o.y < 0 || o.y > canvas.height) o.dy *= -1;
        }
        requestAnimationFrame(drawOrbs);
      }
      drawOrbs();
      window.addEventListener('resize', function() { canvas.width = innerWidth; canvas.height = innerHeight; });
    }
  </script>
</body>
</html>
