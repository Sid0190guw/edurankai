---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const { slug } = Astro.params;
const urlP = new URL(Astro.request.url).searchParams;
const attemptId = urlP.get('attempt');

if (!attemptId) return Astro.redirect('/aquintutor');

let test: any = null;
let attempt: any = null;

try {
  const r = await db.execute(sql`SELECT * FROM tests WHERE slug = ${slug} LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  test = rows[0] || null;

  const r2 = await db.execute(sql`SELECT * FROM test_attempts WHERE id = ${attemptId} LIMIT 1`);
  const rows2 = Array.isArray(r2) ? r2 : (r2?.rows || []);
  attempt = rows2[0] || null;
} catch(e) {}

if (!test || !attempt) return Astro.redirect('/aquintutor');

const percentage = parseFloat(attempt.percentage || '0');
const percentile = parseFloat(attempt.percentile || '0');
const passed = percentage >= (test.pass_mark || 50);
const duration = attempt.duration_seconds || 0;
const minutes = Math.floor(duration / 60);
const seconds = duration % 60;

let rank = '';
let rankColor = '#FF4F00';
if (percentile >= 90) { rank = 'TOP 10%'; rankColor = '#fbbf24'; }
else if (percentile >= 75) { rank = 'TOP 25%'; rankColor = '#10b981'; }
else if (percentile >= 50) { rank = 'ABOVE AVERAGE'; rankColor = '#60a5fa'; }
else if (percentile >= 25) { rank = 'BELOW AVERAGE'; rankColor = '#fbbf24'; }
else { rank = 'KEEP PRACTICING'; rankColor = '#ef4444'; }

const CAT_THEMES: Record<string, any> = {
  coding: { bg: '#020c08', fg: '#10b981' },
  aptitude: { bg: '#03081a', fg: '#60a5fa' },
  mcq: { bg: '#1a0a02', fg: '#FF7040' },
  subjective: { bg: '#150828', fg: '#a78bfa' },
  personality: { bg: '#1a1408', fg: '#fbbf24' },
  video: { bg: '#1a0808', fg: '#ef4444' },
  mixed: { bg: '#1a0a00', fg: '#FF4F00' },
};
const theme = CAT_THEMES[test.test_type] || CAT_THEMES.mixed;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>{passed ? 'Passed' : 'Result'} - {test.title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: var(--bg);
      color: #fff;
      font-family: -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      overflow: hidden;
    }
    .confetti { position: fixed; inset: 0; pointer-events: none; }
    .container { max-width: 560px; width: 100%; text-align: center; position: relative; z-index: 1; }

    .badge-icon {
      width: 110px;
      height: 110px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--fg), rgba(255,255,255,0.1));
      margin: 0 auto 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 56px;
      animation: badgePop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
      box-shadow: 0 0 50px var(--fg);
    }
    @keyframes badgePop {
      0% { transform: scale(0); opacity: 0; }
      60% { transform: scale(1.2); }
      100% { transform: scale(1); opacity: 1; }
    }

    h1 { font-size: clamp(28px, 5vw, 42px); font-weight: 900; letter-spacing: -0.02em; margin-bottom: 8px; }
    .subtitle { font-size: 15px; color: rgba(255,255,255,0.7); margin-bottom: 32px; }

    .score-circle {
      width: 220px;
      height: 220px;
      border-radius: 50%;
      margin: 0 auto 24px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: conic-gradient(var(--fg) 0deg, var(--fg) calc(var(--pct) * 3.6deg), rgba(255,255,255,0.06) calc(var(--pct) * 3.6deg));
      position: relative;
    }
    .score-inner {
      width: 180px;
      height: 180px;
      border-radius: 50%;
      background: var(--bg);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }
    .score-pct { font-size: 60px; font-weight: 900; color: var(--fg); font-family: monospace; line-height: 1; animation: numCount 1.5s ease-out; }
    .score-label { font-size: 11px; color: rgba(255,255,255,0.6); text-transform: uppercase; letter-spacing: 0.15em; margin-top: 4px; }
    @keyframes numCount { from { transform: scale(0.5); opacity: 0; } to { transform: scale(1); opacity: 1; } }

    .rank-badge {
      display: inline-block;
      background: rgba(255,255,255,0.06);
      border: 1px solid;
      border-radius: 100px;
      padding: 8px 20px;
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 0.1em;
      margin-bottom: 28px;
      animation: rankSlide 0.6s ease-out 0.3s both;
    }
    @keyframes rankSlide { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      margin-bottom: 28px;
    }
    .stat-tile {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 12px;
      padding: 16px;
    }
    .stat-val { font-size: 24px; font-weight: 800; color: #fff; font-family: monospace; margin-bottom: 4px; }
    .stat-lbl { font-size: 10px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.1em; }

    .btn { display: inline-block; padding: 13px 24px; border-radius: 10px; font-size: 13px; font-weight: 700; text-decoration: none; letter-spacing: 0.05em; }
    .btn-primary { background: var(--fg); color: #000; }
    .btn-secondary { background: rgba(255,255,255,0.08); color: #fff; border: 1px solid rgba(255,255,255,0.15); }
  </style>
</head>
<body style={`--bg:${theme.bg};--fg:${theme.fg};`}>

  <canvas class="confetti" id="confetti"></canvas>

  <div class="container">
    <div class="badge-icon">{passed ? '*' : '!'}</div>

    <h1>{passed ? 'Nice work!' : 'Good effort!'}</h1>
    <p class="subtitle">{test.title}</p>

    <div class="score-circle" style={`--pct:${Math.round(percentage)};`}>
      <div class="score-inner">
        <p class="score-pct">{Math.round(percentage)}%</p>
        <p class="score-label">{attempt.total_score} / {attempt.max_score} pts</p>
      </div>
    </div>

    {percentile > 0 && (
      <div class="rank-badge" style={`border-color:${rankColor};color:${rankColor};`}>{rank}</div>
    )}

    <div class="stats-grid">
      <div class="stat-tile">
        <p class="stat-val">{minutes}:{seconds < 10 ? '0' : ''}{seconds}</p>
        <p class="stat-lbl">Time taken</p>
      </div>
      <div class="stat-tile">
        <p class="stat-val">{Math.round(percentile)}<span style="font-size:14px;color:rgba(255,255,255,0.5);">%ile</span></p>
        <p class="stat-lbl">Among takers</p>
      </div>
    </div>

    <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;">
      <a href={`/aquintutor/test/${slug}`} class="btn btn-secondary">Try Again</a>
      <a href="/aquintutor" class="btn btn-primary">More Tests &gt;</a>
    </div>
  </div>

  <script is:inline define:vars={{ themeFg: theme.fg, passed: passed }}>
    if (passed) {
      var canvas = document.getElementById('confetti');
      var ctx = canvas.getContext('2d');
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      var pieces = [];
      var colors = [themeFg, '#fff', '#fbbf24', '#10b981'];
      for (var i = 0; i < 80; i++) {
        pieces.push({
          x: Math.random() * canvas.width,
          y: -20,
          w: 8 + Math.random() * 6,
          h: 4 + Math.random() * 4,
          vy: 2 + Math.random() * 3,
          vx: (Math.random() - 0.5) * 2,
          rot: Math.random() * Math.PI * 2,
          vrot: (Math.random() - 0.5) * 0.2,
          color: colors[Math.floor(Math.random() * colors.length)],
        });
      }
      function fall() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        pieces.forEach(function(p) {
          ctx.save();
          ctx.translate(p.x, p.y);
          ctx.rotate(p.rot);
          ctx.fillStyle = p.color;
          ctx.fillRect(-p.w/2, -p.h/2, p.w, p.h);
          ctx.restore();
          p.x += p.vx;
          p.y += p.vy;
          p.rot += p.vrot;
          if (p.y > canvas.height) { p.y = -20; p.x = Math.random() * canvas.width; }
        });
        requestAnimationFrame(fall);
      }
      fall();
    }
  </script>
</body>
</html>
