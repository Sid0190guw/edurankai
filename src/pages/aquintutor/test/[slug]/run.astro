      // /api/tests/log-event every 4s (and on submit / page unload).
      // The candidate sees a warning toast for high-severity events; the
      // admin sees the full trail in /admin/tests/attempts/<id>.
      var eventBuffer = [];
      var totalFlags = 0;
      function logEvent(type, severity, detail) {
        if (submitted) return;
        eventBuffer.push({ type: type, severity: severity || 'info', detail: detail || {}, clientTs: new Date().toISOString() });
        if (severity === 'warn' || severity === 'flag') totalFlags++;
        // Mirror onto right-rail signal cards in real time
        try { updateRailSignal(type, severity); } catch (_) {}
