        try { role = (target.getAttribute && (target.getAttribute('data-action') || target.getAttribute('role') || '')) || ''; } catch (_) {}
        var qIdx = -1, oIdx = -1;
        var node = target;
        for (var i = 0; node && i < 6; i++) {
