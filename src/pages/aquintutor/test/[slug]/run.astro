---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const { slug } = Astro.params;
const user = Astro.locals.user;
const urlP = new URL(Astro.request.url).searchParams;
const resume = urlP.get('resume') === '1';

let test: any = null;
let questions: any[] = [];
let attempt: any = null;

try {
  const r = await db.execute(sql`SELECT * FROM tests WHERE slug = ${slug} AND is_published = true LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  test = rows[0] || null;
} catch(e) {}

if (!test) return Astro.redirect('/aquintutor');

// Guest attempt (no account): tied to the browser by a cookie set at guest-start
// (free) or guest-confirm (after paying). Lets people take the test having only
// given their key details.
const guestCookieId = !user ? (Astro.cookies.get('gat_' + test.id)?.value || null) : null;
let guestAttempt: any = null;
if (guestCookieId) {
  try {
    const gr = await db.execute(sql`SELECT * FROM test_attempts WHERE id = ${guestCookieId} AND test_id = ${test.id} LIMIT 1`);
    const grows = Array.isArray(gr) ? gr : (gr?.rows || []);
    guestAttempt = grows[0] || null;
  } catch (_) {}
}

// Paywall enforcement for premium tests (admin override below)
if (test.is_premium === true && (test.price_inr_paise || 0) >= 100) {
  const isAdmin = user && user.role && ['admin','super_admin','editor','reviewer'].includes(user.role);
  if (!user) {
    // A guest can proceed only with a (paid) guest attempt; otherwise go to the
    // start page to register + pay as a guest.
    if (!guestAttempt) return Astro.redirect('/aquintutor/test/' + slug);
  } else if (!isAdmin) {
    let paid = false;
    try {
      const r = await db.execute(sql`
        SELECT id FROM payments WHERE user_id = ${user.id}
          AND reference_type = 'test' AND reference_id = ${test.id} AND status = 'paid' LIMIT 1
      `);
      const rows = Array.isArray(r) ? r : (r?.rows || []);
      paid = rows.length > 0;
    } catch (_) {}
    if (!paid) return Astro.redirect('/aquintutor/test/' + slug);
  }
}

let allQuestions: any[] = [];
try {
  const r = await db.execute(sql`SELECT id, question_type, question_text, options, code_starter, code_language, marks, difficulty, image_url, category, accepted_answers, answer_tolerance FROM test_questions WHERE test_id = ${test.id} ORDER BY sort_order, created_at`);
  allQuestions = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

if (allQuestions.length === 0) return Astro.redirect('/aquintutor/test/' + slug);

// Find or create attempt
if (guestAttempt) attempt = guestAttempt;
if (!attempt && resume && user) {
  try {
    const r = await db.execute(sql`SELECT * FROM test_attempts WHERE test_id = ${test.id} AND candidate_id = ${user.id} AND status = 'in_progress' ORDER BY started_at DESC LIMIT 1`);
    const rows = Array.isArray(r) ? r : (r?.rows || []);
    attempt = rows[0] || null;
  } catch(e) {}
}

// A guest with no attempt must register via the start page (captures details).
if (!attempt && !user) return Astro.redirect('/aquintutor/test/' + slug);

// Canvas-style gates apply when starting a NEW attempt (resume is exempt).
if (!attempt) {
  const startUrl = '/aquintutor/test/' + slug;
  const now = Date.now();
  // Availability window
  if (test.available_from && now < new Date(test.available_from).getTime()) return Astro.redirect(startUrl + '?blocked=not_open');
  if (test.available_until && now > new Date(test.available_until).getTime()) return Astro.redirect(startUrl + '?blocked=closed');
  // Access code
  if (test.access_code) {
    const provided = (urlP.get('code') || '').trim();
    if (provided !== test.access_code) return Astro.redirect(startUrl + '?blocked=code');
  }
  // Allowed attempts (per candidate)
  if (user && test.allowed_attempts != null) {
    try {
      const ar = await db.execute(sql`SELECT COUNT(*)::int AS c FROM test_attempts WHERE test_id = ${test.id} AND candidate_id = ${user.id} AND status IN ('submitted','auto_submitted')`);
      const arRows = Array.isArray(ar) ? ar : (ar?.rows || []);
      const used = (arRows[0] as any)?.c || 0;
      if (used >= test.allowed_attempts) return Astro.redirect(startUrl + '?blocked=attempts');
    } catch (_) {}
  }
}

if (!attempt) {
  const candidateName = user?.name || 'Anonymous';
  const candidateEmail = user?.email || 'anon-' + Math.random().toString(36).substring(2,10) + '@aquintutor.local';
  const candidateId = user?.id || null;

  try {
    const r = await db.execute(sql`
      INSERT INTO test_attempts (test_id, candidate_id, candidate_email, candidate_name, status, max_score)
      VALUES (${test.id}, ${candidateId}, ${candidateEmail}, ${candidateName}, 'in_progress', ${test.total_marks || 0})
      RETURNING *
    `);
    const rows = Array.isArray(r) ? r : (r?.rows || []);
    attempt = rows[0];
  } catch(e: any) {
    console.error('Failed to create attempt:', e.message);
    return Astro.redirect('/aquintutor/test/' + slug);
  }
}

// ---- Question pool: serve a shuffled subset of N from the bank ------------
// The exact subset + order is persisted per attempt so resume + grading stay
// consistent. If questions_to_show is unset (or >= bank size), serve all.
function shuffle<T>(arr: T[]): T[] {
  const a = arr.slice();
  for (let i = a.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [a[i], a[j]] = [a[j], a[i]]; }
  return a;
}
let servedIds: string[] | null = null;
const rawServed = attempt?.served_question_ids;
if (Array.isArray(rawServed) && rawServed.length > 0) {
  servedIds = rawServed.map((x: any) => String(x));
} else {
  const toShow = parseInt(test.questions_to_show || 0) || 0;
  const wantSubset = toShow > 0 && toShow < allQuestions.length;
  let chosen = allQuestions;
  if (wantSubset) chosen = shuffle(allQuestions).slice(0, toShow);
  if (test.randomize_questions) chosen = shuffle(chosen);
  // Persist when we deviate from the natural full order (subset or randomised).
  if (wantSubset || test.randomize_questions) {
    servedIds = chosen.map((q: any) => String(q.id));
    try { await db.execute(sql`UPDATE test_attempts SET served_question_ids = ${JSON.stringify(servedIds)} WHERE id = ${attempt.id}`); } catch (_) {}
  }
}
if (servedIds) {
  const byId: Record<string, any> = {};
  for (const q of allQuestions) byId[String(q.id)] = q;
  questions = servedIds.map((qid) => byId[qid]).filter(Boolean);
} else {
  questions = allQuestions;
}
if (questions.length === 0) questions = allQuestions;

// Multilingual: overlay approved translations for the chosen language.
const reqLang = (urlP.get('lang') || '').trim();
const offeredLangs = Array.isArray(test.languages) ? test.languages : ['en'];
if (reqLang && reqLang !== 'en' && offeredLangs.includes(reqLang)) {
  try {
    const tr = await db.execute(sql`SELECT question_id, question_text, options FROM test_question_translations WHERE test_id = ${test.id} AND lang = ${reqLang} AND status = 'approved'`);
    const trRows = Array.isArray(tr) ? tr : (tr?.rows || []);
    const trMap: Record<string, any> = {};
    for (const t of trRows as any[]) trMap[t.question_id] = t;
    questions = questions.map((q: any) => {
      const t = trMap[q.id];
      if (!t) return q;
      return { ...q, question_text: t.question_text || q.question_text, options: (Array.isArray(t.options) && t.options.length) ? t.options : q.options };
    });
  } catch (_) {}
}

const existingAnswers = attempt?.answers || {};
const startedAt = attempt?.started_at ? new Date(attempt.started_at) : new Date();
const elapsedSecs = Math.floor((Date.now() - startedAt.getTime()) / 1000);
const remainingSecs = Math.max(0, (test.duration_mins * 60) - elapsedSecs);

// ATLAS-mapped themes. The container bg is uniform deep ATLAS-bg; the
// per-discipline accent ("fg") differs to colour palette/chips/glyphs.
const CAT_THEMES: Record<string, any> = {
  coding:      { bg: '#0b0d10', fg: '#7fb3ff', accent: '#7fb3ff', subjectId: 'ai',       subjectName: 'Coding & AI' },
  aptitude:    { bg: '#0b0d10', fg: '#7dd3a8', accent: '#7dd3a8', subjectId: 'business', subjectName: 'Aptitude' },
  mcq:         { bg: '#0b0d10', fg: '#a78bfa', accent: '#a78bfa', subjectId: 'quantum',  subjectName: 'Quantum / MCQ' },
  subjective:  { bg: '#0b0d10', fg: '#e8b4d0', accent: '#e8b4d0', subjectId: 'liberal',  subjectName: 'Liberal Arts' },
  personality: { bg: '#0b0d10', fg: '#f0b54f', accent: '#f0b54f', subjectId: 'robotics', subjectName: 'Personality' },
  video:       { bg: '#0b0d10', fg: '#e07a6c', accent: '#e07a6c', subjectId: 'design',   subjectName: 'Video' },
  mixed:       { bg: '#0b0d10', fg: '#d97757', accent: '#d97757', subjectId: 'design',   subjectName: 'Mixed' },
};
const theme = CAT_THEMES[test.test_type] || CAT_THEMES.mixed;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>{test.title} - In Progress</title>
  <meta name="robots" content="noindex,nofollow"/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Instrument+Serif:ital@0;1&display=swap" />
  <style is:global>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --atlas-ink: #f4f1ea;
      --atlas-ink-2: #c8c3b8;
      --atlas-ink-3: #8a8579;
      --atlas-surface: #14181d;
      --atlas-surface-2: #1c2128;
      --atlas-border: #2a3038;
      --atlas-bg: #0b0d10;
      --font-sans: "Space Grotesk", system-ui, -apple-system, sans-serif;
      --font-mono: "JetBrains Mono", ui-monospace, SFMono-Regular, monospace;
      --font-serif: "Instrument Serif", "Times New Roman", serif;
    }
    body {
      background: var(--atlas-bg);
      color: var(--atlas-ink);
      font-family: var(--font-sans);
      min-height: 100vh;
      overflow-x: hidden;
      user-select: none;
      -webkit-font-smoothing: antialiased;
    }

    /* COUNTDOWN OVERLAY */
    .countdown {
      position: fixed;
      inset: 0;
      background: var(--bg);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      z-index: 100;
    }
    .count-num {
      font-size: 220px;
      font-weight: 900;
      color: var(--fg);
      font-family: monospace;
      animation: countPulse 1s ease-out;
    }
    .count-label { font-size: 16px; color: rgba(255,255,255,0.7); letter-spacing: 0.3em; text-transform: uppercase; margin-top: 12px; }
    @keyframes countPulse {
      0% { transform: scale(0.3); opacity: 0; }
      50% { transform: scale(1.2); opacity: 1; }
      100% { transform: scale(1); opacity: 1; }
    }
    .go-text { font-size: 120px; font-weight: 900; color: var(--fg); animation: goAnim 0.8s ease-out forwards; }
    @keyframes goAnim {
      0% { transform: scale(0.5); opacity: 0; letter-spacing: 0; }
      50% { transform: scale(1.5); opacity: 1; letter-spacing: 0.3em; }
      100% { transform: scale(1); opacity: 0; }
    }

    /* MAIN GAMEPLAY */
    .game { display: none; min-height: 100vh; flex-direction: column; }
    .game.active { display: flex; }

    /* HUD - ATLAS top bar */
    .hud {
      background: var(--atlas-surface);
      border-bottom: 1px solid var(--atlas-border);
      padding: 12px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 10;
      min-height: 64px;
    }
    .hud-brand { display: flex; align-items: center; gap: 14px; }
    .hud-brand .word {
      font-family: var(--font-serif); font-size: 22px; line-height: 0.9;
      letter-spacing: 0.06em; color: var(--atlas-ink);
      display: inline-flex; align-items: baseline; gap: 4px;
    }
    .hud-brand .word .pin {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--fg); align-self: center; display: inline-block;
      box-shadow: 0 0 8px var(--fg);
    }
    .hud-brand .divider { width: 1px; height: 22px; background: var(--atlas-border); }
    .hud-brand .subj { display: flex; align-items: center; gap: 8px; }
    .hud-brand .subj .glyph { color: var(--fg); display: flex; align-items: center; }
    .hud-brand .subj .name { font-family: var(--font-sans); font-size: 13px; color: var(--atlas-ink); font-weight: 500; }
    .hud-brand .subj .code { font-family: var(--font-mono); font-size: 11px; color: var(--atlas-ink-3); letter-spacing: 0.08em; text-transform: uppercase; }
    .hud-left, .hud-right { display: flex; gap: 10px; align-items: center; }
    .hud-tile {
      background: var(--atlas-surface-2);
      border: 1px solid var(--atlas-border);
      border-radius: 8px;
      padding: 6px 12px;
      font-size: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .hud-tile .label { color: var(--atlas-ink-3); font-size: 9px; text-transform: uppercase; letter-spacing: 0.16em; font-family: var(--font-mono); font-weight: 500; }
    .hud-tile .val { font-weight: 600; color: var(--atlas-ink); font-family: var(--font-mono); font-size: 14px; font-variant-numeric: tabular-nums; }
    .timer-tile .val { font-size: 18px; }
    .timer-tile.warning { background: rgba(240,181,79,0.12); border-color: #f0b54f; }
    .timer-tile.danger { background: rgba(224,122,108,0.16); border-color: #e07a6c; animation: heartbeat 1s infinite; }
    @keyframes heartbeat { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }

    /* PROGRESS PATH */
    .progress-path {
      display: flex;
      gap: 4px;
      padding: 0 20px;
      margin-top: 14px;
      overflow-x: auto;
      scrollbar-width: thin;
    }
    .path-node {
      flex-shrink: 0;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 700;
      color: rgba(255,255,255,0.5);
      cursor: pointer;
      transition: all 0.2s;
    }
    .path-node.current {
      background: var(--fg);
      color: #000;
      transform: scale(1.15);
      box-shadow: 0 0 0 3px rgba(255,255,255,0.1);
    }
    .path-node.answered { background: rgba(255,255,255,0.15); color: #fff; border-color: var(--fg); }
    .path-node.flagged { background: rgba(251,191,36,0.2); border-color: #fbbf24; color: #fbbf24; }

    /* SHELL - 3 columns (left rail, stage, right rail) */
    .shell {
      flex: 1;
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 20px;
      max-width: 1640px;
      width: 100%;
      margin: 0 auto;
      min-height: 0;
    }
    @media (min-width: 960px)  { .shell { grid-template-columns: 260px minmax(0, 1fr); } .rail-right { display: none; } }
    @media (min-width: 1280px) { .shell { grid-template-columns: 260px minmax(0, 1fr) 280px; } .rail-right { display: flex; } }

    .rail { display: flex; flex-direction: column; gap: 12px; min-width: 0; }
    .rail-card {
      background: var(--atlas-surface);
      border: 1px solid var(--atlas-border);
      border-radius: 12px;
      padding: 14px 16px;
    }
    .rail-label {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--atlas-ink-3);
      margin: 0 0 12px;
      font-weight: 500;
    }
    /* Question palette */
    .qpalette {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 6px;
    }
    .qpip {
      aspect-ratio: 1 / 1;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 6px;
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 500;
      background: var(--atlas-surface-2);
      border: 1px solid var(--atlas-border);
      color: var(--atlas-ink-3);
      cursor: pointer;
      transition: background 0.12s, border-color 0.12s, color 0.12s;
      position: relative;
      min-height: 28px;
    }
    .qpip:hover { color: var(--atlas-ink); border-color: var(--atlas-ink-4); }
    .qpip.answered { background: rgba(125,211,168,0.10); border-color: rgba(125,211,168,0.45); color: #7dd3a8; }
    .qpip.current { background: var(--fg); color: #1a0f08; border-color: var(--fg); box-shadow: 0 0 0 2px rgba(217,119,87,0.18); }
    .qpip.flagged::after {
      content: '';
      position: absolute;
      top: 3px; right: 3px;
      width: 6px; height: 6px;
      border-radius: 50%;
      background: #f0b54f;
      box-shadow: 0 0 6px rgba(240,181,79,0.6);
    }
    .qlegend {
      display: flex;
      flex-wrap: wrap;
      gap: 6px 14px;
      margin-top: 12px;
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--atlas-ink-3);
    }
    .qlegend span { display: inline-flex; align-items: center; gap: 5px; }
    .qdot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
    .qdot.dot-current { background: var(--fg); box-shadow: 0 0 6px var(--fg); }
    .qdot.dot-answered { background: #7dd3a8; box-shadow: 0 0 6px #7dd3a8aa; }
    .qdot.dot-flag { background: #f0b54f; box-shadow: 0 0 6px #f0b54faa; }
    .qdot.dot-blank { background: var(--atlas-surface-3); border: 1px solid var(--atlas-border); }

    /* A11y row */
    .a11y-row { display: flex; gap: 6px; flex-wrap: wrap; }
    .a11y-btn {
      flex: 1;
      min-width: 50px;
      padding: 8px 0;
      background: var(--atlas-surface-2);
      border: 1px solid var(--atlas-border);
      color: var(--atlas-ink-2);
      border-radius: 6px;
      cursor: pointer;
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      transition: background 0.12s, color 0.12s;
    }
    .a11y-btn:hover { background: var(--atlas-surface-3); color: var(--atlas-ink); }
    .a11y-btn.on { background: var(--fg); color: #1a0f08; border-color: var(--fg); }
    .a11y-help { font-family: var(--font-mono); font-size: 10px; color: var(--atlas-ink-3); margin: 10px 0 0; line-height: 1.5; }

    /* Proctor cam card */
    .cam-card { padding: 12px; }
    .cam-head { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
    .rec-dot { width: 8px; height: 8px; border-radius: 50%; background: #e07a6c; box-shadow: 0 0 10px #e07a6c; animation: recPulse 1.2s infinite; }
    @keyframes recPulse { 0%,100% { opacity: 1; } 50% { opacity: 0.45; } }
    .cam-lbl { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--atlas-ink); font-weight: 600; }
    .cam-sub { font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--atlas-ink-3); margin-left: auto; }

    /* Signals */
    .signal-row { display: flex; align-items: center; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid var(--atlas-border); font-family: var(--font-mono); font-size: 11px; color: var(--atlas-ink-2); letter-spacing: 0.08em; text-transform: uppercase; }
    .signal-row:last-child { border-bottom: 0; }
    .signal-row .sig { display: inline-flex; align-items: center; gap: 6px; color: #7dd3a8; }
    .signal-row .sig.warn { color: #f0b54f; }
    .signal-row .sig.bad { color: #e07a6c; }
    .signal-row .sdot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; box-shadow: 0 0 6px currentColor; }

    /* Question (existing) */
    .stage {
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding: 20px 0;
      min-width: 0;
    }
    .question-card {
      background: var(--atlas-surface);
      border: 1px solid var(--atlas-border);
      border-radius: 16px;
      padding: 36px 44px;
      max-width: 820px;
      width: 100%;
      animation: slideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      box-shadow: 0 24px 60px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.03);
    }
    @media (min-width: 1280px) { .question-card { padding: 44px 52px; } .q-text { font-size: clamp(24px, 2vw, 30px); } }
    @keyframes slideIn { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

    .q-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 18px; flex-wrap: wrap; }
    .q-meta-pill {
      font-size: 10px; font-weight: 500; padding: 4px 10px; border-radius: 999px;
      text-transform: uppercase; letter-spacing: 0.16em; font-family: var(--font-mono);
      background: var(--atlas-surface-2); border: 1px solid var(--atlas-border); color: var(--atlas-ink-2);
    }
    .q-text {
      font-family: var(--font-serif);
      font-size: clamp(22px, 2.4vw, 30px);
      font-weight: 400;
      color: var(--atlas-ink);
      line-height: 1.35;
      margin-bottom: 28px;
      user-select: text;
    }
    .q-text code { background: var(--atlas-surface-2); padding: 2px 6px; border-radius: 4px; font-family: var(--font-mono); font-size: 0.85em; color: var(--accent); }

    /* OPTIONS (MCQ) */
    #qAnswerArea .options {
      display: flex !important;
      flex-direction: column !important;
      flex-wrap: nowrap !important;
      gap: 10px !important;
      width: 100% !important;
      max-width: 100% !important;
    }
    #qAnswerArea .option {
      background: var(--atlas-surface-2);
      border: 1px solid var(--atlas-border);
      border-radius: 10px;
      padding: 14px 18px;
      cursor: pointer;
      display: flex !important;
      flex-direction: row !important;
      align-items: center;
      gap: 14px;
      transition: background 0.12s, border-color 0.12s, transform 0.12s;
      text-align: left;
      width: 100% !important;
      min-width: 0;
      box-sizing: border-box;
      color: var(--atlas-ink);
      font-family: var(--font-sans);
      font-size: 15px;
      margin: 0;
    }
    #qAnswerArea .option:hover { background: #21262d; border-color: var(--atlas-ink-4); transform: translateX(2px); }
    #qAnswerArea .option.selected { background: rgba(217,119,87,0.12); border-color: var(--fg); }
    #qAnswerArea .option-letter {
      width: 32px !important;
      height: 32px !important;
      min-width: 32px !important;
      border-radius: 8px;
      background: var(--atlas-surface-3);
      border: 1px solid var(--atlas-border);
      display: inline-flex !important;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      font-size: 12px;
      font-family: var(--font-mono);
      flex-shrink: 0;
      color: var(--atlas-ink-2);
      transition: all 0.12s;
      margin-right: 4px;
    }
    #qAnswerArea .option.selected .option-letter { background: var(--fg); color: #1a0f08; border-color: var(--fg); }
    #qAnswerArea .option-text { flex: 1 1 auto; line-height: 1.5; min-width: 0; word-wrap: break-word; }

    /* TEXT ANSWER */
    .text-answer {
      width: 100%;
      background: var(--atlas-surface-2);
      border: 1px solid var(--atlas-border);
      border-radius: 8px;
      padding: 14px 18px;
      color: var(--atlas-ink);
      font-size: 15px;
      font-family: var(--font-serif);
      resize: vertical;
      outline: none;
      transition: border-color 0.12s;
    }
    .text-answer:focus { border-color: var(--fg); }

    /* CODE EDITOR */
    .code-editor {
      width: 100%;
      background: var(--atlas-bg);
      border: 1px solid var(--atlas-border);
      border-radius: 8px;
      padding: 16px;
      color: #7dd3a8;
      font-size: 13px;
      font-family: var(--font-mono);
      resize: vertical;
      outline: none;
      min-height: 240px;
      line-height: 1.6;
      tab-size: 2;
    }
    .code-editor:focus { border-color: var(--fg); }

    /* BOTTOM NAV */
    .nav-bar {
      background: var(--atlas-surface);
      border-top: 1px solid var(--atlas-border);
      padding: 14px 20px;
      display: flex;
      gap: 8px;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      bottom: 0;
    }
    .nav-btn {
      background: var(--atlas-surface-2);
      border: 1px solid var(--atlas-border);
      color: var(--atlas-ink);
      font-size: 13px;
      font-weight: 600;
      padding: 10px 18px;
      border-radius: 8px;
      cursor: pointer;
      font-family: var(--font-sans);
      transition: background 0.12s, border-color 0.12s;
    }
    .nav-btn:hover { background: var(--atlas-surface-3); border-color: var(--atlas-ink-4); }
    .nav-btn.primary { background: var(--fg); color: #1a0f08; border-color: var(--fg); box-shadow: 0 0 18px rgba(217,119,87,0.25); }
    .nav-btn.primary:hover { background: var(--terracotta-d, #b85e3f); }
    .nav-btn.flag { background: transparent; border-color: #f0b54f; color: #f0b54f; }
    .nav-btn.flag.active { background: #fbbf24; color: #000; }
    .nav-btn.submit-final { background: linear-gradient(135deg, #10b981, #34d399); border-color: #10b981; color: #000; font-weight: 800; }

    /* TOAST */
    .toast {
      position: fixed;
      top: 20px;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(0,0,0,0.9);
      border: 1px solid rgba(255,255,255,0.15);
      color: #fff;
      font-size: 13px;
      padding: 12px 22px;
      border-radius: 100px;
      z-index: 50;
      animation: toastIn 0.3s ease-out;
    }
    @keyframes toastIn { from { opacity: 0; transform: translate(-50%, -10px); } to { opacity: 1; transform: translate(-50%, 0); } }
    .toast.warn { border-color: #fbbf24; color: #fbbf24; }

    /* PHASE 1: GAMIFICATION */
    .streak-tile {
      background: linear-gradient(135deg, rgba(251,191,36,0.18), rgba(251,140,0,0.18));
      border: 1px solid rgba(251,191,36,0.4);
      color: #fcd34d;
      transition: transform 0.18s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .streak-tile.bump { transform: scale(1.18); }
    .streak-tile .label { color: rgba(252,211,77,0.7); }
    .streak-tile .val { color: #fcd34d; }
    .streak-flame { display: inline-block; font-size: 14px; line-height: 1; margin-right: 4px; filter: drop-shadow(0 0 6px rgba(251,191,36,0.6)); }

    /* Particle canvas */
    #fxCanvas {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 45;
    }

    /* "FLOW!" stamp */
    .flow-stamp {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) rotate(-12deg) scale(0);
      font-size: clamp(80px, 18vw, 220px);
      font-weight: 900;
      font-family: 'SF Pro Display', system-ui, sans-serif;
      letter-spacing: -0.04em;
      background: linear-gradient(135deg, #fcd34d, #f97316, #ef4444);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      filter: drop-shadow(0 8px 32px rgba(251,191,36,0.5));
      z-index: 60;
      pointer-events: none;
      opacity: 0;
    }
    .flow-stamp.show {
      animation: flowStamp 2.2s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }
    @keyframes flowStamp {
      0% { transform: translate(-50%, -50%) rotate(-22deg) scale(0); opacity: 0; }
      30% { transform: translate(-50%, -50%) rotate(-8deg) scale(1.3); opacity: 1; }
      60% { transform: translate(-50%, -50%) rotate(-12deg) scale(1); opacity: 1; }
      85% { opacity: 1; }
      100% { transform: translate(-50%, -50%) rotate(-12deg) scale(1.05); opacity: 0; }
    }

    /* Combo popup */
    .combo-pop {
      position: absolute;
      font-size: 18px;
      font-weight: 800;
      color: #fcd34d;
      text-shadow: 0 2px 12px rgba(251,191,36,0.8);
      pointer-events: none;
      z-index: 55;
      animation: comboPop 1s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }
    @keyframes comboPop {
      0% { transform: translate(-50%, 0) scale(0.4); opacity: 0; }
      30% { transform: translate(-50%, -16px) scale(1.2); opacity: 1; }
      100% { transform: translate(-50%, -50px) scale(0.9); opacity: 0; }
    }

    /* ===== Mobile + tablet optimisations ===== */
    .mobile-fab { display: none; }
    .mobile-palette { display: none; }
    @media (max-width: 959px) {
      .shell { padding: 12px; gap: 10px; }
      .question-card { padding: 18px 16px; border-radius: 12px; }
      .q-text { font-size: clamp(17px, 4.4vw, 22px); line-height: 1.4; margin-bottom: 18px; }
      #qAnswerArea .option { padding: 14px 14px; font-size: 14.5px; gap: 10px; min-height: 56px; align-items: center; }
      #qAnswerArea .option-letter { width: 30px !important; height: 30px !important; min-width: 30px !important; font-size: 11.5px; }
      .nav-bar { padding: 10px 10px calc(10px + env(safe-area-inset-bottom)); gap: 6px; background: var(--atlas-surface); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); }
      .nav-btn { padding: 12px 10px; font-size: 13px; flex: 1 1 0; min-width: 0; }
      .nav-btn.flag { flex: 0 0 auto; padding: 12px 12px; }
      .hud-tile .label { font-size: 9px; }
      .hud-tile .val { font-size: 14px; }
      .progress-path { display: none; }
      .stage { padding: 4px 0; }
      .text-answer { font-size: 15px; padding: 12px 14px; min-height: 110px; }
      .code-editor { font-size: 13px; min-height: 200px; }
      /* Floating Questions/Tools FAB so candidates can still access the palette */
      .mobile-fab {
        display: flex;
        position: fixed;
        right: 14px;
        bottom: calc(72px + env(safe-area-inset-bottom));
        z-index: 40;
        flex-direction: column;
        gap: 8px;
      }
      .mobile-fab button {
        width: 48px; height: 48px;
        border-radius: 50%;
        border: 1px solid var(--atlas-border);
        background: var(--atlas-surface);
        color: var(--atlas-ink);
        font-family: var(--font-mono);
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 6px 24px rgba(0,0,0,0.45);
      }
      .mobile-fab button.primary { background: var(--fg); color: #1a0f08; border-color: var(--fg); }
      /* Bottom-sheet drawer for palette */
      .mobile-palette {
        display: block;
        position: fixed; inset: auto 0 0 0;
        background: var(--atlas-surface);
        border-top: 1px solid var(--atlas-border);
        border-radius: 18px 18px 0 0;
        padding: 14px 16px calc(20px + env(safe-area-inset-bottom));
        transform: translateY(105%);
        transition: transform .25s cubic-bezier(.16,1,.3,1);
        z-index: 80;
        max-height: 70vh;
        overflow-y: auto;
        box-shadow: 0 -16px 50px rgba(0,0,0,.5);
      }
      .mobile-palette.show { transform: translateY(0); }
      .mobile-palette .handle { width: 40px; height: 4px; background: var(--atlas-ink-4); border-radius: 4px; margin: 0 auto 12px; }
      .mobile-palette .qpalette { grid-template-columns: repeat(6, 1fr); gap: 8px; }
      .mobile-palette .qpip { min-height: 44px; font-size: 13px; }
      .mobile-palette .sheet-section { margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--atlas-border); }
      .mobile-palette .sheet-title { font-family: var(--font-mono); font-size: 10px; letter-spacing: .14em; text-transform: uppercase; color: var(--atlas-ink-3); margin-bottom: 8px; font-weight: 600; }
      .scrim { position: fixed; inset: 0; background: rgba(0,0,0,.55); z-index: 79; opacity: 0; pointer-events: none; transition: opacity .2s; }
      .scrim.show { opacity: 1; pointer-events: auto; }
    }
    @media (max-width: 380px) {
      .nav-btn.flag { padding: 12px 8px; font-size: 11.5px; }
      .nav-btn { font-size: 12.5px; }
      .question-card { padding: 14px 12px; }
    }
    @media (prefers-reduced-motion: reduce) {
      .streak-tile, .streak-tile.bump { transform: none !important; transition: none; }
      .flow-stamp, .combo-pop { animation: none !important; }
      .flow-stamp.show { opacity: 1; transform: translate(-50%, -50%) rotate(-12deg) scale(1); }
    }

    /* SUBMIT CONFIRM */
    .confirm-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.8); backdrop-filter: blur(10px); z-index: 200; display: none; align-items: center; justify-content: center; padding: 20px; }
    .confirm-overlay.show { display: flex; }
    .confirm-box { background: #0a0a0c; border: 1px solid rgba(255,255,255,0.15); border-radius: 16px; padding: 32px; max-width: 440px; width: 100%; text-align: center; }
    .confirm-box h2 { font-size: 24px; font-weight: 800; color: #fff; margin-bottom: 10px; }
    .confirm-box p { font-size: 14px; color: rgba(255,255,255,0.7); line-height: 1.6; margin-bottom: 20px; }
    .confirm-stat { background: rgba(255,255,255,0.05); border-radius: 8px; padding: 10px 14px; margin-bottom: 8px; display: flex; justify-content: space-between; font-size: 13px; }
    .confirm-actions { display: flex; gap: 10px; margin-top: 22px; }
  </style>

  <style is:global>/* test-runner-reset */
    body.era-no-fab { padding-bottom: 0 !important; }
  </style>
</head>
<body class="era-no-fab" style={`--bg:${theme.bg};--fg:${theme.fg};--accent:${theme.accent};`}>

  <!-- COUNTDOWN -->
  <div class="countdown" id="countdown">
    <div class="count-num" id="countNum">3</div>
    <p class="count-label">Get ready</p>
  </div>

  <!-- MAIN GAME -->
  <div class="game" id="game">
    <!-- HUD - ATLAS top bar -->
    <div class="hud">
      <div class="hud-brand">
        <div class="word"><span>ATLAS</span><span class="pin"></span></div>
        <div class="divider"></div>
        <div class="subj">
          <span class="glyph">
            {theme.subjectId === 'quantum' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <ellipse cx="12" cy="12" rx="9" ry="3.5"/>
                <ellipse cx="12" cy="12" rx="9" ry="3.5" transform="rotate(60 12 12)"/>
                <ellipse cx="12" cy="12" rx="9" ry="3.5" transform="rotate(120 12 12)"/>
                <circle cx="12" cy="12" r="1.4" fill="currentColor" stroke="none"/>
              </svg>
            )}
            {theme.subjectId === 'ai' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <rect x="6" y="6" width="12" height="12" rx="2"/>
                <path d="M9 3v3M15 3v3M9 18v3M15 18v3M3 9h3M3 15h3M18 9h3M18 15h3"/>
                <circle cx="12" cy="12" r="2" fill="currentColor" stroke="none"/>
              </svg>
            )}
            {theme.subjectId === 'business' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 18l5-5 4 3 8-9"/>
                <path d="M15 7h5v5"/>
              </svg>
            )}
            {theme.subjectId === 'design' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 20L12 4l9 16"/>
                <path d="M7 20l5-9 5 9"/>
              </svg>
            )}
            {(theme.subjectId === 'liberal' || theme.subjectId === 'robotics') && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="6"/>
                <circle cx="12" cy="12" r="2" fill="currentColor" stroke="none"/>
              </svg>
            )}
          </span>
          <span class="name">{test.title}</span>
        </div>
      </div>
      <div class="hud-left" style="gap:8px;">
        <div class="hud-tile">
          <span class="label">Q</span>
          <span class="val"><span id="qCurrent">1</span>/{questions.length}</span>
        </div>
        <div class="hud-tile">
          <span class="label">Answered</span>
          <span class="val" id="answeredCount">0</span>
        </div>
      </div>
      <div class="hud-right">
        <div class="hud-tile streak-tile" id="streakTile" style="display:none;">
          <span class="label">Streak</span>
          <span class="val" id="streakVal" style="color:#f0b54f;">0</span>
        </div>
        <div class="hud-tile timer-tile" id="timerTile">
          <span class="label">Time</span>
          <span class="val" id="timer">00:00</span>
        </div>
      </div>
    </div>

    <!-- Progress path -->
    <div class="progress-path" id="progressPath"></div>

    <!-- 3-COLUMN TEST SHELL (ATLAS scene 3) -->
    <div class="shell">
      <!-- LEFT RAIL: question palette + accessibility toggles -->
      <aside class="rail rail-left" id="leftRail">
        <div class="rail-card">
          <p class="rail-label">Question palette</p>
          <div class="qpalette" id="qPalette"></div>
          <div class="qlegend">
            <span><span class="qdot dot-current"></span>current</span>
            <span><span class="qdot dot-answered"></span>answered</span>
            <span><span class="qdot dot-flag"></span>flagged</span>
            <span><span class="qdot dot-blank"></span>unanswered</span>
          </div>
        </div>
        <div class="rail-card">
          <p class="rail-label">Accessibility</p>
          <div class="a11y-row">
            <button type="button" class="a11y-btn" id="a11yFont" data-toggle="font">A+</button>
            <button type="button" class="a11y-btn" id="a11yTts" data-toggle="tts">TTS</button>
            <button type="button" class="a11y-btn" id="a11yDys" data-toggle="dys">DYS</button>
            <button type="button" class="a11y-btn" id="a11yExt" data-toggle="ext">+T</button>
          </div>
          <p class="a11y-help">A+ font size &middot; TTS read-aloud &middot; DYS dyslexia mode &middot; +T extra-time request</p>
        </div>
      </aside>

      <!-- CENTER: question -->
      <div class="stage">
        <div class="question-card" id="qCard">
          <div class="q-meta" id="qMeta"></div>
          <div class="q-text" id="qText"></div>
          <div id="qAnswerArea"></div>
        </div>
      </div>

      <!-- RIGHT RAIL: proctor cam + signals + scratch -->
      <aside class="rail rail-right" id="rightRail">
        <div class="rail-card cam-card" id="proctorCard" style="display:none;">
          <div class="cam-head">
            <span class="rec-dot"></span>
            <span class="cam-lbl">LIVE PROCTOR</span>
            <span class="cam-sub">no recording</span>
          </div>
          <video id="proctorVideo" autoplay playsinline muted style="width:100%; aspect-ratio:4/3; background:#000; border-radius:8px; object-fit:cover; transform:scaleX(-1);"></video>
        </div>
        <div class="rail-card">
          <p class="rail-label">Signals</p>
          <div class="signal-row"><span>Gaze</span><span class="sig" id="sigGaze"><span class="sdot"></span><span>steady</span></span></div>
          <div class="signal-row"><span>Audio</span><span class="sig" id="sigAudio"><span class="sdot"></span><span>quiet</span></span></div>
          <div class="signal-row"><span>Focus</span><span class="sig" id="sigFocus"><span class="sdot"></span><span>in-tab</span></span></div>
          <div class="signal-row"><span>Network</span><span class="sig" id="sigNet"><span class="sdot"></span><span>online</span></span></div>
        </div>
        <div class="rail-card">
          <p class="rail-label">Scratch pad</p>
          <textarea id="scratchPad" placeholder="Working notes - autosaved per-question, only visible to you" style="width:100%; min-height:140px; background:var(--atlas-bg); border:1px solid var(--atlas-border); border-radius:8px; padding:10px 12px; color:var(--atlas-ink); font-family:var(--font-mono); font-size:12px; line-height:1.5; resize:vertical; outline:none;"></textarea>
        </div>
      </aside>
    </div>

    <!-- Bottom nav -->
    <div class="nav-bar">
      <button class="nav-btn" id="prevBtn">&lt; Previous</button>
      <button class="nav-btn flag" id="flagBtn">Flag for review</button>
      <button class="nav-btn primary" id="nextBtn">Next &gt;</button>
      <button class="nav-btn submit-final" id="submitBtn" style="display:none;">Submit Test</button>
    </div>
  </div>

  <!-- Mobile bottom-sheet (palette + accessibility) -->
  <div class="scrim" id="mobileScrim"></div>
  <div class="mobile-palette" id="mobilePalette">
    <div class="handle"></div>
    <p class="sheet-title">Question palette</p>
    <div class="qpalette" id="qPaletteMobile"></div>
    <div class="qlegend" style="margin-top:10px;">
      <span><span class="qdot dot-current"></span>current</span>
      <span><span class="qdot dot-answered"></span>answered</span>
      <span><span class="qdot dot-flag"></span>flagged</span>
      <span><span class="qdot dot-blank"></span>unanswered</span>
    </div>
    <div class="sheet-section">
      <p class="sheet-title">Accessibility</p>
      <div class="a11y-row">
        <button type="button" class="a11y-btn" data-mobile-a11y="font">A+</button>
        <button type="button" class="a11y-btn" data-mobile-a11y="tts">TTS</button>
        <button type="button" class="a11y-btn" data-mobile-a11y="dys">DYS</button>
        <button type="button" class="a11y-btn" data-mobile-a11y="ext">+T</button>
      </div>
    </div>
  </div>
  <div class="mobile-fab">
    <button type="button" id="mobilePaletteBtn" class="primary" aria-label="Open question palette">Q&middot;<span id="mobileFabCount">1</span></button>
  </div>

  <script is:inline>
    (function () {
      var btn = document.getElementById('mobilePaletteBtn');
      var sheet = document.getElementById('mobilePalette');
      var scrim = document.getElementById('mobileScrim');
      var palMobile = document.getElementById('qPaletteMobile');
      if (!btn || !sheet || !scrim || !palMobile) return;
      function open() { sheet.classList.add('show'); scrim.classList.add('show'); syncMobile(); }
      function close() { sheet.classList.remove('show'); scrim.classList.remove('show'); }
      btn.addEventListener('click', function () { sheet.classList.contains('show') ? close() : open(); });
      scrim.addEventListener('click', close);
      function syncMobile() {
        var src = document.getElementById('qPalette');
        if (!src) return;
        palMobile.innerHTML = src.innerHTML;
        palMobile.querySelectorAll('.qpip').forEach(function (p) {
          p.addEventListener('click', function () {
            var idx = parseInt(p.getAttribute('data-idx') || '0', 10);
            var orig = src.querySelector('.qpip[data-idx="' + idx + '"]');
            if (orig) orig.click();
            close();
          });
        });
      }
      document.querySelectorAll('[data-mobile-a11y]').forEach(function (b) {
        b.addEventListener('click', function () {
          var k = b.getAttribute('data-mobile-a11y');
          var target = document.getElementById('a11y' + k.charAt(0).toUpperCase() + k.slice(1));
          if (target) target.click();
          b.classList.toggle('on');
        });
      });
      // Keep the count chip on the FAB up to date
      var countEl = document.getElementById('mobileFabCount');
      var qcur = document.getElementById('qCurrent');
      if (countEl && qcur) {
        var ob = new MutationObserver(function () { countEl.textContent = qcur.textContent; });
        ob.observe(qcur, { childList: true, characterData: true, subtree: true });
      }
    })();
  </script>

  <!-- Particle FX canvas + "FLOW!" stamp -->
  <canvas id="fxCanvas"></canvas>
  <div class="flow-stamp" id="flowStamp">FLOW!</div>

  <!-- SUBMIT CONFIRM -->
  <div class="confirm-overlay" id="confirmOverlay">
    <div class="confirm-box">
      <h2>Submit Test?</h2>
      <p>You can't change answers after submission.</p>
      <div class="confirm-stat"><span style="color:rgba(255,255,255,0.6);">Answered</span><span id="confAnswered">0</span></div>
      <div class="confirm-stat"><span style="color:rgba(255,255,255,0.6);">Unanswered</span><span id="confUnanswered">0</span></div>
      <div class="confirm-stat"><span style="color:rgba(255,255,255,0.6);">Flagged</span><span id="confFlagged">0</span></div>
      <div class="confirm-actions">
        <button class="nav-btn" id="confirmCancel" type="button" style="flex:1;">Keep going</button>
        <button class="nav-btn submit-final" id="confirmYes" type="button" style="flex:1;">Yes, Submit</button>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{
    questions: questions,
    existingAnswers: existingAnswers,
    remainingSecs: remainingSecs,
    attemptId: attempt.id,
    testSlug: slug,
    fg: theme.fg,
    copyPasteBlocked: !!test.copy_paste_blocked,
    fullscreenRequired: !!test.fullscreen_required,
    enableCameraMonitor: !!(test.proctoring_enabled || test.webcam_required || test.is_premium),
    enableMicMonitor: !!(test.proctoring_enabled || test.is_premium)
  }}>
    var currentIdx = 0;
    var answers = existingAnswers || {};
    var flagged = {};
    var tabSwitches = 0;
    var timeLeft = remainingSecs;
    var saveTimer = null;
    var submitted = false;
    var streak = 0;
    var streakHighWater = 0;
    var flowShown = false;
    var prefersReducedMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ---- Phase 1: GAMIFICATION ----
    // Web Audio synth - no asset files needed
    var audioCtx = null;
    function getAudio() {
      if (audioCtx) return audioCtx;
      try {
        audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      } catch (e) { return null; }
      return audioCtx;
    }
    function playTone(freq, durMs, type, gainVal) {
      var ctx = getAudio();
      if (!ctx) return;
      try {
        var osc = ctx.createOscillator();
        var gain = ctx.createGain();
        osc.type = type || 'sine';
        osc.frequency.value = freq;
        gain.gain.value = gainVal || 0.08;
        gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + durMs / 1000);
        osc.connect(gain); gain.connect(ctx.destination);
        osc.start(); osc.stop(ctx.currentTime + durMs / 1000);
      } catch (e) {}
    }
    function sndTap() { playTone(660, 80, 'triangle', 0.06); }
    function sndStreak() {
      playTone(880, 90, 'triangle', 0.07);
      setTimeout(function() { playTone(1320, 120, 'triangle', 0.07); }, 70);
    }
    function sndFlow() {
      var notes = [523, 659, 784, 1047];
      notes.forEach(function(n, i) {
        setTimeout(function() { playTone(n, 200, 'triangle', 0.09); }, i * 90);
      });
    }

    // Canvas particle burst
    var fxCanvas = document.getElementById('fxCanvas');
    var fxCtx = null;
    var particles = [];
    function resizeFx() {
      if (!fxCanvas) return;
      fxCanvas.width = window.innerWidth;
      fxCanvas.height = window.innerHeight;
    }
    function initFx() {
      if (!fxCanvas) return;
      fxCtx = fxCanvas.getContext('2d');
      resizeFx();
      window.addEventListener('resize', resizeFx);
      requestAnimationFrame(fxLoop);
    }
    function fxLoop() {
      if (!fxCtx) return;
      fxCtx.clearRect(0, 0, fxCanvas.width, fxCanvas.height);
      var keep = [];
      for (var i = 0; i < particles.length; i++) {
        var p = particles[i];
        p.x += p.vx; p.y += p.vy;
        p.vy += 0.18; // gravity
        p.life -= 1;
        if (p.life > 0) {
          fxCtx.globalAlpha = Math.max(0, p.life / p.maxLife);
          fxCtx.fillStyle = p.color;
          fxCtx.beginPath();
          fxCtx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          fxCtx.fill();
          keep.push(p);
        }
      }
      particles = keep;
      fxCtx.globalAlpha = 1;
      requestAnimationFrame(fxLoop);
    }
    function burst(x, y, color, count) {
      if (prefersReducedMotion) return;
      count = count || 18;
      for (var i = 0; i < count; i++) {
        var angle = Math.random() * Math.PI * 2;
        var speed = 2 + Math.random() * 5;
        particles.push({
          x: x, y: y,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed - 2,
          size: 2 + Math.random() * 3,
          color: color || (fg || '#FF7040'),
          life: 40 + Math.random() * 20,
          maxLife: 60
        });
      }
    }
    function confetti() {
      if (prefersReducedMotion) return;
      var cols = ['#fcd34d', '#f97316', '#ef4444', '#10b981', '#60a5fa', '#a78bfa'];
      var w = window.innerWidth;
      for (var i = 0; i < 80; i++) {
        particles.push({
          x: Math.random() * w,
          y: -10 - Math.random() * 40,
          vx: (Math.random() - 0.5) * 4,
          vy: 1 + Math.random() * 2,
          size: 3 + Math.random() * 4,
          color: cols[Math.floor(Math.random() * cols.length)],
          life: 120 + Math.random() * 60,
          maxLife: 180
        });
      }
    }

    // Streak handling
    function bumpStreak(fromEvent) {
      streak++;
      if (streak > streakHighWater) streakHighWater = streak;
      var tile = document.getElementById('streakTile');
      var val = document.getElementById('streakVal');
      if (tile && val) {
        if (streak >= 2) tile.style.display = '';
        val.textContent = streak;
        tile.classList.remove('bump');
        // force reflow then re-add for re-trigger
        void tile.offsetWidth;
        tile.classList.add('bump');
        setTimeout(function() { tile.classList.remove('bump'); }, 250);
      }
      // Combo pop near the event location
      if (streak >= 3 && fromEvent) {
        var pop = document.createElement('div');
        pop.className = 'combo-pop';
        pop.textContent = streak >= 5 ? streak + 'x COMBO!' : streak + ' in a row!';
        pop.style.left = fromEvent.clientX + 'px';
        pop.style.top = fromEvent.clientY + 'px';
        document.body.appendChild(pop);
        setTimeout(function() { pop.remove(); }, 1000);
        sndStreak();
      } else {
        sndTap();
      }
    }
    function resetStreak() {
      streak = 0;
      var tile = document.getElementById('streakTile');
      var val = document.getElementById('streakVal');
      if (val) val.textContent = '0';
      if (tile && streakHighWater < 2) tile.style.display = 'none';
    }

    function showFlowStamp() {
      if (flowShown || prefersReducedMotion) {
        if (!flowShown) flowShown = true;
        confetti();
        sndFlow();
        return;
      }
      flowShown = true;
      var s = document.getElementById('flowStamp');
      if (s) {
        s.classList.remove('show');
        void s.offsetWidth;
        s.classList.add('show');
      }
      confetti();
      sndFlow();
    }
    // ---- end Phase 1 helpers ----

    // Countdown then start
    var countNum = document.getElementById('countNum');
    var countdown = document.getElementById('countdown');
    var game = document.getElementById('game');

    function startCountdown() {
      var i = 3;
      var t = setInterval(function() {
        i--;
        if (i > 0) { countNum.textContent = i; }
        else if (i === 0) { countNum.innerHTML = '<div class="go-text">GO!</div>'; }
        else {
          clearInterval(t);
          countdown.style.display = 'none';
          game.classList.add('active');
          startGame();
        }
      }, 1000);
    }

    function startGame() {
      initFx();
      buildProgressPath();
      renderQuestion();
      startTimer();
      attachListeners();
    }

    function isAnswered(qId) {
      var a = answers[qId];
      return a !== undefined && a !== null && a !== '' && !(Array.isArray(a) && a.length === 0);
    }
    function checkFlowComplete() {
      for (var i = 0; i < questions.length; i++) {
        if (!isAnswered(questions[i].id)) return;
      }
      // All answered!
      if (!flowShown) showFlowStamp();
    }

    function buildProgressPath() {
      var path = document.getElementById('progressPath');
      var html = '';
      for (var i = 0; i < questions.length; i++) {
        html += '<div class="path-node" data-idx="' + i + '" onclick="goTo(' + i + ')">' + (i+1) + '</div>';
      }
      path.innerHTML = html;
      updateProgressPath();
    }

    function updateProgressPath() {
      var nodes = document.querySelectorAll('.path-node');
      nodes.forEach(function(n, i) {
        n.classList.remove('current', 'answered', 'flagged');
        var qId = questions[i].id;
        if (i === currentIdx) n.classList.add('current');
        else if (flagged[qId]) n.classList.add('flagged');
        else if (answers[qId] !== undefined && answers[qId] !== null && answers[qId] !== '') n.classList.add('answered');
      });
    }

    function renderQuestion() {
      var q = questions[currentIdx];
      document.getElementById('qCurrent').textContent = (currentIdx + 1);

      var diff = q.difficulty || 'medium';
      var diffColor = diff === 'easy' ? '#10b981' : diff === 'hard' ? '#ef4444' : '#fbbf24';
      var typeLabel = (q.question_type || 'mcq').replace('_', ' ').toUpperCase();

      document.getElementById('qMeta').innerHTML =
        '<span class="q-meta-pill" style="background:rgba(255,255,255,0.08);color:#fff;">' + typeLabel + '</span>' +
        '<span class="q-meta-pill" style="background:' + diffColor + '22;color:' + diffColor + ';">' + diff.toUpperCase() + '</span>' +
        '<span class="q-meta-pill" style="background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.7);">' + q.marks + ' pt' + (q.marks !== 1 ? 's' : '') + '</span>';

      // Optional category badge above the question
      var qTextEl = document.getElementById('qText');
      qTextEl.innerHTML = '';
      if (q.category) {
        var catBadge = document.createElement('p');
        catBadge.style.cssText = 'font-size:10px;font-family:Geist Mono,JetBrains Mono,monospace;color:#FF7040;letter-spacing:0.16em;text-transform:uppercase;margin:0 0 10px;font-weight:700;';
        catBadge.textContent = q.category;
        qTextEl.appendChild(catBadge);
      }
      // Optional inline image (per-question image_url)
      if (q.image_url) {
        var img = document.createElement('img');
        img.src = q.image_url;
        img.alt = '';
        img.style.cssText = 'max-width:100%;max-height:320px;border-radius:10px;border:1px solid #2a3038;margin:0 0 14px;display:block;';
        qTextEl.appendChild(img);
      }
      var qBody = document.createElement('div');
      qBody.textContent = q.question_text;
      qTextEl.appendChild(qBody);

      var answerArea = document.getElementById('qAnswerArea');
      var qId = q.id;
      var current = answers[qId];

      var OPTS_STYLE = 'display:flex;flex-direction:column;gap:10px;width:100%;';
      var OPT_BTN = 'display:flex;flex-direction:row;align-items:center;gap:14px;width:100%;background:#161b22;border:1px solid #30363d;border-radius:10px;padding:14px 18px;cursor:pointer;text-align:left;color:#f4f1ea;font-family:Space Grotesk,sans-serif;font-size:15px;margin:0;';
      var OPT_BTN_SEL = 'background:rgba(217,119,87,0.14);border-color:#d97757;color:#f4f1ea;';
      var OPT_LETTER = 'display:inline-flex;width:32px;height:32px;min-width:32px;align-items:center;justify-content:center;border-radius:8px;background:#0d1117;border:1px solid #30363d;font-family:JetBrains Mono,monospace;font-size:12px;font-weight:600;color:#c8c3b8;margin-right:6px;flex-shrink:0;';
      var OPT_LETTER_SEL = 'background:#d97757;border-color:#d97757;color:#1a0f08;';
      var OPT_TEXT = 'flex:1 1 auto;line-height:1.5;min-width:0;word-wrap:break-word;text-align:left;';

      if (q.question_type === 'mcq_single' || q.question_type === 'true_false') {
        var opts = q.options || [];
        var html = '<div class="options" style="' + OPTS_STYLE + '">';
        opts.forEach(function(o, i) {
          var isSel = current === i;
          var btnStyle = OPT_BTN + (isSel ? OPT_BTN_SEL : '');
          var letterStyle = OPT_LETTER + (isSel ? OPT_LETTER_SEL : '');
          var letter = String.fromCharCode(65 + i);
          html += '<button type="button" class="option' + (isSel ? ' selected' : '') + '" style="' + btnStyle + '" onclick="selectOption(' + i + ')"><span class="option-letter" style="' + letterStyle + '">' + letter + '</span><span class="option-text" style="' + OPT_TEXT + '">' + escapeHtml(o.text) + '</span></button>';
        });
        html += '</div>';
        answerArea.innerHTML = html;
      } else if (q.question_type === 'mcq_multi') {
        var opts = q.options || [];
        var html = '<div class="options" style="' + OPTS_STYLE + '"><p style="font-size:11px;color:rgba(255,255,255,0.5);margin-bottom:8px;">Select all that apply</p>';
        var selected = Array.isArray(current) ? current : [];
        opts.forEach(function(o, i) {
          var isSel = selected.indexOf(i) > -1;
          var btnStyle = OPT_BTN + (isSel ? OPT_BTN_SEL : '');
          var letterStyle = OPT_LETTER + (isSel ? OPT_LETTER_SEL : '');
          var letter = String.fromCharCode(65 + i);
          html += '<button type="button" class="option' + (isSel ? ' selected' : '') + '" style="' + btnStyle + '" onclick="toggleOption(' + i + ')"><span class="option-letter" style="' + letterStyle + '">' + letter + '</span><span class="option-text" style="' + OPT_TEXT + '">' + escapeHtml(o.text) + '</span></button>';
        });
        html += '</div>';
        answerArea.innerHTML = html;
      } else if (q.question_type === 'fill_in_blank') {
        answerArea.innerHTML =
          '<input type="text" class="text-answer" placeholder="Type the missing word…" oninput="setTextAnswer(this.value)" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" value="' + escapeHtml(current || '') + '" />' +
          '<p style="font-size:11px;color:rgba(255,255,255,0.45);margin-top:6px;">Single word or short phrase. Case and spacing are ignored.</p>';
      } else if (q.question_type === 'numeric') {
        answerArea.innerHTML =
          '<input type="number" step="any" class="text-answer" placeholder="Enter a number…" oninput="setTextAnswer(this.value)" value="' + escapeHtml(current || '') + '" />' +
          '<p style="font-size:11px;color:rgba(255,255,255,0.45);margin-top:6px;">Decimal numbers OK. ' + (q.answer_tolerance ? ('Tolerance ±' + q.answer_tolerance + '.') : 'Exact answer required.') + '</p>';
      } else if (q.question_type === 'short_answer') {
        answerArea.innerHTML = '<input type="text" class="text-answer" placeholder="Type your answer..." oninput="setTextAnswer(this.value)" value="' + escapeHtml(current || '') + '" />';
      } else if (q.question_type === 'long_answer') {
        answerArea.innerHTML = '<textarea class="text-answer" rows="6" placeholder="Type your answer..." oninput="setTextAnswer(this.value)">' + escapeHtml(current || '') + '</textarea>';
      } else if (q.question_type === 'code') {
        var starter = q.code_starter || '';
        var val = current || starter;
        answerArea.innerHTML =
          '<p style="font-size:11px;color:rgba(255,255,255,0.5);margin-bottom:6px;">Language: ' + (q.code_language || 'python') + '</p>' +
          '<textarea class="code-editor" spellcheck="false" oninput="setTextAnswer(this.value)" placeholder="Write your code...">' + escapeHtml(val) + '</textarea>';
      }

      // Flag button state
      var flagBtn = document.getElementById('flagBtn');
      if (flagged[qId]) flagBtn.classList.add('active');
      else flagBtn.classList.remove('active');

      // Next/Submit visibility
      document.getElementById('nextBtn').style.display = (currentIdx < questions.length - 1) ? '' : 'none';
      document.getElementById('submitBtn').style.display = (currentIdx === questions.length - 1) ? '' : 'none';
      document.getElementById('prevBtn').disabled = (currentIdx === 0);
      document.getElementById('prevBtn').style.opacity = (currentIdx === 0) ? '0.4' : '1';

      updateProgressPath();
      updateAnsweredCount();
      updatePalette();
      restoreScratchForCurrent();
    }

    // ---- LEFT RAIL: question palette ----
    function buildPalette() {
      var pal = document.getElementById('qPalette');
      if (!pal) return;
      var html = '';
      for (var i = 0; i < questions.length; i++) {
        html += '<button type="button" class="qpip" data-idx="' + i + '" aria-label="Go to question ' + (i+1) + '">' + (i+1) + '</button>';
      }
      pal.innerHTML = html;
      pal.querySelectorAll('.qpip').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var idx = parseInt(btn.getAttribute('data-idx') || '0', 10);
          if (!isNaN(idx) && idx >= 0 && idx < questions.length) {
            currentIdx = idx;
            renderQuestion();
            scheduleSave();
          }
        });
      });
    }
    function updatePalette() {
      var pal = document.getElementById('qPalette');
      if (!pal) return;
      pal.querySelectorAll('.qpip').forEach(function(btn) {
        var idx = parseInt(btn.getAttribute('data-idx') || '0', 10);
        var q = questions[idx];
        btn.classList.toggle('current', idx === currentIdx);
        btn.classList.toggle('answered', !!q && isAnswered(q.id) && idx !== currentIdx);
        btn.classList.toggle('flagged', !!q && !!flagged[q.id]);
      });
    }

    // ---- RIGHT RAIL: per-question scratch pad ----
    var scratchByQ = {};
    function restoreScratchForCurrent() {
      var sp = document.getElementById('scratchPad');
      if (!sp) return;
      var qId = questions[currentIdx] && questions[currentIdx].id;
      sp.value = (qId && scratchByQ[qId]) ? scratchByQ[qId] : '';
    }
    function attachScratchPad() {
      var sp = document.getElementById('scratchPad');
      if (!sp) return;
      sp.addEventListener('input', function() {
        var qId = questions[currentIdx] && questions[currentIdx].id;
        if (qId) scratchByQ[qId] = sp.value;
      });
    }

    // ---- A11Y toggles ----
    function attachA11y() {
      var qText = document.getElementById('qText');
      var fontBtn = document.getElementById('a11yFont');
      var dysBtn  = document.getElementById('a11yDys');
      var ttsBtn  = document.getElementById('a11yTts');
      var extBtn  = document.getElementById('a11yExt');
      if (fontBtn) fontBtn.onclick = function() {
        fontBtn.classList.toggle('on');
        if (qText) qText.style.fontSize = fontBtn.classList.contains('on') ? 'clamp(28px,3vw,38px)' : '';
      };
      if (dysBtn) dysBtn.onclick = function() {
        dysBtn.classList.toggle('on');
        if (qText) {
          qText.style.fontFamily = dysBtn.classList.contains('on') ? 'OpenDyslexic, "Comic Sans MS", system-ui, sans-serif' : '';
          qText.style.letterSpacing = dysBtn.classList.contains('on') ? '0.04em' : '';
          qText.style.lineHeight = dysBtn.classList.contains('on') ? '1.55' : '';
        }
      };
      if (ttsBtn) ttsBtn.onclick = function() {
        try {
          if (!('speechSynthesis' in window)) { showToast('Speech synthesis not supported in this browser', 'warn'); return; }
          speechSynthesis.cancel();
          if (!ttsBtn.classList.contains('on')) {
            ttsBtn.classList.add('on');
            var u = new SpeechSynthesisUtterance(qText ? qText.textContent : '');
            u.rate = 0.95;
            u.onend = function() { ttsBtn.classList.remove('on'); };
            speechSynthesis.speak(u);
          } else {
            ttsBtn.classList.remove('on');
          }
        } catch (_) {}
      };
      if (extBtn) extBtn.onclick = function() {
        extBtn.classList.toggle('on');
        showToast(extBtn.classList.contains('on') ? 'Extra-time request flagged for the invigilator' : 'Extra-time request cancelled', 'info');
      };
    }

    function selectOption(idx) {
      var q = questions[currentIdx];
      var wasAnswered = isAnswered(q.id);
      answers[q.id] = idx;
      if (!wasAnswered) bumpStreak(window.event); else sndTap();
      // particle burst from the click
      if (window.event && window.event.clientX) {
        burst(window.event.clientX, window.event.clientY, fg, 22);
      }
      renderQuestion();
      scheduleSave();
      checkFlowComplete();
    }

    function toggleOption(idx) {
      var q = questions[currentIdx];
      var cur = Array.isArray(answers[q.id]) ? answers[q.id].slice() : [];
      var wasAnswered = cur.length > 0;
      var pos = cur.indexOf(idx);
      if (pos > -1) cur.splice(pos, 1);
      else cur.push(idx);
      answers[q.id] = cur;
      var nowAnswered = cur.length > 0;
      if (!wasAnswered && nowAnswered) bumpStreak(window.event); else sndTap();
      if (window.event && window.event.clientX) {
        burst(window.event.clientX, window.event.clientY, fg, 18);
      }
      renderQuestion();
      scheduleSave();
      checkFlowComplete();
    }

    function setTextAnswer(val) {
      var q = questions[currentIdx];
      var wasAnswered = isAnswered(q.id);
      answers[q.id] = val;
      var nowAnswered = isAnswered(q.id);
      // Only bump streak on transition from empty to filled (don't spam on every keystroke)
      if (!wasAnswered && nowAnswered) bumpStreak(null);
      scheduleSave();
      updateAnsweredCount();
      updateProgressPath();
      if (nowAnswered) checkFlowComplete();
    }

    function goTo(idx) {
      currentIdx = idx;
      renderQuestion();
    }

    function next() {
      if (currentIdx < questions.length - 1) {
        currentIdx++;
        renderQuestion();
      }
    }
    function prev() {
      if (currentIdx > 0) {
        currentIdx--;
        renderQuestion();
      }
    }
    function toggleFlag() {
      var qId = questions[currentIdx].id;
      flagged[qId] = !flagged[qId];
      renderQuestion();
    }

    function updateAnsweredCount() {
      var count = 0;
      for (var i = 0; i < questions.length; i++) {
        var a = answers[questions[i].id];
        if (a !== undefined && a !== null && a !== '' && !(Array.isArray(a) && a.length === 0)) count++;
      }
      document.getElementById('answeredCount').textContent = count;
    }

    function startTimer() {
      var timerEl = document.getElementById('timer');
      var tile = document.getElementById('timerTile');
      function tick() {
        if (submitted) return;
        if (timeLeft <= 0) {
          autoSubmit();
          return;
        }
        var m = Math.floor(timeLeft / 60);
        var s = timeLeft % 60;
        timerEl.textContent = (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
        tile.classList.toggle('warning', timeLeft <= 300 && timeLeft > 60);
        tile.classList.toggle('danger', timeLeft <= 60);
        timeLeft--;
      }
      tick();
      setInterval(tick, 1000);
    }

    function scheduleSave() {
      if (saveTimer) clearTimeout(saveTimer);
      saveTimer = setTimeout(doSave, 1500);
    }

    function doSave() {
      fetch('/api/tests/save-progress', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ attemptId: attemptId, answers: answers, flagged: flagged, tabSwitches: tabSwitches })
      }).catch(function() {});
    }

    function attachListeners() {
      document.getElementById('nextBtn').onclick = next;
      document.getElementById('prevBtn').onclick = prev;
      document.getElementById('flagBtn').onclick = toggleFlag;
      document.getElementById('submitBtn').onclick = openSubmitConfirm;
      var confirmYesBtn = document.getElementById('confirmYes');
      var confirmCancelBtn = document.getElementById('confirmCancel');
      if (confirmYesBtn) confirmYesBtn.onclick = submitTest;
      if (confirmCancelBtn) confirmCancelBtn.onclick = function() { document.getElementById('confirmOverlay').classList.remove('show'); };
      // ATLAS rails
      buildPalette();
      updatePalette();
      attachScratchPad();
      attachA11y();
      // Expose key handlers on window as a defensive fallback
      try { window.submitTest = submitTest; window.openSubmitConfirm = openSubmitConfirm; window.selectOption = selectOption; window.toggleOption = toggleOption; window.setTextAnswer = setTextAnswer; } catch (_) {}

