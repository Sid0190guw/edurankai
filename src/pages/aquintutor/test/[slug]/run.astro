        if (eventBuffer.length >= 12 || severity === 'flag') flushEvents();
      }
      function setSig(id, text, cls) {
        var el = document.getElementById(id);
        if (!el) return;
        el.className = 'sig' + (cls ? ' ' + cls : '');
        el.innerHTML = '<span class="sdot"></span><span>' + text + '</span>';
      }
      function updateRailSignal(type, sev) {
        var sevCls = sev === 'flag' ? 'bad' : sev === 'warn' ? 'warn' : '';
        if (type === 'face_lost')         setSig('sigGaze', 'lost', 'warn');
        else if (type === 'multiple_faces') setSig('sigGaze', 'multi', 'bad');
        else if (type === 'looking_away')   setSig('sigGaze', 'away', 'warn');
        else if (type === 'looking_down')   setSig('sigGaze', 'looking down', 'warn');
        else if (type === 'looking_up')     setSig('sigGaze', 'looking up', 'warn');
        else if (type === 'head_tilt')      setSig('sigGaze', 'head tilt', 'warn');
        else if (type === 'bad_posture')    setSig('sigGaze', 'posture', 'warn');
        else if (type === 'face_partial')   setSig('sigGaze', 'off-frame', 'warn');
        else if (type === 'face_too_small') setSig('sigGaze', 'too far', 'warn');
        else if (type === 'gaze_restored')  setSig('sigGaze', 'steady', '');
        else if (type === 'face_visible')   setSig('sigGaze', 'steady', '');
        else if (type === 'voice_detected') setSig('sigAudio', 'talking', 'warn');
        else if (type === 'voice_silenced') setSig('sigAudio', 'quiet', '');
        else if (type === 'tab_hidden' || type === 'window_blur') setSig('sigFocus', 'lost', 'warn');
        else if (type === 'tab_visible' || type === 'window_focus') setSig('sigFocus', 'in-tab', '');
        else if (type === 'network_offline') setSig('sigNet', 'offline', 'bad');
        else if (type === 'network_online')  setSig('sigNet', 'online', '');
      }
      function flushEvents() {
        if (eventBuffer.length === 0) return;
        var batch = eventBuffer.splice(0);
        try {
          var payload = JSON.stringify({ attemptId: attemptId, events: batch });
          // Prefer fetch with keepalive (works in active tabs + during unload).
          // sendBeacon is only used as a last-resort fallback for unload because
          // some browsers / extensions silently drop beacons or strip headers.
