        keyStream = keyStream.filter(function (t) { return now - t < 1500; });
        if (keyStream.length > 20) {
          logEvent('key_press_burst', 'warn', { count: keyStream.length, window_ms: 1500 });
          keyStream = [];
        }
      });

      // Long idle then long-answer pasted-feel
      document.addEventListener('input', function (e) {
        if (submitted) return;
        var t = e.target;
        if (!t || t.value == null) return;
        var gapMs = Date.now() - lastActivity;
