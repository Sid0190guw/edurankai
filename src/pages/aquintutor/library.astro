---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

const sourceTypes = [
  ['Peer-reviewed papers', 1422940, true],
  ['Books & monographs', 318240, false],
  ['Datasets', 47830, false],
  ['Preprints (arXiv)', 1108200, false],
  ['Vedic primary sources', 8412, true],
  ['Course materials', 84120, false],
  ['Patents', 410001, false],
];

const disciplines = [
  { l: 'AI', c: '#2b577e', active: true },
  { l: 'Quantum', c: '#5b4a92' },
  { l: 'Vedic', c: '#a8472c', active: true },
  { l: 'Robotics', c: '#946322' },
  { l: 'Liberal', c: '#8a486b' },
  { l: 'Design', c: '#a04330' },
  { l: 'Business', c: '#4a7048' },
];

const results = [
  { type: 'paper', kind: 'PDF', title: 'Attention Is All You Need', authors: 'Vaswani et al.', venue: 'NeurIPS', year: '2017', cites: '109,842', color: '#2b577e', tag: 'AI · seminal', summary: 'Introduces the Transformer architecture, replacing recurrence with self-attention. Causal masking enables the decoder to be autoregressive.' },
  { type: 'paper', kind: 'PDF', title: 'FlashAttention: Fast and Memory-Efficient Exact Attention', authors: 'Dao et al.', venue: 'NeurIPS', year: '2022', cites: '8,412', color: '#2b577e', tag: 'AI · systems', summary: 'IO-aware exact attention algorithm that achieves linear memory in sequence length without approximation.' },
  { type: 'paper', kind: 'PDF', title: 'Generating Long Sequences with Sparse Transformers', authors: 'Child et al.', venue: 'arXiv', year: '2019', cites: '2,140', color: '#2b577e', tag: 'AI · long-context' },
  { type: 'book', kind: 'BOOK', title: 'Speech and Language Processing (3rd ed.)', authors: 'Reference textbook', venue: 'University textbook', year: '2024', color: '#8a486b', tag: 'textbook', summary: 'Chapter 10 covers transformer architecture with the clearest masking notation in any textbook.' },
  { type: 'vedic', kind: 'VED', title: 'Aṣṭādhyāyī — Pāṇini\'s grammar (with Bhāṣya)', authors: 'Pāṇini · ca. 400 BCE', venue: 'Sanskrit primary', year: '400 BCE', color: '#a8472c', tag: 'primary source', summary: 'A formal grammar of Sanskrit using 3,959 rules - one of the earliest formal systems comparable to modern attention masks in its rule-precedence structure.' },
  { type: 'dataset', kind: 'DSET', title: 'Common Crawl 2024 · 3.5T tokens', authors: 'commoncrawl.org', venue: 'open dataset', year: '2024', color: '#3d6b76', tag: 'dataset', summary: 'Monthly snapshot used for pre-training; 3.5T tokens, 102 languages. Includes filtering scripts and quality reports.' },
];
---
<AquintutorLayout title="Library" description="The research catalogue of AquinTutor - 4.2M sources including peer-reviewed papers, books, datasets, Vedic primary sources, and accredited courseware.">

  <!-- BREADCRUMB -->
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1400px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a>
      <span style="margin:0 8px;">/</span>
      <a href="/aquintutor/dashboard" style="color:var(--ink-500); text-decoration:none;">DASHBOARD</a>
      <span style="margin:0 8px;">/</span>
      <span style="color:var(--rust); font-weight:600;">LIBRARY · 4.2M SOURCES</span>
    </div>
  </div>

  <!-- HEADER -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:32px 28px 24px;">
      <div style="display:flex; align-items:start; justify-content:space-between; gap:18px; flex-wrap:wrap;">
        <div>
          <div style="display:inline-flex; align-items:center; gap:8px; padding:4px 12px; background:rgba(160,66,30,0.08); border:1px solid rgba(160,66,30,0.3); border-radius:999px; font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.16em; text-transform:uppercase; color:var(--rust); font-weight:600; margin-bottom:12px;">LIBRARY &middot; 4.2M SOURCES</div>
          <h1 class="font-display" style="font-size:clamp(1.85rem, 4vw, 2.85rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0; color:var(--ink); max-width:42rem;">The catalogue of everything you might cite.</h1>
          <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1rem, 1.3vw, 1.2rem); color:var(--ink-500); line-height:1.5; margin:14px 0 0; max-width:42rem;">Papers, books, datasets, Vedic primary sources, accredited courseware. Ask Aquin for a literature review, or filter manually by type, year, and discipline.</p>
        </div>
        <div style="display:flex; gap:8px; flex-wrap:wrap;">
          <button type="button" style="background:transparent; color:var(--ink); padding:10px 18px; border:1px solid var(--rule); border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; cursor:pointer;">Saved &middot; 38</button>
          <a href="/aquintutor/aquin" style="background:#3d6b76; color:#fff; padding:10px 18px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; text-decoration:none;">Lit review with Aquin</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1400px; margin:0 auto; padding:28px 28px 48px; display:grid; grid-template-columns:1fr; gap:18px;" class="lib-grid">

      <!-- FILTERS -->
      <aside style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:18px; height:fit-content;">
        <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 12px;">Type</p>
        <div style="display:flex; flex-direction:column; gap:4px;">
          {sourceTypes.map(([l, n, sel]) => (
            <label style="display:flex; align-items:center; gap:10px; padding:5px 4px; cursor:pointer;">
              <span style={'width:14px; height:14px; min-width:14px; border-radius:3px; background:' + (sel ? 'var(--rust)' : 'transparent') + '; border:1px solid ' + (sel ? 'var(--rust)' : 'var(--ink-300)') + '; display:flex; align-items:center; justify-content:center;'}>
                {sel && <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round"><path d="M4 12l5 5L20 6"/></svg>}
              </span>
              <span style="flex:1; font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink);">{l}</span>
              <span style="font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--ink-500);">{n.toLocaleString()}</span>
            </label>
          ))}
        </div>

        <div style="height:1px; background:var(--rule); margin:16px 0;"></div>

        <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 10px;">Year</p>
        <div style="display:flex; flex-direction:column; gap:10px;">
          <div>
            <div style="display:flex; justify-content:space-between; font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--ink-500); margin-bottom:4px;"><span>FROM</span><span style="color:var(--rust); font-weight:600;">1998</span></div>
            <input type="range" min="1500" max="2026" value="1998" style="width:100%; accent-color:var(--rust); cursor:pointer;" />
          </div>
          <div>
            <div style="display:flex; justify-content:space-between; font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--ink-500); margin-bottom:4px;"><span>TO</span><span style="color:var(--rust); font-weight:600;">2026</span></div>
            <input type="range" min="1500" max="2026" value="2026" style="width:100%; accent-color:var(--rust); cursor:pointer;" />
          </div>
        </div>

        <div style="height:1px; background:var(--rule); margin:16px 0;"></div>

        <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 10px;">Discipline</p>
        <div style="display:flex; gap:5px; flex-wrap:wrap;">
          {disciplines.map((d) => (
            <span style={'display:inline-flex; align-items:center; padding:4px 10px; border-radius:999px; font-family:Inter Tight,sans-serif; font-size:11.5px; font-weight:500; cursor:pointer; ' + (d.active ? 'background:' + d.c + '14; border:1px solid ' + d.c + '60; color:' + d.c + ';' : 'background:var(--sand-100); border:1px solid var(--rule); color:var(--ink-500);')}>{d.l}</span>
          ))}
        </div>

        <div style="height:1px; background:var(--rule); margin:16px 0;"></div>

        <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 10px;">Access</p>
        <div style="display:flex; flex-direction:column; gap:5px;">
          {[['Open access', 1240320], ['Library subscription', 2810400], ['Public domain', 187200]].map(([l, n]) => (
            <label style="display:flex; align-items:center; gap:10px; padding:5px 4px; cursor:pointer;">
              <span style="width:14px; height:14px; min-width:14px; border-radius:3px; border:1px solid var(--ink-300);"></span>
              <span style="flex:1; font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink);">{l}</span>
              <span style="font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--ink-500);">{n.toLocaleString()}</span>
            </label>
          ))}
        </div>
      </aside>

      <!-- RESULTS -->
      <div style="display:flex; flex-direction:column; gap:14px; min-width:0;">

        <!-- AI search bar -->
        <div style="padding:16px 18px; background:linear-gradient(135deg, rgba(61,107,118,0.08), rgba(160,66,30,0.05)); border:1px solid rgba(61,107,118,0.3); border-radius:12px;">
          <div style="display:flex; align-items:center; gap:12px;">
            <span style="display:inline-flex; align-items:center; justify-content:center; width:36px; height:36px; min-width:36px; border-radius:50%; background:#3d6b76; color:#dbe7e9; font-family:'Fraunces',serif; font-weight:500; font-size:15px;">A</span>
            <input value="masked attention causal vs bidirectional" style="flex:1; background:transparent; border:none; outline:none; color:var(--ink); font-family:'Cormorant Garamond',serif; font-size:18px; font-style:italic;" />
            <button type="button" style="background:#3d6b76; color:#fff; padding:9px 18px; border:none; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; cursor:pointer;">Search</button>
          </div>
          <div style="margin-top:12px; padding-top:12px; border-top:1px solid rgba(61,107,118,0.2); display:flex; align-items:start; gap:12px; flex-wrap:wrap;">
            <span style="font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.18em; text-transform:uppercase; color:#3d6b76; font-weight:600; flex-shrink:0;">Aquin says</span>
            <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--ink); line-height:1.5; margin:0; flex:1;">328 papers match. The 2017 Vaswani paper introduced causal masking; recent work from 2022-24 explores efficient variants. I've ordered results by citation gradient (recent citations weighted higher).</p>
          </div>
        </div>

        <!-- Result rows -->
        <div style="display:flex; flex-direction:column; gap:8px;">
          {results.map((r) => (
            <article style="padding:18px; background:var(--paper); border:1px solid var(--rule); border-radius:10px; display:flex; gap:16px; transition:border-color 0.15s;" class="lib-row">
              <div style={'width:52px; height:68px; flex-shrink:0; background:' + r.color + '15; border:1px solid ' + r.color + '40; border-radius:6px; display:flex; align-items:center; justify-content:center; font-family:JetBrains Mono,monospace; font-size:11px; color:' + r.color + '; font-weight:700; letter-spacing:0.08em;'}>{r.kind}</div>
              <div style="flex:1; min-width:0;">
                <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-bottom:6px;">
                  <span style={'display:inline-flex; align-items:center; padding:3px 9px; border-radius:999px; font-family:JetBrains Mono,monospace; font-size:9.5px; letter-spacing:0.12em; text-transform:uppercase; font-weight:600; background:' + r.color + '14; color:' + r.color + '; border:1px solid ' + r.color + '40;'}>{r.tag}</span>
                  <span style="font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--ink-500); letter-spacing:0.06em;">{r.venue} &middot; {r.year}</span>
                  {r.cites && <span style="font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--ink-500);">&middot; {r.cites} citations</span>}
                </div>
                <h3 class="font-display" style="font-size:1.15rem; font-weight:500; line-height:1.25; letter-spacing:-0.015em; margin:0; color:var(--ink);">{r.title}</h3>
                <p style="font-family:'Inter Tight',sans-serif; font-size:12.5px; color:var(--ink-500); margin:4px 0 0;">{r.authors}</p>
                {r.summary && <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:13.5px; color:var(--ink); line-height:1.55; margin:10px 0 0;">{r.summary}</p>}
              </div>
              <div style="display:flex; flex-direction:column; gap:8px; align-items:flex-end; flex-shrink:0;">
                <button type="button" style={'background:transparent; color:' + r.color + '; padding:6px 14px; border:1px solid ' + r.color + '; border-radius:6px; font-family:Inter Tight,sans-serif; font-size:12px; font-weight:600; cursor:pointer;'}>Open</button>
                <button type="button" style="background:transparent; border:none; color:var(--ink-500); cursor:pointer; font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.08em;">+ SAVE</button>
                <button type="button" style="background:transparent; border:none; color:var(--ink-500); cursor:pointer; font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.08em;">CITE &rarr;</button>
              </div>
            </article>
          ))}
        </div>

        <!-- Pagination -->
        <div style="display:flex; align-items:center; justify-content:space-between; padding:14px 0; flex-wrap:wrap; gap:10px;">
          <p style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--ink-500); margin:0;">SHOWING 1-6 OF 328</p>
          <div style="display:flex; gap:5px;">
            {['‹', '1', '2', '3', '4', '...', '55', '›'].map((p, i) => (
              <button type="button" style={'padding:6px 12px; background:' + (p === '1' ? 'var(--ink)' : 'var(--paper)') + '; color:' + (p === '1' ? 'var(--sand-50)' : 'var(--ink)') + '; border:1px solid ' + (p === '1' ? 'var(--ink)' : 'var(--rule)') + '; border-radius:6px; font-family:JetBrains Mono,monospace; font-size:11px; font-weight:600; cursor:pointer;'}>{p}</button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .lib-row:hover { border-color: var(--ink-300) !important; }
    @media (min-width: 900px) { .lib-grid { grid-template-columns: 280px 1fr !important; } }
  </style>
</AquintutorLayout>
