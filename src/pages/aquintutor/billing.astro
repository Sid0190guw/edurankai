---
// /aquintutor/billing — plans, checkout & my billing (Prompt AP5a). Real Razorpay checkout when keys
// are configured; a clearly-labelled sandbox otherwise (a test payment is never presented as real).
// A successful payment unlocks the enrolled course; failed/refunded stays/gets locked.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { PLANS, gatewayMode, SANDBOX_TOKEN } from '@/lib/payment-gateway';
import { myPayments } from '@/lib/course-payments';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/billing');
const mode = gatewayMode();
const courseObjId = (Astro.url.searchParams.get('course') || '').trim() || null;
const payments = await myPayments(user.id).catch(() => []);
function rupees(paise: number) { return '₹' + (paise / 100).toLocaleString('en-IN'); }
---
<AquintutorLayout title="Billing">
  <main style="max-width:760px;margin:0 auto;padding:40px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Plans</p>
    <h1 style="font-family:Fraunces,serif;font-size:30px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 6px;">Plans &amp; billing</h1>
    {mode === 'sandbox' && <p style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#9b2c2c;background:#fdecec;border-radius:8px;padding:8px 12px;margin:0 0 6px;">Payment gateway not configured — running in <b>test/sandbox</b> mode. Payments here are NOT real charges.</p>}
    <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#6b6455;margin:0 0 24px;">A paid plan unlocks your enrolled courses. {courseObjId ? 'Buying will unlock this course.' : ''}</p>
    <div id="msg" role="status" aria-live="polite" style="display:none;margin:0 0 14px;padding:9px 13px;border-radius:8px;font-size:13px;"></div>

    <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:28px;">
      {PLANS.map((p) => (
        <div style="display:flex;justify-content:space-between;align-items:center;background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:12px;padding:14px 18px;">
          <div><span style="font-family:'Inter Tight',sans-serif;font-size:15px;font-weight:600;color:var(--ink,#1a1712);">{p.label}</span><br><span style="font-family:'Geist Mono',monospace;font-size:12px;color:#8a8378;">{p.priceInr === 0 ? 'Free' : rupees(p.priceInr * 100) + (p.period ? ' / ' + p.period : '')}</span></div>
          <button class="buyBtn" data-plan={p.id} style="background:var(--ink,#1a1712);color:#fff;border:none;border-radius:9px;padding:9px 18px;font-family:'Inter Tight',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">{p.priceInr === 0 ? 'Get free access' : 'Buy'}</button>
        </div>
      ))}
    </div>

    <h2 style="font-family:Fraunces,serif;font-size:20px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 12px;">My payments</h2>
    {payments.length ? (
      <table style="width:100%;border-collapse:collapse;font-family:'Inter Tight',sans-serif;font-size:13px;">
        <thead><tr style="text-align:left;color:#8a8378;font-size:11px;text-transform:uppercase;"><th style="padding:6px 4px;">Plan</th><th style="padding:6px 4px;">Amount</th><th style="padding:6px 4px;">Status</th><th style="padding:6px 4px;">Mode</th></tr></thead>
        <tbody>
          {payments.map((p: any) => (
            <tr style="border-top:1px solid var(--line,#e6e1d6);color:var(--ink,#1a1712);">
              <td style="padding:8px 4px;">{p.plan}</td>
              <td style="padding:8px 4px;">{rupees(p.amount_paise)}</td>
              <td style={'padding:8px 4px;color:' + (p.status === 'paid' ? '#2f7d5b' : p.status === 'refunded' ? '#b3541e' : '#8a8378')}>{p.status}</td>
              <td style="padding:8px 4px;font-family:'Geist Mono',monospace;font-size:11px;color:#8a8378;">{p.mode}</td>
            </tr>
          ))}
        </tbody>
      </table>
    ) : <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#8a8378;">No payments yet.</p>}
  </main>

  <script is:inline define:vars={{ courseObjId, mode, sandboxToken: SANDBOX_TOKEN }}>
    (function () {
      var msg = document.getElementById('msg');
      function flash(t, ok) { msg.style.display = 'block'; msg.textContent = t; msg.style.background = ok ? '#eef8f1' : '#fdecec'; msg.style.color = ok ? '#2f7d5b' : '#9b2c2c'; }
      function post(body) { return fetch('/api/aquintutor/checkout', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }).then(function (r) { return r.json(); }); }
      function done(j) { if (j.ok && (j.unlocked || j.free)) { flash('Payment complete — access unlocked.', true); setTimeout(function () { location.reload(); }, 1000); } else { flash(j.error || 'Payment not completed.', false); } }
      function loadRzp() { return new Promise(function (res) { if (window.Razorpay) return res(true); var s = document.createElement('script'); s.src = 'https://checkout.razorpay.com/v1/checkout.js'; s.onload = function () { res(true); }; s.onerror = function () { res(false); }; document.head.appendChild(s); }); }
      document.querySelectorAll('.buyBtn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          flash('Opening checkout…', true);
          post({ action: 'create', planId: btn.getAttribute('data-plan'), courseObjId: courseObjId }).then(function (c) {
            if (c.free) return done(c);
            if (!c.ok) return flash(c.error || 'Could not start checkout', false);
            if (c.mode === 'sandbox') { post({ action: 'confirm', orderId: c.orderId, paymentId: 'pay_test', signature: sandboxToken }).then(done); return; }
            loadRzp().then(function (okp) {
              if (!okp || !window.Razorpay) return flash('Checkout unavailable', false);
              var rzp = new window.Razorpay({ key: c.keyId, amount: c.amount, currency: c.currency, order_id: c.orderId, name: 'AquinTutor',
                handler: function (resp) { post({ action: 'confirm', orderId: resp.razorpay_order_id, paymentId: resp.razorpay_payment_id, signature: resp.razorpay_signature }).then(done); } });
              rzp.open();
            });
          });
        });
      });
    })();
  </script>
</AquintutorLayout>
