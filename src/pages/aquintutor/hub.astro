---
// /aquintutor/hub — the virtual-campus hub (Prompt 21, main surface). A real personalized dashboard
// aggregating live subsystems for the signed-in user, scoped by role. No fake immersive content.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { resolvePrincipal } from '@/lib/rbac';
import { visibleSections, listFacilities } from '@/lib/hub';
import { resumeList } from '@/lib/edu-runtime';
import { studentCalendar } from '@/lib/calendar';
import { listNotifications } from '@/lib/edu-notify';
import { studentAnalytics } from '@/lib/analytics';
import { totalXp, gamerState } from '@/lib/xp-ledger';
import { academicRecord } from '@/lib/enrolment';
import { listThreads } from '@/lib/edu-community';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/hub');
const principal = await resolvePrincipal(user);
const sections = new Set(visibleSections(principal.roles));

const [resume, cal, notifs, analytics, xp, state, record, threads, facilities] = await Promise.all([
  resumeList(user.id, 4).catch(() => []),
  studentCalendar(user.id).catch(() => []),
  listNotifications(user.id, 5).catch(() => []),
  studentAnalytics(user.id).catch(() => null),
  totalXp(user.id).catch(() => 0),
  gamerState(user.id).catch(() => ({ streak: 0, optOut: false })),
  academicRecord(user.id).catch(() => ({ credentials: [] })),
  listThreads('general', null, 4).catch(() => []),
  listFacilities().catch(() => []),
]);
const upcoming = cal.slice(0, 4);
function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { day: '2-digit', month: 'short' }); } catch { return ''; } }
const CARD = 'background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:14px;padding:18px 20px;';
const H = 'font-family:Fraunces,serif;font-size:16px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 10px;';
const LINK = 'font-family:Inter Tight,sans-serif;font-size:13px;color:var(--rust,#b3541e);text-decoration:none;';
---
<AquintutorLayout title="Campus">
  <main style="max-width:960px;margin:0 auto;padding:44px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Campus</p>
    <h1 style="font-family:Fraunces,serif;font-size:32px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 6px;line-height:1.15;">Welcome back, {(user.name || '').split(' ')[0]}</h1>
    <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#6b6455;margin:0 0 22px;">Everything you're working on, in one place.</p>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:14px;">
      {sections.has('continue') ? (
        <div style={CARD}><h2 style={H}>Continue learning</h2>
          {resume.length === 0 ? <p style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:#6b6455;margin:0;">No lessons in progress. <a href="/aquintutor/courses" style={LINK}>Browse courses</a>.</p> :
            resume.map((r: any) => <a href={'/aquintutor/lesson/' + r.koId} style="display:block;font-family:'Inter Tight',sans-serif;font-size:14px;color:var(--ink,#1a1712);text-decoration:none;padding:4px 0;">{r.title || 'Lesson'} {r.completed ? '· done' : ''}</a>)}
        </div>
      ) : null}

      {sections.has('deadlines') ? (
        <div style={CARD}><h2 style={H}>Upcoming deadlines</h2>
          {upcoming.length === 0 ? <p style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:#6b6455;margin:0;">Nothing due soon. <a href="/aquintutor/study-calendar" style={LINK}>Calendar</a></p> :
            upcoming.map((d: any) => <div style="display:flex;justify-content:space-between;font-family:'Inter Tight',sans-serif;font-size:14px;padding:3px 0;color:var(--ink,#1a1712);"><span>{d.title}</span><span style="color:#8a8478;">{fmt(d.due_at)}</span></div>)}
        </div>
      ) : null}

      {sections.has('progress') ? (
        <div style={CARD}><h2 style={H}>Progress</h2>
          <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:var(--ink,#1a1712);margin:0;">{analytics?.mastery.mastered || 0} concepts mastered · {analytics?.completion.completed || 0} lessons</p>
          <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:var(--ink,#1a1712);margin:6px 0 0;">{xp} XP · {state.streak}-day streak</p>
          <a href="/aquintutor/analytics" style={LINK + 'display:inline-block;margin-top:8px;'}>My progress &rarr;</a>
        </div>
      ) : null}

      {sections.has('notifications') ? (
        <div style={CARD}><h2 style={H}>Notifications</h2>
          {notifs.length === 0 ? <p style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:#6b6455;margin:0;">All caught up.</p> :
            notifs.map((n: any) => <a href={n.link || '/aquintutor/alerts'} style="display:block;font-family:'Inter Tight',sans-serif;font-size:13.5px;color:var(--ink,#1a1712);text-decoration:none;padding:3px 0;">{n.read ? '' : '• '}{n.title}</a>)}
        </div>
      ) : null}

      {sections.has('credentials') ? (
        <div style={CARD}><h2 style={H}>Credentials</h2>
          {(record.credentials || []).length === 0 ? <p style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:#6b6455;margin:0;">No credentials yet.</p> :
            record.credentials.map((c: any) => <a href={'/credentials/course/' + c.code} style="display:block;font-family:'Inter Tight',sans-serif;font-size:14px;color:var(--ink,#1a1712);text-decoration:none;padding:3px 0;">{c.course_title}{c.revoked ? ' (revoked)' : ''}</a>)}
        </div>
      ) : null}

      {sections.has('community') ? (
        <div style={CARD}><h2 style={H}>Community</h2>
          {threads.length === 0 ? <p style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:#6b6455;margin:0;"><a href="/aquintutor/discussion" style={LINK}>Start a discussion</a></p> :
            threads.map((t: any) => <a href={'/aquintutor/discussion?t=' + t.id} style="display:block;font-family:'Inter Tight',sans-serif;font-size:14px;color:var(--ink,#1a1712);text-decoration:none;padding:3px 0;">{t.title} · {t.posts}</a>)}
        </div>
      ) : null}

      {sections.has('guardian') ? (
        <div style={CARD}><h2 style={H}>Guardian</h2><a href="/aquintutor/guardian" style={LINK}>Oversight of your linked learners &rarr;</a></div>
      ) : null}

      {sections.has('admin') ? (
        <div style={CARD}><h2 style={H}>Staff</h2><a href="/admin" style={LINK}>Open the admin console &rarr;</a></div>
      ) : null}
    </div>

    {facilities.length ? (
      <section style="margin-top:28px;">
        <h2 style="font-family:Fraunces,serif;font-size:20px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 12px;">About the campus</h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px;">{facilities.map((f: any) => (
          <div style={CARD}><h3 style="font-family:Fraunces,serif;font-size:15px;font-weight:600;margin:0 0 6px;">{f.title}</h3><p style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:#6b6455;margin:0;line-height:1.55;">{f.body}</p></div>
        ))}</div>
      </section>
    ) : null}
  </main>
</AquintutorLayout>
