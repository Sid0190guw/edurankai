---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

let paths: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT p.id, p.slug, p.title, p.tagline, p.description, p.category, p.level,
      p.duration_hours, p.hero_color, p.enrolled_count,
      (SELECT COUNT(*)::int FROM training_path_courses WHERE path_id = p.id) as course_count
    FROM training_paths p
    WHERE p.is_published = true
    ORDER BY p.is_featured DESC, p.sort_order ASC, p.created_at DESC
  `);
  paths = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const pageDesc = paths.length > 0
  ? 'Multi-course learning paths from AquinTutor. Stack courses into a programme. Verifiable certificate for each course completed.'
  : 'Learning paths are coming soon. Multi-course programmes that stack into specialisations.';
---
<BaseLayout title="Learning paths - AquinTutor" description={pageDesc}>
  <section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-6xl mx-auto">
    <a href="/aquintutor" class="inline-flex items-center gap-2 text-[0.78rem] font-mono text-ink-soft hover:text-burn transition-colors mb-4">
      &larr; AquinTutor
    </a>
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-3">Learning paths</p>
    <h1 class="font-display text-[clamp(2rem,5vw,3rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-3">
      Stack courses into a <em class="italic text-burn font-medium">programme.</em>
    </h1>
    <p class="text-[0.98rem] text-ink-soft leading-[1.7] max-w-2xl">
      A learning path is a curated sequence of courses. Each course issues its own certificate, and completing the full path unlocks a path-level credential.
    </p>
  </section>

  <section class="px-[5vw] pb-20 max-w-6xl mx-auto">
    {paths.length === 0 && (
      <div class="bg-cream-2 border border-ink/10 rounded-2xl p-10 md:p-16 text-center">
        <p class="font-display text-xl font-medium text-ink mb-3">Paths are being assembled.</p>
        <p class="text-[0.9rem] text-ink-soft mb-6 max-w-md mx-auto leading-relaxed">
          We're sequencing the first set of learning paths. In the meantime, browse our open course catalogue.
        </p>
        <a href="/aquintutor/courses" class="btn-primary">Browse all courses</a>
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {paths.map((p) => (
        <a href={'/aquintutor/paths/' + p.slug} class="group bg-white border border-ink/10 rounded-2xl p-6 transition-all hover:-translate-y-1 hover:shadow-xl flex flex-col" style={`border-top:4px solid ${p.hero_color || '#FF4F00'};`}>
          <div class="flex items-center gap-2 mb-3 flex-wrap">
            {p.category && <span class="text-[0.62rem] font-bold uppercase tracking-wider text-ink-soft bg-cream-2 border border-ink/10 px-2 py-0.5 rounded">{p.category}</span>}
            <span class="text-[0.62rem] font-bold uppercase tracking-wider text-burn bg-burn-pale border border-burn-dim px-2 py-0.5 rounded">{p.level || 'mixed'}</span>
          </div>
          <h2 class="font-display text-[1.2rem] md:text-[1.35rem] font-semibold text-ink leading-snug group-hover:text-burn transition-colors mb-2">{p.title}</h2>
          {p.tagline && <p class="text-[0.95rem] text-ink-soft leading-relaxed mb-4 flex-1">{p.tagline}</p>}
          <div class="flex items-center justify-between text-[0.78rem] text-ink-soft/80 font-mono pt-3 border-t border-ink/8">
            <span><strong class="text-ink">{p.course_count || 0}</strong> courses</span>
            {p.duration_hours > 0 && <span><strong class="text-ink">{p.duration_hours}h</strong> total</span>}
            {p.enrolled_count > 0 && <span>{p.enrolled_count} enrolled</span>}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
