---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

let paths: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT p.id, p.slug, p.title, p.tagline, p.description, p.category, p.level,
      p.duration_hours, p.hero_color, p.enrolled_count,
      (SELECT COUNT(*)::int FROM training_path_courses WHERE path_id = p.id) as course_count
    FROM training_paths p
    WHERE p.is_published = true
    ORDER BY p.is_featured DESC, p.sort_order ASC, p.created_at DESC
  `);
  paths = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const pageDesc = paths.length > 0
  ? 'Multi-course learning paths from AquinTutor. Stack courses into a programme.'
  : 'Learning paths are coming soon.';
---
<AquintutorLayout title="Learning paths" description={pageDesc}>
  <section class="ac-container" style="padding:50px 5vw 24px;">
    <a href="/aquintutor" style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--ac-ink-muted); text-decoration:none; margin-bottom:14px; display:inline-block; letter-spacing:0.08em;">&larr; AquinTutor</a>
    <p class="ac-eyebrow ac-mb-3">Learning paths</p>
    <h1 class="ac-display ac-mb-4">
      Stack courses into a <em class="ac-em">programme.</em>
    </h1>
    <p class="ac-lead" style="max-width:680px;">
      A learning path is a curated sequence of courses. Each course issues its own certificate, and completing the full path unlocks a path-level credential.
    </p>
  </section>

  <section class="ac-container" style="padding:24px 5vw 80px;">
    {paths.length === 0 ? (
      <div class="ac-card" style="text-align:center; padding:60px 20px;">
        <p style="font-family:'Fraunces',serif; font-size:1.4rem; color:var(--ac-ink); margin-bottom:10px;">Paths are being assembled.</p>
        <p style="font-size:14px; color:var(--ac-ink-soft); margin-bottom:20px; max-width:480px; margin-left:auto; margin-right:auto;">We're sequencing the first set of learning paths. In the meantime, browse our open course catalogue.</p>
        <a href="/aquintutor/courses" class="ac-btn">Browse all courses</a>
      </div>
    ) : (
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(320px, 1fr)); gap:18px;">
        {paths.map((p) => (
          <a href={'/aquintutor/paths/' + p.slug} class="ac-school" style={`border-top-color:${p.hero_color || '#B8512E'};`}>
            <div class="ac-flex ac-wrap ac-gap-2 ac-mb-3">
              {p.category && <span class="ac-pill">{p.category}</span>}
              <span class="ac-pill ac-pill-amber">{p.level || 'mixed'}</span>
            </div>
            <h2 class="ac-school-name" style="font-size:1.3rem;">{p.title}</h2>
            {p.tagline && <p class="ac-school-desc">{p.tagline}</p>}
            <div style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--ac-ink-muted); display:flex; gap:14px; padding-top:14px; border-top:1px solid var(--ac-rule);">
              <span><strong style="color:var(--ac-ink); font-family:'Fraunces',serif; font-size:1.05rem;">{p.course_count || 0}</strong> courses</span>
              {p.duration_hours > 0 && <span><strong style="color:var(--ac-ink); font-family:'Fraunces',serif; font-size:1.05rem;">{p.duration_hours}h</strong> total</span>}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</AquintutorLayout>
