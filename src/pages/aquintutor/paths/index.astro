---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

let paths: any[] = [];
let pathCourses: Record<string, any[]> = {};
try {
  const r = await db.execute(sql`
    SELECT p.id, p.slug, p.title, p.tagline, p.description, p.outcome, p.category, p.level,
      p.duration_hours, p.hero_color, p.enrolled_count, p.sort_order,
      (SELECT COUNT(*)::int FROM training_path_courses WHERE path_id = p.id) as course_count
    FROM training_paths p
    WHERE p.is_published = true
    ORDER BY p.sort_order ASC, p.created_at DESC
  `);
  paths = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

try {
  const r = await db.execute(sql`
    SELECT pc.path_id, c.title, c.slug, c.course_code, c.level, pc.sort_order
    FROM training_path_courses pc
    JOIN training_courses c ON pc.course_id = c.id
    WHERE c.is_published = true
    ORDER BY pc.path_id, pc.sort_order ASC
  `);
  const rows = (Array.isArray(r) ? r : (r?.rows || [])) as any[];
  rows.forEach((row) => { (pathCourses[row.path_id] = pathCourses[row.path_id] || []).push(row); });
} catch (_) {}

const totalCourses = paths.reduce((s, p) => s + (p.course_count || 0), 0);
const totalHours = paths.reduce((s, p) => s + (p.duration_hours || 0), 0);

const principles = [
  { num: 'I', label: 'Sequence the prerequisites', body: 'Each course is placed so the one before it is sufficient to begin the one after. No surprise gaps.' },
  { num: 'II', label: 'Credential per course', body: 'You earn a credential at each completed course, not just at the end. The path is a record of consistent work, not a single examination.' },
  { num: 'III', label: 'Path-level credential', body: 'Completing every course in a path unlocks a path-level credential - a single verifiable URL listing all underlying courses.' },
  { num: 'IV', label: 'Your own timeline', body: 'Paths are self-paced. The institutional roadmap publishes recommended pacings, but you graduate when you finish.' },
];

const pageDesc = paths.length > 0
  ? 'Multi-course learning paths from AquinTutor. A curated sequence of courses that earns a path-level credential.'
  : 'Learning paths are being assembled.';
---
<AquintutorLayout title="Learning paths" description={pageDesc}>

  <!-- HERO -->
  <section style="border-bottom:1px solid var(--rule); position:relative; overflow:hidden;">
    <div aria-hidden="true" style="position:absolute; right:-60px; top:80px; opacity:0.07; pointer-events:none;" class="hide-mobile">
      <svg width="320" height="320" viewBox="0 0 100 100" fill="none">
        <path d="M10 50 L30 30 L50 50 L70 30 L90 50" stroke="var(--ink)" stroke-width="0.6" fill="none"/>
        <circle cx="10" cy="50" r="3" fill="var(--ink)"/>
        <circle cx="30" cy="30" r="3" fill="var(--ink)"/>
        <circle cx="50" cy="50" r="3" fill="var(--ink)"/>
        <circle cx="70" cy="30" r="3" fill="var(--ink)"/>
        <circle cx="90" cy="50" r="3" fill="var(--rust)"/>
      </svg>
    </div>
    <div style="max-width:1320px; margin:0 auto; padding:72px 28px 40px; position:relative; z-index:1;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:var(--rust); font-weight:600; letter-spacing:0.04em; margin:0 0 16px;">Learning paths &middot; programmes</p>
      <h1 class="font-display" style="font-size:clamp(2.5rem, 5.5vw, 4.5rem); line-height:0.98; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--ink); max-width:44rem;">
        Stack courses<br/>
        <span style="font-style:italic; font-weight:300; color:var(--ink-500);">into a programme.</span>
      </h1>
      <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.1rem, 1.5vw, 1.35rem); line-height:1.5; color:var(--ink-500); margin:24px 0 0; max-width:42rem;">
        A learning path is a curated sequence of courses with a coherent academic outcome. Each course issues its own credential; completing the full path unlocks a path-level credential and a place on the AquinTutor register for that programme.
      </p>
    </div>
  </section>

  <!-- STAT STRIP -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1320px; margin:0 auto; padding:28px 28px;">
      <div style="display:grid; grid-template-columns:repeat(2, 1fr); gap:12px;" class="stat-row">
        {[
          { l: 'Programmes', v: paths.length },
          { l: 'Courses inside paths', v: totalCourses },
          { l: 'Total hours', v: totalHours + 'h' },
          { l: 'Path credential', v: '1 per path' },
          { l: 'Admission', v: 'By application', accent: true },
          { l: 'Pacing', v: 'Self-paced' },
        ].map((s) => (
          <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px 18px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">{s.l}</p>
            <p class="font-display" style={'font-size:1.5rem; font-weight:500; margin:0; line-height:1; letter-spacing:-0.02em; ' + (s.accent ? 'color:var(--rust);' : 'color:var(--ink);')}>{s.v}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PATHS LIST -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1320px; margin:0 auto; padding:64px 28px;">
      {paths.length === 0 ? (
        <div style="background:var(--paper); border:1px dashed var(--rule); border-radius:14px; padding:60px 24px; text-align:center;">
          <p class="font-display" style="font-size:1.45rem; font-weight:500; line-height:1.2; letter-spacing:-0.015em; margin:0 0 10px; color:var(--ink);">The first set of paths is being assembled by faculty.</p>
          <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1rem; color:var(--ink-500); margin:0 0 22px;">In the meantime, you can enrol in any course directly.</p>
          <a href="/aquintutor/courses" style="background:var(--ink); color:var(--sand-50); padding:13px 24px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none; display:inline-block;">Browse all courses</a>
        </div>
      ) : (
        <div style="display:flex; flex-direction:column; gap:24px;">
          {paths.map((p: any, idx: number) => {
            const accent = p.hero_color || '#A0421E';
            const courses = pathCourses[p.id] || [];
            return (
              <a href={'/aquintutor/paths/' + p.slug} class="path-row" style={'background:var(--paper); border:1px solid var(--rule); border-radius:16px; padding:0; overflow:hidden; text-decoration:none; color:var(--ink); display:grid; grid-template-columns:1fr; transition:transform 0.18s, border-color 0.18s, box-shadow 0.18s; border-left:5px solid ' + accent + ';'}>
                <div style="padding:28px 32px; display:grid; grid-template-columns:1fr; gap:24px; align-items:start;" class="path-inner">
                  <div style="display:flex; flex-direction:column; gap:14px;">
                    <div style="display:flex; align-items:baseline; gap:14px; flex-wrap:wrap;">
                      <span class="font-display" style={'font-style:italic; font-weight:300; font-size:1.85rem; line-height:1; letter-spacing:-0.02em; color:' + accent + ';'}>{String(idx + 1).padStart(2, '0')}</span>
                      <span style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.18em; color:var(--ink-500); font-weight:600;">PROGRAMME {String(idx + 1).padStart(2, '0')} / {String(paths.length).padStart(2, '0')}</span>
                      <span style={'font-family:JetBrains Mono,monospace; font-size:10.5px; letter-spacing:0.18em; padding:3px 9px; border-radius:999px; font-weight:600; color:' + accent + '; background:' + accent + '14; border:1px solid ' + accent + '40;'}>{(p.level || 'MIXED').toUpperCase()}</span>
                      {p.category && <span style="font-family:'Inter Tight',sans-serif; font-size:11.5px; padding:3px 9px; background:var(--sand-100); border:1px solid var(--rule); border-radius:999px; color:var(--ink-500);">{p.category}</span>}
                    </div>
                    <h2 class="font-display" style="font-size:clamp(1.5rem, 2.8vw, 2.15rem); font-weight:500; margin:0; line-height:1.12; letter-spacing:-0.02em; color:var(--ink);">{p.title}</h2>
                    {p.tagline && <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.15rem; color:var(--ink-500); line-height:1.4; margin:0;">{p.tagline}</p>}
                    {p.description && <p style="font-family:'Inter Tight',sans-serif; font-size:14.5px; line-height:1.65; color:var(--ink-500); margin:0; max-width:42rem;">{p.description.substring(0, 220)}{p.description.length > 220 ? '...' : ''}</p>}
                    {p.outcome && (
                      <div style="margin-top:6px; padding:14px 16px; background:var(--sand-100); border:1px solid var(--rule); border-radius:10px; border-left:3px solid var(--rust);">
                        <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--rust); font-weight:600; margin:0 0 6px;">Outcome</p>
                        <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1rem; color:var(--ink); line-height:1.5; margin:0;">{p.outcome}</p>
                      </div>
                    )}
                  </div>

                  <aside style="background:var(--sand-100); border:1px solid var(--rule); border-radius:12px; padding:20px;">
                    <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.18em; color:var(--rust); font-weight:600; margin:0 0 14px;">COURSES IN THIS PATH</p>
                    {courses.length === 0 ? (
                      <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:0.95rem; color:var(--ink-500); margin:0;">Course sequence is being finalised.</p>
                    ) : (
                      <ol style="list-style:none; padding:0; margin:0 0 14px; display:flex; flex-direction:column; gap:8px;">
                        {courses.slice(0, 6).map((cc: any, i: number) => (
                          <li style="display:flex; align-items:center; gap:10px; font-family:'Inter Tight',sans-serif; font-size:13px;">
                            <span style="display:inline-flex; align-items:center; justify-content:center; width:22px; height:22px; min-width:22px; border-radius:50%; background:var(--paper); border:1px solid var(--rule); font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--ink-500); font-weight:600;">{i + 1}</span>
                            <span style="color:var(--ink); line-height:1.4;">{cc.title}</span>
                          </li>
                        ))}
                        {courses.length > 6 && <li style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--ink-500); padding-left:32px; font-style:italic;">+{courses.length - 6} more</li>}
                      </ol>
                    )}

                    <div style="padding-top:14px; border-top:1px solid var(--rule); display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                      <div>
                        <p style="font-family:'Inter Tight',sans-serif; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 3px;">Courses</p>
                        <p class="font-display" style="font-size:1.2rem; font-weight:500; margin:0; line-height:1; color:var(--ink);">{p.course_count || 0}</p>
                      </div>
                      <div>
                        <p style="font-family:'Inter Tight',sans-serif; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 3px;">Hours</p>
                        <p class="font-display" style="font-size:1.2rem; font-weight:500; margin:0; line-height:1; color:var(--ink);">{p.duration_hours || '-'}</p>
                      </div>
                    </div>
                    <p style={'font-family:Inter Tight,sans-serif; font-size:12.5px; margin:12px 0 0; font-weight:600; color:' + accent + ';'}>Open programme &rarr;</p>
                  </aside>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <!-- HOW PATHS WORK -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1320px; margin:0 auto; padding:64px 28px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">How paths work</p>
      <h2 class="font-display" style="font-size:clamp(1.65rem, 3vw, 2.4rem); font-weight:500; line-height:1.1; letter-spacing:-0.015em; margin:0 0 36px; color:var(--ink); max-width:32rem;">
        Four principles<br/>
        <span style="font-style:italic; font-weight:300; color:var(--ink-500);">behind every programme.</span>
      </h2>
      <div style="display:grid; grid-template-columns:1fr; gap:18px;" class="principles-grid">
        {principles.map((p) => (
          <article style="background:var(--paper); border:1px solid var(--rule); border-radius:14px; padding:24px;">
            <div style="display:flex; align-items:baseline; gap:14px; margin-bottom:12px;">
              <span class="font-display" style="font-style:italic; font-weight:300; font-size:2rem; color:var(--rust); line-height:1; letter-spacing:-0.02em;">{p.num}</span>
              <h3 class="font-display" style="font-size:1.1rem; font-weight:500; margin:0; line-height:1.2; letter-spacing:-0.015em; color:var(--ink);">{p.label}</h3>
            </div>
            <p style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink-500); line-height:1.6; margin:0;">{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:var(--ink); color:var(--sand-50);">
    <div style="max-width:1200px; margin:0 auto; padding:64px 28px; display:grid; grid-template-columns:1fr; gap:32px; align-items:center;" class="cta-grid">
      <div>
        <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:#d97757; font-weight:600; letter-spacing:0.04em; margin:0 0 14px;">Open enrolment</p>
        <h2 class="font-display" style="font-size:clamp(1.85rem, 3.5vw, 2.85rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0 0 14px; color:var(--sand-50);">
          A path is a degree<br/>
          <span style="font-style:italic; font-weight:300; color:rgba(251,250,244,0.65);">measured in mastery.</span>
        </h2>
        <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.05rem, 1.4vw, 1.2rem); line-height:1.55; color:rgba(251,250,244,0.78); margin:0; max-width:36rem;">Each finished path is a verifiable, externally citable credential. Pick one, follow the sequence, graduate the programme on your own timeline.</p>
      </div>
      <div style="display:flex; flex-direction:column; gap:10px; max-width:300px; justify-self:end;">
        <a href="/aquintutor/courses" style="background:#d97757; color:#1a0f08; padding:13px 24px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none; text-align:center;">Browse all courses</a>
        <a href="/aquintutor/signup" style="background:transparent; color:var(--sand-50); padding:13px 24px; border-radius:6px; border:1px solid rgba(251,250,244,0.4); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none; text-align:center;">Apply for admission</a>
      </div>
    </div>
  </section>

  <style>
    .path-row:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(11,14,20,0.08); }
    @media (min-width: 640px) { .stat-row { grid-template-columns: repeat(3, 1fr) !important; } }
    @media (min-width: 900px) { .stat-row { grid-template-columns: repeat(6, 1fr) !important; } .path-inner { grid-template-columns: 1.6fr 1fr !important; } .principles-grid { grid-template-columns: repeat(2, 1fr) !important; } .cta-grid { grid-template-columns: 1.6fr 1fr !important; } }
    @media (min-width: 1100px) { .principles-grid { grid-template-columns: repeat(4, 1fr) !important; } }
  </style>
</AquintutorLayout>
