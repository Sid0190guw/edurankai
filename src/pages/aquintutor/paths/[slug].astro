---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { SITE } from '@/lib/site';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/aquintutor/paths');

let path: any = null;
let pathCourses: any[] = [];

try {
  const r = await db.execute(sql`SELECT * FROM training_paths WHERE slug = ${slug} AND is_published = true LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  path = rows[0] || null;
} catch (_) {}

if (!path) return Astro.redirect('/aquintutor/paths');

try {
  const r = await db.execute(sql`
    SELECT c.id, c.slug, c.title, c.short_desc, c.level, c.duration_hours, c.is_free,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as lesson_count,
      pc.sort_order, pc.is_required
    FROM training_path_courses pc
    JOIN training_courses c ON pc.course_id = c.id
    WHERE pc.path_id = ${path.id} AND c.is_published = true
    ORDER BY pc.sort_order ASC
  `);
  pathCourses = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const totalDuration = pathCourses.reduce((s, c) => s + (Number(c.duration_hours) || 0), 0);
const totalLessons = pathCourses.reduce((s, c) => s + (Number(c.lesson_count) || 0), 0);

const pageTitle = path.title + ' - learning path - AquinTutor';
const pageDesc = (path.tagline || path.description || '').substring(0, 160);

const pathSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: path.title,
  description: path.description || path.tagline || '',
  provider: { '@type': 'Organization', name: 'AquinTutor (EduRankAI)', sameAs: SITE.url },
  educationalLevel: path.level || 'mixed',
  hasCourseInstance: {
    '@type': 'CourseInstance',
    courseMode: 'online',
    courseWorkload: 'PT' + Math.ceil(totalDuration || 1) + 'H',
  },
};
---
<BaseLayout title={pageTitle} description={pageDesc}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(pathSchema)} />

  <!-- HERO -->
  <section class="bg-ink text-white" style={`background:linear-gradient(135deg, #0f0f12 0%, ${path.hero_color || '#FF4F00'}22 100%);`}>
    <div class="px-[5vw] py-10 md:py-14 max-w-5xl mx-auto">
      <a href="/aquintutor/paths" class="inline-flex items-center gap-2 text-[0.78rem] font-mono text-white/60 hover:text-burn mb-6">
        &larr; All learning paths
      </a>
      <div class="flex flex-wrap gap-2 mb-4">
        <span class="text-[0.65rem] font-bold uppercase tracking-wider text-white/90 bg-white/12 border border-white/20 px-2.5 py-1 rounded">Learning path</span>
        <span class="text-[0.65rem] font-bold uppercase tracking-wider text-burn bg-burn/15 border border-burn/40 px-2.5 py-1 rounded">{path.level || 'mixed'}</span>
        {path.category && <span class="text-[0.65rem] font-semibold uppercase tracking-wider text-white/70 bg-white/8 border border-white/15 px-2.5 py-1 rounded">{path.category}</span>}
      </div>
      <h1 class="font-display text-[clamp(2rem,5vw,3.2rem)] font-semibold leading-[1.1] tracking-tight mb-4">{path.title}</h1>
      {path.tagline && <p class="text-[1.05rem] md:text-[1.15rem] text-white/80 leading-[1.75] max-w-3xl mb-6">{path.tagline}</p>}

      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-8 max-w-2xl">
        <div class="bg-white/8 border border-white/15 rounded-xl p-3 md:p-4">
          <p class="text-[0.6rem] font-mono uppercase tracking-wider text-white/60 font-bold">Courses</p>
          <p class="text-[1.15rem] font-semibold text-white mt-1">{pathCourses.length}</p>
        </div>
        <div class="bg-white/8 border border-white/15 rounded-xl p-3 md:p-4">
          <p class="text-[0.6rem] font-mono uppercase tracking-wider text-white/60 font-bold">Lessons</p>
          <p class="text-[1.15rem] font-semibold text-white mt-1">{totalLessons}</p>
        </div>
        <div class="bg-white/8 border border-white/15 rounded-xl p-3 md:p-4">
          <p class="text-[0.6rem] font-mono uppercase tracking-wider text-white/60 font-bold">Total time</p>
          <p class="text-[1.15rem] font-semibold text-white mt-1">{totalDuration.toFixed(0)}h</p>
        </div>
        <div class="bg-white/8 border border-white/15 rounded-xl p-3 md:p-4">
          <p class="text-[0.6rem] font-mono uppercase tracking-wider text-white/60 font-bold">Credential</p>
          <p class="text-[1.15rem] font-semibold text-white mt-1">Yes</p>
        </div>
      </div>
    </div>
  </section>

  {path.description && (
    <section class="px-[5vw] py-8 max-w-5xl mx-auto border-t border-ink/8">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn mb-2 font-bold">About this path</p>
      <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-4">Why this path exists</h2>
      <div class="text-[0.95rem] text-ink-2 leading-[1.85] font-light whitespace-pre-line max-w-3xl">{path.description}</div>
    </section>
  )}

  {path.outcome && (
    <section class="px-[5vw] py-8 max-w-5xl mx-auto border-t border-ink/8">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn mb-2 font-bold">Outcome</p>
      <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-4">By the end of this path</h2>
      <p class="text-[1rem] text-ink-2 leading-[1.8] max-w-3xl">{path.outcome}</p>
    </section>
  )}

  <!-- COURSE SEQUENCE -->
  <section class="px-[5vw] py-10 max-w-5xl mx-auto border-t border-ink/8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn mb-2 font-bold">Path sequence</p>
    <h2 class="font-display text-xl md:text-2xl font-semibold text-ink mb-6">{pathCourses.length} courses, in order</h2>

    {pathCourses.length === 0 && (
      <p class="text-[0.92rem] text-ink-soft italic">Courses are being added to this path.</p>
    )}

    <div class="space-y-3">
      {pathCourses.map((c: any, i: number) => (
        <a href={'/aquintutor/courses/' + c.slug} class="group bg-white border border-ink/10 rounded-xl p-5 flex items-start gap-4 hover:border-burn hover:shadow-md transition-all">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-burn-pale border border-burn-dim flex items-center justify-center font-display font-bold text-burn">
            {i + 1}
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex gap-2 mb-1.5 flex-wrap">
              <span class="text-[0.6rem] font-bold uppercase tracking-wider text-ink-soft bg-cream-2 border border-ink/10 px-2 py-0.5 rounded">{c.level}</span>
              {c.is_free && <span class="text-[0.6rem] font-semibold text-leaf bg-leaf-bg border border-leaf-border px-2 py-0.5 rounded">FREE</span>}
              {!c.is_required && <span class="text-[0.6rem] font-semibold text-ink-soft bg-cream-2 border border-ink/10 px-2 py-0.5 rounded">Optional</span>}
            </div>
            <h3 class="font-display text-[1.05rem] font-semibold text-ink group-hover:text-burn transition-colors mb-1">{c.title}</h3>
            <p class="text-[0.85rem] text-ink-soft leading-relaxed mb-2">{c.short_desc}</p>
            <div class="flex gap-4 text-[0.72rem] font-mono text-ink-soft/70">
              <span>{c.lesson_count || 0} lessons</span>
              {c.duration_hours > 0 && <span>{c.duration_hours}h</span>}
            </div>
          </div>
          <span class="self-center text-ink-soft group-hover:text-burn transition-colors flex-shrink-0">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="px-[5vw] py-12 max-w-5xl mx-auto border-t border-ink/8">
    <div class="bg-white border-2 border-burn rounded-2xl p-6 md:p-10 text-center">
      <h3 class="font-display text-2xl md:text-3xl font-semibold text-ink mb-3">Start with course 1.</h3>
      <p class="text-[0.95rem] text-ink-soft mb-6 max-w-xl mx-auto leading-relaxed">
        Enrol in the first course to begin the path. You get a certificate at each step, and one for the full programme.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        {pathCourses[0] && (
          <a href={'/aquintutor/courses/' + pathCourses[0].slug} class="btn-primary">Start with {pathCourses[0].title}</a>
        )}
        <a href="/aquintutor/courses" class="btn-ghost">Browse all courses</a>
      </div>
    </div>
  </section>
</BaseLayout>
