---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { SITE } from '@/lib/site';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/aquintutor/paths');

let path: any = null;
let pathCourses: any[] = [];

try {
  const r = await db.execute(sql`SELECT * FROM training_paths WHERE slug = ${slug} AND is_published = true LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  path = rows[0] || null;
} catch (_) {}
if (!path) return Astro.redirect('/aquintutor/paths');

try {
  const r = await db.execute(sql`
    SELECT c.id, c.slug, c.title, c.short_desc, c.level, c.duration_hours, c.is_free,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as lesson_count,
      pc.sort_order, pc.is_required
    FROM training_path_courses pc
    JOIN training_courses c ON pc.course_id = c.id
    WHERE pc.path_id = ${path.id} AND c.is_published = true
    ORDER BY pc.sort_order ASC
  `);
  pathCourses = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const totalDuration = pathCourses.reduce((s, c) => s + (Number(c.duration_hours) || 0), 0);
const totalLessons = pathCourses.reduce((s, c) => s + (Number(c.lesson_count) || 0), 0);

const pageTitle = path.title + ' - learning path';
const pageDesc = (path.tagline || path.description || '').substring(0, 160);

const pathSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: path.title,
  description: path.description || path.tagline || '',
  provider: { '@type': 'Organization', name: 'AquinTutor (EduRankAI)', sameAs: SITE.url },
  educationalLevel: path.level || 'mixed',
  hasCourseInstance: { '@type': 'CourseInstance', courseMode: 'online', courseWorkload: 'PT' + Math.ceil(totalDuration || 1) + 'H' },
};

const accent = path.hero_color || '#B8512E';
---
<AquintutorLayout title={pageTitle} description={pageDesc}>
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(pathSchema)} />

  <!-- HERO -->
  <section class="ac-container" style={`padding:50px 5vw 40px; border-top:4px solid ${accent};`}>
    <a href="/aquintutor/paths" style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--ac-ink-muted); text-decoration:none; margin-bottom:14px; display:inline-block; letter-spacing:0.08em;">&larr; All learning paths</a>
    <div class="ac-flex ac-wrap ac-gap-2 ac-mb-4">
      <span class="ac-pill" style={`color:${accent}; border-color:${accent}33; background:${accent}10;`}>Learning path</span>
      <span class="ac-pill ac-pill-amber">{path.level || 'mixed'}</span>
      {path.category && <span class="ac-pill">{path.category}</span>}
    </div>
    <h1 class="ac-display ac-mb-4">{path.title}</h1>
    {path.tagline && <p class="ac-lead ac-mb-6" style="max-width:680px;">{path.tagline}</p>}

    <div class="ac-stats" style="margin-top:24px; max-width:640px;">
      <div class="ac-stat"><p class="ac-stat-num">{pathCourses.length}</p><p class="ac-stat-label">Courses</p></div>
      <div class="ac-stat"><p class="ac-stat-num">{totalLessons}</p><p class="ac-stat-label">Lessons</p></div>
      <div class="ac-stat"><p class="ac-stat-num">{totalDuration.toFixed(0)}h</p><p class="ac-stat-label">Total time</p></div>
      <div class="ac-stat"><p class="ac-stat-num" style="font-size:1.4rem;">Yes</p><p class="ac-stat-label">Credential</p></div>
    </div>
  </section>

  {path.description && (
    <section class="ac-container" style="padding:32px 5vw; border-top:1px solid var(--ac-rule);">
      <p class="ac-eyebrow ac-mb-3">About this path</p>
      <h2 class="ac-display ac-mb-4" style="font-size:1.6rem;">Why this path exists</h2>
      <div style="font-size:15px; color:var(--ac-ink-soft); line-height:1.85; white-space:pre-line; max-width:720px;">{path.description}</div>
    </section>
  )}

  {path.outcome && (
    <section class="ac-container" style="padding:32px 5vw; border-top:1px solid var(--ac-rule);">
      <p class="ac-eyebrow ac-mb-3">Outcome</p>
      <h2 class="ac-display ac-mb-4" style="font-size:1.6rem;">By the end of this path</h2>
      <p style="font-size:15.5px; color:var(--ac-ink); line-height:1.8; max-width:720px;">{path.outcome}</p>
    </section>
  )}

  <section class="ac-container" style="padding:40px 5vw; border-top:1px solid var(--ac-rule);">
    <p class="ac-eyebrow ac-mb-3">Path sequence</p>
    <h2 class="ac-display ac-mb-6" style="font-size:1.6rem;">{pathCourses.length} courses, in order</h2>

    {pathCourses.length === 0 && <p style="font-size:14.5px; color:var(--ac-ink-soft); font-style:italic;">Courses are being added to this path.</p>}

    <div style="display:flex; flex-direction:column; gap:12px;">
      {pathCourses.map((c: any, i: number) => (
        <a href={'/aquintutor/courses/' + c.slug} class="ac-card" style="display:flex; align-items:flex-start; gap:18px; text-decoration:none; padding:22px;">
          <div style={`flex-shrink:0; width:44px; height:44px; border-radius:50%; background:${accent}15; border:1px solid ${accent}40; display:flex; align-items:center; justify-content:center; font-family:'Fraunces',serif; font-weight:500; color:${accent}; font-size:1.15rem;`}>
            {i + 1}
          </div>
          <div style="flex:1; min-width:0;">
            <div class="ac-flex ac-wrap ac-gap-2 ac-mb-3">
              <span class="ac-pill">{c.level}</span>
              {c.is_free && <span class="ac-pill ac-pill-leaf">Free</span>}
              {!c.is_required && <span class="ac-pill">Optional</span>}
            </div>
            <h3 style="font-family:'Fraunces',serif; font-size:1.1rem; font-weight:500; color:var(--ac-ink); margin-bottom:6px;">{c.title}</h3>
            <p style="font-size:13.5px; color:var(--ac-ink-soft); line-height:1.6; margin-bottom:10px;">{c.short_desc}</p>
            <div style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--ac-ink-muted); display:flex; gap:14px;">
              <span>{c.lesson_count || 0} lessons</span>
              {c.duration_hours > 0 && <span>{c.duration_hours}h</span>}
            </div>
          </div>
          <span style="align-self:center; color:var(--ac-ink-muted); flex-shrink:0;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="ac-container ac-text-center" style="padding:60px 5vw 80px; border-top:1px solid var(--ac-rule);">
    <h2 class="ac-display ac-mb-4" style="font-size:1.8rem;">Start with course 1.</h2>
    <p class="ac-lead ac-mb-6" style="max-width:560px; margin-left:auto; margin-right:auto;">Enrol in the first course to begin the path. You get a certificate at each step, and one for the full programme.</p>
    <div class="ac-flex ac-wrap ac-gap-3" style="justify-content:center;">
      {pathCourses[0] && <a href={'/aquintutor/courses/' + pathCourses[0].slug} class="ac-btn">Start with course 1</a>}
      <a href="/aquintutor/courses" class="ac-btn ac-btn-ghost">Browse all courses</a>
    </div>
  </section>
</AquintutorLayout>
