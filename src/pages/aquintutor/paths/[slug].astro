---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { SITE } from '@/lib/site';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/aquintutor/paths');

let path: any = null;
let pathCourses: any[] = [];

try {
  const r = await db.execute(sql`SELECT * FROM training_paths WHERE slug = ${slug} AND is_published = true LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  path = rows[0] || null;
} catch (_) {}
if (!path) return Astro.redirect('/aquintutor/paths');

try {
  const r = await db.execute(sql`
    SELECT c.id, c.slug, c.title, c.subtitle, c.short_desc, c.course_code, c.level, c.duration_hours, c.duration_weeks, c.credit_hours, c.is_free,
      c.instructor_name,
      s.code as school_code, s.name as school_name,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as lesson_count,
      pc.sort_order
    FROM training_path_courses pc
    JOIN training_courses c ON pc.course_id = c.id
    LEFT JOIN schools s ON c.school_id = s.id
    WHERE pc.path_id = ${path.id} AND c.is_published = true
    ORDER BY pc.sort_order ASC
  `);
  pathCourses = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const totalDuration = pathCourses.reduce((s, c) => s + (Number(c.duration_hours) || 0), 0);
const totalLessons = pathCourses.reduce((s, c) => s + (Number(c.lesson_count) || 0), 0);
const totalWeeks = pathCourses.reduce((s, c) => s + (Number(c.duration_weeks) || 0), 0);

const pageTitle = path.title + ' - learning path';
const pageDesc = (path.tagline || path.description || '').substring(0, 160);

const pathSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: path.title,
  description: path.description || path.tagline || '',
  provider: { '@type': 'Organization', name: 'AquinTutor', sameAs: SITE.url },
  educationalLevel: path.level || 'mixed',
  hasCourseInstance: { '@type': 'CourseInstance', courseMode: 'online', courseWorkload: 'PT' + Math.ceil(totalDuration || 1) + 'H' },
};

const accent = path.hero_color || '#A0421E';
---
<AquintutorLayout title={pageTitle} description={pageDesc}>
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(pathSchema)} />

  <!-- BREADCRUMB -->
  <div style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1280px; margin:0 auto; padding:10px 28px; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.08em; color:var(--ink-500);">
      <a href="/aquintutor" style="color:var(--ink-500); text-decoration:none;">AQUINTUTOR</a>
      <span style="margin:0 8px;">/</span>
      <a href="/aquintutor/paths" style="color:var(--ink-500); text-decoration:none;">PATHS</a>
      <span style="margin:0 8px;">/</span>
      <span style={'color:' + accent + '; font-weight:600;'}>{(path.level || 'MIXED').toUpperCase()}</span>
    </div>
  </div>

  <!-- HERO with accent top stripe -->
  <section style={'border-bottom:1px solid var(--rule); border-top:6px solid ' + accent + ';'}>
    <div style="max-width:1280px; margin:0 auto; padding:60px 28px 40px;">
      <p style={'font-family:Inter Tight,sans-serif; font-size:13px; font-weight:600; letter-spacing:0.04em; margin:0 0 14px; color:' + accent + ';'}>Programme &middot; {path.category || 'Multi-school'}</p>
      <h1 class="font-display" style="font-size:clamp(2.5rem, 6vw, 4.75rem); line-height:1; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--ink); max-width:46rem;">{path.title}</h1>
      {path.tagline && <p class="font-serif" style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.15rem, 1.6vw, 1.45rem); line-height:1.4; color:var(--ink-500); margin:22px 0 0; max-width:42rem;">{path.tagline}</p>}

      <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:32px;">
        {pathCourses[0] && <a href={'/aquintutor/courses/' + pathCourses[0].slug} style={'background:' + accent + '; color:#fff; padding:14px 24px; border-radius:6px; font-family:Inter Tight,sans-serif; font-size:14px; font-weight:600; text-decoration:none;'}>Start with course 1 &rarr;</a>}
        <a href="/aquintutor/signup" style="background:var(--ink); color:var(--sand-50); padding:14px 24px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Apply for admission</a>
        <a href="/aquintutor/paths" style="background:transparent; color:var(--ink); padding:14px 24px; border-radius:6px; border:1px solid var(--rule); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Other paths</a>
      </div>
    </div>
  </section>

  <!-- STAT STRIP -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1280px; margin:0 auto; padding:28px 28px;">
      <div style="display:grid; grid-template-columns:repeat(2, 1fr); gap:12px;" class="stat-row">
        {[
          { l: 'Courses in sequence', v: pathCourses.length },
          { l: 'Lessons total', v: totalLessons },
          { l: 'Hours', v: totalDuration.toFixed(0) + 'h' },
          { l: 'Weeks (recommended)', v: totalWeeks || '-' },
          { l: 'Level', v: (path.level || 'mixed') },
          { l: 'Path credential', v: 'Issued', accent: true },
        ].map((s) => (
          <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px 18px;">
            <p style="font-family:'Inter Tight',sans-serif; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin:0 0 6px;">{s.l}</p>
            <p class="font-display" style={'font-size:1.45rem; font-weight:500; margin:0; line-height:1; letter-spacing:-0.02em; text-transform:capitalize; ' + (s.accent ? 'color:' + accent + ';' : 'color:var(--ink);')}>{s.v}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {(path.description || path.outcome) && (
    <!-- THESIS + OUTCOME -->
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:1280px; margin:0 auto; padding:64px 28px;">
        <div style="display:grid; grid-template-columns:1fr; gap:36px;" class="thesis-grid">
          {path.description && (
            <div>
              <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">Programme rationale</p>
              <h2 class="font-display" style="font-size:clamp(1.4rem, 2.4vw, 1.85rem); font-weight:500; line-height:1.18; letter-spacing:-0.015em; margin:0 0 16px; color:var(--ink);">Why this path exists.</h2>
              <p style="font-family:'Inter Tight',sans-serif; font-size:15px; color:var(--ink); line-height:1.7; margin:0;">{path.description}</p>
            </div>
          )}
          {path.outcome && (
            <div style={'background:var(--paper); border:1px solid var(--rule); border-left:4px solid ' + accent + '; border-radius:12px; padding:24px;'}>
              <p style={'font-family:JetBrains Mono,monospace; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; font-weight:600; margin:0 0 10px; color:' + accent + ';'}>On completion</p>
              <h3 class="font-display" style="font-size:1.25rem; font-weight:500; line-height:1.2; letter-spacing:-0.015em; margin:0 0 12px; color:var(--ink);">You will be able to:</h3>
              <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.15rem; color:var(--ink); line-height:1.55; margin:0;">{path.outcome}</p>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- COURSE SEQUENCE -->
  <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
    <div style="max-width:1280px; margin:0 auto; padding:64px 28px;">
      <div style="display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:14px; margin-bottom:30px;">
        <div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">Sequence</p>
          <h2 class="font-display" style="font-size:clamp(1.65rem, 3vw, 2.4rem); font-weight:500; line-height:1.12; letter-spacing:-0.015em; margin:0; color:var(--ink);">
            Course sequence.<br/>
            <span style="font-style:italic; font-weight:300; color:var(--ink-500);">Term by term.</span>
          </h2>
        </div>
        <p style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--ink-500); letter-spacing:0.1em; margin:0;">{pathCourses.length} COURSES, IN ORDER</p>
      </div>

      {pathCourses.length === 0 ? (
        <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.05rem; color:var(--ink-500); padding:32px; background:var(--paper); border:1px dashed var(--rule); border-radius:12px; text-align:center;">Courses are being added to this path.</p>
      ) : (
        <ol style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0; background:var(--paper); border:1px solid var(--rule); border-radius:14px; overflow:hidden; position:relative;">
          <!-- Connecting line -->
          <div aria-hidden="true" style={'position:absolute; left:42px; top:30px; bottom:30px; width:2px; background:' + accent + '; opacity:0.18;'} class="hide-mobile"></div>
          {pathCourses.map((c: any, i: number) => (
            <li>
              <a href={'/aquintutor/courses/' + c.slug} style={'display:grid; grid-template-columns:64px 1fr auto; gap:20px; align-items:start; padding:24px 26px; text-decoration:none; color:var(--ink); position:relative; ' + (i < pathCourses.length - 1 ? 'border-bottom:1px solid var(--rule);' : '')}>
                <span style={'display:inline-flex; align-items:center; justify-content:center; width:48px; height:48px; border-radius:50%; background:' + accent + '14; border:1.5px solid ' + accent + '; color:' + accent + '; font-family:Fraunces,serif; font-weight:500; font-size:1.25rem; letter-spacing:-0.02em; position:relative; z-index:1; flex-shrink:0;'}>{String(i + 1).padStart(2, '0')}</span>
                <div style="min-width:0;">
                  <div style="display:flex; gap:8px; flex-wrap:wrap; font-family:'JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.14em; color:var(--ink-500); text-transform:uppercase; margin-bottom:8px;">
                    <span>{c.course_code || (c.level || 'GEN')}</span>
                    {c.school_code && <span style="color:var(--rust);">&middot; {c.school_code}</span>}
                    {c.duration_weeks > 0 && <span>&middot; {c.duration_weeks}w</span>}
                    {c.credit_hours > 0 && <span>&middot; {c.credit_hours}cr</span>}
                    {c.lesson_count > 0 && <span>&middot; {c.lesson_count}L</span>}
                  </div>
                  <h3 class="font-display" style="font-size:1.25rem; font-weight:500; margin:0 0 6px; line-height:1.2; letter-spacing:-0.015em; color:var(--ink);">{c.title}</h3>
                  {c.subtitle ? <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1rem; color:var(--ink-500); margin:0 0 6px; line-height:1.42;">{c.subtitle}</p> : null}
                  {c.short_desc && <p style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink-500); margin:0; line-height:1.55;">{c.short_desc.substring(0, 180)}{c.short_desc.length > 180 ? '...' : ''}</p>}
                  {c.instructor_name && (
                    <p style="font-family:'Inter Tight',sans-serif; font-size:11.5px; color:var(--ink-500); margin:8px 0 0; display:flex; align-items:center; gap:6px;">
                      <span style="display:inline-flex; align-items:center; justify-content:center; width:18px; height:18px; min-width:18px; border-radius:50%; background:var(--ink); color:var(--sand-50); font-family:'Fraunces',serif; font-weight:500; font-size:9px;">{(c.instructor_name || 'F').split(' ').slice(-1)[0][0]}</span>
                      {c.instructor_name}
                    </p>
                  )}
                </div>
                <span style={'font-family:JetBrains Mono,monospace; font-size:11px; letter-spacing:0.14em; color:' + accent + '; font-weight:600; align-self:center; flex-shrink:0;'}>OPEN &rarr;</span>
              </a>
            </li>
          ))}
        </ol>
      )}
    </div>
  </section>

  <!-- HOW THE PATH IS GRADED -->
  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1280px; margin:0 auto; padding:64px 28px;">
      <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 10px;">How the path is graded</p>
      <h2 class="font-display" style="font-size:clamp(1.5rem, 2.6vw, 2.1rem); font-weight:500; line-height:1.15; letter-spacing:-0.015em; margin:0 0 28px; color:var(--ink); max-width:36rem;">Per-course credential, then a path credential at the end.</h2>
      <div style="display:grid; grid-template-columns:1fr; gap:18px;" class="grade-grid">
        {[
          { num: 'I', title: 'Each course issues its own credential', body: 'Complete a course, sit its examination, receive a verifiable credential. Independent of the path.' },
          { num: 'II', title: 'Sequence enforces prerequisites', body: 'The next course assumes the previous one. You can sit them in any order, but the recommended sequence is what we test against.' },
          { num: 'III', title: 'Path credential when every course passes', body: 'When every course in the sequence shows a passed credential, the path-level credential is published at a permanent verifiable URL listing all underlying courses.' },
        ].map((p) => (
          <article style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:24px;">
            <div style="display:flex; align-items:baseline; gap:12px; margin-bottom:12px;">
              <span class="font-display" style="font-style:italic; font-weight:300; font-size:1.85rem; color:var(--rust); line-height:1; letter-spacing:-0.02em;">{p.num}</span>
              <h3 class="font-display" style="font-size:1.05rem; font-weight:500; margin:0; line-height:1.22; letter-spacing:-0.015em;">{p.title}</h3>
            </div>
            <p style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink-500); line-height:1.6; margin:0;">{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:var(--ink); color:var(--sand-50);">
    <div style="max-width:1100px; margin:0 auto; padding:64px 28px; display:grid; grid-template-columns:1fr; gap:32px; align-items:center;" class="cta-grid">
      <div>
        <p style="font-family:'Inter Tight',sans-serif; font-size:13px; color:#d97757; font-weight:600; letter-spacing:0.04em; margin:0 0 14px;">Sequence starts here</p>
        <h2 class="font-display" style="font-size:clamp(1.85rem, 3.5vw, 2.85rem); line-height:1.05; letter-spacing:-0.02em; font-weight:500; margin:0 0 14px; color:var(--sand-50);">
          Start with course one.<br/>
          <span style="font-style:italic; font-weight:300; color:rgba(251,250,244,0.65);">Graduate the programme.</span>
        </h2>
        <p style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:clamp(1.05rem, 1.4vw, 1.2rem); line-height:1.55; color:rgba(251,250,244,0.78); margin:0; max-width:36rem;">
          Each course in the sequence issues its own credential. Finish all of them and the path-level credential publishes at a permanent verifiable URL.
        </p>
      </div>
      <div style="display:flex; flex-direction:column; gap:10px; max-width:300px; justify-self:end;">
        {pathCourses[0] && <a href={'/aquintutor/courses/' + pathCourses[0].slug} style={'background:' + accent + '; color:#fff; padding:13px 24px; border-radius:6px; font-family:Inter Tight,sans-serif; font-size:14px; font-weight:600; text-decoration:none; text-align:center;'}>Start with course 1 &rarr;</a>}
        <a href="/aquintutor/courses" style="background:transparent; color:var(--sand-50); padding:13px 24px; border-radius:6px; border:1px solid rgba(251,250,244,0.4); font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none; text-align:center;">Browse all courses</a>
      </div>
    </div>
  </section>

  <style>
    @media (min-width: 640px) { .stat-row { grid-template-columns: repeat(3, 1fr) !important; } }
    @media (min-width: 900px) { .stat-row { grid-template-columns: repeat(6, 1fr) !important; } .thesis-grid { grid-template-columns: 1.5fr 1fr !important; } .cta-grid { grid-template-columns: 1.6fr 1fr !important; } .grade-grid { grid-template-columns: repeat(3, 1fr) !important; } }
  </style>
</AquintutorLayout>
