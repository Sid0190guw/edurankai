---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { SITE } from '@/lib/site';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/aquintutor/paths');

let path: any = null;
let pathCourses: any[] = [];

try {
  const r = await db.execute(sql`SELECT * FROM training_paths WHERE slug = ${slug} AND is_published = true LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  path = rows[0] || null;
} catch (_) {}
if (!path) return Astro.redirect('/aquintutor/paths');

try {
  const r = await db.execute(sql`
    SELECT c.id, c.slug, c.title, c.subtitle, c.short_desc, c.course_code, c.level, c.duration_hours, c.duration_weeks, c.credit_hours, c.is_free,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) as lesson_count,
      pc.sort_order
    FROM training_path_courses pc
    JOIN training_courses c ON pc.course_id = c.id
    WHERE pc.path_id = ${path.id} AND c.is_published = true
    ORDER BY pc.sort_order ASC
  `);
  pathCourses = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

const totalDuration = pathCourses.reduce((s, c) => s + (Number(c.duration_hours) || 0), 0);
const totalLessons = pathCourses.reduce((s, c) => s + (Number(c.lesson_count) || 0), 0);

const pageTitle = path.title + ' - learning path';
const pageDesc = (path.tagline || path.description || '').substring(0, 160);

const pathSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: path.title,
  description: path.description || path.tagline || '',
  provider: { '@type': 'Organization', name: 'AquinTutor (EduRankAI)', sameAs: SITE.url },
  educationalLevel: path.level || 'mixed',
  hasCourseInstance: { '@type': 'CourseInstance', courseMode: 'online', courseWorkload: 'PT' + Math.ceil(totalDuration || 1) + 'H' },
};

const accent = path.hero_color || '#B8512E';
---
<AquintutorLayout title={pageTitle} description={pageDesc}>
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(pathSchema)} />

  <!-- HERO -->
  <section style={'border-bottom:1px solid var(--rule); border-top:4px solid ' + accent + ';'}>
    <div style="max-width:1400px; margin:0 auto; padding:48px 24px 40px;">
      <div style="display:flex; align-items:center; gap:14px; margin-bottom:20px;" class="numplate">
        <a href="/aquintutor/paths" style="color:var(--ink-500); text-decoration:none;">&larr; PATHS</a>
        <span style="color:var(--ink-300);">/</span>
        <span style={'color:' + accent + ';'}>{(path.level || 'MIXED').toUpperCase()}</span>
      </div>
      <h1 class="font-display" style="font-size:clamp(2.5rem,6vw,5.5rem); line-height:1; letter-spacing:-0.025em; font-weight:500; margin:0;">{path.title}</h1>
      {path.tagline && <p class="font-serif" style="font-size:clamp(1.25rem, 2vw, 1.875rem); font-style:italic; line-height:1.3; color:var(--ink-500); margin-top:18px; max-width:48rem;">{path.tagline}</p>}

      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(140px,1fr)); gap:10px; margin-top:32px; max-width:720px;">
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px;">
          <p class="numplate" style="color:var(--ink-500); margin:0 0 4px;">COURSES</p>
          <p class="font-display" style="font-size:1.875rem; font-weight:500; margin:0; line-height:1;">{pathCourses.length}</p>
        </div>
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px;">
          <p class="numplate" style="color:var(--ink-500); margin:0 0 4px;">LESSONS</p>
          <p class="font-display" style="font-size:1.875rem; font-weight:500; margin:0; line-height:1;">{totalLessons}</p>
        </div>
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px;">
          <p class="numplate" style="color:var(--ink-500); margin:0 0 4px;">TOTAL HOURS</p>
          <p class="font-display" style="font-size:1.875rem; font-weight:500; margin:0; line-height:1;">{totalDuration.toFixed(0)}H</p>
        </div>
        <div style="background:var(--paper); border:1px solid var(--rule); border-radius:10px; padding:14px;">
          <p class="numplate" style="color:var(--ink-500); margin:0 0 4px;">CREDENTIAL</p>
          <p class="font-display" style="font-size:1.875rem; font-weight:500; margin:0; line-height:1;">YES</p>
        </div>
      </div>
    </div>
  </section>

  {path.description && (
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:1400px; margin:0 auto; padding:64px 24px; display:grid; grid-template-columns:1fr; gap:32px;" class="thesis-grid">
        <div>
          <p class="eyebrow">&sect; I &mdash; Thesis</p>
          <p class="numplate" style="color:var(--ink-300); margin-top:8px;">PROGRAMME RATIONALE</p>
        </div>
        <div>
          <p class="font-serif" style="font-size:clamp(1.25rem, 2vw, 1.5rem); color:var(--ink-500); line-height:1.4; margin:0;">{path.description}</p>
        </div>
      </div>
    </section>
  )}

  {path.outcome && (
    <section style="border-bottom:1px solid var(--rule); background:var(--sand-100);">
      <div style="max-width:1400px; margin:0 auto; padding:64px 24px; display:grid; grid-template-columns:1fr; gap:32px;" class="thesis-grid">
        <div>
          <p class="eyebrow">&sect; II &mdash; Outcome</p>
          <p class="numplate" style="color:var(--ink-300); margin-top:8px;">ON COMPLETION</p>
        </div>
        <div>
          <p class="font-serif" style="font-size:clamp(1.25rem, 2vw, 1.5rem); color:var(--ink); line-height:1.4; margin:0;">{path.outcome}</p>
        </div>
      </div>
    </section>
  )}

  <section style="border-bottom:1px solid var(--rule);">
    <div style="max-width:1400px; margin:0 auto; padding:64px 24px;">
      <div style="display:grid; grid-template-columns:1fr; gap:32px; margin-bottom:36px;" class="thesis-grid">
        <div>
          <p class="eyebrow">&sect; III &mdash; Sequence</p>
          <p class="numplate" style="color:var(--ink-300); margin-top:8px;">{String(pathCourses.length).padStart(2, '0')} COURSES, IN ORDER</p>
        </div>
        <div>
          <h2 class="font-display" style="font-size:clamp(2rem,5vw,4rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0;">
            Course sequence.<br/>
            <span style="font-style:italic; font-weight:300; color:var(--ink-500);">Term by term.</span>
          </h2>
        </div>
      </div>

      {pathCourses.length === 0 && (
        <p class="font-serif" style="font-size:1.2rem; color:var(--ink-500); font-style:italic; padding:32px;">Courses are being added to this path.</p>
      )}

      <div style="display:flex; flex-direction:column; gap:0; background:var(--paper); border:1px solid var(--rule); border-radius:14px; overflow:hidden;">
        {pathCourses.map((c: any, i: number) => (
          <a href={'/aquintutor/courses/' + c.slug} style="display:grid; grid-template-columns:60px 1fr auto; gap:18px; align-items:center; padding:22px 24px; border-bottom:1px solid var(--rule); text-decoration:none; color:var(--ink);">
            <div style={'flex-shrink:0; width:48px; height:48px; border-radius:50%; background:' + accent + '15; border:1px solid ' + accent + '40; display:flex; align-items:center; justify-content:center; font-family:Fraunces,serif; font-weight:500; color:' + accent + '; font-size:1.3rem;'}>
              {i + 1}
            </div>
            <div style="min-width:0;">
              <div style="display:flex; gap:8px; flex-wrap:wrap;" class="numplate">
                <span style="color:var(--ink-300);">{c.course_code || (c.level || 'GEN').toUpperCase()}</span>
                {c.duration_weeks > 0 && <span style="color:var(--ink-300);">{c.duration_weeks}W</span>}
                {c.credit_hours > 0 && <span style="color:var(--ink-300);">{c.credit_hours}CR</span>}
              </div>
              <h3 class="font-display" style="font-size:1.375rem; margin:8px 0 4px; line-height:1.15; letter-spacing:-0.02em; font-weight:500;">{c.title}</h3>
              {c.subtitle ? (
                <p class="font-serif" style="font-size:1.05rem; font-style:italic; color:var(--ink-500); margin:0; line-height:1.4;">{c.subtitle}</p>
              ) : c.short_desc ? (
                <p style="font-size:13.5px; color:var(--ink-500); margin:0; line-height:1.5;">{c.short_desc}</p>
              ) : null}
            </div>
            <span class="numplate" style="color:var(--ink-300); flex-shrink:0;">VISIT &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="invert">
    <div style="max-width:1400px; margin:0 auto; padding:80px 24px; display:grid; grid-template-columns:1fr; gap:32px;" class="thesis-grid">
      <div>
        <p class="eyebrow" style="color:rgba(251,250,244,0.5);">&sect; IV &mdash; Begin</p>
        <p class="numplate" style="color:rgba(251,250,244,0.4); margin-top:8px;">SEQUENCE STARTS HERE</p>
      </div>
      <div>
        <h2 class="font-display" style="font-size:clamp(2.5rem,6vw,5rem); line-height:0.95; letter-spacing:-0.025em; font-weight:500; margin:0; color:var(--sand-50);">
          Start with course one.<br/>
          <span style="font-style:italic; font-weight:300; color:var(--gold);">Graduate the programme.</span>
        </h2>
        <p class="font-serif" style="font-size:1.5rem; color:rgba(251,250,244,0.8); margin-top:24px; max-width:42rem; line-height:1.3;">
          Each course in the sequence issues its own credential. Finish all of them and the path-level credential publishes at a permanent verifiable URL.
        </p>
        <div style="margin-top:36px; display:flex; gap:14px; flex-wrap:wrap;">
          {pathCourses[0] && <a href={'/aquintutor/courses/' + pathCourses[0].slug} class="btn-pill filled" style="background:var(--sand-50); color:var(--ink); border-color:var(--sand-50);">Start with course 1 &rarr;</a>}
          <a href="/aquintutor/courses" class="btn-pill outline" style="color:var(--sand-50); border-color:var(--sand-50);">Browse all courses</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    @media (min-width: 768px) { .thesis-grid { grid-template-columns: 3fr 9fr !important; } }
  </style>
</AquintutorLayout>
