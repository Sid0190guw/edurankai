---
// /aquintutor/assess/[id] — take an assessment (Prompt 8, main surface). Server-side gated:
// published + can(read) the securityLabels. Renders items WITHOUT answers; a student picks Practice
// (instant feedback, no eligibility) or Official (recorded, updates mastery). One inline script.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { can } from '@/lib/rbac';
import { createPgKernel } from '@/lib/kernel';
import { listItems } from '@/lib/assessment';
import { mdLite } from '@/lib/content-render';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/aquintutor/login?next=/aquintutor/assess/' + Astro.params.id);
const id = Astro.params.id!;
const obj = await createPgKernel().getObject(id).catch(() => null);
if (!obj) return new Response('Assessment not found', { status: 404 });
const labels = (obj as any).securityLabels || ['public'];
const gate = await can(user, 'read', { type: 'AssessmentObject', securityLabels: labels });
if (!gate.allow) return Astro.redirect('/aquintutor/courses?locked=1');
if (obj.lifecycleState !== 'published') return Astro.redirect('/aquintutor/courses');

const items = await listItems(id, false);   // answers stripped
const title = (obj.data as any).title;
---
<AquintutorLayout title={title}>
  <main style="max-width:720px;margin:0 auto;padding:44px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Assessment</p>
    <h1 style="font-family:Fraunces,serif;font-size:30px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 8px;line-height:1.15;">{title}</h1>
    <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#6b6455;margin:0 0 22px;">{items.length} question{items.length === 1 ? '' : 's'}. Practice is unscored with instant feedback; an official attempt is recorded and can update your mastery.</p>
    <div id="result" style="display:none;margin-bottom:22px;padding:14px 18px;border-radius:12px;font-family:'Inter Tight',sans-serif;font-size:14px;"></div>

    <form id="assessForm">
      {items.map((it: any, i: number) => (
        <div class="qitem" data-id={it.id} data-type={it.type} style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:12px;padding:16px 18px;margin-bottom:12px;">
          <div style="font-family:'Inter Tight',sans-serif;font-size:15.5px;font-weight:600;color:var(--ink,#1a1712);margin-bottom:10px;"><span set:html={String(i + 1) + '. ' + mdLite(it.prompt).replace(/^<p>|<\/p>$/g, '')}></span> <span style="font-weight:400;color:#8a8478;font-size:12.5px;">({it.points} pt{it.points === 1 ? '' : 's'})</span></div>
          {it.type === 'mcq' ? (it.options || []).map((opt: string, oi: number) => (
            <label style="display:block;font-family:'Inter Tight',sans-serif;font-size:14.5px;color:#2a251d;padding:5px 0;cursor:pointer;"><input type="radio" name={'q_' + it.id} value={oi} /> {opt}</label>
          )) : null}
          {it.type === 'true_false' ? (['true', 'false'].map((v) => (
            <label style="display:inline-block;font-family:'Inter Tight',sans-serif;font-size:14.5px;color:#2a251d;padding:5px 16px 5px 0;cursor:pointer;"><input type="radio" name={'q_' + it.id} value={v} /> {v === 'true' ? 'True' : 'False'}</label>
          ))) : null}
          {it.type === 'numeric' ? <input type="number" step="any" name={'q_' + it.id} style="font-family:'Inter Tight',sans-serif;font-size:14.5px;padding:8px 10px;border:1px solid var(--line,#e6e1d6);border-radius:8px;width:180px;" /> : null}
          {it.type === 'short_answer' ? <textarea name={'q_' + it.id} rows="3" style="font-family:'Inter Tight',sans-serif;font-size:14.5px;padding:8px 10px;border:1px solid var(--line,#e6e1d6);border-radius:8px;width:100%;box-sizing:border-box;" placeholder="Your answer (graded by a reviewer)"></textarea> : null}
          <p class="qfb" style="display:none;font-family:'Inter Tight',sans-serif;font-size:13px;margin:8px 0 0;"></p>
        </div>
      ))}
      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:8px;">
        <button type="button" id="btnPractice" style="background:#fff;border:1px solid var(--ink,#1a1712);color:var(--ink,#1a1712);border-radius:10px;padding:11px 22px;font-family:'Inter Tight',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">Practice (unscored)</button>
        <button type="button" id="btnOfficial" style="background:var(--ink,#1a1712);color:var(--sand-50,#fbfaf4);border:none;border-radius:10px;padding:11px 22px;font-family:'Inter Tight',sans-serif;font-size:14px;font-weight:600;cursor:pointer;">Official attempt</button>
      </div>
    </form>
  </main>

  <script is:inline define:vars={{ assessmentId: id }}>
    (function () {
      var resultEl = document.getElementById('result');
      function collect() {
        var out = {};
        document.querySelectorAll('.qitem').forEach(function (q) {
          var id = q.getAttribute('data-id'), type = q.getAttribute('data-type'), r = {};
          if (type === 'mcq') { var c = q.querySelector('input[name="q_' + id + '"]:checked'); if (c) r.choice = parseInt(c.value, 10); }
          else if (type === 'true_false') { var t = q.querySelector('input[name="q_' + id + '"]:checked'); if (t) r.value = t.value === 'true'; }
          else if (type === 'numeric') { var n = q.querySelector('input[name="q_' + id + '"]'); if (n && n.value !== '') r.value = parseFloat(n.value); }
          else { var s = q.querySelector('textarea[name="q_' + id + '"]'); if (s) r.text = s.value; }
          out[id] = r;
        });
        return out;
      }
      function submit(mode) {
        resultEl.style.display = 'block'; resultEl.style.background = '#faf8f2'; resultEl.style.color = '#6b6455'; resultEl.textContent = 'Submitting…';
        fetch('/api/aquintutor/attempt', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ assessmentId: assessmentId, mode: mode, responses: collect() }) })
          .then(function (r) { return r.json(); })
          .then(function (j) {
            if (!j.ok) { resultEl.style.background = '#fdecec'; resultEl.style.color = '#9b2c2c'; resultEl.textContent = j.error || 'Failed'; return; }
            var ok = j.passed;
            resultEl.style.background = j.needsManual ? '#fff8ef' : (ok ? '#eef8f1' : '#fdecec');
            resultEl.style.color = j.needsManual ? '#8a5a1a' : (ok ? '#2f7d5b' : '#9b2c2c');
            resultEl.textContent = j.needsManual ? ('Submitted. Auto-graded so far: ' + j.pct + '% — short answers await a reviewer.') : ((mode === 'practice' ? 'Practice: ' : 'Official: ') + j.pct + '% — ' + (ok ? 'passed' : 'not yet passed') + '.');
            if (mode === 'practice' && j.feedback) {
              document.querySelectorAll('.qitem').forEach(function (q) {
                var f = j.feedback[q.getAttribute('data-id')]; var el = q.querySelector('.qfb'); if (!f || !el) return;
                el.style.display = 'block';
                if (f.needsManual) { el.style.color = '#8a5a1a'; el.textContent = 'Awaits reviewer grading.'; }
                else { el.style.color = f.correct ? '#2f7d5b' : '#9b2c2c'; el.textContent = f.correct ? 'Correct' : 'Not correct'; }
              });
            }
            window.scrollTo({ top: 0, behavior: 'smooth' });
          }).catch(function () { resultEl.style.background = '#fdecec'; resultEl.style.color = '#9b2c2c'; resultEl.textContent = 'Network error'; });
      }
      document.getElementById('btnPractice').addEventListener('click', function () { submit('practice'); });
      document.getElementById('btnOfficial').addEventListener('click', function () { submit('official'); });
    })();
  </script>
</AquintutorLayout>
