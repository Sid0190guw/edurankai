---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { LABS, LAB_CATEGORIES } from '@/data/labs-catalog';

const flagship = LABS.filter((l) => l.flagship);
const grouped = LAB_CATEGORIES.map((cat) => ({ cat, labs: LABS.filter((l) => l.category === cat) }));
const origin = 'https://edurankai.in';
---
<BaseLayout title="Virtual Labs — license & embed" description="Interactive, instrument-grade engineering labs — quantum, AI/ML, cybersecurity, embedded, CAD/FEA — embeddable into any LMS or virtual campus via iframe, SDK, LTI or a JSON API. Self-hosted, offline-capable, built from scratch.">
  <!-- Hero -->
  <section class="px-[5vw] pt-14 md:pt-20 pb-8 max-w-5xl mx-auto">
    <p class="eyebrow mb-3">Virtual Labs · For institutions</p>
    <h1 class="font-display text-[clamp(2rem,5.5vw,3.4rem)] font-semibold text-ink leading-[1.05] tracking-tight mb-4">
      Interactive labs, <em class="italic text-burn font-medium">embeddable as an API.</em>
    </h1>
    <p class="text-[1.05rem] text-ink-soft leading-relaxed max-w-2xl mb-5">
      Course platforms stream video. We build <strong class="text-ink font-medium">instruments</strong> — a real quantum circuit simulator, a neural network you train by hand, a stack-overflow exploit range, a microcontroller you program in assembly, a CAD/FEA suite. Each runs in the browser, offline, from scratch — and drops straight into your LMS or virtual campus.
    </p>
    <div class="flex flex-wrap gap-x-6 gap-y-2 text-[0.85rem] text-ink-soft font-mono">
      <span><strong class="text-ink">{LABS.length}</strong> labs</span>
      <span><strong class="text-ink">{LAB_CATEGORIES.length}</strong> disciplines</span>
      <span><strong class="text-ink">iframe · SDK · LTI · JSON API</strong></span>
      <span><strong class="text-ink">offline-capable</strong>, no third-party libraries</span>
    </div>
  </section>

  <!-- Live demo -->
  <section class="px-[5vw] pb-12 max-w-5xl mx-auto">
    <div class="flex items-center justify-between gap-3 mb-3 flex-wrap">
      <h2 class="font-display text-[1.4rem] font-semibold text-ink">Try one — this is a live embed</h2>
      <select id="demoSel" class="bg-white border border-ink/15 rounded-lg px-3 py-2 text-[0.85rem] text-ink outline-none focus:border-burn">
        {flagship.map((l) => <option value={l.slug}>{l.title}</option>)}
      </select>
    </div>
    <div class="rounded-2xl overflow-hidden border border-ink/12 shadow-xl bg-[#0b0d13]">
      <iframe id="demoFrame" src={'/aquintutor/labs/' + flagship[0].slug + '?embed=1'} title="Live lab embed" style="width:100%;height:min(72vh,620px);border:0;display:block;" allow="microphone; fullscreen; clipboard-write"></iframe>
    </div>
    <p class="text-[0.8rem] text-ink-soft mt-2">Exactly what your learners would see inside your platform — chromeless, themeable, self-contained.</p>
  </section>

  <!-- Integration -->
  <section class="px-[5vw] py-10 max-w-5xl mx-auto border-t border-ink/8">
    <h2 class="font-display text-[1.6rem] font-semibold text-ink mb-1">Integrate in one line</h2>
    <p class="text-[0.95rem] text-ink-soft mb-6 max-w-2xl">Three ways in, depending on your stack. All point at self-hosted, versioned endpoints.</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="bg-cream-2 border border-ink/10 rounded-2xl p-5">
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-2">1 · Embed SDK</p>
        <p class="text-[0.82rem] text-ink-soft mb-3 leading-relaxed">Drop a script + a div anywhere. Auto-mounts a responsive iframe; relays progress events to your gradebook.</p>
        <pre class="code-block" data-copy>{`<script src="${origin}/era-labs-embed.js"></script>
<div data-era-lab="quantum-lab"
     data-height="640"></div>`}</pre>
      </div>
      <div class="bg-cream-2 border border-ink/10 rounded-2xl p-5">
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-2">2 · Plain iframe</p>
        <p class="text-[0.82rem] text-ink-soft mb-3 leading-relaxed">No script needed. Any CMS or LMS that allows an iframe embed works immediately.</p>
        <pre class="code-block" data-copy>{`<iframe
  src="${origin}/aquintutor/labs/nn-playground?embed=1"
  width="100%" height="640"
  style="border:0;border-radius:12px">
</iframe>`}</pre>
      </div>
      <div class="bg-cream-2 border border-ink/10 rounded-2xl p-5">
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-2">3 · JSON API + LTI</p>
        <p class="text-[0.82rem] text-ink-soft mb-3 leading-relaxed">Discover every lab and its embed URL programmatically. LTI 1.3 launch for Canvas / Moodle on request.</p>
        <pre class="code-block" data-copy>{`GET ${origin}/api/labs/catalog.json
// { labs: [ { slug, title,
//   category, embedUrl } ] }`}</pre>
      </div>
    </div>
    <p class="text-[0.82rem] text-ink-soft mt-4 font-mono">Events: the lab posts <code class="text-ink">{'{ source:"era-lab", type, slug }'}</code> via <code class="text-ink">postMessage</code> — the SDK re-dispatches them as a DOM <code class="text-ink">era-lab</code> event you can forward to your LRS.</p>
  </section>

  <!-- Catalog -->
  <section class="px-[5vw] py-10 max-w-5xl mx-auto border-t border-ink/8">
    <h2 class="font-display text-[1.6rem] font-semibold text-ink mb-6">The catalogue</h2>
    {grouped.map((g) => (
      <div class="mb-8">
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-ink-soft font-bold mb-3">{g.cat}</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {g.labs.map((l) => (
            <a href={'/aquintutor/labs/' + l.slug} class="group bg-white border border-ink/10 hover:border-burn-dim rounded-xl p-4 transition-all flex flex-col">
              <div class="flex items-center gap-2 mb-1">
                <span class="font-display text-[1.02rem] font-semibold text-ink group-hover:text-burn transition-colors">{l.title}</span>
                {l.flagship && <span class="text-[0.55rem] font-mono uppercase tracking-wider bg-burn-pale text-burn border border-burn-dim px-1.5 py-0.5 rounded">Flagship</span>}
              </div>
              <p class="text-[0.8rem] text-ink-soft leading-relaxed flex-1">{l.blurb}</p>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>

  <!-- CTA -->
  <section class="px-[5vw] py-14 max-w-5xl mx-auto border-t border-ink/8">
    <div class="bg-ink rounded-2xl p-8 md:p-10 text-center">
      <h2 class="font-display text-[1.7rem] font-semibold text-white mb-2">License the labs for your institution</h2>
      <p class="text-[0.95rem] text-white/70 leading-relaxed max-w-xl mx-auto mb-6">Per-seat or campus licensing, your branding, SSO/LTI, and usage analytics. Tell us your stack and cohort size and we'll scope an integration.</p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="mailto:connect@edurankai.in?subject=Virtual%20Labs%20licensing" class="bg-burn hover:bg-burn/90 text-white font-semibold py-3 px-6 rounded-xl text-[0.92rem] transition-all">Request a license</a>
        <a href="/api/labs/catalog.json" class="border border-white/30 text-white font-semibold py-3 px-6 rounded-xl text-[0.92rem] hover:bg-white/10 transition-all">View the labs API</a>
      </div>
    </div>
  </section>

  <style>
    .code-block { background:#0d1117; color:#c9d1d9; border:1px solid rgba(255,255,255,0.08); border-radius:8px; padding:11px 12px; font-family:'Geist Mono',ui-monospace,monospace; font-size:11px; line-height:1.55; white-space:pre-wrap; word-break:break-word; overflow-x:auto; cursor:copy; position:relative; }
    .code-block:hover { border-color:rgba(255,79,0,0.4); }
    .code-block.copied::after { content:'copied'; position:absolute; top:6px; right:8px; font-size:9px; color:#86efac; }
  </style>
  <script is:inline>
    (function () {
      var sel = document.getElementById('demoSel'), fr = document.getElementById('demoFrame');
      if (sel) sel.addEventListener('change', function () { fr.src = '/aquintutor/labs/' + this.value + '?embed=1'; });
      document.querySelectorAll('[data-copy]').forEach(function (el) {
        el.addEventListener('click', function () {
          navigator.clipboard && navigator.clipboard.writeText(el.textContent).then(function () { el.classList.add('copied'); setTimeout(function () { el.classList.remove('copied'); }, 1200); });
        });
      });
    })();
  </script>
</BaseLayout>
