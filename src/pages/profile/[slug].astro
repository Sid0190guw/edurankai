---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getProfileBySlug } from '@/lib/applicant-profile';

const { slug } = Astro.params;
const profile = slug ? await getProfileBySlug(slug) : null;

const c = (profile?.common || {}) as any;
const links = (profile?.links || {}) as any;
const skills: string[] = Array.isArray(profile?.skills) ? profile!.skills : [];
const experience: any[] = Array.isArray(profile?.experience) ? profile!.experience : [];
const education: any[] = Array.isArray(profile?.education) ? profile!.education : [];
const fullName = profile ? (((c.firstName || '') + ' ' + (c.lastName || '')).trim() || 'Member') : '';
const initials = (((c.firstName || ' ')[0] || '') + ((c.lastName || ' ')[0] || '')).toUpperCase() || 'EA';
const linkList = [
  { label: 'LinkedIn', url: links.linkedin },
  { label: 'GitHub', url: links.github },
  { label: 'Portfolio', url: links.portfolio },
  { label: 'Twitter', url: links.twitter },
].filter((l) => l.url);
---
{!profile ? (
  <BaseLayout title="Profile not found - EduRankAI" description="This profile is private or does not exist.">
    <section class="px-[5vw] py-24 max-w-xl mx-auto text-center">
      <h1 class="font-display text-2xl font-semibold text-ink mb-2">This profile isn't available.</h1>
      <p class="text-[0.92rem] text-ink-soft mb-6">It may be private, or the link may be incorrect.</p>
      <a href="/" class="btn-primary">Back to EduRankAI</a>
    </section>
  </BaseLayout>
) : (
  <BaseLayout title={fullName + ' - EduRankAI'} description={profile.headline || ('Profile of ' + fullName)}>
    <section class="px-[5vw] py-8 md:py-12 max-w-3xl mx-auto">
      <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 mb-6">
        <div class="flex items-start gap-5 flex-wrap">
          {c.photoUrl
            ? <img src={c.photoUrl} alt={fullName} class="w-20 h-20 md:w-24 md:h-24 rounded-2xl object-cover border border-ink/10" />
            : <div class="w-20 h-20 md:w-24 md:h-24 rounded-2xl grid place-items-center font-display text-2xl font-semibold text-burn" style="background:#FFEDE4;">{initials}</div>}
          <div class="flex-1 min-w-0">
            <h1 class="font-display text-[clamp(1.5rem,4vw,2.1rem)] font-semibold text-ink leading-tight">{fullName}</h1>
            {profile.headline && <p class="text-[1rem] text-ink-2 mt-1 leading-snug">{profile.headline}</p>}
            {c.currentCity && (
              <p class="text-[0.85rem] text-ink-soft mt-2 inline-flex items-center gap-1.5">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {c.currentCity}
              </p>
            )}
            {linkList.length > 0 && (
              <div class="flex flex-wrap gap-2 mt-3">
                {linkList.map((l) => (
                  <a href={l.url} target="_blank" rel="noopener nofollow" class="text-[0.78rem] font-semibold text-burn border border-burn-dim bg-burn-pale rounded-full px-3 py-1 no-underline hover:bg-burn hover:text-white transition-colors">{l.label}</a>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>

      {profile.bio && (
        <div class="bg-white border border-ink/10 rounded-2xl p-6 mb-6">
          <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-ink-soft font-bold mb-2">About</p>
          <p class="text-[0.92rem] text-ink-2 leading-[1.8] whitespace-pre-line">{profile.bio}</p>
        </div>
      )}

      {skills.length > 0 && (
        <div class="bg-white border border-ink/10 rounded-2xl p-6 mb-6">
          <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-ink-soft font-bold mb-3">Skills</p>
          <div class="flex flex-wrap gap-2">
            {skills.map((s) => <span class="text-[0.82rem] font-medium text-ink bg-cream-2 border border-ink/10 rounded-full px-3 py-1">{s}</span>)}
          </div>
        </div>
      )}

      {experience.length > 0 && (
        <div class="bg-white border border-ink/10 rounded-2xl p-6 mb-6">
          <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-ink-soft font-bold mb-4">Experience</p>
          <div class="space-y-5">
            {experience.map((e: any) => (
              <div class="flex gap-4">
                <div class="w-2 h-2 rounded-full bg-burn mt-2 shrink-0"></div>
                <div class="min-w-0">
                  <p class="font-display text-[1.02rem] font-semibold text-ink leading-snug">{e.title || 'Role'}</p>
                  <p class="text-[0.85rem] text-ink-2">{[e.org, e.period].filter(Boolean).join(' · ')}</p>
                  {e.detail && <p class="text-[0.85rem] text-ink-soft mt-1 leading-relaxed">{e.detail}</p>}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {education.length > 0 && (
        <div class="bg-white border border-ink/10 rounded-2xl p-6 mb-6">
          <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-ink-soft font-bold mb-4">Education</p>
          <div class="space-y-5">
            {education.map((e: any) => (
              <div class="flex gap-4">
                <div class="w-2 h-2 rounded-full bg-sky mt-2 shrink-0"></div>
                <div class="min-w-0">
                  <p class="font-display text-[1.02rem] font-semibold text-ink leading-snug">{e.school || 'Institution'}</p>
                  <p class="text-[0.85rem] text-ink-2">{[e.degree, e.period].filter(Boolean).join(' · ')}</p>
                  {e.detail && <p class="text-[0.85rem] text-ink-soft mt-1 leading-relaxed">{e.detail}</p>}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <p class="text-center text-[0.75rem] text-ink-soft mt-8">
        <a href="/" class="text-burn no-underline hover:underline">EduRankAI</a> · Public profile
      </p>
    </section>
  </BaseLayout>
)}
