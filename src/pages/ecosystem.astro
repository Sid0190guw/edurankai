---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { products } from '@/lib/db/schema';
import { eq, asc } from 'drizzle-orm';

const allProducts = await db.select().from(products)
  .where(eq(products.isVisible, true))
  .orderBy(asc(products.sortOrder), asc(products.name));

const STATUS_LABELS: Record<string, string> = {
  live: 'Live',
  coming_soon: 'Coming Soon',
  in_development: 'In Development',
  research: 'Research',
  stealth: 'Stealth'
};

const STATUS_COLORS: Record<string, string> = {
  live: 'bg-leaf-bg text-leaf border-leaf-border',
  coming_soon: 'bg-burn-pale text-burn border-burn-dim',
  in_development: 'bg-sky-bg text-sky border-sky-border',
  research: 'bg-plum-bg text-plum border-plum-border',
  stealth: 'bg-ink/5 text-ink-soft border-ink/15'
};
---
<BaseLayout title="Ecosystem - EduRankAI" description="Six ventures across AI, education, communication, and research. More coming.">

  <section class="px-[5vw] py-12 md:py-20 max-w-5xl mx-auto">

    <div class="mb-12 md:mb-16">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-2">ECOSYSTEM</p>
      <h1 class="font-display text-[clamp(2.2rem,5.5vw,3.5rem)] font-semibold text-ink leading-[1.05] tracking-tight mb-4">
        Six ventures, <em class="italic text-burn font-medium">more coming.</em>
      </h1>
      <p class="text-[1.05rem] text-ink-soft leading-relaxed max-w-2xl">
        EduRankAI is not one product. It is a small set of focused ventures across education, AI, communication, and research. Each is being built with the same standards: honest about what it is, honest about what it isn't, and shipped when ready.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {allProducts.map((p) => {
        const statusClass = STATUS_COLORS[p.status] || 'bg-cream-2 text-ink-soft border-ink/15';
        const statusLabel = STATUS_LABELS[p.status] || p.status;
        return (
          <a href={'/ecosystem/' + p.slug} class="bg-white border border-ink/10 hover:border-burn-dim rounded-2xl p-6 transition-all block group">
            <div class="flex items-start justify-between gap-3 mb-3">
              <h2 class="font-display text-[1.3rem] font-semibold text-ink leading-tight group-hover:text-burn transition-colors">
                {p.name}
              </h2>
              <span class={'shrink-0 inline-block text-[0.62rem] font-bold uppercase tracking-wider border px-2 py-0.5 rounded-full ' + statusClass}>
                {statusLabel}
              </span>
            </div>
            <p class="text-[0.92rem] text-ink-2 leading-relaxed mb-4">{p.shortDescription}</p>
            <div class="flex items-center gap-2 text-[0.78rem] font-mono text-ink-soft group-hover:text-burn transition-colors">
              <span>Read more</span>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </div>
          </a>
        );
      })}
    </div>

    <div class="mt-12 md:mt-16 bg-cream-2 border border-ink/10 rounded-2xl p-6 md:p-8">
      <h3 class="font-display text-[1.2rem] font-semibold text-ink mb-2">A note on honesty</h3>
      <p class="text-[0.9rem] text-ink-2 leading-relaxed">
        We have chosen to show our roster as it actually is - with launch dates, development stages, and research-only work clearly marked. We do not claim something is "live" if it isn't yet. We do not invent metrics. If you are evaluating us as an employer, investor, or partner, you are seeing the same picture our team sees internally.
      </p>
    </div>

  </section>

</BaseLayout>
