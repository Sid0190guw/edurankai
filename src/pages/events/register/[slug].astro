---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/events');

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/events/register/' + slug));

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
const ev: any = rows(await db.execute(sql`SELECT * FROM events WHERE slug = ${slug} AND status != 'draft' LIMIT 1`))[0];
if (!ev) return Astro.redirect('/events');
if (!ev.is_series) return Astro.redirect('/events/' + slug);

// Already registered?
const existing = rows(await db.execute(sql`SELECT id FROM event_registrations WHERE event_id = ${ev.id} AND user_id = ${user.id} LIMIT 1`))[0];
if (existing) return Astro.redirect('/events/panel/' + ev.id);
if (ev.registration_open === false) return Astro.redirect('/events/' + slug);

let errorMsg = '';
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const name = (fd.get('name') as string || '').trim();
  const email = (fd.get('email') as string || '').trim().toLowerCase();
  const phone = (fd.get('phone') as string || '').trim() || null;
  const city = (fd.get('city') as string || '').trim() || null;
  const institution = (fd.get('institution') as string || '').trim() || null;
  if (!name || !email || !email.includes('@')) {
    errorMsg = 'Name and a valid email are required.';
  } else {
    try {
      const ip = (Astro.request.headers.get('x-forwarded-for') || '').substring(0, 64);
      const ins = rows(await db.execute(sql`
        INSERT INTO event_registrations (event_id, user_id, participant_name, participant_email, participant_phone, participant_city, institution, ip_address)
        VALUES (${ev.id}, ${user.id}, ${name}, ${email}, ${phone}, ${city}, ${institution}, ${ip})
        ON CONFLICT (event_id, lower(participant_email)) DO UPDATE SET participant_name = EXCLUDED.participant_name, updated_at = NOW()
        RETURNING id
      `));
      try {
        const { pushNotify } = await import('@/lib/push');
        if ((pushNotify as any).eventRegistration) await (pushNotify as any).eventRegistration(name, ev.title, ev.id);
      } catch (_) {}
      return Astro.redirect('/events/panel/' + ev.id);
    } catch (err: any) {
      errorMsg = 'Could not register: ' + (err.message || 'unknown error');
    }
  }
}
---
<BaseLayout title={'Register - ' + ev.title} description="Register for this event.">
  <section class="px-[5vw] py-10 md:py-16 max-w-xl mx-auto">
    <a href={'/events/' + slug} class="text-[0.82rem] text-ink-soft hover:text-burn font-mono">Back to event</a>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.4rem)] font-semibold text-ink leading-tight mt-3 mb-2">Register for <em class="italic text-burn font-medium">{ev.title}</em></h1>
    <p class="text-[0.9rem] text-ink-soft leading-relaxed mb-6">Confirm your details. You will then progress level by level, paying any level fees and taking the tests from your panel.</p>

    {errorMsg && <div class="bg-red-500/10 border border-red-500/30 text-red-700 rounded-lg p-3 mb-4 text-[0.85rem]">{errorMsg}</div>}

    <form method="POST" class="flex flex-col gap-4 bg-white border border-ink/10 rounded-2xl p-5 md:p-6">
      <div>
        <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-1.5">Full name *</label>
        <input type="text" name="name" required value={user.name || ''} class="w-full px-3 py-2.5 bg-cream-2 border border-ink/15 rounded-lg text-[0.9rem] text-ink outline-none focus:border-burn" />
      </div>
      <div>
        <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-1.5">Email *</label>
        <input type="email" name="email" required value={user.email || ''} class="w-full px-3 py-2.5 bg-cream-2 border border-ink/15 rounded-lg text-[0.9rem] text-ink outline-none focus:border-burn" />
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-1.5">Phone</label>
          <input type="text" name="phone" class="w-full px-3 py-2.5 bg-cream-2 border border-ink/15 rounded-lg text-[0.9rem] text-ink outline-none focus:border-burn" />
        </div>
        <div>
          <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-1.5">City</label>
          <input type="text" name="city" class="w-full px-3 py-2.5 bg-cream-2 border border-ink/15 rounded-lg text-[0.9rem] text-ink outline-none focus:border-burn" />
        </div>
      </div>
      <div>
        <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-1.5">School / institution</label>
        <input type="text" name="institution" class="w-full px-3 py-2.5 bg-cream-2 border border-ink/15 rounded-lg text-[0.9rem] text-ink outline-none focus:border-burn" />
      </div>
      <button type="submit" class="bg-burn hover:bg-burn/90 text-white font-semibold py-3 rounded-lg text-[0.92rem] mt-1">Register</button>
    </form>
  </section>
</BaseLayout>
