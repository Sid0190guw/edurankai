---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { events } from '@/lib/db/schema';
import { sql } from 'drizzle-orm';
import { eq, and, ne } from 'drizzle-orm';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/events');

const found = await db.select().from(events)
  .where(and(eq(events.slug, slug), ne(events.status, 'draft')))
  .limit(1);

if (found.length === 0) return Astro.redirect('/events');
const event = found[0];

function evRows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
const isSeries = (event as any).is_series === true || (event as any).isSeries === true;
const levels = isSeries ? evRows(await db.execute(sql`SELECT * FROM event_levels WHERE event_id = ${event.id} AND is_active = true ORDER BY sort_order ASC, created_at ASC`)) : [];
const regOpen = (event as any).registration_open !== false;

const user = Astro.locals.user;
let myRegId: string | null = null;
if (user && isSeries) {
  const rr = evRows(await db.execute(sql`SELECT id FROM event_registrations WHERE event_id = ${event.id} AND user_id = ${user.id} LIMIT 1`));
  myRegId = rr[0]?.id || null;
}
function fmtLvl(d: any): string { return d ? new Date(d).toLocaleString('en-IN', { day: 'numeric', month: 'short', year: 'numeric', hour: 'numeric', minute: '2-digit' }) : 'TBD'; }

// Media for the preview: cover image / GIF + video or YouTube embed.
const coverImageUrl = (event as any).coverImageUrl || (event as any).cover_image_url || '';
const rawVideo = (event as any).videoUrl || (event as any).video_url || '';
function youTubeId(u: string): string | null {
  const m = u.match(/(?:youtube\.com\/(?:watch\?v=|embed\/|shorts\/)|youtu\.be\/)([A-Za-z0-9_-]{6,})/);
  return m ? m[1] : null;
}
const ytId = rawVideo ? youTubeId(rawVideo) : null;
const isMp4 = rawVideo && /\.(mp4|webm|ogg)(\?|$)/i.test(rawVideo);

const MODE_LABELS: Record<string, string> = {
  online: 'Online',
  in_person: 'In-Person',
  hybrid: 'Hybrid'
};

const STATUS_LABELS: Record<string, string> = {
  upcoming: 'Upcoming',
  past: 'Past event',
  cancelled: 'Cancelled',
  draft: 'Draft'
};

const STATUS_COLORS: Record<string, string> = {
  upcoming: 'bg-burn-pale text-burn border-burn-dim',
  past: 'bg-cream-2 text-ink-soft border-ink/15',
  cancelled: 'bg-ink/5 text-ink-soft border-ink/15',
  draft: 'bg-ink/5 text-ink-soft border-ink/15'
};

function formatDateTime(d: any): string {
  if (!d) return 'TBD';
  return new Date(d).toLocaleString('en-IN', { day: 'numeric', month: 'long', year: 'numeric', hour: 'numeric', minute: '2-digit' });
}

const statusClass = STATUS_COLORS[event.status] || 'bg-cream-2 text-ink-soft border-ink/15';
const isCancelled = event.status === 'cancelled';
const isPast = event.status === 'past';

const tags = Array.isArray(event.tags) ? event.tags : [];
---
<BaseLayout title={event.title + ' - EduRankAI Events'} description={event.description || ''}>

  <section class="px-[5vw] py-10 md:py-16 max-w-3xl mx-auto">

    <div class="mb-6">
      <a href="/events" class="text-[0.82rem] text-ink-soft hover:text-burn font-mono">Back to events</a>
    </div>

    <div class="mb-8 pb-8 border-b border-ink/8">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <span class={'inline-block text-[0.7rem] font-bold uppercase tracking-wider border px-3 py-1 rounded-full ' + statusClass}>
          {STATUS_LABELS[event.status] || event.status}
        </span>
        <span class="text-[0.7rem] font-bold uppercase tracking-wider bg-sky-bg text-sky border border-sky-border px-3 py-1 rounded-full">
          {MODE_LABELS[event.mode] || event.mode}
        </span>
        {tags.map((t: string) => (
          <span class="text-[0.7rem] font-mono uppercase tracking-wider bg-cream-2 text-ink-soft border border-ink/10 px-2.5 py-1 rounded-full">{t}</span>
        ))}
      </div>

      <h1 class="font-display text-[clamp(2rem,5vw,3rem)] font-semibold text-ink leading-[1.05] tracking-tight mb-4">
        {event.title}
      </h1>

      {event.description && (
        <p class="text-[1rem] text-ink-soft leading-relaxed">{event.description}</p>
      )}
    </div>

    {(ytId || isMp4 || coverImageUrl) && (
      <div class="mb-8 rounded-2xl overflow-hidden border border-ink/10 bg-ink/5">
        {ytId ? (
          <div style="position:relative;width:100%;padding-top:56.25%;">
            <iframe src={'https://www.youtube.com/embed/' + ytId} title="Event video" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen style="position:absolute;inset:0;width:100%;height:100%;border:0;"></iframe>
          </div>
        ) : isMp4 ? (
          <video src={rawVideo} controls playsinline poster={coverImageUrl || undefined} style="width:100%;display:block;max-height:460px;background:#000;"></video>
        ) : (
          <img src={coverImageUrl} alt={event.title} style="width:100%;display:block;max-height:460px;object-fit:cover;" />
        )}
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
      <div class="bg-cream-2 border border-ink/10 rounded-xl p-4">
        <p class="text-[0.62rem] font-mono uppercase tracking-wider text-ink-soft mb-1">When</p>
        <p class="font-semibold text-ink text-[0.95rem]">{formatDateTime(event.startsAt)}</p>
        {event.endsAt && (
          <p class="text-[0.78rem] text-ink-soft mt-1">Until {formatDateTime(event.endsAt)}</p>
        )}
      </div>
      <div class="bg-cream-2 border border-ink/10 rounded-xl p-4">
        <p class="text-[0.62rem] font-mono uppercase tracking-wider text-ink-soft mb-1">Where</p>
        <p class="font-semibold text-ink text-[0.95rem]">{event.location || 'TBD'}</p>
        <p class="text-[0.78rem] text-ink-soft mt-1">{MODE_LABELS[event.mode] || event.mode}</p>
      </div>
    </div>

    {isCancelled && (
      <div class="bg-ink/5 border border-ink/15 rounded-2xl p-5 md:p-6 mb-8">
        <p class="font-semibold text-ink-2 mb-1">This event was cancelled</p>
        <p class="text-[0.88rem] text-ink-soft">If you need information about a future rescheduled session, please reach out via Contact.</p>
      </div>
    )}

    {event.longDescription && (
      <div class="mb-10">
        <h2 class="font-display text-[1.3rem] font-semibold text-ink mb-3">About this event</h2>
        <div class="text-[0.95rem] text-ink-2 leading-relaxed whitespace-pre-wrap">
          {event.longDescription}
        </div>
      </div>
    )}

    {isSeries && levels.length > 0 && (
      <div class="mb-10">
        <h2 class="font-display text-[1.3rem] font-semibold text-ink mb-4">Levels</h2>
        <div class="flex flex-col gap-3">
          {levels.map((lv: any, i: number) => (
            <div class="relative bg-white border border-ink/10 rounded-2xl p-5">
              <div class="flex items-start gap-4">
                <div class="shrink-0 w-9 h-9 rounded-full bg-burn-pale border border-burn-dim text-burn font-bold flex items-center justify-center text-[0.9rem]">{i + 1}</div>
                <div class="flex-1">
                  <div class="flex flex-wrap items-center gap-2 mb-1">
                    <h3 class="font-display text-[1.1rem] font-semibold text-ink">{lv.name}</h3>
                    {lv.fee_chf > 0 ? (
                      <span class="text-[0.62rem] font-bold uppercase tracking-wider bg-cream-2 text-ink-soft border border-ink/15 px-2 py-0.5 rounded-full">{lv.fee_chf} CHF</span>
                    ) : (
                      <span class="text-[0.62rem] font-bold uppercase tracking-wider bg-leaf-bg text-leaf border border-leaf-border px-2 py-0.5 rounded-full">Free</span>
                    )}
                    {lv.test_slug && <span class="text-[0.62rem] font-bold uppercase tracking-wider bg-sky-bg text-sky border border-sky-border px-2 py-0.5 rounded-full">Test{lv.pass_mark ? ' - pass ' + lv.pass_mark + '%' : ''}</span>}
                  </div>
                  {lv.description && <p class="text-[0.85rem] text-ink-2 leading-relaxed mb-2">{lv.description}</p>}
                  <div class="flex flex-wrap gap-x-4 gap-y-1 text-[0.75rem] text-ink-soft font-mono">
                    {lv.starts_at && <span>{fmtLvl(lv.starts_at)}{lv.ends_at ? ' to ' + fmtLvl(lv.ends_at) : ''}</span>}
                    {lv.conclusion_at && <span>Results: {fmtLvl(lv.conclusion_at)}</span>}
                    {lv.outcome_label && <span class="text-burn">{lv.outcome_label}</span>}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    {isSeries && regOpen && !isCancelled && (
      <div class="bg-burn-pale border border-burn-dim rounded-2xl p-5 md:p-6 mb-8">
        {!user ? (
          <>
            <p class="font-semibold text-burn mb-2 text-[0.95rem]">Register to take part</p>
            <p class="text-[0.85rem] text-ink-2 mb-3">Sign in to register, pay any level fees, take the tests, and collect your certificates.</p>
            <a href={'/portal/login?next=' + encodeURIComponent('/events/register/' + event.slug)} class="inline-flex items-center gap-2 bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.88rem]">Sign in to register</a>
          </>
        ) : myRegId ? (
          <>
            <p class="font-semibold text-burn mb-2 text-[0.95rem]">You are registered</p>
            <p class="text-[0.85rem] text-ink-2 mb-3">Track your progress, pay level fees, take tests, and download your certificates from your panel.</p>
            <a href={'/events/panel/' + event.id} class="inline-flex items-center gap-2 bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.88rem]">Go to your panel</a>
          </>
        ) : (
          <>
            <p class="font-semibold text-burn mb-2 text-[0.95rem]">Register to take part</p>
            <p class="text-[0.85rem] text-ink-2 mb-3">Register for this event, then progress level by level.</p>
            <a href={'/events/register/' + event.slug} class="inline-flex items-center gap-2 bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.88rem]">Register now</a>
          </>
        )}
      </div>
    )}

    {(() => { const formSlug = (event as any).registrationFormSlug || (event as any).registration_form_slug || ''; return (formSlug || event.registrationUrl) && !isCancelled && !isPast && (
      <div class="bg-burn-pale border border-burn-dim rounded-2xl p-5 md:p-6">
        <p class="font-semibold text-burn mb-3 text-[0.95rem]">Register to attend</p>
        {event.capacity && (
          <p class="text-[0.85rem] text-ink-2 mb-3">Limited to {event.capacity} attendees.</p>
        )}
        <a href={formSlug ? ('/f/' + formSlug) : event.registrationUrl} target={formSlug ? '_self' : '_blank'} rel="noopener" class="inline-flex items-center gap-2 bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.88rem] transition-all">
          Register
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17l10-10M7 7h10v10"/></svg>
        </a>
      </div>
    ); })()}

    {isPast && event.registrationUrl && (
      <div class="bg-cream-2 border border-ink/10 rounded-2xl p-5 md:p-6">
        <p class="font-semibold text-ink mb-2 text-[0.95rem]">This event has passed</p>
        <p class="text-[0.85rem] text-ink-2 mb-3">Recording or summary may be available at the original event page.</p>
        <a href={event.registrationUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-ink hover:bg-ink/90 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.88rem] transition-all">
          View event page
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17l10-10M7 7h10v10"/></svg>
        </a>
      </div>
    )}

  </section>

</BaseLayout>