---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { ARTIFACT_LABELS } from '@/lib/event-cert';

const { eventId } = Astro.params;
if (!eventId) return Astro.redirect('/events');

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/events/panel/' + eventId));

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
const ev: any = rows(await db.execute(sql`SELECT * FROM events WHERE id = ${eventId} LIMIT 1`))[0];
if (!ev) return Astro.redirect('/events');

const reg: any = rows(await db.execute(sql`SELECT * FROM event_registrations WHERE event_id = ${eventId} AND user_id = ${user.id} LIMIT 1`))[0];
if (!reg) return Astro.redirect('/events/register/' + ev.slug);

const levels = rows(await db.execute(sql`SELECT * FROM event_levels WHERE event_id = ${eventId} AND is_active = true ORDER BY sort_order ASC, created_at ASC`));
const progress = rows(await db.execute(sql`SELECT * FROM event_level_progress WHERE registration_id = ${reg.id}`));
const certs = rows(await db.execute(sql`SELECT * FROM event_certificates WHERE registration_id = ${reg.id} AND revoked = false ORDER BY issued_at ASC`));

const progIdx: Record<string, any> = {};
for (const p of progress) progIdx[p.level_id] = p;
const certByLevel: Record<string, any[]> = {};
for (const c of certs) { const k = c.level_id || 'none'; (certByLevel[k] = certByLevel[k] || []).push(c); }

const origin = Astro.url.origin;
function fmt(d: any): string { return d ? new Date(d).toLocaleString('en-IN', { day: 'numeric', month: 'short', year: 'numeric', hour: 'numeric', minute: '2-digit' }) : 'TBD'; }

// Build a client-side data array for cert PDF download.
const certData = certs.map((c: any) => ({
  token: c.share_token,
  artifactType: c.artifact_type,
  title: c.title,
  participantName: c.participant_name,
  eventTitle: c.event_title,
  levelName: c.level_name || '',
  body: c.body || '',
  serial: c.serial,
  integrityHash: c.integrity_hash,
  issuedAt: new Date(c.issued_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }),
  organiser: ev.organiser || 'EduRankAI',
  verifyUrl: origin + '/c/' + c.share_token,
}));
---
<BaseLayout title={'Your panel - ' + ev.title} description="Your event progress and certificates.">
  <section class="px-[5vw] py-10 md:py-14 max-w-3xl mx-auto">
    <a href={'/events/' + ev.slug} class="text-[0.82rem] text-ink-soft hover:text-burn font-mono">Back to event</a>
    <div class="mt-3 mb-2 flex items-center justify-between flex-wrap gap-2">
      <h1 class="font-display text-[clamp(1.7rem,4.5vw,2.3rem)] font-semibold text-ink leading-tight">{ev.title}</h1>
    </div>
    <p class="text-[0.85rem] text-ink-soft mb-6">Registered as <strong class="text-ink">{reg.participant_name}</strong> ({reg.participant_email}).</p>

    <div class="flex flex-col gap-4">
      {levels.map((lv: any, i: number) => {
        const pr = progIdx[lv.id];
        const paid = pr && pr.fee_paid;
        const needsFee = lv.fee_chf > 0 && !paid;
        const myCerts = certByLevel[lv.id] || [];
        const statusLabel = pr ? pr.status : 'not started';
        return (
          <div class="bg-white border border-ink/10 rounded-2xl p-5">
            <div class="flex items-start gap-3 mb-3">
              <div class="shrink-0 w-8 h-8 rounded-full bg-burn-pale border border-burn-dim text-burn font-bold flex items-center justify-center text-[0.85rem]">{i + 1}</div>
              <div class="flex-1">
                <div class="flex flex-wrap items-center gap-2">
                  <h3 class="font-display text-[1.1rem] font-semibold text-ink">{lv.name}</h3>
                  <span class="text-[0.62rem] font-bold uppercase tracking-wider bg-cream-2 text-ink-soft border border-ink/15 px-2 py-0.5 rounded-full">{statusLabel}</span>
                  {pr && pr.score != null && <span class="text-[0.62rem] font-bold uppercase tracking-wider bg-sky-bg text-sky border border-sky-border px-2 py-0.5 rounded-full">{pr.score}%</span>}
                </div>
                {lv.description && <p class="text-[0.82rem] text-ink-2 leading-relaxed mt-1">{lv.description}</p>}
                <div class="flex flex-wrap gap-x-4 gap-y-1 text-[0.72rem] text-ink-soft font-mono mt-1">
                  {lv.starts_at && <span>{fmt(lv.starts_at)}{lv.ends_at ? ' to ' + fmt(lv.ends_at) : ''}</span>}
                  {lv.conclusion_at && <span>Results: {fmt(lv.conclusion_at)}</span>}
                </div>
              </div>
            </div>

            <div class="flex flex-wrap items-center gap-2 pl-11">
              {needsFee && (
                <button type="button" class="pay-level-btn bg-burn hover:bg-burn/90 text-white font-semibold py-2 px-4 rounded-lg text-[0.82rem] border-0 cursor-pointer" data-level={lv.id} data-fee={lv.fee_chf}>
                  Pay {lv.fee_chf} CHF to unlock
                </button>
              )}
              {lv.fee_chf > 0 && paid && <span class="text-[0.78rem] text-leaf font-semibold">Fee paid</span>}
              {lv.test_slug && (!lv.fee_chf || paid) && (
                <a href={'/aquintutor/test/' + lv.test_slug} class="bg-ink hover:bg-ink/90 text-white font-semibold py-2 px-4 rounded-lg text-[0.82rem] no-underline">Take the test</a>
              )}
              {lv.test_slug && lv.fee_chf > 0 && !paid && <span class="text-[0.75rem] text-ink-soft">Pay the fee to access the test.</span>}
            </div>

            {myCerts.length > 0 && (
              <div class="mt-3 ml-11 pt-3 border-t border-ink/8">
                <p class="text-[0.62rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Your artifacts</p>
                <div class="flex flex-col gap-2">
                  {myCerts.map((c: any) => (
                    <div class="flex flex-wrap items-center gap-2">
                      <span class="text-[0.8rem] font-semibold text-ink">{c.title}</span>
                      <button type="button" class="cert-dl-btn text-[0.75rem] bg-burn/10 text-burn border border-burn/30 px-3 py-1 rounded-lg cursor-pointer" data-token={c.share_token}>Download PDF</button>
                      <a href={'/c/' + c.share_token} target="_blank" class="text-[0.75rem] text-sky hover:underline font-mono">Share / verify link</a>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        );
      })}
      {levels.length === 0 && <p class="text-[0.85rem] text-ink-soft">No levels are open yet. Check back soon.</p>}
    </div>
  </section>

  <script is:inline src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script is:inline src="/era/era-cert-pdf.js"></script>
  <script is:inline define:vars={{ registrationId: reg.id, eventId: ev.id, certData }}>
    (function () {
      // Per-level payment
      document.querySelectorAll('.pay-level-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var levelId = btn.getAttribute('data-level');
          var prev = btn.textContent; btn.disabled = true; btn.textContent = 'Starting...';
          fetch('/api/payments/start-event-level-fee', {
            method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ registrationId: registrationId, levelId: levelId }),
          }).then(function (r) { return r.json(); }).then(function (d) {
            if (!d.ok) { btn.disabled = false; btn.textContent = prev; alert(d.error || 'Could not start.'); return; }
            if (d.free || d.alreadyPaid) { window.location.reload(); return; }
            if (typeof Razorpay === 'undefined') { btn.disabled = false; btn.textContent = prev; alert('Razorpay failed to load.'); return; }
            var rzp = new Razorpay({
              key: d.keyId, amount: d.amountPaise, currency: d.currency,
              name: 'EduRankAI', description: 'Level fee - ' + (d.levelName || ''), order_id: d.orderId,
              prefill: d.prefill || {}, theme: { color: '#FF4F00' },
              handler: function (resp) {
                btn.textContent = 'Verifying...';
                fetch('/api/payments/verify', {
                  method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ razorpay_order_id: resp.razorpay_order_id, razorpay_payment_id: resp.razorpay_payment_id, razorpay_signature: resp.razorpay_signature }),
                }).then(function (r) { return r.json(); }).then(function (c) {
                  if (c.ok) { window.location.reload(); }
                  else { btn.disabled = false; btn.textContent = prev; alert(c.error || 'Verify failed.'); }
                }).catch(function () { btn.disabled = false; btn.textContent = prev; alert('Network error.'); });
              },
              modal: { ondismiss: function () { btn.disabled = false; btn.textContent = prev; } },
            });
            rzp.open();
          }).catch(function () { btn.disabled = false; btn.textContent = prev; alert('Network error.'); });
        });
      });

      // Certificate download
      var byToken = {};
      (certData || []).forEach(function (c) { byToken[c.token] = c; });
      document.querySelectorAll('.cert-dl-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var c = byToken[btn.getAttribute('data-token')];
          if (!c || !window.EraCertPdf) { alert('Could not generate PDF.'); return; }
          var fname = 'EduRankAI-' + (c.artifactType || 'certificate') + '-' + (c.participantName || '').replace(/[^a-zA-Z0-9]/g, '') + '.pdf';
          window.EraCertPdf.download(c, fname);
        });
      });
    })();
  </script>
</BaseLayout>
