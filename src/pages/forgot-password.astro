---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Forgot password" description="Recover access to your EduRankAI account using your email and date of birth." noindex={true}>

  <section class="px-[5vw] py-12 md:py-20 max-w-md mx-auto">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-3">Recover access</p>
    <h1 class="font-display text-[clamp(1.6rem,4vw,2.4rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-3">
      Forgot your password?
    </h1>
    <p class="text-[0.92rem] text-ink-soft leading-relaxed mb-8">
      Enter the email (or your name) on the account, plus your date of birth as you originally provided it. If they match, we'll generate a new temporary password right here. Sign in with it and change it from your settings.
    </p>

    <form id="forgotForm" class="bg-white border border-ink/10 rounded-2xl p-5 md:p-6 flex flex-col gap-4">
      <div>
        <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Email or name</label>
        <input type="text" name="emailOrName" required placeholder="you@edurankai.in" autocomplete="username" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.95rem] outline-none focus:border-burn bg-cream-2" />
        <p class="text-[0.72rem] text-ink-soft mt-1.5">Email if you remember it, or the full name on your account.</p>
      </div>

      <div>
        <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Date of birth</label>
        <input type="date" name="dob" required class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.95rem] outline-none focus:border-burn bg-cream-2" />
        <p class="text-[0.72rem] text-ink-soft mt-1.5">As it appears on the ID you used at signup / application.</p>
      </div>

      <button type="submit" id="submitBtn" class="bg-burn hover:bg-burn/90 text-white font-semibold py-3 px-6 rounded-lg text-[0.95rem]">
        Verify &amp; reset password
      </button>

      <div id="result" style="display:none;"></div>
    </form>

    <div class="mt-6 flex flex-wrap gap-4 text-[0.85rem]">
      <a href="/portal/login" class="text-burn hover:underline font-semibold">Back to sign in</a>
      <span class="text-ink-soft/50">&middot;</span>
      <a href="mailto:hr@edurankai.in" class="text-burn hover:underline font-semibold">Email HR</a>
    </div>

    <div class="mt-8 bg-cream-2 border border-ink/10 rounded-2xl p-5">
      <p class="text-[0.85rem] text-ink-2 leading-relaxed mb-3">
        <strong class="text-ink">No date of birth on file?</strong><br/>
        Some legacy accounts (especially older admin accounts) don't have a DOB. Use the first-time identity setup with a government ID + live selfie instead.
      </p>
      <a href="/identity-setup" class="inline-block bg-ink hover:bg-burn text-white font-semibold text-[0.85rem] py-2 px-5 rounded-lg transition-colors mb-3 mr-2">First-time identity setup &rarr;</a>
    </div>

    <div class="mt-4 bg-cream-2 border border-ink/10 rounded-2xl p-5">
      <p class="text-[0.85rem] text-ink-2 leading-relaxed mb-3">
        <strong class="text-ink">No ID handy, no camera?</strong><br/>
        Answer a short set of questions drawn from your application and HR record. If your aggregate accuracy is at least 80%, we'll reset your password right here.
      </p>
      <a href="/verify-by-questions" class="inline-block bg-burn hover:bg-ink text-white font-semibold text-[0.85rem] py-2 px-5 rounded-lg transition-colors">Recover by questions &rarr;</a>
    </div>
  </section>

  <script is:inline>
    document.getElementById('forgotForm').addEventListener('submit', function(e) {
      e.preventDefault();
      var fd = new FormData(e.target);
      var emailOrName = (fd.get('emailOrName') || '').toString().trim();
      var dob = (fd.get('dob') || '').toString().trim();
      var btn = document.getElementById('submitBtn');
      var result = document.getElementById('result');

      btn.disabled = true; var prev = btn.textContent; btn.textContent = 'Verifying...';
      result.style.display = 'none';

      fetch('/api/auth/forgot-password', {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ emailOrName: emailOrName, dob: dob }),
      }).then(function(r) { return r.json(); }).then(function(d) {
        btn.disabled = false; btn.textContent = prev;
        result.style.display = 'block';
        if (d.ok) {
          result.innerHTML =
            '<div style="background:#dcfce7;border:1px solid #86efac;color:#166534;padding:14px 16px;border-radius:10px;font-size:13.5px;line-height:1.7;">' +
              '<p style="font-weight:600;margin:0 0 8px;">Password reset for ' + (d.email || '') + '</p>' +
              '<p style="margin:0 0 4px;">Your temporary password is:</p>' +
              '<p style="font-family:ui-monospace,monospace;font-size:18px;font-weight:700;background:#fff;padding:10px 14px;border-radius:6px;border:1px solid #86efac;margin:6px 0;text-align:center;letter-spacing:0.05em;">' + d.tempPassword + '</p>' +
              '<p style="margin:8px 0 0;font-size:12px;color:#15803d;">Sign in below and change it immediately from your account settings.</p>' +
              '<div style="margin-top:10px;display:flex;gap:8px;">' +
                '<a href="/portal/login" style="background:#FF4F00;color:#fff;text-decoration:none;font-weight:600;font-size:13px;padding:8px 14px;border-radius:6px;">Sign in</a>' +
                '<button type="button" onclick="navigator.clipboard.writeText(\'' + d.tempPassword + '\').then(()=>this.textContent=\'Copied!\')" style="background:#fff;border:1px solid #86efac;color:#166534;font-weight:600;font-size:13px;padding:8px 14px;border-radius:6px;cursor:pointer;">Copy password</button>' +
              '</div>' +
            '</div>';
        } else {
          result.innerHTML =
            '<div style="background:#fee2e2;border:1px solid #fca5a5;color:#991b1b;padding:12px 14px;border-radius:8px;font-size:13.5px;">' +
              (d.error || 'Verification failed. Email hr@edurankai.in for manual recovery.') +
            '</div>';
        }
      }).catch(function() {
        btn.disabled = false; btn.textContent = prev;
        result.style.display = 'block';
        result.innerHTML = '<div style="background:#fee2e2;border:1px solid #fca5a5;color:#991b1b;padding:12px 14px;border-radius:8px;font-size:13.5px;">Network error - try again.</div>';
      });
    });
  </script>
</BaseLayout>
