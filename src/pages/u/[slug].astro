---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ensureNetworkSchema, getProfile } from '@/lib/network';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/');
await ensureNetworkSchema();
const p: any = await getProfile(slug);
if (!p) return Astro.redirect('/aquintutor/careerflow/network');
---
<BaseLayout title={p.display_name + ' · EduRankAI'} description={p.tagline || 'EduRankAI profile.'}>

<style>
  body { background: #FAF8F5; }
  .pf-wrap { max-width: 980px; margin: 0 auto; padding: 0 16px 80px; }
  .pf-cover { background: linear-gradient(135deg, #FF4F00 0%, #FF7040 100%); height: 180px; border-radius: 0 0 16px 16px; position: relative; }
  .pf-avatar { width: 130px; height: 130px; border-radius: 50%; background: #fff; border: 6px solid #FAF8F5; display: flex; align-items: center; justify-content: center; font-family: 'Cormorant Garamond', serif; font-size: 54px; font-weight: 600; color: #FF4F00; position: absolute; bottom: -50px; left: 32px; }
  .pf-meta-line { display: flex; justify-content: space-between; align-items: flex-end; padding: 60px 32px 24px; flex-wrap: wrap; gap: 16px; }
  .pf-name { font-family: 'Cormorant Garamond', serif; font-size: 38px; font-weight: 600; color: #0E0B08; margin: 0; letter-spacing: -0.02em; line-height: 1.1; }
  .pf-name em { font-size: 16px; color: #1A6B35; margin-left: 10px; }
  .pf-tagline { font-size: 16px; color: #2E2520; margin: 6px 0 0; }
  .pf-actions { display: flex; gap: 8px; }
  .pf-btn { background: #FF4F00; color: #fff; padding: 10px 20px; border-radius: 10px; text-decoration: none; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 700; border: none; cursor: pointer; }
  .pf-btn-ghost { background: transparent; color: #0E0B08; border: 1px solid rgba(14,11,8,0.15); }

  .pf-info-bar { display: flex; gap: 24px; flex-wrap: wrap; padding: 0 32px 24px; font-family: 'Geist Mono', monospace; font-size: 12px; color: #7A6F68; border-bottom: 1px solid rgba(14,11,8,0.08); }
  .pf-info-bar strong { color: #0E0B08; }
  .pf-info-bar a { color: #FF4F00; text-decoration: none; }

  .pf-grid { display: grid; grid-template-columns: 1fr 320px; gap: 32px; padding: 32px 32px 0; }
  @media (max-width: 800px) { .pf-grid { grid-template-columns: 1fr; padding: 24px 16px 0; } }

  .pf-section { margin-bottom: 28px; }
  .pf-section h2 { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin: 0 0 12px; }
  .pf-bio { font-size: 15.5px; color: #2E2520; line-height: 1.7; white-space: pre-wrap; }

  .pf-side-panel { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 18px; margin-bottom: 14px; }
  .pf-side-panel h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: #7A6F68; font-weight: 700; margin: 0 0 10px; }
  .pf-chip-row { display: flex; gap: 4px; flex-wrap: wrap; }
  .pf-chip { background: #F3EFE8; padding: 4px 10px; border-radius: 100px; font-size: 12px; color: #2E2520; }
  .pf-chip-burn { background: #FFF3EE; color: #FF4F00; }
  .pf-stat { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid rgba(14,11,8,0.06); font-size: 13px; }
  .pf-stat:last-child { border-bottom: none; }
  .pf-stat-label { color: #7A6F68; }
  .pf-stat-val { font-weight: 700; color: #0E0B08; }
</style>

<main class="pf-wrap">
  <div class="pf-cover">
    <div class="pf-avatar">{p.display_name?.charAt(0)?.toUpperCase() || '?'}</div>
  </div>

  <div class="pf-meta-line">
    <div>
      <h1 class="pf-name">{p.display_name}{p.is_verified && <em>✓ Verified</em>}</h1>
      {p.tagline && <p class="pf-tagline">{p.tagline}</p>}
    </div>
    <div class="pf-actions">
      <button class="pf-btn">Connect</button>
      <button class="pf-btn pf-btn-ghost">Message</button>
    </div>
  </div>

  <div class="pf-info-bar">
    <span><strong>{p.kind?.charAt(0).toUpperCase() + p.kind?.slice(1)}</strong></span>
    {p.location && <span style="display:inline-flex;align-items:center;gap:5px;"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>{p.location}</span>}
    {p.seniority && <span>{p.seniority} · {p.years_experience || '—'} yrs</span>}
    {p.website_url && <a href={p.website_url} target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:5px;"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>Website</a>}
    {p.contact_email && <a href={'mailto:' + p.contact_email} style="display:inline-flex;align-items:center;gap:5px;"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>{p.contact_email}</a>}
  </div>

  <div class="pf-grid">

    <main>
      {p.bio && (
        <div class="pf-section">
          <h2>About</h2>
          <p class="pf-bio">{p.bio}</p>
        </div>
      )}

      {Array.isArray(p.skills) && p.skills.length > 0 && (
        <div class="pf-section">
          <h2>Skills</h2>
          <div class="pf-chip-row">
            {p.skills.map((s: string) => <span class="pf-chip pf-chip-burn">{s}</span>)}
          </div>
        </div>
      )}

      {Array.isArray(p.services_offered) && p.services_offered.length > 0 && (
        <div class="pf-section">
          <h2>Services offered</h2>
          <div class="pf-chip-row">
            {p.services_offered.map((s: string) => <span class="pf-chip">{s}</span>)}
          </div>
        </div>
      )}

      {Array.isArray(p.open_to) && p.open_to.length > 0 && (
        <div class="pf-section">
          <h2>Open to</h2>
          <div class="pf-chip-row">
            {p.open_to.map((s: string) => <span class="pf-chip">{s}</span>)}
          </div>
        </div>
      )}
    </main>

    <aside>
      <div class="pf-side-panel">
        <h3>Stats</h3>
        <div class="pf-stat"><span class="pf-stat-label">Profile views</span><span class="pf-stat-val">{p.view_count}</span></div>
        <div class="pf-stat"><span class="pf-stat-label">Connections</span><span class="pf-stat-val">{p.connection_count}</span></div>
        <div class="pf-stat"><span class="pf-stat-label">Joined</span><span class="pf-stat-val">{new Date(p.created_at).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', month: 'short', year: 'numeric' })}</span></div>
      </div>

      {Array.isArray(p.languages) && p.languages.length > 0 && (
        <div class="pf-side-panel">
          <h3>Languages</h3>
          <div class="pf-chip-row">
            {p.languages.map((l: string) => <span class="pf-chip">{l}</span>)}
          </div>
        </div>
      )}
    </aside>

  </div>
</main>
</BaseLayout>
