---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
async function safeRows(q: any): Promise<any[]> { try { return rows(await db.execute(q)); } catch { return []; } }

// Distinct academies = distinct schools (then categories) over published courses.
const bySchool = await safeRows(sql`
  SELECT COALESCE(school, category, 'General') AS name, COUNT(*)::int AS courses, SUM(COALESCE(enrolled_count,0))::int AS learners
  FROM training_courses WHERE is_published = true
  GROUP BY COALESCE(school, category, 'General') ORDER BY courses DESC LIMIT 24`);

function toSlug(s: string) { return (s || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''); }
function hueOf(s: string) { var h = 0; for (var i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) % 360; return h; }
const totalCourses = bySchool.reduce((s: number, a: any) => s + (a.courses || 0), 0);
const totalLearners = bySchool.reduce((s: number, a: any) => s + (a.learners || 0), 0);
---
<BaseLayout title="Academies · EduRankAI" description="Branded academies powered by AquinTutor — each a white-label catalogue of live courses, real simulators, proctored assessments, and verifiable credentials.">

<style>
  body { background: #FAF8F5; color: #0E0B08; }
  .ad-wrap { max-width: 1180px; margin: 0 auto; padding: 50px 5vw 80px; }
  .ad-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .ad-h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 6vw, 66px); font-weight: 600; letter-spacing: -0.03em; margin: 8px 0 12px; line-height: 1.02; }
  .ad-h1 em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .ad-sub { font-size: 17px; color: #2E2520; max-width: 660px; line-height: 1.6; }
  .ad-strip { display: flex; gap: 30px; margin: 24px 0 34px; flex-wrap: wrap; }
  .ad-stat-v { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 600; line-height: 1; }
  .ad-stat-l { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: #7A6F68; margin-top: 4px; font-weight: 700; }
  .ad-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; }
  .ad-card { border-radius: 16px; padding: 26px 24px; text-decoration: none; color: #fff; min-height: 150px; display: flex; flex-direction: column; justify-content: space-between; transition: transform .18s; }
  .ad-card:hover { transform: translateY(-3px); }
  .ad-card-name { font-family: 'Cormorant Garamond', serif; font-size: 27px; font-weight: 600; letter-spacing: -0.01em; line-height: 1.1; }
  .ad-card-m { font-family: 'Geist Mono', monospace; font-size: 11px; opacity: 0.9; margin-top: 8px; }
  .ad-card-go { font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; margin-top: 14px; }
  .ad-cta { background: var(--ink, #0E0B08); color: #fff; border-radius: 16px; padding: 30px; margin-top: 32px; display: flex; justify-content: space-between; align-items: center; gap: 20px; flex-wrap: wrap; }
  .ad-cta h3 { font-family: 'Cormorant Garamond', serif; font-size: 28px; margin: 0; font-weight: 600; }
  .ad-cta a { background: #FF4F00; color: #fff; padding: 13px 26px; border-radius: 10px; text-decoration: none; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 700; white-space: nowrap; }
</style>

<main class="ad-wrap">
  <p class="ad-eye">EduRankAI · Academies</p>
  <h1 class="ad-h1">Branded <em>academies</em>.</h1>
  <p class="ad-sub">Each academy is a white-label catalogue — live courses, real simulators embedded in lessons, proctored assessments, and blockchain-verifiable certificates. A partner's seal on top, our institution-grade infrastructure underneath.</p>

  <div class="ad-strip">
    <div><div class="ad-stat-v">{bySchool.length}</div><div class="ad-stat-l">Academies</div></div>
    <div><div class="ad-stat-v">{totalCourses}</div><div class="ad-stat-l">Courses</div></div>
    <div><div class="ad-stat-v">{totalLearners}</div><div class="ad-stat-l">Learners</div></div>
  </div>

  {bySchool.length === 0 ? (
    <div style="padding:30px;text-align:center;color:#7A6F68;font-family:'Geist Mono',monospace;">No published courses yet. <a href="/admin/aquintutor/courses" style="color:#FF4F00;">Create one &rarr;</a></div>
  ) : (
    <div class="ad-grid">
      {bySchool.map((a) => {
        const hue = hueOf(a.name);
        return (
          <a href={'/academy/' + toSlug(a.name)} class="ad-card" style={`background:linear-gradient(135deg, hsl(${hue},45%,40%), hsl(${hue},45%,26%));`}>
            <div>
              <div class="ad-card-name">{a.name}</div>
              <div class="ad-card-m">{a.courses} course{a.courses === 1 ? '' : 's'} · {a.learners || 0} learners</div>
            </div>
            <div class="ad-card-go">Enter academy &rarr;</div>
          </a>
        );
      })}
    </div>
  )}

  <div class="ad-cta">
    <h3>Want your own branded academy?</h3>
    <a href="/aquintutor/partnerships">Host with us &rarr;</a>
  </div>
</main>
</BaseLayout>
