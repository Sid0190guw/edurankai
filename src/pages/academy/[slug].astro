---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/aquintutor/courses');
const user = Astro.locals.user;

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
async function safeRows(q: any): Promise<any[]> { try { return rows(await db.execute(q)); } catch { return []; } }

// A branded academy groups published courses by school OR category matching the slug.
const key = slug.replace(/-/g, ' ');
let courses = await safeRows(sql`
  SELECT slug, title, subtitle, short_desc, difficulty, school, category, COALESCE(enrolled_count,0) AS enrolled,
    (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = training_courses.id) AS lessons
  FROM training_courses
  WHERE is_published = true AND (LOWER(school) = LOWER(${key}) OR LOWER(category) = LOWER(${key}))
  ORDER BY enrolled DESC, created_at DESC LIMIT 40`);
// fallback: if nothing matches, show all published (so the page is never empty in a demo)
let isFallback = false;
if (courses.length === 0) {
  courses = await safeRows(sql`SELECT slug, title, subtitle, short_desc, difficulty, school, category, COALESCE(enrolled_count,0) AS enrolled, (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = training_courses.id) AS lessons FROM training_courses WHERE is_published = true ORDER BY enrolled DESC, created_at DESC LIMIT 40`);
  isFallback = true;
}

// my enrolments for progress
let myProg: { [k: string]: number } = {};
if (user) {
  const e = await safeRows(sql`SELECT c.slug, e.progress_pct FROM training_enrollments e LEFT JOIN training_courses c ON c.id = e.course_id WHERE e.user_id = ${user.id}`);
  e.forEach((r: any) => { if (r.slug) myProg[r.slug] = r.progress_pct || 0; });
}

const totalLearners = courses.reduce((s: number, c: any) => s + (c.enrolled || 0), 0);
const totalLessons = courses.reduce((s: number, c: any) => s + (c.lessons || 0), 0);
const academyName = key.replace(/\b\w/g, (c) => c.toUpperCase());
// pick a brand hue from the slug
let hue = 0; for (let i = 0; i < slug.length; i++) hue = (hue * 31 + slug.charCodeAt(i)) % 360;
const brand = `hsl(${hue}, 45%, 38%)`, brandSoft = `hsl(${hue}, 45%, 96%)`;
---
<BaseLayout title={academyName + ' Academy · EduRankAI'} description={'The ' + academyName + ' academy — courses, assessments, and verifiable credentials, powered by AquinTutor.'}>

<style>
  body { background: #FAF8F5; color: #0E0B08; }
  .ac-hero { background: linear-gradient(135deg, var(--brand), color-mix(in srgb, var(--brand) 70%, #000)); color: #fff; padding: 60px 5vw 50px; }
  .ac-hero-in { max-width: 1180px; margin: 0 auto; }
  .ac-badge { display: inline-flex; align-items: center; gap: 8px; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; font-weight: 700; opacity: 0.9; }
  .ac-badge .dot { width: 32px; height: 32px; border-radius: 8px; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; font-family: 'Cormorant Garamond', serif; font-size: 18px; }
  .ac-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 6vw, 70px); font-weight: 600; letter-spacing: -0.03em; margin: 16px 0 10px; line-height: 1; }
  .ac-sub { font-size: 17px; opacity: 0.92; max-width: 620px; line-height: 1.6; }
  .ac-stats { display: flex; gap: 32px; margin-top: 28px; flex-wrap: wrap; }
  .ac-stat-v { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 600; line-height: 1; }
  .ac-stat-l { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.8; margin-top: 4px; font-weight: 700; }

  .ac-wrap { max-width: 1180px; margin: 0 auto; padding: 40px 5vw 80px; }
  .ac-sect-h { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 18px; }
  .ac-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 16px; }
  .ac-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 16px; padding: 22px; text-decoration: none; color: inherit; transition: all .18s; display: flex; flex-direction: column; }
  .ac-card:hover { transform: translateY(-2px); box-shadow: 0 14px 34px rgba(14,11,8,0.08); border-color: var(--brand); }
  .ac-card-tag { font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--brand); font-weight: 700; }
  .ac-card-t { font-family: 'Cormorant Garamond', serif; font-size: 23px; font-weight: 600; margin: 6px 0 6px; line-height: 1.15; letter-spacing: -0.01em; }
  .ac-card-d { font-size: 14px; color: #2E2520; line-height: 1.55; flex: 1; }
  .ac-card-m { display: flex; justify-content: space-between; align-items: center; margin-top: 14px; padding-top: 12px; border-top: 1px solid rgba(14,11,8,0.07); font-family: 'Geist Mono', monospace; font-size: 11px; color: #7A6F68; }
  .ac-prog { background: var(--brand-soft); border-radius: 100px; height: 6px; overflow: hidden; width: 80px; }
  .ac-prog i { display: block; height: 100%; background: var(--brand); }
  .ac-foot { text-align: center; margin-top: 50px; font-family: 'Geist Mono', monospace; font-size: 12px; color: #7A6F68; }
  .ac-foot a { color: var(--brand); text-decoration: none; }
  .ac-note { background: #FFF3EE; border: 1px solid #FFD4BC; border-radius: 10px; padding: 12px 16px; font-size: 13px; color: #7A6F68; margin-bottom: 20px; }
</style>

<main style={`--brand:${brand};--brand-soft:${brandSoft};`}>
  <section class="ac-hero" style={`--brand:${brand};`}>
    <div class="ac-hero-in">
      <div class="ac-badge"><span class="dot">{academyName.charAt(0)}</span> {academyName} Academy · powered by AquinTutor</div>
      <h1 class="ac-title">{academyName}.</h1>
      <p class="ac-sub">A branded academy with live courses, real simulators embedded in lessons, proctored assessments, and blockchain-verifiable certificates. Your seal on the credential, our infrastructure underneath.</p>
      <div class="ac-stats">
        <div><div class="ac-stat-v">{courses.length}</div><div class="ac-stat-l">Courses</div></div>
        <div><div class="ac-stat-v">{totalLessons}</div><div class="ac-stat-l">Lessons</div></div>
        <div><div class="ac-stat-v">{totalLearners}</div><div class="ac-stat-l">Learners</div></div>
        <div><div class="ac-stat-v">Verifiable</div><div class="ac-stat-l">Credentials</div></div>
      </div>
    </div>
  </section>

  <div class="ac-wrap">
    {isFallback && <div class="ac-note">No courses are tagged to "{academyName}" yet — showing the full catalogue as a preview of how this branded academy will look.</div>}
    <h2 class="ac-sect-h">Courses</h2>
    {courses.length === 0 ? (
      <div style="padding:30px;text-align:center;color:#7A6F68;font-family:'Geist Mono',monospace;">No published courses yet.</div>
    ) : (
      <div class="ac-grid">
        {courses.map((c) => (
          <a href={'/aquintutor/courses/' + c.slug} class="ac-card">
            <span class="ac-card-tag">{c.school || c.category || 'Course'} · {c.difficulty || 'all levels'}</span>
            <div class="ac-card-t">{c.title}</div>
            <p class="ac-card-d">{c.subtitle || c.short_desc || 'A course on the AquinTutor platform with live labs and verifiable certification.'}</p>
            <div class="ac-card-m">
              <span>{c.lessons || 0} lessons · {c.enrolled || 0} enrolled</span>
              {myProg[c.slug] != null ? <span class="ac-prog"><i style={'width:' + myProg[c.slug] + '%'}></i></span> : <span style="color:var(--brand);font-weight:700;">Enrol &rarr;</span>}
            </div>
          </a>
        ))}
      </div>
    )}

    <p class="ac-foot">This academy runs on <a href="/aquintutor">AquinTutor</a> by EduRankAI. <a href="/aquintutor/partnerships">Host your own branded academy &rarr;</a></p>
  </div>
</main>
</BaseLayout>
