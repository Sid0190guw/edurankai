---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
---
<BaseLayout title="Enrol face for 2FA" description="Add a face descriptor to your account so every future sign-in is protected by 2-factor authentication." noindex={true}>
  <section class="px-[5vw] py-12 md:py-20 max-w-2xl mx-auto">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-3">Two-factor auth &middot; required</p>
    <h1 class="font-display text-[clamp(1.6rem,4vw,2.4rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-3">
      Set up face login.
    </h1>
    <p class="text-[0.92rem] text-ink-soft leading-relaxed mb-7">
      Every EduRankAI account is protected by password + face match. Upload a government ID with your face on it (Aadhaar, PAN, passport, driving licence), then take a quick live selfie. Both face descriptors are computed locally in your browser - the raw photos never leave your device.
    </p>

    <div class="bg-white border border-ink/10 rounded-2xl p-5 md:p-6 mb-5">
      <h2 class="font-display text-lg font-semibold text-ink mb-1">Step 1 &middot; Upload your ID</h2>
      <p class="text-[0.85rem] text-ink-soft mb-3">A clear photo of your government ID. We detect the face locally on your device.</p>
      <div class="flex gap-3 items-center mb-3 flex-wrap">
        <label class="bg-ink text-white text-[0.85rem] font-semibold py-2 px-4 rounded-lg cursor-pointer">
          Choose file
          <input id="idFile" type="file" accept="image/*" style="display:none;" />
        </label>
        <span id="idFileName" class="text-[0.82rem] text-ink-soft">No file chosen</span>
      </div>
      <div class="flex gap-3 items-start">
        <img id="idPreview" alt="" style="display:none;max-width:160px;max-height:160px;border-radius:8px;border:1px solid rgba(15,23,42,0.1);" />
        <p id="idStatus" class="text-[0.85rem] text-ink-2"></p>
      </div>
    </div>

    <div class="bg-white border border-ink/10 rounded-2xl p-5 md:p-6 mb-5">
      <h2 class="font-display text-lg font-semibold text-ink mb-1">Step 2 &middot; Take a live selfie</h2>
      <p class="text-[0.85rem] text-ink-soft mb-3">Face the camera. We extract a face signature locally - the photo never leaves your browser.</p>
      <div style="display:flex;gap:14px;align-items:flex-start;flex-wrap:wrap;">
        <div style="position:relative;width:300px;max-width:100%;aspect-ratio:1/1;background:#000;border-radius:12px;overflow:hidden;">
          <video id="videoEl" autoplay playsinline muted style="width:100%;height:100%;object-fit:cover;transform:scaleX(-1);"></video>
          <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;">
            <div style="width:65%;aspect-ratio:3/4;border:2.5px dashed rgba(220,80,0,0.8);border-radius:50%;"></div>
          </div>
        </div>
        <div style="flex:1;min-width:160px;">
          <button id="camBtn" type="button" class="bg-ink text-white text-[0.85rem] font-semibold py-2 px-4 rounded-lg cursor-pointer block mb-2">Camera on</button>
          <button id="snapBtn" type="button" class="bg-burn text-white text-[0.85rem] font-semibold py-2 px-4 rounded-lg cursor-pointer block mb-2" disabled style="opacity:0.5;">Capture selfie</button>
          <p id="selfieStatus" class="text-[0.82rem] text-ink-2 mt-2"></p>
        </div>
      </div>
    </div>

    <button id="finishBtn" type="button" class="bg-burn hover:bg-burn/90 text-white font-bold py-3.5 px-6 rounded-lg text-[0.95rem] w-full" disabled style="opacity:0.5;">
      Finish setup &amp; activate 2FA
    </button>
    <p id="finalMsg" class="text-[0.85rem] mt-3" style="display:none;"></p>

    <p class="text-[0.82rem] text-ink-soft mt-6 text-center">
      <a href="/portal/login" class="text-burn font-semibold hover:underline">Sign out</a>
      <span class="text-ink-soft/40 mx-2">&middot;</span>
      Need help? <a href="mailto:hr@edurankai.in" class="text-burn font-semibold hover:underline">hr@edurankai.in</a>
    </p>
  </section>

  <script is:inline src="https://cdn.jsdelivr.net/npm/@vladmandic/face-api@1.7.13/dist/face-api.min.js"></script>
  <script is:inline>
    (function() {
      var idDescriptor = null;
      var selfieDescriptor = null;
      var stream = null;
      var modelsLoaded = false;

      var idFile = document.getElementById('idFile');
      var idPreview = document.getElementById('idPreview');
      var idStatus = document.getElementById('idStatus');
      var idFileName = document.getElementById('idFileName');
      var videoEl = document.getElementById('videoEl');
      var camBtn = document.getElementById('camBtn');
      var snapBtn = document.getElementById('snapBtn');
      var selfieStatus = document.getElementById('selfieStatus');
      var finishBtn = document.getElementById('finishBtn');
      var finalMsg = document.getElementById('finalMsg');

      function setMsg(el, text, color) { el.textContent = text; if (color) el.style.color = color; }
      function enableFinish() {
        if (idDescriptor && selfieDescriptor) {
          finishBtn.disabled = false; finishBtn.style.opacity = '1';
        }
      }

      async function loadModels() {
        if (modelsLoaded) return;
        // Initialise the TF backend FIRST or detectSingleFace throws "highest
        // priority backend 'wasm' has not yet been initialized".
        try {
          if (faceapi.tf) {
            try { await faceapi.tf.setBackend('webgl'); } catch (_) {}
            if (faceapi.tf.getBackend && !faceapi.tf.getBackend()) {
              try { await faceapi.tf.setBackend('wasm'); } catch (_) {}
            }
            if (faceapi.tf.ready) await faceapi.tf.ready();
          }
        } catch (_) {}
        // Pinned to a working version; @latest has broken model paths before.
        var url = 'https://cdn.jsdelivr.net/npm/@vladmandic/face-api@1.7.13/model';
        await Promise.all([
          faceapi.nets.tinyFaceDetector.loadFromUri(url),
          faceapi.nets.faceLandmark68TinyNet.loadFromUri(url),
          faceapi.nets.faceRecognitionNet.loadFromUri(url),
        ]);
        modelsLoaded = true;
      }

      function explainCameraError(e) {
        var n = e && e.name || '';
        if (n === 'NotAllowedError' || n === 'PermissionDeniedError') {
          return 'Camera access is blocked. In Chrome / Edge, click the camera icon in the address bar (next to the URL) -> Permissions -> Camera -> Allow, then reload. On iPhone Safari: Settings -> Safari -> Camera -> Allow.';
        }
        if (n === 'NotFoundError' || n === 'DevicesNotFoundError') return 'No camera detected on this device.';
        if (n === 'NotReadableError' || n === 'TrackStartError') return 'Camera is in use by another app. Close Zoom / Meet / other tabs and try again.';
        if (n === 'OverconstrainedError') return 'Camera does not support the requested settings.';
        if (n === 'SecurityError') return 'Browser blocked camera access (page must be served over HTTPS).';
        return 'Camera error: ' + (e && e.message || n || 'unknown');
      }

      idFile.addEventListener('change', async function(e) {
        var f = e.target.files[0]; if (!f) return;
        idFileName.textContent = f.name;
        setMsg(idStatus, 'Reading...', '#0f172a');
        await loadModels();
        var img = new Image();
        img.onload = async function() {
          idPreview.src = img.src; idPreview.style.display = 'block';
          setMsg(idStatus, 'Detecting face on ID...', '#0f172a');
          try {
            var det = await faceapi.detectSingleFace(img, new faceapi.TinyFaceDetectorOptions())
              .withFaceLandmarks(true).withFaceDescriptor();
            if (!det) { setMsg(idStatus, 'No face detected on ID. Use a clearer photo.', '#b91c1c'); return; }
            idDescriptor = Array.from(det.descriptor);
            setMsg(idStatus, 'Face detected on ID. Now capture your selfie.', '#15803d');
            enableFinish();
          } catch(err) { setMsg(idStatus, 'Detection failed: ' + err.message, '#b91c1c'); }
        };
        var rdr = new FileReader();
        rdr.onload = function(ev) { img.src = ev.target.result; };
        rdr.readAsDataURL(f);
      });

      camBtn.addEventListener('click', async function() {
        if (stream) return;
        if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
          setMsg(selfieStatus, 'This browser does not support camera access. Try Chrome / Edge / Safari (latest).', '#b91c1c');
          return;
        }
        // Check current permission state up-front so the message is honest when
        // the browser remembers a previous "Block" and won't even prompt.
        try {
          if (navigator.permissions && navigator.permissions.query) {
            var p = await navigator.permissions.query({ name: 'camera' });
            if (p.state === 'denied') {
              setMsg(selfieStatus, explainCameraError({ name: 'NotAllowedError' }), '#b91c1c');
              return;
            }
          }
        } catch (_) {}
        try {
          await loadModels();
          stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' } });
          videoEl.srcObject = stream;
          setMsg(selfieStatus, 'Camera on. Frame your face inside the oval.', '#15803d');
          snapBtn.disabled = false; snapBtn.style.opacity = '1';
        } catch(e) {
          setMsg(selfieStatus, explainCameraError(e), '#b91c1c');
        }
      });

      snapBtn.addEventListener('click', async function() {
        setMsg(selfieStatus, 'Detecting face on selfie...', '#0f172a');
        try {
          var det = await faceapi.detectSingleFace(videoEl, new faceapi.TinyFaceDetectorOptions())
            .withFaceLandmarks(true).withFaceDescriptor();
          if (!det) { setMsg(selfieStatus, 'No face detected. Try better lighting.', '#b91c1c'); return; }
          selfieDescriptor = Array.from(det.descriptor);
          if (idDescriptor) {
            var dist = faceapi.euclideanDistance(new Float32Array(idDescriptor), new Float32Array(selfieDescriptor));
            setMsg(selfieStatus, 'Selfie captured. Face match distance: ' + dist.toFixed(3) + (dist < 0.5 ? ' (looks like a match).' : ' (above threshold but you can still try).'), dist < 0.5 ? '#15803d' : '#b45309');
          } else {
            setMsg(selfieStatus, 'Selfie captured. Upload your ID first.', '#15803d');
          }
          enableFinish();
        } catch(e) { setMsg(selfieStatus, 'Detection failed: ' + e.message, '#b91c1c'); }
      });

      finishBtn.addEventListener('click', async function() {
        if (!idDescriptor || !selfieDescriptor) return;
        finishBtn.disabled = true; var prev = finishBtn.textContent; finishBtn.textContent = 'Saving...';
        var distance = faceapi.euclideanDistance(new Float32Array(idDescriptor), new Float32Array(selfieDescriptor));
        try {
          var r = await fetch('/api/auth/enroll-face', {
            method: 'POST', credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ faceDescriptor: selfieDescriptor, idDescriptor: idDescriptor, matchDistance: distance }),
          });
          var d = await r.json();
          finalMsg.style.display = 'block';
          if (d.ok) {
            finalMsg.style.cssText = 'background:#dcfce7;border:1px solid #86efac;color:#166534;padding:14px 16px;border-radius:10px;margin-top:14px;';
            finalMsg.innerHTML = '<strong>2FA active.</strong> Next sign-in will require both your password and face match. <a href="/portal" style="color:#FF4F00;font-weight:700;">Continue -&gt;</a>';
            finishBtn.textContent = 'Done';
            setTimeout(function() { window.location.href = '/portal'; }, 1500);
          } else {
            finalMsg.style.cssText = 'background:#fee2e2;border:1px solid #fca5a5;color:#991b1b;padding:14px 16px;border-radius:10px;margin-top:14px;';
            finalMsg.textContent = d.error || 'Enrollment failed.';
            finishBtn.disabled = false; finishBtn.textContent = prev;
          }
        } catch(e) {
          finalMsg.style.display = 'block';
          finalMsg.style.cssText = 'background:#fee2e2;border:1px solid #fca5a5;color:#991b1b;padding:14px 16px;border-radius:10px;margin-top:14px;';
          finalMsg.textContent = 'Network error. Try again.';
          finishBtn.disabled = false; finishBtn.textContent = prev;
        }
      });
    })();
  </script>
</BaseLayout>
