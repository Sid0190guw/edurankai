---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { integrityHash, ARTIFACT_LABELS } from '@/lib/event-cert';

const { token } = Astro.params;
if (!token) return new Response('Not found', { status: 404 });

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
const c: any = rows(await db.execute(sql`SELECT * FROM event_certificates WHERE share_token = ${token} LIMIT 1`))[0];

const origin = Astro.url.origin;
let verified = false;
if (c) {
  const expect = integrityHash({
    serial: c.serial, participantName: c.participant_name, eventTitle: c.event_title,
    levelName: c.level_name || undefined, artifactType: c.artifact_type,
    issuedAt: new Date(c.issued_at).toISOString(),
  });
  verified = expect === c.integrity_hash;
}

const certData = c ? {
  artifactType: c.artifact_type, title: c.title, participantName: c.participant_name,
  eventTitle: c.event_title, levelName: c.level_name || '', body: c.body || '',
  serial: c.serial, integrityHash: c.integrity_hash,
  issuedAt: new Date(c.issued_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }),
  organiser: 'EduRankAI', verifyUrl: origin + '/c/' + c.share_token,
} : null;
function fmt(d: any): string { return d ? new Date(d).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) : ''; }
---
<BaseLayout title={c ? (c.title + ' - ' + c.participant_name) : 'Verify - EduRankAI'} description="Verify an EduRankAI event certificate.">
  <section class="px-[5vw] py-12 md:py-16 max-w-xl mx-auto">
    {!c ? (
      <div class="bg-white border border-ink/10 rounded-2xl p-8 text-center">
        <h1 class="font-display text-[1.5rem] font-semibold text-ink mb-2">Not found</h1>
        <p class="text-[0.9rem] text-ink-soft">No artifact matches this link. It may have been mistyped.</p>
      </div>
    ) : (
      <>
        <div class="text-center mb-6">
          {c.revoked ? (
            <span class="inline-block text-[0.7rem] font-bold uppercase tracking-wider bg-red-500/10 text-red-700 border border-red-500/30 px-3 py-1 rounded-full mb-3">Revoked</span>
          ) : verified ? (
            <span class="inline-block text-[0.7rem] font-bold uppercase tracking-wider bg-leaf-bg text-leaf border border-leaf-border px-3 py-1 rounded-full mb-3">Verified authentic</span>
          ) : (
            <span class="inline-block text-[0.7rem] font-bold uppercase tracking-wider bg-burn-pale text-burn border border-burn-dim px-3 py-1 rounded-full mb-3">Integrity check failed</span>
          )}
        </div>

        <div class="bg-white border border-ink/10 rounded-2xl p-7 text-center">
          <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-3">EduRankAI</p>
          <h1 class="font-display text-[1.5rem] font-semibold text-ink mb-4">{c.title}</h1>
          <p class="text-[0.85rem] text-ink-soft mb-1">This is presented to</p>
          <p class="font-display text-[1.6rem] font-semibold text-burn mb-4">{c.participant_name}</p>
          {c.body && <p class="text-[0.9rem] text-ink-2 leading-relaxed mb-4">{c.body}</p>}
          <div class="border-t border-ink/8 pt-4 mt-4 text-left text-[0.8rem] text-ink-2 space-y-1">
            <p><span class="text-ink-soft">Event:</span> {c.event_title}{c.level_name ? ' - ' + c.level_name : ''}</p>
            <p><span class="text-ink-soft">Type:</span> {ARTIFACT_LABELS[c.artifact_type] || c.artifact_type}</p>
            <p><span class="text-ink-soft">Serial:</span> <span class="font-mono">{c.serial}</span></p>
            <p><span class="text-ink-soft">Integrity:</span> <span class="font-mono text-burn">{c.integrity_hash}</span></p>
            <p><span class="text-ink-soft">Issued:</span> {fmt(c.issued_at)}</p>
          </div>
        </div>

        {!c.revoked && (
          <div class="text-center mt-5">
            <button type="button" id="dlBtn" class="bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.88rem] border-0 cursor-pointer">Download PDF</button>
          </div>
        )}
      </>
    )}
  </section>

  {certData && (
    <>
      <script is:inline src="/era/era-cert-pdf.js"></script>
      <script is:inline define:vars={{ certData }}>
        var b = document.getElementById('dlBtn');
        if (b) b.addEventListener('click', function () {
          if (!window.EraCertPdf) { alert('Could not generate PDF.'); return; }
          var fname = 'EduRankAI-' + (certData.artifactType || 'certificate') + '-' + (certData.participantName || '').replace(/[^a-zA-Z0-9]/g, '') + '.pdf';
          window.EraCertPdf.download(certData, fname);
        });
      </script>
    </>
  )}
</BaseLayout>
