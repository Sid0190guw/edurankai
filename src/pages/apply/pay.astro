---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { applications } from '@/lib/db/schema';
import { eq, and } from 'drizzle-orm';
import { resolveApplicationFeeChf, isFeeExempt } from '@/lib/application-fee';
import { convertToInrPaise } from '@/lib/fx';
import { isConfigured } from '@/lib/razorpay';
import { getIntent } from '@/lib/application-intent';
import { getCheckoutSettings } from '@/lib/app-settings';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
if (user.role !== 'applicant') return Astro.redirect('/admin');

const url = new URL(Astro.request.url);
const intentId = url.searchParams.get('intent') || '';
const appId = url.searchParams.get('id') || '';

let app: any = null;
let mode: 'intent' | 'application' = 'intent';

if (intentId) {
  // Recover a payment that already succeeded at Razorpay but was never applied
  // (e.g. the browser closed before the verify callback, or a double-charge).
  // This flips the paid intent into a real application and deletes the intent,
  // so an applicant who already paid is NEVER shown the pay screen again.
  try { const { reconcileUserPending } = await import('@/lib/payment-effects'); await reconcileUserPending(user.id); } catch (_) {}
  const it = await getIntent(intentId, user.id);
  if (!it) return Astro.redirect('/portal?paid=1'); // materialised on reconcile - stop asking to pay
  if (it) {
    mode = 'intent';
    app = {
      id: it.id,
      firstName: it.first_name,
      lastName: it.last_name,
      email: it.email,
      level: it.level,
      roleTitleSnapshot: it.role_title_snapshot,
      departmentSnapshot: it.department_snapshot,
      feePaid: false,
    };
  }
} else if (appId) {
  // Back-compat: an existing applications row that still needs payment.
  const found = await db.select({
    id: applications.id, firstName: applications.firstName, lastName: applications.lastName,
    email: applications.email, level: applications.level,
    roleTitleSnapshot: applications.roleTitleSnapshot,
    departmentSnapshot: applications.departmentSnapshot, feePaid: applications.feePaid,
  }).from(applications)
    .where(and(eq(applications.id, appId), eq(applications.applicantUserId, user.id)))
    .limit(1);
  if (found.length > 0) { app = found[0]; mode = 'application'; }
}

if (!app) return Astro.redirect('/portal');
if (mode === 'application' && app.feePaid) return Astro.redirect('/apply/confirmation?id=' + appId);

// Policy (2026-07): internships and apprenticeships have NO application fee.
// A fee-exempt applicant must never see the pay screen — materialise the
// application for free and go straight to confirmation.
if (isFeeExempt(app.level)) {
  if (mode === 'intent') {
    try {
      const { materialiseFromIntent } = await import('@/lib/fee-waiver');
      const newId = await materialiseFromIntent(app.id, { paid: false, waiverGranted: true, waiverReason: 'Internship / apprenticeship — no application fee (fee-exempt).' });
      if (newId) return Astro.redirect('/apply/confirmation?id=' + newId);
    } catch (_) {}
  }
  return Astro.redirect('/apply/confirmation?id=' + app.id);
}

const paymentsReady = isConfigured();
const feeChf = resolveApplicationFeeChf({ level: app.level });
const fx = await convertToInrPaise('CHF', feeChf * 100);
const inrLabel = '₹' + (fx.paise / 100).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', maximumFractionDigits: 2 });
const candidateName = (app.firstName || '') + ' ' + (app.lastName || '');
const checkout = await getCheckoutSettings();

// Wallet credit — let the candidate settle the fee instantly from their balance.
let creditPaise = 0;
try { const { getCreditBalance } = await import('@/lib/account-credit'); creditPaise = await getCreditBalance(user.id); } catch (_) {}
const walletCovers = creditPaise >= fx.paise;
const walletLabel = '₹' + (creditPaise / 100).toLocaleString('en-IN', { maximumFractionDigits: 2 });

// Pre-detect a coupon that's redeemable on THIS specific intent. A coupon
// bound_intent_id to a DIFFERENT intent must NEVER surface here — that was the
// "this code is bound to a different application" leak. The filter accepts:
//   (a) coupons with no intent binding (bound_intent_id IS NULL) — applies to any of this user's intents
//   (b) coupons bound to exactly THIS intent (bound_intent_id = current intent.id)
let preBoundCoupon: { code: string; reason: string | null } | null = null;
if (mode === 'intent') {
  try {
    const { sql } = await import('drizzle-orm');
    const r = await db.execute(sql`
      SELECT c.code, c.reason
      FROM fee_waiver_coupons c
      WHERE c.bound_user_id = ${user.id}
        AND (c.bound_intent_id IS NULL OR c.bound_intent_id = ${intent.id})
        AND c.revoked_at IS NULL
        AND (c.expires_at IS NULL OR c.expires_at > NOW())
        AND c.used_count < c.max_uses
        AND NOT EXISTS (
          SELECT 1 FROM fee_waiver_coupon_redemptions rd
          WHERE rd.coupon_id = c.id AND rd.user_id = ${user.id}
        )
      ORDER BY c.bound_intent_id NULLS LAST, c.created_at DESC LIMIT 1
    `);
    const rs = (Array.isArray(r) ? r : ((r as any)?.rows || [])) as any[];
    if (rs[0]) preBoundCoupon = { code: rs[0].code, reason: rs[0].reason };
  } catch (_) {}
}
---
<BaseLayout title="Processing & verification fee - EduRankAI" description="Complete the processing and verification step for your application.">
  <section class="px-[5vw] py-10 md:py-16 max-w-2xl mx-auto">

    {preBoundCoupon && (
      <div style="background:linear-gradient(180deg,#ecfdf5 0%,#ffffff 100%);border:2px solid #10b981;border-radius:14px;padding:18px 20px;margin-bottom:22px;">
        <div style="display:flex;align-items:flex-start;gap:14px;flex-wrap:wrap;">
          <div style="background:#10b981;color:#fff;width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          </div>
          <div style="flex:1;min-width:200px;">
            <p style="font-family:'Geist Mono','JetBrains Mono',monospace;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:#047857;font-weight:700;margin:0 0 4px;">Fully funded coupon waiting</p>
            <p style="font-family:'Fraunces',serif;font-size:1.2rem;font-weight:600;color:#1c1d22;margin:0 0 4px;line-height:1.25;">Your application fee is covered by EduRankAI.</p>
            <p style="font-size:12.5px;color:#5b5b5b;margin:0 0 10px;line-height:1.55;">Our team issued you a coupon code. Redeem it below and your application moves into review at no cost.{preBoundCoupon.reason ? ' Note from us: ' + preBoundCoupon.reason : ''}</p>
            <div style="background:#fff;border:1.5px dashed #10b981;border-radius:8px;padding:10px 14px;display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-bottom:10px;">
              <code id="preBoundCode" style="font-family:'Geist Mono','JetBrains Mono',monospace;font-size:1rem;letter-spacing:0.16em;font-weight:700;color:#047857;">{preBoundCoupon.code}</code>
              <button id="preBoundRedeem" type="button" style="background:#10b981;color:#fff;border:none;font-weight:700;font-size:13px;padding:8px 18px;border-radius:6px;cursor:pointer;">Redeem &amp; finish my application</button>
            </div>
            <p id="preBoundMsg" style="font-size:12px;margin:0;min-height:1.2em;"></p>
          </div>
        </div>
      </div>
    )}

    <div class="text-center mb-8">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">{preBoundCoupon ? 'Or pay the fee directly' : 'Final step'}</p>
      <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.5rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-3">
        Process &amp; <em class="italic text-burn font-medium">verification</em> fee
      </h1>
      <p class="text-[0.95rem] text-ink-soft leading-relaxed max-w-md mx-auto">
        Every application goes through manual identity, document and reference verification. This one-time fee covers that processing for <strong class="text-ink">{app.roleTitleSnapshot}</strong>.
      </p>
    </div>

    {mode === 'intent' && !preBoundCoupon && checkout.showAid && (
      <div id="payChoice" class="mb-7">
        <p class="text-center text-[0.9rem] text-ink-soft mb-4">How would you like to complete this final step?</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <button type="button" id="choosePay" class="text-left bg-white border-2 border-ink/12 hover:border-burn rounded-2xl p-5 transition-all">
            <span class="flex items-center gap-2.5 mb-1.5">
              <span class="grid place-items-center w-9 h-9 rounded-xl shrink-0" style="background:#FFEDE4;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#FF4F00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg></span>
              <span class="font-display text-[1.05rem] font-semibold text-ink">Pay the fee</span>
            </span>
            <span class="block text-[0.82rem] text-ink-soft leading-relaxed">Pay {feeChf} CHF ({inrLabel}) by card, wallet, or coupon &mdash; your application moves straight into review.</span>
          </button>
          <button type="button" id="chooseAid" class="text-left bg-white border-2 border-ink/12 hover:border-burn rounded-2xl p-5 transition-all">
            <span class="flex items-center gap-2.5 mb-1.5">
              <span class="grid place-items-center w-9 h-9 rounded-xl shrink-0" style="background:#ecfdf5;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7Z"/></svg></span>
              <span class="font-display text-[1.05rem] font-semibold text-ink">I need financial aid</span>
            </span>
            <span class="block text-[0.82rem] text-ink-soft leading-relaxed">Genuine hardship? Apply for a fee waiver with proof of your work. Reviewed manually &mdash; no payment needed to apply.</span>
          </button>
        </div>
        <p class="text-center text-[0.75rem] text-ink-soft mt-3">You can switch between these at any time.</p>
      </div>
    )}

    <div id="payPath" class={(mode === 'intent' && !preBoundCoupon && checkout.showAid) ? 'hidden' : ''}>

    {creditPaise > 0 && (
      <div style="background:linear-gradient(180deg,#fff7ed 0%,#ffffff 100%);border:2px solid #FF4F00;border-radius:14px;padding:18px 20px;margin-bottom:22px;">
        <p style="font-size:0.68rem;font-family:monospace;text-transform:uppercase;letter-spacing:0.14em;color:#FF4F00;font-weight:700;margin:0 0 4px;">Your wallet</p>
        <p style={'font-size:0.95rem;color:#100b08;margin:0 0 ' + (walletCovers ? '12px' : '4px') + ';'}>You have <strong>{walletLabel}</strong> in account credit{walletCovers ? ' - enough to cover this fee.' : '. It will be applied toward this fee when you pay.'}</p>
        {walletCovers && (
          <button id="walletPayBtn" type="button" style="width:100%;background:#FF4F00;color:#fff;border:0;border-radius:10px;padding:13px;font-weight:700;font-size:0.95rem;cursor:pointer;">Pay {inrLabel} from wallet - instant, no card</button>
        )}
        <p id="walletMsg" style="font-size:0.8rem;text-align:center;margin:8px 0 0;color:#6a635c;min-height:1.1em;"></p>
      </div>
    )}
    {creditPaise > 0 && walletCovers && (
      <script is:inline define:vars={{ wPayloadId: mode === 'intent' ? intentId : appId, wKind: mode }}>
        (function () {
          var b = document.getElementById('walletPayBtn'); if (!b) return;
          b.addEventListener('click', function () {
            b.disabled = true; var msg = document.getElementById('walletMsg'); if (msg) msg.textContent = 'Paying from wallet...';
            var body = wKind === 'intent' ? { intentId: wPayloadId } : { applicationId: wPayloadId };
            fetch('/api/payments/start-application-fee', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
              .then(function (r) { return r.json(); })
              .then(function (d) {
                if (d && d.ok && (d.paidWithCredit || d.alreadyPaid) && d.redirect) { window.location.href = d.redirect; return; }
                b.disabled = false; if (msg) msg.textContent = (d && d.error) || 'Could not pay from wallet. Use card below.';
              })
              .catch(function () { b.disabled = false; if (msg) msg.textContent = 'Network error - try the card below.'; });
          });
        })();
      </script>
    )}

    <div class="bg-white border border-ink/10 rounded-2xl p-6 mb-6">
      <div class="flex items-center justify-between pb-4 border-b border-ink/8 mb-4">
        <div>
          <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-ink-soft mb-1">Application</p>
          <p class="font-mono text-[1rem] font-bold text-ink">{appId.substring(0, 8).toUpperCase()}</p>
        </div>
        <div class="text-right">
          <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-ink-soft mb-1">Process &amp; verification fee</p>
          <p class="font-display text-[1.6rem] font-semibold text-ink leading-none">{feeChf} CHF</p>
          <p class="text-[0.75rem] text-ink-soft mt-1">{inrLabel} today{fx.live ? '' : ' (indicative)'}</p>
          {checkout.taxMode !== 'none' && checkout.taxNote && <p class="text-[0.66rem] text-ink-soft/80 mt-0.5">{checkout.taxNote}</p>}
        </div>
      </div>

      <ul class="space-y-2 text-[0.85rem] text-ink-2 leading-relaxed">
        {checkout.included.map((line) => (
          <li class="flex gap-2.5"><span class="text-burn font-bold">+</span> {line}</li>
        ))}
      </ul>

      <p class="text-[0.75rem] text-ink-soft mt-4 pt-4 border-t border-ink/8 leading-relaxed">
        Charged in INR at the live exchange rate via Razorpay secure checkout. This fee is described in our policy as "process and verification fees" and is non-refundable once verification begins.
      </p>
      <p class="text-[0.78rem] text-ink-2 mt-3 bg-burn-pale/40 border border-burn-dim rounded-lg p-3 leading-relaxed">
        <strong>Please note:</strong> {checkout.disclaimer}
      </p>
    </div>

    <details class="bg-cream-2 border border-ink/10 rounded-xl mb-5 group">
      <summary class="cursor-pointer list-none px-5 py-3 flex items-center justify-between gap-3">
        <span class="text-[0.88rem] font-semibold text-ink">Why is there a fee at all?</span>
        <span class="text-burn font-mono text-[1.1rem] group-open:rotate-45 transition-transform">+</span>
      </summary>
      <div class="px-5 pb-4 text-[0.85rem] text-ink-soft leading-[1.8] font-light space-y-2">
        <p>EduRankAI takes <strong>no government subsidies, no donations, no advertiser money, no investor pressure on hiring</strong>. The platform you're applying through costs real money to run — the people who review each application, the infrastructure that hosts the proctoring + interview + verification stack, the salaries of the team who'll read your work.</p>
        <p>This small processing fee is how we pay those costs honestly. It does not improve your chances. It does not buy a faster review. It does not weight the rubric. It just lets us stay independent of every other form of influence.</p>
        <p>Full breakdown of where the money goes: <a href="/policy/fees" class="text-burn underline font-semibold">Why a fee?</a></p>
      </div>
    </details>

    {paymentsReady ? (
      <button id="payBtn" class="w-full bg-burn hover:bg-burn/90 text-white font-semibold py-3.5 rounded-lg text-[0.95rem] transition-all flex items-center justify-center gap-2">
        Pay {feeChf} CHF ({inrLabel}) &amp; continue
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </button>
    ) : (
      <div class="bg-burn-pale border border-burn-dim rounded-xl p-4 text-[0.85rem] text-ink-2 leading-relaxed text-center">
        Payments are being set up. Please contact <a href="mailto:hr@edurankai.in" class="text-burn font-semibold hover:underline">hr@edurankai.in</a> to complete this step.
      </div>
    )}

    {mode === 'intent' && !preBoundCoupon && checkout.showAid && (
      <p class="text-center text-[0.8rem] text-ink-soft mt-4">
        Have a coupon code, or paying from outside India?
        <button type="button" id="showAltLink" class="text-burn font-semibold hover:underline">See those options</button>
      </p>
    )}
    </div>

    {mode === 'intent' && checkout.showAid && (
      <div id="altBody" class="hidden scroll-mt-24 mt-2">
        <div class="flex items-center justify-between mb-3 pb-3 border-b border-ink/10">
          <p class="font-display text-[1.05rem] font-semibold text-ink">Other ways to complete this step</p>
          <button type="button" id="altBack" class="text-[0.8rem] font-semibold text-ink-soft hover:text-burn">&larr; Back to options</button>
        </div>
        <div class="grid grid-cols-3 gap-2 mb-3" id="altTabs">
          <button type="button" data-alt="waiver" class="alt-tab text-[0.78rem] font-semibold py-2.5 rounded-lg border border-ink/12 bg-white text-ink transition-colors">Financial aid</button>
          <button type="button" data-alt="coupon" class="alt-tab text-[0.78rem] font-semibold py-2.5 rounded-lg border border-ink/12 bg-white text-ink transition-colors">Coupon code</button>
          <button type="button" data-alt="intl" class="alt-tab text-[0.78rem] font-semibold py-2.5 rounded-lg border border-ink/12 bg-white text-ink transition-colors">Pay from abroad</button>
        </div>

        <div data-altpanel="coupon" class="altpanel bg-cream-2 border border-ink/10 rounded-xl p-5">
          <p class="text-[0.82rem] text-ink-soft leading-relaxed mb-3">Issued a coupon code (looks like <code class="font-mono text-[0.78rem] bg-white border border-ink/12 rounded px-1.5 py-0.5">EDU-XXXX-XXXX</code>)? Paste it — your application moves into review with the fee waived.</p>
          <div class="flex gap-2 items-stretch">
            <input id="couponCode" type="text" placeholder="EDU-XXXX-XXXX" maxlength="32" autocomplete="off" class="flex-1 px-3 py-2.5 border border-ink/15 rounded-lg text-[0.92rem] outline-none focus:border-burn bg-white uppercase font-mono tracking-wider" />
            <button id="redeemBtn" type="button" class="bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.88rem] transition-all whitespace-nowrap">Redeem</button>
          </div>
          <p id="couponMsg" class="text-[0.8rem] mt-2 min-h-[1.2em]"></p>
        </div>

        <div data-altpanel="intl" class="altpanel hidden bg-cream-2 border border-ink/10 rounded-xl p-5">
          <p class="text-[0.82rem] text-ink-soft leading-relaxed mb-3">Card from outside India not working? Tell us your country + preferred method and we'll send a payment link within 1 business day. Your application stays in queue meanwhile.</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-2 mb-3">
            <input id="iplCountry" type="text" placeholder="Country (e.g. United States)" maxlength="80" class="w-full px-3 py-2.5 border border-ink/15 rounded-lg text-[0.88rem] outline-none focus:border-burn bg-white" />
            <select id="iplMethod" class="w-full px-3 py-2.5 border border-ink/15 rounded-lg text-[0.88rem] outline-none focus:border-burn bg-white">
              <option value="">Preferred method</option>
              <option value="stripe">Stripe (international card)</option>
              <option value="paypal">PayPal</option>
              <option value="wise">Wise transfer</option>
              <option value="wire">International wire</option>
              <option value="other">Other</option>
            </select>
          </div>
          <textarea id="iplNotes" rows="3" maxlength="4000" placeholder="Anything we should know (currency, billing address, work email for invoice, etc.)" class="w-full px-3 py-2.5 border border-ink/15 rounded-lg text-[0.86rem] outline-none focus:border-burn bg-white resize-y leading-relaxed mb-3"></textarea>
          <button id="iplSubmit" type="button" class="w-full bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 rounded-lg text-[0.88rem] transition-all">Request international payment link</button>
          <p id="iplMsg" class="text-[0.78rem] mt-2 min-h-[1.2em] text-center"></p>
        </div>

        <div data-altpanel="waiver" class="altpanel hidden bg-cream-2 border border-ink/10 rounded-xl p-5">
          <p class="text-[0.82rem] text-ink-soft leading-relaxed mb-3">Genuine financial hardship? Tell us honestly and share your proof of work. We review every request manually within 5 business days; the decision arrives in your portal. Submitting moves your application into review with no payment.</p>
          <div class="mb-3">
            <label class="block text-[0.7rem] font-mono uppercase tracking-wider text-burn font-bold mb-1.5">Your situation</label>
            <textarea id="wfSituation" rows="3" maxlength="6000" placeholder="What makes paying the fee difficult right now?" class="w-full bg-white border border-ink/15 rounded-lg p-3 text-[0.88rem] leading-relaxed font-light outline-none focus:border-burn"></textarea>
          </div>
          <div class="mb-3">
            <label class="block text-[0.7rem] font-mono uppercase tracking-wider text-burn font-bold mb-1.5">Your expertise</label>
            <textarea id="wfExpertise" rows="3" maxlength="6000" placeholder="What have you built, written, designed, researched, or shipped? Point us at proof." class="w-full bg-white border border-ink/15 rounded-lg p-3 text-[0.88rem] leading-relaxed font-light outline-none focus:border-burn"></textarea>
          </div>
          <div class="mb-3">
            <label class="block text-[0.7rem] font-mono uppercase tracking-wider text-burn font-bold mb-1.5">Drive link (CV / portfolio / supporting docs)</label>
            <input id="wfDriveUrl" type="url" placeholder="https://drive.google.com/file/d/..." class="w-full bg-white border border-ink/15 rounded-lg p-3 text-[0.86rem] font-mono outline-none focus:border-burn" />
            <p class="text-[0.72rem] text-ink-soft mt-1">Set sharing to "Anyone with the link". Combine files into one folder or PDF if helpful.</p>
          </div>
          <button id="waiverSubmitBtn" type="button" class="w-full bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 rounded-lg text-[0.9rem] transition-all">Submit waiver request &amp; finish my application</button>
          <p id="waiverMsg" class="text-[0.8rem] mt-2 min-h-[1.2em] text-center"></p>
        </div>

        <script is:inline>
          (function () {
            var payChoice = document.getElementById('payChoice');
            var payPath = document.getElementById('payPath');
            var altBody = document.getElementById('altBody');
            var tabs = document.querySelectorAll('#altTabs .alt-tab');
            var panels = document.querySelectorAll('[data-altpanel]');
            function show(key) {
              panels.forEach(function (p) { p.classList.toggle('hidden', p.getAttribute('data-altpanel') !== key); });
              tabs.forEach(function (t) {
                var on = t.getAttribute('data-alt') === key;
                t.classList.toggle('bg-burn', on); t.classList.toggle('text-white', on); t.classList.toggle('border-burn', on);
                t.classList.toggle('bg-white', !on); t.classList.toggle('text-ink', !on);
              });
            }
            tabs.forEach(function (t) { t.addEventListener('click', function () { show(t.getAttribute('data-alt')); }); });
            show('waiver');
            function openAlt(tab) { if (altBody) { altBody.classList.remove('hidden'); show(tab); altBody.scrollIntoView({ behavior: 'smooth', block: 'start' }); } }
            var cPay = document.getElementById('choosePay');
            if (cPay) cPay.addEventListener('click', function () { if (payPath) payPath.classList.remove('hidden'); if (altBody) altBody.classList.add('hidden'); if (payPath) payPath.scrollIntoView({ behavior: 'smooth', block: 'start' }); });
            var cAid = document.getElementById('chooseAid');
            if (cAid) cAid.addEventListener('click', function () { if (payPath) payPath.classList.add('hidden'); openAlt('waiver'); });
            var sAlt = document.getElementById('showAltLink');
            if (sAlt) sAlt.addEventListener('click', function () { openAlt('coupon'); });
            var aBack = document.getElementById('altBack');
            if (aBack) aBack.addEventListener('click', function () { if (altBody) altBody.classList.add('hidden'); if (payChoice) payChoice.scrollIntoView({ behavior: 'smooth', block: 'start' }); });
          })();
        </script>
        </div>
    )}
    <p class="text-[0.72rem] text-ink-soft text-center mt-4">
      Questions about this step? <a href="mailto:hr@edurankai.in" class="text-burn hover:underline">hr@edurankai.in</a>
    </p>

  </section>

  {paymentsReady && (
    <>
      <script is:inline src="https://checkout.razorpay.com/v1/checkout.js"></script>
      <script is:inline define:vars={{ payloadId: mode === 'intent' ? intentId : appId, payloadKind: mode, candidateName, candidateEmail: app.email || '' }}>
        (function() {
          var btn = document.getElementById('payBtn');
          if (!btn) return;
          btn.addEventListener('click', function() {
            var prev = btn.innerHTML; btn.disabled = true; btn.textContent = 'Starting...';
            var body = payloadKind === 'intent' ? { intentId: payloadId } : { applicationId: payloadId };
            fetch('/api/payments/start-application-fee', {
              method: 'POST', credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(body),
            }).then(function(r) { return r.json(); }).then(function(d) {
              if (!d.ok) { btn.disabled = false; btn.innerHTML = prev; alert(d.error || 'Could not start.'); return; }
              if (d.alreadyPaid && d.redirect) { window.location.href = d.redirect; return; }
              if (!d.orderId) { btn.disabled = false; btn.innerHTML = prev; alert('Unexpected response.'); return; }
              if (typeof Razorpay === 'undefined') { btn.disabled = false; btn.innerHTML = prev; alert('Razorpay failed to load.'); return; }
              var rzp = new Razorpay({
                key: d.keyId, amount: d.amountPaise, currency: d.currency,
                name: 'EduRankAI', description: 'Process & verification fee', order_id: d.orderId,
                prefill: d.prefill || {},
                theme: { color: '#FF4F00' },
                handler: function(resp) {
                  btn.textContent = 'Verifying...';
                  fetch('/api/payments/verify', {
                    method: 'POST', credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                      razorpay_order_id: resp.razorpay_order_id,
                      razorpay_payment_id: resp.razorpay_payment_id,
                      razorpay_signature: resp.razorpay_signature,
                    }),
                  }).then(function(r) { return r.json(); }).then(function(c) {
                    if (c.ok && c.applicationId) {
                      window.location.href = '/apply/confirmation?id=' + c.applicationId;
                    } else if (c.ok && payloadKind === 'application') {
                      // Existing application re-pay (already has a row).
                      window.location.href = '/apply/confirmation?id=' + payloadId;
                    } else if (c.ok) {
                      // Payment captured but the application is still finalising
                      // (materialisation pending / being recovered). NEVER send to
                      // a broken confirmation page or let them pay again.
                      btn.textContent = 'Payment received';
                      document.body.insertAdjacentHTML('beforeend', '<div style="position:fixed;inset:0;background:rgba(14,11,8,0.55);display:flex;align-items:center;justify-content:center;z-index:99999;padding:20px;"><div style="background:#fff;border-radius:16px;max-width:430px;padding:30px;text-align:center;">' +
                        '<h2 style="margin:0 0 10px;font-size:1.3rem;color:#100b08;font-family:Fraunces,Georgia,serif;">Payment received.</h2>' +
                        '<p style="margin:0 0 20px;font-size:0.92rem;color:#5b5b5b;line-height:1.65;">Thank you. Your fee is paid and your application is being finalised now &mdash; it will appear in your portal shortly, and our team has been notified. <strong>You will not be charged again.</strong></p>' +
                        '<a href="/portal" style="display:inline-block;background:#FF4F00;color:#fff;text-decoration:none;padding:11px 26px;border-radius:9px;font-weight:600;font-size:0.92rem;">Go to my portal</a></div></div>');
                    } else { btn.disabled = false; btn.innerHTML = prev; alert(c.error || 'Payment verify failed.'); }
                  }).catch(function() { btn.disabled = false; btn.innerHTML = prev; alert('Network error.'); });
                },
                modal: { ondismiss: function() { btn.disabled = false; btn.innerHTML = prev; } },
              });
              rzp.open();
            }).catch(function() { btn.disabled = false; btn.innerHTML = prev; alert('Network error.'); });
          });
        })();
      </script>
    </>
  )}

  {mode === 'intent' && (
    <script is:inline define:vars={{ intentId }}>
      (function () {
        // ---- prominent (pre-bound) coupon banner: one-click redeem ----
        var preBtn = document.getElementById('preBoundRedeem');
        var preCode = document.getElementById('preBoundCode');
        var preMsg = document.getElementById('preBoundMsg');
        if (preBtn && preCode && preMsg) {
          preBtn.addEventListener('click', function () {
            var code = (preCode.textContent || '').trim();
            if (!code) return;
            var prev = preBtn.innerHTML; preBtn.disabled = true; preBtn.textContent = 'Redeeming...';
            preMsg.textContent = ''; preMsg.style.color = '';
            fetch('/api/portal/fee-waiver-coupons/redeem', {
              method: 'POST', credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ code: code, intentId: intentId }),
            }).then(function (r) { return r.json(); }).then(function (d) {
              if (d.ok) {
                preMsg.textContent = 'Accepted. Redirecting to your portal...';
                preMsg.style.color = '#047857';
                setTimeout(function () { window.location.href = '/apply/confirmation?id=' + d.applicationId; }, 600);
              } else {
                preBtn.disabled = false; preBtn.innerHTML = prev;
                preMsg.textContent = d.error || 'Could not redeem.';
                preMsg.style.color = '#b91c1c';
              }
            }).catch(function () {
              preBtn.disabled = false; preBtn.innerHTML = prev;
              preMsg.textContent = 'Network error.';
              preMsg.style.color = '#b91c1c';
            });
          });
        }

        // ---- coupon redeem ----
        var btn = document.getElementById('redeemBtn');
        var input = document.getElementById('couponCode');
        var msg = document.getElementById('couponMsg');
        if (btn && input && msg) {
          input.addEventListener('input', function () { input.value = input.value.toUpperCase(); });
          btn.addEventListener('click', function () {
            var code = (input.value || '').trim();
            if (!code) { msg.textContent = 'Enter a code first.'; msg.style.color = '#b85e3f'; return; }
            var prev = btn.innerHTML; btn.disabled = true; btn.textContent = 'Redeeming...';
            msg.textContent = ''; msg.style.color = '';
            fetch('/api/portal/fee-waiver-coupons/redeem', {
              method: 'POST', credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ code: code, intentId: intentId }),
            }).then(function (r) { return r.json(); }).then(function (d) {
              if (d.ok) {
                msg.textContent = 'Accepted. Redirecting...';
                msg.style.color = '#047857';
                setTimeout(function () { window.location.href = '/apply/confirmation?id=' + d.applicationId; }, 600);
              } else {
                btn.disabled = false; btn.innerHTML = prev;
                msg.textContent = d.error || 'Could not redeem.';
                msg.style.color = '#b91c1c';
              }
            }).catch(function () {
              btn.disabled = false; btn.innerHTML = prev;
              msg.textContent = 'Network error.';
              msg.style.color = '#b91c1c';
            });
          });
        }

        // ---- international payment request ----
        var iplBtn = document.getElementById('iplSubmit');
        var iplCountry = document.getElementById('iplCountry');
        var iplMethod = document.getElementById('iplMethod');
        var iplNotes = document.getElementById('iplNotes');
        var iplMsg = document.getElementById('iplMsg');
        if (iplBtn && iplCountry && iplMethod && iplMsg) {
          iplBtn.addEventListener('click', function () {
            var country = (iplCountry.value || '').trim();
            var method = (iplMethod.value || '').trim();
            var notes = (iplNotes && iplNotes.value || '').trim();
            if (!country || !method) {
              iplMsg.textContent = 'Country and preferred method are required.';
              iplMsg.style.color = '#b85e3f';
              return;
            }
            var prev = iplBtn.innerHTML; iplBtn.disabled = true; iplBtn.textContent = 'Sending request...';
            iplMsg.textContent = ''; iplMsg.style.color = '';
            fetch('/api/portal/intl-payment-request', {
              method: 'POST', credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ intentId: intentId, country: country, preferredMethod: method, notes: notes }),
            }).then(function (r) { return r.json(); }).then(function (d) {
              if (d.ok) {
                iplMsg.textContent = 'Request received. We will email you a payment link within 1 business day. You can close this tab.';
                iplMsg.style.color = '#047857';
              } else {
                iplBtn.disabled = false; iplBtn.innerHTML = prev;
                iplMsg.textContent = d.error || 'Could not send request.';
                iplMsg.style.color = '#b91c1c';
              }
            }).catch(function () {
              iplBtn.disabled = false; iplBtn.innerHTML = prev;
              iplMsg.textContent = 'Network error.';
              iplMsg.style.color = '#b91c1c';
            });
          });
        }

        // ---- inline fee-waiver submit ----
        var wBtn = document.getElementById('waiverSubmitBtn');
        var wSit = document.getElementById('wfSituation');
        var wExp = document.getElementById('wfExpertise');
        var wDrive = document.getElementById('wfDriveUrl');
        var wMsg = document.getElementById('waiverMsg');
        if (wBtn && wSit && wExp && wDrive && wMsg) {
          wBtn.addEventListener('click', function () {
            var situation = (wSit.value || '').trim();
            var expertise = (wExp.value || '').trim();
            var driveUrl = (wDrive.value || '').trim();
            if (!situation || !expertise || !driveUrl) {
              wMsg.textContent = 'All three fields are required.';
              wMsg.style.color = '#b85e3f';
              return;
            }
            if (!/^https?:\/\/.+/i.test(driveUrl)) {
              wMsg.textContent = 'Drive link must start with http:// or https://';
              wMsg.style.color = '#b85e3f';
              return;
            }
            var prev = wBtn.innerHTML; wBtn.disabled = true; wBtn.textContent = 'Submitting...';
            wMsg.textContent = ''; wMsg.style.color = '';
            fetch('/api/portal/fee-waivers/submit', {
              method: 'POST', credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ intentId: intentId, situation: situation, expertise: expertise, driveUrl: driveUrl }),
            }).then(function (r) { return r.json(); }).then(function (d) {
              if (d.ok) {
                wMsg.textContent = 'Submitted. Redirecting to your portal...';
                wMsg.style.color = '#047857';
                setTimeout(function () { window.location.href = '/portal'; }, 1200);
              } else {
                wBtn.disabled = false; wBtn.innerHTML = prev;
                wMsg.textContent = d.error || 'Could not submit.';
                wMsg.style.color = '#b91c1c';
              }
            }).catch(function () {
              wBtn.disabled = false; wBtn.innerHTML = prev;
              wMsg.textContent = 'Network error.';
              wMsg.style.color = '#b91c1c';
            });
          });
        }
      })();
    </script>
  )}
</BaseLayout>
