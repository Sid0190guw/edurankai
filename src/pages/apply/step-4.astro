---
import ApplyLayout from '@/layouts/ApplyLayout.astro';
import { db } from '@/lib/db';
import { roles, departments } from '@/lib/db/schema';
import { eq } from 'drizzle-orm';
import { getActiveDraft, saveDraft } from '@/lib/apply/draft';
import { safeDraft } from '@/lib/apply/data';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
if (user.role !== 'applicant') return Astro.redirect('/admin');

const url = new URL(Astro.request.url);
const roleSlug = url.searchParams.get('role') || '';

const draftRow = await getActiveDraft(user.id);
const draft = safeDraft(draftRow?.data);
const s4 = draft.step4 || {};

if (!draft.step1) return Astro.redirect('/apply/step-1' + (roleSlug ? '?role=' + roleSlug : ''));
if (!draft.step2) return Astro.redirect('/apply/step-2' + (roleSlug ? '?role=' + roleSlug : ''));
if (!draft.step3) return Astro.redirect('/apply/step-3' + (roleSlug ? '?role=' + roleSlug : ''));

let role: any = null;
let dept: any = null;
if (roleSlug) {
  const found = await db.select().from(roles).where(eq(roles.slug, roleSlug)).limit(1);
  if (found.length > 0) {
    role = found[0];
    const d = await db.select().from(departments).where(eq(departments.id, role.departmentId)).limit(1);
    if (d.length > 0) dept = d[0];
  }
}

const preselectedRoleTitle = role?.title || draft.step2?.roleTitle || '';
const deptId = role?.departmentId || draft.step2?.departmentId || '';

let errorMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();

  const necessaryChecked = fd.getAll('necessarySkills').map(v => (v as string).trim()).filter(Boolean);
  const optionalChecked = fd.getAll('optionalSkills').map(v => (v as string).trim()).filter(Boolean);
  const eliteChecked = fd.getAll('eliteSkills').map(v => (v as string).trim()).filter(Boolean);

  const proofTitles = fd.getAll('proofTitle').map(v => (v as string).trim());
  const proofUrls = fd.getAll('proofUrl').map(v => (v as string).trim());
  const proofWhich = fd.getAll('proofWhich').map(v => (v as string).trim());
  const proofDesc = fd.getAll('proofDesc').map(v => (v as string).trim());

  const proofs = [];
  for (let i = 0; i < proofUrls.length; i++) {
    if (proofUrls[i]) {
      proofs.push({
        title: proofTitles[i] || '',
        url: proofUrls[i],
        whichSkill: proofWhich[i] || '',
        description: proofDesc[i] || ''
      });
    }
  }

  const data = {
    necessarySkills: necessaryChecked,
    optionalSkills: optionalChecked,
    eliteSkills: eliteChecked,
    otherSkills: (fd.get('otherSkills') as string || '').trim(),
    proofs: proofs,
    deptResponse: (fd.get('deptResponse') as string || '').trim()
  };

  const missing = [];
  if (proofs.length === 0) {
    missing.push('At least one proof of work (artifact link)');
  }
  if (!data.deptResponse) {
    missing.push('Department-specific reflection');
  }

  if (missing.length > 0) {
    errorMsg = 'Please complete: ' + missing.join(', ');
  } else {
    const newDraft = { ...draft, step4: data };
    await saveDraft(user.id, user.email, newDraft, 5);
    return Astro.redirect('/apply/step-5' + (roleSlug ? '?role=' + roleSlug : ''));
  }
}

const DEPT_SKILLS: Record<string, { necessary: string[]; optional: string[]; elite: string[]; question: string; placeholder: string; }> = {
  founders: {
    necessary: ['Self-starter mindset (have shipped something solo)', 'Clear written communication', 'Reading and synthesizing complex material'],
    optional: ['Pitching / public speaking', 'Cold outreach', 'Building in public', 'Hiring / recruiting'],
    elite: ['Started a previous company or org from zero', 'Raised funding before', 'Built a community of 1000+ engaged people', 'Published widely-read writing'],
    question: 'Tell us about a time you started something from nothing - and why you want to build inside EduRankAI vs starting your own thing.',
    placeholder: 'Be specific. A club, a business, a movement, a side project nobody asked for. What did you learn? What would you do differently? Why us vs solo?'
  },
  exec: {
    necessary: ['P and L responsibility experience', 'Hiring senior leaders', 'Strategic planning and execution'],
    optional: ['Board management', 'Investor relations', 'M and A experience', 'Crisis communication', 'Cross-functional org leadership'],
    elite: ['Took company through major funding round', 'Operated through a public-company transition', 'Led 100+ person org', 'Government / policy relations experience'],
    question: 'Describe a high-stakes executive decision you made, the tradeoffs, and what you learned.',
    placeholder: 'We want operators who hold complexity. Real decision, real tradeoffs, real outcome. What did you sacrifice? What surprised you in hindsight?'
  },
  ai: {
    necessary: ['Hands-on with PyTorch or JAX', 'Trained or fine-tuned a model end-to-end', 'Reading current ML papers'],
    optional: ['HuggingFace ecosystem', 'LangChain / RAG architectures', 'Distributed training experience', 'CUDA / Triton optimization', 'Vector databases'],
    elite: ['Published in NeurIPS / ICML / ICLR / ACL', 'Pre-trained models from scratch', 'Mechanistic interpretability research', 'Built RLHF / DPO pipelines at scale', 'Original architecture contributions'],
    question: 'What is the most interesting model behavior you have personally observed - a real bug, surprise, capability, or failure mode?',
    placeholder: 'We care how you think about models. Not tutorials. Real observation. What did you do? What did you learn? Link to a notebook or paper if you have one.'
  },
  data: {
    necessary: ['Strong SQL', 'Python (pandas / polars / numpy)', 'Statistical reasoning'],
    optional: ['A/B testing and experimentation design', 'Bayesian statistics', 'Time series analysis', 'Causal inference', 'dbt / Airflow / Dagster', 'Tableau / Looker / Metabase'],
    elite: ['Published research using statistical methods', 'Designed experiments at >1M user scale', 'Built ML feature stores in production', 'Led a data team'],
    question: 'Walk us through a real analysis you owned end-to-end. Question, data, finding, action.',
    placeholder: 'Specific. Not I analyzed data. What was the business or research question? What surprised you? What did your finding lead to?'
  },
  infra: {
    necessary: ['Linux / cloud fundamentals (AWS, GCP, or Azure)', 'Containerization (Docker)', 'CI/CD pipelines'],
    optional: ['Kubernetes', 'Terraform / Pulumi', 'Observability (Prometheus, Grafana, Datadog)', 'GPU cluster management', 'Networking deep knowledge'],
    elite: ['Operated systems serving >1M users', 'Built GPU training clusters from scratch', 'Designed multi-region disaster recovery', 'Owned production incident response at scale'],
    question: 'Tell us about the most painful infrastructure problem you debugged - the war story.',
    placeholder: 'War stories teach more than tutorials. Real production fire or research-cluster issue. Symptom, hypotheses, root cause, time taken.'
  },
  product: {
    necessary: ['Hands-on with a design tool (Figma / Framer)', 'User research / interviewing users', 'Writing PRDs or design specs'],
    optional: ['Design systems', 'Prototyping with code', 'Product analytics (Mixpanel, Amplitude)', 'A/B testing', 'Information architecture'],
    elite: ['Shipped products used by >100k users', 'Led product from zero to launch', 'Award-winning design portfolio', 'Founded a design-led company'],
    question: 'Show us a product you shaped. What choices did you make and what would you do differently now?',
    placeholder: 'Link or describe a product, feature, or design you owned. We care more about the choices and post-mortem than polish.'
  },
  safety: {
    necessary: ['Reading frontier AI safety literature deeply', 'Understanding of LLM training pipelines', 'Engineering or research background'],
    optional: ['Red-teaming experience', 'Adversarial robustness research', 'Mechanistic interpretability', 'AI governance / policy', 'Cryptography'],
    elite: ['Published in alignment-focused venues', 'Discovered novel jailbreaks or model failures', 'Contributed to RSP or governance frameworks', 'Worked at a frontier lab on safety'],
    question: 'What AI safety question keeps you up at night - and what is wrong about current discourse on it?',
    placeholder: 'We do not want received wisdom. Your actual view. What is overhyped? Under-discussed? How would you design an experiment to test your hypothesis?'
  },
  quantum: {
    necessary: ['Linear algebra at depth', 'Physics or CS background with quantum coursework', 'Basic quantum programming (Qiskit, Cirq, or PennyLane)'],
    optional: ['Quantum algorithms (Shor, Grover, VQE, QAOA)', 'Quantum error correction', 'Quantum hardware understanding', 'Quantum chemistry / simulation', 'Quantum ML'],
    elite: ['Published quantum computing research', 'Worked at a quantum hardware company', 'Contributed to open-source quantum stacks', 'PhD in quantum information or physics'],
    question: 'What part of quantum computing do you find most overhyped, and most underrated?',
    placeholder: 'Pick one overhyped claim, pick one underrated direction. Why? What would you build with a 1000-qubit machine today?'
  },
  research: {
    necessary: ['Reading and critiquing papers', 'Reproducing published results', 'Statistical literacy'],
    optional: ['Writing papers (LaTeX, peer review)', 'Conference experience', 'Designing experiments', 'Cross-disciplinary background', 'Open-sourcing research code'],
    elite: ['First-author publication at top venue', 'Cited research', 'Grant writing experience', 'PhD in relevant field', 'Original research direction proposed'],
    question: 'What paper or finding changed how you think, and what is its main weakness?',
    placeholder: 'Great researchers love and critique their heroes. What paper influenced you? What did it get wrong? What experiment would push it further?'
  },
  dataengine: {
    necessary: ['Python data processing', 'Understanding of data labeling / annotation', 'SQL'],
    optional: ['Active learning techniques', 'Synthetic data generation', 'Distributed processing (Spark, Ray, Beam)', 'Embedding-based search', 'Crowdsourcing platforms'],
    elite: ['Built training datasets used in published models', 'Designed eval benchmarks adopted by others', 'Multilingual data engineering for low-resource languages', 'Led data curation at frontier lab'],
    question: 'How would you build a high-quality dataset from scratch for one EduRankAI venture (Karate.support, AquinTutor, etc)?',
    placeholder: 'Pick one venture. Walk through your plan. Sources, quality controls, labelers, biases, budget tradeoffs. We want concrete thinking.'
  },
  formdb: {
    necessary: ['Postgres or similar SQL DB at depth', 'Schema design and normalization', 'ORM or query layer (Drizzle, Prisma, SQLAlchemy)'],
    optional: ['Query optimization / EXPLAIN plans', 'Index design and partitioning', 'API design (REST, GraphQL, RPC)', 'Migrations / zero-downtime deploys', 'Form builders / no-code platforms'],
    elite: ['Operated databases at 100M+ row scale', 'Designed multi-tenant SaaS schemas', 'Built custom database engines or extensions', 'Contributed to open-source DB tooling'],
    question: 'Design the schema for a form system supporting 100 form types and 1M responses. Sketch the tables.',
    placeholder: 'Tables, key relationships, indexes. What about versioning forms? Search? Branching logic? Analytics? Show your tradeoff thinking.'
  },
  psychology: {
    necessary: ['Foundation in cognitive or educational psychology', 'Familiarity with research methods', 'Reading peer-reviewed psychology papers'],
    optional: ['Behavior change theory', 'Qualitative interviewing', 'Quantitative survey design', 'Statistical analysis (R, SPSS)', 'IRB / ethics in human research'],
    elite: ['Published in psychology journals', 'Designed studies adopted by industry', 'PhD in psychology or related field', 'Bridged psychology with AI / ML research'],
    question: 'What does great learning actually look like, and where does most edtech get it wrong?',
    placeholder: 'Sharp criticism of edtech welcome. What is the deepest principle of learning you believe in? Which popular method or product violates it?'
  },
  hr: {
    necessary: ['Recruiting / sourcing candidates', 'Interviewing with structured rubrics', 'Understanding of compensation basics'],
    optional: ['Performance review systems', 'Career framework design', 'Conflict mediation', 'Labor law / compliance', 'HR systems (Workday, Gusto, etc.)'],
    elite: ['Scaled hiring at fast-growing startup', 'Designed comp framework for a company', 'Led diversity programs with measurable outcomes', 'Built recruiting brand from scratch'],
    question: 'How do you hire for a mission-driven frontier company without compromising on speed or fairness?',
    placeholder: 'Hiring as a craft. What signal do you trust? What signal do you ignore? How would you prevent bias? How would you scale 5x without losing quality?'
  },
  legal: {
    necessary: ['Reading and drafting contracts', 'Understanding of equity / cap tables', 'Indian or international corporate law basics'],
    optional: ['Fundraising docs (SAFE, term sheets)', 'IP / patents / trademarks', 'Compliance (DPDP, GDPR, AI Act)', 'Financial modeling', 'Tax planning'],
    elite: ['Bar admission with strong record', 'CA / CFA / similar professional credential', 'Led major M and A or IPO', 'Government / regulatory advisory experience'],
    question: 'What is one legal or financial risk an Indian AI startup is sleeping on right now?',
    placeholder: 'See around corners. Pick one risk - regulatory, financial, IP, governance. What would you do about it on day 1 if you joined?'
  },
  growth: {
    necessary: ['Understanding of growth funnels and metrics', 'Hands-on with at least one growth channel', 'Copywriting basics'],
    optional: ['SEO (technical and content)', 'Performance marketing (ads platforms)', 'Email / lifecycle marketing', 'Community building', 'Brand strategy'],
    elite: ['Grew a product to >100k users via owned channels', 'Built influential community or audience', 'Award-winning campaigns', 'Operated growth at frontier consumer company'],
    question: 'How would you get the first 10,000 users for Karate.support or AquinTutor.ai?',
    placeholder: 'Pick one venture. Zero-to-10k playbook. Channels, copy angles, budget split, week 1 vs month 3. No vague growth-hacker speak.'
  }
};

const config = DEPT_SKILLS[deptId] || DEPT_SKILLS.founders;
const deptName = dept?.name || 'this department';

const existingNecessary = Array.isArray(s4.necessarySkills) ? s4.necessarySkills : [];
const existingOptional = Array.isArray(s4.optionalSkills) ? s4.optionalSkills : [];
const existingElite = Array.isArray(s4.eliteSkills) ? s4.eliteSkills : [];
const existingProofs = (Array.isArray(s4.proofs) && s4.proofs.length > 0) ? s4.proofs : [{ title: '', url: '', whichSkill: '', description: '' }];

const allSkillsForProof = [...config.necessary, ...config.optional, ...config.elite];
const allSkillsJson = JSON.stringify(allSkillsForProof);
---
<ApplyLayout step={4} totalSteps={6} stepTitle="Skills and Proof of Work" stepSubtitle="What you bring, and the artifacts that prove it." roleTitle={preselectedRoleTitle}>

  {errorMsg && (
    <div style="background:rgba(220,38,38,0.06);border:1px solid rgba(220,38,38,0.25);color:#b91c1c;font-size:0.85rem;padding:11px 14px;border-radius:8px;margin-bottom:18px;line-height:1.6;">
      {errorMsg}
    </div>
  )}

  <div class="bg-cream-2 border border-ink/10 rounded-xl p-4 mb-6 text-[0.82rem] text-ink-2 leading-relaxed">
    <p class="font-semibold text-ink mb-1.5">How this works</p>
    <p>We separate skills into three tiers: <strong class="text-burn">Necessary</strong> (must-have for {deptName}), <strong class="text-sky">Optional</strong> (broadens your fit), and <strong class="text-plum">Elite</strong> (rare signals, fast-track if present). Be honest - we will probe these in the interview. Then attach at least one proof of work artifact below.</p>
  </div>

  <form method="POST" class="flex flex-col gap-6">

    <div>
      <div class="flex items-center gap-2 mb-2">
        <span class="text-[0.62rem] font-mono uppercase tracking-wider text-burn bg-burn-pale border border-burn-dim px-2 py-0.5 rounded-full font-bold">Necessary</span>
        <p class="text-[0.78rem] text-ink-soft italic">Must-have for {deptName}.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
        {config.necessary.map((skill) => {
          const checked = existingNecessary.includes(skill);
          return (
            <label class={'flex items-center gap-2.5 px-3 py-2.5 border rounded-lg cursor-pointer text-[0.85rem] transition-all ' + (checked ? 'border-burn bg-burn-pale text-burn font-semibold' : 'border-ink/15 bg-cream-2 hover:border-burn-dim')}>
              <input type="checkbox" name="necessarySkills" value={skill} checked={checked} class="accent-burn w-4 h-4 shrink-0" />
              <span>{skill}</span>
            </label>
          );
        })}
      </div>
    </div>

    <div>
      <div class="flex items-center gap-2 mb-2">
        <span class="text-[0.62rem] font-mono uppercase tracking-wider text-sky bg-sky-bg border border-sky-border px-2 py-0.5 rounded-full font-bold">Optional</span>
        <p class="text-[0.78rem] text-ink-soft italic">Nice-to-have. Bonus signal.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
        {config.optional.map((skill) => {
          const checked = existingOptional.includes(skill);
          return (
            <label class={'flex items-center gap-2.5 px-3 py-2.5 border rounded-lg cursor-pointer text-[0.85rem] transition-all ' + (checked ? 'border-sky bg-sky-bg text-sky font-semibold' : 'border-ink/15 bg-cream-2 hover:border-sky-border')}>
              <input type="checkbox" name="optionalSkills" value={skill} checked={checked} class="accent-sky w-4 h-4 shrink-0" />
              <span>{skill}</span>
            </label>
          );
        })}
      </div>
    </div>

    <div>
      <div class="flex items-center gap-2 mb-2">
        <span class="text-[0.62rem] font-mono uppercase tracking-wider text-plum bg-plum-bg border border-plum-border px-2 py-0.5 rounded-full font-bold">Elite</span>
        <p class="text-[0.78rem] text-ink-soft italic">Rare, exceptional signals. Check only if you genuinely have these - we will probe.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
        {config.elite.map((skill) => {
          const checked = existingElite.includes(skill);
          return (
            <label class={'flex items-center gap-2.5 px-3 py-2.5 border rounded-lg cursor-pointer text-[0.85rem] transition-all ' + (checked ? 'border-plum bg-plum-bg text-plum font-semibold' : 'border-ink/15 bg-cream-2 hover:border-plum-border')}>
              <input type="checkbox" name="eliteSkills" value={skill} checked={checked} class="accent-plum w-4 h-4 shrink-0" />
              <span>{skill}</span>
            </label>
          );
        })}
      </div>
    </div>

    <div>
      <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">
        Other skills not listed <span class="text-ink-soft/60 font-normal normal-case tracking-normal">(optional)</span>
      </label>
      <input type="text" name="otherSkills" value={s4.otherSkills || ''} placeholder="e.g. Rust, Solidity, Sanskrit translation, music production..." class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
    </div>

    <div class="border-t border-ink/8 pt-6">
      <div class="mb-3">
        <h3 class="font-display text-[1.05rem] font-semibold text-ink">Proof of Work <span class="text-burn">*</span></h3>
        <p class="text-[0.78rem] text-ink-soft italic">At least one artifact required. Link to real work that demonstrates the skills you checked.</p>
      </div>

      <div class="bg-sky-bg border border-sky-border rounded-lg p-3.5 mb-3 text-[0.78rem] text-ink-2 leading-relaxed">
        <p class="font-semibold text-sky mb-1">What counts as proof</p>
        <p>GitHub repo, deployed app URL, Google Drive document, Figma file, Notion page, paper PDF, blog post, YouTube demo, dataset, Kaggle notebook, technical writing, anything tangible. Make links accessible (public or anyone-with-link).</p>
      </div>

      <div id="proof-list" class="flex flex-col gap-3">
        {existingProofs.map((proof) => (
          <div class="proof-entry bg-cream-2/50 border border-ink/10 rounded-lg p-4 relative">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              <div>
                <label class="block text-[0.65rem] font-bold uppercase tracking-wider text-ink-soft mb-1.5">Title</label>
                <input type="text" name="proofTitle" value={proof.title || ''} placeholder="e.g. ML pipeline for X" class="w-full px-3 py-2 border border-ink/15 rounded-md text-[0.85rem] outline-none focus:border-burn bg-white" />
              </div>
              <div>
                <label class="block text-[0.65rem] font-bold uppercase tracking-wider text-ink-soft mb-1.5">Which skill does this prove?</label>
                <select name="proofWhich" class="w-full px-3 py-2 border border-ink/15 rounded-md text-[0.85rem] outline-none focus:border-burn bg-white">
                  <option value="">Select...</option>
                  {allSkillsForProof.map((skill) => {
                    const sel = proof.whichSkill === skill;
                    return <option value={skill} selected={sel}>{skill}</option>;
                  })}
                  <option value="Other / not listed" selected={proof.whichSkill === 'Other / not listed'}>Other / not listed</option>
                </select>
              </div>
              <div class="md:col-span-2">
                <label class="block text-[0.65rem] font-bold uppercase tracking-wider text-ink-soft mb-1.5">Link <span class="text-burn">*</span></label>
                <input type="url" name="proofUrl" value={proof.url || ''} placeholder="https://github.com/... or https://drive.google.com/..." class="w-full px-3 py-2 border border-ink/15 rounded-md text-[0.85rem] outline-none focus:border-burn bg-white" />
              </div>
              <div class="md:col-span-2">
                <label class="block text-[0.65rem] font-bold uppercase tracking-wider text-ink-soft mb-1.5">Brief description (what should we look at)</label>
                <textarea name="proofDesc" rows="2" placeholder="Point us to specific files, sections, or features that demonstrate the skill." class="w-full px-3 py-2 border border-ink/15 rounded-md text-[0.85rem] outline-none focus:border-burn bg-white resize-y">{proof.description || ''}</textarea>
              </div>
            </div>
            <button type="button" class="remove-proof absolute top-2 right-2 text-ink-soft/50 hover:text-burn text-lg leading-none w-7 h-7 flex items-center justify-center" title="Remove proof">x</button>
          </div>
        ))}
      </div>

      <button type="button" id="add-proof" class="mt-3 w-full px-4 py-2.5 border border-dashed border-burn-dim text-burn font-semibold text-[0.82rem] rounded-lg hover:bg-burn-pale transition-all flex items-center justify-center gap-2">
        <span class="text-base">+</span> Add another proof
      </button>
    </div>

    <div class="bg-burn-pale border border-burn-dim rounded-xl p-5">
      <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-burn mb-2">
        {config.question} <span class="text-burn">*</span>
      </label>
      <textarea name="deptResponse" required rows="6" placeholder={config.placeholder} class="w-full px-3 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-white resize-y leading-relaxed">{s4.deptResponse || ''}</textarea>
      <p class="text-[0.7rem] text-ink-soft mt-1 italic">Specific and concrete. 4-8 sentences. We read every word.</p>
    </div>

    <div class="flex gap-3 pt-2">
      <a href={'/apply/step-3' + (roleSlug ? '?role=' + roleSlug : '')} class="px-5 py-3 border border-ink/15 rounded-lg text-[0.88rem] font-medium text-ink-soft hover:border-burn-dim hover:text-ink transition-all flex items-center gap-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M11 6l-6 6 6 6"/></svg>
        Back
      </a>
      <button type="submit" class="flex-1 bg-ink hover:bg-ink/90 text-white font-semibold py-3 rounded-lg text-[0.9rem] transition-all flex items-center justify-center gap-2">
        Continue
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </button>
    </div>

  </form>

</ApplyLayout>

<script id="all-skills-data" type="application/json" set:html={allSkillsJson}></script>

<script is:inline>
(function() {
  const dataEl = document.getElementById('all-skills-data');
  const allSkills = dataEl ? JSON.parse(dataEl.textContent) : [];

  function makeProofEntry() {
    const div = document.createElement('div');
    div.className = 'proof-entry bg-cream-2/50 border border-ink/10 rounded-lg p-4 relative';
    let opts = '<option value="">Select...</option>';
    allSkills.forEach(function(s) {
      const safe = String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      opts += '<option value="' + safe + '">' + safe + '</option>';
    });
    opts += '<option value="Other / not listed">Other / not listed</option>';
    div.innerHTML =
      '<div class="grid grid-cols-1 md:grid-cols-2 gap-3">' +
        '<div><label class="block text-[0.65rem] font-bold uppercase tracking-wider text-ink-soft mb-1.5">Title</label>' +
        '<input type="text" name="proofTitle" placeholder="e.g. ML pipeline for X" class="w-full px-3 py-2 border border-ink/15 rounded-md text-[0.85rem] outline-none focus:border-burn bg-white" /></div>' +
        '<div><label class="block text-[0.65rem] font-bold uppercase tracking-wider text-ink-soft mb-1.5">Which skill does this prove?</label>' +
        '<select name="proofWhich" class="w-full px-3 py-2 border border-ink/15 rounded-md text-[0.85rem] outline-none focus:border-burn bg-white">' + opts + '</select></div>' +
        '<div class="md:col-span-2"><label class="block text-[0.65rem] font-bold uppercase tracking-wider text-ink-soft mb-1.5">Link</label>' +
        '<input type="url" name="proofUrl" placeholder="https://github.com/..." class="w-full px-3 py-2 border border-ink/15 rounded-md text-[0.85rem] outline-none focus:border-burn bg-white" /></div>' +
        '<div class="md:col-span-2"><label class="block text-[0.65rem] font-bold uppercase tracking-wider text-ink-soft mb-1.5">Brief description</label>' +
        '<textarea name="proofDesc" rows="2" placeholder="Point us to specific files or features." class="w-full px-3 py-2 border border-ink/15 rounded-md text-[0.85rem] outline-none focus:border-burn bg-white resize-y"></textarea></div>' +
      '</div>' +
      '<button type="button" class="remove-proof absolute top-2 right-2 text-ink-soft/50 hover:text-burn text-lg leading-none w-7 h-7 flex items-center justify-center" title="Remove proof">x</button>';
    return div;
  }

  document.getElementById('add-proof').addEventListener('click', function() {
    document.getElementById('proof-list').appendChild(makeProofEntry());
  });

  document.addEventListener('click', function(e) {
    if (e.target && e.target.classList && e.target.classList.contains('remove-proof')) {
      const wrap = e.target.closest('.proof-entry');
      if (wrap) {
        const parent = wrap.parentElement;
        if (parent.children.length > 1) {
          wrap.remove();
        } else {
          wrap.querySelectorAll('input, textarea, select').forEach(function(el) {
            if (el.tagName === 'SELECT') el.selectedIndex = 0;
            else el.value = '';
          });
        }
      }
    }
  });
})();
</script>
