---
import ApplyLayout from '@/layouts/ApplyLayout.astro';
import { db } from '@/lib/db';
import { roles, departments, applications } from '@/lib/db/schema';
import { eq, desc as sqlDesc } from 'drizzle-orm';
import { getActiveDraft, deleteDraft } from '@/lib/apply/draft';
import { safeDraft, isInternOrApprentice } from '@/lib/apply/data';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
if (user.role !== 'applicant') return Astro.redirect('/admin');

const url = new URL(Astro.request.url);
const roleSlug = url.searchParams.get('role') || '';

const draftRow = await getActiveDraft(user.id);
const draft = safeDraft(draftRow?.data);

if (!draft.step1) return Astro.redirect('/apply/step-1' + (roleSlug ? '?role=' + roleSlug : ''));
if (!draft.step2) return Astro.redirect('/apply/step-2' + (roleSlug ? '?role=' + roleSlug : ''));
if (!draft.step3) return Astro.redirect('/apply/step-3' + (roleSlug ? '?role=' + roleSlug : ''));
if (!draft.step4) return Astro.redirect('/apply/step-4' + (roleSlug ? '?role=' + roleSlug : ''));
if (!draft.step5) return Astro.redirect('/apply/step-5' + (roleSlug ? '?role=' + roleSlug : ''));

const s1 = draft.step1;
const s2 = draft.step2;
const s3 = draft.step3;
const s4 = draft.step4;
const s5 = draft.step5;

let role: any = null;
let dept: any = null;
if (roleSlug) {
  const found = await db.select().from(roles).where(eq(roles.slug, roleSlug)).limit(1);
  if (found.length > 0) {
    role = found[0];
    const d = await db.select().from(departments).where(eq(departments.id, role.departmentId)).limit(1);
    if (d.length > 0) dept = d[0];
  }
}

const roleTitle = role?.title || s2?.roleTitle || '';
const deptName = dept?.name || '';
const roleLevel = role?.level || s2?.level || '';
const hideCompensation = isInternOrApprentice(roleLevel);

let errorMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const consent = fd.get('consent');

  if (!consent) {
    errorMsg = 'Please confirm that the information you submitted is true and accurate.';
  } else {
    try {
      const fullPhone = (s1.phoneCountry || '+91') + ' ' + (s1.phone || '');

      const techSkillsBlob = {
        necessary: Array.isArray(s4.necessarySkills) ? s4.necessarySkills : [],
        optional: Array.isArray(s4.optionalSkills) ? s4.optionalSkills : [],
        elite: Array.isArray(s4.eliteSkills) ? s4.eliteSkills : [],
        customNecessary: Array.isArray(s4.customNecessary) ? s4.customNecessary : [],
        customOptional: Array.isArray(s4.customOptional) ? s4.customOptional : [],
        customElite: Array.isArray(s4.customElite) ? s4.customElite : [],
        other: s4.otherSkills || '',
        proofs: Array.isArray(s4.proofs) ? s4.proofs : [],
        deptResponse: s4.deptResponse || ''
      };

      const rawSubmission = {
        step1: s1, step2: s2, step3: s3, step4: s4, step5: s5,
        submittedAt: new Date().toISOString()
      };

      const educationSummary = Array.isArray(s3.education) && s3.education.length > 0
        ? s3.education.map((e: any) => (e.degree || '') + ' ' + (e.field || '')).join('; ')
        : '';
      const institutionSummary = Array.isArray(s3.education) && s3.education.length > 0
        ? s3.education.map((e: any) => e.institution || '').filter(Boolean).join('; ')
        : '';
      const fieldSummary = Array.isArray(s3.education) && s3.education.length > 0
        ? s3.education.map((e: any) => e.field || '').filter(Boolean).join('; ')
        : '';

      const ipHeader = Astro.request.headers.get('x-forwarded-for') || Astro.request.headers.get('cf-connecting-ip') || '';
      const ua = Astro.request.headers.get('user-agent') || '';

      // Generate next application number (EDU-YYYY-NNNNN)
      const year = new Date().getFullYear();
      const yearPrefix = `EDU-${year}-`;
      const lastApp = await db.select({ applicationNumber: applications.applicationNumber })
        .from(applications)
        .orderBy(sqlDesc(applications.createdAt))
        .limit(50);
      let maxNum = 0;
      for (const a of lastApp) {
        if (a.applicationNumber && a.applicationNumber.startsWith(yearPrefix)) {
          const n = parseInt(a.applicationNumber.substring(yearPrefix.length), 10);
          if (!isNaN(n) && n > maxNum) maxNum = n;
        }
      }
      const applicationNumber = `${yearPrefix}${String(maxNum + 1).padStart(5, '0')}`;

      const insertResult = await db.insert(applications).values({
        applicationNumber,
        roleId: role?.id || null,
        applicantUserId: user.id,
        firstName: s1.firstName || '',
        lastName: s1.lastName || '',
        email: s1.email || user.email,
        phone: fullPhone,
        city: s1.currentCity || '',
        linkedin: s1.linkedin || null,
        portfolioUrl: s1.resumeLink || '',
        photoUrl: s1.photoUrl || null,
        dob: s1.dateOfBirth || null,
        birthTime: s1.birthTime || null,
        birthPlace: s1.birthPlace || null,
        departmentSnapshot: deptName,
        roleTitleSnapshot: roleTitle,
        level: roleLevel || null,
        openToOther: s2.openToOther === 'Yes',
        education: educationSummary.substring(0, 100) || null,
        fieldOfStudy: fieldSummary.substring(0, 200) || null,
        institution: institutionSummary.substring(0, 300) || null,
        experienceBand: s3.yearsExperience || null,
        experienceDescription: s3.whyRelevant || s3.experienceDescription || null,
        duolingoScore: s3.duolingoScore ? parseInt(s3.duolingoScore) : null,
        duolingoScreenshotUrl: s3.duolingoScreenshotUrl || null,
        techSkills: techSkillsBlob,
        whyERA: s5.whyERA || null,
        whyRole: s5.whyRole || null,
        whyAIEdu: s5.whyAIEdu || null,
        intersection: s5.intersection || null,
        ambitious: s5.ambitious || null,
        ethicsExperience: s5.ethicsExperience || null,
        ethicsIdeal: s5.ethicsIdeal || null,
        availability: s5.availability || null,
        engagementType: s5.engagementType || null,
        remoteComfort: s5.remoteComfort || null,
        compensation: hideCompensation ? null : (s5.compensation || null),
        source: s5.source || null,
        status: 'submitted',
        rawSubmission: rawSubmission,
        ipAddress: ipHeader.substring(0, 64),
        userAgent: ua
      }).returning({ id: applications.id });

      const newAppId = insertResult[0].id;

      await deleteDraft(user.id);

      return Astro.redirect('/apply/confirmation?id=' + newAppId);
    } catch (err: any) {
      console.error('Application submission error:', err);
      errorMsg = 'Submission failed: ' + (err.message || 'Unknown error') + '. Please try again or contact hr@edurankai.in';
    }
  }
}

const fullName = (s1.firstName || '') + ' ' + (s1.lastName || '');
const fullPhoneDisplay = (s1.phoneCountry || '+91') + ' ' + (s1.phone || '');

const eduCount = Array.isArray(s3.education) ? s3.education.length : 0;
const certCount = Array.isArray(s3.certifications) ? s3.certifications.length : 0;
const workCount = Array.isArray(s3.workExperience) ? s3.workExperience.length : 0;
const proofCount = Array.isArray(s4.proofs) ? s4.proofs.length : 0;
const necessaryCount = Array.isArray(s4.necessarySkills) ? s4.necessarySkills.length : 0;
const optionalCount = Array.isArray(s4.optionalSkills) ? s4.optionalSkills.length : 0;
const eliteCount = Array.isArray(s4.eliteSkills) ? s4.eliteSkills.length : 0;
const customNecCount = Array.isArray(s4.customNecessary) ? s4.customNecessary.length : 0;
const customOptCount = Array.isArray(s4.customOptional) ? s4.customOptional.length : 0;
const customEliteCount = Array.isArray(s4.customElite) ? s4.customElite.length : 0;
---
<ApplyLayout step={6} totalSteps={6} stepTitle="Review and Submit" stepSubtitle="Last check before we receive your application." roleTitle={roleTitle}>

  {errorMsg && (
    <div style="background:rgba(220,38,38,0.06);border:1px solid rgba(220,38,38,0.25);color:#b91c1c;font-size:0.85rem;padding:11px 14px;border-radius:8px;margin-bottom:18px;line-height:1.6;">
      {errorMsg}
    </div>
  )}

  <div class="bg-sky-bg border border-sky-border rounded-xl p-4 mb-6 text-[0.85rem] text-ink-2 leading-relaxed">
    <p class="font-semibold text-sky mb-1">Quick review</p>
    <p>Take a moment to scan everything below. Click "Edit" on any section to fix. When you submit, your application will be saved and we will respond within 5 business days.</p>
  </div>

  <div class="flex flex-col gap-4 mb-6">

    <div class="bg-cream-2/50 border border-ink/10 rounded-xl p-4">
      <div class="flex items-start justify-between gap-3 mb-3">
        <div>
          <p class="text-[0.62rem] font-mono uppercase tracking-wider text-burn font-bold mb-0.5">Step 1 - Personal</p>
          <p class="font-display text-[1rem] font-semibold text-ink">{fullName}</p>
        </div>
        <a href={'/apply/step-1' + (roleSlug ? '?role=' + roleSlug : '')} class="text-[0.72rem] font-mono text-ink-soft hover:text-burn underline whitespace-nowrap">Edit</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-4 gap-y-1.5 text-[0.82rem] text-ink-2">
        <p><span class="text-ink-soft">Email:</span> {s1.email}</p>
        <p><span class="text-ink-soft">Phone:</span> {fullPhoneDisplay}</p>
        <p><span class="text-ink-soft">City:</span> {s1.currentCity}</p>
        {s1.linkedin && <p><span class="text-ink-soft">LinkedIn:</span> <a href={s1.linkedin} target="_blank" rel="noopener" class="text-sky hover:underline">{s1.linkedin.substring(0, 35)}...</a></p>}
        <p class="md:col-span-2"><span class="text-ink-soft">Resume:</span> <a href={s1.resumeLink} target="_blank" rel="noopener" class="text-sky hover:underline">{s1.resumeLink ? s1.resumeLink.substring(0, 60) + '...' : 'Not provided'}</a></p>
        <p><span class="text-ink-soft">DOB:</span> {s1.dateOfBirth}</p>
        {s1.birthPlace && <p><span class="text-ink-soft">Birth place:</span> {s1.birthPlace}</p>}
      </div>
    </div>

    <div class="bg-cream-2/50 border border-ink/10 rounded-xl p-4">
      <div class="flex items-start justify-between gap-3 mb-3">
        <div>
          <p class="text-[0.62rem] font-mono uppercase tracking-wider text-burn font-bold mb-0.5">Step 2 - Role</p>
          <p class="font-display text-[1rem] font-semibold text-ink">{roleTitle}</p>
        </div>
        <a href={'/apply/step-2' + (roleSlug ? '?role=' + roleSlug : '')} class="text-[0.72rem] font-mono text-ink-soft hover:text-burn underline whitespace-nowrap">Edit</a>
      </div>
      <div class="text-[0.82rem] text-ink-2 flex flex-wrap gap-2">
        <span class="bg-white border border-ink/10 px-2.5 py-1 rounded-md font-semibold">{roleLevel || 'Level not set'}</span>
        <span class="bg-white border border-ink/10 px-2.5 py-1 rounded-md">{deptName || 'Department not set'}</span>
        <span class="bg-white border border-ink/10 px-2.5 py-1 rounded-md">Open to similar: {s2.openToOther || 'Not specified'}</span>
      </div>
    </div>

    <div class="bg-cream-2/50 border border-ink/10 rounded-xl p-4">
      <div class="flex items-start justify-between gap-3 mb-3">
        <div>
          <p class="text-[0.62rem] font-mono uppercase tracking-wider text-burn font-bold mb-0.5">Step 3 - Education</p>
          <p class="font-display text-[1rem] font-semibold text-ink">{eduCount} education + {certCount} certs + {workCount} work</p>
        </div>
        <a href={'/apply/step-3' + (roleSlug ? '?role=' + roleSlug : '')} class="text-[0.72rem] font-mono text-ink-soft hover:text-burn underline whitespace-nowrap">Edit</a>
      </div>
      <div class="text-[0.82rem] text-ink-2 space-y-1">
        <p><span class="text-ink-soft">Experience:</span> {s3.yearsExperience || 'Not specified'}</p>
        {s3.duolingoScore && <p><span class="text-ink-soft">Duolingo score:</span> {s3.duolingoScore}</p>}
        {s3.whyRelevant && <p class="mt-1.5 italic text-ink-soft">"{s3.whyRelevant.substring(0, 150)}{s3.whyRelevant.length > 150 ? '...' : ''}"</p>}
      </div>
    </div>

    <div class="bg-cream-2/50 border border-ink/10 rounded-xl p-4">
      <div class="flex items-start justify-between gap-3 mb-3">
        <div>
          <p class="text-[0.62rem] font-mono uppercase tracking-wider text-burn font-bold mb-0.5">Step 4 - Skills and Proof</p>
          <p class="font-display text-[1rem] font-semibold text-ink">{proofCount + customNecCount + customOptCount + customEliteCount} proof artifact{(proofCount + customNecCount + customOptCount + customEliteCount) === 1 ? '' : 's'}</p>
        </div>
        <a href={'/apply/step-4' + (roleSlug ? '?role=' + roleSlug : '')} class="text-[0.72rem] font-mono text-ink-soft hover:text-burn underline whitespace-nowrap">Edit</a>
      </div>
      <div class="text-[0.82rem] text-ink-2 flex flex-wrap gap-2">
        {(necessaryCount + customNecCount) > 0 && <span class="bg-burn-pale border border-burn-dim text-burn px-2.5 py-1 rounded-md font-semibold text-[0.75rem]">{necessaryCount + customNecCount} necessary</span>}
        {(optionalCount + customOptCount) > 0 && <span class="bg-sky-bg border border-sky-border text-sky px-2.5 py-1 rounded-md font-semibold text-[0.75rem]">{optionalCount + customOptCount} optional</span>}
        {(eliteCount + customEliteCount) > 0 && <span class="bg-plum-bg border border-plum-border text-plum px-2.5 py-1 rounded-md font-semibold text-[0.75rem]">{eliteCount + customEliteCount} elite</span>}
      </div>
    </div>

    <div class="bg-cream-2/50 border border-ink/10 rounded-xl p-4">
      <div class="flex items-start justify-between gap-3 mb-3">
        <div>
          <p class="text-[0.62rem] font-mono uppercase tracking-wider text-burn font-bold mb-0.5">Step 5 - Motivation and Logistics</p>
          <p class="font-display text-[1rem] font-semibold text-ink">{s5.availability} - {s5.engagementType}</p>
        </div>
        <a href={'/apply/step-5' + (roleSlug ? '?role=' + roleSlug : '')} class="text-[0.72rem] font-mono text-ink-soft hover:text-burn underline whitespace-nowrap">Edit</a>
      </div>
      <div class="text-[0.82rem] text-ink-2 space-y-1">
        <p><span class="text-ink-soft">Remote comfort:</span> {s5.remoteComfort}</p>
        <p><span class="text-ink-soft">Heard via:</span> {s5.source}</p>
        {!hideCompensation && s5.compensation && <p><span class="text-ink-soft">Expected comp:</span> {s5.compensation}</p>}
        {s5.whyERA && <p class="mt-1.5 italic text-ink-soft">"{s5.whyERA.substring(0, 150)}{s5.whyERA.length > 150 ? '...' : ''}"</p>}
      </div>
    </div>

  </div>

  <form method="POST" class="flex flex-col gap-5">

    <div class="bg-burn-pale border border-burn-dim rounded-xl p-4">
      <label class="flex items-start gap-3 cursor-pointer">
        <input type="checkbox" name="consent" required class="accent-burn w-4 h-4 mt-1 shrink-0" />
        <span class="text-[0.85rem] text-ink-2 leading-relaxed">
          I confirm that everything I submitted is <strong>true and accurate</strong>. I understand that EduRankAI takes honesty seriously and that any misrepresentation may end the application or my employment. I consent to EduRankAI storing and reviewing my application.
        </span>
      </label>
    </div>

    <div class="flex gap-3">
      <a href={'/apply/step-5' + (roleSlug ? '?role=' + roleSlug : '')} class="px-5 py-3 border border-ink/15 rounded-lg text-[0.88rem] font-medium text-ink-soft hover:border-burn-dim hover:text-ink transition-all flex items-center gap-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M11 6l-6 6 6 6"/></svg>
        Back
      </a>
      <button type="submit" class="flex-1 bg-burn hover:bg-burn/90 text-white font-semibold py-3 rounded-lg text-[0.95rem] transition-all flex items-center justify-center gap-2">
        Submit Application
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
      </button>
    </div>

  </form>

</ApplyLayout>