---
import ApplyLayout from '@/layouts/ApplyLayout.astro';
import { db } from '@/lib/db';
import { roles } from '@/lib/db/schema';
import { eq } from 'drizzle-orm';
import { getActiveDraft, saveDraft } from '@/lib/apply/draft';
import { safeDraft } from '@/lib/apply/data';

const user = Astro.locals.user;
if (!user) {
  const url = new URL(Astro.request.url);
  const roleSlug = url.searchParams.get('role') || '';
  const next = '/apply/step-1' + (roleSlug ? '?role=' + roleSlug : '');
  return Astro.redirect('/portal/signup?next=' + encodeURIComponent(next));
}
if (user.role !== 'applicant') return Astro.redirect('/admin');

const url = new URL(Astro.request.url);
const roleSlug = url.searchParams.get('role') || '';

let preselectedRole = null;
if (roleSlug) {
  const found = await db.select({ title: roles.title, slug: roles.slug, departmentId: roles.departmentId, level: roles.level })
    .from(roles).where(eq(roles.slug, roleSlug)).limit(1);
  if (found.length > 0) preselectedRole = found[0];
}

const draftRow = await getActiveDraft(user.id);
const draft = safeDraft(draftRow?.formData);
const s1 = draft.step1 || {};

let errorMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const data = {
    firstName: (fd.get('firstName') as string || '').trim(),
    lastName: (fd.get('lastName') as string || '').trim(),
    email: (fd.get('email') as string || '').trim().toLowerCase(),
    phoneCountry: (fd.get('phoneCountry') as string || '+91').trim(),
    phone: (fd.get('phone') as string || '').trim(),
    currentCity: (fd.get('currentCity') as string || '').trim(),
    linkedin: (fd.get('linkedin') as string || '').trim(),
    resumeLink: (fd.get('resumeLink') as string || '').trim(),
    dateOfBirth: (fd.get('dateOfBirth') as string || '').trim(),
    birthTime: (fd.get('birthTime') as string || '').trim(),
    birthPlace: (fd.get('birthPlace') as string || '').trim(),
    photoUrl: (fd.get('photoUrl') as string || '').trim()
  };

  const missing = [];
  if (!data.firstName) missing.push('First name');
  if (!data.lastName) missing.push('Last name');
  if (!data.email || !/.+@.+\..+/.test(data.email)) missing.push('Valid email');
  if (!data.phone || data.phone.length < 7) missing.push('Phone number');
  if (!data.currentCity) missing.push('Current city');
  if (!data.resumeLink) missing.push('Resume / Portfolio link');
  if (!data.dateOfBirth) missing.push('Date of birth');
  if (!data.birthPlace) missing.push('Birth place');

  if (missing.length > 0) {
    errorMsg = 'Please fill in: ' + missing.join(', ');
  } else {
    const newDraft = { ...draft, step1: data };
    if (roleSlug && !newDraft.roleSlug) newDraft.roleSlug = roleSlug;
    await saveDraft(user.id, user.email, newDraft, 2);
    return Astro.redirect('/apply/step-2' + (roleSlug ? '?role=' + roleSlug : ''));
  }
}

const initFirstName = s1.firstName || (user.name ? user.name.split(' ')[0] : '');
const initLastName = s1.lastName || (user.name && user.name.split(' ').length > 1 ? user.name.split(' ').slice(1).join(' ') : '');
const initEmail = s1.email || user.email;

const COUNTRY_CODES = [
  { code: '+91', label: 'IN +91' },
  { code: '+1', label: 'US +1' },
  { code: '+44', label: 'UK +44' },
  { code: '+90', label: 'TR +90' },
  { code: '+971', label: 'AE +971' },
  { code: '+61', label: 'AU +61' },
  { code: '+65', label: 'SG +65' },
  { code: '+49', label: 'DE +49' },
  { code: '+33', label: 'FR +33' },
  { code: '+81', label: 'JP +81' },
  { code: '+86', label: 'CN +86' },
  { code: '+880', label: 'BD +880' },
  { code: '+92', label: 'PK +92' },
  { code: '+977', label: 'NP +977' },
  { code: '+94', label: 'LK +94' },
  { code: '+62', label: 'ID +62' },
  { code: '+60', label: 'MY +60' },
  { code: '+66', label: 'TH +66' },
  { code: '+82', label: 'KR +82' },
  { code: '+27', label: 'ZA +27' },
  { code: '+234', label: 'NG +234' },
  { code: '+254', label: 'KE +254' },
  { code: '+20', label: 'EG +20' },
  { code: '+966', label: 'SA +966' },
  { code: '+972', label: 'IL +972' },
  { code: '+98', label: 'IR +98' },
  { code: '+7', label: 'RU +7' },
  { code: '+39', label: 'IT +39' },
  { code: '+34', label: 'ES +34' },
  { code: '+31', label: 'NL +31' },
  { code: '+46', label: 'SE +46' },
  { code: '+52', label: 'MX +52' },
  { code: '+55', label: 'BR +55' },
  { code: '+54', label: 'AR +54' },
  { code: '+64', label: 'NZ +64' }
];

const todayDate = new Date().toISOString().split('T')[0];
---
<ApplyLayout step={1} totalSteps={6} stepTitle="Personal Info" stepSubtitle="Quick basics — just enough to reach you." roleTitle={preselectedRole?.title}>

  {errorMsg && (
    <div style="background:rgba(220,38,38,0.06);border:1px solid rgba(220,38,38,0.25);color:#b91c1c;font-size:0.85rem;padding:11px 14px;border-radius:8px;margin-bottom:18px;line-height:1.6;">
      WARNING: {errorMsg}
    </div>
  )}

  <form method="POST" class="flex flex-col gap-5">

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">First Name <span class="text-burn">*</span></label>
        <input type="text" name="firstName" required value={initFirstName} placeholder="Aryan" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 transition-colors" />
      </div>
      <div>
        <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Last Name <span class="text-burn">*</span></label>
        <input type="text" name="lastName" required value={initLastName} placeholder="Sharma" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 transition-colors" />
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Email <span class="text-burn">*</span></label>
        <input type="email" name="email" required value={initEmail} placeholder="aryan@email.com" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 transition-colors" />
      </div>
      <div>
        <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Phone <span class="text-burn">*</span></label>
        <div class="flex gap-2">
          <select name="phoneCountry" class="px-2 py-2.5 border border-ink/15 rounded-lg text-[0.82rem] bg-cream-2 outline-none focus:border-burn min-w-[110px]">
            {COUNTRY_CODES.map((c) => {
              const sel = (s1.phoneCountry || '+91') === c.code;
              return <option value={c.code} selected={sel}>{c.label}</option>;
            })}
          </select>
          <input type="tel" name="phone" required value={s1.phone || ''} placeholder="98765 43210" class="flex-1 px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 transition-colors" />
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Current City <span class="text-burn">*</span></label>
        <div class="relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-[0.85rem] pointer-events-none">PIN</span>
          <input type="text" name="currentCity" required value={s1.currentCity || ''} placeholder="e.g. Bangalore, India" class="w-full pl-12 pr-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 transition-colors" />
        </div>
      </div>
      <div>
        <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">LinkedIn <span class="text-ink-soft/60 font-normal normal-case tracking-normal">(optional)</span></label>
        <input type="url" name="linkedin" value={s1.linkedin || ''} placeholder="linkedin.com/in/yourname" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 transition-colors" />
      </div>
    </div>

    <div>
      <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Resume / Portfolio Link <span class="text-burn">*</span></label>
      <div class="bg-sky-bg border border-sky-border rounded-lg p-3.5 mb-2 text-[0.8rem] text-ink-2 leading-relaxed">
        <p class="font-semibold text-sky mb-1.5">Upload your resume to Google Drive first</p>
        <p class="text-[0.78rem]">1. Upload PDF to Google Drive then Share then set to "Anyone with the link" then paste the link below</p>
        <p class="text-[0.78rem] mt-1">OR paste a GitHub, LinkedIn, or portfolio site link directly</p>
      </div>
      <input type="url" name="resumeLink" required value={s1.resumeLink || ''} placeholder="https://drive.google.com/... or https://github.com/..." class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 transition-colors" />
      <p class="text-[0.7rem] text-ink-soft mt-1.5 italic">Google Drive (PDF) or GitHub or Portfolio site or LinkedIn profile</p>
    </div>

    <div class="border-t border-ink/8 pt-5">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Date of Birth <span class="text-burn">*</span></label>
          <input type="date" name="dateOfBirth" required value={s1.dateOfBirth || ''} max={todayDate} class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 transition-colors" />
        </div>
        <div>
          <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Birth Time <span class="text-ink-soft/60 font-normal normal-case tracking-normal">(optional)</span></label>
          <input type="time" name="birthTime" value={s1.birthTime || ''} class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 transition-colors" />
          <p class="text-[0.7rem] text-ink-soft mt-1 italic">As per birth certificate</p>
        </div>
      </div>

      <div class="mt-4">
        <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Birth Place <span class="text-burn">*</span></label>
        <input type="text" name="birthPlace" required value={s1.birthPlace || ''} placeholder="City and country where you were born" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 transition-colors" />
      </div>
    </div>

    <div class="border-t border-ink/8 pt-5">
      <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Current Photo <span class="text-ink-soft/60 font-normal normal-case tracking-normal">(optional - file upload coming soon)</span></label>
      <div class="border-2 border-dashed border-ink/15 rounded-lg p-5 text-center bg-cream-2/40">
        <p class="text-[0.85rem] text-ink-2 mb-1">File upload coming soon</p>
        <p class="text-[0.72rem] text-ink-soft italic">For now, paste a photo URL below (Google Drive, ImgBB, or any public link)</p>
      </div>
      <input type="url" name="photoUrl" value={s1.photoUrl || ''} placeholder="https://... (optional photo URL)" class="w-full mt-3 px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 transition-colors" />
      <p class="text-[0.7rem] text-ink-soft italic mt-1">Recent passport-style or professional photo preferred</p>
    </div>

    <div class="pt-2">
      <button type="submit" class="w-full bg-ink hover:bg-ink/90 text-white font-semibold py-3.5 rounded-lg text-[0.92rem] transition-all flex items-center justify-center gap-2">
        Continue
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </button>
    </div>

  </form>

</ApplyLayout>


