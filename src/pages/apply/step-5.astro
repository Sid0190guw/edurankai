---
import ApplyLayout from '@/layouts/ApplyLayout.astro';
import { db } from '@/lib/db';
import { roles } from '@/lib/db/schema';
import { eq } from 'drizzle-orm';
import { getActiveDraft, saveDraft } from '@/lib/apply/draft';
import { safeDraft, isInternOrApprentice } from '@/lib/apply/data';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
if (user.role !== 'applicant') return Astro.redirect('/admin');

const url = new URL(Astro.request.url);
const roleSlug = url.searchParams.get('role') || '';

const draftRow = await getActiveDraft(user.id);
const draft = safeDraft(draftRow?.data);
const s5 = draft.step5 || {};

if (!draft.step1) return Astro.redirect('/apply/step-1' + (roleSlug ? '?role=' + roleSlug : ''));
if (!draft.step2) return Astro.redirect('/apply/step-2' + (roleSlug ? '?role=' + roleSlug : ''));
if (!draft.step3) return Astro.redirect('/apply/step-3' + (roleSlug ? '?role=' + roleSlug : ''));
if (!draft.step4) return Astro.redirect('/apply/step-4' + (roleSlug ? '?role=' + roleSlug : ''));

let preselectedRoleTitle = '';
let roleLevel = '';
if (roleSlug) {
  const found = await db.select({ title: roles.title, level: roles.level }).from(roles).where(eq(roles.slug, roleSlug)).limit(1);
  if (found.length > 0) {
    preselectedRoleTitle = found[0].title;
    roleLevel = found[0].level;
  }
}
if (!preselectedRoleTitle) preselectedRoleTitle = draft.step2?.roleTitle || '';
if (!roleLevel) roleLevel = draft.step2?.level || '';

const hideCompensation = isInternOrApprentice(roleLevel);

let errorMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();

  const data = {
    whyERA: (fd.get('whyERA') as string || '').trim(),
    whyRole: (fd.get('whyRole') as string || '').trim(),
    whyAIEdu: (fd.get('whyAIEdu') as string || '').trim(),
    intersection: (fd.get('intersection') as string || '').trim(),
    ambitious: (fd.get('ambitious') as string || '').trim(),
    ethicsExperience: (fd.get('ethicsExperience') as string || '').trim(),
    ethicsIdeal: (fd.get('ethicsIdeal') as string || '').trim(),
    availability: (fd.get('availability') as string || '').trim(),
    engagementType: (fd.get('engagementType') as string || '').trim(),
    remoteComfort: (fd.get('remoteComfort') as string || '').trim(),
    compensation: hideCompensation ? '' : (fd.get('compensation') as string || '').trim(),
    source: (fd.get('source') as string || '').trim()
  };

  const missing = [];
  if (!data.whyERA) missing.push('Why EduRankAI');
  if (!data.whyRole) missing.push('Why this role');
  if (!data.whyAIEdu) missing.push('Why AI in education');
  if (!data.availability) missing.push('When you can start');
  if (!data.engagementType) missing.push('Engagement type preference');
  if (!data.remoteComfort) missing.push('Remote comfort');
  if (!data.source) missing.push('How you heard about us');

  if (missing.length > 0) {
    errorMsg = 'Please complete: ' + missing.join(', ');
  } else {
    const newDraft = { ...draft, step5: data };
    await saveDraft(user.id, user.email, newDraft, 6);
    return Astro.redirect('/apply/step-6' + (roleSlug ? '?role=' + roleSlug : ''));
  }
}

const AVAILABILITY_OPTIONS = [
  'Immediately',
  'Within 2 weeks',
  'Within 1 month',
  '1-3 months',
  '3+ months',
  'Flexible'
];

const ENGAGEMENT_OPTIONS = [
  'Internship (part-time)',
  'Internship (full-time)',
  'Apprenticeship',
  'Full-time employment',
  'Contract / consultant',
  'Open to discussion'
];

const REMOTE_OPTIONS = [
  'Fully remote',
  'Hybrid (some in-person)',
  'Mostly in-person',
  'Either works'
];

const SOURCE_OPTIONS = [
  'LinkedIn',
  'College / university',
  'Referred by someone',
  'Google search',
  'Instagram / social media',
  'EduRankAI website',
  'Other'
];
---
<ApplyLayout step={5} totalSteps={6} stepTitle="Motivation and Logistics" stepSubtitle="The why, and the when. Half the form left." roleTitle={preselectedRoleTitle}>

  {errorMsg && (
    <div style="background:rgba(220,38,38,0.06);border:1px solid rgba(220,38,38,0.25);color:#b91c1c;font-size:0.85rem;padding:11px 14px;border-radius:8px;margin-bottom:18px;line-height:1.6;">
      {errorMsg}
    </div>
  )}

  <form method="POST" class="flex flex-col gap-6">

    <div>
      <h3 class="font-display text-[1.05rem] font-semibold text-ink mb-1">Motivation</h3>
      <p class="text-[0.78rem] text-ink-soft italic mb-4">Why us. Why this. Why now. We read every word.</p>

      <div class="flex flex-col gap-4">
        <div>
          <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Why EduRankAI? <span class="text-burn">*</span></label>
          <textarea name="whyERA" required rows="4" placeholder="What about EduRankAI specifically resonates with you? Not why AI in general - why us." class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 resize-y leading-relaxed">{s5.whyERA || ''}</textarea>
        </div>

        <div>
          <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Why this role specifically? <span class="text-burn">*</span></label>
          <textarea name="whyRole" required rows="4" placeholder="Of all the roles we have open, why this one? How does it fit your trajectory?" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 resize-y leading-relaxed">{s5.whyRole || ''}</textarea>
        </div>

        <div>
          <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">What excites you most about AI in education? <span class="text-burn">*</span></label>
          <textarea name="whyAIEdu" required rows="4" placeholder="The shift, the risk, the opportunity - what do you find most interesting?" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 resize-y leading-relaxed">{s5.whyAIEdu || ''}</textarea>
        </div>

        <div>
          <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Quantum, safety, or another intersection that interests you <span class="text-ink-soft/60 font-normal normal-case tracking-normal">(optional)</span></label>
          <textarea name="intersection" rows="3" placeholder="EduRankAI works across AI, quantum, safety, psychology. Where does your curiosity intersect?" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 resize-y leading-relaxed">{s5.intersection || ''}</textarea>
        </div>

        <div>
          <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">An ambitious project you would propose <span class="text-ink-soft/60 font-normal normal-case tracking-normal">(optional)</span></label>
          <textarea name="ambitious" rows="3" placeholder="If you had a free month inside EduRankAI, what would you build?" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 resize-y leading-relaxed">{s5.ambitious || ''}</textarea>
        </div>
      </div>
    </div>

    <div class="border-t border-ink/8 pt-6">
      <h3 class="font-display text-[1.05rem] font-semibold text-ink mb-1">Ethics and Moral Compass</h3>
      <p class="text-[0.78rem] text-ink-soft italic mb-4">Optional but valued. We care how you think about right and wrong.</p>

      <div class="flex flex-col gap-4">
        <div>
          <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Have you ever witnessed a moral wrong and spoken up? <span class="text-ink-soft/60 font-normal normal-case tracking-normal">(optional)</span></label>
          <textarea name="ethicsExperience" rows="3" placeholder="A workplace, a community, a family situation. What did you do? What happened?" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 resize-y leading-relaxed">{s5.ethicsExperience || ''}</textarea>
        </div>

        <div>
          <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">What does an ethical workplace look like to you? <span class="text-ink-soft/60 font-normal normal-case tracking-normal">(optional)</span></label>
          <textarea name="ethicsIdeal" rows="3" placeholder="Specific. Not slogans. What practices would you expect to see?" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 resize-y leading-relaxed">{s5.ethicsIdeal || ''}</textarea>
        </div>
      </div>
    </div>

    <div class="border-t border-ink/8 pt-6">
      <h3 class="font-display text-[1.05rem] font-semibold text-ink mb-1">Logistics</h3>
      <p class="text-[0.78rem] text-ink-soft italic mb-4">The practical pieces.</p>

      <div class="flex flex-col gap-5">
        <div>
          <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">When can you start? <span class="text-burn">*</span></label>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
            {AVAILABILITY_OPTIONS.map((opt) => {
              const sel = s5.availability === opt;
              return (
                <label class={'flex items-center gap-2 px-3.5 py-2.5 border rounded-lg cursor-pointer text-[0.85rem] transition-all ' + (sel ? 'border-burn bg-burn-pale text-burn font-semibold' : 'border-ink/15 bg-cream-2 hover:border-burn-dim')}>
                  <input type="radio" name="availability" value={opt} checked={sel} class="accent-burn" />
                  <span>{opt}</span>
                </label>
              );
            })}
          </div>
        </div>

        <div>
          <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Preferred engagement type <span class="text-burn">*</span></label>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
            {ENGAGEMENT_OPTIONS.map((opt) => {
              const sel = s5.engagementType === opt;
              return (
                <label class={'flex items-center gap-2 px-3.5 py-2.5 border rounded-lg cursor-pointer text-[0.85rem] transition-all ' + (sel ? 'border-burn bg-burn-pale text-burn font-semibold' : 'border-ink/15 bg-cream-2 hover:border-burn-dim')}>
                  <input type="radio" name="engagementType" value={opt} checked={sel} class="accent-burn" />
                  <span>{opt}</span>
                </label>
              );
            })}
          </div>
        </div>

        <div>
          <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Remote comfort <span class="text-burn">*</span></label>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
            {REMOTE_OPTIONS.map((opt) => {
              const sel = s5.remoteComfort === opt;
              return (
                <label class={'flex items-center gap-2 px-3 py-2.5 border rounded-lg cursor-pointer text-[0.82rem] transition-all ' + (sel ? 'border-burn bg-burn-pale text-burn font-semibold' : 'border-ink/15 bg-cream-2 hover:border-burn-dim')}>
                  <input type="radio" name="remoteComfort" value={opt} checked={sel} class="accent-burn" />
                  <span>{opt}</span>
                </label>
              );
            })}
          </div>
        </div>

        {!hideCompensation && (
          <div>
            <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Expected compensation <span class="text-ink-soft/60 font-normal normal-case tracking-normal">(optional - annual CTC or range)</span></label>
            <input type="text" name="compensation" value={s5.compensation || ''} placeholder="e.g. 25 LPA INR, or open to discussion, or $120k USD" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
            <p class="text-[0.7rem] text-ink-soft mt-1 italic">Be honest. We will not penalize realistic numbers.</p>
          </div>
        )}

        {hideCompensation && (
          <div class="bg-cream-2 border border-ink/10 rounded-lg p-3.5 text-[0.78rem] text-ink-soft">
            Intern and apprentice roles are currently unpaid (early-stage). Compensation discussion is skipped for this role.
          </div>
        )}

        <div>
          <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">How did you hear about us? <span class="text-burn">*</span></label>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
            {SOURCE_OPTIONS.map((opt) => {
              const sel = s5.source === opt;
              return (
                <label class={'flex items-center gap-2 px-3 py-2.5 border rounded-lg cursor-pointer text-[0.82rem] transition-all ' + (sel ? 'border-burn bg-burn-pale text-burn font-semibold' : 'border-ink/15 bg-cream-2 hover:border-burn-dim')}>
                  <input type="radio" name="source" value={opt} checked={sel} class="accent-burn" />
                  <span>{opt}</span>
                </label>
              );
            })}
          </div>
        </div>
      </div>
    </div>

    <div class="flex gap-3 pt-2">
      <a href={'/apply/step-4' + (roleSlug ? '?role=' + roleSlug : '')} class="px-5 py-3 border border-ink/15 rounded-lg text-[0.88rem] font-medium text-ink-soft hover:border-burn-dim hover:text-ink transition-all flex items-center gap-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M11 6l-6 6 6 6"/></svg>
        Back
      </a>
      <button type="submit" class="flex-1 bg-ink hover:bg-ink/90 text-white font-semibold py-3 rounded-lg text-[0.9rem] transition-all flex items-center justify-center gap-2">
        Continue
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </button>
    </div>

  </form>

</ApplyLayout>