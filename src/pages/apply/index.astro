---
import { getActiveDraft } from '@/lib/apply/draft';

const user = Astro.locals.user;
const url = new URL(Astro.request.url);
const roleSlugFromUrl = url.searchParams.get('role') || '';

if (!user) {
  const next = '/apply' + (roleSlugFromUrl ? '?role=' + roleSlugFromUrl : '');
  return Astro.redirect('/portal/signup?next=' + encodeURIComponent(next));
}

if (user.role !== 'applicant') {
  return Astro.redirect('/admin');
}

const draft = await getActiveDraft(user.id);

// If user came from a specific role URL AND that role differs from draft's role,
// reset their progress to step 1 with the new role.
// Otherwise, resume at last saved step.
let resumeStep = 1;
let useRoleSlug = roleSlugFromUrl;

if (draft) {
  const draftRoleSlug = (draft.data as any)?.roleSlug || '';
  if (roleSlugFromUrl && roleSlugFromUrl !== draftRoleSlug) {
    // Different role - start over but keep the new role
    resumeStep = 1;
    useRoleSlug = roleSlugFromUrl;
  } else {
    // Same role or no URL - resume where they left off
    resumeStep = draft.step || 1;
    useRoleSlug = draftRoleSlug || roleSlugFromUrl;
    if (resumeStep < 1 || resumeStep > 7) resumeStep = 1;
  }
}

const target = '/apply/step-' + resumeStep + (useRoleSlug ? '?role=' + useRoleSlug : '');
return Astro.redirect(target);
---
