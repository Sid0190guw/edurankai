---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { applications } from '@/lib/db/schema';
import { eq, and } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
if (user.role !== 'applicant') return Astro.redirect('/admin');

const url = new URL(Astro.request.url);
const appId = url.searchParams.get('id') || '';

let appInfo: any = null;
if (appId) {
  const found = await db.select({
    id: applications.id,
    firstName: applications.firstName,
    email: applications.email,
    roleTitleSnapshot: applications.roleTitleSnapshot,
    departmentSnapshot: applications.departmentSnapshot,
    createdAt: applications.createdAt,
    status: applications.status
  }).from(applications)
    .where(and(eq(applications.id, appId), eq(applications.applicantUserId, user.id)))
    .limit(1);
  if (found.length > 0) appInfo = found[0];
}

if (!appInfo) {
  return Astro.redirect('/portal');
}

const shortId = appId.substring(0, 8).toUpperCase();
const submittedDate = new Date(appInfo.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
---
<BaseLayout title="Application Submitted - EduRankAI" description="Your application has been received.">
  <section class="px-[5vw] py-10 md:py-16 max-w-2xl mx-auto">

    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-leaf-bg border-2 border-leaf-border mb-5">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-leaf">
          <path d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <h1 class="font-display text-[clamp(2rem,5vw,2.8rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-3">
        Application <em class="italic text-burn font-medium">received</em>
      </h1>
      <p class="text-[0.95rem] text-ink-soft leading-relaxed">
        Thank you, <strong class="text-ink">{appInfo.firstName}</strong>. We have your application for <strong class="text-ink">{appInfo.roleTitleSnapshot}</strong>.
      </p>
    </div>

    <div class="bg-white border border-ink/10 rounded-2xl p-6 mb-6">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3 pb-4 border-b border-ink/8 mb-4">
        <div>
          <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-ink-soft mb-1">Application ID</p>
          <p class="font-mono text-[1.1rem] font-bold text-ink">{shortId}</p>
        </div>
        <div class="md:text-right">
          <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-ink-soft mb-1">Status</p>
          <span class="inline-block text-[0.72rem] font-bold uppercase tracking-wider bg-sky-bg text-sky border border-sky-border px-2.5 py-1 rounded-full">
            {appInfo.status}
          </span>
        </div>
      </div>

      <div class="space-y-2 text-[0.88rem]">
        <p><span class="text-ink-soft">Role:</span> <strong class="text-ink">{appInfo.roleTitleSnapshot}</strong></p>
        <p><span class="text-ink-soft">Department:</span> {appInfo.departmentSnapshot}</p>
        <p><span class="text-ink-soft">Submitted:</span> {submittedDate}</p>
        <p><span class="text-ink-soft">Confirmation sent to:</span> {appInfo.email}</p>
      </div>
    </div>

    <div class="bg-cream-2 border border-ink/10 rounded-2xl p-6 mb-6">
      <h2 class="font-display text-[1.1rem] font-semibold text-ink mb-3">What happens next</h2>
      <ol class="space-y-3 text-[0.88rem] text-ink-2 leading-relaxed">
        <li class="flex gap-3">
          <span class="shrink-0 w-6 h-6 rounded-full bg-burn-pale border border-burn-dim text-burn text-[0.72rem] font-bold flex items-center justify-center">1</span>
          <span>Our team reviews your application carefully. We read every word. No bots in this loop.</span>
        </li>
        <li class="flex gap-3">
          <span class="shrink-0 w-6 h-6 rounded-full bg-burn-pale border border-burn-dim text-burn text-[0.72rem] font-bold flex items-center justify-center">2</span>
          <span>You will hear back within <strong class="text-ink">5 business days</strong> - either with next steps (technical conversation, walkthrough of your work) or honest feedback.</span>
        </li>
        <li class="flex gap-3">
          <span class="shrink-0 w-6 h-6 rounded-full bg-burn-pale border border-burn-dim text-burn text-[0.72rem] font-bold flex items-center justify-center">3</span>
          <span>You can track your status anytime at your <a href="/portal" class="text-burn font-semibold hover:underline">applicant portal</a>. We do not keep applicants in the dark.</span>
        </li>
      </ol>
    </div>

    <div class="bg-burn-pale/50 border border-burn-dim rounded-2xl p-5 mb-6 text-[0.85rem] text-ink-2 leading-relaxed">
      <p class="font-semibold text-burn mb-1.5">A note from us</p>
      <p>EduRankAI is being built with care. We are a small team reading every application. If you do not hear back exactly on day 5, please give us a day or two - we would rather respond thoughtfully than fast. For urgent questions: <a href="mailto:hr@edurankai.in" class="text-burn font-semibold hover:underline">hr@edurankai.in</a></p>
    </div>

    <div class="flex flex-col md:flex-row gap-3">
      <a href="/portal" class="flex-1 bg-ink hover:bg-ink/90 text-white font-semibold py-3 px-5 rounded-lg text-[0.9rem] transition-all flex items-center justify-center gap-2 text-center">
        Go to your portal
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
      <a href="/careers" class="flex-1 bg-cream-2 border border-ink/15 hover:border-burn-dim text-ink font-semibold py-3 px-5 rounded-lg text-[0.9rem] transition-all flex items-center justify-center gap-2 text-center">
        Browse more roles
      </a>
    </div>

  </section>
</BaseLayout>