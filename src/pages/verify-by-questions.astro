---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Recover by questions" description="Verify your identity by answering a few questions drawn from your application and HR record." noindex={true}>
  <section class="px-[5vw] py-12 md:py-20 max-w-xl mx-auto">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-3">Identity recovery &middot; question set</p>
    <h1 class="font-display text-[clamp(1.6rem,4vw,2.4rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-3">
      Verify by questions.
    </h1>
    <p class="text-[0.92rem] text-ink-soft leading-relaxed mb-6">
      No DOB on file, no camera, no government ID handy? Answer a short set of questions drawn from your application and HR record. If your aggregate accuracy is at least <strong>80%</strong>, we'll issue a fresh temporary password right here.
    </p>

    <div id="step1" class="bg-white border border-ink/10 rounded-2xl p-5 md:p-6">
      <form id="emailForm" class="flex flex-col gap-4">
        <div>
          <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Account email</label>
          <input type="email" name="email" required placeholder="you@edurankai.in" autocomplete="email" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.95rem] outline-none focus:border-burn bg-cream-2" />
        </div>
        <button type="submit" id="loadBtn" class="bg-burn hover:bg-burn/90 text-white font-semibold py-3 px-6 rounded-lg text-[0.95rem]">
          Load my questions
        </button>
      </form>
      <div id="step1Err" style="display:none;margin-top:14px;background:#fee2e2;border:1px solid #fca5a5;color:#991b1b;padding:12px 14px;border-radius:8px;font-size:13.5px;"></div>
    </div>

    <div id="step2" style="display:none;" class="mt-6">
      <div class="bg-white border border-ink/10 rounded-2xl p-5 md:p-6">
        <p class="text-[0.72rem] font-mono uppercase tracking-wider text-ink-soft font-bold mb-1">Answer to the best of your memory</p>
        <p class="text-[0.85rem] text-ink-2 leading-relaxed mb-4">Aim for an aggregate match of <strong>80% or more</strong>. Each text answer is fuzzy-matched; numeric answers (years, scores) need to be exact.</p>
        <form id="answersForm" class="flex flex-col gap-4">
          <div id="questionsRoot" class="flex flex-col gap-3.5"></div>
          <button type="submit" id="verifyBtn" class="bg-burn hover:bg-burn/90 text-white font-semibold py-3 px-6 rounded-lg text-[0.95rem]">
            Verify &amp; reset password
          </button>
        </form>
      </div>
    </div>

    <div id="result" style="display:none;" class="mt-6"></div>

    <div class="mt-8 flex flex-wrap gap-4 text-[0.85rem]">
      <a href="/portal/login" class="text-burn hover:underline font-semibold">Back to sign in</a>
      <span class="text-ink-soft/50">&middot;</span>
      <a href="/forgot-password" class="text-burn hover:underline font-semibold">Reset by DOB</a>
      <span class="text-ink-soft/50">&middot;</span>
      <a href="/identity-setup" class="text-burn hover:underline font-semibold">ID + face match</a>
    </div>
  </section>

  <script is:inline>
    (function() {
      var token = null;
      var emailForm = document.getElementById('emailForm');
      var loadBtn = document.getElementById('loadBtn');
      var step1Err = document.getElementById('step1Err');
      var step2 = document.getElementById('step2');
      var questionsRoot = document.getElementById('questionsRoot');
      var answersForm = document.getElementById('answersForm');
      var verifyBtn = document.getElementById('verifyBtn');
      var result = document.getElementById('result');
      var email = '';

      function showError(box, msg) {
        box.style.display = 'block';
        box.textContent = msg || 'Something went wrong. Try again.';
      }

      function inputType(t) {
        if (t === 'year' || t === 'number') return 'number';
        if (t === 'date') return 'date';
        return 'text';
      }

      function buildQuestionField(q) {
        var wrap = document.createElement('div');
        var lbl = document.createElement('label');
        lbl.textContent = q.label;
        lbl.style.cssText = 'display:block;font-size:0.78rem;font-weight:700;color:#475569;margin-bottom:6px;';
        var inp = document.createElement('input');
        inp.type = inputType(q.type);
        inp.name = q.id;
        inp.required = true;
        inp.autocomplete = 'off';
        inp.style.cssText = 'width:100%;padding:9px 12px;border:1px solid rgba(15,23,42,0.15);border-radius:8px;font-size:0.92rem;outline:none;background:#fafaf7;box-sizing:border-box;';
        inp.addEventListener('focus', function() { inp.style.borderColor = '#FF4F00'; });
        inp.addEventListener('blur', function() { inp.style.borderColor = 'rgba(15,23,42,0.15)'; });
        wrap.appendChild(lbl);
        wrap.appendChild(inp);
        return wrap;
      }

      emailForm.addEventListener('submit', function(e) {
        e.preventDefault();
        var fd = new FormData(emailForm);
        email = (fd.get('email') || '').toString().trim().toLowerCase();
        if (!email) return;
        step1Err.style.display = 'none';
        result.style.display = 'none';
        loadBtn.disabled = true; var prev = loadBtn.textContent; loadBtn.textContent = 'Loading...';

        fetch('/api/auth/verify-by-questions', {
          method: 'POST', credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'get-questions', email: email }),
        }).then(function(r) { return r.json(); }).then(function(d) {
          loadBtn.disabled = false; loadBtn.textContent = prev;
          if (!d.ok) { showError(step1Err, d.error); return; }
          token = d.token;
          questionsRoot.innerHTML = '';
          (d.questions || []).forEach(function(q) {
            questionsRoot.appendChild(buildQuestionField(q));
          });
          step2.style.display = 'block';
          step2.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }).catch(function() {
          loadBtn.disabled = false; loadBtn.textContent = prev;
          showError(step1Err, 'Network error - try again.');
        });
      });

      answersForm.addEventListener('submit', function(e) {
        e.preventDefault();
        var fd = new FormData(answersForm);
        var answers = {};
        fd.forEach(function(v, k) { answers[k] = (v || '').toString().trim(); });
        verifyBtn.disabled = true; var prev = verifyBtn.textContent; verifyBtn.textContent = 'Verifying...';
        result.style.display = 'none';

        fetch('/api/auth/verify-by-questions', {
          method: 'POST', credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'verify', email: email, token: token, answers: answers }),
        }).then(function(r) { return r.json(); }).then(function(d) {
          verifyBtn.disabled = false; verifyBtn.textContent = prev;
          result.style.display = 'block';
          result.scrollIntoView({ behavior: 'smooth', block: 'start' });
          if (d.ok) {
            result.innerHTML =
              '<div style="background:#dcfce7;border:1px solid #86efac;color:#166534;padding:16px 18px;border-radius:12px;">' +
                '<p style="font-weight:700;margin:0 0 6px;font-size:14.5px;">Verified at ' + d.score + '% &mdash; password reset for ' + (d.email || '') + '</p>' +
                '<p style="margin:0 0 6px;font-size:13px;">Your temporary password is:</p>' +
                '<p style="font-family:ui-monospace,monospace;font-size:18px;font-weight:700;background:#fff;padding:10px 14px;border-radius:6px;border:1px solid #86efac;margin:6px 0;text-align:center;letter-spacing:0.05em;">' + d.tempPassword + '</p>' +
                '<p style="margin:8px 0 0;font-size:12px;color:#15803d;">Sign in below and change it immediately from your account settings.</p>' +
                '<div style="margin-top:12px;display:flex;gap:8px;flex-wrap:wrap;">' +
                  '<a href="/portal/login" style="background:#FF4F00;color:#fff;text-decoration:none;font-weight:600;font-size:13px;padding:8px 14px;border-radius:6px;">Sign in</a>' +
                  '<button type="button" id="copyBtn" style="background:#fff;border:1px solid #86efac;color:#166534;font-weight:600;font-size:13px;padding:8px 14px;border-radius:6px;cursor:pointer;">Copy password</button>' +
                '</div>' +
              '</div>';
            var copyBtn = document.getElementById('copyBtn');
            if (copyBtn) copyBtn.addEventListener('click', function() {
              navigator.clipboard.writeText(d.tempPassword).then(function() { copyBtn.textContent = 'Copied!'; });
            });
          } else {
            var scoreLine = (typeof d.score === 'number') ? ('<p style="margin:0 0 6px;font-size:13px;"><strong>Aggregate score:</strong> ' + d.score + '% (need ' + (d.threshold || 80) + '%)</p>') : '';
            result.innerHTML =
              '<div style="background:#fee2e2;border:1px solid #fca5a5;color:#991b1b;padding:14px 16px;border-radius:10px;">' +
                '<p style="font-weight:700;margin:0 0 6px;font-size:14px;">Verification did not pass</p>' +
                scoreLine +
                '<p style="margin:0;font-size:12.5px;line-height:1.6;">' + (d.error || 'Try again, or use ID + face match: ') + ' <a href="/identity-setup" style="color:#FF4F00;font-weight:600;">/identity-setup</a></p>' +
              '</div>';
          }
        }).catch(function() {
          verifyBtn.disabled = false; verifyBtn.textContent = prev;
          result.style.display = 'block';
          result.innerHTML = '<div style="background:#fee2e2;border:1px solid #fca5a5;color:#991b1b;padding:12px 14px;border-radius:8px;font-size:13.5px;">Network error - try again.</div>';
        });
      });
    })();
  </script>
</BaseLayout>
