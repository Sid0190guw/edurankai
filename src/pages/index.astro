---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Products from '@/components/home/Products.astro';
import { HERO, MISSION, PILLARS } from '@/data/home';

const DIMENSIONS = [
  { letter: 'P', title: 'Physical', desc: 'Active health, energy, stamina, body awareness.', color: 'burn' },
  { letter: 'M', title: 'Mental', desc: 'Clarity, focus, resilience, learning capacity.', color: 'sky' },
  { letter: 'E', title: 'Emotional', desc: 'Self-awareness, empathy, regulation, feedback.', color: 'plum' },
  { letter: 'S', title: 'Social', desc: 'Collaboration, communication, team trust.', color: 'teal' },
  { letter: 'Sp', title: 'Spiritual', desc: 'Purpose, values, meaning beyond the task.', color: 'gold' }
];
---
<BaseLayout title="EduRankAI - Frontier AI Research Lab. Building toward ASI." description="EduRankAI is a frontier AI research lab building foundational models, reasoning systems, and quantum-era architectures. While others build toward AGI, we build toward ASI.">

  <!-- HERO -->
  <section class="px-[5vw] pt-16 md:pt-24 pb-16 md:pb-20 max-w-6xl mx-auto">
    <p class="eyebrow mb-6">{HERO.eyebrow}</p>
    <h1 class="font-display text-[clamp(2.5rem,6vw,5rem)] font-semibold text-ink leading-[1.02] tracking-tight mb-7 max-w-4xl">
      {HERO.headline}<br/>
      <em class="italic text-burn font-medium">{HERO.headlineEm}</em>
    </h1>

    <p class="text-[1rem] md:text-[1.1rem] text-ink-soft leading-[1.8] font-light max-w-2xl mb-10">
      {HERO.description}
    </p>

    <div class="flex flex-wrap gap-3">
      <a href="/ecosystem/foundational-models" class="btn-primary">Read the research</a>
      <a href="/careers" class="btn-ghost">View open roles &rarr;</a>
    </div>
  </section>

  <!-- 3 PILLARS - what we are at a glance -->
  <section class="px-[5vw] py-12 md:py-16 max-w-6xl mx-auto border-t border-ink/8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {PILLARS.map((p) => (
        <a href={p.href} target={p.external ? '_blank' : '_self'} rel={p.external ? 'noopener noreferrer' : ''} class="group bg-white border border-ink/10 rounded-2xl p-6 transition-all hover:border-burn-dim hover:-translate-y-1 hover:shadow-xl flex flex-col">
          <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn mb-3 font-bold">{p.eyebrow}</p>
          <h3 class="font-display text-[1.3rem] font-bold text-ink mb-3 leading-tight">{p.title}</h3>
          <p class="text-[0.85rem] text-ink-soft font-light leading-relaxed flex-1 mb-4">{p.description}</p>
          <span class="text-[0.82rem] font-semibold text-burn group-hover:gap-2 inline-flex items-center gap-1 transition-all">
            {p.cta} <span>&rarr;</span>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- MISSION / RESEARCH THESIS -->
  <section class="px-[5vw] py-20 md:py-28 max-w-6xl mx-auto border-t border-ink/8">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12">
      <div class="md:col-span-4">
        <p class="eyebrow mb-3">{MISSION.eyebrow}</p>
        <h2 class="section-title" set:html={MISSION.title}></h2>
      </div>
      <div class="md:col-span-7 md:col-start-6 space-y-5">
        {MISSION.body.map((p) => (
          <p class="text-[0.98rem] text-ink-2 font-light leading-[1.9]">{p}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- ECOSYSTEM - 6 ventures -->
  <section id="ecosystem" class="border-t border-ink/8">
    <Products />
  </section>

  <!-- 5 DIMENSIONS -->
  <section class="px-[5vw] py-20 md:py-28 max-w-6xl mx-auto border-t border-ink/8">
    <div class="max-w-2xl mb-12">
      <p class="eyebrow mb-3">Why education</p>
      <h2 class="section-title mb-4">We see the <em>whole person.</em></h2>
      <p class="text-[0.95rem] text-ink-soft font-light leading-[1.85]">
        Our reasoning models are anchored in education because learning is where intelligence develops. And the kind of intelligence we want machines to have looks like the kind we cultivate in humans — across all five dimensions of being.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
      {DIMENSIONS.map((d) => {
        const colorClasses = {
          burn: 'border-burn-dim bg-burn-pale text-burn',
          sky: 'border-sky-border bg-sky-bg text-sky',
          plum: 'border-plum-border bg-plum-bg text-plum',
          teal: 'border-teal-border bg-teal-bg text-teal',
          gold: 'border-gold-border bg-gold-bg text-gold-deep'
        };
        const cls = colorClasses[d.color] || colorClasses.burn;
        return (
          <div class="bg-white border border-ink/10 rounded-2xl p-5 hover:border-burn-dim hover:-translate-y-1 transition-all">
            <div class={'w-10 h-10 rounded-full flex items-center justify-center font-display text-base font-semibold border mb-3 ' + cls}>{d.letter}</div>
            <p class="font-display text-[1rem] font-semibold text-ink mb-2">{d.title}</p>
            <p class="text-[0.78rem] text-ink-soft font-light leading-relaxed">{d.desc}</p>
          </div>
        );
      })}
    </div>
  </section>

  <!-- BHARAT - thesis closer -->
  <section class="px-[5vw] py-20 md:py-28 bg-cream-2/40 border-t border-ink/8">
    <div class="max-w-3xl mx-auto text-center">
      <p class="eyebrow mb-4">Where we build</p>
      <h2 class="font-display text-[clamp(2rem,4.5vw,3.2rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-6">
        Rooted in <em class="italic text-burn font-medium">Bharat.</em><br/>Built for everyone.
      </h2>
      <p class="text-[1rem] text-ink-2 font-light leading-[1.85] mb-8">
        Every breakthrough in modern AI has come from one geography. We think the next one comes from a different place. EduRankAI is a frontier lab built in India — because the most consequential ideas should not all be born within a five-mile radius of the same bay.
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/careers" class="btn-primary">Join us &rarr;</a>
        <a href="/ecosystem" class="btn-ghost">Explore the ecosystem</a>
      </div>
    </div>
  </section>

</BaseLayout>