---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Products from '@/components/home/Products.astro';
import { HERO, MISSION } from '@/data/home';

const DIMENSIONS = [
  { letter: 'P', title: 'Physical', desc: 'Active health, energy, stamina, body awareness.', color: 'burn' },
  { letter: 'M', title: 'Mental', desc: 'Clarity, focus, resilience, learning capacity.', color: 'sky' },
  { letter: 'E', title: 'Emotional', desc: 'Self-awareness, empathy, regulation, feedback.', color: 'plum' },
  { letter: 'S', title: 'Social', desc: 'Collaboration, communication, team trust.', color: 'teal' },
  { letter: 'Sp', title: 'Spiritual', desc: 'Purpose, values, meaning beyond the task.', color: 'gold' }
];

const STATS = [
  { value: '6', label: 'Ventures currently building' },
  { value: '5', label: 'Dimensions of human development' },
  { value: '12+', label: 'Languages planned for launch' },
  { value: '∞', label: 'Belief in human potential' }
];
---
<BaseLayout title="EduRankAI - Frontier AI Educational Intelligence" description="EduRankAI is a Bharat-built frontier AI company. Currently building six ventures across education, human connection, travel, business, and community.">

  <section class="px-[5vw] pt-16 md:pt-24 pb-16 md:pb-20 max-w-6xl mx-auto">
    <h1 class="font-display text-[clamp(2.5rem,6vw,4.5rem)] font-semibold text-ink leading-[1.05] tracking-tight mb-7 max-w-4xl">
      {HERO.headline}<br/>
      <em class="italic text-burn font-medium">{HERO.headlineEm}</em>
    </h1>

    <p class="text-[1rem] md:text-[1.05rem] text-ink-soft leading-[1.85] font-light max-w-2xl mb-10">
      {HERO.description}
    </p>

    <div class="flex flex-wrap gap-3">
      <a href="#ecosystem" class="btn-primary">Explore Our Ecosystem</a>
      <a href="/ecosystem" class="btn-ghost">Learn More →</a>
    </div>
  </section>

  <section class="px-[5vw] py-16 md:py-20 max-w-6xl mx-auto border-t border-ink/8">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12">
      <div class="md:col-span-4">
        <p class="eyebrow mb-3">{MISSION.eyebrow}</p>
        <h2 class="section-title" set:html={MISSION.title}></h2>
      </div>
      <div class="md:col-span-7 md:col-start-6 space-y-5">
        {MISSION.body.map((p) => (
          <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">{p}</p>
        ))}
      </div>
    </div>
  </section>

  <section id="ecosystem">
    <Products />
  </section>

  <section class="px-[5vw] py-16 md:py-20 max-w-6xl mx-auto">
    <div class="max-w-2xl mb-12">
      <p class="eyebrow mb-3">Our Approach</p>
      <h2 class="section-title mb-4">We see the <em>whole person.</em></h2>
      <p class="text-[0.92rem] text-ink-soft font-light leading-[1.8]">
        The systems we build serve five dimensions of human wholeness. Education that develops only the mind misses the human. We build for all five.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
      {DIMENSIONS.map((d) => {
        const colorClasses = {
          burn: 'border-burn-dim bg-burn-pale text-burn',
          sky: 'border-sky-border bg-sky-bg text-sky',
          plum: 'border-plum-border bg-plum-bg text-plum',
          teal: 'border-teal-border bg-teal-bg text-teal',
          gold: 'border-gold-border bg-gold-bg text-gold-deep'
        };
        const cls = colorClasses[d.color] || colorClasses.burn;
        return (
          <div class="bg-white border border-ink/10 rounded-2xl p-5 hover:border-burn-dim hover:-translate-y-1 transition-all">
            <div class={'w-9 h-9 rounded-full flex items-center justify-center font-display text-base font-semibold border mb-3 ' + cls}>{d.letter}</div>
            <p class="font-display text-[1rem] font-semibold text-ink mb-2">{d.title}</p>
            <p class="text-[0.78rem] text-ink-soft font-light leading-relaxed">{d.desc}</p>
          </div>
        );
      })}
    </div>
  </section>

  <section class="px-[5vw] py-16 md:py-20 bg-cream-2/40">
    <div class="max-w-6xl mx-auto">
      <div class="max-w-3xl mb-12">
        <p class="eyebrow mb-3">Building for Bharat. Building for the World.</p>
        <h2 class="section-title mb-5">
          Rooted in <em>Bharat.</em><br/>Built for everyone.
        </h2>
        <p class="text-[0.95rem] text-ink-soft font-light leading-[1.85] max-w-2xl">
          EduRankAI is born in India and built for the world. We ship in multiple languages, design for learners in any geography, and incubate ventures that solve problems across education, human connection, travel, and business. India is our home. The world is our scope.
        </p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {STATS.map((s) => (
          <div class="bg-white border border-ink/10 rounded-2xl p-5 md:p-6">
            <p class="font-display text-[2.5rem] md:text-[3rem] font-semibold text-burn leading-none mb-2 tracking-tight">{s.value}</p>
            <p class="text-[0.78rem] text-ink-soft font-light leading-snug">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
