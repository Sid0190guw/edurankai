---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const company = (fd.get('company') as string || '').trim();
    const contact = (fd.get('contact') as string || '').trim();
    const email = (fd.get('email') as string || '').trim();
    const monthly_volume = (fd.get('monthly_volume') as string || '').trim();
    const use_case = (fd.get('use_case') as string || '').trim();
    if (!company || !email || !use_case || use_case.length < 60) errMsg = 'Company, email, and a 60+ char use case required.';
    else {
      await db.execute(sql`CREATE TABLE IF NOT EXISTS atlas_partner_leads (
        id UUID PRIMARY KEY DEFAULT gen_random_uuid(), company VARCHAR(200), contact VARCHAR(200), email VARCHAR(200),
        monthly_volume VARCHAR(80), use_case TEXT, status VARCHAR(20) DEFAULT 'open', created_at TIMESTAMPTZ DEFAULT NOW())`);
      await db.execute(sql`INSERT INTO atlas_partner_leads (company, contact, email, monthly_volume, use_case)
        VALUES (${company}, ${contact || null}, ${email}, ${monthly_volume || null}, ${use_case})`);
      okMsg = 'Request received. Our partnership team will reach out within 2 business days with sandbox credentials.';
    }
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 240); }
}
---
<BaseLayout title="ATLAS Proctoring API · EduRankAI" description="Honorlock-class proctoring as a service. Plug into any LMS, hiring tool, or testing platform via REST + JS SDK. Devtools + multi-monitor + face + voice + screen detection.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; }
  .at-wrap { max-width: 1300px; margin: 0 auto; }
  .at-hero { padding: 70px 5vw 50px; }
  .at-eye { font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.22em; text-transform: uppercase; color: #67e8f9; font-weight: 700; }
  .at-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(48px, 8vw, 88px); font-weight: 600; letter-spacing: -0.035em; margin: 14px 0 18px; line-height: 0.96; max-width: 1000px; }
  .at-title em { font-style: italic; font-weight: 500; background: linear-gradient(135deg, #67e8f9, #86efac); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
  .at-sub { font-size: 18px; color: #9aa6b6; max-width: 720px; line-height: 1.7; }

  .at-cta-row { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 28px; }
  .at-btn { background: #67e8f9; color: #04161b; padding: 13px 26px; border-radius: 10px; text-decoration: none; font-weight: 800; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; }
  .at-btn-ghost { background: transparent; border: 1px solid #2a2a35; color: #cfd6da; }

  .at-strip { padding: 30px 5vw; display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 12px; border-top: 1px solid #1a1a25; border-bottom: 1px solid #1a1a25; }
  .at-stat { padding: 14px 0; }
  .at-stat-val { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 600; color: #fff; line-height: 1; letter-spacing: -0.02em; }
  .at-stat-lbl { font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #9aa6b6; margin-top: 6px; font-weight: 700; }

  .at-section { padding: 60px 5vw; border-bottom: 1px solid #1a1a25; }
  .at-section-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #67e8f9; font-weight: 700; }
  .at-section-h { font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 4vw, 44px); font-weight: 600; letter-spacing: -0.025em; margin: 8px 0 14px; line-height: 1.1; }
  .at-section-h em { color: #67e8f9; font-style: italic; font-weight: 500; }
  .at-section-sub { font-size: 16px; color: #9aa6b6; max-width: 720px; line-height: 1.65; }

  .at-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 14px; margin-top: 28px; }
  .at-card { background: #11131a; border: 1px solid #2a2a35; border-radius: 14px; padding: 22px; }
  .at-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; margin: 8px 0; letter-spacing: -0.01em; line-height: 1.2; }
  .at-card-icon { width: 42px; height: 42px; border-radius: 10px; background: rgba(103,232,249,0.15); color: #67e8f9; display: flex; align-items: center; justify-content: center; }
  .at-card p { font-size: 14px; color: #9aa6b6; line-height: 1.6; margin: 0; }

  .at-code { background: #08080a; border: 1px solid #2a2a35; border-radius: 10px; padding: 18px 22px; font-family: ui-monospace, monospace; font-size: 13px; line-height: 1.65; color: #cfd6da; overflow-x: auto; }
  .at-code .k { color: #c4b5fd; } .at-code .s { color: #86efac; } .at-code .c { color: #6e6e78; font-style: italic; } .at-code .f { color: #67e8f9; }

  .at-event-tbl { width: 100%; border-collapse: collapse; margin-top: 18px; }
  .at-event-tbl th { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #67e8f9; text-align: left; padding: 8px 14px; border-bottom: 1px solid #2a2a35; font-weight: 700; }
  .at-event-tbl td { padding: 7px 14px; border-bottom: 1px solid #1a1a25; font-size: 13px; color: #cfd6da; }
  .at-event-tbl .sev-high { color: #f87171; font-weight: 700; }
  .at-event-tbl .sev-med { color: #fbbf24; font-weight: 700; }
  .at-event-tbl .sev-low { color: #86efac; font-weight: 700; }

  .at-price-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 14px; margin-top: 28px; }
  .at-price { background: #11131a; border: 1px solid #2a2a35; border-radius: 16px; padding: 26px; }
  .at-price.featured { border: 2px solid #67e8f9; }
  .at-price-eye { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; }
  .at-price-name { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 600; margin: 6px 0 12px; }
  .at-price-amt { font-family: 'Cormorant Garamond', serif; font-size: 42px; font-weight: 600; color: #fff; letter-spacing: -0.02em; }
  .at-price-per { font-family: 'Geist Mono', monospace; font-size: 12px; color: #9aa6b6; }
  .at-price ul { margin: 14px 0 0; padding: 0; list-style: none; }
  .at-price li { padding: 6px 0; color: #cfd6da; font-size: 13.5px; display: flex; gap: 8px; align-items: flex-start; }
  .at-price li::before { content: '✓'; color: #86efac; font-weight: 700; flex-shrink: 0; }

  .at-form { background: linear-gradient(135deg, #11131a, #1a1a25); border: 1px solid #2a2a35; border-radius: 18px; padding: 32px; margin-top: 22px; max-width: 720px; }
  .at-form input, .at-form textarea, .at-form select { width: 100%; box-sizing: border-box; background: #0a0a0c; border: 1px solid #2a2a35; color: #fff; padding: 10px 14px; border-radius: 8px; font-family: inherit; font-size: 14px; margin-bottom: 10px; }
  .at-form label { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; margin-bottom: 5px; display: block; }
  .at-form button { background: #67e8f9; color: #04161b; padding: 12px 28px; border-radius: 8px; border: none; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; margin-top: 8px; }
</style>

<main class="at-wrap">

  <section class="at-hero">
    <p class="at-eye">ATLAS · Proctoring API</p>
    <h1 class="at-title">Honorlock-class proctoring,<br/><em>any platform</em>.</h1>
    <p class="at-sub">The same proctoring engine that secures EduRankAI's tests &mdash; available to any LMS, hiring tool, or testing platform through one REST API and a 14&thinsp;KB JavaScript SDK. Devtools detection. Multi-monitor detection. Face + voice + screen monitoring. 28-event integrity log with severity-weighted scoring.</p>
    <div class="at-cta-row">
      <a href="#start" class="at-btn">Get sandbox keys &rarr;</a>
      <a href="#api" class="at-btn at-btn-ghost">View API</a>
      <a href="https://docs.edurankai.in/atlas" class="at-btn at-btn-ghost">Docs</a>
    </div>
  </section>

  <section class="at-strip">
    <div class="at-stat"><p class="at-stat-val">28+</p><p class="at-stat-lbl">Event types tracked</p></div>
    <div class="at-stat"><p class="at-stat-val">14 KB</p><p class="at-stat-lbl">JS SDK · gzipped</p></div>
    <div class="at-stat"><p class="at-stat-val">Browser-side</p><p class="at-stat-lbl">No video upload</p></div>
    <div class="at-stat"><p class="at-stat-val">REST + JS</p><p class="at-stat-lbl">Two endpoints</p></div>
    <div class="at-stat"><p class="at-stat-val">Advisory</p><p class="at-stat-lbl">Human reviews</p></div>
  </section>

  <section class="at-section" id="features">
    <p class="at-section-eye">What it sees</p>
    <h2 class="at-section-h">Every signal worth <em>flagging</em>.</h2>
    <p class="at-section-sub">Live detection runs in the browser. Severity-weighted integrity score updates in real time. Recorded events flush to your endpoint as text-only JSON &mdash; no video bytes ever leave the candidate machine.</p>
    <div class="at-grid">
      <div class="at-card">
        <div class="at-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 2"/></svg></div>
        <h3>Devtools detection</h3>
        <p>Window-resize delta heuristic + console.log timing trap + debugger statement detection. Catches every standard devtools open path including detached panel.</p>
      </div>
      <div class="at-card">
        <div class="at-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg></div>
        <h3>Multi-monitor</h3>
        <p>Screen.availWidth / availHeight cross-check + window-position delta on focus events. Surfaces second-display + external-display scenarios.</p>
      </div>
      <div class="at-card">
        <div class="at-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg></div>
        <h3>Face monitoring</h3>
        <p>Local face-api on a 320&times;240 stream emits face_lost / face_visible / multiple_faces / looking_away events. Zero bytes uploaded.</p>
      </div>
      <div class="at-card">
        <div class="at-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg></div>
        <h3>Voice monitoring</h3>
        <p>Web Audio RMS analyser emits voice_detected / voice_silenced. Catches background conversation, dictation, candidate-coaching scenarios.</p>
      </div>
      <div class="at-card">
        <div class="at-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg></div>
        <h3>Tab / window switch</h3>
        <p>document.visibilityState + window.blur with 200ms debounce. Distinguishes brief glance-aways from genuine context switches.</p>
      </div>
      <div class="at-card">
        <div class="at-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6v6H9z"/></svg></div>
        <h3>Copy-paste + shortcuts</h3>
        <p>Blocks + logs cmd/ctrl-c/v/x, screenshot, print, save, view-source. Surface logged with timestamp for review.</p>
      </div>
      <div class="at-card">
        <div class="at-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33"/></svg></div>
        <h3>Fullscreen + network</h3>
        <p>Detects fullscreen exit; flags interruption. Network online / offline transitions logged with bandwidth marker.</p>
      </div>
      <div class="at-card">
        <div class="at-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></div>
        <h3>Integrity score</h3>
        <p>Severity-weighted real-time score (0 to 100). Configurable thresholds per event type. Score history exportable as a chart per attempt.</p>
      </div>
    </div>
  </section>

  <section class="at-section" id="api">
    <p class="at-section-eye">Integrate</p>
    <h2 class="at-section-h">Two endpoints, <em>one SDK</em>.</h2>
    <p class="at-section-sub">Drop the SDK into your test runner. Call <code style="background:rgba(103,232,249,0.1);padding:1px 6px;border-radius:3px;font-family:ui-monospace,monospace;">Atlas.start()</code> at the start of an attempt; events flush automatically.</p>

    <div style="margin-top:18px;display:grid;grid-template-columns:1fr;gap:14px;">
      <div class="at-code" set:html={`<span class="c">// 1. Include the SDK (14 KB gzipped)</span>
&lt;<span class="k">script</span> <span class="k">src</span>=<span class="s">"https://atlas.edurankai.in/sdk.js"</span> <span class="k">defer</span>&gt;&lt;/<span class="k">script</span>&gt;`}></div>

      <div class="at-code" set:html={`<span class="c">// 2. Initialise + start at the test runner</span>
<span class="k">const</span> session = <span class="k">await</span> <span class="f">Atlas.start</span>({
  apiKey:    <span class="s">"sk_live_..."</span>,
  attemptId: <span class="s">"att_4abcd"</span>,
  candidate: { id: <span class="s">"u_12"</span>, name: <span class="s">"Jane Doe"</span> },
  features:  { face: <span class="k">true</span>, voice: <span class="k">true</span>, devtools: <span class="k">true</span>, multiMon: <span class="k">true</span> },
  webhookUrl:<span class="s">"https://yourapp.com/proctor-events"</span>,
  onFlag:    (e) =&gt; console.<span class="f">log</span>(<span class="s">"flag"</span>, e),
});`}></div>

      <div class="at-code" set:html={`<span class="c">// 3. End the session when the candidate submits</span>
<span class="k">await</span> session.<span class="f">end</span>();`}></div>

      <div class="at-code" set:html={`<span class="c">// 4. Pull the full event log + integrity score on your server</span>
<span class="f">GET</span> <span class="s">"https://atlas.edurankai.in/v1/attempts/att_4abcd"</span>
Authorization: Bearer sk_live_...
<span class="c">// returns { events: [...], integrityScore: 78, flags: [...] }</span>`}></div>
    </div>
  </section>

  <section class="at-section">
    <p class="at-section-eye">Event vocabulary</p>
    <h2 class="at-section-h">28 event types, <em>severity-tagged</em>.</h2>
    <table class="at-event-tbl">
      <thead><tr><th>Type</th><th>Severity</th><th>Trigger</th></tr></thead>
      <tbody>
        <tr><td>devtools_opened</td><td><span class="sev-high">High</span></td><td>Window-resize delta + console-timing trap</td></tr>
        <tr><td>multi_monitor</td><td><span class="sev-high">High</span></td><td>availWidth/Height &gt; screen, or window outside primary</td></tr>
        <tr><td>multiple_faces</td><td><span class="sev-high">High</span></td><td>Face-api detects &ge;2 faces in stream</td></tr>
        <tr><td>face_lost</td><td><span class="sev-med">Medium</span></td><td>No face for &gt;3s</td></tr>
        <tr><td>looking_away</td><td><span class="sev-med">Medium</span></td><td>Head-pose yaw &gt; 30&deg; for &gt;2s</td></tr>
        <tr><td>tab_switch</td><td><span class="sev-med">Medium</span></td><td>visibilitychange to hidden</td></tr>
        <tr><td>fullscreen_exit</td><td><span class="sev-med">Medium</span></td><td>fullscreenchange to null</td></tr>
        <tr><td>copy_paste_blocked</td><td><span class="sev-low">Low</span></td><td>cmd/ctrl-c|v|x intercepted</td></tr>
        <tr><td>voice_detected</td><td><span class="sev-low">Low</span></td><td>RMS &gt; threshold for &gt;500ms</td></tr>
        <tr><td>network_drop</td><td><span class="sev-low">Low</span></td><td>navigator.onLine = false</td></tr>
      </tbody>
    </table>
    <p style="font-family:'Geist Mono',monospace;font-size:11px;color:#9aa6b6;margin-top:12px;letter-spacing:0.04em;">+ 18 more &mdash; see <a href="https://docs.edurankai.in/atlas/events" style="color:#67e8f9;">/atlas/events</a></p>
  </section>

  <section class="at-section">
    <p class="at-section-eye">Pricing</p>
    <h2 class="at-section-h">Per-attempt, <em>volume-tiered</em>.</h2>
    <p class="at-section-sub">No setup fees. No seat licences. You pay per completed attempt. First 100 attempts every month are free.</p>

    <div class="at-price-grid">
      <div class="at-price"><p class="at-price-eye">Starter</p><p class="at-price-name">Pilot</p><p><span class="at-price-amt">Free</span><span class="at-price-per"> &middot; first 100 / month</span></p><ul><li>All 28 event types</li><li>JS SDK + webhook</li><li>Community support</li></ul></div>
      <div class="at-price featured"><p class="at-price-eye">Most popular</p><p class="at-price-name">Growth</p><p><span class="at-price-amt">$0.40</span><span class="at-price-per"> / attempt</span></p><ul><li>Everything in Pilot</li><li>Integrity score API</li><li>Replay UI embed</li><li>Webhook retry + signing</li><li>Email + chat support</li></ul></div>
      <div class="at-price"><p class="at-price-eye">High volume</p><p class="at-price-name">Scale</p><p><span class="at-price-amt">Custom</span><span class="at-price-per"> &middot; 50K+ / mo</span></p><ul><li>Volume discount</li><li>Self-hosted option</li><li>Custom event types</li><li>Dedicated SLA</li><li>Premium support</li></ul></div>
    </div>
  </section>

  <section class="at-section" id="start" style="border-bottom:none;">
    <p class="at-section-eye">Get started</p>
    <h2 class="at-section-h">Request <em>sandbox keys</em>.</h2>
    <p class="at-section-sub">Sandbox tier gives you 1,000 free attempts and a live integration engineer for the first two weeks. We typically reply within 1 business day.</p>

    {okMsg && <div style="background:rgba(134,239,172,0.10);border:1px solid #86efac;padding:14px 18px;border-radius:10px;margin-top:18px;max-width:720px;"><p style="color:#86efac;font-weight:600;margin:0;">{okMsg}</p></div>}
    {errMsg && <div style="background:rgba(248,113,113,0.10);border:1px solid #f87171;padding:14px 18px;border-radius:10px;margin-top:18px;max-width:720px;"><p style="color:#f87171;font-weight:600;margin:0;">{errMsg}</p></div>}

    {!okMsg && (
      <form method="POST" class="at-form">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
          <div><label>Company *</label><input name="company" required maxlength="200"/></div>
          <div><label>Contact name</label><input name="contact" maxlength="200"/></div>
        </div>
        <label>Email *</label>
        <input name="email" type="email" required maxlength="200"/>
        <label>Expected monthly volume</label>
        <select name="monthly_volume">
          <option value="">Select range</option>
          <option value="lt-1k">&lt; 1,000 attempts</option>
          <option value="1k-10k">1,000 to 10,000</option>
          <option value="10k-50k">10,000 to 50,000</option>
          <option value="50k-200k">50,000 to 200,000</option>
          <option value="gt-200k">200,000+</option>
        </select>
        <label>Use case * (60+ chars)</label>
        <textarea name="use_case" rows="4" minlength="60" maxlength="2000" required placeholder="Describe what platform you're integrating into and which attempts you want to proctor."></textarea>
        <button type="submit">Request keys &rarr;</button>
      </form>
    )}
  </section>

</main>
</BaseLayout>
