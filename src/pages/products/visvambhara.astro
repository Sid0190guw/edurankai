---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ensureVisvambharaProduct } from '@/lib/products-seed';
import { hasApprovedAccess, getUserAccess, ensureVisvambharaAccessSchema } from '@/lib/visvambhara-access';

await ensureVisvambharaProduct();
await ensureVisvambharaAccessSchema();

const user = Astro.locals.user;
const isStaff = !!user && user.role !== 'applicant';
const access = user ? await getUserAccess(user.id) : null;
const canViewModules = isStaff || (access?.status === 'approved');
const accessState: 'staff'|'approved'|'pending'|'rejected'|'unrequested'|'unauthed' =
  isStaff ? 'staff' :
  !user ? 'unauthed' :
  !access ? 'unrequested' :
  access.status as any;

const modules = [
  { slug: 'architecture',   t: 'Architecture',     d: 'Master document. Mission, vehicle family, mass budgets, propulsion stack, the full thesis.',                                tag: 'OVERVIEW',   size: '255 KB' },
  { slug: 'datasheet',      t: 'Engineering Datasheet', d: 'First-order engineering numbers — masses, thrust-to-weight, Δv, dimensions — all internally consistent across tiers.', tag: 'NUMBERS',    size: '189 KB' },
  { slug: 'concept-film',   t: 'Concept Film',     d: 'Animated walkthrough of the entire programme: Bee → Mother → Grandmother → swarm operations.',                              tag: 'FILM',       size: '1.5 MB' },
  { slug: '3d-viewer',      t: '3D Viewer',        d: 'Interactive blueprints of each vehicle. Rotate, inspect cross-sections, see the structural lattice.',                       tag: 'INTERACTIVE',size: '36 KB' },
  { slug: 'fleet-3d',       t: 'Fleet 3D',         d: 'See all three tiers in formation at scale. The honeycomb docking matrices are visible.',                                    tag: 'INTERACTIVE',size: '67 KB' },
  { slug: 'wind-tunnel',    t: 'CFD Wind Tunnel',  d: 'Live Lattice-Boltzmann CFD on each airframe — set Mach, inspect pressure and L/D, dial the angle of attack.',               tag: 'SIMULATION', size: '186 KB' },
  { slug: 'flight-profile', t: 'Flight Profile',   d: 'Atmosphere → orbit → interplanetary, animated. Single-stage to orbit on variable-cycle engines.',                           tag: 'SIMULATION', size: '1.4 MB' },
];

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Viśvambhara — VESPER aerospace concept',
  description: 'Frontier autonomous aerospace research from EduRankAI. Three-tier vehicle family: Bee micro-UAV, Mother SSTO ship, Grandmother interplanetary command vessel.',
  brand: { '@type': 'Organization', name: 'EduRankAI' },
  category: 'Aerospace Research',
  url: 'https://edurankai.in/products/visvambhara',
};
---
<BaseLayout
  title="Viśvambhara — Aerospace Research — EduRankAI"
  description="Viśvambhara is EduRankAI's frontier aerospace research line. Flagship VESPER concept: a three-tier autonomous swarm — Bee, Mother, and Grandmother — built from one parametric family. Interactive CFD, fleet 3D, flight profile.">

  <script is:inline type="application/ld+json" set:html={JSON.stringify(productSchema)} />

  <section style="background:#06121a;color:#e8f3f6;min-height:100vh;padding:80px 5vw 60px;font-family:'Space Grotesk',system-ui,sans-serif;">
    <div style="max-width:1180px;margin:0 auto;">
      <a href="/ecosystem" style="display:inline-flex;align-items:center;gap:8px;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.18em;color:#7e98a1;text-decoration:none;text-transform:uppercase;margin-bottom:40px;">
        ← Ecosystem
      </a>

      <p style="font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:0.4em;color:#22d3ee;text-transform:uppercase;margin:0 0 18px;">Viśvambhara · Aerospace</p>

      <h1 style="font-size:clamp(36px,7vw,72px);line-height:1.02;font-weight:700;letter-spacing:-0.025em;margin:0 0 22px;">
        One parametric family.<br/>
        <span style="color:#22d3ee;">Three scales of swarm.</span>
      </h1>

      <p style="max-width:740px;font-size:19px;line-height:1.55;color:#9fc4ce;text-wrap:pretty;margin:0 0 24px;">
        Viśvambhara is EduRankAI's frontier aerospace research line. The flagship <b style="color:#7fe9f5;">VESPER</b> concept demonstrates one design philosophy across three scales: a <b>3.2 g bee-class micro-UAV</b>, a <b>38 t blended lifting body</b> that carries 100,000 bees from atmosphere to orbit, and a <b>28,000 t interplanetary command vessel</b> that commands 50 million bees across the solar system.
      </p>

      <div style="margin:0 0 50px;font-family:'JetBrains Mono',monospace;font-size:11.5px;letter-spacing:0.04em;color:#9fc4ce;border:1px solid rgba(120,200,220,0.16);border-left:2px solid #ffb347;border-radius:9px;padding:14px 18px;max-width:740px;line-height:1.7;">
        CONCEPT / MVP — figures are first-order engineering estimates for a design study, not flight-qualified data. Three tiers share one parametric family: the bee is rotor-borne; both ships are blended lifting bodies sized for surface → orbit → interplanetary flight.
      </div>

      <!-- Three-tier summary -->
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:18px;margin-bottom:60px;">
        <div style="background:linear-gradient(180deg,#0a1c25,#06141d);border:1px solid rgba(120,200,220,0.16);border-radius:14px;padding:22px;">
          <p style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.2em;color:#22d3ee;text-transform:uppercase;margin:0 0 8px;">Tier 01</p>
          <h3 style="font-size:22px;font-weight:700;margin:0 0 4px;letter-spacing:-0.01em;">VSP-M1 · Bee</h3>
          <p style="font-size:13px;color:#9fc4ce;margin:0 0 14px;line-height:1.5;">Rotor-borne micro-UAV. Wing acts as radar aperture and silent glide surface.</p>
          <div style="font-family:'JetBrains Mono',monospace;font-size:11.5px;color:#7fe9f5;line-height:1.9;">
            32 mm rotor span<br/>3.2 g all-up mass<br/>6 min flight · 6h perch
          </div>
        </div>
        <div style="background:linear-gradient(180deg,#0a1c25,#06141d);border:1px solid rgba(120,200,220,0.16);border-radius:14px;padding:22px;">
          <p style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.2em;color:#22d3ee;text-transform:uppercase;margin:0 0 8px;">Tier 02</p>
          <h3 style="font-size:22px;font-weight:700;margin:0 0 4px;letter-spacing:-0.01em;">VSP-M2 · Mother</h3>
          <p style="font-size:13px;color:#9fc4ce;margin:0 0 14px;line-height:1.5;">Blended lifting body. Same airframe loiters in atmosphere, then SSTO on variable-cycle engines.</p>
          <div style="font-family:'JetBrains Mono',monospace;font-size:11.5px;color:#7fe9f5;line-height:1.9;">
            24 m × 17.5 m × 4.8 m<br/>38 t MTOM · 9.4 km/s Δv<br/>Carries 100,000 bees
          </div>
        </div>
        <div style="background:linear-gradient(180deg,#0a1c25,#06141d);border:1px solid rgba(255,179,71,0.28);border-radius:14px;padding:22px;">
          <p style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.2em;color:#ffb347;text-transform:uppercase;margin:0 0 8px;">Tier 03</p>
          <h3 style="font-size:22px;font-weight:700;margin:0 0 4px;letter-spacing:-0.01em;">VSP-G1 · Grandmother</h3>
          <p style="font-size:13px;color:#9fc4ce;margin:0 0 14px;line-height:1.5;">Crewed interplanetary command vessel. Magnetoplasma cluster. Berths 500 Mother Ships.</p>
          <div style="font-family:'JetBrains Mono',monospace;font-size:11.5px;color:#7fe9f5;line-height:1.9;">
            240 m × 150 m × 46 m<br/>28,000 t · 30 km/s Δv<br/>Commands 50M bees
          </div>
        </div>
      </div>

      <!-- ========== APPLICATIONS ========== -->
      <p style="font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:0.2em;color:#22d3ee;text-transform:uppercase;margin:0 0 8px;">Where VESPER goes to work</p>
      <h2 style="font-size:36px;font-weight:700;letter-spacing:-0.02em;margin:0 0 14px;">Authentic applications.<br/><span style="color:#22d3ee;">From border line to street corner.</span></h2>
      <p style="max-width:760px;font-size:16px;line-height:1.6;color:#9fc4ce;margin:0 0 36px;">
        One parametric family, scaled across regimes. The Bee perches silently on a leaf in a forest near the LoC; the Mother SSTO carries 100,000 of them above an entire city; the Grandmother holds a continental coordination layer overhead. Below is what that capability actually does — for security forces, for civic infrastructure, for citizens.
      </p>

      <!-- Animated demo strip — six scenarios, the swarm transitions between them -->
      <div style="background:#04101a;border:1px solid rgba(120,200,220,0.22);border-radius:14px;padding:18px;margin-bottom:36px;overflow:hidden;">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:12px;flex-wrap:wrap;">
          <p style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.2em;color:#22d3ee;text-transform:uppercase;margin:0;">Live simulation · 6 scenarios looped</p>
          <p style="font-family:'JetBrains Mono',monospace;font-size:10.5px;color:#7e98a1;margin:0;">Bee = circle · Mother = triangle · Target = pulsing square</p>
        </div>
        <svg viewBox="0 0 800 320" preserveAspectRatio="xMidYMid meet" style="width:100%;height:auto;display:block;background:#02080d;border-radius:9px;">
          <defs>
            <radialGradient id="targetGrad" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="#ff6b6b" stop-opacity="0.85"/><stop offset="60%" stop-color="#ff6b6b" stop-opacity="0.25"/><stop offset="100%" stop-color="#ff6b6b" stop-opacity="0"/></radialGradient>
            <radialGradient id="cleanGrad" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="#4ade80" stop-opacity="0.85"/><stop offset="60%" stop-color="#4ade80" stop-opacity="0.25"/><stop offset="100%" stop-color="#4ade80" stop-opacity="0"/></radialGradient>
            <radialGradient id="cyanGrad" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="#22d3ee" stop-opacity="0.95"/><stop offset="100%" stop-color="#22d3ee" stop-opacity="0"/></radialGradient>
            <linearGradient id="grid" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#0a2330"/><stop offset="1" stop-color="#02080d"/></linearGradient>
            <!-- Radar sweep -->
            <linearGradient id="radarSweep" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="#22d3ee" stop-opacity="0"/>
              <stop offset="80%" stop-color="#22d3ee" stop-opacity="0.18"/>
              <stop offset="100%" stop-color="#22d3ee" stop-opacity="0.45"/>
            </linearGradient>
            <!-- Bloom -->
            <filter id="vis-bloom" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="3" result="b"/>
              <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <filter id="vis-strong-bloom" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="6" result="b"/>
              <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>

          <!-- Terrain / city plate -->
          <rect width="800" height="320" fill="url(#grid)"/>
          <g stroke="#0e3848" stroke-width="0.5" opacity="0.6">
            <path d="M0 60 L800 60 M0 120 L800 120 M0 180 L800 180 M0 240 L800 240"/>
            <path d="M120 0 L120 320 M280 0 L280 320 M440 0 L440 320 M600 0 L600 320"/>
          </g>

          <!-- Border line (left third) -->
          <path d="M40 30 C 90 80, 60 150, 100 200 C 130 240, 80 290, 140 310" stroke="#fbbf24" stroke-width="1.5" stroke-dasharray="4 3" fill="none" opacity="0.7"/>
          <text x="46" y="22" fill="#fbbf24" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="0.1em">BORDER LINE</text>

          <!-- City silhouette (right) -->
          <g fill="#0e3848" opacity="0.9">
            <rect x="500" y="220" width="40" height="80"/>
            <rect x="550" y="200" width="30" height="100"/>
            <rect x="590" y="240" width="50" height="60"/>
            <rect x="650" y="180" width="35" height="120"/>
            <rect x="695" y="220" width="40" height="80"/>
            <rect x="745" y="200" width="30" height="100"/>
          </g>
          <text x="560" y="170" fill="#7e98a1" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="0.1em">CITY GRID</text>

          <!-- Forest near border -->
          <g fill="#0a2920" opacity="0.85">
            <circle cx="170" cy="265" r="14"/>
            <circle cx="200" cy="280" r="11"/>
            <circle cx="155" cy="290" r="10"/>
            <circle cx="220" cy="260" r="12"/>
          </g>

          <!-- Highway / infrastructure -->
          <line x1="280" y1="160" x2="500" y2="160" stroke="#475569" stroke-width="3" opacity="0.7"/>
          <text x="320" y="155" fill="#7e98a1" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="0.1em">HIGHWAY · INFRA</text>

          <!-- Radar sweep — pivots from the mother's position, gives the impression of active scanning -->
          <g transform="translate(400 80)">
            <line x1="0" y1="0" x2="380" y2="0" stroke="url(#radarSweep)" stroke-width="40" opacity="0.55" stroke-linecap="round">
              <animateTransform attributeName="transform" type="rotate" from="0" to="360" dur="9s" repeatCount="indefinite"/>
            </line>
            <!-- Concentric radar rings -->
            <circle r="60" fill="none" stroke="#22d3ee" stroke-width="0.6" opacity="0.18"/>
            <circle r="120" fill="none" stroke="#22d3ee" stroke-width="0.6" opacity="0.15"/>
            <circle r="180" fill="none" stroke="#22d3ee" stroke-width="0.6" opacity="0.10"/>
          </g>

          <!-- Mother ship — circles slowly above; now with multi-layer glow + telemetry trail -->
          <g>
            <!-- Trail polygon (slight lag, low opacity) -->
            <polygon points="0,-14 12,10 -12,10" fill="#22d3ee" opacity="0.12" filter="url(#vis-strong-bloom)">
              <animateMotion dur="22s" repeatCount="indefinite" path="M 80 80 Q 400 30 720 80 Q 400 130 80 80 Z"/>
            </polygon>
            <!-- Main hull -->
            <polygon points="0,-14 12,10 -12,10" fill="#22d3ee" filter="url(#vis-bloom)">
              <animateMotion dur="22s" repeatCount="indefinite" path="M 80 80 Q 400 30 720 80 Q 400 130 80 80 Z"/>
            </polygon>
            <!-- Pulse beacon -->
            <circle r="4" fill="#fff" filter="url(#vis-bloom)">
              <animateMotion dur="22s" repeatCount="indefinite" path="M 80 80 Q 400 30 720 80 Q 400 130 80 80 Z"/>
              <animate attributeName="opacity" values="0.4;1;0.4" dur="1.4s" repeatCount="indefinite"/>
            </circle>
          </g>

          <!-- Bee swarm – pulsing targets cycling through scenarios -->
          <!-- Scenario 1: Border infiltrator -->
          <circle cx="180" cy="270" r="18" fill="url(#targetGrad)"><animate attributeName="opacity" values="0;1;1;0;0;0;0" dur="18s" repeatCount="indefinite"/></circle>
          <rect x="175" y="266" width="10" height="9" fill="#ff6b6b"><animate attributeName="opacity" values="0;1;1;0;0;0;0" dur="18s" repeatCount="indefinite"/></rect>
          <text x="125" y="245" fill="#ff6b6b" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="0.1em" opacity="0"><animate attributeName="opacity" values="0;1;1;0;0;0;0" dur="18s" repeatCount="indefinite"/>BORDER · INFILTRATOR</text>

          <!-- Scenario 2: Crowd density / public safety -->
          <circle cx="620" cy="245" r="22" fill="url(#targetGrad)"><animate attributeName="opacity" values="0;0;1;1;0;0;0" dur="18s" repeatCount="indefinite"/></circle>
          <rect x="615" y="241" width="10" height="9" fill="#ff6b6b"><animate attributeName="opacity" values="0;0;1;1;0;0;0" dur="18s" repeatCount="indefinite"/></rect>
          <text x="540" y="220" fill="#ff6b6b" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="0.1em" opacity="0"><animate attributeName="opacity" values="0;0;1;1;0;0;0" dur="18s" repeatCount="indefinite"/>PUBLIC · CROWD DENSITY</text>

          <!-- Scenario 3: Highway hazard -->
          <circle cx="400" cy="158" r="20" fill="url(#targetGrad)"><animate attributeName="opacity" values="0;0;0;1;1;0;0" dur="18s" repeatCount="indefinite"/></circle>
          <rect x="395" y="154" width="10" height="9" fill="#ff6b6b"><animate attributeName="opacity" values="0;0;0;1;1;0;0" dur="18s" repeatCount="indefinite"/></rect>
          <text x="330" y="132" fill="#ff6b6b" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="0.1em" opacity="0"><animate attributeName="opacity" values="0;0;0;1;1;0;0" dur="18s" repeatCount="indefinite"/>INFRA · POTHOLE DETECTED</text>

          <!-- Scenario 4: Swachata / litter -->
          <circle cx="320" cy="260" r="16" fill="url(#cleanGrad)"><animate attributeName="opacity" values="0;0;0;0;1;1;0" dur="18s" repeatCount="indefinite"/></circle>
          <rect x="315" y="256" width="10" height="9" fill="#4ade80"><animate attributeName="opacity" values="0;0;0;0;1;1;0" dur="18s" repeatCount="indefinite"/></rect>
          <text x="260" y="237" fill="#4ade80" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="0.1em" opacity="0"><animate attributeName="opacity" values="0;0;0;0;1;1;0" dur="18s" repeatCount="indefinite"/>SWACHATA · LITTER FLAG</text>

          <!-- Scenario 5: Stealth perch -->
          <g>
            <circle cx="200" cy="280" r="3" fill="#4ade80" opacity="0.9"><animate attributeName="opacity" values="0;0;0;0;0;1;0.4" dur="18s" repeatCount="indefinite"/></circle>
            <circle cx="170" cy="265" r="3" fill="#4ade80" opacity="0.9"><animate attributeName="opacity" values="0;0;0;0;0;1;0.4" dur="18s" repeatCount="indefinite"/></circle>
            <circle cx="220" cy="260" r="3" fill="#4ade80" opacity="0.9"><animate attributeName="opacity" values="0;0;0;0;0;1;0.4" dur="18s" repeatCount="indefinite"/></circle>
          </g>
          <text x="140" y="320" fill="#4ade80" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="0.1em" opacity="0"><animate attributeName="opacity" values="0;0;0;0;0;1;0.4" dur="18s" repeatCount="indefinite"/>STEALTH · PERCHED RECON</text>

          <!-- Persistent bee swarm — multi-layer (2-3x larger than before, with bloom glow) -->
          <g filter="url(#vis-bloom)">
            <!-- Lead formation -->
            <circle r="3.4" fill="#22d3ee">
              <animateMotion dur="14s" repeatCount="indefinite" path="M 90 100 C 240 60, 380 140, 520 90 S 720 110, 90 100"/>
            </circle>
            <circle r="3.4" fill="#22d3ee">
              <animateMotion dur="14s" begin="-0.4s" repeatCount="indefinite" path="M 90 100 C 240 60, 380 140, 520 90 S 720 110, 90 100"/>
            </circle>
            <circle r="3.4" fill="#22d3ee">
              <animateMotion dur="14s" begin="-0.8s" repeatCount="indefinite" path="M 90 100 C 240 60, 380 140, 520 90 S 720 110, 90 100"/>
            </circle>
            <!-- Mid trail -->
            <circle r="2.8" fill="#22d3ee" opacity="0.85">
              <animateMotion dur="16s" repeatCount="indefinite" path="M 120 110 C 280 80, 420 140, 580 110 S 720 90, 120 110"/>
            </circle>
            <circle r="2.8" fill="#22d3ee" opacity="0.85">
              <animateMotion dur="16s" begin="-2s" repeatCount="indefinite" path="M 120 110 C 280 80, 420 140, 580 110 S 720 90, 120 110"/>
            </circle>
            <!-- Wide-orbit scouts -->
            <circle r="2.2" fill="#22d3ee" opacity="0.7">
              <animateMotion dur="18s" repeatCount="indefinite" path="M 100 200 Q 400 240 720 200 Q 400 160 100 200"/>
            </circle>
            <circle r="2.2" fill="#22d3ee" opacity="0.7">
              <animateMotion dur="18s" begin="-4s" repeatCount="indefinite" path="M 100 200 Q 400 240 720 200 Q 400 160 100 200"/>
            </circle>
            <circle r="2.2" fill="#22d3ee" opacity="0.7">
              <animateMotion dur="18s" begin="-9s" repeatCount="indefinite" path="M 100 200 Q 400 240 720 200 Q 400 160 100 200"/>
            </circle>
          </g>

          <!-- Target-lock reticles that flash on each scenario beacon -->
          <g fill="none" stroke="#fbbf24" stroke-width="1.2" opacity="0">
            <g transform="translate(180 270)">
              <circle r="22" stroke-dasharray="6 4"><animateTransform attributeName="transform" type="rotate" from="0" to="360" dur="4s" repeatCount="indefinite"/></circle>
              <line x1="-30" y1="0" x2="-14" y2="0"/><line x1="14" y1="0" x2="30" y2="0"/>
              <line x1="0" y1="-30" x2="0" y2="-14"/><line x1="0" y1="14" x2="0" y2="30"/>
              <animate attributeName="opacity" values="0;1;1;0;0;0;0" dur="18s" repeatCount="indefinite"/>
            </g>
            <g transform="translate(620 245)">
              <circle r="26" stroke-dasharray="6 4"><animateTransform attributeName="transform" type="rotate" from="0" to="360" dur="4s" repeatCount="indefinite"/></circle>
              <line x1="-34" y1="0" x2="-18" y2="0"/><line x1="18" y1="0" x2="34" y2="0"/>
              <line x1="0" y1="-34" x2="0" y2="-18"/><line x1="0" y1="18" x2="0" y2="34"/>
              <animate attributeName="opacity" values="0;0;1;1;0;0;0" dur="18s" repeatCount="indefinite"/>
            </g>
            <g transform="translate(400 158)">
              <circle r="24" stroke-dasharray="6 4"><animateTransform attributeName="transform" type="rotate" from="0" to="360" dur="4s" repeatCount="indefinite"/></circle>
              <line x1="-32" y1="0" x2="-16" y2="0"/><line x1="16" y1="0" x2="32" y2="0"/>
              <line x1="0" y1="-32" x2="0" y2="-16"/><line x1="0" y1="16" x2="0" y2="32"/>
              <animate attributeName="opacity" values="0;0;0;1;1;0;0" dur="18s" repeatCount="indefinite"/>
            </g>
          </g>

          <!-- HUD telemetry overlay — top right -->
          <g font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="0.12em">
            <rect x="610" y="10" width="180" height="46" rx="3" fill="#02080d" fill-opacity="0.7" stroke="#22d3ee" stroke-opacity="0.25" stroke-width="0.8"/>
            <text x="620" y="24" fill="#22d3ee">SWARM · STATUS</text>
            <text x="620" y="38" fill="#86efac">[ACTIVE] · 4,872 BEES</text>
            <text x="620" y="50" fill="#7e98a1">EDGE INFERENCE · NOMINAL</text>
            <!-- Pulsing live dot -->
            <circle cx="780" cy="21" r="2.5" fill="#86efac"><animate attributeName="opacity" values="0.3;1;0.3" dur="1.4s" repeatCount="indefinite"/></circle>
          </g>

          <!-- HUD bottom-left -->
          <g font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="0.12em">
            <rect x="10" y="280" width="200" height="32" rx="3" fill="#02080d" fill-opacity="0.7" stroke="#fbbf24" stroke-opacity="0.25" stroke-width="0.8"/>
            <text x="20" y="294" fill="#fbbf24">SCENARIO · LIVE CYCLE</text>
            <text x="20" y="306" fill="#cfd6da">
              <tspan opacity="0"><animate attributeName="opacity" values="1;1;0;0;0;0;0" dur="18s" repeatCount="indefinite"/>01 · BORDER</tspan>
              <tspan opacity="0"><animate attributeName="opacity" values="0;0;1;1;0;0;0" dur="18s" repeatCount="indefinite"/>02 · CROWD</tspan>
              <tspan opacity="0"><animate attributeName="opacity" values="0;0;0;0;1;1;0" dur="18s" repeatCount="indefinite"/>03 · INFRA</tspan>
              <tspan opacity="0"><animate attributeName="opacity" values="0;0;0;0;0;0;1" dur="18s" repeatCount="indefinite"/>04 · SWACHATA / STEALTH</tspan>
