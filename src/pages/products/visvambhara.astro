          <!-- Vertical data-stream lines descending from mother (telemetry uplink visual) -->
          <g stroke="#22d3ee" stroke-width="0.6" opacity="0.5">
            <line x1="200" y1="80" x2="200" y2="280" stroke-dasharray="2 6">
