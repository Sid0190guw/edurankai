---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { ensureVisvambharaAccessSchema, getUserAccess, wordCount } from '@/lib/visvambhara-access';

const user = Astro.locals.user;
let okMsg = '', errMsg = '';

await ensureVisvambharaAccessSchema();

if (Astro.request.method === 'POST') {
  if (!user) {
    return Astro.redirect('/portal/login?next=/products/visvambhara/access');
  }
  try {
    const fd = await Astro.request.formData();
    const note = (fd.get('note') as string || '').trim();
    const cvUrl = (fd.get('cv_url') as string || '').trim();
    const wc = wordCount(note);
    if (!note || !cvUrl) errMsg = 'Both fields are required.';
    else if (wc > 300) errMsg = 'Note exceeds 300 words (current: ' + wc + '). Please tighten and resubmit.';
    else if (!/^https?:\/\/.+/i.test(cvUrl)) errMsg = 'CV link must be a public URL starting with http(s)://';
    else {
      await db.execute(sql`
        INSERT INTO visvambhara_access_requests (user_id, note, cv_url, status)
        VALUES (${user.id}, ${note}, ${cvUrl}, 'pending')
        ON CONFLICT (user_id) DO UPDATE SET
          note = EXCLUDED.note,
          cv_url = EXCLUDED.cv_url,
          status = 'pending',
          reviewed_by_user_id = NULL,
          reviewed_at = NULL,
          reject_reason = NULL,
          created_at = NOW()
      `);
      okMsg = 'Request submitted. We will review and respond inside your portal — no email.';
    }
  } catch (e: any) { errMsg = 'Failed: ' + (e?.message || 'unknown'); }
}

const existing = user ? await getUserAccess(user.id) : null;
---
<BaseLayout
  title="Request Viśvambhara access — EduRankAI"
  description="Apply for access to the Viśvambhara deep documents: architecture, datasheet, CFD wind tunnel, flight profile, 3D viewers. A 300-word note and a CV link are required. Reviewed by the research team.">

  <section style="background:#06121a;color:#e8f3f6;min-height:100vh;padding:60px 5vw 80px;font-family:'Space Grotesk',system-ui,sans-serif;">
    <div style="max-width:760px;margin:0 auto;">
      <a href="/products/visvambhara" style="display:inline-flex;align-items:center;gap:8px;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.18em;color:#7e98a1;text-decoration:none;text-transform:uppercase;margin-bottom:36px;">← Viśvambhara hub</a>

      <p style="font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:0.4em;color:#22d3ee;text-transform:uppercase;margin:0 0 14px;">Restricted Research · Access Required</p>
      <h1 style="font-size:clamp(32px,5vw,52px);line-height:1.05;font-weight:700;letter-spacing:-0.02em;margin:0 0 18px;">Request access</h1>
      <p style="font-size:17px;line-height:1.6;color:#9fc4ce;max-width:580px;margin:0 0 32px;">The architecture, datasheet, CFD tunnel, flight-profile, and 3D viewer documents are gated. Sign in, share a short note on why you want access and your relevant background, and link to your CV. The research team reviews every request.</p>

      {!user && (
        <div style="background:#0a1c25;border:1px solid #ffb347;border-radius:14px;padding:24px;margin-bottom:24px;">
          <p style="font-size:16px;margin:0 0 14px;color:#ffd9a0;"><b>Sign in first.</b> You need an EduRankAI portal account to request access.</p>
          <div style="display:flex;gap:12px;flex-wrap:wrap;">
            <a href="/portal/login?next=/products/visvambhara/access" style="background:#22d3ee;color:#04161b;font-family:'JetBrains Mono',monospace;font-weight:700;font-size:13px;letter-spacing:0.08em;padding:12px 22px;border-radius:9px;text-decoration:none;">Sign in →</a>
            <a href="/portal/signup?next=/products/visvambhara/access" style="border:1px solid rgba(120,200,220,0.3);color:#7fe9f5;font-family:'JetBrains Mono',monospace;font-weight:700;font-size:13px;letter-spacing:0.08em;padding:12px 22px;border-radius:9px;text-decoration:none;">Create account →</a>
          </div>
        </div>
      )}

      {okMsg && <div style="background:rgba(70,230,160,0.10);border:1px solid rgba(70,230,160,0.35);color:#46e6a0;padding:14px 18px;border-radius:10px;margin-bottom:20px;font-size:14px;">{okMsg}</div>}
      {errMsg && <div style="background:rgba(255,100,90,0.10);border:1px solid rgba(255,100,90,0.4);color:#ff9b8e;padding:14px 18px;border-radius:10px;margin-bottom:20px;font-size:14px;">{errMsg}</div>}

      {user && existing && existing.status === 'pending' && (
        <div style="background:#0a1c25;border:1px solid rgba(255,179,71,0.4);border-radius:14px;padding:22px;margin-bottom:24px;">
          <p style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.2em;color:#ffb347;text-transform:uppercase;margin:0 0 8px;">Pending review</p>
          <p style="font-size:15px;line-height:1.6;color:#e8f3f6;margin:0;">We've received your request. The research team will respond inside your portal thread — we do not send email. You can update the note + CV below to add detail at any time.</p>
        </div>
      )}
      {user && existing && existing.status === 'approved' && (
        <div style="background:rgba(70,230,160,0.10);border:1px solid rgba(70,230,160,0.4);border-radius:14px;padding:22px;margin-bottom:24px;">
          <p style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.2em;color:#46e6a0;text-transform:uppercase;margin:0 0 8px;">Approved</p>
          <p style="font-size:15px;line-height:1.6;color:#e8f3f6;margin:0 0 14px;">You have access to the deep documents. Open the modules from the hub.</p>
          <a href="/products/visvambhara" style="background:#46e6a0;color:#04161b;font-family:'JetBrains Mono',monospace;font-weight:700;font-size:13px;letter-spacing:0.08em;padding:12px 22px;border-radius:9px;text-decoration:none;display:inline-block;">Open modules →</a>
        </div>
      )}
      {user && existing && existing.status === 'rejected' && (
        <div style="background:rgba(255,100,90,0.10);border:1px solid rgba(255,100,90,0.4);border-radius:14px;padding:22px;margin-bottom:24px;">
          <p style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.2em;color:#ff9b8e;text-transform:uppercase;margin:0 0 8px;">Not approved</p>
          <p style="font-size:15px;line-height:1.6;color:#e8f3f6;margin:0;">Your request was reviewed and not approved at this time. {existing.reject_reason ? 'Reason: ' + existing.reject_reason + '. ' : ''}You may submit an updated note and CV below.</p>
        </div>
      )}

      {user && (
        <form method="POST" style="background:#0a1c25;border:1px solid rgba(120,200,220,0.18);border-radius:14px;padding:26px;display:flex;flex-direction:column;gap:18px;">
          <div>
            <label style="display:block;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.16em;color:#7fe9f5;text-transform:uppercase;margin-bottom:8px;">Your note · max 300 words</label>
            <textarea name="note" rows="10" required maxlength="3000" placeholder="Why do you need access? What aerospace / propulsion / autonomy / AI background do you bring? Concrete projects, papers, or work that's relevant." style="width:100%;background:#06121a;border:1px solid rgba(120,200,220,0.18);border-radius:9px;padding:14px 16px;color:#e8f3f6;font-family:'Space Grotesk',sans-serif;font-size:15px;line-height:1.6;resize:vertical;outline:none;">{existing?.note || ''}</textarea>
            <p id="wcLine" style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#7e98a1;margin:6px 0 0;">0 / 300 words</p>
          </div>
          <div>
            <label style="display:block;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.16em;color:#7fe9f5;text-transform:uppercase;margin-bottom:8px;">CV link · Drive / public URL</label>
            <input name="cv_url" type="url" required placeholder="https://drive.google.com/file/d/..." value={existing?.cv_url || ''} style="width:100%;background:#06121a;border:1px solid rgba(120,200,220,0.18);border-radius:9px;padding:13px 16px;color:#e8f3f6;font-family:'JetBrains Mono',monospace;font-size:14px;outline:none;" />
            <p style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#7e98a1;margin:6px 0 0;">Make sure the link is publicly accessible (Anyone with the link → Viewer).</p>
          </div>
          <button type="submit" style="background:#22d3ee;color:#04161b;font-family:'JetBrains Mono',monospace;font-weight:700;font-size:14px;letter-spacing:0.08em;padding:15px 26px;border-radius:11px;border:none;cursor:pointer;text-transform:uppercase;">Submit request</button>
        </form>
      )}
    </div>
  </section>

  <script is:inline>
    (function () {
      var ta = document.querySelector('textarea[name="note"]');
      var wcEl = document.getElementById('wcLine');
      if (!ta || !wcEl) return;
      function count() {
        var n = (ta.value || '').trim().split(/\s+/).filter(Boolean).length;
        wcEl.textContent = n + ' / 300 words';
        wcEl.style.color = n > 300 ? '#ff9b8e' : '#7e98a1';
      }
      ta.addEventListener('input', count); count();
    })();
  </script>
</BaseLayout>
