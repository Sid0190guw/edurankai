---
import BaseLayout from '@/layouts/BaseLayout.astro';

const VALUES = [
  {
    num: '01',
    title: 'Reasoning over retrieval',
    body: 'We build models that think, not memorise. Architecture before scale.'
  },
  {
    num: '02',
    title: 'Bharat-first, world-open',
    body: 'Built in India for the world. Our research is rooted in the Indic tradition of inquiry and open to global collaboration.'
  },
  {
    num: '03',
    title: 'Truth over hype',
    body: 'We publish what works, what does not, and why. No demos that do not generalise. No claims that cannot be reproduced.'
  },
  {
    num: '04',
    title: 'Long horizon',
    body: 'We are building for the next decade of compute, including quantum substrates. Short-cycle metrics are not our compass.'
  }
];

const PILLARS = [
  { label: 'HEI', desc: 'The Higher Education Intelligence ranking — universities ranked on truth, not prestige.' },
  { label: 'AquinTutor', desc: 'Adaptive tutoring built on reasoning architectures, not pattern matching.' },
  { label: 'Karate.support', desc: 'Safety, self-defence and well-being infrastructure for students and women.' },
  { label: 'Sambandh', desc: 'Connection layer for collaborative learning communities.' },
  { label: 'Research Lab', desc: 'Foundational models, reasoning systems, quantum-era architectures.' },
];
---
<BaseLayout title="About" description="EduRankAI is a frontier AI research lab building foundational models and reasoning systems for how humanity learns. Built in Bharat, open to the world.">

  <section class="px-[5vw] pt-16 md:pt-24 pb-12 max-w-5xl mx-auto">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-6">About</p>
    <h1 class="font-display text-[clamp(2.5rem,6vw,4.5rem)] font-semibold text-ink leading-[1.05] tracking-tight mb-8 max-w-4xl">
      A research lab betting on <em class="italic text-burn font-medium">reasoning.</em>
    </h1>
    <p class="text-[1.05rem] md:text-[1.15rem] text-ink-soft leading-[1.85] font-light max-w-3xl">
      EduRankAI is a frontier AI lab building foundational models, reasoning systems, and quantum-era architectures — with one orienting question: how does humanity learn, and how do we build machines that learn the same way?
    </p>
  </section>

  <section data-reveal class="px-[5vw] py-12 md:py-16 max-w-5xl mx-auto border-t border-ink/8">
    <h2 class="font-display text-[clamp(1.5rem,3.5vw,2.25rem)] font-semibold text-ink mb-3">Why we exist</h2>
    <p class="text-[1rem] text-ink-soft leading-[1.85] mb-4">
      The current generation of frontier models has shown what scale can do. The next generation will show what scale cannot. Models that score well on benchmarks still reason without understanding — they memorise patterns rather than infer structure.
    </p>
    <p class="text-[1rem] text-ink-soft leading-[1.85]">
      We believe the path to genuinely general — and eventually superhuman — intelligence runs through architecture, not parameter count alone. That belief shapes everything we build, from the HEI ranking to AquinTutor to the lab's long-horizon research.
    </p>
  </section>

  <section data-reveal class="px-[5vw] py-12 md:py-16 max-w-5xl mx-auto border-t border-ink/8">
    <h2 class="font-display text-[clamp(1.5rem,3.5vw,2.25rem)] font-semibold text-ink mb-8">What we value</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      {VALUES.map((v) => (
        <div class="bg-cream-2 border border-ink/8 rounded-2xl p-5 md:p-6">
          <p class="text-[0.7rem] font-mono text-burn mb-2 font-bold">{v.num}</p>
          <h3 class="font-display text-[1.1rem] font-semibold text-ink mb-2">{v.title}</h3>
          <p class="text-[0.9rem] text-ink-soft leading-relaxed">{v.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section data-reveal class="px-[5vw] py-12 md:py-16 max-w-5xl mx-auto border-t border-ink/8">
    <h2 class="font-display text-[clamp(1.5rem,3.5vw,2.25rem)] font-semibold text-ink mb-3">What we build</h2>
    <p class="text-[0.95rem] text-ink-soft leading-relaxed mb-8 max-w-3xl">
      Five interlocking pillars — each tied to the same mission of building better intelligence for how humanity learns.
    </p>
    <div class="space-y-3">
      {PILLARS.map((p) => (
        <div class="bg-white border border-ink/10 rounded-xl p-4 md:p-5 flex flex-col md:flex-row md:items-baseline gap-2 md:gap-6">
          <p class="font-display text-[1rem] font-semibold text-burn shrink-0 md:w-32">{p.label}</p>
          <p class="text-[0.92rem] text-ink-soft leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section data-reveal class="px-[5vw] py-12 md:py-16 max-w-5xl mx-auto border-t border-ink/8">
    <h2 class="font-display text-[clamp(1.5rem,3.5vw,2.25rem)] font-semibold text-ink mb-3">The team</h2>
    <p class="text-[1rem] text-ink-soft leading-[1.85] mb-6 max-w-3xl">
      We are a small, technical team — researchers, engineers, and educators — based out of India and operating globally. The lab is intentionally lean: we believe smaller teams with deeper conviction will produce the breakthroughs of this decade.
    </p>
    <p class="text-[1rem] text-ink-soft leading-[1.85] mb-6 max-w-3xl">
      We hire by demonstrated work, not credentials. If you are working on something that fits our thesis, we want to hear from you.
    </p>
    <div class="flex flex-wrap gap-3">
      <a href="/careers" class="bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.9rem] transition-colors">View open roles -&gt;</a>
      <a href="/contact" class="bg-cream-2 border border-ink/15 hover:border-burn text-ink font-semibold py-2.5 px-5 rounded-lg text-[0.9rem] transition-colors">Get in touch</a>
    </div>
  </section>

</BaseLayout>
