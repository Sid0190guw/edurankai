---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getFounder } from '@/lib/founder';
import { isConfigured } from '@/lib/razorpay';

const f = await getFounder();
if (!f.isPublic) return Astro.redirect('/');

const initials = (f.name || 'F').split(/\s+/).map((x) => x[0]).slice(0, 2).join('').toUpperCase();
const gatewayLive = isConfigured();
// Messaging is gated regardless of whether a direct-line number exists — the
// paid step is the serious-intent filter; the message reaches the founder.
const textGated = f.gateText && f.textPriceChf > 0 && gatewayLive;
const consultGated = f.gateConsult && f.consultPriceChf > 0 && gatewayLive;
const cur = f.currency || 'CHF';
---
<BaseLayout title={(f.name || 'Founder') + ' - EduRankAI'} description={f.tagline || 'Connect with the founder of EduRankAI.'} noindex={true}>
  <div class="fp">
    <!-- Hero -->
    <section class="fp-hero">
      <div class="fp-hero-inner">
        <div class="fp-avatar">
          {f.photoUrl ? <img src={f.photoUrl} alt={f.name} /> : <span>{initials}</span>}
        </div>
        <p class="fp-eyebrow">{f.role || 'Founder'} · EduRankAI</p>
        <h1 class="fp-name">{f.name || 'Founder'}</h1>
        {f.tagline && <p class="fp-tag">{f.tagline}</p>}
        {f.bio && <p class="fp-bio">{f.bio}</p>}
      </div>
      <div class="fp-hero-glow"></div>
    </section>

    <!-- Channels -->
    <section class="fp-channels">
      <article class="fp-card">
        <div class="fp-card-ico text">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <h3>{f.connectLabel || 'Message me directly'}</h3>
        <p>A direct written line to me — read personally. {textGated ? 'A ' + f.textPriceChf + ' ' + cur + ' step keeps it to serious, well-formed asks.' : 'Reach me with a genuine, specific message.'}</p>
        <div class="fp-price">{textGated ? f.textPriceChf + ' ' + cur : 'Free'}</div>
        <button type="button" class="fp-btn burn" data-open="text">{textGated ? 'Write to me' : 'Message me'}</button>
      </article>

      <article class="fp-card feature">
        <div class="fp-card-ico consult">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <h3>Book a consultancy</h3>
        <p>A focused call at a time I can fully commit to. Pick a live slot from my calendar below. If the fit is right, I go out of my way for it.</p>
        <div class="fp-price">{consultGated ? f.consultPriceChf + ' ' + cur : 'Free'}<span> · {f.slotMinutes} min</span></div>
        <button type="button" class="fp-btn ink" data-scrollto="sched">See my calendar</button>
      </article>
    </section>

    <!-- Inline scheduler -->
    <section class="fp-sched" id="sched">
      <div class="fp-sched-head">
        <h2>Book time on my calendar</h2>
        <p>Live availability in <b id="fpTz">{f.timezone}</b>. Select a day, then a time.</p>
      </div>
      <div class="fp-days" id="fpDays"><div class="fp-days-load">Loading availability…</div></div>
      <div class="fp-slots" id="fpSlots"></div>
      <p class="fp-note">Every request is reviewed personally and accepted at my discretion. A paid step is a filter for serious intent, not a purchase of a decision.</p>
    </section>

    <!-- Modal -->
    <div id="fModal" class="fp-modal hidden">
      <div class="fp-modal-box">
        <button type="button" id="fClose" class="fp-modal-x" aria-label="Close"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
        <h2 id="fTitle">Message me</h2>
        <p id="fSub"></p>
        <div id="fSlotChip" class="fp-slotchip hidden"></div>
        <div class="fp-form">
          <input id="fName" placeholder="Your name" />
          <input id="fEmail" type="email" placeholder="Email" />
          <input id="fPhone" placeholder="Phone (optional)" />
          <textarea id="fNote" rows="3" placeholder="Your message — be specific about what you need."></textarea>
        </div>
        <button id="fSend" type="button" class="fp-btn burn full">Continue</button>
        <p id="fMsg" class="fp-modal-msg"></p>
        <div id="fDone" class="hidden fp-modal-done"></div>
      </div>
    </div>
  </div>

  {(textGated || consultGated) && <script is:inline src="https://checkout.razorpay.com/v1/checkout.js"></script>}
  <script is:inline define:vars={{ textGated, consultGated, cur, textPrice: f.textPriceChf, consultPrice: f.consultPriceChf, fname: f.name, durationMin: f.slotMinutes }}>
    (function () {
      var modal = document.getElementById('fModal'), kind = 'text', chosenSlot = null;
      function gv(id) { return (document.getElementById(id).value || '').trim(); }
      function show() { modal.classList.remove('hidden'); }
      function hide() { modal.classList.add('hidden'); }
      document.getElementById('fClose').addEventListener('click', hide);
      modal.addEventListener('click', function (e) { if (e.target === modal) hide(); });
      document.querySelectorAll('[data-scrollto]').forEach(function (b) { b.addEventListener('click', function () { document.getElementById(b.getAttribute('data-scrollto')).scrollIntoView({ behavior: 'smooth' }); }); });

      // ---- scheduler ----
      var daysEl = document.getElementById('fpDays'), slotsEl = document.getElementById('fpSlots'), activeDate = null;
      fetch('/api/founder/slots?days=21').then(function (r) { return r.json(); }).then(function (j) {
        if (!j.ok) { daysEl.innerHTML = '<div class="fp-days-load">Availability unavailable right now.</div>'; return; }
        document.getElementById('fpTz').textContent = j.tz;
        var open = j.days.filter(function (d) { return d.open > 0; });
        if (!open.length) { daysEl.innerHTML = '<div class="fp-days-load">No open times in the next weeks. Please check back.</div>'; return; }
        daysEl.innerHTML = '';
        j.days.forEach(function (d) {
          var b = document.createElement('button'); b.type = 'button'; b.className = 'fp-day' + (d.open ? '' : ' off'); b.disabled = !d.open;
          b.innerHTML = '<span class="wd">' + d.weekday + '</span><span class="dt">' + d.label + '</span><span class="op">' + (d.open ? d.open + ' open' : '—') + '</span>';
          b.addEventListener('click', function () { selectDay(d.date, b); });
          daysEl.appendChild(b);
        });
        var first = open[0]; var firstBtn = Array.prototype.find.call(daysEl.children, function (el) { return !el.disabled; });
        if (firstBtn) selectDay(first.date, firstBtn);
      }).catch(function () { daysEl.innerHTML = '<div class="fp-days-load">Could not load availability.</div>'; });

      function selectDay(date, btn) {
        activeDate = date;
        Array.prototype.forEach.call(daysEl.children, function (el) { el.classList.remove('on'); });
        if (btn) btn.classList.add('on');
        slotsEl.innerHTML = '<div class="fp-slot-load">Loading times…</div>';
        fetch('/api/founder/slots?date=' + encodeURIComponent(date)).then(function (r) { return r.json(); }).then(function (j) {
          if (!j.ok || !j.slots.length) { slotsEl.innerHTML = '<div class="fp-slot-load">No open times this day.</div>'; return; }
          slotsEl.innerHTML = '';
          j.slots.forEach(function (s) {
            var b = document.createElement('button'); b.type = 'button'; b.className = 'fp-slot'; b.textContent = s.label;
            b.addEventListener('click', function () { openBooking('consult', s); });
            slotsEl.appendChild(b);
          });
        });
      }

      function openBooking(k, slot) {
        kind = k; chosenSlot = slot || null;
        var gated = k === 'text' ? textGated : consultGated;
        var price = k === 'text' ? textPrice : consultPrice;
        document.getElementById('fTitle').textContent = k === 'text' ? 'Write to me' : 'Confirm your consultation';
        document.getElementById('fSub').textContent = gated ? ('A ' + price + ' ' + cur + ' step — reviewed personally, accepted at my discretion.') : 'Reviewed personally, accepted at my discretion.';
        var chip = document.getElementById('fSlotChip');
        if (k === 'consult' && slot) { chip.classList.remove('hidden'); chip.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> ' + slot.label + ' · ' + durationMin + ' min'; }
        else chip.classList.add('hidden');
        document.getElementById('fSend').textContent = gated ? ('Continue · ' + price + ' ' + cur) : 'Send';
        document.getElementById('fSend').style.display = '';
        document.getElementById('fMsg').textContent = ''; document.getElementById('fDone').classList.add('hidden');
        show();
      }
      document.querySelectorAll('[data-open]').forEach(function (b) { b.addEventListener('click', function () { openBooking(b.getAttribute('data-open'), null); }); });

      function done(html) { var el = document.getElementById('fDone'); el.innerHTML = html; el.classList.remove('hidden'); document.getElementById('fSend').style.display = 'none'; }

      document.getElementById('fSend').addEventListener('click', function () {
        var name = gv('fName'), email = gv('fEmail'), msg = document.getElementById('fMsg');
        if (!name || !email) { msg.className = 'fp-modal-msg err'; msg.textContent = 'Please add your name and email.'; return; }
        if (kind === 'consult' && !chosenSlot) { msg.className = 'fp-modal-msg err'; msg.textContent = 'Please pick a time slot first.'; return; }
        var payload = { kind: kind, name: name, email: email, phone: gv('fPhone'), note: gv('fNote'), preferred: chosenSlot ? chosenSlot.iso : '', durationMin: durationMin };
        var btn = this; btn.disabled = true; btn.textContent = 'Please wait…';
        fetch('/api/founder/pay/create', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) })
          .then(function (r) { return r.json(); }).then(function (j) {
            btn.disabled = false;
            if (!j.ok) { msg.className = 'fp-modal-msg err'; msg.textContent = j.error || 'Something went wrong.'; btn.textContent = 'Continue'; return; }
            if (j.free) {
              if (kind === 'text' && j.revealHref) done('<a href="' + j.revealHref + '" target="_blank" rel="noopener" class="fp-btn burn">Open direct line</a>');
              else done('<p class="ok">Request sent. I will be in touch to confirm.</p>');
              return;
            }
            var rzp = new Razorpay({
              key: j.keyId, order_id: j.orderId, amount: j.amountPaise, currency: 'INR', name: 'EduRankAI',
              description: (kind === 'text' ? 'Direct line to ' : 'Consultation with ') + (fname || 'the founder'),
              prefill: { name: name, email: email, contact: gv('fPhone') }, theme: { color: '#FF4F00' },
              handler: function (resp) {
                msg.className = 'fp-modal-msg'; msg.textContent = 'Confirming…';
                fetch('/api/founder/pay/verify', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ razorpay_order_id: resp.razorpay_order_id, razorpay_payment_id: resp.razorpay_payment_id, razorpay_signature: resp.razorpay_signature, kind: kind }) })
                  .then(function (r) { return r.json(); }).then(function (v) {
                    msg.textContent = '';
                    if (!v.ok) { msg.className = 'fp-modal-msg err'; msg.textContent = v.error || 'Could not confirm payment.'; return; }
                    if (v.kind === 'text') done('<p class="ok">Payment received — your message has reached me.</p>' + (v.revealHref ? '<a href="' + v.revealHref + '" target="_blank" rel="noopener" class="fp-btn burn">' + (v.label || 'Open direct line') + '</a>' : ''));
                    else done('<p class="ok">Confirmed. Your time is held on my calendar and I will reach out.</p>' + (v.calendarHref ? '<a href="' + v.calendarHref + '" target="_blank" rel="noopener" class="fp-btn ink">Add to your calendar</a>' : ''));
                  });
              },
              modal: { ondismiss: function () { msg.className = 'fp-modal-msg err'; msg.textContent = 'Payment cancelled.'; btn.textContent = 'Continue · ' + (kind === 'text' ? textPrice : consultPrice) + ' ' + cur; } }
            });
            rzp.open(); btn.textContent = 'Continue · ' + (kind === 'text' ? textPrice : consultPrice) + ' ' + cur;
          }).catch(function () { btn.disabled = false; btn.textContent = 'Continue'; msg.className = 'fp-modal-msg err'; msg.textContent = 'Network error. Try again.'; });
      });
    })();
  </script>

  <style>
    .fp { --bg:#faf7f2; }
    .fp-hero { position:relative; text-align:center; padding:56px 5vw 34px; overflow:hidden; }
    .fp-hero-inner { position:relative; z-index:2; max-width:640px; margin:0 auto; }
    .fp-hero-glow { position:absolute; top:-120px; left:50%; transform:translateX(-50%); width:520px; height:340px; background:radial-gradient(closest-side, rgba(255,79,0,0.14), transparent); z-index:1; pointer-events:none; }
    .fp-avatar { width:96px; height:96px; margin:0 auto 18px; border-radius:24px; overflow:hidden; border:1px solid rgba(26,21,16,0.1); box-shadow:0 12px 40px rgba(0,0,0,0.1); background:#fff3ee; display:flex; align-items:center; justify-content:center; }
    .fp-avatar img { width:100%; height:100%; object-fit:cover; }
    .fp-avatar span { font-family:'Fraunces',Georgia,serif; font-size:2.2rem; font-weight:700; color:#FF4F00; }
    .fp-eyebrow { font-size:0.66rem; font-family:'Geist Mono',monospace; text-transform:uppercase; letter-spacing:0.18em; color:#FF4F00; font-weight:700; margin:0 0 6px; }
    .fp-name { font-family:'Fraunces',Georgia,serif; font-size:clamp(2.1rem,6vw,3.2rem); font-weight:600; color:#1a1510; margin:0; letter-spacing:-0.015em; line-height:1.03; }
    .fp-tag { font-size:1.05rem; color:#6b5d49; margin:10px 0 0; }
    .fp-bio { font-size:0.96rem; color:#4a4238; line-height:1.85; margin:16px auto 0; max-width:560px; white-space:pre-line; font-weight:300; }
    .fp-channels { display:grid; grid-template-columns:1fr 1fr; gap:16px; max-width:820px; margin:8px auto 0; padding:0 5vw; }
    @media (max-width:680px){ .fp-channels { grid-template-columns:1fr; } }
    .fp-card { background:#fff; border:1px solid rgba(26,21,16,0.1); border-radius:20px; padding:22px; display:flex; flex-direction:column; transition:transform .2s, box-shadow .2s, border-color .2s; }
    .fp-card:hover { transform:translateY(-3px); box-shadow:0 18px 50px rgba(0,0,0,0.08); border-color:rgba(255,79,0,0.3); }
    .fp-card.feature { background:linear-gradient(160deg,#fff,#fff6f1); }
    .fp-card-ico { width:44px; height:44px; border-radius:13px; display:flex; align-items:center; justify-content:center; margin-bottom:12px; }
    .fp-card-ico.text { background:rgba(255,79,0,0.1); color:#FF4F00; }
    .fp-card-ico.consult { background:#1a1510; color:#FF9066; }
    .fp-card h3 { font-family:'Fraunces',Georgia,serif; font-size:1.25rem; font-weight:600; color:#1a1510; margin:0 0 6px; }
    .fp-card p { font-size:0.86rem; color:#6b5d49; line-height:1.6; margin:0 0 14px; flex:1; }
    .fp-price { font-family:'Geist Mono',monospace; font-size:1.35rem; font-weight:700; color:#1a1510; margin-bottom:12px; }
    .fp-price span { font-size:0.8rem; color:#9a8f84; font-weight:400; }
    .fp-btn { display:inline-flex; align-items:center; justify-content:center; gap:6px; font-size:0.9rem; font-weight:600; padding:12px 20px; border-radius:12px; border:none; cursor:pointer; text-decoration:none; transition:opacity .15s, transform .1s; }
    .fp-btn:active { transform:scale(0.98); }
    .fp-btn.burn { background:#FF4F00; color:#fff; } .fp-btn.burn:hover { opacity:0.92; }
    .fp-btn.ink { background:#1a1510; color:#fff; } .fp-btn.ink:hover { opacity:0.92; }
    .fp-btn.full { width:100%; margin-top:6px; }
    .fp-sched { max-width:820px; margin:40px auto 60px; padding:26px 5vw; }
    .fp-sched-head h2 { font-family:'Fraunces',Georgia,serif; font-size:1.6rem; font-weight:600; color:#1a1510; margin:0 0 4px; }
    .fp-sched-head p { font-size:0.86rem; color:#6b5d49; margin:0 0 18px; }
    .fp-days { display:flex; gap:8px; overflow-x:auto; padding-bottom:8px; scroll-snap-type:x mandatory; }
    .fp-days-load, .fp-slot-load { color:#9a8f84; font-size:0.85rem; padding:14px 0; }
    .fp-day { flex:0 0 auto; scroll-snap-align:start; min-width:78px; background:#fff; border:1px solid rgba(26,21,16,0.12); border-radius:14px; padding:11px 10px; cursor:pointer; display:flex; flex-direction:column; align-items:center; gap:2px; transition:border-color .15s, transform .1s; }
    .fp-day:hover:not(.off) { border-color:#FF4F00; }
    .fp-day.on { background:#1a1510; border-color:#1a1510; }
    .fp-day.on .wd, .fp-day.on .dt { color:#fff; } .fp-day.on .op { color:#FF9066; }
    .fp-day.off { opacity:0.4; cursor:not-allowed; }
    .fp-day .wd { font-size:0.66rem; text-transform:uppercase; letter-spacing:0.08em; color:#9a8f84; font-weight:700; }
    .fp-day .dt { font-size:0.9rem; font-weight:700; color:#1a1510; }
    .fp-day .op { font-size:0.62rem; color:#1c7a45; font-weight:600; }
    .fp-slots { display:flex; flex-wrap:wrap; gap:8px; margin-top:16px; }
    .fp-slot { background:#fff; border:1px solid rgba(26,21,16,0.14); border-radius:10px; padding:9px 15px; font-size:0.86rem; font-weight:600; color:#1a1510; cursor:pointer; font-family:'Geist Mono',monospace; transition:all .12s; }
    .fp-slot:hover { background:#FF4F00; border-color:#FF4F00; color:#fff; transform:translateY(-1px); }
    .fp-note { font-size:0.76rem; color:#9a8f84; line-height:1.6; margin-top:22px; }
    .fp-modal { position:fixed; inset:0; z-index:90; display:flex; align-items:center; justify-content:center; background:rgba(26,21,16,0.5); padding:16px; backdrop-filter:blur(3px); }
    .fp-modal.hidden { display:none; }
    .fp-modal-box { background:var(--bg); width:100%; max-width:440px; border-radius:22px; padding:26px; position:relative; box-shadow:0 30px 80px rgba(0,0,0,0.3); }
    .fp-modal-x { position:absolute; top:14px; right:14px; color:#9a8f84; background:none; border:none; cursor:pointer; }
    .fp-modal-box h2 { font-family:'Fraunces',Georgia,serif; font-size:1.4rem; font-weight:600; color:#1a1510; margin:0 0 4px; }
    .fp-modal-box > p#fSub { font-size:0.82rem; color:#6b5d49; margin:0 0 14px; }
    .fp-slotchip { display:inline-flex; align-items:center; gap:6px; background:#fff3ee; border:1px solid #ffd4bc; color:#c2410c; font-size:0.82rem; font-weight:700; padding:7px 12px; border-radius:10px; margin-bottom:14px; }
    .fp-slotchip.hidden { display:none; }
    .fp-form { display:flex; flex-direction:column; gap:9px; }
    .fp-form input, .fp-form textarea { width:100%; background:#fff; border:1px solid rgba(26,21,16,0.12); border-radius:11px; padding:11px 13px; font-size:0.9rem; color:#1a1510; outline:none; font-family:inherit; }
    .fp-form input:focus, .fp-form textarea:focus { border-color:#FF4F00; }
    .fp-modal-msg { font-size:0.82rem; text-align:center; margin:12px 0 0; min-height:1.1em; color:#6b5d49; }
    .fp-modal-msg.err { color:#b3382c; }
    .fp-modal-done { text-align:center; margin-top:14px; }
    .fp-modal-done .ok { color:#1c7a45; font-weight:600; margin:0 0 12px; }
    .fp-modal-done .fp-btn { display:inline-flex; }
    .hidden { display:none; }
  </style>
</BaseLayout>
