---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getFounder } from '@/lib/founder';
import { isConfigured } from '@/lib/razorpay';

const f = await getFounder();
if (!f.isPublic) return Astro.redirect('/');

const gatewayLive = isConfigured();
const textGated = f.gateText && f.textPriceChf > 0 && gatewayLive;
const consultGated = f.gateConsult && f.consultPriceChf > 0 && gatewayLive;
const cur = f.currency || 'CHF';
const nameParts = (f.name || 'Founder').split(/\s+/);
---
<BaseLayout title={(f.name || 'Founder') + ' - EduRankAI'} description={f.tagline || ''} noindex={true} showNav={false} showFooter={false}>
  <div class="fp">
    <header class="fp-mast">
      <a href="/" class="fp-mast-brand">EduRank<span>AI</span></a>
      <span class="fp-mast-meta">The Founder&rsquo;s Desk &middot; Private</span>
    </header>

    <section class="fp-lede">
      <div class="fp-lede-l">
        <p class="fp-kick">{f.role || 'Founder'} &mdash; EduRankAI</p>
        <h1 class="fp-name">
          {nameParts.map((w, i) => <span>{w}{i < nameParts.length - 1 ? <br/> : <span class="fp-dot">.</span>}</span>)}
        </h1>
        {f.tagline && <p class="fp-tag">{f.tagline}</p>}
      </div>
      <div class="fp-lede-r">
        {f.photoUrl && <img src={f.photoUrl} alt={f.name} class="fp-portrait" />}
        {f.bio && <p class="fp-bio">{f.bio}</p>}
      </div>
    </section>

    <div class="fp-rule"></div>

    <section class="fp-index">
      <p class="fp-index-cap">Two ways to reach me &mdash; each accepted at my discretion</p>

      <div class="fp-row" data-open="text" role="button" tabindex="0">
        <span class="fp-num">01</span>
        <span class="fp-row-body">
          <span class="fp-row-title">{f.connectLabel || 'A written line'}</span>
          <span class="fp-row-desc">A direct message, read personally. {textGated ? 'The step below keeps it to serious, well-formed asks.' : 'Reach me with something specific.'}</span>
        </span>
        <span class="fp-row-price">{textGated ? f.textPriceChf : '—'}<em>{textGated ? cur : 'free'}</em></span>
        <span class="fp-row-go">Write &rarr;</span>
      </div>

      <div class="fp-row" data-scrollto="sched" role="button" tabindex="0">
        <span class="fp-num">02</span>
        <span class="fp-row-body">
          <span class="fp-row-title">A conversation</span>
          <span class="fp-row-desc">A {f.slotMinutes}-minute call at a time I can fully commit to. If the fit is right, I go out of my way for it.</span>
        </span>
        <span class="fp-row-price">{consultGated ? f.consultPriceChf : '—'}<em>{consultGated ? cur : 'free'}</em></span>
        <span class="fp-row-go">Calendar &darr;</span>
      </div>
    </section>

    <section class="fp-sched" id="sched">
      <div class="fp-sched-head">
        <p class="fp-kick">Availability</p>
        <h2 class="fp-sched-h">Choose a time.</h2>
        <p class="fp-sched-sub">Live openings in <b id="fpTz">{f.timezone}</b>. Select a day, then an hour.</p>
      </div>
      <div class="fp-days" id="fpDays"><div class="fp-load">Loading availability&hellip;</div></div>
      <div class="fp-slots" id="fpSlots"></div>
      <p class="fp-foot">Every request is reviewed personally. A paid step is a filter for serious intent &mdash; not a purchase of a decision.</p>
    </section>
  </div>

  <div id="fModal" class="fp-modal hidden">
    <div class="fp-sheet">
      <button type="button" id="fClose" class="fp-sheet-x" aria-label="Close">Close &times;</button>
      <p class="fp-kick" id="fTitle">A written line</p>
      <p class="fp-sheet-sub" id="fSub"></p>
      <div id="fSlotChip" class="fp-sheet-slot hidden"></div>
      <div class="fp-fields">
        <input id="fName" placeholder="Your name" />
        <input id="fEmail" type="email" placeholder="Email" />
        <input id="fPhone" placeholder="Phone (optional)" />
        <textarea id="fNote" rows="3" placeholder="Your message — be specific about what you need."></textarea>
      </div>
      <button id="fSend" type="button" class="fp-btn burn">Continue</button>
      <p id="fMsg" class="fp-sheet-msg"></p>
      <div id="fDone" class="hidden fp-sheet-done"></div>
    </div>
  </div>

  {(textGated || consultGated) && <script is:inline src="https://checkout.razorpay.com/v1/checkout.js"></script>}
  <script is:inline define:vars={{ textGated, consultGated, cur, textPrice: f.textPriceChf, consultPrice: f.consultPriceChf, fname: f.name, durationMin: f.slotMinutes }}>
    (function () {
      var modal = document.getElementById('fModal'), kind = 'text', chosenSlot = null;
      function gv(id) { return (document.getElementById(id).value || '').trim(); }
      function show() { modal.classList.remove('hidden'); }
      function hide() { modal.classList.add('hidden'); }
      document.getElementById('fClose').addEventListener('click', hide);
      modal.addEventListener('click', function (e) { if (e.target === modal) hide(); });
      document.querySelectorAll('[data-scrollto]').forEach(function (b) { b.addEventListener('click', function () { document.getElementById(b.getAttribute('data-scrollto')).scrollIntoView({ behavior: 'smooth' }); }); });

      var daysEl = document.getElementById('fpDays'), slotsEl = document.getElementById('fpSlots');
      fetch('/api/founder/slots?days=21').then(function (r) { return r.json(); }).then(function (j) {
        if (!j.ok) { daysEl.innerHTML = '<div class="fp-load">Availability unavailable right now.</div>'; return; }
        document.getElementById('fpTz').textContent = j.tz;
        var open = j.days.filter(function (d) { return d.open > 0; });
        if (!open.length) { daysEl.innerHTML = '<div class="fp-load">No open times in the coming weeks. Please check back.</div>'; return; }
        daysEl.innerHTML = '';
        j.days.forEach(function (d) {
          var b = document.createElement('button'); b.type = 'button'; b.className = 'fp-day' + (d.open ? '' : ' off'); b.disabled = !d.open;
          b.innerHTML = '<span class="wd">' + d.weekday + '</span><span class="dt">' + d.label + '</span><span class="op">' + (d.open ? d.open : '') + '</span>';
          b.addEventListener('click', function () { selectDay(d.date, b); });
          daysEl.appendChild(b);
        });
        var firstBtn = Array.prototype.find.call(daysEl.children, function (el) { return !el.disabled; });
        if (firstBtn) selectDay(open[0].date, firstBtn);
      }).catch(function () { daysEl.innerHTML = '<div class="fp-load">Could not load availability.</div>'; });

      function selectDay(date, btn) {
        Array.prototype.forEach.call(daysEl.children, function (el) { el.classList.remove('on'); });
        if (btn) btn.classList.add('on');
        slotsEl.innerHTML = '<div class="fp-load">Loading times&hellip;</div>';
        fetch('/api/founder/slots?date=' + encodeURIComponent(date)).then(function (r) { return r.json(); }).then(function (j) {
          if (!j.ok || !j.slots.length) { slotsEl.innerHTML = '<div class="fp-load">No open times this day.</div>'; return; }
          slotsEl.innerHTML = '';
          j.slots.forEach(function (s) {
            var b = document.createElement('button'); b.type = 'button'; b.className = 'fp-slot'; b.textContent = s.label;
            b.addEventListener('click', function () { openBooking('consult', s); });
            slotsEl.appendChild(b);
          });
        });
      }

      function openBooking(k, slot) {
        kind = k; chosenSlot = slot || null;
        var gated = k === 'text' ? textGated : consultGated;
        var price = k === 'text' ? textPrice : consultPrice;
        document.getElementById('fTitle').textContent = k === 'text' ? 'A written line' : 'Confirm your time';
        document.getElementById('fSub').textContent = gated ? ('A ' + price + ' ' + cur + ' step — reviewed personally, accepted at my discretion.') : 'Reviewed personally, accepted at my discretion.';
        var chip = document.getElementById('fSlotChip');
        if (k === 'consult' && slot) { chip.classList.remove('hidden'); chip.textContent = slot.label + '  ·  ' + durationMin + ' min'; }
        else chip.classList.add('hidden');
        document.getElementById('fSend').textContent = gated ? ('Continue — ' + price + ' ' + cur) : 'Send';
        document.getElementById('fSend').style.display = '';
        document.getElementById('fMsg').textContent = ''; document.getElementById('fDone').classList.add('hidden');
        show();
      }
      document.querySelectorAll('[data-open]').forEach(function (b) { b.addEventListener('click', function () { openBooking(b.getAttribute('data-open'), null); }); });

      function done(html) { var el = document.getElementById('fDone'); el.innerHTML = html; el.classList.remove('hidden'); document.getElementById('fSend').style.display = 'none'; }

      document.getElementById('fSend').addEventListener('click', function () {
        var name = gv('fName'), email = gv('fEmail'), msg = document.getElementById('fMsg');
        if (!name || !email) { msg.className = 'fp-sheet-msg err'; msg.textContent = 'Please add your name and email.'; return; }
        if (kind === 'consult' && !chosenSlot) { msg.className = 'fp-sheet-msg err'; msg.textContent = 'Please pick a time first.'; return; }
        var payload = { kind: kind, name: name, email: email, phone: gv('fPhone'), note: gv('fNote'), preferred: chosenSlot ? chosenSlot.iso : '', durationMin: durationMin };
        var btn = this; btn.disabled = true; btn.textContent = 'Please wait…';
        fetch('/api/founder/pay/create', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) })
          .then(function (r) { return r.json(); }).then(function (j) {
            btn.disabled = false;
            if (!j.ok) { msg.className = 'fp-sheet-msg err'; msg.textContent = j.error || 'Something went wrong.'; btn.textContent = 'Continue'; return; }
            if (j.free) {
              if (kind === 'text' && j.revealHref) done('<a href="' + j.revealHref + '" target="_blank" rel="noopener" class="fp-btn burn">Open direct line</a>');
              else done('<p class="ok">Request sent. I will be in touch to confirm.</p>');
              return;
            }
            var rzp = new Razorpay({
              key: j.keyId, order_id: j.orderId, amount: j.amountPaise, currency: 'INR', name: 'EduRankAI',
              description: (kind === 'text' ? 'Direct line to ' : 'Consultation with ') + (fname || 'the founder'),
              prefill: { name: name, email: email, contact: gv('fPhone') }, theme: { color: '#FF4F00' },
              handler: function (resp) {
                msg.className = 'fp-sheet-msg'; msg.textContent = 'Confirming…';
                fetch('/api/founder/pay/verify', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ razorpay_order_id: resp.razorpay_order_id, razorpay_payment_id: resp.razorpay_payment_id, razorpay_signature: resp.razorpay_signature, kind: kind }) })
                  .then(function (r) { return r.json(); }).then(function (v) {
                    msg.textContent = '';
                    if (!v.ok) { msg.className = 'fp-sheet-msg err'; msg.textContent = v.error || 'Could not confirm payment.'; return; }
                    if (v.kind === 'text') done('<p class="ok">Payment received — your message has reached me.</p>' + (v.revealHref ? '<a href="' + v.revealHref + '" target="_blank" rel="noopener" class="fp-btn burn">' + (v.label || 'Open direct line') + '</a>' : ''));
                    else done('<p class="ok">Confirmed. Your time is held on my calendar and I will reach out.</p>' + (v.calendarHref ? '<a href="' + v.calendarHref + '" target="_blank" rel="noopener" class="fp-btn ink">Add to your calendar</a>' : ''));
                  });
              },
              modal: { ondismiss: function () { msg.className = 'fp-sheet-msg err'; msg.textContent = 'Payment cancelled.'; btn.textContent = 'Continue — ' + (kind === 'text' ? textPrice : consultPrice) + ' ' + cur; } }
            });
            rzp.open(); btn.textContent = 'Continue — ' + (kind === 'text' ? textPrice : consultPrice) + ' ' + cur;
          }).catch(function () { btn.disabled = false; btn.textContent = 'Continue'; msg.className = 'fp-sheet-msg err'; msg.textContent = 'Network error. Try again.'; });
      });
    })();
  </script>

  <style>
    :root { --pp:#f1ebdf; --ink:#171310; --soft:#6b6152; --line:rgba(23,19,16,0.16); --rust:#e8420c; }
    .fp { background:var(--pp); color:var(--ink); min-height:100vh; padding:0 clamp(20px,7vw,90px) 90px;
      font-family:'Cormorant Garamond',Georgia,serif; -webkit-font-smoothing:antialiased; }
    .fp ::selection { background:var(--rust); color:#fff; }

    .fp-mast { display:flex; align-items:baseline; justify-content:space-between; padding:22px 0 20px; }
    .fp-mast-brand { font-family:'Instrument Serif',Georgia,serif; font-size:1.15rem; font-weight:600; letter-spacing:-0.01em; color:var(--ink); text-decoration:none; }
    .fp-mast-brand span { color:var(--rust); }
    .fp-mast-meta { font-family:'Geist Mono',ui-monospace,monospace; font-size:0.64rem; text-transform:uppercase; letter-spacing:0.24em; color:var(--soft); }

    .fp-kick { font-family:'Geist Mono',ui-monospace,monospace; font-size:0.66rem; text-transform:uppercase; letter-spacing:0.26em; color:var(--rust); margin:0 0 18px; font-weight:500; }

    .fp-lede { display:grid; grid-template-columns:1.35fr 1fr; gap:40px; align-items:end; padding:clamp(30px,7vw,80px) 0 clamp(26px,5vw,54px); }
    @media (max-width:820px){ .fp-lede { grid-template-columns:1fr; gap:26px; align-items:start; } }
    .fp-name { font-family:'Instrument Serif',Georgia,serif; font-weight:400; font-size:clamp(3.4rem,12vw,7.2rem); line-height:0.9; letter-spacing:-0.01em; margin:0; color:var(--ink); }
    .fp-name .fp-dot { color:var(--rust); }
    .fp-tag { font-size:clamp(1.15rem,2.4vw,1.5rem); color:var(--soft); margin:22px 0 0; font-style:italic; max-width:30ch; line-height:1.35; }
    .fp-lede-r { padding-bottom:8px; }
    .fp-portrait { width:120px; height:150px; object-fit:cover; filter:grayscale(0.15) contrast(1.03); margin-bottom:16px; display:block; }
    .fp-bio { font-size:1.12rem; line-height:1.62; color:var(--ink); margin:0; max-width:42ch; white-space:pre-line; }

    .fp-rule { height:1px; background:var(--ink); opacity:0.85; margin:0; }

    .fp-index { padding:8px 0 clamp(40px,7vw,80px); }
    .fp-index-cap { font-family:'Geist Mono',ui-monospace,monospace; font-size:0.66rem; text-transform:uppercase; letter-spacing:0.16em; color:var(--soft); margin:20px 0 8px; }
    .fp-row { display:grid; grid-template-columns:auto 1fr auto auto; align-items:baseline; gap:clamp(16px,4vw,54px);
      padding:30px 0; border-bottom:1px solid var(--line); cursor:pointer; position:relative; }
    .fp-row:first-of-type { border-top:1px solid var(--line); }
    .fp-row:focus-visible { outline:none; } .fp-row:focus-visible .fp-row-title { color:var(--rust); }
    .fp-num { font-family:'Instrument Serif',Georgia,serif; font-size:clamp(1.4rem,3vw,2.1rem); font-weight:400; color:var(--rust); line-height:1; }
    .fp-row-title { font-family:'Instrument Serif',Georgia,serif; font-size:clamp(1.7rem,4vw,2.6rem); font-weight:400; letter-spacing:-0.02em; display:block; transition:color .18s; line-height:1.05; }
    .fp-row-desc { display:block; font-size:1.06rem; color:var(--soft); line-height:1.5; margin-top:8px; max-width:52ch; }
    .fp-row-price { font-family:'Geist Mono',ui-monospace,monospace; font-size:clamp(1.4rem,3vw,2rem); font-variant-numeric:tabular-nums; white-space:nowrap; align-self:center; }
    .fp-row-price em { font-style:normal; font-size:0.5em; text-transform:uppercase; letter-spacing:0.14em; color:var(--soft); margin-left:6px; }
    .fp-row-go { font-family:'Geist Mono',ui-monospace,monospace; font-size:0.72rem; text-transform:uppercase; letter-spacing:0.14em; color:var(--soft); white-space:nowrap; align-self:center; transition:color .18s; }
    .fp-row:hover .fp-row-title { color:var(--rust); }
    .fp-row:hover .fp-row-go { color:var(--ink); }
    @media (max-width:640px){ .fp-row { grid-template-columns:auto 1fr; grid-template-areas:'num body' '. price' '. go'; gap:6px 18px; }
      .fp-num { grid-area:num; } .fp-row-body { grid-area:body; } .fp-row-price { grid-area:price; align-self:start; margin-top:10px; }
      .fp-row-go { grid-area:go; align-self:start; margin-top:6px; } }

    .fp-sched { padding-top:clamp(20px,4vw,40px); }
    .fp-sched-h { font-family:'Instrument Serif',Georgia,serif; font-weight:400; font-size:clamp(2.2rem,6vw,3.6rem); letter-spacing:-0.03em; margin:0; line-height:1; }
    .fp-sched-sub { font-size:1.06rem; color:var(--soft); margin:14px 0 26px; }
    .fp-sched-sub b { color:var(--ink); font-weight:600; font-style:italic; }
    .fp-load { font-family:'Geist Mono',ui-monospace,monospace; font-size:0.78rem; color:var(--soft); padding:14px 0; letter-spacing:0.02em; }
    .fp-days { display:flex; gap:0; overflow-x:auto; border-top:1px solid var(--line); border-bottom:1px solid var(--line); }
    .fp-day { flex:0 0 auto; min-width:92px; background:transparent; border:none; border-right:1px solid var(--line); padding:16px 14px 14px; cursor:pointer;
      display:flex; flex-direction:column; gap:5px; text-align:left; transition:background .15s; font-family:inherit; }
    .fp-day:first-child { border-left:1px solid var(--line); }
    .fp-day:hover:not(.off) { background:rgba(23,19,16,0.04); }
    .fp-day.on { background:var(--ink); }
    .fp-day.on .wd { color:var(--rust); } .fp-day.on .dt { color:var(--pp); } .fp-day.on .op { color:rgba(241,235,223,0.6); }
    .fp-day.off { opacity:0.32; cursor:not-allowed; }
    .fp-day .wd { font-family:'Geist Mono',ui-monospace,monospace; font-size:0.6rem; text-transform:uppercase; letter-spacing:0.18em; color:var(--soft); }
    .fp-day .dt { font-family:'Instrument Serif',Georgia,serif; font-size:1.2rem; font-weight:400; letter-spacing:-0.01em; }
    .fp-day .op { font-family:'Geist Mono',ui-monospace,monospace; font-size:0.58rem; letter-spacing:0.08em; color:var(--rust); min-height:0.8em; }
    .fp-slots { display:flex; flex-wrap:wrap; gap:0; margin-top:0; }
    .fp-slot { background:transparent; border:none; border-bottom:1px solid var(--line); border-right:1px solid var(--line); padding:14px 22px;
      font-family:'Geist Mono',ui-monospace,monospace; font-size:0.86rem; letter-spacing:0.04em; color:var(--ink); cursor:pointer; transition:color .14s, background .14s; }
    .fp-slot:hover { background:var(--rust); color:#fff; }
    .fp-foot { font-size:1rem; color:var(--soft); line-height:1.6; margin-top:34px; max-width:60ch; font-style:italic; }

    .fp-btn { display:inline-block; font-family:'Geist Mono',ui-monospace,monospace; font-size:0.74rem; text-transform:uppercase; letter-spacing:0.14em;
      padding:15px 26px; border:1px solid var(--ink); cursor:pointer; text-decoration:none; background:transparent; color:var(--ink); transition:background .16s, color .16s; }
    .fp-btn.burn { background:var(--ink); color:var(--pp); border-color:var(--ink); }
    .fp-btn.burn:hover { background:var(--rust); border-color:var(--rust); }
    .fp-btn.ink:hover { background:var(--ink); color:var(--pp); }

    .fp-modal { position:fixed; inset:0; z-index:90; display:flex; align-items:flex-end; justify-content:center; background:rgba(23,19,16,0.62); padding:0; }
    @media (min-width:640px){ .fp-modal { align-items:center; padding:20px; } }
    .fp-modal.hidden { display:none; }
    .fp-sheet { background:var(--pp); width:100%; max-width:440px; padding:30px 26px 26px; position:relative; border-top:3px solid var(--rust); }
    @media (min-width:640px){ .fp-sheet { border:1px solid var(--ink); border-top:3px solid var(--rust); } }
    .fp-sheet-x { position:absolute; top:16px; right:20px; font-family:'Geist Mono',ui-monospace,monospace; font-size:0.66rem; text-transform:uppercase; letter-spacing:0.12em; color:var(--soft); background:none; border:none; cursor:pointer; }
    .fp-sheet-x:hover { color:var(--ink); }
    .fp-sheet .fp-kick { margin-bottom:8px; }
    .fp-sheet-sub { font-size:1.02rem; color:var(--soft); margin:0 0 16px; line-height:1.4; }
    .fp-sheet-slot { font-family:'Geist Mono',ui-monospace,monospace; font-size:0.78rem; letter-spacing:0.04em; color:var(--rust); border:1px solid var(--line); padding:9px 12px; margin-bottom:16px; display:inline-block; }
    .fp-sheet-slot.hidden { display:none; }
    .fp-fields { display:flex; flex-direction:column; gap:0; border:1px solid var(--line); }
    .fp-fields input, .fp-fields textarea { width:100%; background:transparent; border:none; border-bottom:1px solid var(--line); padding:13px 14px; font-size:1.05rem; font-family:inherit; color:var(--ink); outline:none; }
    .fp-fields textarea { border-bottom:none; resize:vertical; }
    .fp-fields input:focus, .fp-fields textarea:focus { background:rgba(232,66,12,0.04); }
    .fp-fields input::placeholder, .fp-fields textarea::placeholder { color:var(--soft); opacity:0.7; }
    #fSend { width:100%; margin-top:16px; }
    .fp-sheet-msg { font-size:0.95rem; text-align:center; margin:12px 0 0; min-height:1.1em; color:var(--soft); }
    .fp-sheet-msg.err { color:#b3382c; }
    .fp-sheet-done { text-align:center; margin-top:16px; }
    .fp-sheet-done .ok { color:var(--ink); margin:0 0 14px; font-size:1.08rem; }
    .hidden { display:none; }
  </style>
</BaseLayout>
