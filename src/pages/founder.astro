---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getFounder } from '@/lib/founder';
import { isConfigured } from '@/lib/razorpay';

const f = await getFounder();
if (!f.isPublic) return Astro.redirect('/');

const initials = (f.name || 'F').split(/\s+/).map((x) => x[0]).slice(0, 2).join('').toUpperCase();
const gatewayLive = isConfigured();
const textGated = f.gateText && f.textPriceChf > 0 && gatewayLive && !!f.connectNumber;
const consultGated = f.gateConsult && f.consultPriceChf > 0 && gatewayLive;
const cur = f.currency || 'CHF';
---
<BaseLayout title={(f.name || 'Founder') + ' - EduRankAI'} description={f.tagline || 'Connect with the founder of EduRankAI.'} noindex={true}>
  <section class="px-[5vw] py-14 md:py-20 max-w-3xl mx-auto">
    <div class="flex flex-col sm:flex-row sm:items-center gap-6 mb-9">
      {f.photoUrl
        ? <img src={f.photoUrl} alt={f.name} class="w-28 h-28 rounded-2xl object-cover border border-ink/10 shrink-0" />
        : <div class="w-28 h-28 rounded-2xl bg-burn-pale border border-burn-dim flex items-center justify-center text-burn font-display text-3xl font-bold shrink-0">{initials}</div>}
      <div>
        <p class="eyebrow mb-1.5">{f.role || 'Founder'}</p>
        <h1 class="font-display text-[clamp(1.9rem,5vw,2.8rem)] font-semibold text-ink leading-[1.05] tracking-tight">{f.name || 'Founder'}</h1>
        {f.tagline && <p class="text-[1.02rem] text-ink-soft mt-2 leading-relaxed">{f.tagline}</p>}
      </div>
    </div>

    {f.bio && <div class="text-[0.98rem] text-ink-2 leading-[1.85] font-light whitespace-pre-line mb-9">{f.bio}</div>}

    <!-- Two ways to reach me. Both are at my discretion — a paid step keeps the
         intent serious so my time and attention go where they matter. -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
      <div class="bg-white border border-ink/10 rounded-2xl p-5 flex flex-col">
        <div class="flex items-center gap-2 mb-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#FF4F00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          <h3 class="font-display text-[1.1rem] font-semibold text-ink">{f.connectLabel || 'Message me directly'}</h3>
        </div>
        <p class="text-[0.82rem] text-ink-soft leading-relaxed flex-1">A direct written line to me. {textGated ? 'A ' + f.textPriceChf + ' ' + cur + ' step keeps it to serious asks.' : 'Reach me with a genuine, well-formed message.'}</p>
        <button type="button" class="mt-3 bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 rounded-lg text-[0.88rem] transition-all" data-open="text">
          {textGated ? 'Continue · ' + f.textPriceChf + ' ' + cur : 'Message me'}
        </button>
      </div>
      <div class="bg-white border border-ink/10 rounded-2xl p-5 flex flex-col">
        <div class="flex items-center gap-2 mb-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#FF4F00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <h3 class="font-display text-[1.1rem] font-semibold text-ink">Book a consultancy</h3>
        </div>
        <p class="text-[0.82rem] text-ink-soft leading-relaxed flex-1">A focused call on your terms — {consultGated ? f.consultPriceChf + ' ' + cur + ' for my time. ' : ''}scheduled at a time I can commit to. If the fit is right, I go out of my way for it.</p>
        <button type="button" class="mt-3 bg-ink hover:bg-ink/90 text-white font-semibold py-2.5 rounded-lg text-[0.88rem] transition-all" data-open="consult">
          {consultGated ? 'Request · ' + f.consultPriceChf + ' ' + cur : 'Request a call'}
        </button>
      </div>
    </div>
    <p class="text-[0.76rem] text-ink-soft/80 leading-relaxed">Every request is reviewed personally and accepted at my discretion. A paid step is not a purchase of a decision — it is a filter for serious intent so my time goes where it is genuinely useful.</p>

    <!-- Contact / payment modal -->
    <div id="fModal" class="fixed inset-0 z-[80] hidden items-center justify-center bg-ink/50 px-4">
      <div class="bg-cream w-full max-w-md rounded-2xl p-6 relative">
        <button type="button" id="fClose" class="absolute top-3 right-3 text-ink-soft hover:text-ink" aria-label="Close">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <h2 id="fTitle" class="font-display text-[1.3rem] font-semibold text-ink mb-1">Message me directly</h2>
        <p id="fSub" class="text-[0.82rem] text-ink-soft mb-4"></p>
        <div class="grid grid-cols-1 gap-2.5">
          <input id="fName" placeholder="Your name" class="w-full bg-white border border-ink/12 rounded-lg px-3.5 py-2.5 text-[0.9rem] outline-none focus:border-burn" />
          <input id="fEmail" type="email" placeholder="Email" class="w-full bg-white border border-ink/12 rounded-lg px-3.5 py-2.5 text-[0.9rem] outline-none focus:border-burn" />
          <input id="fPhone" placeholder="Phone (optional)" class="w-full bg-white border border-ink/12 rounded-lg px-3.5 py-2.5 text-[0.9rem] outline-none focus:border-burn" />
          <div id="fConsultOnly" class="grid grid-cols-2 gap-2.5">
            <input id="fWhen" type="datetime-local" class="w-full bg-white border border-ink/12 rounded-lg px-3 py-2.5 text-[0.86rem] outline-none focus:border-burn text-ink-soft" />
            <select id="fDur" class="w-full bg-white border border-ink/12 rounded-lg px-3 py-2.5 text-[0.86rem] outline-none focus:border-burn">
              <option value="15">15 min</option><option value="30" selected>30 min</option><option value="45">45 min</option><option value="60">60 min</option>
            </select>
          </div>
          <textarea id="fNote" rows="3" placeholder="Your message — be specific about what you need." class="w-full bg-white border border-ink/12 rounded-lg px-3.5 py-2.5 text-[0.9rem] outline-none focus:border-burn"></textarea>
        </div>
        <button id="fSend" type="button" class="mt-4 w-full bg-burn hover:bg-burn/90 text-white font-semibold py-3 rounded-lg text-[0.92rem] transition-all">Continue</button>
        <p id="fMsg" class="text-[0.82rem] mt-3 min-h-[1.2em] text-center"></p>
        <div id="fDone" class="hidden text-center mt-2"></div>
      </div>
    </div>
  </section>

  {(textGated || consultGated) && <script is:inline src="https://checkout.razorpay.com/v1/checkout.js"></script>}
  <script is:inline define:vars={{ textGated, consultGated, cur, textPrice: f.textPriceChf, consultPrice: f.consultPriceChf, fname: f.name }}>
    (function () {
      var modal = document.getElementById('fModal'), kind = 'text';
      function gv(id) { return (document.getElementById(id).value || '').trim(); }
      function show() { modal.classList.remove('hidden'); modal.classList.add('flex'); }
      function hide() { modal.classList.add('hidden'); modal.classList.remove('flex'); }
      document.getElementById('fClose').addEventListener('click', hide);
      modal.addEventListener('click', function (e) { if (e.target === modal) hide(); });
      document.querySelectorAll('[data-open]').forEach(function (b) {
        b.addEventListener('click', function () {
          kind = b.getAttribute('data-open');
          var gated = kind === 'text' ? textGated : consultGated;
          var price = kind === 'text' ? textPrice : consultPrice;
          document.getElementById('fTitle').textContent = kind === 'text' ? 'Message me directly' : 'Book a consultancy';
          document.getElementById('fSub').textContent = gated ? ('A ' + price + ' ' + cur + ' step, reviewed personally and accepted at my discretion.') : 'Reviewed personally and accepted at my discretion.';
          document.getElementById('fConsultOnly').style.display = kind === 'consult' ? 'grid' : 'none';
          document.getElementById('fSend').textContent = gated ? ('Continue · ' + price + ' ' + cur) : 'Send request';
          document.getElementById('fMsg').textContent = ''; document.getElementById('fDone').classList.add('hidden');
          show();
        });
      });
      function done(html) { document.getElementById('fDone').innerHTML = html; document.getElementById('fDone').classList.remove('hidden'); document.getElementById('fSend').style.display = 'none'; }
      document.getElementById('fSend').addEventListener('click', function () {
        var name = gv('fName'), email = gv('fEmail'), msg = document.getElementById('fMsg');
        if (!name || !email) { msg.style.color = '#b3382c'; msg.textContent = 'Please add your name and email.'; return; }
        var payload = { kind: kind, name: name, email: email, phone: gv('fPhone'), note: gv('fNote'), preferred: kind === 'consult' ? gv('fWhen') : '', durationMin: Number(gv('fDur')) || 30 };
        var btn = this; btn.disabled = true; btn.textContent = 'Please wait...';
        fetch('/api/founder/pay/create', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) })
          .then(function (r) { return r.json(); }).then(function (j) {
            btn.disabled = false;
            if (!j.ok) { msg.style.color = '#b3382c'; msg.textContent = j.error || 'Something went wrong.'; btn.textContent = 'Continue'; return; }
            if (j.free) {
              if (kind === 'text' && j.revealHref) done('<a href="' + j.revealHref + '" target="_blank" rel="noopener" class="inline-block bg-burn text-white font-semibold py-2.5 px-6 rounded-lg text-[0.9rem]">Open direct line</a>');
              else done('<p class="text-leaf font-semibold">Request sent. I will be in touch to confirm.</p>');
              return;
            }
            // Paid: open the gateway
            var rzp = new Razorpay({
              key: j.keyId, order_id: j.orderId, amount: j.amountPaise, currency: 'INR',
              name: 'EduRankAI', description: (kind === 'text' ? 'Direct line to ' : 'Consultation with ') + (fname || 'the founder'),
              prefill: { name: name, email: email, contact: gv('fPhone') },
              theme: { color: '#FF4F00' },
              handler: function (resp) {
                msg.style.color = '#6b5d49'; msg.textContent = 'Confirming...';
                fetch('/api/founder/pay/verify', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({
                  razorpay_order_id: resp.razorpay_order_id, razorpay_payment_id: resp.razorpay_payment_id, razorpay_signature: resp.razorpay_signature, kind: kind
                }) }).then(function (r) { return r.json(); }).then(function (v) {
                  msg.textContent = '';
                  if (!v.ok) { msg.style.color = '#b3382c'; msg.textContent = v.error || 'Could not confirm the payment.'; return; }
                  if (v.kind === 'text' && v.revealHref) done('<p class="text-leaf font-semibold mb-2">Payment received. Here is your direct line.</p><a href="' + v.revealHref + '" target="_blank" rel="noopener" class="inline-block bg-burn text-white font-semibold py-2.5 px-6 rounded-lg text-[0.9rem]">' + (v.label || 'Message me') + '</a>');
                  else done('<p class="text-leaf font-semibold mb-2">Payment received. Your request is confirmed — I will reach out to lock the time.</p>' + (v.calendarHref ? '<a href="' + v.calendarHref + '" target="_blank" rel="noopener" class="inline-block bg-ink text-white font-semibold py-2.5 px-6 rounded-lg text-[0.9rem]">Add to my calendar</a>' : ''));
                });
              },
              modal: { ondismiss: function () { msg.style.color = '#b3382c'; msg.textContent = 'Payment cancelled.'; btn.textContent = 'Continue · ' + (kind === 'text' ? textPrice : consultPrice) + ' ' + cur; } }
            });
            rzp.open(); btn.textContent = 'Continue · ' + (kind === 'text' ? textPrice : consultPrice) + ' ' + cur;
          }).catch(function () { btn.disabled = false; btn.textContent = 'Continue'; msg.style.color = '#b3382c'; msg.textContent = 'Network error. Try again.'; });
      });
    })();
  </script>
</BaseLayout>
