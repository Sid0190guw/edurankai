---
import { db } from '@/lib/db';
import { heiStories, heiInstitutions, users } from '@/lib/db/schema';
import { eq, and } from 'drizzle-orm';
import { marked } from 'marked';

const { slug } = Astro.params;
if (!slug) return new Response('Not found', { status: 404 });

const found = await db.select().from(heiStories).where(and(eq(heiStories.slug, slug), eq(heiStories.isPublished, true))).limit(1);
if (found.length === 0) {
  return new Response('Story not found', { status: 404 });
}
const story = found[0];

let inst: any = null;
if (story.institutionId) {
  const i = await db.select().from(heiInstitutions).where(eq(heiInstitutions.id, story.institutionId)).limit(1);
  inst = i[0] || null;
}

let author: any = null;
if (story.authorUserId) {
  const u = await db.select({ name: users.name }).from(users).where(eq(users.id, story.authorUserId)).limit(1);
  author = u[0] || null;
}

const bodyHtml = marked.parse(story.body || '');
const published = story.publishedAt ? new Date(story.publishedAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) : '';

const categoryLabel: Record<string, string> = {
  investigation: 'Investigation',
  analysis: 'Analysis',
  methodology: 'Methodology',
  institution_profile: 'Institution profile',
  editorial: 'Editorial',
  data_release: 'Data release'
};
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{story.headline} - EduRankAI Truth Report</title>
<meta name="description" content={story.deck || story.headline} />
<meta property="og:title" content={story.headline} />
<meta property="og:description" content={story.deck || story.headline} />
<meta property="og:type" content="article" />
{story.coverImageUrl && <meta property="og:image" content={story.coverImageUrl} />}
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,800&family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --ink:#0A0A0A; --ink-2:#1F1F1F;
    --paper:#FAF8F3; --paper-2:#F2EFE7;
    --rule:#E5DFD0; --rule-2:#C9C0A8;
    --muted:#6B6457; --muted-2:#999185;
    --accent:#B91C1C; --accent-2:#DC2626;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { background: var(--paper); color: var(--ink); font-family: 'Inter', sans-serif; font-size: 16px; line-height: 1.6; -webkit-font-smoothing: antialiased; }
  a { color: var(--accent); }

  .top { background: var(--paper); border-bottom: 1px solid var(--rule); padding: 14px 40px; }
  .top-inner { max-width:880px; margin: 0 auto; display:flex; justify-content:space-between; align-items:center; }
  .brand { font-family: 'Fraunces', serif; font-size: 22px; font-weight: 700; color: var(--ink); letter-spacing: -0.02em; text-decoration:none; }
  .brand .dot { color: var(--accent); }
  .back-link { font-family:'JetBrains Mono', monospace; font-size: 11px; color: var(--muted); text-transform:uppercase; letter-spacing: 0.1em; text-decoration:none; }
  .back-link:hover { color: var(--accent); }

  .article { max-width: 720px; margin: 0 auto; padding: 56px 24px 80px; }
  .article-meta { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--accent); letter-spacing: 0.15em; text-transform: uppercase; font-weight: 700; margin-bottom: 14px; display:flex; gap:18px; }
  .article-meta .pub { color: var(--muted); font-weight: 500; }
  .article-headline { font-family: 'Fraunces', serif; font-size: 46px; line-height: 1.05; letter-spacing: -0.02em; color: var(--ink); font-weight: 600; margin-bottom: 18px; }
  .article-deck { font-family: 'Fraunces', serif; font-size: 22px; line-height: 1.45; color: var(--ink-2); font-weight: 400; font-style: italic; margin-bottom: 30px; max-width: 640px; }
  .article-byline { font-size: 13px; color: var(--muted); padding-bottom: 28px; margin-bottom: 32px; border-bottom: 2px solid var(--ink); }

  .cover-image { width: 100%; max-height: 460px; object-fit: cover; margin-bottom: 32px; border-radius: 2px; }

  .article-body { font-size: 17px; line-height: 1.78; color: var(--ink-2); }
  .article-body h1, .article-body h2 { font-family:'Fraunces',serif; color: var(--ink); letter-spacing: -0.01em; }
  .article-body h2 { font-size: 28px; margin: 40px 0 14px; font-weight: 600; }
  .article-body h3 { font-family:'Fraunces',serif; font-size: 22px; color: var(--ink); margin: 32px 0 10px; font-weight: 600; }
  .article-body p { margin: 1.1em 0; }
  .article-body strong { color: var(--ink); font-weight: 600; }
  .article-body em { font-style: italic; }
  .article-body a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .article-body blockquote { border-left: 3px solid var(--accent); padding: 6px 0 6px 22px; margin: 24px 0; color: var(--ink); font-family:'Fraunces',serif; font-style: italic; font-size: 21px; line-height: 1.45; }
  .article-body ul, .article-body ol { padding-left: 26px; margin: 1.1em 0; }
  .article-body li { margin: 0.4em 0; }
  .article-body code { font-family:'JetBrains Mono', monospace; font-size: 0.92em; background: var(--paper-2); padding: 2px 6px; border-radius: 2px; }
  .article-body hr { border: 0; border-top: 1px solid var(--rule); margin: 36px 0; }

  .inst-tag { display:inline-block; margin-top: 24px; padding: 14px 18px; background: var(--paper-2); border: 1px solid var(--rule); border-radius: 2px; }
  .inst-tag .label { font-family:'JetBrains Mono', monospace; font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.12em; font-weight: 600; margin-bottom: 4px; }
  .inst-tag .name { font-family:'Fraunces',serif; font-size: 18px; color: var(--ink); font-weight: 600; }

  .footer { background: var(--ink); color: var(--paper); padding: 40px; margin-top: 60px; }
  .footer-inner { max-width: 880px; margin: 0 auto; }
  .footer h4 { font-family:'Fraunces',serif; font-weight: 600; margin-bottom: 8px; }
  .footer p { font-size: 13px; color: var(--muted-2); line-height: 1.7; }
  .footer a { color: var(--paper); }

  @media (max-width: 700px) {
    .article-headline { font-size: 34px; }
    .article-deck { font-size: 18px; }
    .article-body { font-size: 16px; }
  }
</style>
</head>
<body>

<header class="top">
  <div class="top-inner">
    <a href="/hei" class="brand">EduRank<span class="dot">.</span>AI</a>
    <a href="/hei" class="back-link">&larr; Back to all stories</a>
  </div>
</header>

<article class="article">

  <div class="article-meta">
    <span>{categoryLabel[story.category] || story.category}</span>
    {published && <span class="pub">Published {published}</span>}
  </div>

  <h1 class="article-headline">{story.headline}</h1>

  {story.deck && <p class="article-deck">{story.deck}</p>}

  <p class="article-byline">
    {author ? 'By ' + author.name : 'EduRankAI Editorial'} - Truth Report
  </p>

  {story.coverImageUrl && <img src={story.coverImageUrl} alt={story.headline} class="cover-image" />}

  <div class="article-body" set:html={bodyHtml}></div>

  {inst && (
    <div class="inst-tag">
      <div class="label">Institution covered</div>
      <div class="name">{inst.name}{inst.city ? ' - ' + inst.city : ''}</div>
    </div>
  )}

</article>

<footer class="footer">
  <div class="footer-inner">
    <h4>EduRankAI <span style="color: #DC2626;">Truth Report</span></h4>
    <p>Published by EduRankAI - a Bharat-built frontier AI lab. Methodology in academic peer review.</p>
    <p style="margin-top: 12px;">
      <a href="/hei">All investigations</a> - <a href="/ecosystem/hei">About HEI</a> - <a href="/contact">Contact</a> - <a href="mailto:hei@edurankai.in">hei@edurankai.in</a>
    </p>
  </div>
</footer>

</body>
</html>