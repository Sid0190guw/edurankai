---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { institutionClaims, heiInstitutions, institutionSubmissions, institutionSubmissionScores, heiDimensions } from '@/lib/db/schema';
import { eq, desc, asc } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/hei/login');
if (user.role !== 'institution_admin') {
  return Astro.redirect('/hei/login');
}
if (!user.institutionId) {
  return new Response('No institution linked to this account. Contact hei@edurankai.in.', { status: 400 });
}

const inst = (await db.select().from(heiInstitutions).where(eq(heiInstitutions.id, user.institutionId)).limit(1))[0];
if (!inst) return new Response('Institution not found.', { status: 404 });

// Find the most recent claim for this institution
const claims = await db.select().from(institutionClaims)
  .where(eq(institutionClaims.institutionId, user.institutionId))
  .orderBy(desc(institutionClaims.submittedAt))
  .limit(1);
const myClaim = claims[0] || null;
const claimStatus = myClaim ? myClaim.status : 'unknown';
const portalToken = myClaim ? myClaim.claimToken : null;

const submissions = await db.select().from(institutionSubmissions)
  .where(eq(institutionSubmissions.institutionId, user.institutionId))
  .orderBy(desc(institutionSubmissions.submittedAt));

let latestScoreDetails: any[] = [];
if (submissions.length > 0) {
  latestScoreDetails = await db.select().from(institutionSubmissionScores).where(eq(institutionSubmissionScores.submissionId, submissions[0].id));
}

const dimensions = await db.select().from(heiDimensions).orderBy(asc(heiDimensions.sortOrder));
const dimMap = Object.fromEntries(dimensions.map(d => [d.id, d.title]));

function fmt(d: any) { return d ? new Date(d).toLocaleString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) : '-'; }
---
<BaseLayout title={'Portal - ' + inst.name} description="EduRankAI Institution Portal">
  <section class="px-[5vw] py-10 md:py-14 max-w-5xl mx-auto">

    <div class="mb-6 flex justify-between items-start gap-4 flex-wrap">
      <div>
        <p class="eyebrow mb-2">Institution Portal</p>
        <h1 class="font-display text-3xl md:text-4xl font-semibold text-ink leading-tight">{inst.name}</h1>
        <p class="text-[0.88rem] text-ink-soft mt-2">Signed in as <strong>{user.name}</strong> · {user.email}</p>
      </div>
      <form method="POST" action="/portal/logout">
        <button type="submit" class="text-[0.82rem] text-ink-soft hover:text-burn underline">Sign out</button>
      </form>
    </div>

    {claimStatus === 'pending' && (
      <div class="bg-gold-bg/30 border border-gold-border rounded-2xl p-6 mb-6">
        <p class="text-[0.72rem] font-mono uppercase tracking-wider text-gold-deep font-bold mb-2">Verification pending</p>
        <p class="text-[0.92rem] text-ink-2 leading-relaxed">Your institutional claim is under editorial review. You will be able to submit dimension scores once verified. Typical turnaround: 5-10 business days.</p>
      </div>
    )}

    {claimStatus === 'rejected' && (
      <div class="bg-red-50 border border-red-200 rounded-2xl p-6 mb-6">
        <p class="text-[0.72rem] font-mono uppercase tracking-wider text-red-700 font-bold mb-2">Claim rejected</p>
        <p class="text-[0.92rem] text-ink-2 leading-relaxed">{myClaim && myClaim.decisionNotes ? myClaim.decisionNotes : 'Your claim was not verified. Contact hei@edurankai.in to discuss.'}</p>
      </div>
    )}

    {claimStatus === 'verified' && portalToken && (
      <>
        <div class="bg-leaf-bg/40 border border-leaf-border rounded-2xl p-6 mb-6">
          <p class="text-[0.72rem] font-mono uppercase tracking-wider text-leaf font-bold mb-2">Verified institution</p>
          <p class="text-[0.92rem] text-ink-2 leading-relaxed">You can submit dimension scores with evidence URLs and respond to any findings issued by the editorial team.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-4 mb-6">
          <a href={'/hei/portal/' + portalToken + '/submit'} class="bg-white border-2 border-burn/20 hover:border-burn rounded-2xl p-6 transition-all">
            <p class="text-[0.72rem] font-mono uppercase tracking-wider text-burn font-bold mb-2">Submit data</p>
            <h3 class="font-display text-xl font-semibold text-ink mb-2">Dimension scores + evidence</h3>
            <p class="text-[0.85rem] text-ink-soft leading-relaxed">Fill scores across the 7 dimensions, with evidence URLs. Editorial team reviews each dimension separately.</p>
            <p class="text-[0.85rem] text-burn font-semibold mt-3">Open form &rarr;</p>
          </a>
          <a href={'/hei/portal/' + portalToken + '/findings'} class="bg-white border border-ink/10 hover:border-burn/40 rounded-2xl p-6 transition-all">
            <p class="text-[0.72rem] font-mono uppercase tracking-wider text-ink-soft font-bold mb-2">Right of reply</p>
            <h3 class="font-display text-xl font-semibold text-ink mb-2">Findings notices</h3>
            <p class="text-[0.85rem] text-ink-soft leading-relaxed">When editorial team publishes findings about your institution, you receive 30 days to respond.</p>
            <p class="text-[0.85rem] text-burn font-semibold mt-3">View findings &rarr;</p>
          </a>
        </div>

        {submissions.length > 0 && (
          <div class="bg-white border border-ink/10 rounded-2xl p-6 mb-6">
            <h3 class="font-display text-lg font-semibold text-ink mb-4">Submission history</h3>
            <div class="flex flex-col gap-3">
              {submissions.map((s) => (
                <div class="bg-cream-2 border border-ink/8 rounded-lg p-4">
                  <div class="flex justify-between items-start gap-3 flex-wrap">
                    <div>
                      <p class="text-[0.78rem] text-ink-soft">Submitted {fmt(s.submittedAt)}</p>
                    </div>
                    <span class={'text-[0.7rem] uppercase tracking-wider font-bold px-2 py-1 rounded-full ' +
                      (s.submissionStatus === 'accepted' ? 'bg-leaf-bg text-leaf border border-leaf-border' :
                       s.submissionStatus === 'rejected' ? 'bg-red-50 text-red-700 border border-red-200' :
                       'bg-burn-pale text-burn border border-burn-dim')}>
                      {(s.submissionStatus || '').replace(/_/g, ' ')}
                    </span>
                  </div>
                </div>
              ))}
            </div>

            {latestScoreDetails.length > 0 && (
              <div class="mt-5 pt-5 border-t border-ink/10">
                <p class="text-[0.78rem] font-mono uppercase tracking-wider text-ink-soft font-bold mb-3">Latest submission (per dimension)</p>
                <table class="w-full text-[0.85rem] text-ink-2">
                  <thead><tr class="border-b border-ink/10 text-left text-[0.72rem] uppercase tracking-wider text-ink-soft"><th class="py-2">Dimension</th><th class="py-2">Proposed</th><th class="py-2">Decision</th><th class="py-2">Accepted</th></tr></thead>
                  <tbody>
                    {latestScoreDetails.map((d) => (
                      <tr class="border-b border-ink/5">
                        <td class="py-2">{dimMap[d.dimensionId] || d.dimensionId}</td>
                        <td class="py-2 font-mono">{d.proposedScore}</td>
                        <td class="py-2"><span class={'text-[0.72rem] uppercase ' + (d.adminDecision === 'accepted' ? 'text-leaf' : d.adminDecision === 'rejected' ? 'text-red-700' : 'text-burn')}>{d.adminDecision}</span></td>
                        <td class="py-2 font-mono">{d.adminAcceptedScore || '-'}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>
        )}
      </>
    )}

    <div class="text-center mt-8 text-[0.78rem] text-ink-soft">
      Questions? <a href="mailto:hei@edurankai.in" class="text-burn hover:underline font-semibold">hei@edurankai.in</a>
    </div>

  </section>
</BaseLayout>