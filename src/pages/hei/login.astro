---
import BaseLayout from '@/layouts/BaseLayout.astro';

if (Astro.locals.user && Astro.locals.user.role === 'institution_admin') {
  return Astro.redirect('/hei/portal');
}

let errorMsg = '';
let requireFace = false;
let pendingUserId = '';
let pendingUserName = '';
let faceDescriptor = '';

const pendingId = Astro.cookies.get('hei_face_pending')?.value || '';

if (pendingId) {
  requireFace = true;
  pendingUserId = pendingId;
  try {
    const { db } = await import('@/lib/db');
    const { users } = await import('@/lib/db/schema');
    const { eq } = await import('drizzle-orm');
    const { sql } = await import('drizzle-orm');
    const u = await db.select({ name: users.name }).from(users).where(eq(users.id, pendingId)).limit(1);
    pendingUserName = u[0]?.name || '';
    const fd = await db.execute(sql`SELECT face_descriptor FROM user_face_enrollments WHERE user_id = ${pendingId} AND is_active = true LIMIT 1`);
    const rows = Array.isArray(fd) ? fd : (fd?.rows || []);
    faceDescriptor = rows.length > 0 ? JSON.stringify((rows[0] as any).face_descriptor) : '';
  } catch(e) {}
}

if (Astro.request.method === 'POST') {
  const fd2 = await Astro.request.formData();
  const action = (fd2.get('action') as string) || '';

  if (action === 'face_verified') {
    const userId = (fd2.get('user_id') as string) || '';
    if (userId === pendingId) {
      try {
        const { db } = await import('@/lib/db');
        const { generateSessionToken, createSession } = await import('@/lib/auth/session');
        const { setSessionCookie } = await import('@/lib/auth/cookie');
        const { sql } = await import('drizzle-orm');
        await db.execute(sql`UPDATE user_face_enrollments SET last_used_at = NOW() WHERE user_id = ${userId}`);
        const token = generateSessionToken();
        const session = await createSession(token, userId, {
          userAgent: Astro.request.headers.get('user-agent') || undefined,
          ipAddress: Astro.clientAddress
        });
        setSessionCookie(Astro.cookies, token, session.expiresAt);
        Astro.cookies.delete('hei_face_pending', { path: '/' });
        return Astro.redirect('/hei/portal');
      } catch(e: any) { errorMsg = 'Login error. Please try again.'; }
    } else {
      errorMsg = 'Session mismatch. Please sign in again.';
      Astro.cookies.delete('hei_face_pending', { path: '/' });
      requireFace = false;
    }
  } else if (action === 'cancel_face') {
    Astro.cookies.delete('hei_face_pending', { path: '/' });
    return Astro.redirect('/hei/login');
  } else {
    const email = (fd2.get('email') as string || '').trim().toLowerCase();
    const password = fd2.get('password') as string || '';

    if (!email || !password) {
      errorMsg = 'Email and password are required.';
    } else {
      const { db } = await import('@/lib/db');
      const { users } = await import('@/lib/db/schema');
      const { verifyPassword } = await import('@/lib/auth/password');
      const { generateSessionToken, createSession } = await import('@/lib/auth/session');
      const { setSessionCookie } = await import('@/lib/auth/cookie');
      const { eq } = await import('drizzle-orm');
      const { sql } = await import('drizzle-orm');

      const found = await db.select().from(users).where(eq(users.email, email)).limit(1);
      const user = found[0];

      if (!user || !user.isActive) {
        errorMsg = 'Invalid email or password.';
      } else {
        const valid = await verifyPassword(user.passwordHash, password);
        if (!valid) {
          errorMsg = 'Invalid email or password.';
        } else if (user.role !== 'institution_admin') {
          errorMsg = 'This account does not have institution portal access. Visit /admin/login for admin or /portal/login for applicant.';
        } else {
          // Face enrolled? Require face verification before session.
          const faceCheck = await db.execute(sql`SELECT id FROM user_face_enrollments WHERE user_id = ${user.id} AND is_active = true LIMIT 1`);
          const faceRows = Array.isArray(faceCheck) ? faceCheck : (faceCheck?.rows || []);

          if (faceRows.length > 0) {
            Astro.cookies.set('hei_face_pending', user.id, {
              path: '/', httpOnly: true, maxAge: 300, sameSite: 'lax'
            });
            return Astro.redirect('/hei/login');
          } else {
            const token = generateSessionToken();
            const session = await createSession(token, user.id, {
              userAgent: Astro.request.headers.get('user-agent') || undefined,
              ipAddress: Astro.clientAddress
            });
            setSessionCookie(Astro.cookies, token, session.expiresAt);
            return Astro.redirect('/hei/portal');
          }
        }
      }
    }
  }
}
---
<BaseLayout title="Institution Sign-in - EduRankAI HEI" description="Sign in to your institution portal">
  <style>
    .face-card { background: #fff; border: 1px solid rgba(0,0,0,0.1); border-radius: 16px; overflow: hidden; max-width: 420px; margin: 0 auto; }
    .cam-wrap { background: #000; aspect-ratio: 3/4; position: relative; max-height: 380px; }
    .cam-wrap video { width: 100%; height: 100%; object-fit: cover; transform: scaleX(-1); }
    .oval-ring { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; pointer-events: none; }
    .oval-inner { width: 55%; aspect-ratio: 3/4; border: 2.5px solid rgba(220,80,0,0.7); border-radius: 50%; }
    .cam-status { position: absolute; bottom: 12px; left: 0; right: 0; text-align: center; }
    .cam-status span { background: rgba(0,0,0,0.75); color: #fff; font-size: 12px; padding: 4px 14px; border-radius: 100px; }
    .prog-bar { height: 3px; background: #f0f0f0; }
    .prog-fill { height: 100%; background: #DC5000; width: 0%; transition: width 0.4s; }
    .face-btn { width: 100%; border: none; font-size: 15px; font-weight: 700; padding: 14px; cursor: pointer; border-radius: 0; }
    .face-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  </style>

  <section class="px-[5vw] py-14 md:py-20 max-w-md mx-auto">

    <div class="mb-7 text-center">
      <p class="eyebrow mb-3">Institution Portal</p>
      <h1 class="font-display text-3xl font-semibold text-ink mb-2">{requireFace ? 'Verify your face' : 'Sign in'}</h1>
      {!requireFace && <p class="text-[0.88rem] text-ink-soft">Don't have an account? <a href="/hei/register" class="text-burn font-semibold hover:underline">Register</a></p>}
      {requireFace && <p class="text-[0.88rem] text-ink-soft">Welcome back, <strong>{pendingUserName}</strong></p>}
    </div>

    {errorMsg && <div style="background:rgba(220,38,38,0.06);border:1px solid rgba(220,38,38,0.2);color:#b91c1c;font-size:0.85rem;padding:11px 14px;border-radius:8px;margin-bottom:18px;">{errorMsg}</div>}

    {!requireFace && (
      <form method="POST" class="bg-white border border-ink/10 rounded-2xl p-7 flex flex-col gap-5">
        <div>
          <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Official email</label>
          <input type="email" name="email" required autofocus class="w-full px-4 py-3 border border-ink/15 rounded-lg text-[0.95rem] outline-none focus:border-burn bg-cream-2" />
        </div>
        <div>
          <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Password</label>
          <input type="password" name="password" required class="w-full px-4 py-3 border border-ink/15 rounded-lg text-[0.95rem] outline-none focus:border-burn bg-cream-2" />
        </div>
        <button type="submit" class="bg-burn hover:bg-burn/90 text-white font-semibold py-3 px-6 rounded-lg text-[0.95rem]">Sign in</button>
        <p class="text-[0.75rem] text-ink-soft text-center mt-2">Face verification required after password if enrolled.</p>
      </form>
    )}

    {requireFace && faceDescriptor && (
      <div class="face-card">
        <div class="cam-wrap">
          <video id="videoEl" autoplay playsinline muted></video>
          <div class="oval-ring"><div class="oval-inner" id="ovalRing"></div></div>
          <div class="cam-status"><span id="camStatus">Loading face model...</span></div>
        </div>
        <div class="prog-bar"><div class="prog-fill" id="progFill"></div></div>
        <button id="verifyBtn" class="face-btn" disabled style="background:#DC5000;color:#fff;">Scanning...</button>
      </div>
    )}

    {requireFace && !faceDescriptor && (
      <div style="text-align:center;padding:32px;background:#fff;border:1px solid rgba(0,0,0,0.1);border-radius:16px;">
        <p style="font-size:14px;color:#6b7280;margin:0 0 16px;">Face data not found for this account. Use password sign-in.</p>
        <form method="POST">
          <input type="hidden" name="action" value="cancel_face"/>
          <button type="submit" style="background:#DC5000;color:#fff;border:none;font-size:14px;font-weight:600;padding:10px 24px;border-radius:8px;cursor:pointer;">Use Password Instead</button>
        </form>
      </div>
    )}

    {requireFace && (
      <div style="text-align:center;margin-top:16px;">
        <form method="POST" style="display:inline;">
          <input type="hidden" name="action" value="cancel_face"/>
          <button type="submit" style="background:transparent;border:none;color:#6b7280;font-size:13px;cursor:pointer;text-decoration:underline;">Use password instead</button>
        </form>
      </div>
    )}

  </section>

  {requireFace && faceDescriptor && (
    <form id="faceSuccessForm" method="POST" style="display:none;">
      <input type="hidden" name="action" value="face_verified"/>
      <input type="hidden" name="user_id" value={pendingUserId}/>
    </form>
  )}

  {requireFace && faceDescriptor && (
    <script is:inline src="https://cdn.jsdelivr.net/npm/@vladmandic/face-api@1.7.13/dist/face-api.min.js"></script>
    <script is:inline define:vars={{ storedDescriptor: faceDescriptor }}>
      var video = document.getElementById('videoEl');
      var verifyBtn = document.getElementById('verifyBtn');
      var camStatus = document.getElementById('camStatus');
      var progFill = document.getElementById('progFill');
      var ovalRing = document.getElementById('ovalRing');
      var verified = false;
      var attempts = 0;

      function setStatus(msg, color) {
        camStatus.innerHTML = '<span style="background:rgba(0,0,0,0.75);color:' + (color||'#fff') + ';font-size:12px;padding:4px 14px;border-radius:100px;">' + msg + '</span>';
      }

      async function init() {
        try {
          setStatus('Loading face model...');
          progFill.style.width = '20%';
          var MODEL_URL = 'https://cdn.jsdelivr.net/npm/@vladmandic/face-api@latest/model';
          await Promise.all([
            faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL),
            faceapi.nets.faceLandmark68TinyNet.loadFromUri(MODEL_URL),
            faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL),
          ]);
          progFill.style.width = '60%';
          var stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: 640 } });
          video.srcObject = stream;
          progFill.style.width = '100%';
          setTimeout(function() {
            progFill.style.display = 'none';
            verifyBtn.disabled = false;
            verifyBtn.textContent = 'Verify My Face';
            verifyBtn.onclick = doVerify;
            setStatus('Center face in the oval', '#10b981');
            autoVerifyLoop();
          }, 300);
        } catch(e) {
          setStatus('Camera error: ' + e.message, '#ef4444');
        }
      }

      async function tryMatch() {
        var det = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions())
          .withFaceLandmarks(true).withFaceDescriptor();
        if (!det) return false;
        var stored = JSON.parse(storedDescriptor);
        var storedArr = Array.isArray(stored) ? stored : Object.values(stored);
        var storedFloat = new Float32Array(storedArr);
        var dist = faceapi.euclideanDistance(det.descriptor, storedFloat);
        return dist < 0.5;
      }

      async function autoVerifyLoop() {
        if (verified || attempts > 25) {
          if (attempts > 25) setStatus('Auto-verify failed. Click button.', '#fbbf24');
          return;
        }
        attempts++;
        try { if (await tryMatch()) { onVerified(); return; } } catch(_) {}
        setTimeout(autoVerifyLoop, 700);
      }

      async function doVerify() {
        verifyBtn.disabled = true;
        verifyBtn.textContent = 'Verifying...';
        setStatus('Scanning face...', '#fbbf24');
        try {
          if (await tryMatch()) { onVerified(); }
          else { setStatus('Face not recognised. Try again.', '#ef4444'); verifyBtn.disabled = false; verifyBtn.textContent = 'Try Again'; }
        } catch(e) {
          setStatus('Error: ' + e.message, '#ef4444');
          verifyBtn.disabled = false; verifyBtn.textContent = 'Try Again';
        }
      }

      function onVerified() {
        verified = true;
        setStatus('Verified! Signing you in...', '#10b981');
        verifyBtn.textContent = 'Verified!';
        verifyBtn.style.background = '#10b981';
        setTimeout(function() { document.getElementById('faceSuccessForm').submit(); }, 600);
      }

      init();
    </script>
  )}
</BaseLayout>
