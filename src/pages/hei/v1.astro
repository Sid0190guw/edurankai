---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { heiMetrics, heiAspects, heiPipelines, heiSdgIndicMap, heiPurusharthas } from '@/lib/db/schema';
import { asc, eq } from 'drizzle-orm';

const metrics = await db.select().from(heiMetrics).where(eq(heiMetrics.methodologyVersion, 'v1.0')).orderBy(asc(heiMetrics.sortOrder));
const aspects = await db.select().from(heiAspects).where(eq(heiAspects.methodologyVersion, 'v1.0')).orderBy(asc(heiAspects.sortOrder));
const pipelines = await db.select().from(heiPipelines).orderBy(asc(heiPipelines.sortOrder));
const sdgMap = await db.select().from(heiSdgIndicMap).orderBy(asc(heiSdgIndicMap.sdgNumber));
const purusharthas = await db.select().from(heiPurusharthas).orderBy(asc(heiPurusharthas.sortOrder));

const aspectsByMetric: Record<string, any[]> = {};
for (const a of aspects) {
  if (!aspectsByMetric[a.metricId]) aspectsByMetric[a.metricId] = [];
  aspectsByMetric[a.metricId].push(a);
}

const totalWeight = metrics.reduce((s, m) => s + parseFloat(m.weightPercent || '0'), 0);

const PIPELINE_USE_LABEL: Record<string, string> = {
  direct_citation: 'Direct citation',
  aggregate_only: 'Aggregate only',
  outcome_metrics: 'Outcome metrics',
  investigation_lead: 'Investigation leads only'
};
---
<BaseLayout title="HEI v1.0 Canonical Framework - EduRankAI" description="The canonical specification of the EduRankAI Holistic Education Index v1.0. Four metrics, twenty-three aspects, seven evidence pipelines, dual UN-SDG and Indic itihasa-purana vocabularies.">

  <section style="padding:48px 5vw 24px;max-width:980px;margin:0 auto;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.12em;color:#FF4F00;font-weight:700;text-transform:uppercase;margin-bottom:10px;">HEI Canonical Framework</p>
    <h1 style="font-family:'Fraunces',serif;font-size:48px;line-height:1.1;font-weight:600;letter-spacing:-0.02em;color:#0d0d11;margin-bottom:14px;">v1.0 — Holistic Education Index</h1>
    <p style="font-size:18px;line-height:1.55;color:#4a4a52;max-width:760px;">Measuring universities, schools, and training institutes by whether their training produces humans whose existence demonstrably improves the world. Four metrics. Twenty-three aspects. Seven evidence pipelines. One unified score.</p>

    <div style="margin-top:24px;padding:18px 22px;background:rgba(255,79,0,0.04);border:1px solid rgba(255,79,0,0.18);border-radius:12px;font-family:'Geist Mono',monospace;font-size:14px;line-height:1.7;color:#1a1a1f;">
      HEI Score = <strong style="color:#FF4F00;">0.30·HDI + 0.20·R&amp;I + 0.30·Excellence + 0.20·Wellbeing</strong>
      <div style="font-size:11px;color:#6e6e78;margin-top:8px;letter-spacing:0.05em;">Σ = {totalWeight.toFixed(0)}%</div>
    </div>
  </section>

  <!-- 4 METRICS -->
  <section style="padding:0 5vw 36px;max-width:980px;margin:0 auto;">
    <h2 style="font-family:'Fraunces',serif;font-size:30px;font-weight:600;color:#0d0d11;margin-bottom:6px;">Four metrics</h2>
    <p style="font-size:15px;color:#6e6e78;margin-bottom:20px;">Each metric expanded into its constituent aspects below.</p>

    {metrics.map((m) => (
      <div style="margin-bottom:22px;padding:20px 22px;background:#fff;border:1px solid rgba(0,0,0,0.08);border-radius:14px;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:wrap;margin-bottom:10px;">
          <div style="flex:1;min-width:240px;">
            <h3 style="font-family:'Fraunces',serif;font-size:24px;font-weight:600;color:#0d0d11;">{m.title}</h3>
            {m.subtitle && <p style="font-family:'Fraunces',serif;font-style:italic;color:#6e6e78;font-size:15px;margin-top:2px;">{m.subtitle}</p>}
          </div>
          <span style="font-family:'Geist Mono',monospace;font-size:16px;background:rgba(255,79,0,0.15);color:#FF4F00;padding:6px 14px;border-radius:100px;font-weight:700;">{m.weightPercent}%</span>
        </div>
        <p style="font-size:14.5px;line-height:1.65;color:#3a3a40;">{m.description}</p>
        {m.blurb && <p style="font-size:13.5px;line-height:1.65;color:#6e6e78;font-style:italic;border-left:3px solid #FF4F00;padding-left:12px;margin-top:12px;">{m.blurb}</p>}

        {aspectsByMetric[m.id] && aspectsByMetric[m.id].length > 0 && (
          <div style="margin-top:14px;padding-top:14px;border-top:1px solid rgba(0,0,0,0.06);">
            <p style="font-family:'Geist Mono',monospace;font-size:10px;color:#FF4F00;letter-spacing:0.12em;font-weight:700;margin-bottom:10px;">{aspectsByMetric[m.id].length} ASPECTS</p>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:10px;">
              {aspectsByMetric[m.id].map((a) => (
                <div style="padding:12px 14px;background:#faf8f4;border:1px solid rgba(0,0,0,0.06);border-radius:8px;">
                  <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:4px;">
                    <span style="font-weight:600;color:#0d0d11;font-size:14px;">{a.title}</span>
                    {a.sdgLinks && <span style="font-family:'Geist Mono',monospace;font-size:9.5px;color:#FF4F00;">{a.sdgLinks}</span>}
                  </div>
                  {a.sanskritRoot && <p style="font-family:'Fraunces',serif;font-style:italic;font-size:13px;color:#6e6e78;margin-bottom:5px;">{a.sanskritRoot}</p>}
                  <p style="font-size:12.5px;color:#3a3a40;line-height:1.55;">{a.description}</p>
                  {a.measurementNotes && <p style="font-size:11px;color:#6e6e78;line-height:1.5;margin-top:5px;font-style:italic;">{a.measurementNotes}</p>}
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    ))}
  </section>

  <!-- PIPELINES -->
  <section style="padding:36px 5vw;max-width:980px;margin:0 auto;background:#faf8f4;border-radius:18px;">
    <h2 style="font-family:'Fraunces',serif;font-size:30px;font-weight:600;color:#0d0d11;margin-bottom:6px;">Seven evidence pipelines</h2>
    <p style="font-size:14.5px;color:#6e6e78;margin-bottom:18px;">Triangulation required: at least two of P1, P2, P4, P5 for any published claim about a named institution.</p>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:12px;">
      {pipelines.map((p) => (
        <div style="padding:14px 16px;background:#fff;border:1px solid rgba(0,0,0,0.08);border-radius:10px;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
            <span style="font-family:'Geist Mono',monospace;font-weight:700;color:#FF4F00;font-size:14px;">{p.id}</span>
            <span style={'font-size:10px;font-family:Geist Mono,monospace;padding:2px 8px;border-radius:100px;' + (p.useClass === 'investigation_lead' ? 'background:rgba(251,191,36,0.15);color:#a16207;' : p.useClass === 'aggregate_only' ? 'background:rgba(59,130,246,0.15);color:#1e40af;' : 'background:rgba(16,185,129,0.15);color:#047857;')}>{PIPELINE_USE_LABEL[p.useClass] || p.useClass}</span>
          </div>
          <h3 style="font-weight:600;color:#0d0d11;font-size:14.5px;margin-bottom:5px;">{p.title}</h3>
          <p style="font-size:12px;color:#3a3a40;line-height:1.55;margin-bottom:6px;">{p.sources}</p>
          <p style="font-size:11.5px;color:#6e6e78;font-style:italic;line-height:1.5;">{p.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- PURUSHARTHAS -->
  <section style="padding:36px 5vw 24px;max-width:980px;margin:0 auto;">
    <h2 style="font-family:'Fraunces',serif;font-size:30px;font-weight:600;color:#0d0d11;margin-bottom:14px;">The four puruṣārthas</h2>
    <p style="font-size:14.5px;color:#6e6e78;margin-bottom:18px;">The streams of training that run through life — not phase-locked. Each trained alongside the others.</p>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px;">
      {purusharthas.map((p) => (
        <div style="padding:14px 16px;background:#fff;border:1px solid rgba(0,0,0,0.08);border-radius:10px;">
          <h3 style="font-family:'Fraunces',serif;font-size:20px;color:#0d0d11;font-weight:600;">{p.title}</h3>
          {p.transliteration && <p style="font-style:italic;color:#6e6e78;font-size:13px;margin-bottom:6px;">{p.transliteration}</p>}
          <p style="font-size:12.5px;color:#3a3a40;line-height:1.55;">{p.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- SDG-INDIC -->
  <section style="padding:24px 5vw 36px;max-width:980px;margin:0 auto;">
    <h2 style="font-family:'Fraunces',serif;font-size:30px;font-weight:600;color:#0d0d11;margin-bottom:6px;">17 UN SDGs ↔ Indic principles</h2>
    <p style="font-size:14.5px;color:#6e6e78;margin-bottom:18px;">Two vocabularies, one standard. HEI reports in both.</p>

    <div style="background:#fff;border:1px solid rgba(0,0,0,0.08);border-radius:12px;overflow:hidden;">
      <table style="width:100%;font-size:13px;border-collapse:collapse;">
        <thead style="background:#faf8f4;">
          <tr>
            <th style="padding:10px 12px;text-align:left;font-family:'Geist Mono',monospace;font-size:10.5px;text-transform:uppercase;letter-spacing:0.08em;color:#6e6e78;">#</th>
            <th style="padding:10px 12px;text-align:left;font-family:'Geist Mono',monospace;font-size:10.5px;text-transform:uppercase;letter-spacing:0.08em;color:#6e6e78;">UN SDG</th>
            <th style="padding:10px 12px;text-align:left;font-family:'Geist Mono',monospace;font-size:10.5px;text-transform:uppercase;letter-spacing:0.08em;color:#6e6e78;">Indic principle</th>
            <th style="padding:10px 12px;text-align:left;font-family:'Geist Mono',monospace;font-size:10.5px;text-transform:uppercase;letter-spacing:0.08em;color:#6e6e78;">Sanskrit</th>
          </tr>
        </thead>
        <tbody>
          {sdgMap.map((m) => (
            <tr style="border-top:1px solid rgba(0,0,0,0.06);">
              <td style="padding:10px 12px;font-family:'Geist Mono',monospace;color:#FF4F00;font-weight:600;">{m.sdgNumber}</td>
              <td style="padding:10px 12px;color:#0d0d11;font-weight:500;">{m.sdgName}</td>
              <td style="padding:10px 12px;color:#3a3a40;">{m.indicPrinciple}</td>
              <td style="padding:10px 12px;font-family:'Fraunces',serif;font-style:italic;color:#6e6e78;">{m.sanskritPhrase || ''}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- CTA -->
  <section style="padding:30px 5vw 48px;max-width:980px;margin:0 auto;text-align:center;">
    <p style="font-size:14px;color:#6e6e78;margin-bottom:14px;">v1.0 supersedes v0.4 as the canonical framework. Public ranking deployment continues to use v0.4 dimension scoring until v1.0 measurement pipelines are operational.</p>
    <a href="/hei" style="display:inline-block;background:#FF4F00;color:#fff;padding:12px 24px;border-radius:10px;font-weight:600;text-decoration:none;font-size:15px;">&larr; Back to Truth Report</a>
  </section>

</BaseLayout>