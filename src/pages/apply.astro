---
import BaseLayout from '@/layouts/BaseLayout.astro';
const title = 'apply';
---
<BaseLayout title={title.charAt(0).toUpperCase() + title.slice(1)}>
  <section class="container-edge pt-24 pb-32 max-w-3xl">
    <p class="eyebrow mb-4">Coming in a later message</p>
    <h1 class="section-title mb-6">{title.charAt(0).toUpperCase() + title.slice(1)} - <em>under construction</em></h1>
    <p class="text-ink-soft leading-relaxed mb-8">
      This page will be built out in a subsequent message. The skeleton is in place - content arrives shortly.
    </p>
    <a href="/" class="btn-ghost">Back home</a>
  </section>
</BaseLayout>
