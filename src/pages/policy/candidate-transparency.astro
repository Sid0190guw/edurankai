---
import BaseLayout from '@/layouts/BaseLayout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Candidate Privacy & Data Transparency — EduRankAI',
  description: 'What EduRankAI collects from applicants, why, how long it is kept, and what your rights are. Plain language. Read before you apply.',
  publisher: { '@type': 'Organization', name: 'EduRankAI', url: 'https://www.edurankai.in' },
  inLanguage: 'en-IN',
  dateModified: '2026-06-03',
};

const SECTIONS = [
  {
    tag: 'Why we collect',
    title: 'Why we collect information',
    body: [
      'EduRankAI receives applications across a wide range of roles — internships, research, specialist tracks, leadership positions. To keep the recruitment process honest, we collect only what is needed for:',
      [
        'Candidate identification and verification.',
        'Prevention of spam, bot activity, duplicate applications, and impersonation.',
        'Assessment administration and candidate evaluation.',
        'Communication regarding applications and hiring processes.',
        'Platform security and integrity.',
      ],
      'We do not collect information for the purpose of selling, renting, or commercially exploiting applicant data. Ever.',
    ],
  },
  {
    tag: 'Identity verification',
    title: 'Identity verification',
    body: [
      'Certain positions or application stages may require identity verification. The purpose is to reduce fraudulent applications, prevent duplicate accounts, protect the integrity of assessments, and ensure fair evaluation of candidates.',
      'Identity verification does not imply employment eligibility, job offers, or selection decisions. Passing verification means we know you are who you say you are. It does not mean you are hired.',
    ],
  },
  {
    tag: 'Government ID',
    title: 'Government-issued identification',
    body: [
      'Where government-issued identification is requested, it is used solely for verification and anti-abuse purposes. We process only what is necessary for verification and do not maintain unnecessary repositories of government identification documents. Access is restricted to authorized personnel and systems.',
      'You can contact us at any time for clarification regarding requested documentation. The expectation is that you will be able to see exactly what we have on file about you, on request.',
    ],
  },
  {
    tag: 'Facial verification',
    title: 'Facial verification',
    body: [
      'Some verification flows involve facial verification. The purpose is identity confirmation, prevention of duplicate or fraudulent accounts, and protection of assessment integrity.',
      'EduRankAI does not operate a facial recognition database for commercial purposes. Only the minimum required information is retained. Facial verification data is not sold, not shared, and not used for advertising.',
    ],
  },
  {
    tag: 'Storage & security',
    title: 'Data storage and security',
    body: [
      'EduRankAI is a small organization, but we recognise the responsibility associated with handling personal information. We take reasonable technical and organizational measures to protect applicant information, restrict unauthorized access, reduce misuse, and maintain recruitment system integrity.',
      'No internet-based system can guarantee absolute security. We continuously work to improve our practices and safeguards, and we publish material updates here.',
    ],
  },
  {
    tag: 'Assessments',
    title: 'Recruitment assessments',
    body: [
      'Applications may go through some combination of human review, assessment-based evaluation, project-based evaluation, portfolio review, interview processes, and specialist review where applicable.',
      'We may engage qualified evaluators, reviewers, or subject-matter experts when assessing candidates. They are bound by the same data-handling expectations as our own team.',
    ],
  },
  {
    tag: 'Application fees',
    title: 'Application fees',
    body: [
      'Certain opportunities involve an application fee. The fee exists to support candidate evaluation, assessment administration, verification systems, reviewer and examiner compensation, and recruitment operations.',
      'The existence of an application fee does not guarantee selection, interviews, employment, internships, or any future opportunity. Paying the fee buys you a fair, processed application — not a result.',
      'Full detail on what the fee covers and why: <a href="/policy/fees" class="text-burn underline font-semibold">Why we charge an application fee</a>.',
    ],
  },
  {
    tag: 'Fee waivers',
    title: 'Fee waivers',
    body: [
      'EduRankAI believes financial limitations should not prevent exceptional individuals from being considered. Candidates facing genuine financial hardship may request an application fee waiver through the application process.',
      'Every waiver request is reviewed individually. There is no second-class treatment of waiver-granted applications — the rubric and the review are identical.',
    ],
  },
  {
    tag: 'Long-term mission',
    title: 'Long-term mission',
    body: [
      'EduRankAI operates in research-intensive and technology-intensive domains, including educational intelligence, advanced artificial intelligence, and emerging technologies. Building such systems requires long-term investment in research, infrastructure, talent, and evaluation processes.',
      'Our recruitment systems are designed with these long-term objectives in mind. We are not optimizing for hiring volume. We are optimizing for the quality of the people who end up doing the work.',
    ],
  },
  {
    tag: 'Candidate respect',
    title: 'Candidate respect',
    body: [
      'We believe applicants should be treated as individuals rather than merely as resources. We look for clarity of thought, clarity of intention, clarity of action, demonstrated capability, intellectual rigour, initiative, and evidence of excellence.',
      'Some of our standards are demanding. We try to conduct evaluations in a manner that respects your time, your well-being, and your professional aspirations. If we ever fall short of that, you can write to us.',
    ],
  },
  {
    tag: 'Communications',
    title: 'Candidate communications',
    body: [
      'We may communicate with applicants regarding applications, assessments, interviews, recruitment updates, and platform-related notifications.',
      'We do not send marketing email. We do not share your contact information with third parties. We continuously improve communication practices and welcome feedback.',
    ],
  },
  {
    tag: 'Your rights',
    title: 'Your rights as a candidate',
    body: [
      'Under DPDPA 2023 (India) and GDPR Article 17 (where applicable), you may contact EduRankAI to:',
      [
        'Request clarification regarding collected information.',
        'Request correction of inaccurate information.',
        'Request deletion of information where appropriate.',
        'Raise privacy concerns.',
        'Seek clarification regarding application fees or verification requirements.',
      ],
      'Reach us at <a href="mailto:hr@edurankai.in" class="text-burn underline font-semibold">hr@edurankai.in</a> — we treat candidate-rights requests as high-priority and respond within five business days.',
    ],
  },
  {
    tag: 'Continuous improvement',
    title: 'Continuous improvement',
    body: [
      'As EduRankAI evolves, our policies, systems, and safeguards may also evolve. We welcome constructive feedback and are committed to improving transparency, privacy protections, candidate experience, and recruitment fairness over time.',
      'Material changes are reflected on this page. The "last updated" date below is authoritative.',
    ],
  },
];

const lastUpdated = '3 June 2026';
---
<BaseLayout title="Candidate Privacy & Transparency - EduRankAI" description="What EduRankAI collects from applicants, why, how long it is kept, and what your rights are. Plain language. Read before you apply.">
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>

  <section class="px-[5vw] pt-14 md:pt-20 pb-10 max-w-3xl mx-auto">
    <p class="eyebrow mb-5">Before you apply</p>
    <h1 class="font-display text-[clamp(1.9rem,4.5vw,3rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-5">
      What we collect. <em class="italic text-burn font-medium">Why.</em> What we will not do with it.
    </h1>
    <p class="text-[1.02rem] md:text-[1.08rem] text-ink-soft leading-[1.8] font-light max-w-2xl">
      We know applying anywhere means trusting someone with your information. This page is the plain-language version of what EduRankAI does with the data you share when you apply for a role here. Read it before you sign up. If anything is unclear, write to <a href="mailto:hr@edurankai.in" class="text-burn font-semibold underline">hr@edurankai.in</a> and we will explain it.
    </p>
  </section>

  <section class="px-[5vw] py-8 max-w-3xl mx-auto">
    <div class="bg-cream-2/60 border border-ink/10 rounded-2xl p-5 md:p-6 grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
      <div>
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.16em] text-burn font-bold mb-1.5">In short</p>
        <p class="text-[0.88rem] text-ink-2 leading-relaxed">We collect only what we need to verify it is you, evaluate your work, and communicate with you.</p>
      </div>
      <div>
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.16em] text-burn font-bold mb-1.5">We never</p>
        <p class="text-[0.88rem] text-ink-2 leading-relaxed">Sell your data. Share it with third-party recruiters. Use it for advertising. Use it to train a model. Send you marketing email.</p>
      </div>
      <div>
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.16em] text-burn font-bold mb-1.5">You can</p>
        <p class="text-[0.88rem] text-ink-2 leading-relaxed">Ask what we hold, correct it, or have it deleted. Anytime. Under DPDPA 2023 and GDPR Article 17.</p>
      </div>
    </div>
  </section>

  {SECTIONS.map((s) => (
    <section class="px-[5vw] py-10 md:py-12 max-w-3xl mx-auto border-t border-ink/8">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10">
        <div class="md:col-span-3">
          <p class="font-mono text-[0.7rem] uppercase tracking-[0.16em] text-burn font-bold mb-2">{s.tag}</p>
          <h2 class="font-display text-[clamp(1.2rem,2.2vw,1.6rem)] font-semibold text-ink leading-tight">{s.title}</h2>
        </div>
        <div class="md:col-span-9 space-y-4">
          {s.body.map((para: any) =>
            Array.isArray(para) ? (
              <ul class="space-y-1.5 pl-4 list-disc marker:text-burn/60">
                {para.map((item: string) => <li class="text-[0.95rem] text-ink-2 font-light leading-[1.8]" set:html={item} />)}
              </ul>
            ) : (
              <p class="text-[0.97rem] text-ink-2 font-light leading-[1.85]" set:html={para} />
            )
          )}
        </div>
      </div>
    </section>
  ))}

  <section class="px-[5vw] py-12 md:py-14 max-w-3xl mx-auto border-t border-ink/8">
    <div class="bg-burn-pale/40 border border-burn-dim rounded-2xl p-6 md:p-8 text-center">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-3">Last updated</p>
      <p class="font-display text-[1.2rem] text-ink mb-4">{lastUpdated}</p>
      <p class="text-[0.92rem] text-ink-soft leading-relaxed max-w-xl mx-auto mb-5">
        If you have read this and you are ready to apply, you are welcome to continue. If you have questions first, our admissions team responds within five business days.
      </p>
      <div class="flex gap-3 justify-center flex-wrap">
        <a href="/careers" class="bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-6 rounded-lg text-[0.9rem] no-underline">Browse open roles</a>
        <a href="mailto:hr@edurankai.in" class="bg-white hover:bg-cream-2 text-ink border border-ink/15 font-semibold py-2.5 px-6 rounded-lg text-[0.9rem] no-underline">Email hr@edurankai.in</a>
      </div>
    </div>
  </section>
</BaseLayout>
