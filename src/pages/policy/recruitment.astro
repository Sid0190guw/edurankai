---
import BaseLayout from '@/layouts/BaseLayout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'EduRankAI Recruitment & Work Policy v2.0',
  description: 'Binding recruitment, work, conduct, termination, exit, and rights policy. Applies from Day 1 to every intern, full-time, and senior team member.',
  publisher: { '@type': 'Organization', name: 'EduRankAI', url: 'https://www.edurankai.in' },
  inLanguage: 'en-IN',
  dateModified: '2026-05-31',
};

const principles = [
  { n: 'I',   t: 'Merit Over Pedigree',     d: 'What you have built, demonstrated, and proven always outweighs where you studied or worked. Credentials are signals. Work is evidence. We prioritise evidence.' },
  { n: 'II',  t: 'Radical Transparency',    d: 'Every candidate receives honest, specific feedback. Every decision is explainable. We never ghost, mislead, or delay without communication.' },
  { n: 'III', t: 'Objective Scoring',       d: 'All tasks are scored against a published rubric before any human reviews the result. Subjective impression cannot override objective score.' },
  { n: 'IV',  t: 'Holistic Assessment',     d: 'We hire across Physical, Mental, Emotional, Social, Spiritual — plus Intellectual, Innovative, Skilful, and Character. The person matters.' },
  { n: 'V',   t: 'Speed & Respect',         d: 'Every application is read by a human within 5 business days. Every decision is communicated within 5 business days of the final step.' },
  { n: 'VI',  t: 'Equal Opportunity',       d: 'EduRankAI recruits without discrimination on the basis of gender, religion, caste, nationality, disability, or socioeconomic background. The only criteria are capability, character, and commitment.' },
];

const processSteps = [
  { n: '01', tag: 'Entry',       t: 'Application Submission', d: 'Candidates submit via the official EduRankAI careers page. Applications must include a CV and a short covering note explaining why EduRankAI. Portfolio or proof-of-work is strongly encouraged and weighted positively. Applications sent via personal email, LinkedIn DM, or any channel other than the official portal are not accepted.', meta: 'All Roles · Required · No ATS screening' },
  { n: '02', tag: 'Screening',   t: 'Human Review',           d: 'Every application is read by a real person from the EduRankAI team. No automated keyword filtering. No ATS rejection. Reviewers evaluate based on the Priority Tier framework (Brilliance first, then institutional background) and provide a written assessment. Candidates who are not proceeding receive a written explanation within 5 business days.', meta: 'SLA: 5 business days' },
  { n: '03', tag: 'Assessment',  t: 'Task & Assessment',      d: 'Shortlisted candidates receive a role-specific task. Tasks are time-bounded, fair, and directly relevant to the role. For internships, tasks are completed within 48 hours. For full-time roles, up to 5 days. Candidates are told exactly what the task will assess, and the rubric dimensions they will be scored against.', meta: 'Internship: 48 hrs · Full-Time: 5 days · Rubric published upfront' },
  { n: '04', tag: 'Evaluation',  t: 'Scoring Engine Evaluation', d: 'Every submitted task is evaluated by EduRankAI\'s internal scoring engine before any human reviewer sees it. The engine scores across five weighted dimensions — Accuracy, Clarity, Depth, Originality, and Execution. A minimum score threshold must be met before the application proceeds to the interview stage. Scores and written feedback are shared with the candidate regardless of outcome.', meta: 'Objective rubric · Score shared · Human review follows' },
  { n: '05', tag: 'Interview',   t: 'Structured Interview',   d: 'Candidates who meet the scoring threshold proceed to a structured interview via video call. For internships, this is a 30-minute session. For senior and full-time roles, interviews may include multiple rounds. All interviews follow a standardised question framework. Holistic assessment is incorporated. Interviewers submit written scorecards within 24 hours.', meta: 'Internship: 30 min · Full-Time: Multi-round · Structured scorecard' },
  { n: '06', tag: 'Decision',    t: 'Offer & Onboarding',     d: 'Final decisions are communicated within 5 business days of the interview. Successful candidates receive a formal offer letter specifying role, start date, duration, work hours, and all relevant terms. All candidates — successful or not — receive written feedback. Accepted candidates begin onboarding within 14 days.', meta: 'Decision: 5 days · Feedback for all · Onboarding: 14 days' },
];

const scoreDims = [
  { e: '🎯', t: 'Accuracy',    w: '25%' },
  { e: '💡', t: 'Clarity',     w: '20%' },
  { e: '🔬', t: 'Depth',       w: '25%' },
  { e: '✨', t: 'Originality', w: '15%' },
  { e: '⚙️', t: 'Execution',   w: '15%' },
];

const scoreTiers = [
  { range: '85 – 100', tag: 'Exceptional',     d: 'Proceeds to interview. Fast-tracked for expanded responsibilities. Strong consideration for full-time conversion.', bg: '#dcfce7', bd: '#86efac', c: '#166534' },
  { range: '65 – 84',  tag: 'Competent',       d: 'Proceeds to interview. Standard track. Specific feedback provided for improvement areas.',                          bg: '#dbeafe', bd: '#93c5fd', c: '#1e40af' },
  { range: '45 – 64',  tag: 'Developing',      d: 'Does not proceed. Detailed written feedback given. May reapply after 60 days with demonstrated improvement.',          bg: '#fef9c3', bd: '#fde047', c: '#854d0e' },
  { range: '0 – 44',   tag: 'Below Threshold', d: 'Does not proceed. Feedback provided. Reapplication eligibility reviewed case-by-case after 90 days.',                  bg: '#fee2e2', bd: '#fca5a5', c: '#991b1b' },
];

const workPolicies = [
  { e: '⏱️', t: 'Internship Hours & Stipend', d: 'Part-time interns commit to exactly 2.5 hours of deep, focused work per day, 5 days per week — unpaid, exact (working under or over is equally a breach). Full-time interns outside Founder\'s Office now commit ~40 hours/week and earn a stipend of up to ₹25,000/month calibrated to level and contribution. Founder\'s Office interns remain unpaid regardless of mode, in exchange for direct founder access, revenue share, and equity conversations. Performance benchmarks are strict — we guide you through iteration, innovation, and reflection so you develop holistically.', m: 'Part-time: 2.5 hrs/day, unpaid · Full-time: 40 hrs/week, up to ₹25k/mo · Founder\'s Office: unpaid (equity track)' },
  { e: '🌐', t: 'Internship Work Mode',    d: 'All internships at EduRankAI are 100% remote. Interns work from wherever they are. There is no requirement to be in any specific location or time zone, provided daily availability windows are maintained.', m: '100% Remote · Any location · Any time zone · Coordination windows agreed at onboarding' },
  { e: '🏢', t: 'Full-Time Work Mode',     d: 'Full-time roles span all work modes — remote, hybrid, in-office, and field-based. Mode is determined by the nature of the role. Roles in sports, health, on-ground education, and physical research cannot be performed remotely. Work mode is stated explicitly in every offer letter.', m: 'All modes: Remote · Hybrid · In-Office · Field-based · Mode defined per role' },
  { e: '📊', t: 'Output Measurement',      d: 'We measure outcomes, not attendance. Every team member has clearly defined weekly deliverables scored by the scoring engine. Attendance without output is not recognised. Output without attendance records is fully recognised.', m: 'Weekly deliverables · Scored objectively · Output over presence · No surprise KPI changes' },
  { e: '📡', t: 'Communication Standards', d: 'EduRankAI operates async-first. Team members are not expected to respond instantly to messages. However, all messages must receive a response within 24 hours on working days. Status updates on deliverables are required weekly — not when asked. Silence is never acceptable as a response.', m: 'Async-first · 24hr response SLA · Weekly status updates · Proactive blocker reporting' },
  { e: '🌿', t: 'Wellbeing & Overwork',    d: 'EduRankAI is not a hustle-culture company. Burnout serves no one. Consistent overwork is flagged by managers as a performance concern, not a badge of honour. Working beyond committed hours for more than 3 consecutive weeks without approval is a policy breach.', m: 'No glorified overwork · Wellbeing tracked in reviews · Sustained overwork = policy breach' },
];

const breaches = [
  { b: 'Late deliverable (unreported)',  d: 'Missing a deadline without prior communication or documented reason.',                                                    sev: 'Level 1', act: 'Written warning · Noted in record' },
  { b: 'Hours breach (over or under)',   d: 'Consistently working significantly more or less than the committed hours without approval.',                              sev: 'Level 1', act: 'Counselling session · Written warning' },
  { b: 'Communication failure',          d: 'Failing to respond to messages within 24 hours repeatedly, or going silent on deliverables.',                             sev: 'Level 1', act: 'Warning · Performance review triggered' },
  { b: 'Misrepresentation',              d: 'Overstating qualifications, fabricating experience, or submitting others\' work as your own in any context.',             sev: 'Level 2', act: 'Immediate review · Likely termination · No certificate' },
  { b: 'Plagiarism / AI abuse',          d: 'Submitting AI-generated or plagiarised work without disclosure, in tasks, deliverables, or publications.',               sev: 'Level 2', act: 'Immediate review · Score voided · Possible termination' },
  { b: 'Unprofessional conduct',         d: 'Disrespectful, discriminatory, or hostile behaviour toward any team member or external party.',                          sev: 'Level 2', act: 'Formal investigation · Suspension pending review' },
  { b: 'Confidentiality breach',         d: 'Sharing proprietary information, internal documents, or team details with external parties without authorisation.',     sev: 'Level 3', act: 'Immediate termination · No certificate · Legal action possible' },
  { b: 'IP theft',                       d: 'Claiming, using, or selling EduRankAI intellectual property — code, models, data, or research — outside your role.',     sev: 'Level 3', act: 'Immediate termination · Legal proceedings' },
  { b: 'Conflict of interest (undisclosed)', d: 'Working simultaneously with a direct competitor or pursuing interests that conflict without prior disclosure.',     sev: 'Level 3', act: 'Immediate termination · No reference provided' },
  { b: 'Harassment or abuse',            d: 'Any form of harassment, bullying, sexual misconduct, or abusive behaviour toward any person connected to EduRankAI.',    sev: 'Level 3', act: 'Immediate termination · Formal report · Possible legal referral' },
];

const termCases = [
  { tag: '⚠️ With Prior Warning',    t: 'Performance-Based Termination', tone: 'amber',
    bullets: ['Triggered after 2 consecutive scoring periods below threshold','A formal Performance Improvement Plan (PIP) is issued first','PIP runs for 2 weeks with weekly check-ins','If PIP targets not met — formal termination with 7 days notice','Certificate issued for internship work completed to date','Reference provided at manager\'s discretion'] },
  { tag: '🚫 Immediate — No Warning', t: 'Conduct-Based Termination', tone: 'red',
    bullets: ['Effective immediately upon breach confirmation','No notice period. No appeal to continue engagement.','No certificate issued for any internship period','No reference letter provided','NDA remains binding post-termination','Legal action may follow for IP, confidentiality, or fraud breaches'] },
  { tag: '🔄 Voluntary', t: 'Resignation by Team Member', tone: 'sky',
    bullets: ['Interns: 7 days written notice required','Full-time: 30 days written notice required','Founder\'s Office: 14 days notice + handover document','Certificate issued for completed period in good standing','Exit interview offered','NDA remains binding indefinitely'] },
  { tag: '✅ Natural Completion', t: 'End of Engagement Period', tone: 'leaf',
    bullets: ['Certificate of completion issued within 7 days','Letter of Recommendation issued for strong performers','Formal exit interview conducted','Alumni status granted — community access maintained','Priority consideration for future full-time openings','Founder\'s Office exceptional performers enter conversion discussion'] },
];

const rights = [
  { e: '📄', t: 'Right to Written Communication', d: 'Every decision affecting your engagement — warnings, score results, deliverable changes, terminations — must be communicated in writing. Verbal-only decisions are not enforceable and must be confirmed in writing within 24 hours.' },
  { e: '📊', t: 'Right to Your Score',            d: 'Every task you submit — in hiring or during engagement — will have its score shared with you, along with structured written feedback. You are never evaluated invisibly. Scores cannot be withheld.' },
  { e: '🔁', t: 'Right to Appeal',                d: 'Any decision — performance review outcome, breach classification, or termination — may be appealed within 7 days. Appeals are reviewed by a senior leader not involved in the original decision. The outcome is binding and documented.' },
  { e: '🔒', t: 'Right to Confidentiality',       d: 'Personal information, performance records, and exit documentation are kept strictly confidential. No details of your engagement — including the existence of a disciplinary process — are shared externally without your written consent.' },
  { e: '🛡️', t: 'Right to Safe Environment',     d: 'You have the right to work — remotely or in-person — free from harassment, discrimination, bullying, or hostile conduct. Any report triggers an immediate, confidential investigation. Retaliation for reporting is itself a Level 3 breach.' },
  { e: '📬', t: 'Right to Raise Concerns',        d: 'Any team member may raise a concern about policy, management, culture, or conduct directly with the founders via a confidential channel. Concerns are acknowledged within 48 hours and resolved or formally responded to within 14 days.' },
];

const sevColors: Record<string,string> = { 'Level 1':'#a16207', 'Level 2':'#c2410c', 'Level 3':'#991b1b' };
---
<BaseLayout
  title="Recruitment & Work Policy v2.0 — EduRankAI"
  description="EduRankAI's binding recruitment, work, conduct, termination, exit, and rights policy. Six steps. Objective scoring. Transparent decisions. Applies from Day 1 to every team member.">

  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />

  <section class="px-[5vw] py-12 md:py-16 max-w-5xl mx-auto">
    <a href="/careers" class="inline-flex items-center gap-2 text-[0.8rem] font-mono text-ink-soft hover:text-burn transition-colors mb-6"><span>&larr;</span> Careers</a>

    <div class="flex flex-wrap items-center gap-2 mb-4">
      <span class="text-[0.65rem] font-mono uppercase tracking-wider text-burn bg-burn-pale border border-burn-dim px-2.5 py-1 rounded-full font-semibold">Official Document</span>
      <span class="text-[0.65rem] font-mono uppercase tracking-wider text-ink-soft bg-cream-2 border border-ink/10 px-2.5 py-1 rounded-full">Version 2.0 · Effective May 2026</span>
      <span class="text-[0.65rem] font-mono uppercase tracking-wider text-leaf bg-leaf-bg/60 border border-leaf-border px-2.5 py-1 rounded-full font-semibold">Active Policy</span>
    </div>

    <p class="eyebrow mb-3">EduRankAI</p>
    <h1 class="section-title mb-5">Recruitment <em>&amp; Work</em> Policy</h1>
    <p class="text-[0.95rem] text-ink-2 leading-[1.85] font-light max-w-3xl mb-6">This document governs how EduRankAI attracts, evaluates, onboards, manages, and where necessary, parts ways with every intern and full-time team member. It is binding, transparent, and applies to all roles at all levels — without exception.</p>
    <div class="flex flex-wrap gap-2 mb-12">
      <span class="text-[0.75rem] font-semibold px-3 py-1.5 rounded-md bg-burn-pale text-burn border border-burn-dim">Binding on All Roles</span>
      <span class="text-[0.75rem] font-semibold px-3 py-1.5 rounded-md bg-cream-2 text-ink border border-ink/10">Applies from Day 1</span>
      <span class="text-[0.75rem] font-semibold px-3 py-1.5 rounded-md bg-cream-2 text-ink border border-ink/10">Internship</span>
      <span class="text-[0.75rem] font-semibold px-3 py-1.5 rounded-md bg-cream-2 text-ink border border-ink/10">Full-Time</span>
      <span class="text-[0.75rem] font-semibold px-3 py-1.5 rounded-md bg-cream-2 text-ink border border-ink/10">Founder's Office</span>
      <span class="text-[0.75rem] font-semibold px-3 py-1.5 rounded-md bg-cream-2 text-ink border border-ink/10">C-Level</span>
      <span class="text-[0.75rem] font-semibold px-3 py-1.5 rounded-md bg-cream-2 text-ink border border-ink/10">Remote &amp; On-site</span>
    </div>

    <nav class="bg-cream-2 border border-ink/10 rounded-xl p-5 mb-14 grid grid-cols-2 md:grid-cols-4 gap-3 text-[0.85rem]">
      <a href="#principles" class="font-semibold text-burn hover:underline">01 · Principles</a>
      <a href="#process" class="font-semibold text-burn hover:underline">02 · Process</a>
      <a href="#scoring" class="font-semibold text-burn hover:underline">03 · Scoring Engine</a>
      <a href="#work" class="font-semibold text-burn hover:underline">04 · Work Policy</a>
      <a href="#conduct" class="font-semibold text-burn hover:underline">05 · Conduct</a>
      <a href="#termination" class="font-semibold text-burn hover:underline">06 · Termination</a>
      <a href="#exit" class="font-semibold text-burn hover:underline">07 · Exit Policy</a>
      <a href="#rights" class="font-semibold text-burn hover:underline">08 · Rights &amp; Appeals</a>
    </nav>

    <section id="principles" class="mb-16">
      <p class="eyebrow mb-3">01 · Foundation</p>
      <h2 class="font-display text-[clamp(1.6rem,3vw,2.2rem)] font-semibold text-ink mb-3">Recruitment Principles</h2>
      <p class="text-[0.9rem] text-ink-2 leading-[1.85] font-light mb-6 max-w-3xl">Every decision we make in recruitment — from first application to final offer — is grounded in these six non-negotiable principles. They are not aspirational. They are operational.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {principles.map((p) => (
          <div class="bg-white border border-ink/10 rounded-xl p-5">
            <div class="flex items-baseline gap-3 mb-2">
              <span class="font-display text-[1.3rem] font-bold text-burn">{p.n}</span>
              <span class="font-display text-[1.05rem] font-semibold text-ink">{p.t}</span>
            </div>
            <p class="text-[0.85rem] text-ink-2 leading-relaxed font-light">{p.d}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="process" class="mb-16">
      <p class="eyebrow mb-3">02 · Recruitment Process</p>
      <h2 class="font-display text-[clamp(1.6rem,3vw,2.2rem)] font-semibold text-ink mb-3">Six steps. No surprises.</h2>
      <p class="text-[0.9rem] text-ink-2 leading-[1.85] font-light mb-6 max-w-3xl">Every candidate — intern or senior hire — goes through the same structured, documented process. Steps cannot be skipped. Offers cannot be made outside this process.</p>
      <div class="flex flex-col gap-3">
        {processSteps.map((s) => (
          <div class="bg-white border border-ink/10 rounded-xl p-5 md:p-6 flex gap-4">
            <div class="shrink-0 w-12 h-12 rounded-full bg-burn-pale border border-burn-dim flex items-center justify-center font-display text-[1.1rem] font-bold text-burn">{s.n}</div>
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-2">
                <span class="eyebrow">{s.tag}</span>
                <span class="font-display text-[1.05rem] font-semibold text-ink">{s.t}</span>
              </div>
              <p class="text-[0.86rem] text-ink-2 leading-[1.8] font-light mb-3">{s.d}</p>
              <p class="text-[0.72rem] font-mono uppercase tracking-wider text-burn">{s.meta}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section id="scoring" class="mb-16">
      <p class="eyebrow mb-3">03 · Scoring Engine</p>
      <h2 class="font-display text-[clamp(1.6rem,3vw,2.2rem)] font-semibold text-ink mb-3">Every task scored. Every score explained.</h2>
      <p class="text-[0.9rem] text-ink-2 leading-[1.85] font-light mb-6 max-w-3xl">The scoring engine is the backbone of EduRankAI's objective, bias-free evaluation. It applies at two stages: during hiring (task evaluation) and throughout the engagement (ongoing deliverable scoring). Both use the same framework.</p>

      <h3 class="font-display text-[1.1rem] font-semibold text-ink mb-3">Five Scoring Dimensions — Applied to Every Task</h3>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-2 mb-8">
        {scoreDims.map((d) => (
          <div class="bg-white border border-ink/10 rounded-xl p-4 text-center">
            <div class="text-[1.6rem] mb-1">{d.e}</div>
            <p class="font-display text-[0.95rem] font-semibold text-ink">{d.t}</p>
            <p class="text-[0.85rem] font-mono text-burn font-semibold">{d.w}</p>
          </div>
        ))}
      </div>

      <h3 class="font-display text-[1.1rem] font-semibold text-ink mb-3">Score Tiers &amp; Consequences</h3>
      <div class="flex flex-col gap-2 mb-6">
        {scoreTiers.map((t) => (
          <div class="rounded-xl p-4 md:p-5" style={`background:${t.bg};border:1px solid ${t.bd};color:${t.c};`}>
            <div class="flex flex-wrap items-baseline gap-3 mb-1">
              <span class="font-display text-[1.1rem] font-bold">{t.range}</span>
              <span class="text-[0.75rem] font-mono uppercase tracking-wider font-bold">{t.tag}</span>
            </div>
            <p class="text-[0.86rem] leading-[1.7]">{t.d}</p>
          </div>
        ))}
      </div>

      <div class="bg-ink/[0.04] border-l-4 border-burn rounded-xl p-5 md:p-6">
        <p class="eyebrow mb-2">⚖️ Human Oversight Clause</p>
        <p class="text-[0.86rem] text-ink-2 leading-[1.8] font-light">The scoring engine informs — it does not decide. All engine scores are reviewed by a human before any communication is sent to the candidate. A human reviewer may escalate a borderline score (64–66) to leadership for a second opinion. Engine scores may never be manually lowered after the fact. They may only be escalated upward through a documented review process.</p>
      </div>
    </section>

    <section id="work" class="mb-16">
      <p class="eyebrow mb-3">04 · Work Policy</p>
      <h2 class="font-display text-[clamp(1.6rem,3vw,2.2rem)] font-semibold text-ink mb-3">Hours, output, and expectations.</h2>
      <p class="text-[0.9rem] text-ink-2 leading-[1.85] font-light mb-6 max-w-3xl">EduRankAI's work culture is built on precise expectations, not vague aspirations. What is expected is stated here. What is not stated is not expected.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {workPolicies.map((p) => (
          <div class="bg-white border border-ink/10 rounded-xl p-5">
            <div class="flex items-baseline gap-3 mb-2"><span class="text-[1.4rem]">{p.e}</span><span class="font-display text-[1rem] font-semibold text-ink">{p.t}</span></div>
            <p class="text-[0.85rem] text-ink-2 leading-relaxed font-light mb-3">{p.d}</p>
            <p class="text-[0.72rem] font-mono uppercase tracking-wider text-burn leading-relaxed">{p.m}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="conduct" class="mb-16">
      <p class="eyebrow mb-3">05 · Code of Conduct</p>
      <h2 class="font-display text-[clamp(1.6rem,3vw,2.2rem)] font-semibold text-ink mb-3">Standards of behaviour.</h2>
      <p class="text-[0.9rem] text-ink-2 leading-[1.85] font-light mb-6 max-w-3xl">All team members — intern and full-time — are bound by this code from Day 1. Severity levels determine the response. All breaches are documented. No breach goes unrecorded.</p>
      <div class="overflow-x-auto bg-white border border-ink/10 rounded-xl">
        <table class="w-full text-[0.85rem]">
          <thead>
            <tr class="bg-cream-2 border-b border-ink/10 text-left">
              <th class="px-4 py-3 font-mono uppercase text-[0.7rem] tracking-wider text-ink-soft">Breach</th>
              <th class="px-4 py-3 font-mono uppercase text-[0.7rem] tracking-wider text-ink-soft">Description</th>
              <th class="px-4 py-3 font-mono uppercase text-[0.7rem] tracking-wider text-ink-soft">Severity</th>
              <th class="px-4 py-3 font-mono uppercase text-[0.7rem] tracking-wider text-ink-soft">Action</th>
            </tr>
          </thead>
          <tbody>
            {breaches.map((row) => (
              <tr class="border-b border-ink/5 last:border-0">
                <td class="px-4 py-3 font-semibold text-ink align-top">{row.b}</td>
                <td class="px-4 py-3 text-ink-2 font-light align-top">{row.d}</td>
                <td class="px-4 py-3 align-top"><span class="text-[0.7rem] font-mono uppercase tracking-wider font-bold" style={`color:${sevColors[row.sev] || '#374151'};`}>{row.sev}</span></td>
                <td class="px-4 py-3 text-ink-2 font-light align-top">{row.act}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="bg-burn-pale/40 border-l-4 border-burn rounded-xl p-5 mt-6">
        <p class="font-display font-semibold text-ink text-[0.95rem] mb-1">📋 Three-Strike Rule — Level 1 Breaches</p>
        <p class="text-[0.85rem] text-ink-2 leading-[1.8] font-light">Three documented Level 1 breaches within a single engagement period automatically escalate to a Level 2 formal review, regardless of the time gap between them. Level 1 warnings do not expire.</p>
      </div>
    </section>

    <section id="termination" class="mb-16">
      <p class="eyebrow mb-3">06 · Termination Policy</p>
      <h2 class="font-display text-[clamp(1.6rem,3vw,2.2rem)] font-semibold text-ink mb-3">When and how we part ways.</h2>
      <p class="text-[0.9rem] text-ink-2 leading-[1.85] font-light mb-6 max-w-3xl">Termination is the last resort, not the first response. Every termination must be documented, reviewed, and where possible, preceded by a warning. The process is fair — and it is final.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {termCases.map((c) => (
          <div class={'rounded-xl p-5 border ' + (
            c.tone === 'amber' ? 'bg-gold-bg/30 border-gold-border'
            : c.tone === 'red' ? 'bg-red-50 border-red-200'
            : c.tone === 'sky' ? 'bg-sky-bg/30 border-sky-border'
            : 'bg-leaf-bg/30 border-leaf-border')}>
            <p class="text-[0.72rem] font-mono uppercase tracking-wider text-ink-soft mb-1">{c.tag}</p>
            <p class="font-display text-[1.05rem] font-semibold text-ink mb-3">{c.t}</p>
            <ul class="space-y-1.5 text-[0.84rem] text-ink-2 font-light leading-relaxed">
              {c.bullets.map((b) => (<li class="flex gap-2"><span class="text-burn shrink-0">→</span><span>{b}</span></li>))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section id="exit" class="mb-16">
      <p class="eyebrow mb-3">07 · Exit Policy</p>
      <h2 class="font-display text-[clamp(1.6rem,3vw,2.2rem)] font-semibold text-ink mb-3">How we close well.</h2>
      <p class="text-[0.9rem] text-ink-2 leading-[1.85] font-light mb-6 max-w-3xl">A good exit is as important as a good onboarding. Whether voluntary, performance-based, or natural completion — we close every engagement with structure, clarity, and respect.</p>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-3 mb-8">
        {[
          { n: '01', t: 'Notice Served', d: 'Written notice submitted via official channel. Date confirmed by both parties in writing.' },
          { n: '02', t: 'Knowledge Handover', d: 'Structured handover document completed. All in-progress work documented. Passwords, assets, and files transferred to manager.' },
          { n: '03', t: 'Exit Interview', d: '30-minute structured exit interview. Feedback on experience, culture, management, and growth. Anonymous option available.' },
          { n: '04', t: 'Documents Issued', d: 'Certificate, LoR (if applicable), final scoring summary, and NDA reminder issued within 7 days of last working day.' },
        ].map((s) => (
          <div class="bg-cream-2 border border-ink/10 rounded-xl p-4">
            <p class="eyebrow mb-1">{s.n}</p>
            <p class="font-display text-[0.98rem] font-semibold text-ink mb-1.5">{s.t}</p>
            <p class="text-[0.82rem] text-ink-2 font-light leading-relaxed">{s.d}</p>
          </div>
        ))}
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        <div class="bg-leaf-bg/30 border border-leaf-border rounded-xl p-5">
          <p class="font-display font-semibold text-leaf mb-3">Post-Exit: What You Keep</p>
          <ul class="space-y-1.5 text-[0.86rem] text-ink-2 font-light leading-relaxed">
            <li class="flex gap-2"><span>✅</span><span>Certificate of completion (if in good standing)</span></li>
            <li class="flex gap-2"><span>✅</span><span>Letter of Recommendation (if earned)</span></li>
            <li class="flex gap-2"><span>✅</span><span>Alumni community access</span></li>
            <li class="flex gap-2"><span>✅</span><span>Right to list EduRankAI on your CV and LinkedIn</span></li>
            <li class="flex gap-2"><span>✅</span><span>Your personal work and portfolio from your period</span></li>
          </ul>
        </div>
        <div class="bg-plum-bg/30 border border-plum-border rounded-xl p-5">
          <p class="font-display font-semibold text-plum mb-3">Post-Exit: What Remains Bound</p>
          <ul class="space-y-1.5 text-[0.86rem] text-ink-2 font-light leading-relaxed">
            <li class="flex gap-2"><span>🔒</span><span>Non-Disclosure Agreement — indefinitely</span></li>
            <li class="flex gap-2"><span>🔒</span><span>IP ownership for all work created during engagement</span></li>
            <li class="flex gap-2"><span>🔒</span><span>Non-solicitation of EduRankAI team (12 months)</span></li>
            <li class="flex gap-2"><span>🔒</span><span>Non-disparagement clause (12 months)</span></li>
            <li class="flex gap-2"><span>🔒</span><span>No use of EduRankAI name for unapproved commercial purposes</span></li>
          </ul>
        </div>
      </div>
    </section>

    <section id="rights" class="mb-16">
      <p class="eyebrow mb-3">08 · Rights &amp; Appeals</p>
      <h2 class="font-display text-[clamp(1.6rem,3vw,2.2rem)] font-semibold text-ink mb-3">Your rights. Clearly stated.</h2>
      <p class="text-[0.9rem] text-ink-2 leading-[1.85] font-light mb-6 max-w-3xl">Every person who works with EduRankAI — at any level — holds these rights. They are non-waivable and cannot be overridden by any manager, policy update, or verbal agreement.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-8">
        {rights.map((r) => (
          <div class="bg-white border border-ink/10 rounded-xl p-5">
            <div class="flex items-baseline gap-3 mb-2"><span class="text-[1.4rem]">{r.e}</span><span class="font-display text-[1rem] font-semibold text-ink">{r.t}</span></div>
            <p class="text-[0.85rem] text-ink-2 leading-relaxed font-light">{r.d}</p>
          </div>
        ))}
      </div>
      <h3 class="font-display text-[1.1rem] font-semibold text-ink mb-3">How to Submit an Appeal</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        {[
          { n: 'Step 1', t: 'Submit in Writing',   d: 'Email hr@edurankai.in with subject line: APPEAL — [Your Name] — [Decision Date]. Include the decision you are appealing and your grounds.' },
          { n: 'Step 2', t: 'Independent Review',  d: 'A senior leader not involved in the original decision reviews the appeal within 7 days. You may be asked for additional information.' },
          { n: 'Step 3', t: 'Written Outcome',     d: 'The appeal outcome is communicated in writing within 7 days of the review. The outcome — uphold, modify, or overturn — is final and documented.' },
        ].map((s) => (
          <div class="bg-cream-2 border border-ink/10 rounded-xl p-5">
            <p class="eyebrow mb-1">{s.n}</p>
            <p class="font-display text-[0.98rem] font-semibold text-ink mb-1.5">{s.t}</p>
            <p class="text-[0.82rem] text-ink-2 font-light leading-relaxed">{s.d}</p>
          </div>
        ))}
      </div>
    </section>

    <div class="bg-ink text-white rounded-2xl p-8 md:p-10 text-center">
      <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-burn mb-3">Ready to Apply?</p>
      <h3 class="font-display text-[1.8rem] md:text-[2.2rem] font-semibold leading-tight mb-3">You've read the policy. Now show us who you are.</h3>
      <p class="text-[0.92rem] text-white/80 leading-relaxed mb-6 max-w-xl mx-auto">Every application is read by a human. Every score is shared. Every decision is explained. Apply with confidence.</p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/careers" class="inline-block bg-burn hover:bg-burn/90 font-semibold px-7 py-3 rounded-lg text-[0.95rem]">View open roles &rarr;</a>
        <a href="/policy/hiring" class="inline-block bg-white/10 hover:bg-white/15 font-semibold px-7 py-3 rounded-lg text-[0.95rem] border border-white/20">Hiring Policy</a>
        <a href="/policy/work-culture" class="inline-block bg-white/10 hover:bg-white/15 font-semibold px-7 py-3 rounded-lg text-[0.95rem] border border-white/20">Work Culture</a>
      </div>
    </div>
  </section>
</BaseLayout>
