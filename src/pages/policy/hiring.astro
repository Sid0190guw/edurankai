---
import BaseLayout from '@/layouts/BaseLayout.astro';

const policySchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'EduRankAI Hiring Policy',
  description: 'Official hiring policy: candidate priority tiers, holistic standard, internship + full-time policies, domains, application process. Published for transparency.',
  publisher: { '@type': 'Organization', name: 'EduRankAI', url: 'https://www.edurankai.in' },
  inLanguage: 'en-IN',
  dateModified: '2026-05-31',
};

const tiers = [
  { n: 1, weight: 'Highest', title: 'Brilliance & Character', sub: 'Independent of institution', color: 'plum' },
  { n: 2, weight: 'Strong', title: "World's Top Institutions", sub: 'Ivy League, IITs, Russell Group, CFTIs', color: 'burn' },
  { n: 3, weight: 'Considered', title: 'New CFTIs & Global Universities', sub: 'Newer central institutions worldwide', color: 'sky' },
  { n: 4, weight: 'Considered', title: 'Top Private Universities', sub: 'Recognised private institutions globally', color: 'leaf' },
  { n: 5, weight: 'Open', title: 'All Other Universities', sub: 'Any background welcome', color: 'gold' },
];

const internshipPolicies = [
  { icon: '💰', t: 'Compensation', d: 'Full-time internships in every department EXCEPT Founder\'s Office now carry a stipend of up to ₹25,000 per month, calibrated to level and demonstrated contribution. Part-time internships and ALL Founder\'s Office internships remain unpaid — Founder\'s Office trades cash for direct founder access, revenue share, and equity conversation eligibility. Performance benchmarks are strict, but we walk every intern through iteration, innovation, and reflection so you feel your inner-self develop holistically alongside your craft.', m: 'Full-time: up to ₹25,000/mo · Part-time + Founder\'s Office: unpaid' },
  { icon: '⏰', t: 'Strict Productivity Hours', d: 'We are strict about hours — but not in the way most companies are. We do not want more than the committed hours, and we do not accept less. The 2.5 hours are deep-work hours: no multitasking, no passive attendance.', m: 'Exactly 2.5 hrs/day · 5 days/week · No more · No less · Deep work only' },
  { icon: '🌐', t: 'Work Mode', d: 'All internships are remote-only. You work from wherever you are. We coordinate across time zones via async-first communication.', m: '100% Remote · No relocation required · Async-first' },
  { icon: '📅', t: 'Duration', d: 'Standard internships run for 3 months. Founder\'s Office internships may extend to 6 months based on performance and project scope.', m: 'Standard: 3 months · Founder\'s Office: up to 6 months' },
  { icon: '📜', t: 'Certificate & Letter', d: 'All interns who complete the programme in good standing receive an official EduRankAI internship certificate. Outstanding performers receive a personalised letter of recommendation from leadership.', m: 'Certificate: All completers · LoR: Performance-based' },
  { icon: '🚀', t: 'Full-Time Conversion', d: 'Strong interns are considered first for any full-time openings. We prefer to promote from within. Exceptional Founder\'s Office interns may enter equity or co-founder conversations.', m: 'FT priority: Exceptional interns · Timeline: Post-series A' },
  { icon: '🛡️', t: 'Code of Conduct', d: 'Interns are bound by EduRankAI\'s confidentiality agreement and code of conduct. Any breach of trust results in immediate termination with no certificate issued.', m: 'NDA required · Immediate termination for breach' },
  { icon: '📋', t: 'Performance Review', d: 'Every intern receives a structured mid-point check-in (Week 6) and a final review (Week 12). Feedback is honest, specific, and developmental — not just a rubber stamp.', m: 'Mid-point: Week 6 · Final review: Week 12' },
  { icon: '🎓', t: 'Eligibility', d: 'We accept interns from any educational background, at any stage — current students, recent graduates, career-changers, and self-taught individuals are all welcome to apply.', m: 'Open to all · No minimum GPA · No minimum year of study' },
  { icon: '🔄', t: 'Rolling Admissions', d: 'We accept internship applications on a rolling basis. There is no single deadline. However, applying early significantly increases your chances as cohort spots are limited.', m: 'Rolling · No fixed deadline · Apply early for best chances' },
  { icon: '🌍', t: 'Global Reach', d: 'We hire interns from any country in the world. There are no geographic restrictions. You must be able to communicate effectively in English and maintain the required daily availability.', m: 'Open globally · English required · Any timezone' },
  { icon: '📊', t: 'Task Scoring Engine', d: 'Every task — during the hiring process and throughout the internship — is evaluated by our internal scoring engine. Scores are objective, rubric-based, and shared with you transparently.', m: 'Every task scored · Rubric-based · Transparent · Shared with intern' },
];

const fullTimeOffers = [
  { t: 'All Work Modes — Role Dependent', d: 'Full-time roles span all work modes: fully remote, hybrid, in-office, and field-based. Many positions — particularly in sports, health, physical education, on-ground research, and in-person education delivery — cannot be performed online. Work mode is defined per role and agreed at offer stage.' },
  { t: 'Compensation', d: 'Competitive salary benchmarked to industry. Currently not disclosed on job listings — discussed at offer stage. Equity is available for senior and leadership roles.' },
  { t: 'Early-Stage Opportunity', d: 'Joining early means significant ownership, direct founder access, broad scope of impact, and the potential for equity upside as EduRankAI scales.' },
  { t: 'Learning & Growth', d: 'We invest in the development of our team. Conferences, courses, research access, and time set aside for learning are part of our culture.' },
  { t: 'Mission-Aligned Work', d: 'You will be working on frontier AI — models, systems, and products with the potential to change how humanity learns. The work is real, hard, and important.' },
];

const fullTimeExpect = [
  { t: 'Ownership Mentality', d: 'You are responsible for outcomes, not just tasks. We do not micromanage. We hire people who take their work personally and see it through.' },
  { t: 'Availability for Collaboration', d: 'Regardless of location, full-time team members maintain core hours for synchronous collaboration. This window is agreed at onboarding based on team timezone overlap.' },
  { t: 'High Quality Standard', d: 'We expect your best work — not perfection, but genuine effort and craft. We are building something that matters. Mediocrity is not something we tolerate in ourselves or others.' },
  { t: 'Continuous Learning', d: 'The field moves fast. We expect team members to stay current with developments in their domain — reading papers, following the field, and sharing knowledge with the team.' },
  { t: 'Holistic Wellbeing', d: 'We are not a hustle-culture company. We expect you to take care of yourself — physically, mentally, emotionally, and spiritually. Burnout helps no one, least of all the mission.' },
];

const domains = [
  { icon: '⚙️', tag: 'Core', t: 'Engineering & Technology', d: 'CS, EE, Mech, Civil, Chemical, Aerospace. Core technical talent for model building, infra, and product.' },
  { icon: '🔬', tag: 'Research', t: 'Natural Sciences', d: 'Physics, Math, Chemistry, Biology. The mathematical and scientific rigour that underpins ML research.' },
  { icon: '📊', tag: 'Growth', t: 'Business & Management', d: 'Strategy, Finance, Marketing, Operations. Needed to commercialise and scale what we build.' },
  { icon: '📖', tag: 'Safety', t: 'Humanities & Social Sciences', d: 'Philosophy, Linguistics, Psychology, Sociology, Literature. Critical for AI safety, alignment, language models, and ethical AI.' },
  { icon: '⚖️', tag: 'Governance', t: 'Law & Policy', d: 'Legal, Regulatory, Public Policy. Essential for navigating AI regulation, IP, contracts, and governance.' },
  { icon: '🏥', tag: 'Frontier', t: 'Health & Medicine', d: 'Medicine, Public Health, Biotech, Neuroscience. AI\'s convergence with healthcare is one of our long-term frontiers.' },
  { icon: '🏋️', tag: 'Emerging', t: 'Sports & Physical Education', d: 'Sport Science, Coaching, Physiology, Performance Analysis. AI in sports education and performance optimisation is an active product area.' },
  { icon: '🎨', tag: 'Product', t: 'Design & Arts', d: 'UI/UX, Industrial Design, Fine Arts, Architecture. The humans who interact with AI need beautiful, thoughtful interfaces. Design is not optional.' },
  { icon: '🌐', tag: 'Data', t: 'Linguistics & Languages', d: 'Computational linguistics, translation, Sanskrit, regional languages. EduRankAI is multilingual by design.' },
  { icon: '⚛️', tag: 'Research', t: 'Quantum & Physics', d: 'Quantum Computing, Theoretical Physics, Applied Math. A small but critical team exploring post-classical computing for AI acceleration.' },
  { icon: '🧠', tag: 'Core', t: 'Psychology & Cognitive Science', d: 'Behavioural science, learning theory, HCI, educational psychology. The science of how humans learn drives every design and model decision we make.' },
  { icon: '📡', tag: 'Core', t: 'Data & Statistics', d: 'Statistics, Data Science, Econometrics, Operations Research. Our models are only as good as our data — this team is the backbone of everything we build.' },
];

const steps = [
  { n: '01', t: 'Application', d: 'Submit via our careers page. CV, portfolio or proof of work, and a short note on why EduRankAI.' },
  { n: '02', t: 'Human Review', d: 'A real person reads every application. No ATS. No keyword filtering. Every submission is seen personally.' },
  { n: '03', t: 'Task & Assessment', d: 'A focused, role-relevant task. Time-bound and specific. Designed to reveal real capability, not textbook knowledge.' },
  { n: '04', t: 'Scoring Engine', d: 'Every submitted task is evaluated by our internal scoring engine — objective criteria, weighted rubrics, zero bias. You receive a score and structured feedback.' },
  { n: '05', t: 'Interview', d: 'A structured interview based on your task score and application. We go deep on thinking, judgment, and fit — not rehearsed answers.' },
  { n: '06', t: 'Offer', d: 'Decision within 5 business days of interview. Offer letter issued. Onboarding begins within 2 weeks.' },
];
---
<BaseLayout
  title="Hiring Policy — EduRankAI"
  description="Official EduRankAI hiring policy. Candidate priority tiers, holistic standard, internship + full-time policies, domains, application process. Brilliance always outweighs university tier.">

  <script is:inline type="application/ld+json" set:html={JSON.stringify(policySchema)} />

  <section class="px-[5vw] py-12 md:py-16 max-w-5xl mx-auto">
    <a href="/careers" class="inline-flex items-center gap-2 text-[0.8rem] font-mono text-ink-soft hover:text-burn transition-colors mb-6"><span>&larr;</span> Back to Careers</a>

    <p class="eyebrow mb-3">EduRankAI · Hiring Policy Document · v1 · 2026</p>
    <h1 class="section-title mb-5">Categorization, <em>Internship</em> &amp; Job Policies</h1>
    <p class="text-[0.95rem] md:text-[1rem] text-ink-2 leading-[1.85] font-light max-w-3xl mb-8">
      We believe exceptional talent can come from anywhere. This page explains exactly how we evaluate candidates, what gives you a stronger application, and what our policies mean in practice. We publish this because transparency is a form of respect.
    </p>

    <div class="rounded-2xl p-5 md:p-6 mb-12" style="background:#fff7ed;border-left:4px solid #c2410c;">
      <p class="text-[0.92rem] text-ink-2 leading-[1.85]"><strong style="color:#7c2d12;">📌 The most important thing to know:</strong> Category 1 — brilliance, sharpness, and character — always outweighs university tier. A Category 1 candidate from a lesser-known institution will always be preferred over a mediocre candidate from an Ivy League school. <em>University is a signal, not a gate.</em></p>
    </div>

    <nav class="bg-cream-2 border border-ink/10 rounded-xl p-5 mb-12 grid grid-cols-2 md:grid-cols-4 gap-3 text-[0.85rem]">
      <a href="#tiers" class="font-semibold text-burn hover:underline">Candidate Tiers</a>
      <a href="#principles" class="font-semibold text-burn hover:underline">Hiring Principles</a>
      <a href="#holistic" class="font-semibold text-burn hover:underline">Holistic Standard</a>
      <a href="#internship" class="font-semibold text-burn hover:underline">Internship Policy</a>
      <a href="#fulltime" class="font-semibold text-burn hover:underline">Full-Time Policy</a>
      <a href="#domains" class="font-semibold text-burn hover:underline">Domain Coverage</a>
      <a href="#process" class="font-semibold text-burn hover:underline">Application Process</a>
      <a href="/policy/recruitment" class="font-semibold text-burn hover:underline">Recruitment &amp; Conduct →</a>
    </nav>

    <section id="tiers" class="mb-16">
      <p class="eyebrow mb-3">01 · Candidate Categorization</p>
      <h2 class="font-display text-[clamp(1.6rem,3vw,2.2rem)] font-semibold text-ink mb-3">Our hiring priority tiers</h2>
      <p class="text-[0.9rem] text-ink-2 leading-[1.85] font-light mb-6 max-w-3xl">We evaluate every candidate across five priority tiers. These tiers do not eliminate candidates — they reflect how we weight applications when making decisions between equally strong pools.</p>

      <div class="flex flex-col gap-3 mb-8">
        {tiers.map((t) => (
          <div class="bg-white border border-ink/10 rounded-xl p-5 md:p-6 flex items-start gap-4">
            <div class="shrink-0 w-12 h-12 rounded-full bg-burn-pale border border-burn-dim flex items-center justify-center font-display text-[1.3rem] font-bold text-burn">{t.n}</div>
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-1">
                <h3 class="font-display text-[1.05rem] font-semibold text-ink">{t.title}</h3>
                <span class="text-[0.7rem] font-mono uppercase tracking-wider text-burn">{t.weight}</span>
              </div>
              <p class="text-[0.85rem] text-ink-soft font-light">{t.sub}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="bg-burn-pale/40 border-l-4 border-burn rounded-xl p-6 md:p-8">
        <p class="eyebrow mb-3">Priority 1 · Always Preferred</p>
        <h3 class="font-display text-[1.3rem] font-semibold text-ink mb-3">Brilliant, Niche, Sharp, Essence &amp; Exceptional</h3>
        <p class="text-[0.9rem] text-ink-2 leading-[1.85] font-light mb-5">The single most important category. A person who demonstrates rare intellectual sharpness, unique depth of knowledge, exceptional execution, or a quality that makes them genuinely one of a kind — regardless of where they studied. This is what we're always hunting for.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-5">
          {[
            { e: '⚡', t: 'Sharp Mind', d: 'Thinks from first principles. Sees patterns others miss. Asks the questions nobody thought to ask.' },
            { e: '🎯', t: 'Exceptional Execution', d: 'Ships things. Has built something real — a project, a product, a research paper, anything that demonstrates follow-through.' },
            { e: '🔬', t: 'Niche Mastery', d: 'Knows something very deeply. A narrow, rare expertise that most people don\'t have — and that\'s exactly why we want it.' },
            { e: '✨', t: 'Essence & Character', d: 'Holistically excellent. Balanced across mind, body, and spirit. The kind of person who raises the bar simply by being in the room.' },
          ].map((x) => (
            <div class="bg-white rounded-xl p-4 border border-burn-dim/40">
              <div class="text-[1.5rem] mb-1">{x.e}</div>
              <p class="font-display text-[0.95rem] font-semibold text-ink mb-1">{x.t}</p>
              <p class="text-[0.82rem] text-ink-2 leading-relaxed font-light">{x.d}</p>
            </div>
          ))}
        </div>
        <p class="text-[0.85rem] text-ink-2 leading-relaxed"><strong>💡 How to demonstrate this:</strong> A strong portfolio, an unusual project, a research contribution, open-source work, a self-taught skill taken to an exceptional level, or a compelling personal story of building something from nothing. We read everything.</p>
      </div>
    </section>

    <section id="principles" class="mb-16">
      <p class="eyebrow mb-3">The EduRankAI Hiring Principle</p>
      <blockquote class="border-l-4 border-burn pl-6 mb-8">
        <p class="font-display text-[1.1rem] md:text-[1.3rem] text-ink italic leading-snug mb-3">
          "We would rather hire a brilliant dropout who has shipped something real than a mediocre graduate from the world's most famous university. The degree tells us where you've been. <em class="text-burn">Your work tells us who you are.</em>"
        </p>
        <p class="text-[0.78rem] font-mono text-ink-soft">— EduRankAI Founding Philosophy · 2026</p>
      </blockquote>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {[
          { e: '🧠', t: 'Mind over Credential', d: 'We hire for how you think, not where you studied. First-principles reasoning always outranks prestige.' },
          { e: '🔨', t: 'Work over Words', d: 'Show us something you built, wrote, designed, or published. Proof of work is the most honest signal we know.' },
          { e: '🌱', t: 'Character over Résumé', d: 'We are hiring humans, not qualifications. Integrity, curiosity, and dedication are not on a transcript but they are the most important things we look for.' },
        ].map((x) => (
          <div class="bg-cream-2 border border-ink/10 rounded-xl p-5">
            <div class="text-[1.6rem] mb-2">{x.e}</div>
            <p class="font-display text-[1rem] font-semibold text-ink mb-1.5">{x.t}</p>
            <p class="text-[0.85rem] text-ink-2 leading-relaxed font-light">{x.d}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="holistic" class="mb-16">
      <p class="eyebrow mb-3">02 · Complete Human Standard</p>
      <h2 class="font-display text-[clamp(1.6rem,3vw,2.2rem)] font-semibold text-ink mb-3">We see the whole person.</h2>
      <p class="text-[0.92rem] text-ink-2 leading-[1.85] font-light mb-3 max-w-3xl">At hiring. And every day after.</p>
      <p class="text-[0.9rem] text-ink-2 leading-[1.85] font-light mb-6 max-w-3xl">We don't stop caring about these dimensions once you join. This is not a one-time filter — it is the culture. EduRankAI is building AI to develop complete humans. The people building it must live that standard, continuously.</p>

      <h3 class="font-display text-[1.1rem] font-semibold text-ink mb-4">Core Human Dimensions <span class="text-[0.7rem] font-mono uppercase tracking-wider text-ink-soft ml-2">Assessed at hiring · Supported throughout</span></h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-8">
        {[
          { e: '💪', t: 'Physical', tags: 'Active health · Body awareness · Stamina · Energy management · Discipline in self-care', d: 'You maintain the body that carries the mind. Physical vitality sustains long-term focus, resilience, and creative output.' },
          { e: '🧠', t: 'Mental', tags: 'Cognitive clarity · Focus · Stress resilience · Learning agility · First-principles thinking', d: 'The capacity to think clearly under pressure, learn fast, and operate calmly in ambiguity. Not IQ alone — but the quality of how you use your mind day to day.' },
          { e: '❤️', t: 'Emotional', tags: 'Self-awareness · Empathy · Emotional regulation · Feedback receptivity · Psychological safety', d: 'You understand your inner world and act from it wisely. You can receive hard feedback without collapsing and give it honestly without cruelty.' },
          { e: '🤝', t: 'Social', tags: 'Collaboration · Trust-building · Communication · Accountability · Lifting others around you', d: 'How you show up in a room — or a Slack channel. Whether you earn trust or just expect it. Whether you make your team better.' },
          { e: '✨', t: 'Spiritual', tags: 'Purpose · Meaning · Values · Sense of why · Groundedness beyond ambition', d: 'You know why you\'re here — and it\'s bigger than a salary or a title. Purpose is what keeps you steady when things are hard, and generous when things go well.' },
        ].map((x) => (
          <div class="bg-white border border-ink/10 rounded-xl p-5">
            <div class="flex items-baseline gap-3 mb-2"><span class="text-[1.6rem]">{x.e}</span><span class="font-display text-[1.05rem] font-semibold text-ink">{x.t}</span></div>
            <p class="text-[0.78rem] font-mono uppercase tracking-wider text-ink-soft mb-2 leading-relaxed">{x.tags}</p>
            <p class="text-[0.85rem] text-ink-2 leading-relaxed font-light">{x.d}</p>
          </div>
        ))}
      </div>

      <h3 class="font-display text-[1.1rem] font-semibold text-ink mb-4">Performance &amp; Capability Dimensions <span class="text-[0.7rem] font-mono uppercase tracking-wider text-ink-soft ml-2">Assessed in task · Grown on the job</span></h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-8">
        {[
          { e: '💡', t: 'Intellectual', d: 'Depth of understanding · Conceptual reasoning · Curiosity that goes beyond surface · Academic or self-directed rigour.' },
          { e: '🚀', t: 'Innovative', d: 'Original thinking · Problem reframing · Creative solutions · Comfort with uncertainty · Bias toward invention.' },
          { e: '🛠️', t: 'Skilful', d: 'Craft · Technical mastery · Domain expertise · Precision in execution · Continuous skill-building.' },
          { e: '🧭', t: 'Character', d: 'Integrity · Honesty · Accountability · Courage to disagree · Consistency between private and public self. Non-negotiable.' },
        ].map((x) => (
          <div class="bg-white border border-ink/10 rounded-xl p-5">
            <div class="flex items-baseline gap-3 mb-2"><span class="text-[1.6rem]">{x.e}</span><span class="font-display text-[1.05rem] font-semibold text-ink">{x.t}</span></div>
            <p class="text-[0.85rem] text-ink-2 leading-relaxed font-light">{x.d}</p>
          </div>
        ))}
      </div>

      <h3 class="font-display text-[1.1rem] font-semibold text-ink mb-4">Growth &amp; Essence Dimensions <span class="text-[0.7rem] font-mono uppercase tracking-wider text-ink-soft ml-2">What separates good from rare</span></h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {[
          { e: '🎯', t: 'Dedicated', d: 'Deep ownership of work. The kind of dedication that doesn\'t need to be asked for — you do it because you care about the outcome, not because someone is watching.' },
          { e: '🌊', t: 'Adaptable', d: 'We are early-stage. Things change. The people who thrive here treat change as information, not disruption.' },
          { e: '🪞', t: 'Self-Aware', d: 'You know your strengths without arrogance and your weaknesses without shame. You can name what you don\'t know. This is the foundation of real learning and real collaboration.' },
          { e: '⚗️', t: 'Essence', d: 'The quality that makes you distinctively you — a rare combination of traits, perspectives, or abilities that nobody else has in quite the same way. Be unignorably yourself.' },
        ].map((x) => (
          <div class="bg-cream-2 border border-ink/10 rounded-xl p-5">
            <div class="flex items-baseline gap-3 mb-2"><span class="text-[1.6rem]">{x.e}</span><span class="font-display text-[1.05rem] font-semibold text-ink">{x.t}</span></div>
            <p class="text-[0.85rem] text-ink-2 leading-relaxed font-light">{x.d}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="internship" class="mb-16">
      <p class="eyebrow mb-3">03 · Internship Policy</p>
      <h2 class="font-display text-[clamp(1.6rem,3vw,2.2rem)] font-semibold text-ink mb-3">What every intern needs to know</h2>
      <p class="text-[0.9rem] text-ink-2 leading-[1.85] font-light mb-6 max-w-3xl">Our internship programme is structured, purposeful, and transparent. Here are the official policies that govern every internship at EduRankAI.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {internshipPolicies.map((p) => (
          <div class="bg-white border border-ink/10 rounded-xl p-5">
            <div class="flex items-baseline gap-3 mb-2"><span class="text-[1.4rem]">{p.icon}</span><span class="font-display text-[1rem] font-semibold text-ink">{p.t}</span></div>
            <p class="text-[0.85rem] text-ink-2 leading-relaxed font-light mb-3">{p.d}</p>
            <p class="text-[0.72rem] font-mono uppercase tracking-wider text-burn leading-relaxed">{p.m}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="fulltime" class="mb-16">
      <p class="eyebrow mb-3">04 · Full-Time Job Policy</p>
      <h2 class="font-display text-[clamp(1.6rem,3vw,2.2rem)] font-semibold text-ink mb-3">Full-time roles — what we offer &amp; expect</h2>
      <p class="text-[0.9rem] text-ink-2 leading-[1.85] font-light mb-8 max-w-3xl">Full-time positions at EduRankAI come with different standards and flexibility than internships. Here's exactly what to expect.</p>

      <h3 class="font-display text-[1.15rem] font-semibold text-ink mb-4">What we offer</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-8">
        {fullTimeOffers.map((p) => (
          <div class="bg-leaf-bg/30 border border-leaf-border/40 rounded-xl p-5">
            <p class="font-display text-[1rem] font-semibold text-ink mb-1.5">{p.t}</p>
            <p class="text-[0.85rem] text-ink-2 leading-relaxed font-light">{p.d}</p>
          </div>
        ))}
      </div>
      <h3 class="font-display text-[1.15rem] font-semibold text-ink mb-4">What we expect</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {fullTimeExpect.map((p) => (
          <div class="bg-burn-pale/30 border border-burn-dim/30 rounded-xl p-5">
            <p class="font-display text-[1rem] font-semibold text-ink mb-1.5">{p.t}</p>
            <p class="text-[0.85rem] text-ink-2 leading-relaxed font-light">{p.d}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="domains" class="mb-16">
      <p class="eyebrow mb-3">05 · Domain Coverage</p>
      <h2 class="font-display text-[clamp(1.6rem,3vw,2.2rem)] font-semibold text-ink mb-3">We hire across all disciplines</h2>
      <p class="text-[0.9rem] text-ink-2 leading-[1.85] font-light mb-6 max-w-3xl">Our institution tiers apply across every sector. Here are the specific domains we recruit from and why each matters to our mission.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
        {domains.map((d) => (
          <div class="bg-white border border-ink/10 rounded-xl p-5">
            <div class="flex items-center justify-between gap-2 mb-2">
              <span class="text-[1.5rem]">{d.icon}</span>
              <span class="text-[0.65rem] font-mono uppercase tracking-wider text-burn bg-burn-pale border border-burn-dim px-2 py-0.5 rounded-full font-semibold">{d.tag}</span>
            </div>
            <p class="font-display text-[0.98rem] font-semibold text-ink mb-1.5">{d.t}</p>
            <p class="text-[0.82rem] text-ink-2 leading-relaxed font-light">{d.d}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="process" class="mb-16">
      <p class="eyebrow mb-3">06 · Application Process</p>
      <h2 class="font-display text-[clamp(1.6rem,3vw,2.2rem)] font-semibold text-ink mb-3">How we evaluate you</h2>
      <p class="text-[0.9rem] text-ink-2 leading-[1.85] font-light mb-6 max-w-3xl">Six steps. No surprises. We read every application personally, score every task objectively, and interview only those who demonstrate real capability.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
        {steps.map((s) => (
          <div class="bg-cream-2 border border-ink/10 rounded-xl p-5">
            <p class="eyebrow mb-2">Step {s.n}</p>
            <p class="font-display text-[1.05rem] font-semibold text-ink mb-2">{s.t}</p>
            <p class="text-[0.85rem] text-ink-2 leading-relaxed font-light">{s.d}</p>
          </div>
        ))}
      </div>
      <p class="text-[0.85rem] text-ink-soft mt-6">For the full binding process, scoring engine, conduct, termination, exit, and your rights — see <a href="/policy/recruitment" class="text-burn font-semibold underline">Recruitment &amp; Work Policy v2.0</a>.</p>
    </section>

    <div class="bg-ink text-white rounded-2xl p-8 md:p-10 text-center">
      <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-burn mb-3">Ready to Apply?</p>
      <h3 class="font-display text-[1.8rem] md:text-[2.2rem] font-semibold leading-tight mb-3">You've read the policy. Now show us who you are.</h3>
      <p class="text-[0.92rem] text-white/80 leading-relaxed mb-6 max-w-xl mx-auto">Apply today. We read every application personally. The right person — regardless of tier — will always get a response.</p>
      <a href="/careers" class="inline-block bg-burn hover:bg-burn/90 font-semibold px-7 py-3 rounded-lg text-[0.95rem] transition-all">View open roles &rarr;</a>
    </div>
  </section>
</BaseLayout>
