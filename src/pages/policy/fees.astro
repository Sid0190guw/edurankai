---
import BaseLayout from '@/layouts/BaseLayout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Why EduRankAI charges a small processing fee',
  description: 'How application + portal access fees keep EduRankAI independent. No donations, no investors, no advertiser influence over hiring outcomes.',
  publisher: { '@type': 'Organization', name: 'EduRankAI', url: 'https://www.edurankai.in' },
  inLanguage: 'en-IN',
  dateModified: '2026-06-02',
};

const COSTS = [
  { tag: 'People',          desc: 'Every application is read by a real human reviewer. Interview panels, talent ops, training leads, payroll. Real salaries, not donated time.' },
  { tag: 'Infrastructure',  desc: 'Hosting, databases, the in-app mailbox, file storage, push notifications, proctoring models, identity verification, payment gateway, monitoring — every line item is a paid subscription.' },
  { tag: 'Verification',    desc: 'Identity checks, credential cross-checks, reference calls, document validation. Fraud prevention. Every application is verified end-to-end.' },
  { tag: 'Tooling',         desc: 'Test runner, AI interview platform, proctoring stack, mail server, CI/CD, secrets and security. We build a lot in-house — but the cloud compute under it still costs money.' },
  { tag: 'Independence',    desc: 'Crucially, the fee buys us the right to take no advertiser money, no donations with strings attached, no investor pressure to ship roles a certain way. Your fee is the only stakeholder.' },
];

const FAQ = [
  {
    q: 'Why a fee at all? Most application portals are free.',
    a: 'Most "free" portals are paid for by someone — the recruiting company, an ATS vendor, the candidate\'s data being sold, or ads. We do none of those. The small per-application fee lets us be honest about who pays for the platform: the applicant pays for the processing of their own application. Nothing else.',
  },
  {
    q: 'Where does the money actually go?',
    a: 'Salaries for the team that reviews applications, runs interviews, verifies identity and credentials, and operates the platform. Cloud bills for hosting, mail, database, and AI services. Payment gateway fees. The rest goes back into building better tooling so future applicants are processed faster and more fairly.',
  },
  {
    q: 'Does paying the fee improve my chances?',
    a: 'No. The fee covers processing — not selection. Hiring decisions are made entirely on merit and the published rubric. You can read the rubric on the Recruitment Policy page. A paid application gets the same review as a waiver-approved one.',
  },
  {
    q: 'I genuinely can\'t afford this. Now what?',
    a: 'Request a fee waiver. We review every waiver application manually. If your circumstances are genuine, we waive it — no questions about your performance, no second-class treatment, no record of the waiver in your file. The "Request a fee waiver" link sits on the same page as the payment button.',
  },
  {
    q: 'Is the fee refundable?',
    a: 'It is non-refundable once verification begins, because the cost is incurred the moment our team starts processing the application. We make this clear before you pay. If something goes wrong on our side (duplicate charge, payment failed but money debited, etc.) we refund the same day — write to hr@edurankai.in.',
  },
  {
    q: 'Why are some roles\' fees higher than others?',
    a: 'Senior and leadership roles require deeper verification — more references, more credential checks, longer interview panels, structured background reviews. That work costs more, so the fee scales with the level. Intern and entry-level fees are the lowest.',
  },
  {
    q: 'Do I have to pay for the portal itself?',
    a: 'No. There is no longer a separate "account creation" or "portal access" fee. The application fee is the only paid step. If you previously paid CHF 1 to activate an old account, that\'s the legacy flow — your account stays approved and you only pay the application fee from here.',
  },
  {
    q: 'What about non-applicants — partners, conference attendees, public users?',
    a: 'Public reading is free. Browsing roles, reading research, reading the policy library, attending public events, signing up for a newsletter — none of that costs anything. Fees only apply when our team has to do verified work on your behalf (process an application, issue a certificate, run a paid event level).',
  },
];
---
<BaseLayout title="Why a fee? - EduRankAI" description="EduRankAI takes no government subsidies, no donations, no advertiser money. Here's exactly what the application fee pays for.">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />

  <section class="px-[5vw] pt-16 md:pt-24 pb-12 max-w-3xl mx-auto">
    <p class="eyebrow mb-6">Pricing &amp; independence</p>
    <h1 class="font-display text-[clamp(2rem,5vw,3.4rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-6">
      Why we charge an <em class="italic text-burn font-medium">application fee.</em>
    </h1>
    <p class="text-[1.05rem] md:text-[1.1rem] text-ink-soft leading-[1.8] font-light max-w-2xl">
      EduRankAI takes no government subsidies, no advertiser money, no investor pressure on hiring outcomes, and no donations with strings attached. The platform you're using costs real money to run — people, infrastructure, verification, tooling, security. The small per-application processing fee is how we pay those bills honestly, while keeping the platform free of every other form of influence.
    </p>
  </section>

  <section class="px-[5vw] py-12 md:py-16 max-w-3xl mx-auto border-t border-ink/8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn mb-3 font-bold">Where the money goes</p>
    <h2 class="font-display text-[clamp(1.5rem,3vw,2.2rem)] font-semibold text-ink leading-tight mb-8 max-w-2xl">
      Five line items, no leftovers.
    </h2>
    <div class="space-y-6">
      {COSTS.map((c) => (
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8 pb-6 border-b border-ink/8 last:border-0">
          <div class="md:col-span-3">
            <p class="font-mono text-[0.72rem] uppercase tracking-[0.16em] text-burn font-bold">{c.tag}</p>
          </div>
          <div class="md:col-span-9">
            <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">{c.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="px-[5vw] py-12 md:py-16 max-w-3xl mx-auto border-t border-ink/8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn mb-3 font-bold">The honest version</p>
    <h2 class="font-display text-[clamp(1.5rem,3vw,2.2rem)] font-semibold text-ink leading-tight mb-6 max-w-2xl">
      Nothing about hiring is free.
    </h2>
    <div class="space-y-4 text-[1rem] text-ink-2 font-light leading-[1.85]">
      <p>
        When you apply to most companies, the cost is invisible. Either the company eats it (and passes it on to customers), or the platform you applied through is harvesting your data, or an ATS vendor is making money on volume, or a recruiter is paid on placement. The cost is there. You just don't see it.
      </p>
      <p>
        We made a different choice. We charge a small, transparent fee per application — clearly disclosed, capped at the actual cost of processing your application, with a fee waiver for anyone who genuinely cannot pay. In exchange:
      </p>
      <ul class="space-y-2 pl-4">
        <li class="text-[0.95rem]">No advertiser ever pays us to rank a role, surface a company, or influence who gets shortlisted.</li>
        <li class="text-[0.95rem]">No donor ever attaches conditions to who we hire or what we research.</li>
        <li class="text-[0.95rem]">No investor ever pressures us to ship roles we don't believe in.</li>
        <li class="text-[0.95rem]">Your application data is never sold, never shared with third-party recruiters, never used to train a model.</li>
      </ul>
      <p>
        That independence is not free either. It is exactly what your fee buys.
      </p>
    </div>
  </section>

  <section class="px-[5vw] py-12 md:py-16 max-w-3xl mx-auto border-t border-ink/8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn mb-3 font-bold">Questions we get</p>
    <h2 class="font-display text-[clamp(1.5rem,3vw,2.2rem)] font-semibold text-ink leading-tight mb-8 max-w-2xl">
      The fee, candidly.
    </h2>
    <div class="space-y-5">
      {FAQ.map((f) => (
        <details class="group border border-ink/10 rounded-xl bg-cream-2 hover:bg-white transition-colors">
          <summary class="cursor-pointer list-none px-5 py-4 flex items-center justify-between gap-4">
            <span class="text-[0.95rem] font-semibold text-ink">{f.q}</span>
            <span class="text-burn font-mono text-[1.2rem] group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="px-5 pb-5 text-[0.9rem] text-ink-soft leading-[1.85] font-light">{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="px-[5vw] py-12 md:py-16 max-w-3xl mx-auto border-t border-ink/8">
    <h2 class="font-display text-[clamp(1.4rem,3vw,2rem)] font-semibold text-ink mb-4">Need a fee waiver?</h2>
    <p class="text-[0.95rem] text-ink-soft leading-[1.85] font-light mb-6">
      If the fee is a genuine barrier — student in a low-income context, between jobs, family circumstances — request a waiver. We review each one manually. Approved waivers are completely silent: no flag on your application, no impact on review, no different treatment.
    </p>
    <div class="flex flex-wrap gap-3">
      <a href="/apply/waiver" class="bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.9rem] transition-colors">Request a fee waiver →</a>
      <a href="/policy/recruitment" class="bg-cream-2 border border-ink/15 hover:border-burn text-ink font-semibold py-2.5 px-5 rounded-lg text-[0.9rem] transition-colors">Read the recruitment policy</a>
      <a href="mailto:hr@edurankai.in" class="font-mono text-[0.78rem] text-burn underline self-center">hr@edurankai.in</a>
    </div>
  </section>

</BaseLayout>
