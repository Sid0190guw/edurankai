---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="First-time identity setup" description="Set up your EduRankAI account with government ID + face verification." noindex={true}>

  <script is:inline src="https://cdn.jsdelivr.net/npm/@vladmandic/face-api@1.7.13/dist/face-api.min.js"></script>

  <section class="px-[5vw] py-10 md:py-14 max-w-2xl mx-auto">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-3">First-time setup</p>
    <h1 class="font-display text-[clamp(1.8rem,4vw,2.6rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-3">
      Verify your <em class="italic text-burn font-medium">identity.</em>
    </h1>
    <p class="text-[0.95rem] text-ink-soft leading-relaxed mb-8">
      For accounts created before face login existed (or where date of birth is missing), this one-time flow verifies you're the real account holder. You'll upload a government ID, take a live selfie, and our system compares the face on the ID to your selfie. On a match, your new password and face are saved for future sign-ins.
    </p>

    <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-6 text-[0.85rem] text-amber-900 leading-relaxed">
      <strong>Before you start:</strong> Have a government photo ID ready (Aadhaar, PAN, Passport, Driving Licence). Good lighting. No glasses or mask. The ID must show your face clearly.
    </div>

    <!-- STEP 1: account details -->
    <div id="step1" class="bg-white border border-ink/10 rounded-2xl p-5 md:p-6 mb-4">
      <p class="text-[0.7rem] font-mono uppercase tracking-wider text-burn font-bold mb-3">Step 1 &middot; About your account</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-1.5">Account email</label>
          <input type="email" id="iEmail" required placeholder="you@edurankai.in" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.95rem] outline-none focus:border-burn bg-cream-2" />
        </div>
        <div>
          <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-1.5">Full name (as on ID)</label>
          <input type="text" id="iName" required placeholder="As shown on the ID" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.95rem] outline-none focus:border-burn bg-cream-2" />
        </div>
        <div>
          <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-1.5">Date of birth</label>
          <input type="date" id="iDob" required class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.95rem] outline-none focus:border-burn bg-cream-2" />
        </div>
        <div>
          <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-1.5">ID type</label>
          <select id="iIdType" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.95rem] outline-none focus:border-burn bg-cream-2">
            <option value="aadhaar">Aadhaar</option>
            <option value="pan">PAN</option>
            <option value="passport">Passport</option>
            <option value="driving">Driving Licence</option>
            <option value="other">Other government ID</option>
          </select>
        </div>
        <div class="md:col-span-2">
          <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-1.5">Choose a new password (8+ chars)</label>
          <input type="password" id="iPassword" required minlength="8" placeholder="Pick a strong password" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.95rem] outline-none focus:border-burn bg-cream-2" />
        </div>
      </div>
    </div>

    <!-- STEP 2: ID upload -->
    <div id="step2" class="bg-white border border-ink/10 rounded-2xl p-5 md:p-6 mb-4">
      <p class="text-[0.7rem] font-mono uppercase tracking-wider text-burn font-bold mb-3">Step 2 &middot; Upload your ID</p>
      <p class="text-[0.85rem] text-ink-soft mb-3">A clear photo of your government ID. We detect the face on it locally on your device.</p>
      <label class="block">
        <input type="file" id="idFile" accept="image/*" capture="environment" class="block w-full text-[0.85rem] text-ink-soft file:bg-ink file:text-white file:border-0 file:rounded-lg file:font-semibold file:px-4 file:py-2 file:mr-3 file:cursor-pointer file:text-[0.82rem]" />
      </label>
      <div id="idPreview" class="hidden mt-4">
        <div class="flex gap-3 items-start">
          <img id="idImg" alt="ID preview" class="w-32 h-32 object-cover rounded-lg border border-ink/10" />
          <div class="flex-1">
            <p id="idFaceStatus" class="text-[0.82rem] text-ink-soft">Analysing ID face...</p>
          </div>
        </div>
      </div>
    </div>

    <!-- STEP 3: live selfie -->
    <div id="step3" class="bg-white border border-ink/10 rounded-2xl p-5 md:p-6 mb-4">
      <p class="text-[0.7rem] font-mono uppercase tracking-wider text-burn font-bold mb-3">Step 3 &middot; Take a live selfie</p>
      <p class="text-[0.85rem] text-ink-soft mb-3">Face the camera. We extract a face signature locally - the photo never leaves your browser.</p>
      <div class="flex flex-col md:flex-row gap-4 items-start">
        <div class="relative bg-ink rounded-xl overflow-hidden" style="width:240px;height:240px;flex-shrink:0;">
          <video id="iVideo" autoplay playsinline muted style="width:100%;height:100%;object-fit:cover;"></video>
          <div id="iOval" style="position:absolute;inset:30px;border:2px dashed #FF7040;border-radius:50%;pointer-events:none;"></div>
        </div>
        <div class="flex-1">
          <p id="selfieStatus" class="text-[0.85rem] text-ink-soft mb-3">Click Start camera, then Capture once you see a green border on your face.</p>
          <div class="flex flex-wrap gap-2">
            <button type="button" id="startCamBtn" class="bg-ink hover:bg-burn text-white font-semibold text-[0.85rem] py-2 px-4 rounded-lg transition-colors">Start camera</button>
            <button type="button" id="captureBtn" disabled class="bg-burn hover:bg-burn/90 text-white font-semibold text-[0.85rem] py-2 px-4 rounded-lg disabled:opacity-50 disabled:cursor-not-allowed">Capture selfie</button>
          </div>
          <p id="matchDistanceLabel" class="text-[0.78rem] text-ink-soft mt-3 font-mono"></p>
        </div>
      </div>
    </div>

    <!-- SUBMIT -->
    <div class="flex flex-col gap-3">
      <button type="button" id="submitBtn" disabled class="bg-burn hover:bg-burn/90 text-white font-semibold py-3 px-6 rounded-lg text-[0.95rem] disabled:opacity-50 disabled:cursor-not-allowed">
        Verify identity &amp; finish setup
      </button>
      <div id="result" style="display:none;"></div>
      <p class="text-[0.78rem] text-ink-soft text-center">
        <a href="/portal/login" class="text-burn hover:underline">Back to sign in</a> &middot;
        <a href="mailto:hr@edurankai.in" class="text-burn hover:underline">Need help?</a>
      </p>
    </div>
  </section>

  <script is:inline>
    (function() {
      var MODEL_URL = 'https://cdn.jsdelivr.net/npm/@vladmandic/face-api@1.7.13/model';
      var modelsLoaded = false;
      var idDescriptor = null;
      var selfieDescriptor = null;
      var matchDistance = null;
      var stream = null;

      var idFileEl = document.getElementById('idFile');
      var idPreview = document.getElementById('idPreview');
      var idImg = document.getElementById('idImg');
      var idFaceStatus = document.getElementById('idFaceStatus');
      var video = document.getElementById('iVideo');
      var startCamBtn = document.getElementById('startCamBtn');
      var captureBtn = document.getElementById('captureBtn');
      var selfieStatus = document.getElementById('selfieStatus');
      var matchLabel = document.getElementById('matchDistanceLabel');
      var submitBtn = document.getElementById('submitBtn');
      var result = document.getElementById('result');
      var oval = document.getElementById('iOval');

      function setStatus(el, msg, color) {
        if (el) { el.textContent = msg; if (color) el.style.color = color; }
      }
      function updateSubmitState() {
        var hasIdFace = !!idDescriptor;
        var hasSelfieFace = !!selfieDescriptor;
        if (hasIdFace && hasSelfieFace) {
          // Compute distance
          matchDistance = faceapi.euclideanDistance(idDescriptor, selfieDescriptor);
          var pass = matchDistance <= 0.50;
          matchLabel.textContent = 'Match distance: ' + matchDistance.toFixed(3) + ' (' + (pass ? 'PASS' : 'NO MATCH') + ', threshold 0.50)';
          matchLabel.style.color = pass ? '#16a34a' : '#dc2626';
          submitBtn.disabled = !pass;
        } else {
          submitBtn.disabled = true;
          matchLabel.textContent = '';
        }
      }

      async function ensureModels() {
        if (modelsLoaded) return;
        try {
          await Promise.all([
            faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL),
            faceapi.nets.faceLandmark68TinyNet.loadFromUri(MODEL_URL),
            faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL),
          ]);
          modelsLoaded = true;
        } catch (e) {
          alert('Could not load face detection models. Check your network and reload.');
          throw e;
        }
      }

      // ID upload handling
      idFileEl.addEventListener('change', async function() {
        var file = idFileEl.files && idFileEl.files[0];
        if (!file) return;
        idPreview.classList.remove('hidden');
        var url = URL.createObjectURL(file);
        idImg.src = url;
        setStatus(idFaceStatus, 'Loading face models...', '#6b7280');
        try {
          await ensureModels();
          setStatus(idFaceStatus, 'Detecting face on ID...', '#6b7280');
          // Wait for image to be loaded
          await new Promise(function(res, rej) {
            if (idImg.complete && idImg.naturalWidth > 0) res();
            else { idImg.onload = res; idImg.onerror = rej; }
          });
          var det = await faceapi.detectSingleFace(idImg, new faceapi.TinyFaceDetectorOptions({ inputSize: 416, scoreThreshold: 0.4 }))
            .withFaceLandmarks(true).withFaceDescriptor();
          if (!det || !det.descriptor) {
            setStatus(idFaceStatus, 'No face detected on the ID. Try a clearer photo with the face well-lit.', '#dc2626');
            idDescriptor = null;
            updateSubmitState();
            return;
          }
          idDescriptor = Array.from(det.descriptor);
          setStatus(idFaceStatus, 'Face detected on ID. Now take a live selfie below.', '#16a34a');
          updateSubmitState();
        } catch (e) {
          setStatus(idFaceStatus, 'Could not analyse this image. Try a different photo.', '#dc2626');
          idDescriptor = null;
          updateSubmitState();
        }
      });

      // Camera
      startCamBtn.addEventListener('click', async function() {
        try {
          await ensureModels();
          setStatus(selfieStatus, 'Starting camera...', '#6b7280');
          stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: 480 } });
          video.srcObject = stream;
          startCamBtn.disabled = true;
          startCamBtn.textContent = 'Camera on';
          captureBtn.disabled = false;
          setStatus(selfieStatus, 'Face the camera, then click Capture.', '#16a34a');
          // Continuous face tracking for the oval
          requestAnimationFrame(trackFace);
        } catch (e) {
          setStatus(selfieStatus, 'Camera access denied. Allow camera permission and reload.', '#dc2626');
        }
      });

      async function trackFace() {
        if (!stream || !modelsLoaded) return;
        try {
          var det = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions({ inputSize: 320, scoreThreshold: 0.4 }));
          if (det) oval.style.borderColor = '#10b981';
          else oval.style.borderColor = '#FF7040';
        } catch (_) {}
        if (stream) setTimeout(trackFace, 600);
      }

      captureBtn.addEventListener('click', async function() {
        try {
          setStatus(selfieStatus, 'Capturing...', '#6b7280');
          var det = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions({ inputSize: 416, scoreThreshold: 0.4 }))
            .withFaceLandmarks(true).withFaceDescriptor();
          if (!det || !det.descriptor) {
            setStatus(selfieStatus, 'No face detected. Center your face in the oval and try again.', '#dc2626');
            return;
          }
          selfieDescriptor = Array.from(det.descriptor);
          setStatus(selfieStatus, 'Selfie captured. Verifying match...', '#16a34a');
          updateSubmitState();
        } catch (e) {
          setStatus(selfieStatus, 'Could not capture. Try again.', '#dc2626');
        }
      });

      // Submit
      submitBtn.addEventListener('click', function() {
        var email = document.getElementById('iEmail').value.trim();
        var name = document.getElementById('iName').value.trim();
        var dob = document.getElementById('iDob').value.trim();
        var pw = document.getElementById('iPassword').value;
        var idType = document.getElementById('iIdType').value;

        if (!email || !name || !dob || !pw) { alert('Please fill all fields in step 1.'); return; }
        if (pw.length < 8) { alert('Password must be at least 8 characters.'); return; }
        if (!selfieDescriptor || !idDescriptor) { alert('Capture both the ID face and the selfie.'); return; }

        submitBtn.disabled = true;
        var prev = submitBtn.textContent;
        submitBtn.textContent = 'Verifying...';
        result.style.display = 'none';

        fetch('/api/auth/identity-setup', {
          method: 'POST', credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: email, name: name, dob: dob, newPassword: pw,
            faceDescriptor: selfieDescriptor,
            matchDistance: matchDistance,
            idCardType: idType,
          }),
        }).then(function(r) { return r.json(); }).then(function(d) {
          submitBtn.disabled = false;
          submitBtn.textContent = prev;
          result.style.display = 'block';
          if (d.ok) {
            result.innerHTML =
              '<div style="background:#dcfce7;border:1px solid #86efac;color:#166534;padding:14px 16px;border-radius:10px;font-size:13.5px;line-height:1.7;">' +
                '<p style="font-weight:600;margin:0 0 4px;">Identity verified for ' + (d.email || '') + '</p>' +
                '<p style="margin:0 0 10px;">' + (d.message || 'You can now sign in with your new password.') + '</p>' +
                '<a href="' + ((d.role && d.role !== 'applicant') ? '/admin/login' : '/portal/login') + '" style="background:#FF4F00;color:#fff;text-decoration:none;font-weight:600;font-size:13px;padding:8px 16px;border-radius:6px;display:inline-block;">Sign in now</a>' +
              '</div>';
            // Stop camera
            if (stream) { stream.getTracks().forEach(function(t) { t.stop(); }); stream = null; }
          } else {
            result.innerHTML = '<div style="background:#fee2e2;border:1px solid #fca5a5;color:#991b1b;padding:12px 14px;border-radius:8px;font-size:13.5px;">' + (d.error || 'Verification failed.') + '</div>';
          }
        }).catch(function() {
          submitBtn.disabled = false;
          submitBtn.textContent = prev;
          result.style.display = 'block';
          result.innerHTML = '<div style="background:#fee2e2;border:1px solid #fca5a5;color:#991b1b;padding:12px 14px;border-radius:8px;font-size:13.5px;">Network error - try again.</div>';
        });
      });
    })();
  </script>
</BaseLayout>
