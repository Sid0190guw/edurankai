---
// /credentials/course/[code] — PUBLIC credential verification (Prompt 10). No login: anyone can
// confirm a course credential is genuine, see what it certifies, and detect tampering or revocation.
export const prerender = false;
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { getCredentialByCode, verifyRow } from '@/lib/credential';

const code = (Astro.params.code || '').trim().toUpperCase();
const row = await getCredentialByCode(code).catch(() => null);
const { valid, revoked } = verifyRow(row);
const status = !row ? 'not-found' : revoked ? 'revoked' : valid ? 'valid' : 'invalid';
const competencies: string[] = row?.competencies || [];
function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' }); } catch { return '-'; } }
const badge: Record<string, { c: string; bg: string; label: string; note: string }> = {
  valid: { c: '#1f7a4d', bg: '#eef8f1', label: 'Verified', note: 'This credential is genuine and its contents are intact.' },
  revoked: { c: '#9b2c2c', bg: '#fdecec', label: 'Revoked', note: 'This credential was issued but has since been revoked and is no longer valid.' },
  invalid: { c: '#9b2c2c', bg: '#fdecec', label: 'Tampered', note: 'The signature does not match the credential contents — this record has been altered.' },
  'not-found': { c: '#8a5a1a', bg: '#fff8ef', label: 'Not found', note: 'No credential exists with that verification code.' },
};
const b = badge[status];
---
<AquintutorLayout title={'Verify credential ' + code} noindex={true}>
  <main style="max-width:640px;margin:0 auto;padding:48px 22px 80px;">
    <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--rust,#b3541e);margin:0 0 8px;">Credential verification</p>
    <div style={'border-radius:14px;padding:14px 18px;margin-bottom:22px;background:' + b.bg + ';border:1px solid ' + b.c + '33;'}>
      <p style={'font-family:Inter Tight,sans-serif;font-size:15px;font-weight:700;margin:0;color:' + b.c + ';'}>{b.label}</p>
      <p style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:#4a453c;margin:5px 0 0;">{b.note}</p>
    </div>

    {row ? (
      <div style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:16px;padding:26px 28px;">
        <p style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#8a8478;margin:0 0 4px;">This certifies that</p>
        <h1 style="font-family:Fraunces,serif;font-size:30px;font-weight:600;color:var(--ink,#1a1712);margin:0 0 6px;line-height:1.15;">{row.holder_name}</h1>
        <p style="font-family:'Inter Tight',sans-serif;font-size:15px;color:#4a453c;margin:0 0 20px;">completed <b>{row.course_title}</b> on the AquinTutor platform.</p>

        {competencies.length ? (
          <div style="margin-bottom:20px;">
            <p style="font-family:'Geist Mono',monospace;font-size:10.5px;text-transform:uppercase;letter-spacing:0.1em;color:#8a8478;margin:0 0 8px;">Competencies</p>
            <div style="display:flex;flex-wrap:wrap;gap:6px;">{competencies.map((c) => <span style="font-family:'Inter Tight',sans-serif;font-size:12.5px;background:#faf8f2;border:1px solid var(--line,#e6e1d6);border-radius:100px;padding:4px 12px;color:var(--ink,#1a1712);">{c}</span>)}</div>
          </div>
        ) : null}

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;border-top:1px solid #f0ece2;padding-top:16px;font-family:'Inter Tight',sans-serif;font-size:13px;">
          <div><span style="color:#8a8478;">Issued</span><br/><b style="color:var(--ink,#1a1712);">{fmt(row.issued_at)}</b></div>
          <div><span style="color:#8a8478;">Verification ID</span><br/><b style="font-family:'Geist Mono',monospace;color:var(--ink,#1a1712);">{row.code}</b></div>
        </div>
      </div>
    ) : (
      <div style="background:#fff;border:1px solid var(--line,#e6e1d6);border-radius:16px;padding:26px 28px;">
        <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#6b6455;margin:0;">Check the verification code and try again. Codes look like <b style="font-family:'Geist Mono',monospace;">ABCD-EFGH-JKLM</b>.</p>
      </div>
    )}
    <p style="font-family:'Inter Tight',sans-serif;font-size:12px;color:#8a8478;margin:18px 0 0;">AquinTutor is a learning platform; credentials certify completion of platform courses. Awarding bodies for accredited qualifications are the partner universities.</p>
  </main>
</AquintutorLayout>
