---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { SITE } from '@/lib/site';

const { number } = Astro.params;
if (!number) return Astro.redirect('/');

let cert: any = null;
try {
  const r = await db.execute(sql`
    SELECT c.id, c.certificate_number, c.issued_at, c.expires_at,
      u.name as user_name,
      co.title as course_title, co.slug as course_slug,
      co.instructor_name, co.duration_hours, co.category, co.level
    FROM training_certificates c
    JOIN users u ON c.user_id = u.id
    JOIN training_courses co ON c.course_id = co.id
    WHERE c.certificate_number = ${number}
    LIMIT 1
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  cert = rows[0] || null;
} catch (_) {}

const isValid = !!cert && (!cert.expires_at || new Date(cert.expires_at) > new Date());
const issuedDate = cert?.issued_at
  ? new Date(cert.issued_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })
  : '';
const expiresDate = cert?.expires_at
  ? new Date(cert.expires_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })
  : '';

const pageTitle = cert
  ? 'Verified credential: ' + cert.course_title + ' - ' + cert.user_name
  : 'Credential not found';
const pageDesc = cert
  ? cert.user_name + ' completed ' + cert.course_title + ' on AquinTutor (EduRankAI). Verified credential ' + cert.certificate_number + '.'
  : 'This credential could not be verified.';

const credentialSchema = cert ? {
  '@context': 'https://schema.org',
  '@type': 'EducationalOccupationalCredential',
  identifier: cert.certificate_number,
  name: cert.course_title,
  credentialCategory: 'Course Completion Certificate',
  educationalLevel: cert.level || 'beginner',
  dateCreated: cert.issued_at,
  ...(cert.expires_at && { expires: cert.expires_at }),
  recognizedBy: { '@type': 'Organization', name: 'AquinTutor (EduRankAI)', sameAs: SITE.url },
  about: { '@type': 'Course', name: cert.course_title, url: SITE.url + '/aquintutor/courses/' + cert.course_slug },
  url: SITE.url + '/credentials/' + cert.certificate_number,
} : null;

const verificationUrl = SITE.url + '/credentials/' + (number || '');
const linkedinShare = cert ? ('https://www.linkedin.com/profile/add?startTask=CERTIFICATION_NAME&name=' + encodeURIComponent(cert.course_title) + '&organizationName=' + encodeURIComponent('AquinTutor (EduRankAI)') + '&issueYear=' + new Date(cert.issued_at).getFullYear() + '&issueMonth=' + (new Date(cert.issued_at).getMonth() + 1) + '&certUrl=' + encodeURIComponent(verificationUrl) + '&certId=' + encodeURIComponent(number || '')) : '#';
---
<AquintutorLayout title={pageTitle} description={pageDesc} noindex={!cert}>
  {credentialSchema && <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(credentialSchema)} />}

  <section class="ac-container" style="padding:60px 5vw 80px; max-width:760px;">
    {!cert ? (
      <div style="text-align:center; padding:60px 20px;">
        <div style="display:inline-flex; align-items:center; justify-content:center; width:64px; height:64px; border-radius:50%; background:rgba(239,68,68,0.1); color:#B91C1C; margin-bottom:24px;">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        </div>
        <h1 class="ac-display ac-mb-4" style="font-size:2rem;">Credential not found</h1>
        <p style="font-size:14.5px; color:var(--ac-ink-soft); max-width:480px; margin:0 auto 24px; line-height:1.7;">
          No AquinTutor credential exists with the number <code style="font-family:'Geist Mono',monospace; background:var(--ac-paper-deep); padding:2px 8px; border-radius:4px; font-size:13px;">{number}</code>. Check that the number is correct, or contact <a href="mailto:hr@edurankai.in" style="color:var(--ac-amber); text-decoration:underline;">hr@edurankai.in</a> if you believe this is in error.
        </p>
        <a href="/aquintutor" class="ac-btn">Back to AquinTutor</a>
      </div>
    ) : (
      <>
        <div style="text-align:center; margin-bottom:36px;">
          <div style={'display:inline-flex; align-items:center; justify-content:center; width:64px; height:64px; border-radius:50%; margin-bottom:20px; ' + (isValid ? 'background:rgba(74,107,46,0.12); color:#4A6B2E;' : 'background:var(--ac-paper-deep); color:var(--ac-ink-muted);')}>
            {isValid ? (
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            ) : (
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="6" x2="12" y2="12"/><line x1="12" y1="16" x2="12" y2="16"/></svg>
            )}
          </div>
          <p class="ac-eyebrow ac-mb-3" style={isValid ? 'color:#4A6B2E;' : ''}>{isValid ? 'Verified credential' : 'Credential expired'}</p>
          <h1 class="ac-display ac-mb-4" style="font-size:clamp(1.6rem, 3.5vw, 2.4rem); line-height:1.15;">{cert.course_title}</h1>
          <p style="font-size:16px; color:var(--ac-ink-soft);">Issued to <strong style="color:var(--ac-ink); font-weight:600;">{cert.user_name}</strong></p>
        </div>

        <div class="ac-card" style="margin-bottom:24px; padding:32px;">
          <div style="display:grid; grid-template-columns:1fr; gap:20px;" class="cert-grid">
            <div>
              <p style="font-family:'Geist Mono',monospace; font-size:10px; color:var(--ac-ink-muted); font-weight:700; text-transform:uppercase; letter-spacing:0.14em; margin-bottom:6px;">Recipient</p>
              <p style="font-size:15px; color:var(--ac-ink); font-weight:500;">{cert.user_name}</p>
            </div>
            <div>
              <p style="font-family:'Geist Mono',monospace; font-size:10px; color:var(--ac-ink-muted); font-weight:700; text-transform:uppercase; letter-spacing:0.14em; margin-bottom:6px;">Course</p>
              <p style="font-size:15px; color:var(--ac-ink); font-weight:500;">
                <a href={'/aquintutor/courses/' + cert.course_slug} style="color:var(--ac-ink); text-decoration:none;">{cert.course_title}</a>
              </p>
            </div>
            <div>
              <p style="font-family:'Geist Mono',monospace; font-size:10px; color:var(--ac-ink-muted); font-weight:700; text-transform:uppercase; letter-spacing:0.14em; margin-bottom:6px;">Issued</p>
              <p style="font-size:15px; color:var(--ac-ink); font-weight:500;">{issuedDate}</p>
            </div>
            {cert.expires_at && (
              <div>
                <p style="font-family:'Geist Mono',monospace; font-size:10px; color:var(--ac-ink-muted); font-weight:700; text-transform:uppercase; letter-spacing:0.14em; margin-bottom:6px;">Expires</p>
                <p style="font-size:15px; color:var(--ac-ink); font-weight:500;">{expiresDate}</p>
              </div>
            )}
            {cert.duration_hours > 0 && (
              <div>
                <p style="font-family:'Geist Mono',monospace; font-size:10px; color:var(--ac-ink-muted); font-weight:700; text-transform:uppercase; letter-spacing:0.14em; margin-bottom:6px;">Duration</p>
                <p style="font-size:15px; color:var(--ac-ink); font-weight:500;">{cert.duration_hours} hours</p>
              </div>
            )}
            {cert.instructor_name && (
              <div>
                <p style="font-family:'Geist Mono',monospace; font-size:10px; color:var(--ac-ink-muted); font-weight:700; text-transform:uppercase; letter-spacing:0.14em; margin-bottom:6px;">Instructor</p>
                <p style="font-size:15px; color:var(--ac-ink); font-weight:500;">{cert.instructor_name}</p>
              </div>
            )}
            <div style="padding-top:20px; border-top:1px solid var(--ac-rule); grid-column:1/-1;">
              <p style="font-family:'Geist Mono',monospace; font-size:10px; color:var(--ac-ink-muted); font-weight:700; text-transform:uppercase; letter-spacing:0.14em; margin-bottom:6px;">Credential number</p>
              <p style="font-size:13.5px; color:var(--ac-ink); font-family:'Geist Mono',monospace; word-break:break-all;">{cert.certificate_number}</p>
            </div>
            <div style="grid-column:1/-1;">
              <p style="font-family:'Geist Mono',monospace; font-size:10px; color:var(--ac-ink-muted); font-weight:700; text-transform:uppercase; letter-spacing:0.14em; margin-bottom:6px;">Issued by</p>
              <p style="font-size:15px; color:var(--ac-ink); font-weight:500;">AquinTutor &mdash; an institution of EduRank&middot;AI</p>
              <p style="font-size:13px; color:var(--ac-ink-soft); margin-top:2px;">{SITE.url}</p>
            </div>
          </div>
        </div>

        <div class="ac-flex ac-wrap ac-gap-3" style="justify-content:center; margin-bottom:32px;">
          <a href={linkedinShare} target="_blank" rel="noopener noreferrer" class="ac-btn">Add to LinkedIn</a>
          <button type="button" id="copyLink" class="ac-btn ac-btn-ghost">Copy verification URL</button>
          <button type="button" onclick="window.print()" class="ac-btn ac-btn-ghost">Print / save PDF</button>
        </div>

        <p style="font-size:13px; color:var(--ac-ink-muted); text-align:center; max-width:560px; margin:0 auto; line-height:1.7;">
          This credential was issued by AquinTutor (EduRankAI) and can be verified at this URL by anyone, with no login required. The credential number is unique and tamper-resistant.
        </p>
      </>
    )}
  </section>

  <style is:global>
    @media (min-width: 640px) {
      .academy .cert-grid { grid-template-columns: 1fr 1fr !important; }
    }
  </style>

  <script is:inline define:vars={{ verificationUrl }}>
    var btn = document.getElementById('copyLink');
    if (btn) {
      btn.addEventListener('click', function() {
        navigator.clipboard.writeText(verificationUrl).then(function() {
          btn.textContent = 'Copied!';
          setTimeout(function() { btn.textContent = 'Copy verification URL'; }, 1800);
        }).catch(function() {
          window.prompt('Copy this URL:', verificationUrl);
        });
      });
    }
  </script>
</AquintutorLayout>
