---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { SITE } from '@/lib/site';

const { number } = Astro.params;
if (!number) return Astro.redirect('/');

let cert: any = null;
try {
  const r = await db.execute(sql`
    SELECT c.id, c.certificate_number, c.issued_at, c.expires_at,
      u.name as user_name,
      co.title as course_title, co.slug as course_slug,
      co.instructor_name, co.duration_hours, co.category, co.level
    FROM training_certificates c
    JOIN users u ON c.user_id = u.id
    JOIN training_courses co ON c.course_id = co.id
    WHERE c.certificate_number = ${number}
    LIMIT 1
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  cert = rows[0] || null;
} catch (_) {}

const isValid = !!cert && (!cert.expires_at || new Date(cert.expires_at) > new Date());
const issuedDate = cert?.issued_at
  ? new Date(cert.issued_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })
  : '';
const expiresDate = cert?.expires_at
  ? new Date(cert.expires_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })
  : '';

const pageTitle = cert
  ? 'Verified credential: ' + cert.course_title + ' - ' + cert.user_name
  : 'Credential not found';
const pageDesc = cert
  ? cert.user_name + ' completed ' + cert.course_title + ' on AquinTutor (EduRankAI). Verified credential ' + cert.certificate_number + '.'
  : 'This credential could not be verified.';

// EducationalOccupationalCredential schema
const credentialSchema = cert ? {
  '@context': 'https://schema.org',
  '@type': 'EducationalOccupationalCredential',
  identifier: cert.certificate_number,
  name: cert.course_title,
  credentialCategory: 'Course Completion Certificate',
  educationalLevel: cert.level || 'beginner',
  dateCreated: cert.issued_at,
  ...(cert.expires_at && { expires: cert.expires_at }),
  recognizedBy: {
    '@type': 'Organization',
    name: 'AquinTutor (EduRankAI)',
    sameAs: SITE.url,
  },
  about: {
    '@type': 'Course',
    name: cert.course_title,
    url: SITE.url + '/aquintutor/courses/' + cert.course_slug,
  },
  url: SITE.url + '/credentials/' + cert.certificate_number,
} : null;

const verificationUrl = SITE.url + '/credentials/' + (number || '');
const linkedinShare = 'https://www.linkedin.com/profile/add?startTask=CERTIFICATION_NAME&name=' + encodeURIComponent(cert?.course_title || '') + '&organizationName=' + encodeURIComponent('AquinTutor (EduRankAI)') + '&issueYear=' + (cert ? new Date(cert.issued_at).getFullYear() : '') + '&issueMonth=' + (cert ? new Date(cert.issued_at).getMonth() + 1 : '') + '&certUrl=' + encodeURIComponent(verificationUrl) + '&certId=' + encodeURIComponent(number || '');
---
<BaseLayout title={pageTitle} description={pageDesc} noindex={!cert}>
  {credentialSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(credentialSchema)} />}

  <section class="px-[5vw] py-12 md:py-16 max-w-3xl mx-auto">
    {!cert ? (
      <div class="text-center py-16">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-red-100 text-red-700 mb-6">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        </div>
        <h1 class="font-display text-[clamp(1.8rem,4vw,2.5rem)] font-semibold text-ink mb-3">Credential not found</h1>
        <p class="text-[0.95rem] text-ink-soft max-w-md mx-auto leading-relaxed mb-6">
          No EduRankAI credential exists with the number <code class="font-mono bg-cream-2 px-2 py-0.5 rounded text-[0.85rem]">{number}</code>. Check that the number is correct, or contact <a href="mailto:hr@edurankai.in" class="text-burn hover:underline">hr@edurankai.in</a> if you believe this is in error.
        </p>
        <a href="/" class="btn-primary">Back to home</a>
      </div>
    ) : (
      <>
        <div class="text-center mb-8">
          <div class={'inline-flex items-center justify-center w-16 h-16 rounded-full mb-5 ' + (isValid ? 'bg-leaf-bg text-leaf' : 'bg-cream-2 text-ink-soft')}>
            {isValid ? (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            ) : (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="6" x2="12" y2="12"/><line x1="12" y1="16" x2="12" y2="16"/></svg>
            )}
          </div>
          <p class="text-[0.7rem] font-mono uppercase tracking-[0.18em] text-leaf font-bold mb-2">{isValid ? 'Verified credential' : 'Credential expired'}</p>
          <h1 class="font-display text-[clamp(1.6rem,3.5vw,2.4rem)] font-semibold text-ink mb-3 leading-tight">{cert.course_title}</h1>
          <p class="text-[1rem] text-ink-soft">Issued to <strong class="text-ink font-semibold">{cert.user_name}</strong></p>
        </div>

        <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 mb-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-5">
            <div>
              <p class="text-[0.62rem] font-mono uppercase tracking-wider text-ink-soft font-bold mb-1.5">Recipient</p>
              <p class="text-[1rem] text-ink font-medium">{cert.user_name}</p>
            </div>
            <div>
              <p class="text-[0.62rem] font-mono uppercase tracking-wider text-ink-soft font-bold mb-1.5">Course</p>
              <p class="text-[1rem] text-ink font-medium">
                <a href={'/aquintutor/courses/' + cert.course_slug} class="hover:text-burn">{cert.course_title}</a>
              </p>
            </div>
            <div>
              <p class="text-[0.62rem] font-mono uppercase tracking-wider text-ink-soft font-bold mb-1.5">Issued</p>
              <p class="text-[1rem] text-ink font-medium">{issuedDate}</p>
            </div>
            {cert.expires_at && (
              <div>
                <p class="text-[0.62rem] font-mono uppercase tracking-wider text-ink-soft font-bold mb-1.5">Expires</p>
                <p class="text-[1rem] text-ink font-medium">{expiresDate}</p>
              </div>
            )}
            {cert.duration_hours > 0 && (
              <div>
                <p class="text-[0.62rem] font-mono uppercase tracking-wider text-ink-soft font-bold mb-1.5">Duration</p>
                <p class="text-[1rem] text-ink font-medium">{cert.duration_hours} hours</p>
              </div>
            )}
            {cert.instructor_name && (
              <div>
                <p class="text-[0.62rem] font-mono uppercase tracking-wider text-ink-soft font-bold mb-1.5">Instructor</p>
                <p class="text-[1rem] text-ink font-medium">{cert.instructor_name}</p>
              </div>
            )}
            <div class="md:col-span-2 pt-5 border-t border-ink/10">
              <p class="text-[0.62rem] font-mono uppercase tracking-wider text-ink-soft font-bold mb-1.5">Credential number</p>
              <p class="text-[0.9rem] text-ink font-mono break-all">{cert.certificate_number}</p>
            </div>
            <div class="md:col-span-2">
              <p class="text-[0.62rem] font-mono uppercase tracking-wider text-ink-soft font-bold mb-1.5">Issued by</p>
              <p class="text-[1rem] text-ink font-medium">AquinTutor &mdash; an institution of EduRankAI</p>
              <p class="text-[0.78rem] text-ink-soft mt-0.5">{SITE.url}</p>
            </div>
          </div>
        </div>

        <div class="flex flex-wrap gap-3 justify-center mb-8">
          <a href={linkedinShare} target="_blank" rel="noopener noreferrer" class="btn-primary inline-flex items-center gap-2">
            Add to LinkedIn
          </a>
          <button type="button" id="copyLink" class="btn-ghost">Copy verification URL</button>
          <button type="button" onclick="window.print()" class="btn-ghost">Print / save PDF</button>
        </div>

        <p class="text-[0.78rem] text-ink-soft text-center max-w-xl mx-auto leading-relaxed">
          This credential was issued by EduRankAI and can be verified at this URL by anyone, with no login required. The credential number is unique and tamper-resistant.
        </p>
      </>
    )}
  </section>

  <script is:inline define:vars={{ verificationUrl }}>
    var btn = document.getElementById('copyLink');
    if (btn) {
      btn.addEventListener('click', function() {
        navigator.clipboard.writeText(verificationUrl).then(function() {
          btn.textContent = 'Copied!';
          setTimeout(function() { btn.textContent = 'Copy verification URL'; }, 1800);
        }).catch(function() {
          window.prompt('Copy this URL:', verificationUrl);
        });
      });
    }
  </script>
</BaseLayout>
