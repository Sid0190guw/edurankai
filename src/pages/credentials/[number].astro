---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { SITE } from '@/lib/site';

const { number } = Astro.params;
if (!number) return Astro.redirect('/');

// First check universal_certificates (test pass / event / internship / employment /
// LOR / custom — issued via /admin/certificates). If found, render via dedicated
// renderer below. Otherwise fall through to the legacy training-course flow.
let universal: any = null;
try {
  const { getUniversalBySerial } = await import('@/lib/universal-certificates');
  universal = await getUniversalBySerial(number);
} catch (_) {}
if (universal) {
  const { UCERT_KIND_LABELS } = await import('@/lib/universal-certificates');
  const kindMeta = UCERT_KIND_LABELS[universal.kind] || UCERT_KIND_LABELS.custom;
  const fmtDate = (d: any) => { try { return new Date(d).toLocaleDateString('en-IN', { day:'2-digit', month:'long', year:'numeric' }); } catch { return ''; } };
  return new Response(`<!DOCTYPE html><html><head><meta charset="utf-8"><title>Credential ${universal.serial} — ${universal.recipient_name}</title>
<meta name="viewport" content="width=device-width,initial-scale=1">
<style>
  body{margin:0;background:#f5f1e8;font-family:Georgia,'Times New Roman',serif;color:#1a1a1a;}
  .wrap{max-width:900px;margin:32px auto;padding:0 16px 60px;}
  .banner{padding:14px 20px;margin-bottom:16px;border-radius:10px;display:flex;align-items:center;gap:14px;font-family:'Inter Tight',sans-serif;}
  .banner.ok{background:rgba(74,222,128,0.10);border:1px solid rgba(74,222,128,0.32);color:#1a6b3a;}
  .banner.bad{background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.32);color:#9a2828;}
  .cert{background:#fffdf8;border:1px solid #e5dcc6;border-radius:14px;padding:48px 56px;position:relative;overflow:hidden;}
  .accent{position:absolute;top:0;left:0;right:0;height:6px;background:linear-gradient(90deg,${kindMeta.accent},#FF7040);}
  .meta{font-family:'Inter Tight',sans-serif;font-size:10.5px;letter-spacing:0.16em;text-transform:uppercase;color:#9a9a9a;font-weight:700;}
  h1.name{font-size:50px;font-style:italic;font-weight:500;margin:8px 0 16px;color:#0a0a0a;line-height:1.05;}
  h2.title{font-size:26px;font-weight:600;margin:0 0 12px;line-height:1.25;font-family:Georgia,serif;}
  .achievement{font-size:18px;line-height:1.55;color:#3a3a3a;margin:0 0 26px;font-style:italic;}
  .body-text{font-size:14.5px;line-height:1.7;color:#3a3a3a;white-space:pre-wrap;margin:18px 0;}
  .score{background:#fff5e8;border-left:3px solid #FF7040;padding:14px 18px;margin:24px 0;border-radius:0 6px 6px 0;}
  .score .num{font-size:32px;font-weight:700;color:#FF7040;margin:4px 0 0;font-family:Georgia,serif;}
  .footer{display:flex;justify-content:space-between;align-items:flex-end;margin-top:48px;padding-top:24px;border-top:1px solid #e5dcc6;}
  .sig{font-style:italic;font-size:22px;color:#1a1a1a;margin:0;}
  .sig-line{height:1px;background:#1a1a1a;margin:6px 0 8px;width:200px;margin-left:auto;}
  .verify{font-size:9.5px;color:#bdbdbd;text-align:center;margin:36px 0 0;letter-spacing:0.1em;font-family:'Inter Tight',sans-serif;}
  .actions{display:flex;gap:10px;margin-top:18px;flex-wrap:wrap;font-family:'Inter Tight',sans-serif;}
  .actions button,.actions a{padding:10px 22px;border-radius:8px;font-size:13px;font-weight:700;cursor:pointer;text-decoration:none;border:none;}
  .btn-print{background:#0a0a0a;color:#fff;}
  .btn-li{background:#0a66c2;color:#fff;}
  .btn-copy{background:#fff;color:#0a0a0a;border:1px solid #d8d8d8;}
  @media print {
    body{background:#fff;}
    .banner,.actions{display:none !important;}
    .wrap{margin:0;padding:0;max-width:none;}
    .cert{box-shadow:none;border:none;padding:30px;}
  }
</style></head><body><div class="wrap">
  <div class="banner ${universal.revoked ? 'bad' : 'ok'}">
    <strong>${universal.revoked ? 'REVOKED' : 'VERIFIED'}</strong>
    <span>${universal.revoked ? (universal.revocation_reason || 'This credential has been revoked.') : ('Authentic credential issued ' + fmtDate(universal.signed_at) + ' · Serial ' + universal.serial)}</span>
  </div>
  <article class="cert">
    <div class="accent"></div>
    <div style="display:flex;justify-content:space-between;margin-bottom:36px;">
      <div>
        <div class="meta">${universal.issuer_org || 'EduRankAI'}</div>
        <div class="meta" style="margin-top:4px;color:#bdbdbd;">${kindMeta.label}</div>
      </div>
      <div style="text-align:right;">
        <div class="meta">SERIAL · ${universal.serial}</div>
        <div class="meta" style="margin-top:4px;">VERIFIED · ${universal.verify_count} ×</div>
      </div>
    </div>
    <div class="meta" style="margin:0 0 8px;">This is to certify that</div>
    <h1 class="name">${universal.recipient_name}</h1>
    ${universal.achievement ? '<p class="achievement">' + universal.achievement + '</p>' : ''}
    <h2 class="title">${universal.title}</h2>
    ${universal.body ? '<p class="body-text">' + universal.body.replace(/</g, '&lt;') + '</p>' : ''}
    ${universal.score_pct != null ? '<div class="score"><div class="meta" style="color:#a05030;">Score on record</div><div class="num">' + Number(universal.score_pct).toFixed(1) + '%</div></div>' : ''}
    <div class="footer">
      <div>
        <div class="meta">Issued on</div>
        <div style="font-size:16px;font-weight:600;margin-top:4px;">${fmtDate(universal.signed_at)}</div>
        ${universal.valid_until ? '<div style="font-size:11px;color:#7a7a7a;margin-top:4px;">Valid until ' + fmtDate(universal.valid_until) + '</div>' : ''}
      </div>
      ${universal.issued_by_name ? `<div style="text-align:right;">
        <div class="sig">${universal.issued_by_name}</div>
        <div class="sig-line"></div>
        <div style="font-size:11.5px;color:#5a5a5a;">${universal.issued_by_designation || ''}</div>
        <div style="font-size:11.5px;color:#5a5a5a;font-weight:600;margin-top:2px;">${universal.issuer_org || 'EduRankAI'}</div>
      </div>` : ''}
    </div>
    <div class="verify">Verify at edurankai.in/credentials/${universal.serial}</div>
  </article>
  <div class="actions">
    <button class="btn-print" onclick="window.print()">Print / Save as PDF</button>
    <a class="btn-li" href="https://www.linkedin.com/profile/add?startTask=CERTIFICATION_NAME&name=${encodeURIComponent(universal.title)}&organizationName=${encodeURIComponent(universal.issuer_org || 'EduRankAI')}&issueYear=${new Date(universal.signed_at).getFullYear()}&issueMonth=${new Date(universal.signed_at).getMonth()+1}&certUrl=${encodeURIComponent('https://edurankai.in/credentials/' + universal.serial)}&certId=${universal.serial}" target="_blank" rel="noopener">Add to LinkedIn</a>
    <button class="btn-copy" onclick="navigator.clipboard.writeText('https://edurankai.in/credentials/${universal.serial}');this.textContent='Copied'">Copy verify URL</button>
  </div>
</div></body></html>`, { headers: { 'content-type': 'text/html; charset=utf-8' } });
}

let cert: any = null;
try {
  const r = await db.execute(sql`
    SELECT c.id, c.certificate_number, c.issued_at, c.expires_at,
      u.name as user_name,
      co.title as course_title, co.slug as course_slug,
      co.instructor_name, co.duration_hours, co.category, co.level
    FROM training_certificates c
    JOIN users u ON c.user_id = u.id
    JOIN training_courses co ON c.course_id = co.id
    WHERE c.certificate_number = ${number}
    LIMIT 1
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  cert = rows[0] || null;
} catch (_) {}

const isValid = !!cert && (!cert.expires_at || new Date(cert.expires_at) > new Date());
const issuedDate = cert?.issued_at
  ? new Date(cert.issued_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })
  : '';
const expiresDate = cert?.expires_at
  ? new Date(cert.expires_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })
  : '';

const pageTitle = cert
  ? 'Verified credential: ' + cert.course_title + ' - ' + cert.user_name
  : 'Credential not found';
const pageDesc = cert
  ? cert.user_name + ' completed ' + cert.course_title + ' on AquinTutor (EduRankAI). Verified credential ' + cert.certificate_number + '.'
  : 'This credential could not be verified.';

const credentialSchema = cert ? {
  '@context': 'https://schema.org',
  '@type': 'EducationalOccupationalCredential',
  identifier: cert.certificate_number,
  name: cert.course_title,
  credentialCategory: 'Course Completion Certificate',
  educationalLevel: cert.level || 'beginner',
  dateCreated: cert.issued_at,
  ...(cert.expires_at && { expires: cert.expires_at }),
  recognizedBy: { '@type': 'Organization', name: 'AquinTutor (EduRankAI)', sameAs: SITE.url },
  about: { '@type': 'Course', name: cert.course_title, url: SITE.url + '/aquintutor/courses/' + cert.course_slug },
  url: SITE.url + '/credentials/' + cert.certificate_number,
} : null;

const verificationUrl = SITE.url + '/credentials/' + (number || '');
const linkedinShare = cert ? ('https://www.linkedin.com/profile/add?startTask=CERTIFICATION_NAME&name=' + encodeURIComponent(cert.course_title) + '&organizationName=' + encodeURIComponent('AquinTutor (EduRankAI)') + '&issueYear=' + new Date(cert.issued_at).getFullYear() + '&issueMonth=' + (new Date(cert.issued_at).getMonth() + 1) + '&certUrl=' + encodeURIComponent(verificationUrl) + '&certId=' + encodeURIComponent(number || '')) : '#';
---
<AquintutorLayout title={pageTitle} description={pageDesc} noindex={!cert}>
  {credentialSchema && <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(credentialSchema)} />}

  {!cert ? (
    <section style="border-bottom:1px solid var(--rule);">
      <div style="max-width:760px; margin:0 auto; padding:96px 28px; text-align:center;">
        <div style="display:inline-flex; align-items:center; justify-content:center; width:56px; height:56px; border-radius:50%; background:rgba(160,66,30,0.08); color:var(--rust); margin-bottom:24px;">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        </div>
        <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 12px;">Verification failed</p>
        <h1 class="font-display" style="font-size:clamp(1.75rem, 3.5vw, 2.5rem); line-height:1.15; letter-spacing:-0.02em; font-weight:500; margin:0 0 20px; color:var(--ink);">Credential not found</h1>
        <p style="font-family:'Inter Tight',sans-serif; font-size:15.5px; color:var(--ink-500); max-width:480px; margin:0 auto 28px; line-height:1.65;">
          No AquinTutor credential exists with the number <code style="font-family:'JetBrains Mono',monospace; background:var(--sand-100); padding:2px 8px; border-radius:4px; font-size:13px; color:var(--ink);">{number}</code>. Check that the number is correct, or contact <a href="mailto:hr@edurankai.in" style="color:var(--rust); text-decoration:underline;">hr@edurankai.in</a>.
        </p>
        <a href="/aquintutor" style="background:var(--ink); color:var(--sand-50); padding:13px 24px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none; display:inline-block;">Back to AquinTutor</a>
      </div>
    </section>
  ) : (
    <>
      <section style="border-bottom:1px solid var(--rule);">
        <div style="max-width:760px; margin:0 auto; padding:64px 28px 40px; text-align:center;">
          <div style={'display:inline-flex; align-items:center; justify-content:center; width:54px; height:54px; border-radius:50%; margin-bottom:18px; ' + (isValid ? 'background:rgba(125,211,168,0.18); border:1px solid #7dd3a8; color:#3f8a64;' : 'background:var(--sand-100); border:1px solid var(--rule); color:var(--ink-500);')}>
            {isValid ? (
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            ) : (
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="6" x2="12" y2="12"/><line x1="12" y1="16" x2="12" y2="16"/></svg>
            )}
          </div>
          <p style={'font-family:Inter Tight,sans-serif; font-size:12px; font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 14px; ' + (isValid ? 'color:#3f8a64;' : 'color:var(--ink-500);')}>{isValid ? 'Verified credential' : 'Credential expired'}</p>
          <h1 class="font-display" style="font-size:clamp(1.75rem, 4vw, 2.85rem); line-height:1.12; letter-spacing:-0.02em; font-weight:500; margin:0 0 14px; color:var(--ink);">{cert.course_title}</h1>
          <p style="font-family:'Inter Tight',sans-serif; font-size:16.5px; color:var(--ink-500); margin:0;">Issued to <strong style="color:var(--ink); font-weight:600;">{cert.user_name}</strong></p>
        </div>
      </section>

      <section style="background:var(--sand-100); border-bottom:1px solid var(--rule);">
        <div style="max-width:760px; margin:0 auto; padding:48px 28px;">
          <p style="font-family:'Inter Tight',sans-serif; font-size:12px; color:var(--rust); font-weight:600; letter-spacing:0.16em; text-transform:uppercase; margin:0 0 14px;">Credential record</p>
          <div style="background:var(--paper); border:1px solid var(--rule); border-radius:12px; padding:28px;">
            <dl style="display:grid; grid-template-columns:1fr; gap:18px 28px; margin:0; font-family:'Inter Tight',sans-serif; font-size:14.5px;" class="cred-grid">
              <div>
                <dt style="font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin-bottom:4px;">Recipient</dt>
                <dd style="margin:0; color:var(--ink); font-weight:500;">{cert.user_name}</dd>
              </div>
              <div>
                <dt style="font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin-bottom:4px;">Course</dt>
                <dd style="margin:0;"><a href={'/aquintutor/courses/' + cert.course_slug} style="color:var(--ink); text-decoration:underline; font-weight:500;">{cert.course_title}</a></dd>
              </div>
              <div>
                <dt style="font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin-bottom:4px;">Issued</dt>
                <dd style="margin:0; color:var(--ink); font-weight:500;">{issuedDate}</dd>
              </div>
              {cert.expires_at && (
                <div>
                  <dt style="font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin-bottom:4px;">Expires</dt>
                  <dd style="margin:0; color:var(--ink); font-weight:500;">{expiresDate}</dd>
                </div>
              )}
              {cert.duration_hours > 0 && (
                <div>
                  <dt style="font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin-bottom:4px;">Duration</dt>
                  <dd style="margin:0; color:var(--ink); font-weight:500;">{cert.duration_hours} hours</dd>
                </div>
              )}
              {cert.instructor_name && (
                <div>
                  <dt style="font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin-bottom:4px;">Instructor</dt>
                  <dd style="margin:0; color:var(--ink); font-weight:500;">{cert.instructor_name}</dd>
                </div>
              )}
              <div style="grid-column:1/-1; padding-top:18px; border-top:1px solid var(--rule);">
                <dt style="font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin-bottom:4px;">Credential number</dt>
                <dd style="margin:0; color:var(--ink); font-family:'JetBrains Mono',monospace; font-size:13px; word-break:break-all;">{cert.certificate_number}</dd>
              </div>
              <div style="grid-column:1/-1;">
                <dt style="font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-500); font-weight:600; margin-bottom:4px;">Issued by</dt>
                <dd style="margin:0; color:var(--ink); font-weight:500;">AquinTutor &mdash; an institution of EduRank·AI</dd>
                <dd style="margin:4px 0 0; color:var(--ink-500); font-size:13px;">{SITE.url}</dd>
              </div>
            </dl>
          </div>
        </div>
      </section>

      <section>
        <div style="max-width:760px; margin:0 auto; padding:40px 28px 80px;">
          <div style="display:flex; gap:10px; flex-wrap:wrap; justify-content:center; margin-bottom:24px;">
            <a href={linkedinShare} target="_blank" rel="noopener noreferrer" style="background:var(--ink); color:var(--sand-50); padding:13px 22px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; text-decoration:none;">Add to LinkedIn</a>
            <button type="button" id="copyLink" style="background:transparent; color:var(--ink); padding:13px 22px; border:1px solid var(--ink); border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; cursor:pointer;">Copy verification URL</button>
            <button type="button" onclick="window.print()" style="background:transparent; color:var(--ink); padding:13px 22px; border:1px solid var(--rule); border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:600; cursor:pointer;">Print / save PDF</button>
          </div>
          <p style="font-family:'Inter Tight',sans-serif; font-size:13.5px; color:var(--ink-500); text-align:center; max-width:520px; margin:0 auto; line-height:1.65;">
            This credential was issued by AquinTutor (EduRankAI) and can be verified at this URL by anyone, with no login required. The credential number is unique and tamper-resistant.
          </p>
        </div>
      </section>
    </>
  )}

  <style>
    @media (min-width: 640px) {
      .cred-grid { grid-template-columns: 1fr 1fr !important; }
    }
  </style>

  <script is:inline define:vars={{ verificationUrl }}>
    var btn = document.getElementById('copyLink');
    if (btn) {
      btn.addEventListener('click', function() {
        navigator.clipboard.writeText(verificationUrl).then(function() {
          btn.textContent = 'Copied';
          setTimeout(function() { btn.textContent = 'Copy verification URL'; }, 1800);
        }).catch(function() {
          window.prompt('Copy this URL:', verificationUrl);
        });
      });
    }
  </script>
</AquintutorLayout>
