---
import AquintutorLayout from '@/layouts/AquintutorLayout.astro';

// Public credential-verify entry point. Anyone (e.g. an employer) can enter a
// credential number to look it up at /credentials/<number>. No sign-in needed.
const q = (new URL(Astro.request.url).searchParams.get('n') || '').trim();
if (q) return Astro.redirect('/credentials/' + encodeURIComponent(q));
---
<AquintutorLayout title="Verify a credential">
  <section style="max-width:620px;margin:0 auto;padding:48px 24px 80px;text-align:center;">
    <p style="font-size:11px;font-family:'Inter Tight',sans-serif;text-transform:uppercase;letter-spacing:0.16em;color:var(--rust);font-weight:700;margin:0 0 10px;">Credential registry</p>
    <h1 class="font-display" style="font-size:clamp(1.8rem,5vw,2.6rem);font-weight:500;letter-spacing:-0.01em;margin:0 0 12px;">Verify a credential.</h1>
    <p class="font-serif" style="font-size:16px;font-style:italic;color:var(--ink-500);line-height:1.6;margin:0 0 28px;">Enter the credential number printed on any EduRank&middot;AI or AquinTutor certificate to confirm it is genuine and see what it certifies.</p>

    <form method="get" action="/credentials" style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;max-width:480px;margin:0 auto;">
      <input type="text" name="n" required placeholder="e.g. ERA-2026-XXXXXX" autocomplete="off"
        style="flex:1;min-width:240px;padding:13px 16px;border:1px solid var(--rule);border-radius:9px;font-size:15px;font-family:'Inter Tight',sans-serif;background:var(--sand-50);outline:none;text-transform:uppercase;letter-spacing:0.04em;" />
      <button type="submit"
        style="background:var(--ink);color:var(--sand-50);border:0;border-radius:9px;padding:13px 28px;font-family:'Inter Tight',sans-serif;font-weight:600;font-size:15px;cursor:pointer;">Verify</button>
    </form>

    <p style="font-size:13px;color:var(--ink-500);margin:22px 0 0;font-family:'Inter Tight',sans-serif;">Hold a credential yourself? It is listed in <a href="/portal/profile#credentials" style="color:var(--rust);text-decoration:none;">your profile</a>.</p>
  </section>
</AquintutorLayout>
