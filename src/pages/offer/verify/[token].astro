---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { offerLetters } from '@/lib/db/schema';
import { eq } from 'drizzle-orm';

const { token } = Astro.params;
if (!token) return Astro.redirect('/');

const offerList = await db.select({
  id: offerLetters.id,
  token: offerLetters.token,
  status: offerLetters.status,
  candidateName: offerLetters.candidateName,
  roleTitle: offerLetters.roleTitle,
  department: offerLetters.department,
  refNumber: offerLetters.refNumber,
  integrityHash: offerLetters.integrityHash,
  offerDate: offerLetters.offerDate,
  joiningDate: offerLetters.joiningDate,
  signedAt: offerLetters.signedAt,
  withdrawnAt: offerLetters.withdrawnAt,
  expiryDate: offerLetters.expiryDate
}).from(offerLetters).where(eq(offerLetters.token, token)).limit(1);

const offer = offerList.length > 0 ? offerList[0] : null;

function formatDate(d: any): string {
  if (!d) return '';
  const date = typeof d === 'string' ? new Date(d) : d;
  if (isNaN(date.getTime())) return d;
  return date.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
}

function formatDateTime(d: any): string {
  if (!d) return '';
  const date = typeof d === 'string' ? new Date(d) : d;
  if (isNaN(date.getTime())) return d;
  return date.toLocaleString('en-IN', { day: 'numeric', month: 'short', year: 'numeric', hour: 'numeric', minute: '2-digit' });
}

const STATUS_LABELS: Record<string, string> = {
  draft: 'Draft - Not Sent',
  sent: 'Sent - Awaiting Signature',
  signed: 'Accepted and Signed',
  withdrawn: 'Withdrawn'
};

const STATUS_COLORS: Record<string, string> = {
  draft: 'bg-cream-2 text-ink-soft border-ink/15',
  sent: 'bg-burn-pale text-burn border-burn-dim',
  signed: 'bg-leaf-bg text-leaf border-leaf-border',
  withdrawn: 'bg-red-500/10 text-red-700 border-red-300'
};

const isExpired = offer && offer.expiryDate && offer.status === 'sent'
  ? (new Date(offer.expiryDate).getTime() < Date.now())
  : false;
---
<BaseLayout title={offer ? 'Verify Offer - ' + offer.refNumber : 'Offer Not Found'} description="Verify the authenticity of an EduRankAI offer letter.">

  <section class="px-[5vw] py-10 md:py-16 max-w-2xl mx-auto">

    <div class="mb-8 text-center">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-2">OFFER VERIFICATION</p>
      <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.5rem)] font-semibold text-ink leading-[1.1] tracking-tight">
        EduRankAI <em class="italic text-burn font-medium">Offer Authenticity</em>
      </h1>
      <p class="text-[0.85rem] text-ink-soft mt-2 leading-relaxed">Public verification page. No login required.</p>
    </div>

    {!offer ? (
      <div class="bg-red-500/10 border border-red-500/30 rounded-2xl p-8 text-center">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-red-500/20 border-2 border-red-500/40 mb-4">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-red-700">
            <path d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </div>
        <h2 class="font-display text-[1.4rem] font-semibold text-red-700 mb-2">No offer found</h2>
        <p class="text-[0.88rem] text-ink-2 leading-relaxed">This verification link is invalid or has been deleted. If you received this link from EduRankAI and believe this is an error, please contact <a href="mailto:hr@edurankai.in" class="text-burn font-semibold hover:underline">hr@edurankai.in</a>.</p>
      </div>
    ) : (
      <article class="bg-white border border-ink/10 rounded-2xl overflow-hidden">

        <div class={'p-6 md:p-8 text-center ' + (offer.status === 'signed' ? 'bg-leaf-bg/40' : offer.status === 'withdrawn' ? 'bg-red-500/5' : 'bg-burn-pale/30')}>
          <div class={'inline-flex items-center justify-center w-16 h-16 rounded-full mb-3 border-2 ' + (offer.status === 'signed' ? 'bg-leaf-bg border-leaf' : offer.status === 'withdrawn' ? 'bg-red-100 border-red-400' : 'bg-burn-pale border-burn-dim')}>
            {offer.status === 'signed' && (
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-leaf">
                <path d="M5 13l4 4L19 7"/>
              </svg>
            )}
            {offer.status === 'sent' && !isExpired && (
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-burn">
                <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>
              </svg>
            )}
            {(offer.status === 'withdrawn' || isExpired) && (
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-red-700">
                <path d="M6 18L18 6M6 6l12 12"/>
              </svg>
            )}
          </div>
          <p class="font-display text-[1.3rem] font-semibold text-ink leading-tight">
            {offer.status === 'signed' && 'This offer has been accepted and signed'}
            {offer.status === 'sent' && !isExpired && 'This is an authentic active offer'}
            {offer.status === 'sent' && isExpired && 'This offer has expired'}
            {offer.status === 'withdrawn' && 'This offer was withdrawn'}
            {offer.status === 'draft' && 'This offer is in draft (not sent)'}
          </p>
        </div>

        <div class="p-6 md:p-8">

          <div class="grid grid-cols-2 gap-3 mb-5">
            <div class="bg-cream-2 border border-ink/8 rounded-lg p-3">
              <p class="text-[0.58rem] font-bold uppercase tracking-wider text-ink-soft mb-1">Reference</p>
              <p class="font-mono text-[0.95rem] font-semibold text-ink">{offer.refNumber}</p>
            </div>
            <div class="bg-cream-2 border border-ink/8 rounded-lg p-3">
              <p class="text-[0.58rem] font-bold uppercase tracking-wider text-ink-soft mb-1">Status</p>
              <span class={'inline-block text-[0.7rem] font-bold uppercase tracking-wider border px-2 py-0.5 rounded-full ' + (STATUS_COLORS[offer.status] || 'bg-cream-2 text-ink border-ink/15')}>
                {STATUS_LABELS[offer.status] || offer.status}
              </span>
            </div>
          </div>

          <div class="border-t border-ink/8 pt-4">
            <p class="text-[0.62rem] font-bold uppercase tracking-wider text-ink-soft mb-3">Offer Details</p>
            <table class="w-full text-[0.88rem]">
              <tbody>
                <tr class="border-b border-ink/5"><td class="text-ink-soft py-2.5 w-2/5">Candidate</td><td class="font-semibold text-ink">{offer.candidateName}</td></tr>
                <tr class="border-b border-ink/5"><td class="text-ink-soft py-2.5">Role</td><td class="font-semibold text-ink">{offer.roleTitle}</td></tr>
                {offer.department && <tr class="border-b border-ink/5"><td class="text-ink-soft py-2.5">Department</td><td class="font-semibold text-ink">{offer.department}</td></tr>}
                {offer.offerDate && <tr class="border-b border-ink/5"><td class="text-ink-soft py-2.5">Issued</td><td class="font-semibold text-ink">{formatDate(offer.offerDate)}</td></tr>}
                {offer.joiningDate && <tr class="border-b border-ink/5"><td class="text-ink-soft py-2.5">Joining Date</td><td class="font-semibold text-ink">{formatDate(offer.joiningDate)}</td></tr>}
                {offer.signedAt && <tr class="border-b border-ink/5"><td class="text-ink-soft py-2.5">Signed</td><td class="font-semibold text-leaf">{formatDateTime(offer.signedAt)}</td></tr>}
                {offer.withdrawnAt && <tr class="border-b border-ink/5"><td class="text-ink-soft py-2.5">Withdrawn</td><td class="font-semibold text-red-700">{formatDateTime(offer.withdrawnAt)}</td></tr>}
                {offer.expiryDate && !offer.signedAt && <tr class="border-b border-ink/5"><td class="text-ink-soft py-2.5">Expires</td><td class={'font-semibold ' + (isExpired ? 'text-red-700' : 'text-ink')}>{formatDate(offer.expiryDate)}</td></tr>}
                <tr><td class="text-ink-soft py-2.5">Integrity Hash</td><td class="font-mono text-burn text-[0.78rem]">{offer.integrityHash}</td></tr>
              </tbody>
            </table>
          </div>

          {offer.status === 'sent' && !isExpired && (
            <div class="mt-5 bg-burn-pale/30 border border-burn-dim/30 rounded-lg p-3.5 text-[0.82rem] text-ink-2 leading-relaxed">
              <p class="font-semibold text-burn mb-1">For the candidate</p>
              <p>To accept this offer, log into your portal at <a href="/portal" class="text-burn font-semibold hover:underline">edurankai.in/portal</a> and follow the signing instructions there.</p>
            </div>
          )}

          <div class="mt-5 pt-4 border-t border-ink/8 text-[0.75rem] text-ink-soft leading-relaxed">
            <p><strong class="text-ink">This page verifies authenticity, not employment status.</strong> Signed offers represent the candidate's acceptance of the terms shown above. For employment verification, contact <a href="mailto:hr@edurankai.in" class="text-burn font-semibold hover:underline">hr@edurankai.in</a>.</p>
          </div>

        </div>
      </article>
    )}

    <div class="mt-8 text-center text-[0.78rem] text-ink-soft">
      <p>EduRankAI - <a href="/" class="text-burn hover:underline">edurankai.in</a></p>
    </div>

  </section>

</BaseLayout>