---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found" description="The page you were looking for doesn't exist." noindex={true}>

  <section class="px-[5vw] py-24 md:py-32 max-w-2xl mx-auto text-center">
    <p class="eyebrow mb-6 text-burn">404</p>
    <h1 class="font-display text-[clamp(2.5rem,7vw,4.5rem)] font-semibold text-ink leading-[1.05] tracking-tight mb-6">
      This page <em class="italic text-burn font-medium">went exploring.</em>
    </h1>
    <p class="text-[1.05rem] text-ink-soft leading-relaxed mb-10 max-w-xl mx-auto">
      The link you followed is broken or the page has moved. While you're here, here's where most people go next.
    </p>

    <div class="flex flex-wrap justify-center gap-3 mb-12">
      <a href="/" class="bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.9rem] transition-colors">Home</a>
      <a href="/careers" class="bg-ink hover:bg-ink/90 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.9rem] transition-colors">Open roles</a>
      <a href="/research" class="bg-cream-2 border border-ink/15 hover:border-burn text-ink font-semibold py-2.5 px-5 rounded-lg text-[0.9rem] transition-colors">Research</a>
      <a href="/contact" class="bg-cream-2 border border-ink/15 hover:border-burn text-ink font-semibold py-2.5 px-5 rounded-lg text-[0.9rem] transition-colors">Contact</a>
    </div>

    <p class="text-[0.82rem] text-ink-soft">
      Found a broken link? Email <a href="mailto:connect@edurankai.in" class="text-burn hover:underline">connect@edurankai.in</a> and we'll fix it.
    </p>
  </section>

</BaseLayout>
