---
import BaseLayout from '@/layouts/BaseLayout.astro';

const FAQS = [
  {
    q: 'What is EduRankAI?',
    a: 'EduRankAI is a frontier AI research lab building foundational models, reasoning systems, and quantum-era architectures. Our orienting mission is how humanity learns — and how machines can learn the same way.'
  },
  {
    q: 'Are you the same as the HEI ranking?',
    a: 'HEI (Higher Education Intelligence) is one of our products — an AI-driven ranking of universities. The full company is broader: a research lab, AquinTutor, Karate.support, Sambandh, and more. See the <a href="/ecosystem" class="text-burn hover:underline">Ecosystem</a> page for the full picture.'
  },
  {
    q: 'Where are you based?',
    a: 'Built in Bharat (India). Open to the world. Our team operates remotely with a primary base in India.'
  },
  {
    q: 'How do I apply for a role?',
    a: 'Visit the <a href="/careers" class="text-burn hover:underline">Careers page</a>, pick a role that fits, and submit through the applicant portal. We hire on demonstrated work, not credentials.'
  },
  {
    q: 'What is the hiring process like?',
    a: 'A typical path: application review → short conversation → a take-home task or walkthrough → final interview → offer. We aim to keep the full loop under three weeks. See our <a href="/p/hiring-philosophy" class="text-burn hover:underline">hiring philosophy</a> for the principles behind it.'
  },
  {
    q: 'How is your research different from OpenAI, Anthropic, or DeepMind?',
    a: 'Most frontier labs are scaling current architectures. We are designing new ones — architectures where reasoning is the primary operation, not an emergent side-effect of scale. Our bet is that the next jump in intelligence comes from architecture, not parameter count. See <a href="/research" class="text-burn hover:underline">Research</a> for the thesis.'
  },
  {
    q: 'Will you publish your research?',
    a: 'Yes. We publish what works, what does not, and why. Research outputs will be linked from the <a href="/research" class="text-burn hover:underline">Research</a> page as they are released.'
  },
  {
    q: 'Is there an investor / partnership inquiry path?',
    a: 'Yes — use the <a href="/contact" class="text-burn hover:underline">contact form</a> and select "Partnership / collaboration" or "Press / media". We reply within two business days.'
  },
  {
    q: 'How do I report a security issue?',
    a: 'Email <a href="mailto:security@edurankai.in" class="text-burn hover:underline">security@edurankai.in</a>. We follow responsible disclosure and will acknowledge within 48 hours.'
  },
  {
    q: 'I have a press inquiry. Who do I contact?',
    a: 'Use the <a href="/contact" class="text-burn hover:underline">contact form</a> with category "Press / media", or email <a href="mailto:hr@edurankai.in" class="text-burn hover:underline">hr@edurankai.in</a> directly.'
  }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQS.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a.replace(/<[^>]*>/g, '')
    }
  }))
};
---
<BaseLayout title="FAQ" description="Frequently asked questions about EduRankAI — our research, hiring, products, and partnerships.">

  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <section class="px-[5vw] pt-16 md:pt-24 pb-10 max-w-3xl mx-auto">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-6">FAQ</p>
    <h1 class="font-display text-[clamp(2rem,5vw,3.5rem)] font-semibold text-ink leading-[1.05] tracking-tight mb-6">
      Questions, <em class="italic text-burn font-medium">answered.</em>
    </h1>
    <p class="text-[1rem] text-ink-soft leading-relaxed">
      Common questions about EduRankAI — research, hiring, products, partnerships. Don't see what you need? <a href="/contact" class="text-burn hover:underline font-semibold">Get in touch</a>.
    </p>
  </section>

  <section class="px-[5vw] pb-20 max-w-3xl mx-auto">
    <div class="space-y-3">
      {FAQS.map((f, i) => (
        <details data-reveal class="bg-white border border-ink/10 rounded-xl group" open={i === 0}>
          <summary class="cursor-pointer list-none p-5 flex items-center justify-between gap-4 font-display text-[1.02rem] font-semibold text-ink hover:text-burn transition-colors">
            <span>{f.q}</span>
            <svg class="w-5 h-5 text-burn shrink-0 transition-transform group-open:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
          </summary>
          <div class="px-5 pb-5 text-[0.92rem] text-ink-soft leading-[1.75]" set:html={f.a}></div>
        </details>
      ))}
    </div>
  </section>

</BaseLayout>
