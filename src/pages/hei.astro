<script>
  function openModal(id) {
    document.querySelectorAll('.overlay').forEach(o => o.classList.remove('show'));
    const el = document.getElementById('modal-' + id);
    if (el) el.classList.add('show');
    document.body.style.overflow = 'hidden';
    window.scrollTo({ top: window.scrollY });
  }
  function closeModal() {
    document.querySelectorAll('.overlay').forEach(o => o.classList.remove('show'));
    document.body.style.overflow = '';
  }
  document.querySelectorAll('.overlay').forEach(o => {
    o.addEventListener('click', (e) => { if (e.target === o) closeModal(); });
  });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  // ============ GAP CHART ============
  const gapCtx = document.getElementById('gapChart').getContext('2d');
  // Each point: x = NIRF percentile (higher = better-claimed), y = Truth percentile (higher = better-real)
  const gapPoints = [
    { uni: 'IIT Bombay', x: 99, y: 78, r: 8 },
    { uni: 'IIT Madras', x: 98, y: 82, r: 8 },
    { uni: 'IISc Bangalore', x: 99, y: 89, r: 9 },
    { uni: 'IIT Kanpur', x: 96, y: 75, r: 7 },
    { uni: 'Galgotias U.', x: 86, y: 14, r: 12 },
    { uni: 'Tezpur U.', x: 91, y: 93, r: 7 },
    { uni: 'NLSIU', x: 99, y: 81, r: 7 },
    { uni: 'Delhi U.', x: 92, y: 79, r: 7 },
    { uni: 'JNU', x: 94, y: 86, r: 7 },
    { uni: 'BHU', x: 88, y: 71, r: 7 },
    { uni: 'AIIMS Delhi', x: 99, y: 86, r: 7 },
    { uni: 'IIT Guwahati', x: 95, y: 84, r: 7 },
    { uni: 'IIT Roorkee', x: 93, y: 76, r: 7 },
    { uni: 'Jamia Millia', x: 84, y: 78, r: 7 },
    { uni: 'Manipal Academy', x: 82, y: 58, r: 7 },
    { uni: 'Shiv Nadar U.', x: 78, y: 84, r: 7 },
    { uni: 'Ashoka U.', x: 70, y: 88, r: 7 },
    { uni: 'Symbiosis Pune', x: 76, y: 64, r: 7 },
    { uni: 'VIT Vellore', x: 80, y: 52, r: 7 },
    { uni: 'SRM Chennai', x: 74, y: 48, r: 7 },
    { uni: 'Christ U.', x: 72, y: 76, r: 7 },
    { uni: 'KIIT Bhubaneswar', x: 78, y: 56, r: 7 },
    { uni: 'Chandigarh U.', x: 68, y: 22, r: 10 },
    { uni: 'Lovely Pro. U.', x: 65, y: 19, r: 11 },
    { uni: 'Amity U.', x: 78, y: 38, r: 8 },
    { uni: 'Calcutta U.', x: 86, y: 81, r: 7 },
    { uni: 'IIT Hyderabad', x: 90, y: 88, r: 7 },
    { uni: 'IIT BHU', x: 89, y: 73, r: 7 }
  ];

  new Chart(gapCtx, {
    type: 'bubble',
    data: {
      datasets: [
        {
          label: 'India universities',
          data: gapPoints,
          backgroundColor: (ctx) => {
            const p = ctx.raw;
            if (!p) return '#999';
            const gap = p.x - p.y;
            if (gap > 25) return 'rgba(185,28,28,0.7)';
            if (gap > 5) return 'rgba(180,83,9,0.65)';
            if (gap < -10) return 'rgba(21,128,61,0.7)';
            return 'rgba(31,31,31,0.65)';
          },
          borderColor: '#0A0A0A',
          borderWidth: 1,
        }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: (ctx) => {
              const p = ctx.raw;
              const gap = p.x - p.y;
              return [`${p.uni}`, `NIRF percentile: ${p.x}`, `Truth percentile: ${p.y}`, `Reality gap: ${gap > 0 ? '+' : ''}${gap} (${gap > 5 ? 'over-rated' : gap < -5 ? 'under-rated' : 'aligned'})`];
            }
          },
          backgroundColor: '#0A0A0A',
          padding: 12, cornerRadius: 4,
          titleFont: { family: 'Fraunces', size: 14, weight: 600 },
          bodyFont: { family: 'JetBrains Mono', size: 11 }
        },
        annotation: {} // placeholder
      },
      scales: {
        x: {
          title: { display: true, text: 'NIRF percentile (official ranking â€” higher = better-rated)', font: { family: 'Inter', size: 12, weight: 600 }, color: '#0A0A0A' },
          min: 0, max: 100,
          grid: { color: '#E5DFD0' },
          ticks: { font: { family: 'JetBrains Mono', size: 10 }, color: '#6B6457' }
        },
        y: {
          title: { display: true, text: 'EduRankAI Truth percentile (real outcomes)', font: { family: 'Inter', size: 12, weight: 600 }, color: '#0A0A0A' },
          min: 0, max: 100,
          grid: { color: '#E5DFD0' },
          ticks: { font: { family: 'JetBrains Mono', size: 10 }, color: '#6B6457' }
        }
      }
    },
    plugins: [{
      id: 'diagonal',
      beforeDatasetsDraw(chart) {
        const { ctx, chartArea: { left, right, top, bottom }, scales: { x, y } } = chart;
        // diagonal y = x line
        ctx.save();
        ctx.strokeStyle = '#C9C0A8';
        ctx.setLineDash([4, 4]);
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(x.getPixelForValue(0), y.getPixelForValue(0));
        ctx.lineTo(x.getPixelForValue(100), y.getPixelForValue(100));
        ctx.stroke();

        // labels
        ctx.setLineDash([]);
        ctx.fillStyle = '#6B6457';
        ctx.font = "italic 11px 'Fraunces', serif";
        ctx.fillText('above line: under-rated by official rankings', x.getPixelForValue(8), y.getPixelForValue(94));
        ctx.fillText('below line: over-rated by official rankings', x.getPixelForValue(45), y.getPixelForValue(8));
        ctx.restore();
      }
    }]
  });
</script>

