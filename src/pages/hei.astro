---
import { db } from '@/lib/db';
import { heiInstitutions, heiDimensions, heiSubmetrics, heiStories, heiInstitutionScores } from '@/lib/db/schema';
import { asc, eq, and, desc } from 'drizzle-orm';
import { marked } from 'marked';

// Fetch all DB-driven content with safe fallbacks
let publishedStories: any[] = [];
let publishedInstitutions: any[] = [];
let allDimensions: any[] = [];
let allSubmetrics: any[] = [];
let scoresByInstitution: Record<string, Record<string, string>> = {};

try {
  publishedStories = await db.select().from(heiStories).where(eq(heiStories.isPublished, true)).orderBy(desc(heiStories.publishedAt)).limit(6);
} catch (e) { console.error('[hei] stories fetch failed:', e); }

try {
  publishedInstitutions = await db.select().from(heiInstitutions).where(eq(heiInstitutions.isPublished, true)).orderBy(asc(heiInstitutions.truthRank), asc(heiInstitutions.name)).limit(50);
} catch (e) { console.error('[hei] institutions fetch failed:', e); }

try {
  allDimensions = await db.select().from(heiDimensions).where(eq(heiDimensions.isPublished, true)).orderBy(asc(heiDimensions.sortOrder));
} catch (e) { console.error('[hei] dimensions fetch failed:', e); }

try {
  allSubmetrics = await db.select().from(heiSubmetrics).orderBy(asc(heiSubmetrics.dimensionId), asc(heiSubmetrics.sortOrder));
} catch (e) { console.error('[hei] submetrics fetch failed:', e); }

try {
  const allScores = await db.select().from(heiInstitutionScores);
  for (const s of allScores) {
    if (!scoresByInstitution[s.institutionId]) scoresByInstitution[s.institutionId] = {};
    scoresByInstitution[s.institutionId][s.dimensionId] = s.score;
  }
} catch (e) { console.error('[hei] scores fetch failed:', e); }

// Group submetrics by dimension
const submetricsByDimension: Record<string, any[]> = {};
for (const sm of allSubmetrics) {
  if (!submetricsByDimension[sm.dimensionId]) submetricsByDimension[sm.dimensionId] = [];
  submetricsByDimension[sm.dimensionId].push(sm);
}

const today = new Date().toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
const totalWeight = allDimensions.reduce((sum, d) => sum + parseFloat(d.weightPercent || '0'), 0);

function fmtDate(d: any): string {
  if (!d) return '';
  return new Date(d).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
}

function categoryLabel(c: string): string {
  const m: Record<string, string> = {
    investigation: 'Investigation',
    analysis: 'Analysis',
    methodology: 'Methodology',
    institution_profile: 'Profile',
    editorial: 'Editorial',
    data_release: 'Data release'
  };
  return m[c] || c;
}
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EduRankAI - The Truth Report on Universities</title>
<meta name="description" content="A new ranking that measures what universities actually do. Rooted in research. Built for students. No payment to game the score." />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,800&family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #0A0A0A; --ink-2: #1F1F1F;
    --paper: #FAF8F3; --paper-2: #F2EFE7;
    --rule: #E5DFD0; --rule-2: #C9C0A8;
    --muted: #6B6457; --muted-2: #999185;
    --accent: #B91C1C; --accent-2: #DC2626; --accent-soft: #FEE2E2;
    --good: #15803D; --good-soft: #DCFCE7;
    --warn: #B45309; --warn-soft: #FEF3C7;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { background: var(--paper); color: var(--ink); font-family: 'Inter', sans-serif; font-size: 15px; line-height: 1.55; -webkit-font-smoothing: antialiased; }
  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }

  .masthead { background: var(--paper); border-bottom: 2px solid var(--ink); padding: 20px 40px 14px; }
  .masthead-top { display:flex;justify-content:space-between;align-items:center;font-size:11px;color:var(--muted);letter-spacing:0.05em;padding-bottom:12px;border-bottom:1px solid var(--rule);text-transform:uppercase;font-weight:500; }
  .live-tag { display:inline-flex;align-items:center;gap:6px;color:var(--accent);font-weight:600; }
  .live-dot { width:7px;height:7px;border-radius:50%;background:var(--accent);animation:blink 1.4s infinite; }
  @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
  .brand-row { padding: 18px 0 6px; text-align: center; }
  .brand { font-family:'Fraunces',serif;font-size:64px;font-weight:700;letter-spacing:-0.04em;line-height:0.95;color:var(--ink); }
  .brand .dot { color: var(--accent); }
  .tagline { font-family:'Fraunces',serif;font-style:italic;font-size:17px;color:var(--muted);margin-top:8px; }
  .masthead-nav { display:flex;justify-content:center;gap:32px;padding:14px 0 4px;font-size:12px;letter-spacing:0.12em;text-transform:uppercase;font-weight:600;color:var(--ink); }
  .masthead-nav a { color: var(--ink); border-bottom: 2px solid transparent; padding-bottom: 4px; }
  .masthead-nav a:hover { border-bottom-color: var(--accent); text-decoration: none; }

  .hero-banner { padding: 40px;border-bottom: 1px solid var(--rule);background: var(--paper); }
  .hero-content { max-width: 1320px; margin: 0 auto; display:grid;grid-template-columns:1.4fr 1fr;gap:48px;align-items:start; }
  .hero-eyebrow { font-size:12px;color:var(--accent);letter-spacing:0.18em;text-transform:uppercase;font-weight:700;margin-bottom:12px; }
  .hero-title { font-family:'Fraunces',serif;font-size:54px;font-weight:600;line-height:1.04;letter-spacing:-0.02em;color:var(--ink);margin-bottom:16px; }
  .hero-title em { font-style:italic;color:var(--accent); }
  .hero-sub { font-size:16px;color:var(--ink-2);max-width:600px;line-height:1.65; }
  .hero-stat { background:var(--ink);color:var(--paper);padding:32px;border-radius:2px; }
  .hero-stat-num { font-family:'Fraunces',serif;font-size:64px;font-weight:700;color:var(--accent-2);line-height:1; }
  .hero-stat-label { font-size:14px;color:var(--paper);margin-top:14px;line-height:1.55; }
  .hero-stat-source { font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.1em;color:var(--muted-2);margin-top:14px;text-transform:uppercase; }

  .container { max-width: 1320px; margin: 0 auto; padding: 40px; }
  .section-eyebrow { font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:8px; }
  .section-title { font-family:'Fraunces',serif;font-size:38px;font-weight:600;color:var(--ink);line-height:1.1;margin-bottom:12px;letter-spacing:-0.015em; }
  .section-lead { font-size:16px;color:var(--ink-2);max-width:780px;line-height:1.65;margin-bottom:32px; }

  .stories-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(330px,1fr));gap:24px;margin-top:24px; }
  .story-card { background:var(--paper);border:1px solid var(--rule);padding:24px;border-radius:2px;transition:border-color 0.2s; }
  .story-card:hover { border-color: var(--ink); }
  .story-meta { display:flex;justify-content:space-between;align-items:center;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.1em;color:var(--muted);text-transform:uppercase;margin-bottom:14px;font-weight:600; }
  .story-headline { font-family:'Fraunces',serif;font-size:22px;line-height:1.2;color:var(--ink);margin-bottom:10px;font-weight:600;letter-spacing:-0.01em; }
  .story-headline a { color: var(--ink); }
  .story-deck { font-size:14px;color:var(--ink-2);line-height:1.55; }

  .ranking-table { width:100%;border-collapse:collapse;font-size:14px;margin-top:16px;background:var(--paper); }
  .ranking-table th { text-align:left;padding:12px 14px;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);font-weight:600;background:var(--paper-2);border-bottom:2px solid var(--ink); }
  .ranking-table td { padding:14px;border-bottom:1px solid var(--rule);color:var(--ink-2); }
  .ranking-table tr:hover td { background:var(--paper-2); }
  .ranking-table .rank { font-family:'Fraunces',serif;font-size:22px;font-weight:600;color:var(--ink);width:50px; }
  .ranking-table .score { font-family:'JetBrains Mono',monospace;font-weight:600;color:var(--accent); }
  .ranking-table .inst-name { font-weight:600;color:var(--ink); }
  .ranking-table .external-rank { font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--muted-2); }

  .dim-card { background:var(--paper);border:1px solid var(--rule);padding:24px;border-radius:2px;margin-bottom:16px; }
  .dim-num { font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--accent);letter-spacing:0.15em;font-weight:700; }
  .dim-title { font-family:'Fraunces',serif;font-size:24px;color:var(--ink);margin-top:6px;margin-bottom:6px;font-weight:600;letter-spacing:-0.01em; }
  .dim-weight { display:inline-block;font-family:'JetBrains Mono',monospace;font-size:11px;background:var(--accent);color:var(--paper);padding:2px 8px;border-radius:2px;font-weight:600;margin-left:8px; }
  .dim-blurb { font-size:14.5px;color:var(--ink-2);line-height:1.65;margin-top:10px; }
  .dim-submetrics { margin-top:14px;padding-top:14px;border-top:1px solid var(--rule);display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:8px; }
  .dim-sub { font-size:13px;color:var(--ink-2);padding:6px 0; }
  .dim-sub::before { content:"-";color:var(--accent);margin-right:6px;font-weight:600; }

  .empty-note { padding:40px;background:var(--paper-2);border:1px dashed var(--rule-2);border-radius:2px;text-align:center;color:var(--muted); }

  .footer { background:var(--ink);color:var(--paper);padding:48px 40px;margin-top:64px; }
  .footer-inner { max-width:1320px;margin:0 auto; }
  .footer h4 { font-family:'Fraunces',serif;font-size:20px;font-weight:600;margin-bottom:12px; }
  .footer p { color:var(--muted-2);font-size:13px;line-height:1.7; }
  .footer a { color: var(--paper); }

  @media (max-width: 900px) {
    .hero-content { grid-template-columns: 1fr; }
    .hero-title { font-size: 38px; }
    .brand { font-size: 44px; }
    .masthead-nav { gap: 18px; font-size: 11px; flex-wrap: wrap; }
    .masthead, .container, .footer { padding: 24px 18px; }
    .section-title { font-size: 28px; }
  }
</style>
</head>
<body>

<header class="masthead">
  <div class="masthead-top">
    <div>Vol. 1 - Issue 01 - {today} - <span class="live-tag"><span class="live-dot"></span>LIVE</span> Data refreshed daily</div>
    <div>Pre-launch preview - Methodology v0.4</div>
  </div>
  <div class="brand-row">
    <div class="brand">EduRank<span class="dot">.</span>AI</div>
    <div class="tagline">The Truth Report on Universities</div>
  </div>
  <nav class="masthead-nav">
    <a href="#stories">Investigations</a>
    <a href="#ranking">The Ranking</a>
    <a href="#methodology">Methodology</a>
    <a href="/ecosystem/hei">About HEI</a>
    <a href="/contact">Contact</a>
  </nav>
</header>

<main class="container">

  <section class="hero-banner" style="margin:0 -40px 48px; padding: 56px 40px;">
    <div class="hero-content">
      <div>
        <div class="hero-eyebrow">The Truth Report - Volume 1</div>
        <h1 class="hero-title">The world's universities, ranked by what's <em>actually happening</em> - not what brochures say.</h1>
        <p class="hero-sub">For 30 years, university rankings have been written by the universities themselves. We rebuilt the methodology from scratch. Every claim is sourced. Every institution has a right of reply. Every student has a voice. Nobody pays to look better.</p>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">14,488</div>
        <div class="hero-stat-label">Indian student deaths by suicide in 2024 alone. Up 89% from 2011. The rankings that exist today are not measuring this. We are.</div>
        <div class="hero-stat-source">SOURCE - NCRB ADSI 2024</div>
      </div>
    </div>
  </section>

  <section id="stories">
    <div class="section-eyebrow">This week's investigations</div>
    <h2 class="section-title">What rankings won't tell you</h2>
    <p class="section-lead">Original journalism on what universities do and don't disclose, why student outcomes drift from the prestige cycle, and where public money goes vs where outcomes follow.</p>

    {publishedStories.length === 0 ? (
      <div class="empty-note">No stories published yet. Editorial team is preparing the first investigation series.</div>
    ) : (
      <div class="stories-grid">
        {publishedStories.map((s) => (
          <article class="story-card">
            <div class="story-meta">
              <span>{categoryLabel(s.category)}</span>
              <span>{fmtDate(s.publishedAt)}</span>
            </div>
            <h3 class="story-headline"><a href={'/hei/story/' + s.slug}>{s.headline}</a></h3>
            {s.deck && <p class="story-deck">{s.deck}</p>}
          </article>
        ))}
      </div>
    )}
  </section>

  <section id="ranking" style="margin-top: 64px;">
    <div class="section-eyebrow">The ranking - updated daily</div>
    <h2 class="section-title">Top universities - measured honestly</h2>
    <p class="section-lead">Seven dimensions. Public methodology. Click any university for the full evidence file.</p>

    {publishedInstitutions.length === 0 ? (
      <div class="empty-note">No institutions published yet. Methodology review is in progress; pilot cohort data publishes after Phase 1 sign-off.</div>
    ) : (
      <div style="overflow-x:auto;border:1px solid var(--rule);border-radius:2px;">
        <table class="ranking-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Institution</th>
              <th>Truth Score</th>
              <th>NIRF</th>
              <th>QS</th>
              <th>THE</th>
              <th>Location</th>
            </tr>
          </thead>
          <tbody>
            {publishedInstitutions.map((i, idx) => (
              <tr>
                <td class="rank">{i.truthRank || (idx + 1)}</td>
                <td class="inst-name">{i.name}{i.type ? ' / ' + i.type : ''}</td>
                <td class="score">{i.truthScore || '-'}</td>
                <td class="external-rank">{i.nirfRank || '-'}</td>
                <td class="external-rank">{i.qsRank || '-'}</td>
                <td class="external-rank">{i.theRank || '-'}</td>
                <td>{i.city ? i.city + ', ' : ''}{i.country}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </section>

  <section id="methodology" style="margin-top: 64px;">
    <div class="section-eyebrow">How we measure</div>
    <h2 class="section-title">Seven dimensions. Published in full.</h2>
    <p class="section-lead">The methodology, source code, weights, and every data pipeline is open. If you disagree with our weights, fork them. If you spot an error, file an issue. Working Paper v0.4 is in academic peer review now - the public ranking goes live only after review is complete.</p>

    {allDimensions.length === 0 ? (
      <div class="empty-note">Methodology dimensions loading. Check back.</div>
    ) : (
      <div>
        {allDimensions.map((d, idx) => (
          <div class="dim-card">
            <div class="dim-num">DIMENSION {String(idx + 1).padStart(2, '0')}</div>
            <div>
              <span class="dim-title">{d.title}</span>
              <span class="dim-weight">{d.weightPercent}%</span>
            </div>
            {d.subtitle && <p style="font-family:'Fraunces',serif;font-style:italic;font-size:14px;color:var(--muted);margin-top:4px;">{d.subtitle}</p>}
            <p class="dim-blurb">{d.blurb}</p>
            {submetricsByDimension[d.id] && submetricsByDimension[d.id].length > 0 && (
              <div class="dim-submetrics">
                {submetricsByDimension[d.id].map((sm) => (
                  <div class="dim-sub">{sm.title}</div>
                ))}
              </div>
            )}
          </div>
        ))}
        <p style="font-size:13px;color:var(--muted);margin-top:12px;text-align:right;">Total weight: <strong style="color:var(--accent);">{totalWeight.toFixed(1)}%</strong></p>
      </div>
    )}
  </section>

</main>

<footer class="footer">
  <div class="footer-inner">
    <h4>EduRankAI <span style="color: var(--accent-2);">Truth Report</span></h4>
    <p>Published by EduRankAI - a Bharat-built frontier AI lab. Methodology in academic peer review. Public ranking goes live after Phase 1 sign-off.</p>
    <p style="margin-top:14px;">
      <a href="/ecosystem/hei">About HEI</a> -
      <a href="/p/privacy">Privacy</a> -
      <a href="/p/terms">Terms</a> -
      <a href="/contact">Contact</a> -
      <a href="mailto:hei@edurankai.in">hei@edurankai.in</a>
    </p>
  </div>
</footer>

</body>
</html>