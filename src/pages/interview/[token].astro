---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const { token } = Astro.params;
if (!token) return new Response('Not found', { status: 404 });
function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
const mi: any = rows(await db.execute(sql`SELECT * FROM manual_interviews WHERE join_token = ${token} LIMIT 1`))[0];

const fmt = (d: any) => d ? new Date(d).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', weekday: 'long', day: 'numeric', month: 'long', year: 'numeric', hour: 'numeric', minute: '2-digit' }) : 'To be scheduled';
const cancelled = mi && mi.status === 'cancelled';
const completed = mi && mi.status === 'completed';
---
<BaseLayout title={mi ? ('Interview - ' + mi.title) : 'Interview'} description="Your EduRankAI interview.">
  <section class="px-[5vw] py-12 md:py-16 max-w-xl mx-auto">
    {!mi ? (
      <div class="bg-white border border-ink/10 rounded-2xl p-8 text-center">
        <h1 class="font-display text-[1.5rem] font-semibold text-ink mb-2">Interview not found</h1>
        <p class="text-[0.9rem] text-ink-soft">This link is invalid or has expired. Please check with our team at <a href="mailto:hr@edurankai.in" class="text-burn hover:underline">hr@edurankai.in</a>.</p>
      </div>
    ) : (
      <>
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">EduRankAI Interview</p>
        <h1 class="font-display text-[clamp(1.7rem,4.5vw,2.4rem)] font-semibold text-ink leading-tight mb-2">{mi.title}</h1>
        <p class="text-[0.95rem] text-ink-soft mb-6">Hello <strong class="text-ink">{mi.candidate_name}</strong>{mi.role_title ? ', for the ' + mi.role_title + ' role' : ''}.</p>

        <div class="bg-white border border-ink/10 rounded-2xl p-6 mb-5">
          <div class="flex items-start justify-between gap-3 pb-4 border-b border-ink/8 mb-4">
            <div>
              <p class="text-[0.62rem] font-mono uppercase tracking-wider text-ink-soft mb-1">When</p>
              <p class="font-semibold text-ink text-[0.95rem]">{fmt(mi.scheduled_at)}</p>
              <p class="text-[0.8rem] text-ink-soft mt-1">Duration: about {mi.duration_mins} minutes</p>
            </div>
          </div>
          {mi.instructions && <p class="text-[0.88rem] text-ink-2 leading-relaxed mb-4 whitespace-pre-wrap">{mi.instructions}</p>}

          {cancelled ? (
            <div class="bg-red-500/10 border border-red-500/30 text-red-700 rounded-lg p-3 text-[0.85rem]">This interview has been cancelled. Our team will be in touch.</div>
          ) : completed ? (
            <div class="bg-cream-2 border border-ink/10 rounded-lg p-3 text-[0.85rem] text-ink-2">This interview is complete. Thank you — our team will follow up with next steps.</div>
          ) : mi.meeting_link ? (
            <a href={mi.meeting_link} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-burn hover:bg-burn/90 text-white font-semibold py-3 px-5 rounded-lg text-[0.9rem] no-underline">
              Join the interview
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17l10-10M7 7h10v10"/></svg>
            </a>
          ) : (
            <p class="text-[0.85rem] text-ink-soft">The meeting link will appear here closer to the scheduled time. Please check back, or watch your email.</p>
          )}
        </div>

        <div class="bg-burn-pale/50 border border-burn-dim rounded-2xl p-5 text-[0.85rem] text-ink-2 leading-relaxed">
          <p class="font-semibold text-burn mb-1.5">A few tips</p>
          <ul class="space-y-1 list-disc pl-5">
            <li>Join from a quiet, well-lit place with a stable connection.</li>
            <li>Be ready a few minutes early. A panel of our faculty will meet you.</li>
            <li>Be yourself — we evaluate fairly across the whole panel.</li>
          </ul>
          <p class="mt-3">Questions? <a href="mailto:hr@edurankai.in" class="text-burn hover:underline">hr@edurankai.in</a></p>
        </div>
      </>
    )}
  </section>
</BaseLayout>
