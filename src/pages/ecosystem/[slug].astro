---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { products } from '@/lib/db/schema';
import { eq, and } from 'drizzle-orm';
import { getRolesForProduct } from '@/lib/role-products';
import { ensureVentureCopy, VENTURE_COPY } from '@/lib/products-seed';
import SambandhHero from '@/components/ecosystem-heroes/SambandhHero.astro';
import SamparkHero from '@/components/ecosystem-heroes/SamparkHero.astro';
import SancharanHero from '@/components/ecosystem-heroes/SancharanHero.astro';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/ecosystem');

// Self-heal the three consumer-venture rows (travel / CRM / matchmaking copy)
// before reading — replaces stale education-placeholder text in the DB once.
await ensureVentureCopy();

// Canonical-known products get rendered even when the DB seed has not run
// yet. Copy comes from the same VENTURE_COPY source of truth as the DB sync.
const KNOWN: Record<string, any> = {};
for (const v of VENTURE_COPY) {
  KNOWN[v.slug] = {
    slug: v.slug,
    name: v.name,
    status: 'in_development',
    shortDescription: v.short,
    longDescription: v.long,
    externalUrl: null,
  };
}

const found = await db.select().from(products)
  .where(and(eq(products.slug, slug), eq(products.isVisible, true)))
  .limit(1);

const product: any = found[0] || KNOWN[slug] || null;
if (!product) return Astro.redirect('/ecosystem');

// Open roles that build THIS venture specifically (roles.product == this slug).
// A role with no product tag is cross-company and intentionally does not appear
// here — so AquinTutor and Karate.support never show each other's openings.
const relatedRoles = await getRolesForProduct(product.slug, 6);

const STATUS_LABELS: Record<string, string> = {
  live: 'Live',
  coming_soon: 'Coming Soon',
  in_development: 'In Development',
  research: 'Research',
  stealth: 'Stealth'
};

const STATUS_COLORS: Record<string, string> = {
  live: 'bg-leaf-bg text-leaf border-leaf-border',
  coming_soon: 'bg-burn-pale text-burn border-burn-dim',
  in_development: 'bg-sky-bg text-sky border-sky-border',
  research: 'bg-plum-bg text-plum border-plum-border',
  stealth: 'bg-ink/5 text-ink-soft border-ink/15'
};

const statusClass = STATUS_COLORS[product.status] || 'bg-cream-2 text-ink-soft border-ink/15';
const statusLabel = STATUS_LABELS[product.status] || product.status;
---
<BaseLayout title={product.name + ' - EduRankAI'} description={product.shortDescription || ''}>

  {slug === 'sambandh' && <SambandhHero />}
  {slug === 'sampark' && <SamparkHero />}
  {slug === 'sancharan' && <SancharanHero />}

  <section class="px-[5vw] py-10 md:py-16 max-w-3xl mx-auto">

    <div class="mb-6">
      <a href="/ecosystem" class="text-[0.82rem] text-ink-soft hover:text-burn font-mono">Back to ecosystem</a>
    </div>

    <div class="mb-8 pb-8 border-b border-ink/8">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span class={'inline-block text-[0.7rem] font-bold uppercase tracking-wider border px-3 py-1 rounded-full ' + statusClass}>
          {statusLabel}
        </span>
      </div>
      <h1 class="font-display text-[clamp(2rem,5vw,3rem)] font-semibold text-ink leading-[1.05] tracking-tight mb-4">
        {product.name}
      </h1>
      <p class="text-[1.05rem] text-ink-soft leading-relaxed">
        {product.shortDescription}
      </p>
      {product.externalUrl && (
        <a href={product.externalUrl} target="_blank" rel="noopener" class="mt-5 inline-flex items-center gap-2 bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.88rem] transition-all">
          Visit {product.name}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17l10-10M7 7h10v10"/></svg>
        </a>
      )}
    </div>

    {product.longDescription && (
      <div class="mb-10">
        <h2 class="font-display text-[1.3rem] font-semibold text-ink mb-3">About</h2>
        <div class="text-[0.95rem] text-ink-2 leading-relaxed whitespace-pre-wrap">
          {product.longDescription}
        </div>
      </div>
    )}

    {product.status === 'in_development' && (
      <div class="bg-sky-bg/40 border border-sky-border rounded-2xl p-5 md:p-6 mb-10">
        <p class="font-semibold text-sky mb-2 text-[0.95rem]">In active development</p>
        <p class="text-[0.88rem] text-ink-2 leading-relaxed">
          We are building this product right now. If you would like to contribute, see our open roles or get in touch directly.
        </p>
      </div>
    )}

    {product.status === 'research' && (
      <div class="bg-plum-bg/40 border border-plum-border rounded-2xl p-5 md:p-6 mb-10">
        <p class="font-semibold text-plum mb-2 text-[0.95rem]">Research stage</p>
        <p class="text-[0.88rem] text-ink-2 leading-relaxed">
          This is exploratory research, not a product. We share findings as they mature. Collaborators and researchers welcome to reach out.
        </p>
      </div>
    )}

    {product.status === 'coming_soon' && (
      <div class="bg-burn-pale/60 border border-burn-dim rounded-2xl p-5 md:p-6 mb-10">
        <p class="font-semibold text-burn mb-2 text-[0.95rem]">Launching soon</p>
        <p class="text-[0.88rem] text-ink-2 leading-relaxed">
          This product has a scheduled launch. Visit the link above for the live status, or reach out via Contact for early access.
        </p>
      </div>
    )}

    <div class="mb-10">
      <h2 class="font-display text-[1.3rem] font-semibold text-ink mb-1">Work on {product.name}</h2>
      <p class="text-[0.85rem] text-ink-soft italic mb-4">Open roles building this product specifically.</p>
      {relatedRoles.length > 0 ? (
        <Fragment>
          <div class="flex flex-col gap-2">
            {relatedRoles.map((r) => (
              <a href={'/careers/' + r.slug} class="bg-white border border-ink/10 hover:border-burn-dim rounded-lg p-3.5 flex items-center justify-between gap-3 transition-all group">
                <div>
                  <p class="font-semibold text-ink text-[0.92rem] group-hover:text-burn transition-colors">{r.title}</p>
                  <p class="text-[0.75rem] text-ink-soft mt-0.5">{r.level} - {r.department_id}{r.openings > 0 ? ' · ' + r.openings + (r.openings === 1 ? ' opening' : ' openings') : ''}</p>
                </div>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-ink-soft group-hover:text-burn transition-colors"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </a>
            ))}
          </div>
          <a href={'/careers?product=' + product.slug} class="inline-block mt-3 text-[0.85rem] text-burn font-semibold hover:underline">All {product.name} roles -&gt;</a>
        </Fragment>
      ) : (
        <div class="bg-cream-2 border border-dashed border-ink/15 rounded-xl p-5 text-center">
          <p class="text-[0.88rem] text-ink-2 mb-1">No {product.name}-specific roles are open right now.</p>
          <a href="/careers" class="text-[0.85rem] text-burn font-semibold hover:underline">Browse all open roles -&gt;</a>
        </div>
      )}
    </div>

  </section>

</BaseLayout>