---
import BaseLayout from '@/layouts/BaseLayout.astro';

const DIMENSIONS = [
  {
    num: '01',
    weight: '30%',
    title: 'Academic Excellence',
    subtitle: 'Whether students actually learn',
    blurb: 'Not reputation. Not endowment size. Not how many famous faculty are on the payroll. Whether students walk out genuinely capable in the discipline they came to study.',
    metrics: ['Learning outcome attainment rate', 'Teaching quality index (student-reported)', 'Formative assessment prevalence', 'Graduate outcome quality (12-month)', 'Curriculum-to-assessment alignment'],
    basis: 'Biggs & Tang (2011); Hattie (2009); Black & Wiliam (1998); OECD AHELO (2013)'
  },
  {
    num: '02',
    weight: '20%',
    title: 'Research & Innovation',
    subtitle: 'Originality, not citation cartels',
    blurb: 'Research that genuinely moves a field forward. Penalises citation gaming, self-citation rings, and the production of papers nobody reads. Rewards interdisciplinarity, student co-authorship, and open science.',
    metrics: ['Research originality (NLP-scored novelty)', 'Field-normalised citation quality', 'Student co-authorship rate', 'Interdisciplinary reach', 'Open access & reproducibility'],
    basis: 'Uzzi et al. (2013); Waltman et al. (2011); Seymour et al. (2004); Ioannidis (2005)'
  },
  {
    num: '03',
    weight: '20%',
    title: 'Student Well-being',
    subtitle: 'The dimension every other ranking ignores',
    blurb: 'Mental health. Burnout. Belonging. Basic-needs security. Forty-seven per cent of OECD university students reported significant psychological distress in 2023. The QS World Rankings allocate zero per cent to this. We treat their silence as the failure it is.',
    metrics: ['WEMWBS well-being index', 'Burnout prevalence (LMS + survey signal)', 'Mental health support access rate', 'Sense of belonging index', 'Physical safety and basic needs'],
    basis: 'Tennant et al. (2007); Maslach & Leiter (2016); Walton & Cohen (2011); Goldrick-Rab (2016)'
  },
  {
    num: '04',
    weight: '15%',
    title: 'Ethical & Social Impact',
    subtitle: 'What the institution returns to the world',
    blurb: 'Equity. Environmental responsibility. Civic engagement. Ethics inside the curriculum. Governance transparency. Universities are publicly trusted institutions. Their conduct beyond their own walls is in scope.',
    metrics: ['Equity & inclusion index', 'Environmental sustainability score', 'Community & civic engagement', 'Ethics in curriculum (NLP audit)', 'Governance transparency'],
    basis: 'AdvanceHE (2022); IPCC (2022); Boyer (1990); UNESCO (2017); OECD (2020)'
  },
  {
    num: '05',
    weight: '15%',
    title: 'Adaptability',
    subtitle: 'Whether the institution can still learn',
    blurb: 'How fast does this institution respond to evidence, student feedback, and the changing shape of work? An institution that cannot revise its curriculum, hear its students, or update its policies is not excellent &mdash; it is brittle.',
    metrics: ['Curriculum revision velocity', 'Student feedback response rate', 'Technology adoption maturity', 'Policy response speed', 'Continuous improvement culture'],
    basis: 'Bok (2006); Gibbs (2010); EDUCAUSE Horizon Report; Senge (1990)'
  }
];

const SCOPES = [
  { tier: 'Tier 1', label: 'Universities & Higher Education', detail: 'Public, private, and autonomous universities; degree-granting colleges; institutes of national importance. Bharat-first, then global.' },
  { tier: 'Tier 2', label: 'Schools & K-12 Education', detail: 'Public, private, and government-run schools. Boards of education. State-level systems. The earlier the system, the more leverage on a life.' },
  { tier: 'Tier 3', label: 'Government Programmes', detail: 'Publicly-funded education initiatives, scholarship schemes, skill-development programmes. Where money is allocated and where outcomes either follow or do not.' }
];

const COMPARISON = [
  { dim: 'Academic Excellence (actual learning, not brand)', qs: 'partial', the: 'partial', arwu: 'missing', um: 'partial', hei: 'full' },
  { dim: 'Research originality (not citation volume)', qs: 'missing', the: 'partial', arwu: 'missing', um: 'partial', hei: 'full' },
  { dim: 'Student well-being and mental health', qs: 'missing', the: 'missing', arwu: 'missing', um: 'missing', hei: 'full' },
  { dim: 'Ethical and social impact', qs: 'missing', the: 'partial', arwu: 'missing', um: 'partial', hei: 'full' },
  { dim: 'Institutional adaptability', qs: 'missing', the: 'missing', arwu: 'missing', um: 'missing', hei: 'full' },
  { dim: 'Transparency of scoring logic', qs: 'partial', the: 'partial', arwu: 'missing', um: 'full', hei: 'full' },
  { dim: 'Actionable improvement guidance', qs: 'missing', the: 'missing', arwu: 'missing', um: 'missing', hei: 'full' },
  { dim: 'Schools & K-12 covered', qs: 'missing', the: 'missing', arwu: 'missing', um: 'missing', hei: 'full' },
  { dim: 'Government educational programmes covered', qs: 'missing', the: 'missing', arwu: 'missing', um: 'missing', hei: 'full' },
  { dim: 'Built primarily for students, not administrators', qs: 'missing', the: 'missing', arwu: 'missing', um: 'missing', hei: 'full' }
];

const cellMark = (v: string) => v === 'full' ? '✓' : v === 'partial' ? '◑' : '✗';
const cellClass = (v: string) => v === 'full' ? 'text-leaf font-bold' : v === 'partial' ? 'text-gold-deep' : 'text-ink-soft/50';
---
<BaseLayout title="Holistic Education Index (HEI) - EduRankAI" description="A ranking system built for students, not institutions. Grounded in dharmic principles of holistic mastery. Covers universities, schools, and government educational programmes worldwide.">

  <!-- HERO -->
  <section class="px-[5vw] pt-16 md:pt-24 pb-12 max-w-5xl mx-auto">
    <p class="eyebrow mb-6">Holistic Education Index</p>
    <h1 class="font-display text-[clamp(2.5rem,6vw,4.5rem)] font-semibold text-ink leading-[1.05] tracking-tight mb-8 max-w-4xl">
      The first ranking built for the <em class="italic text-burn font-medium">student</em>, not the institution.
    </h1>
    <p class="text-[1.05rem] md:text-[1.15rem] text-ink-soft leading-[1.85] font-light max-w-3xl mb-8">
      The Holistic Education Index is a global ranking system for universities, schools, and government educational programmes. It measures what shapes a student's actual life &mdash; the quality of learning, the well-being of the learner, the ethical integrity of the institution &mdash; not the prestige cycles, citation cartels, and administrator-facing optics that dominate every existing global ranking.
    </p>
    <div class="inline-flex flex-wrap items-center gap-2">
      <span class="text-[0.7rem] font-bold uppercase tracking-wider bg-gold-bg text-gold-deep border border-gold-border px-3 py-1.5 rounded-full">Methodology v1.0</span>
      <span class="text-[0.7rem] font-bold uppercase tracking-wider bg-plum-bg text-plum border border-plum-border px-3 py-1.5 rounded-full">Academic Advisory Review</span>
      <span class="text-[0.7rem] font-bold uppercase tracking-wider bg-leaf-bg text-leaf border border-leaf-border px-3 py-1.5 rounded-full">Bharat-First, Global</span>
    </div>
  </section>

  <!-- THE INDICTMENT -->
  <section class="px-[5vw] py-16 md:py-20 max-w-5xl mx-auto border-t border-ink/8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn mb-3 font-bold">Why this exists</p>
    <h2 class="font-display text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold text-ink leading-[1.15] tracking-tight mb-8 max-w-3xl">
      The current rankings are a story told for institutions, not for the people who live with the consequences.
    </h2>
    <div class="space-y-5 max-w-3xl text-[1rem] text-ink-2 font-light leading-[1.9]">
      <p>
        Every dominant global ranking is built around inputs an institution can curate: reputation surveys filled out by other administrators, citation counts, endowment size, the names of famous faculty. None of these tell a sixteen-year-old whether the place they are about to commit four years of their life to will actually teach them anything, support them when they break, or send them out the other side capable of building a life.
      </p>
      <p>
        We see the consequences of that gap every day. Career insecurity. Depression. Burnout. Quiet quitting. Suicide rates among young adults that the institutions never have to answer for. Divorce rates traceable in part to a generation that was sorted by exam scores instead of helped to understand themselves. Public funds poured into educational systems that produce graduates with degrees and no mastery of anything they can stand on.
      </p>
      <p>
        Rankings shape this. Students choose institutions based on rankings. Governments allocate money based on rankings. Parents push their children based on rankings. When the ranking measures the wrong thing, the entire system optimises for the wrong thing &mdash; and the cost is paid by individuals who never see the methodology that decided their future.
      </p>
      <p class="font-medium text-ink">
        The HEI exists to put the truth back on the table. The truth about which institutions actually teach, actually support their students, actually serve their public role &mdash; and which ones merely present well.
      </p>
    </div>
  </section>

  <!-- THE VEDIC ANCHOR -->
  <section class="px-[5vw] py-16 md:py-20 max-w-5xl mx-auto border-t border-ink/8 bg-cream-2/30">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn mb-3 font-bold">The deeper root</p>
    <h2 class="font-display text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold text-ink leading-[1.15] tracking-tight mb-8 max-w-3xl">
      Education, before it was an industry, knew what it was for.
    </h2>
    <div class="space-y-5 max-w-3xl text-[1rem] text-ink-2 font-light leading-[1.9]">
      <p>
        In the Vedic tradition of Bharat, the gurukul system worked on a principle the modern world has nearly forgotten. A student lived with a guru for years &mdash; sometimes from age five to graduation &mdash; and what they learned was determined by their own nature, their svadharma, not by a market signal or an exam quota.
      </p>
      <p>
        Some students were trained in scripture and reasoning. Some in metallurgy and engineering. Some in medicine. Some in governance. Some in the arts. The principle was simple: a person who has mastered the work their inner nature points them toward will not feel insecure about livelihood. They will not be confused about career. They will not be paralysed when circumstances change, because their training prepared them not for a job but for a life.
      </p>
      <p>
        And critically &mdash; the training was holistic. Physical, mental, emotional, intellectual, spiritual. A student of warfare studied poetry. A student of mathematics studied music. A student of medicine studied ethics. The whole person was developed because anything less is not education &mdash; it is processing.
      </p>
      <p>
        Modernity gave us scale, standardisation, and credentials. It also gave us the highest rates of career confusion, depression, and existential disorientation in recorded history. We are not arguing for a return to the past. We are arguing that the deepest insight of the past &mdash; education must serve the whole person, aligned with their nature &mdash; is exactly the principle that the modern ranking systems have systematically erased.
      </p>
      <p class="font-medium text-ink">
        The HEI is built on that principle, translated into measurable instruments any modern institution can be evaluated against.
      </p>
    </div>
  </section>

  <!-- WHO WE COVER -->
  <section class="px-[5vw] py-16 md:py-20 max-w-5xl mx-auto border-t border-ink/8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn mb-3 font-bold">Scope</p>
    <h2 class="font-display text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold text-ink leading-[1.15] tracking-tight mb-8 max-w-3xl">
      Three tiers. One framework. The whole education system.
    </h2>
    <p class="text-[0.95rem] text-ink-soft font-light leading-[1.85] mb-10 max-w-3xl">
      Every other ranking system stops at the university gates. The largest leverage on a person's life happens earlier. We measure the whole pipeline.
    </p>
    <div class="space-y-4">
      {SCOPES.map((s) => (
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6 bg-white border border-ink/10 rounded-2xl p-6 md:p-7">
          <div class="md:col-span-3">
            <p class="text-[0.65rem] font-bold uppercase tracking-wider bg-burn-pale text-burn border border-burn-dim px-2.5 py-1 rounded-md inline-block mb-3">{s.tier}</p>
            <h3 class="font-display text-[1.2rem] font-semibold text-ink leading-tight">{s.label}</h3>
          </div>
          <div class="md:col-span-9">
            <p class="text-[0.92rem] text-ink-2 font-light leading-[1.85]">{s.detail}</p>
          </div>
        </div>
      ))}
    </div>
    <div class="mt-8 bg-burn-pale border border-burn-dim rounded-xl p-5 max-w-3xl">
      <p class="text-[0.85rem] text-ink-2 leading-[1.8] font-light"><strong class="text-burn">Why government programmes are in scope:</strong> Public funds are spent and rarely audited against student outcomes. Corruption and negligence are educational variables when they affect millions of children. We will name them.</p>
    </div>
  </section>

  <!-- THE FIVE DIMENSIONS -->
  <section class="px-[5vw] py-16 md:py-20 max-w-5xl mx-auto border-t border-ink/8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn mb-3 font-bold">The five dimensions</p>
    <h2 class="font-display text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold text-ink leading-[1.15] tracking-tight mb-3 max-w-3xl">
      What we actually measure.
    </h2>
    <p class="text-[0.95rem] text-ink-soft font-light leading-[1.85] mb-10 max-w-3xl">
      Each dimension is grounded in mainstream education research. Each sub-metric is measurable, reproducible, and traceable back to a peer-reviewed source. The principle is ancient. The instrument is modern.
    </p>
    <div class="space-y-6">
      {DIMENSIONS.map((d) => (
        <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8">
          <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8">
            <div class="md:col-span-3">
              <div class="flex items-baseline gap-3 mb-2">
                <p class="font-mono text-[1.5rem] text-burn font-bold">{d.num}</p>
                <span class="text-[0.65rem] font-bold uppercase tracking-wider bg-burn-pale text-burn border border-burn-dim px-2 py-1 rounded-md">Weight {d.weight}</span>
              </div>
              <h3 class="font-display text-[1.4rem] font-semibold text-ink leading-tight mb-1">{d.title}</h3>
              <p class="text-[0.8rem] text-ink-soft italic">{d.subtitle}</p>
            </div>
            <div class="md:col-span-9">
              <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85] mb-4">{d.blurb}</p>
              <p class="text-[0.7rem] font-mono uppercase tracking-[0.15em] text-ink-soft mb-2 font-bold">Sub-metrics</p>
              <ul class="space-y-1.5 mb-4">
                {d.metrics.map((m) => (
                  <li class="text-[0.85rem] text-ink-2 flex gap-2">
                    <span class="text-burn font-bold">&middot;</span>
                    <span>{m}</span>
                  </li>
                ))}
              </ul>
              <p class="text-[0.72rem] text-ink-soft/80 italic"><strong class="text-ink-soft not-italic">Evidence basis:</strong> {d.basis}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- COMPARISON TABLE -->
  <section class="px-[5vw] py-16 md:py-20 max-w-5xl mx-auto border-t border-ink/8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn mb-3 font-bold">The comparison</p>
    <h2 class="font-display text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold text-ink leading-[1.15] tracking-tight mb-3 max-w-3xl">
      What the existing rankings measure &mdash; and what they leave out.
    </h2>
    <p class="text-[0.9rem] text-ink-soft font-light leading-[1.8] mb-8 max-w-3xl">
      <span class="font-bold text-leaf">&#10003;</span> measured meaningfully &middot; <span class="font-bold text-gold-deep">&#9681;</span> partial or methodologically compromised &middot; <span class="font-bold text-ink-soft">&#10007;</span> not measured at all
    </p>
    <div class="overflow-x-auto bg-white border border-ink/10 rounded-2xl">
      <table class="w-full text-[0.85rem] min-w-[700px]">
        <thead>
          <tr class="border-b border-ink/10 bg-cream-2">
            <th class="text-left p-4 font-display font-semibold text-ink">Dimension</th>
            <th class="text-center p-4 font-display font-semibold text-ink">QS</th>
            <th class="text-center p-4 font-display font-semibold text-ink">Times Higher</th>
            <th class="text-center p-4 font-display font-semibold text-ink">ARWU</th>
            <th class="text-center p-4 font-display font-semibold text-ink">U-Multirank</th>
            <th class="text-center p-4 font-display font-semibold text-burn bg-burn-pale">HEI</th>
          </tr>
        </thead>
        <tbody>
          {COMPARISON.map((row, idx) => (
            <tr class={'border-b border-ink/8 ' + (idx % 2 === 0 ? '' : 'bg-cream-2/30')}>
              <td class="p-4 text-ink-2 font-medium">{row.dim}</td>
              <td class={'p-4 text-center text-lg ' + cellClass(row.qs)}>{cellMark(row.qs)}</td>
              <td class={'p-4 text-center text-lg ' + cellClass(row.the)}>{cellMark(row.the)}</td>
              <td class={'p-4 text-center text-lg ' + cellClass(row.arwu)}>{cellMark(row.arwu)}</td>
              <td class={'p-4 text-center text-lg ' + cellClass(row.um)}>{cellMark(row.um)}</td>
              <td class={'p-4 text-center text-lg bg-burn-pale/50 ' + cellClass(row.hei)}>{cellMark(row.hei)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- WHO THIS IS FOR -->
  <section class="px-[5vw] py-16 md:py-20 max-w-5xl mx-auto border-t border-ink/8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn mb-3 font-bold">Who this serves</p>
    <h2 class="font-display text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold text-ink leading-[1.15] tracking-tight mb-10 max-w-3xl">
      Built for the people the system has been failing.
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="bg-white border border-ink/10 rounded-2xl p-6">
        <p class="text-[0.75rem] font-bold uppercase tracking-wider text-burn mb-3">Students &amp; families</p>
        <p class="text-[0.92rem] text-ink-2 font-light leading-[1.85]">An honest, decomposable score for every institution they are considering &mdash; with sub-metrics they can interrogate, alternatives they can compare, and well-being signals nobody else will show them.</p>
      </div>
      <div class="bg-white border border-ink/10 rounded-2xl p-6">
        <p class="text-[0.75rem] font-bold uppercase tracking-wider text-burn mb-3">Career counsellors &amp; advisors</p>
        <p class="text-[0.92rem] text-ink-2 font-light leading-[1.85]">A defensible framework for guiding a young person &mdash; not based on which institution sounds impressive at a dinner table, but which one matches their actual nature and likelihood of thriving.</p>
      </div>
      <div class="bg-white border border-ink/10 rounded-2xl p-6">
        <p class="text-[0.75rem] font-bold uppercase tracking-wider text-burn mb-3">Reformers within institutions</p>
        <p class="text-[0.92rem] text-ink-2 font-light leading-[1.85]">A scoring instrument that exposes where to actually improve, with sub-metric decomposition. Not a black-box rank to game &mdash; a diagnostic to act on.</p>
      </div>
      <div class="bg-white border border-ink/10 rounded-2xl p-6">
        <p class="text-[0.75rem] font-bold uppercase tracking-wider text-burn mb-3">Public-policy and audit</p>
        <p class="text-[0.92rem] text-ink-2 font-light leading-[1.85]">An independent index against which publicly-funded education programmes can be assessed. Where funds are flowing. Where outcomes follow. Where they do not.</p>
      </div>
    </div>
  </section>

  <!-- THE FORMULA -->
  <section class="px-[5vw] py-16 md:py-20 max-w-5xl mx-auto border-t border-ink/8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn mb-3 font-bold">The formula</p>
    <h2 class="font-display text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold text-ink leading-[1.15] tracking-tight mb-8 max-w-3xl">
      Every score is fully decomposable. No black boxes.
    </h2>
    <div class="bg-ink text-cream rounded-2xl p-6 md:p-8 font-mono text-[0.9rem] leading-relaxed mb-8">
      <p class="opacity-60 text-[0.7rem] uppercase tracking-wider mb-3">HEI Score Formula</p>
      <p>HEI =</p>
      <p class="pl-4">(0.30 &times; Academic Excellence)</p>
      <p class="pl-4">+ (0.20 &times; Research &amp; Innovation)</p>
      <p class="pl-4">+ (0.20 &times; Student Well-being)</p>
      <p class="pl-4">+ (0.15 &times; Ethical / Social Impact)</p>
      <p class="pl-4">+ (0.15 &times; Adaptability)</p>
    </div>
    <div class="space-y-5 max-w-3xl text-[0.95rem] text-ink-2 font-light leading-[1.9]">
      <p>
        The result is a number between 0 and 100. The sector average in our pilot cohort is between 62 and 68. No institution is expected to score 100 &mdash; the ideal standards are aspirational, set by research rather than by the top performer in any given year.
      </p>
      <p>
        Every HEI score is fully decomposed. Any institution being scored can see exactly which sub-metric drove a change in any dimension. There is no opaque aggregation step. This is a fundamental design requirement &mdash; without traceability, no one can act on the score, and the index becomes another reputation instrument.
      </p>
      <p>
        Smaller and less-resourced institutions face real structural disadvantages on several sub-metrics (open access publishing costs, sustainability infrastructure, technology adoption). The HEI runs a resource-adjusted scoring track for Tier 2 and Tier 3 institutions, applying peer-group normalisation within size and budget bands. This prevents the HEI from simply replicating the prestige hierarchy under a new name.
      </p>
    </div>
  </section>

  <!-- STATUS & CTA -->
  <section class="px-[5vw] py-16 md:py-20 max-w-5xl mx-auto border-t border-ink/8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn mb-3 font-bold">Where we are</p>
    <h2 class="font-display text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold text-ink leading-[1.15] tracking-tight mb-6 max-w-3xl">
      Methodology complete. Academic advisory review in progress. Public ranking when the work is real.
    </h2>
    <div class="space-y-5 max-w-3xl text-[1rem] text-ink-2 font-light leading-[1.9]">
      <p>
        Phase 1 is methodology sign-off &mdash; complete and currently in independent academic review. Phase 2 is pilot data collection with invited institutions. Phase 3 is the first public HEI report. We will publish phase transitions when they happen, not before.
      </p>
      <p>
        We are inviting feedback on the methodology from university leaders, institutional researchers, education economists, school administrators, government auditors, and peer reviewers with relevant expertise. If you are any of those &mdash; or if you are a student or family member who has been failed by the existing systems and wants the work to land &mdash; write to us.
      </p>
    </div>
    <div class="flex flex-wrap gap-3 mt-10">
      <a href="mailto:hei@edurankai.in?subject=HEI Methodology Feedback" class="btn-primary">Request the methodology document &rarr;</a>
      <a href="/careers" class="btn-ghost">Join the HEI team</a>
    </div>
  </section>

</BaseLayout>