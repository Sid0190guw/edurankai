---
import BaseLayout from '@/layouts/BaseLayout.astro';

const DIMENSIONS = [
  {
    num: '01',
    weight: '30%',
    title: 'Academic Excellence',
    subtitle: 'Learning quality, not brand prestige',
    blurb: 'Whether students are actually learning well. Measured through learning-outcome attainment, teaching quality, formative assessment prevalence, graduate outcomes, and curriculum alignment.',
    metrics: ['Learning outcome attainment rate', 'Teaching quality index', 'Formative assessment prevalence', 'Graduate outcome quality', 'Curriculum alignment score'],
    basis: 'Biggs & Tang (2011); Hattie (2009); Black & Wiliam (1998); OECD AHELO (2013)'
  },
  {
    num: '02',
    weight: '20%',
    title: 'Research & Innovation',
    subtitle: 'Originality, not citation cartels',
    blurb: 'Research that genuinely advances knowledge. Penalises citation gaming and self-citation. Rewards originality, interdisciplinarity, student co-authorship, and open science.',
    metrics: ['Research originality (NLP-scored)', 'Field-normalised citation quality', 'Student co-authorship rate', 'Interdisciplinary reach', 'Open access & reproducibility'],
    basis: 'Uzzi et al. (2013); Waltman et al. (2011); Seymour et al. (2004); Open Science Collaboration'
  },
  {
    num: '03',
    weight: '20%',
    title: 'Student Well-being',
    subtitle: 'The dimension every other ranking ignores',
    blurb: 'Mental health, burnout, belonging, and basic-needs security. Not measured by QS, Times Higher, ARWU, or U-Multirank. We treat its absence as a fundamental ethical failure of the ranking ecosystem.',
    metrics: ['WEMWBS well-being index', 'Burnout prevalence (LMS + survey)', 'Mental health support access rate', 'Sense of belonging index', 'Physical safety and basic needs'],
    basis: 'Tennant et al. (2007); Maslach & Leiter (2016); Walton & Cohen (2011); Goldrick-Rab (2016)'
  },
  {
    num: '04',
    weight: '15%',
    title: 'Ethical & Social Impact',
    subtitle: 'Responsibility beyond the campus walls',
    blurb: 'Equity, environmental sustainability, civic engagement, ethics in curriculum, and governance transparency. Universities are publicly trusted institutions. Their conduct beyond their walls is in scope.',
    metrics: ['Equity & inclusion index', 'Environmental sustainability score', 'Community & civic engagement', 'Ethics in curriculum (NLP audit)', 'Governance transparency'],
    basis: 'AdvanceHE (2022); IPCC (2022); Boyer (1990); UNESCO (2017); OECD (2020)'
  },
  {
    num: '05',
    weight: '15%',
    title: 'Adaptability',
    subtitle: 'An institution that cannot learn is brittle',
    blurb: 'Speed and quality of institutional response to evidence, student feedback, and societal shifts. The dimension most directly under leadership control. Brittle institutions are not excellent institutions.',
    metrics: ['Curriculum revision velocity', 'Student feedback response rate', 'Technology adoption index', 'Policy response speed', 'Continuous improvement culture'],
    basis: 'Bok (2006); Gibbs (2010); EDUCAUSE Horizon Report; Senge (1990)'
  }
];

const COMPARISON = [
  { dim: 'Academic Excellence (learning quality)', qs: 'partial', the: 'partial', arwu: 'missing', um: 'partial', hei: 'full' },
  { dim: 'Research originality (not citation volume)', qs: 'missing', the: 'partial', arwu: 'missing', um: 'partial', hei: 'full' },
  { dim: 'Student Well-being', qs: 'missing', the: 'missing', arwu: 'missing', um: 'missing', hei: 'full' },
  { dim: 'Ethical & Social Impact', qs: 'missing', the: 'partial', arwu: 'missing', um: 'partial', hei: 'full' },
  { dim: 'Adaptability', qs: 'missing', the: 'missing', arwu: 'missing', um: 'missing', hei: 'full' },
  { dim: 'Transparency of scoring logic', qs: 'partial', the: 'partial', arwu: 'missing', um: 'full', hei: 'full' },
  { dim: 'Actionable improvement guidance', qs: 'missing', the: 'missing', arwu: 'missing', um: 'missing', hei: 'full' },
  { dim: 'Private institutional intelligence', qs: 'missing', the: 'missing', arwu: 'missing', um: 'missing', hei: 'full' }
];

const cellMark = (v: string) => v === 'full' ? '✓' : v === 'partial' ? '◑' : '✗';
const cellClass = (v: string) => v === 'full' ? 'text-leaf font-bold' : v === 'partial' ? 'text-gold-deep' : 'text-ink-soft/50';
---
<BaseLayout title="Holistic Education Index (HEI) - EduRankAI" description="A new way to rank universities. The HEI methodology measures learning quality, student well-being, and ethical impact - not citation cartels and brand prestige.">

  <!-- HERO -->
  <section class="px-[5vw] pt-16 md:pt-24 pb-12 max-w-5xl mx-auto">
    <p class="eyebrow mb-6">Holistic Education Index</p>
    <h1 class="font-display text-[clamp(2.5rem,6vw,4.5rem)] font-semibold text-ink leading-[1.05] tracking-tight mb-8 max-w-4xl">
      A new way to rank universities. <em class="italic text-burn font-medium">Built on real research.</em>
    </h1>
    <p class="text-[1.05rem] md:text-[1.15rem] text-ink-soft leading-[1.85] font-light max-w-3xl mb-8">
      The Holistic Education Index is a five-dimension scoring methodology for higher education institutions. It measures what universities should actually optimise for &mdash; learning outcomes, student well-being, ethical impact &mdash; not brand prestige, citation cartels, or reputation surveys that anchor on past rankings.
    </p>
    <div class="inline-flex flex-wrap items-center gap-2 mb-2">
      <span class="text-[0.7rem] font-bold uppercase tracking-wider bg-gold-bg text-gold-deep border border-gold-border px-3 py-1.5 rounded-full">Methodology v1.0</span>
      <span class="text-[0.7rem] font-bold uppercase tracking-wider bg-plum-bg text-plum border border-plum-border px-3 py-1.5 rounded-full">In Academic Advisory Review</span>
    </div>
  </section>

  <!-- WHY THIS EXISTS -->
  <section class="px-[5vw] py-16 md:py-20 max-w-5xl mx-auto border-t border-ink/8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn mb-3 font-bold">Why this exists</p>
    <h2 class="font-display text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold text-ink leading-[1.15] tracking-tight mb-8 max-w-3xl">
      Existing global rankings measure the wrong things.
    </h2>
    <div class="space-y-5 max-w-3xl text-[1rem] text-ink-2 font-light leading-[1.9]">
      <p>
        University rankings exist to help students choose, institutions improve, and policymakers allocate resources. For any of these purposes, rankings should correlate with the actual quality of learning, the well-being of participants, and the long-term benefit to society. Current rankings do not achieve this reliably.
      </p>
      <p>
        QS and Times Higher Education derive 30 to 50 per cent of their scores from reputation surveys &mdash; instruments that measure brand recognition, not learning. ARWU draws 60 per cent or more from raw citation volume, rewarding large research-intensive universities regardless of teaching quality. None of the four major global rankings allocates a single percentage point to student mental health.
      </p>
      <p>
        In 2023, the OECD reported that 47 per cent of university students experienced significant psychological distress. The QS World Rankings allocate 0 per cent to this. An institution with a 40 per cent student burnout rate and a 30 per cent dropout rate due to mental health crises can still rank in the global top 50. We treat this as a fundamental ethical failure of the ranking ecosystem.
      </p>
      <p>
        The HEI was designed to correct this. It is grounded in education research (Biggs &amp; Tang, Hattie, Keyes, OECD AHELO), measures learning outcomes through evidence-based sub-metrics, and weighs student well-being at 20 per cent &mdash; not zero.
      </p>
    </div>
  </section>

  <!-- THE FIVE DIMENSIONS -->
  <section class="px-[5vw] py-16 md:py-20 max-w-5xl mx-auto border-t border-ink/8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn mb-3 font-bold">The five dimensions</p>
    <h2 class="font-display text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold text-ink leading-[1.15] tracking-tight mb-10 max-w-3xl">
      What we actually measure.
    </h2>
    <div class="space-y-6">
      {DIMENSIONS.map((d) => (
        <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8">
          <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8">
            <div class="md:col-span-3">
              <div class="flex items-baseline gap-3 mb-2">
                <p class="font-mono text-[1.5rem] text-burn font-bold">{d.num}</p>
                <span class="text-[0.65rem] font-bold uppercase tracking-wider bg-burn-pale text-burn border border-burn-dim px-2 py-1 rounded-md">Weight {d.weight}</span>
              </div>
              <h3 class="font-display text-[1.4rem] font-semibold text-ink leading-tight mb-1">{d.title}</h3>
              <p class="text-[0.78rem] text-ink-soft italic">{d.subtitle}</p>
            </div>
            <div class="md:col-span-9">
              <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85] mb-4">{d.blurb}</p>
              <p class="text-[0.7rem] font-mono uppercase tracking-[0.15em] text-ink-soft mb-2 font-bold">Sub-metrics</p>
              <ul class="space-y-1.5 mb-4">
                {d.metrics.map((m) => (
                  <li class="text-[0.85rem] text-ink-2 flex gap-2">
                    <span class="text-burn font-bold">&middot;</span>
                    <span>{m}</span>
                  </li>
                ))}
              </ul>
              <p class="text-[0.72rem] text-ink-soft/80 italic"><strong class="text-ink-soft not-italic">Evidence basis:</strong> {d.basis}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- COMPARISON TABLE -->
  <section class="px-[5vw] py-16 md:py-20 max-w-5xl mx-auto border-t border-ink/8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn mb-3 font-bold">The comparison</p>
    <h2 class="font-display text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold text-ink leading-[1.15] tracking-tight mb-3 max-w-3xl">
      What the existing rankings measure &mdash; and don't.
    </h2>
    <p class="text-[0.9rem] text-ink-soft font-light leading-[1.8] mb-8 max-w-3xl">
      <span class="font-bold text-leaf">&#10003;</span> measured &middot; <span class="font-bold text-gold-deep">&#9681;</span> partial or methodologically flawed &middot; <span class="font-bold text-ink-soft">&#10007;</span> not measured
    </p>
    <div class="overflow-x-auto bg-white border border-ink/10 rounded-2xl">
      <table class="w-full text-[0.85rem]">
        <thead>
          <tr class="border-b border-ink/10 bg-cream-2">
            <th class="text-left p-4 font-display font-semibold text-ink">HEI Dimension</th>
            <th class="text-center p-4 font-display font-semibold text-ink">QS</th>
            <th class="text-center p-4 font-display font-semibold text-ink">Times Higher</th>
            <th class="text-center p-4 font-display font-semibold text-ink">ARWU</th>
            <th class="text-center p-4 font-display font-semibold text-ink">U-Multirank</th>
            <th class="text-center p-4 font-display font-semibold text-burn bg-burn-pale">EduRankAI HEI</th>
          </tr>
        </thead>
        <tbody>
          {COMPARISON.map((row, idx) => (
            <tr class={'border-b border-ink/8 ' + (idx % 2 === 0 ? '' : 'bg-cream-2/30')}>
              <td class="p-4 text-ink-2 font-medium">{row.dim}</td>
              <td class={'p-4 text-center text-lg ' + cellClass(row.qs)}>{cellMark(row.qs)}</td>
              <td class={'p-4 text-center text-lg ' + cellClass(row.the)}>{cellMark(row.the)}</td>
              <td class={'p-4 text-center text-lg ' + cellClass(row.arwu)}>{cellMark(row.arwu)}</td>
              <td class={'p-4 text-center text-lg ' + cellClass(row.um)}>{cellMark(row.um)}</td>
              <td class={'p-4 text-center text-lg bg-burn-pale/50 ' + cellClass(row.hei)}>{cellMark(row.hei)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- THE FORMULA -->
  <section class="px-[5vw] py-16 md:py-20 max-w-5xl mx-auto border-t border-ink/8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn mb-3 font-bold">The formula</p>
    <h2 class="font-display text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold text-ink leading-[1.15] tracking-tight mb-8 max-w-3xl">
      Every score is fully decomposable.
    </h2>
    <div class="bg-ink text-cream rounded-2xl p-6 md:p-8 font-mono text-[0.9rem] leading-relaxed mb-8">
      <p class="opacity-60 text-[0.7rem] uppercase tracking-wider mb-3">HEI Score Formula</p>
      <p>HEI =</p>
      <p class="pl-4">(0.30 &times; Academic Excellence)</p>
      <p class="pl-4">+ (0.20 &times; Research &amp; Innovation)</p>
      <p class="pl-4">+ (0.20 &times; Student Well-being)</p>
      <p class="pl-4">+ (0.15 &times; Ethical / Social Impact)</p>
      <p class="pl-4">+ (0.15 &times; Adaptability)</p>
    </div>
    <div class="space-y-5 max-w-3xl text-[0.95rem] text-ink-2 font-light leading-[1.9]">
      <p>
        The result is a value between 0 and 100. The sector average in our pilot cohort is approximately 62 to 68. No institution is expected to score 100 &mdash; the ideal standards are aspirational, set by research, not by the top performer in a given year.
      </p>
      <p>
        Every HEI score presented to an institution is fully decomposed. The institution can see exactly which sub-metric drove any change in any dimension. There is no aggregation step that is opaque. This is a fundamental design requirement &mdash; without it, institutions cannot act on their scores.
      </p>
      <p>
        Smaller and less-resourced institutions face structural disadvantages on several sub-metrics (open access publishing costs, sustainability infrastructure). The HEI offers a resource-adjusted scoring track for Tier 2 and Tier 3 institutions, applying peer-group normalisation within institution size and budget bands. This prevents the HEI from simply replicating the prestige hierarchy under a new name.
      </p>
    </div>
  </section>

  <!-- WHERE WE ARE -->
  <section class="px-[5vw] py-16 md:py-20 max-w-5xl mx-auto border-t border-ink/8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn mb-3 font-bold">Status</p>
    <h2 class="font-display text-[clamp(1.75rem,3.5vw,2.5rem)] font-semibold text-ink leading-[1.15] tracking-tight mb-6 max-w-3xl">
      Currently in academic advisory review.
    </h2>
    <div class="space-y-5 max-w-3xl text-[1rem] text-ink-2 font-light leading-[1.9]">
      <p>
        The HEI methodology v1.0 is complete and currently under review by an independent academic advisory board. We are not yet ranking institutions publicly. We are not yet accepting institutional data submissions.
      </p>
      <p>
        Phase 1 is methodology sign-off. Phase 2 is pilot data collection with invited institutions. Phase 3 is the first public HEI report. We will publish phase transitions when they happen, not before.
      </p>
      <p>
        If you are a university leader, institutional researcher, education economist, or peer reviewer with relevant expertise &mdash; we are inviting feedback on the methodology document. Write to us.
      </p>
    </div>
    <div class="flex flex-wrap gap-3 mt-10">
      <a href="mailto:hei@edurankai.in?subject=HEI Methodology Feedback" class="btn-primary">Request methodology document &rarr;</a>
      <a href="/careers" class="btn-ghost">Join the HEI team</a>
    </div>
  </section>

</BaseLayout>