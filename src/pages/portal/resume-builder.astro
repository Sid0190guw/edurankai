---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/resume-builder'));

await db.execute(sql`CREATE TABLE IF NOT EXISTS user_resumes (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id UUID UNIQUE,
  template VARCHAR(40) DEFAULT 'classic',
  headline TEXT, summary TEXT, contact_info JSONB DEFAULT '{}'::jsonb,
  education JSONB DEFAULT '[]'::jsonb,
  experience JSONB DEFAULT '[]'::jsonb,
  projects JSONB DEFAULT '[]'::jsonb,
  skills JSONB DEFAULT '[]'::jsonb,
  certifications JSONB DEFAULT '[]'::jsonb,
  publications JSONB DEFAULT '[]'::jsonb,
  awards JSONB DEFAULT '[]'::jsonb,
  languages JSONB DEFAULT '[]'::jsonb,
  pdf_url TEXT,
  updated_at TIMESTAMPTZ DEFAULT NOW()
)`);

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

// Auto-save POST
let savedAt: string | null = null;
if (Astro.request.method === 'POST') {
  try {
    const body = await Astro.request.json();
    const existing = rows(await db.execute(sql`SELECT id FROM user_resumes WHERE user_id = ${user.id} LIMIT 1`));
    const contactJson = JSON.stringify(body.contact_info || {});
    const eduJson = JSON.stringify(body.education || []);
    const expJson = JSON.stringify(body.experience || []);
    const projJson = JSON.stringify(body.projects || []);
    const skillsJson = JSON.stringify(body.skills || []);
    const certsJson = JSON.stringify(body.certifications || []);
    const pubsJson = JSON.stringify(body.publications || []);
    const awardsJson = JSON.stringify(body.awards || []);
    const langsJson = JSON.stringify(body.languages || []);
    if (existing[0]) {
      await db.execute(sql`UPDATE user_resumes SET template=${body.template || 'classic'}, headline=${body.headline || ''}, summary=${body.summary || ''},
        contact_info=${contactJson}::jsonb, education=${eduJson}::jsonb, experience=${expJson}::jsonb, projects=${projJson}::jsonb,
        skills=${skillsJson}::jsonb, certifications=${certsJson}::jsonb, publications=${pubsJson}::jsonb,
        awards=${awardsJson}::jsonb, languages=${langsJson}::jsonb, updated_at=NOW() WHERE user_id=${user.id}`);
    } else {
      await db.execute(sql`INSERT INTO user_resumes (user_id, template, headline, summary, contact_info, education, experience, projects, skills, certifications, publications, awards, languages)
        VALUES (${user.id}, ${body.template || 'classic'}, ${body.headline || ''}, ${body.summary || ''},
        ${contactJson}::jsonb, ${eduJson}::jsonb, ${expJson}::jsonb, ${projJson}::jsonb,
        ${skillsJson}::jsonb, ${certsJson}::jsonb, ${pubsJson}::jsonb, ${awardsJson}::jsonb, ${langsJson}::jsonb)`);
    }
    return new Response(JSON.stringify({ ok: true, savedAt: new Date().toISOString() }), { status: 200, headers: { 'content-type': 'application/json' } });
  } catch (e: any) {
    return new Response(JSON.stringify({ ok: false, error: String(e?.message || e).slice(0, 240) }), { status: 500, headers: { 'content-type': 'application/json' } });
  }
}

const existing = rows(await db.execute(sql`SELECT * FROM user_resumes WHERE user_id = ${user.id} LIMIT 1`))[0] || {};
const initial = {
  template: existing.template || 'classic',
  headline: existing.headline || '',
  summary: existing.summary || '',
  contact_info: existing.contact_info || { email: user.email || '', phone: '', location: '', website: '', linkedin: '', github: '' },
  education: existing.education || [],
  experience: existing.experience || [],
  projects: existing.projects || [],
  skills: existing.skills || [],
  certifications: existing.certifications || [],
  publications: existing.publications || [],
  awards: existing.awards || [],
  languages: existing.languages || [],
};
---
<BaseLayout title="Resume builder · EduRankAI" description="Build a polished resume with live A4 preview. Multiple templates. Auto-save. Print to PDF.">

<style>
  body { background: #FAF8F5; color: #0E0B08; }
  .rb-wrap { max-width: 1400px; margin: 0 auto; padding: 14px 16px 60px; }
  .rb-top { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 12px; margin-bottom: 16px; }
  .rb-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; }
  .rb-title { font-family: 'Cormorant Garamond', serif; font-size: 32px; font-weight: 600; margin: 4px 0 0; letter-spacing: -0.02em; }
  .rb-title em { color: #FF4F00; font-style: italic; font-weight: 500; }
  .rb-actions { display: flex; gap: 6px; flex-wrap: wrap; }
  .rb-btn { background: #FF4F00; color: #fff; padding: 9px 18px; border-radius: 8px; border: none; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700; }
  .rb-btn-ghost { background: transparent; color: #0E0B08; border: 1px solid rgba(14,11,8,0.15); }
  .rb-saved { font-family: 'Geist Mono', monospace; font-size: 11px; color: #1A6B35; padding: 8px 14px; }

  .rb-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  @media (max-width: 1000px) { .rb-grid { grid-template-columns: 1fr; } }

  .rb-editor { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 16px; max-height: calc(100vh - 160px); overflow-y: auto; }
  .rb-section { border-bottom: 1px solid rgba(14,11,8,0.08); padding: 12px 0; }
  .rb-section:last-child { border-bottom: none; }
  .rb-section-head { display: flex; justify-content: space-between; align-items: center; cursor: pointer; padding: 4px 0; }
  .rb-section-head h3 { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin: 0; }
  .rb-section-body { padding: 8px 0 0; }
  .rb-section-body.collapsed { display: none; }
  .rb-field { margin-bottom: 10px; }
  .rb-field label { font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; color: #7A6F68; font-weight: 700; margin-bottom: 4px; display: block; }
  .rb-field input, .rb-field textarea, .rb-field select { width: 100%; box-sizing: border-box; background: #FAF8F5; border: 1px solid rgba(14,11,8,0.15); padding: 8px 12px; border-radius: 6px; font-family: inherit; font-size: 13px; color: #0E0B08; }
  .rb-field textarea { resize: vertical; min-height: 60px; font-family: inherit; }
  .rb-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .rb-item { background: #FAF8F5; border: 1px solid rgba(14,11,8,0.08); border-radius: 8px; padding: 10px; margin-bottom: 8px; }
  .rb-item-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
  .rb-item-del { background: transparent; border: none; color: #b91c1c; cursor: pointer; font-size: 14px; }
  .rb-add { background: #FFF3EE; color: #FF4F00; border: 1px dashed #FFD4BC; padding: 8px 14px; border-radius: 8px; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 700; width: 100%; }

  .rb-preview-wrap { position: sticky; top: 14px; max-height: calc(100vh - 100px); overflow-y: auto; }
  .rb-preview { background: #fff; aspect-ratio: 210/297; box-shadow: 0 10px 30px rgba(14,11,8,0.10); padding: 40px 50px; font-family: 'Inter Tight', sans-serif; font-size: 11px; line-height: 1.45; color: #0E0B08; }
  .rb-preview.classic { font-family: 'Cormorant Garamond', serif; font-size: 11px; }
  .rb-preview.modern { font-family: 'Inter Tight', sans-serif; }
  .rb-preview.minimal { font-family: ui-monospace, monospace; font-size: 10.5px; }
  .rb-prev-header { border-bottom: 2px solid #0E0B08; padding-bottom: 12px; margin-bottom: 12px; }
  .rb-prev-name { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 600; letter-spacing: -0.02em; margin: 0; line-height: 1; }
  .rb-prev-headline { font-size: 12px; color: #7A6F68; margin: 4px 0 6px; }
  .rb-prev-contact { font-size: 10.5px; color: #2E2520; display: flex; gap: 12px; flex-wrap: wrap; }
  .rb-prev-section { margin-top: 12px; }
  .rb-prev-h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin: 0 0 6px; border-bottom: 1px solid rgba(14,11,8,0.10); padding-bottom: 3px; }
  .rb-prev.modern .rb-prev-h3 { color: #1045BB; }
  .rb-prev.minimal .rb-prev-h3 { color: #0E0B08; }
  .rb-prev-entry { margin-bottom: 8px; }
  .rb-prev-entry-top { display: flex; justify-content: space-between; gap: 6px; }
  .rb-prev-entry-title { font-weight: 700; font-size: 11.5px; }
  .rb-prev-entry-date { font-size: 10px; color: #7A6F68; font-family: 'Geist Mono', monospace; }
  .rb-prev-entry-sub { font-size: 10.5px; color: #2E2520; font-style: italic; }
  .rb-prev-entry-body { font-size: 10.5px; color: #2E2520; margin-top: 3px; white-space: pre-wrap; }
  .rb-chips { display: flex; gap: 4px; flex-wrap: wrap; }
  .rb-chip { background: #FFF3EE; color: #FF4F00; padding: 2px 8px; border-radius: 100px; font-size: 10px; font-family: 'Geist Mono', monospace; }

  @media print {
    body * { visibility: hidden; }
    .rb-preview, .rb-preview * { visibility: visible; }
    .rb-preview { position: absolute; left: 0; top: 0; width: 210mm; min-height: 297mm; aspect-ratio: auto; box-shadow: none; padding: 18mm 20mm; }
  }
</style>

<main class="rb-wrap">
  <div class="rb-top">
    <div>
      <a href="/portal" style="font-family:'Geist Mono',monospace;font-size:11px;color:#FF4F00;text-decoration:none;letter-spacing:0.08em;">&larr; Portal</a>
      <p class="rb-eye" style="margin-top:10px;">Portal &middot; Resume builder</p>
      <h1 class="rb-title">A polished <em>resume</em>.</h1>
    </div>
    <div class="rb-actions">
      <select id="template" class="rb-btn rb-btn-ghost" style="padding:6px 12px;text-transform:none;">
        <option value="classic">Classic · serif</option>
        <option value="modern">Modern · sans</option>
        <option value="minimal">Minimal · mono</option>
      </select>
      <span id="savedAt" class="rb-saved"></span>
      <button id="exportBtn" class="rb-btn">Export PDF</button>
    </div>
  </div>

  <div class="rb-grid">

    <div class="rb-editor" id="editor">
      <div class="rb-section">
        <div class="rb-section-head"><h3>Header</h3></div>
        <div class="rb-section-body">
          <div class="rb-field"><label>Headline / role</label><input id="headline" type="text" placeholder="Senior software engineer"/></div>
          <div class="rb-row">
            <div class="rb-field"><label>Email</label><input id="c_email" type="email"/></div>
            <div class="rb-field"><label>Phone</label><input id="c_phone" type="tel"/></div>
          </div>
          <div class="rb-row">
            <div class="rb-field"><label>Location</label><input id="c_location" type="text" placeholder="City, Country"/></div>
            <div class="rb-field"><label>Website</label><input id="c_website" type="url"/></div>
          </div>
          <div class="rb-row">
            <div class="rb-field"><label>LinkedIn</label><input id="c_linkedin" type="url"/></div>
            <div class="rb-field"><label>GitHub</label><input id="c_github" type="url"/></div>
          </div>
        </div>
      </div>

      <div class="rb-section">
        <div class="rb-section-head"><h3>Summary</h3></div>
        <div class="rb-section-body">
          <div class="rb-field"><textarea id="summary" rows="3" placeholder="One paragraph describing what you do, who for, and why it matters."></textarea></div>
        </div>
      </div>

      <div class="rb-section" data-list="education">
        <div class="rb-section-head"><h3>Education</h3></div>
        <div class="rb-section-body">
          <div class="rb-items" id="education-items"></div>
          <button class="rb-add" data-add="education">+ Add education</button>
        </div>
      </div>

      <div class="rb-section" data-list="experience">
        <div class="rb-section-head"><h3>Experience</h3></div>
        <div class="rb-section-body">
          <div class="rb-items" id="experience-items"></div>
          <button class="rb-add" data-add="experience">+ Add experience</button>
        </div>
      </div>

      <div class="rb-section" data-list="projects">
        <div class="rb-section-head"><h3>Projects</h3></div>
        <div class="rb-section-body">
          <div class="rb-items" id="projects-items"></div>
          <button class="rb-add" data-add="projects">+ Add project</button>
        </div>
      </div>

      <div class="rb-section">
        <div class="rb-section-head"><h3>Skills</h3></div>
        <div class="rb-section-body">
          <div class="rb-field"><textarea id="skills_text" rows="3" placeholder="One skill per line, or comma-separated"></textarea></div>
        </div>
      </div>

      <div class="rb-section" data-list="certifications">
        <div class="rb-section-head"><h3>Certifications</h3></div>
        <div class="rb-section-body">
          <div class="rb-items" id="certifications-items"></div>
          <button class="rb-add" data-add="certifications">+ Add certification</button>
        </div>
      </div>

      <div class="rb-section" data-list="awards">
        <div class="rb-section-head"><h3>Awards</h3></div>
        <div class="rb-section-body">
          <div class="rb-items" id="awards-items"></div>
          <button class="rb-add" data-add="awards">+ Add award</button>
        </div>
      </div>

      <div class="rb-section">
        <div class="rb-section-head"><h3>Languages</h3></div>
        <div class="rb-section-body">
          <div class="rb-field"><textarea id="languages_text" rows="2" placeholder="English (fluent), Hindi (native), Sanskrit (intermediate)"></textarea></div>
        </div>
      </div>
    </div>

    <div class="rb-preview-wrap">
      <div id="preview" class="rb-preview classic"></div>
    </div>
  </div>
</main>

<script is:inline define:vars={{ initial }}>
  (function () {
    var state = JSON.parse(JSON.stringify(initial));

    function $(id) { return document.getElementById(id); }
    function esc(s) { return (s || '').toString().replace(/[<>&]/g, function (c) { return { '<':'&lt;','>':'&gt;','&':'&amp;' }[c]; }); }

    // Populate initial values
    $('headline').value = state.headline || '';
    $('summary').value = state.summary || '';
    $('c_email').value = state.contact_info?.email || '';
    $('c_phone').value = state.contact_info?.phone || '';
    $('c_location').value = state.contact_info?.location || '';
    $('c_website').value = state.contact_info?.website || '';
    $('c_linkedin').value = state.contact_info?.linkedin || '';
    $('c_github').value = state.contact_info?.github || '';
    $('template').value = state.template || 'classic';
    $('skills_text').value = (state.skills || []).join('\n');
    $('languages_text').value = (state.languages || []).join(', ');

    // List items
    function renderList(key) {
      var root = $(key + '-items');
      root.innerHTML = '';
      (state[key] || []).forEach(function (item, i) {
        var el = document.createElement('div');
        el.className = 'rb-item';
        var fieldsHtml = '';
        if (key === 'education') {
          fieldsHtml = '<div class="rb-row"><input data-k="institution" placeholder="Institution" value="' + esc(item.institution) + '"/><input data-k="degree" placeholder="Degree" value="' + esc(item.degree) + '"/></div>'
            + '<div class="rb-row"><input data-k="start" placeholder="Start (e.g. 2020)" value="' + esc(item.start) + '"/><input data-k="end" placeholder="End (e.g. 2024)" value="' + esc(item.end) + '"/></div>'
            + '<textarea data-k="detail" rows="2" placeholder="Highlights, GPA, awards">' + esc(item.detail) + '</textarea>';
        } else if (key === 'experience') {
          fieldsHtml = '<div class="rb-row"><input data-k="company" placeholder="Company" value="' + esc(item.company) + '"/><input data-k="role" placeholder="Role" value="' + esc(item.role) + '"/></div>'
            + '<div class="rb-row"><input data-k="start" placeholder="Start" value="' + esc(item.start) + '"/><input data-k="end" placeholder="End" value="' + esc(item.end) + '"/></div>'
            + '<textarea data-k="detail" rows="3" placeholder="What you did + impact (use bullets)">' + esc(item.detail) + '</textarea>';
        } else if (key === 'projects') {
          fieldsHtml = '<input data-k="name" placeholder="Project name" value="' + esc(item.name) + '"/>'
            + '<input data-k="tech" placeholder="Tech stack" value="' + esc(item.tech) + '"/>'
            + '<input data-k="url" placeholder="URL (optional)" value="' + esc(item.url) + '"/>'
            + '<textarea data-k="detail" rows="2" placeholder="One-line description + impact">' + esc(item.detail) + '</textarea>';
        } else if (key === 'certifications') {
          fieldsHtml = '<input data-k="name" placeholder="Certification" value="' + esc(item.name) + '"/>'
            + '<div class="rb-row"><input data-k="issuer" placeholder="Issuer" value="' + esc(item.issuer) + '"/><input data-k="date" placeholder="Date" value="' + esc(item.date) + '"/></div>';
        } else if (key === 'awards') {
          fieldsHtml = '<input data-k="title" placeholder="Award" value="' + esc(item.title) + '"/>'
            + '<div class="rb-row"><input data-k="issuer" placeholder="Issuer" value="' + esc(item.issuer) + '"/><input data-k="date" placeholder="Date" value="' + esc(item.date) + '"/></div>';
        }
        el.innerHTML = '<div class="rb-item-top"><span style="font-family:Geist Mono;font-size:10px;color:#7A6F68;letter-spacing:0.1em;text-transform:uppercase;">#' + (i+1) + '</span><button class="rb-item-del" data-i="' + i + '">&times;</button></div>' + fieldsHtml;
        el.querySelector('.rb-item-del').addEventListener('click', function () { state[key].splice(i, 1); renderList(key); save(); render(); });
        el.querySelectorAll('[data-k]').forEach(function (inp) {
          inp.addEventListener('input', function () {
            state[key][i] = state[key][i] || {};
            state[key][i][inp.getAttribute('data-k')] = inp.value;
            save(); render();
          });
        });
        root.appendChild(el);
      });
    }

    function blankItem(key) {
      if (key === 'education') return { institution: '', degree: '', start: '', end: '', detail: '' };
      if (key === 'experience') return { company: '', role: '', start: '', end: '', detail: '' };
      if (key === 'projects') return { name: '', tech: '', url: '', detail: '' };
      if (key === 'certifications') return { name: '', issuer: '', date: '' };
      if (key === 'awards') return { title: '', issuer: '', date: '' };
      return {};
    }
    document.querySelectorAll('[data-add]').forEach(function (b) {
      b.addEventListener('click', function () {
        var key = b.getAttribute('data-add');
        state[key] = state[key] || [];
        state[key].push(blankItem(key));
        renderList(key);
        save(); render();
      });
    });

    function render() {
      var p = $('preview');
      p.className = 'rb-preview ' + state.template;
      var name = '' + (window.userName || 'Your Name');
      var ci = state.contact_info || {};
      var contact = [ci.email, ci.phone, ci.location, ci.website, ci.linkedin, ci.github].filter(Boolean).map(esc).join(' &middot; ');
      var html = '<div class="rb-prev-header"><h1 class="rb-prev-name">' + esc(name) + '</h1>';
      if (state.headline) html += '<p class="rb-prev-headline">' + esc(state.headline) + '</p>';
      if (contact) html += '<p class="rb-prev-contact">' + contact + '</p>';
      html += '</div>';

      if (state.summary) html += '<div class="rb-prev-section"><h3 class="rb-prev-h3">Summary</h3><p class="rb-prev-entry-body">' + esc(state.summary) + '</p></div>';

      function renderEntries(key, label, fmtFn) {
        var arr = state[key] || [];
        if (arr.length === 0) return '';
        var inner = arr.map(fmtFn).join('');
        return '<div class="rb-prev-section"><h3 class="rb-prev-h3">' + label + '</h3>' + inner + '</div>';
      }

      html += renderEntries('experience', 'Experience', function (e) {
        return '<div class="rb-prev-entry"><div class="rb-prev-entry-top"><span class="rb-prev-entry-title">' + esc(e.role) + ' &middot; ' + esc(e.company) + '</span><span class="rb-prev-entry-date">' + esc(e.start) + ' &mdash; ' + esc(e.end || 'Present') + '</span></div>' + (e.detail ? '<div class="rb-prev-entry-body">' + esc(e.detail) + '</div>' : '') + '</div>';
      });
      html += renderEntries('education', 'Education', function (e) {
        return '<div class="rb-prev-entry"><div class="rb-prev-entry-top"><span class="rb-prev-entry-title">' + esc(e.degree) + ' &middot; ' + esc(e.institution) + '</span><span class="rb-prev-entry-date">' + esc(e.start) + ' &mdash; ' + esc(e.end || '') + '</span></div>' + (e.detail ? '<div class="rb-prev-entry-body">' + esc(e.detail) + '</div>' : '') + '</div>';
      });
      html += renderEntries('projects', 'Projects', function (e) {
        return '<div class="rb-prev-entry"><div class="rb-prev-entry-top"><span class="rb-prev-entry-title">' + esc(e.name) + (e.url ? ' &middot; <span class="rb-prev-entry-sub">' + esc(e.url) + '</span>' : '') + '</span></div>' + (e.tech ? '<div class="rb-prev-entry-sub">' + esc(e.tech) + '</div>' : '') + (e.detail ? '<div class="rb-prev-entry-body">' + esc(e.detail) + '</div>' : '') + '</div>';
      });

      var skills = (state.skills || []).filter(Boolean);
      if (skills.length) {
        html += '<div class="rb-prev-section"><h3 class="rb-prev-h3">Skills</h3><div class="rb-chips">';
        skills.forEach(function (s) { html += '<span class="rb-chip">' + esc(s) + '</span>'; });
        html += '</div></div>';
      }

      html += renderEntries('certifications', 'Certifications', function (e) {
        return '<div class="rb-prev-entry"><div class="rb-prev-entry-top"><span class="rb-prev-entry-title">' + esc(e.name) + '</span><span class="rb-prev-entry-date">' + esc(e.date) + '</span></div>' + (e.issuer ? '<div class="rb-prev-entry-sub">' + esc(e.issuer) + '</div>' : '') + '</div>';
      });
      html += renderEntries('awards', 'Awards', function (e) {
        return '<div class="rb-prev-entry"><div class="rb-prev-entry-top"><span class="rb-prev-entry-title">' + esc(e.title) + '</span><span class="rb-prev-entry-date">' + esc(e.date) + '</span></div>' + (e.issuer ? '<div class="rb-prev-entry-sub">' + esc(e.issuer) + '</div>' : '') + '</div>';
      });

      var langs = (state.languages || []).filter(Boolean);
      if (langs.length) {
        html += '<div class="rb-prev-section"><h3 class="rb-prev-h3">Languages</h3><p class="rb-prev-entry-body">' + langs.map(esc).join(', ') + '</p></div>';
      }
      p.innerHTML = html;
    }

    var saveTimer = null;
    function save() {
      clearTimeout(saveTimer);
      saveTimer = setTimeout(function () {
        // Capture text-area lists
        state.skills = $('skills_text').value.split(/[,\n]/).map(function (s) { return s.trim(); }).filter(Boolean);
        state.languages = $('languages_text').value.split(/[,]/).map(function (s) { return s.trim(); }).filter(Boolean);
        state.headline = $('headline').value;
        state.summary = $('summary').value;
        state.template = $('template').value;
        state.contact_info = {
          email: $('c_email').value, phone: $('c_phone').value, location: $('c_location').value,
          website: $('c_website').value, linkedin: $('c_linkedin').value, github: $('c_github').value,
        };
        fetch(window.location.pathname, { method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin', body: JSON.stringify(state) })
          .then(function (r) { return r.json(); })
          .then(function (d) {
            if (d.ok) $('savedAt').textContent = '✓ Saved ' + new Date().toLocaleTimeString();
          }).catch(function () {});
        render();
      }, 800);
    }

    // Wire text inputs
    ['headline','summary','c_email','c_phone','c_location','c_website','c_linkedin','c_github','skills_text','languages_text','template'].forEach(function (id) {
      $(id).addEventListener('input', save);
      $(id).addEventListener('change', save);
    });

    $('exportBtn').addEventListener('click', function () { window.print(); });

    ['education','experience','projects','certifications','awards'].forEach(renderList);
    render();
  })();
</script>

<script is:inline define:vars={{ userName: user.name || user.email || 'You' }}>
  window.userName = userName;
</script>
</BaseLayout>
