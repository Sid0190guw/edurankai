/* ==========================================================================
   REACTIONS
   ========================================================================== */
function flyReaction(kind) {
  const layer = $('#reactionsLayer');
  const div = document.createElement('div');
  div.className = 'mt-rx';
  const svgs = {
    thumb: '<svg viewBox="0 0 24 24" fill="currentColor" style="color:#fbbf24"><path d="M7 22V11h5.13L10 4.5C9.7 3.5 10.5 2 12 2c.6 0 1.1.4 1.3 1l1.7 5H22v4.5l-3 7.5H7z"/></svg>',
    heart: '<svg viewBox="0 0 24 24" fill="currentColor" style="color:#f87171"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>',
    clap: '<svg viewBox="0 0 24 24" fill="currentColor" style="color:#fbbf24"><path d="M14 11l-3 9-2-1 2-7H7l4-9 2 1-2 7h6z"/></svg>',
    laugh: '<svg viewBox="0 0 24 24" fill="currentColor" style="color:#67e8f9"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2" stroke="#0a0a0c" stroke-width="2" fill="none"/></svg>',
    surprise: '<svg viewBox="0 0 24 24" fill="currentColor" style="color:#a78bfa"><circle cx="12" cy="12" r="10"/></svg>',
    fire: '<svg viewBox="0 0 24 24" fill="currentColor" style="color:#FF4F00"><path d="M12 2c2 4-4 6 0 14-6-2-8-7-6-12 1 2 3 3 5 4-1-3 1-4 1-6z"/></svg>',
  };
  div.innerHTML = svgs[kind] || svgs.thumb;
  div.style.left = (10 + Math.random() * 80) + '%';
  layer.appendChild(div);
  setTimeout(() => div.remove(), 3600);

  // Broadcast over data channel
  if (state.dc && state.dc.readyState === 'open') {
    try { state.dc.send(JSON.stringify({ type: 'reaction', kind })); } catch {}
  }
}

