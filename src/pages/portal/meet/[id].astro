/* ==========================================================================
   CHAT
   ========================================================================== */
function appendChatMsg(c) {
  const list = $('#chatList');
  const empty = list.querySelector('.mt-empty');
  if (empty) empty.remove();
  const div = document.createElement('div');
  div.className = 'mt-chat-msg';
  div.innerHTML = `
    <div class="mt-chat-from">
      <span>${escapeHtml(c.display_name || 'Unknown')}</span>
      ${c.is_private_to ? '<span class="priv">PRIVATE</span>' : ''}
    </div>
    <div class="mt-chat-body">${escapeHtml(c.body)}</div>
  `;
  list.appendChild(div);
  list.parentElement.scrollTop = list.parentElement.scrollHeight;
}

async function sendChat() {
  const ta = $('#chatInput');
  const body = ta.value.trim();
  if (!body) return;
  const privTo = $('#chatTo').value;
  appendChatMsg({ display_name: myDisplayName, body, is_private_to: privTo || null });
  ta.value = '';

  // Broadcast to peer via data channel
  if (state.dc && state.dc.readyState === 'open' && !privTo) {
    try { state.dc.send(JSON.stringify({ type: 'chat', from: myDisplayName, body })); } catch {}
  }

  // Persist
  const fd = new FormData();
  fd.append('action', 'chat');
  fd.append('body', body);
  if (privTo) fd.append('is_private_to', privTo);
  try { await fetch(location.pathname, { method: 'POST', body: fd }); } catch {}
}

/* ==========================================================================
   POLLS
   ========================================================================== */
let pollOpts = ['', ''];
function renderPollOpts() {
  $('#pollOpts').innerHTML = pollOpts.map((v, i) => `
    <div class="mt-modal-row">
      <input type="text" data-poll-opt="${i}" value="${escapeHtml(v)}" placeholder="Option ${i+1}"/>
      <button data-rm-opt="${i}">x</button>
    </div>
  `).join('');
  $$('#pollOpts input').forEach(inp => {
    inp.addEventListener('input', (e) => { pollOpts[+e.target.dataset.pollOpt] = e.target.value; });
  });
  $$('#pollOpts button').forEach(btn => {
    btn.addEventListener('click', () => {
      const i = +btn.dataset.rmOpt;
      pollOpts.splice(i, 1); renderPollOpts();
    });
  });
}

async function submitPoll() {
  const q = $('#pollQ').value.trim();
  const opts = pollOpts.map(o => o.trim()).filter(Boolean);
  if (!q || opts.length < 2) { toast('Need a question and 2+ options'); return; }
  const fd = new FormData();
  fd.append('action', 'create_poll');
  fd.append('question', q);
  fd.append('options', JSON.stringify(opts));
  await fetch(location.pathname, { method: 'POST', body: fd });
  closeModal('pollModal');
  toast('Poll launched');
  setTimeout(() => location.reload(), 500);
}

async function votePoll(pollId, choice) {
  const fd = new FormData();
  fd.append('action', 'vote');
  fd.append('poll_id', pollId);
  fd.append('choice', choice);
  await fetch(location.pathname, { method: 'POST', body: fd });
  toast('Vote recorded');
}

/* ==========================================================================
   BREAKOUTS
   ========================================================================== */
async function submitBreakouts() {
  const count = Math.max(1, Math.min(20, parseInt($('#boCount').value, 10) || 3));
  const mins = Math.max(1, Math.min(120, parseInt($('#boMins').value, 10) || 15));
  const prefix = ($('#boPrefix').value || 'Group').trim().slice(0, 60);
  // Round-robin split of non-host participants
  const pool = state.participants.filter(p => p.id !== userId).map(p => p.name);
  for (let i = 0; i < count; i++) {
    const members = pool.filter((_, idx) => idx % count === i);
    const fd = new FormData();
    fd.append('action', 'create_breakout');
    fd.append('label', `${prefix} ${i+1}`);
    fd.append('participants', JSON.stringify(members));
    fd.append('minutes', String(mins));
    await fetch(location.pathname, { method: 'POST', body: fd });
  }
  closeModal('boModal');
  toast(`Opened ${count} breakouts`);
  setTimeout(() => location.reload(), 500);
}

/* ==========================================================================
   WHITEBOARD
   ========================================================================== */
const wb = { tool: 'pen', color: '#0a0a0c', size: 2, last: null, strokes: [] };

function setupWhiteboard() {
  const cv = $('#wbCanvas');
  const ctx = cv.getContext('2d');
  ctx.fillStyle = '#fafafa'; ctx.fillRect(0, 0, cv.width, cv.height);
  ctx.lineCap = 'round'; ctx.lineJoin = 'round';

  function pos(e) {
    const r = cv.getBoundingClientRect();
    const t = e.touches ? e.touches[0] : e;
    return { x: (t.clientX - r.left) * (cv.width / r.width), y: (t.clientY - r.top) * (cv.height / r.height) };
  }

  function draw(p) {
    if (wb.tool === 'pen' || wb.tool === 'eraser') {
      ctx.strokeStyle = wb.tool === 'eraser' ? '#fafafa' : wb.color;
      ctx.lineWidth = wb.tool === 'eraser' ? 14 : wb.size;
      ctx.beginPath();
      if (wb.last) ctx.moveTo(wb.last.x, wb.last.y); else ctx.moveTo(p.x, p.y);
      ctx.lineTo(p.x, p.y);
      ctx.stroke();
      // broadcast
      if (state.dc && state.dc.readyState === 'open' && wb.last) {
        try { state.dc.send(JSON.stringify({ type: 'stroke', tool: wb.tool, color: wb.color, size: wb.size, x1: wb.last.x, y1: wb.last.y, x2: p.x, y2: p.y })); } catch {}
      }
      wb.last = p;
    }
  }

  let drawing = false;
  cv.addEventListener('pointerdown', (e) => {
    if (wb.tool === 'text') {
      const text = prompt('Text:');
      if (text) {
        const p = pos(e);
        ctx.fillStyle = wb.color;
        ctx.font = '16px DM Sans';
        ctx.fillText(text, p.x, p.y);
      }
      return;
    }
    if (wb.tool === 'clear') { ctx.fillStyle='#fafafa'; ctx.fillRect(0,0,cv.width,cv.height); return; }
    if (wb.tool === 'png') {
      const a = document.createElement('a');
      a.href = cv.toDataURL('image/png'); a.download = 'whiteboard.png'; a.click();
      return;
    }
    drawing = true; wb.last = pos(e); draw(pos(e));
  });
  cv.addEventListener('pointermove', (e) => { if (drawing) draw(pos(e)); });
  cv.addEventListener('pointerup', () => { drawing = false; wb.last = null; });
  cv.addEventListener('pointerleave', () => { drawing = false; wb.last = null; });

  // Tools
  $$('[data-wb-tool]').forEach(btn => {
    btn.addEventListener('click', () => {
      wb.tool = btn.dataset.wbTool;
      $$('[data-wb-tool]').forEach(b => b.classList.toggle('active', b === btn));
      if (wb.tool === 'clear') { ctx.fillStyle='#fafafa'; ctx.fillRect(0,0,cv.width,cv.height); }
      if (wb.tool === 'png') {
        const a = document.createElement('a');
        a.href = cv.toDataURL('image/png'); a.download = 'whiteboard.png'; a.click();
      }
    });
  });

  // Colors
  $$('[data-wb-color]').forEach(c => {
    c.addEventListener('click', () => {
      wb.color = c.dataset.wbColor;
      $$('[data-wb-color]').forEach(x => x.classList.toggle('active', x === c));
    });
  });
}

function drawRemoteStroke(s) {
  const cv = $('#wbCanvas'); if (!cv) return;
  const ctx = cv.getContext('2d');
  ctx.strokeStyle = s.tool === 'eraser' ? '#fafafa' : (s.color || '#0a0a0c');
  ctx.lineWidth = s.tool === 'eraser' ? 14 : (s.size || 2);
  ctx.beginPath();
  ctx.moveTo(s.x1, s.y1); ctx.lineTo(s.x2, s.y2);
  ctx.stroke();
}

/* ==========================================================================
   APPS — notes, timer, music
   ========================================================================== */
function setupNotes() {
  const ta = $('#notesArea');
  const saved = localStorage.getItem('meet-notes-' + roomId);
  if (saved) ta.value = saved;
  ta.addEventListener('input', () => localStorage.setItem('meet-notes-' + roomId, ta.value));
}

function setupTimer() {
  const display = $('#timerDisplay');
  function render() {
    const m = Math.floor(state.timerSeconds / 60);
    const s = state.timerSeconds % 60;
    display.textContent = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
  }
  render();
  $('#timerSet').addEventListener('click', () => {
    const mins = parseInt($('#timerMins').value, 10) || 5;
    state.timerSeconds = mins * 60; render();
  });
  $('#timerStart').addEventListener('click', () => {
    if (state.timerInterval) clearInterval(state.timerInterval);
    state.timerRunning = true;
    state.timerInterval = setInterval(() => {
      if (state.timerSeconds > 0) { state.timerSeconds--; render(); }
      else { clearInterval(state.timerInterval); state.timerRunning = false; toast('Time up'); beep(); }
    }, 1000);
  });
  $('#timerPause').addEventListener('click', () => { if (state.timerInterval) clearInterval(state.timerInterval); state.timerRunning = false; });
  $('#timerReset').addEventListener('click', () => { state.timerSeconds = (parseInt($('#timerMins').value, 10) || 5) * 60; render(); });
}

function beep() {
  try {
    const ac = state.audioCtx = state.audioCtx || new (window.AudioContext || window.webkitAudioContext)();
    const o = ac.createOscillator(); const g = ac.createGain();
    o.frequency.value = 880; o.connect(g); g.connect(ac.destination);
    g.gain.setValueAtTime(0.001, ac.currentTime);
    g.gain.exponentialRampToValueAtTime(0.2, ac.currentTime + 0.05);
    g.gain.exponentialRampToValueAtTime(0.001, ac.currentTime + 0.5);
    o.start(); o.stop(ac.currentTime + 0.5);
  } catch {}
}

function setupMusic() {
  $('#musicPlay').addEventListener('click', () => {
    const ac = state.audioCtx = state.audioCtx || new (window.AudioContext || window.webkitAudioContext)();
    if (state.musicNodes.length) return;
    const master = ac.createGain();
    master.gain.value = (+$('#musicVol').value) / 500;
    master.connect(ac.destination);
    [220, 277.18, 329.63, 440].forEach((freq, i) => {
      const o = ac.createOscillator();
      o.type = i % 2 ? 'sine' : 'triangle';
      o.frequency.value = freq;
      const g = ac.createGain(); g.gain.value = 0.15;
      const lfo = ac.createOscillator(); lfo.frequency.value = 0.12 + i * 0.03;
      const lfoGain = ac.createGain(); lfoGain.gain.value = 0.06;
      lfo.connect(lfoGain).connect(g.gain);
      o.connect(g).connect(master);
      o.start(); lfo.start();
      state.musicNodes.push(o, lfo);
    });
    state.musicMaster = master;
    toast('Music playing');
  });
  $('#musicStop').addEventListener('click', () => {
    state.musicNodes.forEach(n => { try { n.stop(); } catch {} });
    state.musicNodes = [];
    toast('Music stopped');
  });
  $('#musicVol').addEventListener('input', () => {
    if (state.musicMaster) state.musicMaster.gain.value = (+$('#musicVol').value) / 500;
  });
}

/* ==========================================================================
   MEETING CLOCK
   ========================================================================== */
function startClock() {
  state.meetingClockInterval = setInterval(() => {
    const t = Math.floor((Date.now() - state.startedAt) / 1000);
    const h = Math.floor(t/3600), m = Math.floor((t%3600)/60), s = t % 60;
    $('#meetingClock').textContent = h > 0
      ? `${h}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`
      : `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
  }, 1000);
}

/* ==========================================================================
   MODALS
   ========================================================================== */
function openModal(id) { $('#' + id).classList.add('open'); }
function closeModal(id) { $('#' + id).classList.remove('open'); }

/* ==========================================================================
   END CALL
   ========================================================================== */
async function endCall() {
  if (!confirm(isHost ? 'End the meeting for everyone?' : 'Leave the meeting?')) return;
  try {
    stopRecording();
    stopCaptions();
    if (state.localStream) state.localStream.getTracks().forEach(t => t.stop());
    if (state.screenStream) state.screenStream.getTracks().forEach(t => t.stop());
    if (state.pcLocal) state.pcLocal.close();
    if (state.pcRemote) state.pcRemote.close();
    if (isHost) {
      const fd = new FormData(); fd.append('action', 'end');
      await fetch(location.pathname, { method: 'POST', body: fd });
    }
  } catch {}
  location.href = '/portal';
}

/* ==========================================================================
   KEYBOARD SHORTCUTS
   ========================================================================== */
document.addEventListener('keydown', (e) => {
  if (e.target.matches('input, textarea, [contenteditable]')) return;
  if (e.key === 'm' || e.key === 'M') { toggleMic(); }
  if (e.key === 'c' || e.key === 'C') { toggleCam(); }
  if (e.key === 's' || e.key === 'S') { startScreenShare(); }
  if (e.key === 'r' || e.key === 'R') { toggleHand(); }
  if (e.key === 'p' || e.key === 'P') { switchTab('people'); togglePanel(); }
  if (e.key === '?') { $('#helpOverlay').classList.add('open'); }
  if (e.key === 'Escape') {
    $$('.mt-modal-bg').forEach(m => m.classList.remove('open'));
    $('#helpOverlay').classList.remove('open');
    $('#rxPop').classList.remove('open');
    $('#moreMenu').classList.remove('open');
  }
  // Push-to-talk: hold Space while muted
  if (e.code === 'Space' && !state.audioOn && !state.ptt) {
    e.preventDefault();
    state.ptt = true;
    if (state.localStream) state.localStream.getAudioTracks().forEach(t => t.enabled = true);
    toast('PTT on');
  }
});
document.addEventListener('keyup', (e) => {
  if (e.code === 'Space' && state.ptt) {
    state.ptt = false;
    if (state.localStream && !state.audioOn) state.localStream.getAudioTracks().forEach(t => t.enabled = false);
  }
});

/* ==========================================================================
   WIRE EVERYTHING
   ========================================================================== */
async function init() {
  // Top bar
  $('#copyInvite').addEventListener('click', () => {
    const url = location.origin + '/portal/meet/' + roomId;
    navigator.clipboard.writeText(url).then(() => toast('Invite link copied'));
  });

  // Title save (host only)
  if (isHost) {
    const titleInp = $('#roomTitle');
    let titleTimer;
    titleInp.addEventListener('input', () => {
      clearTimeout(titleTimer);
      titleTimer = setTimeout(async () => {
        const fd = new FormData(); fd.append('action', 'set_title'); fd.append('title', titleInp.value);
        await fetch(location.pathname, { method: 'POST', body: fd });
      }, 600);
    });
  }

  // Bottom bar
  $('#micBtn').addEventListener('click', toggleMic);
  $('#camBtn').addEventListener('click', toggleCam);
  $('#shareBtn').addEventListener('click', startScreenShare);
  $('#handBtn').addEventListener('click', toggleHand);
  $('#rxBtn').addEventListener('click', (e) => { e.stopPropagation(); $('#moreMenu').classList.remove('open'); $('#rxPop').classList.toggle('open'); });
  $('#moreBtn').addEventListener('click', (e) => { e.stopPropagation(); $('#rxPop').classList.remove('open'); $('#moreMenu').classList.toggle('open'); });
  $('#peopleBtn').addEventListener('click', () => switchTab('people'));
  $('#chatBtn').addEventListener('click', () => switchTab('chat'));
  $('#endBtn').addEventListener('click', endCall);
  document.addEventListener('click', () => { $('#rxPop').classList.remove('open'); $('#moreMenu').classList.remove('open'); });

  // Reactions
  $$('#rxPop button').forEach(b => b.addEventListener('click', () => { flyReaction(b.dataset.rx); $('#rxPop').classList.remove('open'); }));

  // More menu
  $$('#moreMenu button').forEach(b => b.addEventListener('click', () => {
    const a = b.dataset.more;
    $('#moreMenu').classList.remove('open');
    if (a === 'blur') { state.blurOn ? stopBlur() : startBlur(); }
    if (a === 'record') { state.recording ? stopRecording() : startRecording(); }
    if (a === 'captions') { state.capOn ? stopCaptions() : startCaptions(); }
    if (a === 'breakout' && isHost) { openModal('boModal'); }
    if (a === 'settings') { openModal('settingsModal'); }
    if (a === 'help') { $('#helpOverlay').classList.add('open'); }
    if (a === 'layout') { toast('Layout cycles automatically with participant count'); }
  }));

  // Tabs
  $$('.mt-panel-tab').forEach(t => t.addEventListener('click', () => switchTab(t.dataset.tab)));

  // Chat
  $('#chatSend').addEventListener('click', sendChat);
  $('#chatInput').addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendChat(); }
  });

  // Polls
  if (isHost) {
    $('#newPollBtn')?.addEventListener('click', () => { pollOpts = ['', '']; renderPollOpts(); openModal('pollModal'); });
    $('#addPollOpt')?.addEventListener('click', () => { pollOpts.push(''); renderPollOpts(); });
    $('#pollSubmit')?.addEventListener('click', submitPoll);
    $('#createBreakoutBtn')?.addEventListener('click', () => openModal('boModal'));
    $('#boSubmit')?.addEventListener('click', submitBreakouts);
    $('#muteAllBtn')?.addEventListener('click', () => { toggleMic(); toast('Asked all to mute'); });
    $('#lockBtn')?.addEventListener('click', async () => {
      const fd = new FormData(); fd.append('action', 'lock'); fd.append('locked', isLockedFlag ? '0' : '1');
      await fetch(location.pathname, { method: 'POST', body: fd });
      location.reload();
    });
  }

  // Poll vote
  $$('[data-poll-vote]').forEach(r => r.addEventListener('change', (e) => {
    votePoll(e.target.dataset.pollVote, e.target.value);
  }));

  // Modals close
  $$('[data-close]').forEach(b => b.addEventListener('click', () => closeModal(b.dataset.close)));
  $$('.mt-modal-bg').forEach(m => m.addEventListener('click', (e) => { if (e.target === m) m.classList.remove('open'); }));
  $('#helpOverlay').addEventListener('click', (e) => { if (e.target.id === 'helpOverlay') e.currentTarget.classList.remove('open'); });

  // Captions toggle
  $('#capToggle')?.addEventListener('click', () => state.capOn ? stopCaptions() : startCaptions());
  $('#capExport')?.addEventListener('click', () => {
    const text = $('#capLog').innerText;
    const blob = new Blob([text], { type: 'text/plain' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob); a.download = 'captions.txt'; a.click();
  });

  // Apps
  $$('[data-app]').forEach(c => c.addEventListener('click', () => {
    const a = c.dataset.app;
    ['Notes', 'Timer', 'Music'].forEach(n => $('#appBody' + n).classList.add('hidden'));
    if (a === 'notes') $('#appBodyNotes').classList.remove('hidden');
    if (a === 'timer') $('#appBodyTimer').classList.remove('hidden');
    if (a === 'music') $('#appBodyMusic').classList.remove('hidden');
    if (a === 'board') switchTab('board');
  }));

  // People search
  $('#peopleSearch')?.addEventListener('input', (e) => {
    const q = e.target.value.toLowerCase();
    $$('#peopleList .mt-pl-item').forEach(i => {
      const txt = i.textContent.toLowerCase();
      i.style.display = txt.includes(q) ? '' : 'none';
    });
  });

  // People host actions
  $$('.mt-pl-ctrl').forEach(b => b.addEventListener('click', (e) => {
    const act = b.dataset.act;
    const uid = b.closest('.mt-pl-item')?.dataset.uid;
    if (act === 'remove') { if (confirm('Remove this participant?')) toast('Participant removed'); }
    if (act === 'ask-mute') { toast('Asked to mute'); }
  }));

  // Setup pipelines
  await startLocalMedia();
  if (state.localStream) {
    await startLoopbackPC();
    startActiveSpeakerDetection();
  }

  // Whiteboard
  setupWhiteboard();
  setupNotes();
  setupTimer();
  setupMusic();
  startClock();

  // Auto-join
  const fd = new FormData();
  fd.append('action', 'join'); fd.append('display_name', myDisplayName);
  fetch(location.pathname, { method: 'POST', body: fd }).catch(()=>{});

  // Initial pane state
  switchTab('chat');

  // First-time tip
  if (!sessionStorage.getItem('meet-tip')) {
    setTimeout(() => { toast('Press ? for keyboard shortcuts'); sessionStorage.setItem('meet-tip', '1'); }, 1500);
  }
}

window.addEventListener('beforeunload', () => {
  try {
    if (state.localStream) state.localStream.getTracks().forEach(t => t.stop());
    if (state.screenStream) state.screenStream.getTracks().forEach(t => t.stop());
    if (state.pcLocal) state.pcLocal.close();
    if (state.pcRemote) state.pcRemote.close();
  } catch {}
});

init();
</script>

</BaseLayout>
