---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
const { id } = Astro.params as { id: string };

if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/meet/' + id));

/* ============================================================
   SELF-BOOTSTRAP MEETING TABLES
   ============================================================ */
function rowsOf(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

try {
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS meet_rooms (
      id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
      host_user_id UUID,
      title TEXT,
      kind VARCHAR(20) DEFAULT 'huddle',
      scheduled_at TIMESTAMPTZ,
      duration_minutes INT DEFAULT 60,
      passcode VARCHAR(40),
      is_locked BOOLEAN DEFAULT false,
      recording_enabled BOOLEAN DEFAULT false,
      recording_url TEXT,
      max_participants INT DEFAULT 250,
      status VARCHAR(20) DEFAULT 'open',
      features JSONB DEFAULT '{}'::jsonb,
      created_at TIMESTAMPTZ DEFAULT NOW()
    )
  `);
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS meet_participants (
      room_id UUID REFERENCES meet_rooms(id) ON DELETE CASCADE,
      user_id UUID,
      display_name VARCHAR(200),
      role VARCHAR(20) DEFAULT 'attendee',
      joined_at TIMESTAMPTZ DEFAULT NOW(),
      left_at TIMESTAMPTZ,
      in_lobby BOOLEAN DEFAULT false,
      PRIMARY KEY (room_id, user_id)
    )
  `);
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS meet_chat (
      id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
      room_id UUID,
      user_id UUID,
      body TEXT,
      is_private_to UUID,
      created_at TIMESTAMPTZ DEFAULT NOW()
    )
  `);
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS meet_polls (
      id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
      room_id UUID,
      question TEXT,
      options JSONB DEFAULT '[]'::jsonb,
      votes JSONB DEFAULT '{}'::jsonb,
      status VARCHAR(20) DEFAULT 'live',
      created_at TIMESTAMPTZ DEFAULT NOW()
    )
  `);
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS meet_breakouts (
      id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
      room_id UUID,
      label VARCHAR(120),
      participants JSONB DEFAULT '[]'::jsonb,
      ends_at TIMESTAMPTZ,
      created_at TIMESTAMPTZ DEFAULT NOW()
    )
  `);
} catch (e) {
  console.error('meet schema bootstrap failed', e);
}

/* ============================================================
   LOAD-OR-CREATE ROOM
   ============================================================ */
const isUuid = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i.test(id);

let room: any = null;
if (isUuid) {
  const r = rowsOf(await db.execute(sql`SELECT * FROM meet_rooms WHERE id = ${id}::uuid LIMIT 1`));
  room = r[0] || null;
}
if (!room) {
  const r = rowsOf(await db.execute(sql`
    INSERT INTO meet_rooms (id, host_user_id, title, kind)
    VALUES (${isUuid ? id : sql`gen_random_uuid()`}, ${user.id}, ${'Untitled huddle'}, 'huddle')
    ON CONFLICT (id) DO NOTHING
    RETURNING *
  `));
  room = r[0] || null;
  if (!room) {
    const r2 = rowsOf(await db.execute(sql`SELECT * FROM meet_rooms WHERE id = ${id}::uuid LIMIT 1`));
    room = r2[0] || null;
  }
}

const isHost = room && room.host_user_id === user.id;

/* ============================================================
   POST HANDLERS — join / chat / poll / vote / breakout / end
   ============================================================ */
let actionResult: any = null;
if (Astro.request.method === 'POST' && room) {
  try {
    const fd = await Astro.request.formData();
    const action = (fd.get('action') as string || '').trim();

    if (action === 'join') {
      const displayName = (fd.get('display_name') as string || user.email || 'Guest').slice(0, 200);
      const role = isHost ? 'host' : 'attendee';
      await db.execute(sql`
        INSERT INTO meet_participants (room_id, user_id, display_name, role, in_lobby)
        VALUES (${room.id}::uuid, ${user.id}, ${displayName}, ${role}, ${room.is_locked && !isHost})
        ON CONFLICT (room_id, user_id) DO UPDATE SET left_at = NULL, joined_at = NOW()
      `);
      actionResult = { ok: true };
    }

    if (action === 'chat') {
      const body = (fd.get('body') as string || '').trim().slice(0, 4000);
      const priv = (fd.get('is_private_to') as string || '').trim();
      if (body) {
        await db.execute(sql`
          INSERT INTO meet_chat (room_id, user_id, body, is_private_to)
          VALUES (${room.id}::uuid, ${user.id}, ${body}, ${priv ? sql`${priv}::uuid` : null})
        `);
      }
      actionResult = { ok: true };
    }

    if (action === 'create_poll' && isHost) {
      const question = (fd.get('question') as string || '').trim().slice(0, 500);
      let opts: string[] = [];
      try { opts = JSON.parse((fd.get('options') as string || '[]')); } catch { opts = []; }
      if (question && opts.length >= 2) {
        await db.execute(sql`
          INSERT INTO meet_polls (room_id, question, options, status)
          VALUES (${room.id}::uuid, ${question}, ${JSON.stringify(opts)}::jsonb, 'live')
        `);
      }
      actionResult = { ok: true };
    }

    if (action === 'vote') {
      const pollId = (fd.get('poll_id') as string || '').trim();
      const choice = (fd.get('choice') as string || '').trim();
      if (pollId && choice) {
        await db.execute(sql`
          UPDATE meet_polls SET votes = jsonb_set(
            COALESCE(votes,'{}'::jsonb),
            ${'{' + user.id + '}'}::text[],
            to_jsonb(${choice}::text)
          ) WHERE id = ${pollId}::uuid
        `);
      }
      actionResult = { ok: true };
    }

    if (action === 'create_breakout' && isHost) {
      const label = (fd.get('label') as string || '').trim().slice(0, 120);
      let parts: string[] = [];
      try { parts = JSON.parse((fd.get('participants') as string || '[]')); } catch { parts = []; }
      const mins = parseInt((fd.get('minutes') as string || '15'), 10) || 15;
      if (label) {
        await db.execute(sql`
          INSERT INTO meet_breakouts (room_id, label, participants, ends_at)
          VALUES (${room.id}::uuid, ${label}, ${JSON.stringify(parts)}::jsonb, NOW() + (${mins} || ' minutes')::interval)
        `);
      }
      actionResult = { ok: true };
    }

    if (action === 'end' && isHost) {
      await db.execute(sql`UPDATE meet_rooms SET status='ended' WHERE id=${room.id}::uuid`);
      actionResult = { ok: true, ended: true };
    }

    if (action === 'lock' && isHost) {
      const lk = (fd.get('locked') as string) === '1';
      await db.execute(sql`UPDATE meet_rooms SET is_locked=${lk} WHERE id=${room.id}::uuid`);
      actionResult = { ok: true };
    }

    if (action === 'set_title' && isHost) {
      const t = (fd.get('title') as string || '').trim().slice(0, 200);
      if (t) await db.execute(sql`UPDATE meet_rooms SET title=${t} WHERE id=${room.id}::uuid`);
      actionResult = { ok: true };
    }
  } catch (e: any) {
    actionResult = { ok: false, error: String(e?.message || e).slice(0, 240) };
  }
}

/* ============================================================
   LOAD ROOM STATE FOR INITIAL RENDER
   ============================================================ */
let participants: any[] = [];
let chat: any[] = [];
let polls: any[] = [];
let breakouts: any[] = [];

if (room) {
  participants = rowsOf(await db.execute(sql`
    SELECT user_id, display_name, role, joined_at, left_at, in_lobby
    FROM meet_participants WHERE room_id = ${room.id}::uuid AND left_at IS NULL
    ORDER BY joined_at ASC LIMIT 250
  `));
  chat = rowsOf(await db.execute(sql`
    SELECT c.id, c.user_id, c.body, c.is_private_to, c.created_at, p.display_name
    FROM meet_chat c
    LEFT JOIN meet_participants p ON p.user_id = c.user_id AND p.room_id = c.room_id
    WHERE c.room_id = ${room.id}::uuid AND (c.is_private_to IS NULL OR c.is_private_to = ${user.id}::uuid OR c.user_id = ${user.id}::uuid)
    ORDER BY c.created_at DESC LIMIT 100
  `));
  chat = chat.reverse();
  polls = rowsOf(await db.execute(sql`
    SELECT id, question, options, votes, status, created_at
    FROM meet_polls WHERE room_id = ${room.id}::uuid
    ORDER BY created_at DESC LIMIT 20
  `));
  breakouts = rowsOf(await db.execute(sql`
    SELECT id, label, participants, ends_at, created_at
    FROM meet_breakouts WHERE room_id = ${room.id}::uuid
    AND ends_at > NOW() ORDER BY created_at DESC LIMIT 20
  `));
}

const roomTitle = room?.title || 'Untitled huddle';
const roomKind = room?.kind || 'huddle';
const isRecording = !!room?.recording_enabled;
const isLocked = !!room?.is_locked;
const myDisplayName = user.email?.split('@')[0] || 'Guest';
---

<BaseLayout title={`${roomTitle} - Meeting room`} description="Live video meeting room. Audio, video, screen share, chat, polls, whiteboard, breakouts, captions, recording — all browser-native." showNav={false} showFooter={false}>

<style is:global>
  html, body { background: #0a0a0c; color: #e8e8ee; margin: 0; padding: 0; height: 100%; overflow: hidden; font-family: 'DM Sans', system-ui, sans-serif; }
  body.era-has-fab { padding-bottom: 0 !important; }
  .era-fab, [class*="era-fab"] { display: none !important; }
</style>

<style>
  /* ===========================================================
     MEETING ROOM LAYOUT
     =========================================================== */
  .mt-shell {
    display: grid;
    grid-template-rows: 52px 1fr 78px;
    height: 100vh;
    width: 100vw;
    background: #0a0a0c;
    color: #e8e8ee;
    overflow: hidden;
    position: relative;
  }

  /* ---------- TOP BAR ---------- */
  .mt-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 16px;
    background: #11131a;
    border-bottom: 1px solid #1f1f2a;
    gap: 12px;
  }
  .mt-top-left, .mt-top-right { display: flex; align-items: center; gap: 12px; min-width: 0; }
  .mt-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 19px; font-weight: 600;
    color: #e8e8ee;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    max-width: 320px;
    border: none; background: transparent; outline: none;
    padding: 4px 6px; border-radius: 4px;
  }
  .mt-title:focus { background: #1a1a25; }
  .mt-pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 10px; border-radius: 999px;
    font-family: 'Geist Mono', monospace; font-size: 10px;
    letter-spacing: 0.12em; text-transform: uppercase; font-weight: 700;
    border: 1px solid #2a2a35;
    color: #cfd6da;
    background: #181821;
  }
  .mt-pill.host { color: #a78bfa; border-color: rgba(167,139,250,0.4); background: rgba(167,139,250,0.08); }
  .mt-pill.rec { color: #FF4F00; border-color: rgba(255,79,0,0.4); background: rgba(255,79,0,0.08); }
  .mt-pill.rec .dot { width: 8px; height: 8px; background: #FF4F00; border-radius: 50%; animation: pulseDot 1.2s ease-in-out infinite; }
  .mt-pill.e2e { color: #67e8f9; border-color: rgba(103,232,249,0.4); background: rgba(103,232,249,0.08); }
  .mt-pill.kind { color: #e8e8ee; }
  @keyframes pulseDot { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.4; transform: scale(1.3); } }

  .mt-btn {
    background: #1a1a25; color: #e8e8ee;
    border: 1px solid #2a2a35;
    padding: 6px 12px; border-radius: 6px;
    font-family: 'Geist Mono', monospace;
    font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700;
    cursor: pointer;
    display: inline-flex; align-items: center; gap: 6px;
    transition: all 0.15s;
  }
  .mt-btn:hover { background: #22222e; border-color: #3a3a4a; }
  .mt-btn.primary { background: #FF4F00; border-color: #FF4F00; color: #fff; }
  .mt-btn.primary:hover { background: #e84600; }
  .mt-btn.danger { background: #dc2626; border-color: #dc2626; color: #fff; }
  .mt-btn.danger:hover { background: #b91c1c; }
  .mt-btn.cyan { background: rgba(103,232,249,0.1); border-color: rgba(103,232,249,0.4); color: #67e8f9; }
  .mt-btn.purple { background: rgba(167,139,250,0.1); border-color: rgba(167,139,250,0.4); color: #a78bfa; }
  .mt-btn svg { width: 14px; height: 14px; }
  .mt-btn-count { background: #2a2a35; color: #67e8f9; padding: 1px 6px; border-radius: 999px; font-size: 9.5px; }

  /* ---------- BODY (stage + right panel) ---------- */
  .mt-body { display: grid; grid-template-columns: 1fr 0; overflow: hidden; transition: grid-template-columns 0.22s; }
  .mt-body.panel-open { grid-template-columns: 1fr 340px; }

  /* ---------- STAGE ---------- */
  .mt-stage {
    position: relative;
    background: #0a0a0c;
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    padding: 12px;
  }
  .mt-grid {
    width: 100%; height: 100%;
    display: grid; gap: 8px;
    align-items: stretch; justify-items: stretch;
  }
  .mt-grid.share-on { grid-template-columns: 1fr 220px; grid-template-rows: 1fr; }
  .mt-grid.share-on .share-tile { grid-column: 1; grid-row: 1; }
  .mt-grid.share-on .tile-strip {
    grid-column: 2; grid-row: 1;
    display: flex; flex-direction: column; gap: 8px; overflow-y: auto;
  }
  .mt-grid.share-on .tile-strip .mt-tile { aspect-ratio: 16 / 10; min-height: 124px; }

  /* Auto-arrange — uses CSS data-count */
  .mt-grid[data-count="1"]  { grid-template-columns: 1fr; grid-template-rows: 1fr; }
  .mt-grid[data-count="2"]  { grid-template-columns: 1fr 1fr; grid-template-rows: 1fr; }
  .mt-grid[data-count="3"]  { grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; }
  .mt-grid[data-count="4"]  { grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; }
  .mt-grid[data-count="5"], .mt-grid[data-count="6"]  { grid-template-columns: repeat(3,1fr); grid-template-rows: 1fr 1fr; }
  .mt-grid[data-count="7"], .mt-grid[data-count="8"], .mt-grid[data-count="9"] { grid-template-columns: repeat(3,1fr); grid-template-rows: repeat(3,1fr); }
  .mt-grid[data-count="10"], .mt-grid[data-count="11"], .mt-grid[data-count="12"] { grid-template-columns: repeat(4,1fr); grid-template-rows: repeat(3,1fr); }
  .mt-grid[data-count="13"], .mt-grid[data-count="14"], .mt-grid[data-count="15"], .mt-grid[data-count="16"] { grid-template-columns: repeat(4,1fr); grid-template-rows: repeat(4,1fr); }
  .mt-grid[data-count="17"], .mt-grid[data-count="18"], .mt-grid[data-count="19"], .mt-grid[data-count="20"], .mt-grid[data-count="25"] { grid-template-columns: repeat(5,1fr); grid-template-rows: repeat(5,1fr); }
  .mt-grid[data-count="49"] { grid-template-columns: repeat(7,1fr); grid-template-rows: repeat(7,1fr); }

  /* ---------- TILE ---------- */
  .mt-tile {
    position: relative;
    background: #11131a;
    border-radius: 12px;
    overflow: hidden;
    border: 2px solid transparent;
    transition: border-color 0.18s;
    min-height: 0;
  }
  .mt-tile.active-speaker { border-color: #fbbf24; box-shadow: 0 0 0 2px rgba(251,191,36,0.18); }
  .mt-tile.pinned { border-color: #67e8f9; }
  .mt-tile video {
    width: 100%; height: 100%;
    object-fit: cover;
    background: linear-gradient(135deg, #1a1a25, #0c0e14);
  }
  .mt-tile .placeholder {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    background: var(--tile-bg, linear-gradient(135deg, #1f2937, #0f172a));
    color: #e8e8ee;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(28px, 6vw, 64px);
    font-weight: 600;
  }
  .mt-tile.share-tile { background: #000; }
  .mt-tile.share-tile video { object-fit: contain; }

  .mt-tile-overlay {
    position: absolute; left: 8px; bottom: 8px; right: 8px;
    display: flex; align-items: center; justify-content: space-between;
    gap: 6px; pointer-events: none;
  }
  .mt-tile-name {
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(6px);
    color: #fff;
    padding: 3px 8px;
    border-radius: 5px;
    font-family: 'Geist Mono', monospace;
    font-size: 10.5px;
    letter-spacing: 0.06em;
    font-weight: 600;
    display: inline-flex; align-items: center; gap: 6px;
    max-width: 70%;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .mt-tile-icons { display: flex; gap: 4px; }
  .mt-tile-icon {
    width: 22px; height: 22px;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(6px);
    border-radius: 5px;
    display: inline-flex; align-items: center; justify-content: center;
    color: #fff;
  }
  .mt-tile-icon svg { width: 12px; height: 12px; }
  .mt-tile-icon.muted { background: rgba(220,38,38,0.85); }
  .mt-tile-icon.cam-off { background: rgba(220,38,38,0.85); }
  .mt-tile-icon.hand { background: rgba(251,191,36,0.85); color: #0a0a0c; }
  .mt-tile-icon.pin { background: rgba(103,232,249,0.85); color: #0a0a0c; }
  .mt-signal { position: absolute; top: 8px; right: 8px; display: flex; gap: 2px; align-items: flex-end; }
  .mt-signal span { width: 3px; background: rgba(255,255,255,0.35); border-radius: 1px; }
  .mt-signal span:nth-child(1) { height: 4px; }
  .mt-signal span:nth-child(2) { height: 7px; }
  .mt-signal span:nth-child(3) { height: 10px; }
  .mt-signal.s1 span:nth-child(1) { background: #34d399; }
  .mt-signal.s2 span:nth-child(1), .mt-signal.s2 span:nth-child(2) { background: #34d399; }
  .mt-signal.s3 span { background: #34d399; }

  /* ---------- CAPTIONS STRIP ---------- */
  .mt-captions {
    position: absolute;
    left: 50%; bottom: 16px;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.78);
    color: #fff;
    padding: 10px 18px;
    border-radius: 10px;
    max-width: 70%;
    font-size: 16px;
    line-height: 1.4;
    text-align: center;
    pointer-events: none;
    z-index: 30;
    display: none;
  }
  .mt-captions.on { display: block; }

  /* ---------- REACTIONS LAYER ---------- */
  .mt-rx-layer {
    position: absolute; inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 25;
  }
  .mt-rx {
    position: absolute;
    bottom: 0;
    font-size: 36px;
    animation: rxFloat 3.5s ease-out forwards;
  }
  .mt-rx svg { width: 42px; height: 42px; }
  @keyframes rxFloat {
    0% { transform: translateY(0) scale(0.5); opacity: 0; }
    10% { opacity: 1; transform: translateY(-20px) scale(1.1); }
    100% { transform: translateY(-70vh) scale(1.1) rotate(15deg); opacity: 0; }
  }

  /* ---------- RIGHT PANEL ---------- */
  .mt-panel {
    background: #11131a;
    border-left: 1px solid #1f1f2a;
    display: flex; flex-direction: column;
    overflow: hidden;
    min-width: 0;
  }
  .mt-panel-tabs {
    display: grid; grid-template-columns: repeat(6, 1fr);
    background: #0c0e14;
    border-bottom: 1px solid #1f1f2a;
  }
  .mt-panel-tab {
    background: transparent; border: none; color: #9aa6b6;
    padding: 10px 4px;
    font-family: 'Geist Mono', monospace;
    font-size: 9.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.15s;
  }
  .mt-panel-tab:hover { color: #e8e8ee; }
  .mt-panel-tab.active { color: #67e8f9; border-bottom-color: #67e8f9; background: rgba(103,232,249,0.05); }

  .mt-panel-body { flex: 1; overflow-y: auto; padding: 12px; }
  .mt-panel-body::-webkit-scrollbar { width: 8px; }
  .mt-panel-body::-webkit-scrollbar-thumb { background: #2a2a35; border-radius: 4px; }
  .mt-panel-section { display: none; }
  .mt-panel-section.active { display: block; }

  /* Chat */
  .mt-chat-list { display: flex; flex-direction: column; gap: 10px; padding-bottom: 8px; }
  .mt-chat-msg { font-size: 13px; line-height: 1.5; }
  .mt-chat-from { font-family: 'Geist Mono', monospace; font-size: 10.5px; color: #67e8f9; font-weight: 700; margin-bottom: 2px; display: flex; gap: 6px; align-items: center; }
  .mt-chat-from .priv { background: rgba(167,139,250,0.15); color: #a78bfa; padding: 1px 5px; border-radius: 3px; font-size: 9px; }
  .mt-chat-body { color: #e8e8ee; word-wrap: break-word; }
  .mt-chat-form { display: flex; flex-direction: column; gap: 6px; padding-top: 8px; border-top: 1px solid #1f1f2a; }
  .mt-chat-input {
    background: #0a0a0c; border: 1px solid #2a2a35;
    color: #e8e8ee; padding: 8px 10px; border-radius: 6px;
    font-family: 'DM Sans', sans-serif; font-size: 13px; outline: none;
    resize: none; min-height: 56px;
  }
  .mt-chat-input:focus { border-color: #67e8f9; }
  .mt-chat-priv { display: flex; gap: 6px; align-items: center; font-size: 11px; color: #9aa6b6; }
  .mt-chat-priv select { background: #0a0a0c; border: 1px solid #2a2a35; color: #e8e8ee; padding: 3px 6px; border-radius: 4px; font-size: 11px; flex: 1; }

  /* Participants list */
  .mt-pl-search { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; color: #e8e8ee; padding: 7px 10px; border-radius: 6px; font-size: 12.5px; outline: none; margin-bottom: 10px; }
  .mt-pl-search:focus { border-color: #67e8f9; }
  .mt-pl-section-title { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; margin: 10px 0 6px; }
  .mt-pl-item {
    display: flex; align-items: center; gap: 8px;
    padding: 7px 8px; border-radius: 6px;
    margin-bottom: 2px;
  }
  .mt-pl-item:hover { background: #1a1a25; }
  .mt-pl-av {
    width: 28px; height: 28px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Garamond', serif; font-weight: 600; font-size: 13px;
    color: #fff;
    flex-shrink: 0;
  }
  .mt-pl-name { flex: 1; font-size: 13px; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .mt-pl-role { font-family: 'Geist Mono', monospace; font-size: 9.5px; color: #a78bfa; text-transform: uppercase; letter-spacing: 0.08em; }
  .mt-pl-ctrls { display: flex; gap: 3px; }
  .mt-pl-ctrl {
    width: 22px; height: 22px;
    background: #1a1a25; border: 1px solid #2a2a35;
    color: #cfd6da;
    border-radius: 4px;
    display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer;
  }
  .mt-pl-ctrl:hover { color: #67e8f9; border-color: #67e8f9; }
  .mt-pl-ctrl svg { width: 11px; height: 11px; }
  .mt-pl-ctrl.danger:hover { color: #f87171; border-color: #f87171; }

  /* Polls */
  .mt-poll { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; padding: 12px; margin-bottom: 10px; }
  .mt-poll-q { font-weight: 600; color: #e8e8ee; margin-bottom: 8px; font-size: 13.5px; }
  .mt-poll-opt { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; cursor: pointer; }
  .mt-poll-opt input[type=radio] { accent-color: #67e8f9; }
  .mt-poll-opt-label { flex: 1; font-size: 12.5px; color: #cfd6da; }
  .mt-poll-bar { height: 4px; background: #1f1f2a; border-radius: 2px; overflow: hidden; margin: 3px 0 6px 22px; }
  .mt-poll-bar-fill { height: 100%; background: linear-gradient(90deg, #67e8f9, #a78bfa); }
  .mt-poll-result { font-family: 'Geist Mono', monospace; font-size: 10px; color: #9aa6b6; margin-left: 22px; }
  .mt-poll-status { display: inline-block; padding: 1px 6px; border-radius: 3px; font-family: 'Geist Mono', monospace; font-size: 9.5px; font-weight: 700; letter-spacing: 0.08em; }
  .mt-poll-status.live { background: rgba(52,211,153,0.15); color: #34d399; }
  .mt-poll-status.closed { background: rgba(154,166,182,0.15); color: #9aa6b6; }

  /* Whiteboard */
  .mt-wb-tools { display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 8px; }
  .mt-wb-tool { background: #1a1a25; border: 1px solid #2a2a35; color: #cfd6da; padding: 6px 8px; border-radius: 5px; cursor: pointer; display: inline-flex; align-items: center; gap: 4px; font-size: 11px; }
  .mt-wb-tool.active { background: #67e8f9; color: #0a0a0c; border-color: #67e8f9; }
  .mt-wb-tool svg { width: 12px; height: 12px; }
  .mt-wb-colors { display: flex; gap: 4px; }
  .mt-wb-color { width: 18px; height: 18px; border-radius: 50%; border: 2px solid transparent; cursor: pointer; }
  .mt-wb-color.active { border-color: #fff; transform: scale(1.1); }
  .mt-wb-canvas {
    width: 100%;
    background: #fafafa;
    border-radius: 8px;
    border: 1px solid #2a2a35;
    cursor: crosshair;
    display: block;
  }

  /* Captions tab */
  .mt-cap-log { font-size: 13px; line-height: 1.55; color: #cfd6da; white-space: pre-wrap; }
  .mt-cap-line { margin-bottom: 8px; padding-bottom: 8px; border-bottom: 1px dashed #1f1f2a; }
  .mt-cap-line .ts { font-family: 'Geist Mono', monospace; font-size: 9.5px; color: #67e8f9; letter-spacing: 0.08em; display: block; margin-bottom: 2px; }

  /* Apps tab */
  .mt-app-card { background: #0a0a0c; border: 1px solid #2a2a35; border-radius: 8px; padding: 12px; margin-bottom: 10px; cursor: pointer; }
  .mt-app-card:hover { border-color: #67e8f9; }
  .mt-app-card h4 { margin: 0 0 4px; font-size: 13.5px; color: #e8e8ee; display: flex; align-items: center; gap: 8px; }
  .mt-app-card h4 svg { width: 14px; height: 14px; color: #67e8f9; }
  .mt-app-card p { margin: 0; font-size: 11.5px; color: #9aa6b6; line-height: 1.4; }

  /* Notes app */
  .mt-notes-area {
    width: 100%; box-sizing: border-box;
    background: #0a0a0c; border: 1px solid #2a2a35;
    color: #e8e8ee; padding: 10px;
    border-radius: 6px;
    font-family: 'DM Sans', sans-serif; font-size: 13px; line-height: 1.55;
    outline: none; resize: vertical;
    min-height: 200px;
  }

  /* Timer app */
  .mt-timer {
    text-align: center;
    background: #0a0a0c; border: 1px solid #2a2a35;
    border-radius: 8px; padding: 16px;
  }
  .mt-timer-display {
    font-family: 'Geist Mono', monospace;
    font-size: 38px; font-weight: 700;
    color: #67e8f9;
    letter-spacing: 0.04em;
    margin: 8px 0 12px;
  }
  .mt-timer-ctrls { display: flex; gap: 6px; justify-content: center; flex-wrap: wrap; }

  /* ---------- BOTTOM CONTROL BAR ---------- */
  .mt-controls {
    background: #11131a;
    border-top: 1px solid #1f1f2a;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 16px;
    gap: 10px;
  }
  .mt-controls-left, .mt-controls-center, .mt-controls-right {
    display: flex; align-items: center; gap: 8px;
  }
  .mt-time {
    font-family: 'Geist Mono', monospace;
    font-size: 13px; color: #cfd6da;
    letter-spacing: 0.04em;
  }
  .mt-ctrl {
    width: 48px; height: 48px;
    background: #1a1a25; border: 1px solid #2a2a35;
    color: #e8e8ee;
    border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: all 0.15s;
    position: relative;
  }
  .mt-ctrl svg { width: 20px; height: 20px; }
  .mt-ctrl:hover { background: #22222e; border-color: #3a3a4a; }
  .mt-ctrl.on { background: #67e8f9; border-color: #67e8f9; color: #0a0a0c; }
  .mt-ctrl.off { background: rgba(220,38,38,0.85); border-color: #dc2626; color: #fff; }
  .mt-ctrl.purple { background: #a78bfa; border-color: #a78bfa; color: #0a0a0c; }
  .mt-ctrl.end {
    width: auto; padding: 0 22px; border-radius: 999px;
    background: #dc2626; border-color: #dc2626; color: #fff;
    font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase;
    gap: 6px;
  }
  .mt-ctrl.end:hover { background: #b91c1c; }
  .mt-ctrl-label {
    position: absolute; bottom: -16px;
    font-family: 'Geist Mono', monospace; font-size: 8.5px;
    color: #6e6e78; letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap; pointer-events: none;
    opacity: 0;
  }
  .mt-ctrl:hover .mt-ctrl-label { opacity: 1; }

  /* Reactions popover */
  .mt-rx-pop {
    position: absolute;
    bottom: 60px;
    left: 50%; transform: translateX(-50%);
    display: none;
    background: #1a1a25;
    border: 1px solid #2a2a35;
    border-radius: 12px;
    padding: 8px;
    gap: 4px;
    z-index: 50;
  }
  .mt-rx-pop.open { display: flex; }
  .mt-rx-pop button {
    width: 40px; height: 40px;
    background: transparent; border: none;
    border-radius: 8px; cursor: pointer;
    color: #fbbf24;
    display: inline-flex; align-items: center; justify-content: center;
  }
  .mt-rx-pop button svg { width: 22px; height: 22px; }
  .mt-rx-pop button:hover { background: rgba(251,191,36,0.15); }

  /* More menu */
  .mt-more {
    position: absolute;
    bottom: 60px;
    left: 50%; transform: translateX(-50%);
    display: none;
    background: #1a1a25;
    border: 1px solid #2a2a35;
    border-radius: 10px;
    padding: 6px;
    min-width: 220px;
    flex-direction: column;
    z-index: 50;
  }
  .mt-more.open { display: flex; }
  .mt-more button {
    background: transparent; border: none;
    color: #e8e8ee; text-align: left;
    padding: 9px 12px; border-radius: 6px;
    cursor: pointer; font-size: 13px;
    display: flex; align-items: center; gap: 9px;
  }
  .mt-more button:hover { background: #22222e; }
  .mt-more button svg { width: 14px; height: 14px; color: #67e8f9; }
  .mt-more hr { border: 0; border-top: 1px solid #2a2a35; margin: 4px 0; }

  /* ---------- MODALS ---------- */
  .mt-modal-bg {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.72);
    display: none;
    align-items: center; justify-content: center;
    z-index: 100;
    padding: 16px;
  }
  .mt-modal-bg.open { display: flex; }
  .mt-modal {
    background: #11131a;
    border: 1px solid #2a2a35;
    border-radius: 14px;
    padding: 22px;
    width: 100%;
    max-width: 520px;
    max-height: 90vh;
    overflow-y: auto;
  }
  .mt-modal h3 { font-family: 'Cormorant Garamond', serif; font-size: 22px; margin: 0 0 14px; color: #e8e8ee; }
  .mt-modal label { display: block; font-family: 'Geist Mono', monospace; font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase; color: #9aa6b6; font-weight: 700; margin-bottom: 6px; margin-top: 10px; }
  .mt-modal input[type=text], .mt-modal input[type=number], .mt-modal textarea, .mt-modal select {
    width: 100%; box-sizing: border-box;
    background: #0a0a0c; border: 1px solid #2a2a35;
    color: #e8e8ee; padding: 9px 11px;
    border-radius: 6px; font-family: 'DM Sans', sans-serif; font-size: 13px; outline: none;
  }
  .mt-modal textarea { min-height: 60px; resize: vertical; }
  .mt-modal-row { display: flex; gap: 8px; align-items: center; margin-top: 6px; }
  .mt-modal-row input { flex: 1; }
  .mt-modal-row button { background: #1a1a25; border: 1px solid #2a2a35; color: #cfd6da; padding: 7px 10px; border-radius: 5px; cursor: pointer; font-size: 11px; font-family: 'Geist Mono', monospace; }
  .mt-modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 18px; }

  /* Help overlay */
  .mt-help {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.85);
    display: none;
    align-items: center; justify-content: center;
    z-index: 200;
    padding: 16px;
  }
  .mt-help.open { display: flex; }
  .mt-help-card {
    background: #11131a;
    border: 1px solid #2a2a35;
    border-radius: 14px;
    padding: 28px;
    max-width: 460px;
    width: 100%;
  }
  .mt-help-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 26px; margin: 0 0 18px; }
  .mt-help-card table { width: 100%; }
  .mt-help-card td { padding: 7px 4px; font-size: 13px; }
  .mt-help-card td:first-child { font-family: 'Geist Mono', monospace; color: #67e8f9; font-weight: 700; width: 100px; font-size: 12px; }

  /* Lobby state */
  .mt-lobby {
    position: fixed; inset: 0;
    background: #0a0a0c;
    display: flex; align-items: center; justify-content: center;
    z-index: 300;
    padding: 16px;
  }
  .mt-lobby-card {
    background: #11131a;
    border: 1px solid #2a2a35;
    border-radius: 14px;
    padding: 36px;
    max-width: 480px; width: 100%;
    text-align: center;
  }
  .mt-lobby-card h2 { font-family: 'Cormorant Garamond', serif; font-size: 30px; margin: 0 0 8px; }
  .mt-lobby-card p { color: #9aa6b6; font-size: 14px; line-height: 1.6; margin: 0 0 20px; }

  /* Breakouts panel */
  .mt-bo-item {
    background: #0a0a0c; border: 1px solid #2a2a35;
    border-radius: 8px; padding: 10px;
    margin-bottom: 8px;
  }
  .mt-bo-label { font-weight: 600; color: #e8e8ee; margin-bottom: 4px; }
  .mt-bo-meta { font-family: 'Geist Mono', monospace; font-size: 10px; color: #9aa6b6; letter-spacing: 0.08em; }
  .mt-bo-parts { margin-top: 6px; display: flex; flex-wrap: wrap; gap: 4px; }
  .mt-bo-parts span { background: rgba(103,232,249,0.12); color: #67e8f9; padding: 2px 7px; border-radius: 999px; font-size: 11px; }

  /* Toast */
  .mt-toast {
    position: fixed; left: 50%; bottom: 110px;
    transform: translateX(-50%);
    background: #1a1a25;
    border: 1px solid #2a2a35;
    color: #e8e8ee;
    padding: 10px 18px; border-radius: 8px;
    font-size: 13px;
    z-index: 500;
    display: none;
    box-shadow: 0 8px 24px rgba(0,0,0,0.5);
  }
  .mt-toast.show { display: block; animation: toastIn 0.3s; }
  @keyframes toastIn { from { opacity: 0; transform: translate(-50%, 10px); } to { opacity: 1; transform: translate(-50%, 0); } }

  /* Misc */
  .hidden { display: none !important; }
  .mt-empty { padding: 20px; text-align: center; color: #6e6e78; font-size: 12.5px; }
</style>

<main class="mt-shell">

  <!-- ============ TOP BAR ============ -->
  <div class="mt-top">
    <div class="mt-top-left">
      <input id="roomTitle" class="mt-title" value={roomTitle} readonly={!isHost} data-host={isHost ? '1' : '0'} maxlength="120"/>
      <span class="mt-pill kind">{roomKind.toUpperCase()}</span>
      {isHost && <span class="mt-pill host">HOST</span>}
      {isLocked && <span class="mt-pill" style="color:#fbbf24;border-color:rgba(251,191,36,0.4);background:rgba(251,191,36,0.08);">LOCKED</span>}
      <span class="mt-pill rec hidden" id="recPill"><span class="dot"></span> RECORDING</span>
    </div>
    <div class="mt-top-right">
      <span class="mt-pill e2e">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="11" height="11"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        E2E ENCRYPTED
      </span>
      <span class="mt-pill" id="attendeeCount">{participants.length} IN ROOM</span>
      <button class="mt-btn cyan" id="copyInvite">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        Copy invite
      </button>
    </div>
  </div>

  <!-- ============ BODY ============ -->
  <div class="mt-body" id="meetBody">

    <div class="mt-stage" id="stage">
      <div class="mt-grid" id="tileGrid" data-count="2"></div>

      <!-- Captions strip -->
      <div class="mt-captions" id="captionsStrip"></div>

      <!-- Reactions float -->
      <div class="mt-rx-layer" id="reactionsLayer"></div>
    </div>

    <!-- Right Panel -->
    <aside class="mt-panel" id="rightPanel">
      <div class="mt-panel-tabs">
        <button class="mt-panel-tab active" data-tab="chat">Chat</button>
        <button class="mt-panel-tab" data-tab="people">People</button>
        <button class="mt-panel-tab" data-tab="polls">Polls</button>
        <button class="mt-panel-tab" data-tab="board">Board</button>
        <button class="mt-panel-tab" data-tab="captions">Captions</button>
        <button class="mt-panel-tab" data-tab="apps">Apps</button>
      </div>

      <div class="mt-panel-body">

        <!-- CHAT -->
        <section class="mt-panel-section active" data-tab-body="chat">
          <div class="mt-chat-list" id="chatList">
            {chat.map(c => (
              <div class="mt-chat-msg">
                <div class="mt-chat-from">
                  <span>{c.display_name || 'Unknown'}</span>
                  {c.is_private_to && <span class="priv">PRIVATE</span>}
                </div>
                <div class="mt-chat-body">{c.body}</div>
              </div>
            ))}
            {chat.length === 0 && <div class="mt-empty">No messages yet. Say hello.</div>}
          </div>
          <div class="mt-chat-form">
            <div class="mt-chat-priv">
              <span>To:</span>
              <select id="chatTo">
                <option value="">Everyone</option>
                {participants.filter((p:any) => p.user_id !== user.id).map((p:any) => (
                  <option value={p.user_id}>{p.display_name} (private)</option>
                ))}
              </select>
            </div>
            <textarea class="mt-chat-input" id="chatInput" placeholder="Type a message - Enter to send, Shift+Enter newline"></textarea>
            <button class="mt-btn primary" id="chatSend">Send</button>
          </div>
        </section>

        <!-- PEOPLE -->
        <section class="mt-panel-section" data-tab-body="people">
          <input class="mt-pl-search" id="peopleSearch" placeholder="Search people..."/>

          {isHost && (
            <div style="display:flex;gap:6px;margin-bottom:10px;">
              <button class="mt-btn" id="muteAllBtn" style="flex:1;">Mute all</button>
              <button class="mt-btn" id="lockBtn" style="flex:1;">{isLocked ? 'Unlock' : 'Lock'}</button>
            </div>
          )}

          <div class="mt-pl-section-title">In the room <span style="color:#9aa6b6;">({participants.filter((p:any) => !p.in_lobby).length})</span></div>
          <div id="peopleList">
            {participants.filter((p:any) => !p.in_lobby).map((p:any) => (
              <div class="mt-pl-item" data-uid={p.user_id}>
                <div class="mt-pl-av" style={`background: hsl(${Math.abs((p.display_name||'').split('').reduce((a:number,c:string)=>a+c.charCodeAt(0),0)) % 360}, 60%, 45%);`}>
                  {(p.display_name || '?').slice(0,1).toUpperCase()}
                </div>
                <div class="mt-pl-name">
                  {p.display_name}
                  {p.user_id === user.id && <span style="color:#9aa6b6;font-size:11px;"> (you)</span>}
                  <div class="mt-pl-role">{p.role}</div>
                </div>
                {isHost && p.user_id !== user.id && (
                  <div class="mt-pl-ctrls">
                    <button class="mt-pl-ctrl" title="Ask to mute" data-act="ask-mute">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
                    </button>
                    <button class="mt-pl-ctrl danger" title="Remove" data-act="remove">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                  </div>
                )}
              </div>
            ))}
          </div>

          {participants.filter((p:any) => p.in_lobby).length > 0 && (
            <>
              <div class="mt-pl-section-title" style="color:#fbbf24;">In the lobby <span style="color:#9aa6b6;">({participants.filter((p:any) => p.in_lobby).length})</span></div>
              {participants.filter((p:any) => p.in_lobby).map((p:any) => (
                <div class="mt-pl-item">
                  <div class="mt-pl-av" style="background:#fbbf24;color:#0a0a0c;">{(p.display_name || '?').slice(0,1).toUpperCase()}</div>
                  <div class="mt-pl-name">{p.display_name}<div class="mt-pl-role">waiting</div></div>
                  {isHost && <button class="mt-pl-ctrl" title="Admit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></button>}
                </div>
              ))}
            </>
          )}

          {breakouts.length > 0 && (
            <>
              <div class="mt-pl-section-title">Active breakouts</div>
              {breakouts.map((b:any) => (
                <div class="mt-bo-item">
                  <div class="mt-bo-label">{b.label}</div>
                  <div class="mt-bo-meta">Ends {new Date(b.ends_at).toLocaleTimeString()}</div>
                  <div class="mt-bo-parts">{(Array.isArray(b.participants) ? b.participants : []).map((p:string) => <span>{p}</span>)}</div>
                </div>
              ))}
            </>
          )}

          {isHost && (
            <button class="mt-btn purple" id="createBreakoutBtn" style="width:100%;margin-top:12px;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
              Create breakouts
            </button>
          )}
        </section>

        <!-- POLLS -->
        <section class="mt-panel-section" data-tab-body="polls">
          {isHost && (
            <button class="mt-btn primary" id="newPollBtn" style="width:100%;margin-bottom:12px;">+ New poll</button>
          )}
          <div id="pollList">
            {polls.map((p:any) => {
              const opts = Array.isArray(p.options) ? p.options : [];
              const votes = p.votes && typeof p.votes === 'object' ? p.votes : {};
              const total = Object.keys(votes).length;
              const counts: any = {};
              opts.forEach((o:string) => { counts[o] = 0; });
              Object.values(votes).forEach((v:any) => { if (counts[v] !== undefined) counts[v]++; });
              return (
                <div class="mt-poll" data-poll={p.id}>
                  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                    <span class={`mt-poll-status ${p.status}`}>{p.status.toUpperCase()}</span>
