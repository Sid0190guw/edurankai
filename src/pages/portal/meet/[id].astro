<script is:inline define:vars={{ roomId: room?.id || id, isHost, userId: user.id, myDisplayName, isRecordingFlag: isRecording, isLockedFlag: isLocked }}>
/* ==========================================================================
   MEETING ROOM — REAL WORKING WEBRTC
   Hand-rolled. No 3rd-party libraries.

   Pipeline:
     1. getUserMedia()  -> local stream
     2. Local RTCPeerConnection loopback to prove the WebRTC pipeline
        (offer/answer between two PCs in the same tab, like a self-signaling
         demo — this is the real WebRTC API, not a mock).
     3. RTCDataChannel for chat + whiteboard strokes.
     4. getDisplayMedia() for screen sharing.
     5. MediaRecorder over a captureStream of a composed canvas for recording.
     6. SpeechRecognition (webkit fallback) for captions.
     7. Background blur via Canvas2D filter + captureStream.
   ========================================================================== */

const $ = (s) => document.querySelector(s);
const $$ = (s) => Array.from(document.querySelectorAll(s));

const state = {
  localStream: null,
  blurredStream: null,
  screenStream: null,
  recorder: null,
  recording: false,
  recordChunks: [],
  pcLocal: null,
  pcRemote: null,
  dc: null,
  audioOn: true,
  videoOn: true,
  blurOn: false,
  capOn: false,
  recog: null,
  handRaised: false,
  pinnedId: null,
  panelOpen: true,
  activeTab: 'chat',
  participants: [
    { id: userId, name: myDisplayName + ' (you)', muted: false, camOff: false, hand: false, isLocal: true, signal: 3, color: hsl(userId), isHost: !!isHost, role: isHost ? 'host' : 'attendee' },
  ],
  startedAt: Date.now(),
  pushToTalk: false,
  audioCtx: null,
  musicNodes: [],
  notesText: '',
  timerSeconds: 300,
  timerInterval: null,
  timerRunning: false,
  meetingClockInterval: null,
  ptt: false,
};

/* ---------- helpers ---------- */
function toast(msg) {
  const t = $('#toast'); t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2400);
}
function hsl(str) {
  let h = 0; for (let i = 0; i < (str||'').length; i++) h = (h * 31 + str.charCodeAt(i)) >>> 0;
  return `hsl(${h % 360}, 60%, 45%)`;
}
function nowStamp() {
  const d = new Date();
  return d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
}
function escapeHtml(s) {
  return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

/* ==========================================================================
   1. GET USER MEDIA  -> local stream
   ========================================================================== */
async function startLocalMedia() {
  try {
    state.localStream = await navigator.mediaDevices.getUserMedia({
      video: { width: { ideal: 1280 }, height: { ideal: 720 }, facingMode: 'user' },
      audio: { echoCancellation: true, noiseSuppression: true, autoGainControl: true }
    });
    $('#localVideoPipe').srcObject = state.localStream;
    renderTiles();
    populateDeviceLists();
    return true;
  } catch (e) {
    toast('Camera/mic permission denied — joining audio-off');
    state.audioOn = false; state.videoOn = false;
    updateMicBtn(); updateCamBtn();
    return false;
  }
}

async function populateDeviceLists() {
  try {
    const devs = await navigator.mediaDevices.enumerateDevices();
    const cams = devs.filter(d => d.kind === 'videoinput');
    const mics = devs.filter(d => d.kind === 'audioinput');
    const spks = devs.filter(d => d.kind === 'audiooutput');
    if (cams.length) {
      $('#camSelect').innerHTML = cams.map(d => `<option value="${d.deviceId}">${escapeHtml(d.label || 'Camera')}</option>`).join('');
    }
    if (mics.length) {
      $('#micSelect').innerHTML = mics.map(d => `<option value="${d.deviceId}">${escapeHtml(d.label || 'Mic')}</option>`).join('');
    }
    if (spks.length) {
      $('#spkSelect').innerHTML = spks.map(d => `<option value="${d.deviceId}">${escapeHtml(d.label || 'Speaker')}</option>`).join('');
    }
  } catch {}
}

/* ==========================================================================
   2. LOOPBACK RTCPeerConnection — real WebRTC pipeline
   We negotiate offer/answer between two PCs in this tab to prove the API
   actually works without needing a signaling server.
   ========================================================================== */
async function startLoopbackPC() {
  if (!state.localStream) return;
  state.pcLocal = new RTCPeerConnection({ iceServers: [{ urls: 'stun:stun.l.google.com:19302' }] });
  state.pcRemote = new RTCPeerConnection({ iceServers: [{ urls: 'stun:stun.l.google.com:19302' }] });

  // ICE candidate trickle between the two
  state.pcLocal.onicecandidate = e => e.candidate && state.pcRemote.addIceCandidate(e.candidate).catch(()=>{});
  state.pcRemote.onicecandidate = e => e.candidate && state.pcLocal.addIceCandidate(e.candidate).catch(()=>{});

  // The "remote" peer receives our tracks
  const inboundStream = new MediaStream();
  state.pcRemote.ontrack = (e) => {
    e.streams[0].getTracks().forEach(t => inboundStream.addTrack(t));
    const peerVid = $('#peerVideoPipe');
    peerVid.srcObject = inboundStream;
    // Add a "peer 1 (echo)" participant tile to show the loopback works
    if (!state.participants.find(p => p.id === 'peer-loopback')) {
      state.participants.push({
        id: 'peer-loopback',
        name: 'Loopback peer',
        muted: false, camOff: false, hand: false,
        signal: 3, isLocal: false, color: '#67e8f9',
        srcObject: inboundStream, isHost: false, role: 'attendee'
      });
      renderTiles();
    }
  };

  // Data channel for chat & whiteboard strokes
  state.dc = state.pcLocal.createDataChannel('rtc-data', { ordered: true });
  state.dc.onopen = () => console.log('[DataChannel] open');
  state.dc.onmessage = (e) => onDataChannelMessage(e.data);

  state.pcRemote.ondatachannel = (e) => {
    e.channel.onmessage = (ev) => onDataChannelMessage(ev.data);
  };

  // Add our local tracks
  state.localStream.getTracks().forEach(t => state.pcLocal.addTrack(t, state.localStream));

  // Offer / Answer
  const offer = await state.pcLocal.createOffer();
  await state.pcLocal.setLocalDescription(offer);
  await state.pcRemote.setRemoteDescription(offer);
  const answer = await state.pcRemote.createAnswer();
  await state.pcRemote.setLocalDescription(answer);
  await state.pcLocal.setRemoteDescription(answer);
}

function onDataChannelMessage(raw) {
  try {
    const msg = JSON.parse(raw);
    if (msg.type === 'chat') {
      appendChatMsg({ display_name: msg.from || 'Peer', body: msg.body, is_private_to: null });
    } else if (msg.type === 'stroke') {
      drawRemoteStroke(msg);
    } else if (msg.type === 'reaction') {
      flyReaction(msg.kind);
    }
  } catch {}
}

/* ==========================================================================
   3. SCREEN SHARE — getDisplayMedia
   ========================================================================== */
async function startScreenShare() {
  if (state.screenStream) return stopScreenShare();
  try {
    state.screenStream = await navigator.mediaDevices.getDisplayMedia({
      video: { frameRate: 30 },
      audio: true
    });
    state.screenStream.getVideoTracks()[0].onended = () => stopScreenShare();
    renderTiles();
    $('#shareBtn').classList.add('on');
    toast('Sharing screen');
  } catch (e) { toast('Share cancelled'); }
}
function stopScreenShare() {
  if (state.screenStream) state.screenStream.getTracks().forEach(t => t.stop());
  state.screenStream = null;
  $('#shareBtn').classList.remove('on');
  renderTiles();
}

/* ==========================================================================
   4. RECORDING — MediaRecorder over a composed canvas captureStream
   ========================================================================== */
function startRecording() {
  try {
    const canvas = $('#recordCanvas');
    const ctx = canvas.getContext('2d');
    const recStream = canvas.captureStream(24);

    // Mix audio: local mic + screen audio
    state.audioCtx = state.audioCtx || new (window.AudioContext || window.webkitAudioContext)();
    const dest = state.audioCtx.createMediaStreamDestination();
    if (state.localStream) {
      const a = state.audioCtx.createMediaStreamSource(state.localStream);
      a.connect(dest);
    }
    if (state.screenStream && state.screenStream.getAudioTracks().length) {
      const a = state.audioCtx.createMediaStreamSource(state.screenStream);
      a.connect(dest);
    }
    dest.stream.getAudioTracks().forEach(t => recStream.addTrack(t));

    // Composer draw loop
    function frame() {
      if (!state.recording) return;
      ctx.fillStyle = '#0a0a0c';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      const tiles = $$('.mt-tile video');
      if (tiles.length === 0) {
        ctx.fillStyle = '#e8e8ee';
        ctx.font = '28px "Cormorant Garamond", serif';
        ctx.fillText('No video', 40, 60);
      } else {
        const cols = Math.ceil(Math.sqrt(tiles.length));
        const rows = Math.ceil(tiles.length / cols);
        const w = canvas.width / cols, h = canvas.height / rows;
        tiles.forEach((v, i) => {
          const cx = (i % cols) * w, cy = Math.floor(i / cols) * h;
          try { ctx.drawImage(v, cx + 4, cy + 4, w - 8, h - 8); } catch {}
        });
      }
      ctx.fillStyle = '#FF4F00';
      ctx.beginPath(); ctx.arc(24, 24, 8, 0, Math.PI*2); ctx.fill();
      ctx.fillStyle = '#fff'; ctx.font = '14px "Geist Mono", monospace';
      const t = Math.floor((Date.now() - state.startedAt) / 1000);
      ctx.fillText(`${String(Math.floor(t/60)).padStart(2,'0')}:${String(t%60).padStart(2,'0')}  REC`, 42, 30);
      requestAnimationFrame(frame);
    }

    const mime = MediaRecorder.isTypeSupported('video/webm;codecs=vp9') ? 'video/webm;codecs=vp9' : 'video/webm';
    state.recorder = new MediaRecorder(recStream, { mimeType: mime, videoBitsPerSecond: 2_500_000 });
    state.recordChunks = [];
    state.recorder.ondataavailable = (e) => e.data.size && state.recordChunks.push(e.data);
    state.recorder.onstop = () => {
      const blob = new Blob(state.recordChunks, { type: 'video/webm' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url; a.download = `meeting-${Date.now()}.webm`;
      a.click(); setTimeout(() => URL.revokeObjectURL(url), 4000);
      toast('Recording saved');
    };
    state.recorder.start(1000);
    state.recording = true;
    requestAnimationFrame(frame);
    $('#recPill').classList.remove('hidden');
    $('#recLabel').textContent = 'Stop recording';
    toast('Recording started');
  } catch (e) {
    toast('Recording unavailable: ' + e.message);
  }
}
function stopRecording() {
  if (state.recorder && state.recording) {
    state.recording = false;
    try { state.recorder.stop(); } catch {}
    $('#recPill').classList.add('hidden');
    $('#recLabel').textContent = 'Start recording';
  }
}

/* ==========================================================================
   5. BACKGROUND BLUR — Canvas2D filter + captureStream
   ========================================================================== */
let blurRafId = null;
function startBlur() {
  if (!state.localStream || state.blurOn) return;
  const srcVid = $('#localVideoPipe');
  const cv = $('#blurCanvas');
  const cx = cv.getContext('2d');
  state.blurOn = true;
  $('#blurState').textContent = 'ON';
  function loop() {
    if (!state.blurOn) return;
    if (srcVid.readyState >= 2) {
      // Strong blur on full frame, then re-composite centre band crisp
      cx.filter = 'blur(14px) brightness(0.9)';
      cx.drawImage(srcVid, 0, 0, cv.width, cv.height);
      cx.filter = 'none';
      // Crisp centre — naive subject area
      const w = cv.width, h = cv.height;
      const cw = w * 0.55, ch = h * 0.7;
      const cxp = (w - cw)/2, cyp = (h - ch)/2;
      cx.save();
      cx.beginPath();
      cx.ellipse(w/2, h/2, cw/2, ch/2, 0, 0, Math.PI * 2);
      cx.clip();
      cx.drawImage(srcVid, 0, 0, w, h);
      cx.restore();
    }
    blurRafId = requestAnimationFrame(loop);
  }
  loop();
  state.blurredStream = cv.captureStream(24);
  // Replace local video tile with blurred stream
  renderTiles();
}
function stopBlur() {
  state.blurOn = false;
  $('#blurState').textContent = 'OFF';
  if (blurRafId) cancelAnimationFrame(blurRafId);
  if (state.blurredStream) state.blurredStream.getTracks().forEach(t => t.stop());
  state.blurredStream = null;
  renderTiles();
}

/* ==========================================================================
   6. LIVE CAPTIONS — Web Speech API (browser-native)
   ========================================================================== */
function startCaptions() {
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) { toast('Captions not supported in this browser'); return; }
  state.recog = new SR();
  state.recog.continuous = true;
  state.recog.interimResults = true;
  state.recog.lang = navigator.language || 'en-US';
  state.recog.onresult = (e) => {
    let interim = '', final = '';
    for (let i = e.resultIndex; i < e.results.length; i++) {
      const r = e.results[i];
      if (r.isFinal) final += r[0].transcript;
      else interim += r[0].transcript;
    }
    const strip = $('#captionsStrip');
    strip.classList.add('on');
    strip.textContent = (final || interim).slice(-180);
    if (final.trim()) {
      const log = $('#capLog');
      const empty = log.querySelector('.mt-empty');
      if (empty) empty.remove();
      const line = document.createElement('div');
      line.className = 'mt-cap-line';
      line.innerHTML = `<span class="ts">${nowStamp()} - ${escapeHtml(myDisplayName)}</span>${escapeHtml(final.trim())}`;
      log.appendChild(line);
      log.scrollTop = log.scrollHeight;
    }
  };
  state.recog.onerror = () => {};
  state.recog.onend = () => { if (state.capOn) try { state.recog.start(); } catch {} };
  try { state.recog.start(); state.capOn = true; $('#capState').textContent = 'ON'; $('#capToggle').textContent = 'Stop captions'; toast('Captions on'); } catch {}
}
function stopCaptions() {
  if (state.recog) { try { state.recog.stop(); } catch {} state.recog = null; }
  state.capOn = false;
  $('#captionsStrip').classList.remove('on');
  $('#capState').textContent = 'OFF';
  $('#capToggle').textContent = 'Start captions';
}

/* ==========================================================================
   TILE RENDERING — auto-arranging grid
   ========================================================================== */
function renderTiles() {
  const grid = $('#tileGrid');
  const hasShare = !!state.screenStream;
  grid.className = 'mt-grid' + (hasShare ? ' share-on' : '');

  let html = '';

  if (hasShare) {
    html += `
      <div class="mt-tile share-tile">
        <video autoplay playsinline id="shareVideo"></video>
        <div class="mt-tile-overlay">
          <span class="mt-tile-name">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="11" height="11"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/></svg>
            ${escapeHtml(myDisplayName)} - presenting
          </span>
        </div>
      </div>
      <div class="tile-strip" id="tileStrip"></div>
    `;
  } else {
    const n = state.participants.length;
    grid.setAttribute('data-count', String(Math.min(n, 49)));
  }

  const tileHtml = (p) => {
    const isMe = p.isLocal;
    const ringClass = (state.pinnedId === p.id) ? ' pinned' : '';
    const signalClass = `s${p.signal || 3}`;
    return `
      <div class="mt-tile${ringClass}" data-pid="${escapeHtml(p.id)}">
        ${(isMe || p.srcObject) ? `<video autoplay playsinline ${isMe ? 'muted' : ''} id="vid-${escapeHtml(p.id)}"></video>` : ''}
        ${(!isMe && !p.srcObject) ? `<div class="placeholder" style="background: linear-gradient(135deg, ${p.color}, #0c0e14);">${escapeHtml((p.name||'?').slice(0,1).toUpperCase())}</div>` : ''}
        <div class="mt-signal ${signalClass}"><span></span><span></span><span></span></div>
        <div class="mt-tile-overlay">
          <span class="mt-tile-name">
            ${p.muted ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="10" height="10"><line x1="1" y1="1" x2="23" y2="23"/><path d="M9 9v3a3 3 0 0 0 5.12 2.12M15 9.34V4a3 3 0 0 0-5.94-.6"/><path d="M17 16.95A7 7 0 0 1 5 12v-2m14 0v2a7 7 0 0 1-.11 1.23"/><line x1="12" y1="19" x2="12" y2="22"/></svg>' : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="10" height="10"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>'}
            ${escapeHtml(p.name)}
          </span>
          <div class="mt-tile-icons">
            ${p.hand ? '<span class="mt-tile-icon hand"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 11V6a2 2 0 0 0-4 0v5"/><path d="M14 10V4a2 2 0 0 0-4 0v6"/><path d="M10 10.5V6a2 2 0 0 0-4 0v8.5"/></svg></span>' : ''}
            ${p.camOff ? '<span class="mt-tile-icon cam-off"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="1" y1="1" x2="23" y2="23"/><path d="M16 16v3a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h3m11.5-1l4.5-2v12L17 11"/></svg></span>' : ''}
            ${state.pinnedId === p.id ? '<span class="mt-tile-icon pin"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L8 8H4l5 5-2 9 5-5 5 5-2-9 5-5h-4z"/></svg></span>' : ''}
          </div>
        </div>
      </div>
    `;
  };

  if (hasShare) {
    const inner = state.participants.slice(0, 6).map(tileHtml).join('');
    html = html.replace('<div class="tile-strip" id="tileStrip"></div>', `<div class="tile-strip" id="tileStrip">${inner}</div>`);
  } else {
    html += state.participants.slice(0, 49).map(tileHtml).join('');
  }

  grid.innerHTML = html;

  // Wire video srcObjects after DOM update
  state.participants.forEach(p => {
    const v = document.getElementById('vid-' + p.id);
    if (!v) return;
    if (p.isLocal) {
      v.srcObject = state.blurOn && state.blurredStream ? state.blurredStream : state.localStream;
    } else if (p.srcObject) {
      v.srcObject = p.srcObject;
    }
  });
  if (hasShare) {
    const sv = $('#shareVideo'); if (sv) sv.srcObject = state.screenStream;
  }

  // Wire tile click -> pin
  $$('.mt-tile').forEach(t => {
    t.addEventListener('click', () => {
      const pid = t.getAttribute('data-pid');
      state.pinnedId = state.pinnedId === pid ? null : pid;
      renderTiles();
    });
  });

  // Update attendee count
  $('#attendeeCount').textContent = `${state.participants.length} IN ROOM`;
}

/* ==========================================================================
   ACTIVE-SPEAKER DETECTION via WebAudio analyser on local stream
   ========================================================================== */
function startActiveSpeakerDetection() {
  if (!state.localStream) return;
  try {
    const ac = state.audioCtx = state.audioCtx || new (window.AudioContext || window.webkitAudioContext)();
    const src = ac.createMediaStreamSource(state.localStream);
    const analyser = ac.createAnalyser();
    analyser.fftSize = 512;
    src.connect(analyser);
    const buf = new Uint8Array(analyser.frequencyBinCount);
    function tick() {
      analyser.getByteTimeDomainData(buf);
      let max = 0;
      for (let i = 0; i < buf.length; i++) max = Math.max(max, Math.abs(buf[i] - 128));
      const speaking = !state.participants[0].muted && max > 14;
      const myTile = document.querySelector(`.mt-tile[data-pid="${userId}"]`);
      $$('.mt-tile').forEach(t => t.classList.remove('active-speaker'));
      if (speaking && myTile) myTile.classList.add('active-speaker');
      requestAnimationFrame(tick);
    }
    tick();
  } catch {}
}

