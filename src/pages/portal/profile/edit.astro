---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getApplicantProfile, updateProfile, setProfilePublic } from '@/lib/applicant-profile';
import { publicOrigin } from '@/lib/public-url';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/profile/edit'));
if (user.role !== 'applicant') return Astro.redirect('/admin');

let okMsg = '';
let errMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('_action');
  try {
    if (action === 'toggle_public') {
      const makePublic = fd.get('isPublic') === 'on';
      const existing = await getApplicantProfile(user.id);
      const c = (existing?.common || {}) as any;
      const name = ((c.firstName || '') + ' ' + (c.lastName || '')).trim() || (user.email || 'member');
      await setProfilePublic(user.id, makePublic, name);
      okMsg = makePublic ? 'Your profile is now public.' : 'Your profile is now private.';
    } else if (action === 'save') {
      const existing = await getApplicantProfile(user.id);
      const prevCommon = (existing?.common || {}) as any;
      const common = {
        ...prevCommon,
        firstName: (fd.get('firstName') as string || '').trim(),
        lastName: (fd.get('lastName') as string || '').trim(),
        currentCity: (fd.get('currentCity') as string || '').trim(),
        phone: (fd.get('phone') as string || '').trim(),
        photoUrl: (fd.get('photoUrl') as string || '').trim(),
      };
      const skills = (fd.get('skills') as string || '').split(',').map((s) => s.trim()).filter(Boolean).slice(0, 40);
      const links = {
        linkedin: (fd.get('linkedin') as string || '').trim(),
        github: (fd.get('github') as string || '').trim(),
        portfolio: (fd.get('portfolio') as string || '').trim(),
        twitter: (fd.get('twitter') as string || '').trim(),
      };
      const parseJson = (v: any) => { try { const a = JSON.parse(String(v || '[]')); return Array.isArray(a) ? a.slice(0, 30) : []; } catch { return []; } };
      await updateProfile(user.id, {
        headline: (fd.get('headline') as string || '').trim().slice(0, 160),
        bio: (fd.get('bio') as string || '').trim().slice(0, 4000),
        skills,
        links,
        experience: parseJson(fd.get('experienceJson')),
        education: parseJson(fd.get('educationJson')),
        common,
      });
      okMsg = 'Profile saved.';
    }
  } catch (e: any) { errMsg = 'Could not save. ' + (e?.cause?.message || e?.message || ''); }
}

const profile = await getApplicantProfile(user.id);
const c = (profile?.common || {}) as any;
const links = (profile?.links || {}) as any;
const skills: string[] = Array.isArray(profile?.skills) ? profile!.skills : [];
const experience: any[] = Array.isArray(profile?.experience) ? profile!.experience : [];
const education: any[] = Array.isArray(profile?.education) ? profile!.education : [];
const isPublic = !!profile?.is_public;
const slug = profile?.slug || '';
const origin = publicOrigin(Astro.request);
const shareUrl = slug ? origin + '/profile/' + slug : '';
---
<BaseLayout title="Edit profile - EduRankAI" description="Your applicant profile.">
  <section class="px-[5vw] py-8 md:py-12 max-w-3xl mx-auto">
    <div class="mb-6">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-1"><a href="/portal/profile" class="text-burn no-underline">&larr; Profile</a></p>
      <h1 class="font-display text-[clamp(1.6rem,4vw,2.2rem)] font-semibold text-ink leading-tight">Build your <em class="italic text-burn font-medium">profile</em> once.</h1>
      <p class="text-[0.9rem] text-ink-soft mt-2 leading-relaxed">Fill this in once — every new application pre-fills from here, and you can publish a shareable public profile.</p>
    </div>

    {okMsg && <div class="mb-5 bg-leaf-bg border border-leaf-border text-leaf rounded-xl px-4 py-3 text-[0.88rem]">{okMsg}</div>}
    {errMsg && <div class="mb-5 bg-burn-pale border border-burn-dim text-ink-2 rounded-xl px-4 py-3 text-[0.88rem]">{errMsg}</div>}

    <!-- Public share -->
    <div class="bg-white border border-ink/10 rounded-2xl p-5 mb-6">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div class="min-w-0">
          <p class="font-display text-[1.05rem] font-semibold text-ink">Public profile</p>
          <p class="text-[0.82rem] text-ink-soft mt-0.5 leading-relaxed">Turn this on to share a public link. Off = only you and our team can see it.</p>
        </div>
        <form method="POST" id="pubForm">
          <input type="hidden" name="_action" value="toggle_public" />
          <input type="hidden" name="isPublic" value={isPublic ? '' : 'on'} />
          <button type="submit" class={'relative inline-flex items-center rounded-full transition-colors ' + (isPublic ? 'bg-burn' : 'bg-ink/15')} style="width:52px;height:28px;" aria-label="Toggle public">
            <span class="absolute bg-white rounded-full transition-all" style={'width:22px;height:22px;top:3px;left:' + (isPublic ? '27px' : '3px') + ';'}></span>
          </button>
        </form>
      </div>
      {isPublic && shareUrl && (
        <div class="mt-4 flex items-center gap-2 bg-cream-2 border border-ink/10 rounded-lg px-3 py-2.5">
          <input id="shareUrl" readonly value={shareUrl} class="flex-1 bg-transparent border-0 outline-none text-[0.85rem] text-ink font-mono" />
          <button type="button" id="copyShare" class="text-[0.78rem] font-semibold text-burn whitespace-nowrap">Copy link</button>
          <a href={'/u/' + slug} target="_blank" rel="noopener" class="text-[0.78rem] font-semibold text-sky whitespace-nowrap no-underline">View</a>
        </div>
      )}
    </div>

    <form method="POST" id="profForm" class="space-y-6">
      <input type="hidden" name="_action" value="save" />

      <div class="bg-white border border-ink/10 rounded-2xl p-5">
        <p class="font-display text-[1.05rem] font-semibold text-ink mb-4">Identity</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div><label class="prof-l">First name</label><input name="firstName" value={c.firstName || ''} class="prof-i" /></div>
          <div><label class="prof-l">Last name</label><input name="lastName" value={c.lastName || ''} class="prof-i" /></div>
          <div><label class="prof-l">City</label><input name="currentCity" value={c.currentCity || ''} class="prof-i" /></div>
          <div><label class="prof-l">Phone</label><input name="phone" value={c.phone || ''} class="prof-i" /></div>
          <div class="sm:col-span-2"><label class="prof-l">Photo URL</label><input name="photoUrl" value={c.photoUrl || ''} placeholder="https://..." class="prof-i" /></div>
          <div class="sm:col-span-2"><label class="prof-l">Headline</label><input name="headline" value={profile?.headline || ''} maxlength="160" placeholder="e.g. ML engineer building verified-learning systems" class="prof-i" /></div>
        </div>
      </div>

      <div class="bg-white border border-ink/10 rounded-2xl p-5">
        <p class="font-display text-[1.05rem] font-semibold text-ink mb-3">About</p>
        <textarea name="bio" rows="5" maxlength="4000" placeholder="A few sentences about who you are and what you do." class="prof-i resize-y leading-relaxed">{profile?.bio || ''}</textarea>
      </div>

      <div class="bg-white border border-ink/10 rounded-2xl p-5">
        <p class="font-display text-[1.05rem] font-semibold text-ink mb-3">Skills &amp; links</p>
        <div class="mb-3"><label class="prof-l">Skills (comma-separated)</label><input name="skills" value={skills.join(', ')} placeholder="PyTorch, Distributed training, Research" class="prof-i" /></div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div><label class="prof-l">LinkedIn</label><input name="linkedin" value={links.linkedin || c.linkedin || ''} class="prof-i" /></div>
          <div><label class="prof-l">GitHub</label><input name="github" value={links.github || ''} class="prof-i" /></div>
          <div><label class="prof-l">Portfolio / website</label><input name="portfolio" value={links.portfolio || c.resumeLink || ''} class="prof-i" /></div>
          <div><label class="prof-l">Twitter / X</label><input name="twitter" value={links.twitter || ''} class="prof-i" /></div>
        </div>
      </div>

      <div class="bg-white border border-ink/10 rounded-2xl p-5">
        <div class="flex items-center justify-between mb-3">
          <p class="font-display text-[1.05rem] font-semibold text-ink">Experience</p>
          <button type="button" data-add="exp" class="text-[0.8rem] font-semibold text-burn">+ Add</button>
        </div>
        <div id="expList" class="space-y-3"></div>
        <input type="hidden" name="experienceJson" id="experienceJson" />
      </div>

      <div class="bg-white border border-ink/10 rounded-2xl p-5">
        <div class="flex items-center justify-between mb-3">
          <p class="font-display text-[1.05rem] font-semibold text-ink">Education</p>
          <button type="button" data-add="edu" class="text-[0.8rem] font-semibold text-burn">+ Add</button>
        </div>
        <div id="eduList" class="space-y-3"></div>
        <input type="hidden" name="educationJson" id="educationJson" />
      </div>

      <button type="submit" class="w-full bg-burn hover:bg-burn/90 text-white font-semibold py-3.5 rounded-lg text-[0.95rem] transition-all">Save profile</button>
    </form>
  </section>

  <style>
    .prof-l { display:block; font-size:0.7rem; font-family:ui-monospace,monospace; text-transform:uppercase; letter-spacing:0.08em; color:#9a5b3f; font-weight:700; margin-bottom:5px; }
    .prof-i { width:100%; background:#fff; border:1px solid rgba(26,21,16,0.15); border-radius:9px; padding:10px 12px; font-size:0.9rem; color:#1a1510; outline:none; }
    .prof-i:focus { border-color:#FF4F00; }
    .prof-row input { width:100%; background:#fbf6f1; border:1px solid rgba(26,21,16,0.12); border-radius:8px; padding:8px 10px; font-size:0.85rem; outline:none; }
    .prof-row input:focus { border-color:#FF4F00; background:#fff; }
  </style>

  <script is:inline define:vars={{ initExp: experience, initEdu: education }}>
    (function () {
      function row(kind, item) {
        item = item || {};
        var wrap = document.createElement('div');
        wrap.className = 'prof-row grid grid-cols-1 sm:grid-cols-2 gap-2 border border-ink/10 rounded-xl p-3';
        var fields = kind === 'exp'
          ? [['title','Role / title'],['org','Organisation'],['period','Period (e.g. 2023-2025)'],['detail','What you did']]
          : [['school','School / institution'],['degree','Degree / field'],['period','Period'],['detail','Notes (optional)']];
        fields.forEach(function (f) {
          var inp = document.createElement('input');
          inp.setAttribute('data-k', f[0]); inp.placeholder = f[1]; inp.value = item[f[0]] || '';
          if (f[0] === 'detail') inp.className = 'sm:col-span-2';
          wrap.appendChild(inp);
        });
        var del = document.createElement('button');
        del.type = 'button'; del.textContent = 'Remove';
        del.className = 'text-[0.72rem] text-ink-soft hover:text-burn sm:col-span-2 text-right';
        del.addEventListener('click', function () { wrap.remove(); });
        wrap.appendChild(del);
        return wrap;
      }
      function mount(kind, listId, initial) {
        var list = document.getElementById(listId);
        (initial || []).forEach(function (it) { list.appendChild(row(kind, it)); });
      }
      mount('exp', 'expList', initExp);
      mount('edu', 'eduList', initEdu);
      document.querySelectorAll('[data-add]').forEach(function (b) {
        b.addEventListener('click', function () {
          var kind = b.getAttribute('data-add');
          document.getElementById(kind === 'exp' ? 'expList' : 'eduList').appendChild(row(kind, {}));
        });
      });
      function serialize(listId) {
        var out = [];
        document.querySelectorAll('#' + listId + ' .prof-row').forEach(function (r) {
          var o = {}; var any = false;
          r.querySelectorAll('input[data-k]').forEach(function (i) { var v = (i.value || '').trim(); o[i.getAttribute('data-k')] = v; if (v) any = true; });
          if (any) out.push(o);
        });
        return JSON.stringify(out);
      }
      var form = document.getElementById('profForm');
      if (form) form.addEventListener('submit', function () {
        document.getElementById('experienceJson').value = serialize('expList');
        document.getElementById('educationJson').value = serialize('eduList');
      });
      var copyBtn = document.getElementById('copyShare');
      if (copyBtn) copyBtn.addEventListener('click', function () {
        var u = document.getElementById('shareUrl');
        if (u) { u.select(); try { navigator.clipboard.writeText(u.value); } catch (_) { document.execCommand('copy'); } copyBtn.textContent = 'Copied'; setTimeout(function () { copyBtn.textContent = 'Copy link'; }, 1500); }
      });
    })();
  </script>
</BaseLayout>
