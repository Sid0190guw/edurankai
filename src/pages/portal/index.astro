<script is:inline>
  // Quiet update-stamp on the applications section + close avatar menu on outside click.
  (function () {
    var stamp = document.querySelector('[data-applist-updated]');
    var start = Date.now();
    if (stamp) {
      setInterval(function () {
        var s = Math.round((Date.now() - start) / 1000);
        if (s < 5) stamp.textContent = 'Updated just now';
        else if (s < 60) stamp.textContent = 'Updated ' + s + 's ago';
        else if (s < 3600) stamp.textContent = 'Updated ' + Math.floor(s / 60) + ' min ago';
        else stamp.textContent = 'Updated ' + Math.floor(s / 3600) + ' h ago';
      }, 5000);
    }
    document.addEventListener('click', function (e) {
      var menus = document.querySelectorAll('details.menu[open]');
      menus.forEach(function (m) {
        if (!m.contains(e.target)) m.removeAttribute('open');
      });
    });
  })();
</script>
