---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { applications, applicationMessages } from '@/lib/db/schema';
import { eq, desc, sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
if (user.role !== 'applicant') return Astro.redirect('/admin');

// Auto-promote any legacy 'pending' account.
try {
  await db.execute(sql`UPDATE users SET access_status = 'approved', updated_at = NOW() WHERE id = ${user.id} AND access_status = 'pending'`);
} catch (_) {}

// Settle any "paid but still pending" application the moment the applicant
// returns: reconcile their recent open Razorpay orders so a captured payment
// materialises / flips the application to submitted right here (no waiting on
// the daily cron or a webhook).
try {
  const { reconcileUserPending } = await import('@/lib/payment-effects');
  await reconcileUserPending(user.id);
} catch (_) {}

// Active employee → employee portal.
try {
  const empCheck = await db.execute(sql`
    SELECT id, onboarding_status FROM hr_employees
    WHERE (personal_email = ${user.email} OR email = ${user.email} OR user_id = ${user.id}) AND is_active = true
    LIMIT 1
  `);
  const empRows = Array.isArray(empCheck) ? empCheck : (empCheck?.rows || []);
  if (empRows.length > 0) {
    if ((empRows[0] as any).onboarding_status === 'pending') return Astro.redirect('/portal/employee/onboarding');
    return Astro.redirect('/portal/employee');
  }
} catch(_) {}

// Applications + last message (single LATERAL join — no N+1).
let appsWithMessages: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT a.id, a.role_title_snapshot, a.department_snapshot, a.level, a.status,
      a.score, a.scoring_feedback, a.created_at, a.updated_at,
      m.body AS last_msg_body, m.sender_role AS last_msg_role,
      m.sender_name AS last_msg_name, m.is_system AS last_msg_system, m.created_at AS last_msg_at,
      COALESCE(unread.n, 0)::int AS unread_count
    FROM applications a
    LEFT JOIN LATERAL (
      SELECT body, sender_role, sender_name, is_system, created_at
      FROM application_messages
      WHERE application_id = a.id
      ORDER BY created_at DESC LIMIT 1
    ) m ON true
    LEFT JOIN LATERAL (
      SELECT COUNT(*)::int AS n
      FROM application_messages
      WHERE application_id = a.id AND sender_role = 'admin' AND COALESCE(read_by_applicant, false) = false
    ) unread ON true
    WHERE a.applicant_user_id = ${user.id}
    ORDER BY a.created_at DESC
  `);
  const rows = Array.isArray(r) ? r : ((r as any)?.rows || []);
  appsWithMessages = rows.map((row: any) => ({
    id: row.id,
    roleTitleSnapshot: row.role_title_snapshot,
    departmentSnapshot: row.department_snapshot,
    level: row.level,
    status: row.status,
    score: row.score,
    scoringFeedback: row.scoring_feedback,
    createdAt: row.created_at,
    updatedAt: row.updated_at,
    unreadCount: row.unread_count || 0,
    lastMessage: row.last_msg_body ? {
      body: row.last_msg_body,
      senderRole: row.last_msg_role,
      senderName: row.last_msg_name,
      isSystem: row.last_msg_system,
      createdAt: row.last_msg_at,
    } : null,
  }));
} catch (_) {
  // Fallback: minimal query if the read_by_applicant column doesn't exist.
  try {
    const apps = await db.select({
      id: applications.id,
      roleTitleSnapshot: applications.roleTitleSnapshot,
      departmentSnapshot: applications.departmentSnapshot,
      level: applications.level,
      status: applications.status,
      score: applications.score,
      scoringFeedback: applications.scoringFeedback,
      createdAt: applications.createdAt,
      updatedAt: applications.updatedAt
    }).from(applications)
      .where(eq(applications.applicantUserId, user.id))
      .orderBy(desc(applications.createdAt));
    for (const app of apps) {
      const lastMsgs = await db.select({
        body: applicationMessages.body,
        senderRole: applicationMessages.senderRole,
        senderName: applicationMessages.senderName,
        isSystem: applicationMessages.isSystem,
        createdAt: applicationMessages.createdAt
      }).from(applicationMessages)
        .where(eq(applicationMessages.applicationId, app.id))
        .orderBy(desc(applicationMessages.createdAt))
        .limit(1);
      appsWithMessages.push({ ...app, lastMessage: lastMsgs[0] || null, unreadCount: 0 });
    }
  } catch (_) {}
}

const firstName = user.name ? user.name.split(' ')[0] : 'there';

// Face 2FA enrollment status.
let faceEnrolled = false;
try {
  const fr = await db.execute(sql`SELECT id FROM user_face_enrollments WHERE user_id = ${user.id} AND is_active = true LIMIT 1`);
  const frows = Array.isArray(fr) ? fr : (fr?.rows || []);
  faceEnrolled = frows.length > 0;
} catch (_) {}

// Open admin↔applicant request threads.
let openRequests: any[] = [];
try {
  const { listApplicantRequests } = await import('@/lib/request-threads');
  openRequests = await listApplicantRequests(user.id);
} catch (_) {}

// Pending intents (unpaid application fees).
let pendingIntents: any[] = [];
try {
  const ri = await db.execute(sql`
    SELECT i.id, i.role_title_snapshot, i.department_snapshot, i.level, i.created_at,
      i.first_name, i.last_name,
      w.id AS waiver_id, w.status AS waiver_status
    FROM application_intents i
    LEFT JOIN application_fee_waivers w ON w.intent_id = i.id
    WHERE i.user_id = ${user.id}
    ORDER BY i.created_at DESC
    LIMIT 20
  `);
  pendingIntents = (Array.isArray(ri) ? ri : (ri as any)?.rows || []).map((r: any) => ({
    id: r.id, roleTitle: r.role_title_snapshot, department: r.department_snapshot, level: r.level,
    createdAt: r.created_at,
    waiverId: r.waiver_id, waiverStatus: r.waiver_status,
  }));
} catch (_) {}

// Active in-progress application draft (mid-wizard, before step-6 submission).
// Lets the applicant resume exactly where they left off.
let activeDraft: { step: number } | null = null;
try {
  const { getActiveDraft } = await import('@/lib/apply/draft');
  const dr: any = await getActiveDraft(user.id);
  if (dr && dr.data) {
    const dd = typeof dr.data === 'string' ? JSON.parse(dr.data) : dr.data;
    if (dd && dd.step1) activeDraft = { step: Math.min(6, Math.max(1, parseInt(dr.step) || 1)) };
  }
} catch (_) {}

// AquinTutor learning surface — trimmed to 3 courses + 3 tests (slim rail).
function rowsOf(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
let learnerXp: any = { totalXp: 0, level: 1, streakDays: 0 };
try {
  const { getUserXp } = await import('@/lib/xp');
  learnerXp = await getUserXp(user.id);
} catch (_) {}
let portalCourses: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT slug, title, subtitle, category, level,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) AS lesson_count
    FROM training_courses c
    WHERE c.is_published = true AND c.access_type IN ('public','both','applicants')
    ORDER BY c.created_at DESC LIMIT 3
  `);
  portalCourses = rowsOf(r);
} catch (_) {}
let portalTests: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT t.slug, t.title, t.duration_mins, t.total_questions,
      COALESCE(t.is_premium, false) AS is_premium,
      COALESCE(t.practice_enabled, true) AS practice_enabled
    FROM tests t WHERE t.is_published = true
    ORDER BY t.created_at ASC LIMIT 3
  `);
  portalTests = rowsOf(r);
} catch (_) {}

// Quick access counts (interviews / submissions / mail / appeals).
const quickCounts: Record<string, number> = { interviews: 0, submissions: 0, mail: 0, appeals: 0, certificates: 0 };
try {
  const c = await db.execute(sql`
    SELECT
      (SELECT COUNT(*)::int FROM interviews WHERE user_id = ${user.id} AND scheduled_at >= NOW()) AS interviews,
      (SELECT COUNT(*)::int FROM portal_submissions WHERE submitter_user_id = ${user.id} AND status IN ('submitted','under_review','revisions_requested')) AS submissions,
      (SELECT COUNT(*)::int FROM application_appeals WHERE user_id = ${user.id} AND status IN ('open','reviewing')) AS appeals,
      (SELECT COUNT(*)::int FROM training_certificates WHERE user_id = ${user.id}) AS certificates
  `);
  const cr = rowsOf(c)[0] as any;
  if (cr) {
    quickCounts.interviews = cr.interviews || 0;
    quickCounts.submissions = cr.submissions || 0;
    quickCounts.appeals = cr.appeals || 0;
    quickCounts.certificates = cr.certificates || 0;
  }
} catch (_) {}

// Six-stage stepper labels (matches /policy/recruitment).
const STAGES = [
  { key: 'submitted',  label: 'Submitted' },
  { key: 'reviewing',  label: 'Reviewing' },
  { key: 'task_sent',  label: 'Assessment' },
  { key: 'interview',  label: 'Interview' },
  { key: 'offer',      label: 'Decision' },
  { key: 'hired',      label: 'Onboarded' },
];

function getStageIndex(status: string): number {
  const i = STAGES.findIndex(s => s.key === status);
  return i >= 0 ? i : 0;
}
function isClosedStatus(status: string): boolean {
  return status === 'rejected' || status === 'withdrawn';
}
function timeAgo(date: any): string {
  if (!date) return '';
  const diff = Math.floor((Date.now() - new Date(date).getTime()) / 1000);
  if (diff < 60) return 'just now';
  if (diff < 3600) return Math.floor(diff / 60) + ' min ago';
  if (diff < 86400) return Math.floor(diff / 3600) + ' h ago';
  if (diff < 86400 * 7) return Math.floor(diff / 86400) + ' d ago';
  return new Date(date).toLocaleDateString('en-IN', { day: '2-digit', month: 'short' });
}

const STATUS_TONE: Record<string, { cls: string; label: string }> = {
  submitted:  { cls: 'bg-sky-bg text-sky border-sky-border',                  label: 'Submitted' },
  reviewing:  { cls: 'bg-gold-bg text-gold-deep border-gold-border',          label: 'Reviewing' },
  task_sent:  { cls: 'bg-burn-pale text-burn border-burn-dim',                label: 'Assessment' },
  interview:  { cls: 'bg-plum-bg text-plum border-plum-border',               label: 'Interview' },
  offer:      { cls: 'bg-leaf-bg text-leaf border-leaf-border',               label: 'Offer' },
  hired:      { cls: 'bg-leaf-bg text-leaf border-leaf-border',               label: 'Hired' },
  rejected:   { cls: 'bg-cream-3 text-ink-soft border-ink/15',                label: 'Closed' },
  withdrawn:  { cls: 'bg-cream-3 text-ink-soft border-ink/15',                label: 'Withdrawn' },
};

// ============ Compute the single Next Step (server-side) ============
type NextStep = { kind: string; eyebrow: string; title: string; subtitle?: string; cta: string; href: string; urgent: boolean };
let nextStep: NextStep | null = null;

const newestUnread = appsWithMessages.find((a: any) => a.lastMessage && a.lastMessage.senderRole === 'admin' && (a.unreadCount > 0));
const unpaidIntent = pendingIntents.find((p: any) => p.waiverStatus !== 'approved');

if (newestUnread) {
  nextStep = {
    kind: 'unread',
    eyebrow: 'Next step',
    title: 'Reply to your ' + (newestUnread.roleTitleSnapshot || 'application') + ' thread.',
    subtitle: 'A reviewer wrote to you ' + timeAgo(newestUnread.lastMessage.createdAt) + '.',
    cta: 'Open thread',
    href: '/portal/applications/' + newestUnread.id,
    urgent: true,
  };
} else if (!faceEnrolled) {
  // Face 2FA is mandatory for every applicant. Surfaces here until enrolled,
  // regardless of interview-stage status. Offer signing, identity verification
  // and the proctored test runners all depend on it.
  nextStep = {
    kind: 'face',
    eyebrow: 'Account security',
    title: 'Set up Face 2FA for your applicant account.',
    subtitle: 'Required for every applicant before interview, offer signing, and proctored tests. Takes 30 seconds — your face descriptor stays on your device.',
    cta: 'Set up Face 2FA',
    href: '/portal/face-setup',
    urgent: true,
  };
} else if (activeDraft) {
  nextStep = {
    kind: 'draft',
    eyebrow: 'Continue',
    title: 'Finish your application - step ' + activeDraft.step + ' of 6.',
    subtitle: 'Your progress is saved. Pick up right where you left off.',
    cta: 'Resume application',
    href: '/apply/step-' + activeDraft.step,
    urgent: true,
  };
} else if (unpaidIntent) {
  nextStep = {
    kind: 'intent',
    eyebrow: 'Next step',
    title: 'Finish your ' + (unpaidIntent.roleTitle || 'application') + ' fee.',
    subtitle: 'Your application is saved. Pay the processing fee, redeem a coupon, or request a waiver.',
    cta: 'Resume application',
    href: '/apply/pay?intent=' + unpaidIntent.id,
    urgent: true,
  };
} else if (openRequests && openRequests.length > 0) {
  const r = openRequests[0];
  nextStep = {
    kind: 'request',
    eyebrow: 'Next step',
    title: 'Open the ' + (r.title || 'support') + ' thread.',
    subtitle: r.subject || 'A reply is waiting for you.',
    cta: 'Open',
    href: r.href || '/portal/requests',
    urgent: true,
  };
} else if (appsWithMessages.length === 0) {
  nextStep = {
    kind: 'browse',
    eyebrow: 'Ready',
    title: 'Browse the open roles.',
    subtitle: 'Hundreds of roles, every application read by a human.',
    cta: 'Open roles',
    href: '/careers',
    urgent: false,
  };
} else {
  nextStep = {
    kind: 'ready',
    eyebrow: 'Ready',
    title: "You're all caught up.",
    subtitle: 'No outstanding actions. We will message you when there is news.',
    cta: 'Browse more roles',
    href: '/careers',
    urgent: false,
  };
}

// ============ Build the merged Action-needed inbox ============
type InboxRow = { key: string; icon: string; title: string; subtitle: string; href: string; dismissible?: boolean };
const inboxRows: InboxRow[] = [];
if (activeDraft) {
  inboxRows.push({
    key: 'draft',
    icon: 'draft',
    title: 'Continue your application - step ' + activeDraft.step + ' of 6',
    subtitle: 'Saved progress - resume where you left off',
    href: '/apply/step-' + activeDraft.step,
  });
}
pendingIntents.forEach((p: any) => {
  if (p.waiverStatus === 'approved') return;
  inboxRows.push({
    key: 'intent:' + p.id,
    icon: 'wallet',
    title: 'Fee pending — ' + (p.roleTitle || 'Application draft'),
    subtitle: (p.department || '') + ' · ' + (p.level || '') + ' · started ' + timeAgo(p.createdAt),
    href: '/apply/pay?intent=' + p.id,
  });
});
(openRequests || []).forEach((r: any) => {
  inboxRows.push({
    key: 'request:' + (r.id || r.href),
    icon: 'message',
    title: r.title || 'Open request',
    subtitle: r.subject || 'Reply waiting',
    href: r.href || '/portal/requests',
  });
});
if (!faceEnrolled) {
  inboxRows.push({
    key: 'face',
    icon: 'shield',
    title: 'Set up Face 2FA',
    subtitle: 'Adds an extra layer of identity verification on your offer letter signing.',
    href: '/portal/face-setup',
    dismissible: true,
  });
}

// ============ Quick access strip ============
const QUICK_ACCESS = [
  { key: 'interviews',  label: 'Interviews',   href: '/portal/interviews',  count: quickCounts.interviews,  icon: 'calendar' },
  { key: 'submissions', label: 'Submissions',  href: '/portal/submissions', count: quickCounts.submissions, icon: 'upload' },
  { key: 'appeals',     label: 'Appeals',      href: '/portal/appeals',     count: quickCounts.appeals,     icon: 'gavel' },
  { key: 'certificates',label: 'Credentials',  href: '/portal/profile#credentials', count: quickCounts.certificates, icon: 'award' },
  { key: 'tools',       label: 'Profile Tools',href: '/portal/tools',       count: 0, icon: 'tool' },
  { key: 'discussion',  label: 'Discussion',   href: '/portal/discussion',  count: 0, icon: 'community' },
];

const noOpenApps = appsWithMessages.length === 0;
---
<BaseLayout title="Portal — EduRankAI" description="Track every application, message, and next step.">
<style>
  /* finish-level micro-polish */
  .glow-soft { box-shadow: 0 1px 2px rgba(14,11,8,0.04), 0 8px 24px rgba(14,11,8,0.04); }
  .glow-soft:hover { box-shadow: 0 1px 2px rgba(14,11,8,0.06), 0 14px 36px rgba(14,11,8,0.07); }
  .fade-in { animation: fadeUp 0.55s cubic-bezier(0.16,1,0.3,1) both; }
  .fade-in-delay-1 { animation-delay: 0.08s; }
  .fade-in-delay-2 { animation-delay: 0.16s; }
  .fade-in-delay-3 { animation-delay: 0.24s; }
  @keyframes fadeUp { from { opacity:0; transform:translateY(14px); } to { opacity:1; transform:translateY(0); } }
  .step-line { background: linear-gradient(90deg, var(--from, #0E0B08) 0%, var(--to, #0E0B0815) 100%); }
  details.menu > summary { list-style: none; cursor: pointer; }
  details.menu > summary::-webkit-details-marker { display: none; }
  details.menu[open] .menu-panel { display: block; }
  details.menu .menu-panel { display: none; }
</style>

<main class="bg-cream min-h-screen pb-16">

  {/* ============ 1. WELCOME BAR ============ */}
  <header class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-6xl mx-auto">
    <div class="flex items-start justify-between gap-6 flex-wrap">
      <div class="fade-in">
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.2em] text-burn font-bold">Portal</p>
        <h1 class="font-display text-[clamp(2.2rem,4.5vw,3.2rem)] font-semibold text-ink leading-[1.05] tracking-tightest mt-2">
          Welcome back, <em class="italic text-burn font-medium">{firstName}</em>.
        </h1>
        <p class="text-[0.95rem] text-ink-soft mt-3 max-w-xl leading-relaxed">
          Every application, message, and next step in one place. We never keep you in the dark.
        </p>
      </div>
      <details class="menu relative fade-in fade-in-delay-1">
        <summary class="inline-flex items-center gap-2 bg-white border border-ink/10 hover:border-ink/25 rounded-full pl-1.5 pr-3 py-1.5 transition-all">
          <span class="w-8 h-8 rounded-full bg-burn text-white flex items-center justify-center font-display text-[0.95rem] font-semibold">{firstName.charAt(0).toUpperCase()}</span>
          <span class="text-sm text-ink font-medium hidden sm:inline">{firstName}</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-ink-soft"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <div class="menu-panel absolute right-0 mt-2 w-56 bg-white border border-ink/10 rounded-xl glow-soft py-2 z-20">
          <a href="/portal/profile" class="flex items-center gap-3 px-4 py-2 text-sm text-ink hover:bg-cream-2"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>Profile</a>
          <a href="/portal/notifications" class="flex items-center gap-3 px-4 py-2 text-sm text-ink hover:bg-cream-2"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>Notifications</a>
          <a href="/portal/face-setup" class="flex items-center gap-3 px-4 py-2 text-sm text-ink hover:bg-cream-2"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>Security & 2FA</a>
          <div class="my-1 border-t border-ink/10"></div>
          <a href="/portal/logout" class="flex items-center gap-3 px-4 py-2 text-sm text-ink-soft hover:bg-cream-2 hover:text-ink"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>Sign out</a>
        </div>
      </details>
    </div>
  </header>

  {/* ============ 2. NEXT STEP CARD ============ */}
  {nextStep && (
    <section class="px-[5vw] mb-10 max-w-6xl mx-auto">
      <div class={`rounded-2xl p-6 md:p-7 flex flex-col sm:flex-row sm:items-center gap-5 fade-in fade-in-delay-1 ${nextStep.urgent ? 'bg-burn-pale border border-burn-dim' : 'bg-white border border-ink/10'}`}>
        <div class={`w-12 h-12 rounded-xl flex items-center justify-center shrink-0 ${nextStep.urgent ? 'bg-burn text-white' : 'bg-cream-2 text-burn'}`}>
          {nextStep.urgent ? (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/></svg>
          ) : (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="20 6 9 17 4 12"/></svg>
          )}
        </div>
        <div class="flex-1">
          <p class={`text-[0.6rem] font-mono uppercase tracking-[0.2em] font-bold ${nextStep.urgent ? 'text-burn' : 'text-ink-soft'}`}>{nextStep.eyebrow}</p>
          <p class="text-[1.05rem] font-display font-semibold text-ink mt-1.5 leading-snug">{nextStep.title}</p>
          {nextStep.subtitle && <p class="text-[0.88rem] text-ink-soft mt-1.5 leading-relaxed">{nextStep.subtitle}</p>}
        </div>
        <a href={nextStep.href} class={`inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg text-sm font-semibold transition-all hover:-translate-y-0.5 shrink-0 ${nextStep.urgent ? 'bg-burn text-white hover:bg-burn-2' : 'border border-ink/15 text-ink-2 hover:border-ink/40'}`}>
          {nextStep.cta}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </section>
  )}

  {/* ============ 3. APPLICATIONS — the work list ============ */}
  <section class="px-[5vw] mb-14 max-w-6xl mx-auto fade-in fade-in-delay-2">
    <div class="flex items-end justify-between gap-4 mb-6 flex-wrap">
      <div>
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.2em] text-burn font-bold">Applications</p>
        <h2 class="font-display text-[clamp(1.6rem,3vw,2.2rem)] font-semibold text-ink leading-[1.1] tracking-tight mt-1.5">
          Your <em class="italic text-burn font-medium">applications</em>.
        </h2>
      </div>
      <p class="text-[0.72rem] font-mono text-ink-soft" data-applist-updated>Updated just now</p>
    </div>

    {noOpenApps ? (
      <div class="bg-white border border-ink/10 rounded-2xl p-10 md:p-14 text-center glow-soft">
        <div class="w-14 h-14 rounded-full bg-burn-pale flex items-center justify-center mx-auto mb-5">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FF4F00" stroke-width="2"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
        </div>
