---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { applications, applicationMessages } from '@/lib/db/schema';
import { eq, desc, sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
if (user.role !== 'applicant') return Astro.redirect('/admin');

// Auto-promote any legacy 'pending' account. The 1 CHF registration fee is no
// longer required — the application fee is now the single paid step — and we
// don't want existing pending users to remain locked out.
try {
  await db.execute(sql`UPDATE users SET access_status = 'approved', updated_at = NOW() WHERE id = ${user.id} AND access_status = 'pending'`);
} catch (_) {}

// Check if this user is an active employee → employee portal (or onboarding
// first if they were just hired and haven't completed it).
try {
  const empCheck = await db.execute(sql`
    SELECT id, onboarding_status FROM hr_employees
    WHERE (personal_email = ${user.email} OR email = ${user.email} OR user_id = ${user.id}) AND is_active = true
    LIMIT 1
  `);
  const rows = Array.isArray(empCheck) ? empCheck : (empCheck?.rows || []);
  if (rows.length > 0) {
    if ((rows[0] as any).onboarding_status === 'pending') return Astro.redirect('/portal/employee/onboarding');
    return Astro.redirect('/portal/employee');
  }
} catch(e) {}

const apps = await db.select({
  id: applications.id,
  roleTitleSnapshot: applications.roleTitleSnapshot,
  departmentSnapshot: applications.departmentSnapshot,
  level: applications.level,
  status: applications.status,
  score: applications.score,
  scoringFeedback: applications.scoringFeedback,
  createdAt: applications.createdAt,
  updatedAt: applications.updatedAt
}).from(applications)
  .where(eq(applications.applicantUserId, user.id))
  .orderBy(desc(applications.createdAt));

const appsWithMessages = [];
for (const app of apps) {
  const lastMsgs = await db.select({
    body: applicationMessages.body,
    senderRole: applicationMessages.senderRole,
    senderName: applicationMessages.senderName,
    isSystem: applicationMessages.isSystem,
    createdAt: applicationMessages.createdAt
  }).from(applicationMessages)
    .where(eq(applicationMessages.applicationId, app.id))
    .orderBy(desc(applicationMessages.createdAt))
    .limit(1);

  appsWithMessages.push({ ...app, lastMessage: lastMsgs[0] || null });
}

const firstName = user.name ? user.name.split(' ')[0] : 'there';

// Face 2FA enrollment status - prompt applicants who haven't set it up.
let faceEnrolled = false;
try {
  const fr = await db.execute(sql`SELECT id FROM user_face_enrollments WHERE user_id = ${user.id} AND is_active = true LIMIT 1`);
  const frows = Array.isArray(fr) ? fr : (fr?.rows || []);
  faceEnrolled = frows.length > 0;
} catch (_) {}

// Open admin↔applicant request threads (Vis-vambhara, fee waivers, ...)
let openRequests: any[] = [];
try {
  const { listApplicantRequests } = await import('@/lib/request-threads');
  openRequests = await listApplicantRequests(user.id);
} catch (_) {}

// Pending intents — applications the user started but never completed because
// the processing & verification fee step is unpaid. They can finish payment
// or redeem a fee-waiver coupon here.
let pendingIntents: any[] = [];
try {
  const ri = await db.execute(sql`
    SELECT i.id, i.role_title_snapshot, i.department_snapshot, i.level, i.created_at,
      i.first_name, i.last_name,
      w.id AS waiver_id, w.status AS waiver_status
    FROM application_intents i
    LEFT JOIN application_fee_waivers w ON w.intent_id = i.id
    WHERE i.user_id = ${user.id}
    ORDER BY i.created_at DESC
    LIMIT 20
  `);
  pendingIntents = (Array.isArray(ri) ? ri : (ri as any)?.rows || []).map((r: any) => ({
    id: r.id,
    roleTitle: r.role_title_snapshot,
    department: r.department_snapshot,
    level: r.level,
    createdAt: r.created_at,
    name: ((r.first_name || '') + ' ' + (r.last_name || '')).trim(),
    waiverId: r.waiver_id,
    waiverStatus: r.waiver_status,
  }));
} catch (_) {}

const STAGE_ORDER = ['submitted', 'reviewing', 'task_sent', 'interview', 'offer', 'hired'];
const STAGE_LABELS: Record<string, string> = {
  submitted: 'Submitted', reviewing: 'Under Review', task_sent: 'Task / Walkthrough',
  interview: 'Interview', offer: 'Offer Extended', hired: 'Hired',
  rejected: 'Closed', withdrawn: 'Withdrawn'
};
const STATUS_COLORS: Record<string, string> = {
  submitted: 'bg-sky-bg text-sky border-sky-border',
  reviewing: 'bg-burn-pale text-burn border-burn-dim',
  task_sent: 'bg-gold-bg text-gold-deep border-gold-border',
  interview: 'bg-plum-bg text-plum border-plum-border',
  offer: 'bg-leaf-bg text-leaf border-leaf-border',
  hired: 'bg-leaf-bg text-leaf border-leaf-border',
  rejected: 'bg-ink/5 text-ink-soft border-ink/15',
  withdrawn: 'bg-ink/5 text-ink-soft border-ink/15'
};

function getStageIndex(status: string): number {
  const i = STAGE_ORDER.indexOf(status);
  return i >= 0 ? i : -1;
}
function isClosedStatus(status: string): boolean {
  return status === 'rejected' || status === 'withdrawn';
}
function timeAgo(date: Date): string {
  const diff = Math.floor((Date.now() - new Date(date).getTime()) / 1000);
  if (diff < 60) return 'just now';
  if (diff < 3600) return Math.floor(diff / 60) + ' min ago';
  if (diff < 86400) return Math.floor(diff / 3600) + ' hr ago';
  return Math.floor(diff / 86400) + ' day ago';
}

// ===== AquinTutor learning surface inside the portal =====
function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
let learnerXp: any = { totalXp: 0, level: 1, streakDays: 0 };
try {
  const { getUserXp } = await import('@/lib/xp');
  learnerXp = await getUserXp(user.id);
} catch (_) {}
let portalCourses: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT slug, title, subtitle, category, level,
      (SELECT COUNT(*)::int FROM training_lessons WHERE course_id = c.id) AS lesson_count
    FROM training_courses c
    WHERE c.is_published = true AND c.access_type IN ('public','both','applicants')
    ORDER BY c.created_at DESC LIMIT 8
  `);
  portalCourses = rows(r);
} catch (_) {}
let portalTests: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT t.slug, t.title, t.duration_mins, t.total_questions,
      COALESCE(t.price_chf, 0) AS price_chf, COALESCE(t.is_premium, false) AS is_premium,
      COALESCE(t.practice_enabled, true) AS practice_enabled
    FROM tests t WHERE t.is_published = true
    ORDER BY t.created_at ASC LIMIT 6
  `);
  portalTests = rows(r);
} catch (_) {}
---
<BaseLayout title="My Applications - EduRankAI" description="Track your applications transparently.">
  <section class="px-[5vw] py-10 md:py-14 max-w-4xl mx-auto">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-3 mb-8">
      <div>
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-1">PORTAL</p>
        <h1 class="font-display text-[clamp(1.8rem,4vw,2.5rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-2">
          Welcome, {firstName}.
        </h1>
        <p class="text-[0.88rem] text-ink-soft">Track every application and message us anytime. We never keep you in the dark.</p>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;"><a href="/portal/courses" style="font-size:12px;font-weight:600;color:#DC5000;padding:6px 12px;border:1px solid rgba(220,80,0,0.3);border-radius:8px;text-decoration:none;">Courses</a><a href="/portal/discussion" style="font-size:12px;color:#374151;padding:6px 12px;border:1px solid rgba(0,0,0,0.1);border-radius:8px;text-decoration:none;">Community</a><a href="/portal/logout" class="text-[0.82rem] font-medium text-ink-soft hover:text-burn px-4 py-2 border border-ink/15 rounded-lg hover:border-burn-dim transition-all">Sign out</a></div>
    </div>

    <div id="notifCard" class="flex items-center gap-4 rounded-2xl p-4 md:p-5 mb-6" style="background:#fff7ed;border:1px solid #fdba74;display:none;">
      <div class="shrink-0 w-11 h-11 rounded-full flex items-center justify-center" style="background:rgba(194,65,12,0.12);border:1px solid #fdba74;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c2410c" stroke-width="2"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
      </div>
      <div class="flex-1 min-w-0">
        <p class="font-display text-[1rem] font-semibold" style="color:#7c2d12;">Turn on notifications</p>
        <p class="text-[0.82rem] leading-snug mt-0.5" style="color:#9a3412;">We will not email or call. Get pinged the moment our team replies, your status moves, or an offer arrives.</p>
      </div>
      <button type="button" id="enableNotifBtnHome" class="shrink-0 inline-flex items-center gap-1.5 font-semibold px-4 py-2 rounded-lg text-[0.85rem]" style="background:#c2410c;color:#fff;border:none;cursor:pointer;">Enable</button>
    </div>

    <meta name="vapid-public-key" content={import.meta.env.VAPID_PUBLIC_KEY || ''} />
    <script is:inline>
      (function () {
        var card = document.getElementById('notifCard');
        var btn = document.getElementById('enableNotifBtnHome');
        var vapid = document.querySelector('meta[name="vapid-public-key"]')?.getAttribute('content');
        function urlB64(s) {
          var pad = '='.repeat((4 - s.length % 4) % 4);
          var b64 = (s + pad).replace(/-/g, '+').replace(/_/g, '/');
          var raw = atob(b64); var out = new Uint8Array(raw.length);
          for (var i = 0; i < raw.length; i++) out[i] = raw.charCodeAt(i);
          return out;
        }
        if (!('serviceWorker' in navigator) || !('PushManager' in window) || !vapid) return;
        navigator.serviceWorker.register('/sw.js').then(function (reg) {
          return reg.pushManager.getSubscription().then(function (sub) {
            if (sub) return; // already enabled - keep card hidden
            if (card) card.style.display = 'flex';
            if (btn) btn.addEventListener('click', function () {
              btn.disabled = true; btn.textContent = 'Enabling...';
              reg.pushManager.subscribe({ userVisibleOnly: true, applicationServerKey: urlB64(vapid) })
                .then(function (s) {
                  return fetch('/api/push/subscribe', {
                    method: 'POST', credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(s),
                  });
                })
                .then(function () { if (card) card.style.display = 'none'; })
                .catch(function () { btn.disabled = false; btn.textContent = 'Try again'; });
            });
          });
        }).catch(function () {});
      })();
    </script>

    {!faceEnrolled && (
      <a href="/portal/face-setup?next=/portal" class="flex items-center gap-4 bg-burn-pale/60 border-2 border-burn-dim rounded-2xl p-4 md:p-5 mb-6 no-underline group">
        <div class="shrink-0 w-11 h-11 rounded-full bg-burn/15 border border-burn-dim flex items-center justify-center">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c2410c" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 3v6c0 5-3.5 9-8 11-4.5-2-8-6-8-11V5l8-3z"/><circle cx="12" cy="11" r="2.4"/><path d="M8.5 17a3.6 3.6 0 017 0"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-display text-[1rem] font-semibold text-ink leading-tight">Secure your account with Face 2FA</p>
          <p class="text-[0.82rem] text-ink-2 leading-snug mt-0.5">Add a quick face check for sign-in. Ten seconds — your photo never leaves your browser.</p>
        </div>
        <span class="shrink-0 inline-flex items-center gap-1.5 text-[0.82rem] font-semibold text-burn group-hover:gap-2.5 transition-all">Set up
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </span>
      </a>
    )}

    {pendingIntents.length > 0 && (
      <div style="background:linear-gradient(180deg,#fff7ed 0%,#ffffff 100%);border:1px solid rgba(220,80,0,0.25);border-radius:16px;padding:18px 22px;margin-bottom:18px;">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:12px;flex-wrap:wrap;">
          <div>
            <p style="font-family:'Geist Mono','JetBrains Mono',monospace;font-size:10.5px;letter-spacing:0.16em;text-transform:uppercase;color:#DC5000;font-weight:700;margin:0 0 4px;">Pending - fee step</p>
            <p style="font-family:Fraunces,serif;font-size:1.15rem;font-weight:600;color:#1c1d22;margin:0;">Applications waiting on you</p>
            <p style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#5b5b5b;margin:4px 0 0;">Pay the process &amp; verification fee, redeem a coupon, or request a waiver.</p>
          </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px;">
          {pendingIntents.map((p: any) => (
            <div style="background:#fff;border:1px solid #e6e3da;border-radius:10px;padding:12px 14px;display:flex;flex-direction:column;gap:8px;">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;flex-wrap:wrap;">
                <div style="min-width:0;flex:1;">
                  <p style="font-family:'Inter Tight',sans-serif;font-size:13.5px;font-weight:600;margin:0 0 2px;color:#1c1d22;">{p.roleTitle || 'Application draft'}</p>
                  <p style="font-family:'Inter Tight',sans-serif;font-size:11.5px;color:#5b5b5b;margin:0;">{[p.department, p.level].filter(Boolean).join(' · ') || 'Started ' + new Date(p.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' })}</p>
                </div>
                <span style="font-family:'JetBrains Mono',monospace;font-size:9.5px;text-transform:uppercase;letter-spacing:0.14em;font-weight:700;padding:3px 9px;border-radius:100px;background:rgba(250,204,21,0.16);color:#92400e;">Fee pending</span>
              </div>
              <div style="display:flex;gap:6px;flex-wrap:wrap;">
                <a href={`/apply/pay?intent=${p.id}`} style="background:#FF4F00;color:#fff;text-decoration:none;font-size:11.5px;font-weight:700;padding:6px 13px;border-radius:6px;font-family:'Inter Tight',sans-serif;">Pay or redeem coupon</a>
                {!p.waiverId && <a href={`/apply/waiver?intent=${p.id}`} style="background:#fff;color:#1c1d22;text-decoration:none;font-size:11.5px;font-weight:700;padding:6px 13px;border-radius:6px;border:1px solid #d6d3cb;font-family:'Inter Tight',sans-serif;">Request waiver</a>}
                {p.waiverId && p.waiverStatus === 'pending' && <span style="font-size:11.5px;color:#92400e;align-self:center;">Waiver pending review</span>}
                {p.waiverId && p.waiverStatus === 'rejected' && <span style="font-size:11.5px;color:#991b1b;align-self:center;">Waiver declined - pay or use a coupon</span>}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    {openRequests.length > 0 && (
      <div style="background:#fff;border:1px solid rgba(0,0,0,0.08);border-radius:16px;padding:18px 22px;margin-bottom:18px;">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:12px;">
          <div>
            <p style="font-family:'Geist Mono','JetBrains Mono',monospace;font-size:10.5px;letter-spacing:0.16em;text-transform:uppercase;color:#DC5000;font-weight:700;margin:0 0 4px;">Open requests</p>
            <p style="font-family:Fraunces,serif;font-size:1.15rem;font-weight:600;color:#1c1d22;margin:0;">Your live threads with the team</p>
          </div>
          <a href="/portal/requests" style="font-size:12px;color:#DC5000;font-weight:600;text-decoration:none;">View all →</a>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px;">
          {openRequests.slice(0, 3).map((r: any) => {
            const sBg = r.status === 'approved' ? 'rgba(16,185,129,0.12)' : r.status === 'rejected' ? 'rgba(239,68,68,0.10)' : 'rgba(250,204,21,0.14)';
            const sFg = r.status === 'approved' ? '#047857' : r.status === 'rejected' ? '#991b1b' : '#92400e';
            return (
              <a href={r.href} style="display:flex;align-items:center;justify-content:space-between;gap:10px;padding:11px 14px;background:#faf8f3;border:1px solid #e6e3da;border-radius:10px;text-decoration:none;color:#1c1d22;">
                <div style="min-width:0;flex:1;">
                  <p style="font-family:'Inter Tight',sans-serif;font-size:13.5px;font-weight:600;margin:0 0 2px;">{r.title}</p>
                  <p style="font-family:'Inter Tight',sans-serif;font-size:11.5px;color:#5b5b5b;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{(r.subject || '').substring(0, 100)}</p>
                </div>
                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;">
                  <span style={'font-family:JetBrains Mono,monospace;font-size:9.5px;text-transform:uppercase;letter-spacing:0.14em;font-weight:700;padding:2px 8px;border-radius:100px;background:' + sBg + ';color:' + sFg + ';'}>{r.status}</span>
                  {r.unread > 0 && <span style="background:#FF4F00;color:#fff;font-size:10px;font-weight:700;padding:2px 7px;border-radius:100px;">{r.unread} new</span>}
                </div>
              </a>
            );
          })}
        </div>
      </div>
    )}

    <!-- ===== Learning surface (AquinTutor in the portal) ===== -->
    <div style="background:linear-gradient(180deg,#fff8f3 0%,#ffffff 100%); border:1px solid rgba(217,119,87,0.25); border-radius:16px; padding:22px 24px; margin-bottom:24px;">
      <div style="display:flex; align-items:center; justify-content:space-between; gap:14px; flex-wrap:wrap; margin-bottom:16px;">
        <div>
          <p style="font-family:'Geist Mono','JetBrains Mono',monospace; font-size:10.5px; letter-spacing:0.16em; text-transform:uppercase; color:#d97757; font-weight:700; margin:0 0 6px;">AquinTutor · learning portal</p>
          <p class="font-display" style="font-size:1.3rem; font-weight:600; color:#1c1d22; margin:0;">Keep your streak. Stretch your skills.</p>
        </div>
        <div style="display:flex; gap:18px; align-items:center; font-family:'JetBrains Mono',monospace; font-size:11.5px; color:#5b5b5b;">
          <span style="display:inline-flex; align-items:center; gap:8px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14a4 4 0 1 0 7 0c0-2-1-3.5-3-5-2 1.5-3 3-3 5z"/><path d="M12 2c1 2 2 3.5 2 5a3 3 0 0 1-3 3"/></svg>
            <b style="color:#f97316; font-size:14px;">{learnerXp.streakDays}</b> day{learnerXp.streakDays === 1 ? '' : 's'}
          </span>
          <span style="display:inline-flex; align-items:center; gap:8px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d97757" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            <b style="color:#d97757; font-size:14px;">{learnerXp.totalXp.toLocaleString()}</b> XP · Lv {learnerXp.level}
          </span>
        </div>
      </div>

      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(140px,1fr)); gap:8px; margin-bottom:18px;">
        <a href="/aquintutor/dashboard" style="background:#0f172a; color:#fff; padding:10px 14px; border-radius:8px; text-decoration:none; font-size:12.5px; font-weight:700; text-align:center; font-family:'Inter Tight',sans-serif;">Dashboard</a>
        <a href="/aquintutor/daily" style="background:#d97757; color:#fff; padding:10px 14px; border-radius:8px; text-decoration:none; font-size:12.5px; font-weight:700; text-align:center; font-family:'Inter Tight',sans-serif;">Daily challenge</a>
        <a href="/aquintutor/converse" style="background:#fff; color:#1c1d22; padding:10px 14px; border-radius:8px; text-decoration:none; font-size:12.5px; font-weight:700; text-align:center; font-family:'Inter Tight',sans-serif; border:1px solid #e6e3da;">AI tutor</a>
        <a href="/aquintutor/league" style="background:#fff; color:#1c1d22; padding:10px 14px; border-radius:8px; text-decoration:none; font-size:12.5px; font-weight:700; text-align:center; font-family:'Inter Tight',sans-serif; border:1px solid #e6e3da;">League</a>
        <a href="/aquintutor/review" style="background:#fff; color:#1c1d22; padding:10px 14px; border-radius:8px; text-decoration:none; font-size:12.5px; font-weight:700; text-align:center; font-family:'Inter Tight',sans-serif; border:1px solid #e6e3da;">Review</a>
        <a href="/aquintutor/classrooms" style="background:#fff; color:#1c1d22; padding:10px 14px; border-radius:8px; border:1px solid #e6e3da; text-decoration:none; font-size:12.5px; font-weight:700; text-align:center; font-family:'Inter Tight',sans-serif;">Classroom</a>
      </div>

      {portalCourses.length > 0 && (
        <div style="margin-bottom:14px;">
          <p style="font-family:'Geist Mono','JetBrains Mono',monospace; font-size:10px; letter-spacing:0.14em; text-transform:uppercase; color:#5b5b5b; font-weight:700; margin:0 0 8px;">Language + skill courses (free)</p>
          <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:8px;">
            {portalCourses.map((c: any) => (
              <a href={'/aquintutor/courses/' + c.slug} style="background:#fff; border:1px solid #e6e3da; border-radius:10px; padding:12px 14px; text-decoration:none; color:#1c1d22; transition:transform .12s;">
                <p style="font-family:'Fraunces',serif; font-size:14.5px; font-weight:600; margin:0 0 4px; line-height:1.25;">{c.title}</p>
                <p style="font-family:'Inter Tight',sans-serif; font-size:11.5px; color:#5b5b5b; margin:0; line-height:1.4;">{c.category} · {c.lesson_count} lesson{c.lesson_count === 1 ? '' : 's'}</p>
              </a>
            ))}
          </div>
        </div>
      )}

      {portalTests.length > 0 && (
        <div>
          <p style="font-family:'Geist Mono','JetBrains Mono',monospace; font-size:10px; letter-spacing:0.14em; text-transform:uppercase; color:#5b5b5b; font-weight:700; margin:0 0 8px;">Tests · practice free · official 1 CHF</p>
          <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:8px;">
            {portalTests.map((t: any) => {
              const priceChf = Number(t.price_chf || 0);
              const free = !t.is_premium || priceChf < 0.01;
              return (
                <div style="background:#fff; border:1px solid #e6e3da; border-radius:10px; padding:12px 14px;">
                  <p style="font-family:'Fraunces',serif; font-size:14.5px; font-weight:600; margin:0 0 4px; line-height:1.25;">{t.title}</p>
                  <p style="font-family:'JetBrains Mono',monospace; font-size:10.5px; color:#5b5b5b; margin:0 0 8px;">{t.total_questions}q · {t.duration_mins}m · {free ? 'FREE' : (priceChf + ' CHF')}</p>
                  <div style="display:flex; gap:6px;">
                    {t.practice_enabled && <a href={'/aquintutor/practice/' + t.slug} style="flex:1; background:#faf8f3; color:#1c1d22; padding:6px 8px; border-radius:6px; font-size:11.5px; font-weight:700; text-decoration:none; text-align:center; border:1px solid #e6e3da;">Practise</a>}
                    <a href={'/aquintutor/test/' + t.slug} style="flex:1; background:#1c1d22; color:#fff; padding:6px 8px; border-radius:6px; font-size:11.5px; font-weight:700; text-decoration:none; text-align:center;">{free ? 'Take' : 'Official →'}</a>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      )}
    </div>

    {appsWithMessages.length === 0 ? (
      <div class="bg-cream-2 border border-ink/10 rounded-2xl p-8 md:p-10 text-center">
        <p class="font-display text-[1.2rem] font-semibold text-ink mb-2">No applications yet.</p>
        <p class="text-[0.88rem] text-ink-soft mb-5">Browse open roles and apply, or check your fee-waiver requests if you have one in review.</p>
        <div class="flex gap-3 justify-center flex-wrap">
          <a href="/careers" class="inline-block bg-burn hover:bg-burn/90 text-white font-semibold py-3 px-6 rounded-lg text-[0.9rem] transition-all no-underline">View Open Roles</a>
          <a href="/portal/waivers" class="inline-block bg-white hover:bg-cream-2 text-ink border border-ink/15 font-semibold py-3 px-6 rounded-lg text-[0.9rem] transition-all no-underline">My waiver requests</a>
        </div>
      </div>
    ) : (
      <div class="flex flex-col gap-5">
        {appsWithMessages.map((app) => {
          const stageIdx = getStageIndex(app.status);
          const isClosed = isClosedStatus(app.status);
          const shortId = app.id.substring(0, 8).toUpperCase();
          const submittedDate = new Date(app.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
          const statusClass = STATUS_COLORS[app.status] || 'bg-cream-2 text-ink-soft border-ink/15';
          return (
            <div class="bg-white border border-ink/10 rounded-2xl p-5 md:p-6">
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-3 mb-4 pb-4 border-b border-ink/8">
                <div>
                  <div class="flex items-center gap-2 mb-1.5">
                    <p class="font-mono text-[0.7rem] text-ink-soft">{shortId}</p>
                    <span class={'inline-block text-[0.68rem] font-bold uppercase tracking-wider border px-2 py-0.5 rounded-full ' + statusClass}>
                      {STAGE_LABELS[app.status] || app.status}
                    </span>
                  </div>
                  <p class="font-display text-[1.15rem] font-semibold text-ink leading-tight">{app.roleTitleSnapshot}</p>
                  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-[0.78rem] text-ink-soft mt-1">
                    <span>{app.departmentSnapshot}</span>
                    {app.level && <><span>-</span><span>{app.level}</span></>}
                    <span>-</span><span>Applied {submittedDate}</span>
                  </div>
                </div>
              </div>
              {!isClosed && (
                <div class="mb-4">
                  <div class="flex items-center justify-between mb-2">
                    {STAGE_ORDER.slice(0, 5).map((stage, i) => {
                      const isDone = stageIdx > i;
                      const isCurrent = stageIdx === i;
                      return (
                        <div class="flex flex-col items-center flex-1 relative">
                          <div class={'w-6 h-6 rounded-full border-2 flex items-center justify-center text-[0.62rem] font-bold relative z-10 ' + (isDone ? 'bg-leaf border-leaf text-white' : isCurrent ? 'bg-burn border-burn text-white animate-pulse' : 'bg-white border-ink/15 text-ink-soft')}>
                            {isDone ? 'OK' : (i + 1)}
                          </div>
                          {i < 4 && <div class={'absolute top-3 left-1/2 w-full h-[2px] ' + (isDone ? 'bg-leaf' : 'bg-ink/10')} style="z-index: 0;"></div>}
                          <p class={'text-[0.6rem] font-mono mt-1.5 text-center ' + (isCurrent ? 'text-burn font-bold' : isDone ? 'text-ink-2' : 'text-ink-soft')}>
                            {STAGE_LABELS[stage]}
                          </p>
                        </div>
                      );
                    })}
                  </div>
                </div>
              )}
              {app.lastMessage && (
                <div class="bg-cream-2 border border-ink/10 rounded-lg p-3.5 mb-3 text-[0.85rem] leading-relaxed">
                  <div class="flex items-center justify-between mb-1.5">
                    <p class="text-[0.7rem] font-mono uppercase tracking-wider text-ink-soft font-bold">
                      {app.lastMessage.isSystem ? 'System update' : (app.lastMessage.senderRole === 'admin' ? 'From the team' : 'You')}
                    </p>
                    <p class="text-[0.7rem] text-ink-soft font-mono">{timeAgo(app.lastMessage.createdAt)}</p>
                  </div>
                  <p class="text-ink-2 line-clamp-2">{app.lastMessage.body}</p>
                </div>
              )}
              <div class="flex gap-2 mt-3">
                <a href={'/portal/applications/' + app.id} class="flex-1 bg-ink hover:bg-ink/90 text-white font-semibold py-2.5 px-4 rounded-lg text-[0.85rem] transition-all text-center flex items-center justify-center gap-2">
                  View thread and reply
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </div>
          );
        })}
      </div>
    )}

    {appsWithMessages.length > 0 && (
      <div class="mt-6 text-center text-[0.78rem] text-ink-soft italic">
        Status and messages auto-refresh every 30 seconds.
      </div>
    )}

  </section>
</BaseLayout>

<script is:inline>
  setTimeout(function() { window.location.reload(); }, 30000);
</script>
