---
import BaseLayout from '@/layouts/BaseLayout.astro';

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/portal/login');
}

if (user.role !== 'applicant') {
  return Astro.redirect('/admin');
}

const firstName = user.name ? user.name.split(' ')[0] : 'there';
---
<BaseLayout title="Your Applications - EduRankAI Portal" description="Track your EduRankAI applications.">
  <section class="px-[5vw] py-12 md:py-16 max-w-4xl mx-auto">
    <div class="mb-8 flex items-start justify-between gap-4 pb-6 border-b border-ink/10">
      <div>
        <p class="eyebrow mb-2">Portal</p>
        <h1 class="font-display text-3xl md:text-4xl font-semibold text-ink leading-tight">
          Welcome, {firstName}.
        </h1>
        <p class="text-[0.88rem] text-ink-soft mt-2">Track every application transparently. We never keep you in the dark.</p>
      </div>
      <form method="POST" action="/portal/logout" style="margin:0">
        <button type="submit" class="btn-ghost text-[0.8rem]">Sign out</button>
      </form>
    </div>

    <div class="bg-cream-2 border border-ink/10 rounded-2xl p-8 md:p-12 text-center">
      <p class="font-display text-xl md:text-2xl text-ink mb-3 font-medium">No applications yet.</p>
      <p class="text-[0.88rem] text-ink-soft mb-6 max-w-md mx-auto leading-relaxed">
        Browse open roles and apply. Once you do, you will see them here with live status updates.
      </p>
      <a href="/careers" class="btn-primary">View Open Roles</a>
    </div>
  </section>
</BaseLayout>
