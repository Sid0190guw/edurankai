---
// Legacy registration-fee activation page — deprecated.
// Account creation is FREE. The application fee is the only paid step, and it
// is per-application (not per-account). Anyone hitting this URL gets bounced
// straight to /portal so the legacy "pay 1 CHF to activate" prompt cannot
// gate an applicant by accident.
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

// Belt-and-braces: any user who landed here while still on 'pending' gets
// promoted to 'approved' before being bounced to /portal.
try {
  await db.execute(sql`UPDATE users SET access_status = 'approved', updated_at = NOW() WHERE id = ${user.id} AND access_status = 'pending'`);
} catch (_) {}

return Astro.redirect('/portal');
---
