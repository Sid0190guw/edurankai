---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { isConfigured } from '@/lib/razorpay';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/activate'));

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
const u: any = rows(await db.execute(sql`SELECT access_status, reg_fee_paid, waiver_requested FROM users WHERE id = ${user.id} LIMIT 1`))[0] || {};
if (u.access_status === 'approved') return Astro.redirect('/portal');

let msg = '';
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  if (fd.get('action') === 'request_waiver') {
    const reason = (fd.get('reason') as string || '').trim().slice(0, 4000);
    const proofUrl = (fd.get('proof_url') as string || '').trim().slice(0, 600);
    const wordCount = reason ? reason.split(/\s+/).filter(Boolean).length : 0;
    const validUrl = /^https?:\/\/.+\..+/.test(proofUrl);
    if (wordCount < 200 || wordCount > 500) {
      msg = 'Your statement must be 200-500 words (you wrote ' + wordCount + '). Tell us about yourself, your motivation, and your financial need.';
    } else if (!validUrl) {
      msg = 'Please share a valid link (https://...) to a proof of income or other valid proof.';
    } else {
      await db.execute(sql`UPDATE users SET waiver_requested = true, waiver_reason = ${reason}, waiver_proof_url = ${proofUrl}, updated_at = NOW() WHERE id = ${user.id}`);
      try { const { pushNotify } = await import('@/lib/push'); if ((pushNotify as any).waiverRequested) await (pushNotify as any).waiverRequested(user.name || user.email, user.id); } catch (_) {}
      u.waiver_requested = true;
      msg = 'waiver_submitted';
    }
  }
}

const paymentsReady = isConfigured();
---
<BaseLayout title="Activate your account - EduRankAI" description="Activate your EduRankAI account.">
  <section class="px-[5vw] py-12 md:py-16 max-w-lg mx-auto">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">Almost there</p>
    <h1 class="font-display text-[clamp(1.7rem,4.5vw,2.4rem)] font-semibold text-ink leading-tight mb-3">Activate your account</h1>

    {u.waiver_requested ? (
      <div class="bg-cream-2 border border-ink/10 rounded-2xl p-6">
        <p class="font-semibold text-ink mb-2">Fee waiver requested</p>
        <p class="text-[0.9rem] text-ink-soft leading-relaxed">Your account is <strong>pending review</strong>. Our team will review your waiver request and approve your access. You'll be able to continue once approved. For urgent help: <a href="mailto:hr@edurankai.in" class="text-burn hover:underline">hr@edurankai.in</a></p>
      </div>
    ) : (
      <>
        <p class="text-[0.92rem] text-ink-soft leading-relaxed mb-3">A one-time <strong class="text-ink">CHF 1</strong> verification fee activates your account. If you cannot pay, you may request a fee waiver — your profile stays pending until an administrator approves it.</p>
        <p class="text-[0.8rem] text-ink-2 leading-relaxed mb-6 bg-burn-pale/40 border border-burn-dim rounded-lg p-3"><strong>Please note:</strong> this is a one-time account processing &amp; verification fee only. It does <strong>not</strong> guarantee a job, role, admission, or any outcome — it simply covers the cost of processing and verifying your account. It is non-refundable once verification begins.</p>

        <div class="bg-white border border-ink/10 rounded-2xl p-6 mb-4">
          <div class="flex items-center justify-between mb-4">
            <span class="font-semibold text-ink">One-time activation fee</span>
            <span class="font-display text-[1.5rem] font-semibold text-burn">CHF 1</span>
          </div>
          {paymentsReady ? (
            <button id="payBtn" class="w-full bg-burn hover:bg-burn/90 text-white font-semibold py-3 rounded-lg text-[0.92rem]">Pay CHF 1 &amp; activate</button>
          ) : (
            <p class="text-[0.82rem] text-ink-soft text-center">Online payment is being set up. Please request a fee waiver below for now.</p>
          )}
        </div>

        <form method="POST" class="bg-cream-2 border border-ink/10 rounded-2xl p-5">
          <input type="hidden" name="action" value="request_waiver" />
          <p class="font-semibold text-ink mb-1 text-[0.92rem]">Can't pay? Request a fee waiver</p>
          <p class="text-[0.8rem] text-ink-soft leading-relaxed mb-3">To keep out spam and protect genuine applicants, a waiver needs a real case. Tell us <strong>about yourself</strong> — a summarised CV and your motivation — and <strong>demonstrate your financial need</strong> in writing (<strong>200–500 words</strong>), plus a link to a proof of income or other valid proof.</p>
          {msg && msg !== 'waiver_submitted' && <p class="text-[0.82rem] text-red-700 mb-2">{msg}</p>}
          <textarea name="reason" id="waiverReason" rows="8" required placeholder="About you (summarised CV), your motivation, and your financial need — 200 to 500 words." class="w-full px-3 py-2.5 bg-white border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn mb-1"></textarea>
          <p class="text-[0.74rem] text-ink-soft mb-3"><span id="wordCount">0</span> / 200–500 words</p>
          <input type="url" name="proof_url" required placeholder="https://… link to proof of income / valid proof" class="w-full px-3 py-2.5 bg-white border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn mb-3" />
          <button type="submit" class="w-full bg-ink hover:bg-ink/90 text-white font-semibold py-2.5 rounded-lg text-[0.88rem]">Request waiver (profile stays pending)</button>
        </form>
        <script is:inline>
          (function () {
            var ta = document.getElementById('waiverReason'), wc = document.getElementById('wordCount');
            if (!ta || !wc) return;
            function count() { var n = ta.value.trim() ? ta.value.trim().split(/\s+/).filter(Boolean).length : 0; wc.textContent = n; wc.style.color = (n >= 200 && n <= 500) ? '#15803d' : '#b45309'; }
            ta.addEventListener('input', count); count();
          })();
        </script>
      </>
    )}
  </section>

  {paymentsReady && !u.waiver_requested && (
    <>
      <script is:inline src="https://checkout.razorpay.com/v1/checkout.js"></script>
      <script is:inline>
        (function () {
          var btn = document.getElementById('payBtn');
          if (!btn) return;
          btn.addEventListener('click', function () {
            var prev = btn.textContent; btn.disabled = true; btn.textContent = 'Starting...';
            fetch('/api/payments/start-registration-fee', { method: 'POST', credentials: 'same-origin' })
              .then(function (r) { return r.json(); }).then(function (d) {
                if (!d.ok) { btn.disabled = false; btn.textContent = prev; alert(d.error || 'Could not start.'); return; }
                if (d.alreadyPaid) { window.location.href = d.redirect || '/portal'; return; }
                if (typeof Razorpay === 'undefined') { btn.disabled = false; btn.textContent = prev; alert('Razorpay failed to load.'); return; }
                var rzp = new Razorpay({
                  key: d.keyId, amount: d.amountPaise, currency: d.currency,
                  name: 'EduRankAI', description: 'Account activation (CHF 1)', order_id: d.orderId,
                  prefill: d.prefill || {}, theme: { color: '#FF4F00' },
                  handler: function (resp) {
                    btn.textContent = 'Verifying...';
                    fetch('/api/payments/verify', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({ razorpay_order_id: resp.razorpay_order_id, razorpay_payment_id: resp.razorpay_payment_id, razorpay_signature: resp.razorpay_signature }) })
                      .then(function (r) { return r.json(); }).then(function (c) {
                        if (c.ok) { window.location.href = '/portal'; } else { btn.disabled = false; btn.textContent = prev; alert(c.error || 'Verify failed.'); }
                      }).catch(function () { btn.disabled = false; btn.textContent = prev; alert('Network error.'); });
                  },
                  modal: { ondismiss: function () { btn.disabled = false; btn.textContent = prev; } },
                });
                rzp.open();
              }).catch(function () { btn.disabled = false; btn.textContent = prev; alert('Network error.'); });
          });
        })();
      </script>
    </>
  )}
</BaseLayout>
