---
// /portal/study-abroad/new — applicant submits a Study Abroad Request.
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { ensureStudyAbroadSchema, PROGRAMME_LEVELS, INTAKE_TERMS, BUDGET_BANDS, CURRENT_STAGES } from '@/lib/study-abroad';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/study-abroad/new'));
if (user.role !== 'applicant') return Astro.redirect('/admin');

await ensureStudyAbroadSchema();

let okMsg = '', errMsg = '', createdId = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const countries = (fd.get('countries') as string || '').split(',').map(s => s.trim()).filter(Boolean).slice(0, 10);
    const programme = (fd.get('programme_level') as string || '').trim() || null;
    const intakeTerm = (fd.get('intake_term') as string || '').trim() || null;
    const intakeYear = parseInt(fd.get('intake_year') as string || '0') || null;
    const budget = (fd.get('budget_band') as string || '').trim() || null;
    const stage = (fd.get('current_stage') as string || '').trim() || null;
    const notes = (fd.get('notes') as string || '').trim().slice(0, 6000);

    if (countries.length === 0 || !programme) {
      errMsg = 'At least one country and a programme level are required.';
    } else {
      const ins = await db.execute(sql`
        INSERT INTO study_abroad_requests
          (applicant_user_id, countries, programme_level, intake_term, intake_year, budget_band, current_stage, notes, status)
        VALUES (${user.id}, ${countries}, ${programme}, ${intakeTerm}, ${intakeYear}, ${budget}, ${stage}, ${notes}, 'pending')
        RETURNING id
      `);
      const rs = (Array.isArray(ins) ? ins : ((ins as any)?.rows || []));
      createdId = rs[0]?.id;
      try {
        const { sendPushToAdmins } = await import('@/lib/push');
        await sendPushToAdmins({
          type: 'study_abroad_request',
          title: 'New study-abroad request',
          body: (user.name || user.email) + ' — ' + countries.join(', ') + ' · ' + programme,
          url: '/admin/study-abroad',
          tag: 'sa-' + createdId,
        });
      } catch (_) {}
      return Astro.redirect('/portal/study-abroad');
    }
  } catch (e: any) { errMsg = 'Failed: ' + (e?.message || 'unknown'); }
}
---
<BaseLayout title="Study abroad support — EduRankAI" description="Get matched with a consultant for your study abroad plans.">
  <section class="px-[5vw] py-10 md:py-14 max-w-2xl mx-auto">
    <a href="/portal" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">&lt; Portal home</a>

    <div class="mt-4 mb-6">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">Study abroad support</p>
      <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.5rem)] font-semibold text-ink leading-[1.15] mb-3">Tell us where you want to go.</h1>
      <p class="text-[0.92rem] text-ink-soft leading-relaxed max-w-xl">
        A consultant will read your request, get back to you within 2 business days, and help you across programme research, applications, scholarships, visa, and departure. All conversation happens inside your portal — no spam.
      </p>
    </div>

    {errMsg && <div style="background:rgba(220,38,38,0.06);border:1px solid rgba(220,38,38,0.2);color:#b91c1c;font-size:0.85rem;padding:11px 14px;border-radius:8px;margin-bottom:18px;">{errMsg}</div>}

    <form method="POST" class="bg-white border border-ink/10 rounded-2xl p-6 md:p-7 flex flex-col gap-5">
      <div>
        <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-burn mb-2">Countries you're considering *</label>
        <input name="countries" required placeholder="e.g. United Kingdom, Germany, Canada" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
        <p class="text-[0.72rem] text-ink-soft mt-1">Comma-separated. Add as many as relevant — narrowing happens with the consultant.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-burn mb-2">Programme level *</label>
          <select name="programme_level" required class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2">
            <option value="">Select...</option>
            {PROGRAMME_LEVELS.map((p) => <option value={p}>{p}</option>)}
          </select>
        </div>
        <div>
          <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-burn mb-2">Intake</label>
          <div class="flex gap-2">
            <select name="intake_term" class="flex-1 px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2">
              <option value="">Term</option>
              {INTAKE_TERMS.map((t) => <option value={t}>{t}</option>)}
            </select>
            <input name="intake_year" type="number" min="2026" max="2030" placeholder="Year" class="w-24 px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-burn mb-2">Budget per year</label>
          <select name="budget_band" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2">
            <option value="">Select...</option>
            {BUDGET_BANDS.map((b) => <option value={b}>{b}</option>)}
          </select>
        </div>
        <div>
          <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-burn mb-2">Where you are right now</label>
          <select name="current_stage" class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2">
            <option value="">Select...</option>
            {CURRENT_STAGES.map((s) => <option value={s}>{s}</option>)}
          </select>
        </div>
      </div>

      <div>
        <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-burn mb-2">Anything else the consultant should know</label>
        <textarea name="notes" rows="6" maxlength="6000" placeholder="Your academic background, target programmes if any, language tests done / scheduled, deadlines you care about, specific questions." class="w-full bg-cream-2/50 border border-ink/15 rounded-lg p-3 text-[0.88rem] leading-relaxed font-light outline-none focus:border-burn"></textarea>
      </div>

      <button type="submit" class="bg-burn hover:bg-burn/90 text-white font-semibold py-3 rounded-lg text-[0.92rem]">Submit request</button>
    </form>
  </section>
</BaseLayout>
