---
// /portal/study-abroad — applicant's list of requests + their threads.
import BaseLayout from '@/layouts/BaseLayout.astro';
import { listApplicantRequests, ensureStudyAbroadSchema } from '@/lib/study-abroad';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/study-abroad'));
if (user.role !== 'applicant') return Astro.redirect('/admin');

await ensureStudyAbroadSchema();
const requests = await listApplicantRequests(user.id);

function fmt(d: any): string { try { return new Date(d).toLocaleString('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); } catch { return ''; } }
function ago(d: any): string {
  if (!d) return '';
  try {
    const diff = (Date.now() - new Date(d).getTime()) / 1000;
    if (diff < 60) return 'just now';
    if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
    if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
    return Math.floor(diff / 86400) + 'd ago';
  } catch { return ''; }
}
function statusPill(s: string) {
  if (s === 'pending') return { bg: 'rgba(250,204,21,0.14)', fg: '#92400e' };
  if (s === 'assigned') return { bg: 'rgba(59,130,246,0.12)', fg: '#1e40af' };
  if (s === 'in_progress') return { bg: 'rgba(99,102,241,0.12)', fg: '#3730a3' };
  if (s === 'completed') return { bg: 'rgba(16,185,129,0.12)', fg: '#047857' };
  if (s === 'cancelled') return { bg: 'rgba(115,115,115,0.12)', fg: '#6b7280' };
  return { bg: 'rgba(250,204,21,0.14)', fg: '#92400e' };
}
---
<BaseLayout title="Study abroad — EduRankAI" description="Your study abroad requests + consultant conversations.">
  <section class="px-[5vw] py-10 md:py-14 max-w-3xl mx-auto">
    <a href="/portal" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">&lt; Portal home</a>

    <div class="mt-4 mb-6 flex justify-between items-baseline gap-3 flex-wrap">
      <div>
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">Study abroad</p>
        <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.5rem)] font-semibold text-ink leading-[1.15] mb-1">Your requests</h1>
      </div>
      <a href="/portal/study-abroad/new" class="inline-block bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.88rem] no-underline">+ New request</a>
    </div>

    {requests.length === 0 ? (
      <div class="bg-cream-2/60 border border-ink/10 rounded-2xl p-8 text-center">
        <p class="text-[0.92rem] text-ink-soft mb-4">No study-abroad requests yet.</p>
        <a href="/portal/study-abroad/new" class="inline-block bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-6 rounded-lg text-[0.9rem] no-underline">Start your first request</a>
      </div>
    ) : (
      <div class="flex flex-col gap-3">
        {requests.map((r: any) => {
          const pill = statusPill(r.status);
          return (
            <a href={'/portal/study-abroad/' + r.id} class="bg-white border border-ink/10 rounded-xl p-5 hover:border-burn transition-colors no-underline" style="color:inherit;display:block;">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:14px;margin-bottom:8px;flex-wrap:wrap;">
                <div style="min-width:0;flex:1;">
                  <p class="font-display text-[1.05rem] font-semibold text-ink leading-tight m-0">{(r.countries || []).join(', ')} · {r.programme_level}</p>
                  <p class="text-[0.78rem] text-ink-soft mt-1 m-0">Submitted {fmt(r.created_at)} {r.consultant_name && ' · Consultant: ' + r.consultant_name}</p>
                </div>
                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:5px;flex-shrink:0;">
                  <span style={'font-family:JetBrains Mono,monospace;font-size:10px;text-transform:uppercase;letter-spacing:0.14em;font-weight:700;padding:3px 10px;border-radius:100px;background:' + pill.bg + ';color:' + pill.fg + ';'}>{r.status.replace('_', ' ')}</span>
                  {r.unread > 0 && <span style="background:#FF4F00;color:#fff;font-size:10px;font-weight:700;padding:2px 8px;border-radius:100px;">{r.unread} new</span>}
                </div>
              </div>
              <p class="text-[0.72rem] text-ink-soft m-0" style="font-family:'JetBrains Mono',monospace;">Last activity {ago(r.last_message_at)} →</p>
            </a>
          );
        })}
      </div>
    )}
  </section>
</BaseLayout>
