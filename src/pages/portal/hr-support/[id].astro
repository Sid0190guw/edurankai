---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { ensureHrSupportSchema, SUPPORT_KINDS } from '@/lib/hr-support';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const { id } = Astro.params;
if (!id) return Astro.redirect('/portal/hr-support');

await ensureHrSupportSchema();
function rowsOf(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const body = (fd.get('body') as string || '').trim().slice(0, 8000);
    if (!body) errMsg = 'Reply cannot be empty.';
    else {
      await db.execute(sql`
        INSERT INTO hr_support_messages (request_id, sender_role, sender_user_id, sender_name, body)
        VALUES (${id}, 'candidate', ${user.id}, ${user.name || user.email}, ${body})
      `);
      okMsg = 'Reply sent.';
    }
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 240); }
}

const r = rowsOf(await db.execute(sql`
  SELECT * FROM hr_application_support WHERE id = ${id}
    AND (candidate_email = ${user.email} OR user_id = ${user.id})
  LIMIT 1
`))[0] as any;
if (!r) return Astro.redirect('/portal/hr-support');

const messages = rowsOf(await db.execute(sql`
  SELECT id, sender_role, sender_name, body, meta, created_at FROM hr_support_messages
  WHERE request_id = ${id} ORDER BY created_at ASC LIMIT 500
`));

function fmt(d: any) { try { return new Date(d).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' }); } catch { return ''; } }
const kindMeta = SUPPORT_KINDS[r.support_kind] || SUPPORT_KINDS.general;
const status = r.completed_at ? 'completed' : r.meet_scheduled_at ? 'scheduled' : r.payment_status === 'paid' ? 'paid' : 'awaiting payment';
const tone = status === 'completed' ? 'bg-plum-bg text-plum border-plum-border'
  : status === 'scheduled' ? 'bg-sky-bg text-sky border-sky-border'
  : status === 'paid' ? 'bg-leaf-bg text-leaf border-leaf-border'
  : 'bg-gold-bg text-gold-deep border-gold-border';
---
<BaseLayout title={"HR Support · " + kindMeta.label}>
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/hr-support" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All sessions</a>

  <div class="mt-5 mb-6 flex justify-between items-start flex-wrap gap-3">
    <div>
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-sky font-bold mb-2">{kindMeta.label}</p>
      <h1 class="font-display text-[clamp(1.6rem,4vw,2.2rem)] font-semibold text-ink leading-[1.15] mb-2">{r.requested_slot_label || fmt(r.requested_slot_at) || 'Session'}</h1>
      <p class="text-[0.86rem] text-ink-soft m-0">Booked {fmt(r.created_at)}</p>
    </div>
    <span class={`font-mono text-[0.62rem] uppercase tracking-[0.14em] font-bold px-3 py-1.5 rounded-full border ${tone}`}>{status}</span>
  </div>

  {r.meet_link && (
    <a href={r.meet_link} target="_blank" class="block bg-sky text-white rounded-2xl px-5 py-4 mb-5 no-underline hover:bg-sky/90" style="color:#fff;">
      <p class="text-[0.6rem] font-mono uppercase tracking-[0.14em] font-bold m-0 mb-1" style="opacity:0.9;">Google Meet ready</p>
      <p class="font-display text-[1.1rem] font-semibold m-0">Join the call →</p>
      <p class="text-[0.78rem] m-0 mt-1" style="opacity:0.85;font-family:'JetBrains Mono',monospace;">{r.meet_link}</p>
    </a>
  )}
</section>

<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-5 md:p-6 mb-5">
    <p class="text-[0.6rem] font-mono uppercase tracking-[0.14em] text-burn font-bold mb-2">Your original request</p>
    <p class="text-[0.92rem] text-ink-2 leading-relaxed m-0 whitespace-pre-wrap">{r.situation}</p>
  </div>

  <p class="eyebrow mb-3">Thread ({messages.length})</p>

  {messages.length === 0 ? (
    <div class="bg-cream-2/40 border border-ink/10 rounded-xl p-5 text-[0.88rem] text-ink-soft mb-5">No messages yet. Our HR team will reach out within 24 hours of payment.</div>
  ) : (
    <div class="space-y-3 mb-5">
      {messages.map((m: any) => (
        <div class={`rounded-2xl p-4 md:p-5 ${m.sender_role === 'admin' ? 'bg-sky-bg/50 border border-sky-border' : 'bg-white border border-ink/10'}`}>
          <p class="text-[0.62rem] font-mono uppercase tracking-[0.12em] text-ink-soft font-bold mb-1">{m.sender_role === 'admin' ? 'EduRankAI HR' : 'You'} · {fmt(m.created_at)}</p>
          <p class="text-[0.92rem] text-ink-2 leading-relaxed m-0 whitespace-pre-wrap">{m.body}</p>
          {m.meta && m.meta.meet_link && <p class="text-[0.82rem] text-sky font-semibold m-0 mt-2"><a href={m.meta.meet_link} target="_blank" class="underline">Join meeting →</a></p>}
        </div>
      ))}
    </div>
  )}

  {okMsg && <div class="bg-leaf-bg border border-leaf-border rounded-xl px-4 py-3 mb-4 text-[0.88rem] text-leaf font-semibold">{okMsg}</div>}
  {errMsg && <div class="bg-burn-pale border border-burn-dim rounded-xl px-4 py-3 mb-4 text-[0.88rem] text-burn font-semibold">{errMsg}</div>}

  <form method="POST" class="bg-white border border-ink/10 rounded-2xl p-5">
    <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Reply</label>
    <textarea name="body" rows="4" required class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.92rem] text-ink font-body leading-relaxed resize-y focus:border-sky focus:outline-none" placeholder="Type your reply..."></textarea>
    <div class="flex justify-end mt-3"><button type="submit" class="bg-sky hover:bg-sky/90 text-white font-semibold py-2.5 px-5 rounded-xl text-[0.88rem]">Send reply →</button></div>
  </form>
</section>
</BaseLayout>
