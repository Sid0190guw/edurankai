---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { ensureHrSupportSchema, SUPPORT_KINDS } from '@/lib/hr-support';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/hr-support'));

await ensureHrSupportSchema();
function rowsOf(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

const myReqs = rowsOf(await db.execute(sql`
  SELECT id, support_kind, situation, requested_slot_label, requested_slot_at, fee_amount, fee_currency,
    payment_status, meet_link, meet_scheduled_at, completed_at, created_at,
    (SELECT COUNT(*) FROM hr_support_messages WHERE request_id = hr_application_support.id) AS msg_count
  FROM hr_application_support
  WHERE candidate_email = ${user.email} OR user_id = ${user.id}
  ORDER BY created_at DESC LIMIT 100
`));

function fmt(d: any) { try { return new Date(d).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' }); } catch { return ''; } }
---
<BaseLayout title="HR Application Support · My requests">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← Portal home</a>

  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-sky font-bold mb-2">HR application support</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.5rem)] font-semibold text-ink leading-[1.15] mb-3">Your support sessions</h1>
    <p class="text-[0.92rem] text-ink-soft leading-relaxed">Bookings, confirmations, and the thread with our HR team — in one place.</p>
  </div>
</section>

<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  {myReqs.length === 0 ? (
    <div class="bg-cream-2/60 border border-ink/10 rounded-2xl p-8 text-center">
      <p class="font-display text-[1.2rem] font-semibold text-ink mb-2">No sessions yet</p>
      <p class="text-[0.9rem] text-ink-soft mb-5">Book a 25 CHF call with our HR team to get guided through your application.</p>
      <a href="/careers/hr-support" class="btn-primary inline-block">Book a call →</a>
    </div>
  ) : (
    <div class="space-y-3">
      {myReqs.map((r: any) => {
        const kindMeta = SUPPORT_KINDS[r.support_kind] || SUPPORT_KINDS.general;
        const status = r.completed_at ? 'completed' : r.meet_scheduled_at ? 'scheduled' : r.payment_status === 'paid' ? 'paid' : 'awaiting payment';
        const tone = status === 'completed' ? 'bg-plum-bg text-plum border-plum-border'
          : status === 'scheduled' ? 'bg-sky-bg text-sky border-sky-border'
          : status === 'paid' ? 'bg-leaf-bg text-leaf border-leaf-border'
          : 'bg-gold-bg text-gold-deep border-gold-border';
        return (
          <a href={'/portal/hr-support/' + r.id} class="block bg-white border border-ink/10 hover:border-sky rounded-2xl p-5 no-underline" style="color:inherit;">
            <div class="flex justify-between flex-wrap gap-2 mb-2">
              <div>
                <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-sky font-bold mb-1">{kindMeta.label}</p>
                <p class="font-display text-[1.05rem] font-semibold text-ink m-0">{r.requested_slot_label || fmt(r.requested_slot_at) || 'Slot pending'}</p>
              </div>
              <span class={`font-mono text-[0.62rem] uppercase tracking-[0.14em] font-bold px-2.5 py-1 rounded-full border ${tone}`}>{status}</span>
            </div>
            <p class="text-[0.85rem] text-ink-soft m-0">Fee: {r.fee_currency} {Number(r.fee_amount).toFixed(2)} · Messages: {r.msg_count || 0}</p>
            {r.meet_link && <p class="text-[0.82rem] text-sky m-0 mt-2 font-semibold">Meet link ready · open thread to join</p>}
          </a>
        );
      })}
    </div>
  )}

  <p class="text-center mt-8"><a href="/careers/hr-support" class="text-sky font-semibold underline underline-offset-2 text-[0.88rem]">+ Book another session</a></p>
</section>
</BaseLayout>
