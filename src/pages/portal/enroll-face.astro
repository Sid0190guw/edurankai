---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const isNew = new URL(Astro.request.url).searchParams.get('new') === '1';
let okMsg = '', errorMsg = '';
let enrolled = false;

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  if (action === 'enroll') {
    const descriptor = fd.get('face_descriptor') as string;
    try {
      const parsed = JSON.parse(descriptor);
      if (Array.isArray(parsed) && parsed.length === 128) {
        await db.execute(sql`
          INSERT INTO user_face_enrollments (user_id, face_descriptor, device_info, is_active)
          VALUES (${user.id}, ${descriptor}, ${Astro.request.headers.get('user-agent') || null}, true)
          ON CONFLICT (user_id) DO UPDATE SET face_descriptor = ${descriptor}, enrolled_at = NOW(), is_active = true
        `);
        return Astro.redirect('/portal?enrolled=1');
      } else { errorMsg = 'Invalid face data. Try again.'; }
    } catch(e: any) { errorMsg = e.message; }
  } else if (action === 'skip') {
    return Astro.redirect('/portal');
  }
}

try {
  const r = await db.execute(sql`SELECT id FROM user_face_enrollments WHERE user_id = ${user.id} AND is_active = true LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  enrolled = rows.length > 0;
} catch(e) {}
---
<!doctype html>
<html lang="en" style="background:#08080a;">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Set Up Face Login - EduRankAI</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #08080a; min-height: 100vh; display: flex; align-items: center; justify-content: center; font-family: system-ui, sans-serif; padding: 16px; }
    .card { background: #0f0f14; border: 1px solid #1a1a1f; border-radius: 16px; width: 100%; max-width: 420px; overflow: hidden; }
    .card-header { padding: 24px; border-bottom: 1px solid #1a1a1f; text-align: center; }
    .card-body { padding: 20px; }
    .logo { font-size: 20px; font-weight: 800; color: #fff; margin-bottom: 16px; }
    .logo em { font-style: normal; color: #FF4F00; }
    .step-badge { background: rgba(255,79,0,0.1); border: 1px solid rgba(255,79,0,0.2); border-radius: 100px; padding: 4px 12px; font-size: 11px; font-weight: 700; color: #FF7040; display: inline-block; margin-bottom: 12px; }
    .cam-box { background: #000; border-radius: 12px; overflow: hidden; aspect-ratio: 4/3; position: relative; margin-bottom: 14px; }
    .cam-box video { width: 100%; height: 100%; object-fit: cover; transform: scaleX(-1); }
    .oval { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; pointer-events: none; }
    .oval-ring { width: 160px; height: 200px; border: 2px solid rgba(255,79,0,0.6); border-radius: 50%; }
    .cam-status { position: absolute; bottom: 10px; left: 0; right: 0; text-align: center; }
    .cam-status span { background: rgba(0,0,0,0.7); color: #fff; font-size: 11px; padding: 3px 10px; border-radius: 100px; }
    .btn { width: 100%; border: none; font-weight: 600; font-size: 14px; padding: 12px; border-radius: 10px; cursor: pointer; }
    .btn-primary { background: #FF4F00; color: #fff; }
    .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-skip { background: transparent; color: #6e6e78; font-size: 13px; padding: 10px; }
    .benefit { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
    .benefit-icon { width: 32px; height: 32px; border-radius: 8px; background: rgba(255,79,0,0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  </style>
</head>
<body>
<div class="card">
  <div class="card-header">
    <div class="logo">EduRank<em>AI</em></div>
    {isNew && <div class="step-badge">Account Created - Step 2 of 2</div>}
    <h1 style="font-size:18px;font-weight:700;color:#fff;margin:0 0 6px;">{enrolled ? 'Update Face Login' : 'Set Up Face Login'}</h1>
    <p style="font-size:13px;color:#6e6e78;">{enrolled ? 'Your face is enrolled. You can update it here.' : 'Log in instantly with your face - no password needed next time.'}</p>
  </div>

  <div class="card-body">
    {errorMsg && <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;border-radius:8px;padding:10px 14px;font-size:13px;margin-bottom:14px;">{errorMsg}</div>}

    <!-- Benefits -->
    {!enrolled && (
      <div style="margin-bottom:16px;">
        {[
          { icon: '&#128274;', text: 'No password to remember or forget' },
          { icon: '&#9889;', text: 'Log in in under 2 seconds' },
          { icon: '&#128274;', text: 'Your face data never leaves your device' },
        ].map(b => (
          <div class="benefit">
            <div class="benefit-icon"><span style="font-size:16px;" set:html={b.icon}></span></div>
            <p style="font-size:13px;color:#d8d8de;margin:0;">{b.text}</p>
          </div>
        ))}
      </div>
    )}

    <!-- Camera -->
    <div class="cam-box">
      <video id="video" autoplay playsinline muted></video>
      <div class="oval"><div class="oval-ring" id="ovalRing"></div></div>
      <div class="cam-status"><span id="camStatus">Loading camera...</span></div>
    </div>

    <div style="background:#15151a;border-radius:100px;height:3px;margin-bottom:12px;">
      <div id="loadProg" style="background:#FF4F00;height:100%;width:0%;border-radius:100px;transition:width 0.4s;"></div>
    </div>

    <button id="captureBtn" class="btn btn-primary" disabled onclick="doCapture()">Loading face detection...</button>

    <form method="POST" style="margin-top:10px;">
      <input type="hidden" name="action" value="skip"/>
      <button type="submit" class="btn btn-skip">Skip for now - I'll set this up later</button>
    </form>
  </div>
</div>

<form id="enrollForm" method="POST" style="display:none;">
  <input type="hidden" name="action" value="enroll"/>
  <input type="hidden" id="faceInput" name="face_descriptor"/>
</form>

<script is:inline src="https://cdn.jsdelivr.net/npm/@vladmandic/face-api@1.7.13/dist/face-api.min.js"></script>
<script is:inline>
var video = document.getElementById('video');
var captureBtn = document.getElementById('captureBtn');
var camStatus = document.getElementById('camStatus');
var loadProg = document.getElementById('loadProg');
var ovalRing = document.getElementById('ovalRing');
var modelsLoaded = false;

function setStatus(msg, color) {
  camStatus.innerHTML = '<span style="background:rgba(0,0,0,0.7);color:'+(color||'#fff')+';font-size:11px;padding:3px 10px;border-radius:100px;">'+msg+'</span>';
}

async function init() {
  try {
    setStatus('Loading face model...');
    loadProg.style.width = '20%';
    var MODEL_URL = 'https://cdn.jsdelivr.net/npm/@vladmandic/face-api@latest/model';
    // Initialise the TF backend BEFORE detection (else detect throws "backend not initialized").
    try {
      if (window.faceapi && faceapi.tf) {
        try { await faceapi.tf.setBackend('webgl'); } catch (_) {}
        if (faceapi.tf.getBackend && !faceapi.tf.getBackend()) { try { await faceapi.tf.setBackend('wasm'); } catch (_) {} }
        if (faceapi.tf.ready) await faceapi.tf.ready();
      }
    } catch (_) {}
    await Promise.all([
      faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL),
      faceapi.nets.faceLandmark68TinyNet.loadFromUri(MODEL_URL),
      faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL),
    ]);
    loadProg.style.width = '60%';
    var stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: 640 } });
    video.srcObject = stream;
    loadProg.style.width = '100%';
    setTimeout(function() {
      loadProg.style.display = 'none';
      modelsLoaded = true;
      captureBtn.disabled = false;
      captureBtn.textContent = 'Capture & Save Face';
      setStatus('Position face in oval', '#10b981');
      ovalRing.style.borderColor = 'rgba(16,185,129,0.7)';
      detectLoop();
    }, 400);
  } catch(e) {
    setStatus('Camera error: ' + e.message, '#ef4444');
  }
}

async function detectLoop() {
  if (!video || !modelsLoaded) return;
  try {
    var det = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions()).withFaceLandmarks(true);
    if (det) {
      setStatus('Face detected - ready!', '#10b981');
      ovalRing.style.borderColor = 'rgba(255,79,0,0.8)';
      captureBtn.style.background = '#10b981';
    } else {
      setStatus('Center your face in the oval', '#fbbf24');
      ovalRing.style.borderColor = 'rgba(255,79,0,0.5)';
      captureBtn.style.background = '#FF4F00';
    }
  } catch(e) {}
  setTimeout(detectLoop, 600);
}

async function doCapture() {
  if (!modelsLoaded) return;
  captureBtn.disabled = true;
  captureBtn.textContent = 'Scanning...';
  setStatus('Analyzing face...', '#fbbf24');
  try {
    var descriptors = [];
    for (var i = 0; i < 5; i++) {
      var det = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions())
        .withFaceLandmarks(true).withFaceDescriptor();
      if (det) descriptors.push(Array.from(det.descriptor));
      await new Promise(function(r) { setTimeout(r, 200); });
    }
    if (descriptors.length < 2) {
      setStatus('No face detected. Try again.', '#ef4444');
      captureBtn.disabled = false;
      captureBtn.textContent = 'Try Again';
      return;
    }
    var avg = new Array(128).fill(0);
    descriptors.forEach(function(d) { d.forEach(function(v, i) { avg[i] += v / descriptors.length; }); });
    document.getElementById('faceInput').value = JSON.stringify(avg);
    setStatus('Face captured! Saving...', '#10b981');
    document.getElementById('enrollForm').submit();
  } catch(e) {
    setStatus('Error: ' + e.message, '#ef4444');
    captureBtn.disabled = false;
    captureBtn.textContent = 'Try Again';
  }
}

init();
</script>
</body>
</html>
