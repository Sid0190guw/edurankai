---
import BaseLayout from '@/layouts/BaseLayout.astro';

let message = '';
let messageType = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const email = (fd.get('email') as string || '').trim().toLowerCase();

  if (!email) {
    message = 'Please enter your email address.';
    messageType = 'error';
  } else {
    const { db } = await import('@/lib/db');
    const { applications } = await import('@/lib/db/schema');
    const { eq } = await import('drizzle-orm');

    const found = await db.select({
      applicationNumber: applications.applicationNumber,
      firstName: applications.firstName,
      roleTitleSnapshot: applications.roleTitleSnapshot,
      dob: applications.dob,
      createdAt: applications.createdAt
    }).from(applications).where(eq(applications.email, email)).limit(10);

    if (found.length === 0) {
      message = 'No applications found with that email. Please check the email or contact hr@edurankai.in.';
      messageType = 'error';
    } else {
      // For privacy: don't return data publicly. Show generic success and direct to support.
      message = `We found ${found.length} application${found.length > 1 ? 's' : ''} associated with this email. Our team will email your application details to ${email} within 24 hours. For immediate help, contact hr@edurankai.in.`;
      messageType = 'success';
    }
  }
}
---
<BaseLayout title="Forgot details - EduRankAI Portal" description="Recover your application number">
  <section class="px-[5vw] py-16 md:py-20 max-w-md mx-auto">
    <div class="mb-8 text-center">
      <p class="eyebrow mb-3">Applicant Portal</p>
      <h1 class="font-display text-3xl md:text-4xl font-semibold text-ink leading-tight mb-3">
        Forgot details?
      </h1>
      <p class="text-[0.88rem] text-ink-soft">
        Enter the email you used when applying. We'll send your application number.
      </p>
    </div>

    {messageType === 'error' && (
      <div style="background:rgba(220,38,38,0.06);border:1px solid rgba(220,38,38,0.2);color:#b91c1c;font-size:0.85rem;padding:11px 14px;border-radius:8px;margin-bottom:18px;">
        {message}
      </div>
    )}

    {messageType === 'success' && (
      <div style="background:rgba(46,125,50,0.06);border:1px solid rgba(46,125,50,0.2);color:#2e7d32;font-size:0.85rem;padding:11px 14px;border-radius:8px;margin-bottom:18px;">
        {message}
      </div>
    )}

    <form method="POST" class="bg-white border border-ink/10 rounded-2xl p-6 md:p-7 flex flex-col gap-5">
      <div>
        <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Email used when applying</label>
        <input type="email" name="email" required autocomplete="email" placeholder="you@example.com" class="w-full px-4 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
      </div>
      <button type="submit" class="btn-primary w-full justify-center mt-2">Recover details</button>
    </form>

    <p class="text-center text-[0.85rem] text-ink-soft mt-6">
      Remember now? <a href="/portal/login" class="text-burn font-semibold hover:underline">Back to sign in</a>
    </p>

    <p class="text-center text-[0.78rem] text-ink-soft mt-3">
      Still stuck? Email <a href="mailto:hr@edurankai.in" class="text-burn hover:underline">hr@edurankai.in</a>
    </p>
  </section>
</BaseLayout>
