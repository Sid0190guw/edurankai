---
import BaseLayout from '@/layouts/BaseLayout.astro';

let message = '';
let messageType = '';
let foundApps: any[] = [];
let foundUserOnly = false;

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const email = (fd.get('email') as string || '').trim().toLowerCase();

  if (!email) {
    message = 'Please enter your email address.';
    messageType = 'error';
  } else {
    const { db } = await import('@/lib/db');
    const { applications, users } = await import('@/lib/db/schema');
    const { eq, desc } = await import('drizzle-orm');

    // Look up applications
    foundApps = await db.select({
      applicationNumber: applications.applicationNumber,
      firstName: applications.firstName,
      roleTitleSnapshot: applications.roleTitleSnapshot,
      dob: applications.dob,
      createdAt: applications.createdAt
    }).from(applications).where(eq(applications.email, email)).orderBy(desc(applications.createdAt)).limit(10);

    if (foundApps.length === 0) {
      // Also check the users table - in case they signed up but haven't applied yet
      const userFound = await db.select({ id: users.id, role: users.role }).from(users).where(eq(users.email, email)).limit(1);
      if (userFound.length > 0 && userFound[0].role === 'applicant') {
        foundUserOnly = true;
        messageType = 'success';
      } else {
        message = 'No account or application found with that email. Please check the email, or sign up if you are new. Need help? Contact hr@edurankai.in';
        messageType = 'error';
      }
    } else {
      messageType = 'success';
    }
  }
}

function fmtDob(d: string | null): string {
  if (!d) return '(not on file)';
  try {
    return new Date(d).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
  } catch {
    return d;
  }
}

function fmtDate(d: Date | string | null): string {
  if (!d) return '';
  return new Date(d).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
}
---
<BaseLayout title="Forgot details - EduRankAI Portal" description="Recover your application number">
  <section class="px-[5vw] py-16 md:py-20 max-w-lg mx-auto">

    <div class="mb-8 text-center">
      <p class="eyebrow mb-3">Applicant Portal</p>
      <h1 class="font-display text-3xl md:text-4xl font-semibold text-ink leading-tight mb-3">
        Forgot your details?
      </h1>
      <p class="text-[0.88rem] text-ink-soft leading-relaxed">
        Enter the email you used to apply or sign up. We'll show your application numbers and remind you how to sign in.
      </p>
    </div>

    {messageType === 'error' && (
      <div style="background:rgba(220,38,38,0.06);border:1px solid rgba(220,38,38,0.2);color:#b91c1c;font-size:0.85rem;padding:11px 14px;border-radius:8px;margin-bottom:18px;line-height:1.6;">
        {message}
      </div>
    )}

    {messageType === 'success' && foundApps.length > 0 && (
      <div class="bg-leaf-bg/40 border border-leaf-border rounded-2xl p-5 mb-6">
        <p class="text-[0.72rem] font-mono uppercase tracking-wider text-leaf font-bold mb-3">Found {foundApps.length} application{foundApps.length > 1 ? 's' : ''}</p>
        <div class="flex flex-col gap-3">
          {foundApps.map((app) => (
            <div class="bg-white border border-leaf-border/40 rounded-lg p-3">
              <div class="flex justify-between items-start gap-3 flex-wrap">
                <div>
                  <p class="text-[0.78rem] text-ink-soft">Application number</p>
                  <p class="font-mono font-bold text-ink text-[1.05rem] tracking-tight">{app.applicationNumber || '(legacy - email us)'}</p>
                </div>
                <div class="text-right">
                  <p class="text-[0.78rem] text-ink-soft">Applied</p>
                  <p class="text-[0.85rem] text-ink-2">{fmtDate(app.createdAt)}</p>
                </div>
              </div>
              {app.roleTitleSnapshot && <p class="text-[0.82rem] text-ink-2 mt-2">{app.roleTitleSnapshot}</p>}
              <p class="text-[0.72rem] text-ink-soft mt-2 italic">DOB on file: {fmtDob(app.dob)}</p>
            </div>
          ))}
        </div>
        <div class="mt-4 pt-4 border-t border-leaf-border/40">
          <p class="text-[0.85rem] text-ink-2 leading-relaxed">
            <strong>To sign in:</strong> Go to <a href="/portal/login" class="text-burn font-semibold hover:underline">/portal/login</a> and use either:
          </p>
          <ul class="text-[0.83rem] text-ink-2 list-disc pl-5 mt-2 space-y-1">
            <li>Your email + password</li>
            <li>Your application number + date of birth</li>
          </ul>
          <p class="text-[0.78rem] text-ink-soft mt-3 italic">
            If you forgot your password, sign in with application number + DOB instead. For other help: <a href="mailto:hr@edurankai.in" class="text-burn hover:underline">hr@edurankai.in</a>
          </p>
        </div>
      </div>
    )}

    {messageType === 'success' && foundUserOnly && (
      <div class="bg-gold-bg/30 border border-gold-border rounded-2xl p-5 mb-6">
        <p class="text-[0.72rem] font-mono uppercase tracking-wider text-gold-deep font-bold mb-3">Account found, no applications yet</p>
        <p class="text-[0.92rem] text-ink-2 leading-relaxed mb-3">
          You have a portal account with this email but haven't submitted any applications yet.
        </p>
        <p class="text-[0.88rem] text-ink-2 leading-relaxed">
          To sign in, go to <a href="/portal/login" class="text-burn font-semibold hover:underline">/portal/login</a> and use your email and password.
        </p>
        <p class="text-[0.82rem] text-ink-soft mt-3 italic">
          If you forgot your password, contact <a href="mailto:hr@edurankai.in" class="text-burn hover:underline">hr@edurankai.in</a> for help.
        </p>
      </div>
    )}

    <form method="POST" class="bg-white border border-ink/10 rounded-2xl p-6 md:p-7 flex flex-col gap-5">
      <div>
        <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Email</label>
        <input type="email" name="email" required autocomplete="email" placeholder="you@example.com" class="w-full px-4 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
      </div>
      <button type="submit" class="bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-6 rounded-lg text-[0.9rem]">
        Look up my details
      </button>
      <div class="text-center text-[0.78rem] text-ink-soft pt-2">
        <a href="/portal/login" class="text-burn hover:underline">&larr; Back to sign in</a>
        <span class="mx-2">&middot;</span>
        <a href="/portal/signup" class="text-burn hover:underline">Don't have an account?</a>
      </div>
    </form>

  </section>
</BaseLayout>