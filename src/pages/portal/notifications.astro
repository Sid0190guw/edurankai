---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/notifications'));
if (user.role !== 'applicant') return Astro.redirect('/admin');

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

try {
  await db.execute(sql`CREATE TABLE IF NOT EXISTS notifications (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    title TEXT NOT NULL, body TEXT,
    type TEXT NOT NULL DEFAULT 'info', action_url TEXT,
    entity_type TEXT, entity_id TEXT,
    is_read BOOLEAN DEFAULT false, read_at TIMESTAMPTZ,
    created_at TIMESTAMPTZ DEFAULT NOW())`);
} catch (_) {}

const items = rows(await db.execute(sql`
  SELECT id, title, body, type, action_url, is_read, created_at
  FROM notifications WHERE user_id = ${user.id}
  ORDER BY created_at DESC LIMIT 200
`));
const unreadCount = items.filter((n: any) => !n.is_read).length;

function fmt(d: any): string {
  try {
    const now = Date.now();
    const t = new Date(d).getTime();
    const diff = (now - t) / 1000;
    if (diff < 60) return 'just now';
    if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
    if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
    if (diff < 604800) return Math.floor(diff / 86400) + 'd ago';
    return new Date(d).toLocaleDateString('en-IN', { day: '2-digit', month: 'short' });
  } catch { return ''; }
}

function typeAccent(t: string): string {
  if (t === 'visvambhara_reply' || t === 'fee_waiver_reply' || t === 'inbound_mail') return '#d97757';
  if (t === 'fee_waiver_approved' || t === 'application_approved') return '#10b981';
  if (t === 'fee_waiver_rejected' || t === 'application_rejected') return '#dc2626';
  if (t === 'test_submitted' || t === 'interview_completed' || t === 'course_completed') return '#3b82f6';
  if (t === 'certificate_issued' || t === 'friend_joined') return '#f59e0b';
  return '#FF4F00';
}
---
<BaseLayout title="Notifications" description="Your activity, replies, and updates from EduRankAI.">
  <section class="px-[5vw] py-8 md:py-12 max-w-3xl mx-auto">
    <div class="flex items-baseline justify-between gap-3 mb-6 flex-wrap">
      <div>
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-1">Activity feed</p>
        <h1 class="font-display text-[clamp(1.6rem,4vw,2.2rem)] font-semibold text-ink leading-[1.15]">Notifications {unreadCount > 0 && <span class="ml-2 align-middle text-[0.85rem] bg-burn text-white px-2.5 py-1 rounded-full font-mono font-bold">{unreadCount}</span>}</h1>
      </div>
      {unreadCount > 0 && (
        <button id="markAllBtn" class="text-[0.82rem] font-semibold text-burn hover:underline">Mark all as read</button>
      )}
    </div>

    {items.length === 0 ? (
      <div class="bg-cream-2 border border-ink/10 rounded-2xl p-10 text-center">
        <p class="text-[0.95rem] text-ink-soft">No notifications yet. We'll let you know when there's activity on your application or messages.</p>
      </div>
    ) : (
      <ul id="notifList" class="space-y-2.5">
        {items.map((n: any) => {
          const accent = typeAccent(n.type);
          return (
            <li data-notif-id={n.id} data-unread={!n.is_read ? '1' : '0'} class={(n.is_read ? 'bg-white' : 'bg-burn-pale/30') + ' border border-ink/10 rounded-xl overflow-hidden transition-all'}>
              <a href={n.action_url || '#'} class="flex items-stretch gap-3 px-4 py-3.5 no-underline text-ink hover:bg-burn-pale/40 transition-colors">
                <span style={'flex-shrink:0;width:4px;background:' + accent + ';border-radius:2px;'}></span>
                <div class="flex-1 min-w-0">
                  <div class="flex items-baseline justify-between gap-3 mb-0.5">
                    <p class={'text-[0.92rem] font-semibold ' + (n.is_read ? 'text-ink-2' : 'text-ink')} style="margin:0;line-height:1.3;">{n.title}</p>
                    <span class="text-[0.7rem] font-mono text-ink-soft whitespace-nowrap flex-shrink-0">{fmt(n.created_at)}</span>
                  </div>
                  {n.body && <p class="text-[0.82rem] text-ink-soft leading-[1.5] m-0 line-clamp-2">{n.body}</p>}
                </div>
                {!n.is_read && <span class="self-center w-2 h-2 rounded-full flex-shrink-0" style={'background:' + accent + ';'}></span>}
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </section>

  <script is:inline>
    (function () {
      var btn = document.getElementById('markAllBtn');
      if (btn) {
        btn.addEventListener('click', function () {
          btn.textContent = 'Marking...';
          fetch('/api/portal/notifications-recent', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'mark_all_read' }) })
            .then(function (r) { return r.json(); }).then(function (d) { if (d.ok) location.reload(); else { btn.textContent = 'Mark all as read'; } })
            .catch(function () { btn.textContent = 'Mark all as read'; });
        });
      }
      // Mark individual notif as read when its row is clicked.
      document.querySelectorAll('#notifList li[data-unread="1"] a').forEach(function (a) {
        a.addEventListener('click', function () {
          var li = a.closest('li');
          var id = li && li.getAttribute('data-notif-id');
          if (!id) return;
          fetch('/api/portal/notifications-recent', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'mark_read', id: id }) }).catch(function () {});
        });
      });
    })();
  </script>
</BaseLayout>
