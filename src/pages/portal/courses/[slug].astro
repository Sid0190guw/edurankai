---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const { slug } = Astro.params;
let course: any = null;
let modules: any[] = [];
let lessons: any[] = [];
let enrollment: any = null;
let completedLessonIds: string[] = [];
let certificate: any = null;

try {
  const r = await db.execute(sql`SELECT * FROM training_courses WHERE slug = ${slug} AND is_published = true LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  course = rows[0] || null;
} catch(e) {}

if (!course) return Astro.redirect('/portal/courses');

const isEmployee = user.role !== 'applicant';
const accessOk = course.access_type === 'public' || course.access_type === 'both' ||
  (course.access_type === 'employees' && isEmployee) ||
  (course.access_type === 'applicants' && !isEmployee);
if (!accessOk) return Astro.redirect('/portal/courses');

try {
  const r = await db.execute(sql`SELECT * FROM training_enrollments WHERE course_id = ${course.id} AND user_id = ${user.id} LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  if (rows.length > 0) { enrollment = rows[0]; }
  else {
    const e = await db.execute(sql`INSERT INTO training_enrollments (course_id, user_id, progress_pct) VALUES (${course.id}, ${user.id}, 0) RETURNING *`);
    const er = Array.isArray(e) ? e : (e?.rows || []);
    enrollment = er[0];
    await db.execute(sql`UPDATE training_courses SET enrolled_count = enrolled_count + 1 WHERE id = ${course.id}`);
  }
} catch(e) {}

try {
  const r = await db.execute(sql`SELECT * FROM training_modules WHERE course_id = ${course.id} ORDER BY sort_order`);
  modules = Array.isArray(r) ? r : (r?.rows || []);
  const r2 = await db.execute(sql`SELECT * FROM training_lessons WHERE course_id = ${course.id} ORDER BY sort_order`);
  lessons = Array.isArray(r2) ? r2 : (r2?.rows || []);
} catch(e) {}

if (enrollment) {
  try {
    const r = await db.execute(sql`SELECT lesson_id FROM training_progress WHERE enrollment_id = ${enrollment.id}`);
    const rows = Array.isArray(r) ? r : (r?.rows || []);
    completedLessonIds = (rows as any[]).map((r: any) => r.lesson_id);
  } catch(e) {}
}

try {
  const r = await db.execute(sql`SELECT * FROM training_certificates WHERE course_id = ${course.id} AND user_id = ${user.id} LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  certificate = rows[0] || null;
} catch(e) {}

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  if (fd.get('action') === 'complete_lesson' && enrollment) {
    const lessonId = fd.get('lesson_id') as string;
    try {
      await db.execute(sql`INSERT INTO training_progress (enrollment_id, lesson_id) VALUES (${enrollment.id}, ${lessonId}) ON CONFLICT DO NOTHING`);
      const total = lessons.length;
      const done = completedLessonIds.length + 1;
      const pct = total > 0 ? Math.min(100, Math.round((done/total)*100)) : 0;
      await db.execute(sql`UPDATE training_enrollments SET progress_pct=${pct}, last_lesson_id=${lessonId}, updated_at=NOW() WHERE id=${enrollment.id}`);
      if (pct >= 100 && !certificate) {
        const certNum = 'ERA-CERT-' + Date.now().toString(36).toUpperCase();
        await db.execute(sql`INSERT INTO training_certificates (course_id,user_id,enrollment_id,certificate_number) VALUES (${course.id},${user.id},${enrollment.id},${certNum}) ON CONFLICT DO NOTHING`);
      }
    } catch(e) {}
    return Astro.redirect(`/portal/courses/${slug}?lesson=${lessonId}&done=1`);
  }
}

const urlP = new URL(Astro.request.url).searchParams;
const activeLessonId = urlP.get('lesson') || lessons[0]?.id || '';
const justDone = urlP.get('done') === '1';
const activeLesson = (lessons as any[]).find((l: any) => l.id === activeLessonId) || lessons[0] || null;
const progressPct = enrollment?.progress_pct || 0;
const currentIdx = activeLesson ? (lessons as any[]).findIndex((l: any) => l.id === activeLesson.id) : -1;
const prevLesson = currentIdx > 0 ? lessons[currentIdx-1] : null;
const nextLesson = currentIdx < lessons.length-1 ? lessons[currentIdx+1] : null;
const activeLessonDone = activeLesson ? completedLessonIds.includes(activeLesson.id) : false;

function getYoutubeId(url: string) {
  if (!url) return null;
  const m = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([a-zA-Z0-9_-]{11})/);
  return m ? m[1] : null;
}
function getVimeoId(url: string) {
  if (!url) return null;
  const m = url.match(/vimeo\.com\/(\d+)/);
  return m ? m[1] : null;
}

// Virtual lab configs by category
// Our OWN virtual labs (no third-party embeds) keyed by course category, plus a
// universal flagship set every course gets. Each opens /aquintutor/labs/<slug>.
import { labLabel } from '@/lib/aquintutor-authoring';
const lab = (slug: string, name: string, icon: string) => ({ name, url: '/aquintutor/labs/' + slug, icon });
const LAB_CONFIGS: Record<string,{name:string,url:string,icon:string}[]> = {
  physics:     [lab('optics-bench','Optical Bench','O'), lab('pendulum','Pendulum & SHM','P'), lab('projectile','Projectile Motion','Pr')],
  chemistry:   [lab('titration-bench','Titration Bench','T'), lab('periodic','Periodic Table','Pt'), lab('molecular','Molecular Viewer','M')],
  electronics: [lab('logic-bench','Logic Workbench','L'), lab('eee-bench','Analog Bench','A'), lab('cro-bench','Oscilloscope','C'), lab('vlsi','VLSI & Digital','V'), lab('signals-systems','Signals & Systems','Sg'), lab('dsp','DSP','D')],
  electrical:  [lab('eee','Circuits & Networks','E'), lab('eee-bench','Analog Bench','A'), lab('cro-bench','Oscilloscope','C'), lab('machines','Electrical Machines','Mc'), lab('control-systems','Control Systems','Co')],
  coding:      [lab('sorting','Sorting Visualiser','S'), lab('pathfinding','Path-finding','Pf'), lab('ai-ml','AI & ML','AI'), lab('cybersecurity','Cybersecurity','Cy'), lab('dsa-bench','Data Structures','DS'), lab('os','Operating Systems','OS'), lab('networks','Networks','Nw')],
  cs:          [lab('sorting','Sorting Visualiser','S'), lab('pathfinding','Path-finding','Pf'), lab('ai-ml','AI & ML','AI'), lab('cybersecurity','Cybersecurity','Cy'), lab('dsa-bench','Data Structures','DS'), lab('os','Operating Systems','OS'), lab('networks','Networks','Nw')],
  biology:     [lab('genetics','Punnett Square','G'), lab('ecosystem','Predator-Prey','Pp'), lab('biotech-bench','Molecular Biology','MB')],
  math:        [lab('plot','Function Plotter','F'), lab('linear-algebra','Matrix Transforms','Lx'), lab('numerical','Numerical Methods','Nm')],
  robotics:    [lab('robotics','Robotics & AI','R')],
  mechanical:  [lab('mechanical','Mechanical Engineering','Me'), lab('fluid-bench','Fluid Mechanics','Fl'), lab('structural','Structural Analysis','St')],
  civil:       [lab('structural','Structural Analysis','St'), lab('fluid-bench','Fluid Mechanics','Fl')],
  chemical:    [lab('reaction-bench','Reaction Engineering','Re'), lab('titration-bench','Titration Bench','T')],
};
const UNIVERSAL_LABS = [lab('logic-bench','Logic Workbench','L'), lab('eee-bench','Analog Bench','A'), lab('ai-ml','AI & ML','AI'), lab('plot','Function Plotter','F')];
const _catKey = (course.category || '').toString().toLowerCase().trim();
// Labs the instructor attached to THIS course (from the course editor) come first.
let _attached: {name:string,url:string,icon:string}[] = [];
try {
  let fl: any = (course as any).featured_labs;
  if (typeof fl === 'string') fl = JSON.parse(fl);
  if (Array.isArray(fl)) _attached = fl.filter((s: any) => typeof s === 'string').map((slug: string) => lab(slug, labLabel(slug), labLabel(slug).charAt(0).toUpperCase()));
} catch {}
let catLabs = _attached.concat(((LAB_CONFIGS as any)[_catKey] || []) as {name:string,url:string,icon:string}[]);
{
  const _seen = new Set<string>();
  catLabs = catLabs.filter((l) => { if (_seen.has(l.url)) return false; _seen.add(l.url); return true; });
  catLabs = catLabs.concat(UNIVERSAL_LABS.filter((l) => !_seen.has(l.url)));
}
const typeColors: Record<string,string> = {video:'#ef4444',text:'#60a5fa',quiz:'#a78bfa',pdf:'#f97316',link:'#10b981',live:'#10b981',lab:'#fbbf24',simulation:'#a78bfa'};
---
<!doctype html>
<html lang="en" style="background:#F5F1E8;">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>{course.title} - EduRankAI</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600;700&display=swap');
    :root { --ac-border: rgba(26,22,18,0.10); --ac-rule: rgba(26,22,18,0.08); }
    *{box-sizing:border-box;margin:0;padding:0;}
    body{background:#F5F1E8;color:#1A1612;font-family:'Inter',system-ui,sans-serif;min-height:100vh;-webkit-font-smoothing:antialiased;}
    h1,h2,h3,h4 { font-family:'Fraunces',Georgia,serif; font-weight:500; letter-spacing:-0.015em; }
    .topbar{background:#FBF8F1;border-bottom:1px solid rgba(26,22,18,0.10);padding:0 16px;height:52px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;}
    .layout{display:grid;grid-template-columns:300px 1fr;min-height:calc(100vh - 52px);}
    .sidebar{background:#FBF8F1;border-right:1px solid #1a1a1f;height:calc(100vh - 52px);overflow-y:auto;position:sticky;top:52px;}
    .sidebar-tabs{display:flex;border-bottom:1px solid rgba(26,22,18,0.10);}
    .stab{flex:1;padding:10px;font-size:11px;font-weight:700;text-align:center;cursor:pointer;border:none;background:transparent;color:#8B8175;border-bottom:2px solid transparent;}
    .stab.active{color:#B8512E;border-bottom-color:#B8512E;background:rgba(255,79,0,0.05);}
    .sidebar-hd{padding:10px 14px;border-bottom:1px solid rgba(26,22,18,0.10);}
    .prog-bar{background:#EFE9DC;border-radius:100px;height:4px;margin-top:6px;}
    .prog-fill{background:#B8512E;height:100%;border-radius:100px;}
    .mod-hd{padding:8px 14px;background:#EFE9DC;border-bottom:1px solid rgba(26,22,18,0.10);display:flex;align-items:center;gap:6px;}
    .l-item{padding:9px 14px;display:flex;align-items:center;gap:8px;text-decoration:none;border-bottom:1px solid #0a0a0c;transition:background 0.1s;}
    .l-item:hover{background:#EFE9DC;}
    .l-item.active{background:rgba(255,79,0,0.1);border-left:2px solid #B8512E;}
    .l-check{width:18px;height:18px;border-radius:50%;border:1.5px solid #1a1a1f;flex-shrink:0;display:flex;align-items:center;justify-content:center;}
    .l-check.done{background:#10b981;border-color:#10b981;}
    .l-check.cur{border-color:#B8512E;}
    .l-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0;}
    .l-name{font-size:12px;color:#5C544A;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
    .l-name.active{color:#B8512E;font-weight:600;}
    .main{padding:0;flex:1;overflow:hidden;}
    .vid-wrap{background:#000;aspect-ratio:16/9;}
    .vid-wrap iframe,.vid-wrap video{width:100%;height:100%;border:none;}
    .content-area{padding:20px 24px;}
    .tab-btns{display:flex;gap:6px;margin-bottom:16px;flex-wrap:wrap;}
    .tab-btn{font-size:12px;font-weight:600;padding:6px 14px;border-radius:100px;border:none;cursor:pointer;}
    .tab-btn.active{background:#B8512E;color:#1A1612;}
    .tab-btn:not(.active){background:#EFE9DC;color:#5C544A;}
    .nav-row{display:flex;gap:10px;margin-top:20px;}
    .nav-btn{flex:1;padding:12px;border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;border:none;text-decoration:none;text-align:center;display:block;}
    .cert-banner{background:linear-gradient(135deg,#1a0a00,#0f0f14);border:1px solid rgba(255,79,0,0.3);border-radius:14px;padding:24px;text-align:center;margin-bottom:20px;}
    .lab-card{background:#EFE9DC;border:1px solid var(--ac-border);border-radius:10px;padding:14px;cursor:pointer;transition:border-color 0.15s;}
    .lab-card:hover{border-color:#B8512E;}
    .live-badge{background:rgba(16,185,129,0.15);border:1px solid rgba(16,185,129,0.3);color:#6ee7b7;font-size:10px;font-weight:700;padding:2px 8px;border-radius:100px;animation:pulse 2s infinite;}
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:0.6}}
    @media(max-width:768px){.layout{grid-template-columns:1fr;}.sidebar{position:fixed;left:-300px;top:52px;height:calc(100vh - 52px);z-index:40;transition:left 0.3s;width:300px;}.sidebar.open{left:0;}.content-area{padding:14px 16px;}}
  </style>
</head>
<body>
<script is:inline define:vars={{ lid: activeLesson?.id || null, cid: course.id }}>
  window.__currentLessonId = lid;
  window.__currentCourseId = cid;
</script>
<nav class="topbar">
  <div style="display:flex;align-items:center;gap:10px;min-width:0;">
    <a href="/portal/courses" style="color:#8B8175;text-decoration:none;display:flex;align-items:center;flex-shrink:0;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    </a>
    <span style="font-size:13px;font-weight:600;color:#1A1612;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{course.title}</span>
  </div>
  <div style="display:flex;align-items:center;gap:6px;flex-shrink:0;">
    <button id="bookmarkBtn" title="Bookmark this lesson" aria-label="Bookmark lesson" style="background:#EFE9DC;border:1px solid var(--ac-border);color:#1A1612;width:32px;height:32px;border-radius:6px;cursor:pointer;display:flex;align-items:center;justify-content:center;padding:0;">
      <svg id="bookmarkSvg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
    </button>
    <a href={'/portal/courses/' + slug + '/discuss'} title="Course discussion" aria-label="Course discussion" style="background:#EFE9DC;border:1px solid var(--ac-border);color:#1A1612;width:32px;height:32px;border-radius:6px;display:flex;align-items:center;justify-content:center;text-decoration:none;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    </a>
    <span style="font-size:11px;font-family:monospace;color:#B8512E;background:#EFE9DC;border:1px solid var(--ac-border);border-radius:100px;padding:3px 10px;">{progressPct}%</span>
    <button id="sidebarToggle" onclick="document.getElementById('sidebar').classList.toggle('open')" style="background:#EFE9DC;border:1px solid var(--ac-border);color:#1A1612;padding:5px 10px;border-radius:6px;cursor:pointer;font-size:11px;">Menu</button>
  </div>
</nav>

<div class="layout">
  <!-- Sidebar -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-tabs">
      <button class="stab active" onclick="switchSidebar('lessons',this)">Lessons</button>
      <button class="stab" onclick="switchSidebar('notes',this)">Notes</button>
      <button class="stab" onclick="switchSidebar('labs',this)">Labs</button>
      <button class="stab" onclick="switchSidebar('live',this)">Live</button>
    </div>

    <!-- Notes panel -->
    <div id="panel-notes" style="display:none;padding:14px;">
      <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#B8512E;margin:0 0 8px;">My notes for this lesson</p>
      <p style="font-size:10.5px;color:#8B8175;margin:0 0 10px;line-height:1.5;">Private to you. Saved automatically.</p>
      <textarea id="noteBody" placeholder="Type as you learn..." style="width:100%;min-height:240px;background:#F5F1E8;border:1px solid var(--ac-border);color:#1A1612;font-family:'Inter',system-ui,sans-serif;font-size:13px;padding:10px;border-radius:8px;outline:none;resize:vertical;line-height:1.55;"></textarea>
      <p id="noteStatus" style="font-size:10.5px;color:#8B8175;margin:6px 0 0;text-align:right;font-family:monospace;">Loading...</p>
    </div>

    <!-- Lessons panel -->
    <div id="panel-lessons">
      <div class="sidebar-hd">
        <p style="font-size:11px;font-weight:600;color:#1A1612;margin:0 0 2px;">{completedLessonIds.length}/{lessons.length} complete</p>
        <div class="prog-bar"><div class="prog-fill" style={`width:${progressPct}%;`}></div></div>
      </div>
      {modules.length === 0 && (lessons as any[]).map((l: any) => {
        const done = completedLessonIds.includes(l.id);
        const active = l.id === activeLessonId;
        const tc = (typeColors as any)[l.type] || '#6e6e78';
        return (
          <a href={`/portal/courses/${slug}?lesson=${l.id}`} class={`l-item${active?' active':''}${done?' l-done':''}`}>
            <div class={`l-check${done?' done':''}${active&&!done?' cur':''}`}>{done && <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>}</div>
            <div class="l-dot" style={`background:${tc};`}></div>
            <span class={`l-name${active?' active':''}`}>{l.title}</span>
            {l.duration_mins > 0 && <span style="font-size:9px;color:#8B8175;flex-shrink:0;">{l.duration_mins}m</span>}
          </a>
        );
      })}
      {modules.length > 0 && (modules as any[]).map((m: any) => {
        const ml = (lessons as any[]).filter((l: any) => l.module_id === m.id);
        return (
          <div>
            <div class="mod-hd">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#B8512E" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
              <span style="font-size:10px;font-weight:700;color:#1A1612;text-transform:uppercase;">{m.title}</span>
            </div>
            {ml.map((l: any) => {
              const done = completedLessonIds.includes(l.id);
              const active = l.id === activeLessonId;
              const tc = (typeColors as any)[l.type] || '#6e6e78';
              return (
                <a href={`/portal/courses/${slug}?lesson=${l.id}`} class={`l-item${active?' active':''}${done?' l-done':''}`}>
                  <div class={`l-check${done?' done':''}${active&&!done?' cur':''}`}>{done && <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>}</div>
                  <div class="l-dot" style={`background:${tc};`}></div>
                  <span class={`l-name${active?' active':''}`}>{l.title}</span>
                  {l.duration_mins > 0 && <span style="font-size:9px;color:#8B8175;flex-shrink:0;">{l.duration_mins}m</span>}
                </a>
              );
            })}
          </div>
        );
      })}
    </div>

    <!-- Labs panel -->
    <div id="panel-labs" style="display:none;padding:12px;">
      <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#8B8175;margin:0 0 10px;">Virtual Labs</p>
      {catLabs.length === 0 && <p style="font-size:12px;color:#8B8175;text-align:center;padding:20px;">No labs for this course category.</p>}
      {(catLabs as any[]).map((lab: any) => (
        <div class="lab-card" style="margin-bottom:8px;" onclick={`openLab('${lab.url}','${lab.name}')`}>
          <div style="display:flex;align-items:center;gap:8px;">
            <div style="width:32px;height:32px;background:rgba(251,191,36,0.15);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fbbf24;flex-shrink:0;">{lab.icon}</div>
            <div>
              <p style="font-size:12px;font-weight:600;color:#1A1612;margin:0;">{lab.name}</p>
              <p style="font-size:10px;color:#8B8175;margin:0;">Interactive simulation</p>
            </div>
          </div>
        </div>
      ))}
      <div class="lab-card" style="margin-bottom:8px;" onclick="openLab('https://www.desmos.com/calculator','Desmos Calculator')">
        <div style="display:flex;align-items:center;gap:8px;">
          <div style="width:32px;height:32px;background:rgba(96,165,250,0.15);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#60a5fa;flex-shrink:0;">Calc</div>
          <div><p style="font-size:12px;font-weight:600;color:#1A1612;margin:0;">Desmos Calculator</p><p style="font-size:10px;color:#8B8175;margin:0;">Graphing & scientific</p></div>
        </div>
      </div>
      <div class="lab-card" onclick="openLab('https://replit.com/@replit/Python?lite=1','Code Sandbox')">
        <div style="display:flex;align-items:center;gap:8px;">
          <div style="width:32px;height:32px;background:rgba(167,139,250,0.15);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#a78bfa;flex-shrink:0;">Code</div>
          <div><p style="font-size:12px;font-weight:600;color:#1A1612;margin:0;">Code Sandbox</p><p style="font-size:10px;color:#8B8175;margin:0;">Python / JS playground</p></div>
        </div>
      </div>
    </div>

    <!-- Live panel -->
    <div id="panel-live" style="display:none;padding:12px;">
      <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#8B8175;margin:0 0 10px;">Live Classes</p>
      <div style="background:#FBF8F1;border:1px solid rgba(16,185,129,0.2);border-radius:10px;padding:14px;margin-bottom:8px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
          <div class="live-badge">LIVE</div>
          <p style="font-size:12px;font-weight:600;color:#1A1612;margin:0;">Join Live Class</p>
        </div>
        <p style="font-size:11px;color:#8B8175;margin:0 0 10px;">Join the video call with your instructor and classmates.</p>
        <button onclick={`openLiveClass('${course.slug}')`} style="width:100%;background:#10b981;border:none;color:#1A1612;font-size:13px;font-weight:600;padding:10px;border-radius:8px;cursor:pointer;">Join Class Room</button>
      </div>
      <div style="background:#FBF8F1;border:1px solid var(--ac-border);border-radius:10px;padding:14px;">
        <p style="font-size:12px;font-weight:600;color:#1A1612;margin:0 0-6px;">Start Your Own Room</p>
        <p style="font-size:11px;color:#8B8175;margin:4px 0 10px;">Create a study group or practice session.</p>
        <button onclick="openStudyRoom()" style="width:100%;background:#EFE9DC;border:1px solid var(--ac-border);color:#5C544A;font-size:13px;font-weight:600;padding:10px;border-radius:8px;cursor:pointer;">Create Study Room</button>
      </div>
    </div>
  </aside>

  <!-- Main content -->
  <div class="main">
    {activeLesson && (
      <div>
        {/* Video player at top for video lessons */}
        {activeLesson.type === 'video' && activeLesson.video_url && (
          <div class="vid-wrap">
            {getYoutubeId(activeLesson.video_url) ? (
              <iframe src={`https://www.youtube.com/embed/${getYoutubeId(activeLesson.video_url)}?rel=0&modestbranding=1`} allowfullscreen allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture"></iframe>
            ) : getVimeoId(activeLesson.video_url) ? (
              <iframe src={`https://player.vimeo.com/video/${getVimeoId(activeLesson.video_url)}`} allowfullscreen></iframe>
            ) : (
              <video controls src={activeLesson.video_url} style="width:100%;height:100%;background:#000;"></video>
            )}
          </div>
        )}

        {/* Live lesson - our own WebRTC meeting room (no third party) */}
        {activeLesson.type === 'live' && (
          <div class="vid-wrap" style="aspect-ratio:16/9;">
            <iframe src={`/portal/meet/${course.slug}-live`} allow="camera;microphone;fullscreen;display-capture" style="width:100%;height:100%;border:none;"></iframe>
          </div>
        )}

        {/* Simulation/Lab */}
        {activeLesson.type === 'simulation' && activeLesson.video_url && (
          <div class="vid-wrap" style="aspect-ratio:16/9;">
            <iframe src={activeLesson.video_url} style="width:100%;height:100%;border:none;" allowfullscreen></iframe>
          </div>
        )}

        <div class="content-area">
          {certificate && (
            <div class="cert-banner">
              <p style="font-size:17px;font-weight:800;color:#1A1612;margin:0 0 4px;">Course Completed!</p>
              <p style="font-size:12px;color:#5C544A;margin:0 0 12px;">Certificate #{certificate.certificate_number}</p>
              <a href={`/portal/certificate/${certificate.certificate_number}`} style="background:#B8512E;color:#1A1612;text-decoration:none;font-size:13px;font-weight:600;padding:9px 20px;border-radius:8px;display:inline-block;">View Certificate</a>
            </div>
          )}

          {justDone && !certificate && (
            <div style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);border-radius:10px;padding:10px 14px;margin-bottom:14px;display:flex;align-items:center;gap:8px;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              <p style="font-size:13px;color:#6ee7b7;margin:0;">Lesson completed!</p>
            </div>
          )}

          <!-- Lesson header -->
          <div style="margin-bottom:16px;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;flex-wrap:wrap;">
              <span style={`font-size:10px;font-weight:700;padding:2px 8px;border-radius:100px;background:${(typeColors as any)[activeLesson.type]||'#6e6e78'}22;color:${(typeColors as any)[activeLesson.type]||'#6e6e78'};text-transform:uppercase;`}>{activeLesson.type}</span>
              {activeLesson.duration_mins > 0 && <span style="font-size:11px;color:#8B8175;">{activeLesson.duration_mins} min</span>}
              {activeLessonDone && <span style="font-size:10px;background:rgba(16,185,129,0.15);color:#6ee7b7;padding:2px 8px;border-radius:100px;">Completed</span>}
            </div>
            <h1 style="font-size:20px;font-weight:700;color:#1A1612;margin:0 0 4px;">{activeLesson.title}</h1>
            <p style="font-size:11px;color:#8B8175;margin:0;">{course.title}</p>
          </div>

          <!-- Content tabs -->
          {(activeLesson.content || activeLesson.type === 'quiz') && (
            <div class="tab-btns">
              <button class="tab-btn active" onclick="showContentTab('notes',this)">Notes</button>
              {activeLesson.type === 'quiz' && <button class="tab-btn" onclick="showContentTab('quiz',this)">Quiz</button>}
              <button class="tab-btn" onclick="showContentTab('discuss',this)">Discuss</button>
              <button class="tab-btn" onclick="showContentTab('resources',this)">Resources</button>
            </div>
          )}

          <!-- Notes tab -->
          <div id="tab-notes">
            {activeLesson.content && <div style="font-size:14px;color:#5C544A;line-height:1.8;white-space:pre-wrap;background:#FBF8F1;border:1px solid var(--ac-border);border-radius:10px;padding:16px;">{activeLesson.content}</div>}
            {activeLesson.type === 'link' && activeLesson.video_url && (
              <div style="text-align:center;padding:32px;background:#FBF8F1;border:1px solid var(--ac-border);border-radius:12px;">
                <a href={activeLesson.video_url} target="_blank" rel="noopener" style="background:#60a5fa;color:#1A1612;text-decoration:none;font-size:13px;font-weight:600;padding:10px 20px;border-radius:8px;display:inline-block;">Open Resource</a>
              </div>
            )}
          </div>

          <!-- Quiz tab -->
          <div id="tab-quiz" style="display:none;">
            <div style="background:#FBF8F1;border:1px solid var(--ac-border);border-radius:12px;padding:20px;">
              <p style="font-size:14px;color:#5C544A;margin:0 0 16px;line-height:1.7;white-space:pre-wrap;">{activeLesson.content}</p>
              <p style="font-size:12px;color:#8B8175;">Complete the quiz in your notebook, then mark this lesson as complete.</p>
            </div>
          </div>

          <!-- Discuss tab -->
          <div id="tab-discuss" style="display:none;">
            <div style="background:#FBF8F1;border:1px solid var(--ac-border);border-radius:12px;padding:20px;">
              <p style="font-size:13px;color:#5C544A;margin:0 0 14px;text-align:center;">Ask a question or start a discussion about this course</p>
              <div style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap;">
                <a href={'/portal/courses/' + course.slug + '/discuss'} style="background:#B8512E;color:#1A1612;text-decoration:none;font-size:13px;font-weight:600;padding:9px 18px;border-radius:8px;">Course forum</a>
                <a href="/portal/discussion" style="background:#EFE9DC;border:1px solid var(--ac-border);color:#5C544A;text-decoration:none;font-size:13px;font-weight:600;padding:9px 18px;border-radius:8px;">General community</a>
              </div>
            </div>
          </div>

          <!-- Resources tab -->
          <div id="tab-resources" style="display:none;">
            <div style="background:#FBF8F1;border:1px solid var(--ac-border);border-radius:12px;padding:16px;display:flex;flex-direction:column;gap:8px;">
              {catLabs.slice(0,2).map((lab: any) => (
                <button onclick={`openLab('${lab.url}','${lab.name}')`} style="background:#EFE9DC;border:1px solid var(--ac-border);border-radius:8px;padding:10px 14px;display:flex;align-items:center;gap:10px;cursor:pointer;text-align:left;">
                  <span style="font-size:12px;font-weight:600;color:#fbbf24;">[Lab]</span>
                  <span style="font-size:13px;color:#5C544A;">{lab.name}</span>
                </button>
              ))}
              <button onclick={`openLiveClass('${course.slug}')`} style="background:#EFE9DC;border:1px solid rgba(16,185,129,0.3);border-radius:8px;padding:10px 14px;display:flex;align-items:center;gap:10px;cursor:pointer;">
                <span style="font-size:12px;font-weight:600;color:#10b981;">[Live]</span>
                <span style="font-size:13px;color:#5C544A;">Join Class Room</span>
              </button>
            </div>
          </div>

          <!-- Navigation -->
          <div class="nav-row">
            {prevLesson && <a href={`/portal/courses/${slug}?lesson=${(prevLesson as any).id}`} class="nav-btn" style="background:#EFE9DC;border:1px solid var(--ac-border);color:#5C544A;">Previous</a>}
            {!activeLessonDone && (
              <form method="POST" style="flex:2;display:contents;">
                <input type="hidden" name="action" value="complete_lesson"/>
                <input type="hidden" name="lesson_id" value={activeLesson.id}/>
                <button type="submit" class="nav-btn" style="flex:2;background:#B8512E;border:none;color:#1A1612;">{nextLesson ? 'Mark Complete & Continue' : 'Complete Course'}</button>
              </form>
            )}
            {activeLessonDone && nextLesson && <a href={`/portal/courses/${slug}?lesson=${(nextLesson as any).id}`} class="nav-btn" style="flex:2;background:#10b981;color:#1A1612;">Next Lesson</a>}
          </div>
        </div>
      </div>
    )}

    {lessons.length === 0 && (
      <div style="display:flex;align-items:center;justify-content:center;height:100%;flex-direction:column;gap:12px;color:#8B8175;padding:48px;">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#6e6e78" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        <p style="font-size:15px;font-weight:600;color:#1A1612;">No lessons yet</p>
        <p style="font-size:13px;">The instructor is still building this course.</p>
      </div>
    )}
  </div>
</div>

<!-- Lab modal -->
<div id="labModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.9);z-index:200;flex-direction:column;">
  <div style="background:#FBF8F1;border-bottom:1px solid rgba(26,22,18,0.10);padding:10px 16px;display:flex;align-items:center;justify-content:space-between;">
    <p id="labTitle" style="font-size:14px;font-weight:600;color:#1A1612;margin:0;">Virtual Lab</p>
    <button onclick="document.getElementById('labModal').style.display='none';document.getElementById('labFrame').src=''" style="background:#EFE9DC;border:1px solid var(--ac-border);color:#1A1612;padding:6px 12px;border-radius:6px;cursor:pointer;font-size:12px;">Close</button>
  </div>
  <iframe id="labFrame" src="" style="flex:1;border:none;background:#fff;"></iframe>
</div>

<script is:inline define:vars={{courseSlug: slug}}>
// Lesson / course context for notes + bookmarks
window.__currentLessonId = window.__currentLessonId || null;
window.__currentCourseId = window.__currentCourseId || null;

function switchSidebar(panel, btn) {
  ['lessons','notes','labs','live'].forEach(function(p) {
    var el = document.getElementById('panel-' + p);
    if (el) el.style.display = p === panel ? 'block' : 'none';
  });
  document.querySelectorAll('.stab').forEach(function(b) { b.classList.remove('active'); });
  if (btn) btn.classList.add('active');
  if (panel === 'notes') loadNote();
}

// ===== NOTES =====
var noteSaveTimer = null;
function loadNote() {
  var el = document.getElementById('noteBody');
  var st = document.getElementById('noteStatus');
  if (!el || !window.__currentLessonId) return;
  if (st) st.textContent = 'Loading...';
  fetch('/api/lessons/notes?lesson_id=' + encodeURIComponent(window.__currentLessonId), { credentials: 'same-origin' })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.ok) {
        el.value = (d.note && d.note.body) || '';
        if (st) st.textContent = d.note ? 'Saved' : 'No notes yet';
      } else if (st) { st.textContent = d.error || 'Failed to load'; }
    }).catch(function() { if (st) st.textContent = 'Network error'; });
}
function saveNoteDebounced() {
  if (noteSaveTimer) clearTimeout(noteSaveTimer);
  var st = document.getElementById('noteStatus');
  if (st) st.textContent = 'Saving...';
  noteSaveTimer = setTimeout(function() {
    var el = document.getElementById('noteBody');
    if (!el || !window.__currentLessonId) return;
    fetch('/api/lessons/notes', {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        lesson_id: window.__currentLessonId,
        course_id: window.__currentCourseId,
        body: el.value
      })
    }).then(function(r) { return r.json(); })
    .then(function(d) { if (st) st.textContent = d.ok ? 'Saved' : (d.error || 'Failed'); })
    .catch(function() { if (st) st.textContent = 'Network error'; });
  }, 800);
}
document.addEventListener('DOMContentLoaded', function() {
  var nb = document.getElementById('noteBody');
  if (nb) nb.addEventListener('input', saveNoteDebounced);

  // ===== BOOKMARK =====
  var bb = document.getElementById('bookmarkBtn');
  var bs = document.getElementById('bookmarkSvg');
  if (bb && window.__currentLessonId) {
    fetch('/api/lessons/bookmark?lesson_id=' + encodeURIComponent(window.__currentLessonId), { credentials: 'same-origin' })
      .then(function(r) { return r.json(); })
      .then(function(d) { if (d.ok && d.bookmarked && bs) bs.setAttribute('fill', '#B8512E'); });
    bb.addEventListener('click', function() {
      fetch('/api/lessons/bookmark', {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ lesson_id: window.__currentLessonId, course_id: window.__currentCourseId })
      }).then(function(r) { return r.json(); })
      .then(function(d) { if (d.ok && bs) bs.setAttribute('fill', d.bookmarked ? '#B8512E' : 'none'); });
    });
  }
});

function showContentTab(tab, btn) {
  ['notes','quiz','discuss','resources'].forEach(function(t) {
    var el = document.getElementById('tab-' + t);
    if (el) el.style.display = t === tab ? 'block' : 'none';
  });
  document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
  if (btn) btn.classList.add('active');
}

function openLab(url, name) {
  document.getElementById('labTitle').textContent = name;
  document.getElementById('labFrame').src = url;
  document.getElementById('labModal').style.display = 'flex';
}

function openLiveClass(slug) {
  var roomName = 'edurankai-' + slug + '-' + new Date().toISOString().split('T')[0];
  window.open('https://meet.jit.si/' + roomName, '_blank');
}

function openStudyRoom() {
  var roomName = 'edurankai-study-' + Math.random().toString(36).substring(2,8);
  window.open('https://meet.jit.si/' + roomName, '_blank');
}

// Mobile toggle
document.querySelectorAll('.l-item').forEach(function(el) {
  el.addEventListener('click', function() {
    document.getElementById('sidebar').classList.remove('open');
  });
});
</script>
</body>
</html>
