---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const { slug } = Astro.params;
let course: any = null;
let threads: any[] = [];

try {
  const r = await db.execute(sql`SELECT id, title, slug FROM training_courses WHERE slug = ${slug} LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  course = rows[0] || null;
} catch (_) {}

if (!course) return Astro.redirect('/portal/courses');

try {
  const r = await db.execute(sql`
    SELECT d.id, d.title, d.body, d.kind, d.is_resolved, d.is_pinned,
      d.reply_count, d.upvote_count, d.created_at, d.last_reply_at,
      u.name as author_name, u.id as author_id, u.role as author_role
    FROM course_discussions d
    JOIN users u ON d.user_id = u.id
    WHERE d.course_id = ${course.id}
    ORDER BY d.is_pinned DESC, COALESCE(d.last_reply_at, d.created_at) DESC
    LIMIT 100
  `);
  threads = Array.isArray(r) ? r : (r?.rows || []);
} catch (_) {}

// If viewing a specific thread
const urlP = new URL(Astro.request.url).searchParams;
const activeThreadId = urlP.get('t') || '';
let activeThread: any = null;
let replies: any[] = [];
if (activeThreadId) {
  try {
    const r = await db.execute(sql`
      SELECT d.*, u.name as author_name, u.role as author_role
      FROM course_discussions d JOIN users u ON d.user_id = u.id
      WHERE d.id = ${activeThreadId} AND d.course_id = ${course.id} LIMIT 1
    `);
    const rows = Array.isArray(r) ? r : (r?.rows || []);
    activeThread = rows[0] || null;
  } catch (_) {}
  if (activeThread) {
    try {
      const r = await db.execute(sql`
        SELECT r.id, r.body, r.is_accepted, r.upvote_count, r.created_at,
          u.name as author_name, u.role as author_role
        FROM course_discussion_replies r JOIN users u ON r.user_id = u.id
        WHERE r.discussion_id = ${activeThread.id} ORDER BY r.created_at ASC
      `);
      replies = Array.isArray(r) ? r : (r?.rows || []);
    } catch (_) {}
  }
}

function timeAgo(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const days = Math.floor(diff / 86400000);
  if (days < 1) {
    const hrs = Math.floor(diff / 3600000);
    if (hrs < 1) return 'just now';
    return hrs + 'h ago';
  }
  if (days < 7) return days + 'd ago';
  if (days < 30) return Math.floor(days / 7) + 'w ago';
  return Math.floor(days / 30) + 'mo ago';
}
---
<!doctype html>
<html lang="en" style="background:#08080a;">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Discuss - {course.title} - EduRankAI</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    body{background:#08080a;color:#e8e8ee;font-family:system-ui,sans-serif;min-height:100vh;}
    a{color:inherit;text-decoration:none;}
    .topbar{background:#0f0f14;border-bottom:1px solid #1a1a1f;padding:14px 18px;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;z-index:30;}
    .wrap{max-width:880px;margin:0 auto;padding:24px 18px 80px;}
    .ttl{font-size:14px;font-weight:600;color:#fff;}
    .sub{font-size:11px;color:#6e6e78;margin-top:2px;}
    .btn{background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:12.5px;padding:9px 16px;border-radius:8px;cursor:pointer;text-decoration:none;display:inline-block;}
    .btn-ghost{background:#15151a;color:#e8e8ee;border:1px solid #1a1a1f;font-size:12.5px;padding:8px 14px;border-radius:8px;text-decoration:none;display:inline-block;cursor:pointer;font-weight:600;}
    .thread-card{background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:16px;margin-bottom:10px;}
    .thread-card:hover{border-color:#FF4F00;}
    .pill{display:inline-block;font-size:9.5px;font-weight:700;padding:2px 8px;border-radius:100px;text-transform:uppercase;letter-spacing:0.06em;}
    .pill-q{background:rgba(96,165,250,0.15);color:#93c5fd;border:1px solid rgba(96,165,250,0.3);}
    .pill-d{background:rgba(167,139,250,0.15);color:#c4b5fd;border:1px solid rgba(167,139,250,0.3);}
    .pill-a{background:rgba(251,191,36,0.15);color:#fbbf24;border:1px solid rgba(251,191,36,0.3);}
    .pill-resolved{background:rgba(16,185,129,0.15);color:#6ee7b7;border:1px solid rgba(16,185,129,0.3);}
    .pill-staff{background:rgba(255,79,0,0.15);color:#FF7040;border:1px solid rgba(255,79,0,0.3);}
    .pill-pinned{background:rgba(251,191,36,0.15);color:#fbbf24;border:1px solid rgba(251,191,36,0.3);}
    input,textarea,select{background:#0f0f14;border:1px solid #1a1a1f;color:#fff;font-family:inherit;font-size:14px;padding:9px 12px;border-radius:8px;outline:none;width:100%;}
    input:focus,textarea:focus{border-color:#FF4F00;}
    textarea{resize:vertical;min-height:90px;line-height:1.55;}
    label{display:block;font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#FF7040;margin:12px 0 5px;}
    .avatar{width:32px;height:32px;border-radius:50%;background:#15151a;border:1px solid #1a1a1f;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#FF7040;flex-shrink:0;}
    @media(max-width:640px){.wrap{padding:18px 14px 60px;}}
  </style>
</head>
<body>
  <nav class="topbar">
    <div style="display:flex;align-items:center;gap:10px;min-width:0;">
      <a href={'/portal/courses/' + slug} style="color:#6e6e78;display:flex;align-items:center;flex-shrink:0;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      </a>
      <div style="min-width:0;">
        <p class="ttl" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">Discussion</p>
        <p class="sub" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{course.title}</p>
      </div>
    </div>
    {!activeThread && (
      <button class="btn" onclick="document.getElementById('newThreadForm').style.display='block';this.style.display='none';">+ New thread</button>
    )}
  </nav>

  <main class="wrap">
    {activeThread ? (
      <>
        <a href={'/portal/courses/' + slug + '/discuss'} style="font-size:11px;font-family:monospace;color:#6e6e78;text-decoration:none;display:inline-block;margin-bottom:14px;">&larr; All threads</a>
        <div class="thread-card">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;flex-wrap:wrap;">
            <span class={'pill ' + (activeThread.kind === 'question' ? 'pill-q' : activeThread.kind === 'announcement' ? 'pill-a' : 'pill-d')}>{activeThread.kind}</span>
            {activeThread.is_pinned && <span class="pill pill-pinned">Pinned</span>}
            {activeThread.is_resolved && <span class="pill pill-resolved">Resolved</span>}
          </div>
          <h1 style="font-size:20px;font-weight:700;color:#fff;margin-bottom:14px;line-height:1.35;">{activeThread.title}</h1>
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
            <div class="avatar">{(activeThread.author_name || '?').substring(0, 1).toUpperCase()}</div>
            <div>
              <p style="font-size:13px;font-weight:600;color:#fff;display:inline;">{activeThread.author_name}</p>
              {activeThread.author_role && activeThread.author_role !== 'applicant' && <span class="pill pill-staff" style="margin-left:6px;">Staff</span>}
              <p style="font-size:11px;color:#6e6e78;">{timeAgo(activeThread.created_at)}</p>
            </div>
          </div>
          <p style="font-size:14.5px;color:#d8d8de;line-height:1.7;white-space:pre-wrap;">{activeThread.body}</p>
        </div>

        <div style="margin:30px 0 10px;">
          <p style="font-size:12.5px;color:#6e6e78;text-transform:uppercase;letter-spacing:0.08em;font-weight:700;">{replies.length} replies</p>
        </div>

        {replies.map((r: any) => (
          <div class="thread-card" style={r.is_accepted ? 'border-color:#10b981;' : ''}>
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
              <div class="avatar">{(r.author_name || '?').substring(0, 1).toUpperCase()}</div>
              <div>
                <p style="font-size:12.5px;font-weight:600;color:#fff;display:inline;">{r.author_name}</p>
                {r.author_role && r.author_role !== 'applicant' && <span class="pill pill-staff" style="margin-left:6px;">Staff</span>}
                {r.is_accepted && <span class="pill pill-resolved" style="margin-left:6px;">Accepted</span>}
                <p style="font-size:11px;color:#6e6e78;">{timeAgo(r.created_at)}</p>
              </div>
            </div>
            <p style="font-size:13.5px;color:#d8d8de;line-height:1.7;white-space:pre-wrap;">{r.body}</p>
          </div>
        ))}

        <div class="thread-card" style="margin-top:20px;">
          <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#FF7040;margin-bottom:10px;">Your reply</p>
          <textarea id="replyBody" placeholder="Type your reply..." rows="4"></textarea>
          <div style="margin-top:10px;display:flex;gap:10px;">
            <button type="button" class="btn" id="replyBtn">Post reply</button>
          </div>
        </div>

        <script is:inline define:vars={{ threadId: activeThread.id }}>
          document.getElementById('replyBtn').addEventListener('click', function() {
            var body = document.getElementById('replyBody').value.trim();
            if (!body) { alert('Reply cannot be empty'); return; }
            this.disabled = true;
            this.textContent = 'Posting...';
            var self = this;
            fetch('/api/discuss/reply', {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ thread_id: threadId, body: body })
            }).then(function(r) { return r.json(); }).then(function(d) {
              if (d.ok) { location.reload(); }
              else { alert(d.error || 'Failed'); self.disabled = false; self.textContent = 'Post reply'; }
            }).catch(function() { alert('Network error'); self.disabled = false; self.textContent = 'Post reply'; });
          });
        </script>
      </>
    ) : (
      <>
        <div class="thread-card" id="newThreadForm" style="display:none;">
          <p style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#FF7040;margin-bottom:14px;">New thread</p>
          <label>Type</label>
          <select id="newKind"><option value="question">Question</option><option value="discussion">Discussion</option></select>
          <label>Title</label>
          <input type="text" id="newTitle" placeholder="A clear, specific question or topic" maxlength="300" />
          <label>Details</label>
          <textarea id="newBody" placeholder="Explain what you've tried, what you expected, what happened. Code or examples welcome." rows="6"></textarea>
          <div style="margin-top:12px;display:flex;gap:10px;">
            <button type="button" class="btn" id="postBtn">Post thread</button>
            <button type="button" class="btn-ghost" onclick="document.getElementById('newThreadForm').style.display='none';">Cancel</button>
          </div>
          <script is:inline define:vars={{ courseId: course.id }}>
            document.getElementById('postBtn').addEventListener('click', function() {
              var title = document.getElementById('newTitle').value.trim();
              var body = document.getElementById('newBody').value.trim();
              var kind = document.getElementById('newKind').value;
              if (!title || title.length < 5) { alert('Title needs at least 5 characters'); return; }
              if (!body || body.length < 10) { alert('Body needs at least 10 characters'); return; }
              this.disabled = true; this.textContent = 'Posting...';
              var self = this;
              fetch('/api/discuss/thread', {
                method: 'POST', credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ course_id: courseId, title: title, body: body, kind: kind })
              }).then(function(r) { return r.json(); }).then(function(d) {
                if (d.ok) { location.search = '?t=' + d.id; }
                else { alert(d.error || 'Failed'); self.disabled = false; self.textContent = 'Post thread'; }
              }).catch(function() { alert('Network error'); self.disabled = false; self.textContent = 'Post thread'; });
            });
          </script>
        </div>

        {threads.length === 0 ? (
          <div style="text-align:center;padding:60px 20px;color:#6e6e78;">
            <p style="font-size:15px;color:#fff;margin-bottom:8px;font-weight:600;">No discussions yet</p>
            <p style="font-size:13px;margin-bottom:18px;">Be the first to ask a question or start a thread.</p>
            <button class="btn" onclick="document.getElementById('newThreadForm').style.display='block';this.style.display='none';">+ New thread</button>
          </div>
        ) : (
          <div>
            {threads.map((t: any) => (
              <a href={'?t=' + t.id} class="thread-card" style="display:block;">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;flex-wrap:wrap;">
                  <span class={'pill ' + (t.kind === 'question' ? 'pill-q' : t.kind === 'announcement' ? 'pill-a' : 'pill-d')}>{t.kind}</span>
                  {t.is_pinned && <span class="pill pill-pinned">Pinned</span>}
                  {t.is_resolved && <span class="pill pill-resolved">Resolved</span>}
                </div>
                <p style="font-size:15px;font-weight:600;color:#fff;margin-bottom:4px;line-height:1.4;">{t.title}</p>
                <p style="font-size:12px;color:#6e6e78;">
                  by <strong style="color:#a8a8b3;">{t.author_name}</strong>
                  {t.author_role && t.author_role !== 'applicant' && <span class="pill pill-staff" style="margin-left:4px;">Staff</span>}
                  &middot; {timeAgo(t.created_at)}
                  &middot; {t.reply_count} {t.reply_count === 1 ? 'reply' : 'replies'}
                </p>
              </a>
            ))}
          </div>
        )}
      </>
    )}
  </main>
</body>
</html>
