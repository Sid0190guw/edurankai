---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/profile'));
if (user.role !== 'applicant') return Astro.redirect('/admin');

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

let acct: any = {};
try {
  acct = rows(await db.execute(sql`SELECT access_status, id_doc_url, id_card_type, created_at, phone FROM users WHERE id = ${user.id} LIMIT 1`))[0] || {};
} catch (_) {}

let faceEnrolled = false;
try {
  faceEnrolled = rows(await db.execute(sql`SELECT 1 FROM user_face_enrollments WHERE user_id = ${user.id} AND is_active = true LIMIT 1`)).length > 0;
} catch (_) {}

let credentials: any[] = [];
try {
  credentials = rows(await db.execute(sql`
    SELECT tc.certificate_number, tc.created_at, c.title
    FROM training_certificates tc
    LEFT JOIN training_courses c ON c.id = tc.course_id
    WHERE tc.user_id = ${user.id}
    ORDER BY tc.created_at DESC LIMIT 50
  `));
} catch (_) {}

const status = (acct.access_status || 'pending').toString();
const statusMap: Record<string, { label: string; cls: string }> = {
  approved: { label: 'Verified', cls: 'ok' },
  pending: { label: 'In review', cls: 'warn' },
  rejected: { label: 'Action needed', cls: 'bad' },
};
const st = statusMap[status] || statusMap.pending;
const firstName = (user.name || 'there').split(' ')[0];
function initials(n: string): string {
  const p = (n || '?').trim().split(/\s+/);
  return (p.length >= 2 ? p[0][0] + p[1][0] : (n || '?').slice(0, 2)).toUpperCase();
}
function fmt(d: any): string { return d ? new Date(d).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short', year: 'numeric' }) : '-'; }
---
<BaseLayout title="Your profile - EduRankAI" description="Your applicant profile, security and credentials." noindex={true}>
  <section class="px-[5vw] py-10 md:py-14 max-w-3xl mx-auto">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-3">Portal</p>

    <!-- Header -->
    <div class="flex items-center gap-4 mb-8">
      <div class="w-16 h-16 rounded-full bg-burn text-white flex items-center justify-center text-[1.3rem] font-bold flex-shrink-0">{initials(user.name)}</div>
      <div class="min-w-0">
        <h1 class="font-display text-[clamp(1.5rem,4vw,2.1rem)] font-semibold text-ink leading-tight tracking-tight">{user.name || firstName}</h1>
        <p class="text-[0.9rem] text-ink-soft break-all">{user.email}</p>
        <span class={'inline-block mt-1 text-[0.68rem] font-mono uppercase tracking-wider font-bold px-2.5 py-0.5 rounded-full status-' + st.cls}>{st.label}</span>
      </div>
    </div>

    <!-- Account -->
    <div class="bg-white border border-ink/10 rounded-2xl p-6 mb-5">
      <h2 class="font-display text-[1.1rem] font-semibold text-ink mb-4">Account</h2>
      <dl class="grid grid-cols-1 sm:grid-cols-2 gap-y-3 gap-x-6 text-[0.88rem]">
        <div><dt class="text-ink-soft text-[0.74rem] uppercase tracking-wide font-mono">Full name</dt><dd class="text-ink font-medium">{user.name || '-'}</dd></div>
        <div><dt class="text-ink-soft text-[0.74rem] uppercase tracking-wide font-mono">Email</dt><dd class="text-ink font-medium break-all">{user.email}</dd></div>
        <div><dt class="text-ink-soft text-[0.74rem] uppercase tracking-wide font-mono">Phone</dt><dd class="text-ink font-medium">{acct.phone || 'Not added'}</dd></div>
        <div><dt class="text-ink-soft text-[0.74rem] uppercase tracking-wide font-mono">Member since</dt><dd class="text-ink font-medium">{fmt(acct.created_at)}</dd></div>
      </dl>
    </div>

    <!-- Security -->
    <div class="bg-white border border-ink/10 rounded-2xl p-6 mb-5">
      <h2 class="font-display text-[1.1rem] font-semibold text-ink mb-4">Security &amp; identity</h2>
      <div class="space-y-3">
        <div class="flex items-center justify-between gap-4 py-2 border-b border-ink/6">
          <div>
            <p class="text-[0.9rem] font-medium text-ink">Face 2FA</p>
            <p class="text-[0.78rem] text-ink-soft">A face check on sign-in, on top of your password.</p>
          </div>
          {faceEnrolled
            ? <span class="text-[0.78rem] font-bold text-leaf whitespace-nowrap">Enabled</span>
            : <a href="/portal/face-setup" class="text-[0.8rem] font-semibold text-burn whitespace-nowrap hover:underline">Set up &rarr;</a>}
        </div>
        <div class="flex items-center justify-between gap-4 py-2 border-b border-ink/6">
          <div>
            <p class="text-[0.9rem] font-medium text-ink">Identity document</p>
            <p class="text-[0.78rem] text-ink-soft">{acct.id_doc_url ? 'Uploaded' + (acct.id_card_type ? ' (' + acct.id_card_type + ')' : '') + ' - under review.' : 'A government ID, verified by a human.'}</p>
          </div>
          {acct.id_doc_url
            ? <span class="text-[0.78rem] font-bold text-leaf whitespace-nowrap">On file</span>
            : <a href="/portal/face-setup" class="text-[0.8rem] font-semibold text-burn whitespace-nowrap hover:underline">Upload &rarr;</a>}
        </div>
        <div class="flex items-center justify-between gap-4 py-2">
          <div>
            <p class="text-[0.9rem] font-medium text-ink">Password</p>
            <p class="text-[0.78rem] text-ink-soft">Change the password on your account.</p>
          </div>
          <a href="/portal/forgot" class="text-[0.8rem] font-semibold text-burn whitespace-nowrap hover:underline">Change &rarr;</a>
        </div>
      </div>
    </div>

    <!-- Credentials -->
    <div id="credentials" class="bg-white border border-ink/10 rounded-2xl p-6 mb-5">
      <h2 class="font-display text-[1.1rem] font-semibold text-ink mb-4">Credentials</h2>
      {credentials.length === 0 ? (
        <p class="text-[0.86rem] text-ink-soft">No certificates yet. Complete a course or assessment to earn verifiable credentials. <a href="/aquintutor" class="text-burn font-semibold hover:underline">Explore courses &rarr;</a></p>
      ) : (
        <ul class="space-y-2">
          {credentials.map((c: any) => (
            <li class="flex items-center justify-between gap-4 py-2.5 border-b border-ink/6 last:border-0">
              <div class="min-w-0">
                <p class="text-[0.9rem] font-medium text-ink truncate">{c.title || 'Certificate'}</p>
                <p class="text-[0.74rem] text-ink-soft font-mono">{c.certificate_number} · {fmt(c.created_at)}</p>
              </div>
              <span class="text-[0.72rem] font-bold text-leaf whitespace-nowrap">Issued</span>
            </li>
          ))}
        </ul>
      )}
    </div>

    <!-- Quick links -->
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-6">
      <a href="/portal" class="ql">Portal home</a>
      <a href="/portal/notifications" class="ql">Notifications</a>
      <a href="/portal/messages" class="ql">Messages</a>
      <a href="/portal/requests" class="ql">My requests</a>
      <a href="/portal/mail" class="ql">Mail</a>
      <a href="/portal/logout" class="ql danger">Sign out</a>
    </div>
  </section>

  <style>
    .status-ok { background: rgba(16,185,129,0.12); color: #047857; }
    .status-warn { background: rgba(250,204,21,0.14); color: #92400e; }
    .status-bad { background: rgba(239,68,68,0.12); color: #b91c1c; }
    .ql { display: flex; align-items: center; justify-content: center; text-align: center; padding: 14px 10px; background: #fff; border: 1px solid rgba(14,11,8,0.1); border-radius: 12px; font-size: 0.85rem; font-weight: 600; color: #2b2620; text-decoration: none; transition: border-color .15s; }
    .ql:hover { border-color: rgba(255,79,0,0.5); color: #FF4F00; }
    .ql.danger:hover { border-color: rgba(239,68,68,0.5); color: #b91c1c; }
  </style>
</BaseLayout>
