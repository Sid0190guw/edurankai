---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { getThread, markApplicantRead } from '@/lib/request-threads';

const user = Astro.locals.user;
const { id } = Astro.params;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/requests/fee-waiver/' + (id || '')));
if (user.role !== 'applicant') return Astro.redirect('/admin');

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

let req: any = null;
try {
  const r = await db.execute(sql`
    SELECT id, status, situation_note, expertise_note, drive_url, created_at, reviewed_at, reject_reason,
      COALESCE(last_message_at, created_at) AS last_message_at
    FROM application_fee_waivers
    WHERE id = ${id} AND user_id = ${user.id} LIMIT 1
  `);
  req = rows(r)[0] || null;
} catch (_) {}
if (!req) return Astro.redirect('/portal/requests');

await markApplicantRead('fee_waiver', String(id));
const messages = await getThread('fee_waiver', String(id));

function fmt(d: any): string {
  try { return new Date(d).toLocaleString('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); } catch { return ''; }
}
function statusBadge(s: string) {
  const map: any = {
    pending: { bg: 'rgba(250,204,21,0.12)', fg: '#92400e', border: 'rgba(250,204,21,0.35)' },
    approved: { bg: 'rgba(16,185,129,0.10)', fg: '#047857', border: 'rgba(16,185,129,0.35)' },
    rejected: { bg: 'rgba(239,68,68,0.10)', fg: '#991b1b', border: 'rgba(239,68,68,0.35)' },
  };
  return map[s] || map.pending;
}
const badge = statusBadge(req.status);
---
<BaseLayout title="Fee waiver request" description="Your fee waiver thread with the admissions team.">
  <section class="px-[5vw] py-8 md:py-12 max-w-3xl mx-auto">
    <a href="/portal/requests" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline">&lt; All requests</a>
    <div class="mt-4 mb-6">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-1">Application fee waiver</p>
      <h1 class="font-display text-[clamp(1.6rem,4vw,2.2rem)] font-semibold text-ink leading-[1.15] mb-3">Your waiver request thread</h1>
      <span style={'display:inline-block;font-family:JetBrains Mono,monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.14em;font-weight:700;padding:4px 12px;border-radius:100px;background:' + badge.bg + ';color:' + badge.fg + ';border:1px solid ' + badge.border + ';'}>{req.status}</span>
    </div>

    <div class="bg-cream-2 border border-ink/10 rounded-2xl p-5 mb-5">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Situation</p>
      <p class="text-[0.92rem] text-ink leading-[1.7] whitespace-pre-wrap">{req.situation_note}</p>
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mt-4 mb-2">Expertise / what you bring</p>
      <p class="text-[0.92rem] text-ink leading-[1.7] whitespace-pre-wrap">{req.expertise_note}</p>
      {req.drive_url && <p class="text-[0.78rem] mt-3"><a href={req.drive_url} target="_blank" rel="noopener" class="text-burn font-semibold hover:underline">Supporting documents (Drive link) →</a></p>}
      {req.reject_reason && (
        <div class="mt-4 pt-4 border-t border-ink/8">
          <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-red-700 font-bold mb-2">Reviewer note</p>
          <p class="text-[0.88rem] text-ink leading-relaxed">{req.reject_reason}</p>
        </div>
      )}
    </div>

    <div class="mb-3">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold">Conversation</p>
    </div>

    {messages.length === 0 ? (
      <div class="bg-white border border-ink/10 rounded-xl p-5 mb-4 text-[0.85rem] text-ink-soft text-center">
        No replies yet. Our admissions team will respond here.
      </div>
    ) : (
      <div class="space-y-3 mb-4">
        {messages.map((m: any) => (
          <div class={'rounded-xl p-4 ' + (m.sender_role === 'admin' ? 'bg-burn-pale border border-burn-dim' : 'bg-white border border-ink/10 ml-8')}>
            <div class="flex items-baseline justify-between gap-3 mb-1">
              <p class="text-[0.62rem] font-mono uppercase tracking-[0.12em] font-bold" style={m.sender_role === 'admin' ? 'color:#b85e3f;' : 'color:#5b5b5b;'}>{m.sender_role === 'admin' ? 'Admissions team · ' + (m.sender_name || 'EduRankAI') : 'You'}</p>
              <p class="text-[0.72rem] font-mono text-ink-soft">{fmt(m.created_at)}</p>
            </div>
            <p class="text-[0.92rem] text-ink leading-[1.65] whitespace-pre-wrap">{m.body}</p>
          </div>
        ))}
      </div>
    )}

    <form id="replyForm" class="bg-white border border-ink/10 rounded-xl p-4 mb-6">
      <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Reply to the admissions team</label>
      <textarea id="replyBody" rows="4" maxlength="5000" placeholder="Add detail or share an updated document link..." class="w-full px-3 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-white resize-y leading-relaxed"></textarea>
      <div class="flex items-center gap-3 mt-3">
        <button type="submit" class="bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.88rem] transition-all">Send reply</button>
        <p id="replyMsg" class="text-[0.78rem] text-ink-soft"></p>
      </div>
    </form>
  </section>

  <script is:inline define:vars={{ requestId: id }}>
    (function () {
      var form = document.getElementById('replyForm');
      var ta = document.getElementById('replyBody');
      var msg = document.getElementById('replyMsg');
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var body = (ta.value || '').trim();
        if (!body) { msg.textContent = 'Type a message first.'; return; }
        msg.textContent = 'Sending...';
        fetch('/api/portal/requests/fee-waiver/reply', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ requestId: requestId, body: body }) })
          .then(function (r) { return r.json(); })
          .then(function (d) {
            if (d.ok) { msg.textContent = 'Sent. Reloading...'; setTimeout(function () { location.reload(); }, 600); }
            else { msg.textContent = d.error || 'Failed'; }
          })
          .catch(function () { msg.textContent = 'Network error.'; });
      });
    })();
  </script>
</BaseLayout>
