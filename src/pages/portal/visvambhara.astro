---
// /portal/visvambhara — dedicated landing for Viśvambhara access requests.
// Mirrors /portal/waivers. Shows every Viśvambhara access request the
// signed-in user has ever submitted with status, last-message preview,
// unread count, and a CTA to the thread.
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/visvambhara'));
if (user.role !== 'applicant') return Astro.redirect('/admin');

function rowsOf(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

let requests: any[] = [];
try {
  requests = rowsOf(await db.execute(sql`
    SELECT r.id, r.status, r.note, r.cv_url, r.reject_reason, r.created_at, r.reviewed_at,
      COALESCE(r.last_message_at, r.created_at) AS last_message_at,
      COALESCE(r.unread_applicant, 0) AS unread
    FROM visvambhara_access_requests r
    WHERE r.user_id = ${user.id}
    ORDER BY COALESCE(r.last_message_at, r.created_at) DESC
  `));
} catch (_) {}

function fmt(d: any): string {
  try { return new Date(d).toLocaleString('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); } catch { return ''; }
}
function ago(d: any): string {
  if (!d) return '';
  try {
    const diff = (Date.now() - new Date(d).getTime()) / 1000;
    if (diff < 60) return 'just now';
    if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
    if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
    return Math.floor(diff / 86400) + 'd ago';
  } catch { return ''; }
}
function statusPill(s: string) {
  if (s === 'approved') return { bg: 'rgba(16,185,129,0.12)', fg: '#047857', border: 'rgba(16,185,129,0.32)' };
  if (s === 'rejected') return { bg: 'rgba(239,68,68,0.10)', fg: '#991b1b', border: 'rgba(239,68,68,0.32)' };
  return { bg: 'rgba(250,204,21,0.14)', fg: '#92400e', border: 'rgba(250,204,21,0.35)' };
}
---
<BaseLayout title="Viśvambhara access requests — EduRankAI" description="Your Viśvambhara access requests, decisions, and thread with the research team.">
  <section class="px-[5vw] py-10 md:py-14 max-w-3xl mx-auto">

    <a href="/portal" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">&lt; Portal home</a>

    <div class="mt-4 mb-6">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">Viśvambhara access</p>
      <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.5rem)] font-semibold text-ink leading-[1.15] mb-3">
        Your access requests
      </h1>
      <p class="text-[0.92rem] text-ink-soft leading-relaxed max-w-xl">
        Every Viśvambhara access request you submit lives here. Decisions, reviewer notes, and your direct thread with the research team — in one place. We respond within 5 business days.
      </p>
    </div>

    {requests.length === 0 ? (
      <div class="bg-cream-2/60 border border-ink/10 rounded-2xl p-8 md:p-10 text-center">
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.16em] text-burn font-bold mb-3">No access requests yet</p>
        <h2 class="font-display text-[1.4rem] font-semibold text-ink mb-3">Viśvambhara is access-controlled.</h2>
        <p class="text-[0.9rem] text-ink-soft leading-relaxed max-w-md mx-auto mb-5">
          Submit an access request with a short engagement note — what you're working on, what you want to use the modules for — and our research team reviews each one individually.
        </p>
        <a href="/products/visvambhara/access" class="inline-block bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-6 rounded-lg text-[0.9rem] no-underline">Request access</a>
      </div>
    ) : (
      <div class="flex flex-col gap-3">
        {requests.map((r) => {
          const pill = statusPill(r.status);
          const href = '/portal/requests/visvambhara/' + r.id;
          return (
            <a href={href} class="bg-white border border-ink/10 rounded-2xl p-5 md:p-6 hover:border-burn transition-colors no-underline" style="color:inherit;display:block;">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:wrap;margin-bottom:10px;">
                <div style="min-width:0;flex:1;">
                  <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-burn font-bold mb-1">Viśvambhara access</p>
                  <p class="font-display text-[1.05rem] font-semibold text-ink leading-tight m-0">Submitted {fmt(r.created_at)}</p>
                </div>
                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px;flex-shrink:0;">
                  <span style={'font-family:JetBrains Mono,monospace;font-size:10px;text-transform:uppercase;letter-spacing:0.14em;font-weight:700;padding:3px 10px;border-radius:100px;background:' + pill.bg + ';color:' + pill.fg + ';border:1px solid ' + pill.border + ';'}>{r.status}</span>
                  {r.unread > 0 && <span style="background:#FF4F00;color:#fff;font-size:10px;font-weight:700;padding:2px 8px;border-radius:100px;">{r.unread} new</span>}
                </div>
              </div>

              {r.status === 'approved' && (
                <p class="text-[0.86rem] text-ink-2 leading-relaxed m-0 mb-1">
                  <strong style="color:#047857;">Approved.</strong> You now have access to the Viśvambhara modules from your portal.
                </p>
              )}
              {r.status === 'rejected' && (
                <p class="text-[0.86rem] text-ink-2 leading-relaxed m-0 mb-1">
                  <strong style="color:#991b1b;">Not granted.</strong> {r.reject_reason || 'See the thread for the reviewer\'s note. You can update your engagement note and re-submit.'}
                </p>
              )}
              {r.status === 'pending' && (
                <p class="text-[0.86rem] text-ink-2 leading-relaxed m-0 mb-1">
                  <strong style="color:#92400e;">Under review.</strong> Decisions arrive within 5 business days. You can reply in the thread anytime.
                </p>
              )}

              <p class="text-[0.72rem] text-ink-soft m-0 mt-3" style="font-family:'JetBrains Mono',monospace;">
                Last activity {ago(r.last_message_at)} &middot; Open thread →
              </p>
            </a>
          );
        })}
      </div>
    )}

    <div class="bg-cream-2/40 border border-ink/8 rounded-xl p-5 mt-8 text-[0.83rem] text-ink-soft leading-relaxed">
      <p class="font-mono text-[0.62rem] uppercase tracking-[0.14em] text-burn font-bold mb-1.5">How access review works</p>
      <p class="m-0">Every request is read by a member of the Viśvambhara research team. Decisions arrive within five business days inside your portal thread — no email blasts. If approved, the deep modules unlock immediately; if not, you can update your engagement note and re-submit, or reply on the thread.</p>
      <p class="text-[0.78rem] mt-3 mb-0">Questions? Reply inside any thread above, or email <a href="mailto:hr@edurankai.in" class="text-burn font-semibold hover:underline">hr@edurankai.in</a>.</p>
    </div>

  </section>
</BaseLayout>
