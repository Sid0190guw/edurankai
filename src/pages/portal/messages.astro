<BaseLayout title="Messages — Encrypted" description="In-house end-to-end encrypted messenger.">
<style>
:root { color-scheme: dark; }
body { background: #0a0a0c; color: #e8e8ee; margin: 0; font-family: 'Cormorant Garamond', Georgia, serif; }
body.era-has-fab { padding-bottom: 0; }
.msg-shell { display: grid; grid-template-columns: 260px 1fr 280px; height: 100vh; max-height: 100vh; overflow: hidden; }
.msg-col { background: #11131a; border-right: 1px solid #2a2a35; display: flex; flex-direction: column; min-height: 0; }
.msg-col.right { border-right: 0; border-left: 1px solid #2a2a35; }
.msg-col.center { background: #0a0a0c; border-right: 0; }

.col-head { padding: 14px 16px; border-bottom: 1px solid #2a2a35; display: flex; align-items: center; gap: 10px; }
.col-head h2 { margin: 0; font-size: 20px; font-weight: 500; letter-spacing: 0.3px; }
.icon-btn { background: transparent; border: 1px solid #2a2a35; color: #e8e8ee; width: 32px; height: 32px; border-radius: 8px; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; transition: all .15s; }
.icon-btn:hover { background: #1a1c25; border-color: #67e8f9; }
.icon-btn svg { width: 16px; height: 16px; }

.search-row { padding: 10px 12px; border-bottom: 1px solid #2a2a35; }
.search-row input { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; color: #e8e8ee; border-radius: 8px; padding: 9px 12px; font-family: 'Geist Mono', monospace; font-size: 12px; }
.search-row input:focus { outline: none; border-color: #67e8f9; }

.thread-list { flex: 1; overflow-y: auto; }
.thread-row { display: flex; gap: 10px; padding: 12px 14px; cursor: pointer; border-bottom: 1px solid #1a1c25; align-items: center; }
.thread-row:hover { background: #161823; }
.thread-row.active { background: #1c2030; border-left: 3px solid #67e8f9; padding-left: 11px; }
.avatar { width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, #67e8f9, #a78bfa); display: flex; align-items: center; justify-content: center; color: #0a0a0c; font-weight: 600; font-family: 'Geist Mono', monospace; font-size: 14px; flex-shrink: 0; position: relative; }
.avatar.lg { width: 44px; height: 44px; font-size: 16px; }
.avatar.xl { width: 56px; height: 56px; font-size: 20px; }
.presence-dot { position: absolute; right: -1px; bottom: -1px; width: 11px; height: 11px; background: #4ade80; border-radius: 50%; border: 2px solid #11131a; }
.presence-dot.away { background: #facc15; }
.presence-dot.off { background: #52525b; }

.thread-meta { flex: 1; min-width: 0; }
.thread-title { font-family: 'Cormorant Garamond', serif; font-size: 17px; line-height: 1.1; margin-bottom: 3px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.thread-preview { font-family: 'Geist Mono', monospace; font-size: 11px; color: #8a8a99; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.thread-time { font-family: 'Geist Mono', monospace; font-size: 10px; color: #6b6b7a; }
.thread-badge { background: #67e8f9; color: #0a0a0c; border-radius: 10px; padding: 1px 7px; font-family: 'Geist Mono', monospace; font-size: 10px; font-weight: 600; }

.new-chat-btn { margin: 10px 12px; padding: 9px 12px; background: linear-gradient(135deg, #67e8f9, #a78bfa); color: #0a0a0c; border: 0; border-radius: 8px; font-weight: 600; cursor: pointer; font-family: 'Geist Mono', monospace; font-size: 12px; }

.chat-head { padding: 12px 18px; border-bottom: 1px solid #2a2a35; display: flex; align-items: center; gap: 12px; background: #11131a; }
.chat-head .thread-title { font-size: 19px; margin-bottom: 1px; }
.chat-head-meta { flex: 1; min-width: 0; }
.chat-head-actions { display: flex; gap: 6px; }
.e2e-pill { display: inline-flex; align-items: center; gap: 5px; background: rgba(34, 197, 94, 0.12); color: #4ade80; padding: 3px 9px; border-radius: 999px; font-family: 'Geist Mono', monospace; font-size: 10px; cursor: pointer; }
.e2e-pill svg { width: 10px; height: 10px; }

.stream { flex: 1; overflow-y: auto; padding: 18px 20px; display: flex; flex-direction: column; gap: 6px; }
.day-sep { text-align: center; font-family: 'Geist Mono', monospace; font-size: 10px; color: #6b6b7a; margin: 14px 0 6px; letter-spacing: 1px; text-transform: uppercase; }
.msg-row { display: flex; gap: 8px; max-width: 70%; align-items: flex-end; }
.msg-row.me { align-self: flex-end; flex-direction: row-reverse; }
.msg-bubble { background: #1a1c25; padding: 8px 12px 6px; border-radius: 14px; border-bottom-left-radius: 4px; position: relative; max-width: 100%; word-wrap: break-word; }
.msg-row.me .msg-bubble { background: linear-gradient(135deg, #4f46e5, #7c3aed); color: #fff; border-bottom-left-radius: 14px; border-bottom-right-radius: 4px; }
.msg-text { font-family: 'Cormorant Garamond', serif; font-size: 16px; line-height: 1.35; white-space: pre-wrap; }
.msg-text.deleted { font-style: italic; color: #6b6b7a; }
.msg-footer { display: flex; align-items: center; gap: 6px; justify-content: flex-end; margin-top: 2px; }
.msg-time { font-family: 'Geist Mono', monospace; font-size: 9px; color: rgba(232,232,238,0.5); }
.msg-row.me .msg-time { color: rgba(255,255,255,0.7); }
.tick { width: 14px; height: 10px; }
.tick.read { color: #67e8f9; }
.tick.sent { color: rgba(255,255,255,0.55); }
.msg-quote { background: rgba(0,0,0,0.25); border-left: 2px solid #67e8f9; padding: 4px 8px; margin-bottom: 4px; border-radius: 4px; font-family: 'Geist Mono', monospace; font-size: 11px; color: #b0b0bb; }
.msg-attach { margin: 4px 0; border-radius: 8px; max-width: 280px; max-height: 200px; }
.msg-actions { position: absolute; top: -10px; right: 10px; display: none; gap: 3px; background: #1a1c25; border: 1px solid #2a2a35; padding: 3px; border-radius: 8px; }
.msg-row:hover .msg-actions { display: flex; }
.msg-actions button { background: transparent; border: 0; color: #b0b0bb; cursor: pointer; padding: 3px; border-radius: 4px; }
.msg-actions button:hover { background: #2a2a35; color: #fff; }
.msg-actions svg { width: 12px; height: 12px; }

.typing { font-family: 'Geist Mono', monospace; font-size: 10px; color: #67e8f9; padding: 4px 20px; height: 18px; }

.composer-wrap { border-top: 1px solid #2a2a35; background: #11131a; padding: 10px 14px 14px; }
.composer { display: flex; align-items: flex-end; gap: 8px; }
.composer textarea { flex: 1; background: #0a0a0c; border: 1px solid #2a2a35; color: #e8e8ee; border-radius: 12px; padding: 10px 12px; font-family: 'Cormorant Garamond', serif; font-size: 16px; resize: none; min-height: 40px; max-height: 140px; }
.composer textarea:focus { outline: none; border-color: #67e8f9; }
.composer .icon-btn { width: 38px; height: 38px; }
.send-btn { background: linear-gradient(135deg, #67e8f9, #a78bfa); border: 0; color: #0a0a0c; }
.send-btn:hover { filter: brightness(1.1); }
.reply-bar { background: #1a1c25; border-left: 3px solid #67e8f9; padding: 6px 10px; margin-bottom: 8px; font-family: 'Geist Mono', monospace; font-size: 11px; color: #b0b0bb; display: flex; justify-content: space-between; align-items: center; border-radius: 4px; }

.emoji-pop { position: absolute; bottom: 60px; right: 80px; background: #11131a; border: 1px solid #2a2a35; border-radius: 10px; padding: 8px; display: none; grid-template-columns: repeat(8, 1fr); gap: 4px; z-index: 50; }
.emoji-pop.open { display: grid; }
.emoji-pop button { background: transparent; border: 0; color: #e8e8ee; cursor: pointer; padding: 4px; border-radius: 4px; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; }
.emoji-pop button:hover { background: #1a1c25; }
.emoji-pop svg { width: 18px; height: 18px; }

.right-section { padding: 16px; border-bottom: 1px solid #2a2a35; }
.right-section h3 { font-family: 'Geist Mono', monospace; font-size: 11px; color: #8a8a99; text-transform: uppercase; letter-spacing: 1px; margin: 0 0 10px; font-weight: 500; }
.member-row { display: flex; align-items: center; gap: 10px; padding: 8px 0; cursor: pointer; }
.member-row:hover { color: #67e8f9; }
.member-name { font-family: 'Cormorant Garamond', serif; font-size: 15px; flex: 1; }
.member-role { font-family: 'Geist Mono', monospace; font-size: 10px; color: #8a8a99; }

.media-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 4px; }
.media-tile { aspect-ratio: 1; background: #1a1c25; border-radius: 6px; overflow: hidden; }
.media-tile img { width: 100%; height: 100%; object-fit: cover; }
.media-empty { font-family: 'Geist Mono', monospace; font-size: 11px; color: #6b6b7a; padding: 12px 0; text-align: center; border: 1px dashed #2a2a35; border-radius: 6px; }

.toggle-row { display: flex; align-items: center; justify-content: space-between; padding: 8px 0; font-family: 'Cormorant Garamond', serif; font-size: 15px; }
.switch { width: 36px; height: 20px; background: #2a2a35; border-radius: 999px; position: relative; cursor: pointer; transition: all .15s; }
.switch::after { content: ''; position: absolute; top: 2px; left: 2px; width: 16px; height: 16px; background: #e8e8ee; border-radius: 50%; transition: all .15s; }
.switch.on { background: #67e8f9; }
.switch.on::after { left: 18px; background: #0a0a0c; }

.fp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; }
.fp-cell { font-family: 'Geist Mono', monospace; font-size: 13px; background: #0a0a0c; border: 1px solid #2a2a35; padding: 4px 6px; border-radius: 4px; text-align: center; color: #67e8f9; }

.modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,0.7); display: none; z-index: 100; align-items: center; justify-content: center; }
.modal-backdrop.open { display: flex; }
.modal { background: #11131a; border: 1px solid #2a2a35; border-radius: 14px; padding: 24px; min-width: 360px; max-width: 480px; }
.modal h3 { margin: 0 0 14px; font-family: 'Cormorant Garamond', serif; font-size: 22px; }
.modal label { display: block; font-family: 'Geist Mono', monospace; font-size: 11px; color: #8a8a99; margin: 10px 0 4px; text-transform: uppercase; letter-spacing: 1px; }
.modal input, .modal select { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; color: #e8e8ee; padding: 9px 12px; border-radius: 8px; font-family: 'Geist Mono', monospace; font-size: 12px; box-sizing: border-box; }
.modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 18px; }
.modal-actions button { padding: 9px 14px; border-radius: 8px; cursor: pointer; border: 0; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 600; }
.btn-primary { background: linear-gradient(135deg, #67e8f9, #a78bfa); color: #0a0a0c; }
.btn-ghost { background: transparent; color: #e8e8ee; border: 1px solid #2a2a35 !important; }

.call-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.92); display: none; flex-direction: column; align-items: center; justify-content: center; gap: 18px; z-index: 200; }
.call-overlay.open { display: flex; }
.call-overlay video { width: 320px; height: 240px; border-radius: 14px; background: #1a1c25; border: 1px solid #67e8f9; }
.call-overlay .call-info { text-align: center; }
.call-overlay h2 { font-size: 26px; margin: 0; }
.call-overlay p { font-family: 'Geist Mono', monospace; font-size: 12px; color: #8a8a99; margin: 6px 0 0; }
.call-end { background: #ef4444; border: 0; color: #fff; width: 56px; height: 56px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; }

.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; color: #6b6b7a; font-family: 'Geist Mono', monospace; font-size: 12px; gap: 10px; }
.empty-state svg { width: 64px; height: 64px; opacity: 0.4; }

@media (max-width: 900px) {
  .msg-shell { grid-template-columns: 240px 1fr; }
  .msg-col.right { display: none; }
}
