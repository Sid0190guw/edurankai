---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=/portal/messages');

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

// --- Self-bootstrap schema ----------------------------------------------------
await db.execute(sql`
  CREATE TABLE IF NOT EXISTS chat_threads (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    kind VARCHAR(20) NOT NULL DEFAULT 'direct',
    title VARCHAR(200),
    cover_url TEXT,
    last_message_preview TEXT,
    last_message_at TIMESTAMPTZ,
    disappearing_seconds INT,
    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
  )
`);
await db.execute(sql`
  CREATE TABLE IF NOT EXISTS chat_thread_members (
    thread_id UUID NOT NULL REFERENCES chat_threads(id) ON DELETE CASCADE,
    user_id UUID NOT NULL,
    role VARCHAR(20) NOT NULL DEFAULT 'member',
    joined_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    last_read_at TIMESTAMPTZ,
    notifications_muted BOOLEAN NOT NULL DEFAULT false,
    public_key_pem TEXT,
    PRIMARY KEY (thread_id, user_id)
  )
`);
await db.execute(sql`
  CREATE TABLE IF NOT EXISTS chat_messages (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    thread_id UUID NOT NULL REFERENCES chat_threads(id) ON DELETE CASCADE,
    sender_user_id UUID NOT NULL,
    ciphertext TEXT NOT NULL,
    iv TEXT NOT NULL,
    envelope JSONB DEFAULT '{}'::jsonb,
    attachment_url TEXT,
    attachment_meta JSONB,
    reply_to_message_id UUID,
    edited_at TIMESTAMPTZ,
    deleted_at TIMESTAMPTZ,
    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
  )
`);
await db.execute(sql`
  CREATE TABLE IF NOT EXISTS chat_message_receipts (
    message_id UUID NOT NULL REFERENCES chat_messages(id) ON DELETE CASCADE,
    user_id UUID NOT NULL,
    delivered_at TIMESTAMPTZ,
    read_at TIMESTAMPTZ,
    PRIMARY KEY (message_id, user_id)
  )
`);
await db.execute(sql`CREATE INDEX IF NOT EXISTS chat_messages_thread_idx ON chat_messages (thread_id, created_at DESC)`).catch(()=>{});
await db.execute(sql`CREATE INDEX IF NOT EXISTS chat_members_user_idx ON chat_thread_members (user_id)`).catch(()=>{});

// --- POST handlers ------------------------------------------------------------
let okMsg = '', errMsg = '';
const ct = Astro.request.headers.get('content-type') || '';

if (Astro.request.method === 'POST' && ct.includes('application/json')) {
  try {
    const body = await Astro.request.json();
    const action = body.action as string;

    if (action === 'publish_key') {
      // Idempotently store this user's public key on all their thread memberships
      const pem = String(body.public_key_pem || '');
      if (!pem.startsWith('-----BEGIN PUBLIC KEY-----')) throw new Error('bad pem');
      await db.execute(sql`
        UPDATE chat_thread_members SET public_key_pem = ${pem}
        WHERE user_id = ${user.id}
      `);
      return new Response(JSON.stringify({ ok: true }), { headers: { 'content-type': 'application/json' } });
    }

    if (action === 'new_thread') {
      const peerEmail = String(body.peer_email || '').trim().toLowerCase();
      const title = String(body.title || '').slice(0, 200);
      const kind = (body.kind === 'group') ? 'group' : 'direct';
      let peerId: string | null = null;
      if (peerEmail) {
        const u = rows(await db.execute(sql`SELECT id, full_name, email FROM users WHERE LOWER(email) = ${peerEmail} LIMIT 1`));
        if (u.length) peerId = u[0].id;
      }
      const t = rows(await db.execute(sql`
        INSERT INTO chat_threads (kind, title) VALUES (${kind}, ${title || (peerEmail || 'New chat')})
        RETURNING id
      `));
      const tid = t[0].id;
      await db.execute(sql`
        INSERT INTO chat_thread_members (thread_id, user_id, role)
        VALUES (${tid}, ${user.id}, 'owner')
        ON CONFLICT DO NOTHING
      `);
      if (peerId && peerId !== user.id) {
        await db.execute(sql`
          INSERT INTO chat_thread_members (thread_id, user_id, role)
          VALUES (${tid}, ${peerId}, 'member')
          ON CONFLICT DO NOTHING
        `);
      }
      return new Response(JSON.stringify({ ok: true, thread_id: tid }), { headers: { 'content-type': 'application/json' } });
    }

    if (action === 'send') {
      const tid = String(body.thread_id);
      const ciphertext = String(body.ciphertext || '');
      const iv = String(body.iv || '');
      const envelope = body.envelope || {};
      const replyTo = body.reply_to_message_id || null;
      const attUrl = body.attachment_url || null;
      const attMeta = body.attachment_meta || null;
      if (!tid || !ciphertext || !iv) throw new Error('bad message');
      // member check
      const m = rows(await db.execute(sql`
        SELECT 1 FROM chat_thread_members WHERE thread_id = ${tid} AND user_id = ${user.id} LIMIT 1
      `));
      if (!m.length) throw new Error('not a member');
      const envelopeJson = JSON.stringify(envelope || {});
      const attMetaJson = attMeta ? JSON.stringify(attMeta) : null;
      const ins = rows(await db.execute(sql`
        INSERT INTO chat_messages (thread_id, sender_user_id, ciphertext, iv, envelope, attachment_url, attachment_meta, reply_to_message_id)
        VALUES (${tid}, ${user.id}, ${ciphertext}, ${iv}, ${envelopeJson}::jsonb,
                ${attUrl}, ${attMetaJson}::jsonb, ${replyTo})
        RETURNING id, created_at
      `));
      await db.execute(sql`
        UPDATE chat_threads SET last_message_preview = ${'[encrypted]'}, last_message_at = NOW() WHERE id = ${tid}
      `);
      // Notify the other member(s) of the new DM (content is E2E so just a ping).
      try {
        const others = rows(await db.execute(sql`
          SELECT m.user_id, u.role FROM chat_thread_members m JOIN users u ON u.id = m.user_id
          WHERE m.thread_id = ${tid} AND m.user_id <> ${user.id}
        `));
        const { sendPushToUser } = await import('@/lib/push');
        const { notifyUser } = await import('@/lib/notify');
        for (const o of others) {
          const staff = ['admin', 'super_admin', 'editor', 'reviewer'].includes((o as any).role);
          const url = (staff ? '/admin/dms' : '/portal/messages') + '?thread=' + tid;
          await sendPushToUser((o as any).user_id, {
            type: 'dm',
            title: 'New message from ' + (user.name || 'someone'),
            body: 'You have a new direct message.',
            url,
            tag: 'dm-' + tid,
          });
          await notifyUser((o as any).user_id, {
            title: 'New message from ' + (user.name || 'someone'),
            body: 'You have a new direct message.',
            type: 'message',
            actionUrl: url,
            entityType: 'chat_thread',
            entityId: tid,
          });
        }
      } catch (_) {}
      return new Response(JSON.stringify({ ok: true, id: ins[0].id, created_at: ins[0].created_at }), { headers: { 'content-type': 'application/json' } });
    }

    if (action === 'edit') {
      const mid = String(body.message_id);
      const ciphertext = String(body.ciphertext || '');
      const iv = String(body.iv || '');
      await db.execute(sql`
        UPDATE chat_messages SET ciphertext = ${ciphertext}, iv = ${iv}, edited_at = NOW()
        WHERE id = ${mid} AND sender_user_id = ${user.id}
      `);
      return new Response(JSON.stringify({ ok: true }), { headers: { 'content-type': 'application/json' } });
    }

    if (action === 'delete') {
      const mid = String(body.message_id);
      await db.execute(sql`
        UPDATE chat_messages SET deleted_at = NOW()
        WHERE id = ${mid} AND sender_user_id = ${user.id}
      `);
      return new Response(JSON.stringify({ ok: true }), { headers: { 'content-type': 'application/json' } });
    }

    if (action === 'mark_read') {
      const tid = String(body.thread_id);
      await db.execute(sql`
        UPDATE chat_thread_members SET last_read_at = NOW()
        WHERE thread_id = ${tid} AND user_id = ${user.id}
      `);
      const msgIds: string[] = body.message_ids || [];
      for (const mid of msgIds.slice(0, 100)) {
        await db.execute(sql`
          INSERT INTO chat_message_receipts (message_id, user_id, delivered_at, read_at)
          VALUES (${mid}, ${user.id}, NOW(), NOW())
          ON CONFLICT (message_id, user_id) DO UPDATE SET read_at = NOW()
        `).catch(()=>{});
      }
      return new Response(JSON.stringify({ ok: true }), { headers: { 'content-type': 'application/json' } });
    }

    if (action === 'toggle_mute') {
      const tid = String(body.thread_id);
      await db.execute(sql`
        UPDATE chat_thread_members SET notifications_muted = NOT notifications_muted
        WHERE thread_id = ${tid} AND user_id = ${user.id}
      `);
      return new Response(JSON.stringify({ ok: true }), { headers: { 'content-type': 'application/json' } });
    }

    if (action === 'set_disappearing') {
      const tid = String(body.thread_id);
      const secs = body.seconds === null ? null : Number(body.seconds || 0) || null;
      await db.execute(sql`UPDATE chat_threads SET disappearing_seconds = ${secs} WHERE id = ${tid}`);
      return new Response(JSON.stringify({ ok: true }), { headers: { 'content-type': 'application/json' } });
    }

    if (action === 'fetch_messages') {
      const tid = String(body.thread_id);
      const m = rows(await db.execute(sql`
        SELECT 1 FROM chat_thread_members WHERE thread_id = ${tid} AND user_id = ${user.id} LIMIT 1
      `));
      if (!m.length) throw new Error('not a member');
      const msgs = rows(await db.execute(sql`
        SELECT id, sender_user_id, ciphertext, iv, envelope, attachment_url, attachment_meta,
               reply_to_message_id, edited_at, deleted_at, created_at
        FROM chat_messages
        WHERE thread_id = ${tid}
        ORDER BY created_at ASC
        LIMIT 200
      `));
      // garbage collect disappearing
      const td = rows(await db.execute(sql`SELECT disappearing_seconds FROM chat_threads WHERE id = ${tid}`));
      const ds = td[0]?.disappearing_seconds;
      let visible = msgs;
      if (ds && ds > 0) {
        const cutoff = Date.now() - ds * 1000;
        visible = msgs.filter((m: any) => new Date(m.created_at).getTime() >= cutoff);
      }
      return new Response(JSON.stringify({ ok: true, messages: visible }), { headers: { 'content-type': 'application/json' } });
    }

  } catch (e: any) {
    return new Response(JSON.stringify({ ok: false, error: e.message || 'failed' }), { status: 400, headers: { 'content-type': 'application/json' } });
  }
}

// --- Initial server render data ----------------------------------------------
// Ensure there's a "Welcome" thread on first visit so the UI isn't empty
const myThreads = rows(await db.execute(sql`
  SELECT t.id, t.kind, t.title, t.last_message_preview, t.last_message_at, t.cover_url, t.disappearing_seconds,
         m.notifications_muted, m.last_read_at
  FROM chat_threads t
  JOIN chat_thread_members m ON m.thread_id = t.id
  WHERE m.user_id = ${user.id}
  ORDER BY COALESCE(t.last_message_at, t.created_at) DESC
  LIMIT 100
`));

if (!myThreads.length) {
  const w = rows(await db.execute(sql`
    INSERT INTO chat_threads (kind, title, last_message_preview, last_message_at)
    VALUES ('direct', 'Encrypted Notes', 'Welcome to your private vault', NOW())
    RETURNING id, kind, title, last_message_preview, last_message_at, cover_url, disappearing_seconds
  `));
  await db.execute(sql`
    INSERT INTO chat_thread_members (thread_id, user_id, role)
    VALUES (${w[0].id}, ${user.id}, 'owner')
  `);
  myThreads.push({ ...w[0], notifications_muted: false, last_read_at: null });
}

// Member lookup per thread (limited)
const threadMembers: { [k: string]: any[] } = {};
for (const t of myThreads.slice(0, 25)) {
  const ms = rows(await db.execute(sql`
    SELECT m.user_id, m.role, m.public_key_pem, m.notifications_muted, m.last_read_at,
           u.full_name, u.email
    FROM chat_thread_members m
    LEFT JOIN users u ON u.id = m.user_id
    WHERE m.thread_id = ${t.id}
    ORDER BY m.joined_at ASC
    LIMIT 20
  `));
  threadMembers[t.id] = ms;
}

const initialThreadId = myThreads[0]?.id || '';
const myName = (user as any).full_name || (user as any).email || 'You';
const myEmail = (user as any).email || '';

// Seed JSON for the client — kept compact
const seed = {
  me: { id: user.id, name: myName, email: myEmail },
  threads: myThreads.map((t: any) => ({
    id: t.id, kind: t.kind, title: t.title || 'Untitled',
    last_message_preview: t.last_message_preview, last_message_at: t.last_message_at,
    muted: !!t.notifications_muted, disappearing_seconds: t.disappearing_seconds,
    members: (threadMembers[t.id] || []).map((m: any) => ({
      user_id: m.user_id, name: m.full_name || m.email || 'Unknown',
      email: m.email || '', role: m.role, public_key_pem: m.public_key_pem || null
    }))
  })),
  initialThreadId
};
