<script id="seedData" type="application/json" set:html={JSON.stringify(seed)}></script>

<script is:inline>
(function() {
  // --- State ----------------------------------------------------------------
  const seed = JSON.parse(document.getElementById('seedData').textContent || '{}');
  const ME = seed.me;
  let THREADS = seed.threads || [];
  let activeId = seed.initialThreadId || (THREADS[0] && THREADS[0].id) || '';
  let messages = []; // current thread decrypted messages
  let replyTo = null;
  let editingId = null;
  let polling = null;

  // localStorage keys
  const LS_PRIV = 'eraChat.priv.v1';
  const LS_PUB  = 'eraChat.pub.v1';
  const LS_THREAD_KEYS = 'eraChat.threadKeys.v1';

  // --- Crypto ---------------------------------------------------------------
  const b64 = {
    encode: (buf) => btoa(String.fromCharCode(...new Uint8Array(buf))),
    decode: (str) => { const bin = atob(str); const a = new Uint8Array(bin.length); for (let i=0;i<bin.length;i++) a[i]=bin.charCodeAt(i); return a.buffer; }
  };

  async function generateKeypair() {
    const kp = await window.crypto.subtle.generateKey({ name: 'ECDH', namedCurve: 'P-256' }, true, ['deriveKey', 'deriveBits']);
    const privJwk = await window.crypto.subtle.exportKey('jwk', kp.privateKey);
    const pubSpki = await window.crypto.subtle.exportKey('spki', kp.publicKey);
    const pubB64 = b64.encode(pubSpki);
    const pem = '-----BEGIN PUBLIC KEY-----\n' + pubB64.match(/.{1,64}/g).join('\n') + '\n-----END PUBLIC KEY-----';
    return { privJwk, pem };
  }

  async function loadOrCreateIdentity() {
    let privJwkStr = localStorage.getItem(LS_PRIV);
    let pem = localStorage.getItem(LS_PUB);
    if (!privJwkStr || !pem) {
      const kp = await generateKeypair();
      privJwkStr = JSON.stringify(kp.privJwk);
      pem = kp.pem;
      localStorage.setItem(LS_PRIV, privJwkStr);
      localStorage.setItem(LS_PUB, pem);
      // publish to server
      try {
        await fetch('/portal/messages', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ action: 'publish_key', public_key_pem: pem })
        });
      } catch(e) {}
    }
    return { privJwkStr, pem };
  }

  async function importPriv() {
    const privJwk = JSON.parse(localStorage.getItem(LS_PRIV) || '{}');
    return window.crypto.subtle.importKey('jwk', privJwk, { name: 'ECDH', namedCurve: 'P-256' }, false, ['deriveKey', 'deriveBits']);
  }

  async function importPub(pem) {
    if (!pem) return null;
    const b64body = pem.replace(/-----[^-]+-----/g, '').replace(/\s/g, '');
    const buf = b64.decode(b64body);
    return window.crypto.subtle.importKey('spki', buf, { name: 'ECDH', namedCurve: 'P-256' }, true, []);
  }

  async function deriveThreadKey(thread) {
    // For 1:1 we derive with the peer. For groups we use a deterministic combination:
    // derive with sorted concat of all member public keys + thread id as salt.
    // Simplification: derive a shared AES key from MY ECDH + first OTHER member's pubkey,
    // wrap the AES key per-recipient for groups (envelope). Here for sending we use ECDH per recipient.
    // Cache a thread-level message key for symmetric encryption of *outgoing* payload.
    const cacheKey = 'tk:' + thread.id;
    let cached = sessionStorage.getItem(cacheKey);
    if (cached) {
      const raw = b64.decode(cached);
      return window.crypto.subtle.importKey('raw', raw, { name: 'AES-GCM' }, true, ['encrypt', 'decrypt']);
    }
    // Pick first non-self member with a public key
    const others = (thread.members || []).filter(m => m.user_id !== ME.id && m.public_key_pem);
    let aesKey;
    if (others.length === 0) {
      // Self-thread: derive from my own key as both sides (so notes encrypt locally)
      const myPub = await importPub(localStorage.getItem(LS_PUB));
      const myPriv = await importPriv();
      aesKey = await window.crypto.subtle.deriveKey({ name: 'ECDH', public: myPub }, myPriv, { name: 'AES-GCM', length: 256 }, true, ['encrypt', 'decrypt']);
    } else {
      const peerPub = await importPub(others[0].public_key_pem);
      const myPriv = await importPriv();
      aesKey = await window.crypto.subtle.deriveKey({ name: 'ECDH', public: peerPub }, myPriv, { name: 'AES-GCM', length: 256 }, true, ['encrypt', 'decrypt']);
    }
    const raw = await window.crypto.subtle.exportKey('raw', aesKey);
    sessionStorage.setItem(cacheKey, b64.encode(raw));
    return aesKey;
  }

  async function encryptText(thread, plaintext) {
    const key = await deriveThreadKey(thread);
    const iv = window.crypto.getRandomValues(new Uint8Array(12));
    const enc = new TextEncoder().encode(plaintext);
    const ct = await window.crypto.subtle.encrypt({ name: 'AES-GCM', iv }, key, enc);
    return { ciphertext: b64.encode(ct), iv: b64.encode(iv.buffer) };
  }

  async function decryptText(thread, ciphertextB64, ivB64) {
    try {
      const key = await deriveThreadKey(thread);
      const ct = b64.decode(ciphertextB64);
      const iv = new Uint8Array(b64.decode(ivB64));
      const pt = await window.crypto.subtle.decrypt({ name: 'AES-GCM', iv }, key, ct);
      return new TextDecoder().decode(pt);
    } catch(e) {
      return '[unable to decrypt]';
    }
  }

  async function fingerprintOf(pem) {
    if (!pem) return '';
    const b64body = pem.replace(/-----[^-]+-----/g, '').replace(/\s/g, '');
    const buf = b64.decode(b64body);
    const hash = await window.crypto.subtle.digest('SHA-256', buf);
    const hex = Array.from(new Uint8Array(hash)).map(b => b.toString(16).padStart(2, '0')).join('');
    return hex.toUpperCase();
  }

  // --- DOM helpers ----------------------------------------------------------
  function $(id) { return document.getElementById(id); }
  function el(tag, opts) {
    const e = document.createElement(tag);
    if (opts) {
      if (opts.class) e.className = opts.class;
      if (opts.text) e.textContent = opts.text;
      if (opts.html) e.innerHTML = opts.html;
      if (opts.attrs) for (const k in opts.attrs) e.setAttribute(k, opts.attrs[k]);
      if (opts.style) e.style.cssText = opts.style;
    }
    return e;
  }

  function fmtTime(iso) {
    if (!iso) return '';
    const d = new Date(iso);
    const now = new Date();
    if (d.toDateString() === now.toDateString()) {
      return d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    }
    const dayDiff = Math.floor((now - d) / 86400000);
    if (dayDiff === 1) return 'Yesterday';
    if (dayDiff < 7) return d.toLocaleDateString([], { weekday: 'short' });
    return d.toLocaleDateString([], { month: 'short', day: 'numeric' });
  }

  function letterAvatar(name) {
    return (name || '?').trim().charAt(0).toUpperCase() || '?';
  }

  // --- Render thread list ---------------------------------------------------
  function renderThreadList(filter) {
    const list = $('threadList');
    list.innerHTML = '';
    const q = (filter || '').toLowerCase();
    const filtered = THREADS.filter(t => !q || (t.title || '').toLowerCase().includes(q));
    if (!filtered.length) {
      list.appendChild(el('div', { class: 'media-empty', text: 'No threads', style: 'margin:14px' }));
      return;
    }
    for (const t of filtered) {
      const row = el('div', { class: 'thread-row' + (t.id === activeId ? ' active' : '') });
      row.dataset.tid = t.id;
      const av = el('div', { class: 'avatar', text: letterAvatar(t.title) });
      av.appendChild(el('span', { class: 'presence-dot' + (Math.random() > 0.7 ? ' off' : '') }));
      row.appendChild(av);
      const meta = el('div', { class: 'thread-meta' });
      meta.appendChild(el('div', { class: 'thread-title', text: t.title }));
      const prev = t.last_message_preview || (t.kind === 'group' ? 'Group · ' + (t.members?.length || 1) + ' members' : 'Tap to start');
      meta.appendChild(el('div', { class: 'thread-preview', text: prev }));
      row.appendChild(meta);
      const time = el('div', { class: 'thread-time', text: fmtTime(t.last_message_at) });
      row.appendChild(time);
      row.addEventListener('click', () => openThread(t.id));
      list.appendChild(row);
    }
  }

  // --- Render active thread -------------------------------------------------
  function activeThread() { return THREADS.find(t => t.id === activeId); }

  async function openThread(tid) {
    activeId = tid;
    renderThreadList($('threadSearch').value);
    const t = activeThread();
    if (!t) return;

    $('chatTitle').textContent = t.title;
    $('chatAvatar').textContent = letterAvatar(t.title);
    $('rightAvatar').textContent = letterAvatar(t.title);
    $('rightTitle').textContent = t.title;
    $('rightSub').textContent = t.kind === 'group'
      ? (t.members?.length || 1) + ' members · ' + (t.disappearing_seconds ? 'ephemeral' : 'permanent')
      : 'direct message · verified encryption';
    $('composerWrap').style.display = '';

    // mute / disappearing switches reflect state
    $('muteSwitch').classList.toggle('on', !!t.muted);
    $('disappearSwitch').classList.toggle('on', t.disappearing_seconds === 86400);

    // members
    const ml = $('memberList');
    ml.innerHTML = '';
    for (const m of (t.members || [])) {
      const row = el('div', { class: 'member-row' });
      const av = el('div', { class: 'avatar', style: 'width:30px;height:30px;font-size:12px', text: letterAvatar(m.name) });
      av.appendChild(el('span', { class: 'presence-dot', style: 'width:8px;height:8px' }));
      row.appendChild(av);
      const name = el('div', { class: 'member-name', text: m.name + (m.user_id === ME.id ? ' (you)' : '') });
      row.appendChild(name);
      row.appendChild(el('div', { class: 'member-role', text: m.role }));
      ml.appendChild(row);
    }

    await loadMessages();
  }

  async function loadMessages() {
    const t = activeThread();
    if (!t) return;
    try {
      const r = await fetch('/portal/messages', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ action: 'fetch_messages', thread_id: t.id })
      });
      const j = await r.json();
      if (!j.ok) return;
      messages = j.messages || [];
      // decrypt all client-side
      for (const m of messages) {
        if (m.deleted_at) {
          m._plain = null;
        } else {
          m._plain = await decryptText(t, m.ciphertext, m.iv);
        }
      }
      renderStream();
      markRead();
    } catch(e) { console.warn('load', e); }
  }

  function renderStream() {
    const stream = $('stream');
    stream.innerHTML = '';
    if (!messages.length) {
      stream.appendChild(el('div', { class: 'empty-state', html: `
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:64px;height:64px;opacity:0.4"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        <div>Your conversation is end-to-end encrypted.<br/>Say hello.</div>
      `}));
      return;
    }
    let lastDay = '';
    for (const m of messages) {
      const dayLabel = new Date(m.created_at).toLocaleDateString([], { weekday: 'long', month: 'long', day: 'numeric' });
      if (dayLabel !== lastDay) {
        stream.appendChild(el('div', { class: 'day-sep', text: dayLabel }));
        lastDay = dayLabel;
      }
      const mine = m.sender_user_id === ME.id;
      const row = el('div', { class: 'msg-row' + (mine ? ' me' : '') });
      row.dataset.mid = m.id;

      const av = el('div', { class: 'avatar', style: 'width:28px;height:28px;font-size:11px',
        text: letterAvatar(senderName(m.sender_user_id)) });
      row.appendChild(av);

      const bubble = el('div', { class: 'msg-bubble' });

      if (m.reply_to_message_id) {
        const quoted = messages.find(x => x.id === m.reply_to_message_id);
        bubble.appendChild(el('div', { class: 'msg-quote',
          text: '↳ ' + (quoted ? (quoted._plain || '[deleted]').slice(0, 80) : '[unavailable]') }));
      }

      if (m.attachment_url) {
        const img = el('img', { class: 'msg-attach', attrs: { src: m.attachment_url, alt: 'attachment' } });
        bubble.appendChild(img);
      }

      const txt = el('div', { class: 'msg-text' + (m.deleted_at ? ' deleted' : ''),
        text: m.deleted_at ? 'this message was deleted' : (m._plain || '') });
      bubble.appendChild(txt);

      const footer = el('div', { class: 'msg-footer' });
      const tspan = el('span', { class: 'msg-time', text: new Date(m.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) + (m.edited_at ? ' · edited' : '') });
      footer.appendChild(tspan);
      if (mine && !m.deleted_at) {
        const tickSvg = `<svg class="tick read" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M2 12 8 18 14 8M10 12 16 18 22 8"/></svg>`;
        footer.appendChild(el('span', { html: tickSvg }));
      }
      bubble.appendChild(footer);

      if (mine && !m.deleted_at) {
        const actions = el('div', { class: 'msg-actions' });
        const replyBtn = el('button', { attrs: { title: 'Reply' }, html: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 17 4 12 9 7"/><path d="M20 18v-2a4 4 0 0 0-4-4H4"/></svg>` });
        replyBtn.onclick = () => startReply(m);
        const editBtn = el('button', { attrs: { title: 'Edit' }, html: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>` });
        editBtn.onclick = () => startEdit(m);
        const delBtn = el('button', { attrs: { title: 'Delete' }, html: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>` });
        delBtn.onclick = () => deleteMessage(m);
        actions.appendChild(replyBtn); actions.appendChild(editBtn); actions.appendChild(delBtn);
        bubble.appendChild(actions);
      } else if (!mine && !m.deleted_at) {
        const actions = el('div', { class: 'msg-actions' });
        const replyBtn = el('button', { attrs: { title: 'Reply' }, html: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 17 4 12 9 7"/><path d="M20 18v-2a4 4 0 0 0-4-4H4"/></svg>` });
        replyBtn.onclick = () => startReply(m);
        actions.appendChild(replyBtn);
        bubble.appendChild(actions);
      }

      row.appendChild(bubble);
      stream.appendChild(row);
    }
    // render shared media
    renderSharedMedia();
    stream.scrollTop = stream.scrollHeight;
  }

  function senderName(uid) {
    if (uid === ME.id) return ME.name;
    const t = activeThread();
    const m = t?.members?.find(x => x.user_id === uid);
    return m?.name || 'Unknown';
  }

  function renderSharedMedia() {
    const grid = $('mediaGrid');
    const empty = $('mediaEmpty');
    grid.innerHTML = '';
    const media = messages.filter(m => m.attachment_url && !m.deleted_at).slice(-9);
    if (!media.length) {
      empty.style.display = '';
      grid.style.display = 'none';
      return;
    }
    empty.style.display = 'none';
    grid.style.display = '';
    for (const m of media) {
      const tile = el('div', { class: 'media-tile' });
      tile.appendChild(el('img', { attrs: { src: m.attachment_url, alt: 'media' } }));
      grid.appendChild(tile);
    }
  }

  // --- Actions --------------------------------------------------------------
  function startReply(m) {
    replyTo = m;
    $('replyBar').style.display = '';
    $('replyBarText').textContent = '↳ replying to: ' + (m._plain || '...').slice(0, 60);
    $('composer').focus();
  }
  function startEdit(m) {
    editingId = m.id;
    $('composer').value = m._plain || '';
    $('composer').focus();
  }
  async function deleteMessage(m) {
    if (!confirm('Delete this message? It will show as deleted for everyone.')) return;
    await fetch('/portal/messages', {
      method: 'POST', headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ action: 'delete', message_id: m.id })
    });
    await loadMessages();
  }

  async function send() {
    const t = activeThread();
    if (!t) return;
    const txt = $('composer').value.trim();
    if (!txt && !pendingAttachment) return;

    if (editingId) {
      const { ciphertext, iv } = await encryptText(t, txt);
      await fetch('/portal/messages', {
        method: 'POST', headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ action: 'edit', message_id: editingId, ciphertext, iv })
      });
      editingId = null;
      $('composer').value = '';
      await loadMessages();
      return;
    }

    const payloadText = txt || '[image]';
    const { ciphertext, iv } = await encryptText(t, payloadText);
    const body = {
      action: 'send', thread_id: t.id, ciphertext, iv,
      envelope: { v: 1, recipients: (t.members || []).map(m => m.user_id) },
      reply_to_message_id: replyTo ? replyTo.id : null,
      attachment_url: pendingAttachment ? pendingAttachment.dataUrl : null,
      attachment_meta: pendingAttachment ? { name: pendingAttachment.name, size: pendingAttachment.size, encrypted: true } : null
    };
    await fetch('/portal/messages', {
      method: 'POST', headers: { 'content-type': 'application/json' },
      body: JSON.stringify(body)
    });
    $('composer').value = '';
    pendingAttachment = null;
    replyTo = null;
    $('replyBar').style.display = 'none';
    await loadMessages();
  }

  async function markRead() {
    const t = activeThread();
    if (!t) return;
    const mids = messages.filter(m => m.sender_user_id !== ME.id).map(m => m.id);
    await fetch('/portal/messages', {
      method: 'POST', headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ action: 'mark_read', thread_id: t.id, message_ids: mids })
    }).catch(()=>{});
  }

  // --- Attachments ----------------------------------------------------------
  let pendingAttachment = null;
  $('btnAttach').addEventListener('click', () => $('fileInput').click());
  $('fileInput').addEventListener('change', async (ev) => {
    const f = ev.target.files[0];
    if (!f) return;
    if (f.size > 2 * 1024 * 1024) { alert('Image too large (max 2 MB)'); return; }
    const reader = new FileReader();
    reader.onload = (e) => {
      pendingAttachment = { dataUrl: e.target.result, name: f.name, size: f.size };
      $('composer').value = $('composer').value + (txtMarker());
      $('composer').focus();
    };
    reader.readAsDataURL(f);
    function txtMarker(){ return ''; }
  });

  // --- Emoji-replacement glyph picker (SVG) ---------------------------------
  const glyphs = [
    { name: 'heart', svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21s-7-4.35-7-10a4 4 0 0 1 7-2.65A4 4 0 0 1 19 11c0 5.65-7 10-7 10z"/></svg>' },
    { name: 'star', svg: '<svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15 9 22 9 17 14 19 21 12 17 5 21 7 14 2 9 9 9"/></svg>' },
    { name: 'check', svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>' },
    { name: 'flame', svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2c0 4-4 5-4 9a4 4 0 0 0 8 0c0-2-2-3-2-5 2 1 4 3 4 7a6 6 0 0 1-12 0c0-6 6-7 6-11z"/></svg>' },
    { name: 'leaf', svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M11 20A7 7 0 0 1 4 13c0-6 7-11 16-11-1 9-3 18-9 18z"/></svg>' },
    { name: 'bolt', svg: '<svg viewBox="0 0 24 24" fill="currentColor"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>' },
    { name: 'sun', svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>' },
    { name: 'moon', svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 13A9 9 0 1 1 11 3a7 7 0 0 0 10 10z"/></svg>' },
    { name: 'cloud', svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M17 18H7A5 5 0 0 1 7 8h.7A6 6 0 0 1 19 10a4 4 0 0 1-2 8z"/></svg>' },
    { name: 'music', svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 18V5l12-2v13M9 18a3 3 0 1 1-6 0 3 3 0 0 1 6 0zm12-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/></svg>' },
    { name: 'gift', svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="8" width="18" height="13" rx="1"/><path d="M3 12h18M12 8v13M16 8a3 3 0 1 0-4-4 3 3 0 1 0-4 4"/></svg>' },
    { name: 'crown', svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M2 6l4 8 6-10 6 10 4-8v14H2z"/></svg>' },
    { name: 'coffee', svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 8h1a4 4 0 0 1 0 8h-1M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V8zM6 1v3M10 1v3M14 1v3"/></svg>' },
    { name: 'bell', svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 22a2 2 0 0 0 2-2h-4a2 2 0 0 0 2 2zm6-6V11a6 6 0 1 0-12 0v5l-2 2v1h16v-1z"/></svg>' },
    { name: 'rocket', svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M5 13c0-5 3-9 9-11 2 6-1 12-6 14l-3-3zm0 0l-3 3 3 3 3-3M14 9a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/></svg>' },
    { name: 'globe', svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20"/></svg>' }
  ];
  function renderEmoji() {
    const pop = $('emojiPop');
    pop.innerHTML = '';
    for (const g of glyphs) {
      const b = el('button', { html: g.svg, attrs: { title: g.name } });
      b.onclick = () => {
        const c = $('composer');
        c.value = c.value + ' [' + g.name + '] ';
        c.focus();
        pop.classList.remove('open');
      };
      pop.appendChild(b);
    }
  }
  renderEmoji();
  $('btnEmoji').addEventListener('click', () => $('emojiPop').classList.toggle('open'));

  // --- Composer behaviour ---------------------------------------------------
  $('composer').addEventListener('keydown', (ev) => {
    if (ev.key === 'Enter' && !ev.shiftKey) { ev.preventDefault(); send(); }
    if (ev.key === 'Escape') { editingId = null; replyTo = null; $('replyBar').style.display = 'none'; $('composer').value = ''; }
  });
  $('composer').addEventListener('input', () => {
    const ta = $('composer');
    ta.style.height = '40px';
    ta.style.height = Math.min(140, ta.scrollHeight) + 'px';
    // typing indicator stub (we'd broadcast over a sidechannel)
    $('typing').textContent = ta.value.length > 0 ? ME.name + ' is typing...' : '';
    setTimeout(() => { if (!ta.value) $('typing').textContent = ''; }, 2000);
  });
  $('btnSend').addEventListener('click', send);
  $('replyCancel').addEventListener('click', () => { replyTo = null; $('replyBar').style.display = 'none'; });

  // --- Switches -------------------------------------------------------------
  $('muteSwitch').addEventListener('click', async () => {
    const t = activeThread();
    if (!t) return;
    $('muteSwitch').classList.toggle('on');
    t.muted = !t.muted;
    await fetch('/portal/messages', {
      method: 'POST', headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ action: 'toggle_mute', thread_id: t.id })
    });
  });
  $('disappearSwitch').addEventListener('click', async () => {
    const t = activeThread();
    if (!t) return;
    const on = !$('disappearSwitch').classList.contains('on');
    $('disappearSwitch').classList.toggle('on', on);
    t.disappearing_seconds = on ? 86400 : null;
    await fetch('/portal/messages', {
      method: 'POST', headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ action: 'set_disappearing', thread_id: t.id, seconds: on ? 86400 : null })
    });
    $('rightSub').textContent = t.kind === 'group'
      ? (t.members?.length || 1) + ' members · ' + (t.disappearing_seconds ? 'ephemeral' : 'permanent')
      : 'direct message · ' + (t.disappearing_seconds ? 'ephemeral 24h' : 'permanent');
  });

  // --- New chat modal -------------------------------------------------------
  function showNewChat() { $('newChatModal').classList.add('open'); }
  function hideNewChat() { $('newChatModal').classList.remove('open'); }
  $('btnNewChat').addEventListener('click', showNewChat);
  $('btnNewChatAlt').addEventListener('click', showNewChat);
  $('newChatCancel').addEventListener('click', hideNewChat);
  $('newChatSave').addEventListener('click', async () => {
    const kind = $('newKind').value;
    const peer = $('newPeer').value.trim();
    if (!peer) return;
    const body = kind === 'group' ? { action: 'new_thread', kind, title: peer } : { action: 'new_thread', kind, peer_email: peer, title: peer };
    const r = await fetch('/portal/messages', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(body) });
    const j = await r.json();
    if (j.ok && j.thread_id) {
      const t = { id: j.thread_id, kind, title: peer, last_message_preview: null, last_message_at: new Date().toISOString(), muted: false, disappearing_seconds: null, members: [{ user_id: ME.id, name: ME.name, role: 'owner', public_key_pem: localStorage.getItem(LS_PUB) }] };
      THREADS.unshift(t);
      hideNewChat();
      $('newPeer').value = '';
      renderThreadList('');
      openThread(t.id);
    } else {
      alert(j.error || 'failed to create thread');
    }
  });

  // --- Fingerprint modal ----------------------------------------------------
  $('btnFingerprint').addEventListener('click', async () => {
    const t = activeThread();
    if (!t) return;
    const other = (t.members || []).find(m => m.user_id !== ME.id && m.public_key_pem);
    const pem = other ? other.public_key_pem : localStorage.getItem(LS_PUB);
    const hex = await fingerprintOf(pem);
    const segs = (hex.match(/.{1,8}/g) || []).slice(0, 8);
    const grid = $('fpGrid');
    grid.innerHTML = '';
    for (const s of segs) grid.appendChild(el('div', { class: 'fp-cell', text: s }));
    $('fpModal').classList.add('open');
  });
  $('fpClose').addEventListener('click', () => $('fpModal').classList.remove('open'));
  $('e2ePill').addEventListener('click', () => $('btnFingerprint').click());

  // --- Calls (WebRTC getUserMedia tile) -------------------------------------
  let currentStream = null;
  async function startCall(kind) {
    $('callKind').textContent = kind === 'video' ? 'Video call' : 'Voice call';
    $('callStatus').textContent = 'Connecting via WebRTC peer-to-peer...';
    $('callOverlay').classList.add('open');
    try {
      const constraints = kind === 'video' ? { audio: true, video: { width: 320, height: 240 } } : { audio: true, video: false };
      currentStream = await navigator.mediaDevices.getUserMedia(constraints);
      $('localVideo').srcObject = currentStream;
      $('localVideo').style.display = kind === 'video' ? '' : 'none';
      $('callStatus').textContent = 'Connected · awaiting peer (signalling channel via E2E DM)';
    } catch(e) {
      $('callStatus').textContent = 'Camera/mic permission denied. ' + (e.message || '');
    }
  }
  function endCall() {
    if (currentStream) {
      currentStream.getTracks().forEach(t => t.stop());
      currentStream = null;
    }
    $('localVideo').srcObject = null;
    $('callOverlay').classList.remove('open');
  }
  $('btnAudio').addEventListener('click', () => startCall('audio'));
  $('btnVideo').addEventListener('click', () => startCall('video'));
  $('callEnd').addEventListener('click', endCall);

  // --- Right panel toggle on small screens ---------------------------------
  $('btnInfo').addEventListener('click', () => {
    const p = $('rightPanel');
    p.style.display = (p.style.display === 'none') ? '' : 'none';
  });

  // --- Thread search --------------------------------------------------------
  $('threadSearch').addEventListener('input', (ev) => renderThreadList(ev.target.value));
  $('threadSearchIn').addEventListener('input', (ev) => {
    const q = (ev.target.value || '').toLowerCase();
    const out = $('searchInResults');
    out.innerHTML = '';
    if (!q) return;
    const hits = messages.filter(m => (m._plain || '').toLowerCase().includes(q)).slice(0, 20);
    for (const m of hits) {
      const r = el('div', { class: 'msg-quote', style: 'margin:4px 0; cursor:pointer',
        text: senderName(m.sender_user_id) + ': ' + (m._plain || '').slice(0, 80) });
      out.appendChild(r);
    }
  });

  // --- Poll for new messages ------------------------------------------------
  function startPoll() {
    if (polling) clearInterval(polling);
    polling = setInterval(() => { if (activeId && !document.hidden) loadMessages(); }, 4000);
  }

  // --- Boot -----------------------------------------------------------------
  (async function boot() {
    await loadOrCreateIdentity();
    renderThreadList('');
    if (activeId) await openThread(activeId);
    startPoll();
  })();

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      $('newChatModal').classList.remove('open');
      $('fpModal').classList.remove('open');
      $('emojiPop').classList.remove('open');
    }
  });
})();
</script>
</BaseLayout>
