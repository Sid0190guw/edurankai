---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TwoFactorPanel from '@/components/security/TwoFactorPanel.astro';
import { isTotpEnabled, countUnusedBackupCodes } from '@/lib/auth/twofactor';
import { listPasskeys } from '@/lib/auth/webauthn';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

let enabled = false;
let backupRemaining = 0;
let passkeys: any[] = [];
try {
  enabled = await isTotpEnabled(user.id);
  if (enabled) backupRemaining = await countUnusedBackupCodes(user.id);
  passkeys = await listPasskeys(user.id);
} catch (_) {}
const accountLabel = user.email || (user as any).internalHandle || user.name || '';
---
<BaseLayout title="Security - EduRankAI" description="Protect your account with two-factor authentication.">
  <section style="padding:48px 20px; max-width:640px; margin:0 auto;">
    <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:#DC5000;margin:0 0 8px;">Account security</p>
    <h1 style="font-size:28px;font-weight:700;color:#111;margin:0 0 6px;">Two-factor authentication</h1>
    <p style="font-size:14px;color:#6b7280;margin:0 0 24px;line-height:1.6;">A second step at sign-in keeps your account safe even if your password is stolen.</p>

    <TwoFactorPanel enabled={enabled} backupRemaining={backupRemaining} accountLabel={accountLabel} passkeys={passkeys} />

    <p style="margin-top:18px;font-size:13px;"><a href="/portal" style="color:#DC5000;font-weight:600;">&larr; Back to portal</a></p>
  </section>
</BaseLayout>
