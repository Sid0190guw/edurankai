---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=/portal/mail');

function rows(r: any) { return Array.isArray(r) ? r : (r?.rows || []); }

// --- Bootstrap schema (idempotent) ---
try {
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS portal_mail_threads (
      id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
      subject TEXT,
      snippet TEXT,
      participants JSONB DEFAULT '[]'::jsonb,
      last_message_at TIMESTAMPTZ DEFAULT NOW(),
      has_attachments BOOLEAN DEFAULT false,
      labels JSONB DEFAULT '[]'::jsonb,
      created_at TIMESTAMPTZ DEFAULT NOW()
    )
  `);
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS portal_mail_messages (
      id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
      thread_id UUID REFERENCES portal_mail_threads(id) ON DELETE CASCADE,
      from_user_id UUID,
      from_email VARCHAR(200),
      to_emails JSONB DEFAULT '[]'::jsonb,
      cc_emails JSONB DEFAULT '[]'::jsonb,
      body_html TEXT,
      body_text TEXT,
      attachments JSONB DEFAULT '[]'::jsonb,
      sent_at TIMESTAMPTZ DEFAULT NOW()
    )
  `);
  await db.execute(sql`ALTER TABLE portal_mail_messages ADD COLUMN IF NOT EXISTS is_encrypted BOOLEAN DEFAULT false`);
  await db.execute(sql`ALTER TABLE portal_mail_messages ADD COLUMN IF NOT EXISTS ciphertext TEXT`);
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS portal_mail_thread_state (
      user_id UUID,
      thread_id UUID,
      is_starred BOOLEAN DEFAULT false,
      is_archived BOOLEAN DEFAULT false,
      is_read BOOLEAN DEFAULT false,
      folder VARCHAR(40) DEFAULT 'inbox',
      snooze_until TIMESTAMPTZ,
      PRIMARY KEY (user_id, thread_id)
    )
  `);
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS portal_mail_labels (
      id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
      user_id UUID,
      name VARCHAR(80),
      color VARCHAR(20) DEFAULT '#67e8f9',
      created_at TIMESTAMPTZ DEFAULT NOW()
    )
  `);
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS portal_mail_thread_labels (
      thread_id UUID,
      label_id UUID,
      user_id UUID,
      PRIMARY KEY (thread_id, label_id, user_id)
    )
  `);
} catch (e) {
  console.error('[mail bootstrap]', e);
}

// --- POST handlers ---
let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();
    const action = String(form.get('action') || '');
    if (action === 'send') {
      const subject = String(form.get('subject') || '(no subject)').slice(0, 500);
      const toRaw = String(form.get('to') || '').trim();
      const ccRaw = String(form.get('cc') || '').trim();
      const bccRaw = String(form.get('bcc') || '').trim();
      const bodyHtml = String(form.get('body_html') || '');
      const bodyText = String(form.get('body_text') || '');
      const isEnc = String(form.get('is_encrypted') || '') === '1';
      const cipher = String(form.get('ciphertext') || '');
      const attachRaw = String(form.get('attachments') || '[]');
      const toList = toRaw.split(/[,;\s]+/).filter(Boolean);
      const ccList = ccRaw.split(/[,;\s]+/).filter(Boolean);
      const bccList = bccRaw.split(/[,;\s]+/).filter(Boolean);
      if (!toList.length) { errMsg = 'Need at least one recipient'; }
      else {
        const snippet = bodyText.slice(0, 180);
        const participants = JSON.stringify([user.email, ...toList, ...ccList, ...bccList]);
        const labels = JSON.stringify([]);
        const tr = await db.execute(sql`
          INSERT INTO portal_mail_threads (subject, snippet, participants, last_message_at, has_attachments, labels)
          VALUES (${subject}, ${snippet}, ${participants}::jsonb, NOW(), ${attachRaw !== '[]'}, ${labels}::jsonb)
          RETURNING id
        `);
        const threadId = rows(tr)[0]?.id;
        await db.execute(sql`
          INSERT INTO portal_mail_messages
            (thread_id, from_user_id, from_email, to_emails, cc_emails, body_html, body_text, attachments, is_encrypted, ciphertext)
          VALUES
            (${threadId}, ${user.id}, ${user.email},
             ${JSON.stringify(toList)}::jsonb, ${JSON.stringify(ccList)}::jsonb,
             ${isEnc ? '' : bodyHtml}, ${isEnc ? '' : bodyText},
             ${attachRaw}::jsonb, ${isEnc}, ${isEnc ? cipher : null})
        `);
        // sender's state -> sent
        await db.execute(sql`
          INSERT INTO portal_mail_thread_state (user_id, thread_id, is_read, folder)
          VALUES (${user.id}, ${threadId}, true, 'sent')
          ON CONFLICT (user_id, thread_id) DO UPDATE SET folder = 'sent', is_read = true
        `);
        // for each recipient that exists in system, drop in inbox
        for (const em of [...toList, ...ccList, ...bccList]) {
          try {
            const u = await db.execute(sql`SELECT id FROM users WHERE LOWER(email) = LOWER(${em}) LIMIT 1`);
            const uid = rows(u)[0]?.id;
            if (uid) {
              await db.execute(sql`
                INSERT INTO portal_mail_thread_state (user_id, thread_id, is_read, folder)
                VALUES (${uid}, ${threadId}, false, 'inbox')
                ON CONFLICT (user_id, thread_id) DO NOTHING
              `);
            }
          } catch (_) { /* user table shape may differ */ }
        }
        okMsg = 'Sent';
      }
    } else if (action === 'reply') {
      const threadId = String(form.get('thread_id') || '');
      const bodyHtml = String(form.get('body_html') || '');
      const bodyText = String(form.get('body_text') || '');
      const isEnc = String(form.get('is_encrypted') || '') === '1';
      const cipher = String(form.get('ciphertext') || '');
      if (threadId && bodyText) {
        const tr = await db.execute(sql`SELECT participants FROM portal_mail_threads WHERE id = ${threadId}::uuid LIMIT 1`);
        const t = rows(tr)[0];
        const others = (t?.participants || []).filter((p: string) => p !== user.email);
        const toJ = JSON.stringify(others);
        await db.execute(sql`
          INSERT INTO portal_mail_messages
            (thread_id, from_user_id, from_email, to_emails, body_html, body_text, is_encrypted, ciphertext)
          VALUES
            (${threadId}::uuid, ${user.id}, ${user.email}, ${toJ}::jsonb,
             ${isEnc ? '' : bodyHtml}, ${isEnc ? '' : bodyText},
             ${isEnc}, ${isEnc ? cipher : null})
        `);
        await db.execute(sql`
          UPDATE portal_mail_threads
            SET last_message_at = NOW(), snippet = ${bodyText.slice(0, 180)}
            WHERE id = ${threadId}::uuid
        `);
        okMsg = 'Reply sent';
      }
    } else if (action === 'toggle_star') {
      const threadId = String(form.get('thread_id') || '');
      await db.execute(sql`
        INSERT INTO portal_mail_thread_state (user_id, thread_id, is_starred, folder)
        VALUES (${user.id}, ${threadId}::uuid, true, 'inbox')
        ON CONFLICT (user_id, thread_id) DO UPDATE SET is_starred = NOT portal_mail_thread_state.is_starred
      `);
    } else if (action === 'move') {
      const threadId = String(form.get('thread_id') || '');
      const folder = String(form.get('folder') || 'inbox');
      await db.execute(sql`
        INSERT INTO portal_mail_thread_state (user_id, thread_id, folder)
        VALUES (${user.id}, ${threadId}::uuid, ${folder})
        ON CONFLICT (user_id, thread_id) DO UPDATE SET folder = ${folder}
      `);
    } else if (action === 'snooze') {
      const threadId = String(form.get('thread_id') || '');
      const until = String(form.get('until') || '');
      await db.execute(sql`
        INSERT INTO portal_mail_thread_state (user_id, thread_id, snooze_until)
        VALUES (${user.id}, ${threadId}::uuid, ${until}::timestamptz)
        ON CONFLICT (user_id, thread_id) DO UPDATE SET snooze_until = ${until}::timestamptz
      `);
    } else if (action === 'create_label') {
      const name = String(form.get('label_name') || '').slice(0, 80);
      const color = String(form.get('label_color') || '#67e8f9');
      if (name) {
        await db.execute(sql`
          INSERT INTO portal_mail_labels (user_id, name, color) VALUES (${user.id}, ${name}, ${color})
        `);
      }
    } else if (action === 'apply_label') {
      const threadId = String(form.get('thread_id') || '');
      const labelId = String(form.get('label_id') || '');
      await db.execute(sql`
        INSERT INTO portal_mail_thread_labels (thread_id, label_id, user_id)
        VALUES (${threadId}::uuid, ${labelId}::uuid, ${user.id})
        ON CONFLICT DO NOTHING
      `);
    }
  } catch (e: any) {
    errMsg = String(e.message || e);
    console.error('[mail post]', e);
  }
}

// --- Query state ---
const url = new URL(Astro.request.url);
const folder = url.searchParams.get('folder') || 'inbox';
const search = url.searchParams.get('q') || '';
const openId = url.searchParams.get('t') || '';
const filterFrom = url.searchParams.get('from') || '';
const filterHasAttach = url.searchParams.get('attach') === '1';

// labels for this user
const lblRes = await db.execute(sql`
  SELECT id, name, color FROM portal_mail_labels WHERE user_id = ${user.id} ORDER BY created_at DESC LIMIT 50
`);
const labels = rows(lblRes);

// folder counts
const countRes = await db.execute(sql`
  SELECT folder, COUNT(*) FILTER (WHERE is_read = false) AS unread, COUNT(*) AS total
  FROM portal_mail_thread_state WHERE user_id = ${user.id} GROUP BY folder
`);
const counts: Record<string, { unread: number; total: number }> = {};
for (const c of rows(countRes)) counts[c.folder] = { unread: Number(c.unread), total: Number(c.total) };

// thread list - precomputed condition to avoid JSX < parser confusion
let threadsRes;
if (folder === 'starred') {
  threadsRes = await db.execute(sql`
    SELECT t.id, t.subject, t.snippet, t.participants, t.last_message_at, t.has_attachments,
           s.is_read, s.is_starred, s.folder
    FROM portal_mail_threads t
    JOIN portal_mail_thread_state s ON s.thread_id = t.id
    WHERE s.user_id = ${user.id} AND s.is_starred = true
      AND (${search} = '' OR LOWER(COALESCE(t.subject,'')) LIKE LOWER(${'%' + search + '%'}) OR LOWER(COALESCE(t.snippet,'')) LIKE LOWER(${'%' + search + '%'}))
    ORDER BY t.last_message_at DESC LIMIT 100
  `);
} else {
  threadsRes = await db.execute(sql`
    SELECT t.id, t.subject, t.snippet, t.participants, t.last_message_at, t.has_attachments,
           s.is_read, s.is_starred, s.folder
    FROM portal_mail_threads t
    JOIN portal_mail_thread_state s ON s.thread_id = t.id
    WHERE s.user_id = ${user.id} AND s.folder = ${folder}
      AND (${search} = '' OR LOWER(COALESCE(t.subject,'')) LIKE LOWER(${'%' + search + '%'}) OR LOWER(COALESCE(t.snippet,'')) LIKE LOWER(${'%' + search + '%'}))
      AND (${filterFrom} = '' OR EXISTS (SELECT 1 FROM jsonb_array_elements_text(t.participants) p WHERE LOWER(p) LIKE LOWER(${'%' + filterFrom + '%'})))
      AND (${filterHasAttach ? 'y' : 'n'} = 'n' OR t.has_attachments = true)
    ORDER BY t.last_message_at DESC LIMIT 100
  `);
}
const threads = rows(threadsRes);

// open thread messages
let openMessages: any[] = [];
let openThread: any = null;
if (openId) {
  const otRes = await db.execute(sql`SELECT * FROM portal_mail_threads WHERE id = ${openId}::uuid LIMIT 1`);
  openThread = rows(otRes)[0] || null;
  if (openThread) {
    const mRes = await db.execute(sql`
      SELECT id, from_email, to_emails, cc_emails, body_html, body_text, attachments, sent_at, is_encrypted, ciphertext
      FROM portal_mail_messages WHERE thread_id = ${openId}::uuid ORDER BY sent_at ASC
    `);
    openMessages = rows(mRes);
    await db.execute(sql`
      UPDATE portal_mail_thread_state SET is_read = true WHERE user_id = ${user.id} AND thread_id = ${openId}::uuid
    `);
  }
}

const folders = [
  { key: 'inbox', label: 'Inbox' },
  { key: 'starred', label: 'Starred' },
  { key: 'sent', label: 'Sent' },
  { key: 'drafts', label: 'Drafts' },
  { key: 'archived', label: 'Archive' },
  { key: 'trash', label: 'Trash' },
  { key: 'spam', label: 'Spam' },
];

function fmtTime(t: any) {
  if (!t) return '';
  const d = new Date(t);
  const now = new Date();
  const sameDay = d.toDateString() === now.toDateString();
  if (sameDay) return d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  const diffDays = (now.getTime() - d.getTime()) / 86400000;
  if (diffDays < 365) return d.toLocaleDateString([], { month: 'short', day: 'numeric' });
  return d.toLocaleDateString();
}

function senderOf(t: any) {
  const p = t.participants || [];
  return (p.find((x: string) => x !== user.email) || p[0] || '').toString();
}
function initials(em: string) {
  return (em || '?').slice(0, 2).toUpperCase();
}

const threadIdList = threads.map((t: any) => t.id);
