---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MailClient from '@/components/MailClient.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
// Admins use the admin mail client.
if (['super_admin', 'hr', 'editor'].includes(user.role)) return Astro.redirect('/admin/mail');
---
<BaseLayout title="Mail">
  <div class="portal-mail-wrap">
    <MailClient user={user} basePath="/portal/mail" />
  </div>
</BaseLayout>

<style is:global>
  .portal-mail-wrap{ background:#07090d; }
  .portal-mail-wrap .mailc{ height:100dvh; }
</style>
