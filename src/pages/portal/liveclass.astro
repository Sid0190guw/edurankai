---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

function rows(r: any) { return Array.isArray(r) ? r : (r?.rows || []); }

let okMsg = '';
let errMsg = '';

// --- self-bootstrap schema ---
try {
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS live_classes (
      id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
      host_user_id UUID,
      title TEXT,
      subject VARCHAR(120),
      course_id UUID,
      scheduled_at TIMESTAMPTZ,
      duration_minutes INT DEFAULT 60,
      meet_url TEXT,
      status VARCHAR(20) DEFAULT 'scheduled',
      capacity INT DEFAULT 50,
      enrolled_count INT DEFAULT 0,
      recording_url TEXT,
      created_at TIMESTAMPTZ DEFAULT NOW()
    )
  `);
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS live_class_enrollments (
      class_id UUID,
      user_id UUID,
      joined_at TIMESTAMPTZ DEFAULT NOW(),
      PRIMARY KEY(class_id, user_id)
    )
  `);
} catch (_) {}

// --- POST handlers (enroll / unenroll) ---
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = (fd.get('action') as string) || '';
  const classId = (fd.get('class_id') as string) || '';
  try {
    if (action === 'enroll' && classId) {
      // capacity check
      const cap = rows(await db.execute(sql`
        SELECT capacity, enrolled_count FROM live_classes WHERE id = ${classId} LIMIT 1
      `))[0];
      if (cap && Number(cap.enrolled_count) >= Number(cap.capacity)) {
        errMsg = 'This class is full.';
      } else {
        const ins = await db.execute(sql`
          INSERT INTO live_class_enrollments (class_id, user_id)
          VALUES (${classId}, ${user.id})
          ON CONFLICT DO NOTHING
          RETURNING class_id
        `);
        if (rows(ins).length > 0) {
          await db.execute(sql`
            UPDATE live_classes SET enrolled_count = enrolled_count + 1 WHERE id = ${classId}
          `);
        }
        okMsg = 'Enrolled. See you in class.';
      }
    } else if (action === 'unenroll' && classId) {
      const del = await db.execute(sql`
        DELETE FROM live_class_enrollments WHERE class_id = ${classId} AND user_id = ${user.id}
        RETURNING class_id
      `);
      if (rows(del).length > 0) {
        await db.execute(sql`
          UPDATE live_classes SET enrolled_count = GREATEST(0, enrolled_count - 1) WHERE id = ${classId}
        `);
      }
      okMsg = 'Cancelled.';
    }
  } catch (e: any) {
    errMsg = 'Could not complete the request.';
  }
  return Astro.redirect('/portal/liveclass?msg=' + encodeURIComponent(okMsg || errMsg));
}

const url = new URL(Astro.request.url);
const flash = url.searchParams.get('msg') || '';
const tab = url.searchParams.get('tab') || 'upcoming';

// --- query classes ---
let upcoming: any[] = [];
let liveNow: any[] = [];
let past: any[] = [];
let myEnrollments = new Set<string>();

try {
  const enr = rows(await db.execute(sql`
    SELECT class_id FROM live_class_enrollments WHERE user_id = ${user.id}
  `));
  for (const e of enr) myEnrollments.add(e.class_id);
} catch (_) {}

try {
  const r = rows(await db.execute(sql`
    SELECT c.*, u.name AS host_name
    FROM live_classes c
    LEFT JOIN users u ON u.id = c.host_user_id
    WHERE c.scheduled_at > NOW() AND c.status = 'scheduled'
    ORDER BY c.scheduled_at ASC
    LIMIT 50
  `));
  upcoming = r;
} catch (_) {}

try {
  const r = rows(await db.execute(sql`
    SELECT c.*, u.name AS host_name
    FROM live_classes c
    LEFT JOIN users u ON u.id = c.host_user_id
    WHERE (c.status = 'live')
       OR (c.scheduled_at <= NOW() AND c.scheduled_at + (c.duration_minutes || ' minutes')::interval > NOW() AND c.status = 'scheduled')
    ORDER BY c.scheduled_at ASC
    LIMIT 20
  `));
  liveNow = r;
} catch (_) {}

try {
  const r = rows(await db.execute(sql`
    SELECT c.*, u.name AS host_name
    FROM live_classes c
    LEFT JOIN users u ON u.id = c.host_user_id
    WHERE c.scheduled_at + (c.duration_minutes || ' minutes')::interval < NOW()
       OR c.status = 'ended'
    ORDER BY c.scheduled_at DESC
    LIMIT 40
  `));
  past = r;
} catch (_) {}

function timeUntil(d: any): string {
  if (!d) return '';
  const diff = new Date(d).getTime() - Date.now();
  if (diff <= 0) return 'starting now';
  const m = Math.floor(diff / 60000);
  if (m < 60) return 'in ' + m + ' min';
  const h = Math.floor(m / 60);
  if (h < 24) return 'in ' + h + 'h ' + (m % 60) + 'm';
  const d2 = Math.floor(h / 24);
  return 'in ' + d2 + 'd';
}
function fmtDate(d: any): string {
  if (!d) return '';
  const dt = new Date(d);
  return dt.toLocaleDateString('en-GB', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short' }) + ' &middot; ' +
         dt.toLocaleTimeString('en-GB', { timeZone: 'Asia/Kolkata', hour: '2-digit', minute: '2-digit' });
}

const listForTab = tab === 'live' ? liveNow : tab === 'past' ? past : upcoming;
---
<BaseLayout title="Live Classes - EduRankAI" description="Join scheduled live classes with your faculty and cohorts.">
<style>
  .lc-wrap { max-width: 1080px; margin: 0 auto; padding: 32px 20px 80px; background: #FAF8F5; }
  .lc-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 16px; flex-wrap: wrap; margin-bottom: 22px; }
  .lc-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; font-weight: 700; margin-bottom: 8px; }
  .lc-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 4vw, 42px); font-weight: 600; color: #0E0B08; letter-spacing: -0.01em; line-height: 1.1; margin: 0; }
  .lc-title em { font-style: italic; color: #FF4F00; font-weight: 500; }
  .lc-sub { color: #5b5650; font-size: 14px; margin-top: 6px; max-width: 560px; }
  .lc-host-cta { display: inline-flex; align-items: center; gap: 8px; background: #FF4F00; color: #fff; padding: 11px 18px; border-radius: 10px; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none; transition: background 0.15s; }
  .lc-host-cta:hover { background: #e64600; }
  .lc-host-cta svg { width: 16px; height: 16px; }
  .lc-tabs { display: flex; gap: 4px; border-bottom: 1px solid rgba(14,11,8,0.10); margin-bottom: 22px; }
  .lc-tab { padding: 10px 16px; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700; color: #5b5650; text-decoration: none; border-bottom: 2px solid transparent; transition: color 0.15s, border-color 0.15s; }
  .lc-tab.active { color: #FF4F00; border-bottom-color: #FF4F00; }
  .lc-tab .count { display: inline-block; background: rgba(255,79,0,0.10); color: #FF4F00; font-size: 10px; padding: 2px 7px; border-radius: 100px; margin-left: 6px; }
  .lc-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(330px, 1fr)); gap: 16px; }
  .lc-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 14px; padding: 20px; display: flex; flex-direction: column; gap: 12px; transition: border-color 0.15s, transform 0.15s; }
  .lc-card:hover { border-color: rgba(255,79,0,0.30); }
  .lc-card.live { border-color: rgba(220,38,38,0.40); box-shadow: 0 0 0 3px rgba(220,38,38,0.06); }
  .lc-card-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; }
  .lc-subj { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #5b5650; font-weight: 700; }
  .lc-live-pill { display: inline-flex; align-items: center; gap: 6px; background: #DC2626; color: #fff; font-family: 'Geist Mono', monospace; font-size: 9px; padding: 3px 8px; border-radius: 100px; font-weight: 700; letter-spacing: 0.10em; text-transform: uppercase; }
  .lc-live-dot { width: 6px; height: 6px; background: #fff; border-radius: 50%; animation: lcblink 1.2s infinite; }
  @keyframes lcblink { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
  .lc-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; color: #0E0B08; margin: 0; line-height: 1.2; letter-spacing: -0.01em; }
  .lc-host { font-size: 13px; color: #5b5650; display: flex; align-items: center; gap: 6px; }
  .lc-host svg { width: 14px; height: 14px; color: #FF4F00; }
  .lc-meta { display: flex; gap: 14px; font-size: 12px; color: #5b5650; padding-top: 4px; }
  .lc-meta-item { display: flex; align-items: center; gap: 5px; }
  .lc-meta-item svg { width: 13px; height: 13px; color: #FF4F00; }
  .lc-cap-bar { width: 100%; height: 5px; background: rgba(14,11,8,0.06); border-radius: 100px; overflow: hidden; }
  .lc-cap-fill { height: 100%; background: linear-gradient(90deg, #FF4F00, #ff7040); border-radius: 100px; transition: width 0.3s; }
  .lc-cap-fill.full { background: #DC2626; }
  .lc-cap-text { font-family: 'Geist Mono', monospace; font-size: 10px; color: #5b5650; letter-spacing: 0.04em; }
  .lc-actions { display: flex; gap: 8px; margin-top: 4px; }
  .lc-btn { flex: 1; padding: 10px 14px; border-radius: 8px; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; cursor: pointer; border: none; text-align: center; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; gap: 6px; transition: background 0.15s, opacity 0.15s; }
  .lc-btn-primary { background: #FF4F00; color: #fff; }
  .lc-btn-primary:hover { background: #e64600; }
  .lc-btn-ghost { background: #fff; color: #0E0B08; border: 1px solid rgba(14,11,8,0.18); }
  .lc-btn-ghost:hover { background: #FAF8F5; }
  .lc-btn-disabled { background: rgba(14,11,8,0.05); color: #5b5650; cursor: not-allowed; }
  .lc-btn svg { width: 13px; height: 13px; }
  .lc-empty { background: #fff; border: 1px dashed rgba(14,11,8,0.18); border-radius: 14px; padding: 60px 20px; text-align: center; color: #5b5650; font-size: 14px; }
  .lc-empty strong { display: block; font-family: 'Cormorant Garamond', serif; font-size: 22px; color: #0E0B08; font-weight: 600; font-style: italic; margin-bottom: 6px; }
  .lc-flash { background: #fff; border: 1px solid rgba(255,79,0,0.30); border-left: 3px solid #FF4F00; padding: 12px 16px; border-radius: 8px; margin-bottom: 18px; font-size: 13px; color: #0E0B08; }
  form.lc-inline { display: contents; }
  @media (max-width: 600px) {
    .lc-wrap { padding: 22px 14px 80px; }
    .lc-grid { grid-template-columns: 1fr; }
    .lc-head { flex-direction: column; align-items: flex-start; }
  }
</style>
<main class="lc-wrap">
  <div class="lc-head">
    <div>
      <div class="lc-eyebrow">Live classroom</div>
      <h1 class="lc-title">Live <em>classes</em></h1>
      <div class="lc-sub">Scheduled lectures, doubt sessions, and faculty office hours. Enroll to reserve a seat and receive a join link 15 minutes before start.</div>
    </div>
    <a class="lc-host-cta" href="/portal/liveclass">
      <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M12 5v14M5 12h14"/></svg>
      Host a class
    </a>
  </div>

  {flash && <div class="lc-flash">{flash}</div>}

  <div class="lc-tabs">
    <a class={`lc-tab ${tab==='upcoming'?'active':''}`} href="/portal/liveclass?tab=upcoming">
      Upcoming<span class="count">{upcoming.length}</span>
    </a>
    <a class={`lc-tab ${tab==='live'?'active':''}`} href="/portal/liveclass?tab=live">
      Live now<span class="count">{liveNow.length}</span>
    </a>
    <a class={`lc-tab ${tab==='past'?'active':''}`} href="/portal/liveclass?tab=past">
      Past<span class="count">{past.length}</span>
    </a>
  </div>

  {listForTab.length === 0 ? (
    <div class="lc-empty">
      <strong>No classes here yet</strong>
      {tab === 'upcoming' && 'New sessions are added every week. Check back soon or host your own.'}
      {tab === 'live' && 'Nothing streaming right now. Upcoming classes will appear here when they begin.'}
      {tab === 'past' && 'Past sessions and recordings will be listed here.'}
    </div>
  ) : (
    <div class="lc-grid">
      {listForTab.map((c: any) => {
        const cap = Number(c.capacity || 50);
        const enr = Number(c.enrolled_count || 0);
        const pct = cap > 0 ? Math.min(100, Math.round((enr / cap) * 100)) : 0;
        const isFull = enr >= cap;
        const isEnrolled = myEnrollments.has(c.id);
        const isLive = tab === 'live';
        const isPast = tab === 'past';
        return (
          <div class={`lc-card ${isLive ? 'live' : ''}`}>
            <div class="lc-card-top">
              <div class="lc-subj">{c.subject || 'General'}</div>
              {isLive && (
                <span class="lc-live-pill"><span class="lc-live-dot"></span>Live</span>
              )}
            </div>
            <h3>{c.title || 'Untitled session'}</h3>
            <div class="lc-host">
              <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a8 8 0 0116 0v1"/></svg>
              {c.host_name || 'Faculty'}
            </div>
            <div class="lc-meta">
              <div class="lc-meta-item">
                <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                <span set:html={fmtDate(c.scheduled_at)} />
              </div>
              <div class="lc-meta-item">
                <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                {c.duration_minutes || 60} min
              </div>
              {!isPast && !isLive && (
                <div class="lc-meta-item">
                  <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z"/></svg>
                  {timeUntil(c.scheduled_at)}
                </div>
              )}
            </div>
            <div>
              <div class="lc-cap-text">{enr} of {cap} seats &middot; {pct}% full</div>
              <div class="lc-cap-bar" style="margin-top:5px;">
                <div class={`lc-cap-fill ${isFull ? 'full' : ''}`} style={`width:${pct}%`}></div>
              </div>
            </div>
            <div class="lc-actions">
              {isLive && (
                <a class="lc-btn lc-btn-primary" href={`/portal/liveclass/${c.id}`}>
                  <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><polygon points="6 4 20 12 6 20 6 4"/></svg>
                  Join now
                </a>
              )}
              {isPast && c.recording_url && (
                <a class="lc-btn lc-btn-ghost" href={c.recording_url}>
                  <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
                  Watch recording
                </a>
              )}
              {isPast && !c.recording_url && (
                <button class="lc-btn lc-btn-disabled" disabled>Recording pending</button>
              )}
              {!isLive && !isPast && (
                isEnrolled ? (
                  <form method="POST" class="lc-inline">
                    <input type="hidden" name="action" value="unenroll" />
                    <input type="hidden" name="class_id" value={c.id} />
                    <button class="lc-btn lc-btn-ghost" type="submit">Cancel seat</button>
                  </form>
                ) : isFull ? (
                  <button class="lc-btn lc-btn-disabled" disabled>Class full</button>
                ) : (
                  <form method="POST" class="lc-inline">
                    <input type="hidden" name="action" value="enroll" />
                    <input type="hidden" name="class_id" value={c.id} />
                    <button class="lc-btn lc-btn-primary" type="submit">
                      <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M20 6L9 17l-5-5"/></svg>
                      Reserve seat
                    </button>
                  </form>
                )
              )}
            </div>
          </div>
        );
      })}
    </div>
  )}
</main>
</BaseLayout>
