---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ensureGamificationSchema, getLearnerStats, getLeaderboard } from '@/lib/gamification';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/achievements'));

await ensureGamificationSchema();

const stats = await getLearnerStats(user.id);
const leaderboard = await getLeaderboard(20);

const currentStreak = stats?.currentStreak || 0;
const longestStreak = stats?.longestStreak || 0;
const totalXp = stats?.totalXp || 0;
const level = stats?.level || 1;
const progress = stats?.progress || { pct: 0, earnedInLevel: 0, neededForLevel: 100, toNextLevel: 100, floorXp: 0, ceilXp: 100 };
const badges = stats?.recentBadges || [];
const totalBadges = stats?.totalBadges || 0;
const myRank = stats?.rank;

const inLeaderboard = leaderboard.some((row: any) => row.user_id === user.id);

function fmtDate(d: any): string {
  if (!d) return '';
  try {
    return new Date(d).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short', year: 'numeric' });
  } catch { return ''; }
}

function shortName(name: string): string {
  if (!name) return 'Learner';
  const parts = String(name).trim().split(/\s+/);
  if (parts.length === 1) return parts[0];
  return parts[0] + ' ' + (parts[parts.length - 1][0] || '') + '.';
}

function initials(name: string): string {
  if (!name) return 'L';
  const parts = String(name).trim().split(/\s+/);
  if (parts.length === 1) return (parts[0][0] || 'L').toUpperCase();
  return ((parts[0][0] || '') + (parts[parts.length - 1][0] || '')).toUpperCase();
}

// Generic default badge SVG for badges that didn't ship an icon
const defaultBadgeSvg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526"/></svg>';
---
<BaseLayout title="Achievements" description="Your streak, XP, level, and badges on EduRankAI.">
  <section class="px-[5vw] py-10 md:py-14 max-w-6xl mx-auto">

    <!-- Hero -->
    <header class="mb-10 md:mb-12 max-w-3xl">
      <p class="text-[0.68rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-3">Portal &middot; Achievements</p>
      <h1 class="font-display text-[clamp(2rem,5.5vw,3.4rem)] font-semibold text-ink leading-[1.05] tracking-[-0.01em] mb-4">
        Show your <em class="not-italic font-display italic text-burn">work</em>.
      </h1>
      <p class="text-[1.02rem] text-ink-soft leading-[1.55] max-w-2xl">
        Your day-by-day streak, XP earned across lessons and quizzes, and the badges
        you've collected on the journey. Every solved doubt, completed lesson and
        weekly habit counts.
      </p>
    </header>

    <!-- Top stat strip -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 mb-10">
      <div class="bg-white border border-ink/10 rounded-2xl p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-burn" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
          </span>
          <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft">Current streak</p>
        </div>
        <p class="font-display text-[2.4rem] font-semibold text-ink leading-none">{currentStreak}<span class="text-[0.95rem] font-mono text-ink-soft ml-2 align-middle">day{currentStreak === 1 ? '' : 's'}</span></p>
      </div>

      <div class="bg-white border border-ink/10 rounded-2xl p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-ink-soft" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
          </span>
          <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft">Longest streak</p>
        </div>
        <p class="font-display text-[2.4rem] font-semibold text-ink leading-none">{longestStreak}<span class="text-[0.95rem] font-mono text-ink-soft ml-2 align-middle">day{longestStreak === 1 ? '' : 's'}</span></p>
      </div>

      <div class="bg-white border border-ink/10 rounded-2xl p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-burn" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </span>
          <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft">Total XP</p>
        </div>
        <p class="font-display text-[2.4rem] font-semibold text-ink leading-none">{totalXp.toLocaleString('en-IN')}</p>
      </div>

      <div class="bg-white border border-ink/10 rounded-2xl p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-leaf" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
          </span>
          <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft">Level</p>
        </div>
        <p class="font-display text-[2.4rem] font-semibold text-ink leading-none">{level}</p>
      </div>
    </div>

    <!-- Level progress + badges + leaderboard grid -->
    <div class="grid lg:grid-cols-3 gap-5 md:gap-6">

      <!-- Left col: level progress + badges -->
      <div class="lg:col-span-2 space-y-5 md:space-y-6">

        <!-- Level progress card -->
        <div class="bg-white border border-ink/10 rounded-2xl p-6">
          <div class="flex items-baseline justify-between gap-3 mb-4 flex-wrap">
            <div>
              <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft mb-1">Level progress</p>
              <p class="font-display text-[1.4rem] font-semibold text-ink leading-tight">Level {level} &rarr; Level {level + 1}</p>
            </div>
            <p class="text-[0.85rem] font-mono text-ink-soft">{progress.earnedInLevel} / {progress.neededForLevel} XP</p>
          </div>
          <div class="w-full h-3 bg-burn-pale rounded-full overflow-hidden border border-ink/10">
            <div class="h-full bg-burn rounded-full transition-all" style={'width:' + progress.pct + '%;'}></div>
          </div>
          <p class="mt-3 text-[0.85rem] text-ink-soft">
            {progress.toNextLevel > 0
              ? <Fragment>You're <strong class="text-ink font-semibold">{progress.toNextLevel} XP</strong> away from Level {level + 1}. Keep going.</Fragment>
              : <Fragment>You've reached this level &mdash; the next milestone unlocks on your next XP earn.</Fragment>
            }
          </p>
        </div>

        <!-- Badges grid -->
        <div class="bg-white border border-ink/10 rounded-2xl p-6">
          <div class="flex items-baseline justify-between gap-3 mb-5 flex-wrap">
            <div>
              <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft mb-1">Badges</p>
              <p class="font-display text-[1.4rem] font-semibold text-ink leading-tight">Recent collection</p>
            </div>
            <p class="text-[0.78rem] font-mono text-ink-soft">{totalBadges} earned</p>
          </div>

          {badges.length === 0 ? (
            <div class="border border-dashed border-ink/15 rounded-xl p-8 text-center bg-cream-2">
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-burn-pale text-burn mb-3" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526"/></svg>
              </div>
              <p class="text-[0.95rem] text-ink-soft max-w-md mx-auto">No badges yet. Complete your first lesson, answer a doubt, or hit a 7-day streak to start collecting.</p>
            </div>
          ) : (
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
              {badges.map((b: any) => (
                <div class="border border-ink/10 rounded-xl p-4 hover:border-burn/40 hover:bg-burn-pale/30 transition-colors text-center">
                  <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-burn-pale text-burn mb-2" aria-hidden="true">
                    {b.icon_svg
                      ? <Fragment set:html={b.icon_svg} />
                      : <Fragment set:html={defaultBadgeSvg} />
                    }
                  </div>
                  <p class="text-[0.88rem] font-semibold text-ink leading-tight mb-1">{b.badge_name}</p>
                  {b.badge_description && <p class="text-[0.72rem] text-ink-soft leading-snug line-clamp-2">{b.badge_description}</p>}
                  <p class="text-[0.62rem] font-mono uppercase tracking-[0.1em] text-ink-soft mt-2">{fmtDate(b.awarded_at)}</p>
                </div>
              ))}
            </div>
          )}
        </div>

        {stats?.recentXp && stats.recentXp.length > 0 && (
          <div class="bg-white border border-ink/10 rounded-2xl p-6">
            <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft mb-1">XP log</p>
            <p class="font-display text-[1.4rem] font-semibold text-ink leading-tight mb-4">Recent earnings</p>
            <ul class="divide-y divide-ink/10">
              {stats.recentXp.map((e: any) => (
                <li class="py-2.5 flex items-center justify-between gap-3">
                  <div class="min-w-0">
                    <p class="text-[0.9rem] font-medium text-ink-2 capitalize">{String(e.source || '').replace(/_/g, ' ')}</p>
                    <p class="text-[0.7rem] font-mono text-ink-soft">{fmtDate(e.created_at)}</p>
                  </div>
                  <p class="text-[0.95rem] font-mono font-semibold text-burn flex-shrink-0">+{e.xp_amount} XP</p>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>

      <!-- Right col: leaderboard -->
      <aside class="lg:col-span-1">
        <div class="bg-white border border-ink/10 rounded-2xl p-6 lg:sticky lg:top-6">
          <div class="flex items-baseline justify-between gap-3 mb-1 flex-wrap">
            <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft">Leaderboard</p>
            {myRank && <p class="text-[0.7rem] font-mono text-ink-soft">You: <strong class="text-burn">#{myRank}</strong></p>}
          </div>
          <p class="font-display text-[1.4rem] font-semibold text-ink leading-tight mb-4">Top 20 this season</p>

          {leaderboard.length === 0 ? (
            <p class="text-[0.85rem] text-ink-soft">The leaderboard is empty &mdash; be the first to earn XP and claim rank one.</p>
          ) : (
            <ol class="space-y-1.5">
              {leaderboard.map((row: any, i: number) => {
                const isMe = row.user_id === user.id;
                const rank = i + 1;
                const display = shortName(row.display_name || row.email || 'Learner');
                return (
                  <li class={(isMe ? 'bg-burn-pale border-burn/50' : 'bg-cream-2 border-ink/5') + ' border rounded-lg px-3 py-2 flex items-center gap-3'}>
                    <span class={(rank <= 3 ? 'text-burn' : 'text-ink-soft') + ' font-mono font-bold text-[0.78rem] w-6 text-right flex-shrink-0'}>{rank}</span>
                    <span class={(isMe ? 'bg-burn text-white' : 'bg-white border border-ink/10 text-ink-2') + ' inline-flex items-center justify-center w-7 h-7 rounded-full font-mono text-[0.68rem] font-bold flex-shrink-0'}>{initials(row.display_name || row.email || 'L')}</span>
                    <span class="flex-1 min-w-0">
                      <span class={(isMe ? 'text-ink font-semibold' : 'text-ink-2') + ' text-[0.85rem] block truncate'}>{display}{isMe && <span class="ml-1 text-burn font-mono text-[0.62rem] uppercase tracking-[0.1em]">you</span>}</span>
                      <span class="text-[0.66rem] font-mono text-ink-soft">L{row.level} &middot; {Number(row.current_streak_days || 0)}d streak</span>
                    </span>
                    <span class="text-[0.82rem] font-mono font-semibold text-ink flex-shrink-0">{Number(row.total_xp || 0).toLocaleString('en-IN')}</span>
                  </li>
                );
              })}
            </ol>
          )}

          {!inLeaderboard && myRank && (
            <div class="mt-3 pt-3 border-t border-ink/10">
              <div class="bg-burn-pale border border-burn/40 rounded-lg px-3 py-2 flex items-center gap-3">
                <span class="text-burn font-mono font-bold text-[0.78rem] w-6 text-right flex-shrink-0">#{myRank}</span>
                <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-burn text-white font-mono text-[0.68rem] font-bold flex-shrink-0">{initials(user.full_name || user.email || 'L')}</span>
                <span class="flex-1 min-w-0">
                  <span class="text-ink font-semibold text-[0.85rem] block truncate">{shortName(user.full_name || user.email || 'You')}<span class="ml-1 text-burn font-mono text-[0.62rem] uppercase tracking-[0.1em]">you</span></span>
                  <span class="text-[0.66rem] font-mono text-ink-soft">L{level} &middot; {currentStreak}d streak</span>
                </span>
                <span class="text-[0.82rem] font-mono font-semibold text-ink flex-shrink-0">{totalXp.toLocaleString('en-IN')}</span>
              </div>
            </div>
          )}
        </div>
      </aside>
    </div>

    <!-- Footer help strip -->
    <div class="mt-10 border-t border-ink/10 pt-6">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft mb-2">How XP works</p>
      <p class="text-[0.88rem] text-ink-soft leading-[1.55] max-w-3xl">
        Levels follow a square-root curve &mdash; the first few are quick, later levels take steady effort.
        XP comes from completing lessons, getting quiz answers right, answering classmates' doubts on Visvambhara,
        and showing up day after day. Streaks reset if you skip a day; the longest you've ever held is kept as a separate badge of honour.
      </p>
    </div>
  </section>
</BaseLayout>
