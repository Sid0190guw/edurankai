---
// /portal/waivers — dedicated landing for fee-waiver-only users.
// Shows every waiver the signed-in user has ever submitted with a status
// pill, last-message preview, unread count, and a CTA to the thread for
// each. Designed for applicants who came in via the waiver path and don't
// have a full application yet — they should see exactly what's happening
// with their requests without having to navigate the broader portal.
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { ensureFeeWaiverSchema } from '@/lib/fee-waiver';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/waivers'));
if (user.role !== 'applicant') return Astro.redirect('/admin');

await ensureFeeWaiverSchema();
function rowsOf(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

let waivers: any[] = [];
try {
  waivers = rowsOf(await db.execute(sql`
    SELECT w.id, w.status, w.situation_note, w.expertise_note, w.drive_url,
      w.created_at, w.reviewed_at, w.reject_reason, w.application_id,
      COALESCE(w.last_message_at, w.created_at) AS last_message_at,
      COALESCE(w.unread_applicant, 0) AS unread,
      i.role_title_snapshot AS role_title
    FROM application_fee_waivers w
    LEFT JOIN application_intents i ON i.id = w.intent_id
    WHERE w.user_id = ${user.id}
    ORDER BY COALESCE(w.last_message_at, w.created_at) DESC
  `));
} catch (_) {}

function fmt(d: any): string {
  try { return new Date(d).toLocaleString('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }); } catch { return ''; }
}
function ago(d: any): string {
  if (!d) return '';
  try {
    const diff = (Date.now() - new Date(d).getTime()) / 1000;
    if (diff < 60) return 'just now';
    if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
    if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
    return Math.floor(diff / 86400) + 'd ago';
  } catch { return ''; }
}
function statusPill(s: string) {
  if (s === 'approved') return { bg: 'rgba(16,185,129,0.12)', fg: '#047857', border: 'rgba(16,185,129,0.32)' };
  if (s === 'rejected') return { bg: 'rgba(239,68,68,0.10)', fg: '#991b1b', border: 'rgba(239,68,68,0.32)' };
  return { bg: 'rgba(250,204,21,0.14)', fg: '#92400e', border: 'rgba(250,204,21,0.35)' };
}
---
<BaseLayout title="Fee waiver requests — EduRankAI" description="Your fee waiver requests, decisions, and thread with the admissions team.">
  <section class="px-[5vw] py-10 md:py-14 max-w-3xl mx-auto">

    <a href="/portal" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">&lt; Portal home</a>

    <div class="mt-4 mb-6">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">Fee waivers</p>
      <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.5rem)] font-semibold text-ink leading-[1.15] mb-3">
        Your waiver requests
      </h1>
      <p class="text-[0.92rem] text-ink-soft leading-relaxed max-w-xl">
        Every waiver you submit lives here. Decisions, reviewer notes, and your direct thread with the admissions team — in one place. We respond within 5 business days.
      </p>
    </div>

    {waivers.length === 0 ? (
      <div class="bg-cream-2/60 border border-ink/10 rounded-2xl p-8 md:p-10 text-center">
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.16em] text-burn font-bold mb-3">No waiver requests yet</p>
        <h2 class="font-display text-[1.4rem] font-semibold text-ink mb-3">If the application fee is a barrier, request a waiver.</h2>
        <p class="text-[0.9rem] text-ink-soft leading-relaxed max-w-md mx-auto mb-5">
          Pick a role first — the waiver form sits on the same page as the payment button, so you can request one for the specific role you want.
        </p>
        <a href="/careers" class="inline-block bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-6 rounded-lg text-[0.9rem] no-underline">Browse open roles</a>
      </div>
    ) : (
      <div class="flex flex-col gap-3">
        {waivers.map((w) => {
          const pill = statusPill(w.status);
          const isApproved = w.status === 'approved';
          const href = '/portal/requests/fee-waiver/' + w.id;
          return (
            <a href={href} class="bg-white border border-ink/10 rounded-2xl p-5 md:p-6 hover:border-burn transition-colors no-underline" style="color:inherit;display:block;">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:wrap;margin-bottom:10px;">
                <div style="min-width:0;flex:1;">
                  <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-burn font-bold mb-1">{w.role_title || 'Fee waiver request'}</p>
                  <p class="font-display text-[1.05rem] font-semibold text-ink leading-tight m-0">Submitted {fmt(w.created_at)}</p>
                </div>
                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px;flex-shrink:0;">
                  <span style={'font-family:JetBrains Mono,monospace;font-size:10px;text-transform:uppercase;letter-spacing:0.14em;font-weight:700;padding:3px 10px;border-radius:100px;background:' + pill.bg + ';color:' + pill.fg + ';border:1px solid ' + pill.border + ';'}>{w.status}</span>
                  {w.unread > 0 && <span style="background:#FF4F00;color:#fff;font-size:10px;font-weight:700;padding:2px 8px;border-radius:100px;">{w.unread} new</span>}
                </div>
              </div>

              {w.status === 'approved' && (
                <p class="text-[0.86rem] text-ink-2 leading-relaxed m-0 mb-1">
                  <strong style="color:#047857;">Approved.</strong> Your application is now in review.
                  {w.application_id && <span> <a href={'/portal/applications/' + w.application_id} class="text-burn font-semibold hover:underline">Open application →</a></span>}
                </p>
              )}
              {w.status === 'rejected' && (
                <p class="text-[0.86rem] text-ink-2 leading-relaxed m-0 mb-1">
                  <strong style="color:#991b1b;">Not granted.</strong> {w.reject_reason || 'See the thread for the reviewer\'s note. You can update your notes and re-submit, or pay the fee.'}
                </p>
              )}
              {w.status === 'pending' && (
                <p class="text-[0.86rem] text-ink-2 leading-relaxed m-0 mb-1">
                  <strong style="color:#92400e;">Under review.</strong> Decisions arrive within 5 business days. You can update the notes below at any time.
                </p>
              )}

              <p class="text-[0.72rem] text-ink-soft m-0 mt-3" style="font-family:'JetBrains Mono',monospace;">
                Last activity {ago(w.last_message_at)} &middot; Open thread →
              </p>
            </a>
          );
        })}
      </div>
    )}

    <div class="bg-cream-2/40 border border-ink/8 rounded-xl p-5 mt-8 text-[0.83rem] text-ink-soft leading-relaxed">
      <p class="font-mono text-[0.62rem] uppercase tracking-[0.14em] text-burn font-bold mb-1.5">How waiver review works</p>
      <p class="m-0">Every request is read by a human. Decisions arrive within five business days inside your portal thread — no email blasts, no spam, no record of the waiver in your file. If the answer is yes, your application moves into review; if no, you can update the notes and re-submit, or pay the fee. The review is identical either way.</p>
      <p class="text-[0.78rem] mt-3 mb-0">Questions? Reply inside any thread above, or email <a href="mailto:hr@edurankai.in" class="text-burn font-semibold hover:underline">hr@edurankai.in</a>.</p>
    </div>

  </section>
</BaseLayout>
