---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

let interviews: any[] = [];
try {
  const r = await db.execute(sql`
    SELECT ir.*, a.role_title_snapshot, a.application_number
    FROM interview_rounds ir
    JOIN applications a ON ir.application_id = a.id
    WHERE a.email = ${user.email} OR ir.candidate_id = ${user.id}
    ORDER BY ir.scheduled_at DESC
    LIMIT 30
  `);
  interviews = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

const upcoming = (interviews as any[]).filter((i: any) => i.scheduled_at && new Date(i.scheduled_at) > new Date() && i.status !== 'cancelled');
const past = (interviews as any[]).filter((i: any) => !(i.scheduled_at && new Date(i.scheduled_at) > new Date()) || i.status === 'cancelled');
const TYPE_COLORS: Record<string,string> = {
  screening:'#60a5fa', technical:'#a78bfa', culture_fit:'#10b981',
  case_study:'#fbbf24', final:'#FF4F00', reference_check:'#8b5cf6', custom:'#6b7280'
};
---
<!doctype html>
<html lang="en" style="background:#f8f6f1;">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>My Interviews - EduRankAI</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    body{background:#f8f6f1;font-family:system-ui,sans-serif;min-height:100vh;padding-bottom:90px;}
    .topbar{background:#0f0f14;padding:0 16px;height:52px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:40;}
    .iv-card{background:#fff;border:1px solid rgba(0,0,0,0.08);border-radius:14px;padding:16px;margin:0 14px 12px;}
    .pill{font-size:10px;font-weight:700;padding:3px 8px;border-radius:100px;text-transform:uppercase;letter-spacing:0.05em;}
    .bottom-nav{position:fixed;bottom:0;left:0;right:0;background:#0f0f14;border-top:1px solid #1a1a1f;display:flex;z-index:40;padding-bottom:env(safe-area-inset-bottom);}
    .nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8px 4px;text-decoration:none;color:#6e6e78;font-size:10px;gap:3px;}
    .nav-btn.active{color:#FF7040;}
  </style>
</head>
<body>
<nav class="topbar">
  <div style="display:flex;align-items:center;gap:10px;">
    <a href="/portal" style="color:#6e6e78;text-decoration:none;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg></a>
    <span style="font-size:15px;font-weight:700;color:#fff;">My Interviews</span>
  </div>
</nav>

<div style="padding-top:14px;">
  {upcoming.length === 0 && past.length === 0 && (
    <div style="text-align:center;padding:48px 24px;color:#6b7280;">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5" style="margin-bottom:14px;"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      <p style="font-size:15px;font-weight:600;color:#111;margin-bottom:6px;">No interviews scheduled</p>
      <p style="font-size:13px;">Once your application advances, interviews will appear here.</p>
    </div>
  )}

  {upcoming.length > 0 && (
    <div>
      <p style="padding:0 18px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6b7280;margin:0 0 8px;">Upcoming ({upcoming.length})</p>
      {(upcoming as any[]).map((i: any) => {
        const tc = (TYPE_COLORS as any)[i.round_type] || '#6b7280';
        const tsIso = new Date(i.scheduled_at).toISOString();
        const minsAway = Math.floor((new Date(i.scheduled_at).getTime() - Date.now()) / 60000);
        const isSoon = minsAway < 30 && minsAway > -90;
        return (
          <div class="iv-card" style={isSoon ? 'border-color:#FF4F00;background:linear-gradient(135deg,#fff5f0,#fff);' : ''}>
            <div style="display:flex;align-items:center;gap:6px;margin-bottom:8px;flex-wrap:wrap;">
              <span class="pill" style={`background:${tc}22;color:${tc};`}>Round {i.round_number} - {i.round_type?.replace('_',' ')}</span>
              {isSoon && <span class="pill" style="background:rgba(239,68,68,0.15);color:#ef4444;animation:pulse 2s infinite;">Starting soon</span>}
            </div>
            <p style="font-size:16px;font-weight:700;color:#111;margin:0 0 4px;">{i.title}</p>
            <p style="font-size:12px;color:#6b7280;margin:0 0 12px;">For: {i.role_title_snapshot}</p>

            <div style="display:flex;flex-direction:column;gap:6px;background:#f8f6f1;border-radius:8px;padding:10px 12px;margin-bottom:12px;">
              <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:#374151;">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#FF4F00" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span data-ts={tsIso}>{i.scheduled_at}</span>
                <span style="color:#9ca3af;">({i.duration_mins}min)</span>
              </div>
              {i.notes && <p style="font-size:11px;color:#6b7280;margin:4px 0 0;line-height:1.5;font-style:italic;">"{i.notes}"</p>}
            </div>

            {i.meeting_url && (i.status === 'scheduled' || i.status === 'rescheduled') && (
              <a href={i.meeting_url} target="_blank" style={`display:flex;align-items:center;justify-content:center;gap:6px;background:${isSoon?'#10b981':'#0f0f14'};color:#fff;text-decoration:none;font-size:13px;font-weight:700;padding:12px;border-radius:8px;`}>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
                {isSoon ? 'Join Now' : 'Join Room'}
              </a>
            )}
          </div>
        );
      })}
    </div>
  )}

  {past.length > 0 && (
    <div style="margin-top:18px;">
      <p style="padding:0 18px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6b7280;margin:0 0 8px;">Past ({past.length})</p>
      {(past as any[]).map((i: any) => {
        const tsIso = i.scheduled_at ? new Date(i.scheduled_at).toISOString() : '';
        return (
          <div class="iv-card" style="opacity:0.85;">
            <div style="display:flex;justify-content:space-between;gap:8px;align-items:flex-start;margin-bottom:4px;">
              <p style="font-size:14px;font-weight:600;color:#111;margin:0;">{i.title}</p>
              <span class="pill" style="background:#f0f0f0;color:#6b7280;flex-shrink:0;">{i.status?.replace('_',' ')}</span>
            </div>
            <p style="font-size:11px;color:#6b7280;margin:0;" data-ts={tsIso}>{i.scheduled_at}</p>
          </div>
        );
      })}
    </div>
  )}
</div>

<nav class="bottom-nav">
  <a href="/portal" class="nav-btn">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
    Home
  </a>
  <a href="/portal/interviews" class="nav-btn active">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    Interviews
  </a>
  <a href="/portal/courses" class="nav-btn">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
    Learn
  </a>
  <a href="/portal/discussion" class="nav-btn">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    Community
  </a>
</nav>

<script is:inline>
document.querySelectorAll('[data-ts]').forEach(function(el) {
  var ts = el.getAttribute('data-ts');
  if (!ts) return;
  var d = new Date(ts);
  el.textContent = d.toLocaleString(undefined, { weekday:'short', day:'numeric', month:'short', hour:'numeric', minute:'2-digit' });
});
</script>
<style>@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.5}}</style>
</body>
</html>
