    </div>
  </div>

  <!-- AR modal -->
  <div class="ar-modal" id="arModal">
    <div class="ar-stage">
      <video id="arVideo" autoplay playsinline muted></video>
      <canvas id="arCanvas"></canvas>
    </div>
    <div class="ar-controls">
      <button class="active" data-fx="soft-glow">Soft Glow</button>
      <button data-fx="threshold">Threshold</button>
      <button data-fx="rgb-shift">RGB Shift</button>
      <button data-fx="edge-find">Edge Find</button>
      <button data-fx="polar-warp">Polar Warp</button>
      <button data-fx="anatomy">Anatomy Overlay</button>
      <button data-fx="math-notation">Math Notation</button>
      <button data-fx="molecule">Molecule Halo</button>
