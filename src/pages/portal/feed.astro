---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=/portal/feed');

function rows(r: any) { return Array.isArray(r) ? r : (r?.rows || []); }

// ---------------- Bootstrap schema ----------------
try {
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS feed_posts (
      id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
      author_user_id UUID NOT NULL,
      kind VARCHAR(20) NOT NULL DEFAULT 'reel',
      title TEXT,
      description TEXT,
      topic_tags JSONB DEFAULT '[]'::jsonb,
      media_url TEXT,
      thumbnail_url TEXT,
      duration_seconds INT,
      visibility VARCHAR(20) DEFAULT 'public',
      course_id UUID,
      ar_filter_id UUID,
      engagement_score INT DEFAULT 0,
      view_count INT DEFAULT 0,
      like_count INT DEFAULT 0,
      comment_count INT DEFAULT 0,
      share_count INT DEFAULT 0,
      is_pinned BOOLEAN DEFAULT false,
      created_at TIMESTAMPTZ DEFAULT NOW()
    )
  `);
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS feed_likes (
      post_id UUID NOT NULL REFERENCES feed_posts(id) ON DELETE CASCADE,
      user_id UUID NOT NULL,
      created_at TIMESTAMPTZ DEFAULT NOW(),
      PRIMARY KEY (post_id, user_id)
    )
  `);
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS feed_comments (
      id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
      post_id UUID REFERENCES feed_posts(id) ON DELETE CASCADE,
      user_id UUID,
      body TEXT,
      reply_to UUID,
      created_at TIMESTAMPTZ DEFAULT NOW()
    )
  `);
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS feed_view_events (
      user_id UUID,
      post_id UUID,
      watched_pct INT,
      device VARCHAR(20),
      created_at TIMESTAMPTZ DEFAULT NOW()
    )
  `);
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS ar_filters (
      id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
      creator_user_id UUID,
      slug VARCHAR(120) UNIQUE,
      name VARCHAR(200),
      kind VARCHAR(20),
      preview_url TEXT,
      code TEXT,
      use_count INT DEFAULT 0,
      created_at TIMESTAMPTZ DEFAULT NOW()
    )
  `);
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS feed_user_interests (
      user_id UUID PRIMARY KEY,
      interests JSONB DEFAULT '[]'::jsonb,
      follows JSONB DEFAULT '[]'::jsonb,
      daily_cap_minutes INT DEFAULT 90,
      updated_at TIMESTAMPTZ DEFAULT NOW()
    )
  `);
} catch (e) {}

// ---------------- Seed AR filter catalogue if empty ----------------
try {
  const f = rows(await db.execute(sql`SELECT COUNT(*)::int AS n FROM ar_filters`));
  if ((f[0]?.n ?? 0) === 0) {
    const presets = [
      ['soft-glow', 'Soft Glow', 'face', 'Gentle Gaussian halo around facial features'],
      ['threshold', 'Ink Stamp', 'face', 'Binary high-contrast etching of the visible scene'],
      ['rgb-shift', 'Chroma Drift', 'face', 'Channel separation effect with R/G/B offset'],
      ['anatomy', 'Anatomy Overlay', 'educational-overlay', 'Skull and facial muscle landmarks projected on the camera'],
      ['math-notation', 'Math Notation', 'educational-overlay', 'Live equation grid and coordinate axes'],
      ['molecule', 'Molecule Halo', 'educational-overlay', 'Ball-and-stick caffeine molecule orbiting the face'],
      ['hand-trail', 'Hand Trail', 'hand', 'Particle trail following motion regions'],
      ['world-grid', 'World Grid', 'world', 'Perspective grid anchored to the scene floor'],
      ['polar-warp', 'Polar Warp', 'face', 'Radial coordinate warp around the centre'],
      ['edge-find', 'Edge Find', 'face', 'Sobel edge detection in cyan'],
    ];
    for (const p of presets) {
      await db.execute(sql`
        INSERT INTO ar_filters (slug, name, kind, code, creator_user_id)
        VALUES (${p[0]}, ${p[1]}, ${p[2]}, ${p[3]}, ${user.id})
        ON CONFLICT (slug) DO NOTHING
      `);
    }
  }
} catch (e) {}

// ---------------- Seed posts if empty ----------------
try {
  const p = rows(await db.execute(sql`SELECT COUNT(*)::int AS n FROM feed_posts`));
  if ((p[0]?.n ?? 0) === 0) {
    const reels = [
      ['Why entropy never decreases — 30 sec', 'reel', ['thermodynamics','physics','jee'], 32, 18400, 2100, 140],
      ['Solve any integration by parts in 3 steps', 'reel', ['calculus','math','jee'], 41, 31200, 4800, 312],
      ['What is a transformer attention head?', 'reel', ['ai','transformers','ml'], 58, 12100, 980, 89],
      ['Spotting a fake proof: the missing axiom', 'reel', ['logic','math','foundations'], 47, 8700, 540, 41],
      ['Why DNA is right-handed and what would happen if it were not', 'reel', ['biology','biochem'], 39, 21300, 2950, 180],
      ['Reduce a matrix to row-echelon form, fast', 'reel', ['linear-algebra','math'], 52, 9400, 720, 55],
      ['Build a NAND gate from two transistors', 'reel', ['electronics','digital'], 44, 14800, 1180, 92],
      ['What pH actually means (it is not what you think)', 'reel', ['chemistry','acid-base'], 36, 19200, 1620, 121],
      ['A 60-second proof of the Pythagorean theorem', 'reel', ['geometry','math'], 60, 38700, 5210, 410],
      ['Why orbitals are not little planets', 'reel', ['quantum','chemistry'], 51, 22100, 2800, 195],
      ['Difference between weak and strong induction', 'reel', ['discrete','proof'], 43, 6700, 410, 28],
      ['The fastest way to balance a redox equation', 'reel', ['chemistry','redox'], 38, 11400, 870, 64],
    ];
    const clips = [
      ['Full lecture: Tensor calculus for general relativity', 'clip', ['relativity','tensor','physics'], 3420, 142000, 11200, 980],
      ['One-hour deep dive: discrete Fourier transform from scratch', 'clip', ['fourier','signal','math'], 3680, 89000, 7100, 540],
      ['Walkthrough: building a simple operating-system kernel', 'clip', ['os','systems'], 4900, 67000, 5800, 410],
      ['Organic chemistry exam-prep marathon', 'clip', ['organic','chemistry','exam'], 5400, 102000, 8200, 670],
      ['Number theory: from Fermat to elliptic curves', 'clip', ['number-theory','math'], 4200, 41000, 3100, 220],
      ['Microeconomics: indifference curves and utility', 'clip', ['economics','micro'], 3120, 28000, 1900, 120],
      ['Human physiology: the cardiac cycle in detail', 'clip', ['biology','physiology'], 2880, 56000, 4200, 280],
      ['Recursion and the call stack, visualised', 'clip', ['programming','cs'], 1980, 73000, 6100, 380],
    ];
    const xr = [
      ['Try the Anatomy Overlay AR filter', 'xr-experience', ['biology','ar'], 0, 4200, 320, 42],
      ['Floating molecule halo: caffeine in 3D', 'xr-experience', ['chemistry','ar'], 0, 3100, 240, 18],
      ['Math notation overlay on your study desk', 'xr-experience', ['math','ar'], 0, 5600, 410, 51],
    ];
    const all = [...reels, ...clips, ...xr];
    for (const r of all) {
      await db.execute(sql`
        INSERT INTO feed_posts (author_user_id, kind, title, topic_tags, duration_seconds, view_count, like_count, comment_count, engagement_score)
        VALUES (
          ${user.id}, ${r[1]}, ${r[0]},
          ${JSON.stringify(r[2])}::jsonb,
          ${r[3]}, ${r[4]}, ${r[5]}, ${r[6]},
          ${Math.floor((r[4] as number)/10 + (r[5] as number)/3)}
        )
      `);
    }
  }
} catch (e) {}

// ---------------- Load user interests (or default) ----------------
let interests: string[] = [];
let follows: string[] = [];
let dailyCap = 90;
try {
  const r = rows(await db.execute(sql`
    SELECT interests, follows, daily_cap_minutes FROM feed_user_interests WHERE user_id = ${user.id}
  `));
  if (r[0]) {
    interests = Array.isArray(r[0].interests) ? r[0].interests : (typeof r[0].interests === 'string' ? JSON.parse(r[0].interests) : []);
    follows = Array.isArray(r[0].follows) ? r[0].follows : (typeof r[0].follows === 'string' ? JSON.parse(r[0].follows) : []);
    dailyCap = r[0].daily_cap_minutes ?? 90;
  } else {
    interests = ['math','physics','ai','chemistry'];
    await db.execute(sql`
      INSERT INTO feed_user_interests (user_id, interests, follows)
      VALUES (${user.id}, ${JSON.stringify(interests)}::jsonb, '[]'::jsonb)
      ON CONFLICT (user_id) DO NOTHING
    `);
  }
} catch (e) {}

// ---------------- Handle POST ----------------
let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();
    const action = String(form.get('action') || '');
    if (action === 'create_post') {
      const kind = String(form.get('kind') || 'reel');
      const title = String(form.get('title') || '').slice(0, 280);
      const description = String(form.get('description') || '').slice(0, 2000);
      const tagsRaw = String(form.get('tags') || '');
      const visibility = String(form.get('visibility') || 'public');
      const tags = tagsRaw.split(',').map(t => t.trim().toLowerCase()).filter(Boolean).slice(0, 12);
      if (!title) { errMsg = 'Title is required'; }
      else {
        await db.execute(sql`
          INSERT INTO feed_posts (author_user_id, kind, title, description, topic_tags, visibility)
          VALUES (${user.id}, ${kind}, ${title}, ${description}, ${JSON.stringify(tags)}::jsonb, ${visibility})
        `);
        okMsg = 'Post published';
      }
    } else if (action === 'save_interests') {
      const raw = String(form.get('interests') || '');
      const list = raw.split(',').map(s => s.trim().toLowerCase()).filter(Boolean).slice(0, 30);
      await db.execute(sql`
        INSERT INTO feed_user_interests (user_id, interests, updated_at)
        VALUES (${user.id}, ${JSON.stringify(list)}::jsonb, NOW())
        ON CONFLICT (user_id) DO UPDATE SET interests = EXCLUDED.interests, updated_at = NOW()
      `);
      interests = list;
      okMsg = 'Interests saved';
    } else if (action === 'like') {
      const postId = String(form.get('post_id') || '');
      if (postId) {
        await db.execute(sql`
          INSERT INTO feed_likes (post_id, user_id) VALUES (${postId}::uuid, ${user.id})
          ON CONFLICT DO NOTHING
        `);
        await db.execute(sql`UPDATE feed_posts SET like_count = like_count + 1 WHERE id = ${postId}::uuid`);
      }
    }
  } catch (e: any) { errMsg = e?.message || 'Error'; }
}

// ---------------- Fetch posts ----------------
const allPosts = rows(await db.execute(sql`
  SELECT id, kind, title, description, topic_tags, duration_seconds, view_count, like_count, comment_count, share_count, engagement_score, created_at
  FROM feed_posts ORDER BY created_at DESC LIMIT 200
`));

// ---------------- Seen post ids today ----------------
const seenRows = rows(await db.execute(sql`
  SELECT DISTINCT post_id FROM feed_view_events WHERE user_id = ${user.id} AND created_at > NOW() - INTERVAL '7 days'
`));
const seenSet = new Set(seenRows.map((r: any) => r.post_id));

// ---------------- Watched-time today ----------------
const watchRow = rows(await db.execute(sql`
  SELECT COALESCE(SUM(watched_pct), 0)::int AS pct_sum
  FROM feed_view_events WHERE user_id = ${user.id} AND created_at >= CURRENT_DATE
`));
const pctSumToday = watchRow[0]?.pct_sum || 0;
// Rough: assume avg post is 45s, watched_pct of 100 = 45s watched. So minutes ~ pct_sum/100 * 45 / 60
const minutesToday = Math.floor((pctSumToday / 100) * 45 / 60);
const watchPct = Math.min(100, Math.floor((minutesToday / dailyCap) * 100));
const capReached = minutesToday >= dailyCap;

// ---------------- Hand-rolled recommendation scoring ----------------
function jaccard(a: string[], b: string[]) {
  if (!a.length || !b.length) return 0;
  const sa = new Set(a), sb = new Set(b);
  let inter = 0;
  sa.forEach(x => { if (sb.has(x)) inter++; });
  const uni = new Set([...a, ...b]).size;
  return uni === 0 ? 0 : inter / uni;
}
function scorePost(p: any) {
  const tags = Array.isArray(p.topic_tags) ? p.topic_tags : (typeof p.topic_tags === 'string' ? JSON.parse(p.topic_tags || '[]') : []);
  const created = new Date(p.created_at).getTime();
  const ageDays = (Date.now() - created) / (1000 * 60 * 60 * 24);
  const recency = ageDays < 7 ? 1 : 0.5;
  const tm = jaccard(tags, interests);
  const authorFollowed = follows.includes(p.author_user_id) ? 0.3 : 0;
  const seen = seenSet.has(p.id) ? 1.5 : 0;
  const score =
    Math.log((p.view_count || 0) + 1) * 0.4 +
    Math.log((p.like_count || 0) + 1) * 0.3 +
    recency +
    tm * 0.5 +
    authorFollowed -
    seen;
  return { score: Math.round(score * 100) / 100, tags, recency, tm, authorFollowed, seen };
}
const scored = allPosts.map((p: any) => ({ ...p, ...scorePost(p) }));
scored.sort((a: any, b: any) => b.score - a.score);

const reels = scored.filter((p: any) => p.kind === 'reel').slice(0, 20);
const clips = scored.filter((p: any) => p.kind === 'clip').slice(0, 20);
const xrPosts = scored.filter((p: any) => p.kind === 'xr-experience').slice(0, 20);

// ---------------- AR filters ----------------
const filters = rows(await db.execute(sql`
  SELECT id, slug, name, kind, code, use_count FROM ar_filters ORDER BY use_count DESC, name ASC LIMIT 24
`));

const safeReels = JSON.stringify(reels);
const safeClips = JSON.stringify(clips);
const safeXr = JSON.stringify(xrPosts);
const safeFilters = JSON.stringify(filters);
const safeInterests = JSON.stringify(interests);
---
<BaseLayout title="Feed - EduRankAI" description="Student media feed with reels, clips and AR experiences">
<style>
  body { background: #0a0a0c !important; color: #e8e8ee !important; }
  body.era-has-fab { padding-bottom: 0 !important; }
  .feed-root { min-height: 100vh; background: #0a0a0c; color: #e8e8ee; font-family: 'Cormorant Garamond', Georgia, serif; }
  .feed-top {
    position: sticky; top: 0; z-index: 30; background: rgba(10,10,12,0.92); backdrop-filter: blur(14px);
    border-bottom: 1px solid #2a2a35; padding: 14px 22px; display: flex; align-items: center; gap: 18px;
  }
  .feed-top h1 { margin: 0; font-size: 26px; font-weight: 500; letter-spacing: -0.01em; }
  .feed-top h1 span { color: #67e8f9; font-style: italic; }
  .tabs { display: flex; gap: 6px; margin-left: auto; }
  .tab {
    background: transparent; border: 1px solid #2a2a35; color: #c8c8d2;
    padding: 8px 16px; border-radius: 999px; cursor: pointer; font-family: inherit;
    font-size: 14px; letter-spacing: 0.02em; transition: all 0.15s;
  }
  .tab:hover { border-color: #67e8f9; color: #67e8f9; }
  .tab.active { background: #67e8f9; color: #0a0a0c; border-color: #67e8f9; font-weight: 600; }
  .wellbeing {
    margin: 12px 22px; padding: 12px 16px; background: #11131a;
    border: 1px solid #2a2a35; border-left: 3px solid #a78bfa; border-radius: 8px;
    font-size: 13px; color: #c8c8d2; display: flex; align-items: center; gap: 14px;
  }
  .wellbeing svg { flex-shrink: 0; color: #a78bfa; }
  .wb-meter { flex: 1; height: 6px; background: #1a1a22; border-radius: 4px; overflow: hidden; min-width: 140px; }
  .wb-meter > div { height: 100%; background: linear-gradient(90deg, #67e8f9, #a78bfa); transition: width 0.4s; }
  .wb-text { font-family: 'Geist Mono', monospace; font-size: 11px; color: #c8c8d2; white-space: nowrap; }

  /* TAB PANELS */
  .panel { display: none; }
  .panel.active { display: block; }

  /* ---------- REELS PANEL (vertical snap scroll) ---------- */
  .reels-panel {
    height: calc(100vh - 100px); overflow-y: scroll; scroll-snap-type: y mandatory;
    scrollbar-width: none; position: relative;
  }
  .reels-panel::-webkit-scrollbar { display: none; }
  .reel {
    height: calc(100vh - 100px); scroll-snap-align: start;
    display: flex; justify-content: center; align-items: center; position: relative;
  }
  .reel-card {
    position: relative; width: 380px; height: calc(100vh - 140px); max-height: 760px;
    background: #11131a; border-radius: 18px; overflow: hidden;
    border: 1px solid #2a2a35; box-shadow: 0 12px 60px rgba(0,0,0,0.6);
  }
  .reel-thumb { position: absolute; inset: 0; }
  .reel-thumb canvas { width: 100%; height: 100%; display: block; }
  .reel-overlay {
    position: absolute; inset: 0; background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,0.85) 100%);
    pointer-events: none;
  }
  .reel-meta {
    position: absolute; left: 16px; right: 70px; bottom: 18px; z-index: 2;
  }
  .reel-meta .rtitle { font-size: 19px; line-height: 1.25; font-weight: 500; margin-bottom: 6px; }
  .reel-meta .rauth { font-size: 13px; color: #c8c8d2; font-family: 'Geist Mono', monospace; margin-bottom: 6px; }
  .reel-meta .rtags { display: flex; flex-wrap: wrap; gap: 5px; }
  .reel-meta .rtags span {
    background: rgba(167,139,250,0.16); color: #c4b5fd; padding: 3px 8px; border-radius: 6px;
    font-size: 11px; font-family: 'Geist Mono', monospace;
  }
  .reel-side {
    position: absolute; right: 12px; bottom: 24px; z-index: 3; display: flex; flex-direction: column; gap: 14px;
  }
  .rs-btn {
    background: rgba(20,20,28,0.6); border: 1px solid rgba(255,255,255,0.08); color: #e8e8ee;
    width: 46px; height: 46px; border-radius: 50%; display: flex; flex-direction: column;
    align-items: center; justify-content: center; cursor: pointer;
    transition: all 0.15s; backdrop-filter: blur(4px);
  }
  .rs-btn:hover { background: rgba(103,232,249,0.18); border-color: #67e8f9; transform: scale(1.08); }
  .rs-btn.liked { color: #fb7185; border-color: #fb7185; }
  .rs-btn svg { width: 22px; height: 22px; }
  .rs-count { font-size: 10px; font-family: 'Geist Mono', monospace; color: #c8c8d2; margin-top: 2px; text-align: center; }
  .reel-top-actions {
    position: absolute; top: 14px; right: 14px; z-index: 3; display: flex; gap: 8px;
  }
  .reel-top-actions button {
    background: rgba(20,20,28,0.5); border: 1px solid rgba(255,255,255,0.1); color: #e8e8ee;
    width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
    cursor: pointer; backdrop-filter: blur(4px);
  }
  .why-tip {
    position: absolute; top: 60px; right: 14px; z-index: 4;
    background: #11131a; border: 1px solid #2a2a35; border-radius: 10px;
    padding: 10px 12px; font-size: 11px; color: #c8c8d2; max-width: 230px;
    font-family: 'Geist Mono', monospace; display: none;
  }
  .why-tip.show { display: block; }
  .why-tip h4 { margin: 0 0 6px 0; color: #67e8f9; font-size: 11px; font-family: inherit; font-weight: 600; }
  .why-tip .sig { display: flex; justify-content: space-between; margin: 3px 0; }
  .why-tip .sig span:last-child { color: #67e8f9; }

  /* ---------- CLIPS PANEL ---------- */
  .clips-panel { padding: 24px; }
  .filter-bar { display: flex; gap: 10px; margin-bottom: 22px; flex-wrap: wrap; align-items: center; }
  .filter-bar select, .filter-bar input {
    background: #11131a; border: 1px solid #2a2a35; color: #e8e8ee; padding: 8px 12px;
    border-radius: 8px; font-family: inherit; font-size: 14px;
  }
  .filter-bar input:focus, .filter-bar select:focus { outline: none; border-color: #67e8f9; }
  .clip-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 22px;
  }
  .clip-card { background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; overflow: hidden; cursor: pointer; transition: all 0.15s; }
  .clip-card:hover { transform: translateY(-3px); border-color: #67e8f9; }
  .clip-thumb { width: 100%; aspect-ratio: 16/9; position: relative; background: #06080a; }
  .clip-thumb canvas { width: 100%; height: 100%; display: block; }
  .clip-dur {
    position: absolute; right: 8px; bottom: 8px; background: rgba(0,0,0,0.78);
    color: #fff; padding: 3px 7px; border-radius: 4px; font-family: 'Geist Mono', monospace; font-size: 11px;
  }
  .clip-body { padding: 14px; }
  .clip-body h3 { margin: 0 0 7px 0; font-size: 17px; line-height: 1.3; font-weight: 500; }
  .clip-body .meta {
    font-size: 12px; color: #8a8a99; font-family: 'Geist Mono', monospace;
  }
  .clip-body .ctags { margin-top: 8px; display: flex; flex-wrap: wrap; gap: 5px; }
  .clip-body .ctags span {
    background: rgba(103,232,249,0.12); color: #67e8f9; padding: 2px 7px; border-radius: 6px;
    font-size: 10px; font-family: 'Geist Mono', monospace;
  }

  /* ---------- AR PANEL ---------- */
  .xr-panel { padding: 24px; }
  .xr-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 18px; }
  .xr-card {
    background: #11131a; border: 1px solid #2a2a35; border-radius: 12px; padding: 18px;
    display: flex; flex-direction: column; gap: 10px;
  }
  .xr-preview {
    width: 100%; aspect-ratio: 4/5; border-radius: 8px; background: #06080a; overflow: hidden;
    border: 1px solid #2a2a35;
  }
  .xr-preview canvas { width: 100%; height: 100%; display: block; }
  .xr-card h3 { margin: 0; font-size: 18px; font-weight: 500; }
  .xr-card .kind {
    font-family: 'Geist Mono', monospace; font-size: 10px; color: #a78bfa;
    text-transform: uppercase; letter-spacing: 0.06em;
  }
  .xr-card .desc { font-size: 13px; color: #c8c8d2; line-height: 1.45; font-family: inherit; min-height: 36px; }
  .xr-card button.try {
    background: #67e8f9; color: #0a0a0c; border: 0; padding: 9px 14px; border-radius: 8px;
    font-family: inherit; font-weight: 600; cursor: pointer; font-size: 14px;
  }
  .xr-card button.try:hover { background: #a78bfa; }

  /* AR live modal */
  .ar-modal {
    position: fixed; inset: 0; background: rgba(0,0,0,0.92); z-index: 100; display: none;
    align-items: center; justify-content: center; flex-direction: column; padding: 20px;
  }
  .ar-modal.open { display: flex; }
  .ar-stage {
    position: relative; max-width: 640px; width: 100%; aspect-ratio: 3/4;
    background: #0a0a0c; border-radius: 14px; overflow: hidden; border: 1px solid #2a2a35;
  }
  .ar-stage video, .ar-stage canvas {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
  }
  .ar-stage video { visibility: hidden; }
  .ar-controls {
    display: flex; gap: 8px; margin-top: 14px; flex-wrap: wrap; justify-content: center;
  }
  .ar-controls button {
    background: #11131a; color: #e8e8ee; border: 1px solid #2a2a35; padding: 8px 14px;
    border-radius: 8px; cursor: pointer; font-family: 'Cormorant Garamond', serif; font-size: 14px;
  }
  .ar-controls button.active { background: #67e8f9; color: #0a0a0c; border-color: #67e8f9; }
