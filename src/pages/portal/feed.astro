<div class="feed-root">
  <div class="feed-top">
    <h1><span>edu</span>Feed</h1>
    <div class="tabs">
      <button class="tab active" data-tab="reels">Reels</button>
      <button class="tab" data-tab="clips">Clips</button>
      <button class="tab" data-tab="xr">AR / XR</button>
      <button class="tab" data-tab="interests">Interests</button>
    </div>
  </div>

  <div class="wellbeing">
