      </div>
      <div class="clip-grid" id="clipGrid">
        {clips.length === 0 && <div class="empty">No long-form clips yet.</div>}
        {clips.map((c: any, i: number) => (
          <div class="clip-card" data-tags={(Array.isArray(c.tags) ? c.tags : []).join(',')} data-dur={c.duration_seconds}>
