  <!-- XR PANEL -->
  <div class="panel" id="panel-xr">
    <div class="xr-panel">
      <div class="xr-grid" id="xrGrid">
        {filters.map((f: any, i: number) => (
          <div class="xr-card" data-filter-slug={f.slug}>
