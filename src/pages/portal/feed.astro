    </div>
  </div>

  <!-- INTERESTS PANEL -->
  <div class="panel" id="panel-interests">
    <div style="padding:24px; max-width:680px">
      <h2 style="font-weight:500; font-size:28px; margin:0 0 10px 0">Your interests</h2>
      <p style="color:#c8c8d2; margin:0 0 18px 0">Comma-separated tags. We use these to drive the recommendation algorithm.</p>
      <form method="POST">
        <input type="hidden" name="action" value="save_interests" />
        <textarea name="interests" rows="4" style="width:100%; background:#11131a; border:1px solid #2a2a35; color:#e8e8ee; padding:12px; border-radius:8px; font-family:'Geist Mono', monospace; font-size:13px">{interests.join(', ')}</textarea>
        <button type="submit" style="margin-top:14px; background:#67e8f9; color:#0a0a0c; border:0; padding:10px 18px; border-radius:8px; font-family:inherit; font-weight:600; cursor:pointer; font-size:15px">Save interests</button>
      </form>

      <h3 style="margin:32px 0 10px 0; font-weight:500">Algorithm transparency</h3>
      <pre style="background:#11131a; border:1px solid #2a2a35; padding:14px; border-radius:8px; font-size:11px; line-height:1.6; color:#c8c8d2; overflow-x:auto">score = log(views+1) * 0.4
      + log(likes+1) * 0.3
      + (recency_days &lt; 7 ? 1 : 0.5)
      + jaccard(post_tags, your_interests) * 0.5
      + (author_followed ? 0.3 : 0)
      - (already_seen ? 1.5 : 0)</pre>
      <p style="color:#8a8a99; font-size:13px; line-height:1.5; margin-top:14px">No outrage signals, no purely-attention-grabbing weighting, and a hard 90-minute daily cap. You can see the exact score on every reel by tapping the question-mark icon.</p>
    </div>
  </div>

  <button class="feed-fab" id="fab" title="New post">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
  </button>

  <!-- Create modal -->
  <div class="create-modal" id="createModal">
    <div class="create-card">
      <h2>Publish to the feed</h2>
      <form method="POST">
        <input type="hidden" name="action" value="create_post" />
        <label>Kind</label>
        <select name="kind">
          <option value="reel">Reel (short-form vertical)</option>
          <option value="clip">Clip (long-form horizontal)</option>
          <option value="photo">Photo</option>
          <option value="xr-experience">AR / XR experience</option>
