  {capReached && (
    <div class="timeup open">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      <h2>Time's up for today</h2>
      <p>You've reached your daily watch-time cap of {dailyCap} minutes. We do this on purpose. Take a walk, do a problem set, or come back tomorrow.</p>
      <a href="/portal" style="color:#67e8f9; text-decoration:none; border:1px solid #67e8f9; padding:9px 16px; border-radius:8px; font-family:'Geist Mono', monospace; font-size:13px">Back to portal</a>
    </div>
  )}
</div>

<script is:inline define:vars={{ safeReels, safeClips, safeXr, safeFilters, safeInterests }}>
(function(){
  const reels = JSON.parse(safeReels);
  const clips = JSON.parse(safeClips);
  const xrPosts = JSON.parse(safeXr);
  const filters = JSON.parse(safeFilters);

  // -------- TAB SWITCHING --------
  const tabs = document.querySelectorAll('.tab');
  const panels = document.querySelectorAll('.panel');
  tabs.forEach(t => t.addEventListener('click', () => {
    tabs.forEach(x => x.classList.remove('active'));
    panels.forEach(x => x.classList.remove('active'));
    t.classList.add('active');
    const id = 'panel-' + t.dataset.tab;
    const p = document.getElementById(id);
    if (p) p.classList.add('active');
  }));

  // -------- ANIMATED CANVAS THUMBNAILS --------
  function drawReelThumb(canvas, seed) {
    const w = canvas.width = canvas.clientWidth || 380;
    const h = canvas.height = canvas.clientHeight || 600;
    const ctx = canvas.getContext('2d');
    // hash seed
    const hue1 = (seed * 47) % 360;
    const hue2 = (seed * 89 + 120) % 360;
    const g = ctx.createLinearGradient(0, 0, w, h);
    g.addColorStop(0, `hsl(${hue1}, 70%, 22%)`);
    g.addColorStop(1, `hsl(${hue2}, 65%, 14%)`);
    ctx.fillStyle = g; ctx.fillRect(0, 0, w, h);
    // floating shapes
    const t = Date.now() / 1000;
    for (let i = 0; i < 14; i++) {
      const x = w/2 + Math.cos(t * 0.4 + i + seed) * (w * 0.35);
      const y = h/2 + Math.sin(t * 0.5 + i * 1.3 + seed) * (h * 0.32);
      const r = 28 + Math.sin(t + i) * 14;
      const ng = ctx.createRadialGradient(x, y, 0, x, y, r);
      ng.addColorStop(0, `hsla(${(hue1 + i * 22) % 360}, 80%, 65%, 0.55)`);
      ng.addColorStop(1, `hsla(${(hue1 + i * 22) % 360}, 80%, 60%, 0)`);
      ctx.fillStyle = ng;
      ctx.beginPath(); ctx.arc(x, y, r, 0, Math.PI * 2); ctx.fill();
    }
    // grid lines
    ctx.strokeStyle = 'rgba(255,255,255,0.04)';
    ctx.lineWidth = 1;
    for (let i = 0; i < 12; i++) {
      ctx.beginPath(); ctx.moveTo(0, (h/12)*i); ctx.lineTo(w, (h/12)*i); ctx.stroke();
    }
    // central icon shape
    ctx.fillStyle = 'rgba(255,255,255,0.06)';
    ctx.beginPath();
    ctx.arc(w/2, h*0.45, w * 0.18, 0, Math.PI * 2);
    ctx.fill();
  }

  function drawClipThumb(canvas, seed) {
    const w = canvas.width = canvas.clientWidth || 360;
    const h = canvas.height = canvas.clientHeight || 200;
    const ctx = canvas.getContext('2d');
    const hue1 = (seed * 37) % 360;
    const hue2 = (seed * 71 + 60) % 360;
    const g = ctx.createLinearGradient(0, 0, w, h);
    g.addColorStop(0, `hsl(${hue1}, 60%, 25%)`);
    g.addColorStop(1, `hsl(${hue2}, 55%, 14%)`);
    ctx.fillStyle = g; ctx.fillRect(0, 0, w, h);
    // wave-form lines
    ctx.strokeStyle = `hsla(${hue1}, 90%, 75%, 0.6)`;
    ctx.lineWidth = 1.5;
    for (let k = 0; k < 5; k++) {
      ctx.beginPath();
      for (let x = 0; x < w; x++) {
        const y = h/2 + Math.sin(x * 0.03 + k + seed) * (15 + k * 8);
        if (x === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
      }
      ctx.stroke();
    }
    // central play
    ctx.fillStyle = 'rgba(255,255,255,0.18)';
    ctx.beginPath();
    ctx.arc(w/2, h/2, 24, 0, Math.PI * 2);
    ctx.fill();
    ctx.fillStyle = '#fff';
    ctx.beginPath();
    ctx.moveTo(w/2 - 7, h/2 - 9);
    ctx.lineTo(w/2 + 11, h/2);
    ctx.lineTo(w/2 - 7, h/2 + 9);
    ctx.closePath(); ctx.fill();
  }

  function drawXrPreview(canvas, slug, idx) {
    const w = canvas.width = canvas.clientWidth || 280;
    const h = canvas.height = canvas.clientHeight || 350;
    const ctx = canvas.getContext('2d');
    const hue = (idx * 47) % 360;
    const g = ctx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w);
    g.addColorStop(0, `hsl(${hue}, 60%, 30%)`);
    g.addColorStop(1, `hsl(${(hue + 180) % 360}, 40%, 10%)`);
    ctx.fillStyle = g; ctx.fillRect(0, 0, w, h);
    // face silhouette
    ctx.fillStyle = 'rgba(255,255,255,0.06)';
    ctx.beginPath(); ctx.ellipse(w/2, h*0.5, w*0.28, h*0.32, 0, 0, Math.PI * 2); ctx.fill();
    // overlay specific
    if (slug === 'soft-glow') {
      const g2 = ctx.createRadialGradient(w/2, h*0.5, 0, w/2, h*0.5, w*0.4);
      g2.addColorStop(0, 'rgba(255,255,255,0.5)');
      g2.addColorStop(1, 'rgba(255,255,255,0)');
      ctx.fillStyle = g2; ctx.fillRect(0,0,w,h);
    } else if (slug === 'threshold') {
      ctx.fillStyle = '#fff';
      for (let i = 0; i < 1200; i++) {
        const x = Math.random() * w, y = Math.random() * h;
        const v = ((x-w/2)*(x-w/2) + (y-h/2)*(y-h/2)) < w*w*0.08 ? 1 : 0;
        if (v) ctx.fillRect(x, y, 2, 2);
      }
    } else if (slug === 'rgb-shift') {
      ctx.fillStyle = 'rgba(255,0,80,0.4)';
      ctx.beginPath(); ctx.ellipse(w/2 - 6, h*0.5, w*0.28, h*0.32, 0, 0, Math.PI * 2); ctx.fill();
      ctx.fillStyle = 'rgba(0,255,200,0.4)';
      ctx.beginPath(); ctx.ellipse(w/2 + 6, h*0.5, w*0.28, h*0.32, 0, 0, Math.PI * 2); ctx.fill();
    } else if (slug === 'anatomy') {
      ctx.strokeStyle = '#67e8f9'; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.ellipse(w/2, h*0.45, w*0.22, h*0.27, 0, 0, Math.PI * 2); ctx.stroke();
      // markers
      ctx.fillStyle = '#a78bfa';
      [[w*0.43, h*0.4], [w*0.57, h*0.4], [w/2, h*0.5], [w*0.45, h*0.6], [w*0.55, h*0.6]].forEach(p => {
        ctx.beginPath(); ctx.arc(p[0], p[1], 3, 0, Math.PI*2); ctx.fill();
      });
      ctx.font = '10px monospace'; ctx.fillStyle = '#67e8f9';
      ctx.fillText('orbital', w*0.38, h*0.35);
      ctx.fillText('zygomatic', w*0.52, h*0.66);
    } else if (slug === 'math-notation') {
      ctx.font = '14px monospace'; ctx.fillStyle = '#67e8f9';
      const eqs = ['∫f(x)dx', 'e^(iπ)+1=0', '∇²φ=ρ', 'Σ1/n²=π²/6', 'a²+b²=c²'];
      eqs.forEach((e, i) => ctx.fillText(e, 20, 30 + i * 60));
    } else if (slug === 'molecule') {
      ctx.strokeStyle = '#a78bfa'; ctx.lineWidth = 1.2;
      const cx = w/2, cy = h*0.5;
      const atoms = [[cx,cy],[cx+30,cy-20],[cx+30,cy+20],[cx-30,cy-20],[cx-30,cy+20],[cx,cy-40],[cx,cy+40]];
      atoms.forEach((a, i) => {
        if (i > 0) {
          ctx.beginPath(); ctx.moveTo(cx, cy); ctx.lineTo(a[0], a[1]); ctx.stroke();
        }
        ctx.fillStyle = i === 0 ? '#67e8f9' : '#a78bfa';
        ctx.beginPath(); ctx.arc(a[0], a[1], 6, 0, Math.PI*2); ctx.fill();
      });
    } else if (slug === 'hand-trail') {
      for (let i = 0; i < 30; i++) {
        ctx.fillStyle = `hsla(${(i*12) % 360}, 80%, 60%, ${1 - i/30})`;
        ctx.beginPath(); ctx.arc(w*0.3 + i*4, h*0.5 - Math.sin(i*0.3)*30, 6, 0, Math.PI*2); ctx.fill();
      }
    } else if (slug === 'world-grid') {
      ctx.strokeStyle = 'rgba(103,232,249,0.5)'; ctx.lineWidth = 1;
      // perspective grid
      for (let i = 0; i < 10; i++) {
        ctx.beginPath();
        ctx.moveTo(0, h*0.6 + i*15);
        ctx.lineTo(w, h*0.6 + i*15);
        ctx.stroke();
      }
      for (let i = -10; i < 10; i++) {
        ctx.beginPath();
        ctx.moveTo(w/2, h*0.6);
        ctx.lineTo(w/2 + i * 30, h);
        ctx.stroke();
      }
    } else if (slug === 'polar-warp') {
      for (let r = 10; r < w/2; r += 14) {
        ctx.strokeStyle = `hsla(${r * 3}, 80%, 60%, 0.5)`;
        ctx.beginPath(); ctx.arc(w/2, h/2, r, 0, Math.PI*2); ctx.stroke();
      }
    } else if (slug === 'edge-find') {
      ctx.strokeStyle = '#67e8f9'; ctx.lineWidth = 1.5;
      ctx.beginPath(); ctx.ellipse(w/2, h*0.5, w*0.28, h*0.32, 0, 0, Math.PI * 2); ctx.stroke();
      ctx.beginPath(); ctx.ellipse(w/2-w*0.1, h*0.42, w*0.04, h*0.03, 0, 0, Math.PI*2); ctx.stroke();
      ctx.beginPath(); ctx.ellipse(w/2+w*0.1, h*0.42, w*0.04, h*0.03, 0, 0, Math.PI*2); ctx.stroke();
    }
  }

  // Animate reel thumbnails
  const reelCanvases = document.querySelectorAll('canvas[data-thumb-kind="reel"]');
  function loopReels() {
    reelCanvases.forEach(c => {
      const seed = parseInt(c.dataset.thumbSeed) || 1;
      drawReelThumb(c, seed);
    });
    requestAnimationFrame(loopReels);
  }
  loopReels();

  // Static clip thumbnails
  document.querySelectorAll('canvas[data-thumb-kind="clip"]').forEach(c => {
    const seed = parseInt(c.dataset.thumbSeed) || 1;
    drawClipThumb(c, seed);
  });
  // XR previews
  document.querySelectorAll('canvas[data-preview-slug]').forEach(c => {
    drawXrPreview(c, c.dataset.previewSlug, parseInt(c.dataset.previewIdx) || 0);
  });

  // -------- WHY-TIP toggle --------
  document.querySelectorAll('.why-btn').forEach(b => {
    b.addEventListener('click', (e) => {
      e.stopPropagation();
      const idx = b.dataset.idx;
      const tip = document.querySelector('.why-tip[data-tip="'+idx+'"]');
      if (tip) tip.classList.toggle('show');
    });
  });

  // -------- LIKE buttons (optimistic + POST) --------
  document.querySelectorAll('.like-btn').forEach(b => {
    b.addEventListener('click', async () => {
      if (b.classList.contains('liked')) return;
      b.classList.add('liked');
      const c = b.querySelector('.rs-count');
      if (c) c.textContent = (parseInt(c.textContent) + 1).toString();
      const fd = new FormData();
      fd.append('action', 'like');
      fd.append('post_id', b.dataset.postId);
      try { await fetch(window.location.pathname, { method: 'POST', body: fd }); } catch(e) {}
    });
  });

  // -------- VIEW EVENT logging via IntersectionObserver --------
  const sentViews = new Set();
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting && e.intersectionRatio > 0.6) {
        const postId = e.target.dataset.postId;
        if (postId && !sentViews.has(postId)) {
          sentViews.add(postId);
          fetch('/api/feed-view', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ post_id: postId, watched_pct: 100, device: 'web' })
          }).catch(() => {});
        }
      }
    });
  }, { threshold: [0.6] });
  document.querySelectorAll('.reel').forEach(r => io.observe(r));

  // -------- CLIPS FILTERING --------
  const clipSearch = document.getElementById('clipSearch');
  const clipTopic = document.getElementById('clipTopic');
  const clipDur = document.getElementById('clipDur');
  function filterClips() {
    const q = (clipSearch.value || '').toLowerCase();
    const t = clipTopic.value;
    const d = clipDur.value;
    document.querySelectorAll('.clip-card').forEach(card => {
      const tags = (card.dataset.tags || '').toLowerCase();
      const dur = parseInt(card.dataset.dur) || 0;
      const title = card.querySelector('h3').textContent.toLowerCase();
      let show = true;
      if (q && !title.includes(q) && !tags.includes(q)) show = false;
      if (t && !tags.includes(t)) show = false;
      if (d === 'short' && dur >= 1800) show = false;
      if (d === 'long' && dur < 1800) show = false;
      card.style.display = show ? '' : 'none';
    });
  }
  clipSearch?.addEventListener('input', filterClips);
  clipTopic?.addEventListener('change', filterClips);
  clipDur?.addEventListener('change', filterClips);

  // -------- CREATE FAB / MODAL --------
  const fab = document.getElementById('fab');
  const createModal = document.getElementById('createModal');
  const cancelCreate = document.getElementById('cancelCreate');
  fab?.addEventListener('click', () => createModal.classList.add('open'));
  cancelCreate?.addEventListener('click', () => createModal.classList.remove('open'));
  createModal?.addEventListener('click', (e) => {
    if (e.target === createModal) createModal.classList.remove('open');
  });

  // -------- AR MODAL + getUserMedia --------
  const arModal = document.getElementById('arModal');
  const arVideo = document.getElementById('arVideo');
  const arCanvas = document.getElementById('arCanvas');
  const arStatus = document.getElementById('arStatus');
  const arClose = document.getElementById('arClose');
  let arStream = null;
  let arFx = 'soft-glow';
  let arRaf = null;

  async function openAr(fx) {
    arFx = fx;
    document.querySelectorAll('.ar-controls button[data-fx]').forEach(b => {
      b.classList.toggle('active', b.dataset.fx === fx);
    });
    arModal.classList.add('open');
    arStatus.textContent = 'Requesting camera...';
    try {
      arStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: 640, height: 480 }, audio: false });
      arVideo.srcObject = arStream;
      await arVideo.play();
      arStatus.textContent = 'Camera live. Effect: ' + fx;
      runArLoop();
    } catch (e) {
      arStatus.textContent = 'Camera unavailable: ' + (e.message || 'permission denied');
    }
  }

  function closeAr() {
    arModal.classList.remove('open');
    if (arStream) {
      arStream.getTracks().forEach(t => t.stop());
      arStream = null;
    }
    if (arRaf) { cancelAnimationFrame(arRaf); arRaf = null; }
  }
  arClose?.addEventListener('click', closeAr);

  document.querySelectorAll('.ar-controls button[data-fx]').forEach(b => {
    b.addEventListener('click', () => {
      arFx = b.dataset.fx;
      document.querySelectorAll('.ar-controls button[data-fx]').forEach(x => x.classList.toggle('active', x === b));
      arStatus.textContent = 'Effect: ' + arFx;
    });
  });

  document.querySelectorAll('button[data-try-slug]').forEach(b => {
    b.addEventListener('click', () => openAr(b.dataset.trySlug));
  });

  // -------- REAL AR EFFECTS --------
  // Pre-blurred buffer for soft-glow
  function gaussianBlur(srcData, w, h) {
    // Separable 3-tap blur approximating gaussian
    const data = srcData.data;
    const out = new Uint8ClampedArray(data.length);
    // horizontal
    for (let y = 0; y < h; y++) {
      for (let x = 0; x < w; x++) {
        const i = (y*w + x) * 4;
        const im = (y*w + Math.max(0, x-1)) * 4;
        const ip = (y*w + Math.min(w-1, x+1)) * 4;
        for (let c = 0; c < 3; c++) {
          out[i+c] = (data[im+c] + 2*data[i+c] + data[ip+c]) / 4;
        }
        out[i+3] = data[i+3];
      }
    }
    // vertical
    const out2 = new Uint8ClampedArray(data.length);
    for (let y = 0; y < h; y++) {
      for (let x = 0; x < w; x++) {
        const i = (y*w + x) * 4;
        const im = (Math.max(0, y-1)*w + x) * 4;
        const ip = (Math.min(h-1, y+1)*w + x) * 4;
        for (let c = 0; c < 3; c++) {
          out2[i+c] = (out[im+c] + 2*out[i+c] + out[ip+c]) / 4;
        }
        out2[i+3] = out[i+3];
      }
    }
    return new ImageData(out2, w, h);
  }

  function applyFx(ctx, w, h, fx, t) {
    // grab frame from video
    ctx.drawImage(arVideo, 0, 0, w, h);
    if (fx === 'soft-glow') {
      const img = ctx.getImageData(0, 0, w, h);
      const blurred = gaussianBlur(img, w, h);
      // Composite: original + (blurred * 0.55)
      const od = img.data, bd = blurred.data;
      for (let i = 0; i < od.length; i += 4) {
        od[i] = Math.min(255, od[i] * 0.55 + bd[i] * 0.55);
        od[i+1] = Math.min(255, od[i+1] * 0.55 + bd[i+1] * 0.55);
        od[i+2] = Math.min(255, od[i+2] * 0.55 + bd[i+2] * 0.55);
      }
      ctx.putImageData(img, 0, 0);
    } else if (fx === 'threshold') {
      const img = ctx.getImageData(0, 0, w, h);
      const d = img.data;
      for (let i = 0; i < d.length; i += 4) {
        const lum = 0.299 * d[i] + 0.587 * d[i+1] + 0.114 * d[i+2];
        const v = lum > 110 ? 255 : 0;
        d[i] = v; d[i+1] = v; d[i+2] = v;
      }
      ctx.putImageData(img, 0, 0);
    } else if (fx === 'rgb-shift') {
      const img = ctx.getImageData(0, 0, w, h);
      const d = img.data;
      const out = new Uint8ClampedArray(d.length);
      const dx = 6;
      for (let y = 0; y < h; y++) {
        for (let x = 0; x < w; x++) {
          const i = (y*w + x) * 4;
          const ir = (y*w + Math.max(0, x - dx)) * 4;
          const ib = (y*w + Math.min(w-1, x + dx)) * 4;
          out[i] = d[ir];
          out[i+1] = d[i+1];
          out[i+2] = d[ib+2];
          out[i+3] = 255;
        }
      }
      ctx.putImageData(new ImageData(out, w, h), 0, 0);
    } else if (fx === 'edge-find') {
      // Sobel
      const img = ctx.getImageData(0, 0, w, h);
      const d = img.data;
      const lum = new Float32Array(w*h);
      for (let i = 0; i < w*h; i++) {
        lum[i] = 0.299*d[i*4] + 0.587*d[i*4+1] + 0.114*d[i*4+2];
      }
      const out = new Uint8ClampedArray(d.length);
      for (let y = 1; y < h-1; y++) {
        for (let x = 1; x < w-1; x++) {
          const tl = lum[(y-1)*w + (x-1)], tt = lum[(y-1)*w + x], tr = lum[(y-1)*w + (x+1)];
          const ll = lum[y*w + (x-1)], rr = lum[y*w + (x+1)];
          const bl = lum[(y+1)*w + (x-1)], bb = lum[(y+1)*w + x], br = lum[(y+1)*w + (x+1)];
          const gx = -tl - 2*ll - bl + tr + 2*rr + br;
          const gy = -tl - 2*tt - tr + bl + 2*bb + br;
          const g = Math.min(255, Math.sqrt(gx*gx + gy*gy));
          const i = (y*w + x) * 4;
          out[i] = 0; out[i+1] = g; out[i+2] = g; out[i+3] = 255;
        }
      }
      ctx.putImageData(new ImageData(out, w, h), 0, 0);
    } else if (fx === 'polar-warp') {
      const img = ctx.getImageData(0, 0, w, h);
      const d = img.data;
      const out = new Uint8ClampedArray(d.length);
      const cx = w/2, cy = h/2;
      for (let y = 0; y < h; y++) {
        for (let x = 0; x < w; x++) {
          const dx = x - cx, dy = y - cy;
          const r = Math.sqrt(dx*dx + dy*dy);
          const a = Math.atan2(dy, dx) + r * 0.005;
          const sx = Math.floor(cx + Math.cos(a) * r);
          const sy = Math.floor(cy + Math.sin(a) * r);
          const i = (y*w + x) * 4;
          if (sx >= 0 && sx < w && sy >= 0 && sy < h) {
            const j = (sy*w + sx) * 4;
            out[i] = d[j]; out[i+1] = d[j+1]; out[i+2] = d[j+2]; out[i+3] = 255;
          }
        }
      }
      ctx.putImageData(new ImageData(out, w, h), 0, 0);
    } else if (fx === 'anatomy') {
      // overlay anatomical markers around centre (rough face approximation)
      ctx.strokeStyle = '#67e8f9'; ctx.lineWidth = 1.5;
      ctx.beginPath(); ctx.ellipse(w/2, h*0.5, w*0.22, h*0.3, 0, 0, Math.PI * 2); ctx.stroke();
      // landmarks
      const landmarks = [
        { x: w*0.41, y: h*0.42, label: 'orbital' },
        { x: w*0.59, y: h*0.42, label: 'orbital' },
        { x: w*0.50, y: h*0.50, label: 'nasal' },
        { x: w*0.42, y: h*0.62, label: 'zygomatic' },
        { x: w*0.58, y: h*0.62, label: 'zygomatic' },
        { x: w*0.50, y: h*0.68, label: 'mental' },
      ];
      landmarks.forEach(l => {
        ctx.fillStyle = '#a78bfa';
        ctx.beginPath(); ctx.arc(l.x, l.y, 4, 0, Math.PI*2); ctx.fill();
        ctx.fillStyle = '#67e8f9';
        ctx.font = '11px monospace';
        ctx.fillText(l.label, l.x + 8, l.y);
      });
    } else if (fx === 'math-notation') {
      ctx.strokeStyle = 'rgba(103,232,249,0.25)'; ctx.lineWidth = 0.5;
      for (let i = 0; i < w; i += 40) {
        ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, h); ctx.stroke();
      }
      for (let i = 0; i < h; i += 40) {
        ctx.beginPath(); ctx.moveTo(0, i); ctx.lineTo(w, i); ctx.stroke();
      }
      ctx.font = '16px monospace'; ctx.fillStyle = '#67e8f9';
      const eqs = ['∫f(x)dx', 'e^(iπ)+1=0', '∇²φ=4πρ', 'Σ1/n² = π²/6', 'F = ma'];
      eqs.forEach((e, i) => {
        const x = (i * 137 + t * 30) % w;
        const y = 40 + ((i * 71) % (h - 80));
        ctx.fillText(e, x, y);
      });
    } else if (fx === 'molecule') {
      const cx = w*0.5, cy = h*0.5;
      const R = Math.min(w, h) * 0.18;
      const atoms = [
        { x: 0, y: 0, z: 0, c: '#67e8f9', r: 8 },
        { x: 1, y: 0, z: 0.3, c: '#a78bfa', r: 6 },
        { x: -1, y: 0, z: 0.3, c: '#a78bfa', r: 6 },
        { x: 0, y: 1, z: -0.4, c: '#fb7185', r: 5 },
        { x: 0, y: -1, z: -0.4, c: '#fb7185', r: 5 },
        { x: 0.7, y: 0.7, z: 0, c: '#fbbf24', r: 4 },
        { x: -0.7, y: -0.7, z: 0, c: '#fbbf24', r: 4 },
      ];
      const proj = atoms.map(a => {
        const ca = Math.cos(t*0.6), sa = Math.sin(t*0.6);
        const x = a.x * ca - a.z * sa;
        const z = a.x * sa + a.z * ca;
        return { x: cx + x * R, y: cy + a.y * R, z, c: a.c, r: a.r * (1 + z*0.3) };
      }).sort((a,b) => a.z - b.z);
      ctx.strokeStyle = 'rgba(255,255,255,0.5)'; ctx.lineWidth = 1.5;
      proj.forEach((p, i) => {
        if (i > 0) { ctx.beginPath(); ctx.moveTo(proj[0].x, proj[0].y); ctx.lineTo(p.x, p.y); ctx.stroke(); }
      });
      proj.forEach(p => {
        ctx.fillStyle = p.c;
        ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI*2); ctx.fill();
      });
    } else if (fx === 'hand-trail') {
      // detect motion regions by frame differencing — simplified: animate particles in random direction
      if (!window.__handTrail) window.__handTrail = [];
      window.__handTrail.push({ x: Math.random()*w, y: Math.random()*h, life: 1, hue: (t*40) % 360 });
      while (window.__handTrail.length > 40) window.__handTrail.shift();
      window.__handTrail.forEach(p => {
        p.life *= 0.96;
        ctx.fillStyle = `hsla(${p.hue}, 80%, 60%, ${p.life})`;
        ctx.beginPath(); ctx.arc(p.x, p.y, 8 * p.life, 0, Math.PI*2); ctx.fill();
      });
    } else if (fx === 'world-grid') {
      ctx.strokeStyle = 'rgba(103,232,249,0.55)'; ctx.lineWidth = 1;
      // horizon-anchored perspective grid (lower half)
      const horizon = h * 0.45;
      const offset = (t * 30) % 30;
      for (let i = 0; i < 14; i++) {
        const y = horizon + Math.pow(i, 1.6) * 4 + offset;
        if (y > h) break;
        ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(w, y); ctx.stroke();
      }
      for (let i = -10; i <= 10; i++) {
        ctx.beginPath();
        ctx.moveTo(w/2, horizon);
        ctx.lineTo(w/2 + i * 60, h);
        ctx.stroke();
      }
    }
  }

  function runArLoop() {
    const w = arCanvas.width = arVideo.videoWidth || 640;
    const h = arCanvas.height = arVideo.videoHeight || 480;
    const ctx = arCanvas.getContext('2d');
    const t = Date.now() / 1000;
    try { applyFx(ctx, w, h, arFx, t); } catch(e) {}
    arRaf = requestAnimationFrame(runArLoop);
  }

  // auto-hide toast after 3s
  setTimeout(() => document.querySelectorAll('.toast').forEach(t => t.classList.remove('show')), 3200);
})();
</script>

</BaseLayout>
