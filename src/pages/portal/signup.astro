---
import BaseLayout from '@/layouts/BaseLayout.astro';

if (Astro.locals.user) {
  // Redirect to face enrollment after signup
return Astro.redirect('/portal/enroll-face?new=1');
}

import { COUNTRIES, validatePhone } from '@/lib/phone-validate';
import { db } from '@/lib/db';
import { roles } from '@/lib/db/schema';
import { eq } from 'drizzle-orm';

// If the user came from an apply link, surface the role context above the form
// so they know what they're signing up to apply for.
const urlForNext = new URL(Astro.request.url);
const nextParam = urlForNext.searchParams.get('next') || '';
let roleContext: { title: string; level: string; slug: string } | null = null;
try {
  if (nextParam) {
    const m = nextParam.match(/[?&]role=([a-z0-9-]+)/i);
    const roleSlug = m ? decodeURIComponent(m[1]) : '';
    if (roleSlug) {
      const found = await db.select({
        title: roles.title, level: roles.level, slug: roles.slug,
      }).from(roles).where(eq(roles.slug, roleSlug)).limit(1);
      if (found.length > 0) roleContext = found[0];
    }
  }
} catch (_) {}

let errorMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const email = (fd.get('email') as string || '').trim().toLowerCase();
  const name = (fd.get('name') as string || '').trim();
  const password = fd.get('password') as string || '';
  const phoneCountry = (fd.get('phone_country') as string || 'IN').trim();
  const phoneRaw = (fd.get('phone') as string || '').trim();
  const consent = fd.get('consent');
  const phoneCheck = validatePhone(phoneCountry, phoneRaw);
  if (!consent) {
    errorMsg = 'You must agree to the Privacy Policy and Terms of Service to create an account.';
  } else if (!email || !name || !password) {
    errorMsg = 'All fields are required.';
  } else if (password.length < 8) {
    errorMsg = 'Password must be at least 8 characters.';
  } else if (!/.+@.+\..+/.test(email)) {
    errorMsg = 'Please enter a valid email.';
  } else if (!phoneCheck.valid) {
    errorMsg = phoneCheck.reason || 'Please enter a valid phone number.';
  } else {
    const { db } = await import('@/lib/db');
    const { users } = await import('@/lib/db/schema');
    const { hashPassword } = await import('@/lib/auth/password');
    const { generateSessionToken, createSession } = await import('@/lib/auth/session');
    const { setSessionCookie } = await import('@/lib/auth/cookie');
    const { eq } = await import('drizzle-orm');

    const existing = await db.select({ id: users.id }).from(users).where(eq(users.email, email)).limit(1);
    if (existing.length > 0) {
      errorMsg = 'An account with this email already exists. Try signing in instead.';
    } else {
      const passwordHash = await hashPassword(password);
      const inserted = await db.insert(users).values({
        email, name, passwordHash, role: 'applicant', isActive: true,
        consentGivenAt: new Date(),
        consentIp: Astro.clientAddress
      }).returning({ id: users.id });

      // New profiles are approved on signup — the application fee is the only paid
      // step, so candidates aren't double-charged. Legacy users still on 'pending'
      // can still use /portal/activate (waiver or 1 CHF) but it's no longer gating.
      // Split the access_status and phone updates so a phone-column issue does
      // not silently leave the user at 'pending' (this was leaving applicants stuck).
      try {
        const { sql } = await import('drizzle-orm');
        await db.execute(sql`UPDATE users SET access_status = 'approved', updated_at = NOW() WHERE id = ${inserted[0].id}`);
      } catch (e) { console.error('[signup] access_status update failed:', e); }
      if (phoneCheck.e164) {
        try {
          const { sql } = await import('drizzle-orm');
          await db.execute(sql`UPDATE users SET phone = ${phoneCheck.e164} WHERE id = ${inserted[0].id}`);
        } catch (_) { /* phone column may not exist on legacy DBs; non-fatal */ }
      }

      // Push notification to admins
      try {
        const { pushNotify } = await import('@/lib/push');
        await pushNotify.newUser(name, inserted[0].id);
      } catch (_) {}
      const token = generateSessionToken();
      const session = await createSession(token, inserted[0].id, {
        userAgent: Astro.request.headers.get('user-agent') || undefined,
        ipAddress: Astro.clientAddress
      });
      setSessionCookie(Astro.cookies, token, session.expiresAt);
      // Honour a 'next' redirect if provided (e.g. apply flow). Otherwise land
      // the user on /portal — NOT /identity-setup. Identity verification is
      // still available but it's no longer the first wall a brand-new applicant
      // hits after creating an account (which was driving abandonment).
      const nextUrl = new URL(Astro.request.url).searchParams.get('next');
      if (nextUrl && nextUrl.startsWith('/')) return Astro.redirect(nextUrl);
      return Astro.redirect('/portal');
    }
  }
}
---
<BaseLayout title="Create Account - EduRankAI Portal" description="Create your EduRankAI applicant portal account.">
  <section class="px-[5vw] py-10 md:py-14 max-w-xl mx-auto">

    {roleContext && (
      <div style="background:linear-gradient(180deg,#fff7ed 0%,#ffffff 100%);border:1px solid rgba(220,80,0,0.22);border-radius:14px;padding:14px 18px;margin-bottom:18px;display:flex;align-items:flex-start;gap:12px;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#DC5000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><path d="M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6l-8-4z"/></svg>
        <div style="min-width:0;">
          <p style="font-family:'Geist Mono','JetBrains Mono',monospace;font-size:9.5px;letter-spacing:0.16em;text-transform:uppercase;color:#DC5000;font-weight:700;margin:0 0 3px;">You're applying for</p>
          <p style="font-family:'Fraunces',serif;font-size:1.05rem;font-weight:600;color:#1c1d22;margin:0;line-height:1.3;">{roleContext.title}</p>
          <p style="font-size:11.5px;color:#5b5b5b;margin:3px 0 0;">Level: {roleContext.level} &middot; Create your account below to continue.</p>
        </div>
      </div>
    )}

    <div class="mb-6 text-center">
      <p class="eyebrow mb-3">Applicant Portal</p>
      <h1 class="font-display text-3xl md:text-[2.4rem] font-semibold text-ink leading-[1.1] mb-3">
        Create your <em class="italic text-burn font-medium">account</em>
      </h1>
      <p class="text-[0.92rem] text-ink-soft leading-relaxed max-w-md mx-auto">
        Takes 30 seconds. One account for every EduRankAI role you ever apply to.
      </p>
    </div>

    <!-- What happens next preview -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:8px;margin-bottom:14px;">
      <div style="background:#fff;border:1px solid rgba(0,0,0,0.08);border-radius:10px;padding:11px 13px;display:flex;align-items:center;gap:10px;">
        <span style="background:#FF4F00;color:#fff;font-family:'Geist Mono',monospace;font-size:11px;font-weight:700;width:22px;height:22px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;">1</span>
        <p style="font-size:11.5px;color:#1c1d22;margin:0;line-height:1.35;font-weight:600;">Create account</p>
      </div>
      <div style="background:#fff;border:1px solid rgba(0,0,0,0.08);border-radius:10px;padding:11px 13px;display:flex;align-items:center;gap:10px;">
        <span style="background:rgba(220,80,0,0.12);color:#DC5000;font-family:'Geist Mono',monospace;font-size:11px;font-weight:700;width:22px;height:22px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;">2</span>
        <p style="font-size:11.5px;color:#1c1d22;margin:0;line-height:1.35;font-weight:600;">Fill the application</p>
      </div>
      <div style="background:#fff;border:1px solid rgba(0,0,0,0.08);border-radius:10px;padding:11px 13px;display:flex;align-items:center;gap:10px;">
        <span style="background:rgba(220,80,0,0.12);color:#DC5000;font-family:'Geist Mono',monospace;font-size:11px;font-weight:700;width:22px;height:22px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;">3</span>
        <p style="font-size:11.5px;color:#1c1d22;margin:0;line-height:1.35;font-weight:600;">Pay fee or request waiver</p>
      </div>
    </div>

    <!-- Read-before-you-sign transparency banner. Surfaces what we collect,
         why, and what we will not do with it. This is the highest-impact
         conversion lever for applicants who are worried about data handling. -->
    <a href="/policy/candidate-transparency" style="display:flex;align-items:center;gap:12px;text-decoration:none;background:#fff;border:1px solid rgba(0,0,0,0.1);border-left:4px solid #DC5000;border-radius:10px;padding:13px 16px;margin-bottom:20px;color:#1c1d22;transition:background .15s;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#DC5000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
      <div style="flex:1;min-width:0;">
        <p style="font-family:'Inter Tight',sans-serif;font-size:13px;font-weight:700;margin:0 0 2px;line-height:1.3;">Before you sign up: what we collect &amp; why</p>
        <p style="font-family:'Inter Tight',sans-serif;font-size:11.5px;color:#5b5b5b;margin:0;line-height:1.5;">Plain-language transparency. We don't sell data, we don't use it for ads, we don't train models on it. Read it in 2 minutes.</p>
      </div>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#DC5000" stroke-width="2.5" style="flex-shrink:0;"><path d="m9 18 6-6-6-6"/></svg>
    </a>

    {errorMsg && (
      <div style="background:rgba(220,38,38,0.06);border:1px solid rgba(220,38,38,0.2);color:#b91c1c;font-size:0.85rem;padding:11px 14px;border-radius:8px;margin-bottom:18px;line-height:1.6;">
        {errorMsg}
      </div>
    )}

    <form method="POST" class="bg-white border border-ink/10 rounded-2xl p-6 md:p-7 flex flex-col gap-5 shadow-[0_4px_28px_-12px_rgba(0,0,0,0.08)]">
      <p class="text-[0.82rem] text-ink-soft text-center -mt-1 mb-1">
        Already have an account? <a href="/portal/login" class="text-burn font-semibold hover:underline">Sign in</a>
      </p>

      <div>
        <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Full Name</label>
        <input type="text" name="name" required autocomplete="name" placeholder="As it should appear on your application" class="w-full px-4 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
      </div>

      <div>
        <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Email</label>
        <input type="email" name="email" required autocomplete="email" placeholder="you@example.com" class="w-full px-4 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
        <p class="text-[0.72rem] text-ink-soft mt-1.5">All application updates go here. No marketing email — ever.</p>
      </div>

      <div>
        <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Phone number</label>
        <div class="flex gap-2">
          <select name="phone_country" class="px-2 py-2.5 border border-ink/15 rounded-lg text-[0.85rem] outline-none focus:border-burn bg-cream-2 max-w-[42%]">
            {COUNTRIES.map((c) => <option value={c.iso} selected={c.iso === 'IN'}>{c.label}</option>)}
          </select>
          <input type="tel" name="phone" required placeholder="Phone number" class="flex-1 px-4 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
        </div>
        <p class="text-[0.72rem] text-ink-soft mt-1.5">For interview scheduling. We never use it for outbound calls.</p>
      </div>

      <div>
        <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Password</label>
        <input type="password" name="password" id="portal-signup-pw" required minlength="8" autocomplete="new-password" placeholder="At least 8 characters" class="w-full px-4 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
        <div id="pwMeter" style="display:none;margin-top:8px;">
          <div style="height:4px;background:#eee;border-radius:2px;overflow:hidden;">
            <div id="pwBar" style="height:100%;width:0%;background:#dc2626;transition:width .2s,background .2s;"></div>
          </div>
          <p id="pwLabel" style="font-size:11px;color:#6e6e78;margin:5px 0 0;">Type a password to see strength</p>
        </div>
      </div>

      <label style="display:flex;align-items:flex-start;gap:9px;font-size:0.82rem;color:#3a3a40;line-height:1.5;cursor:pointer;">
        <input type="checkbox" name="consent" value="yes" required style="margin-top:3px;accent-color:#FF4F00;flex-shrink:0;" />
        <span>I have read and agree to the <a href="/p/privacy" target="_blank" class="text-burn hover:underline">Privacy Policy</a> and <a href="/p/terms" target="_blank" class="text-burn hover:underline">Terms of Service</a>. I consent to EduRankAI processing my personal data for recruitment and related purposes.</span>
      </label>

      <button type="submit" class="btn-primary w-full justify-center mt-1">Create Account &amp; Continue</button>

      <div style="display:flex;align-items:center;gap:8px;font-size:11px;color:#6e6e78;text-align:left;margin-top:2px;">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#6e6e78" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        <span>Your data is encrypted at rest. You can request erasure anytime under DPDPA 2023 / GDPR Article 17 from your portal.</span>
      </div>
    </form>

    <p class="text-center text-[0.82rem] text-ink-soft mt-5">
      Questions? <a href="mailto:hr@edurankai.in" class="text-burn hover:underline">hr@edurankai.in</a>
    </p>
  </section>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const inp = document.getElementById('portal-signup-pw');
    if (!inp || inp.dataset.toggled) return;
    inp.dataset.toggled = '1';
    inp.style.paddingRight = '54px';
    const wrap = document.createElement('div');
    wrap.style.position = 'relative';
    inp.parentNode.insertBefore(wrap, inp);
    wrap.appendChild(inp);
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.textContent = 'Show';
    btn.style.cssText = 'position:absolute;right:8px;top:50%;transform:translateY(-50%);background:transparent;border:none;color:#6e6e78;cursor:pointer;font-size:11px;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;padding:6px;font-family:monospace;';
    btn.addEventListener('click', () => {
      const isPw = inp.type === 'password';
      inp.type = isPw ? 'text' : 'password';
      btn.textContent = isPw ? 'Hide' : 'Show';
    });
    wrap.appendChild(btn);

    // Live password strength meter
    const meter = document.getElementById('pwMeter');
    const bar = document.getElementById('pwBar');
    const label = document.getElementById('pwLabel');
    if (meter && bar && label) {
      inp.addEventListener('input', () => {
        const v = inp.value || '';
        if (!v.length) { meter.style.display = 'none'; return; }
        meter.style.display = 'block';
        let score = 0;
        if (v.length >= 8) score += 1;
        if (v.length >= 12) score += 1;
        if (/[A-Z]/.test(v)) score += 1;
        if (/[0-9]/.test(v)) score += 1;
        if (/[^A-Za-z0-9]/.test(v)) score += 1;
        const tiers = [
          { w: 15, c: '#dc2626', t: 'Weak — at least 8 characters' },
          { w: 30, c: '#dc2626', t: 'Weak' },
          { w: 55, c: '#f59e0b', t: 'Okay' },
          { w: 75, c: '#f59e0b', t: 'Good' },
          { w: 90, c: '#10b981', t: 'Strong' },
          { w: 100, c: '#10b981', t: 'Very strong' },
        ];
        const tier = tiers[Math.min(score, tiers.length - 1)];
        bar.style.width = tier.w + '%';
        bar.style.background = tier.c;
        label.textContent = tier.t;
        label.style.color = tier.c;
      });
    }
  });
</script>
