---
import BaseLayout from '@/layouts/BaseLayout.astro';

if (Astro.locals.user) {
  return Astro.redirect('/portal');
}

let errorMsg = '';
let requireFace = false;
let pendingUserId = '';
let pendingUserName = '';
let faceDescriptor = '';

// Server-side face verification helpers. The browser's match is advisory; the
// authoritative comparison happens HERE so the face 2FA cannot be bypassed by
// forging the success POST.
const FACE_2FA_THRESHOLD = 0.6;
function euclid(a: number[], b: number[]): number {
  let s = 0; const n = Math.min(a.length, b.length);
  for (let i = 0; i < n; i++) { const d = (a[i] || 0) - (b[i] || 0); s += d * d; }
  return Math.sqrt(s);
}
function normDesc(d: any): number[] | null {
  if (d == null) return null;
  if (typeof d === 'string') { try { return normDesc(JSON.parse(d)); } catch { return null; } }
  if (Array.isArray(d)) return d.map(Number);
  if (typeof d === 'object') return Object.keys(d).sort((a, b) => Number(a) - Number(b)).map((k) => Number(d[k]));
  return null;
}

// Check face pending cookie
const pendingId = Astro.cookies.get('portal_face_pending')?.value || '';

if (pendingId) {
  requireFace = true;
  pendingUserId = pendingId;
  try {
    const { db } = await import('@/lib/db');
    const { users } = await import('@/lib/db/schema');
    const { eq } = await import('drizzle-orm');
    const { sql } = await import('drizzle-orm');
    const u = await db.select({ name: users.name }).from(users).where(eq(users.id, pendingId)).limit(1);
    pendingUserName = u[0]?.name || '';
    const fd = await db.execute(sql`SELECT face_descriptor FROM user_face_enrollments WHERE user_id = ${pendingId} AND is_active = true LIMIT 1`);
    const rows = Array.isArray(fd) ? fd : (fd?.rows || []);
    faceDescriptor = rows.length > 0 ? JSON.stringify((rows[0] as any).face_descriptor) : '';
  } catch(e) {}
}

// Authenticator (TOTP) pending — password was correct, awaiting the code.
const tfaPendingId = Astro.cookies.get('portal_tfa_pending')?.value || '';
let requireTotp = false;
let tfaPendingName = '';
if (tfaPendingId && !pendingId) {
  requireTotp = true;
  try {
    const { db } = await import('@/lib/db');
    const { users } = await import('@/lib/db/schema');
    const { eq } = await import('drizzle-orm');
    const u = await db.select({ name: users.name }).from(users).where(eq(users.id, tfaPendingId)).limit(1);
    tfaPendingName = u[0]?.name || '';
  } catch (_) {}
}

if (Astro.request.method === 'POST') {
  const fd2 = await Astro.request.formData();
  const action = fd2.get('action') as string;

  if (action === 'tfa_verify') {
    const userId = (fd2.get('user_id') as string) || '';
    const code = ((fd2.get('code') as string) || '').trim();
    if (!userId || userId !== tfaPendingId) {
      errorMsg = 'Session expired. Please sign in again.';
      Astro.cookies.delete('portal_tfa_pending', { path: '/' });
      requireTotp = false;
    } else {
      const { verifyLoginCode } = await import('@/lib/auth/twofactor');
      const ok = await verifyLoginCode(userId, code);
      if (!ok) {
        errorMsg = 'That code is not right. Use the current code from your authenticator app, or a backup code.';
      } else {
        const { db } = await import('@/lib/db');
        const { users } = await import('@/lib/db/schema');
        const { generateSessionToken, createSession } = await import('@/lib/auth/session');
        const { setSessionCookie } = await import('@/lib/auth/cookie');
        const { eq } = await import('drizzle-orm');
        const token = generateSessionToken();
        const session = await createSession(token, userId, { userAgent: Astro.request.headers.get('user-agent') || undefined, ipAddress: Astro.clientAddress });
        setSessionCookie(Astro.cookies, token, session.expiresAt);
        const u2 = await db.select({ role: users.role }).from(users).where(eq(users.id, userId)).limit(1);
        await db.update(users).set({ lastLoginAt: new Date(), updatedAt: new Date() }).where(eq(users.id, userId));
        Astro.cookies.delete('portal_tfa_pending', { path: '/' });
        return Astro.redirect(u2[0]?.role === 'applicant' ? '/portal' : '/admin');
      }
    }
  } else if (action === 'cancel_tfa') {
    Astro.cookies.delete('portal_tfa_pending', { path: '/' });
    return Astro.redirect('/portal/login');
  } else if (action === 'face_verified') {
    const userId = fd2.get('user_id') as string;
    const liveRaw = (fd2.get('live_descriptor') as string) || '';
    if (userId === pendingId) {
      try {
        const { db } = await import('@/lib/db');
        const { users } = await import('@/lib/db/schema');
        const { generateSessionToken, createSession } = await import('@/lib/auth/session');
        const { setSessionCookie } = await import('@/lib/auth/cookie');
        const { eq } = await import('drizzle-orm');
        const { sql } = await import('drizzle-orm');

        // AUTHORITATIVE server-side match: fetch the enrolled descriptor and
        // compare it to the freshly-captured one. Never trust the client's claim.
        const fdRow = await db.execute(sql`SELECT face_descriptor FROM user_face_enrollments WHERE user_id = ${userId} AND is_active = true LIMIT 1`);
        const fdr = Array.isArray(fdRow) ? fdRow : (fdRow?.rows || []);
        const stored = normDesc((fdr[0] as any)?.face_descriptor);
        let live: number[] | null = null;
        try { live = normDesc(JSON.parse(liveRaw)); } catch { live = null; }
        const dist = (stored && live && stored.length === 128 && live.length === 128) ? euclid(stored, live) : 99;
        const matched = dist < FACE_2FA_THRESHOLD;
        // Audit the 2FA attempt alongside the document/identity records.
        await db.execute(sql`
          INSERT INTO identity_verifications (user_id, email, claimed_name, method, face_match_distance, face_match_passed, verdict, ip_address, user_agent)
          VALUES (${userId}, ${''}, ${pendingUserName || ''}, 'face_login', ${Number.isFinite(dist) ? dist : null}, ${matched}, ${matched ? 'verified' : 'rejected'}, ${(Astro.clientAddress || '').toString().slice(0, 64) || null}, ${(Astro.request.headers.get('user-agent') || '').slice(0, 500)})
        `).catch(() => {});

        if (!matched) {
          errorMsg = 'Face not recognised (distance ' + (Number.isFinite(dist) ? dist.toFixed(3) : 'n/a') + '). Try again in better light, or use your password.';
        } else {
          await db.execute(sql`UPDATE user_face_enrollments SET last_used_at = NOW() WHERE user_id = ${userId}`);
          const token = generateSessionToken();
          const session = await createSession(token, userId, {
            userAgent: Astro.request.headers.get('user-agent') || undefined,
            ipAddress: Astro.clientAddress
          });
          setSessionCookie(Astro.cookies, token, session.expiresAt);
          await db.update(users).set({ lastLoginAt: new Date(), updatedAt: new Date() }).where(eq(users.id, userId));
          Astro.cookies.delete('portal_face_pending', { path: '/' });
          return Astro.redirect('/portal?enrolled=1');
        }
      } catch(e: any) { errorMsg = 'Login error. Please try again.'; }
    } else {
      errorMsg = 'Session mismatch. Please login again.';
      Astro.cookies.delete('portal_face_pending', { path: '/' });
      requireFace = false;
    }
  } else if (action === 'cancel_face') {
    Astro.cookies.delete('portal_face_pending', { path: '/' });
    return Astro.redirect('/portal/login');
  } else if (action === 'face_only_init') {
    // Face-only login - just needs email, no password
    const emailInput = (fd2.get('email') as string || '').trim().toLowerCase();
    if (emailInput) {
      const { db } = await import('@/lib/db');
      const { users } = await import('@/lib/db/schema');
      const { eq, or } = await import('drizzle-orm');
      const { sql } = await import('drizzle-orm');
      const found = await db.select({ id: users.id, name: users.name, isActive: users.isActive })
        .from(users).where(or(eq(users.email, emailInput), eq(users.internalHandle, emailInput))).limit(1);
      if (found.length > 0 && found[0].isActive) {
        const u = found[0];
        const faceCheck = await db.execute(sql`SELECT id FROM user_face_enrollments WHERE user_id = ${u.id} AND is_active = true LIMIT 1`);
        const faceRows = Array.isArray(faceCheck) ? faceCheck : (faceCheck?.rows || []);
        if (faceRows.length > 0) {
          Astro.cookies.set('portal_face_pending', u.id, { path: '/', httpOnly: true, maxAge: 300, sameSite: 'lax' });
          return Astro.redirect('/portal/login');
        } else {
          errorMsg = 'No face enrolled for this account. Please login with password.';
        }
      } else {
        errorMsg = 'Account not found.';
      }
    }
  } else {
    // Password login
    const loginMethod = (fd2.get('login_method') as string || 'email').trim();
    if (loginMethod !== 'email') {
      errorMsg = 'This sign-in method is no longer supported. Please use email and password.';
    } else {
      const { db } = await import('@/lib/db');
      const { users } = await import('@/lib/db/schema');
      const { verifyPassword } = await import('@/lib/auth/password');
      const { generateSessionToken, createSession } = await import('@/lib/auth/session');
      const { setSessionCookie } = await import('@/lib/auth/cookie');
      const { eq, or } = await import('drizzle-orm');
      const { sql } = await import('drizzle-orm');

      const email = (fd2.get('email') as string || '').trim().toLowerCase();
      const password = fd2.get('password') as string || '';
      if (!email || !password) {
        errorMsg = 'Email and password are required.';
      } else {
        const found = await db.select().from(users).where(or(eq(users.email, email), eq(users.internalHandle, email))).limit(1);
        const user = found[0];
        if (!user || !user.isActive) {
          errorMsg = 'Invalid email or password.';
        } else {
          const valid = await verifyPassword(user.passwordHash, password);
          if (!valid) {
            errorMsg = 'Invalid email or password.';
          } else {
            // Any one method signs you in — password alone is enough here.
            // Passkey / authenticator / face are independent options offered below.
            // Face 2FA: applicants log in directly with password; staff
            // (admin/HR/editor) still get the face-scan challenge on the
            // admin login surface. The applicant portal explicitly does NOT
            // ask for face on signup or login until you tell me to enable it.
            const faceCheck = await db.execute(sql`SELECT id FROM user_face_enrollments WHERE user_id = ${user.id} AND is_active = true LIMIT 1`);
            const faceRows = Array.isArray(faceCheck) ? faceCheck : (faceCheck?.rows || []);
            const isApplicant = user.role === 'applicant';

            if (!isApplicant && faceRows.length > 0) {
              // Staff with face enrolled — challenge them.
              Astro.cookies.set('portal_face_pending', user.id, {
                path: '/', httpOnly: true, maxAge: 300, sameSite: 'lax'
              });
              return Astro.redirect('/portal/login');
            } else {
              // Applicant OR no face on file → log in directly.
              const token = generateSessionToken();
              const session = await createSession(token, user.id, {
                userAgent: Astro.request.headers.get('user-agent') || undefined,
                ipAddress: Astro.clientAddress
              });
              setSessionCookie(Astro.cookies, token, session.expiresAt);
              await db.update(users).set({ lastLoginAt: new Date(), updatedAt: new Date() }).where(eq(users.id, user.id));
              if (isApplicant) return Astro.redirect('/portal');
              return Astro.redirect('/admin');
            }
          }
        }
      }
    }
  }
}
---
<BaseLayout title="Sign in - EduRankAI Portal" description="Sign in to your EduRankAI applicant portal.">
<style>
  .face-card { background: #fff; border: 1px solid rgba(0,0,0,0.1); border-radius: 16px; overflow: hidden; max-width: 420px; margin: 0 auto; }
  .cam-wrap { background: #000; aspect-ratio: 3/4; position: relative; max-height: 380px; }
  .cam-wrap video { width: 100%; height: 100%; object-fit: cover; transform: scaleX(-1); }
  .oval-ring { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; pointer-events: none; }
  .oval-inner { width: 55%; aspect-ratio: 3/4; border: 2.5px solid rgba(220,80,0,0.7); border-radius: 50%; }
  .cam-status { position: absolute; bottom: 12px; left: 0; right: 0; text-align: center; }
  .cam-status span { background: rgba(0,0,0,0.75); color: #fff; font-size: 12px; padding: 4px 14px; border-radius: 100px; }
  .prog-bar { height: 3px; background: #f0f0f0; }
  .prog-fill { height: 100%; background: #DC5000; width: 0%; transition: width 0.4s; }
  .face-btn { width: 100%; border: none; font-size: 15px; font-weight: 700; padding: 14px; cursor: pointer; border-radius: 0; }
  .face-btn:disabled { opacity: 0.5; cursor: not-allowed; }
</style>

<section style="padding: 48px 20px; max-width: 480px; margin: 0 auto;">
  <div style="text-align:center;margin-bottom:28px;">
    <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:#DC5000;margin-bottom:8px;">Applicant Portal</p>
    <h1 style="font-size:28px;font-weight:700;color:#111;margin:0;">{requireFace ? 'Verify your face' : requireTotp ? 'Enter your code' : 'Sign in'}</h1>
    {requireFace && <p style="font-size:14px;color:#6b7280;margin:8px 0 0;">Welcome back, <strong>{pendingUserName}</strong></p>}
    {requireTotp && <p style="font-size:14px;color:#6b7280;margin:8px 0 0;">Welcome back{tfaPendingName ? ', ' : ''}<strong>{tfaPendingName}</strong> — enter the 6-digit code from your authenticator app.</p>}
  </div>

  {errorMsg && (
    <div style="background:rgba(220,38,38,0.06);border:1px solid rgba(220,38,38,0.2);color:#b91c1c;font-size:14px;padding:11px 14px;border-radius:8px;margin-bottom:18px;">
      {errorMsg}
    </div>
  )}

  {requireTotp && (
    <div style="background:#fff;border:1px solid rgba(0,0,0,0.1);border-radius:16px;padding:24px;max-width:420px;margin:0 auto;">
      <form method="POST" style="display:flex;flex-direction:column;gap:16px;">
        <input type="hidden" name="action" value="tfa_verify"/>
        <input type="hidden" name="user_id" value={tfaPendingId}/>
        <div>
          <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6b7280;margin-bottom:6px;">Authenticator code</label>
          <input type="text" name="code" inputmode="numeric" autocomplete="one-time-code" maxlength="12" placeholder="123456" autofocus required style="width:100%;padding:12px 14px;border:1px solid rgba(0,0,0,0.15);border-radius:8px;font-size:18px;letter-spacing:0.18em;text-align:center;outline:none;background:#fafaf9;"/>
        </div>
        <button type="submit" style="background:#DC5000;color:#fff;border:none;font-size:15px;font-weight:700;padding:13px;border-radius:8px;cursor:pointer;">Verify</button>
      </form>
      <p style="font-size:12px;color:#6b7280;margin:14px 0 0;text-align:center;">Lost your phone? Enter one of your <strong>backup codes</strong> above.</p>
      <form method="POST" style="text-align:center;margin-top:10px;">
        <input type="hidden" name="action" value="cancel_tfa"/>
        <button type="submit" style="background:transparent;border:none;color:#6b7280;font-size:13px;font-weight:600;cursor:pointer;text-decoration:underline;">Use a different account</button>
      </form>
    </div>
  )}

  {!requireFace && !requireTotp && (
    <div style="background:#fff;border:1px solid rgba(0,0,0,0.1);border-radius:16px;padding:24px;">
      <form method="POST" style="display:flex;flex-direction:column;gap:18px;">
        <input type="hidden" name="login_method" value="email"/>
        <div>
          <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6b7280;margin-bottom:6px;">Email</label>
          <input type="email" name="email" autocomplete="email" placeholder="you@example.com" required style="width:100%;padding:11px 14px;border:1px solid rgba(0,0,0,0.15);border-radius:8px;font-size:15px;outline:none;background:#fafaf9;"/>
        </div>
        <div>
          <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6b7280;margin-bottom:6px;">Password</label>
          <div style="position:relative;">
            <input type="password" name="password" id="portal-login-pw" autocomplete="current-password" required style="width:100%;padding:11px 14px;padding-right:56px;border:1px solid rgba(0,0,0,0.15);border-radius:8px;font-size:15px;outline:none;background:#fafaf9;"/>
            <button type="button" id="pwToggle" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:transparent;border:none;color:#6b7280;font-size:11px;font-weight:700;cursor:pointer;font-family:monospace;text-transform:uppercase;">Show</button>
          </div>
        </div>
        <button type="submit" style="background:#DC5000;color:#fff;border:none;font-size:15px;font-weight:700;padding:13px;border-radius:8px;cursor:pointer;">Sign In</button>
      </form>
      <div style="margin-top:18px;padding-top:18px;border-top:1px solid rgba(0,0,0,0.08);display:flex;flex-direction:column;gap:8px;text-align:center;">
        <a href="/portal/forgot" style="font-size:13px;color:#DC5000;font-weight:600;text-decoration:none;">Forgot password?</a>
        <p style="font-size:12px;color:#6b7280;margin:4px 0 0;">No password? Ask your admin to reset it at <strong>Admin Panel -> Users -> Reset Password</strong></p>
      </div>
    </div>
  )}

  {!requireFace && !requireTotp && (
    <div style="max-width:480px;margin:14px auto 0;">
      <div style="display:flex;align-items:center;gap:10px;color:#9ca3af;font-size:12px;margin:6px 0 12px;">
        <span style="flex:1;height:1px;background:rgba(0,0,0,0.1);"></span>OR<span style="flex:1;height:1px;background:rgba(0,0,0,0.1);"></span>
      </div>
      <button type="button" id="pkLoginBtn" style="width:100%;display:flex;align-items:center;justify-content:center;gap:8px;background:#fff;border:1px solid rgba(0,0,0,0.15);color:#111;font-size:14px;font-weight:700;padding:12px;border-radius:8px;cursor:pointer;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M12 11c0-1.5-1-3-3-3M5 13a7 7 0 0 1 7-7 7 7 0 0 1 7 7M8 21c-1-2-1.5-4-1.5-6M12 13v3c0 2 .5 4 1.5 6M16 14c.3 2 .8 4 1.5 5"/></svg>
        Sign in with fingerprint / passkey
      </button>
      <p id="pkLoginErr" style="color:#b91c1c;font-size:12px;text-align:center;margin:8px 0 0;min-height:1em;"></p>
      <div style="text-align:center;margin-top:6px;">
        <button type="button" id="totpToggle" style="background:transparent;border:none;color:#DC5000;font-size:13px;font-weight:600;cursor:pointer;text-decoration:underline;">Sign in with an authenticator code</button>
      </div>
      <div id="totpBox" style="display:none;margin-top:10px;background:#fff;border:1px solid rgba(0,0,0,0.1);border-radius:12px;padding:14px;display:none;">
        <input id="totpEmail" type="email" placeholder="your@email.com" autocomplete="email" style="width:100%;padding:10px 14px;border:1px solid rgba(0,0,0,0.15);border-radius:8px;font-size:14px;outline:none;margin-bottom:8px;"/>
        <input id="totpCode" inputmode="numeric" autocomplete="one-time-code" maxlength="12" placeholder="6-digit code" style="width:100%;padding:10px 14px;border:1px solid rgba(0,0,0,0.15);border-radius:8px;font-size:16px;letter-spacing:0.15em;text-align:center;outline:none;margin-bottom:8px;"/>
        <button type="button" id="totpBtn" style="width:100%;background:#0f0f14;color:#fff;border:none;font-size:14px;font-weight:600;padding:11px;border-radius:8px;cursor:pointer;">Verify code</button>
        <p id="totpErr" style="color:#b91c1c;font-size:12px;text-align:center;margin:8px 0 0;min-height:1em;"></p>
      </div>
    </div>
  )}

  {requireFace && faceDescriptor && (
    <div class="face-card">
      <div class="cam-wrap">
        <video id="videoEl" autoplay playsinline muted></video>
        <div class="oval-ring"><div class="oval-inner" id="ovalRing"></div></div>
        <div class="cam-status"><span id="camStatus">Loading face model...</span></div>
      </div>
      <div class="prog-bar"><div class="prog-fill" id="progFill"></div></div>
      <button id="verifyBtn" class="face-btn" disabled style="background:#DC5000;color:#fff;">Scanning...</button>
    </div>
  )}

  {requireFace && !faceDescriptor && (
    <div style="text-align:center;padding:32px;background:#fff;border:1px solid rgba(0,0,0,0.1);border-radius:16px;">
      <p style="font-size:14px;color:#6b7280;margin:0 0 16px;">Face data not found. Please login with password.</p>
      <form method="POST">
        <input type="hidden" name="action" value="cancel_face"/>
        <button type="submit" style="background:#DC5000;color:#fff;border:none;font-size:14px;font-weight:600;padding:10px 24px;border-radius:8px;cursor:pointer;">Use Password Instead</button>
      </form>
    </div>
  )}

  {requireFace && (
    <div style="text-align:center;margin-top:16px;">
      <form method="POST" style="display:inline;">
        <input type="hidden" name="action" value="cancel_face"/>
        <button type="submit" style="background:transparent;border:none;color:#6b7280;font-size:13px;cursor:pointer;text-decoration:underline;">Use password instead</button>
      </form>
    </div>
  )}

  {!requireFace && !requireTotp && (
    <p style="text-align:center;font-size:14px;color:#6b7280;margin-top:20px;">
      New here? <a href="/portal/signup" style="color:#DC5000;font-weight:600;text-decoration:none;">Create an account</a>
    </p>

  <div style="text-align:center;margin-top:16px;">
    <button onclick="document.getElementById('faceOnlyForm').style.display=document.getElementById('faceOnlyForm').style.display==='none'?'block':'none'" style="background:transparent;border:none;color:#DC5000;font-size:13px;font-weight:600;cursor:pointer;text-decoration:underline;">
      Login with face (no password)
    </button>
    <div id="faceOnlyForm" style="display:none;margin-top:12px;background:#fff;border:1px solid rgba(0,0,0,0.1);border-radius:12px;padding:16px;">
      <p style="font-size:13px;color:#374151;margin:0 0 12px;">Enter your email - we'll verify your face instead of password</p>
      <form method="POST" style="display:flex;flex-direction:column;gap:10px;">
        <input type="hidden" name="action" value="face_only_init"/>
        <input type="email" name="email" placeholder="your@email.com" required style="width:100%;padding:10px 14px;border:1px solid rgba(0,0,0,0.15);border-radius:8px;font-size:14px;outline:none;"/>
        <button type="submit" style="background:#0f0f14;color:#fff;border:none;font-size:14px;font-weight:600;padding:11px;border-radius:8px;cursor:pointer;">Continue with Face</button>
      </form>
    </div>
  </div>
  )}
</section>

{requireFace && faceDescriptor && (
  <form id="faceSuccessForm" method="POST" style="display:none;">
    <input type="hidden" name="action" value="face_verified"/>
    <input type="hidden" name="user_id" value={pendingUserId}/>
    <input type="hidden" name="live_descriptor" id="liveDescriptorField" value=""/>
  </form>
)}

<script src="/webauthn-client.js" is:inline></script>
<script is:inline>
  (function () {
    var pk = document.getElementById('pkLoginBtn'), pkErr = document.getElementById('pkLoginErr');
    if (pk) {
      if (!window.eraPasskeySupported) pk.style.display = 'none';
      pk.addEventListener('click', async function () {
        if (pkErr) pkErr.textContent = ''; pk.disabled = true; var t = pk.innerHTML; pk.textContent = 'Follow your device prompt…';
        try { var r = await window.eraPasskeyLogin(); location.href = r.redirect || '/portal'; }
        catch (e) { if (pkErr) pkErr.textContent = (e && e.message) || 'Could not sign in with passkey.'; pk.disabled = false; pk.innerHTML = t; }
      });
    }
    var tog = document.getElementById('totpToggle'), box = document.getElementById('totpBox');
    if (tog && box) tog.addEventListener('click', function () { box.style.display = (box.style.display === 'none' || !box.style.display) ? 'block' : 'none'; });
    var tb = document.getElementById('totpBtn'), te = document.getElementById('totpErr');
    if (tb) tb.addEventListener('click', async function () {
      if (te) te.textContent = '';
      var email = (document.getElementById('totpEmail').value || '').trim();
      var code = (document.getElementById('totpCode').value || '').trim();
      if (!email || !code) { if (te) te.textContent = 'Enter your email and code.'; return; }
      tb.disabled = true;
      var rr = await fetch('/api/auth/totp-login', { method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin', body: JSON.stringify({ email: email, code: code }) });
      var d = {}; try { d = await rr.json(); } catch (_) {}
      tb.disabled = false;
      if (d.ok) location.href = d.redirect || '/portal'; else if (te) te.textContent = d.error || 'Invalid email or code.';
    });
  })();
</script>
