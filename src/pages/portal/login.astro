---
import BaseLayout from '@/layouts/BaseLayout.astro';

if (Astro.locals.user) {
  return Astro.redirect('/portal');
}

let errorMsg = '';
let activeTab = 'email';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const loginMethod = (fd.get('login_method') as string || 'email').trim();
  activeTab = loginMethod;

  const { db } = await import('@/lib/db');
  const { users, applications } = await import('@/lib/db/schema');
  const { verifyPassword } = await import('@/lib/auth/password');
  const { generateSessionToken, createSession } = await import('@/lib/auth/session');
  const { setSessionCookie } = await import('@/lib/auth/cookie');
  const { eq, and } = await import('drizzle-orm');

  if (loginMethod === 'email') {
    const email = (fd.get('email') as string || '').trim().toLowerCase();
    const password = fd.get('password') as string || '';
    if (!email || !password) {
      errorMsg = 'Email and password are required.';
    } else {
      const found = await db.select().from(users).where(eq(users.email, email)).limit(1);
      const user = found[0];
      if (!user || !user.isActive) {
        errorMsg = 'Invalid email or password.';
      } else {
        const valid = await verifyPassword(user.passwordHash, password);
        if (!valid) {
          errorMsg = 'Invalid email or password.';
        } else {
          const token = generateSessionToken();
          const session = await createSession(token, user.id, {
            userAgent: Astro.request.headers.get('user-agent') || undefined,
            ipAddress: Astro.clientAddress
          });
          setSessionCookie(Astro.cookies, token, session.expiresAt);
          await db.update(users).set({ lastLoginAt: new Date(), updatedAt: new Date() }).where(eq(users.id, user.id));
          if (user.role === 'applicant') return Astro.redirect('/portal');
          return Astro.redirect('/admin');
        }
      }
    }
  } else if (loginMethod === 'appnumber') {
    const appNumber = (fd.get('app_number') as string || '').trim().toUpperCase();
    const dob = (fd.get('dob') as string || '').trim();

    if (!appNumber || !dob) {
      errorMsg = 'Application number and date of birth are required.';
    } else {
      const appFound = await db.select().from(applications)
        .where(and(eq(applications.applicationNumber, appNumber), eq(applications.dob, dob)))
        .limit(1);
      const app = appFound[0];
      if (!app) {
        errorMsg = 'Invalid application number or date of birth.';
      } else if (!app.applicantUserId) {
        errorMsg = 'This application is not linked to a user account. Please contact support.';
      } else {
        const userFound = await db.select().from(users).where(eq(users.id, app.applicantUserId)).limit(1);
        const user = userFound[0];
        if (!user || !user.isActive) {
          errorMsg = 'Account inactive. Please contact support.';
        } else {
          const token = generateSessionToken();
          const session = await createSession(token, user.id, {
            userAgent: Astro.request.headers.get('user-agent') || undefined,
            ipAddress: Astro.clientAddress
          });
          setSessionCookie(Astro.cookies, token, session.expiresAt);
          await db.update(users).set({ lastLoginAt: new Date(), updatedAt: new Date() }).where(eq(users.id, user.id));
          return Astro.redirect('/portal');
        }
      }
    }
  }
}
---
<BaseLayout title="Sign in - EduRankAI Portal" description="Sign in to your EduRankAI applicant portal.">
  <section class="px-[5vw] py-16 md:py-20 max-w-md mx-auto">
    <div class="mb-8 text-center">
      <p class="eyebrow mb-3">Applicant Portal</p>
      <h1 class="font-display text-3xl md:text-4xl font-semibold text-ink leading-tight mb-3">
        Sign in
      </h1>
      <p class="text-[0.88rem] text-ink-soft">
        Track your applications. See real-time status.
      </p>
    </div>

    {errorMsg && (
      <div style="background:rgba(220,38,38,0.06);border:1px solid rgba(220,38,38,0.2);color:#b91c1c;font-size:0.85rem;padding:11px 14px;border-radius:8px;margin-bottom:18px;">
        {errorMsg}
      </div>
    )}

    <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-7">
      <div class="flex gap-2 mb-6 p-1 bg-cream-2 rounded-lg" style="border:1px solid rgba(0,0,0,0.05);">
        <button type="button" id="tab-email" class="flex-1 py-2 px-3 text-[0.82rem] font-semibold rounded-md transition-all">Email & Password</button>
        <button type="button" id="tab-appnumber" class="flex-1 py-2 px-3 text-[0.82rem] font-semibold rounded-md transition-all">App # & DOB</button>
      </div>

      <form method="POST" id="form-email" class="flex flex-col gap-5">
        <input type="hidden" name="login_method" value="email" />
        <div>
          <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Email</label>
          <input type="email" name="email" autocomplete="email" placeholder="you@example.com" class="w-full px-4 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
        </div>
        <div>
          <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Password</label>
          <input type="password" name="password" id="portal-login-pw" autocomplete="current-password" class="w-full px-4 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
        </div>
        <button type="submit" class="btn-primary w-full justify-center mt-2">Sign in</button>
      </form>

      <form method="POST" id="form-appnumber" class="flex flex-col gap-5" style="display:none;">
        <input type="hidden" name="login_method" value="appnumber" />
        <div>
          <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Application Number</label>
          <input type="text" name="app_number" placeholder="EDU-2026-00001" class="w-full px-4 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 uppercase" />
          <p class="text-[0.7rem] text-ink-soft mt-1">Format: EDU-2026-XXXXX (sent in your application confirmation)</p>
        </div>
        <div>
          <label class="block text-[0.7rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Date of Birth</label>
          <input type="date" name="dob" class="w-full px-4 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2" />
        </div>
        <button type="submit" class="btn-primary w-full justify-center mt-2">Sign in</button>
      </form>

      <div class="mt-5 pt-5 border-t border-ink/10 flex flex-col gap-2 text-center">
        <a href="/portal/forgot" class="text-[0.82rem] text-burn font-semibold hover:underline">Forgot details?</a>
      </div>
    </div>

    <p class="text-center text-[0.85rem] text-ink-soft mt-6">
      New here? <a href="/portal/signup" class="text-burn font-semibold hover:underline">Create an account</a>
    </p>
  </section>

  <script is:inline define:vars={{ initialTab: activeTab }}>
    const tabEmail = document.getElementById('tab-email');
    const tabAppNum = document.getElementById('tab-appnumber');
    const formEmail = document.getElementById('form-email');
    const formAppNum = document.getElementById('form-appnumber');

    function setTab(name) {
      if (name === 'email') {
        formEmail.style.display = 'flex';
        formAppNum.style.display = 'none';
        tabEmail.style.background = '#FF5C00';
        tabEmail.style.color = 'white';
        tabAppNum.style.background = 'transparent';
        tabAppNum.style.color = '#7A7068';
      } else {
        formEmail.style.display = 'none';
        formAppNum.style.display = 'flex';
        tabAppNum.style.background = '#FF5C00';
        tabAppNum.style.color = 'white';
        tabEmail.style.background = 'transparent';
        tabEmail.style.color = '#7A7068';
      }
    }

    tabEmail.addEventListener('click', () => setTab('email'));
    tabAppNum.addEventListener('click', () => setTab('appnumber'));

    setTab(initialTab || 'email');
  </script>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const inp = document.getElementById('portal-login-pw');
    if (!inp || inp.dataset.toggled) return;
    inp.dataset.toggled = '1';
    inp.style.paddingRight = '54px';
    const wrap = document.createElement('div');
    wrap.style.position = 'relative';
    inp.parentNode.insertBefore(wrap, inp);
    wrap.appendChild(inp);
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.textContent = 'Show';
    btn.style.cssText = 'position:absolute;right:8px;top:50%;transform:translateY(-50%);background:transparent;border:none;color:#6e6e78;cursor:pointer;font-size:11px;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;padding:6px;font-family:monospace;';
    btn.addEventListener('click', () => {
      const isPw = inp.type === 'password';
      inp.type = isPw ? 'text' : 'password';
      btn.textContent = isPw ? 'Hide' : 'Show';
    });
    wrap.appendChild(btn);
  });
</script>