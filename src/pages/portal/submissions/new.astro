---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { createSubmission, SUBMISSION_KIND_LABELS } from '@/lib/submissions';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

let successMsg = '', errorMsg = '';
let submittedId = '';

if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const kind = (fd.get('kind') as string || 'work_sample').toString();
    const title = (fd.get('title') as string || '').trim().slice(0, 300);
    const description = (fd.get('description') as string || '').trim().slice(0, 8000);
    const driveUrl = (fd.get('drive_url') as string || '').trim().slice(0, 2000) || undefined;
    const externalUrl = (fd.get('external_url') as string || '').trim().slice(0, 2000) || undefined;
    const platformRaw = (fd.get('platform') as string || 'direct').toString();
    const platform: any = ['direct', 'drive', 'github', 'other'].includes(platformRaw) ? platformRaw : 'direct';
    const targetRoleSlug = (fd.get('target_role_slug') as string || '').trim().slice(0, 120) || undefined;
    const wordCountRaw = parseInt((fd.get('word_count') as string || '0'), 10);
    const wordCount = isFinite(wordCountRaw) && wordCountRaw > 0 ? wordCountRaw : undefined;

    if (!title) errorMsg = 'Title is required.';
    else if (!description && !driveUrl && !externalUrl) errorMsg = 'Provide a description, drive link, or external URL — at least one must be present.';
    else {
      const submitterRole: any = user.role === 'campus_ambassador' ? 'campus_ambassador'
        : user.role === 'intern' ? 'intern'
        : user.role === 'employee' ? 'employee'
        : 'applicant';
      const r = await createSubmission({
        submitterUserId: user.id,
        submitterName: user.name || user.email,
        submitterEmail: user.email,
        submitterRole, kind, title, description,
        driveUrl, externalUrl, platform, wordCount, targetRoleSlug,
      });
      if (r.ok) { submittedId = r.id!; successMsg = 'Submission received. Our reviewers will respond within 5 working days.'; }
      else errorMsg = 'Submission failed.';
    }
  } catch (e: any) { errorMsg = String(e?.message || e).slice(0, 300); }
}

const isCA = user.role === 'campus_ambassador';
const defaultKind = isCA ? 'ca_report' : 'work_sample';
---
<BaseLayout title={isCA ? 'Submit your CA report' : 'Submit your work'} description="Submit original work for review by EduRankAI reviewers.">

<section class="px-[5vw] pt-12 md:pt-16 pb-8 max-w-3xl mx-auto">
  <p class="eyebrow mb-4">Portal · Submissions</p>
  <h1 class="font-display text-[clamp(2rem,4vw,3rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-4">
    {isCA ? <>Submit your <em class="italic text-burn font-medium">Campus Ambassador report</em></> : <>Submit your <em class="italic text-burn font-medium">original work</em></>}
  </h1>
  <p class="text-[0.98rem] text-ink-soft font-light leading-[1.85] max-w-2xl">
    {isCA
      ? 'Submit your period report — events organised, signups driven, classroom outreach, social posts. Attach proof via Drive link or platform URL.'
      : 'Submit original work for review. This becomes part of your applicant record and reviewers can issue a credential on the strength of it. Acceptable formats: Google Drive link, GitHub repo, Behance / Figma, or paste directly into the description.'}
  </p>
</section>

<section class="px-[5vw] pb-24 max-w-3xl mx-auto">

  {successMsg && (
    <div class="bg-leaf-bg border border-leaf-border rounded-2xl px-6 py-5 mb-6">
      <p class="text-[0.95rem] font-semibold text-leaf m-0">{successMsg}</p>
      {submittedId && <p class="text-[0.78rem] text-leaf/80 font-mono mt-2 m-0">Reference: {submittedId.slice(0, 8)}</p>}
      <p class="mt-3 m-0"><a href="/portal/submissions" class="text-[0.85rem] font-semibold text-leaf underline">View all my submissions &rarr;</a></p>
    </div>
  )}
  {errorMsg && <div class="bg-burn-pale border border-burn-dim rounded-2xl px-6 py-4 mb-6 text-[0.92rem] text-burn font-semibold">{errorMsg}</div>}

  <form method="POST" class="bg-white border border-ink/10 rounded-2xl p-8 md:p-10 space-y-6">

    <div>
      <label class="eyebrow block mb-2">What are you submitting? <span class="text-burn">*</span></label>
      <select name="kind" required class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink focus:border-burn focus:outline-none">
        {Object.entries(SUBMISSION_KIND_LABELS).map(([k, v]) => (
          <option value={k} selected={k === defaultKind}>{v.label} — {v.description}</option>
        ))}
      </select>
    </div>

    <div>
      <label class="eyebrow block mb-2">Title <span class="text-burn">*</span></label>
      <input name="title" type="text" required maxlength="300" placeholder={isCA ? 'e.g. Campus Ambassador Report — Q2 2026' : 'e.g. Compliance assessment for Brahmacarya regulation, India 2026'} class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink focus:border-burn focus:outline-none" />
    </div>

    <div>
      <label class="eyebrow block mb-2">Description / abstract</label>
      <textarea name="description" rows="6" maxlength="8000" placeholder={isCA ? 'Summary of work in this period: events organised, signups, classroom visits, social outreach. Include numbers.' : 'A short summary of your submission. What is it, why should we read it, what is the headline finding or output?'} class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink font-body leading-relaxed focus:border-burn focus:outline-none resize-y"></textarea>
    </div>

    <div class="bg-cream-2/50 border border-ink/8 rounded-2xl p-6">
      <p class="eyebrow mb-1">Attach evidence</p>
      <p class="text-[0.85rem] text-ink-soft font-light leading-relaxed mb-5">Provide at least one. Drive link is recommended for documents. External URL for portfolio submissions.</p>

      <label class="eyebrow block mb-2">Google Drive link</label>
      <input name="drive_url" type="url" maxlength="2000" placeholder="https://drive.google.com/..." class="w-full bg-white border border-ink/15 rounded-xl px-4 py-3 text-[0.9rem] text-ink mb-4 focus:border-burn focus:outline-none" />

      <label class="eyebrow block mb-2">External / platform URL (GitHub, Figma, Behance, YouTube)</label>
      <input name="external_url" type="url" maxlength="2000" placeholder="https://github.com/... or https://figma.com/..." class="w-full bg-white border border-ink/15 rounded-xl px-4 py-3 text-[0.9rem] text-ink mb-4 focus:border-burn focus:outline-none" />

      <label class="eyebrow block mb-2">Platform</label>
      <select name="platform" class="w-full bg-white border border-ink/15 rounded-xl px-4 py-3 text-[0.9rem] text-ink focus:border-burn focus:outline-none">
        <option value="direct">Direct (pasted in description)</option>
        <option value="drive">Google Drive</option>
        <option value="github">GitHub</option>
        <option value="other">Other</option>
      </select>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="eyebrow block mb-2">Word count (optional)</label>
        <input name="word_count" type="number" min="0" max="500000" placeholder="e.g. 2400" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink focus:border-burn focus:outline-none" />
      </div>
      <div>
        <label class="eyebrow block mb-2">Targeting a role? (slug, optional)</label>
        <input name="target_role_slug" type="text" maxlength="120" placeholder="e.g. compliance-analyst" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink focus:border-burn focus:outline-none" />
      </div>
    </div>

    <div class="flex flex-col md:flex-row md:items-center gap-3 pt-4 border-t border-ink/8">
      <button type="submit" class="btn-primary">Submit for review &rarr;</button>
      <p class="text-[0.78rem] text-ink-soft font-light leading-relaxed m-0">By submitting, you confirm this work is original. We retain the right to review, score, and reference it as part of your candidate or CAmb record.</p>
    </div>

  </form>

</section>
</BaseLayout>
