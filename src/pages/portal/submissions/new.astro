---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { createSubmission, SUBMISSION_KIND_LABELS } from '@/lib/submissions';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

let successMsg = '', errorMsg = '';
let submittedId = '';

if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const kind = (fd.get('kind') as string || 'work_sample').toString();
    const title = (fd.get('title') as string || '').trim().slice(0, 300);
    const description = (fd.get('description') as string || '').trim().slice(0, 8000);
    const driveUrl = (fd.get('drive_url') as string || '').trim().slice(0, 2000) || undefined;
    const externalUrl = (fd.get('external_url') as string || '').trim().slice(0, 2000) || undefined;
    const platformRaw = (fd.get('platform') as string || 'direct').toString();
    const platform: any = ['direct', 'drive', 'github', 'other'].includes(platformRaw) ? platformRaw : 'direct';
    const targetRoleSlug = (fd.get('target_role_slug') as string || '').trim().slice(0, 120) || undefined;

    const wordCountRaw = parseInt((fd.get('word_count') as string || '0'), 10);
    const wordCount = isFinite(wordCountRaw) && wordCountRaw > 0 ? wordCountRaw : undefined;

    if (!title) errorMsg = 'Title is required.';
    else if (!description && !driveUrl && !externalUrl) errorMsg = 'Provide a description, drive link, or external URL — at least one must be present.';
    else {
      // Detect submitter role from user.role (applicant or campus_ambassador if marked)
      const submitterRole: any = user.role === 'campus_ambassador' ? 'campus_ambassador'
        : user.role === 'intern' ? 'intern'
        : user.role === 'employee' ? 'employee'
        : 'applicant';

      const r = await createSubmission({
        submitterUserId: user.id,
        submitterName: user.name || user.email,
        submitterEmail: user.email,
        submitterRole,
        kind,
        title, description,
        driveUrl, externalUrl, platform, wordCount,
        targetRoleSlug,
      });
      if (r.ok) {
        submittedId = r.id!;
        successMsg = 'Submission received. Our reviewers will respond within 5 working days.';
      } else errorMsg = 'Submission failed.';
    }
  } catch (e: any) { errorMsg = String(e?.message || e).slice(0, 300); }
}

const isCA = user.role === 'campus_ambassador';
const defaultKind = isCA ? 'ca_report' : 'work_sample';
---
<BaseLayout title="Submit your work">
<div style="max-width:780px;margin:32px auto;padding:0 16px 80px;">
  <p style="font-size:10.5px;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;font-family:'Geist Mono',monospace;font-weight:700;">Submissions</p>
  <h1 style="font-size:28px;color:#fff;margin:8px 0 6px;font-weight:700;line-height:1.1;">{isCA ? 'Submit your Campus Ambassador report' : 'Submit your work'}</h1>
  <p style="font-size:14px;color:#9aa6b6;margin:0 0 24px;line-height:1.55;">
    {isCA
      ? 'Submit your period report — events organised, signups driven, classroom outreach, social posts. Attach proof: drive link, photos, posts, screenshots.'
: 'Submit original work for review. This becomes part of your applicant record and reviewers can issue a credential on the strength of it. Acceptable formats: Google Drive link, GitHub repo, Behance / Figma, or paste directly into the description box.'
    }
  </p>

  {successMsg && (
    <div style="background:rgba(74,222,128,0.10);border:1px solid rgba(74,222,128,0.32);color:#86efac;border-radius:12px;padding:14px 18px;margin-bottom:18px;">
      <p style="font-size:13.5px;font-weight:700;margin:0;">{successMsg}</p>
      {submittedId && <p style="font-size:11.5px;margin:6px 0 0;font-family:'Geist Mono',monospace;color:#86efac;opacity:0.85;">Reference: {submittedId.slice(0, 8)}</p>}
      <p style="margin:10px 0 0;"><a href="/portal/submissions" style="font-size:12px;color:#86efac;text-decoration:underline;font-weight:600;">View all my submissions →</a></p>
    </div>
  )}
  {errorMsg && <div style="background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.32);color:#fca5a5;border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;">{errorMsg}</div>}

  <form method="POST" style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:24px;display:grid;gap:14px;">

    <div>
      <label style="font-size:10.5px;color:#9aa6b6;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">What are you submitting? *</label>
      <select name="kind" required style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:10px 12px;border-radius:8px;font-size:13px;margin-top:5px;">
        {Object.entries(SUBMISSION_KIND_LABELS).map(([k, v]) => (
          <option value={k} selected={k === defaultKind}>{v.label} — {v.description}</option>
        ))}
      </select>
    </div>

    <div>
      <label style="font-size:10.5px;color:#9aa6b6;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">Title *</label>
      <input name="title" type="text" required maxlength="300" placeholder={isCA ? 'e.g. "Campus Ambassador Report — Q2 2026"' : 'e.g. "Compliance assessment for Brahmacarya regulation, India 2026"'} style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:10px 12px;border-radius:8px;font-size:13px;margin-top:5px;" />
    </div>

    <div>
      <label style="font-size:10.5px;color:#9aa6b6;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">Description / abstract</label>
      <textarea name="description" rows="6" maxlength="8000" placeholder={isCA ? 'Summary of work in this period: events organised, signups, classroom visits, social outreach. Include numbers.' : 'A short summary of your submission. What is it, why should we read it, what is the headline finding or output?'} style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:10px 12px;border-radius:8px;font-size:13px;margin-top:5px;font-family:'Inter Tight',sans-serif;resize:vertical;line-height:1.6;"></textarea>
    </div>

    <div style="background:#08080a;border:1px solid #1a1a1f;border-radius:10px;padding:14px;">
      <p style="font-size:11px;color:#FF7040;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;margin:0 0 10px;">Attach evidence</p>
      <p style="font-size:11.5px;color:#9aa6b6;margin:0 0 12px;line-height:1.55;">Provide at least one. Drive link is recommended for documents. External URL for portfolio submissions.</p>

      <label style="font-size:10.5px;color:#9aa6b6;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">Google Drive link</label>
      <input name="drive_url" type="url" maxlength="2000" placeholder="https://drive.google.com/..." style="width:100%;background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;margin:5px 0 12px;" />

      <label style="font-size:10.5px;color:#9aa6b6;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">External / platform URL (GitHub, Figma, Behance, YouTube)</label>
      <input name="external_url" type="url" maxlength="2000" placeholder="https://github.com/... or https://figma.com/..." style="width:100%;background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;margin:5px 0 12px;" />

      <label style="font-size:10.5px;color:#9aa6b6;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">Platform</label>
      <select name="platform" style="width:100%;background:#0f0f14;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;margin-top:5px;">
        <option value="direct">Direct (pasted in description)</option>
        <option value="drive">Google Drive</option>
        <option value="github">GitHub</option>
        <option value="other">Other</option>
      </select>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
      <div>
        <label style="font-size:10.5px;color:#9aa6b6;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">Word count (optional)</label>
        <input name="word_count" type="number" min="0" max="500000" placeholder="e.g. 2400" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;margin-top:5px;" />
      </div>
      <div>
        <label style="font-size:10.5px;color:#9aa6b6;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;font-family:'Geist Mono',monospace;">Targeting a role? (slug, optional)</label>
        <input name="target_role_slug" type="text" maxlength="120" placeholder="e.g. compliance-analyst" style="width:100%;background:#08080a;border:1px solid #2a2a2f;color:#fff;padding:9px 12px;border-radius:6px;font-size:12.5px;margin-top:5px;" />
      </div>
    </div>

    <button type="submit" style="background:#FF4F00;color:#fff;border:none;padding:13px 28px;border-radius:10px;font-size:13.5px;font-weight:800;cursor:pointer;letter-spacing:0.06em;text-transform:uppercase;font-family:'Geist Mono',monospace;justify-self:start;margin-top:8px;">Submit for review</button>

    <p style="font-size:11px;color:#6e6e78;margin:0;line-height:1.55;font-style:italic;">By submitting, you confirm this work is original. We retain the right to review, score, and reference it as part of your candidate or CA record.</p>
  </form>

</div>
</BaseLayout>
