---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { listSubmissions, SUBMISSION_KIND_LABELS } from '@/lib/submissions';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const subs = await listSubmissions({ submitterUserId: user.id, limit: 200 });

function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }); } catch { return ''; } }

const STATUS_LABELS: Record<string, { label: string; color: string; bg: string }> = {
  draft:                { label: 'Draft',               color: '#a0a0ab', bg: 'rgba(160,160,171,0.12)' },
  submitted:            { label: 'Submitted',           color: '#67e8f9', bg: 'rgba(34,211,238,0.12)' },
  under_review:         { label: 'Under review',        color: '#fbbf24', bg: 'rgba(251,191,36,0.12)' },
  approved:             { label: 'Approved',            color: '#86efac', bg: 'rgba(74,222,128,0.12)' },
  revisions_requested:  { label: 'Revisions requested', color: '#fb923c', bg: 'rgba(249,115,22,0.14)' },
  rejected:             { label: 'Not selected',        color: '#fca5a5', bg: 'rgba(239,68,68,0.12)' },
};
---
<BaseLayout title="My submissions">
<div style="max-width:960px;margin:32px auto;padding:0 16px 80px;">
  <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:18px;gap:12px;flex-wrap:wrap;">
    <div>
      <p style="font-size:10.5px;color:#FF7040;letter-spacing:0.12em;text-transform:uppercase;margin:0;font-family:'Geist Mono',monospace;font-weight:700;">Submissions</p>
      <h1 style="font-size:28px;color:#fff;margin:6px 0 4px;font-weight:700;">My submissions</h1>
      <p style="font-size:13px;color:#9aa6b6;margin:0;">{subs.length} on file</p>
    </div>
    <a href="/portal/submissions/new" style="background:#FF4F00;color:#fff;border:none;padding:11px 22px;border-radius:10px;font-size:13px;font-weight:800;text-decoration:none;letter-spacing:0.06em;text-transform:uppercase;font-family:'Geist Mono',monospace;">+ New submission</a>
  </div>

  {subs.length === 0 ? (
    <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:14px;padding:48px;text-align:center;">
      <p style="font-size:14px;color:#9aa6b6;margin:0;">No submissions yet. Start by submitting your first piece of work — it becomes part of your record and increases your chances of selection.</p>
      <a href="/portal/submissions/new" style="display:inline-block;margin-top:18px;background:#FF4F00;color:#fff;padding:11px 22px;border-radius:10px;font-size:13px;font-weight:800;text-decoration:none;letter-spacing:0.06em;text-transform:uppercase;font-family:'Geist Mono',monospace;">Submit now</a>
    </div>
  ) : (
    <div style="display:flex;flex-direction:column;gap:10px;">
      {subs.map((s: any) => {
        const kindMeta = SUBMISSION_KIND_LABELS[s.kind] || SUBMISSION_KIND_LABELS.other;
        const stMeta = STATUS_LABELS[s.status] || STATUS_LABELS.submitted;
        return (
          <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;padding:18px;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap;margin-bottom:8px;">
              <div>
                <div style="display:flex;gap:8px;align-items:center;margin-bottom:4px;">
                  <span style={`background:${kindMeta.accent}22;color:${kindMeta.accent};font-size:10px;font-weight:700;padding:3px 9px;border-radius:100px;font-family:'Geist Mono',monospace;letter-spacing:0.06em;text-transform:uppercase;`}>{kindMeta.label}</span>
                  <span style={`background:${stMeta.bg};color:${stMeta.color};font-size:10px;font-weight:700;padding:3px 9px;border-radius:100px;font-family:'Geist Mono',monospace;letter-spacing:0.06em;text-transform:uppercase;`}>{stMeta.label}</span>
                </div>
                <h3 style="font-size:16px;color:#fff;margin:0;font-weight:700;line-height:1.3;">{s.title}</h3>
              </div>
              <span style="font-size:11px;color:#6e6e78;font-family:'Geist Mono',monospace;white-space:nowrap;">{fmt(s.submitted_at)}</span>
            </div>
            {s.description && <p style="font-size:12.5px;color:#cfd6da;margin:6px 0 8px;line-height:1.6;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{s.description}</p>}
            <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:8px;">
              {s.drive_url && <a href={s.drive_url} target="_blank" style="font-size:11px;color:#67e8f9;text-decoration:none;font-family:'Geist Mono',monospace;display:inline-flex;align-items:center;gap:5px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12.5 3.5l3.5 6L19 16h-3.5L12.5 9.5 9.5 16H6l3-6.5L12.5 3.5z"/></svg> Drive</a>}
              {s.external_url && <a href={s.external_url} target="_blank" style="font-size:11px;color:#86efac;text-decoration:none;font-family:'Geist Mono',monospace;display:inline-flex;align-items:center;gap:5px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg> {s.platform || 'External'}</a>}
              {s.score_pct != null && <span style="font-size:11px;color:#FF7040;font-weight:700;font-family:'Geist Mono',monospace;">Score: {Number(s.score_pct).toFixed(1)}%</span>}
            </div>
            {s.review_notes && (
              <div style="margin-top:10px;padding:10px 14px;background:#08080a;border-left:3px solid #FF7040;border-radius:0 6px 6px 0;">
                <p style="font-size:10.5px;color:#FF7040;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;font-family:'Geist Mono',monospace;margin:0 0 4px;">Reviewer notes</p>
                <p style="font-size:12px;color:#cfd6da;margin:0;line-height:1.55;white-space:pre-wrap;">{s.review_notes}</p>
              </div>
            )}
          </div>
        );
      })}
    </div>
  )}
</div>
</BaseLayout>
