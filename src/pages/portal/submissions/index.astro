---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { listSubmissions, SUBMISSION_KIND_LABELS } from '@/lib/submissions';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const subs = await listSubmissions({ submitterUserId: user.id, limit: 200 });

function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day:'2-digit', month:'short', year:'numeric' }); } catch { return ''; } }

const STATUS_META: Record<string, { label: string; tone: string }> = {
  draft:                { label: 'Draft',               tone: 'neutral' },
  submitted:            { label: 'Submitted',           tone: 'sky' },
  under_review:         { label: 'Under review',        tone: 'gold' },
  approved:             { label: 'Approved',            tone: 'leaf' },
  revisions_requested:  { label: 'Revisions requested', tone: 'burn' },
  rejected:             { label: 'Not selected',        tone: 'plum' },
};
const TONE_CLASSES: Record<string, string> = {
  neutral: 'bg-cream-2 text-ink-soft border-ink/10',
  sky:     'bg-sky-bg text-sky border-sky-border',
  gold:    'bg-gold-bg text-gold-deep border-gold-border',
  leaf:    'bg-leaf-bg text-leaf border-leaf-border',
  burn:    'bg-burn-pale text-burn border-burn-dim',
  plum:    'bg-plum-bg text-plum border-plum-border',
};
---
<BaseLayout title="My submissions">

<section class="px-[5vw] pt-12 md:pt-16 pb-6 max-w-4xl mx-auto">
  <div class="flex justify-between items-end gap-6 flex-wrap">
    <div>
      <p class="eyebrow mb-4">Portal · Submissions</p>
      <h1 class="font-display text-[clamp(2rem,4vw,2.8rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-2">
        My <em class="italic text-burn font-medium">submissions</em>
      </h1>
      <p class="text-[0.95rem] text-ink-soft font-light">{subs.length} on file</p>
    </div>
    <a href="/portal/submissions/new" class="btn-primary">+ New submission</a>
  </div>
</section>

<section class="px-[5vw] pb-24 max-w-4xl mx-auto">

  {subs.length === 0 ? (
    <div class="bg-white border border-ink/10 rounded-2xl p-12 text-center">
      <p class="font-display text-[1.4rem] font-semibold text-ink mb-3">Nothing yet</p>
      <p class="text-[0.95rem] text-ink-soft font-light leading-relaxed max-w-md mx-auto mb-6">Submit your first piece of work — it becomes part of your record and strengthens your candidacy.</p>
      <a href="/portal/submissions/new" class="btn-primary">Submit now</a>
    </div>
  ) : (
    <div class="space-y-3">
      {subs.map((s: any) => {
        const kindMeta = SUBMISSION_KIND_LABELS[s.kind] || SUBMISSION_KIND_LABELS.other;
        const stMeta = STATUS_META[s.status] || STATUS_META.submitted;
        const stCls = TONE_CLASSES[stMeta.tone] || TONE_CLASSES.neutral;
        return (
          <article class="bg-white border border-ink/10 rounded-2xl p-6 hover:border-burn-dim transition-all">
            <div class="flex justify-between items-start gap-4 flex-wrap mb-3">
              <div class="flex-1 min-w-0">
                <div class="flex gap-2 items-center mb-2 flex-wrap">
                  <span class="font-mono text-[0.62rem] uppercase tracking-[0.14em] font-bold px-2.5 py-1 rounded-full bg-burn-pale text-burn border border-burn-dim">{kindMeta.label}</span>
                  <span class={`font-mono text-[0.62rem] uppercase tracking-[0.14em] font-bold px-2.5 py-1 rounded-full border ${stCls}`}>{stMeta.label}</span>
                </div>
                <h3 class="font-display text-[1.15rem] font-semibold text-ink leading-snug m-0">{s.title}</h3>
              </div>
              <span class="font-mono text-[0.72rem] text-ink-soft whitespace-nowrap">{fmt(s.submitted_at)}</span>
            </div>
            {s.description && <p class="text-[0.88rem] text-ink-2 font-light leading-relaxed mb-3 line-clamp-2">{s.description}</p>}
            <div class="flex gap-4 flex-wrap items-center">
              {s.drive_url && <a href={s.drive_url} target="_blank" class="text-[0.8rem] font-mono text-burn font-semibold inline-flex items-center gap-1.5 hover:underline"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12.5 3.5l3.5 6L19 16h-3.5L12.5 9.5 9.5 16H6l3-6.5L12.5 3.5z"/></svg>Drive</a>}
              {s.external_url && <a href={s.external_url} target="_blank" class="text-[0.8rem] font-mono text-sky font-semibold inline-flex items-center gap-1.5 hover:underline"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>{s.platform || 'External'}</a>}
              {s.score_pct != null && <span class="text-[0.8rem] font-mono font-bold text-burn">Score: {Number(s.score_pct).toFixed(1)}%</span>}
            </div>
            {s.review_notes && (
              <div class="mt-4 bg-cream-2/60 border-l-2 border-burn px-4 py-3 rounded-r-lg">
                <p class="eyebrow mb-1">Reviewer notes</p>
                <p class="text-[0.85rem] text-ink-2 font-light leading-relaxed whitespace-pre-wrap m-0">{s.review_notes}</p>
              </div>
            )}
          </article>
        );
      })}
    </div>
  )}

</section>
</BaseLayout>
