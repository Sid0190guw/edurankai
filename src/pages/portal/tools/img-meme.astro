---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/img-meme'));
---
<BaseLayout title="Meme generator · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-sky font-bold mb-2">Image · Meme</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Meme generator</h1>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="image/*" class="block w-full text-[0.92rem] file:bg-sky file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Top text</span><input id="top" type="text" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink uppercase" /></label>
    <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Bottom text</span><input id="bot" type="text" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink uppercase" /></label>
    <button id="goBtn" class="bg-sky hover:bg-sky/90 text-white font-semibold py-3 px-6 rounded-xl text-[0.92rem]" disabled style="opacity:0.5;">Make meme & download</button>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
  </div>
</section>
<script is:inline>
  (function () {
    var file = null;
    document.getElementById('fileInput').addEventListener('change', function (e) { file = e.target.files[0]; document.getElementById('goBtn').disabled = !file; document.getElementById('goBtn').style.opacity = file ? '1' : '0.5'; });
    document.getElementById('goBtn').addEventListener('click', function () {
      if (!file) return;
      var img = new Image();
      img.onload = function () {
        var c = document.createElement('canvas'); c.width = img.naturalWidth; c.height = img.naturalHeight; var ctx = c.getContext('2d');
        ctx.drawImage(img, 0, 0);
        var sz = Math.round(c.width / 12);
        ctx.font = 'bold ' + sz + 'px Impact, "Arial Black", sans-serif'; ctx.textAlign = 'center'; ctx.lineWidth = Math.max(2, sz / 12); ctx.strokeStyle = '#000'; ctx.fillStyle = '#fff';
        var top = (document.getElementById('top').value || '').toUpperCase(); var bot = (document.getElementById('bot').value || '').toUpperCase();
        if (top) { ctx.strokeText(top, c.width / 2, sz + 10); ctx.fillText(top, c.width / 2, sz + 10); }
        if (bot) { ctx.strokeText(bot, c.width / 2, c.height - 14); ctx.fillText(bot, c.width / 2, c.height - 14); }
        c.toBlob(function (blob) { var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'meme-' + Date.now() + '.png'; a.click(); document.getElementById('status').textContent = 'Done.'; }, 'image/png');
      };
      img.src = URL.createObjectURL(file);
    });
  })();
</script>
</BaseLayout>
