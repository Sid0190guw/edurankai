---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/img-meme'));
---
<BaseLayout title="Meme generator · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-4xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-sky hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-sky font-bold mb-2">Image · Meme</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Meme generator</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Classic top/bottom captions with a live preview. Text wraps automatically, stays crisp at full resolution, and never leaves your browser.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-4xl mx-auto">
  <div class="grid md:grid-cols-[1fr,300px] gap-6 items-start">
    <!-- Preview -->
    <div class="bg-white border border-ink/10 rounded-2xl p-4 md:p-5">
      <label for="fileInput" id="dropZone" class="block border-2 border-dashed border-sky/40 rounded-xl px-6 py-12 text-center cursor-pointer hover:bg-sky/5 transition-colors">
        <svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" style="margin:0 auto 8px;"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.09-3.09a2 2 0 0 0-2.82 0L6 21"/></svg>
        <p class="font-display text-[1.05rem] font-semibold text-ink m-0">Choose an image</p>
        <p class="text-[0.82rem] text-ink-soft m-0 mt-1">Click to browse or drop it here</p>
        <input type="file" id="fileInput" accept="image/*" style="display:none;" />
      </label>
      <div id="canvasWrap" style="display:none;">
        <canvas id="canvas" style="max-width:100%;height:auto;display:block;margin:0 auto;border-radius:8px;"></canvas>
      </div>
    </div>

    <!-- Controls -->
    <div class="bg-white border border-ink/10 rounded-2xl p-5 space-y-4">
      <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-1.5 block">Top text</span><input id="top" type="text" class="w-full bg-cream border border-ink/15 rounded-lg px-3 py-2 text-[0.9rem] text-ink" /></label>
      <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-1.5 block">Bottom text</span><input id="bot" type="text" class="w-full bg-cream border border-ink/15 rounded-lg px-3 py-2 text-[0.9rem] text-ink" /></label>
      <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-1.5 block">Font size <span id="szVal" class="text-sky">10%</span></span><input id="size" type="range" min="5" max="18" value="10" class="w-full accent-sky" /></label>
      <div class="grid grid-cols-2 gap-3">
        <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-1.5 block">Text</span><input id="fill" type="color" value="#ffffff" class="w-full h-9 rounded-lg border border-ink/15 bg-cream cursor-pointer" /></label>
        <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-1.5 block">Outline</span><input id="stroke" type="color" value="#000000" class="w-full h-9 rounded-lg border border-ink/15 bg-cream cursor-pointer" /></label>
      </div>
      <label class="flex items-center gap-2 cursor-pointer"><input id="caps" type="checkbox" checked class="accent-sky w-4 h-4" /><span class="text-[0.85rem] text-ink-2">Uppercase</span></label>
      <button id="dlBtn" class="w-full bg-sky hover:bg-sky/90 text-white font-semibold py-2.5 px-6 rounded-xl text-[0.9rem]" disabled style="opacity:0.5;">Download meme</button>
      <p id="status" class="text-[0.8rem] text-ink-soft m-0 text-center"></p>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var img = null, fi = document.getElementById('fileInput'), dz = document.getElementById('dropZone');
    var canvas = document.getElementById('canvas'), wrap = document.getElementById('canvasWrap');
    var els = ['top','bot','size','fill','stroke','caps'].map(function(id){ return document.getElementById(id); });
    var status = document.getElementById('status'), dlBtn = document.getElementById('dlBtn'), szVal = document.getElementById('szVal');

    ['dragover','dragenter'].forEach(function(ev){ dz.addEventListener(ev, function(e){ e.preventDefault(); dz.classList.add('bg-sky/5'); }); });
    ['dragleave','drop'].forEach(function(ev){ dz.addEventListener(ev, function(e){ e.preventDefault(); dz.classList.remove('bg-sky/5'); }); });
    dz.addEventListener('drop', function(e){ if (e.dataTransfer.files[0]) loadFile(e.dataTransfer.files[0]); });
    fi.addEventListener('change', function(){ if (fi.files[0]) loadFile(fi.files[0]); });

    function loadFile(file) {
      var im = new Image();
      im.onload = function () { img = im; wrap.style.display = 'block'; dz.style.padding = '18px'; dlBtn.disabled = false; dlBtn.style.opacity = '1'; draw(); };
      im.src = URL.createObjectURL(file);
    }

    function wrapText(ctx, text, maxWidth) {
      var words = text.split(/\s+/), lines = [], cur = '';
      for (var i = 0; i < words.length; i++) {
        var test = cur ? cur + ' ' + words[i] : words[i];
        if (ctx.measureText(test).width > maxWidth && cur) { lines.push(cur); cur = words[i]; }
        else cur = test;
      }
      if (cur) lines.push(cur);
      return lines;
    }

    function drawBlock(ctx, text, W, H, top, sz) {
      if (!text) return;
      var pad = W * 0.04, maxW = W - pad * 2;
      var lines = wrapText(ctx, text, maxW);
      var lh = sz * 1.1;
      for (var i = 0; i < lines.length; i++) {
        var y = top ? (pad + sz + i * lh) : (H - pad - (lines.length - 1 - i) * lh);
        ctx.strokeText(lines[i], W / 2, y);
        ctx.fillText(lines[i], W / 2, y);
      }
    }

    function draw() {
      if (!img) return;
      var W = img.naturalWidth, H = img.naturalHeight;
      canvas.width = W; canvas.height = H;
      var ctx = canvas.getContext('2d');
      ctx.drawImage(img, 0, 0, W, H);
      var pct = parseInt(els[2].value, 10); szVal.textContent = pct + '%';
      var sz = Math.round(W * pct / 100);
      ctx.font = '900 ' + sz + 'px Impact, "Arial Black", Haettenschweiler, sans-serif';
      ctx.textAlign = 'center'; ctx.textBaseline = 'alphabetic';
      ctx.lineWidth = Math.max(2, sz / 10); ctx.lineJoin = 'round';
      ctx.strokeStyle = els[4].value; ctx.fillStyle = els[3].value;
      var caps = els[5].checked;
      var t = els[0].value || '', b = els[1].value || '';
      if (caps) { t = t.toUpperCase(); b = b.toUpperCase(); }
      drawBlock(ctx, t, W, H, true, sz);
      drawBlock(ctx, b, W, H, false, sz);
    }

    els.forEach(function (el) { el.addEventListener('input', draw); el.addEventListener('change', draw); });

    dlBtn.addEventListener('click', function () {
      if (!img) return;
      canvas.toBlob(function (blob) {
        var a = document.createElement('a'); a.href = URL.createObjectURL(blob);
        a.download = 'meme-' + Date.now() + '.png'; a.click();
        status.textContent = 'Downloaded (' + (blob.size / 1024).toFixed(0) + ' KB).';
      }, 'image/png');
    });
  })();
</script>
</BaseLayout>
