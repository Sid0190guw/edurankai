---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/notebook'));
---
<BaseLayout title="Notebook · EduRankAI Tools" description="A Colab-style cell notebook. Code cells run JavaScript in a sandboxed evaluator. Markdown cells render inline. Outputs persist.">

<style>
  body { background: #FAF8F5; }
  .nb-wrap { max-width: 920px; margin: 0 auto; padding: 16px; }
  .nb-top { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid rgba(14,11,8,0.10); flex-wrap: wrap; gap: 10px; }
  .nb-title { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 600; margin: 0; color: #0E0B08; }
  .nb-title em { font-style: italic; color: #FF4F00; font-weight: 500; }
  .nb-meta { font-family: 'Geist Mono', monospace; font-size: 11px; color: #7A6F68; letter-spacing: 0.08em; }
  .nb-action { background: #FF4F00; color: #fff; border: none; padding: 8px 16px; border-radius: 6px; font-weight: 700; cursor: pointer; font-size: 12px; font-family: 'Geist Mono', monospace; letter-spacing: 0.06em; text-transform: uppercase; }
  .nb-action.ghost { background: transparent; color: #0E0B08; border: 1px solid rgba(14,11,8,0.15); }

  .nb-cell { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 10px; margin: 16px 0; overflow: hidden; }
  .nb-cell-head { background: #f7f3ea; padding: 6px 12px; display: flex; justify-content: space-between; align-items: center; font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #7A6F68; font-weight: 700; border-bottom: 1px solid rgba(14,11,8,0.06); }
  .nb-cell-head .actions { display: flex; gap: 4px; }
  .nb-cell-head button { background: transparent; border: 1px solid rgba(14,11,8,0.15); padding: 2px 8px; border-radius: 4px; cursor: pointer; font-size: 10.5px; color: #0E0B08; font-family: inherit; }
  .nb-cell-head button:hover { background: #fff; }

  .nb-input { width: 100%; box-sizing: border-box; background: #fff; border: none; padding: 12px 14px; font-family: ui-monospace, monospace; font-size: 13.5px; line-height: 1.6; outline: none; color: #0E0B08; resize: vertical; min-height: 60px; }
  .nb-input.markdown { font-family: 'DM Sans', sans-serif; }

  .nb-output { background: #f7f3ea; padding: 10px 14px; border-top: 1px solid rgba(14,11,8,0.06); font-family: ui-monospace, monospace; font-size: 13px; line-height: 1.55; color: #0E0B08; white-space: pre-wrap; word-wrap: break-word; }
  .nb-output.error { background: rgba(239,68,68,0.06); color: #b91c1c; }
  .nb-output.md { font-family: 'DM Sans', sans-serif; padding: 14px 18px; background: #fff; }
  .nb-output.md h1, .nb-output.md h2, .nb-output.md h3 { font-family: 'Cormorant Garamond', serif; margin: 12px 0 6px; line-height: 1.2; }
  .nb-output.md h1 { font-size: 28px; }
  .nb-output.md h2 { font-size: 22px; }
  .nb-output.md h3 { font-size: 18px; }
  .nb-output.md p { margin: 8px 0; }
  .nb-output.md code { background: #f3efe8; padding: 1px 5px; border-radius: 3px; font-family: ui-monospace, monospace; font-size: 13px; }
  .nb-output.md pre { background: #08080a; color: #cfd6da; padding: 12px; border-radius: 6px; overflow-x: auto; }

  .nb-add { display: flex; gap: 6px; justify-content: center; padding: 6px; }
  .nb-add button { background: #fff; border: 1px solid rgba(14,11,8,0.15); border-radius: 6px; padding: 4px 12px; cursor: pointer; font-size: 11.5px; color: #0E0B08; font-family: 'Geist Mono', monospace; letter-spacing: 0.06em; text-transform: uppercase; }
  .nb-add button:hover { background: #FFF3EE; border-color: #FF4F00; color: #FF4F00; }

  .nb-run { background: #FF4F00; color: #fff; border: none; padding: 4px 10px; border-radius: 4px; cursor: pointer; font-size: 10.5px; font-weight: 700; font-family: 'Geist Mono', monospace; letter-spacing: 0.06em; text-transform: uppercase; }

  /* Chart preview */
  .nb-chart { background: #fff; padding: 12px; margin: 8px 0; border-radius: 6px; border: 1px solid rgba(14,11,8,0.06); }
</style>

<div class="nb-wrap">

  <div class="nb-top">
    <div>
      <p style="font-family:'Geist Mono',monospace;font-size:11px;letter-spacing:0.18em;text-transform:uppercase;color:#FF4F00;margin:0;font-weight:700;">EduRankAI · Notebook</p>
      <h1 class="nb-title" id="nbTitle" contenteditable="true">Untitled <em>notebook</em></h1>
    </div>
    <div style="display:flex;gap:6px;">
      <button class="nb-action ghost" id="downloadBtn">Download .json</button>
      <button class="nb-action ghost" id="loadBtn">Load .json</button>
      <input type="file" id="loadFile" accept=".json" style="display:none;"/>
      <button class="nb-action" id="runAllBtn">Run all</button>
    </div>
  </div>

  <p class="nb-meta">Cells run in a sandboxed JS evaluator. <code>print(x)</code> shows on next line. <code>chart(arr)</code> renders a bar chart. <code>table(data)</code> renders a table.</p>

  <div id="cells"></div>

  <div class="nb-add">
    <button data-kind="code">+ Code cell</button>
    <button data-kind="markdown">+ Markdown cell</button>
  </div>
</div>

<script is:inline>
  /* ============================================================
     EduRankAI Notebook — Colab-style, built from scratch.
     - Code cells run user JS in a Function() sandbox
     - print(), chart(), table() helpers
     - Markdown cells render to safe HTML (subset)
     - Whole notebook persists to localStorage; .json export/import
     ============================================================ */
  (function () {
    var KEY = 'era_notebook_v1';
    var nb = { title: 'Untitled notebook', cells: [
      { id: c(), kind: 'markdown', src: '# Welcome\n\nThis is a hand-built notebook. Code cells run **JavaScript** in your browser.\n\n## Helpers\n\n- `print(x)` prints to the output\n- `chart([1,2,3,4,5])` draws a bar chart\n- `table([{a:1,b:2},{a:3,b:4}])` renders a table' },
      { id: c(), kind: 'code', src: 'print("Hello from a notebook cell!");\nvar primes = [];\nfor (var n = 2; n <= 50; n++) {\n  var ok = true;\n  for (var i = 2; i * i <= n; i++) if (n % i === 0) { ok = false; break; }\n  if (ok) primes.push(n);\n}\nprint("Primes up to 50:", primes.join(", "));\nchart(primes.slice(0, 10));' },
      { id: c(), kind: 'code', src: 'var rows = [];\nfor (var i = 1; i <= 5; i++) {\n  rows.push({ n: i, square: i*i, cube: i*i*i });\n}\ntable(rows);' },
    ]};
    function c() { return 'c' + Math.random().toString(36).slice(2, 9); }
    try { var s = localStorage.getItem(KEY); if (s) nb = JSON.parse(s); } catch (_) {}
    function save() { try { localStorage.setItem(KEY, JSON.stringify(nb)); } catch (_) {} }

    var $ = function (id) { return document.getElementById(id); };
    $('nbTitle').textContent = nb.title.replace(/notebook$/, '').trim() || 'Untitled';
    $('nbTitle').addEventListener('blur', function () { nb.title = ($('nbTitle').textContent || '').trim() + ' notebook'; save(); });

    function renderAll() {
      var root = $('cells'); root.innerHTML = '';
      nb.cells.forEach(function (cell) { root.appendChild(renderCell(cell)); });
    }

    function renderCell(cell) {
      var el = document.createElement('div');
      el.className = 'nb-cell'; el.id = cell.id;
      var head = document.createElement('div'); head.className = 'nb-cell-head';
      var label = document.createElement('span'); label.textContent = cell.kind === 'code' ? 'Code · JS' : 'Markdown'; head.appendChild(label);
      var actions = document.createElement('div'); actions.className = 'actions';
      if (cell.kind === 'code') { var run = document.createElement('button'); run.className = 'nb-run'; run.textContent = 'Run'; run.addEventListener('click', function () { runCell(cell, el); }); actions.appendChild(run); }
      else { var prev = document.createElement('button'); prev.textContent = 'Render'; prev.addEventListener('click', function () { renderMd(cell, el); }); actions.appendChild(prev); }
      var up = document.createElement('button'); up.textContent = '↑'; up.addEventListener('click', function () { move(cell.id, -1); }); actions.appendChild(up);
      var dn = document.createElement('button'); dn.textContent = '↓'; dn.addEventListener('click', function () { move(cell.id, 1); }); actions.appendChild(dn);
      var del = document.createElement('button'); del.textContent = '×'; del.addEventListener('click', function () { remove(cell.id); }); actions.appendChild(del);
      head.appendChild(actions);
      el.appendChild(head);

      var ta = document.createElement('textarea');
      ta.className = 'nb-input' + (cell.kind === 'markdown' ? ' markdown' : '');
      ta.value = cell.src;
      ta.rows = Math.max(3, cell.src.split('\n').length);
      ta.addEventListener('input', function () { cell.src = ta.value; save(); ta.rows = Math.max(3, cell.src.split('\n').length); });
      ta.addEventListener('keydown', function (e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') { e.preventDefault(); cell.kind === 'code' ? runCell(cell, el) : renderMd(cell, el); }
      });
      el.appendChild(ta);

      if (cell.output) {
        var outEl = document.createElement('div');
        outEl.className = 'nb-output' + (cell.outputError ? ' error' : '') + (cell.kind === 'markdown' ? ' md' : '');
        outEl.innerHTML = cell.output;
        el.appendChild(outEl);
      }
      return el;
    }

    function runCell(cell, el) {
      var outputs = [];
      var sandbox = {
        print: function () { outputs.push(Array.from(arguments).map(function (a) { return typeof a === 'object' ? JSON.stringify(a) : String(a); }).join(' ')); },
        chart: function (arr) {
          if (!Array.isArray(arr) || arr.length === 0) return;
          var max = Math.max.apply(null, arr.map(Number));
          var bars = arr.map(function (v) { return '<div style="display:flex;align-items:center;gap:8px;margin:2px 0;"><span style="width:30px;text-align:right;font-family:ui-monospace,monospace;font-size:11px;color:#7A6F68;">' + v + '</span><div style="background:#FF4F00;height:14px;width:' + ((Number(v) / max) * 100) + '%;border-radius:2px;"></div></div>'; }).join('');
          outputs.push('<div class="nb-chart">' + bars + '</div>');
        },
        table: function (data) {
          if (!Array.isArray(data) || data.length === 0) return;
          var keys = Object.keys(data[0]);
          var head = '<tr>' + keys.map(function (k) { return '<th style="padding:6px 12px;text-align:left;border-bottom:2px solid rgba(14,11,8,0.15);font-family:Geist Mono;font-size:11px;text-transform:uppercase;letter-spacing:0.08em;">' + k + '</th>'; }).join('') + '</tr>';
          var body = data.map(function (row) { return '<tr>' + keys.map(function (k) { return '<td style="padding:5px 12px;border-bottom:1px solid rgba(14,11,8,0.06);font-family:ui-monospace,monospace;font-size:12.5px;">' + row[k] + '</td>'; }).join('') + '</tr>'; }).join('');
          outputs.push('<div class="nb-chart"><table style="width:100%;border-collapse:collapse;">' + head + body + '</table></div>');
        },
        Math: Math, JSON: JSON, Object: Object, Array: Array, String: String, Number: Number, Boolean: Boolean,
      };
      try {
        var fn = new Function('print', 'chart', 'table', 'Math', 'JSON', cell.src);
        fn(sandbox.print, sandbox.chart, sandbox.table, Math, JSON);
        cell.output = outputs.length === 0 ? '<span style="color:#7A6F68;">(no output)</span>' : outputs.join('\n');
        cell.outputError = false;
      } catch (e) {
        cell.output = String(e.message || e);
        cell.outputError = true;
      }
      save();
      el.replaceWith(renderCell(cell));
    }

    function renderMd(cell, el) {
      cell.output = renderMarkdown(cell.src);
      cell.outputError = false;
      save();
      el.replaceWith(renderCell(cell));
    }

    function renderMarkdown(src) {
      var esc = (src || '').replace(/[<>&]/g, function (c) { return { '<':'&lt;','>':'&gt;','&':'&amp;' }[c]; });
      // headings
      esc = esc.replace(/^###### (.+)$/gm, '<h6>$1</h6>')
               .replace(/^##### (.+)$/gm, '<h5>$1</h5>')
               .replace(/^#### (.+)$/gm, '<h4>$1</h4>')
               .replace(/^### (.+)$/gm, '<h3>$1</h3>')
               .replace(/^## (.+)$/gm, '<h2>$1</h2>')
               .replace(/^# (.+)$/gm, '<h1>$1</h1>');
      // bold + italic + code
      esc = esc.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
               .replace(/\*(.+?)\*/g, '<em>$1</em>')
               .replace(/`(.+?)`/g, '<code>$1</code>');
      // lists
      esc = esc.replace(/^- (.+)$/gm, '<li>$1</li>');
      esc = esc.replace(/(<li>[\s\S]+?<\/li>)/g, '<ul>$1</ul>');
      // paragraphs
      esc = esc.split('\n\n').map(function (p) { return p.match(/^<(h\d|ul|li|pre)/) ? p : '<p>' + p.replace(/\n/g, '<br/>') + '</p>'; }).join('\n');
      return esc;
    }

    function move(id, dir) {
      var i = nb.cells.findIndex(function (x) { return x.id === id; });
      var j = i + dir; if (j < 0 || j >= nb.cells.length) return;
      var tmp = nb.cells[i]; nb.cells[i] = nb.cells[j]; nb.cells[j] = tmp;
      save(); renderAll();
    }
    function remove(id) {
      nb.cells = nb.cells.filter(function (x) { return x.id !== id; });
      save(); renderAll();
    }
    function add(kind) { nb.cells.push({ id: c(), kind: kind, src: '' }); save(); renderAll(); }

    document.querySelectorAll('.nb-add button').forEach(function (b) { b.addEventListener('click', function () { add(b.getAttribute('data-kind')); }); });

    $('runAllBtn').addEventListener('click', function () {
      nb.cells.forEach(function (cell) {
        if (cell.kind === 'code') runCell(cell, document.getElementById(cell.id));
        else renderMd(cell, document.getElementById(cell.id));
      });
    });

    $('downloadBtn').addEventListener('click', function () {
      var blob = new Blob([JSON.stringify(nb, null, 2)], { type: 'application/json' });
      var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = (nb.title || 'notebook') + '.json'; a.click();
    });
    $('loadBtn').addEventListener('click', function () { $('loadFile').click(); });
    $('loadFile').addEventListener('change', function (e) {
      var f = e.target.files[0]; if (!f) return;
      var r = new FileReader(); r.onload = function () { try { nb = JSON.parse(r.result); save(); renderAll(); } catch (_) { alert('Invalid notebook JSON'); } };
      r.readAsText(f);
    });

    renderAll();
  })();
</script>
</BaseLayout>
