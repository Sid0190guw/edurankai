---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/brand-kit'));
---
<BaseLayout title="Brand kit · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-leaf font-bold mb-2">Design · Brand kit</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Your brand kit</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Save your colours, fonts, and logos so they're one click away inside the design canvas. Stored locally in your browser — never uploaded.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto space-y-5">

  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-3">Colours</p>
    <div id="colors" class="flex gap-2 flex-wrap mb-3"></div>
    <div class="flex gap-2 flex-wrap"><input id="cIn" type="color" value="#FF4F00" class="h-9 w-12 border border-ink/15 rounded cursor-pointer" /><button id="addC" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-4 rounded-lg text-[0.85rem]">+ Add colour</button></div>
  </div>

  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-3">Fonts</p>
    <div id="fonts" class="space-y-2 mb-3"></div>
    <div class="flex gap-2 flex-wrap"><input id="fIn" type="text" placeholder="Font family (e.g. Fraunces, Inter Tight)" class="flex-1 bg-cream border border-ink/15 rounded-xl px-3 py-2 text-[0.92rem]" /><button id="addF" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-4 rounded-lg text-[0.85rem]">+ Add font</button></div>
  </div>

  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-3">Logos</p>
    <div id="logos" class="grid grid-cols-3 md:grid-cols-4 gap-3 mb-3"></div>
    <input id="lIn" type="file" accept="image/*" class="text-[0.85rem]" />
  </div>

  <p class="text-[0.78rem] text-ink-soft text-center m-0">Everything above lives in your browser. Clearing site data wipes it.</p>
</section>

<script is:inline>
  (function () {
    var KEY = 'era_brand_kit_v1';
    function load() { try { return JSON.parse(localStorage.getItem(KEY) || '{}'); } catch { return {}; } }
    function save(k) { localStorage.setItem(KEY, JSON.stringify(k)); }
    var k = load(); k.colors = k.colors || ['#FF4F00','#0E0B08','#1045BB','#1A6B35']; k.fonts = k.fonts || ['Fraunces','Inter Tight','Geist Mono']; k.logos = k.logos || []; save(k);

    function renderColors() {
      var el = document.getElementById('colors'); el.innerHTML = '';
      k.colors.forEach(function (c, i) {
        var d = document.createElement('div'); d.style.cssText = 'position:relative;';
        d.innerHTML = '<div style="width:54px;height:54px;border-radius:10px;background:' + c + ';border:1px solid rgba(14,11,8,0.10);"></div><p style="font-size:9.5px;font-family:ui-monospace,monospace;text-align:center;margin:4px 0 0;color:#7A6F68;">' + c + '</p><button data-i="' + i + '" style="position:absolute;top:-4px;right:-4px;background:#fff;border:1px solid #FF4F00;color:#FF4F00;width:18px;height:18px;border-radius:50%;cursor:pointer;font-size:10px;line-height:1;">×</button>';
        el.appendChild(d);
      });
      el.querySelectorAll('button').forEach(function (b) { b.addEventListener('click', function () { k.colors.splice(+b.getAttribute('data-i'), 1); save(k); renderColors(); }); });
    }
    function renderFonts() {
      var el = document.getElementById('fonts'); el.innerHTML = '';
      k.fonts.forEach(function (f, i) {
        var d = document.createElement('div'); d.style.cssText = 'background:#FAF8F5;border:1px solid rgba(14,11,8,0.10);border-radius:8px;padding:10px 14px;display:flex;justify-content:space-between;align-items:center;';
        d.innerHTML = '<span style="font-family:\'' + f + '\',serif;font-size:18px;color:#0E0B08;">' + f + '</span><button data-i="' + i + '" style="background:transparent;border:none;color:#FF4F00;cursor:pointer;font-weight:600;">×</button>';
        el.appendChild(d);
      });
      el.querySelectorAll('button').forEach(function (b) { b.addEventListener('click', function () { k.fonts.splice(+b.getAttribute('data-i'), 1); save(k); renderFonts(); }); });
    }
    function renderLogos() {
      var el = document.getElementById('logos'); el.innerHTML = '';
      k.logos.forEach(function (l, i) {
        var d = document.createElement('div'); d.style.cssText = 'position:relative;background:#FAF8F5;border:1px solid rgba(14,11,8,0.10);border-radius:8px;aspect-ratio:1;padding:10px;display:flex;align-items:center;justify-content:center;';
        d.innerHTML = '<img src="' + l + '" style="max-width:100%;max-height:100%;"/><button data-i="' + i + '" style="position:absolute;top:-4px;right:-4px;background:#fff;border:1px solid #FF4F00;color:#FF4F00;width:20px;height:20px;border-radius:50%;cursor:pointer;font-size:11px;">×</button>';
        el.appendChild(d);
      });
      el.querySelectorAll('button').forEach(function (b) { b.addEventListener('click', function () { k.logos.splice(+b.getAttribute('data-i'), 1); save(k); renderLogos(); }); });
    }
    renderColors(); renderFonts(); renderLogos();
    document.getElementById('addC').addEventListener('click', function () { k.colors.push(document.getElementById('cIn').value); save(k); renderColors(); });
    document.getElementById('addF').addEventListener('click', function () { var v = document.getElementById('fIn').value.trim(); if (v) { k.fonts.push(v); save(k); renderFonts(); document.getElementById('fIn').value = ''; } });
    document.getElementById('lIn').addEventListener('change', function (e) {
      var f = e.target.files[0]; if (!f) return; var r = new FileReader();
      r.onload = function () { k.logos.push(r.result); save(k); renderLogos(); };
      r.readAsDataURL(f);
    });
  })();
</script>
</BaseLayout>
