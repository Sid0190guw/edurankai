---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/templates'));

const TEMPLATES = [
  { slug: 'cv-classic', name: 'CV · Classic',  category: 'Resume', accent: '#0E0B08' },
  { slug: 'cv-modern',  name: 'CV · Modern',   category: 'Resume', accent: '#FF4F00' },
  { slug: 'poster-event', name: 'Event poster', category: 'Poster', accent: '#1045BB' },
  { slug: 'poster-talk',  name: 'Lecture flyer', category: 'Poster', accent: '#1A6B35' },
  { slug: 'cert-completion', name: 'Certificate of Completion', category: 'Certificate', accent: '#6B1FBE' },
  { slug: 'cert-merit',      name: 'Certificate of Merit',      category: 'Certificate', accent: '#C49A00' },
  { slug: 'social-square',   name: 'Social square (1080×1080)', category: 'Social', accent: '#FF4F00' },
  { slug: 'social-story',    name: 'Social story (1080×1920)',  category: 'Social', accent: '#1045BB' },
  { slug: 'letterhead',      name: 'Letterhead',                category: 'Business', accent: '#0E0B08' },
  { slug: 'invoice',         name: 'Invoice',                   category: 'Business', accent: '#1A6B35' },
];
---
<BaseLayout title="Templates · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-6xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-leaf font-bold mb-2">Design · Templates</p>
    <h1 class="font-display text-[clamp(2rem,5vw,3rem)] font-semibold text-ink leading-[1.05] mb-3">Templates ready to edit</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85] max-w-2xl">Pick a template, open it in the design canvas, and customise. Every element is editable — text, color, shape, image.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-6xl mx-auto">
  <div class="grid gap-4" style="grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));">
    {TEMPLATES.map((t) => (
      <a href={'/portal/tools/canvas?template=' + t.slug} class="bg-white border border-ink/10 hover:border-leaf rounded-2xl p-5 no-underline transition-colors" style="color:inherit;">
        <div class="aspect-[3/4] rounded-lg mb-3 flex items-center justify-center" style={`background:linear-gradient(135deg, ${t.accent}11, ${t.accent}22); border: 1px solid ${t.accent}44;`}>
          <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke={t.accent} stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/></svg>
        </div>
        <p class="text-[0.6rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold m-0 mb-1">{t.category}</p>
        <p class="font-display text-[1rem] font-semibold text-ink leading-tight m-0">{t.name}</p>
      </a>
    ))}
  </div>
</section>
</BaseLayout>
