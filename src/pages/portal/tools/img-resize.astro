---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/img-resize'));
---
<BaseLayout title="Resize image · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-sky font-bold mb-2">Image · Resize</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Resize image</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">By pixels, percentage, or a social/print preset. High-quality stepped resampling avoids the jaggies of a single-pass shrink. Choose your output format and quality.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="image/*" class="block w-full text-[0.92rem] file:bg-sky file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <p id="meta" class="text-[0.85rem] text-ink-soft m-0"></p>

    <div>
      <span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Mode</span>
      <div class="flex flex-wrap gap-2" id="modeChips">
        <button data-m="px" class="pchip on">Pixels</button>
        <button data-m="pct" class="pchip">Percentage</button>
        <button data-m="preset" class="pchip">Preset</button>
      </div>
    </div>

    <div id="pxRow" class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <label class="block"><span class="lbl">Width (px)</span><input id="w" type="number" min="1" class="inp" /></label>
      <label class="block"><span class="lbl">Height (px)</span><input id="h" type="number" min="1" class="inp" /></label>
      <label class="flex items-center gap-2 md:pt-7"><input id="lock" type="checkbox" checked class="w-4 h-4" /><span class="text-[0.88rem] text-ink-2">Lock ratio</span></label>
    </div>
    <div id="pctRow" class="hidden"><span class="lbl">Scale: <span id="pctVal">50</span>%</span><input id="pct" type="range" min="5" max="200" value="50" class="w-full" /></div>
    <div id="presetRow" class="hidden"><span class="lbl">Preset</span><select id="presetSel" class="inp">
      <option value="1080x1080">Instagram square · 1080×1080</option>
      <option value="1080x1350">Instagram portrait · 1080×1350</option>
      <option value="1080x1920">Story / Reel · 1080×1920</option>
      <option value="1200x630">Open Graph / LinkedIn · 1200×630</option>
      <option value="1280x720">HD · 1280×720</option>
      <option value="1920x1080" selected>Full HD · 1920×1080</option>
      <option value="800x800">Web thumbnail · 800×800</option>
      <option value="300x300">Avatar · 300×300</option>
    </select><label class="flex items-center gap-2 mt-2"><input id="fitCover" type="checkbox" class="w-4 h-4" /><span class="text-[0.88rem] text-ink-2">Crop to fill (cover) instead of fit</span></label></div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <label class="block"><span class="lbl">Output format</span><select id="fmt" class="inp"><option value="image/jpeg">JPEG</option><option value="image/png">PNG</option><option value="image/webp" selected>WebP</option></select></label>
      <label class="block" id="qWrap"><span class="lbl">Quality: <span id="qVal">90</span>%</span><input id="quality" type="range" min="10" max="100" value="90" class="w-full" /></label>
    </div>

    <button id="goBtn" class="bg-sky hover:bg-sky/90 text-white font-semibold py-3 px-6 rounded-xl text-[0.92rem]" disabled style="opacity:0.5;">Resize</button>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
    <div id="result" class="hidden pt-1"><img id="prev" class="w-full max-h-80 object-contain rounded-xl border border-sky/30 bg-cream" /><div class="mt-3 bg-cream rounded-xl p-4 flex items-center justify-between gap-3 flex-wrap"><span id="savedTxt" class="text-[0.9rem] text-ink font-semibold"></span><a id="dlBtn" class="bg-leaf hover:bg-leaf/90 text-white font-semibold py-2.5 px-5 rounded-xl text-[0.88rem] no-underline">Download</a></div></div>
  </div>
</section>
<style is:global>
  .pchip{ background:#faf7f2; border:1px solid rgba(14,11,8,0.15); color:#0E0B08; border-radius:99px; padding:6px 14px; font-family:'Geist Mono',monospace; font-size:11px; font-weight:600; cursor:pointer; } .pchip.on{ background:#0ea5e9; color:#fff; border-color:#0ea5e9; }
  .lbl{ font-family:'Geist Mono',monospace; font-size:0.62rem; text-transform:uppercase; letter-spacing:0.14em; color:#8a7f76; font-weight:700; margin-bottom:8px; display:block; }
  .inp{ width:100%; background:#faf7f2; border:1px solid rgba(14,11,8,0.15); border-radius:12px; padding:12px 16px; font-size:0.95rem; color:#0E0B08; box-sizing:border-box; }
</style>
<script is:inline>
  (function () {
    var file = null, img = null, ow = 0, oh = 0, mode = 'px', blob = null;
    var $ = function (id) { return document.getElementById(id); };
    function kb(b){ return b<1048576?(b/1024).toFixed(1)+' KB':(b/1048576).toFixed(2)+' MB'; }
    $('quality').addEventListener('input', function(){ $('qVal').textContent = this.value; });
    $('pct').addEventListener('input', function(){ $('pctVal').textContent = this.value; });
    $('fmt').addEventListener('change', function(){ $('qWrap').style.display = this.value==='image/png'?'none':'block'; });
    document.querySelectorAll('#modeChips .pchip').forEach(function(b){ b.addEventListener('click', function(){ mode=b.getAttribute('data-m'); document.querySelectorAll('#modeChips .pchip').forEach(function(x){x.classList.toggle('on',x===b);}); $('pxRow').classList.toggle('hidden',mode!=='px'); $('pctRow').classList.toggle('hidden',mode!=='pct'); $('presetRow').classList.toggle('hidden',mode!=='preset'); }); });
    $('w').addEventListener('input', function(){ if($('lock').checked && ow) $('h').value=Math.round(this.value*oh/ow); });
    $('h').addEventListener('input', function(){ if($('lock').checked && oh) $('w').value=Math.round(this.value*ow/oh); });

    $('fileInput').addEventListener('change', function(){ if(!this.files[0])return; file=this.files[0]; img=new Image(); img.onload=function(){ ow=img.naturalWidth; oh=img.naturalHeight; $('w').value=ow; $('h').value=oh; $('meta').textContent=file.name+' · '+ow+'×'+oh+' px · '+kb(file.size); $('goBtn').disabled=false; $('goBtn').style.opacity='1'; $('result').classList.add('hidden'); }; img.src=URL.createObjectURL(file); });

    // high-quality stepped downscale
    function resample(src, tw, th){ var cw=src.width, ch=src.height, cur=src;
      while(cw>tw*2||ch>th*2){ var nw=Math.max(tw,Math.floor(cw/2)), nh=Math.max(th,Math.floor(ch/2)); var n=document.createElement('canvas'); n.width=nw; n.height=nh; var x=n.getContext('2d'); x.imageSmoothingEnabled=true; x.imageSmoothingQuality='high'; x.drawImage(cur,0,0,cw,ch,0,0,nw,nh); cur=n; cw=nw; ch=nh; }
      var o=document.createElement('canvas'); o.width=tw; o.height=th; var ox=o.getContext('2d'); ox.imageSmoothingEnabled=true; ox.imageSmoothingQuality='high'; return {c:o,ctx:ox,cur:cur,cw:cw,ch:ch}; }

    $('goBtn').addEventListener('click', function(){
      if(!img)return; var tw,th, cover=false;
      if(mode==='px'){ tw=parseInt($('w').value,10); th=parseInt($('h').value,10); }
      else if(mode==='pct'){ var s=+$('pct').value/100; tw=Math.max(1,Math.round(ow*s)); th=Math.max(1,Math.round(oh*s)); }
      else { var p=$('presetSel').value.split('x'); tw=+p[0]; th=+p[1]; cover=$('fitCover').checked; }
      if(!tw||!th){ return; }
      var base=document.createElement('canvas'); base.width=ow; base.height=oh; base.getContext('2d').drawImage(img,0,0);
      var out=document.createElement('canvas'); out.width=tw; out.height=th; var octx=out.getContext('2d'); octx.imageSmoothingEnabled=true; octx.imageSmoothingQuality='high';
      if($('fmt').value!=='image/png'){ octx.fillStyle='#fff'; octx.fillRect(0,0,tw,th); }
      if(cover){ var s=Math.max(tw/ow,th/oh), dw=ow*s, dh=oh*s; octx.drawImage(base,(tw-dw)/2,(th-dh)/2,dw,dh); }
      else { var rr=resample(base,tw,th); octx.drawImage(rr.cur,0,0,rr.cw,rr.ch,0,0,tw,th); }
      var fmt=$('fmt').value, q=+$('quality').value/100;
      out.toBlob(function(b){ blob=b; var url=URL.createObjectURL(b); $('prev').src=url; var ext=fmt.split('/')[1]; if(ext==='jpeg')ext='jpg';
        $('savedTxt').textContent=tw+'×'+th+' · '+kb(b.size)+' (was '+kb(file.size)+')'; var dl=$('dlBtn'); dl.href=url; dl.download=file.name.replace(/\.[^.]+$/,'')+'-'+tw+'x'+th+'.'+ext; $('result').classList.remove('hidden'); $('status').textContent='Done.'; }, fmt, q);
    });
  })();
</script>
</BaseLayout>
