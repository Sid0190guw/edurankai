---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/img-resize'));
---
<BaseLayout title="Resize image · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-sky font-bold mb-2">Image · Resize</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Resize image</h1>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="image/*" class="block w-full text-[0.92rem] file:bg-sky file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <p id="meta" class="text-[0.85rem] text-ink-soft m-0"></p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Width (px)</span><input id="w" type="number" min="1" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink" /></label>
      <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Height (px)</span><input id="h" type="number" min="1" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink" /></label>
      <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Lock aspect ratio</span><select id="lock" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink"><option value="1">Yes</option><option value="0">No</option></select></label>
    </div>
    <button id="goBtn" class="bg-sky hover:bg-sky/90 text-white font-semibold py-3 px-6 rounded-xl text-[0.92rem]" disabled style="opacity:0.5;">Resize & download</button>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
  </div>
</section>
<script is:inline>
  (function () {
    var file = null; var ow = 0; var oh = 0;
    var fi = document.getElementById('fileInput'); var meta = document.getElementById('meta');
    var btn = document.getElementById('goBtn'); var status = document.getElementById('status');
    var wIn = document.getElementById('w'); var hIn = document.getElementById('h'); var lock = document.getElementById('lock');
    fi.addEventListener('change', function () {
      if (!fi.files[0]) return; file = fi.files[0];
      var img = new Image(); img.onload = function () {
        ow = img.naturalWidth; oh = img.naturalHeight;
        wIn.value = ow; hIn.value = oh;
        meta.textContent = file.name + ' · ' + ow + ' × ' + oh + ' px';
        btn.disabled = false; btn.style.opacity = '1';
      };
      img.src = URL.createObjectURL(file);
    });
    wIn.addEventListener('input', function () { if (lock.value === '1' && ow) hIn.value = Math.round(wIn.value * oh / ow); });
    hIn.addEventListener('input', function () { if (lock.value === '1' && oh) wIn.value = Math.round(hIn.value * ow / oh); });
    btn.addEventListener('click', function () {
      if (!file) return; btn.disabled = true; status.textContent = 'Resizing...';
      var img = new Image(); img.onload = function () {
        var c = document.createElement('canvas'); c.width = parseInt(wIn.value, 10); c.height = parseInt(hIn.value, 10);
        c.getContext('2d').drawImage(img, 0, 0, c.width, c.height);
        c.toBlob(function (blob) {
          var a = document.createElement('a'); a.href = URL.createObjectURL(blob);
          a.download = file.name.replace(/\.[^.]+$/, '') + '-' + c.width + 'x' + c.height + '.png'; a.click();
          status.textContent = 'Done. ' + c.width + ' × ' + c.height;
          btn.disabled = false;
        }, 'image/png');
      };
      img.src = URL.createObjectURL(file);
    });
  })();
</script>
</BaseLayout>
