---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/merge'));
---
<BaseLayout title="Merge PDF · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">PDF · Merge</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Merge PDF</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Combine multiple PDFs into one file in the order you choose. Drag to reorder. Everything happens in your browser — no upload.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8">
    <label for="fileInput" class="block border-2 border-dashed border-burn-dim rounded-xl px-6 py-10 text-center cursor-pointer hover:bg-burn-pale transition-colors">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#FF4F00" stroke-width="2" style="margin:0 auto 8px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
      <p class="font-display text-[1.1rem] font-semibold text-ink m-0">Choose PDF files</p>
      <p class="text-[0.82rem] text-ink-soft m-0 mt-1">Click to browse · multiple at once supported</p>
      <input type="file" id="fileInput" accept="application/pdf" multiple style="display:none;" />
    </label>
    <ul id="fileList" class="mt-5 space-y-2"></ul>
    <button id="mergeBtn" class="btn-primary mt-6" disabled style="opacity:0.5;">Merge & download</button>
    <p id="status" class="text-[0.82rem] text-ink-soft mt-3 m-0"></p>
  </div>
</section>

<script is:inline src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
<script is:inline>
  (function () {
    var files = [];
    var fi = document.getElementById('fileInput');
    var list = document.getElementById('fileList');
    var btn = document.getElementById('mergeBtn');
    var status = document.getElementById('status');

    function render() {
      list.innerHTML = '';
      files.forEach(function (f, i) {
        var li = document.createElement('li');
        li.style.cssText = 'background:#FAF8F5;border:1px solid rgba(14,11,8,0.10);border-radius:10px;padding:10px 14px;display:flex;justify-content:space-between;align-items:center;gap:10px;';
        var info = '<div><p style="font-size:13.5px;font-weight:600;color:#0E0B08;margin:0;">' + (i + 1) + '. ' + f.name + '</p><p style="font-size:11px;color:#7A6F68;margin:2px 0 0;font-family:ui-monospace,monospace;">' + (f.size / 1024).toFixed(1) + ' KB</p></div>';
        var ctrl = '<div style="display:flex;gap:4px;">'
          + (i > 0 ? '<button data-up="' + i + '" style="background:transparent;border:1px solid rgba(14,11,8,0.15);color:#0E0B08;padding:4px 8px;border-radius:5px;cursor:pointer;font-size:12px;">↑</button>' : '')
          + (i < files.length - 1 ? '<button data-down="' + i + '" style="background:transparent;border:1px solid rgba(14,11,8,0.15);color:#0E0B08;padding:4px 8px;border-radius:5px;cursor:pointer;font-size:12px;">↓</button>' : '')
          + '<button data-del="' + i + '" style="background:transparent;border:1px solid rgba(239,68,68,0.3);color:#FF4F00;padding:4px 8px;border-radius:5px;cursor:pointer;font-size:12px;">×</button></div>';
        li.innerHTML = info + ctrl;
        list.appendChild(li);
      });
      btn.disabled = files.length < 2;
      btn.style.opacity = files.length < 2 ? '0.5' : '1';
    }

    list.addEventListener('click', function (e) {
      var t = e.target;
      if (t.hasAttribute('data-up')) { var i = +t.getAttribute('data-up'); [files[i-1], files[i]] = [files[i], files[i-1]]; render(); }
      else if (t.hasAttribute('data-down')) { var i = +t.getAttribute('data-down'); [files[i+1], files[i]] = [files[i], files[i+1]]; render(); }
      else if (t.hasAttribute('data-del')) { files.splice(+t.getAttribute('data-del'), 1); render(); }
    });

    fi.addEventListener('change', function (e) {
      for (var i = 0; i < fi.files.length; i++) files.push(fi.files[i]);
      render();
      fi.value = '';
    });

    btn.addEventListener('click', async function () {
      btn.disabled = true; status.textContent = 'Merging ' + files.length + ' files...';
      try {
        var merged = await PDFLib.PDFDocument.create();
        for (var i = 0; i < files.length; i++) {
          var bytes = new Uint8Array(await files[i].arrayBuffer());
          var src = await PDFLib.PDFDocument.load(bytes, { ignoreEncryption: true });
          var pages = await merged.copyPages(src, src.getPageIndices());
          pages.forEach(function (p) { merged.addPage(p); });
          status.textContent = 'Merging... (' + (i + 1) + ' / ' + files.length + ')';
        }
        var out = await merged.save();
        var blob = new Blob([out], { type: 'application/pdf' });
        var a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'merged-' + Date.now() + '.pdf';
        a.click();
        status.textContent = 'Done. ' + (out.length / 1024).toFixed(1) + ' KB downloaded.';
      } catch (e) { status.textContent = 'Failed: ' + e.message; }
      btn.disabled = false;
    });
  })();
</script>
</BaseLayout>
