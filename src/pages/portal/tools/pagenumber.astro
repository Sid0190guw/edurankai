---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/pagenumber'));
---
<BaseLayout title="Page numbers · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">PDF · Page numbers</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Add page numbers</h1>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="application/pdf" class="block w-full text-[0.92rem] file:bg-burn file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <p id="meta" class="text-[0.85rem] text-ink-soft m-0"></p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Position</span>
        <select id="pos" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink">
          <option value="br">Bottom right</option><option value="bc">Bottom centre</option><option value="bl">Bottom left</option>
          <option value="tr">Top right</option><option value="tc">Top centre</option><option value="tl">Top left</option>
        </select>
      </label>
      <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Format</span>
        <select id="fmt" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink">
          <option value="n">1, 2, 3</option><option value="page n">Page 1</option><option value="n of t">1 of 10</option><option value="page n of t">Page 1 of 10</option>
        </select>
      </label>
      <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Font size</span><input id="sz" type="number" value="11" min="6" max="40" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink" /></label>
    </div>
    <button id="goBtn" class="btn-primary" disabled style="opacity:0.5;">Add numbers & download</button>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
  </div>
</section>
<script is:inline src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
<script is:inline>
  (function () {
    var file = null; var fi = document.getElementById('fileInput');
    var meta = document.getElementById('meta'); var btn = document.getElementById('goBtn'); var status = document.getElementById('status');
    fi.addEventListener('change', function () { if (!fi.files[0]) return; file = fi.files[0]; meta.textContent = file.name; btn.disabled = false; btn.style.opacity = '1'; });
    btn.addEventListener('click', async function () {
      if (!file) return; btn.disabled = true; status.textContent = 'Numbering...';
      try {
        var src = await PDFLib.PDFDocument.load(new Uint8Array(await file.arrayBuffer()), { ignoreEncryption: true });
        var font = await src.embedFont(PDFLib.StandardFonts.Helvetica);
        var pos = document.getElementById('pos').value; var fmt = document.getElementById('fmt').value; var sz = parseFloat(document.getElementById('sz').value) || 11;
        var pages = src.getPages(); var total = pages.length;
        pages.forEach(function (p, i) {
          var num = (i + 1);
          var label = fmt.replace('n of t', num + ' of ' + total).replace('page n of t', 'Page ' + num + ' of ' + total).replace('page n', 'Page ' + num).replace(/^n$/, '' + num);
          var w = p.getWidth(); var h = p.getHeight(); var tw = font.widthOfTextAtSize(label, sz);
          var x, y;
          if (pos[1] === 'l') x = 30; else if (pos[1] === 'c') x = (w - tw) / 2; else x = w - tw - 30;
          if (pos[0] === 't') y = h - 30; else y = 20;
          p.drawText(label, { x: x, y: y, font: font, size: sz, color: PDFLib.rgb(0.2, 0.2, 0.2) });
        });
        var blob = new Blob([await src.save()], { type: 'application/pdf' });
        var a = document.createElement('a'); a.href = URL.createObjectURL(blob);
        a.download = file.name.replace(/\.pdf$/i, '') + '-numbered.pdf'; a.click();
        status.textContent = 'Done.';
      } catch (e) { status.textContent = 'Failed: ' + e.message; }
      btn.disabled = false;
    });
  })();
</script>
</BaseLayout>
