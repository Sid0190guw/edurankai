---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/to-jpg'));
---
<BaseLayout title="PDF to images · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">PDF · To images</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">PDF to JPG / PNG</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Each PDF page becomes a separate image at the resolution you choose.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="application/pdf" class="block w-full text-[0.92rem] file:bg-burn file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <p id="meta" class="text-[0.85rem] text-ink-soft m-0"></p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Format</span>
        <select id="fmt" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink"><option value="image/jpeg">JPEG</option><option value="image/png">PNG</option></select>
      </label>
      <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Scale (DPI multiplier)</span>
        <select id="scale" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink"><option value="1">1× (screen)</option><option value="2" selected>2× (print quality)</option><option value="3">3× (high res)</option></select>
      </label>
    </div>
    <button id="goBtn" class="btn-primary" disabled style="opacity:0.5;">Render & download</button>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
  </div>
</section>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script is:inline>
  (function () {
    if (window.pdfjsLib) { window.pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js'; }
    var file = null;
    document.getElementById('fileInput').addEventListener('change', function (e) { file = e.target.files[0]; document.getElementById('meta').textContent = file ? file.name : ''; var b = document.getElementById('goBtn'); b.disabled = !file; b.style.opacity = file ? '1' : '0.5'; });
    document.getElementById('goBtn').addEventListener('click', async function () {
      if (!file || !window.pdfjsLib) return;
      var btn = document.getElementById('goBtn'); btn.disabled = true;
      var status = document.getElementById('status'); var fmt = document.getElementById('fmt').value; var scale = parseFloat(document.getElementById('scale').value);
      try {
        var buf = await file.arrayBuffer(); var pdf = await window.pdfjsLib.getDocument({ data: buf }).promise;
        for (var i = 1; i <= pdf.numPages; i++) {
          var page = await pdf.getPage(i); var vp = page.getViewport({ scale: scale });
          var c = document.createElement('canvas'); c.width = vp.width; c.height = vp.height;
          await page.render({ canvasContext: c.getContext('2d'), viewport: vp }).promise;
          await new Promise(function (resolve) {
            c.toBlob(function (blob) {
              var a = document.createElement('a'); a.href = URL.createObjectURL(blob);
              var ext = fmt.split('/')[1]; a.download = file.name.replace(/\.pdf$/i, '') + '-page-' + i + '.' + (ext === 'jpeg' ? 'jpg' : ext);
              a.click(); resolve();
            }, fmt, 0.92);
          });
          status.textContent = 'Rendered ' + i + ' / ' + pdf.numPages;
          await new Promise(function (r) { setTimeout(r, 120); });
        }
        status.textContent = 'Done.';
      } catch (e) { status.textContent = 'Failed: ' + e.message; }
      btn.disabled = false;
    });
  })();
</script>
</BaseLayout>
