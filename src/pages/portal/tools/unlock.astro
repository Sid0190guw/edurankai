---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/unlock'));
---
<BaseLayout title="Unlock PDF · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">PDF · Unlock</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Unlock PDF</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Remove ownership restrictions (no-print / no-copy / no-edit). Only use this on documents you own — we do not bypass open-passwords.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="application/pdf" class="block w-full text-[0.92rem] file:bg-burn file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <p id="meta" class="text-[0.85rem] text-ink-soft m-0"></p>
    <div class="bg-cream-2/60 border border-ink/10 rounded-xl p-4 text-[0.85rem] text-ink-2">
      <p class="m-0 mb-2 font-semibold text-ink">By unlocking you confirm:</p>
      <ul class="m-0 pl-5 list-disc space-y-1">
        <li>You own this PDF or have the right to remove its restrictions.</li>
        <li>You are not bypassing a copyright protection mechanism.</li>
      </ul>
    </div>
    <button id="goBtn" class="btn-primary" disabled style="opacity:0.5;">Unlock & download</button>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
  </div>
</section>
<script is:inline src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
<script is:inline>
  (function () {
    var file = null;
    document.getElementById('fileInput').addEventListener('change', function (e) { file = e.target.files[0]; document.getElementById('meta').textContent = file ? file.name + ' · ' + (file.size / 1024).toFixed(1) + ' KB' : ''; var b = document.getElementById('goBtn'); b.disabled = !file; b.style.opacity = file ? '1' : '0.5'; });
    document.getElementById('goBtn').addEventListener('click', async function () {
      if (!file) return; var btn = document.getElementById('goBtn'); btn.disabled = true; document.getElementById('status').textContent = 'Unlocking...';
      try {
        var src = await PDFLib.PDFDocument.load(new Uint8Array(await file.arrayBuffer()), { ignoreEncryption: true });
        var out = await PDFLib.PDFDocument.create();
        var pages = await out.copyPages(src, src.getPageIndices()); pages.forEach(function (p) { out.addPage(p); });
        var blob = new Blob([await out.save()], { type: 'application/pdf' });
        var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = file.name.replace(/\.pdf$/i, '') + '-unlocked.pdf'; a.click();
        document.getElementById('status').textContent = 'Done.';
      } catch (e) { document.getElementById('status').textContent = 'Failed (may need an open-password): ' + e.message; }
      btn.disabled = false;
    });
  })();
</script>
</BaseLayout>
