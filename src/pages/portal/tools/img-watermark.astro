---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/img-watermark'));
---
<BaseLayout title="Watermark image · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-sky font-bold mb-2">Image · Watermark</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Watermark image</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Live preview — every change shows instantly. Text, colour, size, opacity, single position or a tiled diagonal pattern, and your output format.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="image/*" class="block w-full text-[0.92rem] file:bg-sky file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <canvas id="prev" class="hidden w-full rounded-xl border border-ink/10 bg-cream" style="max-height:60vh;object-fit:contain;"></canvas>
    <label class="block"><span class="lbl">Text</span><input id="txt" type="text" value="© EduRankAI" class="inp" /></label>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <label class="block"><span class="lbl">Position</span><select id="pos" class="inp"><option value="br">Bottom right</option><option value="bl">Bottom left</option><option value="tr">Top right</option><option value="tl">Top left</option><option value="c">Centre</option><option value="diag" selected>Diagonal tile</option></select></label>
      <label class="block"><span class="lbl">Colour</span><select id="col" class="inp"><option value="#ffffff" selected>White</option><option value="#000000">Black</option><option value="#FF4F00">Rust</option></select></label>
      <label class="block"><span class="lbl">Opacity <span id="opV">35</span>%</span><input id="op" type="range" min="5" max="100" value="35" class="w-full" /></label>
      <label class="block"><span class="lbl">Size <span id="szV">5.0</span>%</span><input id="sz" type="range" min="1" max="20" step="0.5" value="5" class="w-full" /></label>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <label class="block" id="densWrap"><span class="lbl">Tile density <span id="densV">3</span></span><input id="dens" type="range" min="1" max="8" value="3" class="w-full" /></label>
      <label class="block"><span class="lbl">Output</span><select id="fmt" class="inp"><option value="image/png" selected>PNG</option><option value="image/jpeg">JPEG</option><option value="image/webp">WebP</option></select></label>
    </div>
    <button id="goBtn" class="bg-sky hover:bg-sky/90 text-white font-semibold py-3 px-6 rounded-xl text-[0.92rem]" disabled style="opacity:0.5;">Download</button>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
  </div>
</section>
<style is:global>
  .lbl{ font-family:'Geist Mono',monospace; font-size:0.62rem; text-transform:uppercase; letter-spacing:0.14em; color:#8a7f76; font-weight:700; margin-bottom:8px; display:block; }
  .inp{ width:100%; background:#faf7f2; border:1px solid rgba(14,11,8,0.15); border-radius:12px; padding:11px 14px; font-size:0.92rem; color:#0E0B08; box-sizing:border-box; }
</style>
<script is:inline>
  (function () {
    var $ = function (id){ return document.getElementById(id); };
    var file=null, img=null;
    function hexA(hex,a){ var n=parseInt(hex.slice(1),16); return 'rgba('+((n>>16)&255)+','+((n>>8)&255)+','+(n&255)+','+a+')'; }
    ['txt','pos','col','op','sz','dens','fmt'].forEach(function(id){ $(id).addEventListener('input', render); $(id).addEventListener('change', render); });
    $('op').addEventListener('input', function(){ $('opV').textContent=this.value; }); $('sz').addEventListener('input', function(){ $('szV').textContent=(+this.value).toFixed(1); }); $('dens').addEventListener('input', function(){ $('densV').textContent=this.value; });

    $('fileInput').addEventListener('change', function(){ if(!this.files[0])return; file=this.files[0]; img=new Image(); img.onload=function(){ $('prev').classList.remove('hidden'); $('goBtn').disabled=false; $('goBtn').style.opacity='1'; render(); }; img.src=URL.createObjectURL(file); });

    function stampAll(ctx, W, H){
      var txt=$('txt').value, sz=Math.round(Math.min(W,H)*(+$('sz').value/100)), op=+$('op').value/100, pos=$('pos').value, col=$('col').value;
      ctx.font='bold '+sz+'px sans-serif'; ctx.textBaseline='alphabetic'; ctx.fillStyle=hexA(col,op); ctx.strokeStyle=hexA(col==='#ffffff'?'#000000':'#ffffff', op*0.5); ctx.lineWidth=Math.max(1,sz*0.04);
      var tw=ctx.measureText(txt).width, m=sz*0.6;
      function s(x,y){ ctx.strokeText(txt,x,y); ctx.fillText(txt,x,y); }
      $('densWrap').style.opacity = pos==='diag'?'1':'0.4';
      if(pos==='br') s(W-tw-m,H-m); else if(pos==='bl') s(m,H-m); else if(pos==='tr') s(W-tw-m,m+sz); else if(pos==='tl') s(m,m+sz); else if(pos==='c') s((W-tw)/2,(H+sz)/2);
      else { var d=+$('dens').value; var stepX=tw+sz*(9-d)*0.4, stepY=sz*(9-d)*0.7; ctx.save(); ctx.translate(W/2,H/2); ctx.rotate(-Math.PI/6); for(var y=-H;y<H;y+=stepY) for(var x=-W;x<W;x+=stepX) s(x,y); ctx.restore(); }
    }
    function render(){ if(!img)return; var W=img.naturalWidth, H=img.naturalHeight; var pv=$('prev'); pv.width=W; pv.height=H; var ctx=pv.getContext('2d'); ctx.clearRect(0,0,W,H); ctx.drawImage(img,0,0); stampAll(ctx,W,H); }

    $('goBtn').addEventListener('click', function(){ if(!img)return; var W=img.naturalWidth,H=img.naturalHeight; var c=document.createElement('canvas'); c.width=W; c.height=H; var ctx=c.getContext('2d'); var fmt=$('fmt').value; if(fmt!=='image/png'){ ctx.fillStyle='#fff'; ctx.fillRect(0,0,W,H); } ctx.drawImage(img,0,0); stampAll(ctx,W,H);
      c.toBlob(function(b){ var a=document.createElement('a'); a.href=URL.createObjectURL(b); var ext=fmt.split('/')[1]; if(ext==='jpeg')ext='jpg'; a.download=file.name.replace(/\.[^.]+$/,'')+'-watermarked.'+ext; a.click(); $('status').textContent='Downloaded.'; }, fmt, 0.92); });
  })();
</script>
</BaseLayout>
