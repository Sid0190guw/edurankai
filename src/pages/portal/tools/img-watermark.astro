---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/img-watermark'));
---
<BaseLayout title="Watermark image · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-sky font-bold mb-2">Image · Watermark</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Watermark image</h1>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="image/*" class="block w-full text-[0.92rem] file:bg-sky file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Text</span><input id="txt" type="text" value="© EduRankAI" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink" /></label>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Position</span>
        <select id="pos" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink"><option value="br">Bottom right</option><option value="bl">Bottom left</option><option value="tr">Top right</option><option value="tl">Top left</option><option value="c">Centre</option><option value="diag">Diagonal repeat</option></select>
      </label>
      <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Opacity %</span><input id="op" type="number" value="40" min="5" max="100" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink" /></label>
      <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Size</span><input id="sz" type="number" value="48" min="8" max="300" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink" /></label>
    </div>
    <button id="goBtn" class="bg-sky hover:bg-sky/90 text-white font-semibold py-3 px-6 rounded-xl text-[0.92rem]" disabled style="opacity:0.5;">Stamp & download</button>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
  </div>
</section>
<script is:inline>
  (function () {
    var file = null;
    document.getElementById('fileInput').addEventListener('change', function (e) { file = e.target.files[0]; document.getElementById('goBtn').disabled = !file; document.getElementById('goBtn').style.opacity = file ? '1' : '0.5'; });
    document.getElementById('goBtn').addEventListener('click', function () {
      if (!file) return; var img = new Image();
      img.onload = function () {
        var c = document.createElement('canvas'); c.width = img.naturalWidth; c.height = img.naturalHeight; var ctx = c.getContext('2d');
        ctx.drawImage(img, 0, 0);
        var txt = document.getElementById('txt').value; var sz = parseInt(document.getElementById('sz').value, 10); var op = parseInt(document.getElementById('op').value, 10) / 100; var pos = document.getElementById('pos').value;
        ctx.font = 'bold ' + sz + 'px sans-serif'; ctx.fillStyle = 'rgba(255,255,255,' + op + ')'; ctx.strokeStyle = 'rgba(0,0,0,' + op + ')'; ctx.lineWidth = 2;
        var w = c.width, h = c.height, m = sz; var tw = ctx.measureText(txt).width;
        function stamp(x, y) { ctx.strokeText(txt, x, y); ctx.fillText(txt, x, y); }
        if (pos === 'br') stamp(w - tw - m, h - m);
        else if (pos === 'bl') stamp(m, h - m);
        else if (pos === 'tr') stamp(w - tw - m, m + sz);
        else if (pos === 'tl') stamp(m, m + sz);
        else if (pos === 'c') stamp((w - tw) / 2, h / 2);
        else if (pos === 'diag') { ctx.save(); ctx.translate(w / 2, h / 2); ctx.rotate(-Math.PI / 6); for (var y = -h; y < h; y += sz * 4) for (var x = -w; x < w; x += tw + sz * 2) stamp(x, y); ctx.restore(); }
        c.toBlob(function (blob) { var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = file.name.replace(/\.[^.]+$/, '') + '-watermarked.png'; a.click(); document.getElementById('status').textContent = 'Done.'; }, 'image/png');
      };
      img.src = URL.createObjectURL(file);
    });
  })();
</script>
</BaseLayout>
