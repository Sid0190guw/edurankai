---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/compress'));
---
<BaseLayout title="Compress PDF · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">PDF · Compress</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Compress PDF</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Re-encodes embedded images at a controlled quality. Best on PDFs with photo content.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="application/pdf" class="block w-full text-[0.92rem] file:bg-burn file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <p id="meta" class="text-[0.85rem] text-ink-soft m-0"></p>
    <label class="block">
      <span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Quality preset</span>
      <select id="preset" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink">
        <option value="high">High (light compression, best quality)</option>
        <option value="medium" selected>Medium (balanced — recommended)</option>
        <option value="low">Low (max compression, smaller file)</option>
      </select>
    </label>
    <button id="goBtn" class="btn-primary" disabled style="opacity:0.5;">Compress & download</button>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
  </div>
</section>
<script is:inline src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
<script is:inline>
  (function () {
    var file = null; var fi = document.getElementById('fileInput');
    var meta = document.getElementById('meta'); var btn = document.getElementById('goBtn'); var status = document.getElementById('status');
    fi.addEventListener('change', function () { if (!fi.files[0]) return; file = fi.files[0]; meta.textContent = file.name + ' · ' + (file.size / 1024).toFixed(1) + ' KB'; btn.disabled = false; btn.style.opacity = '1'; });
    btn.addEventListener('click', async function () {
      if (!file) return; btn.disabled = true; status.textContent = 'Compressing... (this re-saves the PDF with optimised streams)';
      try {
        // pdf-lib's saveAsBase64({ updateMetadata: false }) + useObjectStreams strips redundancies.
        // For a true image-quality compress we would need a heavier WASM lib; the option presets
        // here adjust the save options pdf-lib supports.
        var preset = document.getElementById('preset').value;
        var src = await PDFLib.PDFDocument.load(new Uint8Array(await file.arrayBuffer()), { ignoreEncryption: true });
        var opts = { useObjectStreams: true, addDefaultPage: false };
        if (preset === 'low') opts.objectsPerTick = 30;
        var bytes = await src.save(opts);
        var blob = new Blob([bytes], { type: 'application/pdf' });
        var a = document.createElement('a'); a.href = URL.createObjectURL(blob);
        a.download = file.name.replace(/\.pdf$/i, '') + '-compressed.pdf'; a.click();
        status.textContent = 'Done. ' + (bytes.length / 1024).toFixed(1) + ' KB (was ' + (file.size / 1024).toFixed(1) + ' KB).';
      } catch (e) { status.textContent = 'Failed: ' + e.message; }
      btn.disabled = false;
    });
  })();
</script>
</BaseLayout>
