---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/compress'));
---
<BaseLayout title="Compress PDF · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">PDF · Compress</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Compress PDF</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Real reduction: each page is rendered at a chosen resolution and re-encoded as an optimised JPEG, then reassembled — the same method desktop PDF compressors use. Or keep vector text sharp with lossless optimise. Runs entirely in your browser.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="application/pdf" class="block w-full text-[0.92rem] file:bg-burn file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <p id="meta" class="text-[0.85rem] text-ink-soft m-0"></p>

    <label class="block">
      <span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Compression level</span>
      <select id="preset" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink">
        <option value="strong">Strong — smallest (screen, 96 dpi)</option>
        <option value="balanced" selected>Balanced — recommended (ebook, 130 dpi)</option>
        <option value="light">Light — high quality (print, 170 dpi)</option>
        <option value="lossless">Lossless — keep vector text sharp (optimise only)</option>
      </select>
    </label>
    <div id="grayRow" class="flex items-center gap-2">
      <input type="checkbox" id="gray" class="w-4 h-4" />
      <label for="gray" class="text-[0.88rem] text-ink-2">Convert to greyscale (extra shrink for scans)</label>
    </div>

    <button id="goBtn" class="bg-burn hover:bg-burn/90 text-white font-semibold py-3 px-6 rounded-xl text-[0.92rem]" disabled style="opacity:0.5;">Compress PDF</button>
    <div id="prog" class="hidden"><div class="w-full h-2 bg-cream rounded-full overflow-hidden"><div id="bar" class="h-full bg-burn rounded-full" style="width:0%"></div></div></div>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>

    <div id="result" class="hidden bg-cream rounded-xl p-4 flex items-center justify-between gap-3 flex-wrap">
      <span class="text-[0.9rem] text-ink font-semibold" id="savedTxt"></span>
      <a id="dlBtn" class="bg-leaf hover:bg-leaf/90 text-white font-semibold py-2.5 px-5 rounded-xl text-[0.88rem] no-underline">Download</a>
    </div>
  </div>
</section>
<script is:inline src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script is:inline>
  (function () {
    if (window.pdfjsLib) window.pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    var file = null, $ = function (id) { return document.getElementById(id); };
    var fi = $('fileInput'), meta = $('meta'), btn = $('goBtn'), status = $('status');
    function kb(b) { return b < 1048576 ? (b / 1024).toFixed(1) + ' KB' : (b / 1048576).toFixed(2) + ' MB'; }
    fi.addEventListener('change', function () { if (!fi.files[0]) return; file = fi.files[0]; meta.textContent = file.name + ' · ' + kb(file.size); btn.disabled = false; btn.style.opacity = '1'; $('result').classList.add('hidden'); });

    var LV = { strong: { dpi: 96, q: 0.52 }, balanced: { dpi: 130, q: 0.68 }, light: { dpi: 170, q: 0.82 } };
    function dataURLtoBytes(u) { var b = atob(u.split(',')[1]), n = b.length, a = new Uint8Array(n); for (var i = 0; i < n; i++) a[i] = b.charCodeAt(i); return a; }

    btn.addEventListener('click', async function () {
      if (!file) return; btn.disabled = true; $('result').classList.add('hidden'); status.textContent = 'Reading…';
      var preset = $('preset').value; var gray = $('gray').checked;
      try {
        var buf = new Uint8Array(await file.arrayBuffer());
        if (preset === 'lossless') {
          var doc = await PDFLib.PDFDocument.load(buf, { ignoreEncryption: true });
          var bytes = await doc.save({ useObjectStreams: true });
          finish(bytes); return;
        }
        var cfg = LV[preset];
        var pdf = await pdfjsLib.getDocument({ data: buf }).promise;
        var out = await PDFLib.PDFDocument.create();
        $('prog').classList.remove('hidden');
        for (var p = 1; p <= pdf.numPages; p++) {
          status.textContent = 'Compressing page ' + p + ' / ' + pdf.numPages + '…'; $('bar').style.width = Math.round(p / pdf.numPages * 100) + '%';
          var page = await pdf.getPage(p);
          var vp1 = page.getViewport({ scale: 1 });            // points (72 dpi) = final page size
          var scale = cfg.dpi / 72;
          var vp = page.getViewport({ scale: scale });
          var c = document.createElement('canvas'); c.width = Math.round(vp.width); c.height = Math.round(vp.height);
          var ctx = c.getContext('2d'); ctx.fillStyle = '#fff'; ctx.fillRect(0, 0, c.width, c.height);
          await page.render({ canvasContext: ctx, viewport: vp }).promise;
          if (gray) { var id = ctx.getImageData(0, 0, c.width, c.height), d = id.data; for (var i = 0; i < d.length; i += 4) { var v = (d[i] * 0.299 + d[i + 1] * 0.587 + d[i + 2] * 0.114) | 0; d[i] = d[i + 1] = d[i + 2] = v; } ctx.putImageData(id, 0, 0); }
          var jpg = c.toDataURL('image/jpeg', cfg.q);
          var img = await out.embedJpg(dataURLtoBytes(jpg));
          var pg = out.addPage([vp1.width, vp1.height]); pg.drawImage(img, { x: 0, y: 0, width: vp1.width, height: vp1.height });
          await new Promise(function (r) { setTimeout(r, 0); }); // yield to keep UI responsive
        }
        var bytes2 = await out.save({ useObjectStreams: true });
        // never inflate: if rasterising grew the file (already-compressed text PDF), fall back to lossless optimise
        if (bytes2.length >= file.size) {
          status.textContent = 'This PDF is mostly text — rasterising would enlarge it, so it was optimised losslessly instead.';
          var d2 = await PDFLib.PDFDocument.load(buf, { ignoreEncryption: true }); var lb = await d2.save({ useObjectStreams: true });
          finish(lb.length < file.size ? lb : buf); return;
        }
        finish(bytes2);
      } catch (e) { status.textContent = 'Could not compress: ' + (e && e.message || e); btn.disabled = false; $('prog').classList.add('hidden'); }
    });

    function finish(bytes) {
      $('prog').classList.add('hidden'); btn.disabled = false;
      var blob = new Blob([bytes], { type: 'application/pdf' }); var url = URL.createObjectURL(blob);
      var saved = 1 - blob.size / file.size;
      $('savedTxt').textContent = saved > 0.005 ? ('Saved ' + (saved * 100).toFixed(0) + '% — ' + kb(file.size) + ' → ' + kb(blob.size)) : ('Result ' + kb(blob.size) + ' (already well-compressed)');
      var dl = $('dlBtn'); dl.href = url; dl.download = file.name.replace(/\.pdf$/i, '') + '-compressed.pdf';
      $('result').classList.remove('hidden'); if (!status.textContent) status.textContent = 'Done.';
    }
  })();
</script>
</BaseLayout>
