---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/img-bgremove'));
---
<BaseLayout title="Remove background · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-sky font-bold mb-2">Image · AI Background removal</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Remove background</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Runs a real ML model in your browser (downloads ~30 MB the first time, then cached). Best on subjects with clear edges — people, products, animals.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="image/*" class="block w-full text-[0.92rem] file:bg-sky file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <button id="goBtn" class="bg-sky hover:bg-sky/90 text-white font-semibold py-3 px-6 rounded-xl text-[0.92rem]" disabled style="opacity:0.5;">Remove background</button>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
    <div id="result" class="grid grid-cols-1 md:grid-cols-2 gap-4" style="display:none;">
      <div><p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold m-0 mb-2">Original</p><img id="origImg" style="max-width:100%;border-radius:8px;border:1px solid rgba(14,11,8,0.10);" /></div>
      <div><p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold m-0 mb-2">Result (transparent bg)</p><div style="background-image:linear-gradient(45deg,#eee 25%,transparent 25%,transparent 75%,#eee 75%,#eee),linear-gradient(45deg,#eee 25%,transparent 25%,transparent 75%,#eee 75%,#eee);background-size:14px 14px;background-position:0 0,7px 7px;border-radius:8px;border:1px solid rgba(14,11,8,0.10);padding:4px;"><img id="outImg" style="max-width:100%;display:block;" /></div></div>
    </div>
    <button id="dlBtn" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-5 rounded-xl text-[0.85rem]" style="display:none;">Download PNG</button>
  </div>
</section>
<script is:inline type="module">
  import { removeBackground } from 'https://cdn.jsdelivr.net/npm/@imgly/background-removal@1.4.5/+esm';
  window.__bgRemove = removeBackground;
</script>
<script is:inline>
  (function () {
    var file = null;
    document.getElementById('fileInput').addEventListener('change', function (e) {
      file = e.target.files[0]; var b = document.getElementById('goBtn'); b.disabled = !file; b.style.opacity = file ? '1' : '0.5';
      if (file) { document.getElementById('origImg').src = URL.createObjectURL(file); }
    });
    document.getElementById('goBtn').addEventListener('click', async function () {
      if (!file) return;
      var btn = document.getElementById('goBtn'); btn.disabled = true;
      var status = document.getElementById('status'); status.textContent = 'Loading model... (~30 MB on first run, cached after)';
      try {
        var waitFor = 0;
        while (!window.__bgRemove && waitFor < 50) { await new Promise(function (r) { setTimeout(r, 200); }); waitFor++; }
        if (!window.__bgRemove) { status.textContent = 'Model failed to load. Check connection.'; btn.disabled = false; return; }
        status.textContent = 'Processing image...';
        var blob = await window.__bgRemove(file, { progress: function (k, c, t) { status.textContent = 'Processing... ' + Math.round((c / t) * 100) + '%'; } });
        var url = URL.createObjectURL(blob);
        document.getElementById('outImg').src = url;
        document.getElementById('result').style.display = 'grid';
        var dl = document.getElementById('dlBtn'); dl.style.display = 'inline-block';
        dl.onclick = function () { var a = document.createElement('a'); a.href = url; a.download = file.name.replace(/\.[^.]+$/, '') + '-no-bg.png'; a.click(); };
        status.textContent = 'Done.';
      } catch (e) { status.textContent = 'Failed: ' + e.message; }
      btn.disabled = false;
    });
  })();
</script>
</BaseLayout>
