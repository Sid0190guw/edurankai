---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/img-compress'));
---
<BaseLayout title="Compress image · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-sky font-bold mb-2">Image · Compress</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Compress image</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Reduce JPG / PNG file size at the quality you choose. Re-encoded fully in your browser.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="image/*" class="block w-full text-[0.92rem] file:bg-sky file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <p id="meta" class="text-[0.85rem] text-ink-soft m-0"></p>
    <label class="block">
      <span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Quality: <span id="qVal">75</span>%</span>
      <input id="quality" type="range" min="10" max="100" value="75" class="w-full" />
    </label>
    <label class="block">
      <span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Output format</span>
      <select id="fmt" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink">
        <option value="image/jpeg">JPEG (best compression)</option>
        <option value="image/webp">WebP (modern, smallest)</option>
        <option value="image/png">PNG (lossless)</option>
      </select>
    </label>
    <button id="goBtn" class="bg-sky hover:bg-sky/90 text-white font-semibold py-3 px-6 rounded-xl text-[0.92rem]" disabled style="opacity:0.5;">Compress & download</button>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
  </div>
</section>
<script is:inline>
  (function () {
    var file = null; var fi = document.getElementById('fileInput');
    var meta = document.getElementById('meta'); var btn = document.getElementById('goBtn'); var status = document.getElementById('status');
    var qIn = document.getElementById('quality'); var qVal = document.getElementById('qVal');
    qIn.addEventListener('input', function () { qVal.textContent = qIn.value; });
    fi.addEventListener('change', function () { if (!fi.files[0]) return; file = fi.files[0]; meta.textContent = file.name + ' · ' + (file.size / 1024).toFixed(1) + ' KB'; btn.disabled = false; btn.style.opacity = '1'; });
    btn.addEventListener('click', function () {
      if (!file) return; btn.disabled = true; status.textContent = 'Compressing...';
      var url = URL.createObjectURL(file); var img = new Image();
      img.onload = function () {
        var c = document.createElement('canvas'); c.width = img.naturalWidth; c.height = img.naturalHeight;
        c.getContext('2d').drawImage(img, 0, 0);
        var fmt = document.getElementById('fmt').value; var q = parseInt(qIn.value, 10) / 100;
        c.toBlob(function (blob) {
          var a = document.createElement('a'); a.href = URL.createObjectURL(blob);
          var ext = fmt.split('/')[1]; a.download = file.name.replace(/\.[^.]+$/, '') + '-compressed.' + (ext === 'jpeg' ? 'jpg' : ext);
          a.click();
          status.textContent = 'Done. ' + (blob.size / 1024).toFixed(1) + ' KB (was ' + (file.size / 1024).toFixed(1) + ' KB).';
          btn.disabled = false;
        }, fmt, q);
      };
      img.src = url;
    });
  })();
</script>
</BaseLayout>
