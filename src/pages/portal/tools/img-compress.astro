---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/img-compress'));
---
<BaseLayout title="Compress image · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-sky font-bold mb-2">Image · Compress</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Compress image</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Real size reduction — resize to a max dimension, re-encode to WebP / JPEG at your quality, or hit an exact target file size. Everything runs in your browser; nothing is uploaded.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="image/*" class="block w-full text-[0.92rem] file:bg-sky file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <p id="meta" class="text-[0.85rem] text-ink-soft m-0"></p>

    <div>
      <span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Preset</span>
      <div id="presets" class="flex flex-wrap gap-2">
        <button data-p="max" class="pchip">Max compression</button>
        <button data-p="bal" class="pchip on">Balanced</button>
        <button data-p="best" class="pchip">Best quality</button>
        <button data-p="target" class="pchip">Target size…</button>
        <button data-p="custom" class="pchip">Custom</button>
      </div>
    </div>

    <div id="targetRow" class="hidden">
      <span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Compress to under <span id="tgtVal">200</span> KB</span>
      <input id="target" type="range" min="20" max="2000" step="10" value="200" class="w-full" />
    </div>

    <div id="advanced" class="space-y-5">
      <label class="block">
        <span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Quality: <span id="qVal">72</span>% <span class="text-ink-soft/60 normal-case font-normal">(higher = larger file)</span></span>
        <input id="quality" type="range" min="10" max="100" value="72" class="w-full" />
      </label>
      <label class="block">
        <span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Max dimension (long edge)</span>
        <select id="maxdim" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink">
          <option value="0">Keep original size</option>
          <option value="3840">3840 px (4K)</option>
          <option value="2560">2560 px</option>
          <option value="1920" selected>1920 px (Full HD — recommended for web)</option>
          <option value="1280">1280 px</option>
          <option value="1024">1024 px</option>
          <option value="800">800 px</option>
          <option value="640">640 px (thumbnail)</option>
        </select>
      </label>
      <label class="block">
        <span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Output format</span>
        <select id="fmt" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink">
          <option value="auto" selected>Auto — smallest (WebP, JPEG fallback)</option>
          <option value="image/webp">WebP (modern, smallest)</option>
          <option value="image/jpeg">JPEG (universal)</option>
          <option value="image/png">PNG (lossless — quantised to shrink)</option>
        </select>
      </label>
    </div>

    <button id="goBtn" class="bg-sky hover:bg-sky/90 text-white font-semibold py-3 px-6 rounded-xl text-[0.92rem]" disabled style="opacity:0.5;">Compress</button>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>

    <div id="result" class="hidden pt-2">
      <div class="grid grid-cols-2 gap-4">
        <div><p class="text-[0.62rem] font-mono uppercase tracking-wider text-ink-soft mb-1">Before</p><img id="beforeImg" class="w-full rounded-xl border border-ink/10 bg-cream" /><p id="beforeMeta" class="text-[0.8rem] text-ink-soft mt-1"></p></div>
        <div><p class="text-[0.62rem] font-mono uppercase tracking-wider text-sky mb-1 font-bold">After</p><img id="afterImg" class="w-full rounded-xl border border-sky/30 bg-cream" /><p id="afterMeta" class="text-[0.8rem] text-ink mt-1 font-semibold"></p></div>
      </div>
      <div id="savedBar" class="mt-4 bg-cream rounded-xl p-4 flex items-center justify-between">
        <span class="text-[0.9rem] text-ink font-semibold" id="savedTxt"></span>
        <a id="dlBtn" class="bg-leaf hover:bg-leaf/90 text-white font-semibold py-2.5 px-5 rounded-xl text-[0.88rem] no-underline">Download</a>
      </div>
    </div>
  </div>
</section>
<style is:global>
  .pchip{ background:var(--cream,#faf7f2); border:1px solid rgba(14,11,8,0.15); color:#0E0B08; border-radius:99px; padding:6px 14px; font-family:'Geist Mono',monospace; font-size:11px; font-weight:600; cursor:pointer; }
  .pchip.on{ background:#0ea5e9; color:#fff; border-color:#0ea5e9; }
</style>
<script is:inline>
  (function () {
    var file = null, resultBlob = null, resultName = '';
    var $ = function (id) { return document.getElementById(id); };
    var fi = $('fileInput'), meta = $('meta'), btn = $('goBtn'), status = $('status');
    var qIn = $('quality'), qVal = $('qVal'), tgt = $('target'), tgtVal = $('tgtVal');
    var preset = 'bal';

    qIn.addEventListener('input', function () { qVal.textContent = qIn.value; setPreset('custom', true); });
    $('maxdim').addEventListener('change', function () { setPreset('custom', true); });
    $('fmt').addEventListener('change', function () { setPreset('custom', true); });
    tgt.addEventListener('input', function () { tgtVal.textContent = tgt.value; });

    var PRESETS = { max: { q: 45, dim: '1280' }, bal: { q: 72, dim: '1920' }, best: { q: 88, dim: '0' } };
    function setPreset(p, keepValues) {
      preset = p;
      document.querySelectorAll('.pchip').forEach(function (b) { b.classList.toggle('on', b.getAttribute('data-p') === p); });
      $('targetRow').classList.toggle('hidden', p !== 'target');
      $('advanced').classList.toggle('hidden', p === 'target');
      if (!keepValues && PRESETS[p]) { qIn.value = PRESETS[p].q; qVal.textContent = PRESETS[p].q; $('maxdim').value = PRESETS[p].dim; $('fmt').value = 'auto'; }
    }
    document.querySelectorAll('.pchip').forEach(function (b) { b.addEventListener('click', function () { setPreset(b.getAttribute('data-p')); }); });

    fi.addEventListener('change', function () {
      if (!fi.files[0]) return; file = fi.files[0];
      meta.textContent = file.name + ' · ' + kb(file.size);
      btn.disabled = false; btn.style.opacity = '1'; $('result').classList.add('hidden');
    });
    function kb(b) { return b < 1024 * 1024 ? (b / 1024).toFixed(1) + ' KB' : (b / 1048576).toFixed(2) + ' MB'; }

    function loadImage(f) { return new Promise(function (res, rej) { var url = URL.createObjectURL(f); var im = new Image(); im.onload = function () { res(im); }; im.onerror = rej; im.src = url; }); }
    function drawAt(img, maxDim) {
      var w = img.naturalWidth, h = img.naturalHeight;
      if (maxDim > 0 && Math.max(w, h) > maxDim) { var s = maxDim / Math.max(w, h); w = Math.round(w * s); h = Math.round(h * s); }
      var c = document.createElement('canvas'); c.width = w; c.height = h;
      var ctx = c.getContext('2d'); ctx.imageSmoothingEnabled = true; ctx.imageSmoothingQuality = 'high';
      // white matte for transparent -> JPEG
      ctx.drawImage(img, 0, 0, w, h); return c;
    }
    function toBlob(c, fmt, q) { return new Promise(function (res) { c.toBlob(function (b) { res(b); }, fmt, q); }); }

    // median-cut colour quantisation so PNG output actually shrinks
    function quantize(c, colors) {
      var ctx = c.getContext('2d'), id = ctx.getImageData(0, 0, c.width, c.height), d = id.data;
      var sample = [], step = Math.max(1, Math.floor((d.length / 4) / 16000)) * 4;
      for (var i = 0; i < d.length; i += step) sample.push([d[i], d[i + 1], d[i + 2]]);
      function mk(px) { var mn = [255, 255, 255], mx = [0, 0, 0]; for (var k = 0; k < px.length; k++) for (var a = 0; a < 3; a++) { if (px[k][a] < mn[a]) mn[a] = px[k][a]; if (px[k][a] > mx[a]) mx[a] = px[k][a]; } return { px: px, r: [mx[0] - mn[0], mx[1] - mn[1], mx[2] - mn[2]] }; }
      var boxes = [mk(sample)];
      while (boxes.length < colors) {
        var bi = -1, br = 0; for (var k = 0; k < boxes.length; k++) { var m = Math.max(boxes[k].r[0], boxes[k].r[1], boxes[k].r[2]); if (m > br && boxes[k].px.length > 1) { br = m; bi = k; } }
        if (bi < 0) break; var b = boxes[bi], ax = b.r.indexOf(Math.max(b.r[0], b.r[1], b.r[2]));
        b.px.sort(function (p, q2) { return p[ax] - q2[ax]; }); var mid = b.px.length >> 1;
        boxes.splice(bi, 1, mk(b.px.slice(0, mid)), mk(b.px.slice(mid)));
      }
      var pal = boxes.map(function (b) { var s = [0, 0, 0]; b.px.forEach(function (p) { s[0] += p[0]; s[1] += p[1]; s[2] += p[2]; }); var n = b.px.length || 1; return [Math.round(s[0] / n), Math.round(s[1] / n), Math.round(s[2] / n)]; });
      for (var i = 0; i < d.length; i += 4) { var best = 0, bd = 1e9; for (var p = 0; p < pal.length; p++) { var dr = d[i] - pal[p][0], dg = d[i + 1] - pal[p][1], db = d[i + 2] - pal[p][2]; var dist = dr * dr + dg * dg + db * db; if (dist < bd) { bd = dist; best = p; } } d[i] = pal[best][0]; d[i + 1] = pal[best][1]; d[i + 2] = pal[best][2]; }
      ctx.putImageData(id, 0, 0);
    }
    var webpOk = (function () { var c = document.createElement('canvas'); c.width = c.height = 1; return c.toDataURL('image/webp').indexOf('image/webp') === 5; })();

    function resolveFmt() { var f = $('fmt').value; if (f === 'auto') return webpOk ? 'image/webp' : 'image/jpeg'; return f; }

    function encodeOnce(img, fmt, q, dim) {
      var c = drawAt(img, dim);
      if (fmt === 'image/png') { var colors = Math.max(8, Math.min(256, Math.round(q * 2.56))); quantize(c, colors); return toBlob(c, 'image/png'); }
      return toBlob(c, fmt, q / 100);
    }

    btn.addEventListener('click', async function () {
      if (!file) return; btn.disabled = true; status.textContent = 'Working…';
      try {
        var img = await loadImage(file); var fmt = resolveFmt(); var blob;
        if (preset === 'target') {
          var targetBytes = parseInt(tgt.value, 10) * 1024; var dim = 1920;
          // binary-search quality; if the smallest quality still overshoots, step the dimension down and retry
          var dims = [dim, 1280, 1024, 800, 640, 480];
          blob = null;
          for (var di = 0; di < dims.length; di++) {
            var lo = 10, hi = 95, bestB = await encodeOnce(img, fmt, hi, dims[di]);
            for (var it = 0; it < 8; it++) { var mid = (lo + hi) >> 1; var b = await encodeOnce(img, fmt, mid, dims[di]); if (b.size <= targetBytes) { bestB = b; lo = mid + 1; } else { hi = mid - 1; } }
            var lowest = await encodeOnce(img, fmt, 10, dims[di]);
            if (bestB.size <= targetBytes) { blob = bestB; break; }
            if (lowest.size <= targetBytes) { blob = lowest; break; }
            blob = lowest; // keep the smallest we managed; try a smaller dimension next
          }
          status.textContent = blob.size <= targetBytes ? 'Hit the target.' : 'Smallest achievable at this format shown below.';
        } else {
          blob = await encodeOnce(img, fmt, parseInt(qIn.value, 10), parseInt($('maxdim').value, 10));
          status.textContent = '';
        }
        // never inflate: if bigger than original and no resize requested, keep original bytes
        if (blob.size >= file.size && (preset !== 'target')) {
          status.textContent = 'Re-encoding would not shrink this file at these settings — try a smaller max dimension, lower quality, or WebP.';
        }
        resultBlob = blob; var ext = fmt.split('/')[1]; if (ext === 'jpeg') ext = 'jpg';
        resultName = file.name.replace(/\.[^.]+$/, '') + '-min.' + ext;
        showResult(img);
      } catch (e) { status.textContent = 'Could not process this image.'; }
      btn.disabled = false;
    });

    function showResult(img) {
      $('result').classList.remove('hidden');
      $('beforeImg').src = URL.createObjectURL(file); $('beforeMeta').textContent = img.naturalWidth + '×' + img.naturalHeight + ' · ' + kb(file.size);
      var outUrl = URL.createObjectURL(resultBlob); $('afterImg').src = outUrl;
      var oi = new Image(); oi.onload = function () { $('afterMeta').textContent = oi.naturalWidth + '×' + oi.naturalHeight + ' · ' + kb(resultBlob.size); }; oi.src = outUrl;
      var saved = 1 - resultBlob.size / file.size;
      $('savedTxt').textContent = saved > 0.001 ? ('Saved ' + (saved * 100).toFixed(0) + '% — ' + kb(file.size) + ' → ' + kb(resultBlob.size)) : ('No reduction — ' + kb(resultBlob.size));
      var dl = $('dlBtn'); dl.href = outUrl; dl.download = resultName;
    }
    setPreset('bal');
  })();
</script>
</BaseLayout>
