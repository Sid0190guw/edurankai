---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/rotate'));
---
<BaseLayout title="Rotate PDF · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">PDF · Rotate</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Rotate PDF pages</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Rotate all pages, or a specific page range, by 90 / 180 / 270 degrees.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="application/pdf" class="block w-full text-[0.92rem] file:bg-burn file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <p id="meta" class="text-[0.85rem] text-ink-soft m-0"></p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <label class="block">
        <span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Angle</span>
        <select id="angle" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink">
          <option value="90">90° clockwise</option>
          <option value="180">180°</option>
          <option value="270">90° counter-clockwise</option>
        </select>
      </label>
      <label class="block">
        <span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Pages (blank = all)</span>
        <input id="ranges" type="text" placeholder="e.g. 1-3, 5" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink font-mono" />
      </label>
    </div>
    <button id="goBtn" class="btn-primary" disabled style="opacity:0.5;">Rotate & download</button>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
  </div>
</section>

<script is:inline src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
<script is:inline>
  (function () {
    var file = null; var fi = document.getElementById('fileInput');
    var meta = document.getElementById('meta'); var btn = document.getElementById('goBtn');
    var status = document.getElementById('status'); var pageCount = 0;
    fi.addEventListener('change', async function () {
      if (!fi.files[0]) return; file = fi.files[0];
      var src = await PDFLib.PDFDocument.load(new Uint8Array(await file.arrayBuffer()), { ignoreEncryption: true });
      pageCount = src.getPageCount();
      meta.textContent = file.name + ' · ' + pageCount + ' pages';
      btn.disabled = false; btn.style.opacity = '1';
    });
    function parseRanges(spec, max) {
      var out = [];
      spec.split(',').forEach(function (p) { p = p.trim(); if (!p) return;
        if (p.indexOf('-') >= 0) { var pp = p.split('-').map(function (s) { return parseInt(s.trim(), 10); });
          for (var i = pp[0]; i <= pp[1]; i++) if (i >= 1 && i <= max) out.push(i - 1);
        } else { var n = parseInt(p, 10); if (n >= 1 && n <= max) out.push(n - 1); }
      }); return out;
    }
    btn.addEventListener('click', async function () {
      if (!file) return; btn.disabled = true; status.textContent = 'Rotating...';
      try {
        var src = await PDFLib.PDFDocument.load(new Uint8Array(await file.arrayBuffer()), { ignoreEncryption: true });
        var ranges = document.getElementById('ranges').value.trim();
        var idx = ranges ? parseRanges(ranges, pageCount) : src.getPageIndices();
        var angle = parseInt(document.getElementById('angle').value, 10);
        idx.forEach(function (i) {
          var page = src.getPage(i);
          var cur = page.getRotation().angle;
          page.setRotation(PDFLib.degrees((cur + angle) % 360));
        });
        var blob = new Blob([await src.save()], { type: 'application/pdf' });
        var a = document.createElement('a'); a.href = URL.createObjectURL(blob);
        a.download = file.name.replace(/\.pdf$/i, '') + '-rotated.pdf'; a.click();
        status.textContent = 'Rotated ' + idx.length + ' page(s).';
      } catch (e) { status.textContent = 'Failed: ' + e.message; }
      btn.disabled = false;
    });
  })();
</script>
</BaseLayout>
