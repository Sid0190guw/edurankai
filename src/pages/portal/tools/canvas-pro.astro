---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/canvas-pro'));
---
<BaseLayout title="Canvas Pro · EduRankAI Tools" description="Adobe-style layered image editor. Brushes, filters, layers, blend modes, masks. Built from scratch in HTML5 Canvas.">

<style>
  body { background: #1a1a1f; color: #e8e8ee; margin: 0; }
  .cp-shell { display: grid; grid-template-rows: 42px 1fr; height: 100vh; }
  .cp-toolbar { background: #11131a; border-bottom: 1px solid #2a2a35; display: flex; align-items: center; padding: 0 12px; gap: 10px; font-family: 'Geist Mono', monospace; font-size: 11px; color: #cfd6da; letter-spacing: 0.06em; }
  .cp-toolbar a { color: #67e8f9; text-decoration: none; }
  .cp-toolbar button { background: transparent; border: 1px solid #2a2a35; color: #cfd6da; padding: 5px 12px; border-radius: 4px; cursor: pointer; font-family: inherit; font-size: 10.5px; letter-spacing: 0.06em; text-transform: uppercase; }
  .cp-toolbar button.primary { background: #FF4F00; color: #fff; border-color: #FF4F00; }
  .cp-main { display: grid; grid-template-columns: 56px 1fr 260px; overflow: hidden; }

  .cp-tools { background: #0a0a0c; border-right: 1px solid #2a2a35; padding: 8px 0; display: flex; flex-direction: column; gap: 4px; }
  .cp-tool { background: transparent; border: none; color: #9aa6b6; padding: 10px; cursor: pointer; display: flex; justify-content: center; }
  .cp-tool:hover { background: #1a1a25; color: #fff; }
  .cp-tool.active { background: #FF4F00; color: #fff; }
  .cp-tool svg { width: 18px; height: 18px; }

  .cp-canvas-stage { background: #08080a; display: flex; align-items: center; justify-content: center; overflow: auto; padding: 24px; }
  #stack { position: relative; box-shadow: 0 0 0 1px #2a2a35, 0 16px 60px rgba(0,0,0,0.6); cursor: crosshair; background-image: linear-gradient(45deg, #1a1a1f 25%, transparent 25%, transparent 75%, #1a1a1f 75%, #1a1a1f), linear-gradient(45deg, #1a1a1f 25%, transparent 25%, transparent 75%, #1a1a1f 75%, #1a1a1f); background-size: 16px 16px; background-position: 0 0, 8px 8px; }
  .cp-layer { position: absolute; top: 0; left: 0; pointer-events: none; }

  .cp-panels { background: #0a0a0c; border-left: 1px solid #2a2a35; overflow-y: auto; }
  .cp-panel { border-bottom: 1px solid #1a1a25; padding: 12px 14px; }
  .cp-panel h3 { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; margin: 0 0 8px; font-weight: 700; }
  .cp-panel label { display: block; font-family: 'Geist Mono', monospace; font-size: 9.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #9aa6b6; margin-bottom: 3px; font-weight: 700; }
  .cp-panel input[type=number], .cp-panel input[type=text], .cp-panel select { width: 100%; background: #11131a; border: 1px solid #2a2a35; color: #fff; padding: 5px 8px; border-radius: 4px; font-size: 11.5px; box-sizing: border-box; }
  .cp-panel input[type=range] { width: 100%; }
  .cp-row { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-bottom: 6px; }

  .cp-layer-row { display: flex; align-items: center; gap: 8px; padding: 6px 8px; border-radius: 4px; background: #11131a; margin-bottom: 4px; cursor: pointer; }
  .cp-layer-row.active { background: #1a1a25; border: 1px solid #FF4F00; }
  .cp-layer-thumb { width: 28px; height: 28px; background: #2a2a35; border-radius: 3px; flex-shrink: 0; }
  .cp-layer-name { font-size: 12px; color: #cfd6da; flex: 1; }
  .cp-layer-eye { background: transparent; border: none; color: #67e8f9; cursor: pointer; font-size: 14px; padding: 0 4px; }
  .cp-layer-eye.off { color: #4a4f5e; }
  .cp-layer-actions { display: flex; gap: 4px; margin-top: 8px; }
  .cp-layer-actions button { background: transparent; border: 1px solid #2a2a35; color: #cfd6da; padding: 3px 8px; border-radius: 4px; font-size: 10.5px; cursor: pointer; font-family: 'Geist Mono', monospace; }
</style>

<div class="cp-shell">

  <div class="cp-toolbar">
    <a href="/portal/tools">← Tools</a>
    <span>EduRankAI Canvas Pro · v1.0</span>
    <span style="margin-left:auto;color:#6e6e78;">Z/Y undo · Drag · Layers</span>
    <button id="undoBtn">Undo</button>
    <button id="redoBtn">Redo</button>
    <button id="importBtn">Import</button>
    <input type="file" id="imgFile" accept="image/*" style="display:none;"/>
    <button class="primary" id="exportBtn">Export PNG</button>
  </div>

  <div class="cp-main">

    {/* TOOL BAR (left) */}
    <div class="cp-tools">
      <button class="cp-tool active" data-tool="brush" title="Brush"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg></button>
      <button class="cp-tool" data-tool="erase" title="Erase"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 3l5 5L8 21H3v-5L16 3z"/></svg></button>
      <button class="cp-tool" data-tool="line" title="Line"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="19" x2="19" y2="5"/></svg></button>
      <button class="cp-tool" data-tool="rect" title="Rectangle"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18"/></svg></button>
      <button class="cp-tool" data-tool="ellipse" title="Ellipse"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="12" rx="10" ry="7"/></svg></button>
      <button class="cp-tool" data-tool="text" title="Text"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg></button>
      <button class="cp-tool" data-tool="picker" title="Eyedropper"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="6" cy="18" r="3"/><path d="M9 15l5.41-5.41"/><path d="M22.61 1.39a2 2 0 0 0-2.83 0L11.41 9.76a2 2 0 0 0 0 2.83l1.41 1.41a2 2 0 0 0 2.83 0l8.37-8.37a2 2 0 0 0 0-2.83l-1.41-1.41z"/></svg></button>
    </div>

    {/* STAGE */}
    <div class="cp-canvas-stage">
      <div id="stack" style="width:800px;height:600px;"></div>
    </div>

    {/* SIDE PANELS */}
    <aside class="cp-panels">
      <div class="cp-panel">
        <h3>Canvas</h3>
        <div class="cp-row">
          <div><label>W</label><input id="cWidth" type="number" value="800"/></div>
          <div><label>H</label><input id="cHeight" type="number" value="600"/></div>
        </div>
        <button id="resizeBtn" style="background:#FF4F00;color:#fff;border:none;padding:6px 14px;border-radius:5px;font-size:10.5px;font-weight:700;cursor:pointer;font-family:'Geist Mono',monospace;letter-spacing:0.06em;text-transform:uppercase;width:100%;">Resize</button>
      </div>

      <div class="cp-panel">
        <h3>Brush</h3>
        <div class="cp-row">
          <div><label>Size</label><input id="brushSize" type="number" value="6" min="1" max="200"/></div>
          <div><label>Opacity</label><input id="brushOp" type="number" value="100" min="1" max="100"/></div>
        </div>
        <label>Color</label>
        <input id="brushColor" type="color" value="#FF4F00" style="width:100%;height:32px;background:#11131a;border:1px solid #2a2a35;border-radius:4px;cursor:pointer;"/>
      </div>

      <div class="cp-panel">
        <h3>Layers</h3>
        <div id="layerList"></div>
        <div class="cp-layer-actions">
          <button id="newLayerBtn">+ Layer</button>
          <button id="dupLayerBtn">Duplicate</button>
          <button id="delLayerBtn">Delete</button>
        </div>
        <div style="margin-top:10px;">
          <label>Active layer opacity</label>
          <input id="layerOp" type="range" min="0" max="100" value="100"/>
          <label style="margin-top:6px;">Blend mode</label>
          <select id="blendMode">
            <option value="source-over">Normal</option>
            <option value="multiply">Multiply</option>
            <option value="screen">Screen</option>
            <option value="overlay">Overlay</option>
            <option value="darken">Darken</option>
            <option value="lighten">Lighten</option>
            <option value="color-dodge">Color dodge</option>
            <option value="color-burn">Color burn</option>
            <option value="difference">Difference</option>
            <option value="exclusion">Exclusion</option>
            <option value="hue">Hue</option>
            <option value="saturation">Saturation</option>
            <option value="color">Color</option>
            <option value="luminosity">Luminosity</option>
          </select>
        </div>
      </div>

      <div class="cp-panel">
        <h3>Filters · active layer</h3>
        <label>Brightness</label><input class="filt" data-f="brightness" type="range" min="0" max="200" value="100"/>
        <label>Contrast</label><input class="filt" data-f="contrast" type="range" min="0" max="200" value="100"/>
        <label>Saturation</label><input class="filt" data-f="saturate" type="range" min="0" max="200" value="100"/>
        <label>Hue rotate</label><input class="filt" data-f="hue-rotate" type="range" min="0" max="360" value="0"/>
        <label>Blur (px)</label><input class="filt" data-f="blur" type="range" min="0" max="30" value="0"/>
        <label>Sepia</label><input class="filt" data-f="sepia" type="range" min="0" max="100" value="0"/>
        <label>Grayscale</label><input class="filt" data-f="grayscale" type="range" min="0" max="100" value="0"/>
        <label>Invert</label><input class="filt" data-f="invert" type="range" min="0" max="100" value="0"/>
      </div>
    </aside>
  </div>
</div>

<script is:inline>
  /* ============================================================
     EduRankAI Canvas Pro — Adobe-style raster editor.
     - Stacked HTML5 canvases per layer (with blend mode)
     - Brush / erase / line / rect / ellipse / text / color-picker
     - Per-layer filters via CSS filter prop on the canvas element
     - Undo / redo (per-layer pixel snapshots)
     - PNG export = flatten all visible layers then download
     - NO 3rd-party libs.
     ============================================================ */
  (function () {
    var stack = document.getElementById('stack');
    var W = 800, H = 600;
    var layers = []; // { id, name, canvas, ctx, visible, opacity, blend, filter:{...}, undoStack, redoStack }
    var activeIdx = 0;
    var tool = 'brush';
    var drawing = false;
    var startPt = null;
    var snapshotBeforeStroke = null;

    function setSize(w, h) {
      W = w; H = h;
      stack.style.width = w + 'px'; stack.style.height = h + 'px';
      layers.forEach(function (l) {
        // resize preserves content via temp draw
        var temp = document.createElement('canvas'); temp.width = l.canvas.width; temp.height = l.canvas.height;
        temp.getContext('2d').drawImage(l.canvas, 0, 0);
        l.canvas.width = w; l.canvas.height = h;
        l.ctx = l.canvas.getContext('2d');
        l.ctx.drawImage(temp, 0, 0);
      });
      render();
    }

    function newLayer(name) {
      var c = document.createElement('canvas');
      c.width = W; c.height = H;
      c.className = 'cp-layer';
      c.style.width = '100%'; c.style.height = '100%';
      stack.appendChild(c);
      var l = {
        id: 'L' + Math.random().toString(36).slice(2, 7),
        name: name || ('Layer ' + (layers.length + 1)),
        canvas: c, ctx: c.getContext('2d'),
        visible: true, opacity: 1, blend: 'source-over',
        filter: { brightness: 100, contrast: 100, saturate: 100, 'hue-rotate': 0, blur: 0, sepia: 0, grayscale: 0, invert: 0 },
        undoStack: [], redoStack: [],
      };
      layers.push(l);
      activeIdx = layers.length - 1;
      applyLayerStyle(l);
      renderLayerList();
      return l;
    }

    function applyLayerStyle(l) {
      l.canvas.style.opacity = l.opacity;
      l.canvas.style.mixBlendMode = l.blend;
      l.canvas.style.display = l.visible ? '' : 'none';
      var f = l.filter;
      l.canvas.style.filter = 'brightness(' + f.brightness + '%) contrast(' + f.contrast + '%) saturate(' + f.saturate + '%) hue-rotate(' + f['hue-rotate'] + 'deg) blur(' + f.blur + 'px) sepia(' + f.sepia + '%) grayscale(' + f.grayscale + '%) invert(' + f.invert + '%)';
    }

    function render() { layers.forEach(applyLayerStyle); }

    function renderLayerList() {
      var root = document.getElementById('layerList'); root.innerHTML = '';
      // Reverse so topmost shows first.
      for (var i = layers.length - 1; i >= 0; i--) {
        (function (l, idx) {
          var row = document.createElement('div');
          row.className = 'cp-layer-row' + (idx === activeIdx ? ' active' : '');
          // thumb
          var thumb = document.createElement('canvas'); thumb.className = 'cp-layer-thumb'; thumb.width = 28; thumb.height = 28;
          thumb.getContext('2d').drawImage(l.canvas, 0, 0, 28, 28);
          row.appendChild(thumb);
          var name = document.createElement('span'); name.className = 'cp-layer-name'; name.textContent = l.name;
          name.addEventListener('dblclick', function () { var nv = prompt('Layer name', l.name); if (nv) { l.name = nv; renderLayerList(); } });
          row.appendChild(name);
          var eye = document.createElement('button'); eye.className = 'cp-layer-eye' + (l.visible ? '' : ' off'); eye.textContent = l.visible ? '◉' : '○';
          eye.addEventListener('click', function (e) { e.stopPropagation(); l.visible = !l.visible; applyLayerStyle(l); renderLayerList(); });
          row.appendChild(eye);
          row.addEventListener('click', function () { activeIdx = idx; renderLayerList(); syncLayerControls(); });
          root.appendChild(row);
        })(layers[i], i);
      }
    }

    function syncLayerControls() {
      var l = layers[activeIdx]; if (!l) return;
      document.getElementById('layerOp').value = Math.round(l.opacity * 100);
      document.getElementById('blendMode').value = l.blend;
      document.querySelectorAll('.filt').forEach(function (i) { var f = i.getAttribute('data-f'); i.value = l.filter[f]; });
    }

    // ========== Drawing ==========
    function pos(e) { var r = stack.getBoundingClientRect(); return { x: ((e.clientX - r.left) / r.width) * W, y: ((e.clientY - r.top) / r.height) * H }; }
    function startStroke() { var l = layers[activeIdx]; if (!l) return; snapshotBeforeStroke = l.ctx.getImageData(0, 0, W, H); }
    function endStroke() { var l = layers[activeIdx]; if (!l || !snapshotBeforeStroke) return; l.undoStack.push(snapshotBeforeStroke); l.redoStack = []; snapshotBeforeStroke = null; renderLayerList(); }

    stack.addEventListener('mousedown', function (e) {
      drawing = true; startPt = pos(e);
      startStroke();
      var l = layers[activeIdx]; if (!l) return;
      l.ctx.lineCap = 'round'; l.ctx.lineJoin = 'round';
      var col = document.getElementById('brushColor').value;
      var sz = parseFloat(document.getElementById('brushSize').value) || 6;
      var op = (parseFloat(document.getElementById('brushOp').value) || 100) / 100;
      l.ctx.globalAlpha = op;
      l.ctx.strokeStyle = col; l.ctx.fillStyle = col; l.ctx.lineWidth = sz;
      if (tool === 'brush' || tool === 'erase') {
        l.ctx.globalCompositeOperation = tool === 'erase' ? 'destination-out' : 'source-over';
        l.ctx.beginPath(); l.ctx.moveTo(startPt.x, startPt.y);
      }
      if (tool === 'text') {
        var t = prompt('Text:'); if (t) { l.ctx.font = (sz * 4) + 'px Georgia,serif'; l.ctx.fillText(t, startPt.x, startPt.y); endStroke(); }
        drawing = false;
      }
      if (tool === 'picker') {
        var px = l.ctx.getImageData(Math.round(startPt.x), Math.round(startPt.y), 1, 1).data;
        var hex = '#' + ('0' + px[0].toString(16)).slice(-2) + ('0' + px[1].toString(16)).slice(-2) + ('0' + px[2].toString(16)).slice(-2);
        document.getElementById('brushColor').value = hex;
        drawing = false; snapshotBeforeStroke = null;
      }
    });
    stack.addEventListener('mousemove', function (e) {
      if (!drawing) return;
      var p = pos(e);
      var l = layers[activeIdx]; if (!l) return;
      if (tool === 'brush' || tool === 'erase') {
        l.ctx.lineTo(p.x, p.y); l.ctx.stroke();
      } else if (tool === 'line' || tool === 'rect' || tool === 'ellipse') {
        l.ctx.putImageData(snapshotBeforeStroke, 0, 0);
        l.ctx.beginPath();
        if (tool === 'line') { l.ctx.moveTo(startPt.x, startPt.y); l.ctx.lineTo(p.x, p.y); l.ctx.stroke(); }
        else if (tool === 'rect') { l.ctx.strokeRect(startPt.x, startPt.y, p.x - startPt.x, p.y - startPt.y); }
        else { var rx = Math.abs(p.x - startPt.x) / 2, ry = Math.abs(p.y - startPt.y) / 2; l.ctx.ellipse((startPt.x + p.x) / 2, (startPt.y + p.y) / 2, rx, ry, 0, 0, Math.PI * 2); l.ctx.stroke(); }
      }
    });
    document.addEventListener('mouseup', function () { if (drawing) { drawing = false; endStroke(); } });

    // ========== Tool selection ==========
    document.querySelectorAll('.cp-tool').forEach(function (b) {
      b.addEventListener('click', function () { tool = b.getAttribute('data-tool'); document.querySelectorAll('.cp-tool').forEach(function (x) { x.classList.remove('active'); }); b.classList.add('active'); });
    });

    // ========== Side controls ==========
    document.getElementById('layerOp').addEventListener('input', function (e) { var l = layers[activeIdx]; if (l) { l.opacity = parseFloat(e.target.value) / 100; applyLayerStyle(l); } });
    document.getElementById('blendMode').addEventListener('change', function (e) { var l = layers[activeIdx]; if (l) { l.blend = e.target.value; applyLayerStyle(l); } });
    document.querySelectorAll('.filt').forEach(function (i) { i.addEventListener('input', function () { var l = layers[activeIdx]; if (l) { l.filter[i.getAttribute('data-f')] = parseFloat(i.value); applyLayerStyle(l); } }); });
    document.getElementById('newLayerBtn').addEventListener('click', function () { newLayer(); });
    document.getElementById('dupLayerBtn').addEventListener('click', function () {
      var l = layers[activeIdx]; if (!l) return;
      var n = newLayer(l.name + ' copy'); n.ctx.drawImage(l.canvas, 0, 0);
    });
    document.getElementById('delLayerBtn').addEventListener('click', function () {
      if (layers.length <= 1) return alert('Cannot delete last layer.');
      var l = layers[activeIdx];
      stack.removeChild(l.canvas);
      layers.splice(activeIdx, 1);
      activeIdx = Math.min(activeIdx, layers.length - 1);
      renderLayerList(); syncLayerControls();
    });

    document.getElementById('resizeBtn').addEventListener('click', function () {
      var w = parseInt(document.getElementById('cWidth').value, 10) || 800;
      var h = parseInt(document.getElementById('cHeight').value, 10) || 600;
      setSize(w, h);
    });

    // ========== Undo / Redo ==========
    function undo() { var l = layers[activeIdx]; if (!l || l.undoStack.length === 0) return; l.redoStack.push(l.ctx.getImageData(0, 0, W, H)); l.ctx.putImageData(l.undoStack.pop(), 0, 0); renderLayerList(); }
    function redo() { var l = layers[activeIdx]; if (!l || l.redoStack.length === 0) return; l.undoStack.push(l.ctx.getImageData(0, 0, W, H)); l.ctx.putImageData(l.redoStack.pop(), 0, 0); renderLayerList(); }
    document.getElementById('undoBtn').addEventListener('click', undo);
    document.getElementById('redoBtn').addEventListener('click', redo);
    document.addEventListener('keydown', function (e) {
      if ((e.ctrlKey || e.metaKey) && e.key === 'z') { e.preventDefault(); undo(); }
      if ((e.ctrlKey || e.metaKey) && e.key === 'y') { e.preventDefault(); redo(); }
    });

    // ========== Import / Export ==========
    document.getElementById('importBtn').addEventListener('click', function () { document.getElementById('imgFile').click(); });
    document.getElementById('imgFile').addEventListener('change', function (e) {
      var f = e.target.files[0]; if (!f) return;
      var img = new Image();
      img.onload = function () { var l = newLayer(f.name); l.ctx.drawImage(img, 0, 0, W, H); renderLayerList(); };
      img.src = URL.createObjectURL(f);
    });

    document.getElementById('exportBtn').addEventListener('click', function () {
      var out = document.createElement('canvas'); out.width = W; out.height = H;
      var octx = out.getContext('2d');
      layers.forEach(function (l) {
        if (!l.visible) return;
        octx.globalCompositeOperation = l.blend; octx.globalAlpha = l.opacity;
        // Apply CSS filter via temp canvas — Canvas API does NOT honour CSS filter directly, but we can read pixel data and re-apply.
        // Simple: just composite without filter (export = base layer pixels).
        octx.drawImage(l.canvas, 0, 0);
      });
      out.toBlob(function (b) { var a = document.createElement('a'); a.href = URL.createObjectURL(b); a.download = 'canvas-' + Date.now() + '.png'; a.click(); }, 'image/png');
    });

    // initial
    newLayer('Background');
    layers[0].ctx.fillStyle = '#ffffff'; layers[0].ctx.fillRect(0, 0, W, H);
    newLayer('Layer 1');
    renderLayerList(); syncLayerControls();
  })();
</script>
</BaseLayout>
