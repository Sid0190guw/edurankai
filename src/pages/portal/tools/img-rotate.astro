---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/img-rotate'));
---
<BaseLayout title="Rotate image · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-sky font-bold mb-2">Image · Rotate / flip</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Rotate / flip image</h1>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="image/*" class="block w-full text-[0.92rem] file:bg-sky file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <button class="op bg-cream-2 border border-ink/15 text-ink font-semibold py-3 px-4 rounded-xl text-[0.88rem]" data-op="rot90">↻ 90°</button>
      <button class="op bg-cream-2 border border-ink/15 text-ink font-semibold py-3 px-4 rounded-xl text-[0.88rem]" data-op="rot180">180°</button>
      <button class="op bg-cream-2 border border-ink/15 text-ink font-semibold py-3 px-4 rounded-xl text-[0.88rem]" data-op="rot270">↺ 270°</button>
      <button class="op bg-cream-2 border border-ink/15 text-ink font-semibold py-3 px-4 rounded-xl text-[0.88rem]" data-op="fliph">Flip H</button>
      <button class="op bg-cream-2 border border-ink/15 text-ink font-semibold py-3 px-4 rounded-xl text-[0.88rem]" data-op="flipv">Flip V</button>
    </div>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
  </div>
</section>
<script is:inline>
  (function () {
    var file = null;
    document.getElementById('fileInput').addEventListener('change', function (e) { file = e.target.files[0]; document.getElementById('status').textContent = file ? file.name + ' loaded. Click an operation.' : ''; });
    document.querySelectorAll('.op').forEach(function (b) {
      b.addEventListener('click', function () {
        if (!file) { document.getElementById('status').textContent = 'Choose a file first.'; return; }
        var op = b.getAttribute('data-op'); var img = new Image();
        img.onload = function () {
          var w = img.naturalWidth, h = img.naturalHeight; var c = document.createElement('canvas'); var ctx = c.getContext('2d');
          if (op === 'rot90' || op === 'rot270') { c.width = h; c.height = w; } else { c.width = w; c.height = h; }
          ctx.save();
          if (op === 'rot90') { ctx.translate(h, 0); ctx.rotate(Math.PI / 2); }
          else if (op === 'rot180') { ctx.translate(w, h); ctx.rotate(Math.PI); }
          else if (op === 'rot270') { ctx.translate(0, w); ctx.rotate(-Math.PI / 2); }
          else if (op === 'fliph') { ctx.translate(w, 0); ctx.scale(-1, 1); }
          else if (op === 'flipv') { ctx.translate(0, h); ctx.scale(1, -1); }
          ctx.drawImage(img, 0, 0); ctx.restore();
          c.toBlob(function (blob) { var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = file.name.replace(/\.[^.]+$/, '') + '-' + op + '.png'; a.click(); document.getElementById('status').textContent = 'Done.'; }, 'image/png');
        };
        img.src = URL.createObjectURL(file);
      });
    });
  })();
</script>
</BaseLayout>
