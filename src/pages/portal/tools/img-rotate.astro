---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/img-rotate'));
---
<BaseLayout title="Rotate image · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-sky font-bold mb-2">Image · Rotate / flip</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Rotate / flip image</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Live preview — rotate in 90° steps or at any angle, flip, and stack the transforms together. The canvas auto-expands so nothing is clipped.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="image/*" class="block w-full text-[0.92rem] file:bg-sky file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <canvas id="prev" class="hidden w-full rounded-xl border border-ink/10 bg-cream" style="max-height:56vh;object-fit:contain;"></canvas>
    <div class="grid grid-cols-3 md:grid-cols-6 gap-2" id="ops">
      <button class="opb" data-op="left">↺ 90°</button>
      <button class="opb" data-op="right">↻ 90°</button>
      <button class="opb" data-op="fliph">Flip H</button>
      <button class="opb" data-op="flipv">Flip V</button>
      <button class="opb" data-op="reset">Reset</button>
    </div>
    <label class="block"><span class="lbl">Fine angle: <span id="angV">0</span>°</span><input id="ang" type="range" min="-180" max="180" value="0" class="w-full" /></label>
    <div class="grid grid-cols-2 gap-4">
      <label class="block"><span class="lbl">Output</span><select id="fmt" class="inp"><option value="image/png" selected>PNG</option><option value="image/jpeg">JPEG</option><option value="image/webp">WebP</option></select></label>
      <div class="flex items-end"><button id="goBtn" class="w-full bg-sky hover:bg-sky/90 text-white font-semibold py-3 px-6 rounded-xl text-[0.92rem]" disabled style="opacity:0.5;">Download</button></div>
    </div>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
  </div>
</section>
<style is:global>
  .opb{ background:#faf7f2; border:1px solid rgba(14,11,8,0.15); color:#0E0B08; border-radius:12px; padding:11px 8px; font-size:0.85rem; font-weight:600; cursor:pointer; }
  .opb:hover{ border-color:#0ea5e9; }
  .lbl{ font-family:'Geist Mono',monospace; font-size:0.62rem; text-transform:uppercase; letter-spacing:0.14em; color:#8a7f76; font-weight:700; margin-bottom:8px; display:block; }
  .inp{ width:100%; background:#faf7f2; border:1px solid rgba(14,11,8,0.15); border-radius:12px; padding:12px 16px; font-size:0.95rem; color:#0E0B08; box-sizing:border-box; }
</style>
<script is:inline>
  (function () {
    var $ = function(id){ return document.getElementById(id); };
    var file=null, img=null, st={ angle:0, flipH:false, flipV:false };
    function kb(b){ return b<1048576?(b/1024).toFixed(1)+' KB':(b/1048576).toFixed(2)+' MB'; }

    $('fileInput').addEventListener('change', function(){ if(!this.files[0])return; file=this.files[0]; img=new Image(); img.onload=function(){ $('prev').classList.remove('hidden'); $('goBtn').disabled=false; $('goBtn').style.opacity='1'; st={angle:0,flipH:false,flipV:false}; $('ang').value=0; $('angV').textContent='0'; render($('prev'),false); }; img.src=URL.createObjectURL(file); });

    document.querySelectorAll('.opb').forEach(function(b){ b.addEventListener('click', function(){ var op=b.getAttribute('data-op');
      if(op==='left') st.angle-=90; else if(op==='right') st.angle+=90; else if(op==='fliph') st.flipH=!st.flipH; else if(op==='flipv') st.flipV=!st.flipV; else { st={angle:0,flipH:false,flipV:false}; }
      $('ang').value=((st.angle%360)+360)%360>180?(((st.angle%360)+360)%360)-360:((st.angle%360)+360)%360; $('angV').textContent=Math.round(+$('ang').value); render($('prev'),false); }); });
    $('ang').addEventListener('input', function(){ $('angV').textContent=this.value; st.angle=+this.value; render($('prev'),false); });

    function render(canvas, forDownload){ if(!img)return;
      var w=img.naturalWidth, h=img.naturalHeight, rad=st.angle*Math.PI/180;
      var cos=Math.abs(Math.cos(rad)), sin=Math.abs(Math.sin(rad));
      var nw=Math.round(w*cos+h*sin), nh=Math.round(w*sin+h*cos);
      canvas.width=nw; canvas.height=nh; var ctx=canvas.getContext('2d');
      if(forDownload && $('fmt').value!=='image/png'){ ctx.fillStyle='#fff'; ctx.fillRect(0,0,nw,nh); }
      ctx.save(); ctx.translate(nw/2,nh/2); ctx.rotate(rad); ctx.scale(st.flipH?-1:1, st.flipV?-1:1); ctx.drawImage(img,-w/2,-h/2); ctx.restore();
    }
    $('goBtn').addEventListener('click', function(){ if(!img)return; var c=document.createElement('canvas'); render(c,true); var fmt=$('fmt').value; c.toBlob(function(b){ var a=document.createElement('a'); a.href=URL.createObjectURL(b); var ext=fmt.split('/')[1]; if(ext==='jpeg')ext='jpg'; a.download=file.name.replace(/\.[^.]+$/,'')+'-rotated.'+ext; a.click(); $('status').textContent='Downloaded · '+c.width+'×'+c.height+' · '+kb(b.size); }, fmt, 0.92); });
  })();
</script>
</BaseLayout>
