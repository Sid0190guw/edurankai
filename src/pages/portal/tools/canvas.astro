---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/canvas'));
---
<BaseLayout title="Design canvas · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-4 max-w-6xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-4">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-leaf font-bold mb-2">Design · Canvas</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Design canvas</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.7]">Layered design surface: add text, shapes, and images. Drag to move, click to select, delete or reorder. Export PNG or SVG.</p>
  </div>
</section>

<section class="px-[5vw] pb-20 max-w-6xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-4 md:p-6">
    <!-- Toolbar -->
    <div class="flex gap-2 flex-wrap mb-3 pb-3 border-b border-ink/8">
      <button id="addText" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-4 rounded-lg text-[0.85rem]">+ Text</button>
      <button id="addRect" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-4 rounded-lg text-[0.85rem]">+ Rectangle</button>
      <button id="addCircle" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-4 rounded-lg text-[0.85rem]">+ Circle</button>
      <button id="addLine" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-4 rounded-lg text-[0.85rem]">+ Line</button>
      <label class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-4 rounded-lg text-[0.85rem] cursor-pointer">+ Image<input id="imgIn" type="file" accept="image/*" style="display:none;" /></label>
      <span class="flex-1"></span>
      <button id="forward" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-3 rounded-lg text-[0.85rem]">↑ Front</button>
      <button id="backward" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-3 rounded-lg text-[0.85rem]">↓ Back</button>
      <button id="delBtn" class="bg-burn-pale border border-burn-dim text-burn font-semibold py-2 px-4 rounded-lg text-[0.85rem]">Delete</button>
      <button id="exportPng" class="bg-leaf hover:bg-leaf/90 text-white font-semibold py-2 px-4 rounded-lg text-[0.85rem]">PNG</button>
      <button id="exportSvg" class="bg-leaf hover:bg-leaf/90 text-white font-semibold py-2 px-4 rounded-lg text-[0.85rem]">SVG</button>
    </div>

    <!-- Inspector + Canvas -->
    <div class="grid gap-4" style="grid-template-columns: 220px 1fr;">
      <!-- Inspector -->
      <div id="inspector" class="bg-cream-2/40 border border-ink/8 rounded-xl p-4 text-[0.82rem]">
        <p class="text-[0.6rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold m-0 mb-2">Properties</p>
        <p id="noSel" class="text-ink-soft m-0">Click an element on the canvas to edit it.</p>
        <div id="props" style="display:none;">
          <div class="space-y-3">
            <label class="block"><span class="text-[0.6rem] font-mono uppercase tracking-[0.12em] text-ink-soft font-bold block mb-1">Text</span><input id="pText" type="text" class="w-full bg-white border border-ink/15 rounded px-2 py-1.5 text-[0.85rem]" /></label>
            <label class="block"><span class="text-[0.6rem] font-mono uppercase tracking-[0.12em] text-ink-soft font-bold block mb-1">Fill</span><input id="pFill" type="color" class="w-full h-9 border border-ink/15 rounded cursor-pointer" /></label>
            <label class="block"><span class="text-[0.6rem] font-mono uppercase tracking-[0.12em] text-ink-soft font-bold block mb-1">Stroke</span><input id="pStroke" type="color" class="w-full h-9 border border-ink/15 rounded cursor-pointer" /></label>
            <label class="block"><span class="text-[0.6rem] font-mono uppercase tracking-[0.12em] text-ink-soft font-bold block mb-1">Stroke width</span><input id="pSW" type="number" min="0" max="40" value="0" class="w-full bg-white border border-ink/15 rounded px-2 py-1.5 text-[0.85rem]" /></label>
            <label class="block"><span class="text-[0.6rem] font-mono uppercase tracking-[0.12em] text-ink-soft font-bold block mb-1">Font size</span><input id="pFS" type="number" min="6" max="200" value="24" class="w-full bg-white border border-ink/15 rounded px-2 py-1.5 text-[0.85rem]" /></label>
            <label class="block"><span class="text-[0.6rem] font-mono uppercase tracking-[0.12em] text-ink-soft font-bold block mb-1">Opacity %</span><input id="pOp" type="number" min="0" max="100" value="100" class="w-full bg-white border border-ink/15 rounded px-2 py-1.5 text-[0.85rem]" /></label>
          </div>
        </div>
      </div>

      <!-- Canvas -->
      <div id="stage" style="background:#FAF8F5;border:1px solid rgba(14,11,8,0.10);border-radius:10px;overflow:hidden;height:560px;position:relative;">
        <svg id="svg" viewBox="0 0 800 560" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;display:block;">
          <rect id="bg" x="0" y="0" width="800" height="560" fill="#fff"/>
        </svg>
      </div>
    </div>

    <p class="text-[0.72rem] text-ink-soft mt-2 m-0">Pro tip: hold and drag any element to move it. Use the arrow buttons to layer it.</p>
  </div>
</section>

<script is:inline>
  (function () {
    var svg = document.getElementById('svg');
    var bg = document.getElementById('bg');
    var sel = null;
    var dragging = false; var off = { x: 0, y: 0 };

    function vbPoint(e) { var r = svg.getBoundingClientRect(); var x = (e.clientX - r.left) * (800 / r.width); var y = (e.clientY - r.top) * (560 / r.height); return { x: x, y: y }; }

    function select(el) {
      if (sel) sel.removeAttribute('data-selected');
      sel = el;
      if (sel) sel.setAttribute('data-selected', '1');
      document.getElementById('noSel').style.display = sel ? 'none' : 'block';
      document.getElementById('props').style.display = sel ? 'block' : 'none';
      if (sel) {
        document.getElementById('pText').value = sel.tagName === 'text' ? (sel.textContent || '') : '';
        document.getElementById('pFill').value = sel.getAttribute('fill') || '#000000';
        document.getElementById('pStroke').value = sel.getAttribute('stroke') || '#000000';
        document.getElementById('pSW').value = sel.getAttribute('stroke-width') || '0';
        document.getElementById('pFS').value = sel.getAttribute('font-size') || '24';
        document.getElementById('pOp').value = Math.round((parseFloat(sel.getAttribute('opacity') || '1')) * 100);
      }
    }

    function makeDraggable(el) {
      el.style.cursor = 'move';
      el.addEventListener('mousedown', function (e) {
        e.stopPropagation(); select(el); dragging = true;
        var p = vbPoint(e);
        if (el.tagName === 'text' || el.tagName === 'image') { off.x = p.x - parseFloat(el.getAttribute('x')); off.y = p.y - parseFloat(el.getAttribute('y')); }
        else if (el.tagName === 'rect') { off.x = p.x - parseFloat(el.getAttribute('x')); off.y = p.y - parseFloat(el.getAttribute('y')); }
        else if (el.tagName === 'circle') { off.x = p.x - parseFloat(el.getAttribute('cx')); off.y = p.y - parseFloat(el.getAttribute('cy')); }
        else if (el.tagName === 'line') { off.x = p.x - parseFloat(el.getAttribute('x1')); off.y = p.y - parseFloat(el.getAttribute('y1')); }
      });
    }
    svg.addEventListener('mousemove', function (e) {
      if (!dragging || !sel) return; var p = vbPoint(e);
      if (sel.tagName === 'text' || sel.tagName === 'image') { sel.setAttribute('x', p.x - off.x); sel.setAttribute('y', p.y - off.y); }
      else if (sel.tagName === 'rect') { sel.setAttribute('x', p.x - off.x); sel.setAttribute('y', p.y - off.y); }
      else if (sel.tagName === 'circle') { sel.setAttribute('cx', p.x - off.x); sel.setAttribute('cy', p.y - off.y); }
      else if (sel.tagName === 'line') { var dx = p.x - off.x - parseFloat(sel.getAttribute('x1')); var dy = p.y - off.y - parseFloat(sel.getAttribute('y1')); sel.setAttribute('x1', p.x - off.x); sel.setAttribute('y1', p.y - off.y); sel.setAttribute('x2', parseFloat(sel.getAttribute('x2')) + dx); sel.setAttribute('y2', parseFloat(sel.getAttribute('y2')) + dy); }
    });
    document.addEventListener('mouseup', function () { dragging = false; });
    bg.addEventListener('mousedown', function () { select(null); });

    function add(el) { svg.appendChild(el); makeDraggable(el); select(el); }

    document.getElementById('addText').addEventListener('click', function () {
      var t = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      t.setAttribute('x', 100); t.setAttribute('y', 100); t.setAttribute('font-size', 36); t.setAttribute('fill', '#0E0B08'); t.setAttribute('font-family', 'Fraunces, Georgia, serif'); t.textContent = 'Text';
      add(t);
    });
    document.getElementById('addRect').addEventListener('click', function () {
      var r = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
      r.setAttribute('x', 100); r.setAttribute('y', 100); r.setAttribute('width', 160); r.setAttribute('height', 100); r.setAttribute('fill', '#FF4F00'); r.setAttribute('rx', 6);
      add(r);
    });
    document.getElementById('addCircle').addEventListener('click', function () {
      var c = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      c.setAttribute('cx', 200); c.setAttribute('cy', 200); c.setAttribute('r', 60); c.setAttribute('fill', '#1045BB');
      add(c);
    });
    document.getElementById('addLine').addEventListener('click', function () {
      var l = document.createElementNS('http://www.w3.org/2000/svg', 'line');
      l.setAttribute('x1', 100); l.setAttribute('y1', 100); l.setAttribute('x2', 300); l.setAttribute('y2', 100); l.setAttribute('stroke', '#0E0B08'); l.setAttribute('stroke-width', 3);
      add(l);
    });
    document.getElementById('imgIn').addEventListener('change', function (e) {
      var f = e.target.files[0]; if (!f) return;
      var rd = new FileReader();
      rd.onload = function () {
        var img = document.createElementNS('http://www.w3.org/2000/svg', 'image');
        img.setAttribute('x', 80); img.setAttribute('y', 80); img.setAttribute('width', 200); img.setAttribute('height', 200);
        img.setAttribute('href', rd.result);
        add(img);
      };
      rd.readAsDataURL(f);
    });

    document.getElementById('pText').addEventListener('input', function () { if (sel && sel.tagName === 'text') sel.textContent = this.value; });
    document.getElementById('pFill').addEventListener('input', function () { if (sel) sel.setAttribute('fill', this.value); });
    document.getElementById('pStroke').addEventListener('input', function () { if (sel) sel.setAttribute('stroke', this.value); });
    document.getElementById('pSW').addEventListener('input', function () { if (sel) sel.setAttribute('stroke-width', this.value); });
    document.getElementById('pFS').addEventListener('input', function () { if (sel) sel.setAttribute('font-size', this.value); });
    document.getElementById('pOp').addEventListener('input', function () { if (sel) sel.setAttribute('opacity', (this.value / 100).toString()); });

    document.getElementById('forward').addEventListener('click', function () { if (sel && sel.nextSibling) svg.appendChild(sel); });
    document.getElementById('backward').addEventListener('click', function () { if (sel && sel.previousSibling && sel.previousSibling !== bg) svg.insertBefore(sel, sel.previousSibling); });
    document.getElementById('delBtn').addEventListener('click', function () { if (sel && sel !== bg) { sel.remove(); select(null); } });

    document.getElementById('exportSvg').addEventListener('click', function () {
      var s = svg.outerHTML; var blob = new Blob([s], { type: 'image/svg+xml' });
      var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'design-' + Date.now() + '.svg'; a.click();
    });
    document.getElementById('exportPng').addEventListener('click', function () {
      var s = new XMLSerializer().serializeToString(svg);
      var blob = new Blob([s], { type: 'image/svg+xml' });
      var url = URL.createObjectURL(blob); var img = new Image();
      img.onload = function () {
        var c = document.createElement('canvas'); c.width = 800; c.height = 560;
        c.getContext('2d').drawImage(img, 0, 0, 800, 560);
        c.toBlob(function (b) { var a = document.createElement('a'); a.href = URL.createObjectURL(b); a.download = 'design-' + Date.now() + '.png'; a.click(); }, 'image/png');
      };
      img.src = url;
    });
  })();
</script>
</BaseLayout>
