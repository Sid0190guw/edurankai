---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/canvas'));
---
<BaseLayout title="Design canvas · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-4 max-w-6xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-4">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-leaf font-bold mb-2">Design · Canvas</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Design canvas</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.7]">Layered design surface: add text, shapes, and images. Drag to move, click to select, delete or reorder. Start from a template, apply your brand colours, and export PNG or SVG.</p>
  </div>
</section>

<section class="px-[5vw] pb-20 max-w-6xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-4 md:p-6">
    <!-- Toolbar -->
    <div class="flex gap-2 flex-wrap mb-3 pb-3 border-b border-ink/8">
      <button id="addText" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-4 rounded-lg text-[0.85rem]">+ Text</button>
      <button id="addRect" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-4 rounded-lg text-[0.85rem]">+ Rectangle</button>
      <button id="addCircle" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-4 rounded-lg text-[0.85rem]">+ Circle</button>
      <button id="addLine" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-4 rounded-lg text-[0.85rem]">+ Line</button>
      <label class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-4 rounded-lg text-[0.85rem] cursor-pointer">+ Image<input id="imgIn" type="file" accept="image/*" style="display:none;" /></label>
      <span class="flex-1"></span>
      <button id="forward" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-3 rounded-lg text-[0.85rem]">↑ Front</button>
      <button id="backward" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-3 rounded-lg text-[0.85rem]">↓ Back</button>
      <button id="delBtn" class="bg-burn-pale border border-burn-dim text-burn font-semibold py-2 px-4 rounded-lg text-[0.85rem]">Delete</button>
      <button id="exportPng" class="bg-leaf hover:bg-leaf/90 text-white font-semibold py-2 px-4 rounded-lg text-[0.85rem]">PNG</button>
      <button id="exportSvg" class="bg-leaf hover:bg-leaf/90 text-white font-semibold py-2 px-4 rounded-lg text-[0.85rem]">SVG</button>
    </div>

    <!-- Inspector + Canvas -->
    <div class="grid gap-4" style="grid-template-columns: 230px 1fr;">
      <!-- Inspector -->
      <div id="inspector" class="bg-cream-2/40 border border-ink/8 rounded-xl p-4 text-[0.82rem]">
        <p class="text-[0.6rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold m-0 mb-2">Canvas size</p>
        <select id="sizeSel" class="w-full bg-white border border-ink/15 rounded px-2 py-1.5 text-[0.82rem] mb-2">
          <option value="800x560">Landscape 800 × 560</option>
          <option value="800x1035">A4 portrait</option>
          <option value="1035x800">A4 landscape</option>
          <option value="1080x1080">Social square 1080²</option>
          <option value="1080x1920">Social story 1080 × 1920</option>
          <option value="1000x707">Certificate</option>
        </select>

        <p class="text-[0.6rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold m-0 mb-2 mt-4">Brand colours</p>
        <div id="swatches" class="flex gap-1.5 flex-wrap mb-3"></div>

        <p class="text-[0.6rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold m-0 mb-2">Properties</p>
        <p id="noSel" class="text-ink-soft m-0">Click an element on the canvas to edit it.</p>
        <div id="props" style="display:none;">
          <div class="space-y-3">
            <label class="block"><span class="text-[0.6rem] font-mono uppercase tracking-[0.12em] text-ink-soft font-bold block mb-1">Text</span><input id="pText" type="text" class="w-full bg-white border border-ink/15 rounded px-2 py-1.5 text-[0.85rem]" /></label>
            <label class="block"><span class="text-[0.6rem] font-mono uppercase tracking-[0.12em] text-ink-soft font-bold block mb-1">Fill</span><input id="pFill" type="color" class="w-full h-9 border border-ink/15 rounded cursor-pointer" /></label>
            <label class="block"><span class="text-[0.6rem] font-mono uppercase tracking-[0.12em] text-ink-soft font-bold block mb-1">Stroke</span><input id="pStroke" type="color" class="w-full h-9 border border-ink/15 rounded cursor-pointer" /></label>
            <label class="block"><span class="text-[0.6rem] font-mono uppercase tracking-[0.12em] text-ink-soft font-bold block mb-1">Stroke width</span><input id="pSW" type="number" min="0" max="40" value="0" class="w-full bg-white border border-ink/15 rounded px-2 py-1.5 text-[0.85rem]" /></label>
            <label class="block"><span class="text-[0.6rem] font-mono uppercase tracking-[0.12em] text-ink-soft font-bold block mb-1">Font size</span><input id="pFS" type="number" min="6" max="400" value="24" class="w-full bg-white border border-ink/15 rounded px-2 py-1.5 text-[0.85rem]" /></label>
            <label class="block"><span class="text-[0.6rem] font-mono uppercase tracking-[0.12em] text-ink-soft font-bold block mb-1">Opacity %</span><input id="pOp" type="number" min="0" max="100" value="100" class="w-full bg-white border border-ink/15 rounded px-2 py-1.5 text-[0.85rem]" /></label>
          </div>
        </div>
      </div>

      <!-- Canvas -->
      <div id="stage" style="background:#EFEBE6;border:1px solid rgba(14,11,8,0.10);border-radius:10px;overflow:auto;max-height:74vh;padding:16px;display:flex;align-items:flex-start;justify-content:center;">
        <svg id="svg" viewBox="0 0 800 560" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:auto;display:block;box-shadow:0 4px 20px rgba(14,11,8,0.12);background:#fff;">
          <rect id="bg" x="0" y="0" width="800" height="560" fill="#ffffff"/>
          <rect id="selbox" fill="none" stroke="#FF4F00" stroke-width="1.5" stroke-dasharray="5 4" style="pointer-events:none;display:none;"/>
        </svg>
      </div>
    </div>

    <p class="text-[0.72rem] text-ink-soft mt-2 m-0">Tip: drag any element to move it. Selection shows a dashed outline. Brand colours come from your saved brand kit.</p>
  </div>
</section>

<script is:inline>
  (function () {
    var svg = document.getElementById('svg');
    var bg = document.getElementById('bg');
    var selbox = document.getElementById('selbox');
    var sel = null, dragging = false, off = { x: 0, y: 0 };
    var W = 800, H = 560;

    // ---- Templates: real starter layouts keyed to the templates gallery ----
    var A = { orange: '#FF4F00', ink: '#0E0B08', blue: '#1045BB', leaf: '#1A6B35', gold: '#C49A00', violet: '#6B1FBE' };
    function T(t, x, y, size, fill, family, weight, anchor) { return { k: 'text', t: t, x: x, y: y, size: size, fill: fill, family: family || 'Inter Tight, sans-serif', weight: weight || '400', anchor: anchor || 'start' }; }
    function R(x, y, w, h, fill, rx) { return { k: 'rect', x: x, y: y, w: w, h: h, fill: fill, rx: rx || 0 }; }
    function L(x1, y1, x2, y2, stroke, sw) { return { k: 'line', x1: x1, y1: y1, x2: x2, y2: y2, stroke: stroke, sw: sw || 2 }; }
    var serif = 'Fraunces, Georgia, serif';
    var TEMPLATES = {
      'cv-classic': { w: 800, h: 1035, bg: '#fff', els: [
        T('YOUR NAME', 60, 90, 46, A.ink, serif, '600'), T('Role · City · email@site.com · +00 000', 60, 122, 15, '#555'),
        L(60, 145, 740, 145, A.ink, 2),
        T('EXPERIENCE', 60, 195, 18, A.orange, 'Geist Mono, monospace', '700'),
        T('Job title — Company', 60, 228, 18, A.ink, serif, '600'), T('2022 – present · what you did and the impact you had.', 60, 252, 14, '#555'),
        T('EDUCATION', 60, 320, 18, A.orange, 'Geist Mono, monospace', '700'),
        T('Degree — Institution', 60, 353, 18, A.ink, serif, '600'), T('Year · honours / focus area.', 60, 377, 14, '#555'),
        T('SKILLS', 60, 445, 18, A.orange, 'Geist Mono, monospace', '700'),
        T('Skill · Skill · Skill · Skill · Skill', 60, 478, 15, '#333') ] },
      'cv-modern': { w: 800, h: 1035, bg: '#fff', els: [
        R(0, 0, 270, 1035, A.ink), T('YOUR', 30, 90, 40, '#fff', serif, '700'), T('NAME', 30, 132, 40, A.orange, serif, '700'),
        T('CONTACT', 30, 200, 13, A.orange, 'Geist Mono, monospace', '700'), T('email@site.com', 30, 226, 13, '#ddd'), T('+00 000 000', 30, 248, 13, '#ddd'),
        T('SKILLS', 30, 310, 13, A.orange, 'Geist Mono, monospace', '700'), T('Design', 30, 336, 13, '#ddd'), T('Strategy', 30, 358, 13, '#ddd'),
        T('Profile', 310, 90, 30, A.ink, serif, '600'), T('A short summary of who you are and what you do best.', 310, 128, 15, '#555'),
        T('EXPERIENCE', 310, 200, 16, A.orange, 'Geist Mono, monospace', '700'), T('Job title — Company', 310, 232, 17, A.ink, serif, '600'), T('2022 – present', 310, 255, 13, '#777') ] },
      'poster-event': { w: 800, h: 1000, bg: '#fff', els: [
        R(0, 0, 800, 300, A.blue), T('EVENT', 50, 150, 90, '#fff', serif, '700'), T('TITLE', 50, 235, 90, A.orange, serif, '700'),
        T('A one-line description of the event goes here.', 50, 400, 22, A.ink, serif, '400'),
        L(50, 450, 750, 450, A.ink, 1), T('DATE', 50, 520, 14, A.blue, 'Geist Mono, monospace', '700'), T('Sat 12 Oct · 6 PM', 50, 550, 24, A.ink, serif, '600'),
        T('VENUE', 50, 620, 14, A.blue, 'Geist Mono, monospace', '700'), T('The place, City', 50, 650, 24, A.ink, serif, '600') ] },
      'poster-talk': { w: 800, h: 1000, bg: '#fff', els: [
        R(0, 0, 800, 300, A.leaf), T('LECTURE', 50, 170, 74, '#fff', serif, '700'),
        T('Speaker Name', 50, 400, 34, A.ink, serif, '600'), T('Topic of the talk — a compelling subtitle.', 50, 445, 20, '#555'),
        L(50, 500, 750, 500, A.leaf, 2), T('When · Where · Free entry', 50, 550, 20, A.ink, serif, '400') ] },
      'cert-completion': { w: 1000, h: 707, bg: '#fff', els: [
        R(30, 30, 940, 647, '#fff', 0), { k: 'rect', x: 30, y: 30, w: 940, h: 647, fill: 'none', rx: 0, stroke: A.gold, sw: 4 },
        T('CERTIFICATE', 500, 150, 46, A.ink, serif, '700', 'middle'), T('OF COMPLETION', 500, 195, 22, A.gold, 'Geist Mono, monospace', '700', 'middle'),
        T('This is proudly presented to', 500, 290, 18, '#555', serif, '400', 'middle'),
        T('Recipient Name', 500, 360, 44, A.ink, serif, '600', 'middle'), L(330, 385, 670, 385, A.gold, 1),
        T('for successfully completing the programme.', 500, 430, 17, '#555', serif, '400', 'middle'),
        T('Date', 200, 600, 14, '#777', serif, '400', 'middle'), L(120, 580, 280, 580, A.ink, 1),
        T('Signature', 800, 600, 14, '#777', serif, '400', 'middle'), L(720, 580, 880, 580, A.ink, 1) ] },
      'cert-merit': { w: 1000, h: 707, bg: '#fff', els: [
        { k: 'rect', x: 30, y: 30, w: 940, h: 647, fill: 'none', rx: 0, stroke: A.violet, sw: 4 },
        T('CERTIFICATE', 500, 150, 46, A.ink, serif, '700', 'middle'), T('OF MERIT', 500, 195, 22, A.violet, 'Geist Mono, monospace', '700', 'middle'),
        T('Awarded to', 500, 290, 18, '#555', serif, '400', 'middle'),
        T('Recipient Name', 500, 360, 44, A.ink, serif, '600', 'middle'), L(330, 385, 670, 385, A.violet, 1),
        T('in recognition of outstanding achievement.', 500, 430, 17, '#555', serif, '400', 'middle') ] },
      'social-square': { w: 1080, h: 1080, bg: '#fff', els: [
        R(0, 0, 1080, 1080, A.ink), R(0, 760, 1080, 320, A.orange),
        T('BIG', 80, 300, 150, '#fff', serif, '700'), T('HEADLINE', 80, 450, 150, A.orange, serif, '700'),
        T('Supporting line of copy that adds context.', 80, 560, 34, '#ccc', serif, '400'),
        T('@yourhandle', 80, 900, 40, '#fff', 'Geist Mono, monospace', '700') ] },
      'social-story': { w: 1080, h: 1920, bg: '#fff', els: [
        R(0, 0, 1080, 1920, A.blue), T('YOUR', 80, 300, 130, '#fff', serif, '700'), T('STORY', 80, 430, 130, A.orange, serif, '700'),
        T('Tap-through caption or announcement text here.', 80, 560, 36, '#dbe4ff', serif, '400'),
        R(80, 1750, 380, 90, A.orange, 12), T('Swipe up', 130, 1808, 34, '#fff', 'Geist Mono, monospace', '700') ] },
      'letterhead': { w: 800, h: 1035, bg: '#fff', els: [
        T('ORGANISATION', 60, 80, 30, A.ink, serif, '700'), T('tagline or department', 60, 108, 14, '#777'),
        L(60, 130, 740, 130, A.orange, 3),
        T('Dear …,', 60, 210, 17, A.ink, serif, '400'), T('Body of the letter begins here.', 60, 250, 15, '#333'),
        L(60, 960, 740, 960, A.ink, 1), T('Address · City · email@site.com · +00 000 000', 60, 985, 12, '#777', 'Geist Mono, monospace', '400', 'start') ] },
      'invoice': { w: 800, h: 1035, bg: '#fff', els: [
        T('INVOICE', 60, 90, 44, A.ink, serif, '700'), T('#0001', 740, 90, 20, '#777', 'Geist Mono, monospace', '400', 'end'),
        T('FROM', 60, 160, 12, A.orange, 'Geist Mono, monospace', '700'), T('Your name / company', 60, 185, 15, A.ink), T('email@site.com', 60, 207, 13, '#555'),
        T('BILL TO', 420, 160, 12, A.orange, 'Geist Mono, monospace', '700'), T('Client name', 420, 185, 15, A.ink), T('client@site.com', 420, 207, 13, '#555'),
        R(60, 260, 680, 36, A.ink, 4), T('Description', 76, 284, 14, '#fff', 'Geist Mono, monospace', '700'), T('Amount', 620, 284, 14, '#fff', 'Geist Mono, monospace', '700'),
        T('Service or item', 76, 330, 15, A.ink), T('0.00', 620, 330, 15, A.ink),
        L(60, 360, 740, 360, '#ddd', 1), T('Total', 560, 410, 18, A.ink, serif, '700'), T('0.00', 660, 410, 18, A.orange, serif, '700') ] }
    };

    function vbPoint(e) { var r = svg.getBoundingClientRect(); return { x: (e.clientX - r.left) * (W / r.width), y: (e.clientY - r.top) * (H / r.height) }; }

    function setSize(w, h) {
      W = w; H = h;
      svg.setAttribute('viewBox', '0 0 ' + W + ' ' + H);
      bg.setAttribute('width', W); bg.setAttribute('height', H);
      updateSelbox();
    }

    function updateSelbox() {
      if (!sel || sel === bg) { selbox.style.display = 'none'; return; }
      try {
        var b = sel.getBBox();
        selbox.setAttribute('x', b.x - 4); selbox.setAttribute('y', b.y - 4);
        selbox.setAttribute('width', b.width + 8); selbox.setAttribute('height', b.height + 8);
        selbox.style.display = 'block';
        svg.appendChild(selbox); // keep on top
      } catch (e) { selbox.style.display = 'none'; }
    }

    function select(el) {
      sel = (el === bg) ? null : el;
      document.getElementById('noSel').style.display = sel ? 'none' : 'block';
      document.getElementById('props').style.display = sel ? 'block' : 'none';
      if (sel) {
        document.getElementById('pText').value = sel.tagName === 'text' ? (sel.textContent || '') : '';
        document.getElementById('pFill').value = normHex(sel.getAttribute('fill')) || '#000000';
        document.getElementById('pStroke').value = normHex(sel.getAttribute('stroke')) || '#000000';
        document.getElementById('pSW').value = sel.getAttribute('stroke-width') || '0';
        document.getElementById('pFS').value = sel.getAttribute('font-size') || '24';
        document.getElementById('pOp').value = Math.round((parseFloat(sel.getAttribute('opacity') || '1')) * 100);
      }
      updateSelbox();
    }
    function normHex(v) { if (!v || v === 'none') return null; if (v[0] === '#' && v.length === 7) return v; return null; }

    function makeDraggable(el) {
      el.style.cursor = 'move';
      el.addEventListener('mousedown', function (e) {
        e.stopPropagation(); select(el); dragging = true;
        var p = vbPoint(e), tag = el.tagName;
        if (tag === 'text' || tag === 'image' || tag === 'rect') { off.x = p.x - parseFloat(el.getAttribute('x')); off.y = p.y - parseFloat(el.getAttribute('y')); }
        else if (tag === 'circle') { off.x = p.x - parseFloat(el.getAttribute('cx')); off.y = p.y - parseFloat(el.getAttribute('cy')); }
        else if (tag === 'line') { off.x = p.x - parseFloat(el.getAttribute('x1')); off.y = p.y - parseFloat(el.getAttribute('y1')); }
      });
    }
    svg.addEventListener('mousemove', function (e) {
      if (!dragging || !sel) return; var p = vbPoint(e), tag = sel.tagName;
      if (tag === 'text' || tag === 'image' || tag === 'rect') { sel.setAttribute('x', p.x - off.x); sel.setAttribute('y', p.y - off.y); }
      else if (tag === 'circle') { sel.setAttribute('cx', p.x - off.x); sel.setAttribute('cy', p.y - off.y); }
      else if (tag === 'line') { var dx = p.x - off.x - parseFloat(sel.getAttribute('x1')); var dy = p.y - off.y - parseFloat(sel.getAttribute('y1')); sel.setAttribute('x1', p.x - off.x); sel.setAttribute('y1', p.y - off.y); sel.setAttribute('x2', parseFloat(sel.getAttribute('x2')) + dx); sel.setAttribute('y2', parseFloat(sel.getAttribute('y2')) + dy); }
      updateSelbox();
    });
    document.addEventListener('mouseup', function () { dragging = false; });
    bg.addEventListener('mousedown', function () { select(bg); });

    function svgEl(tag) { return document.createElementNS('http://www.w3.org/2000/svg', tag); }
    function add(el) { svg.appendChild(el); makeDraggable(el); select(el); }

    document.getElementById('addText').addEventListener('click', function () {
      var t = svgEl('text'); t.setAttribute('x', W / 2 - 40); t.setAttribute('y', H / 2); t.setAttribute('font-size', 36); t.setAttribute('fill', '#0E0B08'); t.setAttribute('font-family', serif); t.textContent = 'Text'; add(t);
    });
    document.getElementById('addRect').addEventListener('click', function () { var r = svgEl('rect'); r.setAttribute('x', W / 2 - 80); r.setAttribute('y', H / 2 - 50); r.setAttribute('width', 160); r.setAttribute('height', 100); r.setAttribute('fill', '#FF4F00'); r.setAttribute('rx', 6); add(r); });
    document.getElementById('addCircle').addEventListener('click', function () { var c = svgEl('circle'); c.setAttribute('cx', W / 2); c.setAttribute('cy', H / 2); c.setAttribute('r', 60); c.setAttribute('fill', '#1045BB'); add(c); });
    document.getElementById('addLine').addEventListener('click', function () { var l = svgEl('line'); l.setAttribute('x1', W / 2 - 100); l.setAttribute('y1', H / 2); l.setAttribute('x2', W / 2 + 100); l.setAttribute('y2', H / 2); l.setAttribute('stroke', '#0E0B08'); l.setAttribute('stroke-width', 3); add(l); });
    document.getElementById('imgIn').addEventListener('change', function (e) {
      var f = e.target.files[0]; if (!f) return; var rd = new FileReader();
      rd.onload = function () { var img = svgEl('image'); img.setAttribute('x', 80); img.setAttribute('y', 80); img.setAttribute('width', 200); img.setAttribute('height', 200); img.setAttribute('href', rd.result); img.setAttributeNS('http://www.w3.org/1999/xlink', 'href', rd.result); add(img); };
      rd.readAsDataURL(f);
    });

    document.getElementById('pText').addEventListener('input', function () { if (sel && sel.tagName === 'text') { sel.textContent = this.value; updateSelbox(); } });
    document.getElementById('pFill').addEventListener('input', function () { if (sel) { sel.setAttribute('fill', this.value); } });
    document.getElementById('pStroke').addEventListener('input', function () { if (sel) sel.setAttribute('stroke', this.value); });
    document.getElementById('pSW').addEventListener('input', function () { if (sel) { sel.setAttribute('stroke-width', this.value); updateSelbox(); } });
    document.getElementById('pFS').addEventListener('input', function () { if (sel) { sel.setAttribute('font-size', this.value); updateSelbox(); } });
    document.getElementById('pOp').addEventListener('input', function () { if (sel) sel.setAttribute('opacity', (this.value / 100).toString()); });

    document.getElementById('forward').addEventListener('click', function () { if (sel) { svg.appendChild(sel); updateSelbox(); } });
    document.getElementById('backward').addEventListener('click', function () { if (sel && sel.previousSibling && sel.previousSibling !== bg) { svg.insertBefore(sel, sel.previousSibling); } });
    document.getElementById('delBtn').addEventListener('click', function () { if (sel && sel !== bg) { sel.remove(); select(bg); } });

    document.getElementById('sizeSel').addEventListener('change', function () { var p = this.value.split('x'); setSize(parseInt(p[0], 10), parseInt(p[1], 10)); });

    // ---- Brand kit swatches ----
    function loadBrand() {
      var colors = ['#FF4F00', '#0E0B08', '#1045BB', '#1A6B35'];
      try { var k = JSON.parse(localStorage.getItem('era_brand_kit_v1') || '{}'); if (k.colors && k.colors.length) colors = k.colors; } catch (e) {}
      var wrap = document.getElementById('swatches'); wrap.innerHTML = '';
      colors.forEach(function (c) {
        var b = document.createElement('button');
        b.style.cssText = 'width:26px;height:26px;border-radius:6px;background:' + c + ';border:1px solid rgba(14,11,8,0.15);cursor:pointer;padding:0;';
        b.title = c + ' — click to apply to selected';
        b.addEventListener('click', function () { if (sel) { sel.setAttribute('fill', c); document.getElementById('pFill').value = normHex(c) || document.getElementById('pFill').value; } });
        wrap.appendChild(b);
      });
    }
    loadBrand();

    // ---- Template loader ----
    function buildEl(d) {
      if (d.k === 'text') { var t = svgEl('text'); t.setAttribute('x', d.x); t.setAttribute('y', d.y); t.setAttribute('font-size', d.size); t.setAttribute('fill', d.fill); t.setAttribute('font-family', d.family); t.setAttribute('font-weight', d.weight); if (d.anchor) t.setAttribute('text-anchor', d.anchor); t.textContent = d.t; return t; }
      if (d.k === 'rect') { var r = svgEl('rect'); r.setAttribute('x', d.x); r.setAttribute('y', d.y); r.setAttribute('width', d.w); r.setAttribute('height', d.h); r.setAttribute('fill', d.fill); if (d.rx) r.setAttribute('rx', d.rx); if (d.stroke) { r.setAttribute('stroke', d.stroke); r.setAttribute('stroke-width', d.sw || 2); } return r; }
      if (d.k === 'line') { var l = svgEl('line'); l.setAttribute('x1', d.x1); l.setAttribute('y1', d.y1); l.setAttribute('x2', d.x2); l.setAttribute('y2', d.y2); l.setAttribute('stroke', d.stroke); l.setAttribute('stroke-width', d.sw); return l; }
      return null;
    }
    function loadTemplate(slug) {
      var tpl = TEMPLATES[slug]; if (!tpl) return;
      // clear existing elements (keep bg + selbox)
      Array.prototype.slice.call(svg.querySelectorAll('*')).forEach(function (n) { if (n !== bg && n !== selbox) n.remove(); });
      setSize(tpl.w, tpl.h); bg.setAttribute('fill', tpl.bg || '#fff');
      tpl.els.forEach(function (d) { var el = buildEl(d); if (el) { svg.insertBefore(el, selbox); makeDraggable(el); } });
      // sync the size dropdown if it matches a preset
      var val = tpl.w + 'x' + tpl.h, opt = document.querySelector('#sizeSel option[value="' + val + '"]');
      if (opt) document.getElementById('sizeSel').value = val;
      select(bg);
    }
    var params = new URLSearchParams(location.search);
    var tp = params.get('template');
    if (tp && TEMPLATES[tp]) loadTemplate(tp);

    // ---- Export ----
    function cleanClone() { var c = svg.cloneNode(true); var sb = c.querySelector('#selbox'); if (sb) sb.remove(); return c; }
    document.getElementById('exportSvg').addEventListener('click', function () {
      var s = new XMLSerializer().serializeToString(cleanClone());
      var blob = new Blob([s], { type: 'image/svg+xml' });
      var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'design-' + Date.now() + '.svg'; a.click();
    });
    document.getElementById('exportPng').addEventListener('click', function () {
      var s = new XMLSerializer().serializeToString(cleanClone());
      var blob = new Blob([s], { type: 'image/svg+xml;charset=utf-8' });
      var url = URL.createObjectURL(blob); var img = new Image();
      img.onload = function () {
        var scale = Math.min(2, 2000 / W);
        var c = document.createElement('canvas'); c.width = Math.round(W * scale); c.height = Math.round(H * scale);
        var ctx = c.getContext('2d'); ctx.fillStyle = '#fff'; ctx.fillRect(0, 0, c.width, c.height);
        ctx.drawImage(img, 0, 0, c.width, c.height);
        c.toBlob(function (b) { var a = document.createElement('a'); a.href = URL.createObjectURL(b); a.download = 'design-' + Date.now() + '.png'; a.click(); }, 'image/png');
        URL.revokeObjectURL(url);
      };
      img.src = url;
    });
  })();
</script>
</BaseLayout>
