---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { hasActivePass } from '@/lib/tool-pass';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/pass'));

const active = await hasActivePass(user.id);
---
<BaseLayout title="Tools day pass · 1 CHF">
<section class="px-[5vw] pt-12 md:pt-16 pb-20 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← Back to tools</a>

  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">Tools · Day pass</p>
    <h1 class="font-display text-[clamp(2rem,5vw,3rem)] font-semibold text-ink leading-[1.1] mb-3">
      1 CHF · 24 hours · <em class="italic text-burn font-medium">everything unlocked.</em>
    </h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">
      Unlimited use of every PDF tool, every image tool, and the design canvas for the next 24 hours. Files never leave your browser; the pass simply removes the daily quota.
    </p>
  </div>

  {active ? (
    <div class="bg-leaf-bg border border-leaf-border rounded-2xl p-6">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-leaf font-bold mb-2">Active</p>
      <p class="font-display text-[1.4rem] font-semibold text-ink m-0 mb-2">Your day pass is live.</p>
      <p class="text-[0.92rem] text-ink-2 m-0 mb-4">Every tool on /portal/tools is fully unlocked. Have at it.</p>
      <a href="/portal/tools" class="bg-leaf hover:bg-leaf/90 text-white font-semibold py-2.5 px-5 rounded-xl text-[0.88rem] no-underline inline-block">Open tools →</a>
    </div>
  ) : (
    <div class="bg-white border border-ink/10 rounded-2xl p-7">
      <div class="flex items-baseline gap-2 mb-4">
        <p class="font-display text-[3rem] font-bold text-burn leading-none m-0">1</p>
        <p class="font-mono text-[1rem] text-ink-soft m-0">CHF</p>
      </div>
      <ul class="space-y-2 mb-6">
        <li class="text-[0.92rem] text-ink-2 flex items-start gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1A6B35" stroke-width="2.5" style="flex-shrink:0;margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg> 24 hours of unlimited tool use</li>
        <li class="text-[0.92rem] text-ink-2 flex items-start gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1A6B35" stroke-width="2.5" style="flex-shrink:0;margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg> Every PDF tool (merge / split / rotate / watermark / page numbers / organize / compress / to-images / images-to-PDF)</li>
        <li class="text-[0.92rem] text-ink-2 flex items-start gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1A6B35" stroke-width="2.5" style="flex-shrink:0;margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg> Every image tool (compress / resize / crop / convert / rotate / watermark / meme)</li>
        <li class="text-[0.92rem] text-ink-2 flex items-start gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1A6B35" stroke-width="2.5" style="flex-shrink:0;margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg> Layered design canvas with text, shapes, image import + PNG/SVG export</li>
        <li class="text-[0.92rem] text-ink-2 flex items-start gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1A6B35" stroke-width="2.5" style="flex-shrink:0;margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg> Files stay in your browser. No uploads. No model training on your work.</li>
      </ul>

      <button id="buyBtn" class="btn-primary">Pay 1 CHF →</button>
      <p id="status" class="text-[0.82rem] text-ink-soft mt-3 m-0"></p>
    </div>
  )}
</section>

<script is:inline src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script is:inline>
  (function () {
    var b = document.getElementById('buyBtn'); if (!b) return;
    b.addEventListener('click', async function () {
      b.disabled = true; document.getElementById('status').textContent = 'Creating order...';
      try {
        var r = await fetch('/api/payments/tool-pass/order', { method: 'POST', credentials: 'same-origin' });
        var d = await r.json();
        if (!d.ok) throw new Error(d.error || 'Order failed');
        var rzp = new Razorpay({
          key: d.key, amount: d.amount, currency: d.currency, order_id: d.orderId,
          name: 'EduRankAI', description: 'Tools day pass · 24 hours',
          theme: { color: '#FF4F00' },
          handler: async function (resp) {
            document.getElementById('status').textContent = 'Verifying...';
            var v = await fetch('/api/payments/tool-pass/verify', { method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin', body: JSON.stringify(resp) });
            var vd = await v.json();
            if (vd.ok) { document.getElementById('status').textContent = 'Pass activated. Redirecting...'; setTimeout(function () { location.href = '/portal/tools'; }, 1200); }
            else document.getElementById('status').textContent = 'Verification failed: ' + (vd.error || 'unknown');
          },
        });
        rzp.open();
        document.getElementById('status').textContent = 'Complete payment in the Razorpay popup.';
        b.disabled = false;
      } catch (e) { document.getElementById('status').textContent = 'Failed: ' + e.message; b.disabled = false; }
    });
  })();
</script>
</BaseLayout>
