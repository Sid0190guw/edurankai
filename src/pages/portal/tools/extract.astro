---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/extract'));
---
<BaseLayout title="Extract text from PDF · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">PDF · Extract text</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Extract text from PDF</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Pulls the digital text layer out of a PDF (every page, separated). For scanned PDFs without a text layer, use OCR instead.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="application/pdf" class="block w-full text-[0.92rem] file:bg-burn file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <button id="goBtn" class="btn-primary" disabled style="opacity:0.5;">Extract text</button>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
    <textarea id="out" rows="14" placeholder="Extracted text will appear here." class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.92rem] text-ink font-mono leading-relaxed resize-y"></textarea>
    <div class="flex gap-2 flex-wrap">
      <button id="copyBtn" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-5 rounded-xl text-[0.85rem]">Copy</button>
      <button id="dlBtn" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-5 rounded-xl text-[0.85rem]">Download .txt</button>
      <button id="dlDocxBtn" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-5 rounded-xl text-[0.85rem]">Download .docx (plain)</button>
    </div>
  </div>
</section>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script is:inline>
  (function () {
    if (window.pdfjsLib) window.pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    var file = null;
    document.getElementById('fileInput').addEventListener('change', function (e) { file = e.target.files[0]; var b = document.getElementById('goBtn'); b.disabled = !file; b.style.opacity = file ? '1' : '0.5'; });
    document.getElementById('goBtn').addEventListener('click', async function () {
      if (!file || !window.pdfjsLib) return;
      var btn = document.getElementById('goBtn'); btn.disabled = true;
      var status = document.getElementById('status'); var out = document.getElementById('out');
      try {
        var buf = await file.arrayBuffer(); var pdf = await window.pdfjsLib.getDocument({ data: buf }).promise;
        var allText = '';
        for (var i = 1; i <= pdf.numPages; i++) {
          var page = await pdf.getPage(i); var c = await page.getTextContent();
          var s = c.items.map(function (it) { return it.str; }).join(' ');
          allText += '--- Page ' + i + ' ---\n' + s + '\n\n';
          status.textContent = 'Extracted ' + i + ' / ' + pdf.numPages;
        }
        out.value = allText.trim();
        status.textContent = 'Done. ' + out.value.length + ' characters across ' + pdf.numPages + ' page(s).';
      } catch (e) { status.textContent = 'Failed: ' + e.message; }
      btn.disabled = false;
    });
    document.getElementById('copyBtn').addEventListener('click', function () { var ta = document.getElementById('out'); ta.select(); document.execCommand('copy'); });
    document.getElementById('dlBtn').addEventListener('click', function () {
      var blob = new Blob([document.getElementById('out').value || ''], { type: 'text/plain' });
      var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'extracted-' + Date.now() + '.txt'; a.click();
    });
    document.getElementById('dlDocxBtn').addEventListener('click', function () {
      // Minimal Word-compatible RTF wrapped in a .docx-friendly stub. Word opens this directly.
      var text = (document.getElementById('out').value || '').replace(/[<>&]/g, function (c) { return { '<':'&lt;','>':'&gt;','&':'&amp;' }[c]; });
      var html = '<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:w="urn:schemas-microsoft-com:office:word" xmlns="http://www.w3.org/TR/REC-html40"><head><meta charset="utf-8"></head><body><pre style="font-family:Calibri;font-size:11pt;white-space:pre-wrap;">' + text + '</pre></body></html>';
      var blob = new Blob(['﻿', html], { type: 'application/msword' });
      var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'extracted-' + Date.now() + '.doc'; a.click();
    });
  })();
</script>
</BaseLayout>
