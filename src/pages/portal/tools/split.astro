---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/split'));
---
<BaseLayout title="Split PDF · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">PDF · Split</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Split PDF</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Extract specific pages or page ranges (e.g. <code class="bg-cream-2 px-1.5 rounded">1-3, 5, 8-10</code>) into a new PDF. Browser-only.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <label class="block">
      <span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">PDF file</span>
      <input type="file" id="fileInput" accept="application/pdf" class="block w-full text-[0.92rem] file:bg-burn file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    </label>
    <p id="meta" class="text-[0.85rem] text-ink-soft m-0"></p>
    <label class="block">
      <span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Page ranges</span>
      <input id="ranges" type="text" placeholder="1-3, 5, 8-10" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink font-mono focus:border-burn focus:outline-none" />
      <p class="text-[0.72rem] text-ink-soft mt-1 m-0">Use commas + dashes. Leave blank to split every page into its own file.</p>
    </label>
    <div class="flex gap-2 flex-wrap">
      <button id="extractBtn" class="btn-primary" disabled style="opacity:0.5;">Extract & download</button>
      <button id="splitAllBtn" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-3 px-6 rounded-xl text-[0.88rem]" disabled style="opacity:0.5;">Split every page (.zip)</button>
    </div>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
  </div>
</section>

<script is:inline src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
<script is:inline>
  (function () {
    var file = null;
    var pageCount = 0;
    var fi = document.getElementById('fileInput');
    var meta = document.getElementById('meta');
    var ranges = document.getElementById('ranges');
    var btn = document.getElementById('extractBtn');
    var btnAll = document.getElementById('splitAllBtn');
    var status = document.getElementById('status');

    fi.addEventListener('change', async function () {
      if (!fi.files[0]) return;
      file = fi.files[0];
      var bytes = new Uint8Array(await file.arrayBuffer());
      var src = await PDFLib.PDFDocument.load(bytes, { ignoreEncryption: true });
      pageCount = src.getPageCount();
      meta.textContent = file.name + ' · ' + pageCount + ' pages · ' + (file.size / 1024).toFixed(1) + ' KB';
      btn.disabled = false; btn.style.opacity = '1';
      btnAll.disabled = false; btnAll.style.opacity = '1';
    });

    function parseRanges(spec, max) {
      var indices = [];
      spec.split(',').forEach(function (part) {
        part = part.trim(); if (!part) return;
        if (part.indexOf('-') >= 0) {
          var pair = part.split('-').map(function (s) { return parseInt(s.trim(), 10); });
          if (isFinite(pair[0]) && isFinite(pair[1])) {
            for (var i = pair[0]; i <= pair[1]; i++) if (i >= 1 && i <= max) indices.push(i - 1);
          }
        } else {
          var n = parseInt(part, 10);
          if (isFinite(n) && n >= 1 && n <= max) indices.push(n - 1);
        }
      });
      return indices;
    }

    btn.addEventListener('click', async function () {
      if (!file) return;
      btn.disabled = true; status.textContent = 'Extracting...';
      try {
        var bytes = new Uint8Array(await file.arrayBuffer());
        var src = await PDFLib.PDFDocument.load(bytes, { ignoreEncryption: true });
        var idx = ranges.value.trim() ? parseRanges(ranges.value, pageCount) : src.getPageIndices();
        if (idx.length === 0) { status.textContent = 'No valid pages selected.'; btn.disabled = false; return; }
        var out = await PDFLib.PDFDocument.create();
        var pages = await out.copyPages(src, idx);
        pages.forEach(function (p) { out.addPage(p); });
        var blob = new Blob([await out.save()], { type: 'application/pdf' });
        var a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = file.name.replace(/\.pdf$/i, '') + '-extracted.pdf';
        a.click();
        status.textContent = 'Extracted ' + idx.length + ' pages.';
      } catch (e) { status.textContent = 'Failed: ' + e.message; }
      btn.disabled = false;
    });

    btnAll.addEventListener('click', async function () {
      if (!file) return;
      btnAll.disabled = true; status.textContent = 'Splitting every page (downloading individually)...';
      try {
        var bytes = new Uint8Array(await file.arrayBuffer());
        var src = await PDFLib.PDFDocument.load(bytes, { ignoreEncryption: true });
        for (var i = 0; i < pageCount; i++) {
          var out = await PDFLib.PDFDocument.create();
          var p = await out.copyPages(src, [i]);
          out.addPage(p[0]);
          var blob = new Blob([await out.save()], { type: 'application/pdf' });
          var a = document.createElement('a');
          a.href = URL.createObjectURL(blob);
          a.download = file.name.replace(/\.pdf$/i, '') + '-page-' + (i + 1) + '.pdf';
          a.click();
          await new Promise(function (r) { setTimeout(r, 150); });
        }
        status.textContent = 'Downloaded ' + pageCount + ' files.';
      } catch (e) { status.textContent = 'Failed: ' + e.message; }
      btnAll.disabled = false;
    });
  })();
</script>
</BaseLayout>
