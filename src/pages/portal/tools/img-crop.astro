---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/img-crop'));
---
<BaseLayout title="Crop image · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-sky font-bold mb-2">Image · Crop</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Crop image</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Drag the box to move it, pull the handles to resize, lock a ratio if you need one. Live pixel dimensions; choose your output format.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="image/*" class="block w-full text-[0.92rem] file:bg-sky file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />

    <div id="ratioRow" class="hidden">
      <span class="lbl">Aspect ratio</span>
      <div class="flex flex-wrap gap-2" id="ratios">
        <button data-r="free" class="pchip on">Free</button><button data-r="1:1" class="pchip">1:1</button><button data-r="4:3" class="pchip">4:3</button><button data-r="3:2" class="pchip">3:2</button><button data-r="16:9" class="pchip">16:9</button><button data-r="9:16" class="pchip">9:16</button>
      </div>
    </div>

    <div id="stage" class="hidden" style="position:relative;line-height:0;border-radius:10px;overflow:hidden;background:#0b0d13;user-select:none;touch-action:none;">
      <img id="preview" style="max-width:100%;display:block;" draggable="false" />
      <div id="shade" style="position:absolute;inset:0;box-shadow:0 0 0 9999px rgba(0,0,0,0.5);border:1px solid #FF4F00;display:none;"></div>
    </div>
    <p id="dims" class="text-[0.85rem] text-ink-soft m-0"></p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="outRow" style="display:none;">
      <label class="block"><span class="lbl">Output format</span><select id="fmt" class="inp"><option value="image/png" selected>PNG</option><option value="image/jpeg">JPEG</option><option value="image/webp">WebP</option></select></label>
      <label class="block" id="qWrap" style="display:none;"><span class="lbl">Quality: <span id="qVal">90</span>%</span><input id="quality" type="range" min="10" max="100" value="90" class="w-full" /></label>
    </div>

    <button id="goBtn" class="bg-sky hover:bg-sky/90 text-white font-semibold py-3 px-6 rounded-xl text-[0.92rem]" disabled style="opacity:0.5;">Crop</button>
    <div id="result" class="hidden pt-1"><img id="out" class="max-w-full max-h-72 rounded-xl border border-sky/30 bg-cream" /><div class="mt-3 bg-cream rounded-xl p-4 flex items-center justify-between gap-3 flex-wrap"><span id="savedTxt" class="text-[0.9rem] text-ink font-semibold"></span><a id="dlBtn" class="bg-leaf hover:bg-leaf/90 text-white font-semibold py-2.5 px-5 rounded-xl text-[0.88rem] no-underline">Download</a></div></div>
  </div>
</section>
<style is:global>
  .pchip{ background:#faf7f2; border:1px solid rgba(14,11,8,0.15); color:#0E0B08; border-radius:99px; padding:6px 14px; font-family:'Geist Mono',monospace; font-size:11px; font-weight:600; cursor:pointer; } .pchip.on{ background:#0ea5e9; color:#fff; border-color:#0ea5e9; }
  .lbl{ font-family:'Geist Mono',monospace; font-size:0.62rem; text-transform:uppercase; letter-spacing:0.14em; color:#8a7f76; font-weight:700; margin-bottom:8px; display:block; }
  .inp{ width:100%; background:#faf7f2; border:1px solid rgba(14,11,8,0.15); border-radius:12px; padding:12px 16px; font-size:0.95rem; color:#0E0B08; box-sizing:border-box; }
  .ch{ position:absolute; width:14px; height:14px; background:#fff; border:2px solid #FF4F00; border-radius:3px; z-index:3; }
</style>
<script is:inline>
  (function () {
    var $ = function (id){ return document.getElementById(id); };
    var file=null, img=$('preview'), shade=$('shade'), ratio=null, box={x:0,y:0,w:0,h:0}, dispW=0, dispH=0, scale=1, blob=null;
    function kb(b){ return b<1048576?(b/1024).toFixed(1)+' KB':(b/1048576).toFixed(2)+' MB'; }
    $('quality').addEventListener('input', function(){ $('qVal').textContent=this.value; });
    $('fmt').addEventListener('change', function(){ $('qWrap').style.display=this.value==='image/png'?'none':'block'; });

    // handles
    var handleDefs=[['nw',0,0],['n',0.5,0],['ne',1,0],['e',1,0.5],['se',1,1],['s',0.5,1],['sw',0,1],['w',0,0.5]];
    var handles={};
    handleDefs.forEach(function(hd){ var el=document.createElement('div'); el.className='ch'; el.dataset.h=hd[0]; el.style.cursor=(hd[0].length===2?hd[0]:hd[0])+'-resize'; $('stage').appendChild(el); handles[hd[0]]=el; el.style.display='none'; });

    $('fileInput').addEventListener('change', function(){ if(!this.files[0])return; file=this.files[0]; img.onload=function(){ $('stage').classList.remove('hidden'); $('ratioRow').classList.remove('hidden'); $('outRow').style.display='grid';
      var r=img.getBoundingClientRect(); dispW=img.clientWidth; dispH=img.clientHeight; scale=img.naturalWidth/dispW;
      box={x:dispW*0.1,y:dispH*0.1,w:dispW*0.8,h:dispH*0.8}; if(ratio) applyRatio(); render(); $('goBtn').disabled=false; $('goBtn').style.opacity='1'; $('result').classList.add('hidden'); }; img.src=URL.createObjectURL(file); });
    window.addEventListener('resize', function(){ if(file){ dispW=img.clientWidth; dispH=img.clientHeight; scale=img.naturalWidth/dispW; render(); } });

    document.querySelectorAll('#ratios .pchip').forEach(function(b){ b.addEventListener('click', function(){ document.querySelectorAll('#ratios .pchip').forEach(function(x){x.classList.toggle('on',x===b);}); var r=b.getAttribute('data-r'); ratio = r==='free'?null:(function(){var p=r.split(':');return +p[0]/+p[1];})(); applyRatio(); render(); }); });
    function applyRatio(){ if(!ratio)return; var h=box.w/ratio; if(box.y+h>dispH) h=dispH-box.y; box.h=h; box.w=h*ratio; if(box.x+box.w>dispW){ box.w=dispW-box.x; box.h=box.w/ratio; } }

    function clampBox(){ box.w=Math.max(10,Math.min(box.w,dispW)); box.h=Math.max(10,Math.min(box.h,dispH)); box.x=Math.max(0,Math.min(box.x,dispW-box.w)); box.y=Math.max(0,Math.min(box.y,dispH-box.h)); }
    function render(){ clampBox(); shade.style.display='block'; shade.style.left=box.x+'px'; shade.style.top=box.y+'px'; shade.style.width=box.w+'px'; shade.style.height=box.h+'px';
      handleDefs.forEach(function(hd){ var el=handles[hd[0]]; el.style.display='block'; el.style.left=(box.x+box.w*hd[1]-7)+'px'; el.style.top=(box.y+box.h*hd[2]-7)+'px'; });
      $('dims').textContent = Math.round(box.w*scale)+' × '+Math.round(box.h*scale)+' px'+(ratio?' · locked '+ratio.toFixed(2):''); }

    function pos(e){ var r=$('stage').getBoundingClientRect(); var cx=e.touches?e.touches[0].clientX:e.clientX, cy=e.touches?e.touches[0].clientY:e.clientY; return {x:cx-r.left,y:cy-r.top}; }
    var drag=null, start=null, sb=null;
    function down(e, mode){ e.preventDefault(); start=pos(e); sb={x:box.x,y:box.y,w:box.w,h:box.h}; drag=mode; }
    shade.style.pointerEvents='auto'; shade.style.cursor='move';
    shade.addEventListener('mousedown', function(e){ down(e,'move'); }); shade.addEventListener('touchstart', function(e){ down(e,'move'); },{passive:false});
    handleDefs.forEach(function(hd){ handles[hd[0]].addEventListener('mousedown', function(e){ e.stopPropagation(); down(e,'h:'+hd[0]); }); handles[hd[0]].addEventListener('touchstart', function(e){ e.stopPropagation(); down(e,'h:'+hd[0]); },{passive:false}); });
    function move(e){ if(!drag)return; e.preventDefault(); var p=pos(e), dx=p.x-start.x, dy=p.y-start.y;
      if(drag==='move'){ box.x=sb.x+dx; box.y=sb.y+dy; }
      else { var h=drag.slice(2); var nx=sb.x,ny=sb.y,nw=sb.w,nh=sb.h;
        if(h.indexOf('e')>=0) nw=sb.w+dx; if(h.indexOf('s')>=0) nh=sb.h+dy; if(h.indexOf('w')>=0){ nw=sb.w-dx; nx=sb.x+dx; } if(h.indexOf('n')>=0){ nh=sb.h-dy; ny=sb.y+dy; }
        if(ratio){ if(h==='n'||h==='s') nw=nh*ratio; else nh=nw/ratio; if(h.indexOf('w')>=0) nx=sb.x+sb.w-nw; if(h.indexOf('n')>=0) ny=sb.y+sb.h-nh; }
        box.x=nx; box.y=ny; box.w=nw; box.h=nh; }
      render(); }
    document.addEventListener('mousemove', move); document.addEventListener('touchmove', move,{passive:false});
    document.addEventListener('mouseup', function(){ drag=null; }); document.addEventListener('touchend', function(){ drag=null; });

    $('goBtn').addEventListener('click', function(){ if(!file)return; var sx=Math.round(box.x*scale), sy=Math.round(box.y*scale), sw=Math.round(box.w*scale), sh=Math.round(box.h*scale);
      var c=document.createElement('canvas'); c.width=sw; c.height=sh; var ctx=c.getContext('2d'); if($('fmt').value!=='image/png'){ ctx.fillStyle='#fff'; ctx.fillRect(0,0,sw,sh); }
      ctx.drawImage(img,sx,sy,sw,sh,0,0,sw,sh); var fmt=$('fmt').value, q=+$('quality').value/100;
      c.toBlob(function(b){ blob=b; var url=URL.createObjectURL(b); $('out').src=url; var ext=fmt.split('/')[1]; if(ext==='jpeg')ext='jpg'; $('savedTxt').textContent=sw+'×'+sh+' · '+kb(b.size); var dl=$('dlBtn'); dl.href=url; dl.download=file.name.replace(/\.[^.]+$/,'')+'-crop.'+ext; $('result').classList.remove('hidden'); }, fmt, q); });
  })();
</script>
</BaseLayout>
