---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/img-crop'));
---
<BaseLayout title="Crop image · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-sky font-bold mb-2">Image · Crop</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Crop image</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Drag on the preview to select. Release to set the crop region.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="image/*" class="block w-full text-[0.92rem] file:bg-sky file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <div id="cropWrap" style="position:relative;display:none;border:1px solid rgba(14,11,8,0.1);border-radius:10px;overflow:hidden;background:#FAF8F5;">
      <img id="preview" style="max-width:100%;display:block;user-select:none;" draggable="false" />
      <div id="sel" style="position:absolute;border:2px dashed #FF4F00;background:rgba(255,79,0,0.10);display:none;pointer-events:none;"></div>
    </div>
    <p id="meta" class="text-[0.85rem] text-ink-soft m-0"></p>
    <button id="goBtn" class="bg-sky hover:bg-sky/90 text-white font-semibold py-3 px-6 rounded-xl text-[0.92rem]" disabled style="opacity:0.5;">Crop & download</button>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
  </div>
</section>
<script is:inline>
  (function () {
    var file = null; var img = document.getElementById('preview'); var wrap = document.getElementById('cropWrap');
    var sel = document.getElementById('sel'); var meta = document.getElementById('meta'); var btn = document.getElementById('goBtn'); var status = document.getElementById('status');
    var ow = 0, oh = 0, dragging = false, x0 = 0, y0 = 0, region = null;
    document.getElementById('fileInput').addEventListener('change', function (e) {
      file = e.target.files[0]; if (!file) return;
      img.onload = function () { ow = img.naturalWidth; oh = img.naturalHeight; meta.textContent = ow + ' × ' + oh + ' px · drag to select region'; wrap.style.display = 'block'; sel.style.display = 'none'; region = null; btn.disabled = true; btn.style.opacity = '0.5'; };
      img.src = URL.createObjectURL(file);
    });
    function evtPos(e) { var r = img.getBoundingClientRect(); return { x: (e.clientX || e.touches[0].clientX) - r.left, y: (e.clientY || e.touches[0].clientY) - r.top }; }
    img.addEventListener('mousedown', function (e) { e.preventDefault(); var p = evtPos(e); x0 = p.x; y0 = p.y; dragging = true; sel.style.display = 'block'; sel.style.left = x0 + 'px'; sel.style.top = y0 + 'px'; sel.style.width = '0px'; sel.style.height = '0px'; });
    document.addEventListener('mousemove', function (e) { if (!dragging) return; var p = evtPos(e); var x = Math.min(p.x, x0); var y = Math.min(p.y, y0); var w = Math.abs(p.x - x0); var h = Math.abs(p.y - y0); sel.style.left = x + 'px'; sel.style.top = y + 'px'; sel.style.width = w + 'px'; sel.style.height = h + 'px'; });
    document.addEventListener('mouseup', function (e) { if (!dragging) return; dragging = false; var r = img.getBoundingClientRect(); var x = parseFloat(sel.style.left); var y = parseFloat(sel.style.top); var w = parseFloat(sel.style.width); var h = parseFloat(sel.style.height); if (w < 5 || h < 5) { region = null; btn.disabled = true; btn.style.opacity = '0.5'; return; } var sx = ow / r.width; var sy = oh / r.height; region = { x: x * sx, y: y * sy, w: w * sx, h: h * sy }; btn.disabled = false; btn.style.opacity = '1'; });
    btn.addEventListener('click', function () {
      if (!region) return; btn.disabled = true; status.textContent = 'Cropping...';
      var c = document.createElement('canvas'); c.width = region.w; c.height = region.h;
      c.getContext('2d').drawImage(img, region.x, region.y, region.w, region.h, 0, 0, region.w, region.h);
      c.toBlob(function (blob) { var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = (file ? file.name.replace(/\.[^.]+$/, '') : 'crop') + '-cropped.png'; a.click(); status.textContent = 'Done.'; btn.disabled = false; }, 'image/png');
    });
  })();
</script>
</BaseLayout>
