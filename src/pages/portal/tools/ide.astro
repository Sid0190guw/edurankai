---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/ide'));
---
<BaseLayout title="Code IDE · EduRankAI Tools" description="A browser-based code editor built from scratch. Multi-tab editor, file tree, syntax highlighting, terminal, command palette. Files persist to localStorage.">

<style>
  body { background: #0a0a0c; color: #e8e8ee; margin: 0; }
  .ide-shell { display: grid; grid-template-rows: 36px 1fr 200px; height: 100vh; }
  .ide-titlebar { background: #11131a; border-bottom: 1px solid #2a2a35; display: flex; align-items: center; padding: 0 12px; gap: 16px; font-family: 'Geist Mono', monospace; font-size: 11px; color: #cfd6da; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700; }
  .ide-titlebar a { color: #67e8f9; text-decoration: none; }
  .ide-main { display: grid; grid-template-columns: 220px 1fr; overflow: hidden; }
  .ide-sidebar { background: #0c0e14; border-right: 1px solid #2a2a35; overflow-y: auto; }
  .ide-sidebar-head { padding: 10px 12px; font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #67e8f9; font-weight: 700; border-bottom: 1px solid #1a1a25; display: flex; justify-content: space-between; align-items: center; }
  .ide-sidebar-head button { background: transparent; border: 1px solid #2a2a35; color: #cfd6da; padding: 2px 8px; border-radius: 4px; font-size: 10px; cursor: pointer; font-family: inherit; }
  .ide-file { padding: 5px 14px; font-size: 12.5px; color: #cfd6da; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 4px; }
  .ide-file:hover { background: #1a1a25; }
  .ide-file.active { background: #1a1a25; color: #67e8f9; }
  .ide-file-del { background: transparent; border: none; color: #6e6e78; font-size: 14px; cursor: pointer; opacity: 0; padding: 0 4px; }
  .ide-file:hover .ide-file-del { opacity: 1; }

  .ide-editor-col { display: flex; flex-direction: column; overflow: hidden; }
  .ide-tabs { background: #11131a; border-bottom: 1px solid #2a2a35; display: flex; overflow-x: auto; }
  .ide-tab { padding: 8px 14px; font-family: 'Geist Mono', monospace; font-size: 11px; color: #9aa6b6; cursor: pointer; border-right: 1px solid #2a2a35; display: flex; align-items: center; gap: 8px; }
  .ide-tab.active { background: #0a0a0c; color: #67e8f9; border-top: 2px solid #67e8f9; padding-top: 6px; }
  .ide-tab-x { background: transparent; border: none; color: #6e6e78; font-size: 14px; cursor: pointer; padding: 0; }
  .ide-tab-x:hover { color: #f87171; }

  .ide-editor-wrap { flex: 1; display: grid; grid-template-columns: 50px 1fr; overflow: hidden; background: #0a0a0c; }
  .ide-gutter { background: #0c0e14; color: #4a4f5e; font-family: ui-monospace, monospace; font-size: 13px; line-height: 20px; padding: 10px 8px 10px 0; text-align: right; user-select: none; overflow: hidden; }
  .ide-editor-scroll { overflow: auto; position: relative; }
  .ide-editor-bg { background: #0a0a0c; font-family: ui-monospace, monospace; font-size: 13px; line-height: 20px; padding: 10px 12px; color: transparent; white-space: pre; pointer-events: none; min-height: 100%; }
  .ide-editor-bg .tok-keyword { color: #c4b5fd; }
  .ide-editor-bg .tok-string { color: #86efac; }
  .ide-editor-bg .tok-number { color: #fbbf24; }
  .ide-editor-bg .tok-comment { color: #6e6e78; font-style: italic; }
  .ide-editor-bg .tok-func { color: #67e8f9; }
  .ide-editor-bg .tok-type { color: #fb923c; }
  .ide-editor-bg .tok-op { color: #f87171; }
  .ide-textarea { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: transparent; color: #fff; caret-color: #67e8f9; border: none; outline: none; padding: 10px 12px; font-family: ui-monospace, monospace; font-size: 13px; line-height: 20px; resize: none; white-space: pre; overflow: hidden; box-sizing: border-box; }
  .ide-textarea::selection { background: rgba(103,232,249,0.3); }

  .ide-terminal { background: #08080a; border-top: 1px solid #2a2a35; padding: 10px 14px; overflow-y: auto; font-family: ui-monospace, monospace; font-size: 12px; color: #86efac; }
  .ide-terminal-line { line-height: 1.6; }
  .ide-terminal-prompt { color: #67e8f9; }
  .ide-terminal-input { background: transparent; border: none; color: #fff; font-family: inherit; font-size: inherit; outline: none; width: 80%; caret-color: #67e8f9; }

  .ide-palette { position: fixed; top: 80px; left: 50%; transform: translateX(-50%); background: #11131a; border: 1px solid #2a2a35; border-radius: 10px; width: 540px; max-width: 90vw; padding: 8px; box-shadow: 0 20px 60px rgba(0,0,0,0.6); z-index: 1000; display: none; }
  .ide-palette.open { display: block; }
  .ide-palette input { width: 100%; background: #0a0a0c; border: 1px solid #2a2a35; color: #fff; padding: 10px 14px; border-radius: 6px; font-family: ui-monospace, monospace; font-size: 13px; outline: none; }
  .ide-palette-list { max-height: 360px; overflow-y: auto; margin-top: 8px; }
  .ide-palette-item { padding: 8px 12px; font-size: 12.5px; color: #cfd6da; cursor: pointer; border-radius: 4px; display: flex; justify-content: space-between; }
  .ide-palette-item.active, .ide-palette-item:hover { background: #1a1a25; color: #67e8f9; }
  .ide-palette-item-kbd { color: #6e6e78; font-family: 'Geist Mono', monospace; font-size: 10.5px; }
</style>

<div class="ide-shell">

  <div class="ide-titlebar">
    <a href="/portal/tools">← Tools</a>
    <span>EduRankAI Code IDE · v1.0</span>
    <span style="margin-left:auto;color:#6e6e78;font-weight:400;">Ctrl+P palette · Ctrl+S save · Ctrl+\` terminal</span>
  </div>

  <div class="ide-main">

    <aside class="ide-sidebar">
      <div class="ide-sidebar-head"><span>Files</span><button id="newFileBtn">+ New</button></div>
      <div id="fileTree"></div>
    </aside>

    <div class="ide-editor-col">
      <div class="ide-tabs" id="tabBar"></div>
      <div class="ide-editor-wrap">
        <div class="ide-gutter" id="gutter"></div>
        <div class="ide-editor-scroll" id="editorScroll">
          <div class="ide-editor-bg" id="bg"></div>
          <textarea class="ide-textarea" id="ta" spellcheck="false"></textarea>
        </div>
      </div>
    </div>

  </div>

  <div class="ide-terminal" id="terminal">
    <div class="ide-terminal-line"><span class="ide-terminal-prompt">era@ide ~ $</span> welcome — built from scratch, no external editor lib</div>
    <div class="ide-terminal-line">Commands: <span style="color:#67e8f9;">ls · cat &lt;file&gt; · echo · clear · run js &lt;file&gt; · help</span></div>
    <div class="ide-terminal-line"><span class="ide-terminal-prompt">era@ide ~ $</span> <input class="ide-terminal-input" id="termIn" autocomplete="off"/></div>
  </div>
</div>

{/* Command palette */}
<div class="ide-palette" id="palette">
  <input type="text" id="palInput" placeholder="Type a command or file name..." />
  <div class="ide-palette-list" id="palList"></div>
</div>

<script is:inline>
  /* ============================================================
     EduRankAI Code IDE — built from scratch.
     - Virtual filesystem in localStorage
     - Multi-tab editor
     - Hand-rolled syntax highlighter (JS, Python, HTML, CSS, MD)
     - Synced line-number gutter
     - Hand-rolled command palette
     - Hand-rolled terminal with shell commands
     ============================================================ */
  (function () {
    var KEY = 'era_ide_v1';
    var state = { files: {}, openTabs: [], activeTab: null };
    try { var s = localStorage.getItem(KEY); if (s) state = JSON.parse(s); } catch (_) {}
    if (Object.keys(state.files).length === 0) {
      state.files = {
        'welcome.md': '# EduRankAI IDE\n\nBuilt from scratch — no Monaco, no external editor.\n\n- Multi-tab editor with localStorage persistence\n- Hand-rolled syntax highlighter\n- Command palette (Ctrl+P)\n- Terminal with shell commands\n\n## Try it\n\n1. Click `+ New` in the file tree.\n2. Save a `.js` or `.py` file.\n3. Type `run js example.js` in the terminal.',
        'example.js': '// click run js example.js in the terminal\nfunction fib(n) {\n  if (n < 2) return n;\n  return fib(n - 1) + fib(n - 2);\n}\n\nfor (var i = 0; i < 10; i++) {\n  console.log("fib(" + i + ") = " + fib(i));\n}\n',
        'example.py': '# python file (display-only; no runtime in browser)\ndef gcd(a, b):\n    while b:\n        a, b = b, a % b\n    return a\n\nfor i in range(1, 15):\n    print(gcd(i, 28))\n',
      };
      state.openTabs = ['welcome.md'];
      state.activeTab = 'welcome.md';
    }
    function save() { try { localStorage.setItem(KEY, JSON.stringify(state)); } catch (_) {} }

    // ============ Syntax highlighter ============
    var LANG = {
      js:   { kw: /\b(var|let|const|function|return|if|else|for|while|do|break|continue|new|this|class|extends|import|export|from|default|true|false|null|undefined|typeof|instanceof|async|await|try|catch|throw)\b/g, type: /\b(Number|String|Boolean|Array|Object|Math|JSON|Date|Promise|console)\b/g },
      ts:   { kw: /\b(var|let|const|function|return|if|else|for|while|do|break|continue|new|this|class|extends|import|export|from|default|true|false|null|undefined|typeof|instanceof|async|await|try|catch|throw|interface|type|enum|public|private|protected|readonly|abstract|implements)\b/g, type: /\b(Number|String|Boolean|Array|Object|Math|JSON|Date|Promise|console|any|void|never|unknown)\b/g },
      py:   { kw: /\b(def|class|import|from|as|if|elif|else|for|while|in|return|break|continue|pass|with|try|except|finally|raise|True|False|None|and|or|not|is|lambda|global|nonlocal|yield|async|await)\b/g, type: /\b(int|str|float|bool|list|dict|tuple|set|print|len|range|type)\b/g },
      html: { kw: /(&lt;\/?[a-zA-Z][^&]*&gt;)/g, type: /\b(html|head|body|div|span|h[1-6]|p|a|img|ul|li|table|tr|td|button|input|form)\b/g },
      css:  { kw: /([.#][a-zA-Z][\w-]*|:[a-z-]+)/g, type: /\b(color|background|font-size|margin|padding|border|width|height|display|flex|grid|position|top|left)\b/g },
      md:   { kw: /^(#{1,6} .+)$/gm, type: /\B\*(.+?)\*\B/g },
    };
    function detectLang(name) { var m = (name.split('.').pop() || '').toLowerCase(); if (m === 'jsx' || m === 'mjs') m = 'js'; if (m === 'tsx') m = 'ts'; if (m === 'py') m = 'py'; return m; }

    function highlight(text, lang) {
      // Escape HTML
      var esc = text.replace(/[&<>]/g, function (c) { return { '&':'&amp;', '<':'&lt;', '>':'&gt;' }[c]; });
      // strings + numbers + comments first (greedy)
      esc = esc.replace(/("(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*'|`(?:[^`\\]|\\.)*`)/g, '<span class="tok-string">$1</span>');
      if (lang === 'py') esc = esc.replace(/(#[^\n]*)/g, '<span class="tok-comment">$1</span>');
      else esc = esc.replace(/(\/\/[^\n]*|\/\*[\s\S]*?\*\/)/g, '<span class="tok-comment">$1</span>');
      esc = esc.replace(/\b(\d+\.?\d*)\b/g, '<span class="tok-number">$1</span>');
      // language keywords + types
      var spec = LANG[lang];
      if (spec) {
        if (spec.kw) esc = esc.replace(spec.kw, '<span class="tok-keyword">$&</span>');
        if (spec.type) esc = esc.replace(spec.type, '<span class="tok-type">$&</span>');
      }
      // function calls
      esc = esc.replace(/([a-zA-Z_][\w]*)(?=\s*\()/g, '<span class="tok-func">$1</span>');
      return esc;
    }

    // ============ DOM refs ============
    var $ = function (id) { return document.getElementById(id); };
    var ta = $('ta'), bg = $('bg'), gutter = $('gutter'), tabBar = $('tabBar'), fileTree = $('fileTree');

    function renderFiles() {
      fileTree.innerHTML = '';
      Object.keys(state.files).sort().forEach(function (name) {
        var el = document.createElement('div');
        el.className = 'ide-file' + (name === state.activeTab ? ' active' : '');
        el.innerHTML = '<span>' + name + '</span><button class="ide-file-del" title="Delete">×</button>';
        el.addEventListener('click', function (e) { if (e.target.classList.contains('ide-file-del')) return; openFile(name); });
        el.querySelector('.ide-file-del').addEventListener('click', function (e) { e.stopPropagation(); deleteFile(name); });
        fileTree.appendChild(el);
      });
    }

    function renderTabs() {
      tabBar.innerHTML = '';
      state.openTabs.forEach(function (name) {
        var t = document.createElement('div');
        t.className = 'ide-tab' + (name === state.activeTab ? ' active' : '');
        t.innerHTML = '<span>' + name + '</span><button class="ide-tab-x" title="Close">×</button>';
        t.addEventListener('click', function (e) { if (e.target.classList.contains('ide-tab-x')) return; activateTab(name); });
        t.querySelector('.ide-tab-x').addEventListener('click', function (e) { e.stopPropagation(); closeTab(name); });
        tabBar.appendChild(t);
      });
    }

    function openFile(name) {
      if (!state.files[name] && state.files[name] !== '') return;
      if (state.openTabs.indexOf(name) < 0) state.openTabs.push(name);
      activateTab(name);
    }
    function activateTab(name) {
      state.activeTab = name;
      ta.value = state.files[name] || '';
      renderAll();
      save();
    }
    function closeTab(name) {
      state.openTabs = state.openTabs.filter(function (n) { return n !== name; });
      if (state.activeTab === name) state.activeTab = state.openTabs[0] || null;
      if (state.activeTab) ta.value = state.files[state.activeTab] || '';
      else ta.value = '';
      renderAll();
      save();
    }
    function deleteFile(name) {
      if (!confirm('Delete ' + name + '?')) return;
      delete state.files[name];
      closeTab(name);
      renderFiles();
      save();
    }

    function renderAll() { renderFiles(); renderTabs(); rerenderEditor(); }

    function rerenderEditor() {
      var lang = state.activeTab ? detectLang(state.activeTab) : 'js';
      bg.innerHTML = highlight(ta.value, lang);
      // gutter
      var lines = ta.value.split('\n').length;
      var g = '';
      for (var i = 1; i <= lines; i++) g += i + '\n';
      gutter.textContent = g;
      gutter.scrollTop = ta.scrollTop;
    }

    ta.addEventListener('input', function () {
      if (state.activeTab) { state.files[state.activeTab] = ta.value; save(); }
      rerenderEditor();
    });
    ta.addEventListener('scroll', function () { bg.style.transform = 'translateY(' + (-ta.scrollTop) + 'px)'; gutter.scrollTop = ta.scrollTop; });
    ta.addEventListener('keydown', function (e) {
      if (e.key === 'Tab') { e.preventDefault(); var s = ta.selectionStart, t = ta.selectionEnd; ta.value = ta.value.slice(0, s) + '  ' + ta.value.slice(t); ta.selectionStart = ta.selectionEnd = s + 2; ta.dispatchEvent(new Event('input')); }
      if ((e.ctrlKey || e.metaKey) && e.key === 's') { e.preventDefault(); save(); termLog('Saved ' + state.activeTab); }
    });

    $('newFileBtn').addEventListener('click', function () {
      var name = prompt('File name (with extension):');
      if (!name) return;
      state.files[name] = '';
      openFile(name);
    });

    // ============ Command palette ============
    var palette = $('palette'), palInput = $('palInput'), palList = $('palList');
    var palItems = [];
    function buildPalette() {
      palItems = [
        { label: 'New file', kbd: 'Ctrl+N', action: function () { $('newFileBtn').click(); closePalette(); } },
        { label: 'Save current file', kbd: 'Ctrl+S', action: function () { save(); termLog('Saved'); closePalette(); } },
        { label: 'Toggle terminal focus', kbd: 'Ctrl+`', action: function () { $('termIn').focus(); closePalette(); } },
        { label: 'Clear terminal', action: function () { $('terminal').innerHTML = '<div class="ide-terminal-line"><span class="ide-terminal-prompt">era@ide ~ $</span> <input class="ide-terminal-input" id="termIn" autocomplete="off"/></div>'; closePalette(); wireTerminal(); } },
      ];
      Object.keys(state.files).forEach(function (n) {
        palItems.push({ label: 'Open: ' + n, action: function () { openFile(n); closePalette(); } });
      });
    }
    function renderPalette(filter) {
      buildPalette();
      palList.innerHTML = '';
      var f = (filter || '').toLowerCase();
      palItems.filter(function (it) { return it.label.toLowerCase().indexOf(f) >= 0; }).slice(0, 30).forEach(function (it, i) {
        var el = document.createElement('div');
        el.className = 'ide-palette-item' + (i === 0 ? ' active' : '');
        el.innerHTML = '<span>' + it.label + '</span>' + (it.kbd ? '<span class="ide-palette-item-kbd">' + it.kbd + '</span>' : '');
        el.addEventListener('click', function () { it.action(); });
        palList.appendChild(el);
      });
    }
    function openPalette() { palette.classList.add('open'); palInput.value = ''; renderPalette(''); palInput.focus(); }
    function closePalette() { palette.classList.remove('open'); }
    palInput.addEventListener('input', function () { renderPalette(palInput.value); });
    palInput.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') { var first = palList.querySelector('.ide-palette-item'); if (first) first.click(); }
      if (e.key === 'Escape') closePalette();
    });

    document.addEventListener('keydown', function (e) {
      if ((e.ctrlKey || e.metaKey) && e.key === 'p') { e.preventDefault(); openPalette(); }
      if ((e.ctrlKey || e.metaKey) && e.key === '`') { e.preventDefault(); $('termIn').focus(); }
      if (e.key === 'Escape' && palette.classList.contains('open')) closePalette();
    });

    // ============ Terminal ============
    var term = $('terminal');
    function termLog(line) {
      var el = document.createElement('div');
      el.className = 'ide-terminal-line';
      el.innerHTML = line;
      // Insert before the prompt line
      var promptLine = term.querySelector('.ide-terminal-input').parentNode;
      term.insertBefore(el, promptLine);
      term.scrollTop = term.scrollHeight;
    }
    function wireTerminal() {
      var inp = $('termIn'); if (!inp) return;
      inp.addEventListener('keydown', function (e) {
        if (e.key !== 'Enter') return;
        var cmd = inp.value.trim();
        inp.value = '';
        if (!cmd) return;
        termLog('<span class="ide-terminal-prompt">era@ide ~ $</span> ' + cmd);
        runCommand(cmd);
      });
    }
    function runCommand(cmd) {
      var parts = cmd.split(/\s+/);
      var op = parts[0];
      try {
        if (op === 'help') termLog('Commands: <span style="color:#67e8f9;">ls · cat &lt;file&gt; · echo · clear · run js &lt;file&gt; · pwd · whoami · date</span>');
        else if (op === 'ls') termLog(Object.keys(state.files).sort().join('  '));
        else if (op === 'pwd') termLog('/home/era');
        else if (op === 'whoami') termLog('era');
        else if (op === 'date') termLog('(date unavailable)');
        else if (op === 'cat') {
          var f = parts[1]; if (!f || !state.files[f]) return termLog('cat: ' + f + ': No such file');
          termLog('<pre style="margin:0;color:#cfd6da;">' + (state.files[f]||'').replace(/[<>&]/g, function(c){return{'<':'&lt;','>':'&gt;','&':'&amp;'}[c];}) + '</pre>');
        }
        else if (op === 'echo') termLog(parts.slice(1).join(' '));
        else if (op === 'clear') term.querySelectorAll('.ide-terminal-line').forEach(function (l) { if (!l.querySelector('input')) l.remove(); });
        else if (op === 'run' && parts[1] === 'js') {
          var f = parts[2]; if (!f || !state.files[f]) return termLog('run: ' + f + ': No such file');
          var logs = [];
          var sandboxConsole = { log: function () { logs.push(Array.from(arguments).join(' ')); } };
          try {
            var fn = new Function('console', state.files[f]);
            fn(sandboxConsole);
            logs.forEach(function (l) { termLog('<span style="color:#cfd6da;">' + (l||'').replace(/[<>&]/g, function(c){return{'<':'&lt;','>':'&gt;','&':'&amp;'}[c];}) + '</span>'); });
            termLog('<span style="color:#86efac;">[ok]</span>');
          } catch (e) { termLog('<span style="color:#f87171;">' + e.message + '</span>'); }
        }
        else termLog('<span style="color:#f87171;">' + op + ': command not found</span>');
      } catch (e) { termLog('<span style="color:#f87171;">' + e.message + '</span>'); }
    }
    wireTerminal();

    // Initial render
    renderAll();
  })();
</script>
</BaseLayout>
