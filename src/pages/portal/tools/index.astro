---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { hasActivePass } from '@/lib/tool-pass';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools'));

const passActive = await hasActivePass(user.id);

const PDF_TOOLS = [
  { slug: 'merge',     label: 'Merge PDF',       blurb: 'Combine multiple PDFs into one ordered file.', live: true, icon: 'layers' },
  { slug: 'split',     label: 'Split PDF',       blurb: 'Extract pages or split a PDF into separate files.', live: true, icon: 'columns' },
  { slug: 'rotate',    label: 'Rotate PDF',      blurb: 'Rotate selected pages 90 / 180 / 270 degrees.', live: true, icon: 'refresh-cw' },
  { slug: 'compress',  label: 'Compress PDF',    blurb: 'Shrink file size while keeping readable quality.', live: true, icon: 'minimize-2' },
  { slug: 'watermark', label: 'Watermark PDF',   blurb: 'Add a text watermark across every page.', live: true, icon: 'droplet' },
  { slug: 'pagenumber',label: 'Page numbers',    blurb: 'Add page numbers to every page in a chosen style.', live: true, icon: 'hash' },
  { slug: 'organize',  label: 'Organize PDF',    blurb: 'Reorder, delete, and rearrange pages.', live: true, icon: 'move' },
  { slug: 'to-jpg',    label: 'PDF to images',   blurb: 'Export every page as a JPG/PNG image.', live: true, icon: 'image' },
  { slug: 'from-image',label: 'Images to PDF',   blurb: 'Combine multiple images into one PDF.', live: true, icon: 'file-plus' },
  { slug: 'protect',   label: 'Protect PDF',     blurb: 'Add a password (coming soon — needs heavier WASM).', live: false, icon: 'lock' },
  { slug: 'unlock',    label: 'Unlock PDF',      blurb: 'Strip permissions restrictions from PDFs you own.', live: true, icon: 'unlock' },
  { slug: 'sign',      label: 'Sign PDF',        blurb: 'Draw your signature, click on the page to place it.', live: true, icon: 'edit-3' },
  { slug: 'extract',   label: 'PDF to Word / text', blurb: 'Extract text layer; export as .txt or basic .doc.', live: true, icon: 'file-text' },
  { slug: 'ocr',       label: 'OCR · Image to text', blurb: 'Tesseract.js recognises typed/printed text in 11 languages.', live: true, icon: 'eye' },
];

const IMAGE_TOOLS = [
  { slug: 'img-compress', label: 'Compress image', blurb: 'Reduce JPG / PNG size with controlled quality.', live: true, icon: 'minimize-2' },
  { slug: 'img-resize',   label: 'Resize image',   blurb: 'Change dimensions in pixels or as a percentage.', live: true, icon: 'maximize' },
  { slug: 'img-crop',     label: 'Crop image',     blurb: 'Cut to a precise rectangular region.', live: true, icon: 'crop' },
  { slug: 'img-convert',  label: 'Convert format', blurb: 'JPG ⇄ PNG ⇄ WEBP at any quality.', live: true, icon: 'shuffle' },
  { slug: 'img-rotate',   label: 'Rotate image',   blurb: 'Rotate or flip horizontally / vertically.', live: true, icon: 'rotate-cw' },
  { slug: 'img-watermark',label: 'Watermark image',blurb: 'Add a text watermark with opacity + position.', live: true, icon: 'droplet' },
  { slug: 'img-meme',     label: 'Meme generator', blurb: 'Top + bottom text in classic meme style.', live: true, icon: 'smile' },
  { slug: 'img-bgremove', label: 'Remove background', blurb: 'AI background removal (~30 MB model, browser-only).', live: true, icon: 'scissors' },
  { slug: 'img-upscale',  label: 'AI upscale',     blurb: 'Increase resolution intelligently (coming soon).', live: false, icon: 'zoom-in' },
];

const DESIGN_TOOLS = [
  { slug: 'canvas',       label: 'Design canvas',  blurb: 'Layered design surface — text, shapes, images, export.', live: true, icon: 'pen-tool' },
  { slug: 'templates',    label: 'Templates',      blurb: 'CV / poster / certificate / social — ready to edit.', live: true, icon: 'grid' },
  { slug: 'brand-kit',    label: 'Brand kit',      blurb: 'Save your fonts, colors, logos for one-click reuse.', live: true, icon: 'bookmark' },
];

// Career tools we built for applicants — free, no day-pass needed.
const CAREER_TOOLS = [
  { href: '/resume', label: 'Resume builder', blurb: 'ATS-friendly resume with level-aware guidance, multiple templates and a photo. Free, no sign-up.', icon: 'file-text' },
  { href: '/portal/profile/edit', label: 'Your profile', blurb: 'Build your profile once — applications pre-fill from it; publish a shareable public link.', icon: 'user' },
];

function icon(k: string) {
  const M: any = {
    layers: '<path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>',
    columns: '<path d="M12 3v18M3 8h18M3 16h18"/>',
    'refresh-cw': '<polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10"/><path d="M20.49 15a9 9 0 0 1-14.85 3.36L1 14"/>',
    'minimize-2': '<polyline points="4 14 10 14 10 20"/><polyline points="20 10 14 10 14 4"/><line x1="14" y1="10" x2="21" y2="3"/><line x1="3" y1="21" x2="10" y2="14"/>',
    droplet: '<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>',
    hash: '<line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/>',
    move: '<polyline points="5 9 2 12 5 15"/><polyline points="9 5 12 2 15 5"/><polyline points="15 19 12 22 9 19"/><polyline points="19 9 22 12 19 15"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="12" y1="2" x2="12" y2="22"/>',
    image: '<rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>',
    'file-plus': '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/>',
    lock: '<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
    unlock: '<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/>',
    'edit-3': '<path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4z"/>',
    'file-text': '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>',
    eye: '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>',
    maximize: '<path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>',
    crop: '<path d="M6.13 1L6 16a2 2 0 0 0 2 2h15"/><path d="M1 6.13L16 6a2 2 0 0 1 2 2v15"/>',
    shuffle: '<polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/>',
    'rotate-cw': '<polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>',
    smile: '<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>',
    scissors: '<circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/>',
    'zoom-in': '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>',
    'pen-tool': '<path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/>',
    grid: '<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>',
    bookmark: '<path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>',
    user: '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>',
  };
  return M[k] || '';
}
---
<BaseLayout title="EduRankAI Tools · PDF, image, and design utilities" description="A full suite of PDF, image, and design tools for EduRankAI applicants and members. 1 CHF unlocks a 24-hour pass.">

<section class="px-[5vw] pt-12 md:pt-16 pb-6 max-w-6xl mx-auto">
  <a href="/portal" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← Portal home</a>
  <div class="mt-5 mb-8">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">Tools</p>
    <h1 class="font-display text-[clamp(2rem,5vw,3.4rem)] font-semibold text-ink leading-[1.05] mb-4">
      Everything you need to <em class="italic text-burn font-medium">finish the work.</em>
    </h1>
    <p class="text-[0.98rem] text-ink-2 font-light leading-[1.85] max-w-2xl">
      A full suite of PDF, image, and design tools. All processing happens in your browser — your files never leave your machine. Free to try; 1 CHF unlocks a 24-hour pass for production-quality exports.
    </p>
  </div>

  {!passActive && (
    <div class="bg-burn-pale border border-burn-dim rounded-2xl px-5 py-4 mb-8 flex flex-wrap items-center gap-4 justify-between">
      <div>
        <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-burn font-bold mb-1">Day pass · 1 CHF</p>
        <p class="text-[0.92rem] text-ink-2 m-0">Unlimited use of every tool for 24 hours after activation.</p>
      </div>
      <a href="/portal/tools/pass" class="bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-5 rounded-xl text-[0.88rem] no-underline">Activate pass →</a>
    </div>
  )}
  {passActive && (
    <div class="bg-leaf-bg border border-leaf-border rounded-2xl px-5 py-4 mb-8">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-leaf font-bold mb-1">Day pass active</p>
      <p class="text-[0.92rem] text-ink-2 m-0">Every tool below is fully unlocked. Have fun.</p>
    </div>
  )}
</section>

<section class="px-[5vw] pb-8 max-w-6xl mx-auto">
  <p class="eyebrow mb-4">Career tools</p>
  <div class="grid gap-3" style="grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));">
    {CAREER_TOOLS.map((t) => (
      <a href={t.href} class="bg-white border border-ink/10 hover:border-burn-dim rounded-2xl p-5 no-underline transition-colors" style="color:inherit;">
        <div class="flex justify-between items-start mb-3">
          <div class="w-10 h-10 rounded-xl bg-burn-pale flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF4F00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icon(t.icon)}></svg>
          </div>
          <span class="font-mono text-[0.55rem] uppercase tracking-[0.14em] text-leaf font-bold bg-leaf-bg px-2 py-1 rounded-full">Free</span>
        </div>
        <p class="font-display text-[1.05rem] font-semibold text-ink leading-tight m-0 mb-1">{t.label}</p>
        <p class="text-[0.82rem] text-ink-soft font-light leading-relaxed m-0">{t.blurb}</p>
      </a>
    ))}
  </div>
</section>

<section class="px-[5vw] pb-8 max-w-6xl mx-auto">
  <p class="eyebrow mb-4">PDF tools</p>
  <div class="grid gap-3" style="grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));">
    {PDF_TOOLS.map((t) => (
      <a href={t.live ? '/portal/tools/' + t.slug : '#'} class={`bg-white border ${t.live ? 'border-ink/10 hover:border-burn-dim' : 'border-ink/8 opacity-60 cursor-not-allowed'} rounded-2xl p-5 no-underline transition-colors`} style="color:inherit;">
        <div class="flex justify-between items-start mb-3">
          <div class="w-10 h-10 rounded-xl bg-burn-pale flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF4F00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icon(t.icon)}></svg>
          </div>
          {!t.live && <span class="font-mono text-[0.55rem] uppercase tracking-[0.14em] text-ink-soft font-bold bg-cream-2 px-2 py-1 rounded-full">Soon</span>}
        </div>
        <p class="font-display text-[1.05rem] font-semibold text-ink leading-tight m-0 mb-1">{t.label}</p>
        <p class="text-[0.82rem] text-ink-soft font-light leading-relaxed m-0">{t.blurb}</p>
      </a>
    ))}
  </div>
</section>

<section class="px-[5vw] pb-8 max-w-6xl mx-auto">
  <p class="eyebrow mb-4">Image tools</p>
  <div class="grid gap-3" style="grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));">
    {IMAGE_TOOLS.map((t) => (
      <a href={t.live ? '/portal/tools/' + t.slug : '#'} class={`bg-white border ${t.live ? 'border-ink/10 hover:border-sky' : 'border-ink/8 opacity-60 cursor-not-allowed'} rounded-2xl p-5 no-underline transition-colors`} style="color:inherit;">
        <div class="flex justify-between items-start mb-3">
          <div class="w-10 h-10 rounded-xl bg-sky-bg flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1045BB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icon(t.icon)}></svg>
          </div>
          {!t.live && <span class="font-mono text-[0.55rem] uppercase tracking-[0.14em] text-ink-soft font-bold bg-cream-2 px-2 py-1 rounded-full">Soon</span>}
        </div>
        <p class="font-display text-[1.05rem] font-semibold text-ink leading-tight m-0 mb-1">{t.label}</p>
        <p class="text-[0.82rem] text-ink-soft font-light leading-relaxed m-0">{t.blurb}</p>
      </a>
    ))}
  </div>
</section>

<section class="px-[5vw] pb-20 max-w-6xl mx-auto">
  <p class="eyebrow mb-4">Design tools</p>
  <div class="grid gap-3" style="grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));">
    {DESIGN_TOOLS.map((t) => (
      <a href={t.live ? '/portal/tools/' + t.slug : '#'} class={`bg-white border ${t.live ? 'border-ink/10 hover:border-leaf' : 'border-ink/8 opacity-60 cursor-not-allowed'} rounded-2xl p-5 no-underline transition-colors`} style="color:inherit;">
        <div class="flex justify-between items-start mb-3">
          <div class="w-10 h-10 rounded-xl bg-leaf-bg flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1A6B35" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icon(t.icon)}></svg>
          </div>
          {!t.live && <span class="font-mono text-[0.55rem] uppercase tracking-[0.14em] text-ink-soft font-bold bg-cream-2 px-2 py-1 rounded-full">Soon</span>}
        </div>
        <p class="font-display text-[1.05rem] font-semibold text-ink leading-tight m-0 mb-1">{t.label}</p>
        <p class="text-[0.82rem] text-ink-soft font-light leading-relaxed m-0">{t.blurb}</p>
      </a>
    ))}
  </div>
</section>
</BaseLayout>
