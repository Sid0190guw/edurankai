---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/img-convert'));
---
<BaseLayout title="Convert image format · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-sky font-bold mb-2">Image · Convert</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Convert image format</h1>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="image/*" multiple class="block w-full text-[0.92rem] file:bg-sky file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <p id="meta" class="text-[0.85rem] text-ink-soft m-0"></p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Target format</span>
        <select id="fmt" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink"><option value="image/jpeg">JPEG</option><option value="image/png">PNG</option><option value="image/webp">WebP</option></select>
      </label>
      <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Quality (JPEG / WebP)</span><input id="q" type="range" min="10" max="100" value="92" class="w-full" /></label>
    </div>
    <button id="goBtn" class="bg-sky hover:bg-sky/90 text-white font-semibold py-3 px-6 rounded-xl text-[0.92rem]" disabled style="opacity:0.5;">Convert & download</button>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
  </div>
</section>
<script is:inline>
  (function () {
    var files = []; var fi = document.getElementById('fileInput'); var meta = document.getElementById('meta');
    var btn = document.getElementById('goBtn'); var status = document.getElementById('status');
    fi.addEventListener('change', function () { files = Array.from(fi.files); meta.textContent = files.length + ' file(s) selected'; btn.disabled = !files.length; btn.style.opacity = files.length ? '1' : '0.5'; });
    btn.addEventListener('click', async function () {
      btn.disabled = true; var fmt = document.getElementById('fmt').value; var q = parseInt(document.getElementById('q').value, 10) / 100;
      var done = 0;
      for (var i = 0; i < files.length; i++) {
        await new Promise(function (resolve) {
          var f = files[i]; var img = new Image();
          img.onload = function () {
            var c = document.createElement('canvas'); c.width = img.naturalWidth; c.height = img.naturalHeight;
            c.getContext('2d').drawImage(img, 0, 0);
            c.toBlob(function (blob) {
              var a = document.createElement('a'); a.href = URL.createObjectURL(blob);
              var ext = fmt.split('/')[1]; a.download = f.name.replace(/\.[^.]+$/, '') + '.' + (ext === 'jpeg' ? 'jpg' : ext);
              a.click(); done++; status.textContent = 'Converted ' + done + ' / ' + files.length; resolve();
            }, fmt, q);
          };
          img.src = URL.createObjectURL(f);
        });
      }
      status.textContent = 'Done. ' + done + ' files converted.';
      btn.disabled = false;
    });
  })();
</script>
</BaseLayout>
