---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/watermark'));
---
<BaseLayout title="Watermark PDF · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">PDF · Watermark</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Watermark PDF</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Add a text watermark across every page — choose opacity, angle, and position.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="application/pdf" class="block w-full text-[0.92rem] file:bg-burn file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <p id="meta" class="text-[0.85rem] text-ink-soft m-0"></p>
    <label class="block">
      <span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Watermark text</span>
      <input id="wmText" type="text" value="CONFIDENTIAL" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink focus:border-burn focus:outline-none" />
    </label>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Font size</span><input id="wmSize" type="number" value="60" min="8" max="200" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink" /></label>
      <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Opacity %</span><input id="wmOpacity" type="number" value="20" min="1" max="100" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink" /></label>
      <label class="block"><span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Angle</span><input id="wmAngle" type="number" value="-30" min="-90" max="90" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink" /></label>
    </div>
    <button id="goBtn" class="btn-primary" disabled style="opacity:0.5;">Stamp watermark & download</button>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
  </div>
</section>
<script is:inline src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
<script is:inline>
  (function () {
    var file = null; var fi = document.getElementById('fileInput');
    var meta = document.getElementById('meta'); var btn = document.getElementById('goBtn');
    var status = document.getElementById('status');
    fi.addEventListener('change', async function () {
      if (!fi.files[0]) return; file = fi.files[0];
      meta.textContent = file.name + ' · ' + (file.size / 1024).toFixed(1) + ' KB';
      btn.disabled = false; btn.style.opacity = '1';
    });
    btn.addEventListener('click', async function () {
      if (!file) return; btn.disabled = true; status.textContent = 'Stamping...';
      try {
        var src = await PDFLib.PDFDocument.load(new Uint8Array(await file.arrayBuffer()), { ignoreEncryption: true });
        var font = await src.embedFont(PDFLib.StandardFonts.HelveticaBold);
        var text = document.getElementById('wmText').value || 'CONFIDENTIAL';
        var size = parseFloat(document.getElementById('wmSize').value) || 60;
        var opacity = (parseFloat(document.getElementById('wmOpacity').value) || 20) / 100;
        var angle = parseFloat(document.getElementById('wmAngle').value) || -30;
        src.getPages().forEach(function (p) {
          var w = p.getWidth(); var h = p.getHeight();
          var tw = font.widthOfTextAtSize(text, size);
          p.drawText(text, {
            x: (w - tw) / 2, y: (h - size) / 2,
            font: font, size: size,
            color: PDFLib.rgb(0.6, 0.6, 0.6),
            opacity: opacity,
            rotate: PDFLib.degrees(angle),
          });
        });
        var blob = new Blob([await src.save()], { type: 'application/pdf' });
        var a = document.createElement('a'); a.href = URL.createObjectURL(blob);
        a.download = file.name.replace(/\.pdf$/i, '') + '-watermarked.pdf'; a.click();
        status.textContent = 'Done.';
      } catch (e) { status.textContent = 'Failed: ' + e.message; }
      btn.disabled = false;
    });
  })();
</script>
</BaseLayout>
