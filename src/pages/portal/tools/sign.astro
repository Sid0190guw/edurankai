---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/sign'));
---
<BaseLayout title="Sign PDF · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">PDF · Sign</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Sign PDF</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Draw your signature with the mouse or trackpad, then click anywhere on the rendered page preview to place it. Stamps onto the actual PDF at the same coordinates.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="application/pdf" class="block w-full text-[0.92rem] file:bg-burn file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />

    <div>
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 m-0">Draw your signature</p>
      <canvas id="sigPad" width="400" height="120" style="border:1px solid rgba(14,11,8,0.12);border-radius:10px;cursor:crosshair;background:#fff;display:block;max-width:100%;"></canvas>
      <button id="clearSig" class="mt-2 bg-cream-2 border border-ink/15 text-ink font-semibold py-1.5 px-4 rounded-lg text-[0.8rem]">Clear</button>
    </div>

    <div>
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 m-0">Page preview · click to place</p>
      <p class="text-[0.78rem] text-ink-soft mb-2 m-0">Page: <input id="pageNum" type="number" min="1" value="1" style="width:60px;background:#FAF8F5;border:1px solid rgba(14,11,8,0.15);border-radius:6px;padding:4px 8px;" /></p>
      <div id="pageWrap" style="background:#FAF8F5;border:1px solid rgba(14,11,8,0.10);border-radius:10px;padding:14px;min-height:200px;position:relative;">
        <canvas id="pagePrev" style="max-width:100%;display:block;cursor:crosshair;border:1px solid rgba(14,11,8,0.08);"></canvas>
      </div>
    </div>

    <button id="goBtn" class="btn-primary" disabled style="opacity:0.5;">Stamp signature & download</button>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
  </div>
</section>
<script is:inline src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script is:inline>
  (function () {
    if (window.pdfjsLib) window.pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    var pad = document.getElementById('sigPad'); var pctx = pad.getContext('2d');
    pctx.strokeStyle = '#000'; pctx.lineWidth = 2; pctx.lineCap = 'round';
    var drawing = false; var hasSig = false;
    function pos(e, el) { var r = el.getBoundingClientRect(); return { x: (e.clientX || e.touches[0].clientX) - r.left, y: (e.clientY || e.touches[0].clientY) - r.top }; }
    pad.addEventListener('mousedown', function (e) { drawing = true; var p = pos(e, pad); pctx.beginPath(); pctx.moveTo(p.x, p.y); });
    pad.addEventListener('mousemove', function (e) { if (!drawing) return; var p = pos(e, pad); pctx.lineTo(p.x, p.y); pctx.stroke(); hasSig = true; });
    document.addEventListener('mouseup', function () { drawing = false; });
    document.getElementById('clearSig').addEventListener('click', function () { pctx.clearRect(0, 0, pad.width, pad.height); hasSig = false; });

    var file = null; var stampPoint = null; var pageScale = 1;
    document.getElementById('fileInput').addEventListener('change', async function (e) { file = e.target.files[0]; await renderPreview(); });
    document.getElementById('pageNum').addEventListener('change', renderPreview);
    document.getElementById('pagePrev').addEventListener('click', function (e) {
      var c = document.getElementById('pagePrev'); var r = c.getBoundingClientRect();
      var x = (e.clientX - r.left) * (c.width / r.width); var y = (e.clientY - r.top) * (c.height / r.height);
      stampPoint = { x: x, y: y };
      // draw a marker
      renderPreview().then(function () {
        var ctx = c.getContext('2d');
        ctx.strokeStyle = '#FF4F00'; ctx.lineWidth = 3; ctx.strokeRect(x - 50, y - 18, 100, 36);
      });
      document.getElementById('goBtn').disabled = false; document.getElementById('goBtn').style.opacity = '1';
    });
    async function renderPreview() {
      if (!file || !window.pdfjsLib) return;
      var pNum = parseInt(document.getElementById('pageNum').value, 10) || 1;
      try {
        var buf = await file.arrayBuffer(); var pdf = await window.pdfjsLib.getDocument({ data: buf }).promise;
        var page = await pdf.getPage(Math.min(pNum, pdf.numPages));
        var vp = page.getViewport({ scale: 1.2 });
        var c = document.getElementById('pagePrev'); c.width = vp.width; c.height = vp.height; pageScale = vp.scale;
        await page.render({ canvasContext: c.getContext('2d'), viewport: vp }).promise;
      } catch (e) { document.getElementById('status').textContent = 'Preview failed: ' + e.message; }
    }
    document.getElementById('goBtn').addEventListener('click', async function () {
      if (!file || !hasSig || !stampPoint) return; var btn = document.getElementById('goBtn'); btn.disabled = true;
      document.getElementById('status').textContent = 'Stamping...';
      try {
        var sigDataUrl = pad.toDataURL('image/png');
        var sigBytes = await fetch(sigDataUrl).then(function (r) { return r.arrayBuffer(); });
        var src = await PDFLib.PDFDocument.load(new Uint8Array(await file.arrayBuffer()), { ignoreEncryption: true });
        var sigPng = await src.embedPng(new Uint8Array(sigBytes));
        var pNum = parseInt(document.getElementById('pageNum').value, 10) || 1;
        var page = src.getPage(Math.min(pNum, src.getPageCount()) - 1);
        var pw = page.getWidth(); var ph = page.getHeight();
        var c = document.getElementById('pagePrev');
        // convert preview-canvas coords → PDF coords (canvas size = scale × PDF size; y is flipped)
        var x = (stampPoint.x / c.width) * pw;
        var y = ph - (stampPoint.y / c.height) * ph;
        var sigW = 100; var sigH = (sigPng.height / sigPng.width) * sigW;
        page.drawImage(sigPng, { x: x - sigW / 2, y: y - sigH / 2, width: sigW, height: sigH });
        var blob = new Blob([await src.save()], { type: 'application/pdf' });
        var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = file.name.replace(/\.pdf$/i, '') + '-signed.pdf'; a.click();
        document.getElementById('status').textContent = 'Done.';
      } catch (e) { document.getElementById('status').textContent = 'Failed: ' + e.message; }
      btn.disabled = false;
    });
  })();
</script>
</BaseLayout>
