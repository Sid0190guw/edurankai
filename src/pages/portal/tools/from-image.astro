---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/from-image'));
---
<BaseLayout title="Images to PDF · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">PDF · Images to PDF</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Combine images into a PDF</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Pick multiple JPG / PNG images. Each becomes one page sized to match.</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="image/png,image/jpeg" multiple class="block w-full text-[0.92rem] file:bg-burn file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <ul id="fileList" class="space-y-2"></ul>
    <button id="goBtn" class="btn-primary" disabled style="opacity:0.5;">Build PDF & download</button>
    <p id="status" class="text-[0.82rem] text-ink-soft m-0"></p>
  </div>
</section>
<script is:inline src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
<script is:inline>
  (function () {
    var files = []; var fi = document.getElementById('fileInput'); var list = document.getElementById('fileList');
    var btn = document.getElementById('goBtn'); var status = document.getElementById('status');
    function render() {
      list.innerHTML = '';
      files.forEach(function (f, i) {
        var li = document.createElement('li');
        li.style.cssText = 'background:#FAF8F5;border:1px solid rgba(14,11,8,0.10);border-radius:10px;padding:10px 14px;font-size:13.5px;color:#0E0B08;display:flex;justify-content:space-between;';
        li.innerHTML = '<span>' + (i + 1) + '. ' + f.name + '</span><button data-del="' + i + '" style="background:transparent;border:none;color:#FF4F00;cursor:pointer;font-weight:600;">×</button>';
        list.appendChild(li);
      });
      btn.disabled = files.length < 1; btn.style.opacity = files.length < 1 ? '0.5' : '1';
    }
    list.addEventListener('click', function (e) { if (e.target.hasAttribute('data-del')) { files.splice(+e.target.getAttribute('data-del'), 1); render(); } });
    fi.addEventListener('change', function () { for (var i = 0; i < fi.files.length; i++) files.push(fi.files[i]); render(); fi.value = ''; });
    btn.addEventListener('click', async function () {
      btn.disabled = true; status.textContent = 'Building...';
      try {
        var doc = await PDFLib.PDFDocument.create();
        for (var i = 0; i < files.length; i++) {
          var bytes = new Uint8Array(await files[i].arrayBuffer());
          var img;
          if (files[i].type === 'image/png') img = await doc.embedPng(bytes);
          else img = await doc.embedJpg(bytes);
          var page = doc.addPage([img.width, img.height]);
          page.drawImage(img, { x: 0, y: 0, width: img.width, height: img.height });
          status.textContent = 'Building... (' + (i + 1) + ' / ' + files.length + ')';
        }
        var blob = new Blob([await doc.save()], { type: 'application/pdf' });
        var a = document.createElement('a'); a.href = URL.createObjectURL(blob);
        a.download = 'images-' + Date.now() + '.pdf'; a.click();
        status.textContent = 'Done.';
      } catch (e) { status.textContent = 'Failed: ' + e.message; }
      btn.disabled = false;
    });
  })();
</script>
</BaseLayout>
