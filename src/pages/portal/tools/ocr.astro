---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/tools/ocr'));
---
<BaseLayout title="OCR · EduRankAI Tools">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal/tools" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← All tools</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">Image · OCR</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.6rem)] font-semibold text-ink leading-[1.1] mb-3">Image to text · OCR</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">Extract typed and printed text from an image or scanned document. Tesseract.js runs entirely in your browser (the engine downloads on first use; ~5 MB).</p>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  <div class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
    <input type="file" id="fileInput" accept="image/*,application/pdf" class="block w-full text-[0.92rem] file:bg-burn file:text-white file:border-none file:px-4 file:py-2 file:rounded-xl file:font-semibold file:mr-3 file:cursor-pointer" />
    <label class="block">
      <span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2 block">Language</span>
      <select id="lang" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink">
        <option value="eng">English</option>
        <option value="hin">Hindi (हिन्दी)</option>
        <option value="san">Sanskrit (संस्कृतम्)</option>
        <option value="tam">Tamil</option>
        <option value="ben">Bengali</option>
        <option value="fra">French</option>
        <option value="deu">German</option>
        <option value="spa">Spanish</option>
        <option value="ara">Arabic</option>
        <option value="chi_sim">Chinese (Simplified)</option>
        <option value="jpn">Japanese</option>
      </select>
    </label>
    <button id="goBtn" class="btn-primary" disabled style="opacity:0.5;">Run OCR</button>
    <div id="prog" class="text-[0.82rem] text-ink-soft m-0"></div>
    <textarea id="out" rows="10" placeholder="Extracted text will appear here." class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.92rem] text-ink font-mono leading-relaxed resize-y"></textarea>
    <div class="flex gap-2 flex-wrap">
      <button id="copyBtn" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-5 rounded-xl text-[0.85rem]">Copy</button>
      <button id="dlBtn" class="bg-cream-2 border border-ink/15 text-ink font-semibold py-2 px-5 rounded-xl text-[0.85rem]">Download .txt</button>
    </div>
  </div>
</section>
<script is:inline src="https://unpkg.com/tesseract.js@5/dist/tesseract.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script is:inline>
  (function () {
    if (window.pdfjsLib) window.pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    var file = null;
    document.getElementById('fileInput').addEventListener('change', function (e) { file = e.target.files[0]; var b = document.getElementById('goBtn'); b.disabled = !file; b.style.opacity = file ? '1' : '0.5'; });

    // Rasterise every PDF page to a canvas at 2x so Tesseract can read scans.
    async function pdfToCanvases(f, prog) {
      var buf = await f.arrayBuffer();
      var pdf = await window.pdfjsLib.getDocument({ data: buf }).promise;
      var canvases = [];
      for (var i = 1; i <= pdf.numPages; i++) {
        prog.textContent = 'Rasterising page ' + i + ' / ' + pdf.numPages + '…';
        var page = await pdf.getPage(i);
        var vp = page.getViewport({ scale: 2 });
        var c = document.createElement('canvas'); c.width = vp.width; c.height = vp.height;
        var ctx = c.getContext('2d'); ctx.fillStyle = '#fff'; ctx.fillRect(0, 0, c.width, c.height);
        await page.render({ canvasContext: ctx, viewport: vp }).promise;
        canvases.push(c);
      }
      return canvases;
    }

    document.getElementById('goBtn').addEventListener('click', async function () {
      if (!file || !window.Tesseract) return;
      var btn = document.getElementById('goBtn'); btn.disabled = true;
      var prog = document.getElementById('prog'); var out = document.getElementById('out');
      var lang = document.getElementById('lang').value;
      try {
        prog.textContent = 'Loading engine (~5 MB on first run)…';
        var worker = await Tesseract.createWorker(lang, 1, { logger: function (m) { if (m.status) prog.textContent = m.status + (m.progress != null ? ' · ' + Math.round(m.progress * 100) + '%' : ''); } });
        var isPdf = file.type === 'application/pdf' || /\.pdf$/i.test(file.name);
        if (isPdf) {
          if (!window.pdfjsLib) { prog.textContent = 'PDF engine failed to load.'; await worker.terminate(); btn.disabled = false; return; }
          var pages = await pdfToCanvases(file, prog);
          var all = '';
          for (var p = 0; p < pages.length; p++) {
            prog.textContent = 'Reading page ' + (p + 1) + ' / ' + pages.length + '…';
            var rp = await worker.recognize(pages[p]);
            all += '--- Page ' + (p + 1) + ' ---\n' + rp.data.text.trim() + '\n\n';
            out.value = all.trim();
          }
          prog.textContent = 'Done. ' + out.value.length + ' characters across ' + pages.length + ' page(s).';
        } else {
          var r = await worker.recognize(file);
          out.value = r.data.text;
          prog.textContent = 'Done. ' + r.data.text.length + ' characters extracted.';
        }
        await worker.terminate();
      } catch (e) { prog.textContent = 'Failed: ' + e.message; }
      btn.disabled = false;
    });
    document.getElementById('copyBtn').addEventListener('click', function () { var ta = document.getElementById('out'); ta.select(); document.execCommand('copy'); });
    document.getElementById('dlBtn').addEventListener('click', function () {
      var blob = new Blob([document.getElementById('out').value || ''], { type: 'text/plain' });
      var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'ocr-' + Date.now() + '.txt'; a.click();
    });
  })();
</script>
</BaseLayout>
