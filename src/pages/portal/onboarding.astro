---
// /portal/onboarding — the credential step a new hire completes after accepting their offer letter.
// They share up to 5 educational / professional documents as Google Drive links in a fixed access
// format, so HR can open them without files passing through our servers.
export const prerender = false;
import BaseLayout from '@/layouts/BaseLayout.astro';
import { listDocs, progress, DOC_TYPES, MAX_DOCS, ACCESS_FORMAT, docTypeLabel } from '@/lib/hr-onboarding';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=/portal/onboarding');
const docs = await listDocs(String(user.id)).catch(() => []);
const p = progress(docs);
const remaining = Math.max(0, MAX_DOCS - docs.length);
const statusChip = (s: string) => s === 'verified'
  ? { bg: '#ecfdf5', fg: '#047857', label: 'Verified' }
  : s === 'rejected' ? { bg: '#fef2f2', fg: '#b91c1c', label: 'Needs another copy' }
  : { bg: '#fffbeb', fg: '#92400e', label: 'Under review' };
---
<BaseLayout title="Your joining documents" description="Share your educational and professional credentials before you join." showNav={true} showFooter={false}>
  <main style="max-width:760px;margin:0 auto;padding:48px 22px 90px;">
    <p style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.16em;text-transform:uppercase;color:#FF4F00;margin:0 0 10px;">Onboarding &middot; step 1</p>
    <h1 style="font-family:'Cormorant Garamond',serif;font-size:clamp(30px,5vw,44px);font-weight:500;color:#100b08;margin:0 0 10px;line-height:1.1;">Your joining documents</h1>
    <p style="font-family:'Inter Tight',sans-serif;font-size:15px;color:#5a5148;line-height:1.6;margin:0 0 8px;max-width:36rem;">
      Congratulations on your offer. Before you join, share your educational and professional credentials so HR can verify them.
      You can submit up to <b>{MAX_DOCS} documents</b>.
    </p>

    <!-- the access format, stated once, prominently -->
    <div style="background:#fffbeb;border:1px solid #fde68a;border-radius:12px;padding:16px 18px;margin:22px 0 26px;">
      <p style="font-family:'Inter Tight',sans-serif;font-size:14px;font-weight:700;color:#92400e;margin:0 0 8px;">How to share each file</p>
      <ol style="font-family:'Inter Tight',sans-serif;font-size:13.5px;color:#7c4a03;line-height:1.7;margin:0;padding-left:18px;">
        <li>Upload the document to your <b>Google Drive</b>.</li>
        <li>Right-click it &rarr; <b>Share</b> &rarr; under <i>General access</i> choose <b>{ACCESS_FORMAT}</b>.</li>
        <li>Click <b>Copy link</b> and paste it below.</li>
      </ol>
      <p style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#92400e;margin:10px 0 0;">If the link is left private we cannot open it, and your verification will be held up.</p>
    </div>

    <div id="msg" role="status" aria-live="polite" style="display:none;margin:0 0 16px;padding:10px 14px;border-radius:9px;font-size:13.5px;"></div>

    <!-- submitted documents -->
    <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:26px;">
      {docs.length === 0 && <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#a99e94;">Nothing submitted yet.</p>}
      {docs.map((d) => { const c = statusChip(d.status); return (
        <div style="background:#fff;border:1px solid rgba(14,11,8,0.1);border-radius:12px;padding:14px 16px;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;flex-wrap:wrap;">
            <div style="min-width:0;">
              <p style="font-family:'Inter Tight',sans-serif;font-size:14.5px;font-weight:600;color:#100b08;margin:0;">{d.title || docTypeLabel(d.docType)}</p>
              <p style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#a99e94;margin:3px 0 0;">{docTypeLabel(d.docType)}</p>
            </div>
            <span style={'font-family:Inter Tight,sans-serif;font-size:11px;font-weight:700;padding:4px 11px;border-radius:100px;background:' + c.bg + ';color:' + c.fg + ';'}>{c.label}</span>
          </div>
          {d.reviewNote && <p style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#b91c1c;margin:8px 0 0;">HR note: {d.reviewNote}</p>}
          <div style="display:flex;gap:12px;align-items:center;margin-top:10px;">
            <a href={d.driveUrl} target="_blank" rel="noopener noreferrer" style="font-family:'Inter Tight',sans-serif;font-size:13px;color:#FF4F00;font-weight:600;text-decoration:none;">Open document &rarr;</a>
            {d.status !== 'verified' && <button class="rm" data-id={d.id} style="background:none;border:none;font-family:'Inter Tight',sans-serif;font-size:13px;color:#a99e94;cursor:pointer;padding:0;text-decoration:underline;">Remove</button>}
          </div>
        </div>
      ); })}
    </div>

    <!-- add another -->
    {remaining > 0 ? (
      <form id="addForm" style="background:#fff;border:1px solid rgba(14,11,8,0.1);border-radius:14px;padding:20px 22px;">
        <p style="font-family:'Inter Tight',sans-serif;font-size:14px;font-weight:700;color:#100b08;margin:0 0 14px;">Add a document <span style="font-weight:400;color:#a99e94;">&middot; {remaining} of {MAX_DOCS} remaining</span></p>
        <label style="display:block;font-family:'Inter Tight',sans-serif;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#a99e94;margin-bottom:6px;">Document type</label>
        <select name="docType" style="width:100%;padding:11px 12px;border:1px solid rgba(14,11,8,0.15);border-radius:9px;font-size:14px;background:#fff;margin-bottom:14px;font-family:inherit;">
          {DOC_TYPES.map((t) => <option value={t.key}>{t.label} — {t.hint}</option>)}
        </select>
        <label style="display:block;font-family:'Inter Tight',sans-serif;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#a99e94;margin-bottom:6px;">Title (optional)</label>
        <input name="title" maxlength="200" placeholder="e.g. B.Tech final degree certificate" style="width:100%;padding:11px 12px;border:1px solid rgba(14,11,8,0.15);border-radius:9px;font-size:14px;margin-bottom:14px;box-sizing:border-box;font-family:inherit;" />
        <label style="display:block;font-family:'Inter Tight',sans-serif;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#a99e94;margin-bottom:6px;">Google Drive link</label>
        <input name="driveUrl" type="url" required placeholder="https://drive.google.com/file/d/..." style="width:100%;padding:11px 12px;border:1px solid rgba(14,11,8,0.15);border-radius:9px;font-size:14px;margin-bottom:16px;box-sizing:border-box;font-family:inherit;" />
        <button type="submit" style="background:#FF4F00;color:#fff;border:none;border-radius:9px;padding:12px 24px;font-family:'Inter Tight',sans-serif;font-size:14.5px;font-weight:700;cursor:pointer;">Submit document</button>
      </form>
    ) : (
      <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#5a5148;background:#f6f3ef;border-radius:12px;padding:16px 18px;">
        You have submitted all {MAX_DOCS} documents. Remove one if you need to replace it.
      </p>
    )}

    {p.complete && <p style="font-family:'Inter Tight',sans-serif;font-size:14px;color:#047857;background:#ecfdf5;border:1px solid #a7f3d0;border-radius:12px;padding:14px 16px;margin-top:20px;">All your documents are verified. HR will be in touch about your joining formalities.</p>}
  </main>

  <script is:inline>
    (function () {
      var msg = document.getElementById('msg');
      function flash(t, ok) { msg.style.display = 'block'; msg.textContent = t; msg.style.background = ok ? '#ecfdf5' : '#fef2f2'; msg.style.color = ok ? '#047857' : '#b91c1c'; }
      function post(body) {
        return fetch('/api/portal/onboarding/documents', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }).then(function (r) { return r.json(); });
      }
      var form = document.getElementById('addForm');
      if (form) form.addEventListener('submit', function (e) {
        e.preventDefault();
        var f = e.target, btn = f.querySelector('button[type=submit]');
        btn.disabled = true; btn.textContent = 'Submitting...';
        post({ action: 'add', docType: f.docType.value, title: f.title.value, driveUrl: f.driveUrl.value })
          .then(function (j) {
            if (j.ok) { flash('Document submitted. HR will verify it.', true); setTimeout(function () { location.reload(); }, 700); }
            else { flash(j.error || 'Could not submit that document.', false); btn.disabled = false; btn.textContent = 'Submit document'; }
          })
          .catch(function () { flash('Network problem - please try again.', false); btn.disabled = false; btn.textContent = 'Submit document'; });
      });
      document.querySelectorAll('.rm').forEach(function (b) {
        b.addEventListener('click', function () {
          if (!confirm('Remove this document?')) return;
          post({ action: 'remove', id: Number(b.getAttribute('data-id')) }).then(function (j) {
            if (j.ok) location.reload(); else flash(j.error || 'Could not remove it.', false);
          });
        });
      });
    })();
  </script>
</BaseLayout>
