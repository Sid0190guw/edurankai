---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ensureMentorSchema, listMentors } from '@/lib/mentors';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/mentors'));

await ensureMentorSchema();
const url = new URL(Astro.request.url);
const subj = url.searchParams.get('subject') || undefined;
const lang = url.searchParams.get('language') || undefined;
const mentors = await listMentors({ subject: subj, language: lang });

const SUBJECTS = ['mathematics', 'physics', 'chemistry', 'biology', 'computer-science', 'engineering', 'medicine', 'law', 'management', 'liberal-arts', 'languages', 'engineering-entrance', 'medical-entrance', 'civil-services'];
const LANGUAGES = ['en', 'hi', 'ta', 'te', 'bn', 'mr', 'kn', 'ml', 'gu', 'pa', 'or', 'sa'];
---
<BaseLayout title="Mentor marketplace · EduRankAI" description="Book one-to-one sessions with verified subject experts. Hourly rates in CHF. Multilingual mentors.">

<section class="px-[5vw] pt-12 md:pt-16 pb-6 max-w-6xl mx-auto">
  <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">Portal · Mentor marketplace</p>
  <h1 class="font-display text-[clamp(2.2rem,4.5vw,3.4rem)] font-semibold text-ink leading-[1.05] mb-4">
    Book a <em class="italic text-burn font-medium">verified mentor</em>.
  </h1>
  <p class="text-[1rem] text-ink-2 font-light leading-[1.85] max-w-3xl">
    One-to-one sessions with subject experts who have passed our verification. Pick a subject, pick a mentor, pick a slot. Payment in CHF. Multilingual.
  </p>
</section>

<section class="px-[5vw] pb-8 max-w-6xl mx-auto">
  <form method="GET" class="flex gap-2 flex-wrap mb-6">
    <select name="subject" class="bg-white border border-ink/15 rounded-xl px-4 py-2.5 text-[0.92rem]">
      <option value="">All subjects</option>
      {SUBJECTS.map((s) => <option value={s} selected={s === subj}>{s.replace('-', ' ')}</option>)}
    </select>
    <select name="language" class="bg-white border border-ink/15 rounded-xl px-4 py-2.5 text-[0.92rem]">
      <option value="">All languages</option>
      {LANGUAGES.map((l) => <option value={l} selected={l === lang}>{l.toUpperCase()}</option>)}
    </select>
    <button type="submit" class="bg-ink/8 border border-ink/15 text-ink-2 px-5 py-2.5 rounded-xl text-[0.85rem] font-semibold">Filter</button>
  </form>

  {mentors.length === 0 ? (
    <div class="bg-cream-2/60 border border-ink/10 rounded-2xl p-10 text-center">
      <p class="font-display text-[1.3rem] font-semibold text-ink mb-3">Marketplace is opening.</p>
      <p class="text-[0.95rem] text-ink-soft max-w-md mx-auto leading-relaxed mb-5">No verified mentors match your filter yet. Try a broader filter, or apply to become a mentor yourself.</p>
      <a href="/portal/mentors/apply" class="btn-primary inline-block">Apply to mentor →</a>
    </div>
  ) : (
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {mentors.map((m: any) => (
        <a href={'/portal/mentors/' + m.slug} class="bg-white border border-ink/10 hover:border-burn-dim rounded-2xl p-6 block transition-all hover:-translate-y-0.5 no-underline" style="color:inherit;">
          <div class="flex items-start gap-3 mb-4">
            <div class="w-14 h-14 rounded-full bg-burn-pale text-burn flex items-center justify-center font-display text-[1.4rem] font-semibold flex-shrink-0">{m.full_name?.charAt(0)?.toUpperCase() || '?'}</div>
            <div class="min-w-0">
              <p class="font-display text-[1.15rem] text-ink font-semibold leading-tight">{m.full_name}</p>
              <p class="text-[0.82rem] text-ink-soft mt-0.5">{m.title || 'Mentor'}</p>
              {m.verified && <span class="text-[0.6rem] font-mono uppercase tracking-[0.14em] text-leaf font-bold">✓ Verified</span>}
            </div>
          </div>
          {m.bio && <p class="text-[0.85rem] text-ink-2 line-clamp-3 leading-relaxed mb-3">{m.bio}</p>}
          {Array.isArray(m.subjects) && m.subjects.length > 0 && (
            <div class="flex gap-1 flex-wrap mb-3">
              {m.subjects.slice(0, 3).map((s: string) => <span class="font-mono text-[0.6rem] uppercase tracking-[0.06em] px-2 py-1 rounded-full bg-cream-2 text-ink-soft">{s}</span>)}
            </div>
          )}
          <div class="flex justify-between items-end pt-3 border-t border-ink/8">
            <div>
              <p class="font-mono text-[0.62rem] uppercase tracking-[0.14em] text-ink-soft">Rate</p>
              <p class="font-display text-[1.25rem] font-semibold text-burn">CHF {Number(m.rate_chf_per_hour).toFixed(0)}<span class="text-[0.65rem] text-ink-soft font-normal">/h</span></p>
            </div>
            {m.rating_count > 0 && (
              <div class="text-right">
                <p class="font-mono text-[0.62rem] uppercase tracking-[0.14em] text-ink-soft">{m.sessions_completed} sessions</p>
                <p class="font-mono text-[0.85rem] text-ink font-bold">★ {Number(m.rating_avg).toFixed(1)}</p>
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
  )}
</section>
</BaseLayout>
