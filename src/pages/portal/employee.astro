---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

let okMsg = '', errorMsg = '';
let employee: any = null;
let payslips: any[] = [];
let todayEvents: any[] = [];
let currentStatus: 'clocked_out' | 'clocked_in' | 'on_break' = 'clocked_out';
let todayHours = 0;

// Find employee linked to this user
try {
  const r = await db.execute(sql`SELECT * FROM hr_employees WHERE user_id = ${user.id} AND is_active = true LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  employee = rows[0] || null;
} catch(e) {}

// If no direct link, try matching by any email on file (work, personal, or login).
if (!employee) {
  try {
    const r = await db.execute(sql`SELECT * FROM hr_employees WHERE (work_email = ${user.email} OR personal_email = ${user.email} OR email = ${user.email}) AND is_active = true LIMIT 1`);
    const rows = Array.isArray(r) ? r : (r?.rows || []);
    employee = rows[0] || null;
    // Link user_id
    if (employee) {
      await db.execute(sql`UPDATE hr_employees SET user_id = ${user.id} WHERE id = ${employee.id}`).catch(() => {});
    }
  } catch(e) {}
}

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;

  if (action === 'clock_event' && employee) {
    const eventType = fd.get('event_type') as string;
    const lat = parseFloat(fd.get('lat') as string || '0') || null;
    const lon = parseFloat(fd.get('lon') as string || '0') || null;
    const accuracy = parseFloat(fd.get('accuracy') as string || '0') || null;
    const locationName = (fd.get('location_name') as string || '').trim() || null;
    const workMode = fd.get('work_mode') as string || 'remote';
    const note = (fd.get('note') as string || '').trim() || null;
    const facePhoto = (fd.get('face_photo') as string || '').slice(0, 300000) || null;

    try {
      await db.execute(sql`ALTER TABLE hr_clock_events ADD COLUMN IF NOT EXISTS face_photo TEXT`).catch(() => {});
      await db.execute(sql`
        INSERT INTO hr_clock_events (employee_id, event_type, lat, lon, accuracy, location_name, work_mode, note, face_photo, ip_address, device_info)
        VALUES (${employee.id}, ${eventType}, ${lat}, ${lon}, ${accuracy}, ${locationName}, ${workMode}, ${note}, ${facePhoto},
          ${Astro.clientAddress}, ${Astro.request.headers.get('user-agent')?.substring(0,200) || null})
      `);

      // Update attendance record
      const today = new Date().toISOString().split('T')[0];
      if (eventType === 'clock_in') {
        await db.execute(sql`
          INSERT INTO hr_attendance (employee_id, date, clock_in, status, work_mode, ip_address)
          VALUES (${employee.id}, ${today}, NOW(), 'present', ${workMode}, ${Astro.clientAddress})
          ON CONFLICT (employee_id, date) DO UPDATE SET clock_in = NOW(), status = 'present', work_mode = ${workMode}
        `).catch(() => {});
        okMsg = 'Clocked in successfully!';
      } else if (eventType === 'clock_out') {
        await db.execute(sql`
          UPDATE hr_attendance SET clock_out = NOW(),
            work_hours = EXTRACT(EPOCH FROM (NOW() - clock_in))/3600
          WHERE employee_id = ${employee.id} AND date = ${today}
        `).catch(() => {});
        // Capture the wrap-up task summary (what was completed, status, %).
        try {
          const task = (fd.get('task') as string || '').trim();
          if (task) {
            await db.execute(sql`CREATE TABLE IF NOT EXISTS hr_task_log (id UUID PRIMARY KEY DEFAULT gen_random_uuid(), employee_id UUID NOT NULL, log_date DATE NOT NULL, task TEXT NOT NULL, status TEXT NOT NULL DEFAULT 'done', percent INT NOT NULL DEFAULT 100, details TEXT, created_at TIMESTAMPTZ NOT NULL DEFAULT NOW())`);
            await db.execute(sql`INSERT INTO hr_task_log (employee_id, log_date, task, status, percent, details) VALUES (${employee.id}, ${today}, ${task.slice(0, 500)}, ${(fd.get('task_status') as string) || 'done'}, ${Math.max(0, Math.min(100, parseInt(fd.get('task_percent') as string || '100') || 100))}, ${(fd.get('task_details') as string || '').trim() || null})`);
          }
        } catch (_) {}
        okMsg = 'Clocked out. Have a great day!';
      } else if (eventType === 'break_start') {
        okMsg = 'Break started.';
      } else if (eventType === 'break_end') {
        okMsg = 'Break ended. Welcome back!';
      }
    } catch(e: any) { errorMsg = e.message; }
    return Astro.redirect('/portal/employee?msg=' + encodeURIComponent(okMsg || errorMsg));
  }

  if (action === 'daily_report' && employee) {
    const workDone = (fd.get('work_done') as string || '').trim();
    const progress = (fd.get('progress') as string || '').trim() || null;
    const blockers = (fd.get('blockers') as string || '').trim() || null;
    const today = new Date().toISOString().split('T')[0];
    if (!workDone || workDone.length < 10) {
      return Astro.redirect('/portal/employee?msg=' + encodeURIComponent('Please describe what you did today (at least a sentence).'));
    }
    try {
      await db.execute(sql`
        INSERT INTO hr_daily_reports (employee_id, report_date, work_done, progress, blockers)
        VALUES (${employee.id}, ${today}, ${workDone}, ${progress}, ${blockers})
        ON CONFLICT (employee_id, report_date) DO UPDATE SET work_done = EXCLUDED.work_done, progress = EXCLUDED.progress, blockers = EXCLUDED.blockers, updated_at = NOW()
      `);
    } catch (e: any) { return Astro.redirect('/portal/employee?msg=' + encodeURIComponent('Could not save report: ' + e.message)); }
    return Astro.redirect('/portal/employee?msg=' + encodeURIComponent('Daily report submitted. Thank you!'));
  }

  if (action === 'add_time_log' && employee) {
    const startTime = (fd.get('start_time') as string || '').trim();
    const endTime = (fd.get('end_time') as string || '').trim();
    const task = (fd.get('task') as string || '').trim();
    const today = new Date().toISOString().split('T')[0];
    const toMin = (t: string) => { const m = /^(\d{1,2}):(\d{2})$/.exec(t); return m ? (parseInt(m[1]) * 60 + parseInt(m[2])) : -1; };
    const s = toMin(startTime), e = toMin(endTime);
    if (s < 0 || e < 0 || e <= s) {
      return Astro.redirect('/portal/employee?msg=' + encodeURIComponent('Enter a valid time period (end after start).'));
    }
    if (!task || task.length < 3) {
      return Astro.redirect('/portal/employee?msg=' + encodeURIComponent('Describe what you worked on in that period.'));
    }
    const hours = Math.round(((e - s) / 60) * 100) / 100;
    try {
      await db.execute(sql`INSERT INTO hr_time_logs (employee_id, log_date, start_time, end_time, hours, task) VALUES (${employee.id}, ${today}, ${startTime}, ${endTime}, ${hours}, ${task})`);
    } catch (er: any) { return Astro.redirect('/portal/employee?msg=' + encodeURIComponent('Could not log: ' + er.message)); }
    return Astro.redirect('/portal/employee?msg=' + encodeURIComponent('Logged ' + hours + 'h.'));
  }
  if (action === 'delete_time_log' && employee) {
    const logId = (fd.get('log_id') as string || '').trim();
    if (logId) await db.execute(sql`DELETE FROM hr_time_logs WHERE id = ${logId} AND employee_id = ${employee.id}`).catch(() => {});
    return Astro.redirect('/portal/employee');
  }
}

// Today's time logs (period tracking)
let timeLogs: any[] = [];
let loggedHours = 0;
if (employee) {
  try {
    const today = new Date().toISOString().split('T')[0];
    const r = await db.execute(sql`SELECT * FROM hr_time_logs WHERE employee_id = ${employee.id} AND log_date = ${today} ORDER BY start_time ASC`);
    timeLogs = Array.isArray(r) ? r : (r?.rows || []);
    loggedHours = Math.round(timeLogs.reduce((a: number, l: any) => a + Number(l.hours || 0), 0) * 100) / 100;
  } catch (e) {}
}

// Today's clock-out task summaries
let taskLogs: any[] = [];
if (employee) {
  try {
    const r = await db.execute(sql`SELECT task, status, percent, details, created_at FROM hr_task_log WHERE employee_id = ${employee.id} AND log_date = CURRENT_DATE ORDER BY created_at DESC`);
    taskLogs = Array.isArray(r) ? r : (r?.rows || []);
  } catch (e) {}
}

// Today's daily report (if already submitted)
let todayReport: any = null;
if (employee) {
  try {
    const today = new Date().toISOString().split('T')[0];
    const r = await db.execute(sql`SELECT * FROM hr_daily_reports WHERE employee_id = ${employee.id} AND report_date = ${today} LIMIT 1`);
    const rows = Array.isArray(r) ? r : (r?.rows || []);
    todayReport = rows[0] || null;
  } catch (e) {}
}

// Get payslips
if (employee) {
  try {
    const r = await db.execute(sql`
      SELECT ps.*, pr.month, pr.year
      FROM hr_payslips ps
      JOIN hr_payroll_runs pr ON ps.payroll_run_id = pr.id
      WHERE ps.employee_id = ${employee.id}
      ORDER BY pr.year DESC, pr.month DESC
      LIMIT 12
    `);
    payslips = Array.isArray(r) ? r : (r?.rows || []);
  } catch(e) {}

  // Get today's clock events
  try {
    const r = await db.execute(sql`
      SELECT * FROM hr_clock_events
      WHERE employee_id = ${employee.id} AND DATE(event_time) = CURRENT_DATE
      ORDER BY event_time ASC
    `);
    todayEvents = Array.isArray(r) ? r : (r?.rows || []);

    // Determine current status
    if (todayEvents.length > 0) {
      const last = todayEvents[todayEvents.length - 1] as any;
      if (last.event_type === 'clock_in') currentStatus = 'clocked_in';
      else if (last.event_type === 'clock_out') currentStatus = 'clocked_out';
      else if (last.event_type === 'break_start') currentStatus = 'on_break';
      else if (last.event_type === 'break_end') currentStatus = 'clocked_in';
    }

    // Calculate today's hours
    const clockIn = (todayEvents as any[]).find((e: any) => e.event_type === 'clock_in');
    const clockOut = (todayEvents as any[]).find((e: any) => e.event_type === 'clock_out');
    if (clockIn) {
      const end = clockOut ? new Date(clockOut.event_time) : new Date();
      todayHours = Math.round(((end.getTime() - new Date(clockIn.event_time).getTime()) / 3600000) * 10) / 10;
    }
  } catch(e) {}
}

const msg = new URL(Astro.request.url).searchParams.get('msg') || '';
const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
---
<!doctype html>
<html lang="en" style="background:#f8f6f1;">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"/>
  <title>My HR - EduRankAI</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    body{background:#f8f6f1;font-family:system-ui,sans-serif;min-height:100vh;padding-bottom:80px;}
    .topbar{background:#0f0f14;padding:0 16px;height:52px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:40;}
    .card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;overflow:hidden;margin:0 14px 12px;}
    .card-header{padding:14px 16px;border-bottom:1px solid #f0f0f0;}
    .card-body{padding:14px 16px;}
    .clock-btn{width:100%;border:none;font-size:15px;font-weight:700;padding:16px;border-radius:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;}
    .status-dot{width:10px;height:10px;border-radius:50%;display:inline-block;}
    .payslip-row{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid #f0f0f0;}
    .bottom-nav{position:fixed;bottom:0;left:0;right:0;background:#0f0f14;border-top:1px solid #1a1a1f;display:flex;z-index:40;padding-bottom:env(safe-area-inset-bottom);}
    .nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8px 4px;text-decoration:none;color:#6e6e78;font-size:10px;gap:3px;}
    .nav-btn.active{color:#FF7040;}
    .event-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
  </style>
</head>
<body>
<nav class="topbar">
  <div style="display:flex;align-items:center;gap:10px;">
    <a href="/portal" style="color:#6e6e78;text-decoration:none;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    </a>
    <span style="font-size:15px;font-weight:700;color:#fff;">My HR</span>
  </div>
  <span style="font-size:11px;color:#6e6e78;">{user.name}</span>
</nav>

{msg && <div style="margin:12px 14px 0;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#065f46;border-radius:8px;padding:10px 14px;font-size:13px;">{msg}</div>}

{!employee && (
  <div style="margin:20px 14px;background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:32px;text-align:center;">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5" style="margin-bottom:12px;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    <p style="font-size:15px;font-weight:600;color:#111;margin-bottom:6px;">No employee profile found</p>
    <p style="font-size:13px;color:#6b7280;">Ask HR to link your account to your employee profile.</p>
  </div>
)}

{employee && (
  <div style="padding-top:14px;">

    <!-- Employee info -->
    <div class="card">
      <div class="card-body" style="display:flex;align-items:center;gap:12px;">
        {/* Profile photo = the picture taken at face-verification (2FA) enrolment. Falls back to the initial. */}
        {employee.photo_url
          ? <img src={employee.photo_url} alt={employee.full_name} width="48" height="48" style="width:48px;height:48px;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid rgba(255,79,0,0.25);" />
          : <div style="width:48px;height:48px;border-radius:50%;background:rgba(255,79,0,0.1);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:700;color:#FF4F00;flex-shrink:0;">{employee.full_name?.charAt(0).toUpperCase()}</div>}
        <div>
          <p style="font-size:15px;font-weight:700;color:#111;margin:0;">{employee.full_name}</p>
          <p style="font-size:12px;color:#6b7280;margin:2px 0 0;">{employee.employee_code} - {employee.designation}</p>
        </div>
      </div>
    </div>

    <!-- Wallet + Leave quick links -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:0 14px 12px;">
      <a href="/portal/employee/wallet" style="display:flex;flex-direction:column;gap:8px;background:linear-gradient(135deg,#1a1510,#2b241b);color:#faf6ef;text-decoration:none;border-radius:14px;padding:15px;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 12V8H6a2 2 0 0 1-2-2c0-1.1.9-2 2-2h12v4"/><path d="M4 6v12c0 1.1.9 2 2 2h14v-4"/><path d="M18 12a2 2 0 0 0 0 4h4v-4z"/></svg>
        <div><div style="font-weight:700;font-size:14px;">My wallet</div><div style="font-size:11.5px;opacity:.7;">Salary &amp; withdrawals</div></div>
      </a>
      <a href="/portal/employee/leave" style="display:flex;flex-direction:column;gap:8px;background:linear-gradient(135deg,#c2410c,#e05a1c);color:#fff;text-decoration:none;border-radius:14px;padding:15px;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <div><div style="font-weight:700;font-size:14px;">My leave</div><div style="font-size:11.5px;opacity:.85;">Balance &amp; requests</div></div>
      </a>
    </div>

    <!-- Clock in/out -->
    <div class="card">
      <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;">
        <p style="font-size:13px;font-weight:700;color:#111;margin:0;">Attendance Today</p>
        <div style="display:flex;align-items:center;gap:6px;">
          <div class="status-dot" style={`background:${currentStatus==='clocked_in'?'#10b981':currentStatus==='on_break'?'#fbbf24':'#d1d5db'};`}></div>
          <span style="font-size:12px;font-weight:600;color:#374151;text-transform:capitalize;">{currentStatus.replace('_',' ')}</span>
        </div>
      </div>
      <div class="card-body">
        <div style="text-align:center;margin-bottom:12px;">
          <div id="liveClock" style="font-size:34px;font-weight:800;color:#111;font-family:ui-monospace,monospace;letter-spacing:1px;line-height:1;">--:--:--</div>
          <div id="liveDate" style="font-size:12px;color:#6b7280;margin-top:3px;"></div>
        </div>
        <div id="locChip" style="display:flex;align-items:center;justify-content:center;gap:7px;background:#f3f4f6;border-radius:99px;padding:8px 14px;font-size:12px;color:#6b7280;margin-bottom:14px;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span id="locText">Locating you…</span>
        </div>
        {todayHours > 0 && (
          <div style="text-align:center;margin-bottom:14px;">
            <p style="font-size:36px;font-weight:800;color:#111;font-family:monospace;margin:0;">{todayHours}h</p>
            <p style="font-size:12px;color:#6b7280;margin:2px 0 0;">worked today</p>
          </div>
        )}

        <!-- Today's timeline -->
        {todayEvents.length > 0 && (
          <div style="margin-bottom:14px;display:flex;flex-direction:column;gap:6px;">
            {(todayEvents as any[]).map((e: any) => {
              const colors = { clock_in:'#10b981', clock_out:'#ef4444', break_start:'#fbbf24', break_end:'#10b981' };
              const labels = { clock_in:'Clocked in', clock_out:'Clocked out', break_start:'Break started', break_end:'Break ended' };
              const color = colors[e.event_type] || '#6b7280';
              return (
                <div style="display:flex;align-items:center;gap:8px;">
                  <div class="event-dot" style={`background:${color};`}></div>
                  <span style="font-size:12px;color:#374151;flex:1;">{labels[e.event_type] || e.event_type}</span>
                  {e.location_name && <span style="font-size:11px;color:#6b7280;">{e.location_name}</span>}
                  <span id={`ts-${e.id}`} data-ts={new Date(e.event_time).toISOString()} style="font-size:11px;color:#6b7280;font-family:monospace;"></span>
                </div>
              );
            })}
          </div>
        )}

        <!-- Clock action buttons -->
        <div style="display:flex;flex-direction:column;gap:8px;">
          {currentStatus === 'clocked_out' && (
            <form method="POST" id="clockForm">
              <input type="hidden" name="action" value="clock_event"/>
              <input type="hidden" name="event_type" value="clock_in"/>
              <input type="hidden" name="lat" id="lat_in"/>
              <input type="hidden" name="lon" id="lon_in"/>
              <input type="hidden" name="accuracy" id="acc_in"/>
              <input type="hidden" name="location_name" id="loc_in"/>
              <div style="display:flex;gap-8px;margin-bottom:8px;">
                <select name="work_mode" style="width:100%;background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:9px 12px;font-size:13px;outline:none;margin-bottom:8px;">
                  <option value="remote">Remote</option>
                  <option value="office">Office</option>
                  <option value="hybrid">Hybrid</option>
                  <option value="field">Field</option>
                </select>
              </div>
              <button type="button" class="clock-btn" style="background:#10b981;color:#fff;" onclick="submitClock('clockForm')">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Clock In
              </button>
            </form>
          )}
          {currentStatus === 'clocked_in' && (
            <div style="display:flex;flex-direction:column;gap:10px;">
              <form method="POST" id="outForm">
                <input type="hidden" name="action" value="clock_event"/>
                <input type="hidden" name="event_type" value="clock_out"/>
                <input type="hidden" name="lat"/><input type="hidden" name="lon"/>
                <input type="hidden" name="accuracy"/><input type="hidden" name="location_name"/>
                <label style="font-size:11px;font-weight:600;color:#374151;display:block;margin-bottom:5px;">Wrapping up — what did you get done?</label>
                <input name="task" placeholder="e.g. Finished the signup form; fixed 2 bugs" style="width:100%;background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:9px 12px;font-size:13px;outline:none;"/>
                <div style="display:flex;gap:8px;margin-top:8px;align-items:center;">
                  <select name="task_status" style="flex:1;background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:9px 10px;font-size:13px;outline:none;">
                    <option value="done">Completed</option><option value="pending">In progress</option><option value="blocked">Blocked</option>
                  </select>
                  <div style="flex:1;display:flex;align-items:center;gap:8px;">
                    <input type="range" name="task_percent" min="0" max="100" step="5" value="100" oninput="document.getElementById('pctOut').textContent=this.value" style="flex:1;accent-color:#FF4F00;"/>
                    <span style="font-size:12px;font-weight:700;color:#FF4F00;font-family:monospace;min-width:38px;text-align:right;"><span id="pctOut">100</span>%</span>
                  </div>
                </div>
                <input name="task_details" placeholder="Details / handover (optional)" style="width:100%;background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:9px 12px;font-size:13px;outline:none;margin-top:8px;"/>
                <button type="button" class="clock-btn" style="background:#ef4444;color:#fff;margin-top:10px;" onclick="submitClock('outForm')">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                  Clock Out
                </button>
              </form>
              <form method="POST" id="breakForm">
                <input type="hidden" name="action" value="clock_event"/>
                <input type="hidden" name="event_type" value="break_start"/>
                <input type="hidden" name="lat"/><input type="hidden" name="lon"/>
                <input type="hidden" name="accuracy"/><input type="hidden" name="location_name"/>
                <button type="button" class="clock-btn" style="background:transparent;border:1px solid #e5e7eb;color:#374151;" onclick="submitClock('breakForm')">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
                  Take a break
                </button>
              </form>
            </div>
          )}
          {currentStatus === 'on_break' && (
            <form method="POST" id="resumeForm">
              <input type="hidden" name="action" value="clock_event"/>
              <input type="hidden" name="event_type" value="break_end"/>
              <input type="hidden" name="lat"/><input type="hidden" name="lon"/>
              <input type="hidden" name="accuracy"/><input type="hidden" name="location_name"/>
              <button type="button" class="clock-btn" style="background:#10b981;color:#fff;" onclick="submitClock('resumeForm')">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                Resume Work
              </button>
            </form>
          )}
        </div>
      </div>
    </div>

    {taskLogs.length > 0 && (
      <div class="card">
        <div class="card-header"><p style="font-size:13px;font-weight:700;color:#111;margin:0;">Today's session summaries</p></div>
        <div class="card-body" style="display:flex;flex-direction:column;gap:8px;">
          {(taskLogs as any[]).map((t: any) => (
            <div style="border-bottom:1px solid #f0f0f0;padding-bottom:8px;">
              <div style="display:flex;justify-content:space-between;gap:8px;align-items:center;">
                <span style="font-size:13px;color:#111;font-weight:600;flex:1;">{t.task}</span>
                <span style={`font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;padding:2px 8px;border-radius:99px;color:${t.status==='done'?'#059669':t.status==='blocked'?'#dc2626':'#d97706'};background:${t.status==='done'?'rgba(5,150,105,.12)':t.status==='blocked'?'rgba(220,38,38,.12)':'rgba(217,119,6,.12)'};`}>{t.status}</span>
                <span style="font-size:12px;font-family:monospace;color:#FF4F00;font-weight:700;min-width:38px;text-align:right;">{t.percent}%</span>
              </div>
              {t.details && <div style="font-size:12px;color:#6b7280;margin-top:3px;">{t.details}</div>}
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Hourly / time-period tracking -->
    <div class="card">
      <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;">
        <p style="font-size:13px;font-weight:700;color:#111;margin:0;">Time log (hourly)</p>
        <span style="font-size:12px;font-weight:700;color:#FF4F00;">{loggedHours}h logged</span>
      </div>
      <div class="card-body">
        <p style="font-size:12px;color:#6b7280;margin:0 0 10px;line-height:1.5;">Log each block of work through the day — from / to and what you did.</p>
        {(timeLogs as any[]).length > 0 && (
          <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:12px;">
            {(timeLogs as any[]).map((l: any) => (
              <div style="display:flex;align-items:flex-start;gap:8px;background:#f9fafb;border:1px solid #f0f0f0;border-radius:8px;padding:8px 10px;">
                <span style="font-size:11px;font-weight:700;color:#FF4F00;font-family:monospace;white-space:nowrap;">{l.start_time}-{l.end_time}</span>
                <span style="font-size:12.5px;color:#374151;flex:1;">{l.task}</span>
                <span style="font-size:11px;color:#9ca3af;white-space:nowrap;">{l.hours}h</span>
                <form method="POST" style="margin:0;"><input type="hidden" name="action" value="delete_time_log"/><input type="hidden" name="log_id" value={l.id}/><button type="submit" style="background:none;border:none;color:#ef4444;font-size:11px;cursor:pointer;padding:0;">×</button></form>
              </div>
            ))}
          </div>
        )}
        <form method="POST" style="display:flex;flex-wrap:wrap;gap:8px;align-items:flex-end;">
          <input type="hidden" name="action" value="add_time_log"/>
          <div><label style="font-size:10px;color:#6b7280;display:block;">From</label><input name="start_time" type="time" required style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:8px 10px;font-size:13px;"/></div>
          <div><label style="font-size:10px;color:#6b7280;display:block;">To</label><input name="end_time" type="time" required style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:8px 10px;font-size:13px;"/></div>
          <div style="flex:1;min-width:140px;"><label style="font-size:10px;color:#6b7280;display:block;">What did you do?</label><input name="task" required placeholder="e.g. Built the signup form" style="width:100%;background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:8px 10px;font-size:13px;"/></div>
          <button type="submit" style="background:#111;color:#fff;border:none;font-size:13px;font-weight:600;padding:9px 16px;border-radius:8px;cursor:pointer;">Add</button>
        </form>
      </div>
    </div>

    <!-- Daily work report -->
    <div class="card">
      <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;">
        <p style="font-size:13px;font-weight:700;color:#111;margin:0;">Today's work report</p>
        {todayReport && <span style="font-size:11px;font-weight:600;color:#10b981;">submitted</span>}
      </div>
      <div class="card-body">
        <p style="font-size:12px;color:#6b7280;margin:0 0 10px;line-height:1.5;">A short written report of what you did today is part of your attendance. {todayReport ? 'You can edit and resubmit.' : ''}</p>
        <form method="POST">
          <input type="hidden" name="action" value="daily_report" />
          <label style="font-size:11px;font-weight:600;color:#374151;display:block;margin-bottom:4px;">What did you do today? *</label>
          <textarea name="work_done" required rows="3" placeholder="Tasks completed, work done..." style="width:100%;background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:9px 12px;font-size:13px;outline:none;margin-bottom:8px;resize:vertical;">{todayReport ? todayReport.work_done : ''}</textarea>
          <label style="font-size:11px;font-weight:600;color:#374151;display:block;margin-bottom:4px;">Progress / what's next</label>
          <textarea name="progress" rows="2" placeholder="Progress on ongoing work, plan for tomorrow..." style="width:100%;background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:9px 12px;font-size:13px;outline:none;margin-bottom:8px;resize:vertical;">{todayReport && todayReport.progress ? todayReport.progress : ''}</textarea>
          <label style="font-size:11px;font-weight:600;color:#374151;display:block;margin-bottom:4px;">Blockers (optional)</label>
          <input name="blockers" placeholder="Anything blocking you?" value={todayReport && todayReport.blockers ? todayReport.blockers : ''} style="width:100%;background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:9px 12px;font-size:13px;outline:none;margin-bottom:10px;" />
          <button type="submit" style="width:100%;background:#FF4F00;color:#fff;border:none;font-size:14px;font-weight:700;padding:12px;border-radius:10px;cursor:pointer;">{todayReport ? 'Update report' : 'Submit report'}</button>
        </form>
      </div>
    </div>

    <!-- Payslips -->
    <div class="card">
      <div class="card-header">
        <p style="font-size:13px;font-weight:700;color:#111;margin:0;">Payslips</p>
      </div>
      <div class="card-body" style="padding:0;">
        {payslips.length === 0 && <p style="font-size:13px;color:#6b7280;text-align:center;padding:24px;">No payslips yet.</p>}
        {(payslips as any[]).map((ps: any) => (
          <div class="payslip-row" style="padding:12px 16px;">
            <div>
              <p style="font-size:14px;font-weight:600;color:#111;margin:0;">{MONTHS[(ps.month||1)-1]} {ps.year}</p>
              <p style="font-size:12px;color:#6b7280;margin:2px 0 0;">Net: {ps.currency||'INR'} {Number(ps.net_salary||0).toLocaleString()}</p>
            </div>
            <a href={`/admin/hr/payslip/${ps.id}`} target="_blank" style="background:#111;color:#fff;text-decoration:none;font-size:12px;font-weight:600;padding:7px 14px;border-radius:8px;display:flex;align-items:center;gap:5px;">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Download
            </a>
          </div>
        ))}
      </div>
    </div>

  </div>
)}

<!-- Bottom nav -->
<nav class="bottom-nav">
  <a href="/portal" class="nav-btn">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
    Home
  </a>
  <a href="/portal/discussion" class="nav-btn">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    Community
  </a>
  <a href="/portal/courses" class="nav-btn">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
    Learn
  </a>
  <a href="/portal/employee" class="nav-btn active">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    My HR
  </a>
</nav>

<script is:inline>
// Local-time timestamps
document.querySelectorAll('[data-ts]').forEach(function(el) {
  var d = new Date(el.getAttribute('data-ts'));
  el.textContent = d.toLocaleTimeString(undefined, { hour: 'numeric', minute: '2-digit' });
});

// Live clock
function tick(){ var d=new Date(), c=document.getElementById('liveClock'), dt=document.getElementById('liveDate');
  if(c) c.textContent=d.toLocaleTimeString(undefined,{hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false});
  if(dt) dt.textContent=d.toLocaleDateString(undefined,{weekday:'long',day:'numeric',month:'long'}); }
tick(); setInterval(tick,1000);

// Prefetch location so clock-in is instant and the chip shows it's working.
var GEO_OPTS={enableHighAccuracy:true, timeout:12000, maximumAge:30000};
var lastPos=null;
function chip(txt,ok){ var t=document.getElementById('locText'), c=document.getElementById('locChip'); if(t) t.textContent=txt;
  if(c){ c.style.color= ok?'#065f46':'#6b7280'; c.style.background= ok?'rgba(16,185,129,0.10)':'#f3f4f6'; } }
function prefetch(){ if(!navigator.geolocation){ chip('Location not available on this device',false); return; }
  navigator.geolocation.getCurrentPosition(function(p){ lastPos=p; chip('Location ready · accurate to ±'+Math.round(p.coords.accuracy)+' m', true); },
    function(){ chip('Location off — you can still clock in',false); }, GEO_OPTS); }
prefetch();

function setF(form,n,v){ var el=form.querySelector('[name="'+n+'"]'); if(el) el.value=v; }
function fill(form,p){ var c=p.coords; setF(form,'lat',c.latitude); setF(form,'lon',c.longitude); setF(form,'accuracy',Math.round(c.accuracy));
  setF(form,'location_name','±'+Math.round(c.accuracy)+'m · '+c.latitude.toFixed(5)+', '+c.longitude.toFixed(5)); }

// Attach the captured selfie to the form (creates the hidden field on demand).
function setFace(form,data){ var el=form.querySelector('[name="face_photo"]');
  if(!el){ el=document.createElement('input'); el.type='hidden'; el.name='face_photo'; form.appendChild(el); } el.value=data; }

// Face check-in: take a quick selfie with the front camera as attendance proof.
// Advisory only — a human verifies it later; if the camera is denied or missing
// the clock still proceeds (we never block someone from marking attendance).
function captureFace(form, cb){
  if(!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia){ cb(); return; }
  var settled=false; function done(){ if(settled) return; settled=true; cb(); }
  navigator.mediaDevices.getUserMedia({ video:{ facingMode:'user', width:{ideal:480}, height:{ideal:480} }, audio:false })
  .then(function(stream){
    var ov=document.createElement('div');
    ov.style.cssText='position:fixed;inset:0;z-index:100000;background:rgba(10,12,20,.85);backdrop-filter:blur(4px);display:flex;align-items:center;justify-content:center;padding:20px;';
    ov.innerHTML=''+
      '<div style="background:#fff;border-radius:18px;max-width:340px;width:100%;overflow:hidden;box-shadow:0 24px 70px rgba(0,0,0,.5);font-family:system-ui,sans-serif;">'+
      '<div style="padding:14px 16px;border-bottom:1px solid #f0f0f0;"><p style="margin:0;font-size:14px;font-weight:700;color:#111;">Face check-in</p>'+
      '<p style="margin:3px 0 0;font-size:11.5px;color:#6b7280;">Look at the camera and capture to confirm it’s you.</p></div>'+
      '<div style="position:relative;background:#000;aspect-ratio:1;overflow:hidden;">'+
      '<video autoplay playsinline muted style="width:100%;height:100%;object-fit:cover;transform:scaleX(-1);"></video>'+
      '<div style="position:absolute;inset:14%;border:2px dashed rgba(255,255,255,.55);border-radius:50%;pointer-events:none;"></div></div>'+
      '<div style="padding:12px 16px 16px;display:flex;flex-direction:column;gap:8px;">'+
      '<button type="button" data-cap style="width:100%;background:#10b981;color:#fff;border:none;font-size:14px;font-weight:700;padding:13px;border-radius:11px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;">'+
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>Capture &amp; continue</button>'+
      '<button type="button" data-skip style="width:100%;background:none;border:none;color:#9ca3af;font-size:12px;cursor:pointer;padding:4px;">Skip camera</button></div></div>';
    document.body.appendChild(ov);
    var video=ov.querySelector('video'); video.srcObject=stream;
    function cleanup(){ try{ stream.getTracks().forEach(function(t){t.stop();}); }catch(_){} if(ov.parentNode) ov.parentNode.removeChild(ov); }
    ov.querySelector('[data-cap]').onclick=function(){
      var vw=video.videoWidth||480, vh=video.videoHeight||480;
      var w=240, h=Math.max(1, Math.round(vh*(w/vw)));
      var cv=document.createElement('canvas'); cv.width=w; cv.height=h;
      try{ cv.getContext('2d').drawImage(video,0,0,w,h); setFace(form, cv.toDataURL('image/jpeg',0.6)); }catch(_){}
      cleanup(); done();
    };
    ov.querySelector('[data-skip]').onclick=function(){ cleanup(); done(); };
    setTimeout(function(){ if(!settled){} }, 60000); // leave modal open until the user acts
  })
  .catch(function(){ done(); }); // no permission / no camera -> clock in without a photo
}

// Robust submit — captures GPS, never hangs (hard fallback), no external calls.
function finishClock(form){
  var btn=form.querySelector('button.clock-btn'); if(btn){ btn.disabled=true; btn.textContent='Recording…'; }
  var done=false; function go(){ if(done) return; done=true; form.submit(); }
  var fallback=setTimeout(go, 13000); // never leave the button stuck
  if(lastPos){ fill(form,lastPos); }
  if(!navigator.geolocation){ clearTimeout(fallback); go(); return; }
  navigator.geolocation.getCurrentPosition(
    function(p){ fill(form,p); clearTimeout(fallback); go(); },
    function(){ if(!lastPos) setF(form,'location_name','location unavailable'); clearTimeout(fallback); go(); },
    GEO_OPTS
  );
}

// Clock in/out by face: take the selfie first, then record GPS and submit.
function submitClock(formId){
  var form=document.getElementById(formId); if(!form) return;
  captureFace(form, function(){ finishClock(form); });
}
</script>
</body>
</html>
