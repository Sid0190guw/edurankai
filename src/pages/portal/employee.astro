---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

let okMsg = '', errorMsg = '';
let employee: any = null;
let payslips: any[] = [];
let todayEvents: any[] = [];
let currentStatus: 'clocked_out' | 'clocked_in' | 'on_break' = 'clocked_out';
let todayHours = 0;

// Find employee linked to this user
try {
  const r = await db.execute(sql`SELECT * FROM hr_employees WHERE user_id = ${user.id} AND is_active = true LIMIT 1`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  employee = rows[0] || null;
} catch(e) {}

// If no direct link, try matching by email
if (!employee) {
  try {
    const r = await db.execute(sql`SELECT * FROM hr_employees WHERE work_email = ${user.email} AND is_active = true LIMIT 1`);
    const rows = Array.isArray(r) ? r : (r?.rows || []);
    employee = rows[0] || null;
    // Link user_id
    if (employee) {
      await db.execute(sql`UPDATE hr_employees SET user_id = ${user.id} WHERE id = ${employee.id}`).catch(() => {});
    }
  } catch(e) {}
}

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;

  if (action === 'clock_event' && employee) {
    const eventType = fd.get('event_type') as string;
    const lat = parseFloat(fd.get('lat') as string || '0') || null;
    const lon = parseFloat(fd.get('lon') as string || '0') || null;
    const accuracy = parseFloat(fd.get('accuracy') as string || '0') || null;
    const locationName = (fd.get('location_name') as string || '').trim() || null;
    const workMode = fd.get('work_mode') as string || 'remote';
    const note = (fd.get('note') as string || '').trim() || null;

    try {
      await db.execute(sql`
        INSERT INTO hr_clock_events (employee_id, event_type, lat, lon, accuracy, location_name, work_mode, note, ip_address, device_info)
        VALUES (${employee.id}, ${eventType}, ${lat}, ${lon}, ${accuracy}, ${locationName}, ${workMode}, ${note},
          ${Astro.clientAddress}, ${Astro.request.headers.get('user-agent')?.substring(0,200) || null})
      `);

      // Update attendance record
      const today = new Date().toISOString().split('T')[0];
      if (eventType === 'clock_in') {
        await db.execute(sql`
          INSERT INTO hr_attendance (employee_id, date, clock_in, status, work_mode, ip_address)
          VALUES (${employee.id}, ${today}, NOW(), 'present', ${workMode}, ${Astro.clientAddress})
          ON CONFLICT (employee_id, date) DO UPDATE SET clock_in = NOW(), status = 'present', work_mode = ${workMode}
        `).catch(() => {});
        okMsg = 'Clocked in successfully!';
      } else if (eventType === 'clock_out') {
        await db.execute(sql`
          UPDATE hr_attendance SET clock_out = NOW(),
            work_hours = EXTRACT(EPOCH FROM (NOW() - clock_in))/3600
          WHERE employee_id = ${employee.id} AND date = ${today}
        `).catch(() => {});
        okMsg = 'Clocked out. Have a great day!';
      } else if (eventType === 'break_start') {
        okMsg = 'Break started.';
      } else if (eventType === 'break_end') {
        okMsg = 'Break ended. Welcome back!';
      }
    } catch(e: any) { errorMsg = e.message; }
    return Astro.redirect('/portal/employee?msg=' + encodeURIComponent(okMsg || errorMsg));
  }
}

// Get payslips
if (employee) {
  try {
    const r = await db.execute(sql`
      SELECT ps.*, pr.month, pr.year
      FROM hr_payslips ps
      JOIN hr_payroll_runs pr ON ps.payroll_run_id = pr.id
      WHERE ps.employee_id = ${employee.id}
      ORDER BY pr.year DESC, pr.month DESC
      LIMIT 12
    `);
    payslips = Array.isArray(r) ? r : (r?.rows || []);
  } catch(e) {}

  // Get today's clock events
  try {
    const r = await db.execute(sql`
      SELECT * FROM hr_clock_events
      WHERE employee_id = ${employee.id} AND DATE(event_time) = CURRENT_DATE
      ORDER BY event_time ASC
    `);
    todayEvents = Array.isArray(r) ? r : (r?.rows || []);

    // Determine current status
    if (todayEvents.length > 0) {
      const last = todayEvents[todayEvents.length - 1] as any;
      if (last.event_type === 'clock_in') currentStatus = 'clocked_in';
      else if (last.event_type === 'clock_out') currentStatus = 'clocked_out';
      else if (last.event_type === 'break_start') currentStatus = 'on_break';
      else if (last.event_type === 'break_end') currentStatus = 'clocked_in';
    }

    // Calculate today's hours
    const clockIn = (todayEvents as any[]).find((e: any) => e.event_type === 'clock_in');
    const clockOut = (todayEvents as any[]).find((e: any) => e.event_type === 'clock_out');
    if (clockIn) {
      const end = clockOut ? new Date(clockOut.event_time) : new Date();
      todayHours = Math.round(((end.getTime() - new Date(clockIn.event_time).getTime()) / 3600000) * 10) / 10;
    }
  } catch(e) {}
}

const msg = new URL(Astro.request.url).searchParams.get('msg') || '';
const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
---
<!doctype html>
<html lang="en" style="background:#f8f6f1;">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"/>
  <title>My HR - EduRankAI</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    body{background:#f8f6f1;font-family:system-ui,sans-serif;min-height:100vh;padding-bottom:80px;}
    .topbar{background:#0f0f14;padding:0 16px;height:52px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:40;}
    .card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;overflow:hidden;margin:0 14px 12px;}
    .card-header{padding:14px 16px;border-bottom:1px solid #f0f0f0;}
    .card-body{padding:14px 16px;}
    .clock-btn{width:100%;border:none;font-size:15px;font-weight:700;padding:16px;border-radius:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;}
    .status-dot{width:10px;height:10px;border-radius:50%;display:inline-block;}
    .payslip-row{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid #f0f0f0;}
    .bottom-nav{position:fixed;bottom:0;left:0;right:0;background:#0f0f14;border-top:1px solid #1a1a1f;display:flex;z-index:40;padding-bottom:env(safe-area-inset-bottom);}
    .nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8px 4px;text-decoration:none;color:#6e6e78;font-size:10px;gap:3px;}
    .nav-btn.active{color:#FF7040;}
    .event-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
  </style>
</head>
<body>
<nav class="topbar">
  <div style="display:flex;align-items:center;gap:10px;">
    <a href="/portal" style="color:#6e6e78;text-decoration:none;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    </a>
    <span style="font-size:15px;font-weight:700;color:#fff;">My HR</span>
  </div>
  <span style="font-size:11px;color:#6e6e78;">{user.name}</span>
</nav>

{msg && <div style="margin:12px 14px 0;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#065f46;border-radius:8px;padding:10px 14px;font-size:13px;">{msg}</div>}

{!employee && (
  <div style="margin:20px 14px;background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:32px;text-align:center;">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5" style="margin-bottom:12px;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    <p style="font-size:15px;font-weight:600;color:#111;margin-bottom:6px;">No employee profile found</p>
    <p style="font-size:13px;color:#6b7280;">Ask HR to link your account to your employee profile.</p>
  </div>
)}

{employee && (
  <div style="padding-top:14px;">

    <!-- Employee info -->
    <div class="card">
      <div class="card-body" style="display:flex;align-items:center;gap:12px;">
        <div style="width:48px;height:48px;border-radius:50%;background:rgba(255,79,0,0.1);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:700;color:#FF4F00;flex-shrink:0;">{employee.full_name?.charAt(0).toUpperCase()}</div>
        <div>
          <p style="font-size:15px;font-weight:700;color:#111;margin:0;">{employee.full_name}</p>
          <p style="font-size:12px;color:#6b7280;margin:2px 0 0;">{employee.employee_code} - {employee.designation}</p>
        </div>
      </div>
    </div>

    <!-- Clock in/out -->
    <div class="card">
      <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;">
        <p style="font-size:13px;font-weight:700;color:#111;margin:0;">Attendance Today</p>
        <div style="display:flex;align-items:center;gap:6px;">
          <div class="status-dot" style={`background:${currentStatus==='clocked_in'?'#10b981':currentStatus==='on_break'?'#fbbf24':'#d1d5db'};`}></div>
          <span style="font-size:12px;font-weight:600;color:#374151;text-transform:capitalize;">{currentStatus.replace('_',' ')}</span>
        </div>
      </div>
      <div class="card-body">
        {todayHours > 0 && (
          <div style="text-align:center;margin-bottom:14px;">
            <p style="font-size:36px;font-weight:800;color:#111;font-family:monospace;margin:0;">{todayHours}h</p>
            <p style="font-size:12px;color:#6b7280;margin:2px 0 0;">worked today</p>
          </div>
        )}

        <!-- Today's timeline -->
        {todayEvents.length > 0 && (
          <div style="margin-bottom:14px;display:flex;flex-direction:column;gap:6px;">
            {(todayEvents as any[]).map((e: any) => {
              const colors = { clock_in:'#10b981', clock_out:'#ef4444', break_start:'#fbbf24', break_end:'#10b981' };
              const labels = { clock_in:'Clocked in', clock_out:'Clocked out', break_start:'Break started', break_end:'Break ended' };
              const color = colors[e.event_type] || '#6b7280';
              return (
                <div style="display:flex;align-items:center;gap:8px;">
                  <div class="event-dot" style={`background:${color};`}></div>
                  <span style="font-size:12px;color:#374151;flex:1;">{labels[e.event_type] || e.event_type}</span>
                  {e.location_name && <span style="font-size:11px;color:#6b7280;">{e.location_name}</span>}
                  <span id={`ts-${e.id}`} data-ts={new Date(e.event_time).toISOString()} style="font-size:11px;color:#6b7280;font-family:monospace;"></span>
                </div>
              );
            })}
          </div>
        )}

        <!-- Clock action buttons -->
        <div style="display:flex;flex-direction:column;gap:8px;">
          {currentStatus === 'clocked_out' && (
            <form method="POST" id="clockForm">
              <input type="hidden" name="action" value="clock_event"/>
              <input type="hidden" name="event_type" value="clock_in"/>
              <input type="hidden" name="lat" id="lat_in"/>
              <input type="hidden" name="lon" id="lon_in"/>
              <input type="hidden" name="accuracy" id="acc_in"/>
              <input type="hidden" name="location_name" id="loc_in"/>
              <div style="display:flex;gap-8px;margin-bottom:8px;">
                <select name="work_mode" style="width:100%;background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:9px 12px;font-size:13px;outline:none;margin-bottom:8px;">
                  <option value="remote">Remote</option>
                  <option value="office">Office</option>
                  <option value="hybrid">Hybrid</option>
                  <option value="field">Field</option>
                </select>
              </div>
              <button type="button" class="clock-btn" style="background:#10b981;color:#fff;" onclick="submitClock('clockForm')">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Clock In
              </button>
            </form>
          )}
          {currentStatus === 'clocked_in' && (
            <div style="display:flex;gap:8px;">
              <form method="POST" style="flex:1;" id="breakForm">
                <input type="hidden" name="action" value="clock_event"/>
                <input type="hidden" name="event_type" value="break_start"/>
                <input type="hidden" name="lat" id="lat_brk"/>
                <input type="hidden" name="lon" id="lon_brk"/>
                <button type="button" class="clock-btn" style="background:#fbbf24;color:#fff;" onclick="submitClock('breakForm')">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
                  Break
                </button>
              </form>
              <form method="POST" style="flex:1;" id="outForm">
                <input type="hidden" name="action" value="clock_event"/>
                <input type="hidden" name="event_type" value="clock_out"/>
                <input type="hidden" name="lat" id="lat_out"/>
                <input type="hidden" name="lon" id="lon_out"/>
                <button type="button" class="clock-btn" style="background:#ef4444;color:#fff;" onclick="submitClock('outForm')">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                  Clock Out
                </button>
              </form>
            </div>
          )}
          {currentStatus === 'on_break' && (
            <form method="POST" id="resumeForm">
              <input type="hidden" name="action" value="clock_event"/>
              <input type="hidden" name="event_type" value="break_end"/>
              <button type="button" class="clock-btn" style="background:#10b981;color:#fff;" onclick="submitClock('resumeForm')">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                Resume Work
              </button>
            </form>
          )}
        </div>
      </div>
    </div>

    <!-- Payslips -->
    <div class="card">
      <div class="card-header">
        <p style="font-size:13px;font-weight:700;color:#111;margin:0;">Payslips</p>
      </div>
      <div class="card-body" style="padding:0;">
        {payslips.length === 0 && <p style="font-size:13px;color:#6b7280;text-align:center;padding:24px;">No payslips yet.</p>}
        {(payslips as any[]).map((ps: any) => (
          <div class="payslip-row" style="padding:12px 16px;">
            <div>
              <p style="font-size:14px;font-weight:600;color:#111;margin:0;">{MONTHS[(ps.month||1)-1]} {ps.year}</p>
              <p style="font-size:12px;color:#6b7280;margin:2px 0 0;">Net: {ps.currency||'INR'} {Number(ps.net_salary||0).toLocaleString()}</p>
            </div>
            <a href={`/admin/hr/payslip/${ps.id}`} target="_blank" style="background:#111;color:#fff;text-decoration:none;font-size:12px;font-weight:600;padding:7px 14px;border-radius:8px;display:flex;align-items:center;gap:5px;">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Download
            </a>
          </div>
        ))}
      </div>
    </div>

  </div>
)}

<!-- Bottom nav -->
<nav class="bottom-nav">
  <a href="/portal" class="nav-btn">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
    Home
  </a>
  <a href="/portal/discussion" class="nav-btn">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    Community
  </a>
  <a href="/portal/courses" class="nav-btn">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
    Learn
  </a>
  <a href="/portal/employee" class="nav-btn active">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    My HR
  </a>
</nav>

<script is:inline>
// Format timestamps in local timezone
document.querySelectorAll('[data-ts]').forEach(function(el) {
  var d = new Date(el.getAttribute('data-ts'));
  el.textContent = d.toLocaleTimeString(undefined, { hour: 'numeric', minute: '2-digit' });
});

// Clock submit with GPS
function submitClock(formId) {
  var form = document.getElementById(formId);
  if (!form) return;
  if (!navigator.geolocation) { form.submit(); return; }
  navigator.geolocation.getCurrentPosition(
    function(pos) {
      var lat = form.querySelector('[name="lat"]') || form.querySelector('[id^="lat"]');
      var lon = form.querySelector('[name="lon"]') || form.querySelector('[id^="lon"]');
      var acc = form.querySelector('[name="accuracy"]') || form.querySelector('[id^="acc"]');
      var loc = form.querySelector('[name="location_name"]') || form.querySelector('[id^="loc"]');
      if (lat) lat.value = pos.coords.latitude;
      if (lon) lon.value = pos.coords.longitude;
      if (acc) acc.value = pos.coords.accuracy;
      // Reverse geocode
      fetch('https://nominatim.openstreetmap.org/reverse?lat='+pos.coords.latitude+'&lon='+pos.coords.longitude+'&format=json')
        .then(function(r){return r.json();})
        .then(function(g){if(loc)loc.value=g.address?.suburb||g.address?.city||g.display_name?.split(',')[0]||'';form.submit();})
        .catch(function(){form.submit();});
    },
    function(){form.submit();},
    {enableHighAccuracy:true, timeout:5000}
  );
}
</script>
</body>
</html>
