---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { getCreditBalance, getCreditLedger } from '@/lib/account-credit';
import { walletAmounts, currencyFor } from '@/lib/local-currency';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/wallet'));
if (user.role !== 'applicant') return Astro.redirect('/admin');

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

// Recover any payment that succeeded but was never applied - so the money lands
// in the wallet (or the application) the moment they open this page.
try { const { reconcileUserPending } = await import('@/lib/payment-effects'); await reconcileUserPending(user.id); } catch (_) {}

let country = 'India';
try { country = (rows(await db.execute(sql`SELECT country FROM users WHERE id = ${user.id} LIMIT 1`))[0]?.country) || 'India'; } catch (_) {}

const balancePaise = await getCreditBalance(user.id).catch(() => 0);
const w = await walletAmounts(balancePaise, country);
const cur = currencyFor(country);
const ledger = await getCreditLedger(user.id, 50).catch(() => []);

function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }); } catch { return '-'; } }
function signed(paise: any) {
  const n = (Number(paise) || 0) / 100;
  const s = n < 0 ? '-' : '+';
  return s + '₹' + Math.abs(n).toLocaleString('en-IN', { maximumFractionDigits: 2 });
}
---
<BaseLayout title="Your wallet - EduRankAI" description="Your EduRankAI account credit." noindex={true}>
  <section class="px-[5vw] py-10 md:py-14 max-w-2xl mx-auto">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-3">Account credit</p>
    <h1 class="font-display text-[clamp(1.7rem,4vw,2.4rem)] font-semibold text-ink leading-tight tracking-tight mb-2">Your wallet.</h1>
    <p class="text-[0.9rem] text-ink-soft leading-relaxed mb-7">Credit on your account - including any payment that went through but didn't finish - usable for <strong>any</strong> EduRankAI fee or product. Balance is held in our base currency and shown in yours at today's live rate.</p>

    <!-- Balance card -->
    <div class="rounded-2xl p-6 mb-6 text-white" style="background:linear-gradient(135deg,#100b08,#2a1a12);">
      <p class="text-[0.66rem] font-mono uppercase tracking-[0.16em] text-white/55 mb-2">Available balance</p>
      <p class="font-display text-[2.6rem] font-semibold leading-none">{w.chfLabel}</p>
      <div class="flex items-center gap-3 mt-3 flex-wrap text-[0.86rem] text-white/75">
        {cur.code !== 'CHF' && <span>= <strong class="text-white">{w.localLabel}</strong> <span class="text-white/50">({cur.name})</span></span>}
        {cur.code !== 'INR' && <span class="text-white/45">· ₹{w.inr.toLocaleString('en-IN', { maximumFractionDigits: 2 })} held</span>}
      </div>
      <p class="text-[0.72rem] text-white/45 mt-4">CHF is our base currency. {cur.code === 'INR' ? 'Held and settled in INR.' : 'Converted from INR at the live ECB rate; the actual charge is always in INR via Razorpay.'}</p>
    </div>

    {balancePaise <= 0 && (
      <div class="bg-cream-2 border border-ink/10 rounded-xl p-5 mb-6 text-[0.86rem] text-ink-soft leading-relaxed">
        Your wallet is empty right now. If you paid a fee but your application didn't go through, it appears here automatically once we reconcile the payment - this page checks every time you open it. Questions? <a href="mailto:hr@edurankai.in" class="text-burn font-semibold">hr@edurankai.in</a>
      </div>
    )}

    <!-- Ledger -->
    <h2 class="font-display text-[1.1rem] font-semibold text-ink mb-3">Activity</h2>
    {ledger.length === 0 ? (
      <p class="text-[0.86rem] text-ink-soft">No wallet activity yet.</p>
    ) : (
      <div class="bg-white border border-ink/10 rounded-2xl overflow-hidden">
        {ledger.map((l: any, i: number) => (
          <div class={'flex items-center justify-between gap-4 px-5 py-3.5' + (i > 0 ? ' border-t border-ink/6' : '')}>
            <div class="min-w-0">
              <p class="text-[0.88rem] font-medium text-ink truncate">{l.reason || (Number(l.delta_paise) < 0 ? 'Spent on a fee' : 'Credit added')}</p>
              <p class="text-[0.72rem] text-ink-soft font-mono">{fmt(l.created_at)}</p>
            </div>
            <span class={'text-[0.92rem] font-bold whitespace-nowrap ' + (Number(l.delta_paise) < 0 ? 'text-ink-soft' : 'text-leaf')}>{signed(l.delta_paise)}</span>
          </div>
        ))}
      </div>
    )}

    <div class="flex items-center justify-between flex-wrap gap-3 mt-7">
      <a href="/portal" class="text-[0.84rem] text-ink-soft hover:text-ink underline underline-offset-2">Back to portal</a>
      <a href="/portal/profile" class="text-[0.84rem] text-burn hover:underline">Your profile &rarr;</a>
    </div>
  </section>
</BaseLayout>
