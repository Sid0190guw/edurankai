---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ensureCommunitySchema, listHackathons } from '@/lib/community';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

await ensureCommunitySchema();

const url = new URL(Astro.request.url);
const tab = url.searchParams.get('tab') || 'all';
const validTabs = ['all', 'announced', 'registration_open', 'in_progress', 'completed'];
const activeTab = validTabs.includes(tab) ? tab : 'all';

const all = await listHackathons({});
const filtered = activeTab === 'all' ? all : all.filter((h: any) => h.status === activeTab);

const STATUS_LABEL: Record<string, string> = {
  announced: 'Announced',
  registration_open: 'Registration open',
  in_progress: 'In progress',
  completed: 'Completed'
};

const STATUS_TONE: Record<string, string> = {
  announced: 'tone-ink',
  registration_open: 'tone-leaf',
  in_progress: 'tone-burn',
  completed: 'tone-mute'
};

function fmtDate(d: any): string {
  if (!d) return 'To be announced';
  try {
    return new Date(d).toLocaleDateString(undefined, { day: 'numeric', month: 'short', year: 'numeric' });
  } catch (_) { return 'To be announced'; }
}

function fmtPrize(chf: any): string {
  if (chf === null || chf === undefined) return 'Prize to be announced';
  const n = Number(chf);
  if (!Number.isFinite(n) || n <= 0) return 'Recognition prize';
  return n.toLocaleString() + ' CHF';
}

const TABS = [
  { key: 'all', label: 'All' },
  { key: 'announced', label: 'Announced' },
  { key: 'registration_open', label: 'Open' },
  { key: 'in_progress', label: 'In progress' },
  { key: 'completed', label: 'Completed' }
];
---
<BaseLayout title="Hackathons | Portal" description="Time-boxed builds. Win a prize, ship a portfolio piece, find a team.">
  <main class="hk-shell">
    <section class="hk-hero">
      <div class="hk-eyebrow">Portal &middot; Hackathons</div>
      <h1 class="hk-title">Time-boxed <em>builds</em>.</h1>
      <p class="hk-sub">Form a team. Ship in a weekend. Compete for a prize pool, a portfolio piece, and a place on the public leaderboard. Format: open theme, real judges, transparent rubric.</p>
    </section>

    <section class="hk-tabs">
      {TABS.map(t => (
        <a href={t.key === 'all' ? '/portal/hackathons' : `/portal/hackathons?tab=${t.key}`}
           class={`hk-tab ${activeTab === t.key ? 'is-active' : ''}`}>
          {t.label}
        </a>
      ))}
    </section>

    {filtered.length === 0 ? (
      <section class="hk-empty">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        <div class="hk-empty-title">Nothing here yet.</div>
        <div class="hk-empty-sub">Hackathons in this state will show up when scheduled. Check back, or browse all events.</div>
      </section>
    ) : (
      <section class="hk-grid">
        {filtered.map((h: any) => (
          <a href={`/portal/hackathons/${h.slug}`} class="hk-card">
            <div class="hk-card-top">
              <span class={`hk-pill ${STATUS_TONE[h.status] || 'tone-ink'}`}>{STATUS_LABEL[h.status] || h.status}</span>
              <span class="hk-prize">{fmtPrize(h.prize_pool_chf)}</span>
            </div>
            <h2 class="hk-card-title">{h.title}</h2>
            {h.tagline ? <p class="hk-card-tagline">{h.tagline}</p> : null}
            <div class="hk-meta">
              <div class="hk-meta-row">
                <span class="hk-meta-key">Starts</span>
                <span class="hk-meta-val">{fmtDate(h.starts_at)}</span>
              </div>
              <div class="hk-meta-row">
                <span class="hk-meta-key">Ends</span>
                <span class="hk-meta-val">{fmtDate(h.ends_at)}</span>
              </div>
              <div class="hk-meta-row">
                <span class="hk-meta-key">Team size</span>
                <span class="hk-meta-val">Up to {h.max_team_size || 4}</span>
              </div>
            </div>
            <div class="hk-card-cta">
              <span>View brief</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </div>
          </a>
        ))}
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .hk-shell { max-width: 1180px; margin: 0 auto; padding: 56px 24px 96px; color: #0E0B08; }
  .hk-hero { padding: 24px 0 40px; border-bottom: 1px solid rgba(14,11,8,0.10); }
  .hk-eyebrow { font-family: 'Geist Mono', 'SF Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #FF4F00; margin-bottom: 18px; }
  .hk-title { font-family: 'Fraunces', 'Cormorant Garamond', Georgia, serif; font-weight: 400; font-size: clamp(48px, 7vw, 88px); line-height: 0.98; letter-spacing: -0.02em; margin: 0 0 18px; color: #0E0B08; }
  .hk-title em { font-style: italic; color: #FF4F00; font-weight: 400; }
  .hk-sub { font-family: 'DM Sans', system-ui, sans-serif; font-size: 17px; line-height: 1.55; color: #2E2520; max-width: 640px; margin: 0; }

  .hk-tabs { display: flex; gap: 4px; padding: 32px 0 28px; border-bottom: 1px solid rgba(14,11,8,0.10); margin-bottom: 36px; overflow-x: auto; }
  .hk-tab { font-family: 'Geist Mono', 'SF Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #7A6F68; padding: 10px 16px; border-radius: 10px; text-decoration: none; transition: all 0.18s ease; white-space: nowrap; border: 1px solid transparent; }
  .hk-tab:hover { color: #0E0B08; background: rgba(14,11,8,0.04); }
  .hk-tab.is-active { color: #0E0B08; background: #FFF3EE; border-color: #FFD4BC; }

  .hk-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px; }
  .hk-card { display: flex; flex-direction: column; gap: 14px; background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 16px; padding: 24px; text-decoration: none; color: inherit; transition: all 0.18s ease; min-height: 280px; }
  .hk-card:hover { border-color: rgba(14,11,8,0.30); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(14,11,8,0.06); }

  .hk-card-top { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .hk-pill { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; padding: 5px 10px; border-radius: 999px; border: 1px solid; white-space: nowrap; }
  .tone-ink { color: #2E2520; border-color: rgba(14,11,8,0.20); background: #FAF8F5; }
  .tone-leaf { color: #1A6B35; border-color: rgba(26,107,53,0.25); background: rgba(26,107,53,0.06); }
  .tone-burn { color: #FF4F00; border-color: #FFD4BC; background: #FFF3EE; }
  .tone-mute { color: #7A6F68; border-color: rgba(14,11,8,0.10); background: #FAF8F5; }
  .hk-prize { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.04em; color: #1A6B35; font-weight: 500; }

  .hk-card-title { font-family: 'Fraunces', 'Cormorant Garamond', Georgia, serif; font-weight: 400; font-size: 24px; line-height: 1.15; letter-spacing: -0.01em; margin: 0; color: #0E0B08; }
  .hk-card-tagline { font-family: 'DM Sans', system-ui, sans-serif; font-size: 14px; line-height: 1.5; color: #2E2520; margin: 0; }

  .hk-meta { display: flex; flex-direction: column; gap: 6px; padding: 12px 0; border-top: 1px solid rgba(14,11,8,0.08); border-bottom: 1px solid rgba(14,11,8,0.08); margin-top: auto; }
  .hk-meta-row { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; }
  .hk-meta-key { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: #7A6F68; }
  .hk-meta-val { font-family: 'DM Sans', system-ui, sans-serif; font-size: 13px; color: #2E2520; text-align: right; }

  .hk-card-cta { display: flex; align-items: center; gap: 6px; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #FF4F00; }

  .hk-empty { display: flex; flex-direction: column; align-items: center; gap: 12px; padding: 80px 24px; text-align: center; border: 1px dashed rgba(14,11,8,0.20); border-radius: 16px; color: #7A6F68; }
  .hk-empty-title { font-family: 'Fraunces', serif; font-size: 22px; color: #0E0B08; }
  .hk-empty-sub { font-family: 'DM Sans', system-ui, sans-serif; font-size: 14px; max-width: 360px; }
</style>
</content>
</invoke>