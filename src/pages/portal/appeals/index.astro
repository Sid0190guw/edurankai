---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { ensureAppealsSchema, APPEAL_KINDS } from '@/lib/application-appeals';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/appeals'));
await ensureAppealsSchema();
function rowsOf(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

const mine = rowsOf(await db.execute(sql`
  SELECT aa.*, a.role_title_snapshot FROM application_appeals aa
  LEFT JOIN applications a ON aa.application_id = a.id
  WHERE aa.user_id = ${user.id} ORDER BY aa.created_at DESC
`));

function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }); } catch { return ''; } }
---
<BaseLayout title="My appeals · EduRankAI">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← Portal home</a>
  <div class="mt-5 mb-6 flex justify-between items-end flex-wrap gap-3">
    <div>
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">Recruitment</p>
      <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.5rem)] font-semibold text-ink leading-[1.1] mb-1">My appeals</h1>
      <p class="text-[0.9rem] text-ink-soft m-0">{mine.length} on record · responses within 10 business days</p>
    </div>
    <a href="/portal/appeals/new" class="btn-primary">+ New appeal</a>
  </div>
</section>
<section class="px-[5vw] pb-20 max-w-3xl mx-auto">
  {mine.length === 0 ? (
    <div class="bg-cream-2/60 border border-ink/10 rounded-2xl p-8 text-center">
      <p class="text-[0.95rem] text-ink-soft m-0">No appeals on file. If you believe a decision should be reviewed, submit one.</p>
    </div>
  ) : (
    <div class="space-y-3">
      {mine.map((a: any) => {
        const k = (APPEAL_KINDS as any)[a.appeal_kind] || APPEAL_KINDS.other;
        const tone = a.status === 'upheld' ? 'bg-leaf-bg text-leaf border-leaf-border'
          : a.status === 'denied' ? 'bg-burn-pale text-burn border-burn-dim'
          : a.status === 'reviewing' ? 'bg-gold-bg text-gold-deep border-gold-border'
          : 'bg-sky-bg text-sky border-sky-border';
        return (
          <article class="bg-white border border-ink/10 rounded-2xl p-5">
            <div class="flex justify-between flex-wrap gap-2 mb-2">
              <div>
                <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-burn font-bold mb-1">{k.label}</p>
                <p class="font-display text-[1.05rem] font-semibold text-ink m-0">{a.role_title_snapshot || 'Application'}</p>
                <p class="text-[0.75rem] text-ink-soft m-0 mt-1 font-mono">Filed {fmt(a.created_at)}</p>
              </div>
              <span class={`font-mono text-[0.62rem] uppercase tracking-[0.14em] font-bold px-2.5 py-1 rounded-full border ${tone} h-fit`}>{a.status}</span>
            </div>
            <p class="text-[0.85rem] text-ink-2 leading-relaxed m-0 mt-2 line-clamp-3">{a.grounds}</p>
            {a.decision_note && (
              <div class="mt-3 bg-cream-2/60 border-l-2 border-burn rounded-r-lg px-3 py-2">
                <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-burn font-bold m-0 mb-1">Reviewer's decision note</p>
                <p class="text-[0.84rem] text-ink-2 m-0 whitespace-pre-wrap">{a.decision_note}</p>
              </div>
            )}
          </article>
        );
      })}
    </div>
  )}
</section>
</BaseLayout>
