---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { ensureAppealsSchema, APPEAL_KINDS } from '@/lib/application-appeals';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/appeals/new'));

await ensureAppealsSchema();
function rowsOf(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

let okMsg = '', errMsg = '', appealId = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const appId = (fd.get('application_id') as string || '').trim();
    const kind = (fd.get('appeal_kind') as string || 'other').trim();
    const grounds = (fd.get('grounds') as string || '').trim().slice(0, 6000);
    const evidence = (fd.get('new_evidence') as string || '').trim().slice(0, 6000) || null;
    const drive = (fd.get('drive_url') as string || '').trim().slice(0, 1000) || null;
    if (!appId) errMsg = 'Please choose the application you are appealing.';
    else if (grounds.length < 80) errMsg = 'Grounds must be at least 80 characters — specifics matter.';
    else {
      const r = rowsOf(await db.execute(sql`
        INSERT INTO application_appeals (application_id, user_id, appeal_kind, grounds, new_evidence, drive_url)
        VALUES (${appId}, ${user.id}, ${kind}, ${grounds}, ${evidence}, ${drive}) RETURNING id
      `));
      appealId = r[0]?.id || '';
      okMsg = 'Appeal lodged. A senior reviewer will respond inside your portal within 10 business days.';
    }
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 240); }
}

const myApps = rowsOf(await db.execute(sql`
  SELECT a.id, a.role_title_snapshot, a.status FROM applications a
  WHERE a.user_id = ${user.id} ORDER BY a.created_at DESC LIMIT 30
`));
---
<BaseLayout title="Submit an appeal · EduRankAI">
<section class="px-[5vw] pt-10 md:pt-14 pb-6 max-w-3xl mx-auto">
  <a href="/portal" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">← Portal home</a>
  <div class="mt-5 mb-6">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">Recruitment · Appeal</p>
    <h1 class="font-display text-[clamp(1.8rem,4.5vw,2.5rem)] font-semibold text-ink leading-[1.1] mb-3">Submit an appeal</h1>
    <p class="text-[0.95rem] text-ink-2 font-light leading-[1.85]">
      Per <a href="/policy/recruitment" class="text-burn font-semibold underline underline-offset-2">our recruitment policy</a>, decisions on role applications are appealable. A senior reviewer who was not involved in the original decision will read your appeal. We respond inside your portal within 10 business days. Appeals are NOT for fee waivers — those are non-appealable by design.
    </p>
  </div>
</section>

<section class="px-[5vw] pb-20 max-w-3xl mx-auto">

  {okMsg && (
    <div class="bg-leaf-bg border border-leaf-border rounded-2xl px-5 py-5 mb-4">
      <p class="font-display text-[1.05rem] font-semibold text-leaf m-0">{okMsg}</p>
      {appealId && <p class="text-[0.78rem] m-0 mt-2 font-mono text-leaf">Reference: {appealId.slice(0,8)}</p>}
      <a href="/portal/appeals" class="text-leaf font-semibold underline underline-offset-2 text-[0.85rem] inline-block mt-3">Track your appeals →</a>
    </div>
  )}
  {errMsg && <div class="bg-burn-pale border border-burn-dim rounded-xl px-4 py-3 mb-4 text-[0.88rem] text-burn font-semibold">{errMsg}</div>}

  {!okMsg && (
    <form method="POST" class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8 space-y-5">
      <div>
        <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Which application? <span class="text-burn">*</span></label>
        <select name="application_id" required class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink focus:border-burn focus:outline-none">
          <option value="">— Choose —</option>
          {myApps.map((a: any) => <option value={a.id}>{a.role_title_snapshot || 'Application ' + String(a.id).slice(0,8)} · {a.status}</option>)}
        </select>
      </div>
      <div>
        <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Kind of appeal <span class="text-burn">*</span></label>
        <select name="appeal_kind" required class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink focus:border-burn focus:outline-none">
          {Object.entries(APPEAL_KINDS).map(([k, v]) => <option value={k}>{v.label} — {v.description}</option>)}
        </select>
      </div>
      <div>
        <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Grounds for appeal <span class="text-burn">*</span></label>
        <textarea name="grounds" rows="6" required minlength="80" maxlength="6000" placeholder="Specifically: which scoring dimension(s) you contest, which procedural step was missed, what evidence the reviewer did not have. Vague appeals are denied first round." class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink font-body leading-relaxed resize-y focus:border-burn focus:outline-none"></textarea>
        <p class="text-[0.72rem] text-ink-soft mt-1.5 m-0">Minimum 80 characters.</p>
      </div>
      <div>
        <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">New evidence (optional)</label>
        <textarea name="new_evidence" rows="3" maxlength="6000" placeholder="If you have evidence we did not see in the original review, summarise it here." class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink font-body leading-relaxed resize-y focus:border-burn focus:outline-none"></textarea>
      </div>
      <div>
        <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Drive URL (optional)</label>
        <input name="drive_url" type="url" maxlength="1000" placeholder="https://drive.google.com/..." class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink focus:border-burn focus:outline-none" />
      </div>
      <button type="submit" class="btn-primary">Lodge appeal →</button>
    </form>
  )}
</section>
</BaseLayout>
