---
import BaseLayout from '@/layouts/BaseLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
---
<BaseLayout title="Work log (offline) - EduRankAI" description="Log your work even without a connection; it syncs automatically.">
  <section style="padding:40px 20px; max-width:640px; margin:0 auto;">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:6px;">
      <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:#DC5000;margin:0;">Works offline</p>
      <span id="netBadge" class="net off" style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:100px;">…</span>
    </div>
    <h1 style="font-size:26px;font-weight:700;color:#111;margin:0 0 6px;">Work log</h1>
    <p style="font-size:14px;color:#6b7280;margin:0 0 22px;line-height:1.6;">Record what you did — it saves to this device instantly, even with no signal, and syncs to the team automatically when you are back online.</p>

    <form data-offline="worklog" class="wl-card" style="margin-bottom:20px;">
      <label class="wl-l">What did you work on?</label>
      <input name="title" class="wl-i" placeholder="e.g. Visited 3 schools in the district" required />
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div><label class="wl-l">Hours</label><input name="hours" class="wl-i" inputmode="decimal" placeholder="2.5" /></div>
        <div><label class="wl-l">Date</label><input name="date" class="wl-i" type="date" /></div>
      </div>
      <label class="wl-l">Notes</label>
      <textarea name="notes" class="wl-i" rows="3" placeholder="Anything worth recording…"></textarea>
      <button type="submit" class="wl-btn">Save entry</button>
      <p id="wlSaved" class="wl-ok"></p>
    </form>

    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
      <h2 style="font-size:1rem;font-weight:700;color:#111;margin:0;">Your entries</h2>
      <span id="wlPending" style="font-size:12px;color:#9ca3af;"></span>
    </div>
    <div id="wlList"></div>
  </section>

  <style>
    .wl-card { background:#fff; border:1px solid rgba(0,0,0,0.1); border-radius:16px; padding:18px; }
    .wl-l { display:block; font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:#6b7280; margin:10px 0 5px; }
    .wl-i { width:100%; border:1px solid rgba(0,0,0,0.15); border-radius:9px; padding:10px 12px; font-size:15px; outline:none; background:#fafaf9; }
    .wl-btn { margin-top:14px; width:100%; background:#DC5000; color:#fff; border:none; font-size:15px; font-weight:700; padding:12px; border-radius:9px; cursor:pointer; }
    .wl-ok { color:#1a7f43; font-size:13px; margin:8px 0 0; min-height:1em; }
    .net.on { background:#e7f6ec; color:#1a7f43; }
    .net.off { background:#fef2f2; color:#b91c1c; }
    .wl-entry { background:#fff; border:1px solid rgba(0,0,0,0.1); border-radius:12px; padding:12px 14px; margin-bottom:10px; }
    .wl-entry h3 { font-size:14px; font-weight:700; color:#111; margin:0 0 3px; }
    .wl-entry p { font-size:13px; color:#6b7280; margin:0; }
    .wl-tag { font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:0.06em; padding:2px 8px; border-radius:100px; }
    .wl-tag.synced { background:#e7f6ec; color:#1a7f43; }
    .wl-tag.pending { background:#fff7ed; color:#c2410c; }
  </style>

  <script src="/offline-sync.js" is:inline></script>
  <script is:inline>
    (function () {
      var listEl = document.getElementById('wlList'), pendEl = document.getElementById('wlPending');
      var badge = document.getElementById('netBadge'), saved = document.getElementById('wlSaved');
      function esc(s) { return (s == null ? '' : String(s)).replace(/[&<>]/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]; }); }
      function setNet() {
        var on = navigator.onLine;
        badge.textContent = on ? 'Online' : 'Offline — saved on this device';
        badge.className = 'net ' + (on ? 'on' : 'off');
      }
      async function render() {
        if (!window.eraOffline) return;
        var recs = await window.eraOffline.records();
        var pending = recs.filter(function (r) { return !r.synced; }).length;
        pendEl.textContent = pending ? (pending + ' waiting to sync') : (recs.length ? 'All synced' : '');
        if (!recs.length) { listEl.innerHTML = '<p style="color:#9ca3af;font-size:14px;">No entries yet.</p>'; return; }
        listEl.innerHTML = recs.map(function (r) {
          var d = r.data || {};
          var meta = [d.date, d.hours ? (d.hours + ' h') : ''].filter(Boolean).join(' · ');
          return '<div class="wl-entry"><div style="display:flex;justify-content:space-between;gap:10px;align-items:flex-start;">' +
            '<div style="min-width:0;"><h3>' + esc(d.title || '(untitled)') + '</h3>' +
            (meta ? '<p>' + esc(meta) + '</p>' : '') +
            (d.notes ? '<p style="margin-top:4px;">' + esc(d.notes) + '</p>' : '') + '</div>' +
            '<span class="wl-tag ' + (r.synced ? 'synced' : 'pending') + '">' + (r.synced ? 'Synced' : 'On device') + '</span>' +
            '</div></div>';
        }).join('');
      }
      setNet(); render();
      window.addEventListener('online', function () { setNet(); if (window.eraOffline) window.eraOffline.flush(); });
      window.addEventListener('offline', setNet);
      document.addEventListener('era-offline-saved', function () { saved.textContent = 'Saved to this device.'; setTimeout(function () { saved.textContent = ''; }, 2000); render(); });
      document.addEventListener('era-offline-synced', render);
    })();
  </script>
</BaseLayout>
