---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { applications, applicationMessages } from '@/lib/db/schema';
import { eq, and, asc } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
if (user.role !== 'applicant') return Astro.redirect('/admin');

const { id } = Astro.params;
if (!id) return Astro.redirect('/portal');

let errorMsg = '';
let successMsg = '';

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const body = (fd.get('body') as string || '').trim();

  if (!body) {
    errorMsg = 'Please write a message before sending.';
  } else if (body.length > 5000) {
    errorMsg = 'Message is too long. Please keep it under 5000 characters.';
  } else {
    try {
      const owns = await db.select({ id: applications.id }).from(applications)
        .where(and(eq(applications.id, id), eq(applications.applicantUserId, user.id))).limit(1);
      if (owns.length === 0) {
        return Astro.redirect('/portal');
      }
      const senderName = user.name || (user.email || 'Applicant');
      await db.insert(applicationMessages).values({
        applicationId: id,
        senderUserId: user.id,
        senderRole: 'applicant',
        senderName: senderName,
        body: body,
        isSystem: false
      });
      await db.update(applications).set({ updatedAt: new Date() }).where(eq(applications.id, id));
      return Astro.redirect('/portal/applications/' + id + '?sent=1');
    } catch (err: any) {
      errorMsg = 'Failed to send: ' + (err.message || 'Unknown error');
    }
  }
}

const found = await db.select().from(applications)
  .where(and(eq(applications.id, id), eq(applications.applicantUserId, user.id))).limit(1);
if (found.length === 0) return Astro.redirect('/portal');
const app = found[0];

const messages = await db.select().from(applicationMessages)
  .where(eq(applicationMessages.applicationId, id))
  .orderBy(asc(applicationMessages.createdAt));

const url = new URL(Astro.request.url);
if (url.searchParams.get('sent') === '1') successMsg = 'Message sent. Our team will respond soon.';

const shortId = id.substring(0, 8).toUpperCase();
const submittedDate = new Date(app.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });

const STAGE_LABELS: Record<string, string> = {
  submitted: 'Submitted',
  reviewing: 'Under Review',
  task_sent: 'Task / Walkthrough',
  interview: 'Interview',
  offer: 'Offer Extended',
  hired: 'Hired',
  rejected: 'Closed',
  withdrawn: 'Withdrawn'
};

const STATUS_COLORS: Record<string, string> = {
  submitted: 'bg-sky-bg text-sky border-sky-border',
  reviewing: 'bg-burn-pale text-burn border-burn-dim',
  task_sent: 'bg-gold-bg text-gold-deep border-gold-border',
  interview: 'bg-plum-bg text-plum border-plum-border',
  offer: 'bg-leaf-bg text-leaf border-leaf-border',
  hired: 'bg-leaf-bg text-leaf border-leaf-border',
  rejected: 'bg-ink/5 text-ink-soft border-ink/15',
  withdrawn: 'bg-ink/5 text-ink-soft border-ink/15'
};

const statusClass = STATUS_COLORS[app.status] || 'bg-cream-2 text-ink-soft border-ink/15';

function formatTime(d: Date): string {
  return new Date(d).toLocaleString('en-IN', { day: 'numeric', month: 'short', hour: 'numeric', minute: '2-digit' });
}
---
<BaseLayout title={'Application ' + shortId + ' - EduRankAI'} description="Conversation with the EduRankAI team about your application.">
  <section class="px-[5vw] py-8 md:py-10 max-w-3xl mx-auto">

    <div class="mb-4">
      <a href="/portal" class="text-[0.82rem] text-ink-soft hover:text-burn font-mono">Back to my applications</a>
    </div>

    <div class="bg-white border border-ink/10 rounded-2xl p-5 md:p-6 mb-6">
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-3">
        <div>
          <p class="font-mono text-[0.7rem] text-ink-soft mb-1">{shortId} - Applied {submittedDate}</p>
          <h1 class="font-display text-[1.5rem] font-semibold text-ink leading-tight">{app.roleTitleSnapshot}</h1>
          <p class="text-[0.82rem] text-ink-soft mt-1">{app.departmentSnapshot} - {app.level}</p>
        </div>
        <div>
          <p class="text-[0.62rem] font-mono uppercase tracking-wider text-ink-soft mb-1">Current status</p>
          <span class={'inline-block text-[0.78rem] font-bold uppercase tracking-wider border px-3 py-1 rounded-full ' + statusClass}>
            {STAGE_LABELS[app.status] || app.status}
          </span>
        </div>
      </div>

      {app.scoringFeedback && (
        <div class="bg-sky-bg border border-sky-border rounded-lg p-3.5 mt-4 text-[0.85rem] leading-relaxed">
          <p class="font-semibold text-sky mb-1">Note from the team</p>
          <p class="text-ink-2 whitespace-pre-wrap">{app.scoringFeedback}</p>
        </div>
      )}
    </div>

    <div class="mb-4">
      <h2 class="font-display text-[1.15rem] font-semibold text-ink mb-1">Conversation</h2>
      <p class="text-[0.78rem] text-ink-soft italic">Direct line to our team. We typically reply within 1-2 business days.</p>
    </div>

    {successMsg && (
      <div class="bg-leaf-bg/40 border border-leaf-border text-leaf rounded-lg p-3 mb-4 text-[0.85rem]">{successMsg}</div>
    )}

    {errorMsg && (
      <div style="background:rgba(220,38,38,0.06);border:1px solid rgba(220,38,38,0.25);color:#b91c1c;font-size:0.85rem;padding:11px 14px;border-radius:8px;margin-bottom:14px;">{errorMsg}</div>
    )}

    <div class="bg-white border border-ink/10 rounded-2xl p-4 md:p-5 mb-5">
      {messages.length === 0 ? (
        <div class="text-center py-8">
          <p class="text-[0.88rem] text-ink-soft">No messages yet. Send the first one below to ask a question or share an update.</p>
        </div>
      ) : (
        <div class="flex flex-col gap-3">
          {messages.map((msg) => {
            const isMe = msg.senderRole === 'applicant';
            const isSys = msg.isSystem;
            const bubbleClass = isSys
              ? 'bg-cream-2 border border-ink/10 text-ink-2 text-center italic mx-auto max-w-[80%]'
              : isMe
                ? 'bg-burn text-white ml-auto'
                : 'bg-cream-2 border border-ink/10 text-ink-2';
            const align = isSys ? 'justify-center' : (isMe ? 'justify-end' : 'justify-start');
            return (
              <div class={'flex ' + align}>
                <div class={'rounded-2xl px-4 py-2.5 max-w-[85%] ' + bubbleClass}>
                  {!isSys && (
                    <p class={'text-[0.62rem] font-mono uppercase tracking-wider font-bold mb-1 ' + (isMe ? 'text-white/70' : 'text-ink-soft')}>
                      {isMe ? 'You' : (msg.senderName || 'EduRankAI Team')}
                    </p>
                  )}
                  <p class="text-[0.88rem] leading-relaxed whitespace-pre-wrap">{msg.body}</p>
                  <p class={'text-[0.62rem] font-mono mt-1 ' + (isMe ? 'text-white/60' : 'text-ink-soft')}>{formatTime(msg.createdAt)}</p>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>

    <form method="POST" class="bg-white border border-ink/10 rounded-2xl p-4 md:p-5">
      <label class="block text-[0.68rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Send a message</label>
      <textarea name="body" required rows="4" maxlength="5000" placeholder="Ask a question, share an update, or follow up on a previous message..." class="w-full px-3.5 py-2.5 border border-ink/15 rounded-lg text-[0.9rem] outline-none focus:border-burn bg-cream-2 resize-y leading-relaxed"></textarea>
      <div class="flex items-center justify-between mt-3">
        <p class="text-[0.7rem] text-ink-soft italic">Be specific. Our team reads every message.</p>
        <button type="submit" class="bg-burn hover:bg-burn/90 text-white font-semibold py-2.5 px-5 rounded-lg text-[0.88rem] flex items-center gap-2">
          Send
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </button>
      </div>
    </form>

  </section>
</BaseLayout>

<script is:inline>
  setTimeout(function() {
    window.location.reload();
  }, 30000);
</script>