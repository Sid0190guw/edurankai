---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

let okMsg = '';

// Handle post
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action') as string;
  try {
    if (action === 'post') {
      const body = (fd.get('body') as string || '').trim();
      const category = fd.get('category') as string || 'general';
      const parentId = fd.get('parent_id') as string || null;
      if (body && body.length >= 3) {
        await db.execute(sql`
          INSERT INTO discussions (user_id, body, category, parent_id)
          VALUES (${user.id}, ${body}, ${category}, ${parentId||null})
        `);
        okMsg = 'Posted!';
      }
    } else if (action === 'react') {
      const postId = fd.get('post_id') as string;
      const emoji = fd.get('emoji') as string || 'like';
      await db.execute(sql`
        INSERT INTO discussion_reactions (post_id, user_id, emoji)
        VALUES (${postId}, ${user.id}, ${emoji})
        ON CONFLICT (post_id, user_id) DO UPDATE SET emoji = ${emoji}
      `).catch(() => {});
    }
  } catch(e) {}
  return Astro.redirect('/portal/discussion');
}

const url = new URL(Astro.request.url);
const cat = url.searchParams.get('cat') || 'all';
const viewId = url.searchParams.get('post') || '';

let posts: any[] = [];
let viewPost: any = null;
let replies: any[] = [];

// Ensure discussion tables exist
try {
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS discussions (
      id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
      user_id UUID REFERENCES users(id) ON DELETE CASCADE,
      parent_id UUID REFERENCES discussions(id) ON DELETE CASCADE,
      body TEXT NOT NULL,
      category TEXT DEFAULT 'general',
      is_pinned BOOLEAN DEFAULT false,
      is_deleted BOOLEAN DEFAULT false,
      created_at TIMESTAMPTZ DEFAULT NOW()
    )
  `);
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS discussion_reactions (
      id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
      post_id UUID REFERENCES discussions(id) ON DELETE CASCADE,
      user_id UUID REFERENCES users(id) ON DELETE CASCADE,
      emoji TEXT DEFAULT 'like',
      UNIQUE(post_id, user_id)
    )
  `);
} catch(e) {}

try {
  const catFilter = cat !== 'all' ? sql`AND d.category = ${cat}` : sql``;
  const r = await db.execute(sql`
    SELECT d.*, u.name as author_name, u.role as author_role,
      (SELECT COUNT(*)::int FROM discussions r WHERE r.parent_id = d.id AND r.is_deleted = false) as reply_count,
      (SELECT COUNT(*)::int FROM discussion_reactions WHERE post_id = d.id) as reaction_count
    FROM discussions d JOIN users u ON d.user_id = u.id
    WHERE d.parent_id IS NULL AND d.is_deleted = false ${catFilter}
    ORDER BY d.is_pinned DESC, d.created_at DESC LIMIT 50
  `);
  posts = Array.isArray(r) ? r : (r?.rows || []);
} catch(e) {}

if (viewId) {
  try {
    const r = await db.execute(sql`
      SELECT d.*, u.name as author_name, u.role as author_role FROM discussions d
      JOIN users u ON d.user_id = u.id WHERE d.id = ${viewId} LIMIT 1
    `);
    const rows = Array.isArray(r) ? r : (r?.rows || []);
    viewPost = rows[0] || null;
    const r2 = await db.execute(sql`
      SELECT d.*, u.name as author_name, u.role as author_role,
        (SELECT COUNT(*)::int FROM discussion_reactions WHERE post_id = d.id) as reaction_count
      FROM discussions d JOIN users u ON d.user_id = u.id
      WHERE d.parent_id = ${viewId} AND d.is_deleted = false ORDER BY d.created_at ASC
    `);
    replies = Array.isArray(r2) ? r2 : (r2?.rows || []);
  } catch(e) {}
}

function timeAgo(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const mins = Math.floor(diff/60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins + 'm ago';
  if (mins < 1440) return Math.floor(mins/60) + 'h ago';
  return Math.floor(mins/1440) + 'd ago';
}
const CAT_COLORS: Record<string,string> = { general:'#6e6e78', question:'#60a5fa', feedback:'#10b981', announcement:'#FF7040', help:'#a78bfa', career:'#fbbf24' };
const ROLE_COLOR: Record<string,string> = { super_admin:'#f97316', admin:'#FF4F00', editor:'#a78bfa', applicant:'#60a5fa', hr:'#10b981' };
---
<!doctype html>
<html lang="en" style="background:#08080a;">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"/>
  <title>Discussion - EduRankAI</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    body{background:#08080a;color:#fff;font-family:system-ui,sans-serif;min-height:100vh;padding-bottom:80px;}
    .topbar{background:#0f0f14;border-bottom:1px solid #1a1a1f;padding:0 16px;height:52px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:40;}
    .filters{display:flex;gap:6px;overflow-x:auto;padding:12px 16px;scrollbar-width:none;}
    .filters::-webkit-scrollbar{display:none;}
    .pill{font-size:12px;font-weight:600;padding:6px 14px;border-radius:100px;border:none;cursor:pointer;white-space:nowrap;text-decoration:none;display:inline-block;}
    .pill.active{background:#FF4F00;color:#fff;}
    .pill:not(.active){background:#15151a;color:#8a8a94;border:1px solid #1a1a1f;}
    .post-card{background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;margin:0 12px 10px;overflow:hidden;transition:border-color 0.15s;}
    .post-card:hover{border-color:#2a2a2f;}
    .post-card.pinned{border-color:rgba(255,112,64,0.3);}
    .author-row{display:flex;align-items:center;gap:8px;padding:12px 14px 8px;}
    .avatar{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;flex-shrink:0;}
    .post-body{padding:0 14px 10px;font-size:14px;color:#d8d8de;line-height:1.6;white-space:pre-wrap;word-wrap:break-word;}
    .post-actions{padding:8px 14px;border-top:1px solid #0a0a0c;display:flex;align-items:center;gap:10px;}
    .action-btn{background:none;border:none;color:#6e6e78;font-size:12px;cursor:pointer;display:flex;align-items:center;gap:4px;padding:4px 6px;border-radius:6px;transition:all 0.1s;}
    .action-btn:hover{background:#15151a;color:#fff;}
    .compose-fab{position:fixed;bottom:80px;right:16px;width:52px;height:52px;background:#FF4F00;border-radius:50%;border:none;color:#fff;font-size:24px;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(255,79,0,0.4);z-index:30;}
    .compose-sheet{position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:50;display:none;align-items:flex-end;justify-content:center;}
    .compose-box{background:#0f0f14;border:1px solid #1a1a1f;border-radius:16px 16px 0 0;width:100%;max-width:600px;padding:16px;max-height:90vh;overflow-y:auto;}
    .compose-ta{width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:10px;padding:12px;color:#fff;font-size:14px;font-family:inherit;outline:none;resize:vertical;min-height:100px;line-height:1.5;}
    .compose-ta:focus{border-color:#FF4F00;}
    .bottom-nav{position:fixed;bottom:0;left:0;right:0;background:#0f0f14;border-top:1px solid #1a1a1f;display:flex;z-index:40;padding-bottom:env(safe-area-inset-bottom);}
    .nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8px 4px;text-decoration:none;color:#6e6e78;font-size:10px;gap:3px;border:none;background:none;cursor:pointer;}
    .nav-btn.active{color:#FF7040;}
    .view-header{padding:12px 16px;display:flex;align-items:center;gap:10px;border-bottom:1px solid #1a1a1f;}
  </style>
</head>
<body>
<nav class="topbar">
  <div style="display:flex;align-items:center;gap:10px;">
    <a href="/portal" style="color:#6e6e78;text-decoration:none;display:flex;align-items:center;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    </a>
    <span style="font-size:15px;font-weight:700;color:#fff;">{viewId ? 'Discussion' : 'Community'}</span>
  </div>
  {!viewId && <button onclick="document.getElementById('composeSheet').style.display='flex'" style="background:#FF4F00;border:none;color:#fff;font-size:12px;font-weight:600;padding:6px 12px;border-radius:6px;cursor:pointer;">+ Post</button>}
</nav>

{/* Thread view */}
{viewPost && (
  <div>
    <div style="margin:12px;background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
      <div class="author-row">
        <div class="avatar" style={`background:${(ROLE_COLOR as any)[viewPost.author_role]||'#6e6e78'}22;color:${(ROLE_COLOR as any)[viewPost.author_role]||'#6e6e78'};`}>{viewPost.author_name?.charAt(0).toUpperCase()}</div>
        <div style="flex:1;min-width:0;">
          <p style="font-size:13px;font-weight:600;color:#fff;margin:0;">{viewPost.author_name}</p>
          <p style="font-size:10px;color:#6e6e78;margin:0;">{timeAgo(viewPost.created_at)}</p>
        </div>
        <span style={`font-size:9px;font-weight:600;padding:2px 8px;border-radius:100px;background:${(CAT_COLORS as any)[viewPost.category]||'#6e6e78'}22;color:${(CAT_COLORS as any)[viewPost.category]||'#6e6e78'};`}>{viewPost.category}</span>
      </div>
      <div style="padding:0 14px 14px;font-size:15px;color:#fff;line-height:1.65;white-space:pre-wrap;">{viewPost.body}</div>
    </div>

    {/* Reply composer */}
    <form method="POST" style="margin:0 12px 12px;background:#0f0f14;border:1px solid #1a1a1f;border-radius:12px;overflow:hidden;">
      <input type="hidden" name="action" value="post"/>
      <input type="hidden" name="parent_id" value={viewId}/>
      <input type="hidden" name="category" value={viewPost.category}/>
      <textarea name="body" placeholder="Write a reply..." rows="3" style="width:100%;background:transparent;border:none;padding:12px 14px;color:#fff;font-size:13px;font-family:inherit;outline:none;resize:none;"></textarea>
      <div style="padding:8px 14px;border-top:1px solid #1a1a1f;display:flex;justify-content:flex-end;">
        <button type="submit" style="background:#FF4F00;border:none;color:#fff;font-size:12px;font-weight:600;padding:7px 16px;border-radius:6px;cursor:pointer;">Reply</button>
      </div>
    </form>

    {/* Replies */}
    <div style="padding:0 12px;display:flex;flex-direction:column;gap:8px;">
      <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6e6e78;margin-bottom:4px;">{replies.length} {replies.length === 1 ? 'Reply' : 'Replies'}</p>
      {replies.map((r: any) => (
        <div style="background:#0f0f14;border:1px solid #1a1a1f;border-radius:10px;overflow:hidden;">
          <div class="author-row" style="padding:10px 12px 6px;">
            <div class="avatar" style={`width:28px;height:28px;font-size:11px;background:${(ROLE_COLOR as any)[r.author_role]||'#6e6e78'}22;color:${(ROLE_COLOR as any)[r.author_role]||'#6e6e78'};`}>{r.author_name?.charAt(0).toUpperCase()}</div>
            <div style="flex:1;min-width:0;">
              <p style="font-size:12px;font-weight:600;color:#fff;margin:0;">{r.author_name}</p>
              <p style="font-size:9px;color:#6e6e78;margin:0;">{timeAgo(r.created_at)}</p>
            </div>
          </div>
          <p style="padding:0 12px 10px;font-size:13px;color:#d8d8de;line-height:1.55;white-space:pre-wrap;">{r.body}</p>
        </div>
      ))}
    </div>
  </div>
)}

{/* Posts list */}
{!viewId && (
  <div>
    <div class="filters">
      {['all','general','question','feedback','announcement','help','career'].map(c => (
        <a href={`/portal/discussion?cat=${c}`} class={`pill${cat===c?' active':''}`}>{c.charAt(0).toUpperCase()+c.slice(1)}</a>
      ))}
    </div>

    {posts.length === 0 && (
      <div style="text-align:center;padding:60px 24px;color:#6e6e78;">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#6e6e78" stroke-width="1.5" style="margin-bottom:14px;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        <p style="font-size:15px;font-weight:600;color:#fff;margin-bottom:6px;">No posts yet</p>
        <p style="font-size:13px;">Be the first to post something!</p>
      </div>
    )}

    {posts.map((p: any) => {
      const cc = (CAT_COLORS as any)[p.category] || '#6e6e78';
      const rc = (ROLE_COLOR as any)[p.author_role] || '#6e6e78';
      return (
        <div class={`post-card${p.is_pinned?' pinned':''}`}>
          <div class="author-row">
            <div class="avatar" style={`background:${rc}22;color:${rc};`}>{p.author_name?.charAt(0).toUpperCase()}</div>
            <div style="flex:1;min-width:0;">
              <p style="font-size:13px;font-weight:600;color:#fff;margin:0;">{p.author_name}</p>
              <p style="font-size:10px;color:#6e6e78;margin:0;">{timeAgo(p.created_at)}</p>
            </div>
            <div style="display:flex;align-items:center;gap:6px;flex-shrink:0;">
              {p.is_pinned && <span style="font-size:9px;background:rgba(255,112,64,0.15);color:#FF7040;padding:1px 6px;border-radius:4px;">Pinned</span>}
              <span style={`font-size:9px;font-weight:600;padding:2px 7px;border-radius:100px;background:${cc}22;color:${cc};`}>{p.category}</span>
            </div>
          </div>
          <div class="post-body">{p.body.length > 280 ? p.body.substring(0,280) + '...' : p.body}</div>
          <div class="post-actions">
            <a href={`/portal/discussion?post=${p.id}`} class="action-btn" style="text-decoration:none;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              {p.reply_count || 0}
            </a>
            <form method="POST" style="display:contents;">
              <input type="hidden" name="action" value="react"/>
              <input type="hidden" name="post_id" value={p.id}/>
              <input type="hidden" name="emoji" value="like"/>
              <button type="submit" class="action-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                {p.reaction_count || 0}
              </button>
            </form>
            <a href={`/portal/discussion?post=${p.id}`} class="action-btn" style="text-decoration:none;margin-left:auto;font-size:11px;">
              View thread
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          </div>
        </div>
      );
    })}
  </div>
)}

{/* Compose sheet */}
<div id="composeSheet" class="compose-sheet" onclick="if(event.target===this)this.style.display='none'">
  <div class="compose-box">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
      <h2 style="font-size:15px;font-weight:700;color:#fff;margin:0;">New Post</h2>
      <button onclick="document.getElementById('composeSheet').style.display='none'" style="background:#1a1a1f;border:none;color:#8a8a94;width:28px;height:28px;border-radius:6px;font-size:18px;cursor:pointer;">&times;</button>
    </div>
    <form method="POST">
      <input type="hidden" name="action" value="post"/>
      <div style="margin-bottom:10px;">
        <select name="category" style="width:100%;background:#15151a;border:1px solid #1a1a1f;border-radius:8px;padding:9px 12px;color:#fff;font-size:13px;outline:none;margin-bottom:10px;">
          <option value="general">General</option>
          <option value="question">Question</option>
          <option value="feedback">Feedback</option>
          <option value="help">Help / Support</option>
          <option value="career">Career</option>
          <option value="announcement">Announcement</option>
        </select>
        <textarea name="body" class="compose-ta" placeholder="What's on your mind? Share with the community..." required></textarea>
      </div>
      <button type="submit" style="width:100%;background:#FF4F00;border:none;color:#fff;font-weight:600;font-size:14px;padding:12px;border-radius:10px;cursor:pointer;">Post to Community</button>
    </form>
  </div>
</div>

<!-- Bottom nav -->
<nav class="bottom-nav">
  <a href="/portal" class="nav-btn">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
    Home
  </a>
  <a href="/portal/discussion" class="nav-btn active">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    Community
  </a>
  <a href="/portal/courses" class="nav-btn">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
    Learn
  </a>
  <a href="/portal/enroll-face" class="nav-btn">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    Profile
  </a>
</nav>
</body>
</html>
