---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const { number } = Astro.params;

let cert: any = null;
let course: any = null;
let certUser: any = null;

try {
  const r = await db.execute(sql`
    SELECT c.*, u.name as user_name, u.email as user_email,
      co.title as course_title, co.instructor_name, co.duration_hours, co.category
    FROM training_certificates c
    JOIN users u ON c.user_id = u.id
    JOIN training_courses co ON c.course_id = co.id
    WHERE c.certificate_number = ${number}
    LIMIT 1
  `);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  cert = rows[0] || null;
} catch(e) {}

if (!cert) return Astro.redirect('/portal/courses');

const issuedDate = new Date(cert.issued_at).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day: 'numeric', month: 'long', year: 'numeric' });
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Certificate - {cert.course_title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #f8f6f1; font-family: Georgia, 'Times New Roman', serif; min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding: 24px; }
    .topbar { width: 100%; max-width: 800px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .cert-wrap { width: 100%; max-width: 800px; }
    .cert { background: #fff; border: 1px solid #e5e7eb; border-radius: 16px; padding: 48px; position: relative; overflow: hidden; }
    .cert::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 6px; background: linear-gradient(90deg, #FF4F00, #FF7040, #FF4F00); }
    .cert-border { position: absolute; inset: 12px; border: 1px solid #f3f0eb; border-radius: 10px; pointer-events: none; }
    .cert-logo { font-size: 22px; font-weight: 900; color: #111; font-family: system-ui, sans-serif; letter-spacing: -0.5px; }
    .cert-logo em { font-style: normal; color: #FF4F00; }
    .cert-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.2em; color: #9ca3af; font-family: system-ui; }
    .cert-title { font-size: 36px; font-weight: 700; color: #111; margin: 8px 0 20px; line-height: 1.2; }
    .cert-name { font-size: 32px; color: #FF4F00; font-style: italic; margin: 16px 0; }
    .cert-body { font-size: 16px; color: #374151; line-height: 1.8; margin: 16px 0; }
    .cert-course { font-size: 22px; font-weight: 700; color: #111; margin: 8px 0; }
    .cert-meta { display: flex; gap: 32px; margin: 32px 0 0; padding-top: 24px; border-top: 1px solid #f3f0eb; }
    .cert-meta-item { flex: 1; }
    .cert-meta-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: #9ca3af; font-family: system-ui; margin-bottom: 4px; }
    .cert-meta-value { font-size: 14px; color: #111; font-family: system-ui; }
    .cert-number { font-size: 11px; color: #9ca3af; font-family: monospace; margin-top: 8px; }
    .seal { position: absolute; bottom: 48px; right: 48px; width: 80px; height: 80px; }
    .print-btn { background: #111; color: #fff; border: none; font-size: 13px; font-weight: 600; padding: 9px 18px; border-radius: 8px; cursor: pointer; font-family: system-ui; }
    .share-btn { background: #fff; color: #374151; border: 1px solid #e5e7eb; font-size: 13px; font-weight: 600; padding: 9px 18px; border-radius: 8px; cursor: pointer; font-family: system-ui; }
    @media print {
      body { background: #fff; padding: 0; }
      .topbar { display: none; }
      .cert-wrap { max-width: 100%; }
      .cert { border: none; border-radius: 0; box-shadow: none; }
    }
  </style>
</head>
<body>
  <div class="topbar">
    <a href="/portal/courses" style="font-size:13px;color:#6b7280;text-decoration:none;font-family:system-ui;display:flex;align-items:center;gap:4px;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      Back to courses
    </a>
    <div style="display:flex;gap:8px;">
      <button class="share-btn" onclick="navigator.clipboard.writeText(window.location.href).then(()=>alert('Link copied!'))">Copy link</button>
      <button class="print-btn" onclick="window.print()">Download / Print</button>
    </div>
  </div>

  <div class="cert-wrap">
    <div class="cert">
      <div class="cert-border"></div>

      <!-- Header -->
      <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:32px;">
        <div>
          <div class="cert-logo">EduRank<em>AI</em></div>
          <div style="font-size:11px;color:#9ca3af;font-family:system-ui;margin-top:2px;">Certificate of Completion</div>
        </div>
        <!-- Decorative seal -->
        <svg width="80" height="80" viewBox="0 0 100 100">
          <circle cx="50" cy="50" r="45" fill="none" stroke="#FF4F00" stroke-width="2" stroke-dasharray="4 2"/>
          <circle cx="50" cy="50" r="35" fill="#FF4F00" opacity="0.08"/>
          <text x="50" y="42" text-anchor="middle" font-size="10" fill="#FF4F00" font-family="system-ui" font-weight="700">CERTIFIED</text>
          <text x="50" y="56" text-anchor="middle" font-size="8" fill="#FF7040" font-family="system-ui">EduRankAI</text>
          <polygon points="50,20 53,30 63,30 55,37 58,47 50,41 42,47 45,37 37,30 47,30" fill="#FF4F00" opacity="0.6" transform="scale(0.5) translate(50, 10)"/>
        </svg>
      </div>

      <!-- Body -->
      <div class="cert-label">This is to certify that</div>
      <div class="cert-name">{cert.user_name}</div>
      <div class="cert-body">has successfully completed the course</div>
      <div class="cert-course">{cert.course_title}</div>
      {cert.instructor_name && (
        <div style="font-size:14px;color:#6b7280;margin:8px 0;font-family:system-ui;">Instructed by {cert.instructor_name}</div>
      )}
      <div class="cert-body" style="margin-top:12px;">
        demonstrating dedication to learning and professional development.
      </div>

      <!-- Meta -->
      <div class="cert-meta">
        <div class="cert-meta-item">
          <div class="cert-meta-label">Date Issued</div>
          <div class="cert-meta-value">{issuedDate}</div>
        </div>
        <div class="cert-meta-item">
          <div class="cert-meta-label">Duration</div>
          <div class="cert-meta-value">{cert.duration_hours} hours</div>
        </div>
        <div class="cert-meta-item">
          <div class="cert-meta-label">Category</div>
          <div class="cert-meta-value" style="text-transform:capitalize;">{cert.category}</div>
        </div>
        <div class="cert-meta-item">
          <div class="cert-meta-label">Issued by</div>
          <div class="cert-meta-value">EduRankAI</div>
        </div>
      </div>

      <div class="cert-number">Certificate #{cert.certificate_number} - Verify at edurankai.in/verify/{cert.certificate_number}</div>

      <!-- Signature line -->
      <div style="margin-top:32px;padding-top:20px;border-top:1px solid #f3f0eb;display:flex;justify-content:space-between;align-items:flex-end;">
        <div>
          <div style="width:160px;border-bottom:1px solid #111;margin-bottom:4px;"></div>
          <div style="font-size:12px;color:#6b7280;font-family:system-ui;">EduRankAI Editorial Team</div>
        </div>
        <div style="text-align:right;">
          <div style="font-size:28px;font-weight:900;color:#FF4F00;font-style:italic;">EduRankAI</div>
          <div style="font-size:10px;color:#9ca3af;font-family:system-ui;">The Truth Report on Universities</div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
