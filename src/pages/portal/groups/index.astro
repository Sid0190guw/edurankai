---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ensureCommunitySchema, listStudyGroups, createStudyGroup } from '@/lib/community';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/groups'));

await ensureCommunitySchema();
let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const title = (fd.get('title') as string || '').trim();
    const subject = (fd.get('subject') as string || '').trim();
    const description = (fd.get('description') as string || '').trim();
    const cap = parseInt(fd.get('cap') as string, 10) || 8;
    const meetCadence = (fd.get('meet_cadence') as string || '').trim();
    const meetLink = (fd.get('meet_link') as string || '').trim();
    if (!title || title.length < 6) errMsg = 'Title is too short.';
    else {
      const slug = title.toLowerCase().replace(/[^a-z0-9]+/g, '-').slice(0, 80) + '-' + Math.random().toString(36).slice(2, 6);
      await createStudyGroup({ slug, ownerUserId: user.id, title, subject, description, cap, meetCadence, meetLink });
      okMsg = 'Group created.';
    }
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 240); }
}

const groups = await listStudyGroups({ open: true });
---
<BaseLayout title="Study groups · Portal · EduRankAI" description="Find or create a peer study group around a course or topic.">

<section class="px-[5vw] pt-12 md:pt-16 pb-6 max-w-5xl mx-auto">
  <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">Portal · Study groups</p>
  <div class="flex justify-between items-end flex-wrap gap-3">
    <div>
      <h1 class="font-display text-[clamp(2.2rem,4.5vw,3.4rem)] font-semibold text-ink leading-[1.05]">Find your <em class="italic text-burn font-medium">cohort</em>.</h1>
      <p class="text-[1rem] text-ink-2 font-light leading-[1.85] max-w-xl mt-2">Peer-led study groups. 4-12 members. Set a cadence. Meet on your platform of choice.</p>
    </div>
    <button id="newBtn" class="bg-burn text-white px-5 py-2.5 rounded-xl font-bold font-mono text-[0.75rem] uppercase tracking-wider">+ New group</button>
  </div>
</section>

<section class="px-[5vw] pb-10 max-w-5xl mx-auto">
  {okMsg && <div class="bg-leaf-bg border border-leaf-border rounded-xl px-4 py-3 mb-4 text-[0.92rem] text-leaf font-semibold">{okMsg}</div>}
  {errMsg && <div class="bg-burn-pale border border-burn-dim rounded-xl px-4 py-3 mb-4 text-[0.88rem] text-burn font-semibold">{errMsg}</div>}

  <form id="newForm" method="POST" class="bg-white border border-ink/10 rounded-2xl p-6 mb-6 space-y-3" style="display:none;">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-burn font-bold m-0">New study group</p>
    <input name="title" type="text" required minlength="6" maxlength="200" placeholder="Group title (e.g. Vedic Sanskrit · weekly)" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"/>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <input name="subject" type="text" maxlength="80" placeholder="Subject (e.g. Sanskrit, Quantum)" class="bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"/>
      <input name="cap" type="number" min="2" max="50" value="8" class="bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"/>
    </div>
    <textarea name="description" rows="3" maxlength="2000" placeholder="What you'll cover, who you're looking for..." class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] font-body resize-y"></textarea>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <input name="meet_cadence" type="text" maxlength="80" placeholder="Cadence (e.g. Sundays 19:00 IST)" class="bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"/>
      <input name="meet_link" type="url" placeholder="Meet link (Zoom / Meet / Discord)" class="bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"/>
    </div>
    <button type="submit" class="btn-primary">Create</button>
  </form>

  {groups.length === 0 ? (
    <p class="text-center py-10 text-ink-soft">No open groups yet. Be the first to start one.</p>
  ) : (
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {groups.map((g: any) => (
        <article class="bg-white border border-ink/10 rounded-2xl p-5">
          <p class="text-[0.6rem] font-mono uppercase tracking-[0.14em] text-burn font-bold">{g.subject || 'General'}</p>
          <h2 class="font-display text-[1.2rem] font-semibold text-ink mt-1 leading-tight">{g.title}</h2>
          {g.description && <p class="text-[0.86rem] text-ink-2 mt-2 line-clamp-3 leading-relaxed">{g.description}</p>}
          <div class="flex justify-between text-[0.78rem] text-ink-soft mt-4 pt-3 border-t border-ink/8 font-mono">
            <span>{g.member_count} / {g.cap} members</span>
            <span>{g.meet_cadence || '—'}</span>
          </div>
        </article>
      ))}
    </div>
  )}
</section>

<script is:inline>
  document.getElementById('newBtn').addEventListener('click', function () { var f = document.getElementById('newForm'); f.style.display = f.style.display === 'none' ? 'block' : 'none'; });
</script>
</BaseLayout>
