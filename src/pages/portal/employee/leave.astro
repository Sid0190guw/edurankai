---
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { getBalances, applyLeave, listLeave, cancelLeave, LEAVE_TYPES } from '@/lib/hr-leave';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');
function rowsOf(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
let employee: any = null;
try {
  employee = rowsOf(await db.execute(sql`SELECT * FROM hr_employees WHERE user_id = ${user.id} AND is_active = true LIMIT 1`))[0]
    || rowsOf(await db.execute(sql`SELECT * FROM hr_employees WHERE (work_email = ${user.email} OR personal_email = ${user.email} OR email = ${user.email}) AND is_active = true LIMIT 1`))[0] || null;
} catch (_) {}

let flash = '';
if (Astro.request.method === 'POST' && employee) {
  const fd = await Astro.request.formData();
  if (fd.get('action') === 'apply') {
    const r = await applyLeave(employee.id, fd.get('leave_type') as string, fd.get('start_date') as string, fd.get('end_date') as string, (fd.get('reason') as string) || '');
    flash = r.ok ? `Leave requested (${r.days} day${r.days === 1 ? '' : 's'}) — pending approval.` : (r.error || 'Could not apply.');
  } else if (fd.get('action') === 'cancel') { await cancelLeave(fd.get('id') as string, employee.id); flash = 'Request cancelled.'; }
  return Astro.redirect('/portal/employee/leave?msg=' + encodeURIComponent(flash));
}

const balances = employee ? await getBalances(employee.id) : [];
const history = employee ? await listLeave({ employeeId: employee.id }) : [];
const msg = new URL(Astro.request.url).searchParams.get('msg') || '';
const statusColor: Record<string, string> = { pending: '#d97706', approved: '#059669', rejected: '#dc2626', cancelled: '#6b6255' };
const fmt = (d: any) => new Date(d).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' });
---
<!doctype html>
<html lang="en" style="background:#f6f4ef;">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"/>
  <title>My leave</title><link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <style>
    *{box-sizing:border-box;margin:0;padding:0;} body{background:#f6f4ef;font-family:'Inter Tight',system-ui,sans-serif;min-height:100vh;padding-bottom:40px;color:#1a1510;}
    .top{background:#12100c;height:54px;display:flex;align-items:center;justify-content:space-between;padding:0 16px;position:sticky;top:0;z-index:40;}
    .wrap{max-width:560px;margin:0 auto;padding:16px 14px;}
    .card{background:#fff;border:1px solid #ece4d6;border-radius:16px;padding:18px;margin-bottom:14px;box-shadow:0 10px 30px rgba(26,21,16,.05);}
    .card h3{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:#9a8f7d;font-weight:700;margin:0 0 12px;}
    label{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.1em;text-transform:uppercase;color:#9a8f7d;font-weight:700;display:block;margin:8px 0 4px;}
    input,select,textarea{width:100%;background:#faf7f1;border:1px solid #e6ddcd;border-radius:9px;padding:10px 12px;font-size:14px;font-family:inherit;color:#1a1510;outline:none;}
    input:focus,select:focus,textarea:focus{border-color:#c2410c;}
    .btn{background:#c2410c;color:#fff;border:none;border-radius:10px;padding:11px 18px;font-size:14px;font-weight:600;cursor:pointer;font-family:inherit;width:100%;}
    .row2{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
    .balgrid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
    .bal{background:#faf7f1;border:1px solid #f0e9db;border-radius:12px;padding:12px 14px;}
    .ledger{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid #f2ece0;} .ledger:last-child{border-bottom:none;}
    .pill{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;padding:3px 9px;border-radius:99px;text-transform:uppercase;letter-spacing:.05em;}
  </style>
</head>
<body>
<nav class="top">
  <a href="/portal/employee" style="color:#9a8f7d;text-decoration:none;display:flex;align-items:center;gap:8px;font-size:14px;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>My HR</a>
  <span style="font-size:15px;font-weight:700;color:#fff;font-family:'Fraunces',serif;">Leave</span>
  <span style="font-size:11px;color:#9a8f7d;">{employee?.full_name || user.name}</span>
</nav>
<div class="wrap">
  {msg && <div style="background:rgba(5,150,105,.1);border:1px solid rgba(5,150,105,.3);color:#065f46;border-radius:10px;padding:11px 14px;font-size:13px;margin-bottom:14px;">{msg}</div>}
  {!employee && (<div class="card" style="text-align:center;padding:34px;"><p style="font-weight:600;">No employee profile linked</p></div>)}
  {employee && (<div>
    <div class="card"><h3>Leave balance · {new Date().getFullYear()}</h3>
      <div class="balgrid">{balances.filter((b: any) => b.allowance > 0).map((b: any) => (
        <div class="bal"><div style="font-family:'Fraunces',serif;font-size:26px;font-weight:600;color:#1a1510;">{b.remaining}</div>
          <div style="font-size:11.5px;color:#6b6255;">{b.name} left <span style="color:#9a8f7d;">· {b.used} used{b.pending ? ', ' + b.pending + ' pending' : ''}</span></div></div>
      ))}</div>
    </div>

    <div class="card"><h3>Apply for leave</h3>
      <form method="POST">
        <input type="hidden" name="action" value="apply"/>
        <label>Type</label>
        <select name="leave_type" required>{LEAVE_TYPES.map((t: any) => (<option value={t.id}>{t.name}{t.allowance ? '' : ' (no allowance)'}</option>))}</select>
        <div class="row2"><div><label>From</label><input name="start_date" type="date" required/></div><div><label>To</label><input name="end_date" type="date" required/></div></div>
        <label>Reason</label><textarea name="reason" rows="2" placeholder="Brief reason for your manager"></textarea>
        <button class="btn" style="margin-top:12px;">Request leave</button>
        <p style="font-size:11.5px;color:#9a8f7d;margin-top:8px;line-height:1.5;">Approved by your reporting manager, HR or an administrator. Counts calendar days between the dates (inclusive).</p>
      </form>
    </div>

    <div class="card"><h3>Your requests</h3>
      {history.length === 0 && <p style="font-size:13px;color:#6b6255;">No leave requests yet.</p>}
      {history.map((l: any) => (
        <div class="ledger">
          <div><div style="font-weight:600;text-transform:capitalize;">{l.leave_type} · {l.days}d</div><div style="font-size:11px;color:#9a8f7d;">{fmt(l.start_date)} – {fmt(l.end_date)}{l.reason ? ' · ' + l.reason : ''}</div></div>
          <div style="display:flex;align-items:center;gap:8px;">
            <span class="pill" style={`color:${statusColor[l.status]||'#6b6255'};background:${(statusColor[l.status]||'#6b6255')}18;`}>{l.status}</span>
            {l.status === 'pending' && (<form method="POST" style="margin:0;"><input type="hidden" name="action" value="cancel"/><input type="hidden" name="id" value={l.id}/><button style="background:none;border:none;color:#dc2626;cursor:pointer;font-size:16px;">×</button></form>)}
          </div>
        </div>
      ))}
    </div>
  </div>)}
</div>
</body>
</html>
