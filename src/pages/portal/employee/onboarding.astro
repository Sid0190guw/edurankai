---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/employee/onboarding'));

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }
const emp: any = rows(await db.execute(sql`SELECT * FROM hr_employees WHERE user_id = ${user.id} OR lower(personal_email) = ${(user.email || '').toLowerCase()} OR lower(email) = ${(user.email || '').toLowerCase()} LIMIT 1`))[0];
if (!emp) return Astro.redirect('/portal');

let msg = '';
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const bankName = (fd.get('bank_name') as string || '').trim() || null;
  const bankAcc = (fd.get('bank_account_number') as string || '').trim() || null;
  const bankIfsc = (fd.get('bank_ifsc') as string || '').trim().toUpperCase() || null;
  const bankBranch = (fd.get('bank_branch') as string || '').trim() || null;
  const govtIdType = (fd.get('govt_id_type') as string || '').trim() || null;
  const govtIdNumber = (fd.get('govt_id_number') as string || '').trim().toUpperCase() || null;
  const govtIdDoc = (fd.get('govt_id_doc_url') as string || '').trim() || null;
  const nocDoc = (fd.get('noc_doc_url') as string || '').trim() || null;
  const pan = (fd.get('pan_number') as string || '').trim().toUpperCase() || null;
  const emergencyName = (fd.get('emergency_contact_name') as string || '').trim() || null;
  const emergencyPhone = (fd.get('emergency_contact_phone') as string || '').trim() || null;

  // Every onboarding field is OPTIONAL now. The employee can submit what they
  // have; HR fills in or follows up on the rest. This avoids bouncing a new
  // hire on day one because their ID upload didn't pass or the bank app was
  // glitchy. Identity verification is treated like the 2FA scan elsewhere —
  // we never block on missing documents.
  await db.execute(sql`
    UPDATE hr_employees SET
      bank_name = COALESCE(${bankName}, bank_name),
      bank_account_number = COALESCE(${bankAcc}, bank_account_number),
      bank_ifsc = COALESCE(${bankIfsc}, bank_ifsc),
      bank_branch = COALESCE(${bankBranch}, bank_branch),
      govt_id_type = COALESCE(${govtIdType}, govt_id_type),
      govt_id_number = COALESCE(${govtIdNumber}, govt_id_number),
      govt_id_doc_url = COALESCE(${govtIdDoc}, govt_id_doc_url),
      noc_doc_url = COALESCE(${nocDoc}, noc_doc_url),
      pan_number = COALESCE(${pan}, pan_number),
      emergency_contact_name = COALESCE(${emergencyName}, emergency_contact_name),
      emergency_contact_phone = COALESCE(${emergencyPhone}, emergency_contact_phone),
      onboarding_status = 'submitted', onboarding_submitted_at = NOW(), updated_at = NOW()
    WHERE id = ${emp.id}
  `);
  emp.onboarding_status = 'submitted';
  msg = 'submitted';
}

const done = emp.onboarding_status === 'submitted' || emp.onboarding_status === 'verified';
---
<BaseLayout title="Employee onboarding - EduRankAI" description="Complete your employee onboarding.">
  <section class="px-[5vw] py-10 md:py-14 max-w-2xl mx-auto">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">Welcome aboard</p>
    <h1 class="font-display text-[clamp(1.7rem,4.5vw,2.4rem)] font-semibold text-ink leading-tight mb-2">Employee onboarding</h1>
    <p class="text-[0.92rem] text-ink-soft mb-6">Hi <strong class="text-ink">{emp.full_name}</strong> — your offer is accepted. Fill in what you have right now. Every field below is <strong>optional</strong>; you can come back and update anything later, and HR will follow up directly for anything missing. We never block your start on a document.</p>

    {done ? (
      <div class="bg-leaf-bg/40 border border-leaf-border rounded-2xl p-6">
        <p class="font-semibold text-leaf mb-1">Onboarding submitted</p>
        <p class="text-[0.9rem] text-ink-2">Thank you. HR will verify your details. You can update them by contacting <a href="mailto:hr@edurankai.in" class="text-burn hover:underline">hr@edurankai.in</a>.</p>
        <a href="/portal/employee" class="inline-block mt-4 bg-ink text-white font-semibold py-2.5 px-5 rounded-lg text-[0.88rem] no-underline">Go to employee portal</a>
      </div>
    ) : (
      <form method="POST" id="onbForm" class="flex flex-col gap-5 bg-white border border-ink/10 rounded-2xl p-5 md:p-6">
        {msg && msg !== 'submitted' && <div class="bg-red-500/10 border border-red-500/30 text-red-700 rounded-lg p-3 text-[0.85rem]">{msg}</div>}

        <div>
          <p class="text-[0.7rem] font-bold uppercase tracking-wider text-burn mb-2">Banking (for payroll)</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <input name="bank_name" placeholder="Bank name" class="onbi" />
            <input name="bank_branch" placeholder="Branch" class="onbi" />
            <input name="bank_account_number" required placeholder="Account number *" class="onbi" />
            <input name="bank_ifsc" required placeholder="IFSC / SWIFT *" class="onbi" />
          </div>
        </div>

        <div>
          <p class="text-[0.7rem] font-bold uppercase tracking-wider text-burn mb-2">Government identity</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <select name="govt_id_type" class="onbi">
              <option value="aadhaar">Aadhaar</option><option value="pan">PAN</option><option value="passport">Passport</option><option value="voter">Voter ID</option><option value="driving">Driving Licence</option><option value="other">Other</option>
            </select>
            <input name="govt_id_number" placeholder="ID number" class="onbi" />
            <input name="pan_number" placeholder="PAN (for tax)" class="onbi" />
          </div>
          <div class="mt-3">
            <label class="block text-[0.72rem] text-ink-soft mb-1">Upload government ID (image or PDF)</label>
            <input type="file" id="govtFile" accept="image/png,image/jpeg,image/webp,application/pdf,.png,.jpg,.jpeg,.webp,.pdf" class="block w-full text-[0.82rem]" />
            <input type="hidden" name="govt_id_doc_url" id="govtUrl" />
            <span id="govtStatus" class="text-[0.72rem] text-ink-soft"></span>
          </div>
        </div>

        <div>
          <p class="text-[0.7rem] font-bold uppercase tracking-wider text-burn mb-2">NOC / relieving (if applicable)</p>
          <input type="file" id="nocFile" accept="image/png,image/jpeg,image/webp,application/pdf,.png,.jpg,.jpeg,.webp,.pdf" class="block w-full text-[0.82rem]" />
          <input type="hidden" name="noc_doc_url" id="nocUrl" />
          <span id="nocStatus" class="text-[0.72rem] text-ink-soft"></span>
        </div>

        <div>
          <p class="text-[0.7rem] font-bold uppercase tracking-wider text-burn mb-2">Emergency contact</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <input name="emergency_contact_name" placeholder="Name" class="onbi" />
            <input name="emergency_contact_phone" placeholder="Phone" class="onbi" />
          </div>
        </div>

        <button type="submit" id="onbSubmit" class="bg-burn hover:bg-burn/90 text-white font-semibold py-3 rounded-lg text-[0.92rem]">Submit onboarding</button>
      </form>
    )}
  </section>

  <style>.onbi { width:100%;padding:9px 12px;background:var(--cream-2,#f6f3ec);border:1px solid rgba(0,0,0,0.12);border-radius:8px;font-size:0.9rem;outline:none; } .onbi:focus { border-color:#FF4F00; }</style>
  <script is:inline>
    (function () {
      // Client-side image compression — modern phone ID photos are 5-10 MB
      // and Vercel Hobby caps request bodies at 4.5 MB. We shrink any image
      // to a max edge of 1800 px and re-encode as JPEG @ 0.85 quality before
      // upload. PDFs pass through untouched. This brings 99% of uploads
      // well under the cap without losing readability of the ID text.
      function compressImageIfNeeded(file) {
        return new Promise(function (resolve) {
          var isImage = file.type && file.type.indexOf('image/') === 0;
          if (!isImage) return resolve(file);
          // Skip compression if already small enough.
          if (file.size <= 3 * 1024 * 1024) return resolve(file);
          var img = new Image();
          var reader = new FileReader();
          reader.onload = function (e) { img.src = e.target.result; };
          img.onload = function () {
            var max = 1800;
            var w = img.width, h = img.height;
            if (w > max || h > max) {
              if (w > h) { h = Math.round(h * (max / w)); w = max; }
              else { w = Math.round(w * (max / h)); h = max; }
            }
            var canvas = document.createElement('canvas');
            canvas.width = w; canvas.height = h;
            var ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0, w, h);
            canvas.toBlob(function (blob) {
              if (!blob) return resolve(file);
              var compressed = new File([blob], file.name.replace(/\.(png|webp|heic|heif)$/i, '.jpg'), { type: 'image/jpeg' });
              resolve(compressed.size < file.size ? compressed : file);
            }, 'image/jpeg', 0.85);
          };
          img.onerror = function () { resolve(file); };
          reader.readAsDataURL(file);
        });
      }

      function wire(fileId, urlId, statusId) {
        var f = document.getElementById(fileId); if (!f) return;
        f.addEventListener('change', function () {
          var file = f.files && f.files[0]; if (!file) return;
          var st = document.getElementById(statusId);
          st.textContent = 'Preparing...'; st.style.color = '';
          compressImageIfNeeded(file).then(function (out) {
            var note = (out !== file) ? ' (compressed from ' + Math.round(file.size / 1024) + ' KB to ' + Math.round(out.size / 1024) + ' KB)' : '';
            st.textContent = 'Uploading' + note + '...';
            var fd = new FormData(); fd.append('file', out);
            fetch('/api/uploads/employee-doc', { method: 'POST', credentials: 'same-origin', body: fd })
              .then(function (r) { return r.json(); }).then(function (d) {
                if (d.ok) { document.getElementById(urlId).value = d.url; st.textContent = 'Uploaded.' + note; st.style.color = '#15803d'; }
                else { st.textContent = d.error || 'Upload failed'; st.style.color = '#b91c1c'; }
              }).catch(function () { st.textContent = 'Network error'; st.style.color = '#b91c1c'; });
          });
        });
      }
      wire('govtFile', 'govtUrl', 'govtStatus');
      wire('nocFile', 'nocUrl', 'nocStatus');
      // No blocking submit handler. Every field is optional — the form
      // submits whatever the employee has filled in. HR follows up on the
      // rest.
    })();
  </script>
</BaseLayout>
