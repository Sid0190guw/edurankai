---
import BaseLayout from '@/layouts/BaseLayout.astro';
const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/wellbeing'));
const firstName = (user.name || '').split(' ')[0] || 'there';
---
<BaseLayout title="Wellbeing · EduRankAI" description="Your focus + wellbeing companion. Pomodoro focus timer, breathing pacer, guided desk exercises, hydration and meal reminders, and a focus-streak tracker — all working in your browser.">

<style>
  body { background: #FAF8F5; color: #0E0B08; }
  .wb-wrap { max-width: 1180px; margin: 0 auto; padding: 36px 5vw 90px; }
  .wb-eye { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #1A6B35; font-weight: 700; }
  .wb-h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(34px, 5vw, 54px); font-weight: 600; letter-spacing: -0.03em; margin: 8px 0 8px; line-height: 1.02; }
  .wb-h1 em { color: #1A6B35; font-style: italic; font-weight: 500; }
  .wb-sub { font-size: 16px; color: #2E2520; max-width: 640px; line-height: 1.6; }

  .wb-grid { display: grid; grid-template-columns: 1.3fr 1fr; gap: 18px; margin-top: 28px; }
  @media (max-width: 880px) { .wb-grid { grid-template-columns: 1fr; } }
  .wb-card { background: #fff; border: 1px solid rgba(14,11,8,0.10); border-radius: 18px; padding: 24px; }
  .wb-card h2 { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: #1A6B35; font-weight: 700; margin: 0 0 6px; }
  .wb-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 600; margin: 2px 0 14px; letter-spacing: -0.01em; }

  /* Focus timer */
  .wb-timer { display: flex; flex-direction: column; align-items: center; }
  .wb-ring { position: relative; width: 230px; height: 230px; }
  .wb-ring svg { transform: rotate(-90deg); }
  .wb-ring-track { fill: none; stroke: #EBE6DA; stroke-width: 14; }
  .wb-ring-fill { fill: none; stroke: #1A6B35; stroke-width: 14; stroke-linecap: round; transition: stroke-dashoffset 0.4s linear; }
  .wb-ring.break .wb-ring-fill { stroke: #FF4F00; }
  .wb-ring-label { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .wb-ring-time { font-family: 'Cormorant Garamond', serif; font-size: 52px; font-weight: 600; line-height: 1; letter-spacing: -0.02em; }
  .wb-ring-phase { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: #7A6F68; margin-top: 6px; font-weight: 700; }
  .wb-timer-ctrls { display: flex; gap: 8px; margin-top: 20px; flex-wrap: wrap; justify-content: center; }
  .wb-btn { background: #1A6B35; color: #fff; border: none; padding: 11px 22px; border-radius: 10px; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 700; cursor: pointer; }
  .wb-btn.ghost { background: transparent; border: 1px solid rgba(14,11,8,0.15); color: #0E0B08; }
  .wb-btn.burn { background: #FF4F00; }
  .wb-timer-set { display: flex; gap: 10px; margin-top: 16px; flex-wrap: wrap; justify-content: center; font-family: 'Geist Mono', monospace; font-size: 11px; color: #7A6F68; }
  .wb-timer-set label { display: flex; align-items: center; gap: 6px; }
  .wb-timer-set input { width: 52px; background: #FAF8F5; border: 1px solid rgba(14,11,8,0.15); padding: 5px 8px; border-radius: 6px; font-family: inherit; font-size: 12px; text-align: center; }

  /* Stats */
  .wb-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
  .wb-stat { background: #FAF8F5; border: 1px solid rgba(14,11,8,0.08); border-radius: 12px; padding: 14px; text-align: center; }
  .wb-stat-v { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 600; line-height: 1; color: #1A6B35; }
  .wb-stat-l { font-family: 'Geist Mono', monospace; font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase; color: #7A6F68; margin-top: 5px; font-weight: 700; }

  /* Breathing */
  .wb-breath { display: flex; flex-direction: column; align-items: center; }
  .wb-breath-circle { width: 150px; height: 150px; border-radius: 50%; background: radial-gradient(circle, #86efac, #1A6B35); transition: transform 4s ease-in-out; display: flex; align-items: center; justify-content: center; color: #fff; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 700; }
  .wb-breath-phase { font-family: 'Cormorant Garamond', serif; font-size: 22px; margin-top: 16px; color: #0E0B08; }

  /* Exercises */
  .wb-ex-list { display: flex; flex-direction: column; gap: 8px; }
  .wb-ex { display: flex; gap: 12px; align-items: center; padding: 12px 14px; background: #FAF8F5; border: 1px solid rgba(14,11,8,0.08); border-radius: 12px; cursor: pointer; }
  .wb-ex:hover { border-color: #1A6B35; }
  .wb-ex-ic { width: 36px; height: 36px; border-radius: 9px; background: #EBF5EF; color: #1A6B35; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .wb-ex-t { font-weight: 700; font-size: 14px; }
  .wb-ex-d { font-size: 12px; color: #7A6F68; }

  /* Reminders */
  .wb-rem-row { display: flex; justify-content: space-between; align-items: center; padding: 11px 0; border-bottom: 1px solid rgba(14,11,8,0.06); }
  .wb-rem-row:last-child { border-bottom: none; }
  .wb-rem-l { font-size: 14px; }
  .wb-rem-l small { display: block; color: #7A6F68; font-size: 11px; font-family: 'Geist Mono', monospace; margin-top: 2px; }
  .wb-switch { width: 42px; height: 24px; border-radius: 100px; background: #EBE6DA; position: relative; cursor: pointer; transition: background .15s; flex-shrink: 0; }
  .wb-switch.on { background: #1A6B35; }
  .wb-switch::after { content: ''; position: absolute; top: 2px; left: 2px; width: 20px; height: 20px; border-radius: 50%; background: #fff; transition: left .15s; }
  .wb-switch.on::after { left: 20px; }

  /* mood check */
  .wb-mood-row { display: grid; grid-template-columns: 90px 1fr 40px; gap: 10px; align-items: center; margin-bottom: 10px; }
  .wb-mood-row label { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: #7A6F68; font-weight: 700; }
  .wb-mood-row input[type=range] { width: 100%; }

  /* break overlay */
  .wb-overlay { position: fixed; inset: 0; background: rgba(26,107,53,0.96); color: #fff; display: none; flex-direction: column; align-items: center; justify-content: center; z-index: 1000; text-align: center; padding: 20px; }
  .wb-overlay.show { display: flex; }
  .wb-overlay h2 { font-family: 'Cormorant Garamond', serif; font-size: 44px; font-weight: 600; margin: 0 0 10px; }
  .wb-overlay p { font-size: 17px; max-width: 460px; line-height: 1.6; opacity: 0.95; }
  .wb-overlay .big { font-family: 'Cormorant Garamond', serif; font-size: 64px; margin: 18px 0; }
  .wb-overlay button { background: #fff; color: #1A6B35; border: none; padding: 12px 28px; border-radius: 10px; font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 800; cursor: pointer; margin-top: 14px; }

  .wb-toast { position: fixed; right: 18px; bottom: 18px; background: #0E0B08; color: #fff; padding: 14px 18px; border-radius: 12px; font-size: 14px; max-width: 320px; box-shadow: 0 12px 30px rgba(0,0,0,0.25); display: none; z-index: 900; }
  .wb-toast.show { display: block; }
  .wb-toast b { color: #86efac; }
</style>

<main class="wb-wrap">
  <p class="wb-eye">Portal · Wellbeing</p>
  <h1 class="wb-h1">Stay <em>focused</em>, {firstName}. Stay well.</h1>
  <p class="wb-sub">Your study companion. Run a focus session, take a real break when it ends, breathe, stretch, and keep hydrated. We track your focus alongside your learning — because burning out is not learning.</p>

  <div class="wb-grid">
    {/* LEFT: focus timer + stats */}
    <div>
      <div class="wb-card">
        <h2>Focus session</h2>
        <h3>Deep work timer</h3>
        <div class="wb-timer">
          <div class="wb-ring" id="ring">
            <svg width="230" height="230"><circle class="wb-ring-track" cx="115" cy="115" r="100"/><circle class="wb-ring-fill" id="ringFill" cx="115" cy="115" r="100"/></svg>
            <div class="wb-ring-label"><div class="wb-ring-time" id="timeDisp">25:00</div><div class="wb-ring-phase" id="phaseDisp">Focus</div></div>
          </div>
          <div class="wb-timer-ctrls">
            <button class="wb-btn" id="startBtn">Start</button>
            <button class="wb-btn ghost" id="resetBtn">Reset</button>
            <button class="wb-btn ghost" id="skipBtn">Skip phase</button>
          </div>
          <div class="wb-timer-set">
            <label>Focus min <input id="setFocus" type="number" min="5" max="90" value="25"/></label>
            <label>Break min <input id="setBreak" type="number" min="1" max="30" value="5"/></label>
            <label>Long break <input id="setLong" type="number" min="5" max="45" value="15"/></label>
          </div>
        </div>
      </div>

      <div class="wb-card" style="margin-top:16px;">
        <h2>Today</h2>
        <div class="wb-stats">
          <div class="wb-stat"><div class="wb-stat-v" id="stSessions">0</div><div class="wb-stat-l">Sessions</div></div>
          <div class="wb-stat"><div class="wb-stat-v" id="stMinutes">0</div><div class="wb-stat-l">Focus minutes</div></div>
          <div class="wb-stat"><div class="wb-stat-v" id="stStreak">0</div><div class="wb-stat-l">Day streak</div></div>
        </div>
      </div>

      <div class="wb-card" style="margin-top:16px;">
        <h2>Quick check-in</h2>
        <h3>How are you right now?</h3>
        <div class="wb-mood-row"><label>Energy</label><input id="moodEnergy" type="range" min="1" max="5" value="3"/><span id="moodEnergyV" style="text-align:center;font-weight:700;">3</span></div>
        <div class="wb-mood-row"><label>Focus</label><input id="moodFocus" type="range" min="1" max="5" value="3"/><span id="moodFocusV" style="text-align:center;font-weight:700;">3</span></div>
        <div class="wb-mood-row"><label>Stress</label><input id="moodStress" type="range" min="1" max="5" value="2"/><span id="moodStressV" style="text-align:center;font-weight:700;">2</span></div>
        <button class="wb-btn" id="moodSave" style="margin-top:6px;">Log check-in</button>
        <p id="moodTip" style="font-size:13px;color:#1A6B35;margin:12px 0 0;line-height:1.5;"></p>
      </div>
    </div>

    {/* RIGHT: breathing + exercises + reminders */}
    <div>
      <div class="wb-card wb-breath">
        <h2 style="align-self:flex-start;">Reset · 60 seconds</h2>
        <h3 style="align-self:flex-start;">Box breathing</h3>
        <div class="wb-breath-circle" id="breathCircle">Breathe</div>
        <div class="wb-breath-phase" id="breathPhase">Press start</div>
        <button class="wb-btn ghost" id="breathBtn" style="margin-top:16px;">Start breathing</button>
      </div>

      <div class="wb-card" style="margin-top:16px;">
        <h2>Move · 2 minutes</h2>
        <h3>Desk exercises</h3>
        <div class="wb-ex-list" id="exList"></div>
      </div>

      <div class="wb-card" style="margin-top:16px;">
        <h2>Reminders</h2>
        <h3>Hydrate, eat, look away</h3>
        <div class="wb-rem-row"><div class="wb-rem-l">Hydration<small>Every 45 min</small></div><div class="wb-switch" data-rem="water" data-int="45"></div></div>
        <div class="wb-rem-row"><div class="wb-rem-l">20-20-20 eye rest<small>Every 20 min · look 20ft away 20s</small></div><div class="wb-switch" data-rem="eyes" data-int="20"></div></div>
        <div class="wb-rem-row"><div class="wb-rem-l">Stand &amp; stretch<small>Every 60 min</small></div><div class="wb-switch" data-rem="stand" data-int="60"></div></div>
        <div class="wb-rem-row"><div class="wb-rem-l">Meal break<small>Every 4 hours</small></div><div class="wb-switch" data-rem="meal" data-int="240"></div></div>
        <p style="font-size:12px;color:#7A6F68;margin:12px 0 0;line-height:1.5;">Enable browser notifications for reminders even when this tab is in the background.</p>
        <button class="wb-btn ghost" id="notifBtn" style="margin-top:8px;">Enable notifications</button>
      </div>
    </div>
  </div>
</main>

<div class="wb-overlay" id="breakOverlay">
  <h2 id="breakTitle">Break time</h2>
  <div class="big" id="breakCountdown">5:00</div>
  <p id="breakActivity">Stand up. Roll your shoulders. Look out a window. You earned it.</p>
  <button id="breakEndBtn">Back to focus</button>
</div>

<div class="wb-toast" id="toast"></div>

<script is:inline>
(function () {
  var KEY = 'era_wellbeing_v1';
  var today = new Date().toISOString().slice(0, 10);
  var state = { sessions: 0, minutes: 0, streak: 0, lastDay: today, reminders: {} };
  try { var s = JSON.parse(localStorage.getItem(KEY) || '{}'); state = Object.assign(state, s); } catch (e) {}
  // streak / daily reset
  if (state.lastDay !== today) {
    var yest = new Date(Date.now() - 86400000).toISOString().slice(0, 10);
    state.streak = (state.lastDay === yest) ? (state.streak || 0) + 1 : 1;
    state.sessions = 0; state.minutes = 0; state.lastDay = today;
  }
  function save() { try { localStorage.setItem(KEY, JSON.stringify(state)); } catch (e) {} }
  function $(id) { return document.getElementById(id); }

  function renderStats() { $('stSessions').textContent = state.sessions || 0; $('stMinutes').textContent = state.minutes || 0; $('stStreak').textContent = state.streak || 0; }
  renderStats();

  function toast(html, ms) { var t = $('toast'); t.innerHTML = html; t.classList.add('show'); clearTimeout(t._t); t._t = setTimeout(function () { t.classList.remove('show'); }, ms || 4500); }
  function notify(title, body) {
    if (window.Notification && Notification.permission === 'granted') { try { new Notification(title, { body: body, icon: '/favicon.svg' }); } catch (e) {} }
    toast('<b>' + title + '</b><br/>' + body);
  }

  // ---- Focus timer (Pomodoro) ----
  var R = 100, CIRC = 2 * Math.PI * R;
  $('ringFill').style.strokeDasharray = CIRC; $('ringFill').style.strokeDashoffset = 0;
  var phase = 'focus', remaining = 25 * 60, total = 25 * 60, running = false, tick = null, cycle = 0;
  function dur(p) { if (p === 'focus') return (parseInt($('setFocus').value, 10) || 25) * 60; if (p === 'long') return (parseInt($('setLong').value, 10) || 15) * 60; return (parseInt($('setBreak').value, 10) || 5) * 60; }
  function setPhase(p) { phase = p; total = dur(p); remaining = total; $('phaseDisp').textContent = p === 'focus' ? 'Focus' : (p === 'long' ? 'Long break' : 'Break'); $('ring').classList.toggle('break', p !== 'focus'); render(); }
  function render() {
    var m = Math.floor(remaining / 60), s = remaining % 60;
    $('timeDisp').textContent = m + ':' + (s < 10 ? '0' : '') + s;
    $('ringFill').style.strokeDashoffset = CIRC * (1 - remaining / total);
  }
  function startTimer() { if (running) { pause(); return; } running = true; $('startBtn').textContent = 'Pause'; tick = setInterval(function () { remaining--; if (remaining <= 0) { phaseComplete(); } render(); }, 1000); }
  function pause() { running = false; $('startBtn').textContent = 'Start'; clearInterval(tick); }
  function phaseComplete() {
    pause();
    if (phase === 'focus') {
      state.sessions = (state.sessions || 0) + 1; state.minutes = (state.minutes || 0) + Math.round(total / 60); save(); renderStats();
      cycle++;
      var next = (cycle % 4 === 0) ? 'long' : 'break';
      setPhase(next); openBreak();
    } else { setPhase('focus'); notify('Break over', 'Back to it — one focused session at a time.'); }
  }
  $('startBtn').addEventListener('click', startTimer);
  $('resetBtn').addEventListener('click', function () { pause(); setPhase('focus'); });
  $('skipBtn').addEventListener('click', function () { pause(); phase === 'focus' ? (cycle++, setPhase((cycle % 4 === 0) ? 'long' : 'break')) : setPhase('focus'); });
  ['setFocus', 'setBreak', 'setLong'].forEach(function (id) { $(id).addEventListener('change', function () { if (!running) setPhase(phase); }); });
  setPhase('focus');

  // ---- Break overlay with countdown ----
  var breakTick = null;
  var breakActs = ['Stand up and roll your shoulders back five times.', 'Look at something 20 feet away for 20 seconds.', 'Drink a glass of water.', 'Stretch your arms overhead and breathe.', 'Walk to another room and back.', 'Close your eyes and take ten slow breaths.'];
  function openBreak() {
    var ov = $('breakOverlay'); ov.classList.add('show');
    $('breakTitle').textContent = phase === 'long' ? 'Long break' : 'Break time';
    $('breakActivity').textContent = breakActs[Math.floor((state.sessions || 0) % breakActs.length)];
    notify('Break time', 'You completed a focus session. Take ' + Math.round(total / 60) + ' minutes.');
    var left = total;
    clearInterval(breakTick);
    breakTick = setInterval(function () { left--; var m = Math.floor(left / 60), s = left % 60; $('breakCountdown').textContent = m + ':' + (s < 10 ? '0' : '') + s; if (left <= 0) { clearInterval(breakTick); closeBreak(); } }, 1000);
  }
  function closeBreak() { $('breakOverlay').classList.remove('show'); clearInterval(breakTick); setPhase('focus'); }
  $('breakEndBtn').addEventListener('click', closeBreak);

  // ---- Box breathing ----
  var breathOn = false, breathStep = 0, breathTimer = null;
  var steps = [['Breathe in', 1.4], ['Hold', 1.4], ['Breathe out', 1.0], ['Hold', 1.4]];
  function breathLoop() {
    var st = steps[breathStep % 4];
    $('breathPhase').textContent = st[0]; $('breathCircle').style.transform = 'scale(' + st[1] + ')'; $('breathCircle').textContent = st[0].split(' ')[0];
    breathStep++;
    breathTimer = setTimeout(breathLoop, 4000);
  }
  $('breathBtn').addEventListener('click', function () {
    breathOn = !breathOn;
    if (breathOn) { this.textContent = 'Stop'; breathStep = 0; breathLoop(); }
    else { this.textContent = 'Start breathing'; clearTimeout(breathTimer); $('breathCircle').style.transform = 'scale(1)'; $('breathPhase').textContent = 'Paused'; $('breathCircle').textContent = 'Breathe'; }
  });

  // ---- Desk exercises ----
  var exercises = [
    { t: 'Neck rolls', d: '30s · slow circles each way', secs: 30, steps: ['Roll your head slowly clockwise', 'Now counter-clockwise', 'Relax'] },
    { t: 'Shoulder shrugs', d: '30s · lift and release', secs: 30, steps: ['Lift shoulders to ears', 'Hold 2s', 'Drop and relax', 'Repeat'] },
    { t: 'Wrist + finger stretch', d: '40s · for typing hands', secs: 40, steps: ['Extend arm, pull fingers back gently', 'Switch hands', 'Spread and close fingers'] },
    { t: 'Seated spinal twist', d: '40s · each side', secs: 40, steps: ['Twist gently to the right', 'Hold and breathe', 'Twist to the left'] },
    { t: 'Standing calf raises', d: '30s · stand up first', secs: 30, steps: ['Stand, rise onto your toes', 'Lower slowly', 'Repeat steadily'] },
  ];
  var exList = $('exList');
  exercises.forEach(function (ex, i) {
    var el = document.createElement('div'); el.className = 'wb-ex';
    el.innerHTML = '<div class="wb-ex-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 3v18M18 3v18M6 12h12"/></svg></div><div style="flex:1;"><div class="wb-ex-t">' + ex.t + '</div><div class="wb-ex-d">' + ex.d + '</div></div><div style="font-family:Geist Mono,monospace;font-size:11px;color:#1A6B35;font-weight:700;">Start</div>';
    el.addEventListener('click', function () { runExercise(ex); });
    exList.appendChild(el);
  });
  function runExercise(ex) {
    var ov = $('breakOverlay'); ov.classList.add('show'); $('breakTitle').textContent = ex.t;
    var step = 0, left = ex.secs;
    $('breakActivity').textContent = ex.steps[0];
    clearInterval(breakTick);
    breakTick = setInterval(function () {
      left--; $('breakCountdown').textContent = '0:' + (left < 10 ? '0' : '') + left;
      var idx = Math.min(ex.steps.length - 1, Math.floor((ex.secs - left) / (ex.secs / ex.steps.length)));
      $('breakActivity').textContent = ex.steps[idx];
      if (left <= 0) { clearInterval(breakTick); $('breakOverlay').classList.remove('show'); toast('<b>Nice.</b><br/>' + ex.t + ' done.'); }
    }, 1000);
  }

  // ---- Mood check-in ----
  ['Energy', 'Focus', 'Stress'].forEach(function (k) { var key = 'mood' + k; $(key).addEventListener('input', function () { $(key + 'V').textContent = this.value; }); });
  $('moodSave').addEventListener('click', function () {
    var e = +$('moodEnergy').value, f = +$('moodFocus').value, st = +$('moodStress').value;
    var tip = 'Logged. ';
    if (st >= 4) tip += 'Stress is high — run the box-breathing reset and take a real break before the next session.';
    else if (e <= 2) tip += 'Energy is low — hydrate, eat something, and try a shorter 15-minute focus block.';
    else if (f >= 4 && e >= 4) tip += 'You are in a great state — start a focus session now and ride it.';
    else tip += 'A short walk and water will lift the next session.';
    $('moodTip').textContent = tip;
    try { fetch('/api/activity/log', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ sessionId: 'wellbeing', stage: 'learn', type: 'wellbeing_checkin', detail: 'energy=' + e + ' focus=' + f + ' stress=' + st }) }); } catch (er) {}
  });

  // ---- Reminders ----
  var remTimers = {};
  function startReminder(name, intMin, label) {
    clearInterval(remTimers[name]);
    remTimers[name] = setInterval(function () { notify('Wellbeing reminder', label); }, intMin * 60000);
  }
  var remLabels = { water: 'Time to hydrate — drink a glass of water.', eyes: '20-20-20: look 20 feet away for 20 seconds.', stand: 'Stand up and stretch for a minute.', meal: 'Meal break — step away and eat properly.' };
  document.querySelectorAll('.wb-switch').forEach(function (sw) {
    var name = sw.getAttribute('data-rem'), intv = +sw.getAttribute('data-int');
    if (state.reminders && state.reminders[name]) { sw.classList.add('on'); startReminder(name, intv, remLabels[name]); }
    sw.addEventListener('click', function () {
      sw.classList.toggle('on');
      state.reminders = state.reminders || {};
      if (sw.classList.contains('on')) { state.reminders[name] = true; startReminder(name, intv, remLabels[name]); toast('<b>Reminder on.</b><br/>' + remLabels[name]); }
      else { state.reminders[name] = false; clearInterval(remTimers[name]); }
      save();
    });
  });
  $('notifBtn').addEventListener('click', function () {
    if (window.Notification) Notification.requestPermission().then(function (p) { toast(p === 'granted' ? '<b>Notifications on.</b><br/>You will get reminders in the background.' : 'Notifications blocked — reminders will show in-page only.'); });
  });
})();
</script>
</BaseLayout>
