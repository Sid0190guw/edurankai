---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ensureCommunitySchema, listClubs } from '@/lib/community';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

function rows(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/clubs'));

await ensureCommunitySchema();

const CATEGORIES = ['STEM', 'Humanities', 'Languages', 'Spiritual', 'Career', 'Wellbeing', 'Arts'];

let okMsg = '', errMsg = '';
if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const name = (fd.get('name') as string || '').trim();
    const tagline = (fd.get('tagline') as string || '').trim();
    const description = (fd.get('description') as string || '').trim();
    const category = (fd.get('category') as string || '').trim();
    if (!name || name.length < 4) errMsg = 'Club name is too short.';
    else if (!CATEGORIES.includes(category)) errMsg = 'Pick a category.';
    else {
      const slug = name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 80) + '-' + Math.random().toString(36).slice(2, 6);
      const ins = rows(await db.execute(sql`INSERT INTO clubs (slug, name, tagline, description, category, member_count) VALUES (${slug}, ${name}, ${tagline || null}, ${description || null}, ${category}, 1) RETURNING id, slug`));
      const clubId = ins[0]?.id;
      if (clubId) {
        await db.execute(sql`INSERT INTO club_members (club_id, user_id, role) VALUES (${clubId}, ${user.id}, 'owner') ON CONFLICT DO NOTHING`);
      }
      okMsg = 'Club created.';
    }
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 240); }
}

const url = new URL(Astro.request.url);
const filterCat = url.searchParams.get('cat') || '';
const clubs = await listClubs(filterCat && CATEGORIES.includes(filterCat) ? { category: filterCat } : {});
---
<BaseLayout title="Clubs · Portal · EduRankAI" description="Cross-course interest groups for learners across the EduRankAI ecosystem.">

<section class="px-[5vw] pt-12 md:pt-16 pb-6 max-w-5xl mx-auto">
  <p class="text-[0.62rem] font-mono uppercase tracking-[0.18em] text-burn font-bold mb-2">Portal · Clubs</p>
  <div class="flex justify-between items-end flex-wrap gap-3">
    <div>
      <h1 class="font-display text-[clamp(2.2rem,4.5vw,3.4rem)] font-semibold text-ink leading-[1.05]">Find your <em class="italic text-burn font-medium">tribe</em>.</h1>
      <p class="text-[1rem] text-ink-2 font-light leading-[1.85] max-w-xl mt-2">Cross-course interest groups. Quantum, AI safety, Vedic sciences, Sanskrit, careers, wellbeing. Browse, join, post, debate.</p>
    </div>
    <button id="newBtn" class="bg-burn text-white px-5 py-2.5 rounded-xl font-bold font-mono text-[0.75rem] uppercase tracking-wider">+ New club</button>
  </div>
</section>

<section class="px-[5vw] pb-3 max-w-5xl mx-auto">
  <div class="flex flex-wrap gap-2 items-center">
    <span class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft mr-1">Filter</span>
    <a href="/portal/clubs" class={`px-3 py-1.5 rounded-full text-[0.72rem] font-mono uppercase tracking-wider border ${!filterCat ? 'bg-ink text-cream border-ink' : 'bg-white text-ink border-ink/15 hover:border-burn'}`}>All</a>
    {CATEGORIES.map((c) => (
      <a href={`/portal/clubs?cat=${encodeURIComponent(c)}`} class={`px-3 py-1.5 rounded-full text-[0.72rem] font-mono uppercase tracking-wider border ${filterCat === c ? 'bg-ink text-cream border-ink' : 'bg-white text-ink border-ink/15 hover:border-burn'}`}>{c}</a>
    ))}
  </div>
</section>

<section class="px-[5vw] pb-14 max-w-5xl mx-auto">
  {okMsg && <div class="bg-leaf-bg border border-leaf-border rounded-xl px-4 py-3 mb-4 text-[0.92rem] text-leaf font-semibold">{okMsg}</div>}
  {errMsg && <div class="bg-burn-pale border border-burn-dim rounded-xl px-4 py-3 mb-4 text-[0.88rem] text-burn font-semibold">{errMsg}</div>}

  <form id="newForm" method="POST" class="bg-white border border-ink/10 rounded-2xl p-6 mb-6 space-y-3" style="display:none;">
    <p class="text-[0.62rem] font-mono uppercase tracking-[0.14em] text-burn font-bold m-0">New club</p>
    <div>
      <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft mb-1">Name</label>
      <input name="name" type="text" required minlength="4" maxlength="200" placeholder="Quantum Computing Club" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"/>
    </div>
    <div>
      <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft mb-1">Tagline</label>
      <input name="tagline" type="text" maxlength="300" placeholder="A one-line pitch for your tribe" class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]"/>
    </div>
    <div>
      <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft mb-1">Category</label>
      <select name="category" required class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem]">
        <option value="">Select category</option>
        {CATEGORIES.map((c) => <option value={c}>{c}</option>)}
      </select>
    </div>
    <div>
      <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft mb-1">Description</label>
      <textarea name="description" rows="4" maxlength="3000" placeholder="What this club is about, who should join, what you do together..." class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] font-body resize-y"></textarea>
    </div>
    <button type="submit" class="bg-burn text-white px-5 py-2.5 rounded-xl font-bold font-mono text-[0.75rem] uppercase tracking-wider">Create club</button>
  </form>

  {clubs.length === 0 ? (
    <div class="text-center py-14 border border-dashed border-ink/15 rounded-2xl">
      <p class="text-ink-soft font-body text-[0.95rem]">No clubs in this category yet.</p>
      <p class="text-ink-soft font-mono text-[0.72rem] uppercase tracking-wider mt-2">Be the first to start one.</p>
    </div>
  ) : (
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {clubs.map((c: any) => (
        <a href={`/portal/clubs/${c.slug}`} class="bg-white border border-ink/10 rounded-2xl p-5 block hover:border-burn transition-colors">
          <div class="flex items-center justify-between mb-2">
            <span class="text-[0.6rem] font-mono uppercase tracking-[0.14em] text-burn font-bold px-2 py-0.5 bg-burn-pale rounded-full">{c.category || 'General'}</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ink-soft"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </div>
          <h2 class="font-display text-[1.2rem] font-semibold text-ink leading-tight">{c.name}</h2>
          {c.tagline && <p class="text-[0.86rem] text-ink-2 mt-2 line-clamp-3 leading-relaxed">{c.tagline}</p>}
          <div class="flex justify-between text-[0.72rem] text-ink-soft mt-4 pt-3 border-t border-ink/10 font-mono uppercase tracking-wider">
            <span class="inline-flex items-center gap-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              {c.member_count || 0}
            </span>
            <span class="inline-flex items-center gap-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              {c.post_count || 0}
            </span>
          </div>
        </a>
      ))}
    </div>
  )}
</section>

<script is:inline>
  document.getElementById('newBtn').addEventListener('click', function () {
    var f = document.getElementById('newForm');
    f.style.display = f.style.display === 'none' ? 'block' : 'none';
    if (f.style.display === 'block') f.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
</BaseLayout>
