---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { offerLetters, applications, applicationMessages } from '@/lib/db/schema';
import { eq, and } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/portal/login');

const { token } = Astro.params;
if (!token) return Astro.redirect('/portal');

let errorMsg = '';
let successMsg = '';

// Fetch the offer
const offerList = await db.select().from(offerLetters)
  .where(eq(offerLetters.token, token))
  .limit(1);

if (offerList.length === 0) return Astro.redirect('/portal');
const offer: any = offerList[0];

// Verify the offer belongs to this user via the application
const appList = await db.select().from(applications)
  .where(and(eq(applications.id, offer.applicationId), eq(applications.applicantUserId, user.id)))
  .limit(1);

// Allow admins to view too
const isAdmin = user.role !== 'applicant';
if (appList.length === 0 && !isAdmin) return Astro.redirect('/portal');
const app: any = appList.length > 0 ? appList[0] : null;

// Handle signing
if (Astro.request.method === 'POST' && !isAdmin) {
  const _fdPeek = await Astro.request.clone().formData();
  const _action = (_fdPeek.get('action') as string || 'sign').trim();

  if (_action === 'decline') {
    if (offer.status === 'signed') {
      errorMsg = 'This offer has already been signed and cannot be declined.';
    } else if (offer.status === 'withdrawn') {
      errorMsg = 'This offer has been withdrawn.';
    } else if (offer.status === 'declined') {
      errorMsg = 'This offer has already been declined.';
    } else {
      const reason = (_fdPeek.get('declineReason') as string || '').trim().substring(0, 500);
      try {
        await db.update(offerLetters).set({
          status: 'declined',
          declinedAt: new Date(),
          declinedReason: reason || null,
          updatedAt: new Date()
        }).where(eq(offerLetters.id, offer.id));

        if (offer.createdUserId) {
          const { users } = await import('@/lib/db/schema');
          await db.update(users).set({ isActive: false, updatedAt: new Date() }).where(eq(users.id, offer.createdUserId));
        }

        if (app) {
          await db.update(applications).set({ status: 'rejected', updatedAt: new Date() }).where(eq(applications.id, app.id));
          await db.insert(applicationMessages).values({
            applicationId: app.id,
            senderUserId: user.id,
            senderRole: 'system',
            senderName: 'System',
            body: 'Offer declined by applicant. Account access revoked. 6-month cooling period applies before re-application for the same role.' + (reason ? ' Reason: ' + reason : ''),
            isSystem: true
          });
        }

        offer.status = 'declined';
        (offer as any).declinedAt = new Date();
        (offer as any).declinedReason = reason || null;
        successMsg = 'You have declined this offer. Per EduRankAI terms, a 6-month cooling period applies before you can reapply for the same role. Your auto-issued account access has been revoked.';
      } catch (err: any) {
        errorMsg = 'Failed to record decline: ' + (err.message || 'Unknown error');
      }
    }
  } else if (offer.status === 'signed') {
    errorMsg = 'This offer has already been signed.';
  } else if (offer.status === 'withdrawn') {
    errorMsg = 'This offer has been withdrawn and cannot be signed.';
  } else {
    const fd = await Astro.request.formData();
    const signatureDataUrl = (fd.get('signatureDataUrl') as string || '').trim();

    if (!signatureDataUrl || !signatureDataUrl.startsWith('data:image/')) {
      errorMsg = 'Please draw your signature before submitting.';
    } else if (signatureDataUrl.length > 500000) {
      errorMsg = 'Signature image too large.';
    } else {
      try {
        const ipHeader = Astro.request.headers.get('x-forwarded-for') || Astro.request.headers.get('cf-connecting-ip') || '';
        const ua = Astro.request.headers.get('user-agent') || '';

        await db.update(offerLetters).set({
          status: 'signed',
          signedAt: new Date(),
          signatureDataUrl,
          signatureIp: ipHeader.substring(0, 64),
          signatureUserAgent: ua,
          updatedAt: new Date()
        }).where(eq(offerLetters.id, offer.id));

        // Update application status to hired
        if (app) {
          await db.update(applications).set({
            status: 'hired',
            updatedAt: new Date()
          }).where(eq(applications.id, app.id));

          // Post system message to thread
          await db.insert(applicationMessages).values({
            applicationId: app.id,
            senderUserId: user.id,
            senderRole: 'system',
            senderName: 'System',
            body: 'Offer accepted and signed by the applicant. Status updated to: Hired.',
            isSystem: true
          });
        }

        successMsg = 'Offer accepted. You are officially part of EduRankAI.';
        offer.status = 'signed';
        offer.signedAt = new Date();
        offer.signatureDataUrl = signatureDataUrl;
      } catch (err: any) {
        errorMsg = 'Failed to record signature: ' + (err.message || 'Unknown error');
      }
    }
  }
}

const content = offer.content || {};
const c = content;
const verifyUrl = 'https://www.edurankai.in/offer/verify/' + offer.token;
const shortId = offer.id.substring(0, 8).toUpperCase();

function formatDate(d: any): string {
  if (!d) return '';
  const date = typeof d === 'string' ? new Date(d) : d;
  if (isNaN(date.getTime())) return d;
  return date.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
}

// Load internal handle for the user account, if linked
let internalHandle: string | null = null;
if (offer.createdUserId) {
  try {
    const { users } = await import('@/lib/db/schema');
    const u = await db.select({ h: users.internalHandle }).from(users).where(eq(users.id, offer.createdUserId)).limit(1);
    if (u.length > 0) internalHandle = u[0].h;
  } catch (e) {}
}
const isWithdrawn = offer.status === 'withdrawn';
const isSigned = offer.status === 'signed';
const isDeclined = offer.status === 'declined';
const isAvailable = offer.status === 'sent';

// Expiry check
let expiryStatus = 'ok';
let daysLeft = null;
if (offer.expiryDate && !isSigned) {
  const exp = new Date(offer.expiryDate);
  const diff = exp.getTime() - Date.now();
  daysLeft = Math.ceil(diff / 86400000);
  if (diff <= 0) expiryStatus = 'expired';
  else if (daysLeft <= 3) expiryStatus = 'warning';
}

const TEMPLATE_INTROS: Record<string, string> = {
  intern: 'We are pleased to extend this formal offer of an internship for the position of',
  fulltime: 'We are pleased to extend this formal full-time employment offer for the position of',
  contract: 'We are pleased to extend this contract engagement offer for the position of',
  leadership: 'We are honored to extend this leadership offer for the position of'
};

const intro = TEMPLATE_INTROS[offer.templateType] || TEMPLATE_INTROS.intern;
---
<BaseLayout title={'Offer Letter - ' + c.candidateName} description="Your EduRankAI offer letter">

  <section class="px-[5vw] py-6 md:py-10 max-w-4xl mx-auto">

    <div class="mb-4 flex items-center justify-between flex-wrap gap-2">
      <a href="/portal" class="text-[0.82rem] text-ink-soft hover:text-burn font-mono">Back to portal</a>
      <div class="flex gap-2">
        <a href={"/admin/offer/blank?from=" + offer.applicationId} target="_blank" class="text-[0.82rem] bg-ink hover:bg-ink/90 text-white font-semibold px-4 py-2 rounded-lg inline-block no-underline">View / Download Offer PDF &rarr;</a>
      </div>
    </div>

    {errorMsg && (
      <div style="background:rgba(220,38,38,0.06);border:1px solid rgba(220,38,38,0.25);color:#b91c1c;font-size:0.85rem;padding:11px 14px;border-radius:8px;margin-bottom:14px;">{errorMsg}</div>
    )}
    {successMsg && (
      <div class="bg-leaf-bg/40 border border-leaf-border text-leaf rounded-lg p-4 mb-4 text-[0.88rem] leading-relaxed">{successMsg}</div>
    )}

    {isDeclined && (
      <div style="background:#fef2f2;border:2px solid #dc2626;border-radius:12px;padding:16px;margin-bottom:18px;">
        <p style="font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#dc2626;margin:0 0 6px;">Offer Declined</p>
        <p style="font-size:14px;color:#7f1d1d;margin:0 0 8px;line-height:1.55;">You have declined this offer{(offer as any).declinedAt ? ' on ' + new Date((offer as any).declinedAt).toLocaleDateString('en-IN') : ''}.</p>
        <p style="font-size:12.5px;color:#991b1b;margin:0;line-height:1.55;"><strong>Per EduRankAI terms:</strong> A <strong>6-month cooling period</strong> applies. You cannot reapply for the same role until {(offer as any).declinedAt ? new Date(new Date((offer as any).declinedAt).getTime() + 180 * 86400000).toLocaleDateString('en-IN') : '6 months from the decline date'}. Your auto-issued account access has been revoked.</p>
        {(offer as any).declinedReason && (
          <p style="font-size:12px;color:#6b6b76;margin:8px 0 0;font-style:italic;">Your reason: "{(offer as any).declinedReason}"</p>
        )}
      </div>
    )}

    {isWithdrawn && (
      <div class="bg-red-500/10 border border-red-500/30 text-red-700 rounded-2xl p-5 mb-5 text-[0.9rem] leading-relaxed">
        <p class="font-semibold mb-1">This offer has been withdrawn</p>
        <p>The hiring team has withdrawn this offer. {offer.withdrawnReason && (<span>Reason: {offer.withdrawnReason}</span>)}</p>
        {!isAdmin && <p class="mt-2">If you have questions, please use the message thread on your application.</p>}
      </div>
    )}

    {expiryStatus === 'expired' && !isSigned && (
      <div class="bg-red-500/10 border border-red-500/30 text-red-700 rounded-2xl p-5 mb-5">
        <p class="font-semibold">This offer has expired</p>
        <p class="text-[0.85rem] mt-1">Please contact us via the message thread to discuss.</p>
      </div>
    )}

    {expiryStatus === 'warning' && !isSigned && (
      <div class="bg-burn-pale border border-burn-dim text-burn rounded-2xl p-4 mb-5">
        <p class="font-semibold text-[0.9rem]">This offer expires in {daysLeft} day{daysLeft !== 1 ? 's' : ''} - {formatDate(offer.expiryDate)}</p>
      </div>
    )}

    <article id="offerLetter" class="bg-white border border-ink/10 rounded-2xl overflow-hidden mb-6 shadow-sm">

      <header class="bg-ink text-white p-6 md:p-8">
        <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-4">
          <div>
            <p class="font-display text-[1.6rem] font-semibold leading-tight">Edu<em class="italic text-burn font-medium">Rank</em>AI</p>
            <p class="text-[0.7rem] text-white/50 mt-1 leading-relaxed">AI Research and Technology - Guwahati, Assam, India</p>
            <p class="text-[0.7rem] text-white/40 mt-1">Guwahati, Assam, India</p>
            <p class="text-[0.7rem] text-white/40">hr@edurankai.in - www.edurankai.in</p>
          </div>
          <div class="text-left md:text-right">
            <p class="text-[0.55rem] font-bold uppercase tracking-[0.15em] text-white/40">Reference</p>
            <p class="font-mono text-[0.95rem] mt-1">{offer.refNumber}</p>
            {offer.offerDate && (<p class="text-[0.78rem] text-white/55 mt-1">{formatDate(offer.offerDate)}</p>)}
            <p class="inline-block mt-2 text-[0.6rem] font-bold uppercase tracking-wider text-gold-deep border border-gold-border/50 rounded px-2 py-0.5">Private and Confidential</p>
          </div>
        </div>
      </header>

      <div class="p-6 md:p-8">

        {c.candidateName && (
          <div class="mb-5">
            <p class="font-display text-[1.2rem] font-semibold text-ink">{c.candidateName}</p>
            <p class="text-[0.82rem] text-ink-soft mt-1 leading-relaxed">
              {c.candidateEmail && <span>{c.candidateEmail}</span>}
              {c.candidatePhone && <span> · {c.candidatePhone}</span>}
              {c.candidateCity && <span><br />{c.candidateCity}</span>}
            </p>
          </div>
        )}

        <div class="bg-burn-pale/40 border-l-4 border-burn rounded-r p-3 mb-5">
          <p class="text-[0.95rem] font-semibold text-ink"><span class="text-ink-soft font-normal">Re: </span>Offer of {c.employmentType} - {c.roleTitle}{c.department && (<span>, {c.department}</span>)}</p>
        </div>

        <div class="inline-block bg-ink text-burn text-[0.7rem] font-bold uppercase tracking-wider rounded px-3 py-1 mb-5">{c.employmentType} - {c.department || c.roleTitle}</div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-6">
          <div class="bg-burn-pale/30 border border-burn-dim/30 rounded-lg p-3 text-center">
            <p class="font-display text-[1rem] font-semibold text-burn">{c.duration || 'TBD'}</p>
            <p class="text-[0.6rem] font-bold uppercase tracking-wider text-ink-soft mt-1">Duration</p>
          </div>
          <div class="bg-burn-pale/30 border border-burn-dim/30 rounded-lg p-3 text-center">
            <p class="font-display text-[1rem] font-semibold text-burn">{c.workMode || 'Remote'}</p>
            <p class="text-[0.6rem] font-bold uppercase tracking-wider text-ink-soft mt-1">Work Mode</p>
          </div>
          <div class="bg-burn-pale/30 border border-burn-dim/30 rounded-lg p-3 text-center">
            <p class="font-display text-[1rem] font-semibold text-burn">{c.compensation || 'TBD'}</p>
            <p class="text-[0.6rem] font-bold uppercase tracking-wider text-ink-soft mt-1">Compensation</p>
          </div>
        </div>

        <div class="text-[0.92rem] text-ink-2 leading-loose mb-5 space-y-3">
          <p>Dear <strong class="text-ink">{(c.candidateName || '').split(' ')[0] || 'Candidate'}</strong>,</p>
          <p>{intro} <strong class="text-ink">{c.roleTitle}</strong>{c.department && (<span> within the <strong class="text-ink">{c.department}</strong></span>)} at <strong class="text-ink">EduRankAI</strong>. Following a thorough evaluation of your application and conversations, we are confident you demonstrate the capability, character, and commitment we look for.</p>
          {(offer.templateType === 'intern') && (
            <p>This {c.employmentType} is offered on an <strong>unpaid basis</strong> in accordance with EduRankAI's Internship Policy. You will work <strong>{c.workMode}</strong>, committing <strong>{c.hoursCommitment}</strong> of focused effort. The engagement runs for <strong>{c.duration}</strong>, commencing <strong>{formatDate(c.joiningDate) || 'a mutually agreed date'}</strong>.</p>
          )}
          {(offer.templateType !== 'intern') && (
            <p>This offer is contingent on completion of pre-employment requirements. Your employment commences on <strong>{formatDate(c.joiningDate) || 'a mutually agreed date'}</strong> as a <strong>{c.employmentType}</strong> employee. Onboarding details will be confirmed within 7 days of acceptance.</p>
          )}
          <p>You will receive a mid-point review and final review, assessed via EduRankAI's rubric-based evaluation. Outstanding performers receive a Letter of Recommendation; all successful completers receive a Certificate of Completion.</p>
          <p>By accepting, you confirm you have read and agree to EduRankAI's Recruitment and Work Policy and Code of Conduct.</p>
          {c.customNote && (<p class="italic">{c.customNote}</p>)}
        </div>

        <div class="border-t border-ink/8 pt-4 mb-5">
          <p class="text-[0.65rem] font-bold uppercase tracking-wider text-ink-soft mb-3">Offer Summary</p>
          <table class="w-full text-[0.85rem]">
            <tbody>
              <tr class="border-b border-ink/5"><td class="text-ink-soft py-2 w-2/5">Position</td><td class="font-semibold text-ink">{c.roleTitle}</td></tr>
              {c.department && <tr class="border-b border-ink/5"><td class="text-ink-soft py-2">Department</td><td class="font-semibold text-ink">{c.department}</td></tr>}
              <tr class="border-b border-ink/5"><td class="text-ink-soft py-2">Employment Type</td><td class="font-semibold text-ink">{c.employmentType}</td></tr>
              <tr class="border-b border-ink/5"><td class="text-ink-soft py-2">Work Mode</td><td class="font-semibold text-ink">{c.workMode}</td></tr>
              <tr class="border-b border-ink/5"><td class="text-ink-soft py-2">Duration</td><td class="font-semibold text-ink">{c.duration}</td></tr>
              {c.joiningDate && <tr class="border-b border-ink/5"><td class="text-ink-soft py-2">Joining Date</td><td class="font-semibold text-ink">{formatDate(c.joiningDate)}</td></tr>}
              {c.reportingTo && <tr class="border-b border-ink/5"><td class="text-ink-soft py-2">Reporting To</td><td class="font-semibold text-ink">{c.reportingTo}</td></tr>}
              {c.hoursCommitment && <tr class="border-b border-ink/5"><td class="text-ink-soft py-2">Working Hours</td><td class="font-semibold text-ink">{c.hoursCommitment}</td></tr>}
              <tr class="border-b border-ink/5"><td class="text-ink-soft py-2">Compensation</td><td class="font-semibold text-ink">{c.compensation}</td></tr>
              {offer.expiryDate && <tr class="border-b border-ink/5"><td class="text-ink-soft py-2">Offer Expires</td><td class="font-semibold text-ink">{formatDate(offer.expiryDate)}</td></tr>}
              <tr><td class="text-ink-soft py-2">Integrity Hash</td><td class="font-mono text-burn text-[0.78rem]">{offer.integrityHash}</td></tr>
            </tbody>
          </table>
        </div>

        <div class="border-t border-ink/8 pt-4 mb-5">
          <div class="flex justify-between items-end">
            <div>
              <p class="text-[0.7rem] text-ink-soft mb-2">Issued by EduRankAI - {formatDate(offer.offerDate)}</p>
              <p class="font-display text-[1.05rem] font-semibold text-ink">{c.signatoryName}</p>
              <p class="text-[0.82rem] text-ink-soft">{c.signatoryTitle}</p>
              <p class="text-[0.82rem] font-semibold text-burn">EduRankAI</p>
            </div>
            <div class="w-14 h-14 rounded-full border-2 border-burn-dim/40 bg-burn-pale flex flex-col items-center justify-center">
              <span class="text-burn text-[0.7rem]">◆</span>
              <span class="text-[0.45rem] font-bold text-burn text-center leading-tight">EDU<br />RANK<br />AI</span>
            </div>
          </div>
        </div>

        {isSigned && offer.signatureDataUrl && (
          <div class="border-t border-ink/8 pt-4 mb-5">
            <p class="text-[0.65rem] font-bold uppercase tracking-wider text-ink-soft mb-3">Accepted by Applicant</p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <p class="text-[0.7rem] text-ink-soft mb-1">Candidate Signature</p>
                <img src={offer.signatureDataUrl} alt="Signature" class="max-h-20 border border-ink/10 rounded bg-white p-1" />
                <p class="text-[0.7rem] text-ink-soft italic mt-1">Signed: {new Date(offer.signedAt).toLocaleString('en-IN')}</p>
              </div>
              <div>
                <p class="text-[0.7rem] text-ink-soft mb-1">Date of Signing</p>
                <p class="text-[0.85rem] font-semibold">{formatDate(offer.signedAt)}</p>
                <p class="text-[0.7rem] text-ink-soft mt-2 leading-relaxed">By signing, the candidate has accepted this offer and all terms herein.</p>
              </div>
            </div>
          </div>
        )}

        <div class="border-t border-ink/8 pt-4 mb-5">
          <p class="text-[0.65rem] font-bold uppercase tracking-wider text-burn mb-3">Access Credentials</p>
          {offer.plaintextPassword ? (
            <div class="bg-burn-pale/40 border-2 border-burn-dim/40 rounded-lg p-4">
              <p class="text-[0.85rem] text-ink-2 leading-relaxed mb-3">
                A user account has been created for you. After signing this offer, you can log in to the EduRankAI admin panel at
                <a href="https://www.edurankai.in/admin/login" class="text-burn font-semibold hover:underline">edurankai.in/admin/login</a>.
              </p>
              <p class="text-[0.78rem] text-ink-soft mb-3">You can sign in using <strong class="text-ink">either</strong> your personal email OR your internal handle. Both work.</p>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                <div class="bg-white border border-ink/10 rounded p-3">
                  <p class="text-[0.62rem] font-bold uppercase tracking-wider text-ink-soft mb-1">Personal Email</p>
                  <p class="font-mono text-[0.85rem] text-ink break-all select-all">{c.candidateEmail || offer.candidateEmail}</p>
                </div>
                {offer.createdUserId && (
                  <div class="bg-white border border-burn-dim rounded p-3">
                    <p class="text-[0.62rem] font-bold uppercase tracking-wider text-burn mb-1">Internal Handle</p>
                    <p class="font-mono text-[0.85rem] text-ink break-all select-all">{internalHandle || (c.candidateEmail || offer.candidateEmail)}</p>
                  </div>
                )}
                <div class="bg-white border border-ink/10 rounded p-3">
                  <p class="text-[0.62rem] font-bold uppercase tracking-wider text-ink-soft mb-1">Temporary Password</p>
                  <p class="font-mono text-[0.85rem] text-ink break-all select-all">{offer.plaintextPassword}</p>
                </div>
              </div>
              <p class="text-[0.72rem] text-ink-soft mt-3 italic leading-relaxed">
                <strong class="text-ink">Important:</strong> Change this password after your first login (Settings &gt; Account). These credentials are valid for the entire engagement period and are also embedded in this offer letter PDF for your records.
              </p>
            </div>
          ) : (
            <div class="bg-cream-2 border border-ink/10 rounded-lg p-3">
              <p class="text-[0.78rem] text-ink-soft">Login credentials will be provided after offer acceptance.</p>
            </div>
          )}
        </div>

        <div class="border-t border-ink/8 pt-4">
          <p class="text-[0.65rem] font-bold uppercase tracking-wider text-ink-soft mb-2">Verification</p>
          <div class="flex items-center gap-3 bg-cream-2 rounded p-3">
            <div id="qrCanvasBox" class="w-16 h-16 bg-white border border-ink/10 rounded flex items-center justify-center text-[0.6rem] text-ink-soft">QR</div>
            <div class="flex-1 text-[0.78rem] text-ink-2 leading-relaxed">
              <p class="font-semibold text-ink">Verify this offer letter</p>
              <p>Scan the QR or visit:</p>
              <p class="font-mono text-burn break-all">{verifyUrl}</p>
            </div>
          </div>
        </div>

      </div>
    </article>

    {!isAdmin && isAvailable && !isWithdrawn && expiryStatus !== 'expired' && (
      <div class="bg-burn-pale border border-burn-dim rounded-2xl p-6 mb-5">
        <h2 class="font-display text-[1.3rem] font-semibold text-ink mb-2">Accept this offer</h2>
        <p class="text-[0.9rem] text-ink-2 leading-relaxed mb-4">Type your full legal name as your signature, confirm that you accept the terms, and click <strong>Accept and Sign</strong>. This is a binding electronic acceptance.</p>

        <form method="POST" id="signForm" style="display:flex;flex-direction:column;gap:14px;">
          <input type="hidden" name="signatureDataUrl" id="signatureDataUrl" />

          <div>
            <label for="typedName" style="display:block;font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#6b6b76;margin-bottom:6px;">Your full legal name *</label>
            <input type="text" id="typedName" name="typedName" required minlength="3" maxlength="120"
                   placeholder="e.g. Suhas Puligadda"
                   style="width:100%;padding:12px 14px;background:#fff;border:1.5px solid rgba(0,0,0,0.15);border-radius:8px;font-size:15px;color:#0a0a0c;font-family:inherit;outline:none;-webkit-appearance:none;" />
          </div>

          <div style="background:#fff;border:1.5px solid rgba(0,0,0,0.1);border-radius:8px;padding:14px 12px;">
            <p style="font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#6b6b76;margin:0 0 8px;">Signature preview</p>
            <div id="sigPreview" style="min-height:50px;font-family:'Brush Script MT','Lucida Handwriting',cursive;font-size:30px;color:#0a0a0c;font-style:italic;border-bottom:1.5px solid rgba(0,0,0,0.15);padding:4px 0;text-align:center;">&nbsp;</div>
          </div>

          <label style="display:flex;align-items:flex-start;gap:10px;padding:12px;background:#fff;border:1.5px solid rgba(0,0,0,0.1);border-radius:8px;cursor:pointer;font-size:13.5px;color:#0a0a0c;line-height:1.5;">
            <input type="checkbox" id="acceptCheck" required style="margin-top:3px;accent-color:#FF4F00;flex-shrink:0;width:18px;height:18px;" />
            <span>I have read this offer, accept all the terms, and confirm that the typed name above is my legal electronic signature. My signature, IP address, and timestamp will be permanently recorded as evidence of acceptance.</span>
          </label>

          <button type="submit" id="signSubmitBtn"
                  style="background:#FF4F00;border:none;color:#fff;font-weight:700;padding:14px;border-radius:8px;font-size:15px;cursor:pointer;-webkit-appearance:none;">
            Accept and Sign Offer
          </button>
        </form>

        <details style="margin-top:14px;border-top:1px solid rgba(0,0,0,0.1);padding-top:14px;">
          <summary style="font-size:13px;color:#9a9aa3;cursor:pointer;font-weight:500;">I want to decline this offer instead</summary>
          <form method="POST" style="margin-top:10px;background:#fff;border:1px solid rgba(0,0,0,0.1);padding:14px;border-radius:8px;display:flex;flex-direction:column;gap:10px;" onsubmit="return confirm('Decline this offer? This cannot be undone and a 6-month cooling period applies before you can reapply.');">
            <input type="hidden" name="action" value="decline" />
            <p style="font-size:12px;color:#dc2626;background:#fef2f2;padding:10px;border-radius:6px;margin:0;line-height:1.55;border:1px solid #fecaca;"><strong>Important:</strong> Declining this offer triggers a <strong>6-month cooling period</strong> before you can reapply for the same role. Your auto-issued account access will be revoked. This action cannot be undone.</p>
            <label style="font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#6b6b76;">Reason (optional)</label>
            <textarea name="declineReason" rows="3" maxlength="500" placeholder="Optional - up to 500 characters. Helps us improve our process." style="width:100%;padding:9px 12px;background:#fafaf6;border:1px solid rgba(0,0,0,0.15);border-radius:6px;font-size:13px;color:#0a0a0c;font-family:inherit;outline:none;resize:vertical;"></textarea>
            <button type="submit" style="background:#dc2626;border:none;color:#fff;font-weight:600;padding:11px;border-radius:8px;font-size:14px;cursor:pointer;align-self:flex-start;-webkit-appearance:none;">Decline this Offer</button>
          </form>
        </details>

        <details style="margin-top:14px;border-top:1px solid rgba(0,0,0,0.1);padding-top:14px;">
          <summary style="font-size:13px;color:#9a9aa3;cursor:pointer;font-weight:500;">I want to decline this offer instead</summary>
          <form method="POST" id="declineForm" style="margin-top:10px;background:#fff;border:1px solid rgba(0,0,0,0.1);padding:14px;border-radius:8px;display:flex;flex-direction:column;gap:10px;" onsubmit="return confirm('Decline this offer? This cannot be undone.');">
            <input type="hidden" name="action" value="decline" />
            <label style="font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#6b6b76;">Reason (optional)</label>
            <textarea name="declineReason" rows="3" maxlength="500" placeholder="Optional - let us know why so we can improve our process. Max 500 characters." style="width:100%;padding:9px 12px;background:#fafaf6;border:1px solid rgba(0,0,0,0.15);border-radius:6px;font-size:13px;color:#0a0a0c;font-family:inherit;outline:none;resize:vertical;"></textarea>
            <button type="submit" style="background:#dc2626;border:none;color:#fff;font-weight:600;padding:11px;border-radius:8px;font-size:14px;cursor:pointer;align-self:flex-start;-webkit-appearance:none;">Decline this Offer</button>
          </form>
        </details>
        <p class="text-[0.7rem] text-ink-soft mt-3 italic">Your signature, IP, and timestamp will be recorded as evidence of acceptance.</p>
      </div>
    )}

    {!isAdmin && !isSigned && !isWithdrawn && !isDeclined && (
    <div style="margin-top:18px;border-top:1px solid rgba(0,0,0,0.08);padding-top:16px;">
      <details style="background:#fff8f8;border:1px solid #fecaca;border-radius:10px;padding:14px;">
        <summary style="font-size:13.5px;color:#dc2626;cursor:pointer;font-weight:600;list-style:none;">&#9660; I want to decline this offer</summary>
        <form method="POST" style="margin-top:12px;display:flex;flex-direction:column;gap:10px;" onsubmit="return confirm('Decline this offer? A 6-month cooling period applies. This cannot be undone.');">
          <input type="hidden" name="action" value="decline" />
          <p style="font-size:12px;color:#991b1b;background:#fef2f2;padding:10px;border-radius:6px;margin:0;line-height:1.6;border:1px solid #fecaca;"><strong>Important:</strong> Declining triggers a <strong>6-month cooling period</strong>. You cannot reapply for the same role for 6 months. Your auto-issued account access will be revoked immediately. This cannot be undone.</p>
          <label style="font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#6b6b76;">Reason (optional, up to 500 chars)</label>
          <textarea name="declineReason" rows="3" maxlength="500" placeholder="Help us improve — why are you declining?" style="width:100%;padding:9px 12px;background:#fff;border:1.5px solid #fecaca;border-radius:6px;font-size:13px;color:#0a0a0c;font-family:inherit;outline:none;resize:vertical;box-sizing:border-box;"></textarea>
          <button type="submit" style="background:#dc2626;border:none;color:#fff;font-weight:700;padding:12px 20px;border-radius:8px;font-size:14px;cursor:pointer;align-self:flex-start;-webkit-appearance:none;letter-spacing:0.02em;">Decline this Offer</button>
        </form>
      </details>
    </div>
  )}

  {!isAdmin && isAvailable && expiryStatus !== 'expired' && (
      <div class="text-[0.78rem] text-ink-soft text-center">
        Questions? <a href={'/portal/applications/' + offer.applicationId} class="text-burn font-semibold hover:underline">Use the message thread</a>.
      </div>
    )}

  </section>

  <script is:inline src="https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>

  <script is:inline define:vars={{ verifyUrl: verifyUrl, isAvailable: isAvailable, isAdmin: isAdmin }}>
    // QR rendering
    setTimeout(function() {
      var qrBox = document.getElementById('qrCanvasBox');
      if (qrBox && typeof QRCode !== 'undefined') {
        var cv = document.createElement('canvas');
        cv.width = 64; cv.height = 64;
        QRCode.toCanvas(cv, verifyUrl, { width: 64, margin: 0, color: { dark: '#0C0C0C', light: '#FFFFFF' } }, function(err) {
          if (!err) {
            qrBox.innerHTML = '';
            qrBox.appendChild(cv);
          }
        });
      }
    }, 200);

    // Typed-name signature (Safari-friendly, no canvas drawing)
    var typedNameInput = document.getElementById('typedName');
    var sigPreview = document.getElementById('sigPreview');
    var acceptCheck = document.getElementById('acceptCheck');
    var sigForm = document.getElementById('signForm');
    var sigDataInput = document.getElementById('signatureDataUrl');

    function renderPreview() {
      if (!typedNameInput || !sigPreview) return;
      var v = typedNameInput.value.trim();
      sigPreview.textContent = v || '\u00a0';
    }

    if (typedNameInput) {
      typedNameInput.addEventListener('input', renderPreview);
      typedNameInput.addEventListener('change', renderPreview);
    }

    function nameToSignatureImage(name) {
      // Render the typed name as a cursive PNG image in-memory (no user drawing needed)
      var c = document.createElement('canvas');
      c.width = 600;
      c.height = 140;
      var cx = c.getContext('2d');
      cx.fillStyle = '#ffffff';
      cx.fillRect(0, 0, c.width, c.height);
      cx.fillStyle = '#0a0a0c';
      cx.font = 'italic 56px "Brush Script MT", "Lucida Handwriting", cursive';
      cx.textAlign = 'center';
      cx.textBaseline = 'middle';
      cx.fillText(name, c.width / 2, c.height / 2);
      return c.toDataURL('image/png');
    }

    if (sigForm && isAvailable && !isAdmin) {
      sigForm.addEventListener('submit', function(e) {
        var name = (typedNameInput ? typedNameInput.value : '').trim();
        if (!name || name.length < 3) {
          e.preventDefault();
          alert('Please type your full legal name (at least 3 characters).');
          if (typedNameInput) typedNameInput.focus();
          return false;
        }
        if (acceptCheck && !acceptCheck.checked) {
          e.preventDefault();
          alert('Please tick the acceptance checkbox.');
          return false;
        }
        try {
          sigDataInput.value = nameToSignatureImage(name);
        } catch (err) {
          // If canvas/toDataURL fails for any reason on Safari, fall back to a safer text-only data URL
          sigDataInput.value = 'data:image/svg+xml;utf8,' + encodeURIComponent(
            '<svg xmlns="http://www.w3.org/2000/svg" width="600" height="140"><rect width="100%" height="100%" fill="#fff"/><text x="50%" y="50%" font-family="cursive" font-style="italic" font-size="56" text-anchor="middle" dominant-baseline="middle" fill="#0a0a0c">' +
            name.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;') +
            '</text></svg>'
          );
        }
      });
    }

    // Download PDF
    var dlBtn = document.getElementById('downloadPdfBtn');
    if (dlBtn) dlBtn.addEventListener('click', function() {
      dlBtn.disabled = true;
      dlBtn.textContent = 'Preparing PDF...';
      var letter = document.getElementById('offerLetter');
      if (!letter || typeof html2canvas === 'undefined' || typeof window.jspdf === 'undefined') {
        dlBtn.disabled = false;
        dlBtn.textContent = 'Download PDF';
        alert('PDF library not loaded. Please refresh the page and try again.');
        return;
      }
      html2canvas(letter, { scale: 2, backgroundColor: '#ffffff', useCORS: true }).then(function(canvasImg) {
        var imgData = canvasImg.toDataURL('image/jpeg', 0.92);
        var pdf = new window.jspdf.jsPDF('p', 'mm', 'a4');
        var pdfW = 210, pdfH = 297;
        var imgW = pdfW;
        var imgH = (canvasImg.height * pdfW) / canvasImg.width;
        var heightLeft = imgH;
        var pos = 0;
        pdf.addImage(imgData, 'JPEG', 0, pos, imgW, imgH);
        heightLeft -= pdfH;
        while (heightLeft > 0) {
          pos = heightLeft - imgH;
          pdf.addPage();
          pdf.addImage(imgData, 'JPEG', 0, pos, imgW, imgH);
          heightLeft -= pdfH;
        }
        pdf.save('EduRankAI-Offer-Letter.pdf');
        dlBtn.disabled = false;
        dlBtn.textContent = 'Download PDF';
      }).catch(function(err) {
        console.error(err);
        dlBtn.disabled = false;
        dlBtn.textContent = 'Download PDF';
        alert('Failed to generate PDF. Try printing instead (Ctrl+P).');
      });
    });
  </script>

</BaseLayout>