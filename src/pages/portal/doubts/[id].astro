---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';

const user = Astro.locals.user;
const { id } = Astro.params;
if (!user) return Astro.redirect('/portal/login?next=' + encodeURIComponent('/portal/doubts/' + id));

function rowsOf(r: any): any[] { return Array.isArray(r) ? r : (r?.rows || []); }

// Idempotent schema (safe re-run)
try {
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS doubts (
      id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
      user_id uuid NOT NULL,
      course_id uuid,
      subject text NOT NULL,
      body text NOT NULL,
      language text DEFAULT 'en',
      urgency text DEFAULT 'med',
      status text DEFAULT 'open',
      aquin_answer text,
      accepted_answer_id uuid,
      created_at timestamptz DEFAULT now()
    )
  `);
  await db.execute(sql`
    CREATE TABLE IF NOT EXISTS doubt_answers (
      id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
      doubt_id uuid NOT NULL REFERENCES doubts(id) ON DELETE CASCADE,
      user_id uuid,
      body text NOT NULL,
      is_aquin boolean DEFAULT false,
      upvotes integer DEFAULT 0,
      created_at timestamptz DEFAULT now()
    )
  `);
} catch (e) { console.error('doubts schema bootstrap', e); }

let errMsg = '', okMsg = '';

if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const action = (fd.get('action') as string || '').trim();
    if (action === 'reply') {
      const body = (fd.get('body') as string || '').trim().slice(0, 6000);
      if (body.length < 5) errMsg = 'Reply must be at least 5 characters.';
      else {
        await db.execute(sql`
          INSERT INTO doubt_answers (doubt_id, user_id, body, is_aquin)
          VALUES (${id}, ${user.id}, ${body}, false)
        `);
        // If the doubt is still in 'open', flip to 'peer_answered'
        await db.execute(sql`
          UPDATE doubts SET status = 'peer_answered'
          WHERE id = ${id} AND status = 'open'
        `);
        okMsg = 'Your reply was posted.';
      }
    } else if (action === 'upvote') {
      const ansId = (fd.get('answer_id') as string || '').trim();
      if (ansId) {
        await db.execute(sql`UPDATE doubt_answers SET upvotes = COALESCE(upvotes, 0) + 1 WHERE id = ${ansId}`);
      }
    } else if (action === 'accept') {
      const ansId = (fd.get('answer_id') as string || '').trim();
      // Only the original poster can accept
      const owner = rowsOf(await db.execute(sql`SELECT user_id FROM doubts WHERE id = ${id}`));
      if (owner[0]?.user_id === user.id && ansId) {
        await db.execute(sql`
          UPDATE doubts SET accepted_answer_id = ${ansId}, status = 'resolved'
          WHERE id = ${id}
        `);
        okMsg = 'Marked as accepted. Doubt is now resolved.';
      } else {
        errMsg = 'Only the original poster can accept an answer.';
      }
    }
  } catch (e: any) { errMsg = String(e?.message || e).slice(0, 240); }
}

const doubtRows = rowsOf(await db.execute(sql`SELECT * FROM doubts WHERE id = ${id} LIMIT 1`));
const doubt = doubtRows[0];
if (!doubt) {
  return new Response('Doubt not found', { status: 404 });
}

// Fetch original poster's display info
let posterName = 'a learner';
try {
  const poster = rowsOf(await db.execute(sql`SELECT name, email FROM users WHERE id = ${doubt.user_id} LIMIT 1`));
  if (poster[0]) posterName = poster[0].name || (poster[0].email ? String(poster[0].email).split('@')[0] : 'a learner');
} catch {}

const answers = rowsOf(await db.execute(sql`
  SELECT da.*, u.name AS user_name, u.email AS user_email
  FROM doubt_answers da
  LEFT JOIN users u ON da.user_id = u.id
  WHERE da.doubt_id = ${id}
  ORDER BY COALESCE(da.upvotes, 0) DESC, da.created_at ASC
`));

const isOwner = doubt.user_id === user.id;
const URGENCY_LABEL: Record<string, string> = { low: 'Low', med: 'Medium', high: 'High' };

function relTime(d: any): string {
  try {
    const t = new Date(d).getTime();
    const diff = Date.now() - t;
    const m = Math.floor(diff / 60000);
    if (m < 1) return 'just now';
    if (m < 60) return m + ' min ago';
    const h = Math.floor(m / 60);
    if (h < 24) return h + ' h ago';
    const days = Math.floor(h / 24);
    if (days < 30) return days + ' d ago';
    return new Date(d).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short', year: 'numeric' });
  } catch { return ''; }
}

function nameFrom(a: any): string {
  if (a.is_aquin) return 'Aquin AI';
  if (a.user_name) return a.user_name;
  if (a.user_email) return String(a.user_email).split('@')[0];
  return 'A peer';
}

const urgencyTone = doubt.urgency === 'high' ? 'bg-burn-pale text-burn border-burn-dim'
  : doubt.urgency === 'low' ? 'bg-cream-2 text-ink-soft border-ink/10'
  : 'bg-white text-ink-2 border-ink/10';

const statusTone = doubt.status === 'resolved' ? 'bg-leaf-bg text-leaf border-leaf-border'
  : doubt.status === 'aquin_answered' ? 'bg-leaf-bg text-leaf border-leaf-border'
  : doubt.status === 'peer_answered' ? 'bg-sky-bg text-sky border-sky-border'
  : 'bg-white text-ink-soft border-ink/15';
---
<BaseLayout title={`${doubt.subject} doubt · EduRankAI`}>
<section class="px-[5vw] pt-10 md:pt-14 pb-4 max-w-3xl mx-auto">
  <a href="/portal/doubts" class="text-[0.78rem] font-mono uppercase tracking-wider text-burn hover:underline no-underline">&larr; Doubt Board</a>
</section>

<section class="px-[5vw] pb-6 max-w-3xl mx-auto">

  {okMsg && (
    <div class="bg-leaf-bg border border-leaf-border rounded-2xl px-5 py-3 mb-4">
      <p class="font-display text-[0.95rem] font-semibold text-leaf m-0">{okMsg}</p>
    </div>
  )}
  {errMsg && <div class="bg-burn-pale border border-burn-dim rounded-xl px-4 py-3 mb-4 text-[0.88rem] text-burn font-semibold">{errMsg}</div>}

  <article class="bg-white border border-ink/10 rounded-2xl p-6 md:p-8">
    <div class="flex items-center gap-2 flex-wrap mb-3">
      <span class="font-mono text-[0.62rem] uppercase tracking-[0.18em] text-burn font-bold">{doubt.subject}</span>
      <span class={`font-mono text-[0.58rem] uppercase tracking-[0.14em] font-bold px-2 py-0.5 rounded-full border ${urgencyTone}`}>{URGENCY_LABEL[doubt.urgency] || 'Medium'}</span>
      <span class={`font-mono text-[0.58rem] uppercase tracking-[0.14em] font-bold px-2 py-0.5 rounded-full border ${statusTone}`}>{doubt.status}</span>
      <span class="font-mono text-[0.58rem] uppercase tracking-[0.14em] text-ink-soft">Language: {doubt.language || 'en'}</span>
    </div>
    <p class="text-[0.78rem] text-ink-soft font-mono m-0 mb-3">Asked by {posterName} &middot; {relTime(doubt.created_at)}</p>
    <p class="text-[1.05rem] text-ink-2 leading-[1.75] m-0 whitespace-pre-wrap font-body">{doubt.body}</p>
  </article>

  <div class="mt-6 mb-3 flex items-center justify-between gap-2 flex-wrap">
    <h2 class="font-display text-[1.4rem] font-semibold text-ink m-0">
      {answers.length} {answers.length === 1 ? 'answer' : 'answers'}
    </h2>
    {doubt.status === 'resolved' && (
      <span class="font-mono text-[0.62rem] uppercase tracking-[0.14em] font-bold px-2.5 py-1 rounded-full border bg-leaf-bg text-leaf border-leaf-border">Resolved</span>
    )}
  </div>

  {answers.length === 0 ? (
    <div class="bg-cream-2/60 border border-ink/10 rounded-2xl p-6 text-center mb-6">
      <p class="text-[0.9rem] text-ink-soft m-0">No replies yet. Be the first to help.</p>
    </div>
  ) : (
    <div class="space-y-3 mb-6">
      {answers.map((a: any) => {
        const isAccepted = doubt.accepted_answer_id === a.id;
        return (
          <article class={`bg-white border rounded-2xl p-5 ${isAccepted ? 'border-leaf border-2' : 'border-ink/10'}`}>
            <div class="flex justify-between items-start gap-3 flex-wrap mb-2">
              <div class="flex items-center gap-2 flex-wrap">
                <p class="font-display text-[0.95rem] font-semibold text-ink m-0">{nameFrom(a)}</p>
                {a.is_aquin && (
                  <span class="inline-flex items-center gap-1 font-mono text-[0.58rem] uppercase tracking-[0.14em] font-bold px-2 py-0.5 rounded-full border bg-burn-pale text-burn border-burn-dim">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v1H7a3 3 0 0 0-3 3v2H3a1 1 0 1 0 0 2h1v2a3 3 0 0 0 3 3h2v1a3 3 0 1 0 6 0v-1h2a3 3 0 0 0 3-3v-2h1a1 1 0 1 0 0-2h-1V9a3 3 0 0 0-3-3h-2V5a3 3 0 0 0-3-3z"/></svg>
                    Aquin AI
                  </span>
                )}
                {isAccepted && (
                  <span class="inline-flex items-center gap-1 font-mono text-[0.58rem] uppercase tracking-[0.14em] font-bold px-2 py-0.5 rounded-full border bg-leaf-bg text-leaf border-leaf-border">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    Accepted
                  </span>
                )}
              </div>
              <span class="text-[0.72rem] text-ink-soft font-mono">{relTime(a.created_at)}</span>
            </div>
            <p class="text-[0.95rem] text-ink-2 leading-[1.7] m-0 whitespace-pre-wrap font-body">{a.body}</p>
            <div class="mt-3 flex items-center gap-3 flex-wrap">
              <form method="POST" class="inline">
                <input type="hidden" name="action" value="upvote" />
                <input type="hidden" name="answer_id" value={a.id} />
                <button type="submit" class="inline-flex items-center gap-1 text-[0.78rem] text-ink-soft hover:text-burn font-mono">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 10v12"/><path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H7"/></svg>
                  {Number(a.upvotes) || 0}
                </button>
              </form>
              {isOwner && !isAccepted && doubt.status !== 'resolved' && (
                <form method="POST" class="inline">
                  <input type="hidden" name="action" value="accept" />
                  <input type="hidden" name="answer_id" value={a.id} />
                  <button type="submit" class="inline-flex items-center gap-1 text-[0.78rem] font-mono uppercase tracking-[0.12em] text-leaf font-semibold hover:underline">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    Mark as accepted
                  </button>
                </form>
              )}
            </div>
          </article>
        );
      })}
    </div>
  )}

  {doubt.status !== 'resolved' && (
    <form method="POST" class="bg-white border border-ink/10 rounded-2xl p-6 space-y-4">
      <input type="hidden" name="action" value="reply" />
      <div>
        <label class="block text-[0.62rem] font-mono uppercase tracking-[0.14em] text-ink-soft font-bold mb-2">Your answer</label>
        <textarea name="body" rows="5" required minlength="5" maxlength="6000"
          placeholder="Explain step by step. If you cite a formula or rule, name it."
          class="w-full bg-cream border border-ink/15 rounded-xl px-4 py-3 text-[0.95rem] text-ink font-body leading-relaxed resize-y focus:border-burn focus:outline-none"></textarea>
      </div>
      <button type="submit" class="btn-primary">Post answer &rarr;</button>
    </form>
  )}
</section>
</BaseLayout>
