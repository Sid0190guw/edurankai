---
// BeforeYouApply.astro — the transparency panel surfaced everywhere applicants
// are about to start filling forms. Shows the fee for THIS role (if known),
// what we collect, what we will not do with it, and a link to the full policy.
//
// Props:
//   feeAmount?: number               — application fee for this role (CHF)
//   feeCurrency?: string             — usually 'CHF'
//   roleLevel?: string               — e.g. 'Senior', 'Intern' — used to set fee context
//   compact?: boolean                — render the small (no-headline) version

interface Props {
  feeAmount?: number;
  feeCurrency?: string;
  roleLevel?: string;
  compact?: boolean;
}

const { feeAmount, feeCurrency = 'CHF', roleLevel, compact = false } = Astro.props;

const showFee = typeof feeAmount === 'number' && feeAmount >= 0;
const feeLabel = showFee ? feeCurrency + ' ' + Number(feeAmount).toFixed(0) : null;

const COLLECT = [
  { label: 'Name, email, phone', why: 'Account + application updates. No marketing.' },
  { label: 'Resume / portfolio link', why: 'Human review of your work.' },
  { label: 'Date + place of birth', why: 'Identity verification only.' },
  { label: 'Your written responses', why: 'Selection rubric. Read by humans.' },
  { label: 'Government ID (later)', why: 'Anti-fraud at offer / interview stage. Not at signup.' },
];

const NEVER = [
  'Sell your data',
  'Share with third-party recruiters',
  'Use for advertising',
  'Train models on it',
  'Send marketing email',
];
---

<div style="background:#fff;border:1px solid rgba(0,0,0,0.08);border-radius:14px;padding:18px 20px;margin-bottom:18px;">
  {!compact && (
    <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:14px;flex-wrap:wrap;">
      <div>
        <p style="font-family:'Geist Mono','JetBrains Mono',monospace;font-size:10.5px;letter-spacing:0.16em;text-transform:uppercase;color:#DC5000;font-weight:700;margin:0 0 3px;">Before you start</p>
        <p style="font-family:'Fraunces',serif;font-size:1.15rem;font-weight:600;color:#1c1d22;margin:0;line-height:1.25;">What we will collect. What it costs. What we will not do with it.</p>
      </div>
      {showFee && (
        <div style="text-align:right;flex-shrink:0;">
          <p style="font-family:'Geist Mono','JetBrains Mono',monospace;font-size:9.5px;letter-spacing:0.14em;text-transform:uppercase;color:#5b5b5b;font-weight:700;margin:0 0 2px;">Application fee</p>
          <p style="font-family:'Fraunces',serif;font-size:1.35rem;font-weight:600;color:#1c1d22;margin:0;line-height:1;">{feeLabel}</p>
          {roleLevel && <p style="font-size:10.5px;color:#5b5b5b;margin:3px 0 0;font-family:'Inter Tight',sans-serif;">{roleLevel} tier</p>}
        </div>
      )}
    </div>
  )}

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-bottom:14px;">
    <div>
      <p style="font-family:'Geist Mono','JetBrains Mono',monospace;font-size:9.5px;letter-spacing:0.14em;text-transform:uppercase;color:#5b5b5b;font-weight:700;margin:0 0 8px;">We will collect</p>
      <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:7px;">
        {COLLECT.map((c) => (
          <li style="font-family:'Inter Tight',sans-serif;font-size:12px;color:#1c1d22;line-height:1.5;">
            <span style="font-weight:600;">{c.label}</span>
            <span style="color:#5b5b5b;"> &mdash; {c.why}</span>
          </li>
        ))}
      </ul>
    </div>
    <div>
      <p style="font-family:'Geist Mono','JetBrains Mono',monospace;font-size:9.5px;letter-spacing:0.14em;text-transform:uppercase;color:#5b5b5b;font-weight:700;margin:0 0 8px;">We will never</p>
      <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:7px;">
        {NEVER.map((n) => (
          <li style="font-family:'Inter Tight',sans-serif;font-size:12px;color:#1c1d22;line-height:1.5;display:flex;align-items:flex-start;gap:6px;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#DC5000" stroke-width="2.5" stroke-linecap="round" style="flex-shrink:0;margin-top:3px;"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            <span>{n}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div style="background:#faf8f3;border:1px solid #e6e3da;border-radius:10px;padding:12px 14px;margin-bottom:12px;">
    <p style="font-family:'Geist Mono','JetBrains Mono',monospace;font-size:9.5px;letter-spacing:0.14em;text-transform:uppercase;color:#DC5000;font-weight:700;margin:0 0 5px;">Our situation</p>
    <p style="font-family:'Inter Tight',sans-serif;font-size:12.5px;color:#1c1d22;line-height:1.65;margin:0;">
      EduRankAI is a small, independent organization building long-term capabilities in educational intelligence, advanced AI systems, and research infrastructure. We take no advertiser money, no donations with strings attached, and no investor pressure on hiring decisions. The small per-application fee covers the real cost of processing your application &mdash; human review, identity verification, infrastructure, reviewer time. It buys us the right to be honest. <strong>Genuine financial hardship?</strong> Request a fee waiver inside the application &mdash; reviewed individually within 5 business days, with no record in your file and no second-class treatment of waiver-granted applications.
    </p>
  </div>

  <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
    <a href="/policy/candidate-transparency" style="display:inline-flex;align-items:center;gap:6px;font-family:'Inter Tight',sans-serif;font-size:11.5px;font-weight:700;color:#DC5000;text-decoration:none;border:1px solid #DC5000;padding:6px 12px;border-radius:6px;">
      Full transparency policy
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m9 18 6-6-6-6"/></svg>
    </a>
    {showFee && (
      <a href="/policy/fees" style="display:inline-flex;align-items:center;gap:6px;font-family:'Inter Tight',sans-serif;font-size:11.5px;font-weight:600;color:#5b5b5b;text-decoration:none;border:1px solid #d6d3cb;padding:6px 12px;border-radius:6px;">
        Why we charge a fee
      </a>
    )}
    <a href="mailto:hr@edurankai.in" style="display:inline-flex;align-items:center;gap:6px;font-family:'Inter Tight',sans-serif;font-size:11.5px;font-weight:600;color:#5b5b5b;text-decoration:none;border:1px solid #d6d3cb;padding:6px 12px;border-radius:6px;">
      Questions? Email us
    </a>
  </div>
</div>
