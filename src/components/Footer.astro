---
import { SITE, NAV_PRIMARY } from '@/lib/site';
---
<footer class="bg-cream-2 border-t border-ink/10 px-[5vw] py-7 flex items-center justify-between flex-wrap gap-4 relative z-[2]">
  <a href="/" class="font-display text-[1rem] font-bold text-ink">
    EduRank<span class="text-burn">AI</span>
  </a>
  <div class="flex gap-5 flex-wrap text-[0.78rem] text-ink-soft">
    {NAV_PRIMARY.map((item) => (
      <a href={item.href} class="hover:text-burn transition-colors">{item.label}</a>
    ))}
    <a href={SITE.socials.linkedin} target="_blank" rel="noopener" class="text-burn font-medium">LinkedIn</a>
    <a href={`mailto:${SITE.emails.hr}`} class="text-burn font-medium">HR</a>
  </div>
  <p class="text-[0.7rem] text-ink-soft/70 w-full md:w-auto">{SITE.copyright}</p>
</footer>
