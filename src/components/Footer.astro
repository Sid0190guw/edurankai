---
import { SITE } from '@/lib/site';
const year = new Date().getFullYear();
const user = Astro.locals.user;
---
<footer class="border-t border-ink/8 bg-cream-2/40 mt-20">
  <div class="px-[5vw] py-12 max-w-7xl mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8 mb-10">
      <div class="col-span-2 md:col-span-1">
        <p class="font-display text-lg font-semibold text-ink mb-2">
          EduRank<em class="not-italic text-burn">AI</em>
        </p>
        <p class="text-[0.78rem] text-ink-soft leading-relaxed max-w-[200px]">
          Frontier AI educational intelligence. Building for Bharat. Building for the world.
        </p>
      </div>

      <div>
        <p class="text-[0.68rem] font-mono uppercase tracking-wider text-ink-soft mb-3 font-semibold">Explore</p>
        <div class="flex flex-col gap-2">
          <a href="/" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">Home</a>
          <a href="/about" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">About</a>
          <a href="/hei" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">HEI</a>
          <a href="/aquintutor" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">AquinTutor</a>
          <a href="/research" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">Research</a>
          <a href="/careers" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">Careers</a>
          <a href="/ecosystem" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">Ecosystem</a>
          <a href="/events" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">Events</a>
          <a href="/faq" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">FAQ</a>
          <a href="/policy/fees" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">Why a fee?</a>
          <a href="/policy/recruitment" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">Recruitment policy</a>
          <a href="/contact" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">Contact</a>
        </div>
      </div>

      <div>
        <p class="text-[0.68rem] font-mono uppercase tracking-wider text-ink-soft mb-3 font-semibold">Applicant Portal</p>
        <div class="flex flex-col gap-2">
          {!user && (
            <>
              <a href="/portal/signup" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">Create Account</a>
              <a href="/portal/login" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">Sign In</a>
            </>
          )}
          {user && user.role === 'applicant' && (
            <a href="/portal" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">My Applications</a>
          )}
          {user && user.role !== 'applicant' && (
            <a href="/admin" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">Admin Panel</a>
          )}
          <a href="/careers" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">Browse Open Roles</a>
        </div>
      </div>

      <div>
        <p class="text-[0.68rem] font-mono uppercase tracking-wider text-ink-soft mb-3 font-semibold">Connect</p>
        <div class="flex flex-col gap-2">
          <a href="mailto:connect@edurankai.in" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">connect@edurankai.in</a>
          <a href="https://www.linkedin.com/company/edurankai/" target="_blank" rel="noopener noreferrer" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">LinkedIn ↗</a>
          <a href="https://edurankai.in" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">edurankai.in</a>
        </div>
      </div>
      <div>
        <p class="text-[0.68rem] font-mono uppercase tracking-wider text-ink-soft mb-3 font-semibold">Trust</p>
        <div class="flex flex-col gap-2">
          <a href="/p/hiring-philosophy" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">Hiring Philosophy</a>
          <a href="/p/privacy" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">Privacy Policy</a>
          <a href="/p/terms" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">Terms of Service</a>
          <a href="/accessibility" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">Accessibility</a>
          <a href="mailto:security@edurankai.in" class="text-[0.82rem] text-ink-2 hover:text-burn transition-colors">Security Disclosure</a>
        </div>
      </div>
    </div>

    <div class="pt-6 border-t border-ink/8 flex flex-col md:flex-row items-start md:items-center justify-between gap-3">
      <p class="text-[0.72rem] text-ink-soft">
        © {year} EduRankAI · Building for Bharat. Building for the world.
      </p>
      <p class="text-[0.7rem] font-mono text-ink-soft/70">
        Made in India with care
      </p>
    </div>
  </div>
</footer>
