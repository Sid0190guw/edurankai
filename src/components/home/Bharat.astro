---
import { BHARAT } from '@/data/home';
---
<section class="px-[5vw] py-20 md:py-28 max-w-6xl mx-auto">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
    <div>
      <p class="eyebrow mb-3">{BHARAT.eyebrow}</p>
      <h2 class="section-title mb-5" set:html={BHARAT.title} />
      <p class="text-[0.95rem] text-ink-soft font-light leading-[1.85]">{BHARAT.body}</p>
    </div>
    <div class="grid grid-cols-2 gap-3">
      {BHARAT.stats.map((s) => (
        <div class="bg-cream-2 border border-ink/10 rounded-xl p-6">
          <div class="font-display text-[2.2rem] font-bold text-burn leading-none mb-2">{s.value}</div>
          <p class="text-[0.72rem] text-ink-soft font-medium uppercase tracking-wider">{s.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
