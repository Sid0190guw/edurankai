---
import { DIMENSIONS } from '@/data/home';
const colorMap = {
  burn: 'bg-burn-pale border-burn-dim text-burn',
  sky: 'bg-sky-bg border-sky-border text-sky',
  plum: 'bg-plum-bg border-plum-border text-plum',
  teal: 'bg-teal-bg border-teal-border text-teal',
  gold: 'bg-gold-bg border-gold-border text-gold-deep'
};
---
<section class="bg-cream-2 px-[5vw] py-20 md:py-28">
  <div class="max-w-6xl mx-auto">
    <div class="max-w-2xl mb-12">
      <p class="eyebrow mb-3">The Standard</p>
      <h2 class="section-title mb-4">We see the <em>whole person.</em></h2>
      <p class="text-[0.9rem] text-ink-soft font-light leading-[1.8]">At hiring. And every day after. We evaluate every team member across five dimensions of human wholeness - because the product we are building serves the same dimensions in learners worldwide.</p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
      {DIMENSIONS.map((d) => (
        <div class="bg-white border border-ink/10 rounded-xl p-5 text-center transition-all hover:-translate-y-1 hover:shadow-lg">
          <div class={`w-12 h-12 rounded-full border flex items-center justify-center text-xl mx-auto mb-3 ${colorMap[d.color]}`}>*</div>
          <div class="font-display text-[1.05rem] font-bold text-ink mb-1.5">{d.title}</div>
          <p class="text-[0.72rem] text-ink-soft leading-relaxed">{d.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
