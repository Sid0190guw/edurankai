---
import { PRODUCTS as P } from '@/data/home';

const variantClass = (v) => {
  if (v === 'soon') return 'bg-burn-pale text-burn border-burn-dim';
  if (v === 'dev') return 'bg-gold-bg text-gold-deep border-gold-border';
  if (v === 'research') return 'bg-plum-bg text-plum border-plum-border';
  if (v === 'launch') return 'bg-leaf-bg text-leaf border-leaf-border';
  if (v === 'stealth') return 'bg-ink/5 text-ink-2 border-ink/15';
  return 'bg-cream-2 text-ink-soft border-ink/10';
};
---
<section class="px-[5vw] py-20 md:py-28 max-w-7xl mx-auto">
  <div class="max-w-2xl mb-12">
    <p class="eyebrow mb-3">Ecosystem</p>
    <h2 class="section-title mb-4">Six ventures, <em>one mission</em></h2>
    <p class="text-[0.9rem] text-ink-soft font-light leading-[1.8]">EduRankAI is the parent. Around it we build and incubate a family of products that solve real problems in education, human connection, travel, business, and community. Each ships independently with its own team and brand, anchored by shared values and shared infrastructure.</p>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    {P.map((p) => (
      <a href={p.href} target={p.external ? '_blank' : '_self'} rel={p.external ? 'noopener noreferrer' : ''} class="group bg-white border border-ink/10 rounded-2xl p-6 transition-all hover:border-burn-dim hover:-translate-y-1 hover:shadow-xl flex flex-col">
        <div class="flex items-center justify-between mb-5">
          <span class={`inline-block text-[0.6rem] font-bold tracking-[0.1em] uppercase border px-2.5 py-1 rounded-full ${variantClass(p.statusVariant)}`}>{p.status}</span>
          {p.external && <span class="text-[0.7rem] font-mono text-ink-soft/60 group-hover:text-burn transition-colors">↗</span>}
        </div>
        <h3 class="font-display text-[1.25rem] font-bold text-ink mb-3 leading-tight">{p.name}</h3>
        <p class="text-[0.8rem] text-ink-soft font-light leading-relaxed mb-5 flex-1">{p.description}</p>
        <span class="text-[0.78rem] font-semibold text-burn">{p.external ? 'Visit site' : 'Learn more'}</span>
      </a>
    ))}
  </div>
  <div class="mt-10 bg-cream-2 border border-ink/10 rounded-2xl p-6 md:p-8 flex flex-col md:flex-row items-start md:items-center gap-5 max-w-5xl">
    <div class="flex-1">
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn mb-2">Continuous Pipeline</p>
      <h3 class="font-display text-[1.1rem] font-bold text-ink mb-2 leading-tight">More ventures incubating quietly</h3>
      <p class="text-[0.82rem] text-ink-soft font-light leading-relaxed">Beyond the six visible products, we have additional ventures in early research, design, and prototyping. We share them only when they are genuinely ready. Want to help build the next one? Apply to our Founder Office programme.</p>
    </div>
    <a href="/careers" class="btn-primary whitespace-nowrap flex-shrink-0">View Open Roles</a>
  </div>
</section>
