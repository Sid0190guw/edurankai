---
import { PRODUCTS as P } from '@/data/home';

const variantClass = (v) => {
  if (v === 'launch') return 'bg-leaf-bg text-leaf border-leaf-border';
  if (v === 'dev') return 'bg-burn-pale text-burn border-burn-dim';
  if (v === 'planning') return 'bg-gold-bg text-gold-deep border-gold-border';
  if (v === 'research') return 'bg-plum-bg text-plum border-plum-border';
  return 'bg-cream-2 text-ink-soft border-ink/10';
};
---
<section class="px-[5vw] py-20 md:py-28 max-w-6xl mx-auto">
  <div class="max-w-2xl mb-12">
    <p class="eyebrow mb-3">The ecosystem</p>
    <h2 class="section-title mb-4">Six bets. <em>One thesis.</em></h2>
    <p class="text-[0.95rem] text-ink-soft font-light leading-[1.8]">
      Foundational research anchors the lab. Around it, we incubate ventures where our reasoning systems can meet the real world — education, travel, relationships, work. Each ships independently. Each serves the same long-term goal.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    {P.map((p) => (
      <a href={p.href} target={p.external ? '_blank' : '_self'} rel={p.external ? 'noopener noreferrer' : ''} class="group bg-white border border-ink/10 rounded-2xl p-6 transition-all hover:border-burn-dim hover:-translate-y-1 hover:shadow-xl flex flex-col">
        <div class="flex items-center justify-between mb-5">
          <span class={`inline-block text-[0.6rem] font-bold tracking-[0.1em] uppercase border px-2.5 py-1 rounded-full ${variantClass(p.statusVariant)}`}>{p.status}</span>
          {p.external && <span class="text-[0.7rem] font-mono text-ink-soft/60 group-hover:text-burn transition-colors">&#8599;</span>}
        </div>
        <h3 class="font-display text-[1.3rem] font-bold text-ink mb-2 leading-tight">{p.name}</h3>
        {p.tagline && <p class="text-[0.78rem] font-mono text-burn/80 uppercase tracking-wider mb-4">{p.tagline}</p>}
        <p class="text-[0.82rem] text-ink-soft font-light leading-relaxed mb-5 flex-1">{p.description}</p>
        <span class="text-[0.82rem] font-semibold text-burn group-hover:gap-2 inline-flex items-center gap-1 transition-all">
          {p.external ? 'Visit' : 'Learn more'} <span>&rarr;</span>
        </span>
      </a>
    ))}

    <div class="bg-cream-2/60 border-2 border-dashed border-ink/15 rounded-2xl p-6 flex flex-col items-center justify-center text-center min-h-[280px]">
      <div class="w-12 h-12 rounded-full border-2 border-dashed border-burn/40 flex items-center justify-center mb-4">
        <span class="text-burn text-xl font-light">+</span>
      </div>
      <h3 class="font-display text-[1.1rem] font-semibold text-ink mb-2">More coming</h3>
      <p class="text-[0.78rem] text-ink-soft font-light leading-relaxed">
        We share new ventures when they are real. Not before.
      </p>
    </div>
  </div>
</section>