---
import { HERO } from '@/data/home';
---
<section class="relative overflow-hidden px-[5vw] pt-20 pb-24 md:pt-28 md:pb-32 max-w-7xl mx-auto">
  <div class="relative z-10 max-w-4xl">
    <div class="inline-flex items-center gap-2 bg-burn-pale border border-burn-dim text-burn px-3.5 py-1.5 rounded-full text-[0.7rem] font-bold tracking-[0.08em] uppercase mb-7">
      <span class="w-1.5 h-1.5 bg-burn rounded-full animate-pulse-slow"></span>
      {HERO.badge}
    </div>
    <h1 class="font-display text-[clamp(2.4rem,6vw,4.8rem)] font-light leading-[1.02] tracking-hero text-ink mb-7">
      {HERO.headlineTop} <span class="font-medium">{HERO.headlineBottomA}</span><br />
      <em class="italic text-burn font-medium">{HERO.headlineEm}</em>
      <span class="font-bold">{HERO.headlineBottomB}</span>
    </h1>
    <p class="text-[0.98rem] md:text-[1rem] text-ink-soft font-light leading-[1.85] max-w-2xl mb-10">{HERO.description}</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2.5 max-w-2xl mb-10">
      {HERO.levels.map((lvl) => (
        <div class="flex items-start gap-3 bg-white border border-ink/10 rounded-xl px-4 py-3.5 hover:border-burn-dim transition-colors">
          <div class="w-9 h-9 rounded-lg bg-burn-pale border border-burn-dim flex items-center justify-center text-burn font-bold text-sm flex-shrink-0">+</div>
          <div>
            <div class="text-[0.85rem] font-bold text-ink mb-0.5">{lvl.title}</div>
            <div class="text-[0.75rem] text-ink-soft font-light leading-snug">{lvl.sub}</div>
          </div>
        </div>
      ))}
    </div>
    <div class="flex flex-wrap gap-3">
      <a href="/careers" class="btn-primary">View All Openings</a>
      <a href="/ecosystem" class="btn-ghost">Our Ecosystem</a>
    </div>
  </div>
</section>
