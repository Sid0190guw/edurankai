---
import { MISSION } from '@/data/home';
---
<section class="border-y border-ink/10 bg-cream-2/60 px-[5vw] py-20 md:py-28">
  <div class="max-w-4xl mx-auto">
    <p class="eyebrow mb-4">{MISSION.eyebrow}</p>
    <h2 class="section-title mb-10" set:html={MISSION.title} />
    <div class="space-y-6">
      {MISSION.body.map((para) => (
        <p class="text-[0.95rem] md:text-[1rem] text-ink-2 font-light leading-[1.85]">{para}</p>
      ))}
    </div>
  </div>
</section>
