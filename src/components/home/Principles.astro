---
import { PRINCIPLES } from '@/data/home';
---
<section class="bg-ink text-white px-[5vw] py-20 md:py-28 relative overflow-hidden">
  <div class="relative z-10 max-w-5xl mx-auto">
    <p class="font-mono text-[0.6rem] uppercase tracking-[0.22em] text-gold mb-5">The EduRankAI Hiring Principle</p>
    <p class="font-display italic text-[clamp(1.5rem,3.2vw,2.6rem)] font-light text-white leading-[1.35] mb-12 max-w-4xl">"We would rather hire a <strong class="not-italic font-bold text-gold">brilliant dropout</strong> who has shipped something real than a mediocre graduate from the world's most famous university. The degree tells us where you've been. <strong class="not-italic font-bold text-gold">Your work tells us who you are.</strong>"</p>
    <p class="font-mono text-[0.65rem] tracking-[0.12em] uppercase text-white/30 mb-10">EduRankAI Founding Philosophy 2026</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
      {PRINCIPLES.map((p) => (
        <div class="bg-white/[0.04] border border-white/10 rounded-xl p-6 hover:bg-burn/10 hover:border-burn/30 transition-all">
          <span class="font-display text-[2.5rem] font-bold text-white/20 block leading-none mb-3">{p.n}</span>
          <div class="text-[0.92rem] font-bold text-white mb-2">{p.title}</div>
          <p class="text-[0.78rem] text-white/50 leading-relaxed font-light">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
