---
// Sambandh — Sanskrit for "relationship". Hero animation depicts purposeful
// human connection: a constellation of nodes (learners, mentors, peers) that
// pulse, attract, form a high-confidence match (thick beam), then ripple out.
// Three independent rhythms layered so it never reads as a single loop.
---
<section class="relative w-full bg-gradient-to-b from-cream via-cream-2/60 to-cream overflow-hidden">
  <div class="px-[5vw] py-12 md:py-20 max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center">

      <div class="md:col-span-5 relative z-10">
        <p class="eyebrow mb-4">सम्बन्ध · The relationship layer</p>
        <h2 class="font-display text-[clamp(2rem,4.5vw,3.4rem)] font-semibold text-ink leading-[1.05] tracking-tight mb-5">
          Connections that <em class="italic text-burn font-medium">earn their place.</em>
        </h2>
        <p class="text-[0.98rem] text-ink-2 font-light leading-[1.85]">
          Most matching platforms optimise for time-on-app. Sambandh is built for outcomes — did the learner actually progress because of who they met. Mentor matches, peer cohorts, study circles. The shape of the connection respects what learning actually needs.
        </p>
      </div>

      <div class="md:col-span-7 relative">
        <svg viewBox="0 0 600 420" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" style="max-height:480px;">
          <defs>
            <!-- Glow filter for nodes -->
            <filter id="sambandh-glow" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="3.5" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <!-- Soft halo -->
            <radialGradient id="sambandh-halo" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#FF7040" stop-opacity="0.4"/>
              <stop offset="100%" stop-color="#FF7040" stop-opacity="0"/>
            </radialGradient>
            <!-- Beam gradient (for matched-pair beams) -->
            <linearGradient id="sambandh-beam" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="#FF4F00" stop-opacity="0"/>
              <stop offset="50%" stop-color="#FF4F00" stop-opacity="0.95"/>
              <stop offset="100%" stop-color="#FF4F00" stop-opacity="0"/>
            </linearGradient>
            <!-- Background grid -->
            <pattern id="sambandh-grid" width="40" height="40" patternUnits="userSpaceOnUse">
              <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#0E0B08" stroke-opacity="0.04" stroke-width="0.6"/>
            </pattern>
          </defs>

          <rect width="600" height="420" fill="url(#sambandh-grid)"/>

          <!-- Soft connecting filaments — drawn first, low opacity -->
          <g stroke="#FF7040" stroke-width="0.6" fill="none" opacity="0.28">
            <path d="M 150 130 Q 260 100 340 180" />
            <path d="M 150 130 Q 220 220 320 280" />
            <path d="M 340 180 Q 420 230 480 130" />
            <path d="M 320 280 Q 410 320 480 290" />
            <path d="M 480 130 Q 540 200 480 290" />
            <path d="M 150 280 Q 230 320 320 280" />
            <path d="M 150 280 Q 100 200 150 130" />
            <path d="M 240 350 Q 320 320 410 350" />
            <path d="M 410 350 Q 480 350 480 290" />
            <path d="M 410 350 Q 360 280 340 180" />
          </g>

          <!-- Travelling pulses along filaments (the lifeblood of the connection layer) -->
          <g fill="#FF4F00">
            <circle r="2.6">
              <animateMotion dur="4.5s" repeatCount="indefinite" rotate="auto" path="M 150 130 Q 260 100 340 180"/>
              <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.1;0.9;1" dur="4.5s" repeatCount="indefinite"/>
            </circle>
            <circle r="2.6">
              <animateMotion dur="5.5s" begin="0.6s" repeatCount="indefinite" path="M 340 180 Q 420 230 480 130"/>
              <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.1;0.9;1" dur="5.5s" begin="0.6s" repeatCount="indefinite"/>
            </circle>
            <circle r="2.6">
              <animateMotion dur="6s" begin="1.4s" repeatCount="indefinite" path="M 320 280 Q 410 320 480 290"/>
              <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.1;0.9;1" dur="6s" begin="1.4s" repeatCount="indefinite"/>
            </circle>
            <circle r="2.6">
              <animateMotion dur="5s" begin="2s" repeatCount="indefinite" path="M 150 280 Q 230 320 320 280"/>
              <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.1;0.9;1" dur="5s" begin="2s" repeatCount="indefinite"/>
            </circle>
            <circle r="2.6">
              <animateMotion dur="5.8s" begin="2.8s" repeatCount="indefinite" path="M 410 350 Q 360 280 340 180"/>
              <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.1;0.9;1" dur="5.8s" begin="2.8s" repeatCount="indefinite"/>
            </circle>
          </g>

          <!-- The high-confidence MATCH beam — sweeps across between two key nodes -->
          <g>
            <line x1="150" y1="130" x2="480" y2="290" stroke="url(#sambandh-beam)" stroke-width="3" opacity="0">
              <animate attributeName="opacity" values="0;0;1;1;0;0" keyTimes="0;0.35;0.45;0.65;0.75;1" dur="9s" repeatCount="indefinite"/>
            </line>
            <line x1="340" y1="180" x2="240" y2="350" stroke="url(#sambandh-beam)" stroke-width="3" opacity="0">
              <animate attributeName="opacity" values="0;0;1;1;0;0" keyTimes="0;0.55;0.65;0.85;0.95;1" dur="9s" repeatCount="indefinite"/>
            </line>
          </g>

          <!-- People nodes — each a halo + a solid dot. Pulse rhythm independent per node. -->
          <g>
            <!-- Node 1 -->
            <circle cx="150" cy="130" r="22" fill="url(#sambandh-halo)">
              <animate attributeName="r" values="20;28;20" dur="3.4s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.5;0.95;0.5" dur="3.4s" repeatCount="indefinite"/>
            </circle>
            <circle cx="150" cy="130" r="7" fill="#FF4F00" filter="url(#sambandh-glow)"/>

            <!-- Node 2 — the central mentor -->
            <circle cx="340" cy="180" r="26" fill="url(#sambandh-halo)">
              <animate attributeName="r" values="22;32;22" dur="2.8s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.45;0.95;0.45" dur="2.8s" repeatCount="indefinite"/>
            </circle>
            <circle cx="340" cy="180" r="9" fill="#FF4F00" filter="url(#sambandh-glow)"/>
            <text x="340" y="155" text-anchor="middle" font-family="'Inter Tight', sans-serif" font-size="10" font-weight="700" fill="#0E0B08" opacity="0.55">MENTOR</text>

            <!-- Node 3 -->
            <circle cx="480" cy="130" r="20" fill="url(#sambandh-halo)">
              <animate attributeName="r" values="18;25;18" dur="4.1s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.5;0.9;0.5" dur="4.1s" repeatCount="indefinite"/>
            </circle>
            <circle cx="480" cy="130" r="6.5" fill="#FF4F00" filter="url(#sambandh-glow)"/>

            <!-- Node 4 -->
            <circle cx="320" cy="280" r="20" fill="url(#sambandh-halo)">
              <animate attributeName="r" values="18;26;18" dur="3.7s" begin="0.5s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.5;0.9;0.5" dur="3.7s" begin="0.5s" repeatCount="indefinite"/>
            </circle>
            <circle cx="320" cy="280" r="6.5" fill="#FF4F00" filter="url(#sambandh-glow)"/>

            <!-- Node 5 -->
            <circle cx="150" cy="280" r="20" fill="url(#sambandh-halo)">
              <animate attributeName="r" values="18;25;18" dur="3.2s" begin="1.1s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.5;0.9;0.5" dur="3.2s" begin="1.1s" repeatCount="indefinite"/>
            </circle>
            <circle cx="150" cy="280" r="6.5" fill="#FF4F00" filter="url(#sambandh-glow)"/>

            <!-- Node 6 -->
            <circle cx="480" cy="290" r="22" fill="url(#sambandh-halo)">
              <animate attributeName="r" values="20;28;20" dur="3.9s" begin="0.8s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.5;0.95;0.5" dur="3.9s" begin="0.8s" repeatCount="indefinite"/>
            </circle>
            <circle cx="480" cy="290" r="7" fill="#FF4F00" filter="url(#sambandh-glow)"/>

            <!-- Node 7 -->
            <circle cx="240" cy="350" r="18" fill="url(#sambandh-halo)">
              <animate attributeName="r" values="16;22;16" dur="3.6s" begin="1.4s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.5;0.85;0.5" dur="3.6s" begin="1.4s" repeatCount="indefinite"/>
            </circle>
            <circle cx="240" cy="350" r="6" fill="#FF4F00" filter="url(#sambandh-glow)"/>

            <!-- Node 8 -->
            <circle cx="410" cy="350" r="18" fill="url(#sambandh-halo)">
              <animate attributeName="r" values="16;22;16" dur="3.3s" begin="0.3s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.5;0.85;0.5" dur="3.3s" begin="0.3s" repeatCount="indefinite"/>
            </circle>
            <circle cx="410" cy="350" r="6" fill="#FF4F00" filter="url(#sambandh-glow)"/>
          </g>

          <!-- "Match made" callouts — pulse in periodically -->
          <g>
            <g opacity="0">
              <rect x="260" y="35" width="120" height="22" rx="11" fill="#FF4F00"/>
              <text x="320" y="50" text-anchor="middle" font-family="'Inter Tight', sans-serif" font-size="11" font-weight="700" fill="#fff">MATCH · WEEK 12</text>
              <animate attributeName="opacity" values="0;0;1;1;0;0" keyTimes="0;0.4;0.5;0.7;0.8;1" dur="9s" repeatCount="indefinite"/>
            </g>
            <g opacity="0">
              <rect x="220" y="380" width="180" height="22" rx="11" fill="#0E0B08"/>
              <text x="310" y="395" text-anchor="middle" font-family="'Inter Tight', sans-serif" font-size="10.5" font-weight="700" fill="#fff" letter-spacing="0.5">STUDY COHORT · ACTIVE</text>
              <animate attributeName="opacity" values="0;0;1;1;0" keyTimes="0;0.15;0.3;0.85;1" dur="9s" repeatCount="indefinite"/>
            </g>
          </g>
        </svg>
      </div>

    </div>
  </div>
</section>
