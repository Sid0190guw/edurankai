---
// Sampark — Sanskrit for "contact". Hero animation depicts the bridge
// between classroom and the working world. Left: a school/library
// silhouette with desks. Right: an office tower silhouette. Between them
// a luminous bridge with learners walking across, each carrying a glowing
// "skill" up-converting to a briefcase as they cross.
---
<section class="relative w-full bg-gradient-to-b from-cream via-cream-2/60 to-cream overflow-hidden">
  <div class="px-[5vw] py-12 md:py-20 max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center">

      <div class="md:col-span-5 relative z-10 order-1 md:order-2">
        <p class="eyebrow mb-4">सम्पर्क · The bridge to the working world</p>
        <h2 class="font-display text-[clamp(2rem,4.5vw,3.4rem)] font-semibold text-ink leading-[1.05] tracking-tight mb-5">
          Classroom to <em class="italic text-burn font-medium">consequential work.</em>
        </h2>
        <p class="text-[0.98rem] text-ink-2 font-light leading-[1.85]">
          The disconnect between what a learner studies and what they do at work is the most expensive market failure in education. Sampark treats this as a learning-design problem — not a job board. Real internships, real projects, real artefacts that show what a person can actually do.
        </p>
      </div>

      <div class="md:col-span-7 relative order-2 md:order-1">
        <svg viewBox="0 0 640 380" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" style="max-height:460px;">
          <defs>
            <linearGradient id="sampark-sky" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#FFF3EE"/>
              <stop offset="100%" stop-color="#FAF8F5"/>
            </linearGradient>
            <linearGradient id="sampark-bridge" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="#0E0B08" stop-opacity="0.06"/>
              <stop offset="20%" stop-color="#FF4F00" stop-opacity="0.32"/>
              <stop offset="50%" stop-color="#FF7040" stop-opacity="0.5"/>
              <stop offset="80%" stop-color="#FF4F00" stop-opacity="0.32"/>
              <stop offset="100%" stop-color="#0E0B08" stop-opacity="0.06"/>
            </linearGradient>
            <filter id="sampark-glow" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="3" result="b"/>
              <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <pattern id="sampark-grid" width="40" height="40" patternUnits="userSpaceOnUse">
              <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#0E0B08" stroke-opacity="0.04" stroke-width="0.6"/>
            </pattern>
          </defs>

          <rect width="640" height="380" fill="url(#sampark-sky)"/>
          <rect width="640" height="380" fill="url(#sampark-grid)"/>

          <!-- Ground line -->
          <line x1="0" y1="300" x2="640" y2="300" stroke="#0E0B08" stroke-opacity="0.15" stroke-width="1"/>

          <!-- LEFT: Classroom / library structure -->
          <g>
            <!-- Building body -->
            <rect x="50" y="170" width="170" height="130" fill="#0E0B08" opacity="0.82"/>
            <!-- Roof gable -->
            <polygon points="50,170 135,120 220,170" fill="#0E0B08" opacity="0.92"/>
            <!-- Windows (lit) -->
            <rect x="70" y="190" width="22" height="28" fill="#FFD4BC">
              <animate attributeName="fill" values="#FFD4BC;#FFF3EE;#FFD4BC" dur="4s" repeatCount="indefinite"/>
            </rect>
            <rect x="105" y="190" width="22" height="28" fill="#FFD4BC">
              <animate attributeName="fill" values="#FFF3EE;#FFD4BC;#FFF3EE" dur="3.4s" repeatCount="indefinite"/>
            </rect>
            <rect x="143" y="190" width="22" height="28" fill="#FFD4BC">
              <animate attributeName="fill" values="#FFD4BC;#FFF3EE;#FFD4BC" dur="4.7s" repeatCount="indefinite"/>
            </rect>
            <rect x="178" y="190" width="22" height="28" fill="#FFD4BC">
              <animate attributeName="fill" values="#FFF3EE;#FFD4BC;#FFF3EE" dur="3.1s" repeatCount="indefinite"/>
            </rect>
            <!-- Lower windows -->
            <rect x="70" y="240" width="22" height="28" fill="#FFD4BC" opacity="0.9"/>
            <rect x="105" y="240" width="22" height="28" fill="#FFD4BC" opacity="0.9"/>
            <rect x="143" y="240" width="22" height="28" fill="#FFD4BC" opacity="0.9"/>
            <rect x="178" y="240" width="22" height="28" fill="#FFD4BC" opacity="0.9"/>
            <!-- Door -->
            <rect x="125" y="270" width="22" height="30" fill="#FF4F00"/>
            <!-- Sign -->
            <text x="135" y="160" text-anchor="middle" font-family="'Fraunces', serif" font-style="italic" font-size="13" fill="#FF4F00" font-weight="600">Classroom</text>
          </g>

          <!-- RIGHT: Working-world tower -->
          <g>
            <rect x="425" y="100" width="160" height="200" fill="#0E0B08" opacity="0.85"/>
            <!-- Antenna -->
            <line x1="505" y1="100" x2="505" y2="65" stroke="#0E0B08" stroke-width="2" opacity="0.85"/>
            <circle cx="505" cy="62" r="3" fill="#FF4F00">
              <animate attributeName="opacity" values="0.4;1;0.4" dur="1.6s" repeatCount="indefinite"/>
            </circle>
            <!-- Window grid 4×5 -->
            <g>
              <rect x="440" y="115" width="20" height="28" fill="#FFD4BC" opacity="0.7"/>
              <rect x="470" y="115" width="20" height="28" fill="#FFD4BC" opacity="0.85">
                <animate attributeName="opacity" values="0.85;0.4;0.85" dur="4.4s" repeatCount="indefinite"/>
              </rect>
              <rect x="500" y="115" width="20" height="28" fill="#FFD4BC" opacity="0.7"/>
              <rect x="530" y="115" width="20" height="28" fill="#FFD4BC" opacity="0.85"/>
              <rect x="560" y="115" width="20" height="28" fill="#FFD4BC" opacity="0.7"/>

              <rect x="440" y="155" width="20" height="28" fill="#FFD4BC" opacity="0.85">
                <animate attributeName="opacity" values="0.4;0.95;0.4" dur="3.6s" repeatCount="indefinite"/>
              </rect>
              <rect x="470" y="155" width="20" height="28" fill="#FFD4BC" opacity="0.7"/>
              <rect x="500" y="155" width="20" height="28" fill="#FFD4BC" opacity="0.85"/>
              <rect x="530" y="155" width="20" height="28" fill="#FFD4BC" opacity="0.7">
                <animate attributeName="opacity" values="0.7;0.3;0.7" dur="3.1s" repeatCount="indefinite"/>
              </rect>
              <rect x="560" y="155" width="20" height="28" fill="#FFD4BC" opacity="0.85"/>

              <rect x="440" y="195" width="20" height="28" fill="#FFD4BC" opacity="0.7"/>
              <rect x="470" y="195" width="20" height="28" fill="#FFD4BC" opacity="0.85"/>
              <rect x="500" y="195" width="20" height="28" fill="#FFD4BC" opacity="0.7"/>
              <rect x="530" y="195" width="20" height="28" fill="#FFD4BC" opacity="0.85"/>
              <rect x="560" y="195" width="20" height="28" fill="#FFD4BC" opacity="0.7"/>

              <rect x="440" y="235" width="20" height="28" fill="#FFD4BC" opacity="0.85"/>
              <rect x="470" y="235" width="20" height="28" fill="#FFD4BC" opacity="0.7"/>
              <rect x="500" y="235" width="20" height="28" fill="#FFD4BC" opacity="0.85">
                <animate attributeName="opacity" values="0.85;0.4;0.85" dur="2.8s" repeatCount="indefinite"/>
              </rect>
              <rect x="530" y="235" width="20" height="28" fill="#FFD4BC" opacity="0.7"/>
              <rect x="560" y="235" width="20" height="28" fill="#FFD4BC" opacity="0.85"/>
            </g>
            <text x="505" y="92" text-anchor="middle" font-family="'Fraunces', serif" font-style="italic" font-size="13" fill="#FF4F00" font-weight="600">Working world</text>
          </g>

          <!-- BRIDGE arch — luminous, gradient -->
          <path d="M 220 220 Q 320 130 425 220" stroke="url(#sampark-bridge)" stroke-width="10" fill="none"/>
          <!-- Bridge support cables -->
          <line x1="260" y1="195" x2="260" y2="240" stroke="#FF4F00" stroke-opacity="0.3" stroke-width="1"/>
          <line x1="285" y1="172" x2="285" y2="248" stroke="#FF4F00" stroke-opacity="0.3" stroke-width="1"/>
          <line x1="320" y1="155" x2="320" y2="252" stroke="#FF4F00" stroke-opacity="0.3" stroke-width="1"/>
          <line x1="360" y1="172" x2="360" y2="248" stroke="#FF4F00" stroke-opacity="0.3" stroke-width="1"/>
          <line x1="390" y1="195" x2="390" y2="240" stroke="#FF4F00" stroke-opacity="0.3" stroke-width="1"/>

          <!-- BRIDGE deck (subtle band the travellers walk on) -->
          <path d="M 220 240 Q 320 155 425 240" stroke="#0E0B08" stroke-opacity="0.12" stroke-width="2" fill="none" stroke-dasharray="4 6"/>

          <!-- TRAVELLERS — learners walking across; each carries a glowing learning artefact -->
          <g>
            <!-- Traveller 1 -->
            <g>
              <circle r="6" fill="#FF4F00" filter="url(#sampark-glow)">
                <animateMotion dur="7s" repeatCount="indefinite" path="M 220 240 Q 320 155 425 240"/>
              </circle>
              <circle r="10" fill="#FF7040" opacity="0.3">
                <animateMotion dur="7s" repeatCount="indefinite" path="M 220 240 Q 320 155 425 240"/>
                <animate attributeName="r" values="8;14;8" dur="1.4s" repeatCount="indefinite"/>
              </circle>
            </g>
            <!-- Traveller 2 -->
            <g>
              <circle r="5.5" fill="#FF4F00" filter="url(#sampark-glow)">
                <animateMotion dur="7s" begin="2.3s" repeatCount="indefinite" path="M 220 240 Q 320 155 425 240"/>
              </circle>
              <circle r="9" fill="#FF7040" opacity="0.3">
                <animateMotion dur="7s" begin="2.3s" repeatCount="indefinite" path="M 220 240 Q 320 155 425 240"/>
                <animate attributeName="r" values="7;12;7" dur="1.4s" begin="2.3s" repeatCount="indefinite"/>
              </circle>
            </g>
            <!-- Traveller 3 -->
            <g>
              <circle r="5.5" fill="#FF4F00" filter="url(#sampark-glow)">
                <animateMotion dur="7s" begin="4.7s" repeatCount="indefinite" path="M 220 240 Q 320 155 425 240"/>
              </circle>
              <circle r="9" fill="#FF7040" opacity="0.3">
                <animateMotion dur="7s" begin="4.7s" repeatCount="indefinite" path="M 220 240 Q 320 155 425 240"/>
                <animate attributeName="r" values="7;12;7" dur="1.4s" begin="4.7s" repeatCount="indefinite"/>
              </circle>
            </g>
          </g>

          <!-- Briefcase pickup pulse at the right side (where each traveller arrives) -->
          <g transform="translate(425, 240)">
            <rect x="-10" y="-7" width="20" height="14" rx="2" fill="#0E0B08" opacity="0">
              <animate attributeName="opacity" values="0;0;1;0" keyTimes="0;0.85;0.9;1" dur="7s" repeatCount="indefinite"/>
            </rect>
            <rect x="-4" y="-11" width="8" height="4" rx="1" fill="#0E0B08" opacity="0">
              <animate attributeName="opacity" values="0;0;1;0" keyTimes="0;0.85;0.9;1" dur="7s" repeatCount="indefinite"/>
            </rect>
          </g>

          <!-- Skill text floats above the bridge centre -->
          <g>
            <text x="320" y="100" text-anchor="middle" font-family="'Inter Tight', sans-serif" font-size="11" font-weight="700" fill="#FF4F00" letter-spacing="2" opacity="0">
              SKILL · ARTEFACT · ROLE
              <animate attributeName="opacity" values="0;0;1;1;0" keyTimes="0;0.2;0.4;0.7;1" dur="7s" repeatCount="indefinite"/>
            </text>
          </g>

          <!-- Ground annotation -->
          <text x="135" y="335" text-anchor="middle" font-family="'Geist Mono', monospace" font-size="9" font-weight="700" fill="#0E0B08" opacity="0.5" letter-spacing="1">WHAT YOU LEARN</text>
          <text x="505" y="335" text-anchor="middle" font-family="'Geist Mono', monospace" font-size="9" font-weight="700" fill="#0E0B08" opacity="0.5" letter-spacing="1">WHAT YOU DO</text>
        </svg>
      </div>

    </div>
  </div>
</section>
