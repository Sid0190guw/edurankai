---
// Sancharan — Sanskrit for "movement / travel". Consumer travel venture.
// The hero animation's orderly flowing cascade reads as journeys in motion —
// itineraries moving from plan to trip without chaos.
---
<section class="relative w-full bg-gradient-to-b from-cream via-cream-2/60 to-cream overflow-hidden">
  <div class="px-[5vw] py-12 md:py-20 max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center">

      <div class="md:col-span-5 relative z-10">
        <p class="eyebrow mb-4">सञ्चरण · The travel venture</p>
        <h2 class="font-display text-[clamp(2rem,4.5vw,3.4rem)] font-semibold text-ink leading-[1.05] tracking-tight mb-5">
          Journeys, <em class="italic text-burn font-medium">reimagined.</em>
        </h2>
        <p class="text-[0.98rem] text-ink-2 font-light leading-[1.85]">
          A consumer travel venture by EduRankAI — being built carefully in India to serve every kind of journey that matters: weekend trips, family vacations, pilgrimages, heritage circuits, educational tours, corporate offsites, and more. Where today’s apps treat every traveler the same, Sancharan respects that each journey is different — built without dark patterns, hidden fees, or fake urgency.
        </p>
      </div>

      <div class="md:col-span-7 relative">
        <svg viewBox="0 0 600 420" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" style="max-height:480px;">
          <defs>
            <pattern id="sancharan-grid" width="40" height="40" patternUnits="userSpaceOnUse">
              <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#0E0B08" stroke-opacity="0.04" stroke-width="0.6"/>
            </pattern>
            <linearGradient id="sancharan-ripple" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#FF4F00" stop-opacity="0.18"/>
              <stop offset="100%" stop-color="#FF4F00" stop-opacity="0"/>
            </linearGradient>
            <filter id="sancharan-glow" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="2.6" result="b"/>
              <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>

          <rect width="600" height="420" fill="url(#sancharan-grid)"/>

          <!-- Three vertical "thread" lanes -->
          <line x1="120" y1="40" x2="120" y2="380" stroke="#0E0B08" stroke-opacity="0.18" stroke-width="1"/>
          <line x1="300" y1="40" x2="300" y2="380" stroke="#0E0B08" stroke-opacity="0.18" stroke-width="1"/>
          <line x1="480" y1="40" x2="480" y2="380" stroke="#0E0B08" stroke-opacity="0.18" stroke-width="1"/>

          <!-- Thread labels -->
          <text x="120" y="28" text-anchor="middle" font-family="'Geist Mono', monospace" font-size="9.5" font-weight="700" fill="#FF4F00" letter-spacing="1.5">SEMINAR · WEEK 04</text>
          <text x="300" y="28" text-anchor="middle" font-family="'Geist Mono', monospace" font-size="9.5" font-weight="700" fill="#0E0B08" opacity="0.7" letter-spacing="1.5">PROJECT · PIDAR PHASE</text>
          <text x="480" y="28" text-anchor="middle" font-family="'Geist Mono', monospace" font-size="9.5" font-weight="700" fill="#0E0B08" opacity="0.7" letter-spacing="1.5">MENTOR · OPEN HOURS</text>

          <!-- LANE 1 — message bubbles dropping with stagger -->
          <g>
            <!-- Message 1 -->
            <g>
              <rect x="60" y="60" width="120" height="40" rx="6" fill="#FF4F00" opacity="0">
                <animate attributeName="opacity" values="0;1;1;1" keyTimes="0;0.05;0.95;1" dur="11s" repeatCount="indefinite"/>
                <animate attributeName="y" values="50;60;60;60" keyTimes="0;0.05;0.95;1" dur="11s" repeatCount="indefinite"/>
              </rect>
              <text x="120" y="78" text-anchor="middle" font-family="'Inter Tight', sans-serif" font-size="9" font-weight="600" fill="#fff" opacity="0">
                Q · 9 lines
                <animate attributeName="opacity" values="0;1;1;1" keyTimes="0;0.05;0.95;1" dur="11s" repeatCount="indefinite"/>
              </text>
              <text x="120" y="90" text-anchor="middle" font-family="'Geist Mono', monospace" font-size="7.5" fill="#fff" opacity="0">
                09:14 · ASYNC
                <animate attributeName="opacity" values="0;0.7;0.7;0.7" keyTimes="0;0.05;0.95;1" dur="11s" repeatCount="indefinite"/>
              </text>
              <!-- Ripple -->
              <circle cx="120" cy="80" r="20" fill="url(#sancharan-ripple)" opacity="0">
                <animate attributeName="r" values="20;55;80" keyTimes="0;0.5;1" dur="2.4s" repeatCount="indefinite"/>
                <animate attributeName="opacity" values="0.9;0.4;0" keyTimes="0;0.5;1" dur="2.4s" repeatCount="indefinite"/>
              </circle>
            </g>
            <!-- Message 2 (reply) — indented as a child thread -->
            <g>
              <rect x="75" y="118" width="105" height="36" rx="6" fill="#0E0B08" opacity="0">
                <animate attributeName="opacity" values="0;0;1;1" keyTimes="0;0.18;0.22;1" dur="11s" repeatCount="indefinite"/>
                <animate attributeName="y" values="108;108;118;118" keyTimes="0;0.18;0.22;1" dur="11s" repeatCount="indefinite"/>
              </rect>
              <text x="128" y="135" text-anchor="middle" font-family="'Inter Tight', sans-serif" font-size="8.5" font-weight="600" fill="#fff" opacity="0">
                Reply · structured
                <animate attributeName="opacity" values="0;0;1;1" keyTimes="0;0.18;0.22;1" dur="11s" repeatCount="indefinite"/>
              </text>
              <text x="128" y="146" text-anchor="middle" font-family="'Geist Mono', monospace" font-size="7" fill="#fff" opacity="0">
                +2H · 4 lines
                <animate attributeName="opacity" values="0;0;0.7;0.7" keyTimes="0;0.18;0.22;1" dur="11s" repeatCount="indefinite"/>
              </text>
              <!-- Connector line to parent -->
              <line x1="65" y1="110" x2="65" y2="135" stroke="#FF4F00" stroke-opacity="0.5" stroke-width="1.5"/>
              <line x1="65" y1="135" x2="75" y2="135" stroke="#FF4F00" stroke-opacity="0.5" stroke-width="1.5"/>
            </g>
            <!-- Message 3 (deeper reply) -->
            <g>
              <rect x="90" y="170" width="90" height="32" rx="6" fill="#FFF3EE" stroke="#FF7040" stroke-width="1" opacity="0">
                <animate attributeName="opacity" values="0;0;0;1" keyTimes="0;0.32;0.35;1" dur="11s" repeatCount="indefinite"/>
              </rect>
              <text x="135" y="190" text-anchor="middle" font-family="'Inter Tight', sans-serif" font-size="8.5" font-weight="600" fill="#FF4F00" opacity="0">
                Resolved
                <animate attributeName="opacity" values="0;0;0;1" keyTimes="0;0.32;0.35;1" dur="11s" repeatCount="indefinite"/>
              </text>
              <line x1="80" y1="155" x2="80" y2="186" stroke="#FF4F00" stroke-opacity="0.5" stroke-width="1.5"/>
              <line x1="80" y1="186" x2="90" y2="186" stroke="#FF4F00" stroke-opacity="0.5" stroke-width="1.5"/>
            </g>
          </g>

          <!-- LANE 2 — project lane (different rhythm) -->
          <g>
            <g>
              <rect x="240" y="100" width="120" height="40" rx="6" fill="#0E0B08" opacity="0">
                <animate attributeName="opacity" values="0;0;1;1" keyTimes="0;0.08;0.13;1" dur="9s" repeatCount="indefinite"/>
                <animate attributeName="y" values="90;90;100;100" keyTimes="0;0.08;0.13;1" dur="9s" repeatCount="indefinite"/>
              </rect>
              <text x="300" y="118" text-anchor="middle" font-family="'Inter Tight', sans-serif" font-size="9" font-weight="600" fill="#fff" opacity="0">
                Draft · v2
                <animate attributeName="opacity" values="0;0;1;1" keyTimes="0;0.08;0.13;1" dur="9s" repeatCount="indefinite"/>
              </text>
              <text x="300" y="130" text-anchor="middle" font-family="'Geist Mono', monospace" font-size="7.5" fill="#fff" opacity="0">
                14:02
                <animate attributeName="opacity" values="0;0;0.7;0.7" keyTimes="0;0.08;0.13;1" dur="9s" repeatCount="indefinite"/>
              </text>
              <circle cx="300" cy="120" r="20" fill="url(#sancharan-ripple)" opacity="0">
                <animate attributeName="r" values="20;55;80" keyTimes="0;0.5;1" dur="2.4s" begin="0.8s" repeatCount="indefinite"/>
                <animate attributeName="opacity" values="0.9;0.4;0" keyTimes="0;0.5;1" dur="2.4s" begin="0.8s" repeatCount="indefinite"/>
              </circle>
            </g>
            <g>
              <rect x="255" y="160" width="100" height="32" rx="6" fill="#FFD4BC" opacity="0">
                <animate attributeName="opacity" values="0;0;0;1" keyTimes="0;0.4;0.42;1" dur="9s" repeatCount="indefinite"/>
              </rect>
              <text x="305" y="180" text-anchor="middle" font-family="'Inter Tight', sans-serif" font-size="8.5" font-weight="700" fill="#0E0B08" opacity="0">
                + Annotated
                <animate attributeName="opacity" values="0;0;0;1" keyTimes="0;0.4;0.42;1" dur="9s" repeatCount="indefinite"/>
              </text>
              <line x1="245" y1="150" x2="245" y2="176" stroke="#FF4F00" stroke-opacity="0.5" stroke-width="1.5"/>
              <line x1="245" y1="176" x2="255" y2="176" stroke="#FF4F00" stroke-opacity="0.5" stroke-width="1.5"/>
            </g>
          </g>

          <!-- LANE 3 — mentor open hours (slower rhythm) -->
          <g>
            <g>
              <rect x="420" y="140" width="120" height="40" rx="6" fill="#0E0B08" opacity="0">
                <animate attributeName="opacity" values="0;0;0;1;1" keyTimes="0;0.15;0.2;0.25;1" dur="13s" repeatCount="indefinite"/>
                <animate attributeName="y" values="130;130;130;140;140" keyTimes="0;0.15;0.2;0.25;1" dur="13s" repeatCount="indefinite"/>
              </rect>
              <text x="480" y="158" text-anchor="middle" font-family="'Inter Tight', sans-serif" font-size="9" font-weight="600" fill="#fff" opacity="0">
                Open hour · live
                <animate attributeName="opacity" values="0;0;0;1;1" keyTimes="0;0.15;0.2;0.25;1" dur="13s" repeatCount="indefinite"/>
              </text>
              <text x="480" y="170" text-anchor="middle" font-family="'Geist Mono', monospace" font-size="7.5" fill="#fff" opacity="0">
                17:00 · TODAY
                <animate attributeName="opacity" values="0;0;0;0.85;0.85" keyTimes="0;0.15;0.2;0.25;1" dur="13s" repeatCount="indefinite"/>
              </text>
              <circle cx="480" cy="160" r="20" fill="url(#sancharan-ripple)" opacity="0">
                <animate attributeName="r" values="20;55;80" keyTimes="0;0.5;1" dur="2.4s" begin="1.6s" repeatCount="indefinite"/>
                <animate attributeName="opacity" values="0.9;0.4;0" keyTimes="0;0.5;1" dur="2.4s" begin="1.6s" repeatCount="indefinite"/>
              </circle>
            </g>
            <g>
              <rect x="435" y="200" width="90" height="32" rx="6" fill="#FFF3EE" stroke="#FF7040" stroke-width="1" opacity="0">
                <animate attributeName="opacity" values="0;0;0;1" keyTimes="0;0.45;0.48;1" dur="13s" repeatCount="indefinite"/>
              </rect>
              <text x="480" y="220" text-anchor="middle" font-family="'Inter Tight', sans-serif" font-size="8.5" font-weight="600" fill="#FF4F00" opacity="0">
                Q queued · 7
                <animate attributeName="opacity" values="0;0;0;1" keyTimes="0;0.45;0.48;1" dur="13s" repeatCount="indefinite"/>
              </text>
              <line x1="425" y1="190" x2="425" y2="216" stroke="#FF4F00" stroke-opacity="0.5" stroke-width="1.5"/>
              <line x1="425" y1="216" x2="435" y2="216" stroke="#FF4F00" stroke-opacity="0.5" stroke-width="1.5"/>
            </g>
          </g>

          <!-- Cross-lane attention flow — slim arc connecting lane 1 to lane 3 (a learner moves a question) -->
          <g>
            <path d="M 180 80 Q 330 50 480 160" stroke="#FF4F00" stroke-width="1.5" fill="none" stroke-dasharray="3 3" opacity="0">
              <animate attributeName="opacity" values="0;0;0.7;0.7;0" keyTimes="0;0.6;0.7;0.85;1" dur="13s" repeatCount="indefinite"/>
            </path>
            <circle r="3" fill="#FF4F00" filter="url(#sancharan-glow)" opacity="0">
              <animateMotion dur="2s" begin="9s" repeatCount="indefinite" path="M 180 80 Q 330 50 480 160"/>
              <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.1;0.9;1" dur="2s" begin="9s" repeatCount="indefinite"/>
            </circle>
          </g>

          <!-- Footer: attention budget gauge -->
          <g transform="translate(60, 380)">
            <rect x="0" y="0" width="480" height="20" rx="10" fill="#0E0B08" opacity="0.05"/>
            <rect x="0" y="0" width="200" height="20" rx="10" fill="#FF4F00" opacity="0.85">
              <animate attributeName="width" values="180;320;180" dur="6s" repeatCount="indefinite"/>
            </rect>
            <text x="240" y="14" text-anchor="middle" font-family="'Geist Mono', monospace" font-size="9.5" font-weight="700" fill="#0E0B08" letter-spacing="1.5">DEEP WORK BUDGET · PROTECTED</text>
          </g>
        </svg>
      </div>

    </div>
  </div>
</section>
