---
// Self-contained authenticator-app (TOTP) + backup-codes panel. Talks to
// /api/2fa/* (start / confirm / disable). No third-party libraries.
interface Props { enabled: boolean; backupRemaining: number; accountLabel?: string; passkeys?: Array<{ id: string; name: string; created_at: any; last_used_at: any }>; }
const { enabled, backupRemaining, accountLabel = '', passkeys = [] } = Astro.props as Props;
function fmtDate(d: any): string { try { return d ? new Date(d).toLocaleDateString() : ''; } catch { return ''; } }
---
<div class="tfa" data-enabled={enabled ? '1' : '0'}>
  <div class="tfa-head">
    <div>
      <h2 class="tfa-title">Authenticator app</h2>
      <p class="tfa-sub">Add a second step at sign-in using a code from an authenticator app on your phone.</p>
    </div>
    <span class={`tfa-pill ${enabled ? 'on' : 'off'}`}>{enabled ? 'On' : 'Off'}</span>
  </div>

  {accountLabel && <p class="tfa-acct">Account: <strong>{accountLabel}</strong></p>}

  <!-- OFF state: setup -->
  <div id="tfaSetup" style={enabled ? 'display:none' : ''}>
    <button type="button" id="tfaStartBtn" class="tfa-btn primary">Set up authenticator</button>

    <div id="tfaSteps" style="display:none;margin-top:16px;">
      <ol class="tfa-list">
        <li>Open your authenticator app (Google Authenticator, Authy, Microsoft Authenticator, or any TOTP app).</li>
        <li>On a phone, <a id="tfaDeepLink" href="#" class="tfa-link">tap here to add the account</a>. On a computer, add an account manually and enter this key:</li>
      </ol>
      <div class="tfa-key" id="tfaKey">—</div>
      <p class="tfa-hint">Issuer: <strong>EduRankAI</strong> · type: time-based · 6 digits.</p>
      <label class="tfa-label" for="tfaCode">3. Enter the current 6-digit code to confirm</label>
      <div class="tfa-row">
        <input id="tfaCode" class="tfa-input" inputmode="numeric" autocomplete="one-time-code" maxlength="6" placeholder="123456" />
        <button type="button" id="tfaConfirmBtn" class="tfa-btn primary">Confirm</button>
      </div>
      <p class="tfa-err" id="tfaSetupErr"></p>
    </div>
  </div>

  <!-- backup codes (shown once after confirm) -->
  <div id="tfaBackup" style="display:none;margin-top:16px;">
    <h3 class="tfa-title">Save your backup codes</h3>
    <p class="tfa-sub">Each code works once if you lose your phone. Store them somewhere safe — they will not be shown again.</p>
    <pre class="tfa-codes" id="tfaCodes"></pre>
    <div class="tfa-row">
      <button type="button" id="tfaCopyBtn" class="tfa-btn">Copy codes</button>
      <button type="button" id="tfaDoneBtn" class="tfa-btn primary">I have saved them</button>
    </div>
  </div>

  <!-- ON state -->
  <div id="tfaOn" style={enabled ? '' : 'display:none'}>
    <p class="tfa-ok">Authenticator is protecting this account.</p>
    <p class="tfa-sub">Backup codes remaining: <strong id="tfaRemain">{backupRemaining}</strong></p>
    <details class="tfa-details">
      <summary>Turn off authenticator</summary>
      <p class="tfa-sub">Enter a current authenticator code (or a backup code) to confirm.</p>
      <div class="tfa-row">
        <input id="tfaOffCode" class="tfa-input" inputmode="numeric" autocomplete="one-time-code" placeholder="123456" />
        <button type="button" id="tfaOffBtn" class="tfa-btn danger">Turn off</button>
      </div>
      <p class="tfa-err" id="tfaOffErr"></p>
    </details>
  </div>
</div>

<!-- Passkeys (fingerprint / Face ID / Windows Hello / security key) -->
<div class="tfa" style="margin-top:16px;" id="pkCard">
  <div class="tfa-head">
    <div>
      <h2 class="tfa-title">Fingerprint &amp; passkeys</h2>
      <p class="tfa-sub">Sign in with your fingerprint, face, or device PIN — no password to type. Works on this device and any others you add.</p>
    </div>
    <span class={`tfa-pill ${passkeys.length ? 'on' : 'off'}`}>{passkeys.length ? `${passkeys.length} saved` : 'None'}</span>
  </div>

  {passkeys.length > 0 && (
    <ul class="pk-list">
      {passkeys.map((p) => (
        <li class="pk-item" data-id={p.id}>
          <span class="pk-ico"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M12 11c0-1.5-1-3-3-3M5 13a7 7 0 0 1 7-7 7 7 0 0 1 7 7M8 21c-1-2-1.5-4-1.5-6M12 13v3c0 2 .5 4 1.5 6M16 14c.3 2 .8 4 1.5 5"/></svg></span>
          <span class="pk-name">{p.name || 'Passkey'}<span class="pk-meta">added {fmtDate(p.created_at)}{p.last_used_at ? ` · last used ${fmtDate(p.last_used_at)}` : ''}</span></span>
          <button type="button" class="tfa-btn danger pk-del" data-id={p.id} style="padding:7px 12px;font-size:0.8rem;">Remove</button>
        </li>
      ))}
    </ul>
  )}

  <button type="button" id="pkAddBtn" class="tfa-btn primary" style="margin-top:12px;">Add a fingerprint / passkey</button>
  <p class="tfa-err" id="pkErr"></p>
  <p class="tfa-sub" id="pkUnsupported" style="display:none;margin-top:8px;">This device or browser does not support passkeys. Use the authenticator app instead.</p>
</div>

<style>
  .tfa { background:#fff; border:1px solid rgba(0,0,0,0.1); border-radius:16px; padding:22px; max-width:560px; }
  .tfa-head { display:flex; justify-content:space-between; align-items:flex-start; gap:12px; }
  .tfa-title { font-size:1.05rem; font-weight:700; color:#1a1a1a; margin:0 0 4px; }
  .tfa-sub { font-size:0.85rem; color:#6b7280; margin:0 0 6px; line-height:1.5; }
  .tfa-acct { font-size:0.82rem; color:#374151; margin:10px 0 0; }
  .tfa-pill { font-size:0.66rem; font-weight:800; letter-spacing:0.08em; text-transform:uppercase; padding:4px 10px; border-radius:100px; white-space:nowrap; }
  .tfa-pill.on { background:#e7f6ec; color:#1a7f43; }
  .tfa-pill.off { background:#f3f4f6; color:#6b7280; }
  .tfa-list { margin:0 0 12px; padding-left:18px; color:#374151; font-size:0.86rem; line-height:1.6; }
  .tfa-link { color:#DC5000; font-weight:600; text-decoration:underline; }
  .tfa-key { font-family:ui-monospace,Menlo,Consolas,monospace; font-size:1.05rem; letter-spacing:0.1em; background:#faf8f3; border:1px dashed rgba(0,0,0,0.2); border-radius:10px; padding:12px 14px; word-break:break-all; color:#1a1a1a; }
  .tfa-hint { font-size:0.78rem; color:#9ca3af; margin:6px 0 14px; }
  .tfa-label { display:block; font-size:0.82rem; font-weight:600; color:#374151; margin:0 0 6px; }
  .tfa-row { display:flex; gap:8px; align-items:center; flex-wrap:wrap; }
  .tfa-input { flex:1; min-width:120px; border:1px solid rgba(0,0,0,0.18); border-radius:10px; padding:11px 12px; font-size:1.05rem; letter-spacing:0.15em; }
  .tfa-btn { border:1px solid rgba(0,0,0,0.18); background:#fff; color:#1a1a1a; font-weight:700; font-size:0.88rem; padding:11px 16px; border-radius:10px; cursor:pointer; }
  .tfa-btn.primary { background:#DC5000; border-color:#DC5000; color:#fff; }
  .tfa-btn.danger { background:#fff; border-color:#dc2626; color:#dc2626; }
  .tfa-btn:disabled { opacity:0.5; cursor:not-allowed; }
  .tfa-codes { background:#faf8f3; border:1px solid rgba(0,0,0,0.12); border-radius:10px; padding:14px; font-family:ui-monospace,Menlo,Consolas,monospace; font-size:0.95rem; line-height:1.9; white-space:pre-wrap; color:#1a1a1a; }
  .tfa-ok { font-size:0.9rem; color:#1a7f43; font-weight:600; margin:14px 0 4px; }
  .tfa-err { color:#dc2626; font-size:0.82rem; margin:8px 0 0; min-height:1em; }
  .tfa-details { margin-top:16px; border-top:1px solid rgba(0,0,0,0.08); padding-top:12px; }
  .tfa-details summary { cursor:pointer; font-size:0.85rem; font-weight:600; color:#6b7280; }
  .pk-list { list-style:none; margin:14px 0 0; padding:0; display:flex; flex-direction:column; gap:8px; }
  .pk-item { display:flex; align-items:center; gap:10px; border:1px solid rgba(0,0,0,0.1); border-radius:10px; padding:10px 12px; }
  .pk-ico { color:#DC5000; flex-shrink:0; display:inline-flex; }
  .pk-name { flex:1; min-width:0; font-size:0.88rem; font-weight:600; color:#1a1a1a; display:flex; flex-direction:column; }
  .pk-meta { font-size:0.74rem; color:#9ca3af; font-weight:400; }
</style>

<script>
  (function () {
    var root = document.querySelector('.tfa'); if (!root) return;
    var $ = function (id) { return document.getElementById(id); };
    function show(el, on) { if (el) el.style.display = on ? '' : 'none'; }

    var startBtn = $('tfaStartBtn'), steps = $('tfaSteps'), keyEl = $('tfaKey'), deep = $('tfaDeepLink');
    var codeIn = $('tfaCode'), confirmBtn = $('tfaConfirmBtn'), setupErr = $('tfaSetupErr');
    var backup = $('tfaBackup'), codesEl = $('tfaCodes'), copyBtn = $('tfaCopyBtn'), doneBtn = $('tfaDoneBtn');
    var setup = $('tfaSetup'), onBox = $('tfaOn'), remainEl = $('tfaRemain');
    var offCode = $('tfaOffCode'), offBtn = $('tfaOffBtn'), offErr = $('tfaOffErr');

    async function post(url, body) {
      var r = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin', body: JSON.stringify(body || {}) });
      var d = {}; try { d = await r.json(); } catch (_) {}
      return d;
    }

    if (startBtn) startBtn.addEventListener('click', async function () {
      startBtn.disabled = true; startBtn.textContent = 'Preparing…';
      var d = await post('/api/2fa/start', {});
      startBtn.disabled = false; startBtn.textContent = 'Set up authenticator';
      if (!d.ok) { if (setupErr) setupErr.textContent = d.error || 'Could not start.'; return; }
      if (keyEl) keyEl.textContent = d.formatted || d.secret || '';
      if (deep) deep.setAttribute('href', d.otpauth || '#');
      show(steps, true); show(startBtn, false);
      if (codeIn) codeIn.focus();
    });

    if (confirmBtn) confirmBtn.addEventListener('click', async function () {
      if (setupErr) setupErr.textContent = '';
      var token = (codeIn && codeIn.value || '').replace(/\s/g, '');
      if (!/^\d{6}$/.test(token)) { if (setupErr) setupErr.textContent = 'Enter the 6-digit code.'; return; }
      confirmBtn.disabled = true;
      var d = await post('/api/2fa/confirm', { token: token });
      confirmBtn.disabled = false;
      if (!d.ok) { if (setupErr) setupErr.textContent = d.error || 'Could not confirm.'; return; }
      if (codesEl) codesEl.textContent = (d.backupCodes || []).join('\n');
      show(setup, false); show(backup, true);
    });

    if (copyBtn) copyBtn.addEventListener('click', function () {
      try { navigator.clipboard.writeText((codesEl && codesEl.textContent) || ''); copyBtn.textContent = 'Copied'; setTimeout(function () { copyBtn.textContent = 'Copy codes'; }, 1500); } catch (_) {}
    });
    if (doneBtn) doneBtn.addEventListener('click', function () { location.reload(); });

    if (offBtn) offBtn.addEventListener('click', async function () {
      if (offErr) offErr.textContent = '';
      var code = (offCode && offCode.value || '').trim();
      if (!code) { if (offErr) offErr.textContent = 'Enter a code to confirm.'; return; }
      offBtn.disabled = true;
      var d = await post('/api/2fa/disable', { code: code });
      offBtn.disabled = false;
      if (!d.ok) { if (offErr) offErr.textContent = d.error || 'Could not turn off.'; return; }
      location.reload();
    });
  })();
</script>

<script src="/webauthn-client.js" is:inline></script>
<script>
  (function () {
    var addBtn = document.getElementById('pkAddBtn'), err = document.getElementById('pkErr'), unsup = document.getElementById('pkUnsupported');
    if (!addBtn) return;
    if (!window.eraPasskeySupported) { addBtn.style.display = 'none'; if (unsup) unsup.style.display = 'block'; }
    addBtn.addEventListener('click', async function () {
      if (err) err.textContent = '';
      var name = prompt('Name this device (e.g. "My phone", "Work laptop")', 'My device');
      if (name === null) return;
      addBtn.disabled = true; var label = addBtn.textContent; addBtn.textContent = 'Follow your device prompt…';
      try { await window.eraPasskeyRegister(name || 'Passkey'); location.reload(); }
      catch (e) { if (err) err.textContent = (e && e.message) || 'Could not add passkey.'; addBtn.disabled = false; addBtn.textContent = label; }
    });
    Array.prototype.forEach.call(document.querySelectorAll('.pk-del'), function (b) {
      b.addEventListener('click', async function () {
        if (!confirm('Remove this passkey?')) return;
        b.disabled = true;
        var r = await fetch('/api/2fa/passkey/delete', { method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin', body: JSON.stringify({ id: b.getAttribute('data-id') }) });
        var d = {}; try { d = await r.json(); } catch (_) {}
        if (d.ok) location.reload(); else { b.disabled = false; if (err) err.textContent = (d.error || 'Could not remove'); }
      });
    });
  })();
</script>
