---
import { STAGES, stageIndex } from '@/lib/application-stages';

interface Props {
  currentStage: string;
  events?: any[];
}
const { currentStage, events = [] } = Astro.props;
const currentIdx = stageIndex(currentStage);

function fmt(d: any) { try { return new Date(d).toLocaleDateString('en-IN', { day:'2-digit', month:'short' }); } catch { return ''; } }
const eventsByStage: Record<string, any> = {};
for (const e of events) eventsByStage[e.to_stage] = e;
---
<div class="bg-white border border-ink/10 rounded-2xl p-5 md:p-7 mb-6">
  <p class="text-[0.62rem] font-mono uppercase tracking-[0.16em] text-burn font-bold mb-3">Recruitment funnel · Six steps. No surprises.</p>

  <div class="grid gap-3" style="grid-template-columns: repeat(6, minmax(0, 1fr));">
    {STAGES.map((s, i) => {
      const isDone = i < currentIdx;
      const isCurrent = i === currentIdx;
      const ev = eventsByStage[s.key];
      return (
        <div class="relative">
          {i < STAGES.length - 1 && (
            <div class="absolute top-3 left-[calc(50%+12px)] right-[-50%] h-[2px]" style={`background: ${isDone ? '#FF4F00' : 'rgba(14,11,8,0.10)'};`}></div>
          )}
          <div class="relative flex flex-col items-center">
            <div class={`flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center font-mono text-[0.65rem] font-bold ${isCurrent ? 'bg-burn text-white' : isDone ? 'bg-burn text-white' : 'bg-cream-2 text-ink-soft border border-ink/15'}`}>{isDone ? '✓' : i + 1}</div>
            <p class={`text-[0.6rem] font-mono uppercase tracking-[0.1em] font-bold mt-2 text-center leading-tight ${isCurrent ? 'text-burn' : isDone ? 'text-ink' : 'text-ink-soft'}`}>{s.label}</p>
            {ev && <p class="text-[0.6rem] text-ink-soft mt-0.5 m-0 font-mono">{fmt(ev.created_at)}</p>}
          </div>
        </div>
      );
    })}
  </div>

  <div class="mt-6 bg-cream-2/60 border border-ink/10 rounded-xl p-4">
    <p class="text-[0.6rem] font-mono uppercase tracking-[0.14em] text-burn font-bold m-0 mb-1.5">{STAGES[currentIdx].short}</p>
    <p class="text-[0.92rem] text-ink-2 leading-relaxed m-0">{STAGES[currentIdx].blurb}</p>
  </div>
</div>
