---
import { NAV_PRIMARY } from '@/lib/site';
---
<nav class="sticky top-0 z-50 bg-cream/95 backdrop-blur-xl border-b border-ink/10 h-[62px] flex items-center px-[5vw] justify-between gap-4">
  <a href="/" class="font-display text-[1.35rem] font-bold tracking-tight text-ink hover:text-burn transition-colors">
    EduRank<span class="text-burn">AI</span>
  </a>
  <ul class="hidden md:flex gap-6 list-none">
    {NAV_PRIMARY.map((item) => (
      <li>
        <a href={item.href} class="text-[0.8rem] font-medium text-ink-soft hover:text-ink transition-colors">
          {item.label}
        </a>
      </li>
    ))}
  </ul>
  <div class="flex items-center gap-3">
    <a href="/apply" class="hidden sm:inline-flex bg-burn text-white px-5 py-2 rounded-lg text-[0.82rem] font-semibold hover:bg-burn-2 transition-colors whitespace-nowrap">
      Apply Now
    </a>
    <button class="md:hidden flex flex-col gap-[5px] p-1" aria-label="Menu" onclick="document.getElementById('mobNav').classList.toggle('hidden')">
      <span class="block w-[22px] h-[2px] bg-ink rounded"></span>
      <span class="block w-[22px] h-[2px] bg-ink rounded"></span>
      <span class="block w-[22px] h-[2px] bg-ink rounded"></span>
    </button>
  </div>
</nav>
<div id="mobNav" class="hidden md:hidden fixed top-[62px] inset-x-0 z-40 bg-cream border-b border-ink/10 px-[5vw] py-4">
  {NAV_PRIMARY.map((item) => (
    <a href={item.href} class="block py-3 text-[0.95rem] text-ink border-b border-ink/10 last:border-0">
      {item.label}
    </a>
  ))}
  <a href="/apply" class="mt-3 block bg-burn text-white text-center py-3 rounded-lg font-semibold">
    Apply Now
  </a>
</div>
