---
import { SITE, NAV_PRIMARY } from '@/lib/site';

const user = Astro.locals.user;
const isApplicant = user && user.role === 'applicant';
const isAdmin = user && user.role !== 'applicant';
const userInitial = user && user.name ? user.name.substring(0, 1).toUpperCase() : '';
---
<header class="sticky top-0 z-50 bg-cream/95 backdrop-blur-md border-b border-ink/8">
  <nav class="px-[5vw] py-3.5 max-w-7xl mx-auto flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2 group">
      <span class="font-display text-[1.15rem] font-semibold tracking-tight text-ink">
        EduRank<em class="not-italic text-burn">AI</em>
      </span>
    </a>

    <div class="hidden md:flex items-center gap-7">
      {NAV_PRIMARY.map((item) => (
        <a href={item.href} class="text-[0.82rem] font-medium text-ink-soft hover:text-ink transition-colors">{item.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      {!user && (
        <>
          <a href="/portal/login" class="hidden sm:inline-flex text-[0.82rem] font-medium text-ink-soft hover:text-ink transition-colors">Sign in</a>
          <a href="/careers" class="inline-flex items-center gap-2 bg-burn text-white px-4 py-2 rounded-lg text-[0.82rem] font-semibold hover:bg-burn-2 transition-all">View Roles</a>
        </>
      )}

      {isApplicant && (
        <>
          <a href="/portal" class="hidden sm:inline-flex text-[0.82rem] font-medium text-ink-soft hover:text-ink transition-colors">My Applications</a>
          <a href="/careers" class="inline-flex items-center gap-2 bg-burn text-white px-4 py-2 rounded-lg text-[0.82rem] font-semibold hover:bg-burn-2 transition-all">Browse Roles</a>
          <form method="POST" action="/portal/logout" style="margin:0">
            <button type="submit" title="Sign out" class="w-9 h-9 rounded-full bg-burn text-white font-bold text-[0.85rem] hover:bg-burn-2 transition-all">{userInitial}</button>
          </form>
        </>
      )}

      {isAdmin && (
        <>
          <a href="/admin" class="hidden sm:inline-flex text-[0.82rem] font-medium text-ink-soft hover:text-ink transition-colors">Admin</a>
          <form method="POST" action="/admin/logout" style="margin:0">
            <button type="submit" title="Sign out of admin" class="inline-flex items-center gap-2 bg-burn text-white px-4 py-2 rounded-lg text-[0.82rem] font-semibold hover:bg-burn-2 transition-all">Sign out</button>
          </form>
        </>
      )}
    </div>
  </nav>
</header>
