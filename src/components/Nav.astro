---
import { SITE, NAV_PRIMARY } from '@/lib/site';

const user = Astro.locals.user;
const isApplicant = user && user.role === 'applicant';
const isAdmin = user && user.role !== 'applicant';
const userInitial = user && user.name ? user.name.substring(0, 1).toUpperCase() : '';
---
<header class="sticky top-0 z-50 bg-cream/95 backdrop-blur-md border-b border-ink/8">
  <nav class="px-[5vw] py-3.5 max-w-7xl mx-auto flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2 group">
      <span class="font-display text-[1.15rem] font-semibold tracking-tight text-ink">
        EduRank<em class="not-italic text-burn">AI</em>
      </span>
    </a>

    <div class="hidden md:flex items-center gap-7">
      {NAV_PRIMARY.map((item) => (
        <a href={item.href} class="text-[0.82rem] font-medium text-ink-soft hover:text-ink transition-colors">{item.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      {!user && (
        <>
          <a href="/portal/login" class="hidden sm:inline-flex text-[0.82rem] font-medium text-ink-soft hover:text-ink transition-colors">Sign in</a>
          <a href="/careers" class="inline-flex items-center gap-2 bg-burn text-white px-4 py-2 rounded-lg text-[0.82rem] font-semibold hover:bg-burn-2 transition-all">View Roles</a>
        </>
      )}

      {isApplicant && (
        <>
          <a href="/portal" class="hidden sm:inline-flex text-[0.82rem] font-medium text-ink-soft hover:text-ink transition-colors">My Applications</a>
          <a href="/careers" class="inline-flex items-center gap-2 bg-burn text-white px-4 py-2 rounded-lg text-[0.82rem] font-semibold hover:bg-burn-2 transition-all">Browse Roles</a>
          <form method="POST" action="/portal/logout" style="margin:0">
            <button type="submit" title="Sign out" class="w-9 h-9 rounded-full bg-burn text-white font-bold text-[0.85rem] hover:bg-burn-2 transition-all">{userInitial}</button>
          </form>
        </>
      )}

      {isAdmin && (
        <>
          <a href="/admin" class="hidden sm:inline-flex text-[0.82rem] font-medium text-ink-soft hover:text-ink transition-colors">Admin</a>
          <form method="POST" action="/admin/logout" style="margin:0">
            <button type="submit" title="Sign out of admin" class="inline-flex items-center gap-2 bg-burn text-white px-4 py-2 rounded-lg text-[0.82rem] font-semibold hover:bg-burn-2 transition-all">Sign out</button>
          </form>
        </>
      )}

      {/* Mobile menu toggle - chevron icon, visible only on mobile */}
      <button type="button" id="mobile-nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav-panel" class="md:hidden inline-flex items-center justify-center w-9 h-9 rounded-lg text-ink-soft hover:bg-ink/5 transition-colors">
        <svg id="mobile-nav-icon-down" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
        <svg id="mobile-nav-icon-up" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
          <polyline points="18 15 12 9 6 15"></polyline>
        </svg>
      </button>
    </div>
  </nav>

  {/* Mobile fold-down panel - hidden by default, opens downward */}
  <div id="mobile-nav-panel" class="md:hidden overflow-hidden bg-cream-2 border-t border-ink/8" style="max-height:0;transition:max-height 0.28s ease-out;">
    <div class="px-[5vw] py-4 flex flex-col gap-1">
      {NAV_PRIMARY.map((item) => (
        <a href={item.href} class="block py-2.5 px-3 rounded-lg text-[0.95rem] font-medium text-ink-2 hover:bg-burn-pale/40 hover:text-burn transition-colors">{item.label}</a>
      ))}
      {!user && (
        <a href="/portal/login" class="sm:hidden block py-2.5 px-3 rounded-lg text-[0.95rem] font-medium text-ink-2 hover:bg-burn-pale/40 hover:text-burn transition-colors mt-2 border-t border-ink/8 pt-4">Sign in</a>
      )}
      {isApplicant && (
        <a href="/portal" class="sm:hidden block py-2.5 px-3 rounded-lg text-[0.95rem] font-medium text-ink-2 hover:bg-burn-pale/40 hover:text-burn transition-colors mt-2 border-t border-ink/8 pt-4">My Applications</a>
      )}
      {isAdmin && (
        <a href="/admin" class="sm:hidden block py-2.5 px-3 rounded-lg text-[0.95rem] font-medium text-ink-2 hover:bg-burn-pale/40 hover:text-burn transition-colors mt-2 border-t border-ink/8 pt-4">Admin Panel</a>
      )}
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    var toggle = document.getElementById('mobile-nav-toggle');
    var panel = document.getElementById('mobile-nav-panel');
    var iconDown = document.getElementById('mobile-nav-icon-down');
    var iconUp = document.getElementById('mobile-nav-icon-up');
    if (!toggle || !panel) return;

    var open = false;
    function setOpen(state) {
      open = state;
      if (open) {
        panel.style.maxHeight = panel.scrollHeight + 'px';
        toggle.setAttribute('aria-expanded', 'true');
        toggle.setAttribute('aria-label', 'Close menu');
        if (iconDown) iconDown.style.display = 'none';
        if (iconUp) iconUp.style.display = 'block';
      } else {
        panel.style.maxHeight = '0px';
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Open menu');
        if (iconDown) iconDown.style.display = 'block';
        if (iconUp) iconUp.style.display = 'none';
      }
    }

    toggle.addEventListener('click', function () { setOpen(!open); });

    // Close panel when a link inside it is tapped (so navigation feels clean)
    panel.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', function () { setOpen(false); });
    });

    // Close on Escape key
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && open) setOpen(false);
    });
  })();
</script>
