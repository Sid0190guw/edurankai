---
// Full unified mail client. Used by /admin/mail and /portal/mail.
// Props: user (Astro.locals.user), basePath ('/admin/mail' | '/portal/mail')
import { getFolderCounts, getMailboxAddress, listFolder, getThreadMessages, markThreadRead, FOLDERS } from '@/lib/mail';

const { user, basePath = '/admin/mail' } = Astro.props as { user: any; basePath?: string };

const url = new URL(Astro.request.url);
const folderParam = url.searchParams.get('folder') || 'inbox';
const starred = folderParam === 'starred';
const folder = starred ? 'inbox' : (folderParam as any);
const q = url.searchParams.get('q') || '';
const threadId = url.searchParams.get('thread') || '';

let counts: Record<string, number> = {};
let myAddress = '';
let list: any[] = [];
let dbReady = true;
try {
  counts = await getFolderCounts(user.id);
  myAddress = await getMailboxAddress(user.id);
  list = await listFolder(user.id, folder, q, starred);
} catch (e) {
  dbReady = false;
}

let thread: any[] = [];
let threadSubject = '';
let threadOtherParty = '';
if (threadId && dbReady) {
  try {
    thread = await getThreadMessages(user.id, threadId);
    await markThreadRead(user.id, threadId);
  } catch (e) { thread = []; }
  const first = thread[0];
  threadSubject = first?.subject || '(no subject)';
  const last = thread[thread.length - 1] || {};
  const myEmail = (myAddress || '').toLowerCase();
  threadOtherParty = (last.from_email && last.from_email.toLowerCase() !== myEmail)
    ? last.from_email
    : ((last.recipients || []).find((r: any) => (r.email || '').toLowerCase() !== myEmail)?.email || last.from_email || '');
}

function stripTags(s: string) { return String(s || '').replace(/<style[\s\S]*?<\/style>/gi, '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim(); }
function bodyToText(m: any) { return m.body_text || stripTags(m.body_html); }
function initialOf(s: string) { return (s || '?').trim().charAt(0).toUpperCase() || '?'; }
function timeAgo(d: any) {
  if (!d) return '';
  const diff = Date.now() - new Date(d).getTime();
  const m = Math.floor(diff / 60000);
  if (m < 1) return 'now';
  if (m < 60) return m + 'm';
  const h = Math.floor(m / 60);
  if (h < 24) return h + 'h';
  const days = Math.floor(h / 24);
  if (days < 7) return days + 'd';
  return new Date(d).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' });
}
function fullTime(d: any) { return d ? new Date(d).toLocaleString('en-IN', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : ''; }

const folderLinks = [
  ...FOLDERS.slice(0, 1),
  { key: 'starred', label: 'Starred' } as any,
  ...FOLDERS.slice(1),
];
---

<div class="mailc" data-base={basePath}>
  {!dbReady && (
    <div style="padding:9px 16px;background:rgba(251,191,36,0.12);border-bottom:1px solid rgba(251,191,36,0.28);color:#fbbf24;font-size:12px;">
      Mailboxes are being set up. Once the database migration runs, your inbox will appear here.
    </div>
  )}
  <!-- Header -->
  <div class="mc-head">
    <div class="mc-head-id">
      <span class="mc-dot"></span>
      <div>
        <p class="mc-title">Mail</p>
        <p class="mc-addr">{myAddress}</p>
      </div>
    </div>
    <form class="mc-search" method="get" action={basePath}>
      <input type="hidden" name="folder" value={folderParam} />
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      <input type="search" name="q" value={q} placeholder="Search mail" autocomplete="off" />
    </form>
    <button type="button" class="mc-compose-btn" id="mcComposeBtn">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
      <span>Compose</span>
    </button>
  </div>

  <div class={`mc-body ${threadId ? 'mc-has-thread' : ''}`}>
    <!-- Folder rail -->
    <nav class="mc-rail">
      {folderLinks.map((f: any) => {
        const active = f.key === 'starred' ? starred : (!starred && folderParam === f.key);
        const unread = counts[f.key] || 0;
        return (
          <a href={`${basePath}?folder=${f.key}`} class={`mc-rail-item ${active ? 'on' : ''}`}>
            <span class="mc-rail-label">{f.label}</span>
            {unread > 0 && f.key !== 'sent' && f.key !== 'starred' && <span class="mc-rail-badge">{unread}</span>}
          </a>
        );
      })}
    </nav>

    <!-- Thread list -->
    <div class="mc-list">
      {list.length === 0 && (
        <div class="mc-empty">
          <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
          <p>{q ? 'No mail matches your search.' : 'Nothing here yet.'}</p>
        </div>
      )}
      {list.map((t: any) => (
        <a href={`${basePath}?folder=${folderParam}&thread=${t.thread_id}`} class={`mc-row ${t.is_read ? '' : 'unread'} ${threadId === t.thread_id ? 'sel' : ''}`}>
          <button type="button" class={`mc-star ${t.is_starred ? 'on' : ''}`} data-thread={t.thread_id} data-action={t.is_starred ? 'unstar' : 'star'} aria-label="Star">
            <svg width="16" height="16" viewBox="0 0 24 24" fill={t.is_starred ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="1.7"><path d="M12 2l3 6.3 6.9 1-5 4.9 1.2 6.8L12 17.8 5.9 21l1.2-6.8-5-4.9 6.9-1z"/></svg>
          </button>
          <div class="mc-avatar" aria-hidden="true">{initialOf(folder === 'sent' || folder === 'drafts' ? (t.from_name || myAddress) : t.from_name)}</div>
          <div class="mc-row-main">
            <div class="mc-row-top">
              <span class="mc-from">{t.from_name || t.from_email}</span>
              <span class="mc-time">{timeAgo(t.created_at)}</span>
            </div>
            <p class="mc-subj">{t.subject || '(no subject)'}{t.thread_count > 1 && <span class="mc-count">{t.thread_count}</span>}</p>
            <p class="mc-snip">{t.snippet}</p>
          </div>
          <div class="mc-row-icons">
            {t.has_attachments && <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.4 11.05 12.25 20.2a5 5 0 0 1-7.07-7.07l9.19-9.19a3 3 0 0 1 4.24 4.24l-9.2 9.19a1 1 0 0 1-1.41-1.41l8.49-8.49"/></svg>}
          </div>
        </a>
      ))}
    </div>

    <!-- Reading pane -->
    <div class="mc-read">
      {!threadId && (
        <div class="mc-read-empty">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" opacity="0.45"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
          <p>Select a conversation to read</p>
        </div>
      )}
      {threadId && (
        <div class="mc-thread">
          <div class="mc-thread-head">
            <a href={`${basePath}?folder=${folderParam}`} class="mc-back" aria-label="Back">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
            </a>
            <h2 class="mc-thread-subj">{threadSubject}</h2>
            <div class="mc-thread-actions">
              <button type="button" class="mc-act" data-thread={threadId} data-action="archive" title="Archive">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="5" rx="1"/><path d="M4 9v9a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9M10 13h4"/></svg>
              </button>
              <button type="button" class="mc-act" data-thread={threadId} data-action="trash" title="Delete">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2m2 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg>
              </button>
              <button type="button" class="mc-act" data-thread={threadId} data-action="unread" title="Mark unread">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
              </button>
              <button type="button" class="mc-act" data-thread={threadId} data-action="spam" title="Report spam">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4m0 4h.01M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z"/></svg>
              </button>
            </div>
          </div>

          <div class="mc-msgs">
            {thread.map((m: any) => (
              <div class="mc-msg">
                <div class="mc-msg-head">
                  <div class="mc-avatar sm">{initialOf(m.from_name || m.from_email)}</div>
                  <div class="mc-msg-meta">
                    <p class="mc-msg-from">{m.from_name || m.from_email} <span class="mc-msg-email">&lt;{m.from_email}&gt;</span></p>
                    <p class="mc-msg-to">to {(m.recipients || []).map((r: any) => r.name || r.email).join(', ') || 'me'}</p>
                  </div>
                  <span class="mc-msg-time">{fullTime(m.created_at)}</span>
                </div>
                <div class="mc-msg-body">{bodyToText(m)}</div>
                {(m.attachments || []).length > 0 && (
                  <div class="mc-atts">
                    {m.attachments.map((a: any) => (
                      <a href={a.url} target="_blank" rel="noopener" class="mc-att">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.4 11.05 12.25 20.2a5 5 0 0 1-7.07-7.07l9.19-9.19a3 3 0 0 1 4.24 4.24l-9.2 9.19a1 1 0 0 1-1.41-1.41l8.49-8.49"/></svg>
                        <span>{a.filename}</span>
                      </a>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>

          <div class="mc-reply" data-thread={threadId} data-to={threadOtherParty} data-subject={threadSubject}>
            <button type="button" class="mc-reply-btn" id="mcReplyBtn">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 17l-5-5 5-5M4 12h11a5 5 0 0 1 0 10h-1"/></svg>
              Reply
            </button>
            <button type="button" class="mc-reply-btn ghost" id="mcForwardBtn">Forward</button>
          </div>
        </div>
      )}
    </div>
  </div>

  <!-- Compose modal -->
  <div class="mc-modal" id="mcModal" hidden>
    <div class="mc-modal-card">
      <div class="mc-modal-head">
        <span id="mcModalTitle">New message</span>
        <button type="button" id="mcClose" aria-label="Close">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="mc-modal-body">
        <input type="hidden" id="mcThreadId" />
        <input type="hidden" id="mcInReplyTo" />
        <div class="mc-field"><label>To</label><input type="text" id="mcTo" placeholder="name@example.com, ..." /></div>
        <div class="mc-field mc-ccrow">
          <label>Cc</label><input type="text" id="mcCc" placeholder="cc (optional)" />
          <label>Bcc</label><input type="text" id="mcBcc" placeholder="bcc (optional)" />
        </div>
        <div class="mc-field"><label>Subject</label><input type="text" id="mcSubject" placeholder="Subject" /></div>
        <textarea id="mcBody" rows="9" placeholder="Write your message..."></textarea>
        <div class="mc-field"><label>Attach URL</label><input type="text" id="mcAttUrl" placeholder="https://drive... link (optional)" /></div>
        <div class="mc-att-list" id="mcAttList"></div>
      </div>
      <div class="mc-modal-foot">
        <button type="button" class="mc-send" id="mcSend">Send</button>
        <button type="button" class="mc-savedraft" id="mcSaveDraft">Save draft</button>
        <span class="mc-status" id="mcStatus"></span>
      </div>
    </div>
  </div>
</div>

<style>
.mailc{
  --mc-bg: var(--o-bg0, #07090d);
  --mc-card: var(--o-bg2, #0f1218);
  --mc-soft: var(--o-panel, rgba(255,255,255,0.045));
  --mc-border: var(--o-stroke, rgba(255,255,255,0.09));
  --mc-text: var(--o-hi, #e9edf2);
  --mc-mid: var(--o-mid, #8b94a3);
  --mc-accent: var(--o-brand, #FF4F00);
  --mc-accent-bright: var(--o-brand-bright, #ff8a4c);
  color: var(--mc-text); display:flex; flex-direction:column; height:calc(100vh - 0px); min-height:560px;
  font-family: var(--o-font-body, inherit);
}
.mc-head{ display:flex; align-items:center; gap:12px; padding:12px 16px; border-bottom:1px solid var(--mc-border); background:var(--mc-bg); position:sticky; top:0; z-index:8; flex-wrap:wrap; }
.mc-head-id{ display:flex; align-items:center; gap:9px; min-width:0; }
.mc-dot{ width:32px; height:32px; border-radius:9px; background:linear-gradient(135deg,var(--mc-accent),var(--mc-accent-bright)); flex-shrink:0; box-shadow:0 0 16px var(--o-brand-glow, rgba(255,79,0,0.35)); }
.mc-title{ font-size:14px; font-weight:800; margin:0; letter-spacing:-0.01em; }
.mc-addr{ font-size:11px; margin:0; color:var(--mc-mid); font-family:var(--o-font-mono,monospace); }
.mc-search{ flex:1; min-width:160px; display:flex; align-items:center; gap:8px; background:var(--mc-soft); border:1px solid var(--mc-border); border-radius:10px; padding:0 10px; color:var(--mc-mid); }
.mc-search input{ flex:1; background:transparent; border:none; outline:none; color:var(--mc-text); font-size:13px; padding:9px 0; }
.mc-compose-btn{ display:flex; align-items:center; gap:7px; background:linear-gradient(135deg,var(--mc-accent),var(--mc-accent-bright)); color:#fff; border:none; border-radius:10px; padding:9px 16px; font-size:13px; font-weight:700; cursor:pointer; box-shadow:0 6px 18px var(--o-brand-glow, rgba(255,79,0,0.32)); }

.mc-body{ flex:1; display:grid; grid-template-columns:190px 360px 1fr; min-height:0; }
.mc-rail{ border-right:1px solid var(--mc-border); padding:10px 8px; display:flex; flex-direction:column; gap:2px; background:var(--mc-bg); overflow-y:auto; }
.mc-rail-item{ display:flex; align-items:center; justify-content:space-between; gap:8px; text-decoration:none; color:var(--mc-mid); font-size:13px; font-weight:600; padding:9px 12px; border-radius:9px; }
.mc-rail-item:hover{ background:var(--mc-soft); color:var(--mc-text); }
.mc-rail-item.on{ background:var(--o-brand-soft, rgba(255,79,0,0.14)); color:var(--mc-text); box-shadow:inset 2px 0 0 var(--mc-accent); }
.mc-rail-badge{ background:var(--mc-accent); color:#fff; font-size:10px; font-weight:800; border-radius:100px; padding:1px 7px; }

.mc-list{ border-right:1px solid var(--mc-border); overflow-y:auto; background:var(--mc-bg); }
.mc-row{ display:flex; align-items:flex-start; gap:10px; padding:11px 12px; border-bottom:1px solid var(--mc-border); text-decoration:none; color:var(--mc-text); position:relative; }
.mc-row:hover{ background:var(--mc-soft); }
.mc-row.sel{ background:var(--o-brand-soft, rgba(255,79,0,0.12)); }
.mc-row.unread{ background:color-mix(in srgb, var(--mc-card) 60%, transparent); }
.mc-row.unread .mc-from, .mc-row.unread .mc-subj{ font-weight:800; }
.mc-star{ background:none; border:none; color:var(--mc-mid); cursor:pointer; padding:2px; margin-top:2px; flex-shrink:0; }
.mc-star.on{ color:#f5b30a; }
.mc-avatar{ width:34px; height:34px; border-radius:50%; background:linear-gradient(135deg,var(--mc-accent),var(--mc-accent-bright)); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:14px; flex-shrink:0; }
.mc-avatar.sm{ width:30px; height:30px; font-size:12px; }
.mc-row-main{ flex:1; min-width:0; }
.mc-row-top{ display:flex; justify-content:space-between; gap:8px; }
.mc-from{ font-size:13px; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.mc-time{ font-size:11px; color:var(--mc-mid); flex-shrink:0; }
.mc-subj{ font-size:12.5px; margin:2px 0 0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.mc-count{ display:inline-block; background:var(--mc-soft); border:1px solid var(--mc-border); color:var(--mc-mid); font-size:10px; font-weight:700; border-radius:100px; padding:0 6px; margin-left:6px; }
.mc-snip{ font-size:11.5px; color:var(--mc-mid); margin:2px 0 0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.mc-row-icons{ color:var(--mc-mid); flex-shrink:0; margin-top:3px; }
.mc-empty,.mc-read-empty{ display:flex; flex-direction:column; align-items:center; justify-content:center; gap:12px; color:var(--mc-mid); padding:60px 20px; text-align:center; font-size:13px; height:100%; }

.mc-read{ overflow-y:auto; background:var(--mc-bg); }
.mc-thread-head{ display:flex; align-items:center; gap:10px; padding:14px 18px; border-bottom:1px solid var(--mc-border); position:sticky; top:0; background:var(--mc-bg); z-index:5; }
.mc-back{ display:none; color:var(--mc-text); }
.mc-thread-subj{ font-size:17px; font-weight:800; margin:0; flex:1; letter-spacing:-0.01em; }
.mc-thread-actions{ display:flex; gap:4px; }
.mc-act{ background:var(--mc-soft); border:1px solid var(--mc-border); color:var(--mc-mid); width:32px; height:32px; border-radius:8px; cursor:pointer; display:flex; align-items:center; justify-content:center; }
.mc-act:hover{ color:var(--mc-text); border-color:var(--mc-accent); }
.mc-msgs{ padding:16px 18px; display:flex; flex-direction:column; gap:14px; }
.mc-msg{ background:var(--mc-card); border:1px solid var(--mc-border); border-radius:14px; padding:14px 16px; }
.mc-msg-head{ display:flex; align-items:center; gap:10px; margin-bottom:10px; }
.mc-msg-meta{ flex:1; min-width:0; }
.mc-msg-from{ font-size:13px; font-weight:700; margin:0; }
.mc-msg-email{ font-weight:400; color:var(--mc-mid); font-size:11px; }
.mc-msg-to{ font-size:11px; color:var(--mc-mid); margin:1px 0 0; }
.mc-msg-time{ font-size:11px; color:var(--mc-mid); flex-shrink:0; }
.mc-msg-body{ font-size:14px; line-height:1.65; white-space:pre-wrap; word-break:break-word; }
.mc-atts{ display:flex; flex-wrap:wrap; gap:8px; margin-top:12px; }
.mc-att{ display:flex; align-items:center; gap:6px; background:var(--mc-soft); border:1px solid var(--mc-border); border-radius:8px; padding:6px 10px; font-size:12px; color:var(--mc-text); text-decoration:none; }
.mc-reply{ padding:12px 18px 22px; display:flex; gap:8px; }
.mc-reply-btn{ display:flex; align-items:center; gap:7px; background:var(--mc-soft); border:1px solid var(--mc-border); color:var(--mc-text); border-radius:10px; padding:10px 18px; font-size:13px; font-weight:700; cursor:pointer; }
.mc-reply-btn:not(.ghost){ background:linear-gradient(135deg,var(--mc-accent),var(--mc-accent-bright)); color:#fff; border-color:transparent; }

.mc-modal{ position:fixed; inset:0; background:rgba(0,0,0,0.55); backdrop-filter:blur(4px); z-index:1000; display:flex; align-items:flex-end; justify-content:center; padding:0; }
.mc-modal[hidden]{ display:none !important; }
@media(min-width:721px){ .mc-modal{ align-items:center; padding:24px; } }
.mc-modal-card{ width:100%; max-width:600px; background:var(--mc-card); border:1px solid var(--mc-border); border-radius:16px 16px 0 0; display:flex; flex-direction:column; max-height:92vh; box-shadow:0 -10px 40px rgba(0,0,0,0.4); }
@media(min-width:721px){ .mc-modal-card{ border-radius:16px; } }
.mc-modal-head{ display:flex; align-items:center; justify-content:space-between; padding:14px 16px; border-bottom:1px solid var(--mc-border); font-size:14px; font-weight:800; }
.mc-modal-head button{ background:none; border:none; color:var(--mc-mid); cursor:pointer; }
.mc-modal-body{ padding:14px 16px; overflow-y:auto; display:flex; flex-direction:column; gap:10px; }
.mc-field{ display:flex; align-items:center; gap:10px; border-bottom:1px solid var(--mc-border); }
.mc-field label{ font-size:11px; font-weight:700; color:var(--mc-mid); width:54px; flex-shrink:0; text-transform:uppercase; letter-spacing:0.06em; }
.mc-field input{ flex:1; background:transparent; border:none; outline:none; color:var(--mc-text); font-size:13px; padding:10px 0; }
.mc-ccrow{ gap:8px; }
.mc-ccrow label:last-of-type{ width:auto; }
#mcBody{ background:var(--mc-soft); border:1px solid var(--mc-border); border-radius:10px; padding:12px; color:var(--mc-text); font-size:14px; line-height:1.6; resize:vertical; outline:none; font-family:inherit; }
.mc-att-list{ display:flex; flex-direction:column; gap:4px; }
.mc-att-chip{ display:flex; align-items:center; justify-content:space-between; background:var(--mc-soft); border:1px solid var(--mc-border); border-radius:8px; padding:6px 10px; font-size:12px; }
.mc-att-chip button{ background:none; border:none; color:var(--mc-mid); cursor:pointer; }
.mc-modal-foot{ display:flex; align-items:center; gap:10px; padding:12px 16px; border-top:1px solid var(--mc-border); }
.mc-send{ background:linear-gradient(135deg,var(--mc-accent),var(--mc-accent-bright)); color:#fff; border:none; border-radius:10px; padding:10px 26px; font-size:14px; font-weight:800; cursor:pointer; }
.mc-savedraft{ background:var(--mc-soft); border:1px solid var(--mc-border); color:var(--mc-text); border-radius:10px; padding:10px 16px; font-size:13px; font-weight:600; cursor:pointer; }
.mc-status{ font-size:12px; color:var(--mc-mid); }

@media(max-width:1024px){ .mc-body{ grid-template-columns:64px 320px 1fr; } .mc-rail-label{ display:none; } .mc-rail-item{ justify-content:center; } }
@media(max-width:720px){
  .mc-body{ grid-template-columns:1fr; }
  .mc-rail{ flex-direction:row; overflow-x:auto; border-right:none; border-bottom:1px solid var(--mc-border); padding:8px; }
  .mc-rail-label{ display:inline; }
  .mc-rail-item{ white-space:nowrap; }
  .mc-list{ border-right:none; display:block; }
  .mc-read{ display:none; }
  .mc-has-thread .mc-rail, .mc-has-thread .mc-list{ display:none; }
  .mc-has-thread .mc-read{ display:block; }
  .mc-back{ display:inline-flex; }
}
</style>

<script is:inline define:vars={{ basePath, myAddress }}>
(function(){
  const modal = document.getElementById('mcModal');
  const $ = function(id){ return document.getElementById(id); };
  function openModal(title){ $('mcModalTitle').textContent = title || 'New message'; modal.hidden = false; $('mcTo').focus(); }
  function closeModal(){ modal.hidden = true; $('mcStatus').textContent=''; }
  function clearForm(){ ['mcTo','mcCc','mcBcc','mcSubject','mcBody','mcAttUrl','mcThreadId','mcInReplyTo'].forEach(function(id){ $(id).value=''; }); attachments=[]; renderAtts(); }

  let attachments = [];
  function renderAtts(){
    const box = $('mcAttList'); box.innerHTML='';
    attachments.forEach(function(a,i){
      const d=document.createElement('div'); d.className='mc-att-chip';
      d.innerHTML='<span>'+a.filename+'</span>';
      const b=document.createElement('button'); b.type='button'; b.textContent='remove';
      b.onclick=function(){ attachments.splice(i,1); renderAtts(); };
      d.appendChild(b); box.appendChild(d);
    });
  }
  const attUrl = $('mcAttUrl');
  if (attUrl) attUrl.addEventListener('keydown', function(e){
    if(e.key==='Enter'){ e.preventDefault(); const u=attUrl.value.trim(); if(u){ attachments.push({url:u, filename:u.split('/').pop()||'attachment'}); attUrl.value=''; renderAtts(); } }
  });

  const composeBtn = $('mcComposeBtn');
  if (composeBtn) composeBtn.addEventListener('click', function(){ clearForm(); openModal('New message'); });
  const closeBtn = $('mcClose'); if (closeBtn) closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', function(e){ if(e.target===modal) closeModal(); });

  // Reply / forward prefill
  const replyBox = document.querySelector('.mc-reply');
  const replyBtn = $('mcReplyBtn'), fwdBtn = $('mcForwardBtn');
  if (replyBtn && replyBox) replyBtn.addEventListener('click', function(){
    clearForm();
    $('mcTo').value = replyBox.getAttribute('data-to') || '';
    $('mcThreadId').value = replyBox.getAttribute('data-thread') || '';
    let s = replyBox.getAttribute('data-subject')||''; if(!/^re:/i.test(s)) s='Re: '+s;
    $('mcSubject').value = s;
    openModal('Reply');
  });
  if (fwdBtn && replyBox) fwdBtn.addEventListener('click', function(){
    clearForm();
    let s = replyBox.getAttribute('data-subject')||''; if(!/^fwd:/i.test(s)) s='Fwd: '+s;
    $('mcSubject').value = s; $('mcThreadId').value = replyBox.getAttribute('data-thread')||'';
    openModal('Forward');
  });

  function payload(){
    return {
      to: $('mcTo').value, cc: $('mcCc').value, bcc: $('mcBcc').value,
      subject: $('mcSubject').value, body: $('mcBody').value,
      threadId: $('mcThreadId').value || null, attachments: attachments,
    };
  }
  async function post(url, data){
    const r = await fetch(url, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(data) });
    return r.json();
  }
  const sendBtn = $('mcSend');
  if (sendBtn) sendBtn.addEventListener('click', async function(){
    const p = payload();
    if(!p.to.trim()){ $('mcStatus').textContent='Add a recipient'; return; }
    $('mcStatus').textContent='Sending...'; sendBtn.disabled=true;
    try{
      const res = await post('/api/mail/send', p);
      if(res.ok){
        if (res.external && res.external.attempted > 0 && !res.external.delivered) {
          $('mcStatus').textContent = 'Saved to Sent. External delivery is not set up yet (' + (res.external.error || 'no transport') + ').';
          sendBtn.disabled = false;
        } else {
          $('mcStatus').textContent = res.external && res.external.attempted ? ('Sent (external via ' + res.external.provider + ')') : 'Sent';
          setTimeout(function(){ location.href = basePath + '?folder=sent'; }, 500);
        }
      }
      else { $('mcStatus').textContent = res.error || 'Failed'; sendBtn.disabled=false; }
    }catch(e){ $('mcStatus').textContent='Network error'; sendBtn.disabled=false; }
  });
  const draftBtn = $('mcSaveDraft');
  if (draftBtn) draftBtn.addEventListener('click', async function(){
    $('mcStatus').textContent='Saving...';
    try{ const res = await post('/api/mail/draft', payload()); $('mcStatus').textContent = res.ok ? 'Draft saved' : (res.error||'Failed'); if(res.ok) setTimeout(closeModal, 500); }
    catch(e){ $('mcStatus').textContent='Network error'; }
  });

  // Star toggles + thread actions
  document.querySelectorAll('.mc-star').forEach(function(btn){
    btn.addEventListener('click', async function(e){
      e.preventDefault(); e.stopPropagation();
      const thread = btn.getAttribute('data-thread'); const action = btn.getAttribute('data-action');
      await post('/api/mail/action', { action: action, threadId: thread });
      location.reload();
    });
  });
  document.querySelectorAll('.mc-act').forEach(function(btn){
    btn.addEventListener('click', async function(){
      const thread = btn.getAttribute('data-thread'); const action = btn.getAttribute('data-action');
      await post('/api/mail/action', { action: action, threadId: thread });
      location.href = basePath + '?folder=inbox';
    });
  });
})();
</script>
