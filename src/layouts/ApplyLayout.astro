---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { STEP_LABELS, STEP_SHORT } from '@/lib/apply/data';

interface Props {
  step: number;
  totalSteps: number;
  stepTitle: string;
  stepSubtitle: string;
  pageTitle?: string;
  roleTitle?: string;
}

const { step, totalSteps, stepTitle, stepSubtitle, pageTitle, roleTitle } = Astro.props;
const fullTitle = pageTitle || (stepTitle + ' - Apply to EduRankAI');
const progressPct = Math.max(0, ((step - 1) / (totalSteps - 1)) * 100);
---
<BaseLayout title={fullTitle} description="Apply to build the future of learning at EduRankAI.">
  <section class="px-[5vw] py-10 md:py-14 max-w-3xl mx-auto">

    <div class="text-center mb-8 md:mb-10">
      <p class="font-display text-[1.3rem] md:text-[1.4rem] font-semibold text-ink mb-2">
        EduRank<em class="not-italic text-burn">AI</em>
      </p>
      <h1 class="font-display text-[clamp(1.9rem,4.5vw,2.8rem)] font-semibold text-ink leading-[1.1] tracking-tight mb-3">
        Apply to build the<br/>
        <em class="italic text-burn font-medium">future of learning</em>
      </h1>
      <p class="text-[0.78rem] text-ink-soft">Takes ~6 minutes · Purpose-driven · Roles across all departments</p>
    </div>

    {roleTitle && (
      <div class="bg-cream-2 border border-burn-dim rounded-xl p-4 mb-6 flex items-center justify-between gap-3">
        <div>
          <p class="text-[0.62rem] font-mono uppercase tracking-[0.15em] text-burn font-bold mb-0.5">Applying for</p>
          <p class="font-display text-[1.1rem] font-semibold text-ink leading-tight">{roleTitle}</p>
        </div>
        <a href="/careers" class="text-[0.75rem] text-ink-soft hover:text-burn font-mono">Change →</a>
      </div>
    )}

    <div class="bg-white border border-ink/10 rounded-2xl p-4 md:p-5 mb-5">
      <div class="flex items-center justify-between mb-3 pb-3 border-b border-ink/8">
        <p class="font-display text-[0.95rem] font-semibold text-ink">{STEP_LABELS[step - 1]}</p>
        <p class="text-[0.72rem] text-ink-soft font-mono">Step {step} of {totalSteps}</p>
      </div>

      <div class="h-[3px] bg-ink/10 rounded-full overflow-hidden mb-4">
        <div class="h-full bg-burn rounded-full transition-all" style={'width:' + progressPct + '%'}></div>
      </div>

      <div class="flex items-center justify-between">
        {STEP_SHORT.slice(0, totalSteps).map((short, i) => {
          const num = i + 1;
          const isDone = num < step;
          const isCurrent = num === step;
          const circleClass = isDone
            ? 'bg-burn border-burn text-white'
            : isCurrent
              ? 'bg-burn-pale border-burn text-burn'
              : 'bg-white border-ink/15 text-ink-soft';
          const labelClass = isCurrent ? 'text-burn font-bold' : (isDone ? 'text-ink-2' : 'text-ink-soft');
          return (
            <div class="flex flex-col items-center flex-1 relative">
              <div class={'w-7 h-7 rounded-full border-2 flex items-center justify-center text-[0.7rem] font-bold relative z-10 ' + circleClass}>
                {isDone ? '✓' : String(num).padStart(2, '0')}
              </div>
              <p class={'text-[0.58rem] font-mono mt-1.5 text-center ' + labelClass}>{short}</p>
            </div>
          );
        })}
      </div>
    </div>

    <div class="bg-white border border-ink/10 rounded-2xl p-5 md:p-7">
      <span class="inline-block text-[0.62rem] font-mono uppercase tracking-[0.12em] text-sky bg-sky-bg border border-sky-border px-2.5 py-0.5 rounded-full font-bold mb-3">STEP {step}</span>
      <h2 class="font-display text-[1.45rem] md:text-[1.7rem] font-semibold text-ink leading-tight mb-2">{stepTitle}</h2>
      <p class="text-[0.85rem] text-ink-soft mb-6">{stepSubtitle}</p>

      <slot />
    </div>

  </section>
</BaseLayout>
