---
import '@/styles/global.css';
import '@/styles/admin.css';
import '@/styles/design-system.css';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
// Dedicated, self-contained admin shell for the HEI · Editorial Control Plane —
// its own sidebar, branding and full-control navigation, visually matching the
// v0.1 control-plane design, separate from the main EduRankAI admin (mirrors how
// AquinTutor has its own layout). Every /admin/hei/* page renders inside this.
interface Props { title?: string; active?: string; crumb?: string; }
const { title = 'Editorial Control Plane', active = '', crumb = 'Editorial' } = Astro.props;

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login?next=' + encodeURIComponent(Astro.url.pathname));
if (user.role === 'applicant') return Astro.redirect('/portal');

type NavItem = { id: string; label: string; href: string; icon: string };
type NavGroup = { label: string; items: NavItem[] };
const NAV: NavGroup[] = [
  { label: 'Editorial', items: [
    { id: 'dashboard', label: 'Dashboard', href: '/admin/hei', icon: 'home' },
    { id: 'leads', label: 'Lead queue', href: '/admin/hei/leads', icon: 'inbox' },
    { id: 'findings', label: 'Draft findings', href: '/admin/hei/findings', icon: 'edit' },
    { id: 'replies', label: 'Right-of-reply', href: '/admin/hei/replies', icon: 'clock' },
  ]},
  { label: 'Rankings', items: [
    { id: 'institutions', label: 'Institutions', href: '/admin/hei/institutions', icon: 'grid' },
    { id: 'entity-types', label: 'Entity types', href: '/admin/hei/entity-types', icon: 'tag' },
    { id: 'submetrics', label: 'Sub-metrics', href: '/admin/hei/submetrics', icon: 'sliders' },
    { id: 'methodology', label: 'v1 Methodology', href: '/admin/hei/v1-methodology', icon: 'book' },
  ]},
  { label: 'Data layer', items: [
    { id: 'crawlers', label: 'Crawlers', href: '/admin/hei/crawlers', icon: 'target' },
    { id: 'surveys', label: 'Survey responses', href: '/admin/hei/surveys', icon: 'grid2' },
    { id: 'rti', label: 'RTI tracker', href: '/admin/hei/rti', icon: 'doc' },
    { id: 'import', label: 'CSV import', href: '/admin/hei/import', icon: 'upload' },
  ]},
  { label: 'Public surface', items: [
    { id: 'stories', label: 'Stories', href: '/admin/hei/stories', icon: 'doc' },
    { id: 'claims', label: 'Institution claims', href: '/admin/hei/claims', icon: 'shield' },
    { id: 'submissions', label: 'Submission queue', href: '/admin/hei/submissions', icon: 'inbox' },
  ]},
  { label: 'Operations', items: [
    { id: 'legal', label: 'Legal queue', href: '/admin/hei/legal', icon: 'scale' },
    { id: 'audit', label: 'Audit log', href: '/admin/audit', icon: 'activity' },
  ]},
];

const ICON: Record<string, string> = {
  home: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  inbox: '<polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>',
  edit: '<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4z"/>',
  clock: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  grid: '<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>',
  grid2: '<rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/>',
  tag: '<path d="M20.59 13.41 13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/>',
  sliders: '<line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/>',
  book: '<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>',
  target: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
  doc: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>',
  upload: '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  scale: '<path d="M12 3v18"/><path d="M5 7h14"/><path d="M7 7l-3 6h6z"/><path d="M17 7l-3 6h6z"/><path d="M7 21h10"/>',
  activity: '<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>',
};
function ic(k: string) { return ICON[k] || ICON.doc; }
const initials = (user.name || 'A').substring(0, 2).toUpperCase();

// Live counts for the nav badges — one round trip, degrades to no badges if any
// runtime-bootstrapped table is missing (never breaks the page).
let counts: Record<string, number> = {};
try {
  const r: any = await db.execute(sql`SELECT
    (SELECT count(*) FROM hei_leads WHERE status = 'active') AS leads,
    (SELECT count(*) FROM hei_findings WHERE status = 'draft') AS findings,
    (SELECT count(*) FROM hei_findings WHERE status = 'notice_sent') AS replies,
    (SELECT count(*) FROM hei_institutions WHERE is_published = true) AS institutions,
    (SELECT count(*) FROM hei_survey_responses) AS surveys,
    (SELECT count(*) FROM hei_rti_filings) AS rti,
    (SELECT count(*) FROM hei_crawlers) AS crawlers,
    (SELECT count(*) FROM hei_legal_queue WHERE status = 'open') AS legal,
    (SELECT count(*) FROM institution_claims WHERE status = 'pending') AS claims,
    (SELECT count(*) FROM institution_submissions WHERE submission_status = 'submitted') AS submissions`);
  const rows = Array.isArray(r) ? r : (r?.rows || []);
  const row: any = rows[0] || {};
  ['leads','findings','replies','institutions','surveys','rti','crawlers','legal','claims','submissions'].forEach((k) => { counts[k] = Number(row[k]) || 0; });
} catch (e) { counts = {}; }

// Badge policy: actionable queues show only when > 0 (with a tone); totals always show.
const BADGE: Record<string, { tone: string; total?: boolean }> = {
  leads: { tone: 'alert' }, findings: { tone: '' }, replies: { tone: 'warn' },
  institutions: { tone: '', total: true }, surveys: { tone: '', total: true }, rti: { tone: '', total: true }, crawlers: { tone: '', total: true },
  legal: { tone: 'warn' }, claims: { tone: 'alert' }, submissions: { tone: 'alert' },
};
function badgeFor(id: string): { text: string; cls: string } | null {
  if (!(id in counts)) return null;
  const cfg = BADGE[id]; if (!cfg) return null;
  const n = counts[id];
  if (!cfg.total && n <= 0) return null;
  return { text: n.toLocaleString('en-IN'), cls: cfg.tone };
}
const roleLabel = user.role === 'super_admin' ? 'Editor-in-chief · founder' : (user.role || '').replace(/_/g, ' ');

// Active item: explicit `active` prop wins; otherwise derive from the URL.
const path = (Astro.url.pathname.replace(/\/+$/, '') || '/');
function isActive(it: NavItem): boolean {
  if (active) return it.id === active;
  if (it.href === '/admin/hei') return path === '/admin/hei';
  return path === it.href || path.startsWith(it.href + '/');
}
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex" />
  <title>{title} · Editorial Control Plane</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    :root {
      --hbg:#0E0E10; --hbg2:#16161A; --hbg3:#1F1F24; --hbg4:#2A2A30;
      --hborder:#2D2D33; --hborder2:#3A3A42;
      --hink:#F5F5F7; --hink2:#C9C9D0; --hmuted:#7A7A85; --hmuted2:#5A5A63;
      --haccent:#FF6A3D; --haccent2:#FF8A65; --haccent-soft:rgba(255,106,61,0.15);
    }
    * { box-sizing:border-box; }
    body { margin:0; background:var(--hbg); color:var(--hink); font-family:'Inter Tight',system-ui,-apple-system,sans-serif; font-size:13px; line-height:1.45; -webkit-font-smoothing:antialiased; }
    a { color:inherit; text-decoration:none; }
    .h-app { display:grid; grid-template-columns:240px minmax(0,1fr); min-height:100vh; }
    .h-side { background:var(--hbg2); border-right:1px solid var(--hborder); padding:18px 0; position:fixed; top:0; left:0; width:240px; height:100vh; overflow-y:auto; z-index:40; display:flex; flex-direction:column; }
    .h-side::-webkit-scrollbar { width:6px; } .h-side::-webkit-scrollbar-thumb { background:var(--hborder2); border-radius:3px; }
    .h-main { grid-column:2; min-width:0; }

    .h-brand { padding:0 20px 18px; border-bottom:1px solid var(--hborder); }
    .h-brand-row { display:flex; align-items:center; gap:10px; margin-bottom:6px; }
    .h-mark { width:30px; height:30px; background:var(--haccent); border-radius:7px; display:flex; align-items:center; justify-content:center; font-family:'Fraunces',serif; font-weight:700; font-size:17px; color:var(--hbg); }
    .h-name { font-family:'Fraunces',serif; font-size:19px; font-weight:600; letter-spacing:-0.01em; color:var(--hink); }
    .h-tag { font-size:10px; color:var(--hmuted); letter-spacing:0.15em; text-transform:uppercase; font-weight:600; }

    .h-nav { padding:14px 0; flex:1; }
    .h-grp { margin-bottom:16px; }
    .h-grp-l { font-size:9.5px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:var(--hmuted2); padding:10px 20px 6px; }
    .h-item { display:flex; align-items:center; gap:11px; padding:8px 20px; color:var(--hink2); font-size:13px; font-weight:500; transition:all .12s ease; border-left:2px solid transparent; }
    .h-item:hover { background:var(--hbg3); color:var(--hink); }
    .h-item.on { background:var(--hbg3); color:var(--hink); border-left-color:var(--haccent); font-weight:600; }
    .h-item svg { flex-shrink:0; opacity:0.72; }
    .h-badge { font-size:10px; font-family:'Geist Mono',monospace; font-weight:600; background:var(--hbg4); color:var(--hink2); padding:1px 6px; border-radius:3px; flex-shrink:0; }
    .h-badge.alert { background:rgba(239,68,68,0.14); color:#EF4444; }
    .h-badge.warn { background:rgba(251,191,36,0.14); color:#FBBF24; }

    .h-back { display:flex; align-items:center; gap:9px; padding:8px 20px; margin-top:4px; color:var(--hmuted); font-size:12px; }
    .h-back:hover { color:var(--haccent2); }

    .h-user { padding:14px 18px; border-top:1px solid var(--hborder); display:flex; align-items:center; gap:10px; }
    .h-av { width:32px; height:32px; border-radius:50%; background:linear-gradient(135deg,var(--haccent),var(--haccent2)); display:flex; align-items:center; justify-content:center; font-weight:700; font-size:12px; color:var(--hbg); flex-shrink:0; }
    .h-user-n { font-size:12.5px; font-weight:600; color:var(--hink); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .h-user-r { font-size:10.5px; color:var(--hmuted); }

    .h-top { position:sticky; top:0; z-index:20; background:rgba(14,14,16,0.85); backdrop-filter:blur(8px); border-bottom:1px solid var(--hborder); padding:12px 22px; display:flex; align-items:center; gap:14px; }
    .h-burger { display:none; background:var(--hbg3); border:1px solid var(--hborder); border-radius:8px; width:34px; height:34px; align-items:center; justify-content:center; color:var(--hink); cursor:pointer; }
    .h-crumb { font-size:12.5px; color:var(--hmuted); } .h-crumb strong { color:var(--hink); font-weight:600; }
    .h-scrim { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:35; }

    @media (max-width:900px) {
      .h-app { grid-template-columns:1fr; }
      .h-side { transform:translateX(-100%); transition:transform .2s; } .h-side.open { transform:translateX(0); }
      .h-main { grid-column:1; }
      .h-burger { display:flex; } .h-scrim.open { display:block; }
    }
  </style>
</head>
<body>
  <div class="h-app">
    <aside class="h-side" id="hSide">
      <div class="h-brand">
        <div class="h-brand-row">
          <div class="h-mark">E</div>
          <div class="h-name">EduRankAI</div>
        </div>
        <div class="h-tag">Editorial Control Plane · v0.1</div>
      </div>
      <nav class="h-nav">
        {NAV.map((g) => (
          <div class="h-grp">
            <div class="h-grp-l">{g.label}</div>
            {g.items.map((it) => (
              <a href={it.href} class={'h-item' + (isActive(it) ? ' on' : '')}>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" set:html={ic(it.icon)}></svg>
                <span style="flex:1;">{it.label}</span>
                {badgeFor(it.id) && <span class={'h-badge ' + badgeFor(it.id)!.cls}>{badgeFor(it.id)!.text}</span>}
              </a>
            ))}
          </div>
        ))}
        <a href="/admin" class="h-back">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          EduRankAI admin
        </a>
      </nav>
      <div class="h-user">
        <div class="h-av">{initials}</div>
        <div style="min-width:0;">
          <div class="h-user-n">{user.name}</div>
          <div class="h-user-r">{roleLabel}</div>
        </div>
      </div>
    </aside>

    <div class="h-scrim" id="hScrim"></div>

    <main class="h-main">
      <div class="h-top">
        <button class="h-burger" id="hBurger" aria-label="Menu"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
        <div class="h-crumb">{crumb} <span style="color:var(--hborder2);margin:0 6px;">›</span> <strong>{title}</strong></div>
      </div>
      <slot />
    </main>
  </div>
  <script is:inline>
    (function(){ var s=document.getElementById('hSide'), sc=document.getElementById('hScrim'), b=document.getElementById('hBurger');
      function open(){ s.classList.add('open'); sc.classList.add('open'); } function close(){ s.classList.remove('open'); sc.classList.remove('open'); }
      if(b) b.addEventListener('click', open); if(sc) sc.addEventListener('click', close); })();
  </script>
</body>
</html>
