---
import '@/styles/global.css';
import '@/styles/admin.css';
import '@/styles/design-system.css';
// Dedicated, self-contained admin shell for the HEI · Truth Report control
// plane — its own sidebar, branding and full-control navigation, separate from
// the main EduRankAI admin (mirrors how AquinTutor has its own layout). Every
// /admin/hei/* page renders inside this so the section is one cohesive product.
interface Props { title?: string; active?: string; }
const { title = 'HEI Control Plane', active = '' } = Astro.props;

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login?next=' + encodeURIComponent(Astro.url.pathname));
if (user.role === 'applicant') return Astro.redirect('/portal');

type NavItem = { id: string; label: string; href: string; icon: string };
type NavGroup = { label: string; items: NavItem[] };
const NAV: NavGroup[] = [
  { label: 'Editorial', items: [
    { id: 'dashboard', label: 'Dashboard', href: '/admin/hei', icon: 'home' },
    { id: 'leads', label: 'Lead queue', href: '/admin/hei/leads', icon: 'inbox' },
    { id: 'findings', label: 'Draft findings', href: '/admin/hei/findings', icon: 'shield' },
    { id: 'replies', label: 'Right-of-reply', href: '/admin/hei/replies', icon: 'chat' },
  ]},
  { label: 'Rankings', items: [
    { id: 'institutions', label: 'Institutions', href: '/admin/hei/institutions', icon: 'grid' },
    { id: 'entity-types', label: 'Entity types', href: '/admin/hei/entity-types', icon: 'tag' },
    { id: 'submetrics', label: 'Sub-metrics', href: '/admin/hei/submetrics', icon: 'cog' },
    { id: 'methodology', label: 'v1 Methodology', href: '/admin/hei/v1-methodology', icon: 'book' },
  ]},
  { label: 'Data layer', items: [
    { id: 'crawlers', label: 'Crawlers / ingestion', href: '/admin/hei/crawlers', icon: 'radio' },
    { id: 'surveys', label: 'Survey responses', href: '/admin/hei/surveys', icon: 'doc' },
    { id: 'rti', label: 'RTI tracker', href: '/admin/hei/rti', icon: 'doc' },
    { id: 'import', label: 'CSV import', href: '/admin/hei/import', icon: 'upload' },
  ]},
  { label: 'Trust & public', items: [
    { id: 'stories', label: 'Stories', href: '/admin/hei/stories', icon: 'doc' },
    { id: 'claims', label: 'Institution claims', href: '/admin/hei/claims', icon: 'shield' },
    { id: 'submissions', label: 'Submission queue', href: '/admin/hei/submissions', icon: 'inbox' },
  ]},
  { label: 'Operations', items: [
    { id: 'legal', label: 'Legal queue', href: '/admin/hei/legal', icon: 'shield' },
    { id: 'audit', label: 'Audit log', href: '/admin/audit', icon: 'activity' },
  ]},
];

const ICON: Record<string, string> = {
  home: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  inbox: '<polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  chat: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
  grid: '<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>',
  tag: '<path d="M20.59 13.41 13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/>',
  cog: '<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>',
  book: '<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>',
  radio: '<circle cx="12" cy="12" r="2"/><path d="M16.24 7.76a6 6 0 0 1 0 8.49m-8.48-.01a6 6 0 0 1 0-8.49m11.31-2.82a10 10 0 0 1 0 14.14m-14.14 0a10 10 0 0 1 0-14.14"/>',
  doc: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>',
  upload: '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>',
  activity: '<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>',
};
function ic(k: string) { return ICON[k] || ICON.doc; }
const initials = (user.name || 'A').substring(0, 2).toUpperCase();

// Active item: explicit `active` prop wins; otherwise derive from the URL so
// pages don't need to declare it. Dashboard matches its exact path only.
const path = (Astro.url.pathname.replace(/\/+$/, '') || '/');
function isActive(it: NavItem): boolean {
  if (active) return it.id === active;
  if (it.href === '/admin/hei') return path === '/admin/hei';
  return path === it.href || path.startsWith(it.href + '/');
}
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex" />
  <title>{title} · HEI · EduRankAI</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    :root { --hbg:#08080a; --hpanel:#0f0f14; --hpanel2:#0b0d13; --hstroke:#1a1a1f; --htext:#d8d8de; --hmuted:#8a8a94; --hdim:#6e6e78; --haccent:#FF4F00; --haccent2:#FF7040; }
    * { box-sizing: border-box; }
    body { margin:0; background:var(--hbg); color:var(--htext); font-family:'Inter Tight',system-ui,-apple-system,sans-serif; -webkit-font-smoothing:antialiased; }
    a { color:inherit; }
    .h-shell { display:grid; grid-template-columns:238px minmax(0,1fr); min-height:100vh; }
    .h-side { background:var(--hpanel); border-right:1px solid var(--hstroke); position:fixed; top:0; left:0; width:238px; height:100vh; overflow-y:auto; z-index:40; display:flex; flex-direction:column; }
    .h-main { grid-column:2; min-width:0; }
    .h-brand { padding:15px 16px; border-bottom:1px solid var(--hstroke); display:flex; align-items:center; gap:10px; }
    .h-logo { width:30px; height:30px; border-radius:8px; background:linear-gradient(135deg,#FF4F00,#FF7040); display:flex; align-items:center; justify-content:center; font-weight:800; color:#fff; font-size:15px; flex-shrink:0; }
    .h-brand-t { font-size:13.5px; font-weight:700; color:#fff; line-height:1.1; }
    .h-brand-s { font-size:9.5px; color:var(--hdim); font-family:'Geist Mono',monospace; letter-spacing:0.06em; margin-top:2px; }
    .h-nav { padding:8px 0 12px; flex:1; }
    .h-grp { padding:10px 0 2px; }
    .h-grp-l { font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:0.13em; color:var(--hdim); padding:0 16px 5px; }
    .h-item { display:flex; align-items:center; gap:10px; padding:7px 16px; font-size:12.5px; color:var(--hmuted); text-decoration:none; border-left:2px solid transparent; transition:background .1s,color .1s; }
    .h-item:hover { background:#15151a; color:#fff; }
    .h-item.on { background:#15151a; color:var(--haccent2); border-left-color:var(--haccent); font-weight:600; }
    .h-item svg { flex-shrink:0; opacity:0.85; }
    .h-user { border-top:1px solid var(--hstroke); padding:11px 14px; display:flex; align-items:center; gap:9px; }
    .h-av { width:28px; height:28px; border-radius:50%; background:var(--haccent); display:flex; align-items:center; justify-content:center; font-size:11px; font-weight:700; color:#fff; flex-shrink:0; }
    .h-back { display:block; padding:9px 16px; font-size:11px; color:var(--hdim); text-decoration:none; border-top:1px solid var(--hstroke); font-family:'Geist Mono',monospace; }
    .h-back:hover { color:var(--haccent2); }
    .h-top { position:sticky; top:0; z-index:20; background:rgba(8,8,10,0.85); backdrop-filter:blur(8px); border-bottom:1px solid var(--hstroke); padding:11px 20px; display:flex; align-items:center; gap:12px; }
    .h-burger { display:none; background:var(--hpanel); border:1px solid var(--hstroke); border-radius:8px; width:34px; height:34px; align-items:center; justify-content:center; color:var(--htext); cursor:pointer; }
    .h-top-t { font-size:14px; font-weight:700; color:#fff; }
    .h-scrim { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:35; }
    @media (max-width:900px) {
      .h-shell { grid-template-columns:1fr; }
      .h-side { transform:translateX(-100%); transition:transform .2s; } .h-side.open { transform:translateX(0); }
      .h-main { grid-column:1; }
      .h-burger { display:flex; } .h-scrim.open { display:block; }
    }
  </style>
</head>
<body>
  <div class="h-shell">
    <aside class="h-side" id="hSide">
      <div class="h-brand">
        <div class="h-logo">H</div>
        <div><div class="h-brand-t">HEI · Truth Report</div><div class="h-brand-s">Editorial Control Plane</div></div>
      </div>
      <nav class="h-nav">
        {NAV.map((g) => (
          <div class="h-grp">
            <div class="h-grp-l">{g.label}</div>
            {g.items.map((it) => (
              <a href={it.href} class={'h-item' + (isActive(it) ? ' on' : '')}>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ic(it.icon)}></svg>
                {it.label}
              </a>
            ))}
          </div>
        ))}
      </nav>
      <a href="/admin" class="h-back">← EduRankAI admin</a>
      <div class="h-user">
        <div class="h-av">{initials}</div>
        <div style="min-width:0;"><div style="font-size:11.5px;font-weight:600;color:#fff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{user.name}</div><div style="font-size:9px;color:var(--hdim);">{user.role?.replace('_',' ')}</div></div>
      </div>
    </aside>

    <div class="h-scrim" id="hScrim"></div>

    <main class="h-main">
      <div class="h-top">
        <button class="h-burger" id="hBurger" aria-label="Menu"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
        <div class="h-top-t">{title}</div>
      </div>
      <slot />
    </main>
  </div>
  <script is:inline>
    (function(){ var s=document.getElementById('hSide'), sc=document.getElementById('hScrim'), b=document.getElementById('hBurger');
      function open(){ s.classList.add('open'); sc.classList.add('open'); } function close(){ s.classList.remove('open'); sc.classList.remove('open'); }
      if(b) b.addEventListener('click', open); if(sc) sc.addEventListener('click', close); })();
  </script>
</body>
</html>
