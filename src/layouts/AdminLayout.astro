---
import '@/styles/global.css';
import '@/styles/admin.css';
import { SITE } from '@/lib/site';

interface Props {
  title?: string;
  activeNav?: string;
}

const { title, activeNav = '' } = Astro.props;
const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/admin/login');
}

type NavItem = { id: string; label: string; href: string; icon: string; badge?: number };
type NavGroup = { groupId: string; label: string; icon: string; children: NavItem[] };

const navStructure: (NavItem | NavGroup)[] = [
  { id: 'dashboard', label: 'Dashboard', href: '/admin', icon: 'home' },
  { id: 'applications', label: 'Applications', href: '/admin/applications', icon: 'inbox' },
  { id: 'messages', label: 'Team Messages', href: '/admin/messages', icon: 'chat' },
  { id: 'chat', label: 'Team Chat', href: '/admin/chat', icon: 'message-circle' },
  { id: 'offers', label: 'Offer Letters', href: '/admin/offers', icon: 'document' },
  { id: 'hr', label: 'HR Management', href: '/admin/hr', icon: 'users' },
  { id: 'custom-offer', label: 'Custom Offer', href: '/admin/offer/blank', icon: 'file-text' },
  {
    groupId: 'hei',
    label: 'HEI · Truth Report',
    icon: 'book',
    children: [
      { id: 'hei', label: 'Institutions', href: '/admin/hei/institutions', icon: 'grid' },
      { id: 'hei-types', label: 'Entity Types', href: '/admin/hei/entity-types', icon: 'tag' },
      { id: 'hei-import', label: 'CSV Import', href: '/admin/hei/import', icon: 'upload' },
      { id: 'hei-sub', label: 'Sub-metrics (v0.4)', href: '/admin/hei/submetrics', icon: 'cog' },
      { id: 'hei-v1', label: 'v1.0 Methodology', href: '/admin/hei/v1-methodology', icon: 'book' },
      { id: 'hei-stories', label: 'Stories', href: '/admin/hei/stories', icon: 'document' },
      { id: 'hei-claims', label: 'Institution Claims', href: '/admin/hei/claims', icon: 'shield' },
      { id: 'hei-submissions', label: 'Submission Queue', href: '/admin/hei/submissions', icon: 'inbox' },
      { id: 'hei-findings', label: 'Findings', href: '/admin/hei/findings', icon: 'shield' }
    ]
  },
  { id: 'roles', label: 'Roles', href: '/admin/roles', icon: 'briefcase' },
  { id: 'team-roles', label: 'Custom Roles', href: '/admin/team/roles', icon: 'shield' },
  { id: 'departments', label: 'Departments', href: '/admin/departments', icon: 'grid' },
  { id: 'events', label: 'Events', href: '/admin/events', icon: 'calendar' },
  { id: 'products', label: 'Products', href: '/admin/products', icon: 'package' },
  { id: 'content', label: 'Content Pages', href: '/admin/content', icon: 'document' },
  { id: 'users', label: 'Users', href: '/admin/users', icon: 'users' },
  { id: 'audit', label: 'Audit Log', href: '/admin/audit', icon: 'shield' },
  { id: 'settings', label: 'Settings', href: '/admin/settings', icon: 'cog' }
];

function isGroup(item: NavItem | NavGroup): item is NavGroup {
  return (item as NavGroup).groupId !== undefined;
}
function isGroupActive(group: NavGroup, activeId: string): boolean {
  return group.children.some(c => c.id === activeId);
}

const userInitial = user.name && user.name.length > 0 ? user.name.substring(0, 1).toUpperCase() : 'U';
const userRoleLabel = user.role.split('_').join(' ');
const pageTitle = title ? title + ' - Admin - ' + SITE.name : 'Admin - ' + SITE.name;
---
<!doctype html>
<html lang="en" class="admin-html">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="robots" content="noindex,nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/admin-manifest.json" />
    <meta name="theme-color" content="#FF4F00" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="ERA Admin" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
  </head>
  <body class="admin-body">
    <!-- Mobile top bar (hidden on desktop) -->
    <div class="admin-mobile-bar">
      <button class="admin-mobile-toggle" id="adminMobileToggle" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
      <span class="admin-mobile-brand">EduRank<em style="font-style:normal;color:#FF4F00;">AI</em> <span style="opacity:0.55;font-weight:400;font-size:11px;margin-left:6px;">Admin</span></span>
    </div>
    <div class="admin-shell">
      <aside class="admin-sidebar">
        <div class="admin-brand">
          <a href="/admin" class="admin-logo">
            <span class="admin-logo-mark">E</span>
            <div>
              <div class="admin-logo-name">EduRankAI</div>
              <div class="admin-logo-sub">Admin Panel</div>
            </div>
          </a>
        </div>

        <nav class="admin-nav">
          {navStructure.map((entry) => {
            if (isGroup(entry)) {
              const opened = isGroupActive(entry, activeNav);
              return (
                <details open={opened} class={'admin-nav-group ' + (opened ? 'active-group' : '')} style="margin:2px 0;">
                  <summary class="admin-nav-item" style="display:flex;align-items:center;justify-content:space-between;gap:8px;cursor:pointer;list-style:none;">
                    <span style="display:flex;align-items:center;gap:10px;flex:1;min-width:0;">
                      <span class="admin-nav-icon" data-icon={entry.icon}></span>
                      <span style="font-weight:600;">{entry.label}</span>
                    </span>
                    <span style="font-size:9px;color:#6e6e78;">▾</span>
                  </summary>
                  <div style="display:flex;flex-direction:column;gap:1px;padding:3px 0 5px 20px;border-left:1px solid #1f1f26;margin-left:14px;margin-top:2px;">
                    {entry.children.map((child) => {
                      const childActive = activeNav === child.id;
                      const cls = childActive ? 'admin-nav-item active' : 'admin-nav-item';
                      return (
                        <a href={child.href} class={cls} style="display:flex;align-items:center;gap:9px;padding-left:8px;font-size:12px;">
                          <span class="admin-nav-icon" data-icon={child.icon} style="opacity:0.7;"></span>
                          <span>{child.label}</span>
                        </a>
                      );
                    })}
                  </div>
                </details>
              );
            }
            const item = entry;
            const isActive = activeNav === item.id;
            const cls = isActive ? 'admin-nav-item active' : 'admin-nav-item';
            return (
              <a href={item.href} class={cls} style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
                <span style="display:flex;align-items:center;gap:10px;flex:1;min-width:0;">
                  <span class="admin-nav-icon" data-icon={item.icon}></span>
                  <span>{item.label}</span>
                </span>
                {(item.badge ?? 0) > 0 && (
                  <span style="background:#FF4F00;color:#fff;font-size:9.5px;font-weight:700;padding:1px 6px;border-radius:100px;min-width:18px;text-align:center;line-height:1.5;font-family:'Geist Mono',monospace;">{item.badge}</span>
                )}
              </a>
            );
          })}
        </nav>

        <div class="admin-user">
          <div class="admin-user-avatar">{userInitial}</div>
          <div class="admin-user-info">
            <div class="admin-user-name">{user.name}</div>
            <div class="admin-user-role">{userRoleLabel}</div>
          </div>
          <form method="POST" action="/admin/logout" style="margin:0">
            <button type="submit" class="admin-user-logout" title="Sign out">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            </button>
          </form>
        </div>
      </aside>

      <main class="admin-main">
        <slot />
      </main>
    </div>
  
    <!-- Floating chat button -->
    <a href="/admin/chat" class="admin-chat-fab" aria-label="Team chat">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    </a>

    <!-- Sidebar scrim (mobile only) -->
    <div class="admin-sidebar-scrim" id="adminSidebarScrim"></div>

    <script is:inline>
(function() {
  // Force-show mobile bar at narrow widths (regardless of CSS)
  function applyMobileLayout() {
    var bar = document.querySelector('.admin-mobile-bar');
    var sidebar = document.querySelector('.admin-sidebar');
    var isMobile = window.innerWidth < 1024;
    if (bar) bar.style.display = isMobile ? 'flex' : 'none';
    if (sidebar) {
      if (isMobile) {
        sidebar.style.position = 'fixed';
        sidebar.style.top = '0';
        sidebar.style.left = '0';
        sidebar.style.bottom = '0';
        sidebar.style.height = '100vh';
        sidebar.style.width = '270px';
        sidebar.style.zIndex = '85';
        sidebar.style.transition = 'transform 0.22s ease';
        if (!sidebar.classList.contains('open')) {
          sidebar.style.transform = 'translateX(-100%)';
        }
      } else {
        sidebar.style.position = '';
        sidebar.style.transform = '';
        sidebar.style.width = '';
      }
    }
  }
  function initAdminMobile() {
    applyMobileLayout();
    var toggle = document.getElementById('adminMobileToggle');
    var scrim = document.getElementById('adminSidebarScrim');
    var sidebar = document.querySelector('.admin-sidebar');
    if (!toggle || !sidebar || !scrim) return;
    function closeMenu() {
      sidebar.classList.remove('open');
      sidebar.style.transform = 'translateX(-100%)';
      scrim.classList.remove('show');
      scrim.style.opacity = '0';
      scrim.style.pointerEvents = 'none';
      document.body.style.overflow = '';
    }
    function openMenu() {
      sidebar.classList.add('open');
      sidebar.style.transform = 'translateX(0)';
      sidebar.style.background = '#0a0a0c';
      sidebar.style.color = '#fff';
      sidebar.style.padding = '20px 0';
      sidebar.style.borderRight = '1px solid #1f1f26';
      sidebar.style.display = 'block';
      sidebar.style.visibility = 'visible';
      sidebar.style.opacity = '1';
      sidebar.style.boxShadow = '4px 0 22px rgba(0,0,0,0.55)';
      scrim.classList.add('show');
      scrim.style.position = 'fixed';
      scrim.style.inset = '0';
      scrim.style.background = 'rgba(0,0,0,0.55)';
      scrim.style.zIndex = '80';
      scrim.style.opacity = '1';
      scrim.style.pointerEvents = 'auto';
      document.body.style.overflow = 'hidden';
    }
    toggle.onclick = function(e) {
      e.preventDefault();
      e.stopPropagation();
      if (sidebar.classList.contains('open')) closeMenu(); else openMenu();
    };
    scrim.onclick = closeMenu;
    var links = sidebar.querySelectorAll('a[href]');
    for (var i = 0; i < links.length; i++) {
      links[i].addEventListener('click', function() {
        if (window.innerWidth < 1024) closeMenu();
      });
    }
    window.addEventListener('resize', applyMobileLayout);
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAdminMobile);
  } else {
    initAdminMobile();
  }
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.getRegistrations().then(function(regs) {
      for (var i = 0; i < regs.length; i++) regs[i].unregister();
    }).catch(function(){});
  }
})();
</script>
  
<!-- BULLETPROOF MENU BUTTON (mobile only, always visible) -->


<script is:inline>
(function() {
  function setupBulletproofMenu() {
    var btn = document.getElementById('adminMobileToggle') || document.getElementById('bulletproofMenuBtn');
    var sidebar = document.querySelector('.admin-sidebar');
    var scrim = document.getElementById('adminSidebarScrim');
    if (!btn || !sidebar) return;

    function isMobile() { return window.innerWidth < 1024; }

    function showOrHideBtn() {
      btn.style.display = isMobile() ? 'block' : 'none';
    }


    function openSidebar() {
      sidebar.classList.add('open');
      sidebar.style.position = 'fixed';
      sidebar.style.top = '0';
      sidebar.style.left = '0';
      sidebar.style.bottom = '0';
      sidebar.style.height = '100vh';
      sidebar.style.width = '270px';
      sidebar.style.zIndex = '10000';
      // Move sidebar to body root to escape any parent overflow:hidden
      if (sidebar.parentElement !== document.body) {
        document.body.appendChild(sidebar);
      }
      sidebar.style.transform = 'translateX(0)';
      sidebar.style.background = '#0a0a0c';
      sidebar.style.color = '#fff';
      sidebar.style.padding = '20px 0';
      sidebar.style.borderRight = '1px solid #1f1f26';
      sidebar.style.display = 'block';
      sidebar.style.visibility = 'visible';
      sidebar.style.opacity = '1';
      sidebar.style.transition = 'transform 0.22s ease';
      sidebar.style.boxShadow = '4px 0 22px rgba(0,0,0,0.55)';
      sidebar.style.overflowY = 'auto';
      document.body.style.overflow = 'hidden';
      if (scrim) {
        scrim.style.position = 'fixed';
        scrim.style.inset = '0';
        scrim.style.background = 'rgba(0,0,0,0.55)';
        scrim.style.zIndex = '9998';
        scrim.style.opacity = '1';
        scrim.style.pointerEvents = 'auto';
      }
    }

    function closeSidebar() {
      sidebar.classList.remove('open');
      sidebar.style.transform = 'translateX(-100%)';
      document.body.style.overflow = '';
      if (scrim) {
        scrim.style.opacity = '0';
        scrim.style.pointerEvents = 'none';
      }
    }

    btn.onclick = function(e) {
      e.preventDefault();
      e.stopPropagation();
      if (sidebar.classList.contains('open')) {
        closeSidebar();
      } else {
        openSidebar();
      }
    };

    if (scrim) {
      scrim.onclick = closeSidebar;
    }

    // On mobile: when a link is tapped, navigate explicitly. The reparented sidebar
    // can sometimes confuse the browser into thinking the click was on a detached element.
    var links = sidebar.querySelectorAll('a[href]');
    for (var i = 0; i < links.length; i++) {
      var lnk = links[i];
      // Make sure the link is still clickable
      lnk.style.pointerEvents = 'auto';
      lnk.style.position = 'relative';
      lnk.style.zIndex = '10001';
      lnk.addEventListener('click', function(e) {
        if (!isMobile()) return;
        var href = this.getAttribute('href');
        if (!href || href.charAt(0) === '#') return;
        e.preventDefault();
        e.stopPropagation();
        closeSidebar();
        // Navigate after a tiny delay so close animation doesn't fight navigation
        setTimeout(function() {
          window.location.href = href;
        }, 50);
      }, { capture: true });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupBulletproofMenu);
  } else {
    setupBulletproofMenu();
  }
})();
</script>
</body>
</html>
