        <div id="eraBellDropdown" style="position:fixed;top:54px;right:24px;width:min(380px,calc(100vw - 40px));max-height:60vh;overflow-y:auto;background:var(--o-bg2,#11151c);border:1px solid var(--o-stroke,#1a1a1f);border-radius:14px;box-shadow:0 24px 60px rgba(0,0,0,0.45);padding:8px;display:none;z-index:60;">
          <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 10px 10px;border-bottom:1px solid var(--o-stroke,#1a1a1f);margin-bottom:6px;">
            <span style="font-size:13px;font-weight:700;color:var(--o-hi,#fff);">Notifications</span>
            <div style="display:flex;gap:6px;">
              <button type="button" id="eraBellTest" style="background:none;border:1px solid var(--o-stroke,#1a1a1f);color:#9aa6b6;font-size:10.5px;padding:4px 9px;border-radius:6px;cursor:pointer;">Test</button>
              <button type="button" id="eraBellMarkAll" style="background:none;border:none;color:#FF7040;font-size:10.5px;padding:4px 8px;cursor:pointer;">Mark all read</button>
            </div>
          </div>
          <div id="eraBellList"></div>
          <a href="/admin/notifications" style="display:block;text-align:center;font-size:11.5px;color:#FF7040;text-decoration:none;padding:10px;border-top:1px solid var(--o-stroke,#1a1a1f);margin-top:6px;">Open full inbox →</a>
        </div>
        <script is:inline>
          (function () {
            var btn = document.getElementById('eraBellBtn');
            var box = document.getElementById('eraBellDropdown');
            var list = document.getElementById('eraBellList');
            var badge = document.getElementById('eraBellCount');
            if (!btn || !box) return;
            function fmt(d) { var dt = new Date(d); var diff = Date.now() - dt.getTime(); var m = Math.floor(diff/60000); if (m < 1) return 'now'; if (m < 60) return m + 'm'; var h = Math.floor(m/60); if (h < 24) return h + 'h'; return Math.floor(h/24) + 'd'; }
            // Track which notification ids we've already seen so we only toast NEW ones.
            var seenIds = null;
            // Slide-in toast: stacks bottom-right with auto-dismiss.
            function ensureToastContainer() {
              var c = document.getElementById('eraToastStack');
              if (c) return c;
              c = document.createElement('div');
              c.id = 'eraToastStack';
              c.style.cssText = 'position:fixed;bottom:18px;right:18px;display:flex;flex-direction:column;gap:10px;z-index:1000;pointer-events:none;max-width:min(380px,calc(100vw - 32px));';
              document.body.appendChild(c);
              return c;
            }
            function popToast(n) {
              var c = ensureToastContainer();
              var t = document.createElement('a');
              t.href = n.action_url || '/admin/notifications';
              t.style.cssText = 'pointer-events:auto;background:#11151c;border:1px solid #2a3038;border-left:4px solid #FF4F00;border-radius:12px;padding:13px 16px;color:#f4f1ea;text-decoration:none;box-shadow:0 14px 40px rgba(0,0,0,0.45);transform:translateX(120%);opacity:0;transition:transform .35s cubic-bezier(.16,1,.3,1),opacity .35s;font-family:Inter Tight,system-ui,sans-serif;';
              t.innerHTML = '<p style="font-size:13px;font-weight:700;margin:0;line-height:1.3;">' + (n.title || '') + '</p>' + (n.body ? '<p style="font-size:11.5px;color:#9aa6b6;margin:4px 0 0;line-height:1.5;">' + n.body + '</p>' : '');
              c.appendChild(t);
              // small animation
              requestAnimationFrame(function () { t.style.transform = 'translateX(0)'; t.style.opacity = '1'; });
              setTimeout(function () { t.style.transform = 'translateX(120%)'; t.style.opacity = '0'; setTimeout(function () { try { t.remove(); } catch (_) {} }, 400); }, 6500);
            }
            function load() {
              fetch('/api/admin/notifications-recent', { credentials: 'same-origin' })
                .then(function (r) { return r.json(); })
                .then(function (d) {
                  if (!d.ok) return;
                  if (d.unread > 0) { badge.textContent = d.unread > 99 ? '99+' : d.unread; badge.style.display = 'inline-flex'; }
                  else { badge.style.display = 'none'; }
                  // Toast newly arrived unread items (skip on the very first call)
                  if (Array.isArray(d.items)) {
                    if (seenIds === null) {
                      seenIds = new Set(d.items.map(function (n) { return n.id; }));
                    } else {
                      d.items.forEach(function (n) {
                        if (!n.is_read && !seenIds.has(n.id)) {
                          popToast(n);
                          seenIds.add(n.id);
                        }
                      });
                    }
                  }
                  if (!d.items || !d.items.length) {
                    list.innerHTML = '<p style="color:#6e6e78;font-size:12.5px;padding:24px 12px;text-align:center;">No notifications yet. Click <b>Test</b> to verify the pipeline.</p>';
                    return;
                  }
                  list.innerHTML = d.items.map(function (n) {
                    var dot = n.is_read ? 'transparent' : '#FF4F00';
                    var href = n.action_url || '/admin/notifications';
                    return '<a href="' + href + '" data-nid="' + n.id + '" class="era-bell-item" style="display:flex;gap:10px;padding:10px 12px;text-decoration:none;color:inherit;border-radius:9px;align-items:flex-start;">'
                      + '<span style="width:7px;height:7px;border-radius:50%;background:' + dot + ';margin-top:7px;flex-shrink:0;"></span>'
                      + '<div style="flex:1;min-width:0;">'
                      + '<p style="font-size:13px;font-weight:600;color:var(--o-hi,#fff);margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + (n.title || '') + '</p>'
                      + (n.body ? '<p style="font-size:11.5px;color:#9aa6b6;margin:2px 0 0;line-height:1.5;">' + n.body + '</p>' : '')
                      + '</div>'
                      + '<span style="font-size:10.5px;color:#6e6e78;flex-shrink:0;font-family:Geist Mono,monospace;margin-top:1px;">' + fmt(n.created_at) + '</span>'
                      + '</a>';
                  }).join('');
                  list.querySelectorAll('.era-bell-item').forEach(function (a) {
                    a.addEventListener('click', function () {
                      fetch('/api/admin/notifications-recent', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'mark_read', id: a.getAttribute('data-nid') }) });
                    });
                  });
                });
            }
            btn.addEventListener('click', function (e) { e.stopPropagation(); box.style.display = box.style.display === 'block' ? 'none' : 'block'; if (box.style.display === 'block') load(); });
            document.addEventListener('click', function (e) { if (e.target !== btn && !box.contains(e.target)) box.style.display = 'none'; });
            document.getElementById('eraBellMarkAll').addEventListener('click', function () {
              fetch('/api/admin/notifications-recent', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'mark_all_read' }) })
                .then(function () { load(); });
            });
            document.getElementById('eraBellTest').addEventListener('click', function () {
              fetch('/api/admin/notifications-recent', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'test' }) })
                .then(function () { load(); });
            });
            load();
            // Browser push is the instant channel (free, no function/DB cost).
            // This poll is only a reconciling fallback, so it runs slowly (was
            // 15s) to cut Vercel invocations + Neon wake-ups. Pauses when the
            // tab is hidden and re-polls immediately on focus so the bell is
            // still fresh the moment an admin looks at it.
            setInterval(function () { if (!document.hidden) load(); }, 300000);
            document.addEventListener('visibilitychange', function () { if (!document.hidden) load(); });
            window.addEventListener('focus', function () { load(); });
          })();
        </script>
        <div id="eraSearchResults" style="position:fixed;top:54px;left:50%;transform:translateX(-50%);width:min(680px,calc(100vw - 40px));max-height:60vh;overflow-y:auto;background:var(--o-bg2,#11151c);border:1px solid var(--o-stroke,#1a1a1f);border-radius:14px;box-shadow:0 24px 60px rgba(0,0,0,0.45);padding:8px;display:none;z-index:60;"></div>
        <script is:inline>
          (function () {
            var input = document.getElementById('eraSearch');
            var box = document.getElementById('eraSearchResults');
            if (!input || !box) return;
            var timer = null;
            function run() {
              var q = input.value.trim();
              if (q.length < 2) { box.style.display = 'none'; box.innerHTML = ''; return; }
              fetch('/api/admin/search?q=' + encodeURIComponent(q), { credentials: 'same-origin' })
                .then(function (r) { return r.json(); })
                .then(function (d) {
                  if (!d.ok || !d.results || !d.results.length) { box.innerHTML = '<p style="color:#6e6e78;font-size:12.5px;padding:14px;text-align:center;">No matches for "' + q + '"</p>'; box.style.display = 'block'; return; }
                  var KIND_COLOR = {
                    application: '#FF7040', intent: '#fdba74', employee: '#6ee7b7', user: '#60a5fa',
                    role: '#a78bfa', department: '#c084fc',
                    test: '#fbbf24', bootcamp: '#fb7185', course: '#34d399',
                    event: '#f472b6', form: '#94a3b8',
                    ai_template: '#22d3ee', ai_session: '#22d3ee', interview: '#22d3ee',
                    payment: '#facc15', visvambhara: '#ef4444',
                  };
                  var KIND_LABEL = {
                    ai_template: 'AI tpl', ai_session: 'AI sess', visvambhara: 'visv',
                  };
                  var groups = {};
                  d.results.forEach(function (r) { (groups[r.kind] = groups[r.kind] || []).push(r); });
                  var order = ['application','intent','user','employee','role','department','bootcamp','test','course','event','ai_template','ai_session','interview','form','payment','visvambhara'];
                  var html = '';
                  order.forEach(function (k) {
                    var items = groups[k];
                    if (!items || !items.length) return;
                    html += items.map(function (r) {
                      var color = KIND_COLOR[r.kind] || '#9aa6b6';
                      var label = KIND_LABEL[r.kind] || r.kind;
                      return '<a href="' + r.url + '" style="display:flex;gap:10px;padding:9px 12px;text-decoration:none;color:inherit;border-radius:8px;">'
                        + '<span style="font-family:Geist Mono,monospace;font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:' + color + ';width:84px;flex-shrink:0;padding-top:2px;">' + label + '</span>'
                        + '<div style="min-width:0;flex:1;"><p style="font-size:13.5px;font-weight:600;color:var(--o-hi,#fff);margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + (r.title || '') + '</p>'
                        + '<p style="font-size:11.5px;color:#8a8a94;margin:1px 0 0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + (r.subtitle || '') + '</p></div></a>';
                    }).join('');
                  });
                  box.innerHTML = html;
                  box.style.display = 'block';
                })
                .catch(function () { box.style.display = 'none'; });
            }
            input.addEventListener('input', function () { clearTimeout(timer); timer = setTimeout(run, 180); });
            input.addEventListener('focus', function () { if (input.value.trim().length >= 2) box.style.display = 'block'; });
            document.addEventListener('click', function (e) { if (e.target !== input && !box.contains(e.target)) box.style.display = 'none'; });
            document.addEventListener('keydown', function (e) {
              if (e.key === '/' && document.activeElement !== input && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') { e.preventDefault(); input.focus(); }
              if (e.key === 'Escape') { box.style.display = 'none'; input.blur(); }
            });
          })();
        </script>
        <slot />
      </main>
    </div>
  
