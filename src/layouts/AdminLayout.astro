  <script is:inline>
    (function(){
      var root=document.documentElement, box=document.getElementById('adminThemeSwitch');
      if(!box) return;
      function applyAccent(stored){
        var auto=root.getAttribute('data-auto-accent')||'default';
        var eff=(!stored||stored==='auto')?auto:stored;
        if(eff&&eff!=='default') root.setAttribute('data-accent',eff); else root.removeAttribute('data-accent');
      }
      function sync(){
        var t=root.getAttribute('data-theme')||'dark';
        var stored=localStorage.getItem('era-accent')||'auto';
        box.querySelectorAll('[data-theme-set]').forEach(function(b){ b.classList.toggle('on', b.getAttribute('data-theme-set')===t); });
        box.querySelectorAll('[data-accent-set]').forEach(function(b){ b.classList.toggle('on', b.getAttribute('data-accent-set')===stored); });
      }
      box.querySelectorAll('[data-theme-set]').forEach(function(b){ b.addEventListener('click', function(){ var v=b.getAttribute('data-theme-set'); root.setAttribute('data-theme',v); try{localStorage.setItem('era-theme',v);}catch(e){} sync(); }); });
      box.querySelectorAll('[data-accent-set]').forEach(function(b){ b.addEventListener('click', function(){ var v=b.getAttribute('data-accent-set'); try{localStorage.setItem('era-accent',v);}catch(e){} applyAccent(v); sync(); }); });
      sync();
    })();
  </script>

