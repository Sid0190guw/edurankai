---
import '@/styles/global.css';
import '@/styles/admin.css';
import '@/styles/design-system.css';
import { SITE } from '@/lib/site';
import { db } from '@/lib/db';
import { sql } from 'drizzle-orm';
import { getViewableSectionKeys } from '@/lib/auth/permissions';

interface Props {
  title?: string;
  activeNav?: string;
}

const { title, activeNav = '' } = Astro.props;
const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/admin/login');
}

// Auto accent from the signed-in person's gender (amber=male, rose=female).
// Used as the default when the user hasn't manually picked an accent.
let autoAccent = 'default';
try {
  const gr = await db.execute(sql`SELECT gender FROM hr_employees WHERE user_id = ${user.id} OR personal_email = ${user.email} OR email = ${user.email} LIMIT 1`);
  const g = ((Array.isArray(gr) ? gr : (gr?.rows || []))[0] as any)?.gender;
  if (g) { const gl = String(g).toLowerCase(); if (gl.startsWith('m')) autoAccent = 'amber'; else if (gl.startsWith('f')) autoAccent = 'rose'; }
} catch (_) {}

type NavItem = { id: string; label: string; href: string; icon: string; badge?: number };
type NavGroup = { groupId: string; label: string; icon: string; children: NavItem[] };

const navStructure: (NavItem | NavGroup)[] = [
  { id: 'dashboard', label: 'Dashboard', href: '/admin', icon: 'home' },
  { id: 'applications', label: 'Applications', href: '/admin/applications', icon: 'inbox' },
  { id: 'starters', label: 'Everyone who started', href: '/admin/applications/intents', icon: 'inbox' },
  { id: 'help', label: 'Help Inbox', href: '/admin/help', icon: 'chat' },
  { id: 'messages', label: 'DMs', href: '/admin/messages', icon: 'chat' },
  { id: 'chat', label: 'Discussion', href: '/admin/chat', icon: 'message-circle' },
  { id: 'offers', label: 'Offer Letters', href: '/admin/offers', icon: 'document' },
  {
    groupId: 'mail-group',
    label: 'Mail',
    icon: 'inbox',
    children: [
      { id: 'mail',           label: 'Inbox',             href: '/admin/mail',           icon: 'inbox' },
      { id: 'mail-rules',     label: 'Signature & rules', href: '/admin/mail/rules',     icon: 'document' },
      { id: 'mail-templates', label: 'Templates',         href: '/admin/mail/templates', icon: 'document' },
      { id: 'mail-analytics', label: 'Analytics',         href: '/admin/mail/analytics', icon: 'document' },
      { id: 'mail-groups',    label: 'Groups',            href: '/admin/mail/groups',    icon: 'users' },
      { id: 'mail-setup',     label: 'Setup wizard',      href: '/admin/mail/setup',     icon: 'shield' },
      { id: 'mail-health',    label: 'Health',            href: '/admin/mail/health',    icon: 'shield' },
    ]
  },
  { id: 'threads', label: 'All Threads', href: '/admin/threads', icon: 'chat' },
  { id: 'infra', label: 'Infrastructure', href: '/admin/infra', icon: 'shield' },
  {
    groupId: 'study-abroad-group',
    label: 'Study Abroad',
    icon: 'package',
    children: [
      { id: 'study-abroad', label: 'Request queue', href: '/admin/study-abroad', icon: 'inbox' },
      { id: 'study-abroad-consultants', label: 'Consultants', href: '/admin/study-abroad/consultants', icon: 'users' },
    ]
  },
  { id: 'notifications-setup', label: 'Push Notifications', href: '/admin/notifications-setup', icon: 'shield' },
  {
    groupId: 'access-group',
    label: 'Access & Hardship',
    icon: 'shield',
    children: [
      { id: 'visvambhara-access',   label: 'Viśvambhara Access',     href: '/admin/visvambhara-access',   icon: 'shield' },
      { id: 'fee-waivers',          label: 'Fee Waivers',            href: '/admin/fee-waivers',          icon: 'shield' },
      { id: 'fee-waiver-coupons',   label: 'Waiver Coupons',         href: '/admin/fee-waiver-coupons',   icon: 'document' },
      { id: 'intl-payments',        label: 'International Payments', href: '/admin/intl-payments',        icon: 'package' },
    ]
  },
  {
    groupId: 'hr-group',
    label: 'HR Management',
    icon: 'users',
    children: [
      { id: 'hr',             label: 'Overview',        href: '/admin/hr',                       icon: 'home' },
      { id: 'hr-employees',   label: 'Employees',       href: '/admin/hr/employees',             icon: 'users' },
      { id: 'hr-requisitions',label: 'Requisitions',    href: '/admin/hr/requisitions',          icon: 'document' },
      { id: 'hr-bgv',         label: 'BGV (verification)', href: '/admin/hr/bgv',                icon: 'shield' },
      { id: 'hr-classification',label: 'Classification register', href: '/admin/hr/classification', icon: 'grid' },
      { id: 'hr-separations', label: 'Separations',     href: '/admin/hr/separations',           icon: 'inbox' },
      { id: 'hr-leave',       label: 'Leave',           href: '/admin/hr/leave',                 icon: 'calendar' },
      { id: 'hr-attendance',  label: 'Attendance',      href: '/admin/hr/attendance',            icon: 'calendar' },
      { id: 'hr-payroll',     label: 'Payroll',         href: '/admin/hr/payroll',               icon: 'document' },
      { id: 'hr-training',    label: 'Training',        href: '/admin/hr/training',              icon: 'book' },
      { id: 'hr-support',     label: 'Application Support', href: '/admin/hr-support',           icon: 'message-circle' },
      { id: 'submissions',    label: 'Submissions inbox', href: '/admin/submissions',            icon: 'inbox' },
      { id: 'appeals',        label: 'Appeals',         href: '/admin/appeals',                  icon: 'shield' },
      { id: 'certificates',   label: 'Certificates',    href: '/admin/certificates',             icon: 'document' },
      { id: 'campus-ambassadors', label: 'Campus Ambassadors', href: '/admin/campus-ambassadors', icon: 'users' },
    ]
  },
  { id: 'finance', label: 'Finance', href: '/admin/finance', icon: 'package' },
  { id: 'partnerships', label: 'Partnerships', href: '/admin/partnerships', icon: 'package' },
  { id: 'profiles', label: 'Profiles', href: '/admin/profiles', icon: 'package' },
  { id: 'resumes', label: 'Resumes', href: '/admin/resumes', icon: 'package' },
  { id: 'appsettings', label: 'App Settings', href: '/admin/app-settings', icon: 'package' },
  { id: 'flags', label: 'Feature Flags', href: '/admin/feature-flags', icon: 'package' },
  { id: 'credits', label: 'Account Credit', href: '/admin/credits', icon: 'package' },
  {
    groupId: 'interviews-group',
    label: 'Interviews',
    icon: 'calendar',
    children: [
      { id: 'interviews', label: 'Scheduled', href: '/admin/interviews', icon: 'calendar' },
      { id: 'manual-interviews', label: 'Manual (panel)', href: '/admin/interviews/manual', icon: 'users' },
      { id: 'ai-interviews', label: 'AI Sessions', href: '/admin/interviews/ai', icon: 'message-circle' },
      { id: 'ai-interview-templates', label: 'AI Templates', href: '/admin/ai-interview-templates', icon: 'book' },
    ]
  },
  {
    groupId: 'proctoring',
    label: 'Tests & Proctoring',
    icon: 'check-circle',
    children: [
      { id: 'tests', label: 'Tests', href: '/admin/tests', icon: 'check-circle' },
      { id: 'test-attempts', label: 'Attempts (log)', href: '/admin/tests/attempts', icon: 'inbox' },
      { id: 'identity-verifications', label: 'Identity Verifications', href: '/admin/identity-verifications', icon: 'shield' },
    ]
  },
  {
    groupId: 'aquintutor',
    label: 'AquinTutor LMS',
    icon: 'book',
    children: [
      { id: 'aquintutor-overview', label: 'Overview', href: '/admin/aquintutor', icon: 'grid' },
      { id: 'schools', label: 'Schools & Departments', href: '/admin/schools', icon: 'book' },
      { id: 'courses', label: 'Courses', href: '/admin/courses', icon: 'book' },
      { id: 'paths', label: 'Learning Paths', href: '/admin/paths', icon: 'grid' },
      { id: 'instructors', label: 'Faculty', href: '/admin/instructors', icon: 'users' },
      { id: 'aquintutor-command', label: 'Command Center', href: '/aquintutor/admin', icon: 'shield' },
    ]
  },
  { id: 'custom-offer', label: 'Custom Offer', href: '/admin/offer/blank', icon: 'file-text' },
  { id: 'hei-dashboard', label: 'HEI Control Plane', href: '/admin/hei', icon: 'book' },
  { id: 'roles', label: 'Roles', href: '/admin/roles', icon: 'briefcase' },
  { id: 'team-roles', label: 'Custom Roles', href: '/admin/team/roles', icon: 'shield' },
  { id: 'departments', label: 'Departments', href: '/admin/departments', icon: 'grid' },
  { id: 'events', label: 'Events', href: '/admin/events', icon: 'calendar' },
  { id: 'forms', label: 'Forms', href: '/admin/forms', icon: 'document' },
  { id: 'products', label: 'Products', href: '/admin/products', icon: 'package' },
  {
    groupId: 'visvambhara-group',
    label: 'Viśvambhara',
    icon: 'package',
    children: [
      { id: 'visvambhara-public', label: 'Public page', href: '/products/visvambhara', icon: 'globe' },
      { id: 'visvambhara-access', label: 'Access control', href: '/admin/visvambhara-access', icon: 'shield' },
    ]
  },
  { id: 'content', label: 'Content Pages', href: '/admin/content', icon: 'document' },
  { id: 'knowledge', label: 'Knowledge', href: '/admin/knowledge', icon: 'grid' },
  { id: 'learning', label: 'Learning runtime', href: '/admin/learning', icon: 'chart' },
  { id: 'rbac', label: 'Access / RBAC', href: '/admin/rbac', icon: 'shield' },
  { id: 'users', label: 'Users', href: '/admin/users', icon: 'users' },
  { id: 'analytics', label: 'Analytics', href: '/admin/analytics', icon: 'chart' },
  { id: 'audit', label: 'Audit Log', href: '/admin/audit', icon: 'shield' },
  { id: 'notifications', label: 'Notifications', href: '/admin/notifications', icon: 'bell' },
  { id: 'settings', label: 'Settings', href: '/admin/settings', icon: 'cog' },
  { id: 'diagnostics', label: 'Diagnostics', href: '/admin/diagnostics', icon: 'shield' }
];

function isGroup(item: NavItem | NavGroup): item is NavGroup {
  return (item as NavGroup).groupId !== undefined;
}
function isGroupActive(group: NavGroup, activeId: string): boolean {
  return group.children.some(c => c.id === activeId);
}

// Permission-gated sidebar: hide links a user can't open. Maps each nav id to a
// section key in the role-permission registry (src/lib/admin-sections.ts).
const allowedKeys = await getViewableSectionKeys(user);
const NAV_SECTION: Record<string, string> = {
  applications: 'applications', help: 'messages', messages: 'dms', chat: 'discussion', offers: 'offers',
  hr: 'hr', 'hr-employees': 'employees', 'hr-leave': 'leave', 'hr-attendance': 'attendance', 'hr-payroll': 'payroll', 'hr-training': 'training',
  finance: 'finance',
  interviews: 'interviews', 'manual-interviews': 'interviews_manual', 'ai-interviews': 'interviews_ai', 'ai-interview-templates': 'interviews_ai',
  tests: 'tests', 'test-attempts': 'tests_proctoring', 'identity-verifications': 'tests_proctoring',
  'aquintutor-overview': 'lms', schools: 'lms', courses: 'lms', paths: 'lms', instructors: 'lms', knowledge: 'lms', learning: 'audit', rbac: 'team_roles',
  'custom-offer': 'custom_offer',
  hei: 'hei_institutions', 'hei-types': 'hei_entity_types', 'hei-import': 'hei_import', 'hei-sub': 'hei_submetrics', 'hei-v1': 'hei_v1', 'hei-stories': 'hei_stories', 'hei-claims': 'hei_claims', 'hei-submissions': 'hei_submissions', 'hei-findings': 'hei_findings',
  'hei-dashboard': 'hei_findings', 'hei-leads': 'hei_findings', 'hei-replies': 'hei_findings', 'hei-crawlers': 'hei_institutions', 'hei-surveys': 'hei_institutions', 'hei-rti': 'hei_institutions', 'hei-legal': 'hei_findings',
  roles: 'roles', 'team-roles': 'team_roles', departments: 'departments', events: 'events',
  forms: 'content', products: 'products', content: 'content',
  users: 'users', analytics: 'audit', audit: 'audit', settings: 'settings', diagnostics: 'settings',
};
const UNIVERSAL_NAV = new Set(['dashboard', 'mail', 'notifications']);
function canSee(id: string): boolean {
  if (allowedKeys === null) return true;        // super_admin or unrestricted user
  if (UNIVERSAL_NAV.has(id)) return true;       // everyone has these
  const key = NAV_SECTION[id];
  if (!key) return true;                         // unmapped utility item stays visible
  return allowedKeys.has(key);
}
const visibleNav: (NavItem | NavGroup)[] = navStructure
  .map((entry) => {
    if (isGroup(entry)) {
      const children = entry.children.filter((c) => canSee(c.id));
      return children.length ? { ...entry, children } : null;
    }
    return canSee(entry.id) ? entry : null;
  })
  .filter((x): x is NavItem | NavGroup => x !== null);

const userInitial = user.name && user.name.length > 0 ? user.name.substring(0, 1).toUpperCase() : 'U';
const userRoleLabel = user.role.split('_').join(' ');
const pageTitle = title ? title + ' - Admin - ' + SITE.name : 'Admin - ' + SITE.name;
---
<!doctype html>
<html lang="en" class="admin-html" data-auto-accent={autoAccent}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="robots" content="noindex,nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Manrope:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" />
    <script is:inline>
      (function(){try{var d=document.documentElement;var t=localStorage.getItem('era-theme')||'dark';d.setAttribute('data-theme',t);var stored=localStorage.getItem('era-accent');var auto=d.getAttribute('data-auto-accent')||'default';var eff=(!stored||stored==='auto')?auto:stored;if(eff&&eff!=='default')d.setAttribute('data-accent',eff);else d.removeAttribute('data-accent');}catch(e){}})();
    </script>
    <link rel="manifest" href="/admin-manifest.json" />
    <meta name="theme-color" content="#FF4F00" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="ERA Admin" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="stylesheet" href="/era-ux.css" />
    <link rel="stylesheet" href="/era-polish.css" />
    <script src="/era-ux.js" defer></script>
    <!-- Black-screen mitigation: paint a base background instantly so the
         page never shows pure white-on-black flash before CSS loads, and
         a fallback message if scripts fail to execute. -->
    <style>
      html.admin-html, html.admin-html body { background: #08080a; color: #d8d8de; min-height: 100vh; }
      html.admin-html[data-theme="light"], html.admin-html[data-theme="light"] body { background: #faf8f3; color: #1c1d22; }
      .admin-failsafe { position: fixed; inset: 0; display: none; align-items: center; justify-content: center; flex-direction: column; gap: 10px; padding: 24px; text-align: center; background: inherit; z-index: 99999; }
      noscript .admin-failsafe { display: flex; }
    </style>
  </head>
  <body class="admin-body era-has-fab">
    <!-- Mobile nav: details/summary (zero JS, works on all phones) -->
    <details class="admin-mobile-details">
      <summary class="admin-mobile-summary">
        <span style="font-size:15px;font-weight:600;color:#fff;">EduRank<em style="font-style:normal;color:#FF4F00;">AI</em> <span style="font-size:11px;font-weight:400;opacity:0.6;margin-left:4px;">Admin</span></span>
        <span class="admin-mobile-arrow" style="font-size:11px;color:#FF4F00;">&#9660; Menu</span>
        <a href="/admin/notifications" title="Notifications" onclick="event.stopPropagation();" style="position:relative;display:inline-flex;align-items:center;justify-content:center;width:30px;height:30px;border-radius:6px;color:#a0a0ab;text-decoration:none;margin-left:8px;flex-shrink:0;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          <span id="bellBadge" style="display:none;position:absolute;top:-4px;right:-4px;min-width:16px;height:16px;background:#FF4F00;border-radius:100px;font-size:9px;font-weight:700;color:#fff;display:none;align-items:center;justify-content:center;padding:0 3px;font-family:monospace;">0</span>
        </a>
      </summary>
      <nav class="admin-mobile-nav-dropdown">
        <a href="/admin">Dashboard</a>
        <a href="/admin/applications">Applications</a>
        <a href="/admin/offers">Offer Letters</a>
        <a href="/admin/mail">Mail</a>
        <a href="/admin/hr">HR Management</a>
        <a href="/admin/offer/blank">Custom Offer Builder</a>
        <a href="/admin/chat">Discussion</a>
        <a href="/admin/messages">DMs</a>
        <a href="/admin/hei/institutions">HEI Institutions</a>
        <a href="/admin/partnerships">Partnerships</a>
        <a href="/admin/profiles">Profiles</a>
        <a href="/admin/resumes">Resumes</a>
        <a href="/admin/app-settings">App Settings</a>
        <a href="/admin/feature-flags">Feature Flags</a>
        <a href="/admin/team/roles">Custom Roles</a>
        <a href="/admin/roles">Roles</a>
        <a href="/admin/departments">Departments</a>
        <a href="/admin/users">Users</a>
        <a href="/admin/events">Events</a>
        <a href="/admin/products">Products</a>
        <a href="/admin/content">Content Pages</a>
        <a href="/admin/knowledge">Knowledge</a>
        <a href="/admin/learning">Learning runtime</a>
        <a href="/admin/rbac">Access / RBAC</a>
        <a href="/admin/audit">Audit Log</a>
        <a href="/admin/settings">Settings</a>
        <a href="/admin/logout" style="color:#ff6b6b;border-top:1px solid #1f1f26;margin-top:4px;">Sign Out</a>
      </nav>
    </details>
    <div class="admin-shell">
      <aside class="admin-sidebar">
        <div class="admin-brand">
          <a href="/admin" class="admin-logo">
            <span class="admin-logo-mark">E</span>
            <div>
              <div class="admin-logo-name">EduRankAI</div>
              <div class="admin-logo-sub">Admin Panel</div>
            </div>
          </a>
        </div>

        <nav class="admin-nav">
          {visibleNav.map((entry) => {
            if (isGroup(entry)) {
              const opened = isGroupActive(entry, activeNav);
              return (
                <details open={opened} class={'admin-nav-group ' + (opened ? 'active-group' : '')} style="margin:2px 0;">
                  <summary class="admin-nav-item" style="display:flex;align-items:center;justify-content:space-between;gap:8px;cursor:pointer;list-style:none;">
                    <span style="display:flex;align-items:center;gap:10px;flex:1;min-width:0;">
                      <span class="admin-nav-icon" data-icon={entry.icon}></span>
                      <span style="font-weight:600;">{entry.label}</span>
                    </span>
                    <span style="font-size:9px;color:#6e6e78;">v</span>
                  </summary>
                  <div style="display:flex;flex-direction:column;gap:1px;padding:3px 0 5px 20px;border-left:1px solid #1f1f26;margin-left:14px;margin-top:2px;">
                    {entry.children.map((child) => {
                      const childActive = activeNav === child.id;
                      const cls = childActive ? 'admin-nav-item active' : 'admin-nav-item';
                      return (
                        <a href={child.href} class={cls} style="display:flex;align-items:center;gap:9px;padding-left:8px;font-size:12px;">
                          <span class="admin-nav-icon" data-icon={child.icon} style="opacity:0.7;"></span>
                          <span>{child.label}</span>
                        </a>
                      );
                    })}
                  </div>
                </details>
              );
            }
            const item = entry;
            const isActive = activeNav === item.id;
            const cls = isActive ? 'admin-nav-item active' : 'admin-nav-item';
            return (
              <a href={item.href} class={cls} style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
                <span style="display:flex;align-items:center;gap:10px;flex:1;min-width:0;">
                  <span class="admin-nav-icon" data-icon={item.icon}></span>
                  <span>{item.label}</span>
                </span>
                {(item.badge ?? 0) > 0 && (
                  <span style="background:#FF4F00;color:#fff;font-size:9.5px;font-weight:700;padding:1px 6px;border-radius:100px;min-width:18px;text-align:center;line-height:1.5;font-family:'Geist Mono',monospace;">{item.badge}</span>
                )}
              </a>
            );
          })}
        </nav>

        <div class="admin-theme-switch" id="adminThemeSwitch">
          <button type="button" data-theme-set="dark" title="Dark mode">Dark</button>
          <button type="button" data-theme-set="light" title="Light mode">Light</button>
          <span style="width:1px;height:16px;background:var(--o-stroke);margin:0 2px;"></span>
          <button type="button" data-accent-set="auto" title="Auto (follow your gender)" style="font-size:11px;">Auto</button>
          <button type="button" class="accent-dot" data-accent-set="default" title="Coral (default)" style="background:linear-gradient(135deg,#f2731c,#ff8a3d);"></button>
          <button type="button" class="accent-dot" data-accent-set="amber" title="Amber (male)" style="background:linear-gradient(135deg,#eab308,#facc15);"></button>
          <button type="button" class="accent-dot" data-accent-set="rose" title="Rose (female)" style="background:linear-gradient(135deg,#ec4899,#f472b6);"></button>
          <button type="button" class="accent-dot" data-accent-set="emerald" title="Emerald" style="background:linear-gradient(135deg,#10b981,#34d399);"></button>
          <button type="button" class="accent-dot" data-accent-set="teal" title="Teal" style="background:linear-gradient(135deg,#14b8a6,#2dd4bf);"></button>
          <button type="button" class="accent-dot" data-accent-set="sky" title="Sky" style="background:linear-gradient(135deg,#3b82f6,#60a5fa);"></button>
          <button type="button" class="accent-dot" data-accent-set="violet" title="Violet" style="background:linear-gradient(135deg,#8b5cf6,#a78bfa);"></button>
        </div>

        <div class="admin-user">
          <a href="/admin/profile" class="admin-user-link" style="display:flex;align-items:center;gap:10px;flex:1;min-width:0;text-decoration:none;color:inherit;" title="Your profile">
            <div class="admin-user-avatar">{userInitial}</div>
            <div class="admin-user-info">
              <div class="admin-user-name">{user.name}</div>
              <div class="admin-user-role">{userRoleLabel}</div>
            </div>
          </a>
          <form method="POST" action="/admin/logout" style="margin:0">
            <button type="submit" class="admin-user-logout" title="Sign out">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            </button>
          </form>
        </div>
      </aside>

      <main class="admin-main">
        <div class="era-global-search" style="position:sticky;top:0;z-index:9;display:flex;gap:8px;align-items:center;padding:8px 16px;background:var(--o-bg0,#08080a);border-bottom:1px solid var(--o-stroke,#1a1a1f);">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:#6e6e78;flex-shrink:0;"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input id="eraSearch" type="search" placeholder="Search applicants, employees, roles, tests, bootcamps, courses, events, payments…" autocomplete="off" style="flex:1;background:transparent;border:none;outline:none;color:var(--o-hi,#fff);font-size:13px;padding:6px 0;" />
          <kbd style="font-family:'Geist Mono',monospace;font-size:10px;color:#6e6e78;border:1px solid var(--o-stroke,#1a1a1f);padding:2px 6px;border-radius:5px;">/</kbd>
          <button type="button" id="eraBellBtn" title="Notifications" style="position:relative;display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:8px;background:var(--o-panel,rgba(255,255,255,0.04));border:1px solid var(--o-stroke,#1a1a1f);color:#d8d8de;cursor:pointer;flex-shrink:0;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
            <span id="eraBellCount" style="display:none;position:absolute;top:-5px;right:-5px;min-width:18px;height:18px;background:#FF4F00;border-radius:100px;font-size:10px;font-weight:800;color:#fff;align-items:center;justify-content:center;padding:0 4px;font-family:'Geist Mono',monospace;">0</span>
