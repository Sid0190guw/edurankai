  <script is:inline>
  (function() {
    // Fetch unread notification count and update bell badge
    function updateBellBadge() {
      fetch('/admin/api/notifications/unread-count', { credentials: 'same-origin' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var count = data.count || 0;
          var b1 = document.getElementById('bellBadge');
          if (b1) {
            if (count > 0) {
              b1.textContent = count > 99 ? '99+' : String(count);
              b1.style.display = 'inline-flex';
            } else {
              b1.style.display = 'none';
            }
          }
        }).catch(function() {});
    }
    updateBellBadge();
    // Pause when the tab is hidden so an idle admin tab doesn't keep the DB awake.
    setInterval(function () { if (!document.hidden) updateBellBadge(); }, 300000);

    // SW fix-up: the legacy "mmakf-v1" SW (and any pre-v3 worker) had no push
    // handler, so Chrome shows a generic "site updated in the background"
    // message instead of our title/body. Force-replace it on every admin load.
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.getRegistrations().then(function (regs) {
        var bad = regs.filter(function (r) {
          var u = (r.active && r.active.scriptURL) || (r.waiting && r.waiting.scriptURL) || (r.installing && r.installing.scriptURL) || '';
          // Anything that's not our /sw.js, OR our /sw.js but stuck on the old cache
          return !u.endsWith('/sw.js');
        });
        var p = bad.length
          ? Promise.all(bad.map(function (r) { return r.unregister(); }))
          : Promise.resolve();
        return p.then(function () { return navigator.serviceWorker.register('/sw.js'); });
      }).then(function (reg) {
        try { reg.update(); } catch (_) {}
      }).catch(function () {});
    }
  })();
  </script>
