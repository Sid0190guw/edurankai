---
import '@/styles/global.css';
import '@/styles/design-system.css';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import { SITE } from '@/lib/site';

interface Props {
  title?: string;
  description?: string;
  showNav?: boolean;
  showFooter?: boolean;
  ogImage?: string;
  noindex?: boolean;
}

const { title, description = SITE.description, showNav = true, showFooter = true, ogImage, noindex = false } = Astro.props;
const pageTitle = title ? `${title} - ${SITE.name}` : `${SITE.name} - ${SITE.tagline}`;
const canonicalUrl = new URL(Astro.url.pathname, SITE.url).toString();
const ogImageUrl = ogImage || (SITE.url + '/og-default.png');
const gaId = import.meta.env.PUBLIC_GA_ID;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  additionalType: ['https://schema.org/ResearchOrganization', 'https://schema.org/EducationalOrganization'],
  name: SITE.name,
  alternateName: ['EduRank AI', 'EduRankAI Research Lab', 'EduRank.AI'],
  url: SITE.url,
  logo: SITE.url + '/favicon.svg',
  image: SITE.url + '/favicon.svg',
  description: SITE.description,
  slogan: 'Foundational AI models and reasoning systems built in Bharat.',
  email: SITE.emails.hr,
  foundingLocation: { '@type': 'Place', name: 'Bharat (India)' },
  areaServed: { '@type': 'Place', name: 'Worldwide' },
  // Surface our domains of expertise so the knowledge panel can attribute
  // EduRankAI as a hiring entity for senior AI / research roles.
  knowsAbout: [
    'Foundation Models', 'Reasoning Systems', 'AI Research', 'Machine Learning',
    'Education Technology', 'Higher Education Methodology', 'AI Tutoring',
    'University Ranking Methodology', 'AI Evaluation', 'Reinforcement Learning',
    'Frontier AI', 'Research Engineering',
  ],
  numberOfEmployees: { '@type': 'QuantitativeValue', minValue: 10, maxValue: 50 },
  sameAs: [SITE.socials.linkedin],
  contactPoint: [{
    '@type': 'ContactPoint',
    contactType: 'human resources',
    email: SITE.emails.hr,
    availableLanguage: ['English', 'Hindi'],
    areaServed: 'Worldwide',
  }],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  publisher: { '@type': 'Organization', name: SITE.name, url: SITE.url }
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <meta name="theme-color" content="#FF4F00" />
    <meta name="format-detection" content="telephone=no" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="en_IN" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="EduRankAI" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId, { anonymize_ip: true });
        </script>
      </>
    )}

  <script src="/analytics.js" defer></script>
  <script src="/safety.js" defer></script>
  <script src="/era-pwa.js" defer></script>
  <link rel="stylesheet" href="/era/era-ui.css" />
  <link rel="stylesheet" href="/era/era-mobile.css" />
  <link rel="stylesheet" href="/era-ux.css" />
  <script src="/era-ux.js" defer></script>
  <script src="/era/era-motion.js" defer></script>
  <script src="/era/era-fab.js" defer></script>
  <script>
    // Don't load the help-chat widget on the apply flow / signup / login —
    // these are focused, fast-fill surfaces; the help bubble polls on a timer
    // and can interfere with form state on Safari.
    (function () {
      try {
        var p = location.pathname || '';
        if (p.indexOf('/portal/login') === 0 || p.indexOf('/identity-setup') === 0) return;
      } catch (_) {}
      var s = document.createElement('script'); s.src = '/era-help-chat.js'; s.defer = true;
      document.head.appendChild(s);
    })();
  </script>
  <script src="/sos.js" defer></script>
  </head>
  <body class="min-h-screen flex flex-col grain era-has-fab">
    <a href="#main" class="skip-link">Skip to main content</a>
    {showNav && <Nav />}
    <main id="main" tabindex="-1" class="flex-1 relative z-[2]">
      <slot />
    </main>
    {showFooter && <Footer />}
    <style is:global>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: #FF4F00;
        color: #fff;
        padding: 10px 16px;
        z-index: 9999;
        font-weight: 700;
        text-decoration: none;
        border-radius: 0 0 8px 0;
      }
      .skip-link:focus {
        left: 0;
        outline: 3px solid #fff;
        outline-offset: -3px;
      }
      :focus-visible {
        outline: 2px solid #FF4F00;
        outline-offset: 2px;
        border-radius: 4px;
      }
      main:focus { outline: none; }
    </style>

    <!-- Browser push subscription. Silently re-syncs on every visit if already
         granted; never auto-prompts on the apply / signup flow. -->
    <script src="/push-subscribe.js" defer></script>
    <script is:inline>
      window.addEventListener('load', function () {
        if (!window.EduPush) return;
        var p = location.pathname || '';
        var skipPrompt = p.indexOf('/apply') === 0 || p.indexOf('/portal/signup') === 0 || p.indexOf('/portal/login') === 0;
        window.EduPush.attach({ autoPrompt: !skipPrompt });
      });
    </script>

    <!-- ===== Service-worker reset + notification toast + poller ===== -->
    <script is:inline>
      (function () {
        if (!('serviceWorker' in navigator)) return;
        // Force-unregister any stale service worker (the old /era/sw.js or any
        // worker that isn't our current /sw.js) so Chrome stops showing the
        // generic "site updated in background" notification.
        try {
          navigator.serviceWorker.getRegistrations().then(function (regs) {
            var keepers = [];
            regs.forEach(function (r) {
              try {
                var scriptURL = (r.active && r.active.scriptURL) || (r.installing && r.installing.scriptURL) || (r.waiting && r.waiting.scriptURL) || '';
                if (scriptURL && !scriptURL.endsWith('/sw.js')) {
                  r.unregister();
                } else {
                  keepers.push(r);
                }
              } catch (_) {}
            });
            // Re-register the current SW if none is keeping it alive.
            if (keepers.length === 0) {
              navigator.serviceWorker.register('/sw.js', { scope: '/' }).catch(function () {});
            }
          });
        } catch (_) {}
      })();
    </script>

    <!-- Poll for in-app notifications (signed-in users only). Slides a toast
         into the bottom-right when a new unread one arrives. Same look as the
         admin layout's toast. Endpoint short-circuits to 401 for guests so
         this is cheap. -->
    <script is:inline>
      (function () {
        // Don't run the notification poller on the apply flow, signup, login,
        // or any page where the user might be in the middle of filling a
        // form. The poller never reloads the page directly, but on Safari /
        // iOS the periodic fetch + cookie refresh has been blamed for forcing
        // re-auth mid-flow. Skip it on those paths entirely.
        try {
          var p = window.location.pathname || '';
          if (p.indexOf('/apply') === 0
              || p.indexOf('/portal/signup') === 0
              || p.indexOf('/portal/login') === 0
              || p.indexOf('/identity-setup') === 0
              || p.indexOf('/enroll-face') === 0) {
            return;
          }
        } catch (_) {}
        var seen = null;
        var timer = null;
        var stopped = false;
        function ensureStack() {
          var c = document.getElementById('eraPortalToastStack');
          if (c) return c;
          c = document.createElement('div');
          c.id = 'eraPortalToastStack';
          c.style.cssText = 'position:fixed;bottom:20px;right:20px;display:flex;flex-direction:column;gap:10px;z-index:1000;pointer-events:none;max-width:min(380px,calc(100vw - 32px));';
          document.body.appendChild(c);
          return c;
        }
        function toast(n) {
          var c = ensureStack();
          var t = document.createElement('a');
          t.href = n.action_url || '/portal/notifications';
          t.style.cssText = 'pointer-events:auto;background:#fff;border:1px solid #e6e3da;border-left:4px solid #FF4F00;border-radius:12px;padding:13px 16px;color:#1c1d22;text-decoration:none;box-shadow:0 14px 40px rgba(0,0,0,0.18);transform:translateX(120%);opacity:0;transition:transform .35s cubic-bezier(.16,1,.3,1),opacity .35s;font-family:Inter Tight,system-ui,sans-serif;';
          t.innerHTML = '<p style="font-size:13px;font-weight:700;margin:0;line-height:1.3;">' + (n.title || '') + '</p>' + (n.body ? '<p style="font-size:11.5px;color:#5b5b5b;margin:4px 0 0;line-height:1.5;">' + n.body + '</p>' : '');
          c.appendChild(t);
          requestAnimationFrame(function () { t.style.transform = 'translateX(0)'; t.style.opacity = '1'; });
          setTimeout(function () { t.style.transform = 'translateX(120%)'; t.style.opacity = '0'; setTimeout(function () { try { t.remove(); } catch (_) {} }, 400); }, 7000);
        }
        function stop() { stopped = true; if (timer) { clearInterval(timer); timer = null; } }
        function load() {
          if (stopped || document.hidden) return;
          fetch('/api/portal/notifications-recent', { credentials: 'same-origin' }).then(function (r) {
            if (r.status === 401 || r.status === 403) { stop(); return null; }
            if (!r.ok) return null;
            return r.json();
          }).then(function (d) {
            if (!d || !d.ok || !Array.isArray(d.items)) return;
            if (seen === null) { seen = new Set(d.items.map(function (n) { return n.id; })); return; }
            d.items.forEach(function (n) {
              if (!n.is_read && !seen.has(n.id)) { toast(n); seen.add(n.id); }
            });
          }).catch(function () {});
        }
        load();
        timer = setInterval(load, 20000);
        document.addEventListener('visibilitychange', function () { if (!document.hidden) load(); });
      })();
    </script>
  </body>
</html>
