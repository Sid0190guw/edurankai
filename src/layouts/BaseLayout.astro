---
import '@/styles/global.css';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import { SITE } from '@/lib/site';

interface Props {
  title?: string;
  description?: string;
  showNav?: boolean;
  showFooter?: boolean;
  ogImage?: string;
  noindex?: boolean;
}

const { title, description = SITE.description, showNav = true, showFooter = true, ogImage, noindex = false } = Astro.props;
const pageTitle = title ? `${title} - ${SITE.name}` : `${SITE.name} - ${SITE.tagline}`;
const canonicalUrl = new URL(Astro.url.pathname, SITE.url).toString();
const ogImageUrl = ogImage || (SITE.url + '/og-default.png');
const gaId = import.meta.env.PUBLIC_GA_ID;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  additionalType: ['https://schema.org/ResearchOrganization', 'https://schema.org/EducationalOrganization'],
  name: SITE.name,
  alternateName: ['EduRank AI', 'EduRankAI Research Lab', 'EduRank.AI'],
  url: SITE.url,
  logo: SITE.url + '/favicon.svg',
  image: SITE.url + '/favicon.svg',
  description: SITE.description,
  slogan: 'Foundational AI models and reasoning systems built in Bharat.',
  email: SITE.emails.hr,
  foundingLocation: { '@type': 'Place', name: 'Bharat (India)' },
  areaServed: { '@type': 'Place', name: 'Worldwide' },
  // Surface our domains of expertise so the knowledge panel can attribute
  // EduRankAI as a hiring entity for senior AI / research roles.
  knowsAbout: [
    'Foundation Models', 'Reasoning Systems', 'AI Research', 'Machine Learning',
    'Education Technology', 'Higher Education Methodology', 'AI Tutoring',
    'University Ranking Methodology', 'AI Evaluation', 'Reinforcement Learning',
    'Frontier AI', 'Research Engineering',
  ],
  numberOfEmployees: { '@type': 'QuantitativeValue', minValue: 10, maxValue: 50 },
  sameAs: [SITE.socials.linkedin],
  contactPoint: [{
    '@type': 'ContactPoint',
    contactType: 'human resources',
    email: SITE.emails.hr,
    availableLanguage: ['English', 'Hindi'],
    areaServed: 'Worldwide',
  }],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  publisher: { '@type': 'Organization', name: SITE.name, url: SITE.url }
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <meta name="theme-color" content="#FF4F00" />
    <meta name="format-detection" content="telephone=no" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="en_IN" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="EduRankAI" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId, { anonymize_ip: true });
        </script>
      </>
    )}

  <script src="/analytics.js" defer></script>
  <script src="/safety.js" defer></script>
  <script src="/era-pwa.js" defer></script>
  <link rel="stylesheet" href="/era/era-ui.css" />
  <link rel="stylesheet" href="/era/era-mobile.css" />
  <script src="/era/era-motion.js" defer></script>
  <script src="/era/era-fab.js" defer></script>
  <script src="/era-help-chat.js" defer></script>
  <script src="/sos.js" defer></script>
  </head>
  <body class="min-h-screen flex flex-col grain era-has-fab">
    <a href="#main" class="skip-link">Skip to main content</a>
    {showNav && <Nav />}
    <main id="main" tabindex="-1" class="flex-1 relative z-[2]">
      <slot />
    </main>
    {showFooter && <Footer />}
    <style is:global>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: #FF4F00;
        color: #fff;
        padding: 10px 16px;
        z-index: 9999;
        font-weight: 700;
        text-decoration: none;
        border-radius: 0 0 8px 0;
      }
      .skip-link:focus {
        left: 0;
        outline: 3px solid #fff;
        outline-offset: -3px;
      }
      :focus-visible {
        outline: 2px solid #FF4F00;
        outline-offset: 2px;
        border-radius: 4px;
      }
      main:focus { outline: none; }
    </style>
  </body>
</html>
