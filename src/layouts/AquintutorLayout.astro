---
import '@/styles/aquintutor-academy.css';
import { SITE } from '@/lib/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const { title, description = 'AquinTutor by EduRankAI - the technology platform behind partner universities, with open courses, gamified assessments, and certificates of completion.', ogImage, noindex = false } = Astro.props;
const pageTitle = title ? title + ' - AquinTutor' : 'AquinTutor - the technology platform behind partner universities, by EduRankAI';
// Strip trailing slashes so path variants share ONE canonical (dedupe). Root stays "/".
const canonicalPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const canonicalUrl = new URL(canonicalPath, SITE.url).toString();
const ogImageUrl = ogImage || (SITE.url + '/og-default.png');
const signedIn = !!Astro.locals.user;
const firstName = signedIn ? (Astro.locals.user?.name || '').split(' ')[0] : '';
---
<!doctype html>
<html lang="en" class="academy editorial">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <meta name="theme-color" content="#FBFAF4" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="AquinTutor" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="stylesheet" href="/era-ux.css" />
    <script src="/era-ux.js" defer></script>
    <slot name="head" />
  </head>
  <body class="academy editorial era-has-fab">
    <header style="border-bottom:1px solid var(--rule); background:rgba(251,250,244,0.95); backdrop-filter:blur(6px); position:sticky; top:0; z-index:50;">
      <div style="max-width:1400px; margin:0 auto; padding:18px 28px; display:flex; align-items:center; justify-content:space-between; gap:24px; flex-wrap:wrap;">
        <a href="/aquintutor" style="display:flex; align-items:center; gap:12px; text-decoration:none; color:var(--ink);">
          <span style="display:inline-flex; align-items:center; justify-content:center; width:36px; height:36px; border-radius:8px; background:var(--ink); color:var(--sand-50); font-family:'Fraunces',serif; font-weight:500; font-size:18px;">A</span>
          <span style="display:flex; flex-direction:column; line-height:1.05;">
            <span class="font-display" style="font-size:21px; font-weight:500; letter-spacing:-0.01em;">AquinTutor</span>
            <span style="font-family:'Inter Tight',sans-serif; font-size:10.5px; color:var(--ink-500); letter-spacing:0.04em;">A learning platform by EduRank&middot;AI</span>
          </span>
        </a>
        <nav class="hide-mobile" style="display:flex; align-items:center; gap:28px; font-family:'Inter Tight',sans-serif; font-size:14px; font-weight:500;">
          <a href="/aquintutor/schools" style="color:var(--ink); text-decoration:none;">Schools</a>
          <a href="/aquintutor/courses" style="color:var(--ink); text-decoration:none;">Courses</a>
          <a href="/aquintutor/labs" style="color:var(--ink); text-decoration:none;">Labs</a>
          <a href="/aquintutor/paths" style="color:var(--ink); text-decoration:none;">Programmes</a>
          <a href="/portal/discussion" style="color:var(--ink); text-decoration:none;">Community</a>
          <a href="/aquintutor/instructors" style="color:var(--ink); text-decoration:none;">Faculty</a>
          <a href="/aquintutor/universe" style="color:var(--ink); text-decoration:none;">Research</a>
          <a href="/aquintutor/partnerships" style="color:var(--rust); text-decoration:none; font-weight:600;">Partner</a>
        </nav>
        <div style="display:flex; align-items:center; gap:8px;">
          {signedIn ? (
            <>
              <a href="/aquintutor/dashboard" style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink); text-decoration:none; padding:8px 12px; font-weight:500;">Dashboard</a>
              <a href="/aquintutor/progress" style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink); text-decoration:none; padding:8px 12px; font-weight:500;">Progress</a>
              <a href="/aquintutor/profile" style="background:var(--ink); color:var(--sand-50); padding:9px 16px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; text-decoration:none;">{firstName ? firstName : 'My account'}</a>
            </>
          ) : (
            <>
              <a href="/aquintutor/login" style="font-family:'Inter Tight',sans-serif; font-size:14px; color:var(--ink); text-decoration:none; padding:8px 12px; font-weight:500;">Sign in</a>
              <a href="/aquintutor/signup" style="background:var(--ink); color:var(--sand-50); padding:9px 18px; border-radius:6px; font-family:'Inter Tight',sans-serif; font-size:13px; font-weight:600; text-decoration:none;">Apply</a>
            </>
          )}
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer style="border-top:1px solid var(--rule); background:var(--ink); color:var(--sand-50);">
      <div style="max-width:1400px; margin:0 auto; padding:64px 28px 32px; display:grid; grid-template-columns:1fr; gap:48px;" class="footer-grid">
        <div>
          <div style="display:flex; align-items:center; gap:12px; margin-bottom:16px;">
            <span style="display:inline-flex; align-items:center; justify-content:center; width:36px; height:36px; border-radius:8px; background:var(--sand-50); color:var(--ink); font-family:'Fraunces',serif; font-weight:500; font-size:18px;">A</span>
            <span class="font-display" style="font-size:22px; color:var(--sand-50); font-weight:500;">AquinTutor</span>
          </div>
          <p class="font-serif" style="font-size:15px; font-style:italic; color:rgba(251,250,244,0.7); line-height:1.55; max-width:24rem; margin:0;">The technology platform behind partner universities, by EduRank&middot;AI. Vedic sciences, advanced computing, artificial super-intelligence, and quantum technology &mdash; with partner faculty and verifiable credentials.</p>
        </div>
        <div style="display:grid; grid-template-columns:repeat(4, 1fr); gap:24px; font-family:'Inter Tight',sans-serif;" class="footer-links">
          <div>
            <p style="font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:rgba(251,250,244,0.5); margin:0 0 12px; font-weight:600;">Academic</p>
            <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:8px; font-size:14px;">
              <li><a href="/aquintutor/schools" style="color:rgba(251,250,244,0.85); text-decoration:none;">Schools</a></li>
              <li><a href="/aquintutor/courses" style="color:rgba(251,250,244,0.85); text-decoration:none;">Courses</a></li>
              <li><a href="/aquintutor/paths" style="color:rgba(251,250,244,0.85); text-decoration:none;">Programmes</a></li>
              <li><a href="/aquintutor/instructors" style="color:rgba(251,250,244,0.85); text-decoration:none;">Faculty</a></li>
            </ul>
          </div>
          <div>
            <p style="font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:rgba(251,250,244,0.5); margin:0 0 12px; font-weight:600;">Admissions</p>
            <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:8px; font-size:14px;">
              <li><a href="/aquintutor/signup" style="color:rgba(251,250,244,0.85); text-decoration:none;">Apply</a></li>
              <li><a href="/aquintutor/login" style="color:rgba(251,250,244,0.85); text-decoration:none;">Sign in</a></li>
              <li><a href="/identity-setup" style="color:rgba(251,250,244,0.85); text-decoration:none;">Identity setup</a></li>
              <li><a href="/forgot-password" style="color:rgba(251,250,244,0.85); text-decoration:none;">Recover account</a></li>
            </ul>
          </div>
          <div>
            <p style="font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:rgba(251,250,244,0.5); margin:0 0 12px; font-weight:600;">Research</p>
            <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:8px; font-size:14px;">
              <li><a href="/aquintutor/universe" style="color:rgba(251,250,244,0.85); text-decoration:none;">Discipline index</a></li>
              <li><a href="/aquintutor/campus" style="color:rgba(251,250,244,0.85); text-decoration:none;">Virtual campus</a></li>
              <li><a href="/aquintutor/facility" style="color:rgba(251,250,244,0.85); text-decoration:none;">Campus facilities</a></li>
              <li><a href="/aquintutor/systems" style="color:rgba(251,250,244,0.85); text-decoration:none;">Institutional systems</a></li>
              <li><a href="/aquintutor/stages" style="color:rgba(251,250,244,0.85); text-decoration:none;">Stages &middot; Pre-KG to PhD</a></li>
              <li><a href="/aquintutor/roadmap" style="color:rgba(251,250,244,0.85); text-decoration:none;">Roadmap</a></li>
              <li><a href="/aquintutor/about" style="color:rgba(251,250,244,0.85); text-decoration:none;">About the platform</a></li>
              <li><a href="/" style="color:rgba(251,250,244,0.85); text-decoration:none;">EduRank&middot;AI</a></li>
            </ul>
          </div>
          <div>
            <p style="font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:rgba(251,250,244,0.5); margin:0 0 12px; font-weight:600;">Policy</p>
            <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:8px; font-size:14px;">
              <li><a href="/p/privacy" style="color:rgba(251,250,244,0.85); text-decoration:none;">Privacy</a></li>
              <li><a href="/p/terms" style="color:rgba(251,250,244,0.85); text-decoration:none;">Terms</a></li>
              <li><a href="/contact" style="color:rgba(251,250,244,0.85); text-decoration:none;">Contact</a></li>
            </ul>
          </div>
        </div>
        <div style="border-top:1px solid rgba(251,250,244,0.1); padding-top:24px; display:flex; flex-wrap:wrap; gap:14px; justify-content:space-between; font-family:'Inter Tight',sans-serif; font-size:12.5px; color:rgba(251,250,244,0.5);">
          <p style="margin:0;">&copy; {new Date().getFullYear()} AquinTutor &middot; A learning platform by <a href="/" style="color:rgba(251,250,244,0.7); text-decoration:underline;">EduRank&middot;AI</a></p>
          <p style="margin:0;">Bharat-based &middot; English &middot; Open to applicants worldwide</p>
        </div>
      </div>
    </footer>

    <style>
      @media (min-width: 768px) { .hide-mobile { display: flex !important; } }
      @media (max-width: 767px) { .hide-mobile { display: none !important; } .footer-links { grid-template-columns: repeat(2, 1fr) !important; } }
    </style>

    <!-- Aquin's own in-house assistant (replaces the EduRankAI help chat) + FAB + SOS. -->
    <script src="/era/era-fab.js?v=5" defer></script>
    <script src="/aquin-chat.js?v=1" defer></script>
    <script src="/sos.js?v=5" defer></script>
  </body>
</html>
