---
// /face-2fa/login - second factor after password (or first factor for
// passwordless face login). Captures a frame, sends descriptor to
// /api/face/verify; on { ok: true } the page calls /api/auth/create-session
// which you implement to mint the cookie. We never trust the client's match
// claim - distance check is server-side.
//
// Expects ?email=<the email the user typed at the password step>.
const email = (Astro.url.searchParams.get('email') || '').toLowerCase();
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Sign in with your face</title>
  <style>
    :root { color-scheme: dark; }
    body { margin: 0; background: #0a0a0c; color: #e9edf2; font-family: system-ui, -apple-system, sans-serif; }
    .wrap { max-width: 460px; margin: 32px auto; padding: 0 16px; text-align: center; }
    h1 { font-size: 22px; margin: 0 0 6px; }
    p  { color: #8a93a3; font-size: 13.5px; margin: 0 0 14px; }
    video { width: 100%; max-width: 360px; border-radius: 14px; background: #11151c; aspect-ratio: 3/4; object-fit: cover; transform: scaleX(-1); }
    .status { font-size: 13px; color: #8a93a3; margin: 14px 0 0; min-height: 18px; }
    .ok { color: #6ee7b7; } .err { color: #fca5a5; }
    .btn { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); color: #e9edf2; border-radius: 10px; padding: 9px 18px; font-size: 13px; cursor: pointer; margin-top: 12px; }
    .pill { display: inline-block; background: #FF4F0033; color: #ff8a4c; border: 1px solid #FF4F0066; padding: 3px 10px; border-radius: 100px; font-size: 11px; margin-bottom: 10px; }
  </style>
</head>
<body>
  <div class="wrap">
    <span class="pill">Face verification</span>
    <h1>Look at the camera</h1>
    <p>{email || 'your account'}</p>

    <video id="v" autoplay muted playsinline></video>
    <p id="status" class="status">Loading face model...</p>
    <button id="retry" class="btn" hidden>Try again</button>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/@vladmandic/face-api@1.7.13/dist/face-api.min.js"></script>
  <script is:inline define:vars={{ email }}>
    const MODEL_URL = 'https://cdn.jsdelivr.net/npm/@vladmandic/face-api@1.7.13/model';
    const $ = (id) => document.getElementById(id);
    const status = (m, cls) => { const s = $('status'); s.textContent = m; s.className = 'status' + (cls ? ' ' + cls : ''); };

    let stream;
    async function startCamera() {
      try { stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: 640 }, audio: false }); $('v').srcObject = stream; }
      catch (e) { status('Camera blocked: ' + (e.message || e), 'err'); }
    }
    async function loadModels() {
      await Promise.all([
        faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL),
        faceapi.nets.faceLandmark68TinyNet.loadFromUri(MODEL_URL),
        faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL),
      ]);
    }

    let tries = 0, MAX_TRIES = 25;
    async function tryOnce() {
      tries++;
      const opts = new faceapi.TinyFaceDetectorOptions({ inputSize: 320, scoreThreshold: 0.5 });
      const det = await faceapi.detectSingleFace($('v'), opts).withFaceLandmarks(true).withFaceDescriptor();
      if (!det) return false;
      const r = await fetch('/api/face/verify', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, descriptor: Array.from(det.descriptor) }),
      });
      const d = await r.json();
      if (d.ok) {
        status('Recognised. Signing you in...', 'ok');
        // Call your session-mint endpoint with the verified userId.
        const s = await fetch('/api/auth/create-session', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId: d.userId, factor: 'face' }),
        });
        if (s.ok) { location.href = '/'; return true; }
        status('Verified but session failed.', 'err');
        return true;
      }
      return false;
    }
    async function autoLoop() {
      while (tries < MAX_TRIES) {
        let ok = false;
        try { ok = await tryOnce(); } catch (e) {}
        if (ok) return;
        await new Promise(r => setTimeout(r, 700));
      }
      status('Could not recognise your face. Try again or use the password recovery link.', 'err');
      $('retry').hidden = false;
    }
    $('retry').addEventListener('click', () => { tries = 0; $('retry').hidden = true; status('Looking...'); autoLoop(); });

    (async () => {
      await Promise.all([startCamera(), loadModels()]);
      status('Looking for your face...');
      autoLoop();
    })();

    window.addEventListener('beforeunload', () => { if (stream) stream.getTracks().forEach(t => t.stop()); });
  </script>
</body>
</html>
