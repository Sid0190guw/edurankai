---
// /face-2fa/enroll - capture a selfie, compute its 128-d descriptor in the
// browser, POST it to /api/face/enroll. Assumes the user is already logged in
// (i.e. they reached this page via the post-login enrollment gate).
const user = (Astro.locals as any).user;
if (!user) return Astro.redirect('/login');           // adapt to your login route
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Set up Face Login</title>
  <style>
    :root { color-scheme: dark; }
    body { margin: 0; background: #0a0a0c; color: #e9edf2; font-family: system-ui, -apple-system, sans-serif; }
    .wrap { max-width: 460px; margin: 32px auto; padding: 0 16px; }
    h1 { font-size: 22px; margin: 0 0 6px; }
    p  { color: #8a93a3; font-size: 13.5px; line-height: 1.6; margin: 0 0 18px; }
    video, canvas { width: 100%; max-width: 360px; border-radius: 14px; background: #11151c; aspect-ratio: 3/4; object-fit: cover; transform: scaleX(-1); display: block; margin: 0 auto; }
    .btn { display: inline-flex; align-items: center; gap: 8px; background: linear-gradient(135deg,#FF4F00,#ff8a4c); color: #fff; border: none; border-radius: 10px; padding: 11px 22px; font-size: 14px; font-weight: 700; cursor: pointer; }
    .btn[disabled] { opacity: .5; cursor: not-allowed; }
    .progress { height: 4px; background: rgba(255,255,255,.08); border-radius: 100px; margin: 12px 0; overflow: hidden; }
    .progress > div { height: 100%; background: #FF4F00; width: 0; transition: width .2s; }
    .status { font-size: 13px; color: #8a93a3; margin: 12px 0 0; min-height: 18px; }
    .ok { color: #6ee7b7; } .err { color: #fca5a5; }
    .row { display: flex; gap: 10px; justify-content: center; margin-top: 16px; flex-wrap: wrap; }
  </style>
</head>
<body>
  <div class="wrap">
    <h1>Set up Face Login</h1>
    <p>Look straight at the camera in good light. We'll capture one frame and store its face signature so you can sign in with your face next time.</p>

    <video id="v" autoplay muted playsinline></video>
    <div class="progress"><div id="bar"></div></div>
    <p id="status" class="status">Loading face model...</p>

    <div class="row">
      <button id="capture" class="btn" disabled>Capture & enrol</button>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/@vladmandic/face-api@1.7.13/dist/face-api.min.js"></script>
  <script is:inline>
    const MODEL_URL = 'https://cdn.jsdelivr.net/npm/@vladmandic/face-api@1.7.13/model';
    const $ = (id) => document.getElementById(id);
    const status = (m, cls) => { const s = $('status'); s.textContent = m; s.className = 'status' + (cls ? ' ' + cls : ''); };
    const bar = (pct) => { $('bar').style.width = pct + '%'; };

    let stream;
    function explainCameraError(e) {
      const n = (e && e.name) || '';
      if (n === 'NotAllowedError' || n === 'PermissionDeniedError') return 'Camera is blocked. Click the camera icon in the address bar -> Allow -> reload. iOS Safari: Settings -> Safari -> Camera -> Allow.';
      if (n === 'NotFoundError') return 'No camera detected on this device.';
      if (n === 'NotReadableError') return 'Camera is in use by another app. Close Zoom / Meet / other tabs and try again.';
      if (n === 'SecurityError') return 'Camera blocked (page must be served over HTTPS).';
      return 'Camera error: ' + ((e && e.message) || n || 'unknown');
    }
    async function startCamera() {
      if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) { status('This browser does not support camera access.', 'err'); return; }
      try {
        if (navigator.permissions && navigator.permissions.query) {
          const p = await navigator.permissions.query({ name: 'camera' });
          if (p.state === 'denied') { status(explainCameraError({ name: 'NotAllowedError' }), 'err'); return; }
        }
      } catch (_) {}
      try {
        stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: 640 }, audio: false });
        $('v').srcObject = stream;
      } catch (e) {
        status(explainCameraError(e), 'err');
      }
    }

    async function loadModels() {
      bar(15);
      await Promise.all([
        faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL),
        faceapi.nets.faceLandmark68TinyNet.loadFromUri(MODEL_URL),
        faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL),
      ]);
      bar(100);
    }

    async function init() {
      await Promise.all([startCamera(), loadModels()]);
      status('Ready. Look at the camera and click Capture.');
      $('capture').disabled = false;
    }
    init();

    $('capture').addEventListener('click', async () => {
      $('capture').disabled = true;
      status('Detecting face...');
      const opts = new faceapi.TinyFaceDetectorOptions({ inputSize: 416, scoreThreshold: 0.5 });
      const det = await faceapi.detectSingleFace($('v'), opts).withFaceLandmarks(true).withFaceDescriptor();
      if (!det) { status('No face detected. Move into the light and try again.', 'err'); $('capture').disabled = false; return; }
      const descriptor = Array.from(det.descriptor);
      status('Saving...');
      try {
        const r = await fetch('/api/face/enroll', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ descriptor }) });
        const d = await r.json();
        if (d.ok) { status('Face enrolled. You can now sign in with face.', 'ok'); setTimeout(() => location.href = '/', 800); }
        else { status('Failed: ' + (d.error || 'unknown'), 'err'); $('capture').disabled = false; }
      } catch (e) { status('Network error', 'err'); $('capture').disabled = false; }
    });

    window.addEventListener('beforeunload', () => { if (stream) stream.getTracks().forEach(t => t.stop()); });
  </script>
</body>
</html>
